    <JadeMethod name="delete" id="615dc481-dc56-4a64-b4c4-ac542f5caa2d">
        <updating/>
        <source>delete() updating;
/*

Purpose:			Extra Deleteing Logic to clean up collections

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
26 August 2022	navpw1	Initial creation TFS: 54565 (54384)
01 March 2023	navmk20	Task 56140: EUP Inv Config - Surcharge Logging
23 Oct 2024		navlw1 	JIRA-33107: Invoice Logging Use Levels
*/

begin
	self.allInvoiceTypeDebtorSeparation.purge;
	app.invLog("Extra deleting logic to clean up collections", LogINFO.String); 		// 1.3.2023 navmk20 TFS 56140
end;</source>
    </JadeMethod>
    <JadeMethod name="getCargoTypeSurchargesForInv" id="c8081d1b-faa3-40e8-9a28-e4a7c1a7f4c3">
        <source>getCargoTypeSurchargesForInv( _invoice : CM_Invoice; _surchargeSet : CM_InvTypeCargoMultSchByFromDT input );
/*
Purpose:			Get all the cargo on the invoice. Use all the cargo types involved to get all the cargo type surcharges

Date			Who		Reason
03JUN2021		NAVAB1	TFS 51219
15 Sept 2022	navpw1 	TFS 54565 (54385) - EUP - Inv Config - Invoice Surcharges
01 March 2023	navmk20	Task 56140: EUP Inv Config - Surcharge Logging
23 Oct 2024		navlw1 	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
JIRA 35766 15AUG2025 NAVAB1 added 'SURG' to logging and changed logging levels and added more information.
*/

vars
	iterJob					: Iterator;
	dynaDict				: DynaDictionary;
	ti						: CM_TrackedItem;
	iterTi,
	iterSurchargeRate		: Iterator;							// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	uniqueCargoSet			: CM_TISet;
	
	//ctSurChgRate			: CM_InvTypeCargoSurcharge;
	ctSurChgMultiRate,
	surchargeRate			: CM_InvTypeCargoMultiSurcharge;	// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	cargoType				: CM_CargoType;
	cargoSubType			: CM_Product;
	commodity				: CM_Commodity;
	
	invLine					: CM_InvoiceLine;
	includesCargoType,
	includesCargoSubType,
	includesCommodity,
	includesDebtor,
	allDebtors				: Boolean;							// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("SURG -  ** Checking Cargo type surcharges  -  **", LogINFO.String);	// 1.3.2023 navmk20 TFS 56140
	endif;
	if _invoice = null or _surchargeSet = null then
		//  Start- 6.3.2023 navmk20 TFS 56140
		if canLogExtra then	//27.02.2025 navah1	#34141
			if _invoice &lt;&gt; null then
				app.invLog("SURG - Invoice found", LogTRACE.String);	
			else
				app.invLog("SURG - Invoice  not found ", LogTRACE.String);
			endif;
			if _surchargeSet &lt;&gt; null then
				app.invLog("SURG - SurchargeSet found", LogTRACE.String);
			else
				app.invLog("SURG - SurchargeSet not found ", LogTRACE.String);
			endif;
		endif;
		//End - 6.3.2023 navmk20 TFS 56140
		return;
	endif;
	
	
	_surchargeSet.clear();
	
	create uniqueCargoSet transient;
 
	create dynaDict;
	dynaDict.setMembership( CM_TrackedItem );
	dynaDict.addMemberKey(CM_TrackedItem::cargoType.name, false, false);
	dynaDict.addMemberKey(CM_TrackedItem::productCode.name, false, false);
	dynaDict.addMemberKey(CM_TrackedItem::commodity.name, false, false);
	dynaDict.endKeys( false );
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("SURG - Cargo surcharges  -  by type is  " &amp; self.getDescription(), LogINFO.String); //7.3.2023 navmk20 TFS 56140
	endif;
	foreach invLine in _invoice.invoiceLines do
		ti := invLine.trackedItem;
		if ti &lt;&gt; null then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("SURG - Tracked Item found", LogINFO.String); //6.3.2023 navmk20 TFS 56140
			endif;
				if dynaDict.getAtKey( ti.cargoType, ti.productCode, ti.commodity ) &lt;&gt; null then
					//we already have one like this one
					if canLogExtra then	//27.02.2025 navah1	#34141
						app.invLog("SURG - Avoided the duplicate for dyna dict", LogINFO.String);	//6.3.2023 navmk20 TFS 56140
					endif;
					continue;
				else
					//Start - 6.3.2023 navmk20 TFS 56140
					if canLogExtra then	//27.02.2025 navah1	#34141
						app.invLog("SURG - Added tracked Item", LogINFO.String);	
						if ti.id &lt;&gt; null then
							app.invLog("SURG - Tracked Item Id: "&amp; ti.id.String, LogINFO.String);
						else
							app.invLog("SURG - Tracked Item Id is not found", LogINFO.String);
						endif;
					endif;
					// End - 6.3.2023 navmk20 TFS 56140
					dynaDict.add( ti );
					uniqueCargoSet.add( ti );
				endif;
		else	
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("SURG - Tracked Item not found", LogINFO.String);	//6.3.2023 navmk20 TFS 56140
			endif;
		endif;
	endforeach;
	
	if uniqueCargoSet.isEmpty then
		return;
	endif;
	
	iterTi := uniqueCargoSet.createIterator;
	while iterTi.next( ti ) do
		cargoType		:= ti.myCargoType;
		cargoSubType	:= ti.myProduct;
		commodity		:= ti.getCommodityObject;
		
		// ### TFS 54565 (54385) 19Sep2022 NAVPW1
		iterSurchargeRate := self.allInvTypeCargoMultiSurcharges.createIterator;
		
		while iterSurchargeRate.next( surchargeRate ) do
			// Start - 1.3.2023 navmk20 TFS 56140
			if canLogExtra then	//27.02.2025 navah1	#34141
				if surchargeRate.surchargeRate &lt;&gt; null then
					app.invLog("SURG - Cargo type surcharges - surcharge rate: " &amp; surchargeRate.surchargeRate.String, LogINFO.String);		
				else 
					app.invLog("SURG - Cargo type surcharges  -  surcharge rate is zero", LogINFO.String);
				endif;
			endif;
			// End - 1.3.2023 navmk20 TFS 56140
			if surchargeRate.validTo &lt; _invoice.fromDT then
				continue;
			endif;
			
			if surchargeRate.validFrom &gt; _invoice.fromDT then
				break;
			endif;
			
			//Add cargo, cargoSubTypes, Commodities, debtor checks here
			//All debtors checks if our surcharge rate is for allDebtors
			includesCargoType 		:= surchargeRate.allCargoTypes.includes(cargoType);
			includesCargoSubType 	:= surchargeRate.allCargoSubTypes.includes(cargoSubType);
			includesCommodity		:= surchargeRate.allCommodities.includes(commodity);
			includesDebtor			:= surchargeRate.allDebtors.includes(_invoice.debtor);
			allDebtors				:= surchargeRate.allDebtors.isEmpty();
			
			if (includesCargoType or includesCargoSubType or includesCommodity) and (includesDebtor or allDebtors) then
				ctSurChgMultiRate := surchargeRate;
				// start - 1.3.2023 navmk20 TFS 56140
				if canLogExtra then	//27.02.2025 navah1	#34141
					if ctSurChgMultiRate.surchargeRate &lt;&gt; null then
						app.invLog("SURG - Cargo type surcharges  -  surcharge multi rate: " &amp; ctSurChgMultiRate.surchargeRate.String, LogINFO.String);
					else 
						app.invLog("SURG - Cargo type surcharges  -  surcharge multi rate is zero", LogINFO.String);
					endif;
				endif;
				// End - 1.3.2023 navmk20 TFS 56140
			endif;
			
			if ctSurChgMultiRate &lt;&gt; null then
				// start - 1.3.2023 navmk20 TFS 56140
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("SURG - Cargo type surcharges  -  surcharge multi rate is founded", LogINFO.String);
					if ctSurChgMultiRate.surchargeRate &lt;&gt; null then
						app.invLog("SURG - Cargo type surcharges  -  surcharge multi rate: " &amp; ctSurChgMultiRate.surchargeRate.String, LogINFO.String);
					else 
						app.invLog("SURG - Cargo type surcharges  -  surcharge multi rate is zero", LogINFO.String);
					endif;
				endif;
				// End - 1.3.2023 navmk20 TFS 56140
				_surchargeSet.addNoDuplicates( ctSurChgMultiRate, false );
			else													// 1.3.2023 navmk20 TFS 56140
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Cargo type surcharges  -  surcharge multi rate is not found", LogINFO.String); 	// 1.3.2023 navmk20 TFS 56140
				endif;
			endif;
			
		endwhile;
		// ### TFS 54565 (54385) 19Sep2022 NAVPW1
		
		/*ctSurChgRate := self.allInvTypeCargoSurcharges.getAtKey( cargoType, cargoSubType, commodity );
		if ctSurChgRate = null then
			ctSurChgRate := self.allInvTypeCargoSurcharges.getAtKey( cargoType, cargoSubType, null );
		endif;
		if ctSurChgRate = null then
			ctSurChgRate := self.allInvTypeCargoSurcharges.getAtKey( cargoType, null, commodity );
		endif;
		if ctSurChgRate = null then // ### TFS 51219 03JUN2021 NAVAB1
			ctSurChgRate := self.allInvTypeCargoSurcharges.getAtKey( null, null, null ); // ### TFS 51219 03JUN2021 NAVAB1 allow for ALL CARGO TYPES
		endif;
		if ctSurChgRate &lt;&gt; null then
			_surchargeSet.addNoDuplicates( ctSurChgRate, false );
		endif;*/
	endwhile;
	
epilog
	delete iterJob;
	delete iterTi;
	delete iterSurchargeRate; // ### TFS 54565 (54385) 19Sep2022 NAVPW1
 // ### TFS 51219 03JUN2021 NAVAB1	delete allHoldJobs;
	delete dynaDict;
	delete uniqueCargoSet;
	
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_surchargeSet" type="CM_InvTypeCargoMultSchByFromDT" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeSurchargesForVoy" id="463a6a5a-b919-486c-8b00-4387f19c2761">
        <source>getCargoTypeSurchargesForVoy( _voyage : CM_Voyage; _surchargeSet : CM_InvTypeCargoSurchargeSet input );
/*

Purpose:			

Parameters:			We want a collection of tis that are unique by CargoType, CargoSubType and Commodity
					Just one of each to know each of the cargo type combinations the voyage represents.
					
					Then we find from those the surcharges that match members of that set

Return Value:		

Date			Who		Reason
20 June 2018	jlgndl1	Initial creation	TFS 39305
01 March 2023	navmk20	Task 56140: EUP Inv Config - Surcharge Logging
23 Oct 2024		navlw1 	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
JIRA 35766 15AUG2025 NAVAB1 added 'SURG' to logging and changed logging levels and added more information.
*/

vars

	iterJob : Iterator;
	voyJob : CM_VoyageJob;
	allHoldJobs : CM_VoyageJobSet;
	dynaDict : DynaDictionary;
	ti : CM_TrackedItem;
	iterTi : Iterator;
	uniqueCargoSet : CM_TISet;
	
	ctSurChgRate : CM_InvTypeCargoSurcharge;
	cargoType : CM_CargoType;
	cargoSubType : CM_Product;
	commodity : CM_Commodity;
	descStr : String; // 7.3.2023 navmk20 TFS 56140
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("SURG - ** Checking Cargo type surcharges for voyage **", LogINFO.String);	// 1.3.2023 navmk20 TFS 56140
	endif;
	if _voyage = null or _surchargeSet = null then
		// Start 1.3.2023 navmk20 TFS 56140
		if canLogExtra then	//27.02.2025 navah1	#34141
			if _voyage &lt;&gt; null then 
				if _voyage.code &lt;&gt; null then
					app.invLog("SURG - Cargo type surcharges for voyage are found and voyage code is: "&amp; _voyage.code, LogTRACE.String);	
				else
					app.invLog("SURG - Cargo type surcharges for voyage are found and voyage code are not found", LogTRACE.String);
				endif;
			else
				app.invLog("SURG - Cargo type surcharges for voyage are not found", LogTRACE.String);
			endif;
			if _surchargeSet &lt;&gt; null then 
				app.invLog("SURG - Cargo type surcharges for voyage surchargeSet are found", LogTRACE.String);
			else
				app.invLog("SURG - Cargo type surcharges for voyage surchargeSet are not found", LogTRACE.String);
			endif;
		endif;
		// End 1.3.2023 navmk20 TFS 56140
		return;
	endif;
	
	_surchargeSet.clear();
	
	create uniqueCargoSet transient;
 // ### TFS 51219 03JUN2021 NAVAB1	create allHoldJobs transient;
	
	/* // ### TFS 51219 03JUN2021 NAVAB1 ALLOW ALL VOYAGE JOBS
	iterJob := _voyage.allVoyageJobs.createIterator;
	while iterJob.next( voyJob ) do
		if not voyJob.isVoyageHoldJob then
			continue;
		endif;
		allHoldJobs.add( voyJob );
	endwhile;
	delete iterJob;
	NOW */
	
	
	
 // ### TFS 51219 03JUN2021 NAVAB1	if allHoldJobs.isEmpty then
 // ### TFS 51219 03JUN2021 NAVAB1		return;
 // ### TFS 51219 03JUN2021 NAVAB1	endif;
	
	create dynaDict;
	dynaDict.setMembership( CM_TrackedItem );
	dynaDict.addMemberKey(CM_TrackedItem::cargoType.name, false, false);
	dynaDict.addMemberKey(CM_TrackedItem::productCode.name, false, false);
	dynaDict.addMemberKey(CM_TrackedItem::commodity.name, false, false);
	dynaDict.endKeys( false );
	
	if not _voyage.allVoyageJobs.isEmpty() then // ### TFS 51219 03JUN2021 NAVAB1 - If there are some jobs
		iterJob := _voyage.allVoyageJobs.createIterator; // ### TFS 51219 03JUN2021 NAVAB1
		while iterJob.next( voyJob ) do
			if not voyJob.allReceiveTrackedItems.isEmpty then
				iterTi := voyJob.allReceiveTrackedItems.createIterator;
			elseif not voyJob.allReleaseTrackeditems.isEmpty then
				iterTi := voyJob.allReleaseTrackeditems.createIterator;
			else
				continue;
			endif;
			while iterTi.next( ti ) do
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("SURG - Tracked Item found: "&amp; ti.id.String, LogINFO.String); //6.3.2023 navmk20 TFS 56140
				endif;
				if dynaDict.getAtKey( ti.cargoType, ti.productCode, ti.commodity ) &lt;&gt; null then
					//we already have one like this one
					if canLogExtra then	//27.02.2025 navah1	#34141
						app.invLog("SURG - Avoided the duplicate for dyna dict ", LogINFO.String);	//6.3.2023 navmk20 TFS 56140
					endif;
					continue;
				else
					//Start - 6.3.2023 navmk20 TFS 56140
					if canLogExtra then	//27.02.2025 navah1	#34141
						app.invLog("SURG - Added tracked Item", LogINFO.String);	
						if ti.id &lt;&gt; null then
							app.invLog("SURG - Tracked Item Id: "&amp; ti.id.String, LogINFO.String);
						else
							app.invLog("SURG - Tracked Item Id is not found", LogINFO.String);
						endif;
					endif;
					// End - 6.3.2023 navmk20 TFS 56140
					dynaDict.add( ti );
					uniqueCargoSet.add( ti );
				endif;
			endwhile;
			delete iterTi;
		endwhile;
		delete iterJob;
	else // ### TFS 51219 03JUN2021 NAVAB1 - Allow to work for voyages with no jobs
		foreach ti in _voyage.allOnshipTIsByCargoTypeId discreteLock do 
			if dynaDict.getAtKey( ti.cargoType, ti.productCode, ti.commodity ) &lt;&gt; null then
				//we already have one like this one
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("SURG - Avoided the duplicate for all onship TIs by cargo type", LogINFO.String);	//6.3.2023 navmk20 TFS 56140
				endif;
				continue;
			else
				//Start - 6.3.2023 navmk20 TFS 56140
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("SURG - Added tracked Item for all onship", LogINFO.String);	
					if ti.id &lt;&gt; null then
						app.invLog("SURG - Tracked Item Id for all onship: "&amp; ti.id.String, LogINFO.String);
					else
						app.invLog("SURG - Tracked Item Id for all onship is not found", LogINFO.String);
					endif;
				endif;
				// End - 6.3.2023 navmk20 TFS 56140
				dynaDict.add( ti );
				uniqueCargoSet.add( ti );
			endif;
		endforeach;
		foreach ti in _voyage.allOnsiteTIsByCargoTypeId discreteLock do 
			if dynaDict.getAtKey( ti.cargoType, ti.productCode, ti.commodity ) &lt;&gt; null then
				//we already have one like this one
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("SURG - Avoided the duplicate for all on site TIs by cargo type", LogINFO.String);	//6.3.2023 navmk20 TFS 56140
				endif;
				continue;
			else
				//Start - 6.3.2023 navmk20 TFS 56140
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("SURG - Added tracked Item for all onsite", LogINFO.String);	
					if ti.id &lt;&gt; null then
						app.invLog("SURG - Tracked Item Id for all onsite: "&amp; ti.id.String, LogINFO.String);
					else
						app.invLog("SURG - Tracked Item Id for all onsite is not found", LogINFO.String);
					endif;
				endif;
				// End - 6.3.2023 navmk20 TFS 56140
				dynaDict.add( ti );
				uniqueCargoSet.add( ti );
			endif;
		endforeach;
	endif;
	
	if uniqueCargoSet.isEmpty then
		return;
	endif;
	
	iterTi := uniqueCargoSet.createIterator;
	while iterTi.next( ti ) do
		cargoType := ti.myCargoType;
		cargoSubType := ti.myProduct;
		commodity := ti.getCommodityObject;
		descStr := self.getDescription(); // 7.3.2023 navmk20 TFS 56140
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("SURG - Cargo surcharges for voyage by type is  " &amp; descStr, LogINFO.String); // 7.3.2023 navmk20 TFS 56140
		endif;
		ctSurChgRate := self.allInvTypeCargoSurcharges.getAtKey( cargoType, cargoSubType, commodity );
		if ctSurChgRate = null then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("SURG - Cargo type surcharges for voyage surcharge rate are not found for any cargo type/subtype/commodity: "&amp; descStr, LogINFO.String);	//1.3.2023 navmk20 TFS 56140
			endif;
			ctSurChgRate := self.allInvTypeCargoSurcharges.getAtKey( cargoType, cargoSubType, null );
		else																													//1.3.2023 navmk20 TFS 56140
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("SURG - Cargo type surcharges for voyage surcharge rate are found for any cargo type/subtype/commodity: "&amp; descStr, LogINFO.String);		//1.3.2023 navmk20 TFS 56140
			endif;
		endif;
		if ctSurChgRate = null then
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("SURG - Cargo type surcharges for voyage surcharge rate are not found for any cargo type/commodity: "&amp; descStr, LogINFO.String); //1.3.2023 navmk20 TFS 56140
			endif;
			ctSurChgRate := self.allInvTypeCargoSurcharges.getAtKey( cargoType, null, commodity );
		else																										//1.3.2023 navmk20 TFS 56140
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("SURG - Cargo type surcharges for voyage surcharge rate are found for any cargo type/commodity: "&amp; descStr, LogINFO.String);	//1.3.2023 navmk20 TFS 56140
			endif;
		endif;
		if ctSurChgRate = null then // ### TFS 51219 03JUN2021 NAVAB1
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("SURG - Cargo type surcharges for voyage surcharge rate are not found for default: "&amp; descStr, LogINFO.String);			//1.3.2023 navmk20 TFS 56140
			endif;
			ctSurChgRate := self.allInvTypeCargoSurcharges.getAtKey( null, null, null ); // ### TFS 51219 03JUN2021 NAVAB1 allow for ALL CARGO TYPES
		else		//1.3.2023 navmk20 TFS 56140
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog("SURG - Cargo type surcharges for voyage surcharge rate are found for default: "&amp; descStr, LogINFO.String);				//1.3.2023 navmk20 TFS 56140
			endif;
		endif;
		if ctSurChgRate &lt;&gt; null then
			//Start - 1.3.2023 navmk20 TFS 56140
			if canLogExtra then	//27.02.2025 navah1	#34141
				if ctSurChgRate.surchargeRate &lt;&gt; null then
					app.invLog("SURG - Cargo type surcharges for voyage surcharge rate: " &amp; ctSurChgRate.surchargeRate.String, LogINFO.String);		
				else 
					app.invLog("SURG - Cargo type surcharges for voyage surcharge rate is zero", LogINFO.String);
				endif;
			endif;
			//End - 1.3.2023 navmk20 TFS 56140
			_surchargeSet.addNoDuplicates( ctSurChgRate, false );
		endif;
	endwhile;

epilog

	delete iterJob;
	delete iterTi;
 // ### TFS 51219 03JUN2021 NAVAB1	delete allHoldJobs;
	delete dynaDict;
	delete uniqueCargoSet;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_surchargeSet" type="CM_InvTypeCargoSurchargeSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDebtorSurchargeRate" id="786d1396-2353-4643-98e1-c3159c096f94">
        <source>getDebtorSurchargeRate( _debtor : CM_Debtor; _secondaryDebtor : CM_Debtor ):CM_DebtorSurchargeRate;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 June 2018	jlgndl1	Initial creation	TFS 38914
01 March 2023	navmk20	Task 56140: EUP Inv Config - Surcharge Logging
23 Oct 2024		navlw1 	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	drSurChgRate : CM_DebtorSurchargeRate;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	// Start - 6.3.2023 navmk20 TFS 56140
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("** Checking debtor surcharge rate **", LogINFO.String);
		if _debtor &lt;&gt; null then
			app.invLog("Debtor are found", LogINFO.String);
			if _debtor.name &lt;&gt; null then
				app.invLog("Debtor name are found: "&amp; _debtor.name.String, LogINFO.String);
			else	
				app.invLog("Debtor name are not found", LogINFO.String);
			endif;
		else
			app.invLog("Debtor are not found", LogINFO.String);
		endif;
	endif;
	// End - 6.3.2023 navmk20 TFS 56140
	drSurChgRate := self.allDebtorSurchargeRates.getAtKey( _debtor );
	// Start - 1.3.2023 navmk20 TFS 56140
	if canLogExtra then	//27.02.2025 navah1	#34141
		if drSurChgRate &lt;&gt; null then
			if drSurChgRate.surchargeRate &lt;&gt; null then
				app.invLog("Debtor surcharge rate: " &amp; drSurChgRate.surchargeRate.String, LogINFO.String);		
			else 
				app.invLog("Debtor surcharge rate is zero", LogINFO.String);
			endif;
		else
			app.invLog("Debtor surcharge is not found", LogINFO.String);
		endif;
		
		if _secondaryDebtor &lt;&gt; null then
			app.invLog("Secondary debtor are found", LogINFO.String);
			if _secondaryDebtor.name &lt;&gt; null then
				app.invLog("Secondary debtor name are found: "&amp; _secondaryDebtor.name.String, LogINFO.String);
			else	
				app.invLog("Secondary debtor name are not found", LogINFO.String);
			endif;
		else
			app.invLog("Secondary debtor are not found", LogINFO.String);
		endif;
	endif;
	// End - 6.3.2023 navmk20 TFS 56140
	if drSurChgRate = null and _secondaryDebtor &lt;&gt; null then
		drSurChgRate := self.allDebtorSurchargeRates.getAtKey( _secondaryDebtor );
		// Start - 1.3.2023 navmk20 TFS 56140
		if canLogExtra then	//27.02.2025 navah1	#34141
			if drSurChgRate &lt;&gt; null then
				if drSurChgRate.surchargeRate &lt;&gt; null then
					app.invLog("Secondary debtor surcharge rate: " &amp; drSurChgRate.surchargeRate.String, LogINFO.String);		
				else 
					app.invLog("Secondary debtor surcharge rate is zero", LogINFO.String);
				endif;
			else
				app.invLog("Secondary debtor surcharge is not found", LogINFO.String);
			endif;
		endif;
	else
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("Secondary debtor is not found", LogINFO.String);
		endif;
	// End - 1.3.2023 navmk20 TFS 56140
	endif;
	
	return drSurChgRate;

epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_secondaryDebtor" type="CM_Debtor"/>
        <ReturnType type="CM_DebtorSurchargeRate"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="cec5e983-3ae3-49a0-9ca2-cab851514221">
        <source>getDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 March 2023	navmk20	Task 56140: EUP Inv Config - Surcharge Logging

*/

vars
	descStr : String;
	cargoType : CM_CargoType;
	cargoSubType : CM_Product;
	commodity : CM_Commodity;
begin

	if cargoType &lt;&gt; null then
		if cargoType.description &lt;&gt; null then
			descStr := descStr &amp; "/ "&amp; cargoType.description;
		endif;
	endif;
	if cargoSubType &lt;&gt; null then
		if cargoSubType.description &lt;&gt; null then
		descStr := descStr &amp; "/ "&amp; cargoSubType.description;
		endif;	
	endif;
	if commodity &lt;&gt; null then
		if commodity.description &lt;&gt; null then
			descStr := descStr &amp; "/ "&amp; commodity.description;
		endif;
	endif;
	return descStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHighestRangeAddChgFor" id="948c306a-6205-46d4-9442-333200b41bfd">
        <source>getHighestRangeAddChgFor( _dr : CM_Debtor ):CM_InvTypeAdditionalCharges;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37819
01 March 2023	navmk20						Task 56140: EUP Inv Config - Surcharge Logging
23 Oct 2024		navlw1 	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	iter : Iterator;
	startObj : CM_InvTypeAdditionalCharges;
	addChg : CM_InvTypeAdditionalCharges;
	highestAddChg : CM_InvTypeAdditionalCharges;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	// Start - 6.3.2023 navmk20 TFS 56140
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("** Checking highest range add charges **", LogINFO.String);
		if _dr &lt;&gt; null then
			app.invLog("Debtor are found", LogINFO.String);
			if _dr.name &lt;&gt; null then
				app.invLog("Debtor name are found: "&amp; _dr.name.String, LogINFO.String);
			else	
				app.invLog("Debtor name are not found", LogINFO.String);
			endif;
		else
			app.invLog("Debtor are not found", LogINFO.String);
		endif;
	endif;
	// End - 6.3.2023 navmk20 TFS 56140
	iter := self.allInvTypeAdditionalCharges.createIterator;
	startObj := self.allInvTypeAdditionalCharges.getAtKeyGeq( _dr, 0 );
	if startObj &lt;&gt; null then
		iter.startAtObject(startObj);
		while iter.next( addChg ) do
			if _dr &lt;&gt; addChg.myDebtor then
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Debtor does not match the highest range of additional charges debtor", LogINFO.String); // 1.3.2023 navmk20 TFS 56140	
				endif;
				break;
			else																					// 1.3.2023 navmk20 TFS 56140	
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Debtor match the highest range of additional charges debtor", LogINFO.String); // 1.3.2023 navmk20 TFS 56140
				endif;
			endif;
			highestAddChg := addChg;
		endwhile;
	else																							// 1.3.2023 navmk20 TFS 56140
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("Highest range of additional charges is not found", LogINFO.String); 	// 1.3.2023 navmk20 TFS 56140
		endif;
	endif;

	return highestAddChg;

epilog

	delete iter;

end;</source>
        <Parameter name="_dr" type="CM_Debtor"/>
        <ReturnType type="CM_InvTypeAdditionalCharges"/>
    </JadeMethod>
    <JadeMethod name="getHighestRangeTaxFor" id="996761a9-bd00-43ec-b915-09327cf9e5b6">
        <source>getHighestRangeTaxFor( _dr : CM_Debtor ):CM_InvoiceTypeExternalTax;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37821
01 March 2023	navmk20	Task 56140: EUP Inv Config - Surcharge Logging
23 Oct 2024		navlw1 	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	iter : Iterator;
	startObj : CM_InvoiceTypeExternalTax;
	extTax : CM_InvoiceTypeExternalTax;
	highestExtTax : CM_InvoiceTypeExternalTax;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	// Start - 6.3.2023 navmk20 TFS 56140
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("** Checking highest range tax **", LogINFO.String);
		if _dr &lt;&gt; null then
			app.invLog("Debtor are found", LogINFO.String);
			if _dr.name &lt;&gt; null then
				app.invLog("Debtor name are found: "&amp; _dr.name.String, LogINFO.String);
			else	
				app.invLog("Debtor name are not found", LogINFO.String);
			endif;
		else
			app.invLog("Debtor are not found", LogINFO.String);
		endif;
	endif;
	// End - 6.3.2023 navmk20 TFS 56140
	iter := self.allInvTypeExternalTax.createIterator;
	startObj := self.allInvTypeExternalTax.getAtKeyGeq( _dr, 0 );
	if startObj &lt;&gt; null then
		iter.startAtObject(startObj);
		while iter.next( extTax ) do
			if _dr &lt;&gt; extTax.myDebtor then
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Debtor does not match the highest range tax of external tax debtor", LogINFO.String); 	// 1.3.2023 navmk20 TFS 56140
				endif;
				break;
			else																					// 1.3.2023 navmk20 TFS 56140
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Debtor match the highest range tax of external tax debtor", LogINFO.String); // 1.3.2023 navmk20 TFS 56140
				endif;
			endif;
			highestExtTax := extTax;
		endwhile;
	else																							// 1.3.2023 navmk20 TFS 56140
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("Highest range tax of external tax is not found", LogINFO.String); 		// 1.3.2023 navmk20 TFS 56140
		endif;
	endif; 

	return highestExtTax;

epilog

	delete iter;

end;</source>
        <Parameter name="_dr" type="CM_Debtor"/>
        <ReturnType type="CM_InvoiceTypeExternalTax"/>
    </JadeMethod>
    <JadeMethod name="getInvTypeAddFeesForInvTotal" id="e92e0460-7297-48fb-9e10-3b1141346770">
        <source>getInvTypeAddFeesForInvTotal( _dr : CM_Debtor; _invTotal : Real; _secondaryDebtor : CM_Debtor ):CM_InvTypeAdditionalCharges;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
05 April 2018		jlgndl1	Initial creation	TFS 37819
09 December 2022	navpw1	TFS: 54571 - Fixed leaked iter transient by deleting in epilog
01 March 2023		navmk20	Task 56140: EUP Inv Config - Surcharge Logging
23 Oct 2024			navlw1 	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	iter : Iterator;
	startObj : CM_InvTypeAdditionalCharges;
	addChg : CM_InvTypeAdditionalCharges;
	hasAtLeastOne : Boolean;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	// Start - 6.3.2023 navmk20 TFS 56140
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("** Checking invoice type add fees for invoice total **", LogINFO.String);
		if _dr &lt;&gt; null then
			app.invLog("Debtor are found", LogTRACE.String);
			if _dr.name &lt;&gt; null then
				app.invLog("Debtor name are found: "&amp; _dr.name.String, LogTRACE.String);
			else	
				app.invLog("Debtor name are not found", LogTRACE.String);
			endif;
		else
			app.invLog("Debtor are not found", LogTRACE.String);
		endif;
	endif;
	// End - 6.3.2023 navmk20 TFS 56140
	iter := self.allInvTypeAdditionalCharges.createIterator;
	startObj := self.allInvTypeAdditionalCharges.getAtKeyGeq( _dr, 0 );
	if startObj &lt;&gt; null then
		iter.startAtObject(startObj);
		while iter.next( addChg ) do
			if _dr &lt;&gt; addChg.myDebtor then
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Debtor does not match the invoice type add fees debtor", LogTRACE.String); 	// 1.3.2023 navmk20 TFS 56140
				endif;
				break;
			else																		// 1.3.2023 navmk20 TFS 56140
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Debtor match the invoice type add fees debtor", LogTRACE.String); 			// 1.3.2023 navmk20 TFS 56140
				endif;
			endif;
			if addChg.isValueWithinRange( _invTotal ) then
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Return invoice type add fees", LogTRACE.String); 							// 1.3.2023 navmk20 TFS 56140
				endif;
				return addChg;
			else
				hasAtLeastOne := true;
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("invoice type add fees isValueWithinRange is false and hasAtLeastOne " &amp; hasAtLeastOne.String, LogTRACE.String); 	// 1.3.2023 navmk20 TFS 56140
				endif;
			endif;
		endwhile;
	else 																				// 1.3.2023 navmk20 TFS 56140
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("Add fees for invoice total of additional charges is not found", LogTRACE.String); 	// 1.3.2023 navmk20 TFS 56140
		endif;
	endif;
	// Start - 6.3.2023 navmk20 TFS 56140
	if canLogExtra then	//27.02.2025 navah1	#34141
		if _secondaryDebtor &lt;&gt; null then
			app.invLog("Secondary debtor are found", LogTRACE.String);
			if _secondaryDebtor.name &lt;&gt; null then
				app.invLog("Secondary debtor name are found: "&amp; _secondaryDebtor.name.String, LogTRACE.String);
			else	
				app.invLog("Secondary debtor name are not found", LogTRACE.String);
			endif;
		else
			app.invLog("Secondary debtor are not found", LogTRACE.String);
		endif;
	endif;
	// End - 6.3.2023 navmk20 TFS 56140
	if not hasAtLeastOne and _secondaryDebtor &lt;&gt; null then
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("Get Invoice Type Add Fees For Invoice Total for secondaryDebtor/invTotal ", LogTRACE.String);	// 1.3.2023 navmk20 TFS 56140
		endif;
		return self.getInvTypeAddFeesForInvTotal( _secondaryDebtor, _invTotal, null );
	else																						// 1.3.2023 navmk20 TFS 56140
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("Add fees for invoice total of secondary Debtor is not found", LogTRACE.String); 				// 1.3.2023 navmk20 TFS 56140
		endif;
	endif;

	return null;
	
epilog
	delete iter;	// ### TFS 54571 09Dec2022 NAVPW1
end;</source>
        <Parameter name="_dr" type="CM_Debtor"/>
        <Parameter name="_invTotal" type="Real"/>
        <Parameter name="_secondaryDebtor" type="CM_Debtor"/>
        <ReturnType type="CM_InvTypeAdditionalCharges"/>
    </JadeMethod>
    <JadeMethod name="getInvTypeExtTaxForInvTotal" id="12439ea4-c891-447c-b194-e36b05f6947a">
        <source>getInvTypeExtTaxForInvTotal( _dr : CM_Debtor; _invTotal : Real ):CM_InvoiceTypeExternalTax;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37819
01 March 2023	navmk20	Task 56140: EUP Inv Config - Surcharge Logging
23 Oct 2024		navlw1 	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	iter : Iterator;
	startObj : CM_InvoiceTypeExternalTax;
	addChg : CM_InvoiceTypeExternalTax;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	if canLogExtra then	//27.02.2025 navah1	#34141
	// Start - 6.3.2023 navmk20 TFS 56140
		app.invLog("** Checking invoice type external tax for invoice total **", LogINFO.String); // 1.3.2023 navmk20 TFS 56140
		if _dr &lt;&gt; null then
			app.invLog("Debtor are found", LogINFO.String);
			if _dr.name &lt;&gt; null then
				app.invLog("Debtor name are found: "&amp; _dr.name.String, LogINFO.String);
			else	
				app.invLog("Debtor name are not found", LogINFO.String);
			endif;
		else
			app.invLog("Debtor are not found", LogINFO.String);
		endif;
		// End - 6.3.2023 navmk20 TFS 56140
	endif;
	iter := self.allInvTypeExternalTax.createIterator;
	startObj := self.allInvTypeExternalTax.getAtKeyGeq( _dr, 0 );
	if startObj &lt;&gt; null then
		iter.startAtObject(startObj);
		while iter.next( addChg ) do
			if _dr &lt;&gt; addChg.myDebtor then
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Debtor does not match the invoice type external tax debtor", LogINFO.String); 	// 1.3.2023 navmk20 TFS 56140
				endif;
				break;
			else																			// 1.3.2023 navmk20 TFS 56140
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Debtor match the invoice type external tax debtor", LogINFO.String); // 1.3.2023 navmk20 TFS 56140
				endif;
			endif;
			if addChg.isValueWithinRange( _invTotal ) then
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Return invoice type external tax", LogINFO.String); 	// 1.3.2023 navmk20 TFS 56140
				endif;
				return addChg;
			else																			// 1.3.2023 navmk20 TFS 56140
				if canLogExtra then	//27.02.2025 navah1	#34141
					app.invLog("Invoice type external tax is Value Within Range is false", LogINFO.String); // 1.3.2023 navmk20 TFS 56140
				endif;
			endif;
		endwhile;
	else																					// 1.3.2023 navmk20 TFS 56140
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("Invoice type of external tax is not found", LogINFO.String);	// 1.3.2023 navmk20 TFS 56140
		endif;
	endif; 

	return null;
	
epilog

end;</source>
        <Parameter name="_dr" type="CM_Debtor"/>
        <Parameter name="_invTotal" type="Real"/>
        <ReturnType type="CM_InvoiceTypeExternalTax"/>
    </JadeMethod>
    <JadeMethod name="getMinChargeInvoiceLineType" id="2af606ae-664e-4e64-853b-fdba4aa9682e">
        <source>getMinChargeInvoiceLineType():CM_InvoiceLineDesc;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2018	jlgndl1	Initial creation	TFS 37818

*/

vars

	lineType : CM_InvoiceLineDesc;
	edition : Integer;
	invalid : Boolean;

begin

	lineType := self.myMinimumChargeInvoiceLineType;
	if lineType = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, lineType, invalid );
	edition := lineType.edition;
	if invalid then
		return null;
	endif;
	
	return lineType;

epilog

end;</source>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="getMinDebtorCharges" id="08ed512e-ca1f-4439-b68d-e3926de2cc29">
        <source>getMinDebtorCharges( _debtor : CM_Debtor; _secondaryDebtor : CM_Debtor ):CM_InvTypeDebtorMinCharge;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
05 June 2018	jlgndl1	Initial creation	TFS 38914
01 March 2023	navmk20	Task 56140: EUP Inv Config - Surcharge Logging
23 Oct 2024		navlw1 	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	drMinCharge : CM_InvTypeDebtorMinCharge;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	// Start - 6.3.2023 navmk20 TFS 56140
	if canLogExtra then	//27.02.2025 navah1	#34141
		app.invLog("** Checking minimum debtor charge **", LogINFO.String);
		if _debtor &lt;&gt; null then
			app.invLog("Debtor are found", LogINFO.String);
			if _debtor.name &lt;&gt; null then
				app.invLog("Debtor name are found: "&amp; _debtor.name.String,LogINFO.String);
			else	
				app.invLog("Debtor name are not found", LogINFO.String);
			endif;
		else
			app.invLog("Debtor are not found", LogINFO.String);
		endif;
	endif;
	// End - 6.3.2023 navmk20 TFS 56140
	drMinCharge := self.allInvTypeDebtorMinCharges.getAtKey( _debtor );
	// Start - 1.3.2023 navmk20 TFS 56140
	if canLogExtra then	//27.02.2025 navah1	#34141
		if drMinCharge &lt;&gt; null then
			if drMinCharge.minimumChargeAmount &lt;&gt; null then
				app.invLog("Minimum debtor charge amount rate: " &amp; drMinCharge.minimumChargeAmount.String, LogINFO.String);		
			else 
				app.invLog("Minimum debtor charge amount rate is zero", LogINFO.String);
			endif;
		else
			app.invLog("Minimum debtor charge is not found", LogINFO.String);
		endif;
		if _secondaryDebtor &lt;&gt; null then
			app.invLog("Secondary debtor are found", LogINFO.String);
			if _secondaryDebtor.name &lt;&gt; null then
				app.invLog("Secondary debtor name are found: "&amp; _secondaryDebtor.name.String, LogINFO.String);
			else	
				app.invLog("Secondary debtor name are not found", LogINFO.String);
			endif;
		else
			app.invLog("Secondary debtor are not found", LogINFO.String);
		endif;
	endif;
	// End - 1.3.2023 navmk20 TFS 56140
	if drMinCharge = null and _secondaryDebtor &lt;&gt; null then
		drMinCharge := self.allInvTypeDebtorMinCharges.getAtKey( _secondaryDebtor );
		// Start - 1.3.2023 navmk20 TFS 56140
		if canLogExtra then	//27.02.2025 navah1	#34141
			if drMinCharge &lt;&gt; null then
				if drMinCharge.minimumChargeAmount &lt;&gt; null then
					app.invLog("Minimum secondary debtor charge amount rate: " &amp; drMinCharge.minimumChargeAmount.String, LogINFO.String);		
				else 
					app.invLog("Minimum secondary debtor charge amount rate is zero", LogINFO.String);
				endif;
			else
				app.invLog("Minimum secondary debtor charge is not found", LogINFO.String);
			endif;
		endif;
	else
		if canLogExtra then	//27.02.2025 navah1	#34141
			app.invLog("Minimum debtor secondary debtor is not found", LogINFO.String);
		endif;
	// End - 1.3.2023 navmk20 TFS 56140
	endif;
	
	return drMinCharge;

epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_secondaryDebtor" type="CM_Debtor"/>
        <ReturnType type="CM_InvTypeDebtorMinCharge"/>
    </JadeMethod>
    <JadeMethod name="getMinVessCharge" id="f679d486-2216-4eb9-af58-aa76f683d840">
