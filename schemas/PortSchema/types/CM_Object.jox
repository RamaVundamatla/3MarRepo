    <JadeMethod name="hasEntTableSpecialConditions" id="f40d1d7b-559f-4181-825d-050e95320b19">
        <source>hasEntTableSpecialConditions(	_entRow : EntTableRow;
								_alteredHeaderName : String output;
								_hideRow : Boolean output;
								_measureType : CM_MeasurementType output
								):Boolean;
/*

Purpose:			

Parameters:		
			Re-implemneted
			
			returns true if the entable row with this attrName requires
			any special behaviour for this object...
			I.e. conversion of the header name on the table
			Conversion of a the data value for display i.e.
			a weight stored as kg but displayed as lbs etc.

Return Value:		

Date		Who		Reason
04 September 2013	cnwndl1	Initial creation	Par 32413

*/

vars

begin

	if  _entRow.measurementType &lt;&gt; null then

		_measureType := self.getDefaultMeasurementForType(_entRow.measurementType);
	
		if _measureType &lt;&gt; null then
			return true;
		endif;
		
	endif;

	return false;

epilog

end;</source>
        <Parameter name="_entRow" type="EntTableRow"/>
        <Parameter name="_alteredHeaderName" type="String" usage="output"/>
        <Parameter name="_hideRow" type="Boolean" usage="output"/>
        <Parameter name="_measureType" type="CM_MeasurementType" usage="output"/>
