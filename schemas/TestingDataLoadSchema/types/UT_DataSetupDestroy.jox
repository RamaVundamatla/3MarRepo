    <JadeMethod name="completePTN010010Jobs" id="7b63c6e0-561b-40f0-a03b-8637ac384567">
        <source>completePTN010010Jobs(_voyage : CM_Voyage);

/*

Purpose:		Complete the jobs for voyage "PTN010010"

Date			Who		Reason
27/03/2012		cnwmh5	Initial creation

*/
constants	
	VoyageName			: String = "PTN010010";
vars

	terminal			: CM_Terminal;
	operator			: CM_Operator;
	shippingLine		: CM_ShippingLine;
	crane				: CM_Machine;
	cta					: CM_CraneTransferArea;
	voyage				: CM_Voyage;
	jobSheet			: CM_JobSheet;
	job					: CM_Job;
	
	tas					: StringArray;
	detailsArray		: StringArray;
	idArray				: StringArray;
	descArray			: StringArray;
	
	index				: Integer;
	id					: String;
	voyageFound			: Boolean;

begin

	foreach job in _voyage.allVoyageJobs  discreteLock do
		if job.CM_VoyageJob.isHatchLidJob() then
			continue;
		endif;
		
		write job.id &amp; " - Start";
		if job.id = "105" or job.id = "115" or job.id = "120" or job.id = "305" or 
				job.id = "310" or job.id = "315" or job.id = "320" or job.id = "330" then
			//self.moveCargoForVoyageJobExtra(job);
			self.moveCargoForVoyageJob(job, REAL_MODE);
		endif;
		write job.id &amp; " - End"; 
	endforeach;
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createAreaContsForLoadJobs" id="94030429-a71f-4165-a714-d09cb1935235">
        <source>createAreaContsForLoadJobs(_voyage : CM_Voyage; _detailsArray : StringArray);

/*

Purpose:		Create the load area and containers for load jobs		

Date			Who		Reason
05/03/2012		cnwmh5	Initial creation

*/

vars

	theSlot 			: CM_LocationsController;
	cargo 				: CM_TrackedItem;
	port 				: CM_Port;
	ta					: CM_TerminalArea;
	
	strs 				: StringArray;
	details				: StringArray;
	
	idx 				: Integer;
	detail				: String;
	imex				: Integer;
	
begin

	// create the terminal
	self.opts.purge();
	self.opts.addAssoc("Terminal", "JBL");
	self.opts.addAssoc("use40ftIds", true);
	self.deleteTerminalArea("A01");
	ta := self.addRTGArea("A01", 7, 22, 4);
	if ta = null then
		//app.msgBox("Terminal Area not created", "Terminal Area Error", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;	
	
	port := app.myRoot.allPorts["AUBNE"];
	create strs transient;
	
	create details transient;
	
	self.opts.purge();
	self.opts.addAssoc("Terminal", "JBL");

	foreach detail in _detailsArray do
	
		details.clear();
		details := detail.cnGetTokens(";");
		if details.size &lt;&gt; 6 then
			continue;
		endif;
	
		strs.clear();
		strs.add(details[6]);
		ta.findLocation(strs, false, theSlot, idx);
		
		self.deleteContainer(details[1]);
		//write details[1] &amp; Tab &amp; app.myRoot.allOperators[details[2]].code &amp; Tab &amp; details[3] &amp; Tab &amp; details[4] &amp; Tab &amp; details[6] &amp; Tab &amp; theSlot.String;
		self.addContainerAtLocation(details[1], app.myRoot.allOperators[details[2]], details[3], details[4], TI_IMEX_STATUS_EXPORT, theSlot);
	
	endforeach;
	
epilog

	delete strs;
	delete details;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_detailsArray" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="createPTN0100010DischConts" id="88ab95c8-c4bb-4dd0-93fb-cc301a467647">
        <source>createPTN0100010DischConts(_voyage : CM_Voyage; _detailsArray : StringArray);

/*

Purpose:		Create the discharge cargo for the voyage		

Parameters:			

Return Value:		


Date			Who		Reason
05/03/2012		cnwmh5	Initial creation

*/

vars

	theSlot 			: CM_LocationsController;
	cargo 				: CM_TrackedItem;
	port 				: CM_Port;
	
	strs 				: StringArray;
	details				: StringArray;
	
	idx 				: Integer;
	detail				: String;
	imex				: Integer;
	
begin

	port := app.myRoot.allPorts[_voyage.myTerminal.getConfig(PortDestCode).String];
	create strs transient;
	
	create details transient;
	
	foreach detail in _detailsArray do
	
		details.clear();
		details := detail.cnGetTokens(";");
		if details.size &lt;&gt; 8 then
			continue;
		endif;
	
		strs.clear();
		strs.add(details[4]);
		_voyage.findLocation(strs, false, theSlot, idx);
		self.opts.purge();
		self.opts.addAssoc("Operator", app.myRoot.allOperators[details[6]]);
		self.opts.addAssoc("Terminal", details[8]);
		self.opts.addAssoc(UTTI_TotalWeight, details[5].Integer);
		self.deleteContainer(details[1]);
		imex := TI_IMEX_STATUS_IMPORT;
		if details[7] = "STO" then
			imex := TI_IMEX_STATUS_STORAGE;
		elseif details[7] = "EXP" then
			imex := TI_IMEX_STATUS_EXPORT;
		elseif details[7] = "ROB" then
			imex := TI_IMEX_STATUS_REMAINONBOARD;
		elseif details[7] = "TSH" then
			imex := TI_IMEX_STATUS_TRANSHIP;
		endif;
		self.addContainerAtLocnDisch(details[1], details[2], details[3], imex, theSlot, port, _voyage);
	
	endforeach;
	
epilog

	delete strs;
	delete details;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_detailsArray" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="createPTN0100010Jobs" id="a0f6d472-f86a-4be8-9a4c-74a48bb34325">
