    <JadeMethod name="getCreditNumber" id="e7adf80b-c571-4025-94d6-ee0bdada8f92">
        <source>getCreditNumber():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax

*/

vars
	str			 : String;
	creditDetail : CM_CashCreditDetail;
begin
	foreach creditDetail in self.allCashCreditDetails discreteLock do
		if creditDetail.myDerivedFromCashCredit = null then
			continue;
		endif;
		if str &lt;&gt; null then
			str := str &amp; "," &amp; creditDetail.myDerivedFromCashCredit.externalId;
		else	
			str := creditDetail.myDerivedFromCashCredit.externalId;
		endif;
		
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
