    <JadeMethod name="buildFileExtra" id="27af2684-0152-4254-b51d-eb03bc5ea206">
        <updating/>
        <source>buildFileExtra(_transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile: CM_CamFile input) updating, protected;
/*
Date			Who		Reason
27 June 2012	cnwcs5	Initial creation - par 29601
18 Jul 2012		cnwrs1	CCMS 1269 CAMS remove CM_CamTask
23 Jul 2012		cnwcs5	par 29601/2 - extra logging
*/
vars
	result 	: Boolean;	// par 29601/2
begin
	if not _transaction.isCamsEditType then	
		return;
	endif;
	
	// do we include a gate-in when changed from null voyage 
	if _camProtocol.gateInForNullVoyageChange and not _camProtocol.prcNullVoyageTransaction then // par 16040 cnwrs1 mar 2008
		result := self.checkEditTransactionForVoy(_transaction, _camProtocol, _camAgent, _camFile);	// par 29601/2
	endif;
	
	// do we include gate-in for those changed from null operator (CCMS 1649)
	if  not result and _camProtocol.gateInForNullOperatorChange   then												// par 29601/2
		self.checkEditTransactionForOper(_transaction, _camProtocol, _camAgent, _camFile);
	endif;
	
	inheritMethod (_transaction, _camProtocol, _camAgent, _camFile);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkEditTransactionForNoInfo" id="6dbc4fb0-ac99-49e2-a349-1992da8a3dd2">
        <updating/>
        <source>checkEditTransactionForNoInfo(_transaction:CM_TITransaction; _camProtocol:CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile:CM_CamFile io)updating;

/*

Purpose:			
To examine a CM_Edit Transaction for a change of trackedItem.isNoInfo to false.
If detected we need to send a CM_receival cams message
BUT we need the tracked item info from the edit transaction
So we get the receival transaction and the edit transaction and create a transient cm_receival with info from both.
we then send this through to processTransaction

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2009	cnwrd1	Initial creation

*/
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//17 Jun 2014	cnwdap1	PAR #34422 Remove beginLock / endLock
//23 Feb 2014	cmwrs1	Par 35738 Replace removed beginLock/Endloack with beginLoad /endload
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//06 Mar 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
vars
	trans,
	saveTrans,
	editTrans,
	receivalTrans : CM_TITransaction;
	field,oldValue,newValue : String;
	i : Integer;
	tmpTerminal	: CM_Terminal;
	loadState : Boolean;
begin

	editTrans	 := _transaction;
	
	if not editTrans.isCamsEditType() then
		return;
	endif;
	
	//we have an edit transaction see if it is intesteresting
	foreach i in 1 to editTrans.CM_Edit.fieldsValues.size  do
		editTrans.CM_Edit.getFieldValues(i, field, oldValue, newValue);
		//see if it includes an isNoInfo change
		if field = CM_TrackedItem::isNoInfo.name then
			// if the old value is true and the new value is false
			if oldValue.asBooleanJMT() = true and newValue.asBooleanJMT() = false then
			
				// find the most recent receive/release type transaction prior
				// to the edit transaction being processed.
				foreach trans in editTrans.myTrackedItem.allTransactions do
					if trans.dateTime &gt;= editTrans.dateTime then
						break;
					endif;
					if self.isTransactionToBeProcessed(_camProtocol, trans, _camAgent) and //par 21254 cnwrs1 oct 2009
					   trans.isCamsCodecoRecRelType() then
						saveTrans := trans;
					endif;
				endforeach;
				
				if saveTrans &lt;&gt; null then
					//processed in builFile before this
					if (saveTrans.dateTime &lt;= _camAgent.startDateTime) or (saveTrans.dateTime &gt;= _camAgent.endDateTime) then
					
						//create a transient receival from the saveTrans and populate its data from the edit trans
						//create receivalTrans as saveTrans.class proxy - we later use the proxy to get the real;
						//beginLock;			// PAR #34422
						app.cmsBeginLoad(loadState);
						receivalTrans := saveTrans.pxyCreateUpdateProxy();
						app.cmsEndLoad(loadState);
						//endLock;				// PAR #34422
						receivalTrans.setFromNoInfoEdit(saveTrans.myTrackedItem, editTrans);
						if _camAgent.logIncludedTransactions then
							_camAgent.logReasonForInclusion(receivalTrans, "Transaction is no info to be processed");
						endif;
						self.processTransaction(receivalTrans, _camProtocol, _camAgent, _camFile);						
						delete receivalTrans;

					endif;
				endif;
			endif;
		endif;
	endforeach;
	
epilog
	delete receivalTrans; //to be sure	
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="io"/>
    </JadeMethod>
    <JadeMethod name="checkEditTransactionForOper" id="1f36f2f9-75d7-452c-8c27-fbe22ae0af6f">
        <updating/>
        <source>checkEditTransactionForOper(_transaction:CM_TITransaction; _camProtocol:CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile : CM_CamFile input) updating;
//
// Check for null operator
//
// 27/06/0212	cnwcs5	par 29601 - change usage for _camFile
// 18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 23 Jul 2012	cnwcs5	par 29601/2
//04 Mar 2013	cnwrs1	Par 31344 operator changes are sometimes being missed
//06 Mar 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
vars
	editTrans 		: CM_Edit;
	field 			: String;
	oldValue 		: String;
	newValue 		: String;
	i 				: Integer;
	tmpTerminal		: CM_Terminal;
	isOperatorEdit : Boolean;
begin
	editTrans := _transaction.CM_Edit;
	
	if not editTrans.isCamsEditType() then
		return;
	endif;
	
	if editTrans.type = TRANS_TYPE_OperatorChange then
		if editTrans.CM_EditOperator.myOperatorTo &lt;&gt; null and
		   editTrans.CM_EditOperator.myOperatorTo &lt;&gt; editTrans.CM_EditOperator.myOperatorFrom then
			isOperatorEdit := true;
			self.processOperatorChange(editTrans, _camProtocol, _camAgent, _camFile);
		endif;
	endif;
	
	// if not already processed then try and find the operator change details in the fieldValues
	if not isOperatorEdit then
		//we have an edit transaction see if it is intesteresting
		foreach i in 1 to editTrans.fieldsValues.size  do
			editTrans.getFieldValues(i, field, oldValue, newValue);
			//see if it includes a operator change
			if field = CM_TrackedItem::operatorCode.name or
			   field = CM_TrackedItem::myOperator.name then
				tmpTerminal := editTrans.myTerminal;
				// if the old value is null voyage and the new value is not then find the last gate/rail in and process it
				if newValue &lt;&gt; null and newValue &lt;&gt; oldValue then
					isOperatorEdit := true;
					self.processOperatorChange(editTrans, _camProtocol, _camAgent, _camFile);
				endif;
			endif;
		endforeach;
	endif;

	if not isOperatorEdit and
	   _camAgent.logExcludedTransactions then
		_camAgent.logReasonForExclusion (_transaction, '"Include gate in/out for those with operator change" is set but EDIT transaction is not an operator change'); // par 29601/2 
	endif;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkEditTransactionForVoy" id="e190044c-83a6-4609-aa8c-cb384eba9a86">
        <updating/>
        <source>checkEditTransactionForVoy(_transaction:CM_TITransaction; _camProtocol:CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile :CM_CamFile input):Boolean updating;
//
// Check for null voyage
//
// 27/06/2012	cnwcs5	par 29601 - change usage for _camFile
// 18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 23 Jul 2012	cnwcs5	par 29601/2 - extra logging
// 17 Jun 2014	cnwdap1	PAR #34422 Remove beginLock / endLock
//23 Feb 2014	cmwrs1	Par 35738 Replace removed beginLock/Endloack with beginLoad /endload
//06 Mar 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
vars
	trans 			: CM_TITransaction;
	saveTrans 		: CM_TITransaction;
	editTrans 		: CM_Edit;
	receivalTrans 	: CM_TITransaction;
	field 			: String;
	oldValue 		: String;
	newValue 		: String;
	i 				: Integer;
	tmpTerminal		: CM_Terminal;
	isNullVoyageEdit,
	result			: Boolean;	// par 29601
	loadState : Boolean;
begin
	editTrans := _transaction.CM_Edit;
	
	if not editTrans.isCamsEditType() then
		return false;	// par 29601/2
	endif;
	//we have an edit transaction see if it is intesteresting
	foreach i in 1 to editTrans.fieldsValues.size  do
		editTrans.getFieldValues(i, field, oldValue, newValue);
		//see if it includes a voyage change
		if field = CM_TrackedItem::myVoyage.name then
			tmpTerminal := editTrans.myTerminal;
			// if the old value is null voyage and the new value is not then find the last gate/rail in and process it
			if oldValue = tmpTerminal.getDefaultVoyageCode then
				if newValue &lt;&gt; null and newValue &lt;&gt; oldValue then
					isNullVoyageEdit := true;
					// look for most recent receival transaction
					foreach trans in editTrans.myTrackedItem.allTransactions do
						if trans.dateTime &gt;= editTrans.dateTime then //par16608 cnwrs1 Apr 2008
							break;
						endif;
						if self.isTransactionToBeProcessed(_camProtocol, trans, _camAgent) then //par 21254 cnwrs1 oct 2009
							if trans.isCamsCodecoRecRelType() then // PAR 12951 CNWRS1 Jan 2007
								if saveTrans &lt;&gt; null and
								   _camAgent.logExcludedTransactions then
									// we already had one but we won't be using it 
									_camAgent.logReasonForExclusion (saveTrans, '"Include gate in for those changed from Null voyage" is set. Looking for most recent Receival for EDIT ( ) - this transaction is not most recent CAMS receival/release'); // par 29601/2
								endif;
								
								saveTrans := trans;
							else
								if _camAgent.logExcludedTransactions then
									_camAgent.logReasonForExclusion (trans, '"Include gate in for those changed from Null voyage" is set. Looking for most recent Receival for EDIT ( ) - this transaction is not a CAMS receival/release'); // par 29601/2
								endif;
							endif;
						else
							if _camAgent.logExcludedTransactions then
								_camAgent.logReasonForExclusion (trans, '"Include gate in for those changed from Null voyage" is set. Looking for most recent Receival/Release for EDIT ( ) - this transaction does not match selected transactions for CAM protocol'); // par 29601/2
							endif;
						endif;
					endforeach;
					
					if saveTrans &lt;&gt; null then
						//FD for pars 4298 :The Edit may be done very recently,so the saveTrans might already be
						//processed in builFile before this
						if (saveTrans.dateTime &lt;= _camAgent.startDateTime) or (saveTrans.dateTime &gt;= _camAgent.endDateTime) then
							// receival will not already be in this file
							//beginLock; //par 22391 cnwrs1 24 Feb 2010	// PAR #34422
							app.cmsBeginLoad(loadState);
							receivalTrans := saveTrans.pxyCreateUpdateProxy();
							app.cmsEndLoad(loadState);
							//endLock;									// PAR #34422
							// update receival trasaction with new TI property values after EDIT
							receivalTrans.setFromNoInfoEdit(saveTrans.myTrackedItem, editTrans);
							if _camAgent.logIncludedTransactions then
								_camAgent.logReasonForInclusion(receivalTrans, "Transaction is for voyage change to be processed");
							endif;
							self.processTransaction(receivalTrans, _camProtocol, _camAgent, _camFile);	
							
							result := true;	// par 29601/2
							
							delete receivalTrans;
						else
							if _camAgent.logExcludedTransactions then
								_camAgent.logReasonForExclusion (saveTrans, '"Include gate in for those changed from Null voyage" is set. Looking for most recent Receival for EDIT ( ) - this transaction already falls within CAMS start/end dates'); // par 29601/2 
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;
	endforeach;
	
	if not isNullVoyageEdit then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion (_transaction, '"Include gate in for those changed from Null voyage" is set but EDIT transaction is not a change from Null voyage'); // par 29601/2 
		endif;
	endif;
	
	return result;
epilog
	
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="contentsStatusToString" id="89df38c0-883c-4092-ad72-dbbbded708b0">
        <source>contentsStatusToString(_contentsStatus: Integer; _activity: Integer; _type : Integer): String;
//
//
vars
	contentsString:String;
begin
	if _contentsStatus = TI_CONTENTS_STATUS_EMPTY then
		contentsString := "4";
	elseif _contentsStatus =TI_CONTENTS_STATUS_FCL then
		contentsString := "5";
	elseif _contentsStatus = TI_CONTENTS_STATUS_LCL then
		contentsString := "5";
	else
		contentsString := "6";
	endif;
	if contentsString = "5" and
	   _activity = CODECO_GATEOUT and
	   (_type = TRANS_TYPE_PACK or
	    _type = TRANS_TYPE_PackComplete) then
		contentsString := "4";
	endif;
	if contentsString = "4" and
	   _activity = CODECO_GATEOUT and
	   (_type = TRANS_TYPE_UNPACK or
	    _type = TRANS_TYPE_UnpackComplete) then
		contentsString := "5";
	endif;
	return contentsString;
end;</source>
        <Parameter name="_contentsStatus" type="Integer"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
