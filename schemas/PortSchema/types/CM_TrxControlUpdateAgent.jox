    <JadeMethod name="trxEDIUpdateBulkRelease" id="65e0c75d-9f5e-487b-b9d8-906618a2082f">
        <updating/>
        <source>trxEDIUpdateBulkRelease(_cmifRelease :CMIF_EDIReleaseRequest; _validateOnly : Boolean; _passport : CM_Passport input) updating;
// ----------------	-----------------------------------------------------------
// Created:     15 December 2011
//
// Purpose:     CCMS POL 2122 par 28696
//
// ---------------------------------------------------------------------------
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/02/2012	cnwcs5		par 28756 - new parameter in utlUpdateBulkRelease method
// 28/06/2012	cnwcs5		par 29847 - pass null in _realBooking parameter for utlUpdateBulkRelease
// 25/07/0213	cnwcs5		CCMS POL 2221 / par 32094 - change of signature
// 18/10/2017	jlgrs1		TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 25/07/2023	navdap1		TFS 58923 EUP CallOff EDI Data Type / Data Load
// ---------------------------------------------------------------------------
vars
	pxyRelease	: CM_BulkRelease;
	ediTI		: CM_EDITrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	app.myPassport.setWarningsIgnored(true);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	pxyRelease := _cmifRelease.myBulkRelease;
	
	app.setContinueCMExceptions(true);
		
	beginTransaction;

	app.myUtilityUA.utlUpdateBulkRelease(pxyRelease, null, true, null, _cmifRelease, _passport);		// TFS 58923
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors then
			// we can only update the EDI TI status if we know the trx will not be aborted
			foreach ediTI in _cmifRelease.allEDITIs do
				ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED);
			endforeach;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

end;
</source>
        <Parameter name="_cmifRelease" type="CMIF_EDIReleaseRequest"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxEDIUpdateCargoFromPrenote" id="4857c4dd-41ca-444e-abfe-637a4f74bd52">
        <updating/>
        <source>trxEDIUpdateCargoFromPrenote(_trackedItem : CM_TrackedItem input; _prenoteTI : CM_EDIPrenoteTI input; _passport : CM_Passport input ) updating;
// ---------------------------------------------------------------------------
// Created:	17 December 2009 By Graeme Black cnwgb1
// Status: 	PAR 21881 CCMS 1906 DCTGdansk
// Purpose:	On load of an IFTMIN file, a release PIN and Freight Forwarder 
//          may be added to a tracked item
// ---------------------------------------------------------------------------
//15 May 2013	cnwrs1	par31549 stop removal of unused options
// 25/07/0213	cnwcs5		CCMS POL 2221 / par 32094 - use CM_EDITrackedItem constants

vars
	passport					: CM_Passport;
	proxyTrackedItem			: CM_TrackedItem;
	ediOperatorStopReleasePin	: Boolean;
	stringPin					: String;
begin
	passport := _passport;
	// Always initialize the activity first
	self.initialiseActivityWithPassport(passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, passport);
	on LockException do agtPassportLockExHandler(exception, passport);

	ediOperatorStopReleasePin := _trackedItem.myOperator.getRequiresImpOperatorPIN;
	if ediOperatorStopReleasePin then //ccms1845
		beginTransaction;
		
		proxyTrackedItem := app.createUpdateProxy(_trackedItem).CM_TrackedItem;
		if proxyTrackedItem = null then
			return;
		endif;
		
		//CCMS1807 PAR19528 - cnwsh3 23/4/2009 Remove or add the Operator import pin based on the file function code.  
		if _prenoteTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
			proxyTrackedItem.setOperatorImportReleasePIN(null);
		else
			stringPin := _prenoteTI.getOperatorImportReleasePIN(); //cnwgb1	PAR 22349 28.6.2010
			if stringPin = null then
				// Do nothing - there wasn't a PIN in the file
			elseif stringPin = NULLImportPin then
				proxyTrackedItem.setOperatorImportReleasePIN(null); // null it as there was a RFF+RE with no value in an IFTMIN file
			else	
				proxyTrackedItem.setOperatorImportReleasePIN(stringPin); //Normal update
			endif;
			proxyTrackedItem.setFreightForwarder( _prenoteTI.freightForwarder );
		endif;
		app.myUtilityUA.utlUpdateTrackedItem(proxyTrackedItem, null, TI_UPDMODE_NORMAL, null,null, null, _passport);
		if _passport.noErrors then
			_prenoteTI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED);
		endif;
	endif;
	if _passport.noErrors then
		app.myUtilityUA.utlSetupEDIInfoTransaction(_trackedItem, _prenoteTI.rawEDIDataArray);	//par 27888 cnwrs1 05 Dec 2011
	endif;
epilog
	delete proxyTrackedItem;
	self.finaliseActivityWithPassport(passport);
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_prenoteTI" type="CM_EDIPrenoteTI" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxEndTaskForProtocol" id="31db7bf4-d192-45d0-88bf-b50d2e52969b">
        <updating/>
        <source>trxEndTaskForProtocol(_camAgent : CM_CamControllerAgent input; _camProtocol: CM_CamProtocol io; _passport: CM_Passport input)updating;
// ---------------------------------------------------------------------------
// Created:		20 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//17 May 2012	cnwrs1		Par 26914 - make cam task transient and remove camprotocol::camTask
//25 May 2012	cnwrs1		Par 26914 - make cams restart after lock error
//28 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
vars
	camObject : CM_Object;
	camProtocol : CM_CamProtocol;
	camTaskHistory	: CM_CamTaskHistory;	//25 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	camProtocol := _camProtocol;
	camObject := camProtocol;
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq[camProtocol, _camAgent.processSeqNumber];	//25 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
	beginTransaction;
	if _camAgent.isRestart or
	   _camAgent.isAdhoc then	//28 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
	else
		camProtocol.lastRunDateTime := _camAgent.endDateTime;	//17 May 2012	cnwrs1		Par 26914 - setup the lastRunDateTime at the end of the process
	endif;
	if camProtocol.status &lt;&gt; CAM_IDLESTATUS then
		app.myUtilityUA.utlUpdateCamObjectStatus(camObject, CAM_IDLESTATUS, _passport);
	endif;
	if camTaskHistory &lt;&gt; null then	//25 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
		camObject := camTaskHistory;
		app.myUtilityUA.utlUpdateCamObjectStatus(camObject, CAM_COMPLETESTATUS, _passport);
	endif;
//	app.myUtilityDA.utlDeleteCamTask(_camTask, _passport);	

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
