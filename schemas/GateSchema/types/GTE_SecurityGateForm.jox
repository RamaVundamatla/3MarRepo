    <JadeMethod name="enableMenuToolbarItems" id="b52c370a-fce5-4bc0-a68c-3e6a4758288e">
        <source>enableMenuToolbarItems(_vvr : CM_VehicleVisitRecord);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/01/2014	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Secuity Gate
//
vars

begin
	self.mnuCancelVisit.enabled := false;
	self.mnuDeparture.enabled := false;
	
	// ### TFS 51994 01Oct2021 NAVPW1
	if _vvr = null then 
		return;
	endif;
	// ### TFS 51994 01Oct2021 NAVPW1
	
	if _vvr.isUpdatable then
		self.mnuCancelVisit.enabled := true;
	endif;
	if _vvr.getReadyToLeaveTime &lt;&gt; null or _vvr.getRoadExitTime &lt;&gt; null or (_vvr.getArrivalAtGateInTime = null and _vvr.getArrivalAtYardIC = null) then
		self.mnuDeparture.enabled := true;
	endif;
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="cc867379-440b-44e8-8858-0d76d68e65c4">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/01/2014	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
// 26 Oct 2016	cnwkpd1		TFS #2818 - Improve form load performance

vars
	xmlStr			: String;
	gate 			: CM_Gate;	

begin
	xmlStr := inheritMethod();
	xmlStr := xmlStr &amp; self.tblData.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; global.formatAsXML(self.XML_SearchDays, self.txtSearchDays.text);
	
	return xmlStr;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleSystemNotification" id="e669c943-df32-4c08-978b-79d303a97dd6">
        <updating/>
        <source>handleSystemNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
// 13/03/2014	cnwdap1		PAR #33716 Some notifications will be on CM_VehicleVisitRecordDetail objects
// 25/02/2025	naviv1		JIRA-29374- EUP | Transaction Instrumentation - Gate
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	vvr			: CM_VehicleVisitRecord;
	terminal 	: CM_Terminal;
	localType	: Integer;
	invalid		: Boolean;
begin
	
	if _theObject = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _theObject, invalid);
	
	_theObject.edition;
	
	if invalid then
		return;
	endif;
	
	localType := self.myTerminal.getEventFromTerminalEvent(_eventType);
	
	if _eventType = Object_Update_Event	or _eventType = Object_Create_Event or localType = EVENT_VEHICLEVISIT_UPDATE or localType = EVENT_VEH_VISIT_TRANSACTION then
		if _theObject.isKindOf(CM_VehicleVisitRecord) then
			vvr := _theObject.CM_VehicleVisitRecord;
		elseif _theObject.isKindOf(CM_VehicleVisitRecord) then						// PAR #33716
			vvr := _theObject.CM_VehicleVisitRecordDetail.myVehicleVisitRecord;		// PAR #33716
		endif;
		
		terminal := vvr.myTerminal;													// PAR #33716
		if terminal = null or terminal &lt;&gt; self.myTerminal then						// PAR #33716
			return;																	// PAR #33716
		endif;																		// PAR #33716
		
		if vvr.status = vvr.Status_Cancelled or not vvr.isIncompleteForSecurityGate then
			self.tblData.removeDeletedObject(_theObject);
		else
			self.tblData.updateItemObject(_theObject.CM_Object, self.colorRow1, self.colorRow2, app.myPassport);
		endif;
		
	elseif _eventType = Object_Delete_Event then
		self.tblData.removeDeletedObject(_theObject);
		
	elseif localType = Object_Delete_Event then 		// ### TFS 51994 01Oct2021 NAVPW1
		self.tblData.removeDeletedObject(_theObject);	// ### TFS 51994 01Oct2021 NAVPW1
	endif;
	
	// enable/disable the edit and cancel buttons / menus according to the selected table row
	vvr := self.tblData.allSelectedObjects.first.CM_VehicleVisitRecord;
	self.enableMenuToolbarItems(vvr);
	
	self.statusLine.caption := (self.tblData.rows-self.tblData.fixedRows).String &amp; ' rows found.';			
epilog
	
end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="a8d083f4-f6fd-4f25-8a30-25b35d5c7cf7">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2016	cnwkpd1	TFS 488 - Multi Timezone Support


*/

vars
	searchDays		: String;
	
begin
	inheritMethod(_userWindow);
	
	if _userWindow = null then
		return;
	endif;
	
	searchDays := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_SearchDays).String;
	if searchDays &lt;&gt; null and searchDays.isInteger() then
		self.txtSearchDays.text := searchDays;
	endif;
		
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblData" id="4198bf1d-05cd-45c2-bcf9-183b79de18c4">
        <source>initTblData();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
// 15/05/2014	cnwdap1		PAR #34117 Security Gate
//
vars
	col : Integer;			// PAR #34117
	text : String;			// PAR #34117

begin
	self.tblData.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_SecurityGate));
	self.tblData.userInputEnabled := false;
	self.tblData.selectMode := Table.SelectMode_CurrentRow;
	self.tblData.selectionType := CM_DataTable.SelectionType_Row;
	self.tblData.multiSelect := self.tblData.MultiSelect_None;
	self.tblData.stretchWidth := true;
	self.tblData.stretchHeight := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="0d3cb9fd-93b1-417a-b034-b869cf33edc7">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
// 26 Oct 2016	cnwkpd1		TFS #2818 - Improve form load performance
// 25/02/2025	naviv1		JIRA-29374- EUP | Transaction Instrumentation - Gate
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	vvr			: CM_VehicleVisitRecord;
	failedDAC	: CM_DataAccessController;
	str			: String;
	idx			: Integer;
	backColour	: Integer;
	startTime	: TimeStamp;
	iter		: Iterator;
begin
	self.endNotificationForSubscriber(self);
	
	self.beginClassNotification(CM_VehicleVisitRecord, false, self.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), Response_Continuous, 0);
	self.beginClassNotification(CM_VehicleVisitRecord, false, self.myTerminal.getTerminalEvent(EVENT_VEH_VISIT_TRANSACTION), Response_Continuous, 0);
	
	self.tblData.rows := self.tblData.fixedRows;
	
	startTime := null;
	startTime.setDate(app.actualTimeServer.Date - self.txtSearchDays.text.Integer);
	
	// load all incomplete vehicle visit records into the table, starting from the calculated start time
	iter := self.myTerminal.allVehicleVisits.createIterator();
	self.myTerminal.allVehicleVisits.startKeyGeq(startTime, iter);
	
	while iter.next(vvr) do
		if not vvr.isIncompleteForSecurityGate() then
			continue;
		endif;
	
		if not vvr.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
			continue;
		endif;
		
		str := vvr.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		idx := self.tblData.addItemObject(vvr, str);
		
		self.beginNotification(vvr, self.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), Response_Continuous, 0);
		self.beginNotification(vvr, self.myTerminal.getTerminalEvent(EVENT_VEH_VISIT_TRANSACTION), Response_Continuous, 0);
		self.beginNotification(vvr, self.myTerminal.getTerminalEvent(Object_Delete_Event), Response_Continuous, 0); // ### TFS 51994 01Oct2021 NAVPW1
		if idx mod 2 = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;			
		self.tblData.accessRow(idx).backColor := backColour;
	endwhile;
	
	// select the first row by default
	if self.tblData.rows &gt; self.tblData.fixedRows then
		self.tblData.clearAllSelected(); // ### TFS 51994 07Oct2021 NAVPW1
		self.tblData.accessRow(self.tblData.fixedRows + 1).selected := true;
	else
		self.btnDeparture.enabled := false;
		self.btnDelete.enabled := false;
	endif;

	self.statusLine.caption := (self.tblData.rows-self.tblData.fixedRows).String &amp; ' rows found.';			

epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
