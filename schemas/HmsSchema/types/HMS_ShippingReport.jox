    <JadeMethod name="setupForwardShippingReport" id="f9f25159-23a8-4564-b859-faec6bfb1c7a">
        <updating/>
        <source>setupForwardShippingReport() updating;
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 14/09/2012	cnwdap1		PAR #30248 Correct spelling of STEVEDORE
//
vars
	columnWidths : IntegerArray;
	columnText	 : StringArray;
	int			 : Integer;
begin

	create columnWidths transient;
	create columnText	transient;


	//AJA 22/11/00: Rearrange order of report columns
	columnText[01]   := 'VESSEL NAME';
	columnWidths[01] := 100;

	columnText[02]   := 'ETA';
//	columnWidths[02] := 65;		//ETA
	columnWidths[02] := 75;		//ETA//changed by cnwyl for PAR 12329
	
	columnText[03]   := 'PLANNED BERTH';		//AJA 19/9/00
	columnWidths[03] := 65;

	columnText[04]   := 'VOY No.';
	columnWidths[04] := 60;

	columnText[05]   := 'G.R.T';
	columnWidths[05] := 40;

	columnText[06]   := 'L.O.A';
	columnWidths[06] := 40;

	columnText[07]   := 'AGENT';
	columnWidths[07] := 95;

	columnText[08]   := 'CARGO 
(DISCHARGE)';
	columnWidths[08] := 100;

	columnText[09]   := 'CARGO
(LOAD)';
	columnWidths[09] := 100;

	//columnText[10]   := 'STVEDORE/S 					// PAR #30248
	columnText[10]   := 'STEVEDORE/S 
(DISCHARGE)';
	columnWidths[10] := 85; // Stevedores to discharge

	//columnText[11]   := 'STVEDORE/S					// PAR #30248
	columnText[11]   := 'STEVEDORE/S
(LOAD)';
	columnWidths[11] := 85; // Stevedores to load

	columnText[12]   := 'LAST PORT';
	columnWidths[12] := 75;

	columnText[13]   := 'NEXT PORT';
	columnWidths[13] := 75;

	columnText[14]   := 'WWD';
	columnWidths[14] := 35;



	// setup the header table
	setReportTables(tableHeader,columnWidths,columnText);

	// setup the body table
	columnText.clear;
	columnText[columnWidths.size] := null;
	setReportTables(tableBody,columnWidths,columnText);
epilog
	delete columnWidths;
	delete columnText;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupShippingReport" id="971b8e6a-01c1-4811-bd0c-190bc6255b43">
        <updating/>
        <source>setupShippingReport()updating;

vars
	columnWidths : IntegerArray;
	columnText	 : StringArray;
	int			 : Integer;
begin

	create columnWidths transient;
	create columnText	transient;

	columnWidths[01] := 100;
	columnWidths[02] := 75;
	columnWidths[03] := 110;
	columnWidths[04] := 100;
	columnWidths[05] := 50;
	columnWidths[06] := 70;
//	columnWidths[07] := 70;changed by cnwyl1 for par 12329
//	columnWidths[08] := 70;
	columnWidths[07] := 80;
	columnWidths[08] := 80;
	columnWidths[09] := 105;
	columnWidths[10] := 105;
	columnWidths[11] := 80;
	columnWidths[12] := 80;


	columnText[01]   := 'VESSEL NAME';
	// Modified by Russell 06/04/99
	// --------------------------------------------------------------
	// columnText[02]   := 'VOYAGE CODE';
	columnText[02]   := 'VOYAGE No.';
	// --------------------------------------------------------------
	columnText[03]   := 'AGENT';
	columnText[04]   := 'STEVEDORE/S';
	columnText[05]   := 'BERTH';
	columnText[06]   := 'PHONE';
	columnText[07]   := 'ARRIVES';
	columnText[08]   := 'DEPARTS';
	columnText[09]   := 'CARGO
(DISCHARGE)';
	columnText[10]   := "CARGO
(LOAD)";
	columnText[11]   := 'LAST PORT';
	columnText[12]   := 'NEXT PORT';

	// setup the header table
	setReportTables(tableHeader,columnWidths,columnText);

	// setup the body table
	columnText.clear;
	columnText[columnWidths.size] := null;
	setReportTables(tableBody,columnWidths,columnText);
epilog
	delete columnWidths;
	delete columnText;
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="7af55220-7efe-407a-9ae3-934cd8be2c27">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars
	sm:CnSmtpConnection;
begin
	sm := theObject.CnSmtpConnection;

	// Show a message box if an error occurred
	if sm.result.bitAnd(CnSmtpConnection.Error_Occurred) &lt;&gt; null then
		app.msgBox(sm.extendedErrorText,  "SMTP Error " &amp; sm.errorCode.String, MsgBox_OK_Only);
	endif;

delete sm;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="writeHTMLReportToFile" id="73ef1de4-9e38-4d35-a9d8-f41fee6d4361">
        <updating/>
        <source>writeHTMLReportToFile(sendEmail : Boolean; _emailGroup : CM_EmailGroup) updating;
/*AA 9/7/01

Tauranga enhancement to create the shipping report as a formatted HTML
file instead of the old csv file. Can be e-mailed to distribution
list if required.

Creates an HTML file on the fly by building up the report from a series
of HTML template string constants and saving the resulting HTML code as a file

Changed On	By			Reason
----------	--------	--------------------------------------------------
19/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
*/
vars
	iter: 					Iterator;
	term: 					CM_Terminal;
	voyage: 				CM_Voyage;
	htmlFileString: String;
	htmlStr: String;
	usr : String;
	now : TimeStamp;
	f: File;
	str : String;
	shadeLine : Boolean;
	reportLine : StringArray;
	shadeColour : String;
	int: 					Integer;
	ok: 					Boolean;
	textFileLines: 			HMS_TextFileLineArray;
	fileIO:					CMIF_HMS_FileIO;
	fileName:				String;
	thisHarbour			: String; 
begin
	// This method is called when it is required to create the shipping report
	// as an HTML file rather than a printout

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
    app.mousePointer := MousePointer_HourGlass;
    shadeColour := '#D3D3D3';		//Light Grey
	if self.myHarbour &lt;&gt; null then
		thisHarbour := self.myHarbour.description;
	else
		thisHarbour := "Harbour";
	endif;

	//Gte the initial report header HTML code and substitute tags
	htmlStr := HtmlHeader;
	htmlStr := htmlStr.replaceString("PORT_NAME_TAG", thisHarbour);//"Port of Tauranga"); 

	if app.getMyUser &lt;&gt; null then
		usr := app.getMyUser.userName;
	else
		usr := '** User Not Defined **';
	endif;	

	htmlStr := htmlStr.replaceString("USER_TAG", usr); 
	htmlStr := htmlStr.replaceString("REPORT_DATE_TAG", now.String); 

	//Add this portion of HTML to our file code
	htmlFileString := htmlStr;

	// Generate the report body
	if portDate_From &lt;&gt; null then
		headText := portDate_From.date.String &amp; ' - ' &amp; portDate_From.Time.userFormat($CM_HMS_Time24Hour);
		pFirstTimeStamp:=portDate_From;
		pSecondTimeStamp:=portDate_To;
		pType:=0;
		// Build the section - Vessels in port at....
		// ------------------------------------------------------------------------------
		//Substitute title in table header code
		htmlStr := HtmlInPortTableHeader;
		htmlStr := htmlStr.replaceString('IN_DATE_TAG', portDate_From.date.String &amp; ' - ' &amp; portDate_From.Time.userFormat($CM_HMS_Time24Hour));
		htmlFileString := htmlFileString &amp; htmlStr;

		// Add Section Body
		create textFileLines transient;
		//buildSectionForReportToFile(textFileLines);		//Get the report body output
		self.printShippingReport(textFileLines);
		
	
		foreach reportLine in textFileLines do
			htmlStr := HtmlInPortTableBody;
			//Shade alternate lines
			if shadeLine = true then
				htmlStr := htmlStr.replaceString('#FFFFFF', shadeColour);
				shadeLine := false;
			else
		   		shadeLine := true;
			endif;
			if reportLine.size &lt;&gt; 12 then
				continue;
			endif;
			htmlStr := htmlStr.replaceString('IN_VSL', reportLine[1]);
			htmlStr := htmlStr.replaceString('IN_VOY', reportLine[2]);
			htmlStr := htmlStr.replaceString('IN_AGT', reportLine[3]);
			htmlStr := htmlStr.replaceString('IN_SDORE', reportLine[4]);
			htmlStr := htmlStr.replaceString('IN_BRTH', reportLine[5]);
			htmlStr := htmlStr.replaceString('IN_TEL', reportLine[6]);
			htmlStr := htmlStr.replaceString('IN_ARR', reportLine[7]);
			htmlStr := htmlStr.replaceString('IN_DEP', reportLine[8]);
			htmlStr := htmlStr.replaceString('IN_DISCH', reportLine[9]);
			htmlStr := htmlStr.replaceString('IN_LOAD', reportLine[10]);
			htmlStr := htmlStr.replaceString('IN_LAST', reportLine[11]);
			htmlStr := htmlStr.replaceString('IN_NEXT', reportLine[12]);
            htmlFileString := htmlFileString &amp; htmlStr;
		endforeach;

		//Add final HTML table &amp; table footer to HTML file code
		htmlFileString := htmlFileString &amp; HtmlInPortTableFooter;
	endif;

    if arriveDate_From &lt;&gt; null then
		pFirstTimeStamp:=arriveDate_From;
		pSecondTimeStamp:=arriveDate_To;
		// Build this section - Vessels arriving between start and end dates
		// ------------------------------------------------------------------------------
		//Do Header
		htmlStr := HtmlArrivalTableHeader;
		htmlStr := htmlStr.replaceString('ARR_DATE_TAG', arriveDate_From.date.String &amp; ' - ' &amp; arriveDate_To.date.String);
		htmlFileString := htmlFileString &amp; htmlStr;

		// Add Section Body
		if textFileLines = null then
			create textFileLines transient;
		else
			textFileLines.clear;
		endif;
		shadeLine := false;
		self.printForwardShippingReport(textFileLines);
		foreach reportLine in textFileLines do
			htmlStr := HtmlArrivalTableBody;
			if shadeLine = true then
				htmlStr := htmlStr.replaceString('#FFFFFF', shadeColour);
				shadeLine := false;
			else
		    	shadeLine := true;
			endif;
			htmlStr := htmlStr.replaceString('ARR_VSL', reportLine[1]);
			htmlStr := htmlStr.replaceString('ARR_ETA', reportLine[2]);
			htmlStr := htmlStr.replaceString('ARR_BRTH', reportLine[3]);
			htmlStr := htmlStr.replaceString('ARR_VOY', reportLine[4]);
			htmlStr := htmlStr.replaceString('ARR_GRT', reportLine[5]);
			htmlStr := htmlStr.replaceString('ARR_LOA', reportLine[6]);
			htmlStr := htmlStr.replaceString('ARR_AGT', reportLine[7]);
			htmlStr := htmlStr.replaceString('ARR_DCARGO', reportLine[8]);
			htmlStr := htmlStr.replaceString('ARR_LCARGO', reportLine[9]);
			htmlStr := htmlStr.replaceString('ARR_DSDORE', reportLine[10]);
			htmlStr := htmlStr.replaceString('ARR_LSDORE', reportLine[11]);
			htmlStr := htmlStr.replaceString('ARR_LAST', reportLine[12]);
			htmlStr := htmlStr.replaceString('ARR_NEXT', reportLine[13]);
			htmlStr := htmlStr.replaceString('ARR_WWD', reportLine[14]);
            htmlFileString := htmlFileString &amp; htmlStr;
		endforeach;

		//Add Table footer
		htmlFileString := htmlFileString &amp; HtmlArrivalTableFooter;

	endif;

	if departDate_From &lt;&gt; null then
		//;
		pFirstTimeStamp:=departDate_From;
		pSecondTimeStamp:=departDate_To;
		pType:=1;
		// Build this section - Vessels departed port between start and end dates.
		// ------------------------------------------------------------------------------
		//Do Header
		htmlStr := HtmlDepartureTableHeader;
		htmlStr := htmlStr.replaceString('OUT_DATE_TAG', departDate_From.date.String &amp; ' - ' &amp; departDate_To.date.String);
		htmlFileString := htmlFileString &amp; htmlStr;

		// Add Section Body
		if textFileLines = null then
			create textFileLines transient;
		else
			textFileLines.clear;
		endif;
		
		shadeLine := false;

		//buildSectionForReportToFile(textFileLines);
		self.printShippingReport(textFileLines);
				
		foreach reportLine in textFileLines do
			htmlStr := HtmlDepartureTableBody;
			if shadeLine = true then
				htmlStr := htmlStr.replaceString('#FFFFFF', shadeColour);
				shadeLine := false;
			else
		    	shadeLine := true;
			endif;
			htmlStr := htmlStr.replaceString('OUT_VSL', reportLine[1]);
			htmlStr := htmlStr.replaceString('OUT_VOY', reportLine[2]);
			htmlStr := htmlStr.replaceString('OUT_AGT', reportLine[3]);
			htmlStr := htmlStr.replaceString('OUT_SDORE', reportLine[4]);
			htmlStr := htmlStr.replaceString('OUT_BRTH', reportLine[5]);
			htmlStr := htmlStr.replaceString('OUT_TEL', reportLine[6]);
			htmlStr := htmlStr.replaceString('OUT_ARR', reportLine[7]);
			htmlStr := htmlStr.replaceString('OUT_DEP', reportLine[8]);
			htmlStr := htmlStr.replaceString('OUT_DISCH', reportLine[9]);
			htmlStr := htmlStr.replaceString('OUT_LOAD', reportLine[10]);
			htmlStr := htmlStr.replaceString('OUT_LAST', reportLine[11]);
			htmlStr := htmlStr.replaceString('OUT_NEXT', reportLine[12]);
            htmlFileString := htmlFileString &amp; htmlStr;
		endforeach;

		//Add Table footer
		htmlFileString := htmlFileString &amp; HtmlDepartureTableFooter;

		// ------------------------------------------------------------------------------
	endif;	

  	//Finish off HTML file with footer
  	htmlFileString := htmlFileString &amp; HtmlFooter;

	// Generate HTML output file
	create fileIO transient;

	// Set default directory path and filenames
	if self.myHarbour.pathShippingReportFile &lt;&gt; null then
		fileIO.defaultPath:=self.myHarbour.pathShippingReportFile;
	else
		fileIO.defaultPath := "c:\temp";
	endif;

	if self.myHarbour.defFileNameShipRpt &lt;&gt; null then
		fileIO.defaultFileName:=self.myHarbour.defFileNameShipRpt;
	else
		fileIO.defaultFileName:="HMS_ShippingReport";
	endif;

	//Generate the HTML file using the HTML code produced in this method
	fileName := fileIO.writeHTMLFile(htmlFileString);

    if sendEmail = true then
    	sendEMailToDistributionList(fileName, _emailGroup);
	endif;

epilog
	//endLock;			// PAR #34422
	delete f;
	//textFileLines.purge;
	delete textFileLines;
	delete fileIO;
    app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="sendEmail" type="Boolean"/>
        <Parameter name="_emailGroup" type="CM_EmailGroup"/>
    </JadeMethod>
    <JadeMethod name="writeReportToFile" id="dcb3e189-443d-4a75-abb5-d3d3953953d4">
        <updating/>
        <source>writeReportToFile(sendEmail : Boolean; _emailGroup : CM_EmailGroup) updating;

/*

Date		Who		Reason
23 Nov 2011	cnwkpd1	PAR #28731 - fix transient leaks
14 Sep 2012	cnwdap1	PAR #30248 - Correct hard-coded harbour in heading, and spelling error, and stop error 4s in epilog
								 when deleting StringArrays that have already been purged
19/06/2014	cnwdap1	PAR #34422 Remove beginLock / endLock
*/

vars
	iter: 					Iterator;
	term: 					CM_Terminal;
	voyage: 				CM_Voyage;
	reportHeader:			StringArray;
	sectionHeader1:			StringArray;
	sectionHeader2:			StringArray;
	sectionHeader3:			StringArray;
	shipReportHeadings1:	StringArray;
	shipReportHeadings2:	StringArray;
	fwdShipReportHeadings:	StringArray;
	blankLine1:				StringArray;
	blankLine2:				StringArray;
	blankLine3:				StringArray;
	blankLine4:				StringArray;
	int: 					Integer;
	ok: 					Boolean;
	textFileLines: 			HMS_TextFileLineArray;
	fileIO:					CMIF_HMS_FileIO;
	fileName:				String;
	harbourString:			String;			// PAR #30248
begin
	// This method is called when it is required to create the shipping report
	// as a delimited text file rather than a printout

	// Create the container to hold lines of text for delimited output file
	create textFileLines transient;

	// Create report header
	create reportHeader transient;
	if self.myHarbour &lt;&gt; null then									// PAR #30248
		harbourString := self.myHarbour.description;				// PAR #30248
	else															// PAR #30248
		harbourString := "Harbour";									// PAR #30248
	endif;															// PAR #30248
	//reportHeader.add("Port of Tauranga - 'SHIPPING REPORT'"); 	// PAR #30248
	reportHeader.add(harbourString &amp; " - 'SHIPPING REPORT'"); 		// PAR #30248

	// Create a blank line to add between sections
	create blankLine1 transient;
	blankLine1.add("  ");

	// Create section headings for shipping report
	create shipReportHeadings1 transient;
	shipReportHeadings1.add("VESSEL NAME");
	shipReportHeadings1.add("VOYAGE No.");
	shipReportHeadings1.add("AGENT");
	shipReportHeadings1.add("STEVEDORE/S");
	shipReportHeadings1.add("BERTH");
	shipReportHeadings1.add("PHONE");
	shipReportHeadings1.add("ARRIVES");
	shipReportHeadings1.add("DEPARTS");
	shipReportHeadings1.add("CARGO (DISCHARGE)");
	shipReportHeadings1.add("CARGO (LOAD)");
	shipReportHeadings1.add("LAST PORT");
	shipReportHeadings1.add("NEXT PORT");


	// Create section headings for FORWARD shipping report
	create fwdShipReportHeadings transient;
	fwdShipReportHeadings.add("VESSEL NAME");
	fwdShipReportHeadings.add("ETA");			//AJA 22/11/00
	fwdShipReportHeadings.add("PLANNED BERTH");			//AJA 19/5/00
	fwdShipReportHeadings.add("VOY No.");
	fwdShipReportHeadings.add("G.R.T");
	fwdShipReportHeadings.add("L.O.A");
	fwdShipReportHeadings.add("AGENT");
	fwdShipReportHeadings.add("CARGO (DISCHARGE)");
	fwdShipReportHeadings.add("CARGO (LOAD)");
	//fwdShipReportHeadings.add("STVEDORE/S (DISCHARGE)");		// PAR #30248
	//fwdShipReportHeadings.add("STVEDORE/S (LOAD)");			// PAR #30248
	fwdShipReportHeadings.add("STEVEDORE/S (DISCHARGE)");		// PAR #30248
	fwdShipReportHeadings.add("STEVEDORE/S (LOAD)");			// PAR #30248
	fwdShipReportHeadings.add("LAST PORT");
	fwdShipReportHeadings.add("NEXT PORT");
	fwdShipReportHeadings.add("WWD");

	// Create a blank line to add between sections
	create blankLine2 transient;
	blankLine2.add("  ");

    // Generate the report header
    textFileLines.add(reportHeader);
	// Add blank line at end of section
	textFileLines.add(blankLine1);



	// Generate the report body
	if portDate_From &lt;&gt; null then
		headText := 'Vessels in Port at ' &amp; portDate_From.date.String &amp; ' - ' &amp; portDate_From.Time.userFormat($CM_HMS_Time24Hour);
		pFirstTimeStamp:=portDate_From;
		pSecondTimeStamp:=portDate_To;
		pType:=0;
		// Build this section - Vessels in port at....
		// ------------------------------------------------------------------------------
		// Add Header for section eg: "Vessels in Port at 20 February 1999 - 00:00"
		create sectionHeader1 transient;
		sectionHeader1.add(headText);
		textFileLines.add(sectionHeader1);
		// Add Section Column Headings eg: "Vessel Name		Voy Num			Agent...."
		textFileLines.add(shipReportHeadings1);
		// Add Section Body
		//buildSectionForReportToFile(textFileLines);
		self.printShippingReport(textFileLines);		
		// Add blank line at end of section
		textFileLines.add(blankLine2);
		// ------------------------------------------------------------------------------
	endif;

    if arriveDate_From &lt;&gt; null then
		headText := 'Expected Arrivals: ' &amp; arriveDate_From.date.String &amp; ' - ' &amp; arriveDate_To.date.String;
		pFirstTimeStamp:=arriveDate_From;
		pSecondTimeStamp:=arriveDate_To;
		// Build this section - Vessels in port at....
		// ------------------------------------------------------------------------------
		// Add Header for section eg: "Expected Arrivals between 20 February 1999 - 28 February 1999"
		create sectionHeader3 transient;
		sectionHeader3.add(headText);
		textFileLines.add(sectionHeader3);
		// Add Section Column Headings eg: "Vessel Name		Voy Num			Agent...."
		textFileLines.add(fwdShipReportHeadings);
		// Add Section Body
		self.printForwardShippingReport(textFileLines);
		// Add blank line at end of section
		create blankLine4 transient;
		blankLine1.copy(blankLine4);
		textFileLines.add(blankLine4);
		// ------------------------------------------------------------------------------
	endif;

	if departDate_From &lt;&gt; null then
		headText := 'Vessels Departed: ' &amp; departDate_From.date.String &amp; ' - ' &amp; departDate_To.date.String;
		pFirstTimeStamp:=departDate_From;
		pSecondTimeStamp:=departDate_To;
		pType:=1;
		// Build this section - Vessels in port at....
		// ------------------------------------------------------------------------------
		// Add Header for section eg: "Vessels Departed between 20 February 1999 - 28 February 1999"
		create sectionHeader2 transient;
		sectionHeader2.add(headText);
		textFileLines.add(sectionHeader2);
		// Add Section Column Headings eg: "Vessel Name		Voy Num			Agent...."
		create shipReportHeadings2 transient;
		shipReportHeadings1.copy(shipReportHeadings2);			
		textFileLines.add(shipReportHeadings2);
		// Add Section Body
		//buildSectionForReportToFile(textFileLines);
		self.printShippingReport(textFileLines);		
		// Add blank line at end of section
		create blankLine3 transient;
		blankLine1.copy(blankLine3);
		textFileLines.add(blankLine3);
		// ------------------------------------------------------------------------------
	endif;	

	// Generate output file
	create fileIO transient;
	// Set default directory path and filenames
	// Set default directory path and filenames

	if self.myHarbour.pathShippingReportFile &lt;&gt; null then
		fileIO.defaultPath:=self.myHarbour.pathShippingReportFile;
	else
		fileIO.defaultPath := "c:\temp";
	endif;

	if self.myHarbour.defFileNameShipRpt &lt;&gt; null then
		fileIO.defaultFileName:=self.myHarbour.defFileNameShipRpt;
	else
		fileIO.defaultFileName:="HMS_ShippingReport";
	endif;

	fileName := fileIO.writeTextFile(textFileLines,DelimiterType_Comma);

    if sendEmail = true then
    	sendEMailToDistributionList(fileName, _emailGroup);
	endif;

epilog
	//endLock;					// PAR #34422
	textFileLines.purge;
	delete textFileLines;
	delete fileIO;
	//delete blankLine1;		// PAR #28731 	// PAR #30248
	//delete blankLine2;						// PAR #30248
	//delete blankLine3;						// PAR #30248
	//delete blankLine4;						// PAR #30248
	//delete fwdShipReportHeadings;				// PAR #30248
	//delete reportHeader;						// PAR #30248
	//delete sectionHeader1;					// PAR #30248
	//delete sectionHeader2;					// PAR #30248
	//delete sectionHeader3;					// PAR #30248
	//delete shipReportHeadings1;				// PAR #30248
	//delete shipReportHeadings2;				// PAR #30248
end;</source>
        <Parameter name="sendEmail" type="Boolean"/>
        <Parameter name="_emailGroup" type="CM_EmailGroup"/>
    </JadeMethod>
    <JadeMethod name="xHandler" id="de1ee3a9-7222-4347-9d6c-d7d36e53ea94">
        <source>xHandler(exObj : Exception input; _receiveMailIDS : IDS_Server input) : Integer;
//---------------------------------------
// Created: 4 March 2004 By: cnwgd1
//---------------------------------------
vars
	err, mailSystem,
	errDecode,
	errDecodeAPI		: Integer;
	errMessage,
	str,
	detail				: String;
	pos					: Integer;
	connection			: CnSmtpConnection;
begin

	if exObj.errorCode = 14181 and _receiveMailIDS &lt;&gt; null then
		pos := (exObj.extendedErrorText.pos('=', 1) + 1);
		if pos &lt;&gt; 0 then
			str := exObj.extendedErrorText[pos : end];
			err := str.Integer;
			// It is a communications error with pop server.
			if err = -21472154477 then
				app.writeLog(err.String &amp; ' (communications error with pop server) ' &amp; exObj.extendedErrorText, LogINFO);			
				return Ex_Resume_Next;
			endif;
			_receiveMailIDS.decodeError( err, mailSystem, errDecode, errDecodeAPI, errMessage);
			if errMessage.length &gt; 0 then
				detail := 'OCX Error Message ' &amp; err.String &amp; ' (' &amp;  errMessage &amp; ')';
				app.writeLog(detail, LogINFO);
				exObj.extendedErrorText := detail;
				return Ex_Pass_Back;
			endif;
		endif;
		// File in use by another process.
		app.writeLog(exObj.errorCode.String &amp; ' (File in use by another process) ' &amp; exObj.extendedErrorText, LogINFO);		
	elseif exObj.errorCode = 5030 then
		app.writeLog(exObj.errorCode.String &amp; ' ' &amp; exObj.extendedErrorText, LogINFO);	
		return Ex_Resume_Next;
	endif;

	app.writeLog(exObj.errorCode.String &amp; ' ' &amp; exObj.extendedErrorText, LogINFO);	
	return Ex_Pass_Back; 

end;</source>
        <Parameter name="exObj" type="Exception" usage="input"/>
        <Parameter name="_receiveMailIDS" type="IDS_Server" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
