    <JadeMethod name="setupCarrierCombo" id="f3c50a85-d8d7-4e76-9736-abec57707dbd">
        <updating/>
        <source>setupCarrierCombo()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	carrier : CM_Carrier;
	driver : CM_DriverDetails;
	vehicle : CM_Vehicle;
	failedDAC  :CM_DataAccessController;
	msg : String;

begin

	self.myFilterCarrier := self.cmbCarrier.listObject.CM_Carrier;
	if self.myFilterCarrier &lt;&gt; null then
		self.myFilterDriver := self.cmbDriver.listObject.CM_DriverDetails;
		self.myFilterVehicle := self.cmbVehicle.listObject.CM_Vehicle;
	else
		self.myFilterDriver := null;
		self.myFilterVehicle := null;
	endif;
	
	self.cmbCarrier.clear();
	
	if self.permissionView = PmGteVehSchWeb then
		foreach carrier in app.myRoot.allCarriersRoad where not carrier.isNotAvailableForEntry do
			if (not carrier.canUserAccessSelf(null, failedDAC, app.myPassport)) then
				continue;
			endif;
			self.cmbCarrier.itemObject[self.cmbCarrier.addItem( carrier.code &amp; Tab &amp; carrier.description )] := carrier;
		endforeach;
		if self.cmbCarrier.listCount &lt; 1 then
			msg := app.getErrorString1(Curre_user_acces_only_not_asso, app.getMyUser.getPermissionNameFromInteger(PmGteVehSchWeb) );
			app.msgBox(msg,app.getErrorString(Error), MsgBox_OK_Only);
			self.unloadForm();
			return;
		endif;
		
	else
		foreach carrier in app.myRoot.allCarriersRoad where not carrier.isNotAvailableForEntry do
			self.cmbCarrier.itemObject[self.cmbCarrier.addItem( carrier.code &amp; Tab &amp; carrier.description )] := carrier;
		endforeach;
		self.cmbCarrier.addItem( app.getErrorString(AnyString) );
		
	endif;
	
	if self.myFilterCarrier &lt;&gt; null then
		self.cmbCarrier.listIndex := self.cmbCarrier.findObject(self.myFilterCarrier);
		if self.cmbCarrier.listIndex  &lt; 1 then
			self.cmbCarrier.listIndex := 1;
			self.myFilterCarrier := null;
		endif;
	elseif self.myFilterCarrier = null then
		self.cmbCarrier.listIndex := 1;
	endif;
	
	self.setupDriverCombo();
	
	self.setupVehicleCombo();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupDriverCombo" id="62819419-8e96-4226-b44c-3bb9c066567d">
        <updating/>
        <source>setupDriverCombo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	iter : Iterator;
	driver : CM_DriverDetails;

begin

	self.cmbDriver.clear();

	if self.myFilterCarrier &lt;&gt; null then
		iter := self.myFilterCarrier.allDrivers.createIterator;
	else
		iter := self.myTerminal.allDriversbyName.createIterator;
	endif;
	
	while iter.next( driver ) do
		if driver.myTerminal = self.myTerminal then
			self.cmbDriver.itemObject[self.cmbDriver.addItem( driver.name )] := driver;
		endif;
	endwhile;
	delete iter;
	self.cmbDriver.addItem( app.getErrorString(AnyString) );
	
	if self.myFilterDriver &lt;&gt; null then
		self.cmbDriver.listIndex := self.cmbDriver.findObject( self.myFilterDriver );
		if self.cmbDriver.listIndex &lt; 1 then
			self.cmbDriver.listIndex := 1;
			self.myFilterDriver := null;
		endif;
	else
		self.cmbDriver.listIndex := 1;
	endif;
		

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a4260afa-a4d3-4976-99c7-8a34e9abe19f">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2010	cnwndl1	Initial creation
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	date : Date;
	
begin
	date := self.systemToLocalTime(app.actualTimeServer()).date();// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.refreshToolbar();
	
	self.frmUserColours.visible := false;	
	
	self.setColours();
	
	self.beginClassNotification(CM_VehicleBookingTimeSlot, false, Object_Create_Event, Response_Continuous, null);
	self.beginClassNotification(CM_VehicleBookingTimeSlot, false, Object_Update_Event, Response_Continuous, null);
	self.beginClassNotification(CM_VehicleBookingTimeSlot, false, Object_Delete_Event, Response_Continuous, null);
	
	if self.myTerminal &lt;&gt; null then
		self.myVehicleBookingTerminal := self.myTerminal.getMyVehicleBookingTerminal();
	endif;

	inheritMethod();
	
	self.setupCarrierCombo();
	
	self.minimumWidth := 635;
	self.minimumHeight := 380;
	
	// default values
	self.day := date.day;
	self.month := date.month;
	self.year := date.year;
	
	//07 June 2013	NDL	Par 31729
	if not self.chkInclBooked.value
	and not self.chkInclUnbooked.value
	and not self.chkInclUsed.value
	then
		//defaults all off, nothing to view, turn 'em all on
		self.chkInclBooked.value := true;
		self.chkInclUnbooked.value := true;
		self.chkInclUsed.value := true;
	endif;
	self.doRefreshBookings();
	
	self.cmbPeriod.setFocus();
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMyEntTableDef" id="8a217be3-2a09-4255-bf9a-17488d36387a">
        <updating/>
        <source>setupMyEntTableDef() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2013	cnwndl1	Initial creation

*/

vars

	entTableDef : EntTableDef;
	entTableRow : EntTableRow;

begin

	if self.myEntTableDef = null then
		create self.myEntTableDef transient;
		entTableDef := app.myController.getEntTableDef(ETDef_VehicleSlotDisplay);
		
		foreach entTableRow in entTableDef.allEntTableRows do
			if entTableRow.name = ETRow_EndIntelligent
			or entTableRow.name = ETRow_StartTS
			or entTableRow.name = ETRow_EndTS
			then
				continue;
			endif;
			self.myEntTableDef.allEntTableRows.add( entTableRow );
		endforeach;
		
		self.tblBookings.setTblDataEntRowsFromDef( myEntTableDef );
		
	else
		self.tblBookings.resetColumns(true);
		
	endif;
	
	self.tblBookings.fixedColumns := 1;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupVehicleCombo" id="2cdbb230-9bc7-4a8f-8cc2-9aac2d722d0a">
        <updating/>
        <source>setupVehicleCombo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Apr 2013	cnwndl1	Initial creation	Par 31393
20 Oct 2020	jlgdap1	TFS 50193 PRP VBS Error: 14025 Maximum Number of ListBox entries exceeded
*/

vars

	vehicle : CM_Vehicle;
	iter : Iterator;
	useTextBox : Boolean;			// TFS 50193

begin

	
	self.cmbVehicle.clear();
	self.txtVehicle.text := null;										// TFS 50193
	
	
	if self.myFilterDriver &lt;&gt; null then
		iter := self.myFilterDriver.allVehicleMachines.createIterator;
		if self.myFilterDriver.allVehicleMachines.size &gt; 31998 then		// TFS 50193
			useTextBox := true;											// TFS 50193
		endif;															// TFS 50193
	else
		iter := self.myTerminal.vehicles.createIterator;
		if self.myTerminal.vehicles.size &gt; 31998 then					// TFS 50193
			useTextBox := true;											// TFS 50193
		endif;															// TFS 50193
	endif;
	if useTextBox then													// TFS 50193
		self.txtVehicle.visible := true;								// TFS 50193
		self.btnDoFilter.visible := true;								// TFS 50193
		self.cmbVehicle.visible := false;								// TFS 50193
	else																// TFS 50193
		self.txtVehicle.visible := false;								// TFS 50193
		self.btnDoFilter.visible := false;								// TFS 50193
		self.cmbVehicle.visible := true;								// TFS 50193
		while iter.next( vehicle ) do
			self.cmbVehicle.itemObject[self.cmbVehicle.addItem( vehicle.regNumber )] := vehicle;
		endwhile;
		self.cmbVehicle.addItem( app.getErrorString(AnyString) );
		delete iter;
	endif;																// TFS 50193
	
	if self.myFilterVehicle &lt;&gt; null then
		if useTextBox then												// TFS 50193
			self.txtVehicle.text := self.myFilterVehicle.regNumber;		// TFS 50193
		else															// TFS 50193
			self.cmbVehicle.listIndex := self.cmbVehicle.findObject(self.myFilterVehicle);
			if self.cmbVehicle.listIndex &lt;&gt; null then
				self.cmbVehicle.listIndex := 1;
				self.myFilterDriver := null;
			endif;
		endif;															// TFS 50193
	else
		self.txtVehicle.text := null;									// TFS 50193
		if not useTextBox then											// TFS 50193
			self.cmbVehicle.listIndex := 1;
		endif;															// TFS 50193
	endif;
		
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="showFilter" id="3b4ffa50-c4d8-49de-83cf-0c2cf0d80e4e">
        <updating/>
        <source>showFilter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Apr 2013	cnwndl1	Initial creation	Par 31393
22 Oct 2020	jlgdap1	TFS 50193 PRP VBS Error: 14025 Maximum Number of ListBox entries exceeded
*/

vars

	theFrame : CMUI_MoveableFrame;
	
begin

	app.mousePointer := Window.MousePointer_HourGlass;
	theFrame := self.frmFilter;
	
	if theFrame.visible then 
		theFrame.visible := false;
		self.myFilterCarrier := self.cmbCarrier.listObject.CM_Carrier; 
		self.myFilterDriver := self.cmbDriver.listObject.CM_DriverDetails; 
		if self.txtVehicle.visible then					// TFS 50193
			if self.txtVehicle.text = null then			// TFS 50193
				self.myFilterVehicle := null;			// TFS 50193
			endif;										// TFS 50193
		else											// TFS 50193
			self.myFilterVehicle := self.cmbVehicle.listObject.CM_Vehicle; 
		endif;											// TFS 50193
		self.doRefreshBookings();
		return;
	endif;

	theFrame.centreHorizontallyInParent();
	theFrame.top := 100;
	
	theFrame.zOrder(1);

	theFrame.visible := true;
	
epilog

	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showUserColourFrame" id="60132df9-608a-4da7-a093-bfa543145e7d">
        <source>showUserColourFrame();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2013	cnwndl1	Initial creation

*/

vars

begin

	self.frmUserColours.visible := not self.frmUserColours.visible;
	self.frmUserColours.left := 300;
	self.frmUserColours.top := 200;

	self.clrCurrentDay.setColor(xmlColourCurrentDay);
	self.clrNonCurrMth.setColor(xmlColourNonCurrMth);
	self.clrDateBack.setColor(xmlColourDateBack);
	self.frmUserColours.zOrder(1);

epilog

end;</source>
