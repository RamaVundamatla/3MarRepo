<Class name="BGP_KPICargoCounter" id="8ec8e4cb-1807-4dca-a05a-91106b86f783">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;KPI Cargo Counter&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="endDate" id="ad31400a-5d49-4a8f-81dd-911861d39312">
        <embedded/>
        <type name="Date"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="startDate" id="a9e6d802-002f-4fc0-993d-b1b759ffb8f2">
        <embedded/>
        <type name="Date"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="action" id="36e65a51-8b26-440d-aab5-8188d200223e">
        <updating/>
        <source>action(): Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/09/2010	cnwdap1	Initial creation PAR #25163 CCMS SFW 1108
*/
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	terminal	: CM_Terminal;
	errCode		: Integer;
	errTxt		: String;
	termCode	: String;
	failed		: Boolean;
	msg : String;
begin
	on Exception do app.alertExceptionHandler(exception, null,  self.getErrorDesc(), errCode, errTxt, true, true);
	//on LockException do app.alertLockExceptionHandler(exception);
	
	if self.myTerminal &lt;&gt; null then
		termCode := self.myTerminal.code;
		msg := 'Processing - running for Terminal ' &amp; termCode;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.myTrxUA.trxUpdateTermKPICargoCountBGP(self.myTerminal, self.startDate, self.endDate, app.myPassport);
	else
		foreach terminal in app.myRoot.allTerminals discreteLock do
			termCode := terminal.code;
			msg := 'Processing - running for Terminal ' &amp; termCode;
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			app.myTrxUA.trxUpdateTermKPICargoCountBGP(terminal, self.startDate, self.endDate, app.myPassport);
			// check for errors/warnings - if we had any, break and raise an alert
			if app.myPassport &lt;&gt; null and app.myPassport.hasErrorsOrWarnings() then
				break;
			endif;
		endforeach;
	endif;
	
	// if we had any errors, create a system alert
	if app.myPassport &lt;&gt; null and app.myPassport.hasErrorsOrWarnings() then
		msg := 'KPI Cargo Counter for Terminal ' &amp; termCode &amp; ' had errors';
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.createAlert("KPI Cargo Counter Request for Terminal " &amp; termCode &amp;  " had errors: " &amp; app.myPassport.getAllErrorsAndWarningsAsStr(), true);
		terminal := app.myRoot.allTerminals[termCode];
		terminal.causeEvent(Event_KPICargoCountFailed, true, null);
		failed := true;
	endif;

epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
		msg := 'KPI Cargo Counter had an exception ' &amp; errCode.String &amp; ' ' &amp; errTxt;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		// create a system alert for the error code
		app.createAlert(errCode.String &amp; " " &amp; errTxt, true);
		// and a notification if we're processing one terminal only
		if self.myTerminal &lt;&gt; null then
			msg := 'Raise an event for Event_KPICargoCountFailed and terminal ' &amp; self.myTerminal.code;
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			self.myTerminal.causeEvent(Event_KPICargoCountFailed, true, null);
		endif;
	else
		app.createActivityHistory(ActivityHistoryGeneral, self.myTerminal, null, "Successful KPI Cargo Counter Update", false, false);
		// raise a notification if we're processing one terminal only
		if self.myTerminal &lt;&gt; null and not failed then
			self.myTerminal.causeEvent(Event_KPICargoCountCompleted, true, null);
		endif;
	endif;
	inheritMethod();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromApplication" id="f8e84304-54b3-4583-b6e0-d9b0275a55d1">
        <updating/>
        <source>initRequestFromApplication(_terminal : CM_Terminal; _startDate, _endDate : Date) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/03/2011	cnwdap1	Initial creation PAR #25163 CCMS SFW 1108
*/
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	user	: CM_User;
	msg : String;
begin
	msg := method.qualifiedName &amp; " Started";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	user := app.getMyUser();
	if global.isValidObject(user) then
		self.myUser	:= user;
	endif;
	self.myTerminal	:= _terminal;
	self.startDate 	:= _startDate;
	self.endDate	:= _endDate;
	self.initRequestEvent(true, false, null);
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="94fd4801-a131-4c63-8297-d1b5bcbef539">
        <updating/>
        <source>initRequestFromTask(_task: CM_AutoTaskKPICargoCounter) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/09/2010	cnwdap1	Initial creation PAR #25163 CCMS SFW 1108
*/
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	user : CM_User;
	msg : String;
begin
	msg := method.qualifiedName &amp; " Started";
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	user := _task.myUser;
	if global.isValidObject(user) then
		self.myUser	:= user;
	endif;
	self.myTerminal	:= _task.myTerminal;
	// start and end dates are null for a scheduled task
	self.initRequestEvent(true, false, _task);

epilog

end;</source>
        <Parameter name="_task" type="CM_AutoTaskKPICargoCounter"/>
    </JadeMethod>
</Class>
