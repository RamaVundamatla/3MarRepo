	self.frmStatusLine.enabled := true;

	if self.displayMode = ShpDisplayMode_Actual and _doClick then // not EDI
		self.frmStatusLine.setDisplayMode(DISPLAY_MODE_ACTUAL);
	endif;
	
	self.frmStatusLine.doMenuMoveClick(CMUI_GridAreaStatusLine.MENU_MOVE_INSTANT);
