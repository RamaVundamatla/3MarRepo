	//all self's attributes	CM_ReserveSelection
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveSelection::clean.name, "CM_ReserveSelection", "clean", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveSelection::colour.name, "CM_ReserveSelection", "colour", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveSelection::densitySelection.name, "CM_ReserveSelection", "densitySelection", "", _features);
	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveSelection::descriptionSelection.name, "CM_ReserveSelection", "descriptionSelection", "", _features);
	create xdbFeature transient;
