    <JadeMethod name="initForm" id="ca431769-70d7-4302-b3ef-ef852c75a66d">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29 May 2009	cnwkpd1	PAR #19785 - CCMS SFW 1079 - Booking Reference Status changes
// ---------------------------------------------------------------------------

begin
	//self.useBookingSumView:=app.myPassport.myTerminal.getConfig(UseBookingSummView).Boolean;
	if not self.openWithSavedSettings then					//+cnwml2 PAR22544
		self.mnuEnhanced.checked :=app.myPassport.myTerminal.getConfig(UseBookingSummView).Boolean;
	endif;
	
	inheritMethod();
	self.useTblDataContextMenu := true;
	self.myAssistant.comboBoxVoyageCurrent(	cmbFiltVoyage,
											null,
											true,
											false,
											false,
											true,
											true,
											true,
											true,
											false,
											false);
	self.cmbStatus.automaticCellControl	:=	true;
	self.myAssistant.comboBoxBookingRefStatus(cmbStatus, 0);
	
	self.cmbFiltStatus.automaticCellControl	:=	true;			// PAR #19785
	self.myAssistant.comboBoxBookingRefStatus(cmbFiltStatus, BOOKING_REF_ACTIVE);
	
	//self.cmbReconciled.automaticCellControl := true;
	self.setFilterReconCombo();
	
	self.setFilterBookingTypeCombo();					//+cnwml2 PAR22571
	
	self.tblThumb.bubbleHelp := app.getErrorString(Double_Click_Thumb);	
	self.cmbConsignee.sorted:= true;
	self.cmbConsignee.initialise(false); // adm 260908 Par 17026
	self.cmbConsignor.initialise(false);
	self.dck_BRefItem.visible := false;
	self.beginClassNotification(CM_BookingRef, false, self.myTerminal.getTerminalEvent(Event_BookingRefAdd), Response_Continuous, 0);
	self.beginClassNotification(CM_BookingRef, false, self.myTerminal.getTerminalEvent(Event_BookingRefUpdate), Response_Continuous, 0);


	self.frmDetailsBottom.parentAspect := frmDetailsBottom.ParentAspect_StretchBoth;
	self.tblBRItems.parentAspect := tblBRItems.ParentAspect_StretchBoth;
	self.sptThumbEdit.parentAspect := sptThumbEdit.ParentAspect_StretchBoth;
	

	// cnwrd1 par 23142 11.3.2010 disable these buttons if the user lacks security
	if app.getMyUser.canDo(self.myTerminal, PmAdmBookingRefDiscrepView ) or  app.getMyUser.canDo( self.myTerminal, PmAdmBookingRefDiscrepMaint )  then
		self.btnBookingRefDis.enabled := true;
	else
		self.btnBookingRefDis.enabled := false;
	endif;
	
	
	if app.getMyUser.canDo(self.myTerminal, PmGteBookingRefRecon ) then
		self.btnReconciled.enabled := true;
	else
		self.btnReconciled.enabled := false;
	endif;
	// cnwrd1 par 23142 11.3.2010 disable these buttons if the user lacks security
	
end;</source>
    </JadeMethod>
