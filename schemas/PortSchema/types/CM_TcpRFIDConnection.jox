    <JadeMethod name="readGetStatusMemoryCB" id="65bbebb6-c4cc-4268-b03b-5062ca1fe1ad">
        <source>readGetStatusMemoryCB(_tcp : CM_TcpRFIDConnection; _buffer : Binary);
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	responseString : String;
	values,userCode : String;
	jbusError :Integer;
	memoryPointer, i  : Integer;
	found : Boolean;
	memoryStatus : String;
	jbus,crc16String,crc16 : String;

begin
	
	
	responseString :=_buffer.asHex;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got response of " &amp; responseString,LogDEBUG);
	jbusError:=self.checkForJBUSError(responseString);
	if  jbusError &lt;&gt; 0 then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got JBUS error " &amp; jbusError.String,LogDEBUG);
		self.close;
		return;
	endif;
	//1 byte = channel
	// 2nd byte = function 
	// 3rd byte = nb characters
	// n bytes = data
	//2 bytes = values

	values:=self.getJBUSMessageValue(responseString);
	
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got value of " &amp; values,LogDEBUG);
	if values.length &lt;&gt; 16*2 then
		self.close;
		return;
	endif;
	memoryPointer:=80;
	i:=1;
	while i &lt;= 16 do
		memoryStatus:=values[(i*2)-1 :2];
		if memoryStatus &lt;&gt; "00" then
			found:=true;
			break;
		endif;
		
		i:=i+1;
		memoryPointer:=memoryPointer+1;
	endwhile;
	
	if found then	
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " found tag in memory location " &amp; memoryPointer.String,LogDEBUG);
		jbus := #01.Character &amp; #03.Character &amp; #00.Character &amp; memoryPointer.String.cnEcHexValue.Character &amp; #00.Character &amp; memoryStatus.cnEcHexValue.Character;
		crc16String:= app.crc16(jbus);
		
		crc16:=crc16String[1:2].cnEcHexValue.Character &amp; crc16String[2:4].cnEcHexValue.Character;
		jbus:=jbus &amp; crc16;
		process.sleep(100);
		self.writeBinaryAsynch(jbus.Binary,self,CM_TcpRFIDConnection::writeGetTagMemoryCB.name);
	else
		self.close;
	endif;
end;
</source>
        <Parameter name="_tcp" type="CM_TcpRFIDConnection"/>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="readGetTagCB" id="b58b08a9-62aa-4449-b676-cc808d144b2c">
        <source>readGetTagCB(_tcp : CM_TcpRFIDConnection; _buffer : Binary);
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	responseString : String;
	values,valuesHex,userCode : String;
	jbusError, i :Integer;
begin
	
	
	responseString :=_buffer.asHex;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got response of " &amp; responseString,LogDEBUG);
	jbusError:=self.checkForJBUSError(responseString);
	if  jbusError &lt;&gt; 0 then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got JBUS error " &amp; jbusError.String,LogDEBUG);
		return;
	endif;
	//1 byte = channel
	// 2nd byte = function 
	// 3rd byte = nb characters
	// n bytes = data
	//2 bytes = values
	
	valuesHex:=self.getJBUSMessageValue(responseString);
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got value of " &amp; valuesHex,LogDEBUG);
	
	
	i:=1;
	while i &lt; valuesHex.length do
		values := values &amp; valuesHex[i:2].cnEcHexValue.Character;
		i:=i+2;
	endwhile;
	//at this stage only interested in user_code ??
	//1 btye status tag
	//3 btyes distributor code
	//rest user_code
	//has been converted to string from hex so its 5 not 9
	userCode:=values[5:end];
	if self.myRFIDTagReader &lt;&gt; null then
		self.myRFIDTagReader.doProcessBinary(userCode.Binary);
	endif;
	
epilog

end;</source>
        <Parameter name="_tcp" type="CM_TcpRFIDConnection"/>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="readGetTagMemoryCB" id="159df2fd-4232-4780-a940-c4477960ff70">
        <source>readGetTagMemoryCB(_tcp : CM_TcpRFIDConnection; _buffer : Binary);
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 May 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	responseString, serialNumber : String;
	values,valuesHex,userCode : String;
	jbusError, i :Integer;
begin

	responseString :=_buffer.asHex;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got response of " &amp; responseString,LogDEBUG);
	//self.causeEvent(Event_RFIDInfo,true, "Got response of " &amp; responseString);
	jbusError:=self.checkForJBUSError(responseString);
	if  jbusError &lt;&gt; 0 then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got JBUS error " &amp; jbusError.String,LogDEBUG);
		return;
	endif;
	//1 byte = channel
	// 2nd byte = function 
	// 3rd byte = nb characters
	// n bytes = data
	//2 bytes = values
	
	valuesHex:=self.getJBUSMessageValue(responseString);
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " got value of " &amp; valuesHex,LogDEBUG);
	//at this stage only interested in user_code ??
	//1 btye status tag
	//3 btyes distributor code
	
	//rest user_code
	//has been converted to string from hex so its 5 not 9
	values:=self.getValuesString(valuesHex);
	if values.length &lt; 6 then
		return;
	endif;
	userCode:=values[5:end];
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " tag found " &amp; userCode,LogDEBUG);
	//self.causeEvent(Event_RFIDInfo,true, "Tag found with value " &amp; userCode);
	if self.myRFIDTagReader &lt;&gt; null then
		serialNumber:=self.myRFIDTagReader.doProcessBinary(userCode.Binary);
		if serialNumber = null then
			self.causeEvent(Event_RFIDInfo,true, "No Tag found in JMT with value  " &amp; userCode);
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; " tag found in JMT with value  " &amp; userCode, LogDEBUG);
		else
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; " Found RFID Tag in JMT  " &amp; serialNumber,LogDEBUG);
			self.causeEvent(Event_RFIDInfo,true, "Found RFID Tag in JMT  " &amp; serialNumber);
		endif;
	endif;
	
epilog
	self.close;

end;
</source>
        <Parameter name="_tcp" type="CM_TcpRFIDConnection"/>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
