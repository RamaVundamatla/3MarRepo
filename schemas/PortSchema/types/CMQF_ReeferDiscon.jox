<Class name="CMQF_ReeferDiscon" id="4e73d59c-36b0-476f-9cf5-23fd38015910">
    <superclass name="CMQF_Reefer"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="0b78998c-7f27-4e06-a7c3-a75d3fa1082e">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	24 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	voyage		: CM_Voyage;
	ti			: CM_TrackedItem;
	vj			: CM_VoyageJob;
	terminal	: CM_Terminal;
	breakOut	: Boolean;
	edition : Integer;	//18 July 2016	NDL	TFS 2329
	invalid : Boolean;	//18 July 2016	NDL	TFS 2329
begin

	voyage := self.getMyVoyage;
	
	if voyage &lt;&gt; null then
		if self.allQryVoyageJobs.isEmpty then
			inheritMethod(_collection, _passport);
		else
			on Exception do app.handleDeletedObject( exception, vj, invalid );	//18 July 2016	NDL	TFS 2329
	
			foreach vj in self.allQryVoyageJobs do
						//18 July 2016	NDL	TFS 2329
				invalid := false;
				edition := vj.edition;
				if invalid then
					continue;
				endif;

				foreach ti in vj.allReleaseTrackeditems discreteLock do
					if self.checkStatusIncludesObject(ti, _passport, breakOut) then
//					if self.includesObject(ti, _passport, breakOut) then
						if not _collection.includes(ti) then
						_collection.add(ti);
						endif;
					endif;
				endforeach;
//				if breakOut then
//					return;
//				endif;
			endforeach;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="088933a0-c22a-431d-8b2b-d92a065cf966">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		29 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	if CM_Container.hasInstance(_ti) and
	   _ti.CM_Container.requiresPower and 				//will need disconnection (even if not requiresTemperature)
	   inheritMethod(_ti, _passport, _breakOut) then
		return true;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
