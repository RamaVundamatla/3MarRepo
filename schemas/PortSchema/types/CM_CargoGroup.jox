    <JadeMethod name="getCOOOperator" id="79bd8362-f8f5-4680-88d4-0cb9ff6cb79e">
        <source>getCOOOperator(_oprSet: CM_OperatorSet io; _operatorType: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2023	navma1	ChangeRequest 60920: EUP | Cargo Enquiry Performance - Work Packet 1

*/

vars
	ti 	: CM_TrackedItem;
	coo : CM_OwnershipChange;
begin
	
	inheritMethod(_oprSet, _operatorType);
	
	foreach coo in self.allOwnershipChange do 
		coo.getCOOOperator(_oprSet,_operatorType);
	endforeach;

epilog

end;</source>
        <Parameter name="_oprSet" type="CM_OperatorSet" usage="io"/>
        <Parameter name="_operatorType" type="String"/>
    </JadeMethod>
