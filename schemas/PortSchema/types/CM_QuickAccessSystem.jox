<Class name="CM_QuickAccessSystem" id="80b5c8a2-eefb-487b-a70f-2da0fe04e194">
    <superclass name="CM_QuickAccess"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="quikAccess"/>
    <ExplicitInverseRef name="myRoot" id="d62b9825-7dbf-4738-b7e7-093aff61ad1e">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allSystemQuickAccess"/>
    </ExplicitInverseRef>
    <JadeMethod name="isSystem" id="ad64d207-90b1-4d70-82aa-af67ee80eb3c">
        <source>isSystem(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2014	cnwndl1	Initial creation

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="528ac95a-f4ba-429c-8982-c6021103aaa6">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2014	cnwndl1	Initial creation

*/

vars

	proxy : CM_QuickAccessSystem;

begin

	proxy := inheritMethod();
	proxy.myRoot := self.myRoot;
	
	return proxy;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2852c76d-d3e1-4325-a5cd-136edccc9d7c">
        <updating/>
        <source>setForUpdate(_proxy: CM_QuickAccessSystem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod(_proxy);
	
	self.myRoot := _proxy.myRoot;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_QuickAccessSystem"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="516116c1-02b3-4573-b539-0ad58f217b1d">
        <updating/>
        <source>setProxy(	_helpDescription : String;
			_permissionInteger : Integer;
			_shortCode : String;
			_isForm : Boolean;
			_allowsOption : Boolean
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

begin

	self.allowsOption := _allowsOption;
	self.isForm := _isForm;
	self.helpDescription := _helpDescription;
	self.permissionInteger := _permissionInteger;
	self.shortCode := _shortCode;
	self.myRoot := app.myRoot;

epilog

end;</source>
        <Parameter name="_helpDescription" type="String"/>
        <Parameter name="_permissionInteger" type="Integer"/>
        <Parameter name="_shortCode" type="String"/>
        <Parameter name="_isForm" type="Boolean"/>
        <Parameter name="_allowsOption" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b68891e8-284f-4030-a807-1dbef78e0c10">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod();
	
	if app.myRoot.allSystemQuickAccess[self.shortCode] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.shortCode, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="17ce672a-cdfc-4f8e-80e7-25d47e4b6ce4">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

	existing : CM_QuickAccessSystem;

begin

	inheritMethod();
	
	if not self.isTransient then
	
		existing := app.myRoot.allSystemQuickAccess[self.shortCode];
		
		if existing &lt;&gt; null and existing &lt;&gt; self then 
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.shortCode, null, null);
		endif;
	
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="095ccded-798d-4175-946d-23c85ce3fbe1">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2014	cnwndl1	Initial creation

*/

vars

begin
	inheritMethod();
	
	if self.myRoot = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'System Root', null, null);
		app.raiseCMException(Input_required_field_systemRot, null, null); // cnwdb2	PAR 35364
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
