<Class name="CM_LogSpecies">
    <JadeMethod name="loadTreeViewArray" id="89faf7c0-98c2-4841-89f8-e3bafeca87ed">
        <source>loadTreeViewArray(_collection: Collection input; _level: Integer; _form: CMUI_CodesMaintTree; _parent : SOP_ViewModelObject);
// -----------------------------------------------------------------------------
// Created:		12 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 11 Jan 2011	cnwkpd1		PAR #26678 - Tidy up transient leaks
// -----------------------------------------------------------------------------
vars
	iter : Iterator;
	grade : CM_LogGrade;
	obj  : SOPVM_LogSpecies;
	includeNotAvail : Boolean;	//	//21 Jun 2013	NDL	Par 31770
begin
	create obj transient;
	
	obj.initializeMe(self, _level, _parent);
	obj.myForm := _form;
	_collection.add(obj);
	
	includeNotAvail := _form.chkInclNotAvail.visible and _form.chkInclNotAvail.value;	//21 Jun 2013	NDL	Par 31770
	
	iter := self.allLogGrades.createIterator();
	while iter.next(grade) do
		if includeNotAvail or not grade.notAvailableForEntry then	//21 Jun 2013	NDL	Par 31770
			grade.loadTreeViewArray(_collection, _level +1, _form, obj);
		endif;
	endwhile;
epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_form" type="CMUI_CodesMaintTree"/>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
</Class>
