    </JadeMethod>
    <JadeMethod name="btnSearch_click" id="0ae63df7-431d-498d-bf9c-ba38a06edd93">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSearch_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		11 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doSearch();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormInitialize" id="f73516a0-8cf6-4389-9c9d-d71581dd2665">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		11 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.initializeResultsTable();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSearch" id="7aaa2100-35c0-4bc5-9875-229271795e27">
        <source>doSearch() protected;
// --------------------------------------------------------------------------------
// Created:		11 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	searchText			: String;
	constantText		: String;
	theCoreSchema		: Schema;
	allSubschemas		: SchemaColl;
	theSubschema		: Schema;
	allConstants		: ConstantNDict;
	allResultConstants	: ConstantNDict;
	theConstant			: Constant;
	theTable			: Table;
	rowString			: String;
	
begin
	searchText		:=	txtText.text.trimBlanks().toUpper;
	self.initializeResultsTable();
	
	// Get the Core Schema and all of its subschemas.
	
	theCoreSchema	:=	rootSchema.getSchema(JSSCoreSchema.name);
	
	create allSubschemas transient;
	theCoreSchema.allSubschemas(allSubschemas);
	
	// Gather all of the schema's Exception Global Constants.
	
	create allConstants transient;
	self.getExceptionConstants(theCoreSchema, allConstants);
	
	foreach theSubschema in allSubschemas do
		self.getExceptionConstants(theSubschema, allConstants);
	endforeach;
	
	// Now search all of the Exception Global Constants.
	
	create allResultConstants transient;
	
	foreach theConstant in allConstants do
		constantText	:=	theConstant.text.trimBlanks().toUpper();
		
		if constantText.pos(searchText, 1) &gt; 0 then
			allResultConstants.add(theConstant);
		endif;
	endforeach;
	
	// Finally, display the results of the search in the results table.
	
	theTable	:=	tblResults;
	
	foreach theConstant in allResultConstants do
		rowString	:=	theConstant.GlobalConstant.getSchema().name &amp; Tab &amp;
						theConstant.name &amp; Tab &amp;
						theConstant.valueAsInteger.padLeadingWith("0", 5) &amp; Tab &amp;
						theConstant.text;
		
		theTable.addItem(rowString);
	endforeach;
epilog
	delete allSubschemas;
	delete allConstants;
	delete allResultConstants;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getExceptionConstants" id="c16ec36a-1392-4b5d-a4f0-cc6269e44651">
        <source>getExceptionConstants(pTheSchema:Schema; pAllConstants:ConstantNDict io) protected;
// --------------------------------------------------------------------------------
// Created:		11 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCategory		: ConstantCategory;
	
begin
	theCategory	:=	self.findExceptionConstantCategory(pTheSchema);
	
	if theCategory = null then
		return;
	endif;
	
	theCategory.getConstants().copy(pAllConstants);
end;</source>
        <access>protected</access>
        <Parameter name="pTheSchema" type="Schema"/>
        <Parameter name="pAllConstants" type="ConstantNDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="initializeResultsTable" id="1d9c2cc5-eb9c-4503-b102-7ec235b6aaf6">
        <source>initializeResultsTable() protected;
// --------------------------------------------------------------------------------
// Created:		11 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTable	: Table;
	
begin
	theTable		:=	tblResults;
	theTable.rows	:=	1;
	theTable.setCellText(1, 1, "Schema" &amp; Tab &amp; "Constant" &amp; Tab &amp; "Value" &amp; Tab &amp; "Text");
	theTable.partialTextIndication	:=	true;
	theTable.refreshNow();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblResults_rowColumnChg" id="7dc4f9d6-73f8-4a16-8f6f-dfc4744cf336">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResults_rowColumnChg(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		11 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.selectTableRow(table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
</GUIClass>
