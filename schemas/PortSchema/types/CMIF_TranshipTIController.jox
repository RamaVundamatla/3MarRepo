    <JadeMethod name="clear" id="52292330-ac20-4479-a96a-c15f1694ff18">
        <updating/>
        <source>clear() updating;
// ---------------------------------------------------------------------------
// Created:		20 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 02/06/2010	cnwdap1		CCMS 1116 Tranship changes - export ISO type and commodity deprecated in 7.8.2 release
vars
begin
	self.allTrackedItems.clear;
	//self.myExportCommodity := null;
	self.myExportDestPort := null;
	self.myExportDisPort := null;
	//self.myExportISOType := null;
	self.myExportVoyage := null;
	self.bookingRef := null;
	self.remarks := null;
	//self.removeStops := false;	// TFS 47222 jlgzm1 20/11/2019
	self.billOfLading := null;		// MES1008 JMH 30/9/09
	self.cargoType := null;			// MES1008 JMH 30/9/09
	self.myTranshipToPort := null;	// PAR #23889 CCMS 1116
	self.imexStatus := null;		// PAR #23889 CCMS 1116
	self.interModal := false;		// TFS 53084 jlizm1 20/04/2022
	
end;</source>
    </JadeMethod>
    <JadeMethod name="clearProxies" id="edf7b61f-3a95-4336-8dce-a99b9895c0f0">
        <source>clearProxies();
// ---------------------------------------------------------------------------
// Created:		20 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars	
	realTI, pxyTI : CM_TrackedItem;
begin
	foreach realTI in self.allTrackedItems do
		pxyTI := realTI.pxyGetProxyObject().CM_TrackedItem;
		delete pxyTI;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doStoreTIBookingRef" id="baa55f2e-1ef7-4344-8f47-c8945c8aa13b">
        <source>doStoreTIBookingRef(_tiID:String; _bookingRef:String);
// --------------------------------------------------------------------------------
// Created:		29 July 2010 by cnwdad1
//
// Purpose:		Stores the specified Tracked Item ID and Booking Ref pair in an
//				array element, separated by "=".
//
// Parameters:	_tiID - The ID of the Tracked Item.
//				_bookingRef - The Booking Ref code.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allTIBookingRefs.add(_tiID &amp; "=" &amp; _bookingRef);
end;</source>
        <Parameter name="_tiID" type="String"/>
        <Parameter name="_bookingRef" type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIBookingRef" id="3e68a128-22f3-41c9-bacd-3d8ea325acc0">
        <source>getTIBookingRef(_tiID:String):String;
// --------------------------------------------------------------------------------
// Created:		29 July 2010 by cnwdad1
//
// Purpose:		Using the specified Tracked Item ID, find an element with a matching
//				ID, and return the Booking Ref portion of the element.
//
// Parameters:	_tiID - The ID of the Tracked Item.
//
// Returns:		The Booking Ref, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	element		: String;
	pos			: Integer;
	idToFind	: String;
	
begin
	foreach element in self.allTIBookingRefs do
		idToFind	:=	_tiID &amp; "=";	// Put the separator on the end in case there is a Booking Ref with the same code as the TI's ID.
		
		if element.pos(idToFind, 1) &gt; 0 then
			pos	:=	element.pos("=", 1);
			
			if pos &gt; 0 then
				pos	:=	pos + 1;
				
				if pos &lt;= element.length() then
					return element[pos:end];
				endif;
			endif;
			
			break;
		endif;
	endforeach;
end;</source>
        <Parameter name="_tiID" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validate" id="b0873d98-88ae-42f1-b77c-715147e93b79">
        <source>validate();
// ---------------------------------------------------------------------------
// Created:		20 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On 	By			Reason
// ----------	--------	--------------------------------------------------
// 15/06/2010	cnwdap1		CCMS 1116 Tranship changes - export ISO type and commodity deprecated in this release (7.8.2)
vars
begin
	
	if self.myExportVoyage = null then
		app.raiseCMException1(ERR_INVALID_VALUE,"Tranship Voyage" ,null,null);
	endif;
	if self.allTrackedItems.isEmpty then
		app.raiseCMException1(ERR_INVALID_VALUE,"Tranship Cargo" ,"Please select some cargo to make tranship.",null);
	endif;
end;</source>
    </JadeMethod>
</Class>
