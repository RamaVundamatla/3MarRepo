    <JadeMethod name="getTIForDisplayMode" id="b216b196-f218-4a73-bbfe-b2e134f5bbc1">
        <source>getTIForDisplayMode(_mode : Integer; _ediIndex : Integer; _numTIs : Integer output) : CM_TrackedItem;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	ti : CM_TrackedItem;
	str : String;

begin
	if _mode = ShpDisplayMode_Actual then
		_numTIs := self.allTrackedItems.size;
		if _numTIs &gt; 0 then
			ti := self.allTrackedItems.first;
		endif;

	elseif _mode = ShpDisplayMode_Proposed then
		self.getProposedCargo(ti, _numTIs);
	endif;

	return ti;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_ediIndex" type="Integer"/>
        <Parameter name="_numTIs" type="Integer" usage="output"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTotalsByMode" id="2141b147-2880-4374-8ccd-971857f2b9e0">
        <source>getTotalsByMode(_mode : Integer; _vol, _weight : Decimal io; _qty : Integer io);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/02/2016	cnwdap1		Initial creation PAR #36766 Bulk Graphical Representation
//
vars
	array : CM_TIArray;
	ti : CM_TrackedItem;
	
begin
	create array transient;
	self.getTIs(array, _mode, true);
	
	foreach ti in array discreteLock do
		_vol := _vol + ti.totalVolume;
		_weight := _weight + ti.totalWeight;
		_qty := _qty + ti.totalQuantity;
	endforeach;
	
epilog
	delete array;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_vol" type="Decimal" usage="io"/>
        <Parameter name="_weight" type="Decimal" usage="io"/>
        <Parameter name="_qty" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTransferType" id="bd08432a-e4e3-4199-94ba-deecae1c4b3f">
        <source>getTransferType(): Integer;
/*
Purpose:		 TFS 4435	
Date		Who		Reason
12 May 2017	cnwab1	Initial creation
*/

vars

begin
	return VESSEL_TYPE_RORO;

epilog

