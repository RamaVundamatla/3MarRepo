    <JadeMethod name="frameOne_mouseMove" id="75632ef3-b5c7-4667-93f7-dbf8dfe98159">
        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frameOne_mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     04 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin


	if button = Frame.MouseButton_Left then
		frameOne.dragMode := Frame.DragMode_Drag;
		frameOne.dragCursor := self.makePicture();
	endif;

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="frameOne_mouseUp" id="bbd3ec66-45c2-4838-987a-32d6beac0918">
        <controlMethod name="Frame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frameOne_mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
constants
	RectSize = 100;
vars

	x1,y1 : Integer;
begin
	return;
	
	self.frameOne.clearGraphics;
	
	x1 := x.Integer - RectSize;
	y1 := y.Integer - RectSize;
	self.point1.set(x1,y1);
	
	x1 := x.Integer + RectSize;
	y1 := y.Integer + RectSize;
	self.point2.set(x1,y1);

	if button = Window.MouseButton_Left then
		self.frameOne.drawFillColor := Red;
	else
		self.frameOne.drawFillColor := Blue;
	endif;
	self.frameOne.drawFillStyle := 4;
	self.frameOne.drawFilledRectangle(self.point1.x,self.point1.y,self.point2.x,self.point2.y,self.frameOne.drawFillColor);
	self.frameOne.drawFillStyle := 5;
	self.frameOne.drawFilledRectangle(self.point1.x,self.point1.y,self.point2.x,self.point2.y,self.frameOne.drawFillColor);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="load" id="3551914e-c228-4964-aac2-a2e8d5f1376c">
