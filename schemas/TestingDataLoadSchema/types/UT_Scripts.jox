      &lt;commodity&gt;MCAR&lt;/commodity&gt;
      &lt;dischargePort&gt;NZLYT&lt;/dischargePort&gt;
      &lt;voyageCode&gt;MSCK000002&lt;/voyageCode&gt;
      &lt;messageMode&gt;D&lt;/messageMode&gt;
    &lt;/CargoOnSite&gt;
