    <JadeMethod name="comboBoxStatus" id="fc12fbbc-7b7f-4495-8992-dad8b6ea483d">
        <source>comboBoxStatus() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	self.cmbStatus.sorted:=false;
	self.cmbStatus.addItemWithData("",-1);
	self.cmbStatus.addItemWithData(app.getErrorString(Pending),DutyDoc_Pending);
	self.cmbStatus.addItemWithData(app.getErrorString(Validated), DutyDoc_Validated);
	self.cmbStatus.addItemWithData(app.getErrorString(Approved),DutyDoc_Approved);
	self.cmbStatus.addItemWithData(app.getErrorString(Rejected), DutyDoc_Rejected);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
