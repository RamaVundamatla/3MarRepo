    <JadeMethod name="btnInsert_click" id="caf7305a-6403-4a73-b7cd-331509347795">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnInsert_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2018	jlgndl1	Initial creation	TFS 38070

*/

vars

	existing : String;
	additional : String;
	maxLength: Integer;
	
begin

	if self.cmbCharacter.listIndex &gt; 0 then
		existing := self.txtCurrSymbol.text;
		additional := self.cmbCharacter.text;
		maxLength := self.txtCurrSymbol.maxLength;
		if existing.length + additional.length &lt;= maxLength then
			self.txtCurrSymbol.text := existing &amp; additional;
		else
			app.msgBox( app.getErrorString2( Field_Value_Too_Long, self.lblCurrSymbol.caption, maxLength.String), app.getErrorString(Error), MsgBox_OK_Only );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
