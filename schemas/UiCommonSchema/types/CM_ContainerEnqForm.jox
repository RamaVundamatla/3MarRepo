vars
	tbl : CM_EntryTable;
	
begin
	// cnwrl1 22/11/2010 PAR 26387 - start of coding
	// make sure the parent of the booking item is a entry table (ie the booking detail row entry exists).
	if combobox.parent &lt;&gt; null and combobox.parent.isKindOf( CM_EntryTable ) then
		// cnwrl1 04/11/2010 PAR 26170 - start of coding
		tbl := combobox.parent.CM_EntryTable;
		tbl.setValueByControlName(combobox.name, combobox.text);
		// cnwrl1 04/11/2010 PAR 26170 - end of coding
	endif;
	// cnwrl1 22/11/2010 PAR 26387 - end of coding
	
	combobox.doChangedCompareForEntryTable();
	
epilog
	
end;</source>
