    <JadeMethod name="getRequiredByDT" id="e8381e39-4ebf-421a-ab9b-0ad39bb32e03">
        <source>getRequiredByDT(): TimeStamp;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2010	cnwrd1	Initial creation

*/

vars

begin

	if self.myWODtl = null or self.myWODtl.requiredByDT = null then		
		return self.allRequests.first.getRequiredByDT();
	endif;
	
	return self.myWODtl.requiredByDT;

epilog

end;</source>
