    <JadeMethod name="setForProxyMaster" id="3a2219c6-82cf-4719-a8c4-4c19dedfd77e">
        <updating/>
        <source>setForProxyMaster(	_cargoType		: Integer;
					_id				: String;
					_description 	: String;
					//_tWeight		: Integer;						// PAR #31155
					_tWeight		: Decimal;						// PAR #31155
					_operator 		: CM_Operator;
					_owner 			: CM_Operator;
					_stopTables		: CM_StopsTableByIdDict;
					_toDoTaskDesc	: CM_ToDoTaskDescByCode;
					
					_root			: CM_Root) updating;
// -------------------------------------------
// Created 21 November 2005 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	-------		-----------------------------------------------
// 12/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
//-------------------------------------------------------------------------
vars

begin

	self.cargoType				:= _cargoType;
	self.id						:= _id[1:20].toUpper();
	self.description			:= _description[1:60];
	self.tWeight				:= _tWeight;
	self.myOperatorNew			:= _operator; // cnwrd1 ccms 1034 13.8.2008
	self.myOwner				:= _owner;  // cnwrd1 ccms 1034
	
	self.allStopsNew.clear;
	if _stopTables &lt;&gt; null then
		_stopTables.copy(self.allStopsNew);
	endif;

	self.allToDoTaskDesc.clear;
	if _toDoTaskDesc &lt;&gt; null then
		_toDoTaskDesc.copy(self.allToDoTaskDesc);
	endif;
	
	self.myRoot					:= _root;

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_tWeight" type="Decimal"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_owner" type="CM_Operator"/>
        <Parameter name="_stopTables" type="CM_StopsTableByIdDict"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDescByCode"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5ab3f172-452f-4aae-9d24-bfa7f8144fb8">
        <updating/>
        <source>setForUpdate(_proxyTiMaster : SelfType) updating;
// -------------------------------------------
// Created 01 December 2005 by cnwdvb1
// -------------------------------------------
// cnwrd1 ccms 1034 13.8.2008
// 27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
// 25 Jul 2018	jlgrs1	TFS 38804 SNO Changes to repaired transactions
vars
	damageInstance,
	newDamageInstance: CM_DamageInstance;
	repaired : Boolean;
begin

//	self.myTiMasterGroup		:= _proxyTiMaster.myTiMasterGroup;
	self.id:=_proxyTiMaster.id;
	self.description := _proxyTiMaster.description;
	self.cargoType :=_proxyTiMaster.cargoType;
	self.extHeight := _proxyTiMaster.extHeight;
	self.extLength := _proxyTiMaster.extLength;
	self.extWidth := _proxyTiMaster.extWidth;
	self.intHeight := _proxyTiMaster.intHeight;
	self.intLength := _proxyTiMaster.intLength;
	self.intWidth := _proxyTiMaster.intWidth;
	self.myOperatorNew :=_proxyTiMaster.myOperatorNew;
	self.myOwner := _proxyTiMaster.myOwner;
	self.tWeight := _proxyTiMaster.tWeight;
	self.volume := _proxyTiMaster.volume;
	self.lastUpdated :=  app.actualTimeServer();
	
	self.allStopsNew.clear;
	_proxyTiMaster.allStopsNew.copy(self.allStopsNew);
	
	//should be collection of transient damage instances
	//self.allDamageInstancess.purge;
	self.allDamageInstancesByPos.purge;
	//foreach damageInstance in _proxyTiMaster.allDamageInstancess do
	foreach damageInstance in _proxyTiMaster.allDamageInstancesByPos do
		damageInstance.validateForUpdate;
		create newDamageInstance persistent;
		newDamageInstance.setForUpdate(damageInstance, null, self, true, repaired);	
	//	newDamageInstance.setForUpdateSubject(newDamageInstance, self);	
	endforeach;

	self.allToDoTaskDesc.clear;
	_proxyTiMaster.allToDoTaskDesc.copy(self.allToDoTaskDesc);
	
	//27.02.2018 cnwma1 ChangeRequest #36813
	self.allTIMasterAttachees.clear;
	if _proxyTiMaster.allTIMasterAttachees.isNotEmpty then
		_proxyTiMaster.allTIMasterAttachees.copy(self.allTIMasterAttachees);
	endif;
	//27.02.2018 cnwma1 ChangeRequest #36813
	self.causeEvent(Event_TiMaster_Update, false, null);
	
end;</source>
        <Parameter name="_proxyTiMaster" type="SelfType"/>
    </JadeMethod>
