    <JadeMethod name="tMatchingCargo" id="79b4d484-3644-47ae-9161-75f1526972c0">
        <source>tMatchingCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2025	navnk30	Initial creation

*/

vars
	bgpReq 	: BGP_AgGatewayWSRequest;
	tiColl	: CM_TIByReceiveDT;
	assignedTIs	: CM_TISet;
	ramTerm	: CM_Terminal;
	quan	: Decimal [14,4];
	cargoType	: CM_CargoType;
	product		: CM_Product;
	ti : CM_TrackedItem;
begin
	create bgpReq transient;
	create tiColl transient;
	quan := 31;
	self.getRamTerm(ramTerm);
	self.getCargoTypeProduct(cargoType, product);
	bgpReq.getMatchingCargo(cargoType, product, quan, false, ramTerm, tiColl, assignedTIs, null);
	
	foreach ti in tiColl do
		write ti.id;
	endforeach;
epilog
	delete bgpReq;
end;</source>
    </JadeMethod>
