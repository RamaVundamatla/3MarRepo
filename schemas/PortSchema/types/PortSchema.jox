    <JadeMethod name="createUpdateProxy" id="523f445b-4dc6-4214-a7a7-853ef73109ac">
        <source>createUpdateProxy(persistentEntity : CM_Object) : CM_Object;
// ---------------------------------------------------------------------------
// Created:     19 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	24/5/01			AA		Raise exception if trying to create a proxy for a real
//							object that already has another update proxy in this app
// ---------------------------------------------------------------------------
vars
	needEndLoad			: Boolean;
	loadStateSet 		: Boolean;
	invalidPersistenObj : Boolean;
begin
	needEndLoad := false;

	on Exception do app.handleDeletedObject(exception, persistentEntity, invalidPersistenObj); //Par 17629 - AER 1/08/2008

	if persistentEntity.isTransient then
		app.setContinueCMExceptions(false);
		app.raiseCMException(CannotCreateProxyForTransient, null, null);
		return null;
	endif;

	if invalidPersistenObj then 							//Par 17629 - AER 1/08/2008
		app.setContinueCMExceptions(false);			
		app.raiseCMException(Invalid_persistent_object, null, null);
		return null;
	endif;
	
	if self.myProxyManager.allReals.includesKey(persistentEntity) then
		//Already have an update proxy for this object. Not permitted to make another
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ProxyAlreadyExists, persistentEntity.identity, "", null);
		return null;
	endif;
	
	if (not process.isInTransactionState) and (not process.isInLoadState) and (not process.isInLockState) then
		needEndLoad := true;
		app.cmsBeginLoad(loadStateSet);
	endif;
	
	return persistentEntity.pxyCreateUpdateProxy;
	
epilog
	if needEndLoad then
		app.cmsEndLoad(loadStateSet);
	endif;
	
end;</source>
        <Parameter name="persistentEntity" type="CM_Object"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="createUserLog" id="e891d28b-189c-4578-bea9-be5f6d76d0fb">
        <updating/>
        <source>createUserLog(_fileName: String) : JadeLog updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
 	log : JadeLog;
begin
	create log;
	log.fileName := _fileName;
	log.versionFile := true;
	log.maxFileSize := 1048576; //1M
