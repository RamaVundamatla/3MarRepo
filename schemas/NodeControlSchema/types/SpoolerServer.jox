    <JadeMethod name="fileRejoin" id="4c561ac2-e85e-4f64-bd67-e3026a74eeb5">
        <updating/>
        <source>fileRejoin(originalFileName:String) updating;
//	Rejoins multiple bFiles into a single aFile.
//	aFile.fileName is originalFileName.
//	bFile.fileNames are &lt;originalFileName&gt;_n.
//	Numeric suffixes must be in order, starting with 1.
vars
	chunkSize,fileNum:Integer;
begin
	app.logMessage(method.qualifiedName&amp;" reconstituting "&amp;originalFileName);
	chunkSize:=10*1024;
	aFile.fileName:=originalFileName;
	aFile.kind:=File.Kind_Binary;
	aFile.mode:=File.Mode_Output;

	fileNum:=1;
	bFile.fileName:=originalFileName&amp;"_"&amp;fileNum.String;
	bFile.kind:=File.Kind_Binary;
	bFile.mode:=File.Mode_Input;
	if bFile.isAvailable=false then
		app.logMessage(method.qualifiedName&amp;" error -input file "&amp;bFile.fileName&amp;" not found");
		if app.applicationType=app.ApplicationType_GUI and node.isServerNode=false then
			app.msgBox("input file "&amp;bFile.fileName&amp;" not found",method.qualifiedName&amp;" error",MsgBox_OK_Only);
		endif;
		return;
	endif;
	app.logMessage(method.qualifiedName&amp;" reading file "&amp;bFile.fileName);
	while bFile.isAvailable do
		while not bFile.endOfFile do
			aFile.writeBinary(bFile.readBinary(chunkSize));
		endwhile;
		bFile.close;
		fileNum:=fileNum+1;
		bFile.fileName:=originalFileName&amp;"_"&amp;fileNum.String;
		app.logMessage(method.qualifiedName&amp;" reading file "&amp;bFile.fileName);
	endwhile;
	app.logMessage(method.qualifiedName&amp;" finished");
	aFile.close;
	bFile.close;
end;</source>
        <Parameter name="originalFileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="fileRename" id="af8b4354-91fc-42fc-9ef6-008bb5ee2405">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>fileRename(inFile:File io; newName:String) updating, serverExecution;
// This must be serverExecution otherwise the rename doesn't work over thin client.
// The rename method must not be serverExecution due to the jadrap memory leak with dbPath, fixed in 5.2?
begin
	inFile.rename(newName.toLower);
	inFile.fileName:=newName.toLower;
end;</source>
        <Parameter name="inFile" type="File" usage="io"/>
        <Parameter name="newName" type="String"/>
    </JadeMethod>
    <JadeMethod name="fileSplitup" id="40601d41-25f2-4ee5-bda9-6e4b75ee9ae7">
        <updating/>
        <source>fileSplitup(originalFileName:String; splitupSize:Decimal/*megabytes*/) updating;
//	Splits up a single aFile into multiple bFiles.
//	aFile.fileName is originalFileName.
//	bFile.fileNames are &lt;originalFileName&gt;_n.
//	Numeric suffixes are generated in order, starting with 1.
//	Actual splitup size is rounded up to next multiple of chunkSize.
//	Maximum splitup size is Max_Integer (~2gb).
//	No restriction on input file size.
vars
	chunkSize,fileNum:Integer;
begin
	app.logMessage(method.qualifiedName&amp;" splitting up "&amp;originalFileName&amp;" into "&amp;splitupSize.String&amp;"mb pieces");
	chunkSize:=10*1024;
	if splitupSize&lt;0 or splitupSize&gt;2047 then
		app.logMessage(method.qualifiedName&amp;" error - splitupSize cannot exceed 2047 mb");
		if app.applicationType=app.ApplicationType_GUI and node.isServerNode=false then
			app.msgBox("splitupSize cannot exceed 2047 mb",method.qualifiedName&amp;" error",MsgBox_OK_Only);
		endif;
		return;
	endif;
	aFile.fileName:=originalFileName;
	aFile.kind:=File.Kind_Binary;
	aFile.mode:=File.Mode_Input;
	if aFile.isAvailable=false then
		app.logMessage(method.qualifiedName&amp;" error -input file "&amp;aFile.fileName&amp;" not found");
		if app.applicationType=app.ApplicationType_GUI and node.isServerNode=false then
			app.msgBox("input file "&amp;aFile.fileName&amp;" not found",method.qualifiedName&amp;" error",MsgBox_OK_Only);
		endif;
		return;
	endif;

	fileNum:=1;
	bFile.fileName:=originalFileName&amp;"_"&amp;fileNum.String;
	bFile.kind:=File.Kind_Binary;
	bFile.mode:=File.Mode_Output;
	app.logMessage(method.qualifiedName&amp;" creating file "&amp;bFile.fileName);
	while not aFile.endOfFile do
		bFile.writeBinary(aFile.readBinary(chunkSize));
		if bFile.fileLength&gt;=splitupSize*1024*1024 then
			bFile.close;
			fileNum:=fileNum+1;
			if fileNum mod 100=0 then  // must be something wrong?
				if app.applicationType=app.ApplicationType_GUI and node.isServerNode=false then
					if app.msgBox("more than "&amp;fileNum.String&amp;" files - continue?",method.qualifiedName&amp;" error",MsgBox_OK_Cancel)&lt;&gt;1 then
						return;
					endif;
				else
					app.logMessage(method.qualifiedName&amp;" more than "&amp;fileNum.String&amp;" files");
					return;
				endif;
			endif;
			bFile.fileName:=originalFileName&amp;"_"&amp;fileNum.String;
			app.logMessage(method.qualifiedName&amp;" creating file "&amp;bFile.fileName);
		endif;
	endwhile;
	app.logMessage(method.qualifiedName&amp;" finished");
	aFile.close;
	bFile.close;
end;</source>
        <Parameter name="originalFileName" type="String"/>
        <Parameter name="splitupSize" type="Decimal"/>
    </JadeMethod>
