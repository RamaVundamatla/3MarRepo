    <JadeMethod name="getXMLSettingsForSave" id="6b5da49f-8281-40a7-96c1-54ba58837432">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//cnwas3 par 28400
vars

	theXML : String;
	
begin
	theXML := inheritMethod();

	theXML := theXML &amp; 
			
			global.formatAsXML(XML_EF,(self.btnEnhancedCargo.enabled = true).Integer.String);

	return theXML;

end;
</source>
        <ReturnType type="String"/>
