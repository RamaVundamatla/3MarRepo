    <JadeMethod name="doSave" id="e1e59abd-a771-42af-953f-4d6ff86ae1b4">
        <updating/>
        <source>doSave(): Boolean updating;
//-----------------------------------------
//
// Created : by cnwaer1 19 August 2008
//-----------------------------------------
vars
	proxyDeliveryRelReason	: CM_DeliveryReleaseReason;
	lCode					: Integer;
	lDescription			: String;
	theForm 				: SOP_TableMaintForm;
begin
	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Id).Integer;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DeliveryReleaseReason transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyDeliveryRelReason := theForm.myProxyObject.CM_DeliveryReleaseReason;
	proxyDeliveryRelReason.setProxy(lCode, lDescription);

	if theForm.mode = theForm.Mode_Add then
		 app.myTrxCA.trxCreateDeliveryRelReason(proxyDeliveryRelReason, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDeliveryReleaseReason(proxyDeliveryRelReason, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
