    <JadeMethod name="getJobOperationsPosition" id="c5d450c1-d2d2-4851-a008-a8e6774d0a60">
        <source>getJobOperationsPosition(_voyageJob : CM_VoyageJob) : Integer;

// Created by cnwdvb1 on 27 February 2007

vars

	pos 		: Integer;
	tmpJob		: CM_Job;

begin

	foreach tmpJob in self.allJobsByOrder do
		if tmpJob.CM_VoyageJob.isLoadedToOperations then
			pos := pos + 1;
		endif;
						
		if tmpJob = _voyageJob then
			break;
		endif;
	endforeach;
	
	return pos;

end;</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getJobTotalsCrane" id="63dcae64-c060-4b4f-9d6e-935f43ae90f8">
        <source>getJobTotalsCrane(_completed, _unactioned,_partCompleted : Integer output);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aJob : CM_Job;
	total : Integer;
begin
	foreach aJob in self.allJobsByOrder discreteLock do
		if aJob.status = JOB_COMPLETE then
			_completed := _completed + 1;
		elseif aJob.status = JOB_UNACTIONED then
			_unactioned := _unactioned + 1;
		elseif aJob.status = JOB_PART_COMPLETE then
			_partCompleted := _partCompleted + 1;
		endif;
	endforeach;
	

end;</source>
        <Parameter name="_completed" type="Integer" usage="output"/>
        <Parameter name="_unactioned" type="Integer" usage="output"/>
        <Parameter name="_partCompleted" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getJobTotalsCranePC" id="9aa97b1b-ebaf-4e64-a2ef-f8b7586b7aa6">
        <source>getJobTotalsCranePC(_completed, _unactioned,_partCompleted : Integer io);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aJob : CM_Job;
	total : Integer;
begin
	
	total := _completed +  _unactioned + _partCompleted;

	
	if total &gt; 0 then
		_completed := ((_completed / total) * 100).Integer;
		_unactioned := ((_unactioned / total) * 100).Integer;
		_partCompleted := ((_partCompleted / total) * 100).Integer;
		
		total := _completed +  _unactioned + _partCompleted;
		// rounding
		if total &lt; 100 then
			_completed := _completed + (100 - total);
		endif;
	endif;

end;</source>
        <Parameter name="_completed" type="Integer" usage="io"/>
        <Parameter name="_unactioned" type="Integer" usage="io"/>
        <Parameter name="_partCompleted" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getJobsForPlanning" id="12ad32da-bc36-4116-a5e8-dc43daa09987">
        <source>getJobsForPlanning(_jobs : Collection input);
/*

Date		Who		Reason
27 March 2017	cnwer1	Initial creation TFS 830

*/

vars
	job : CM_Job;
	vJob : CM_VoyageJob;
begin
	foreach job in self.allJobsByOrder discreteLock do
		vJob := job.CM_VoyageJob;
		if vJob.isValidForLoadPlanning() then
			_jobs.add(job);
		endif;
	endforeach;


epilog

end;</source>
        <Parameter name="_jobs" type="Collection" usage="input"/>
    </JadeMethod>
