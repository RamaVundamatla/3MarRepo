vars

begin
	if folder.topSheet = self.shtColumnFilter then	//20 Dec 2011	NDL	Par 28889
		self.showFilterSheet();
	elseif folder.topSheet = self.shtColumnSorter then
		//13/01/2011 cnwdz2 25840
		self.btnResetJMT.visible := false;
		self.btnResetSys.visible := false;
		self.cbxSystem.visible := false;
		self.setColumnSorter(false);
		// cnwrl1 20/03/2009 PAR 19174
		self.doResize;		// in particular this positions the "AD" button.
	else
		//13/01/2011 cnwdz2 25840
		self.btnResetJMT.visible := true;
		self.btnResetSys.visible := true;
		self.cbxSystem.visible := true;
	endif;
	
end;</source>
