    <JadeMethod name="setValueFromCMIF" id="17cd9647-3f4b-484f-ac3f-b1c0b4bd709e">
        <updating/>
        <source>setValueFromCMIF(_cmif : CMIF_CashInvoiceProformaCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//11/07/2024	navkc1 CR 64838 Task 64853: Jade - New Cash API putProformaStatus

*/

vars
	cashReceipt : CM_CashReceipt;
	now			: TimeStamp;
	terminal	: CM_Terminal;
	wsReceiptHeader : WS_ProformaHeader;
	wsReceiptDetails : WS_ProformaDetails;
	object	: Object;
	cashPayment : CM_CashPayment;
	cashCredit : CM_CashCredit;
	
begin
	cashReceipt := _cmif.myNewCashReceipt;
	
	if cashReceipt = null then
		return;
	endif;
	
	terminal := _cmif.myTerminal;
	if terminal = null then
		terminal := cashReceipt.myTerminal;
	endif;
	
	self.bol := cashReceipt.getBOLNumber();
	self.cargoID := _cmif.getAllTisID();
	// Cash receipt header
	if terminal &lt;&gt; null then
		//self.currencyCode := terminal.getConfig(CurrencyCodeForAPI).asStringJSON();
		self.currencyCode := terminal.getConfig(CurrencyCodeForAPI).asString(); //23/08/2024	navkc1 Bug 65781
	endif;
	self.customsAgentCode := _cmif.myDebtorAgentId;
	self.document := _cmif.document;
	 //19/08/2024	navkc1 Defect 65691
	if cashReceipt.paymentStatus &gt;= CM_CashReceipt.API_RECEIPT_PAID then
		self.finalReceiptNumber := cashReceipt.sequenceNum;
	else
		self.draftReceiptNumber := cashReceipt.sequenceNum;
	endif;
	//self.effectiveDate := cashReceipt.effectiveDate.asStringJSON();
	self.effectiveDate := cashReceipt.effectiveDate.asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	self.externalFinancialId := cashReceipt.externalFinancialId;
	self.externalReceiptNumber := cashReceipt.externalReceiptNumber;
	self.externalRef1 := cashReceipt.externalRef1;
	self.externalTransaction := cashReceipt.externalTransaction;
	self.externalUserCode := cashReceipt.externalUserCode;
	//self.finalReceiptNumber := cashReceipt.sequenceNum; //19/08/2024	navkc1 Defect 65691
	self.paymentStatus := app.paymentStatusCashEnumToString(cashReceipt.paymentStatus);
	self.remarks := cashReceipt.remarks;
	//self.shipReleaseDate := cashReceipt.shipReleaseDate.asStringJSON();
	self.shipReleaseDate := cashReceipt.shipReleaseDate.asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	self.voyageCode := cashReceipt.getVoyageCode();
	
	// Receipt Header
	create wsReceiptHeader transient;
	wsReceiptHeader.setValuesFromCMIF2(cashReceipt, _cmif);
	self.cashReceiptHeader := wsReceiptHeader;
	
	// Receipt Details
	foreach object in cashReceipt.allCashPayments do
		if object.isKindOf(CM_CashPayment) then
			cashPayment := object.CM_CashPayment;
		else
			continue;
		endif;
		
		create wsReceiptDetails transient;
		wsReceiptDetails.setValuesFromCMIF(cashPayment, cashCredit);
		wsReceiptHeader.allProformaDetails.add(wsReceiptDetails);
	endforeach;
epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_CashInvoiceProformaCtrl"/>
    </JadeMethod>
</Class>
