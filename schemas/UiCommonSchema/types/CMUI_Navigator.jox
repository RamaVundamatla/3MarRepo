    <JadeMethod name="btnCollapseNav_click" id="0dbcc77d-b5b0-48cf-9117-457fbabc4572">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCollapseNav_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/03/2025	navlw1	JIRA-33938: MTN | Navigator Collapse Option
*/

vars
	index, termIdx : Integer;
	selectedTerm : CM_Terminal;
	obj : Object;
begin

	index := 1;
	while index &lt;= self.lstTest.listCount do
		
		if process.isJLGAB1 then
			obj := self.lstTest.itemObject[index];
			if obj.isKindOf(CM_MenuRootUserTerminal) then
				if obj.CM_MenuRootUserTerminal.getMyTerminal() = self.myCurrentTerminal  and termIdx = 0 then
					termIdx:= index;
				endif;
			elseif obj.isKindOf(CM_MenuUserRootForRoot) then // system
				if self.lstTest.itemExpanded[index] = true then // expanded
					termIdx := index;
				endif;
			endif;
		endif;

		self.lstTest.itemExpanded[index] := false;
		index +=1;
		
	endwhile;
	
	if termIdx &gt; 0 then
		self.lstTest.itemExpanded[termIdx] := true;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
