    <JadeMethod name="setDefaultsFromBooking" id="293c5f18-f7c9-4a9a-940e-98edbe47f88a">
        <source>setDefaultsFromBooking(_booking : CM_BookingRef);
//15 March 2010	cnwml2


vars
	bookingSelectForm	: CMUI_SelectBookingRefForm;

begin	
	//if _booking.myOperator.code &lt;&gt; self.tblContainer.getValueByName(ETRow_VoyageRight).String or
	if (_booking.myVoyage &lt;&gt; null and _booking.myVoyage.code &amp; " " &amp; _booking.myVoyage.vesselCode &lt;&gt; self.tblContainer.getValueByName(ETRow_VoyageRight).String) or			//+cnwml2 PAR23925 CCMS MES 1076
	  _booking.dischargePort &lt;&gt; self.tblContainer.getValueByName(ETRow_DisPortRight).String then
		create bookingSelectForm;
		bookingSelectForm.myCurrentTrackedItem := self.myTerminal.allOnsiteTIsByCargoTypeId[1, self.tblContainer.getValueByName(ETRow_ContainerID).String];
		bookingSelectForm.allBookingRefs.add(_booking);
		bookingSelectForm.txtDestination.visible := false;
		bookingSelectForm.lDestination.visible := false;
		
		bookingSelectForm.showModal();
		
		if bookingSelectForm.modalResult = ModalResultOK then
			self.tblContainer.setValueByControlName(self.cmbVoyageRight.name, _booking.myVoyage.getDisplayDetails(false));
			self.cmbVoyageRight.listObject := _booking.myVoyage;									//+cnwml2 PAR22785
			self.tblContainer.setValueByControlName(self.cmbDisPortRight.name, _booking.dischargePort);
			self.cmbDisPortRight.listObject := app.myRoot.allPorts[_booking.dischargePort];			//+cnwml2 PAR22785
			self.tblContainer.setValueByControlName(self.cmbDestPortRight.name, _booking.destinationPort);
			// from par 27720 testing July 2011 cnwjre1
			if self.cmbDestPortRight.findString(1, _booking.destinationPort) &gt; 0 then
				self.cmbDestPortRight.listObject := app.myRoot.allPorts[_booking.destinationPort];			//+cnwml2 PAR24740
			endif;
			self.tblContainer.setValueByControlName(self.cmbOperatorRight.name, _booking.myOperator.code);	// #26475 08/12/2010
			self.cmbOperatorRight.listObject := _booking.myOperator;										// #26475 08/12/2010
			
		endif;
	endif;
	
epilog	

end;</source>
        <Parameter name="_booking" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setSealTable" id="fd6b0f6f-bbf1-4e09-a20f-938d9fba05d0">
        <source>setSealTable(_sealNumbers : String);
//23 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131

vars
	tbl			: CM_Table;
	sealsList	: StringArray;
	intRow		: Integer;
	strSeal		: String;
begin
	tbl := self.tblSeals;
	tbl.clear;
	
	create sealsList transient;
	_sealNumbers.getTokensForDelimiter(',', sealsList);
	
	intRow := tbl.fixedRows + 1;
	foreach strSeal in sealsList do
		if intRow &gt; tbl.rows then
			tbl.addItemAt(strSeal.trimBlanks, intRow);
		else
			tbl.accessCell(intRow, 1).text := strSeal.trimBlanks;
		endif;
		intRow := intRow + 1;
	endforeach;
	
epilog
	delete sealsList;
end;</source>
        <Parameter name="_sealNumbers" type="String"/>
    </JadeMethod>
    <JadeMethod name="setState" id="7f75a652-91b0-438d-8f15-e6892a1a5179">
        <source>setState(_state : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     21 February 2003		cnwth2	
//
// Purpose:     Used to put the form into various states by way of disabling/enabling controls etc	 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if _state = STATE_DISABLED then	 
		self.btnPack.enabled := false;
		self.btnUnpack.enabled := false;
		self.btnSaveBase.enabled := false;
		self.btnCancelBase.enabled := false;		// 28474 disable Cancel until change made
		self.btnPack.caption := app.getErrorString(Pack);	
	elseif _state = STATE_ENABLED then
		self.btnPack.enabled := true;
		
		self.btnCreateLCL.enabled := true;
		self.btnSaveBase.enabled := true;
		self.btnUnpack.enabled := true;
		self.btnPack.enabled := true;
		
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnPack.enabled:= false;
		self.btnUnpack.enabled:= false;
		self.btnSaveBase.enabled := false;
		self.btnCancelBase.enabled := false;	
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSubTerminalDefault" id="e06ac040-3032-49f6-921b-db4ec238f78f">
        <source>setSubTerminalDefault(_tableObj:CM_EntryTable input) protected;
// --------------------------------------------------------------------------------
// Created:		06 May 2009 by cnwdad1
//
// Purpose:		Using currently entered details, determine a default Sub-Terminal
//				for the current cargo.
//
// Parameters:	_tableObj - A reference to the current data entry table.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 02/02/2010	cnwdad1		PAR 22205.  The release type parameter was added to the
//							CM_Terminal::getDefaultSubTerminal method, but it has
//							no relevance to this method, so we just pass "0".
// --------------------------------------------------------------------------------
vars
	imexStatusObj	: CM_IMEXStatus;
	imexStatus		: Integer;
	commodityObj	: CM_Commodity;
	commodCode		: String;
	terminalObj		: CM_Terminal;
	subTerminalObj	: CM_SubTerminal;
	cargoTypeObj	: CM_CargoBOLType;
	subTerminaType	: Integer;
	isContainer		: Boolean;
	tmpCombo		: ComboBox;
//	releaseType		: Integer;
	
begin
	terminalObj		:=	self.myTerminal;
	
	if cmbTrackedItem.listIndex &lt;&gt; CNEC_NULL_INDEX then
		cargoTypeObj	:=	cmbTrackedItem.listObject.CM_TrackedItem.myCargoType;
	endif;
	
	tmpCombo		:=	cmbImEx;
	if tmpCombo &lt;&gt; null then
		imexStatusObj	:=	tmpCombo.listObject.CM_IMEXStatus;
	endif;
	
	tmpCombo		:=	cmbCommodity;
	if tmpCombo &lt;&gt; null then
		commodityObj	:=	tmpCombo.listObject.CM_Commodity;
	endif;
	
	isContainer		:=	false;
	
	if cargoTypeObj &lt;&gt; null then
		if cargoTypeObj.isCargoType() then
			if cargoTypeObj.id = TI_CargoType_Container then
				isContainer		:=	true;
				subTerminaType	:=	CM_SubTerminal.Type_TrackedItem;
//				releaseType		:=	0;		// cnwdad1 01/02/2010 - PAR #22205.
			else
				subTerminaType	:=	CM_SubTerminal.Type_BulkRelease;
// cnwrs2/cnwdad1 01/02/2010 - PAR #22205.
// Ignore Bulk Release here as this is only ever the target release
// The same as per the Gate In/Out screen.
//				releaseType		:=	bulkRelObj.type; // or just BR_TYPE_PACKING ???
			endif;
		else
			subTerminaType	:=	CM_SubTerminal.Type_BOL;
//			releaseType		:=	0;			cnwdad1 01/02/2010 - PAR #22205.
		endif;
	endif;
	
	if imexStatusObj &lt;&gt; null then
		imexStatus	:=	imexStatusObj.code;
	endif;
	
	if commodityObj &lt;&gt; null then
		commodCode	:=	commodityObj.code;
	endif;
	
	subTerminalObj	:=	terminalObj.getDefaultSubTerminal(	subTerminaType,
															0,	// cnwdad1 27/01/2010 - PAR #22205.
															imexStatus,
															commodCode,
															isContainer);
	
	if subTerminalObj &lt;&gt; null then
		tmpCombo	:=	cmbSubTerminal;
		tmpCombo.cnEcSetObjectIndex(subTerminalObj);
		_tableObj.setValueByName(ETRow_MySubTerminal, subTerminalObj.code);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_tableObj" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="9a1c1c42-fc1c-4e0c-8d08-d253721b3036">
        <updating/>
        <source>setTableDataFromOrganiser( _theTable : CM_DataTable input ) updating;

/*
Date			Who		Reason
13 October 2010	cnwrl1	Initial creation as part of PAR 23899/25674 - Pack/Unpack form column organiser.
*/
	
vars
	
begin
	self.doRefresh();
	
epilog
	
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
