    <JadeMethod name="setForCreate" id="cc4c99e5-1bc1-4485-93f8-f415457f6ed3">
        <updating/>
        <source>setForCreate(pCategoryName, pDescription, pInputControlName, pInputType, pName : String; pScreenOrder : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     06 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.categoryName 	:= pCategoryName;
	self.description	:= pDescription;
	self.inputControlName := pInputControlName;
	self.inputType		:= self.getInputType(pInputType);
	self.name			:= pName;
	self.screenOrder	:= pScreenOrder;

end;</source>
        <Parameter name="pCategoryName" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pInputControlName" type="String"/>
        <Parameter name="pInputType" type="String"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pScreenOrder" type="Integer"/>
    </JadeMethod>
