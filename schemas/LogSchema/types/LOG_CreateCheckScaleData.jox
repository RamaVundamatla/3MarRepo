    <JadeMethod name="create" id="040f025f-32f4-431e-ba26-2951968156d6">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.permissionMaint := PmLogCheckScaleMaint;
	self.permissionView := PmLogCheckScaleMaint;
	
	self.helpFileName := HelpFile_Logs;

end;</source>
    </JadeMethod>
    <JadeMethod name="displayDetails" id="9208da73-671f-430b-9660-3b0fbc9bee95">
        <source>displayDetails() protected;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	scaleDtl			: CM_LogCheckScaleDtl;
	tbl					: CM_DataTable;
	row					: Integer;
begin
	if self.myCheckScaleHdr = null then
		return;
	endif;

	tbl := self.tblDetail;
	tbl.rows := tbl.fixedRows;
	foreach scaleDtl in self.myCheckScaleHdr.allCheckScaleDtls do
		row := tbl.addItem(scaleDtl.logId &amp; Tab &amp;
							scaleDtl.checkSEDMin.String &amp; Tab &amp;
							scaleDtl.checkSEDMax.String &amp; Tab &amp;
							scaleDtl.checkConditionCode);
							
		tbl.accessRow(row).itemObject := scaleDtl;			
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAddDetail" id="55246c8f-0591-48dd-9503-bef85f9b6fd0">
        <source>doAddDetail() protected;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	chkScaleDtl			: CM_LogCheckScaleDtl;
begin

	create chkScaleDtl transient;
	
	chkScaleDtl.setProxy(self.myCheckScaleHdr,
						self.tblEntDetail.getValueByName(ETRow_LogId).String,
						self.tblEntDetail.getValueByName(ETRow_CheckConditionCode).String,
						self.tblEntDetail.getValueByName(ETRow_CheckSEDMin).Decimal,
						self.tblEntDetail.getValueByName(ETRow_CheckSEDMax).Decimal);
						
	
	self.displayDetails();
	self.tblEntDetail.setFocus();
	self.tblEntDetail.goToRowByName(ETRow_LogId);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRemoveDetail" id="40329a16-c66f-4c75-b2c4-2542cba1d3db">
        <source>doRemoveDetail() protected;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	chkScaleDtl			: CM_LogCheckScaleDtl;
begin
	chkScaleDtl := self.tblDetail.accessRow(self.tblDetail.row).itemObject.CM_LogCheckScaleDtl;
	delete chkScaleDtl;
	
	self.displayDetails();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="409caeef-7b10-4f19-adca-b2bb35a0e13b">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.tblDetail.height := self.height - 350;
	self.tblDetail.width := self.width - 30;
	self.tblEntDetail.width := self.width - 30;
	self.tblEntHeader.width := self.width - 30;
	
	self.tblEntDetail.resetSize();
	self.tblEntHeader.resetSize();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="4d6f68f2-f38f-41cc-82fd-db511dff067f">
        <updating/>
        <source>doSave() protected, updating;
// ---------------------------------------------------------------------------
// Created:     14 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	newChkScaleHdr			: CM_LogCheckScaleHdr;
	timeStamp				: TimeStamp;
	result					: Integer;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
//	timeStamp.setDate(self.tblEntHeader.getValueByName(ETRow_Date).Date);
	timeStamp.setDate(self.tblEntHeader.getValueAsDate(ETRow_Date));
	timeStamp.setTime(self.tblEntHeader.getValueByName(ETRow_Time).Time);
	
	self.myCheckScaleHdr.setProxy(self.myTerminal.code,
									self.tblEntHeader.getValueByName(ETRow_UserCode).String,
									self.localToSystemTime(timeStamp));// 15 June 2016	cnwns1	TFS 488 - Multi Timezone Support
									
	while true do
		app.myTrxCA.trxCreateCheckScalingBatch(self.myCheckScaleHdr,
											newChkScaleHdr,
											app.myPassport);
												
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.unloadForm();
			return;
		else
			result := app.showErrorWarningDialog('Create check scaling data', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return;
	endwhile;
	
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
