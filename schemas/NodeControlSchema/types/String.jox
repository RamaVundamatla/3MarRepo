<PrimType name="String">
    <JadeMethod name="cnContains" id="5f8e29d3-d7e8-4dbd-b919-3e9474e2972b">
        <source>cnContains(str : String) : Boolean;		// returns true if self contains the string in str (case-sensitive)

vars
	pos : Integer;
	len	: Integer;
begin
	pos := self.pos(str, 1);
	if pos &gt; 0 then
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="str" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcFindReplace" id="b0767da6-61bf-43ff-ae2c-88f94b4c27d3">
        <source>cnEcFindReplace(pScanFor:String; pReplaceWith:String; pIsFirstOnly:Boolean):String;
// --------------------------------------------------------------------------------
// Created:		01 January 2001 by cnwdad1
//
// Purpose:		The receiver is scanned for occurances of the pScanFor value and
//				these are replaced by the pReplaceWith string.
//
// Parameters:	pScanFor - The substring to search for and replace.
//				pReplaceWith - The value to replace the substring with.
//				pIsFirstOnly - If true, only the first instance of the substring
//					will be replaced.
//
// Returns:		The receiver with the substring(s) replaced.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 09/11/2002	cnwdad1		Changed to handle a null replacement value.
// --------------------------------------------------------------------------------
vars
	posIndex			: Integer;		// Index position in the current field.
	endOfFirstPart		: Integer;		// Points to the end position of the receiver upto the substring to be replaced.
	startOfSecondPart	: Integer;		// Points to the start position of the receiver after the substring to be replaced.
	lengthOfScanFor		: Integer;		// The length of the substring to be replaced.
	lengthOfReplacement	: Integer;		// The length of the replacement substring.
	workString			: String;		// Replacement value of current field.

begin
	workString			:=	self;

	if pScanFor = workString then
		// If the substring is the same as the receiver, then we can save
		// ourselves some work by simply returning the replacement value.
		return pReplaceWith;
	endif;

	lengthOfScanFor		:=	pScanFor.length;
	lengthOfReplacement	:=	pReplaceWith.length;
	posIndex			:=	1;
	
	while true do
		posIndex	:=	workString.pos(pScanFor, posIndex);
		
		if posIndex = 0 then
			break;
		endif;
		
		endOfFirstPart		:=	posIndex - 1;
		startOfSecondPart	:=	posIndex + lengthOfScanFor;
		
		if endOfFirstPart = 0 then
			if workString = pScanFor then								// cnwdad1 09/11/2002.
				workString	:=	pReplaceWith;							// cnwdad1 09/11/2002.
			elseif pReplaceWith = null then								// cnwdad1 09/11/2002.
				workString	:=	workString[startOfSecondPart:end];		// cnwdad1 09/11/2002.
			else														// cnwdad1 09/11/2002.
				workString	:=	pReplaceWith &amp; workString[startOfSecondPart:end];
			endif;														// cnwdad1 09/11/2002.
		else
			if startOfSecondPart &gt; workString.length then
				workString	:=	workString[1:endOfFirstPart] &amp; pReplaceWith;
			else
				workString	:=	workString[1:endOfFirstPart] &amp; pReplaceWith &amp; workString[startOfSecondPart:end];
			endif;
		endif;
		
		if pIsFirstOnly then
			break;
		endif;
		
		posIndex	:=	posIndex + lengthOfReplacement;
	endwhile;
	
	return workString;
end;</source>
        <Parameter name="pScanFor" type="String"/>
        <Parameter name="pReplaceWith" type="String"/>
        <Parameter name="pIsFirstOnly" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="contains" id="9e7946fc-c040-4430-ad2c-434af875568d">
        <source>contains(str:String):Boolean;		// returns true if self contains the string in str (case-sensitive)

vars
	pos : Integer;
	len	: Integer;
begin
	pos := self.pos(str, 1);
	if pos &gt; 0 then
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="str" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="encryptName" id="91b85f2f-afbc-4852-8b06-c36fde4b4443">
        <updating/>
        <source>encryptName() updating;
// Encrypt the 2nd and subsequent letters in the string
vars
	max,i:Integer;
	s:String;
begin
	s:=self;
	max:=s.length;
	if max &lt;= 1 then
		return;
	endif;
	
	foreach i in 2 to max do
		s[i]:=app.random(25).letter;
	endforeach;
	self:=s;
end;</source>
    </JadeMethod>
    <JadeMethod name="encryptNumber" id="c327624a-02d1-4d95-ade2-0c055c7a3f96">
        <updating/>
        <source>encryptNumber() updating;
// Encrypt the 2nd and 6th characters in the string to a random number
vars
	s:String;
begin
	s:=self;
	if s.length &lt;= 1 then
		return;
	endif;

	s[2:1]:=app.random(9).String;
	if s.length &gt; 5 then
		s[6:1]:=app.random(9).String;
	endif;
	self:=s;
end;</source>
    </JadeMethod>
    <JadeMethod name="encryptPostcode" id="efcfc593-7fd8-4737-acfb-98f05ea9a511">
        <updating/>
        <source>encryptPostcode() updating;
// Encrypt the 2nd and 6th letters in the string to a random letter
vars
	s:String;
begin
	s:=self;
	if s.length &lt;= 1 then
		return;
	endif;

	s[2] := app.random(25).letter;
	if s.length &gt; 5 then
		s[6] := app.random(25).letter;
	endif;
	self:=s;
end;</source>
    </JadeMethod>
    <JadeMethod name="encryptStreet" id="2b4bd578-c734-47bd-a565-5fb6ebc34be6">
        <updating/>
        <source>encryptStreet() updating;
// Encrypt the string to a random "MAIN ST" address
vars
	s:String;
begin
	if self = null then
		return;
	endif;
	
	s:=app.random(9999).String &amp; app.random(9999).String &amp; " MAIN ST";
	self:=s;
end;</source>
    </JadeMethod>
    <JadeMethod name="fillWithRubbish" id="9e6d5575-1101-4d1a-999d-a306e5b9f27c">
        <updating/>
        <source>fillWithRubbish() updating;

vars
	i,j,k,selfLength,len,remain:Integer;
begin
	selfLength:=self.length;
	while i &lt; selfLength do
		len:=(selfLength-i).min(10000);
		self[i+1:len]:=Gc_Rubbish[1:len];
		i:=i+10000;
	endwhile;
end;
</source>
    </JadeMethod>
    <JadeMethod name="replace" id="efe78ee0-4889-4909-a119-f291d45e15e8">
        <source>replace(scanFor,replaceWith:String):String;

begin
	return self.cnEcFindReplace(scanFor,replaceWith,false);
end;</source>
        <Parameter name="scanFor" type="String"/>
        <Parameter name="replaceWith" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="rightAlign" id="475cff6f-2b1e-42e5-8c5d-3474df08d4c0">
        <source>rightAlign(len:Integer):String;

vars
	s:String;
	i:Integer;
begin
	i:=len-self.length;
	if i&gt;0 then
		s[i]:=" ";
	endif;
	return s&amp;self;
end;</source>
        <Parameter name="len" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
