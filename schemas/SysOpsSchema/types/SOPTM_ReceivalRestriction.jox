    <JadeMethod name="doCriteriaChange" id="41377541-f99c-4cc4-9093-4a81c3f25f8d">
        <source>doCriteriaChange(_table :CM_EntryTable input;  _defaultRelativeTo, _criteriaType :String);
/*
Date		Who		Reason
29 February 2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	type	:Integer;
begin 
	type := CM_ReceivalCutoffTermDef.CriteriaType_CARGO;
	_table.showRowByName(ETRow_DefaultEarliestReceival, false);	// 12/10/2012 cnwar2 #30508
	_table.showRowByName(ETRow_DefaultEarliestReceivePN, false);	//20/03/2025	navkc1 JIRA Story MTN-34231
	
	if _criteriaType = CM_ReceivalCutoffTermDef.CriteriaType_EDI_Desc then
		type := CM_ReceivalCutoffTermDef.CriteriaType_EDI;
		_table.hideRowByName(ETRow_DefaultEarliestReceival, false);	// 12/10/2012 cnwar2 #30508	
		_table.hideRowByName(ETRow_DefaultEarliestReceivePN, false);	//20/03/2025	navkc1 JIRA Story MTN-34231
	endif;
	
	self.myForm.myAssistant.comboBoxDefaultRelativeTo(_table, ETRow_DefaultRelativeTo, 
														_defaultRelativeTo, 
														type);
	
	_table.adjustHeight(800);
	
epilog

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_defaultRelativeTo" type="String"/>
        <Parameter name="_criteriaType" type="String"/>
    </JadeMethod>
    <JadeMethod name="doDefaultRelativeToChange" id="6dc655b6-b9d9-4c89-a965-575f74a014c5">
        <source>doDefaultRelativeToChange(_table :CM_EntryTable input; _value :Integer);
/*
Date		Who		Reason
29/02/2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars

begin
	if _value = DefaultRelativeTo_ShipExchange then
		// no earliest receival
		_table.setValueByName (ETRow_DefaultEarliestReceival, null);
		_table.setValueByName (ETRow_DefaultEarliestReceivePN, null); //20/03/2025	navkc1 JIRA Story MTN-34231
		_table.disableRowByName (ETRow_DefaultEarliestReceival);
		_table.disableRowByName (ETRow_DefaultEarliestReceivePN); //20/03/2025	navkc1 JIRA Story MTN-34231
		
	elseif _value = DefaultRelativeTo_RecCutOff then
		// clear Default cutoff &amp; default earliest receival
		_table.setValueByName (ETRow_DefaultCutoff, null);
		_table.setValueByName (ETRow_DefaultEarliestReceival, null);
		_table.setValueByName (ETRow_DefaultCutoffPN, null); //20/03/2025	navkc1 JIRA Story MTN-34231
		_table.setValueByName (ETRow_DefaultEarliestReceivePN, null); //20/03/2025	navkc1 JIRA Story MTN-34231
		_table.disableRowByName (ETRow_DefaultCutoff);
		_table.disableRowByName (ETRow_DefaultEarliestReceival);
		_table.disableRowByName (ETRow_DefaultCutoffPN); //20/03/2025	navkc1 JIRA Story MTN-34231
		_table.disableRowByName (ETRow_DefaultEarliestReceivePN); //20/03/2025	navkc1 JIRA Story MTN-34231
	else
		_table.enableRowByName (ETRow_DefaultCutoff);
		_table.enableRowByName (ETRow_DefaultEarliestReceival);
		_table.enableRowByName (ETRow_DefaultCutoffPN); //20/03/2025	navkc1 JIRA Story MTN-34231
		_table.enableRowByName (ETRow_DefaultEarliestReceivePN); //20/03/2025	navkc1 JIRA Story MTN-34231
	endif;
epilog

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="5f819396-cf1f-45c1-bb94-5b051ca57760">
        <updating/>
