    <JadeMethod name="setForCreate" id="893e6156-7fc3-4392-80df-d223688e347e">
        <updating/>
        <source>setForCreate(_proxy: CM_CashPayment) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Nov 2017	jlgmp6	Initial creation
25 Sep 2019 cnwma1	Bug 46645: New cash form - subsequent payments going to default business unit 
16 Jan 2020 cnwma1	Bug 48298: ADP - FW: Ticket 48149 - Minimum Charge Line remove in UAT
*/

vars
	taxPayment, 
	pxyTaxPayment    : CM_CashPayment;
	inv 			 : CM_Invoice;
	pxyCreditDetail,
	cashCreditDetail : CM_CashCreditDetail;
begin

	// ### TAX APPLIED
	pxyTaxPayment := _proxy.myCashPaymentForTax;
	if pxyTaxPayment &lt;&gt; null then
	
		create taxPayment; 						// TFS 7357
		taxPayment.setForCreate(pxyTaxPayment); // TFS 7357
		self.setMyCashPaymentForTax(taxPayment);

		// TFS 44275
		// ### CREDITS APPLIED
		if pxyTaxPayment.allCashCreditDetails.isNotEmpty() then
			
			foreach pxyCreditDetail in pxyTaxPayment.allCashCreditDetails	discreteLock do
				pxyCreditDetail.setCashPayment(taxPayment);
	
				create cashCreditDetail;
				cashCreditDetail.setForCreate(pxyCreditDetail);
			endforeach;
		
		endif;
		
	endif;
	
	// TFS 44275
	// ### PROFORMA DETAIL
	if _proxy.myProformaDetail &lt;&gt; null 
	and _proxy.myProformaDetail.isTransient then
		if self.myProformaDetail = null then
			create self.myProformaDetail;
			self.myProformaDetail.setForCreate(_proxy.myProformaDetail );
			self.myProformaDetail.setMyCashReceipt(_proxy.myCashReceipt);
			self.setProformaDetail(self.myProformaDetail);
		endif;	
	endif;

	
	// TFS 44275
	// ### CREDITS APPLIED
	if _proxy.allCashCreditDetails.isNotEmpty() then

		foreach pxyCreditDetail in _proxy.allCashCreditDetails	discreteLock do
			pxyCreditDetail.setCashPayment(self);

			create cashCreditDetail;
			cashCreditDetail.setForCreate(pxyCreditDetail);
		endforeach;
	endif;	
	
	inheritMethod(_proxy);
	
	// TFS 39443 - create an invoice line for manual cash payments
	// ### MANUAL PAYMENT
	if self.manual then
		if self.myCashReceipt &lt;&gt; null then
			inv := self.myCashReceipt.getCashInvoice();           // 25.05.2019 cnwma1 #46645
			
			if inv &lt;&gt; null then
				
				self.createInvoiceLineFromProforma(inv, true);
				
				// TFS 45953 cash payments have either an invoice line OR a proformaDesc, never both
				//						NOTE myProformaDetail must be created above as it is used to create this manual invoice line
				if self.myInvoiceLine &lt;&gt; null // just created
				and self.myCashReceipt&lt;&gt; null then
				//	TFS 47847 cash payments either have an invoice line OR a profroma detail, however the proforma detail is always kept on the receipt
				//	TFS 47847 self.myCashReceipt.allProformaDetails.remove(self.myProformaDetail);
					//self.myCashReceipt.allInvoiceLines.add(self.myInvoiceLine);					 //	TFS 47847 	//16.01.2020 cnwma1 #48298
					self.myCashReceipt.allInvoiceLines.addNoDuplicates(self.myInvoiceLine,false);    				//16.01.2020 cnwma1 #48298
					self.myProformaDetail := null; //	TFS 47847
				endif;
				
				self.myInvoice := inv;
			endif;
		endif;
	endif;
	
	
epilog
	
end;</source>
        <Parameter name="_proxy" type="CM_CashPayment"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8d062037-b2a0-4118-b975-4fe69731543d">
        <updating/>
        <source>setForUpdate( _proxy: CM_CashPayment ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18/07/2012	cnwndl1	Initial creation
02/11/2015	cnwdap1	PAR #36909 CCMS ADP 2537 Minimum Charges
08/08/2017	jlgdap1	TFS 5740 AAT Changes to Pro Forma Invoices
16/01/2020  cnwma1	Bug 48298: ADP - FW: Ticket 48149 - Minimum Charge Line remove in UAT - ##336278##
07/04/2020  cnwma1	Bug 49079: AAT - Invoicing MTN
*/

vars

begin

	inheritMethod(_proxy);
	
	self.taxAmount        := _proxy.taxAmount;
	self.proformaDesc     := _proxy.proformaDesc;
	self.manual           := _proxy.manual;
	self.status           := _proxy.status;
	self.myVoyage         := _proxy.myVoyage; // TFS 37454
	self.myCarrier        := _proxy.myCarrier;
	self.myDriver         := _proxy.myDriver;
	self.myUser           := _proxy.myUser;
	self.myDebtorTerminal := _proxy.myDebtorTerminal;
	self.myTrackedItem    := _proxy.myTrackedItem;
	self.setVoided( _proxy.voided );
	
	// TFS 5740 don't set any of these references for proforma print objects	 // TFS 5740
	if not self.isCashPaymentProformaPrint then									 // TFS 5740
		self.myCashReceipt := _proxy.myCashReceipt;
		self.myInvoice     := _proxy.myInvoice;
		
		if _proxy.myInvoiceLine &lt;&gt; null then 									 // TFS 44275
			if not _proxy.myInvoiceLine.isTransient then 						 // TFS 44275 now creating cash payments and proforma details in a normal TRX
				self.myInvoiceLine := _proxy.myInvoiceLine; 					 // TFS 44275
					
				// TFS 48127 cash payment's invoice line must be on the same cash invoice as the payment				
				if self.myInvoiceLine.invoice &lt;&gt; self.myInvoice then
					if not  self.myInvoiceLine.invoice.isPostedOrReversal() then //07.04.2020 cnwma1 #49079
						self.myInvoiceLine.moveLineToInvoice(self.myInvoice);
					endif;
				endif;
			endif;
		else
			self.myInvoiceLine := _proxy.myInvoiceLine;
		endif; // TFS 44275
		
		if _proxy.myProformaDetail &lt;&gt; null then // TFS 44275
			if not _proxy.myProformaDetail.isTransient then // TFS 44275 now creating cash payments and proforma details in a normal TRX
				self.myProformaDetail := _proxy.myProformaDetail;
			endif;
		else
			self.myProformaDetail := _proxy.myProformaDetail; // TFS 44275 allow to be nulled. This happens when the invoic eline is set.
		endif;

		self.myTerminal := _proxy.myDebtorTerminal.myTerminal;
	else // TFS 47985 when recording a proforma print need the proforma details
		if _proxy.myInvoiceLine &lt;&gt; null then
			self.myProformaDetail := _proxy.myInvoiceLine.createProformaDetail(null);
		elseif _proxy.myProformaDetail &lt;&gt; null then
			if not _proxy.myProformaDetail.isTransient then 
				self.myProformaDetail := _proxy.myProformaDetail;
			else
				create self.myProformaDetail;
				self.myProformaDetail.setForCreate(_proxy.myProformaDetail );
				self.setProformaDetail(self.myProformaDetail);
			endif;
		endif;	
	endif;

	
	self.isMinimumCharge := _proxy.isMinimumCharge;
	
	if self.isMinimumCharge then                    //16.01.2020 cnwma1	#48298
		self.manual := true;
	endif;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_CashPayment"/>
    </JadeMethod>
