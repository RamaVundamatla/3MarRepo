    <JadeMethod name="rel851_tfs37190" id="2060a65c-a8f2-4be8-ac7f-8dc381a66546">
        <source>rel851_tfs37190();
//
//12 June 2018	jlgrs1	Initial creation
//
vars
	agent : EntTableAgent;
	array : StringArray;
	transAgent : CM_TranslationAgent;
	tmpArray : StringArray;
	newPerms : IntegerArray;
	termRole : CM_SecurityRoleTerminalRoot;
	sysRole : CM_SecurityRoleSystemRoot;
begin
	app.initialize();
/*	create agent transient;
	create array transient;
	agent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	array.add("ETRow_WebServiceType");
	array.add("ETRow_Name");
	array.add("ETRow_BaseEndpoint");
	array.add("ETRow_UserCode");
	array.add("ETRow_Password");
	array.add("ETRow_RestAPIAuthEndpoint");
	array.add("ETRow_RestAPIBaseEndpoint");
	array.add("ETRow_MaxRetries");
	array.add("ETRow_TimeBetweenRetries");
	array.add("ETGrp_ExtWebService");
	array.add("ETDef_ExtWebService");
	array.add("ETDef_ExtWebServiceTbl");
	array.add("ETRow_ExtWebService");
	array.add("ETDef_BgpController");
	agent.trxUpdateFromConstant(array);

	create transAgent transient;
	create tmpArray transient;
	tmpArray.add('Input_require_externa_service');
	tmpArray.add('Base_point');
	tmpArray.add('Type_invalid');
	tmpArray.add("Exter_servi_with_name_apos1_al");
	transAgent.trxLoadSpecificErrors(tmpArray);
*/	
	// load new permissions
	create newPerms transient;
	newPerms.add(PmAdmExtwebSrvMaint);
	newPerms.add(PmAdmExtwebSrvView);
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	beginTransaction;
	termRole.setPermissionsFromIntArray(newPerms, false);	//true if terminal permission
	sysRole.setPermissionsFromIntArray(newPerms, true);	//true if system permission
	commitTransaction;
	return;

	write ETRow_WebServiceType;
	write ETRow_Name;
	write ETRow_BaseEndpoint;
	write ETRow_UserCode;
	write ETRow_Password;
	write ETRow_RestAPIAuthEndpoint;
	write ETRow_RestAPIBaseEndpoint;
	write ETRow_MaxRetries;
	write ETRow_TimeBetweenRetries;
	write ETDef_ExtWebService;
	write ETDef_ExtWebServiceTbl;
	write ETGrp_ExtWebService;
	write Input_require_externa_service;
	write Base_point;
	write Type_invalid;
	write PmAdmExtwebSrvMaint;
	write PmAdmExtwebSrvView;
	write Exter_servi_with_name_apos1_al;
	
epilog
	delete agent;
	delete array;
	delete transAgent;
	delete tmpArray;
end;
</source>
    </JadeMethod>
