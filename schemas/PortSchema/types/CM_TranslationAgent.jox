    <JadeMethod name="trxConvertMenus" id="54b24f97-00e6-448e-b50f-66b2533bbc0e">
        <source>trxConvertMenus();

vars
	menuRoot			: CM_MenuRootForRoot;
	menuItem			: CM_MenuItem;
	translatableText	: XLAT_Menu;

begin

	menuRoot := app.myRoot.myMenuRoot;

	beginTransaction;

	foreach menuItem in menuRoot.allMenuItems do

		translatableText := app.myRoot.allXLAT_TranslatableText[XLAT_Menus, menuItem.getMenuTranslationNumber()].XLAT_Menu;
		if translatableText = null then
			create translatableText persistent;
		endif;
			
		// default locale
		translatableText.initialiseMenu(myRoot, menuItem);
	endforeach;
	commitTransaction;

	menuRoot := app.myRoot.myMenuRootForSysEntities;

	beginTransaction;

	foreach menuItem in menuRoot.allMenuItems do

		translatableText := app.myRoot.allXLAT_TranslatableText[XLAT_Menus, menuItem.getMenuTranslationNumber()].XLAT_Menu;
		if translatableText = null then
			create translatableText persistent;
		endif;
			
		// default locale
		translatableText.initialiseMenu(myRoot, menuItem);
	endforeach;
	commitTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="trxCreateTranslatableText" id="011e4844-a55f-4d08-a6b5-19f0510c52d0">
        <source>trxCreateTranslatableText(_category : XLAT_Category; _categoryEdition : Integer;_proxy : XLAT_TranslationsAndGCProxy; _constant : GlobalConstant) : XLAT_TranslatableText;

vars
	text 	 : XLAT_TranslatableText;
	constant : GlobalConstant;
begin
	constant := _constant;

	// validation
	
	// check the category edition
	if _categoryEdition &lt;&gt; 0 and _category.edition &lt;&gt; _categoryEdition then
		app.raiseCMException2(ExpectedEditionInvalid, _categoryEdition.String, _category.constantCategoryDescription, null, null);
	endif;
	
	beginTransaction;
	constant.setText(_proxy.buildXml);
	text := subTrxLoadFromGlobalConstant(_category, constant);
	commitTransaction;
	
	return text;
end;</source>
        <Parameter name="_category" type="XLAT_Category"/>
        <Parameter name="_categoryEdition" type="Integer"/>
        <Parameter name="_proxy" type="XLAT_TranslationsAndGCProxy"/>
        <Parameter name="_constant" type="GlobalConstant"/>
        <ReturnType type="XLAT_TranslatableText"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteTranslatableText" id="e280110b-1dcb-49d4-b534-dc0e24df92ad">
        <source>trxDeleteTranslatableText(_translatableText : XLAT_TranslatableText io; _passport : CM_Passport);

vars
	searchResults : XLAT_SearchResults;
begin
	exclusiveLock(_translatableText);
	
	beginTransaction;
	
	// remove from search results (no inverse)
	searchResults := self.allSearchResults[_translatableText.myCategory.constantCategoryName];
	if searchResults &lt;&gt; null then
		if searchResults.allTranslatableText[_translatableText.number] &lt;&gt; null then
			searchResults.allTranslatableText.removeKey(_translatableText.number);
		endif;
	endif;
	
	delete _translatableText;
	_translatableText := null;

	commitTransaction;
end;</source>
        <Parameter name="_translatableText" type="XLAT_TranslatableText" usage="io"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="trxLoadSpecificErrors" id="c6d80409-bc24-4d3e-a1e8-47c3f352d502">
        <source>trxLoadSpecificErrors(_strArray : StringArray input) : Boolean;

// Created by cnwdvb1 on 13 December 2006

vars

	translatableText		: XLAT_TranslatableText;
	tmpContStr				: String;
	const					: Constant;
	category				: XLAT_Category;
	
	

begin

	category := self.myRoot.allXLAT_Categories[XLAT_Exceptions];

	beginTransaction;
	
	foreach tmpContStr in _strArray do
		
		const := currentSchema.getConstant(tmpContStr);
		
		if const = null then
			return false;
		endif;

		translatableText := self.subTrxLoadFromGlobalConstant(category, const.GlobalConstant);
	endforeach;	
	
	commitTransaction;
	
	return true;

end;</source>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="trxLoadSpecificTranslations" id="16502cff-4dfa-4c7b-ae01-ec7090d28b25">
        <source>trxLoadSpecificTranslations(_strArray : StringArray input) : Boolean;

vars

	translatableText		: XLAT_TranslatableText;
	tmpContStr				: String;
	const					: Constant;
	category				: XLAT_Category;

begin

	category := self.myRoot.allXLAT_Categories["XLAT_FormCaptions"];

	beginTransaction;
	
	foreach tmpContStr in _strArray do
		
		const := currentSchema.getConstant(tmpContStr);
		if const = null then
