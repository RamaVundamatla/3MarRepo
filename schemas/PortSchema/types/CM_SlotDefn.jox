    <JadeMethod name="checkAttributeChange" id="858d66e2-1954-41bb-9894-f1b45b6bcb5b">
        <source>checkAttributeChange();
vars

begin

//called from setSlotDefattributes which is called from cm_baydefn.setocxdata
//Dave - I have put a // in fron of all } to try and get this to load - rjs.






/*
int JOMAPI CM_SlotDefn_checkAttribChange( DskBuffer* buffer, VB_CM_SlotDefn * pOldData, void *)
{
CM_SlotDefn self(&amp;buffer-&gt;oid);

CM_Vessel 				vessel;
CM_BayDefn 				bayDefn;
CM_VoyageSet			voyages;
OrderedJomColl 		voyageColl;
CM_Voyage 				*pVoyage;
CM_Voyage 				voyage;
CM_BayPlansByIndexMatrix1D	bayPlansByIndex;
CM_ColourCodeByIndexMatrix1D	colourCodesByOrdinal;
OrderedJomColl 		objectColl;		//Used for both bayPlans &amp; colourCodes
CM_BayPlans				*pBayPlans;
CM_BayPlans				bayPlans;
CM_ColourCode			*pColourCodes;
CM_ColourCode			colourCodes;
int								bayIndex;
CM_BayBayPlan 		bayBayPlan;
CM_BayColourCode	bayColourCode;
CM_SlotLCBySlotMatrix4D	slotsByOrdinal;
CM_SlotController slot;
CM_SlotRequest		slotReq;
OrderedJomColl 		tiColl;
CM_TrackedItem		*pTI;
CM_TrackedItem		ti;
bool						isISO;
int								i;
int								loopCnt;
CM_BayBayPlanByBayMatrix1D	baysByOrdinal;
VB_CM_SlotDefn		currDefn;
int								doorChange = FALSE;
int								fortyChange = FALSE;
int								reeferChange = FALSE;
int								powerChange = FALSE;
int								secondaryChange = FALSE;
int								unavailableChange = FALSE;
int								sizeAttribs;
bool						tmpBool;
int								moveType;
//Strings for message return
Character					stowageId[VB_STOWAGE_LEN +1];
Character					voyageCode[VB_CM_VOYAGE_CODE_LEN +1];
Character					bayPlansId[VB_CM_BAYPLANS_ID_LEN +1];
bool						archivedVoyage = false;
ShortDskParam			oidParam;
	//----------------
  //Get current slotDefn
	//----------------
	result = self.getProperty("doorsAft", &amp;tmpBool);
	TEST_RESULT(result);
	currDefn.doorsAft = ConvertToVBBoolean(tmpBool);
  //Users can ONLY SET 40' front.
	result = self.getProperty("fortyFront", &amp;tmpBool);
	TEST_RESULT(result);
	currDefn.fortyFront = ConvertToVBBoolean(tmpBool);

	result = self.getProperty("reefer", &amp;tmpBool);
	TEST_RESULT(result);
	currDefn.reefer = ConvertToVBBoolean(tmpBool);

	result = self.getProperty("power", &amp;tmpBool);
	TEST_RESULT(result);
	currDefn.power = ConvertToVBBoolean(tmpBool);

	result = self.getProperty("secondary", &amp;tmpBool);
	TEST_RESULT(result);
	currDefn.secondary = ConvertToVBBoolean(tmpBool);

	result = self.getProperty("unavailable", &amp;tmpBool);
	TEST_RESULT(result);
	currDefn.unavailable = ConvertToVBBoolean(tmpBool);
	//----------------
  //Determine what changed
	//----------------
	if (currDefn.doorsAft != pOldData-&gt;doorsAft)
		doorChange = TRUE;

	if (currDefn.fortyFront != pOldData-&gt;fortyFront)
		fortyChange = TRUE;

	if (currDefn.reefer != pOldData-&gt;reefer)
		reeferChange = TRUE;

	if (currDefn.power != pOldData-&gt;power)
		powerChange = TRUE;

	if (currDefn.secondary != pOldData-&gt;secondary)
		secondaryChange = TRUE;

	if (currDefn.unavailable != pOldData-&gt;unavailable)
		unavailableChange = TRUE;
	//----------------
  //If nothing changed, Quit
	//----------------
	if (	( !doorChange)
		&amp;&amp;	( !fortyChange)
		&amp;&amp;	( !powerChange)
		&amp;&amp;	( !reeferChange)
		&amp;&amp;	( !secondaryChange)
		&amp;&amp;	( !unavailableChange)	)
    	return 0;

	//----------------
	//Get Vessel Def
	//----------------
	result = self.getProperty("parent", bayDefn);
	TEST_RESULT(result);

	//Make sure onDeck == ordinal Deck for this object. (cant be sure
  //that it is passed in correctly).
	result = self.getProperty("ordinalDeck", &amp;pOldData-&gt;ordinalDeck);
	TEST_RESULT(result);

	REFRESH_LOCK(bayDefn);

	result = bayDefn.getProperty("ordinalBay", &amp;bayIndex);
	TEST_RESULT(result);

	result = bayDefn.getProperty("parent", vessel);
	TEST_RESULT(result);

	//----------------
  //Get voyages for Vessel
	//----------------
	result = vessel.getProperty("voyages", voyages);
	TEST_RESULT(result);

	result = vessel.getProperty("iSOVessel", &amp;isISO);
	TEST_RESULT(result);

	result = voyages.values(voyageColl);
	TEST_RESULT(result);

	voyageColl.start();
	while( voyageColl.next((PJomObj&amp;)pVoyage) )
	{
		//Allocate proxy for Voyage
		voyage.oid = pVoyage-&gt;oid;
		//-------------
		//Get all BayPlans
		//-------------
		result = voyage.getProperty("bayPlansByIndex", bayPlansByIndex);
		TEST_RESULT(result);
		//Prime msg return value
		result = voyage.getProperty("code", voyageCode);
		TEST_RESULT(result);

		result = voyage.getProperty("archived", &amp;archivedVoyage);
		TEST_RESULT(result);
		//-------------
		//Iterate thru each
		//-------------
		clear(objectColl);

		result = bayPlansByIndex.values(objectColl);
		TEST_RESULT(result);

		objectColl.start();
		while( objectColl.next((PJomObj&amp;)pBayPlans) )
		{
			//-------------
			//Allocate proxy for BayPlans obj
			//-------------
			bayPlans.oid = pBayPlans-&gt;oid;
			//-------------
			//Get the bayPlan @ the bay index for defn
			//-------------
			result = bayPlans.getProperty("baysByOrdinal", baysByOrdinal);
			TEST_RESULT(result);

			//Setup message return string
			result = bayPlans.getProperty("id", bayPlansId);
			TEST_RESULT(result);

			result = baysByOrdinal.at(bayIndex, bayBayPlan);
			TEST_RESULT(result);
			//-------------
			//Finally, getSlots by ordinal.
			//-------------
			result = bayBayPlan.getProperty("slotsByOrdinal", slotsByOrdinal);
			TEST_RESULT(result);
			//-------------
			//If ISO ship, get both primary &amp; halfheight
			//-------------
			loopCnt = PRIMARY_SLOT;
			if (isISO)
				loopCnt = HALFHEIGHT_SLOT;

			for ( i = PRIMARY_SLOT; i &lt;= loopCnt; i++ )
      {
				//-------------
				//Get slot controller
				//-------------
				result = slotsByOrdinal.at( pOldData-&gt;ordinalDeck, pOldData-&gt;ordinalCell, pOldData-&gt;ordinalTier, i, slot);
				TEST_RESULT(result);
				//----------
        //Check minor changes 
				//----------
				if ( (unavailableChange) &amp;&amp; (!currDefn.unavailable) &amp;&amp; (slot.isNull()))
				{
					//-------------
					//Was unavailable, now available. Create a new slot.
					//-------------
					result = paramSetOid((DskParam&amp;)oidParam, self.oid);
					TEST_RESULT(result);
					
					result = bayBayPlan.sendMsg("addSlot", (DskParam*)&amp;oidParam, (DskParam*)&amp;i);
					TEST_RESULT(result);
//				}
				//-------------
				//Get slot's TIs
				//-------------
				clear(tiColl);
				//-------------
				//LEGACY. They may have changed the slotdef prior to this, if so, there
        //will NOT be any slot oid, simply jump over
				//-------------
				if (!slot.isNull())
				{
        	//Setup return var for msg string
					result = self.getProperty("stowageId", stowageId);
					TEST_RESULT(result);

					result = slot.getTIs(tiColl);
					TEST_RESULT(result);

					tiColl.start();
					while( tiColl.next((PJomObj&amp;)pTI) )
					{
 		       	//----------
						//Allocate proxy for TI
						//----------
						ti.oid = pTI-&gt;oid;
						//----------
						//Check the Slot
						//----------
						if ((unavailableChange) &amp;&amp; (currDefn.unavailable))
						{
							//----------
							//Has a TI, is now unavailable. Error
							//----------
							//MessageSupply : Cell Position, voyageId, bayplans id (actual/proposed)
							ResetMsgParams();
							result = SetMsgParam(0, stowageId);
							TEST_RESULT( result);

							result = SetMsgParam(1, voyageCode);
							TEST_RESULT( result);

							result = SetMsgParam(2, bayPlansId);
							TEST_RESULT( result);
							result = ERR_SLOT_HAS_TI;

//						}
						TEST_RESULT(result);
						
						if ((fortyChange) &amp;&amp; (!currDefn.fortyFront) &amp;&amp; (pOldData-&gt;fortyFront) &amp;&amp; (!archivedVoyage))
						{
							//----------
							//Was a 40' slot, not now
							//----------
							result = ti.getProperty("sizeAttributes", &amp;sizeAttribs);
							TEST_RESULT(result);

							if ( sizeAttribs &amp; ISO_LEN_40 )
              {
								//MessageSupply : Cell Position, voyageId, bayplans id (actual/proposed)
								ResetMsgParams();
								result = SetMsgParam(0, stowageId);
								TEST_RESULT( result);

								result = SetMsgParam(1, voyageCode);
								TEST_RESULT( result);

								result = SetMsgParam(2, bayPlansId);
								TEST_RESULT( result);
								result = ERR_TI_NEEDS_40;
//              }
//						}
						TEST_RESULT(result);
						
						if ((reeferChange) &amp;&amp; (!currDefn.reefer) &amp;&amp; (pOldData-&gt;reefer) &amp;&amp; (!archivedVoyage))
						{
							//----------
							//Was a reefer slot, not now
							//----------
							result = ti.getProperty("requiresTemperature", &amp;tmpBool);
							TEST_RESULT(result);
							
							if ( tmpBool )
              {
								//MessageSupply : Cell Position, voyageId, bayplans id (actual/proposed)
								ResetMsgParams();
								result = SetMsgParam(0, stowageId);
								TEST_RESULT( result);

								result = SetMsgParam(1, voyageCode);
								TEST_RESULT( result);

								result = SetMsgParam(2, bayPlansId);
								TEST_RESULT( result);
								result = ERR_TI_NEEDS_TEMP;
//              }
//						}
						TEST_RESULT( result);

						if ((powerChange) &amp;&amp; (!currDefn.power) &amp;&amp; (pOldData-&gt;power) &amp;&amp; (!archivedVoyage))
						{
							//----------
							//Was a powered slot, not now
							//----------
							result = ti.getProperty("requiresPower", &amp;tmpBool);
							TEST_RESULT(result);
							
							if ( tmpBool )
              {
								//MessageSupply : Cell Position, voyageId, bayplans id (actual/proposed)
								ResetMsgParams();
								result = SetMsgParam(0, stowageId);
								TEST_RESULT( result);

								result = SetMsgParam(1, voyageCode);
								TEST_RESULT( result);

								result = SetMsgParam(2, bayPlansId);
								TEST_RESULT( result);
								result = ERR_TI_NEEDS_POWER;
//              }
//						}
						TEST_RESULT(result);
//					}
					//-------------
					//No probs with TI's
					//-------------
					if ((unavailableChange) &amp;&amp; (currDefn.unavailable))
					{
						//----------
						//Remove the slot
						//----------
						result = paramSetOid((DskParam&amp;)oidParam, slot.oid);
						TEST_RESULT(result);

						result = bayBayPlan.sendMsg("removeSlot", (DskParam*)&amp;oidParam,  (DskParam*)&amp;i);
						TEST_RESULT(result);
//          }
//				}
//      }
//		}
		//-------------
		//-------------
		//Colour Codes
		//-------------
		//-------------
		clear(objectColl);

		result = voyage.getProperty("colourCodesByOrdinal", colourCodesByOrdinal);
		TEST_RESULT(result);
		//-------------
		//Iterate thru each
		//-------------
		result = colourCodesByOrdinal.values(objectColl);
		TEST_RESULT(result);

		objectColl.start();
		while( objectColl.next((PJomObj&amp;)pColourCodes) )
		{
			//-------------
			//Allocate proxy for BayPlans obj
			//-------------
			colourCodes.oid = pColourCodes-&gt;oid;
			//-------------
			//Get the bayPlan @ the bay index for defn
			//-------------
			result = colourCodes.getProperty("baysByOrdinal", baysByOrdinal);
			TEST_RESULT(result);

			result = baysByOrdinal.at(bayIndex, bayColourCode);
			TEST_RESULT(result);
			//-------------
			//Finally, getSlots by ordinal.
			//-------------
			result = bayColourCode.getProperty("slotsByOrdinal", slotsByOrdinal);
			TEST_RESULT(result);
			//-------------
			//If ISO ship, get both primary &amp; halfheight
			//-------------
			loopCnt = PRIMARY_SLOT;
			if (isISO)
				loopCnt = HALFHEIGHT_SLOT;

			for ( i = PRIMARY_SLOT; i &lt;= loopCnt; i++ )
      {
				//-------------
				//Get slot Request
				//-------------
				result = slotsByOrdinal.at( pOldData-&gt;ordinalDeck, pOldData-&gt;ordinalCell, pOldData-&gt;ordinalTier, i, slotReq);
				TEST_RESULT(result);
				//----------
        //Check minor changes 
				//----------
				if ( (unavailableChange) &amp;&amp; (!currDefn.unavailable) &amp;&amp; (slotReq.isNull()))
				{
					//-------------
					//Was unavailable, now available. Create a new slot.
					//-------------
					result = paramSetOid((DskParam&amp;)oidParam, self.oid);
					TEST_RESULT(result);

					result = bayColourCode.sendMsg("addSlot", (DskParam*)&amp;oidParam, (DskParam*)&amp;i);
					TEST_RESULT(result);
//				}
				//-------------
				//LEGACY. They may have changed the slotdef prior to this, if so, there
        //will NOT be any slot oid, simply jump over
				//-------------
				if (!slotReq.isNull())
				{
					REFRESH_LOCK(slotReq);
					//------------
					//Only need to check moveType for slot requests.
					//------------
					result = slotReq.getProperty("moveType", &amp;moveType);
					TEST_RESULT(result);

					if (   (moveType != NULL_MOVETYPE)
							 &amp;&amp; ((unavailableChange) &amp;&amp; (currDefn.unavailable))
							 &amp;&amp; (!archivedVoyage)
							)
          {
							//MessageSupply : Cell Position, voyageId, bayplans id (actual/proposed)
						ResetMsgParams();
						result = SetMsgParam(0, stowageId);
						TEST_RESULT( result);

						result = SetMsgParam(1, voyageCode);
						TEST_RESULT( result);

						result = SetMsgParam(2, bayPlansId);
						TEST_RESULT( result);

						result = ERR_SLOT_IN_CC;
//					}
					TEST_RESULT( result);

					if ((unavailableChange) &amp;&amp; (currDefn.unavailable))
					{
						//----------
						//Remove the slot
						//----------
						result = paramSetOid((DskParam&amp;)oidParam, slotReq.oid);
						TEST_RESULT(result);

						result = bayColourCode.sendMsg("removeSlot", (DskParam*)&amp;oidParam,  (DskParam*)&amp;i);
						TEST_RESULT(result);
//					}
//        }
//      }
//		}
//	}

  return result;
//}
*/

end;</source>
    </JadeMethod>
    <JadeMethod name="cloneMySelf" id="08b27852-842d-47c2-841f-db7f8f717599">
