    <JadeMethod name="getAllVehicles" id="7584b047-18cf-4bb8-bb23-3b003505b399">
        <source>getAllVehicles()protected;
/*
Purpose:			
Return Value:		

Date			Who		Reason
15 August 2006	cnwer1	Initial creation - PAR#xxxx
26 August 2009	cnwcs5	ccms 1061 - road ops form  changes for new gate config
10 June 2022 	navhl20 TFS 53058 MTN - Job List in Road Operations screen not filtered out by Gate
01 Feb 2022     navma1	Bug 56382: GPHA -- Error 1090 on opening Road Operations Screen
*/
vars
	jobSheet 	: CM_RoadJobSheet;
	vehicle		: CM_Vehicle;
	area		: CM_TerminalArea;
	icArea		: CM_InterchangeArea;	
	operator	: CM_Operator;
	gate 		: CM_Gate;
	operArr		: CM_OperatorArray;
	roadjob     : CM_RoadJob;
begin
	jobSheet := self.getJobSheet.CM_RoadJobSheet;
	
	if jobSheet = null then
		//add exception somethings very wrong
		return;
	endif;
	
	foreach vehicle in jobSheet.allInTerminalVehicles do
		// any vehicle in yard will be in here
		area := vehicle.getTerminalAreaForCurrentLocn;
		
		//Start 10 June 2022 	navhl20 TFS 53058
		roadjob := vehicle.getCurrentRoadJob();								//01.02.2023 navma1 #56382
		if roadjob &lt;&gt; null then
			gate 	 := roadjob.myGate;
			operator := roadjob.myOperator;
		endif;
		
		create operArr transient;
		self.getOperators(operArr);
		//End 10 June 2022 	navhl20 TFS 53058
		
		if  area &lt;&gt; null then
			//Start 10 June 2022 	navhl20 TFS 53058
			/*if  area.isKindOf (CM_InterchangeArea) then 
				if self.myRoadOpController.allInterchangeAreas.includes(area.CM_InterchangeArea) then  
					self.allVehicles.addNoDuplicates (vehicle, false);
				endif;
			elseif  area.isKindOf (CM_CraneTransferArea) then	//31 Jan 2013	NDL	Par 31102 
				if self.myRoadOpController.allInterchangeAreas.includes(area.CM_CraneTransferArea) then   
					self.allVehicles.addNoDuplicates (vehicle, false);
				endif;
			else
				// not an interchange area
				foreach icArea in area.allAssociatedInterchangeAreas do
					if self.myRoadOpController.allInterchangeAreas.includes(icArea) then		
						self.allVehicles.addNoDuplicates (vehicle, false);
						break;
					endif;
				endforeach;
			endif;	*/
			if  area.isKindOf (CM_InterchangeArea) then	
				if self.myRoadOpController.allOperators.size = operArr.size and self.myRoadOpController.allInterchangeAreas.includes(area.CM_InterchangeArea) and self.myRoadOpController.allGates.includes(gate) then  
					self.allVehicles.addNoDuplicates (vehicle, false);
				elseif self.myRoadOpController.allInterchangeAreas.includes(area.CM_InterchangeArea) and self.myRoadOpController.allOperators.includes(operator) and self.myRoadOpController.allGates.includes(gate) then
					self.allVehicles.addNoDuplicates (vehicle, false);
				endif;
			elseif  area.isKindOf (CM_CraneTransferArea) then	//31 Jan 2013	NDL	Par 31102 
				if self.myRoadOpController.allOperators.size = operArr.size and self.myRoadOpController.allInterchangeAreas.includes(area.CM_CraneTransferArea) and self.myRoadOpController.allGates.includes(gate) then  
					self.allVehicles.addNoDuplicates (vehicle, false);
				elseif self.myRoadOpController.allInterchangeAreas.includes(area.CM_CraneTransferArea) and self.myRoadOpController.allOperators.includes(operator) and self.myRoadOpController.allGates.includes(gate) then
					self.allVehicles.addNoDuplicates (vehicle, false);
				endif;
			else
				// not an interchange area
				foreach icArea in area.allAssociatedInterchangeAreas do
					if self.myRoadOpController.allOperators.size = operArr.size and self.myRoadOpController.allInterchangeAreas.includes(icArea) and self.myRoadOpController.allGates.includes(gate) then  
					self.allVehicles.addNoDuplicates (vehicle, false);
				elseif self.myRoadOpController.allInterchangeAreas.includes(icArea) and self.myRoadOpController.allOperators.includes(operator) and self.myRoadOpController.allGates.includes(gate) then
					self.allVehicles.addNoDuplicates (vehicle, false);
				endif;
				endforeach;
			endif;
			//End 10 June 2022 	navhl20 TFS 53058
		endif;
	endforeach;
epilog
	delete operArr;
end;</source>
        <access>protected</access>
    </JadeMethod>
