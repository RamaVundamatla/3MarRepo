    <JadeMethod name="buildClassRegistry" id="5b8b1ddc-830e-4514-acdb-da8d726b67a5">
        <source>buildClassRegistry(_registry: CM_ExportImportClassDict io);
/*

Purpose:			
	* Main registry builder - delegates to category-specific methods
	* To add new class: Just add to appropriate category method below
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

vars

begin
    create _registry transient;
    
    // Build registry by category
    self.addSystemAdminClasses(_registry);
    self.addSystemScreenClasses(_registry);
    self.addTerminalAdminClasses(_registry);
    self.addTerminalScreenClasses(_registry);
    self.addInternalClasses(_registry);
	
end;</source>
        <Parameter name="_registry" type="CM_ExportImportClassDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="configureBlockStack" id="14134a0c-7069-4684-a58c-dd9c7346230d">
        <updating/>
        <source>configureBlockStack(_exportClass: CM_ExportImportClass io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36810 - Use Case - Terminal Screen - Block Stack Terminal Area Definition Export/Import

*/

vars
    builder: CM_ExportPropertyConfigBuilder;
begin
    create builder transient;
    
    builder.forClass(_exportClass)
        .property(CM_BlockStack::id, "Terminal Area ID").asKey()
        .property(CM_BlockStack::type, "Terminal Area Type")
        .property(CM_BlockStack::comment, "Comment")
        .property(CM_BlockStack::maxCapacity, "Maximum Capacity")
        .property(CM_BlockStack::enforceMaxCapacity, "Enforce Maximum Capacity")
        .property(CM_BlockStack::rows, "Width Rows")
        .property(CM_BlockStack::columns, "Length Cols")
        .property(CM_BlockStack::actAsReleasePoint, "Act As Release Point")
        .property(CM_BlockStack::isStockControlled, "Stock Controlled")
        .property(CM_BlockStack::autoRestrictionsEnabled, "Auto Yard Allocations Enabled")
        .property(CM_BlockStack::hideFromOverView, "Hide From Overview")
        .property(CM_BlockStack::myTerminal, "Terminal Code")
        .property(CM_BlockStack::myType, "Terminal Area Type")
        .property(CM_BlockStack::myDefaultInterchangeArea, "Default Interchange Area")
        .property(CM_BlockStack::allowedMachines, "Machines")
        .property(CM_BlockStack::allAssociatedInterchangeAreas, "Interchange Areas")
        .property(CM_BlockStack::allProductMinMax, "Max Values Applied To Terminal Areas").expanded()
        .commit();
    
epilog
    delete builder;
end;</source>
        <Parameter name="_exportClass" type="CM_ExportImportClass" usage="io"/>
    </JadeMethod>
