    <JadeMethod name="dblClick" id="69aaecf3-da23-42e4-95b2-41f4480ab019">
        <controlMethod name="CMUI_GridAreaDrawingFrame::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
