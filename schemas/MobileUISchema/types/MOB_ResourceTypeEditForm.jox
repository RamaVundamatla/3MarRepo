    <JadeMethod name="clearFields" id="f6280a69-8661-4dd0-8b6b-2d2babfc4bd0">
        <source>clearFields();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2010	#cnwdz2	 

*/

vars

begin
	if self.cmbResourceType.listCount = 1 then
		self.cmbResourceType.listIndex := 1;
	else
		self.cmbResourceType.listIndex := -1;
	endif;
	
	self.txtQuantity.text := null;
	self.txtRemarks.text := null;
	self.chkNoCharge.value := false;
	self.lblUnit.caption := null;
	
	self.btnOne.enabled := true;
	
	//cnwmc5 - 25 Sep 2015 - PAR 36920
	self.txtFromDate.text := null;
	self.txtFromTime.text := null;
	self.txtToDate.text := null;
	self.txtToTime.text := null;
	
	//18 Apr 2017	NLD	TFS 3414
	self.cmbPalletType.clear();
	self.chkStoreOnP.value := false;
	self.chkHeatTreated.value := false;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clickStoreOnPallet" id="f2badf45-d7b5-4e54-86e1-32b3a854cac7">
        <source>clickStoreOnPallet();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2020	jlgndl1	Initial creation	TFS 48248

*/

vars

	value : Boolean;

begin

	value := self.chkStoreOnP.value;

	self.chkHeatTreated.enabled := value;
	self.cmbPalletType.enabled := value;
	self.lblPalletType.enabled := value;
	
	if not value then
		self.cmbPalletType.listIndex := -1;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbPalletType_displayEntry" id="bb241544-286f-4390-a40a-2ef908627fd6">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbPalletType_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2017	cnwndl1	Initial creation	TFS 3141

*/

vars

begin

	if obj = null or not obj.isKindOf( CM_PalletType ) then
		return null;
	endif;
	
	return obj.CM_PalletType.description;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cmbResourceType_click" id="dc099e68-b627-4cfc-87d5-96fff6ab4696">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbResourceType_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15/02/2010	#cnwdz2	 
06/04/2020	jlgdap1	TFS 48977 STWO Unable to add enough digits for to do task resource
*/

vars
	
	type : CM_ResourceType;
	decPlaces : Integer;
begin
	if self.cmbResourceType.listIndex &gt; 0 then
		type := self.cmbResourceType.itemObject[self.cmbResourceType.listIndex].CM_ResourceType;
	endif;

	if type &lt;&gt; null then
		decPlaces := type.decimalPlaces;
		
		//cnwmc5 - 25 Sep 2015 - PAR 36920
		if type.isFromToDateTimeRequired then
			self.showFromToDateControls(true);
		else
			self.showFromToDateControls(false);
		endif;
	endif;
	
	self.makePalletStuffVisible( type );	//18 Apr 2017	NDL	TFS 3141
	
	self.txtQuantity.text := null;
	self.txtQuantity.decimals := 0;
	//self.txtQuantity.maxLength := decPlaces + 5;			// TFS 48977
	self.txtQuantity.maxLength := decPlaces + 9;			// TFS 48977
	if decPlaces = null then								// TFS 48977
		self.txtQuantity.maxLength := decPlaces + 8;		// TFS 48977
	endif;													// TFS 48977
	self.txtQuantity.decimals := decPlaces;
	
	if type &lt;&gt; null then
		self.lblUnit.caption := type.unitDescription &amp; ":";
	else
		self.lblUnit.caption := app.getErrorString(Units) &amp; ":";
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="505b822a-29be-4c58-8b13-d909ee741e85">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604
21 Jan 2020	NDL	TFS 48248

*/

vars

	vTop : Real;
	vHeight : Real;
	vLeft : Real;
	stdHeight : Real;
	stdWidth : Real;
	oneThirdWidth : Real;
	twoThirdWidth : Real;
	
begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;
	stdWidth := self.clientWidth - (self.resizedMargin * 2);
	oneThirdWidth :=  (( 1 / 3 ) * ( stdWidth ) ) - self.resizedMargin;
	twoThirdWidth := (( 2 / 3 ) * ( stdWidth ) ) - self.resizedMargin;
	
	vTop := (self.resizedMargin * 2);
	self.lblResource.move( self.resizedMargin,
						   vTop,
						   oneThirdWidth,
						   stdHeight
						   );
	
	
	vLeft := self.lblResource.left + self.lblResource.width + self.resizedMargin;
    self.cmbResourceType.move( 	vLeft,
								vTop,
								twoThirdWidth,
								stdHeight
								);
	
	vTop := self.lblResource.top + self.lblResource.height + (2 * self.resizedMargin);
	self.lblUnit.move(	self.resizedMargin,
						vTop,
						oneThirdWidth,
						stdHeight
						);
						
    self.txtQuantity.move( vLeft,
						   vTop,
						   twoThirdWidth,
						   stdHeight
						   );						   
						   
	vTop := self.lblUnit.top + self.lblUnit.height + (2 * self.resizedMargin);
	self.lblRemarks.move(  self.resizedMargin,
						   vTop,
						   oneThirdWidth,
						   stdHeight
						   );
						   
//	vTop := self.lblRemarks.top + self.lblRemarks.height + (3 * self.resizedMargin);
	self.txtRemarks.move(  vLeft,
						   vTop,
						   twoThirdWidth,
						   stdHeight
						   );		

    vTop := self.txtRemarks.top + self.txtRemarks.height + (2 * self.resizedMargin);
	self.chkNoCharge.move( vLeft,
						   vTop,
						   stdHeight,
						   stdHeight
						   );
						   
	vLeft := self.chkNoCharge.left + self.chkNoCharge.width;
	self.lblNoCharge.move(	vLeft,
							vTop,
							oneThirdWidth,
							stdHeight
							);	
	
	//cnwmc5 - 25 Sep 2015 - PAR 36920 - start
	vTop := self.lblNoCharge.top + self.lblNoCharge.height + (3 * self.resizedMargin);
	self.lblFromDateTime.move(	self.resizedMargin,
								vTop,
								stdWidth/2,
								stdHeight
								);
	vLeft := self.lblFromDateTime.left + self.lblFromDateTime.width;
	self.txtFromDate.move(	vLeft,
							vTop,
							stdWidth/4,
							stdHeight
							);
	vLeft := self.txtFromDate.left + self.txtFromDate.width;
	self.txtFromTime.move(	vLeft,
							vTop,
							stdWidth/4,
							stdHeight
							);
	
	vTop := self.lblFromDateTime.top + self.lblFromDateTime.height + (3 * self.resizedMargin);
	self.lblToDateTime.move(	self.resizedMargin,
								vTop,
								stdWidth/2,
								stdHeight
								);
	vLeft := self.lblToDateTime.left + self.lblToDateTime.width;
	self.txtToDate.move(	vLeft,
							vTop,
							stdWidth/4,
							stdHeight
							);
	vLeft := self.txtToDate.left + self.txtToDate.width;
	self.txtToTime.move(	vLeft,
							vTop,
							stdWidth/4,
							stdHeight
							);
	//cnwmc5 - 25 Sep 2015 - PAR 36920 - end
	
	//18 Apr 2017	NDL	TFS 3414
	vLeft := oneThirdWidth + self.resizedMargin;
	vTop := self.txtToTime.top + self.txtToTime.height + self.resizedMargin;
	
	self.chkStoreOnP.move(	vLeft,
							vTop,
							twoThirdWidth,
							stdHeight
							);
	vTop := self.chkStoreOnP.top + self.chkStoreOnP.height + self.resizedMargin;
	vLeft := self.resizedMargin;
	self.lblPalletType.move(	vLeft,
								vTop,
								oneThirdWidth,
								stdHeight
								);
	vLeft := oneThirdWidth + self.resizedMargin;
	//vTop := self.lblPalletType.top + self.lblPalletType.height + self.resizedMargin;	
	self.cmbPalletType.move(	vLeft,
								vTop,
								twoThirdWidth,
								stdHeight
								);
	//vLeft := self.resizedMargin;
	vTop := self.cmbPalletType.top + self.cmbPalletType.height + self.resizedMargin;
/*	self.chkStoreOnP.move(	vLeft,
							vTop,
							twoThirdWidth,
							stdHeight
							);
	vTop := self.chkStoreOnP.top + self.chkStoreOnP.height + self.resizedMargin; */
	self.chkHeatTreated.move(	vLeft,
								vTop,
								twoThirdWidth,
								stdHeight
								);
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="b9802be0-8c3d-4220-908c-20e64ffb0ff1">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2010	#cnwdz2	 

*/

vars
	resourceType : CM_ResourceType;
begin
	resourceType := self.cmbResourceType.listObject.CM_ResourceType;
	if resourceType = null then
		app.msgBox( app.getErrorString(INV_Please_Select_A) &amp;  " " &amp; app.getErrorString(Resource_usage), app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
		self.cmbResourceType.setFocus();
		return;
	endif;
	
	self.myMasterForm.doEditSave(self);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="dc8b7ba2-49ba-475b-8d83-e8faec8e330d">
        <updating/>
        <source>handleBtnTwo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2010	#cnwdz2	 

*/

vars

begin
	self.myMasterForm.doEditCancel(self);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initFieldsForResourceType" id="a2f3eb32-08d9-4d2b-b977-3a6693b1664c">
        <updating/>
        <source>initFieldsForResourceType(_rtUsage : CM_ResourceTypeUsage) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2010	#cnwdz2	 

*/

vars
	decPlaces : Integer;
begin
	self.cmbResourceType.listIndex := self.cmbResourceType.findObject(_rtUsage.myResourceType);
	decPlaces := _rtUsage.myResourceType.decimalPlaces;
	self.setLblUnitsCaption(_rtUsage.myResourceType);
	self.txtQuantity.text := _rtUsage.quantity.asStringJMTWithPrecision(decPlaces,false);
	self.txtRemarks.text := _rtUsage.remarks;
	self.chkNoCharge.value := _rtUsage.noCharge;
	
	//cnwmc5 - 25 Sep 2015 - PAR 36920
	if _rtUsage.myResourceType &lt;&gt; null then
		self.isFromToDateTimeRequired := _rtUsage.myResourceType.isFromToDateTimeRequired;
	endif;
	self.txtFromDate.setDate(_rtUsage.fromDateTime.date);
	self.txtFromTime.setTime(_rtUsage.fromDateTime.time);
	self.txtToDate.setDate(_rtUsage.toDateTime.date);
	self.txtToTime.setTime(_rtUsage.toDateTime.time);
	
	//18 Apr 2017	NDL	TFS 3414
	self.makePalletStuffVisible( _rtUsage.myResourceType );
	self.cmbPalletType.listIndex := -1;
	if _rtUsage.myPalletType &lt;&gt; null then
		self.cmbPalletType.listIndex := self.cmbPalletType.findObject( _rtUsage.myPalletType );
	endif;
	self.chkStoreOnP.value := _rtUsage.isStoreOnPallet;
	self.chkHeatTreated.value := _rtUsage.isHeatTreated;
	
epilog

end;</source>
        <Parameter name="_rtUsage" type="CM_ResourceTypeUsage"/>
    </JadeMethod>
    <JadeMethod name="makePalletStuffVisible" id="d70f8ae0-6279-4328-b821-0d42731cb970">
        <source>makePalletStuffVisible( _type : CM_ResourceType );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	ti : CM_TrackedItem;

begin

	self.chkHeatTreated.visible := false;
	self.chkStoreOnP.visible := false;
	self.cmbPalletType.visible := false;
	self.lblPalletType.visible := false;
	
	self.chkHeatTreated.value := false;
	self.chkStoreOnP.value := false;
	self.cmbPalletType.clear();
	self.allPalletTypes.clear();
	
	if _type = null or not _type.additionalInfoIs( EXTRA_INFO_PALLET ) then
		return;
	endif;
	
	if self.myHandlingType = null
	or not self.myHandlingType.isPallet
	then
		return;
	endif;

	
	self.myHandlingType.getValidSubTypes( self.allPalletTypes, false );
	self.cmbPalletType.listCollection( self.allPalletTypes, false , 0 );
	
	if not self.allPalletTypes.isEmpty then
		self.chkHeatTreated.visible := true;
		self.chkStoreOnP.visible := true;
		self.cmbPalletType.visible := true;
		self.lblPalletType.visible := true;
	endif;
	
	self.clickStoreOnPallet();	//21 Jan 2020	NDL	TFS 48248

epilog

end;</source>
        <Parameter name="_type" type="CM_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="setLblUnitsCaption" id="f7338855-d07b-4e53-bd53-1c815b54823f">
        <source>setLblUnitsCaption(_type : CM_ResourceType);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16/02/2010	#cnwdz2	 
06/04/20020	jlgdap1	TFS 48977 STWO Unable to add enough digits for to do task resource
*/

vars
	decPlaces : Integer;
begin
	if _type &lt;&gt; null then
		decPlaces := _type.decimalPlaces;
	endif;
	
	self.txtQuantity.text := null;
	self.txtQuantity.decimals := 0;
	//self.txtQuantity.maxLength := decPlaces + 5;			// TFS 48977
	self.txtQuantity.maxLength := decPlaces + 9;			// TFS 48977
	if decPlaces = null then								// TFS 48977
		self.txtQuantity.maxLength := decPlaces + 8;		// TFS 48977
	endif;													// TFS 48977
	self.txtQuantity.decimals := decPlaces;
	
	if _type &lt;&gt; null then
		self.lblUnit.caption := _type.unitDescription &amp; ":";
	else
		self.lblUnit.caption := app.getErrorString(Units) &amp; ":";
	endif;
epilog

end;</source>
        <Parameter name="_type" type="CM_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="677f7115-e66e-406a-9fc9-80c9169d0197">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation

*/

vars

	type : CM_ResourceType;

begin

	self.doResizeControls(true);
	self.showFromToDateControls(self.isFromToDateTimeRequired);		//cnwmc5 - 25 Sep 2015 - PAR 36920
	
	//18 Apr 2017	NDL	TFS 3141
	type := self.cmbResourceType.listObject.CM_ResourceType;
	if type = null then
		//otherwise its already been done...
		self.makePalletStuffVisible( null );	
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="38a6a0a3-ae5f-416e-8620-2b63281284d9">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2010	#cnwdz2	 

*/

vars

begin
	inheritMethod();
	self.setupCmdButtons(2, app.getErrorString(Save), app.getErrorString(Back), null,null,null);
	
	self.setupControls();
	
	self.cmbResourceType.setFocus();
	self.caption := app.getErrorString(Resource_Type_Edit); //31/03/2010 cnwdz2 par22410
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showFromToDateControls" id="96cac610-2ecf-4d03-8203-9eb97994c2da">
        <source>showFromToDateControls(_visible : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2015	cnwmc5	Initial creation		PAR 36920

*/

vars

begin
	self.lblFromDateTime.visible := _visible;
	self.lblToDateTime.visible := _visible;
	self.txtFromDate.visible := _visible;
	self.txtFromTime.visible := _visible;
	self.txtToDate.visible := _visible;
	self.txtToTime.visible := _visible;
epilog

end;</source>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c8e6eb63-07e6-4810-89e0-93d21d7402de">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 April 2017 10:24:06.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014846, locale);
	chkHeatTreated.translateCaption(Xlat_0021994, locale);
	chkStoreOnP.translateCaption(Xlat_0021995, locale);
	lblFromDateTime.translateCaption(Xlat_0021002, locale);
	lblNoCharge.translateCaption(Xlat_0014020, locale);
	lblPalletType.translateCaption(Xlat_0021996, locale);
	lblRemarks.translateCaption(Xlat_0014022, locale);
	lblResource.translateCaption(Xlat_0014023, locale);
	lblToDateTime.translateCaption(Xlat_0021061, locale);
	lblUnit.translateCaption(Xlat_0014256, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
