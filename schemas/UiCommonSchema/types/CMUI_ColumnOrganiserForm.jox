    <JadeMethod name="validateFilterSelections" id="4b9a2bab-7ab6-46b2-ad83-913e3f483e23">
        <source>validateFilterSelections() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

	selectedEntRows : EntTableRowArray;
	entTableRow : EntTableRow;
	filterCol : CM_ColumnFilter;
	foundIt : Boolean;
	msg : String;
	heading : String;

begin

	app.mousePointer := MousePointer_HourGlass;
	
	if self.allFilterColumns = null or self.allFilterColumns.isEmpty then
		return true;
	endif;
	
	create selectedEntRows transient;
	self.mulColumns.getSelected( selectedEntRows );
	
	foreach filterCol in self.allFilterColumns do
		foundIt := false;
		foreach entTableRow in selectedEntRows do
			heading := entTableRow.getHeading(self.myDataTable.getMyTerminologyCargoBOLType, self.myDataTable.getMyTerminologyTerminal, app.myCurrentLocale);
			if heading = filterCol.entableRowHeading then
				foundIt := true;
				break;
			endif;
		endforeach;
		if not foundIt then
			msg := app.getErrorString1(Col_not_selected_not_filter,filterCol.entableRowHeading);
			app.msgBox(msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			self.allFilterColumns.remove( filterCol );
			self.myDataTable.form.updateTableColumnFilters( self.myDataTable, self.allFilterColumns );
		endif;
	endforeach;

	return true;

epilog

	delete selectedEntRows;
	app.mousePointer := MousePointer_Default;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSelected" id="d2798e0f-a19a-4444-9fe9-f562ef758c87">
        <source>validateSelected():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2016	cnwndl1	Initial creation	TFS 2518

*/

vars

	entTableArray : EntTableArray;
	msg : String;

begin

	create entTableArray transient;
	self.mulColumns.getSelected(entTableArray);
	
	if entTableArray.isEmpty then
		msg := "You must select at least one column to display!";
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	return true;

epilog

	delete entTableArray;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
