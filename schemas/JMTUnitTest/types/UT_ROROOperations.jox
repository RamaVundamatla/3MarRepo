    <JadeMethod name="uRotateROROErrorCheck" id="be8db3f5-3f6f-4f4a-81de-8ed1e8413fea">
        <updating/>
        <source>uRotateROROErrorCheck(_voyage : CM_Voyage; _isLoad : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2012	cnwmc5	Initial creation

*/

vars
	voyageDeck 	: CM_DeckVoyage;
	location	: CM_ROROLocnDefn;
begin
	// Get the deck
	voyageDeck := _voyage.myROROStructure.allDecksByCode['D1'];
	
	//////////////////////////////////////////////////
	////                                          ////
	////                Horizontal                ////
	////                                          ////
	//////////////////////////////////////////////////
	
	// Checking to ensure it raises errors when expected (horizontal)
	self.expectedTrxErrors.clear();
	self.expectedTrxErrors.add(Posit_canno_rotat_becau_does_n);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN35'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 10, 2, true, app.myPassport, _isLoad);
	self.assertNoTrxErrorsOrWarnings();
	
	self.expectedTrxErrors.clear();
	self.expectedTrxErrors.add(Posit_canno_rotat_becau_does_n);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN10'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 6, 2, true, app.myPassport, _isLoad);
	self.assertNoTrxErrorsOrWarnings();
	
	self.expectedTrxErrors.clear();
	self.expectedTrxErrors.add(Posit_canno_rotat_becau_does_n);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN9'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 5, 1, true, app.myPassport, _isLoad);
	self.assertNoTrxErrorsOrWarnings();
	
	self.expectedTrxErrors.add(Posit_canno_rotat_becau_does_n);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN4'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 3, 1, true, app.myPassport, _isLoad);
	self.assertNoTrxErrorsOrWarnings();
	
	//////////////////////////////////////////////////
	////                                          ////
	////                Vertical                  ////
	////                                          ////
	//////////////////////////////////////////////////
	
	// Checking to ensure it raises errors when expected (vertical)
	self.expectedTrxErrors.clear();
	self.expectedTrxErrors.add(Posit_canno_rotat_becau_does_n);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN58'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 10, 2, true, app.myPassport, _isLoad);
	self.assertNoTrxErrorsOrWarnings();
	
	self.expectedTrxErrors.clear();
	self.expectedTrxErrors.add(Posit_canno_rotat_becau_does_n);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN62'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 6, 2, true, app.myPassport, _isLoad);
	self.assertNoTrxErrorsOrWarnings();
	
	self.expectedTrxErrors.clear();
	self.expectedTrxErrors.add(Posit_canno_rotat_becau_does_n);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN51'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 5, 1, true, app.myPassport, _isLoad);
	self.assertNoTrxErrorsOrWarnings();
	
	self.expectedTrxErrors.add(Posit_canno_rotat_becau_does_n);
	location := voyageDeck.allROROLocnDefnByCode['AUTOLOCN60'];
	app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 3, 1, true, app.myPassport, _isLoad);
	self.assertNoTrxErrorsOrWarnings();
epilog

end;</source>
