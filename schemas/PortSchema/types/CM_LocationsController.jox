    <JadeMethod name="getFullId" id="19349856-1011-44e2-88aa-cfe0ef262d67">
        <source>getFullId() : String;
//Returns the full id of this terminal area LC
//id "C 2303"
vars
	parentObject : CM_Object;
	tmpStr : String;
	//bay : CM_BayPlans;
begin
	parentObject := self.getParent();
	if parentObject = null then
		return "";
	endif;
	if parentObject.isKindOf(CM_TerminalArea) then
		if parentObject.isKindOf(CM_BlockStack) then
			tmpStr := "";	//blockStack's only have 1 lc, their id is fine!  
		elseif parentObject.isKindOf(CM_Depot) then
			tmpStr := "";	//same for Depots/LCL Storage JC 11/12/2003
		elseif parentObject.isKindOf(CM_CraneTransferArea) then
			tmpStr := "";	//CTA's only have 1 lc, their id is fine too!
		elseif parentObject.isKindOf(CM_BulkArea) then
			tmpStr := "";
		else
			tmpStr := parentObject.CM_TerminalArea.id.trimBlanks;		
		endif;
	//elseif parent.isKindOf(CM_BayBayPlan) then	//Handled by SlotController itself.
	//	bay := parent.CM_BayBayPlan.parent;
	//	tmpStr := bay.voyage.code.trimRight;
	elseif parentObject.isKindOf(CM_Machine) then
		tmpStr := "";	
	endif;
	if self.hasSpaceInID then
		tmpStr := tmpStr &amp; " ";
	endif;
	tmpStr := tmpStr  &amp; self.getID;
	return tmpStr.trimBlanks[1:30];	//21 Apr 2016	NDL	TFS 1885

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
