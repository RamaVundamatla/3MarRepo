	app.printer.print(self.frmTable);
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="printTable" id="cd4bf5b3-c75d-4ae0-bb5d-2274020d8bdc">
        <source>printTable();

vars
	tblRpt, tblFoot	: Table;
	obj		: Object;
	i , count		: Integer;
	noRowsOnTable : Real;
	goToNext : Boolean;
	craneStart,
	craneCount,
	numCranes	: Integer;
	currentPrintTables, currentPrintFooter	: ObjectArray;

begin
	self.tblReport.visible := false;
	self.tblFooter.visible := false;
	
	numCranes := self.allJobTables.size;
	craneStart := 1;
	
	create currentPrintTables transient;
	create currentPrintFooter transient;
	
	count := 1;
	while true do
		// copy next tables from self.allJobTables into currentPrintTables
		currentPrintTables.clear;
		currentPrintFooter.clear;
		foreach count in craneStart to numCranes do
			currentPrintTables.add(self.allJobTables[count]);
			currentPrintFooter.add(self.allFooterTables[count]);
			craneStart := craneStart + 1;
			if currentPrintTables.size = 3 then
				// can only print 3 cranes at a time
				break;
			endif;
		endforeach;
	
		if currentPrintTables.isEmpty then
			break;
		endif;
	
		self.repositionTblsForPrint(currentPrintTables,currentPrintFooter);
		
		count := 1;
		while true do
			app.printer.print(self.frmTable);
			goToNext :=false;
			foreach obj in currentPrintTables do
				tblRpt := obj.Table;
				
				//if tblRpt.rows &gt; (self.noRowsOnTbl * count)  then 
				if tblRpt.rows &gt; (self.noRowsOnTbl * count) + 1  then 	// 22/06/2010 cnwar2 #24543
					goToNext := true;
				
					foreach i in 1 to (self.noRowsOnTbl * count) do
						// need to add 2 below to allow for heading row
						tblRpt.accessRow(i+2).visible := false;
					endforeach;	
				else 
					foreach i in 3 to tblRpt.rows do
						tblRpt.accessRow(i).visible := false;
					endforeach;
				endif;
				
			endforeach;

			if  goToNext &lt;&gt; true then
				break;
			else
				count :=count +1;
				app.printer.newPage();
			endif;
		endwhile;
		app.printer.print(self.frmFooter);
		self.hideTblsAfterPrint(currentPrintTables,currentPrintFooter);

	endwhile;

epilog
	delete currentPrintTables;			// PAR #27874
	delete currentPrintFooter;

end;
</source>
    </JadeMethod>
    <JadeMethod name="repositionTblsForPrint" id="628737ae-f851-4fc7-8d92-d3b0378beeb0">
        <source>repositionTblsForPrint(currentPrintTables,currentPrintFooter :ObjectArray input);

vars
	 count		: Integer;
	 obj		: Object;
	 tblRpt, tblFoot	: Table;
begin
	// postion tblRpt on frmTable
		count := 1;
		foreach obj in currentPrintTables do
			tblRpt := obj.Table;
			tblRpt.left := (count -1) * tblRpt.width;
			tblRpt.visible := true;
			count :=count + 1;
		endforeach;
		
		// postion tblFoot on frmFooter
		count := 1;
		foreach obj in currentPrintFooter do
			tblFoot := obj.Table;
			// postion tblRpt on frmTable
			tblFoot.left := (count -1) * tblRpt.width;
			tblFoot.visible := true;
			count :=count + 1;
		endforeach;

end;
</source>
        <Parameter name="currentPrintTables" type="ObjectArray" usage="input"/>
        <Parameter name="currentPrintFooter" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="run" id="09080d45-8cc9-446a-86b1-07974b051378">
        <updating/>
        <source>run(_isPrintPreview: Boolean; _isCSV: Boolean; _extraDetail: CM_ExtraDetail): Binary updating;
/*
----------   ----------  --------------------------------------------------
Created:	12 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	jrwVoyage		: CM_JRWVoyages;
begin
		
	inheritMethod(_isPrintPreview,_isCSV, _extraDetail);
	app.printer.printPreview := _isPrintPreview;
	app.printer.setMargins(Print_Landscape,0,0,10,10);
	jrwVoyage := app.myQAFilter.allJRWTransients.first.CM_JRWVoyages;
	self.myVoyage := jrwVoyage.allVoyages.first;
	if self.myVoyage = null then
		return null;
	endif;
	self.doLoad();
	
	return null;

epilog
	app.printer.close;
end;

</source>
        <Parameter name="_isPrintPreview" type="Boolean"/>
        <Parameter name="_isCSV" type="Boolean"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="388cf6a9-9c08-4ef4-9efa-d14c0c1cfc5d">
        <updating/>
        <source>setupControls() updating, protected;

constants
	Gap = 10;
vars
begin
	
	self.frmTable.visible := true;
	self.tblReport.visible := true;
	self.frmFooter.visible := true;
	self.tblFooter.visible := true;
	
	self.frmFooter.left := self.frmTable.left;
	self.frmFooter.height := 86;
	self.frmFooter.width := self.width;
	self.frmHeader.height := 140;
	
	self.tblFooter.width := self.frmFooter.width;
	self.tblFooter.height := self.frmFooter.height;

	self.frmTable.width := self.width;	
	self.frmTable.height := self.height - (self.frmHeader.height + self.frmFooter.height + 30);
		
	self.tblReport.left := self.frmTable.left;
	self.tblReport.width := self.frmTable.width;
	self.tblReport.height := self.frmTable.height;
	
	self.tblFooter.left := self.frmFooter.left;
	self.tblFooter.width := self.frmFooter.width;
	self.tblFooter.height := self.frmFooter.height;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupHeader" id="0ff42f10-8ec7-42fd-9edd-5ef76825a873">
        <updating/>
        <source>setupHeader() updating, protected;

constants
	Gap = 5;
vars

begin
	
	//hide some lbl's
	self.lblReportExtra.visible := false;
	self.lblTerminalName.visible := false;
	self.lblReportId.visible := false;
	
	self.lblPrinted.top := self.picPortLogo.top + self.picPortLogo.height + Gap;
	self.lblPrinted.left := self.lblPrinted.left - self.lblPage.width - 20;
	self.lblPrinted.fontBold := true;
	self.lblPrintedDtl.top := self.lblPrinted.top;
	self.lblPrintedDtl.left := self.lblPrintedDtl.left - self.lblPage.width -20;
	self.lblPrintedDtl.fontBold := true;
	self.lblPrintTime.top := self.lblPrinted.top;
	self.lblPrintTime.left := self.lblPrintTime.left - self.lblPage.width -20;
	self.lblPrintTime.fontBold := true;
	self.lblPage.top := self.lblPrinted.top;
	self.lblPage.width := 40;
	self.lblPage.left :=self.lblPrintTime.left + self.lblPrintTime.width + 25;
	self.lblPage.fontBold := true;
	self.lblHeading3_1.left := self.lblPage.left + self.lblPage.width;
	self.lblHeading3_1.top := self.lblPage.top;
	self.lblHeading3_1.width:= 15;
	self.lblHeading3_1.fontBold := true;
	self.lblVesselName.top := self.lblPrintTime.top;
	self.lblVoyageCode.top := self.lblPrintTime.top;
	self.lblSideTo.top := self.lblPrintTime.top;

	self.picJadeLogo.picture := app.getPicLogoProduct;
	self.picPortLogo.picture := app.getPicLogoPort;

	self.lblHeading1.caption := 'Ship Working Programme';
	self.lblHeading1.width := 330;
	self.lblHeading1.top := 30;
	self.lblHeading1.height := 40;
	self.lblHeading1.fontSize := 18;
	self.lblHeading1.fontBold := true;
	self.lblHeading1.fontUnderline := true;	

	
	self.lblHeading2.top := 80;
//	self.lblHeading2.caption := self.myJRWVoyages.code &amp; ' - ' &amp; self.myJRWVoyageSummary.myVoyage.description;
	self.lblHeading2.height := 20;
	self.lblHeading1.fontSize := 18;
	
	self.lblVoyageCode.caption := self.lblVoyageCode.caption &amp; ' ' &amp; self.myVoyage.code;
	self.lblVesselName.caption := self.lblVesselName.caption &amp; ' ' &amp; self.myVoyage.vesselName;
	self.lblSideTo.caption := self.lblSideTo.caption &amp; ' ' &amp; self.myVoyage.starboardBerthedRWD;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
