    <JadeMethod name="utlUpdateVasToDoTaskComplete" id="cfe6b2a3-5c5b-4b57-a2f8-f208156cc3f0">
        <updating/>
        <source>utlUpdateVasToDoTaskComplete(_object : CM_Object input; _toDoCode : Integer; _passport : CM_Passport input; resourceUsageProxys : CM_ResourceTypeUsageSet; _wodtl: CM_WorkOrderToDoDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen
28 Mar 2023 		navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
04 April 2023		navcs2	Bug 57455: EUP - Todo Tasks Completed without adding Mandatory resources

*/

vars
	toDoTaskDesc 	: CM_ToDoTaskDesc;
	resourceUsages	: CM_ResourceTypeUsageSet;
begin
	self.initialiseActivity();
	
	if _passport.noErrors then																							//28.3.2023 navhl20	#57301[57303]
		self.myUpdateAuditAgent.audUpdateGeneric(_wodtl.myParent, true);
	endif;
	
	self.raiseExceptionIfNull(_object, 'Entity Object');
	
	app.setContinueCMExceptions(true);
	
	create resourceUsages transient;														// 05 April 2023	navcs2	Bug 57455
	
	if resourceUsageProxys &lt;&gt; null then
		toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[_toDoCode];							// 05 April 2023	navcs2	Bug 57455
		resourceUsageProxys.copy(resourceUsages);												// 05 April 2023	navcs2	Bug 57455
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then								// 05 April 2023	navcs2	Bug 57455
		return;																				// 05 April 2023	navcs2	Bug 57455
	endif;																					// 05 April 2023	navcs2	Bug 57455
	
	if _passport.noErrors then																// 05 April 2023	navcs2	Bug 57455
		if _object.isKindOf(CM_Voyage) then
			_object.CM_Voyage.setToDoTaskComplete(_toDoCode, _passport, resourceUsageProxys, _wodtl);
		elseif _object.isKindOf(CM_VehicleBookingTimeSlot) then
			_object.CM_VehicleBookingTimeSlot.setToDoTaskComplete(_toDoCode, _passport, resourceUsageProxys, _wodtl);
		elseif _object.isKindOf(CM_Train) then
			_object.CM_Train.setToDoTaskComplete(_toDoCode, _passport, resourceUsageProxys, _wodtl);
		elseif _object.isKindOf(CM_Wagon) then
			_object.CM_Wagon.setToDoTaskComplete(_toDoCode, _passport, resourceUsageProxys, _wodtl);
		elseif _object.isKindOf(CM_Debtor) then
			_object.CM_Debtor.setToDoTaskComplete(_toDoCode, _passport, resourceUsageProxys, _wodtl);
		elseif _object.isKindOf(CM_VehicleVisitRecord) then
			_object.CM_VehicleVisitRecord.setToDoTaskComplete(_toDoCode, _passport, resourceUsageProxys, _wodtl);
		endif;
	endif;
	
	if _passport.noErrors then																							//28.3.2023 navhl20	#57301[57303]
		self.myUpdateAuditAgent.audUpdateGeneric(_wodtl.myParent, false);	
	endif;
epilog	
	delete resourceUsages;																	// 05 April 2023	navcs2	Bug 57455
end;</source>
        <Parameter name="_object" type="CM_Object" usage="input"/>
        <Parameter name="_toDoCode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="resourceUsageProxys" type="CM_ResourceTypeUsageSet"/>
        <Parameter name="_wodtl" type="CM_WorkOrderToDoDtl"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVbsTransferSlot" id="3d608db3-6134-432c-876b-f97a45b667ee">
        <source>utlUpdateVbsTransferSlot(_pxyObject : CM_VehicleBookingTimeSlot io;
						_startTimeSlot, _endTimeSlot : TimeStamp; 
						_remarks : String;
						_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Sep 2022	navak20	ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots
*/

vars
	vbsTimeSlot		: CM_VehicleBookingTimeSlot;
	expectedEdition : Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyObject, 'Vehicle Booking Transfer Time Slot');
	
	_pxyObject.pxyGetRealObjectAndEdition(vbsTimeSlot, expectedEdition);
	self.raiseExceptionIfNull(vbsTimeSlot, 'Transfer Time Slot');
	
	_pxyObject.validateForTransfer();
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(vbsTimeSlot, true);
	endif;
	
	vbsTimeSlot.setForUpdateTransferSlots(_startTimeSlot, _endTimeSlot, _remarks); 
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(vbsTimeSlot, false);
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyObject" type="CM_VehicleBookingTimeSlot" usage="io"/>
        <Parameter name="_startTimeSlot" type="TimeStamp"/>
        <Parameter name="_endTimeSlot" type="TimeStamp"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
