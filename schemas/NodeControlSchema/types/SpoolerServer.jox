    <JadeMethod name="checkFile" id="26931156-1777-4a4e-80ae-bc2d6f661f89">
        <updating/>
        <source>checkFile(inFile:File io):Integer updating;
// determine file type
vars
	s:String;
	result:Integer;
begin
	s:=inFile.name;
	if s[s.length-4:4]=".txt" or inFile.readLine.toLower[1:3]="txt" then
		result:=1;
	elseif s[s.length-4:4]=".log" then
		result:=2;
	else 
		// error, return 0
	endif;

	app.logMessage("File found, type="&amp;result.String);
	inFile.close;
	return result;
end;</source>
        <Parameter name="inFile" type="File" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="compress" id="4c6a3027-0226-42dc-9420-9ffd04a2e5c1">
        <updating/>
        <source>compress(fileName:String) updating;
// note: slows down considerably if reading too much at a time, so limit to 10000
// Date			Who		Reason
// 18 Nov 2025	navpw1	JIRA: MTN-36675 Replaced removal of undocumented feature Binary.compress with compressToBinary
vars
	b:Binary;
begin
	aFile.fileName:=fileName.toLower;
	aFile.kind:=File.Kind_Binary;
	bFile.fileName:=fileName.toLower&amp;".cmp";
	bFile.kind:=File.Kind_Binary;
	while not aFile.endOfFile do
		//b:=aFile.readBinary(10000).compress;
		b:=aFile.readBinary(10000).compressToBinary(Binary.Compression_ZLibFast);	// ### JIRA: MTN-36675 18Nov2025 NAVPW1
		bFile.writeBinary(b.length.Binary);
		bFile.writeBinary(b);
//		bFile.writeBinary(aFile.readBinary(aFile.fileLength).compress);
	endwhile;
	aFile.close;
	bFile.close;
end;</source>
        <Parameter name="fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="copy" id="7ff9e6b6-45a8-4408-81c0-e6aed729e61a">
        <updating/>
        <source>copy(inFileName,outFileName:String):Boolean updating;
// full path names required
vars
	errorText:String;
	errorcode:Integer;
begin
	on FileException do ftpFileException(exception,errorText,errorcode);
	
	aFile.kind:=File.Kind_Binary;
	aFile.fileName:=inFileName.toLower;

	bFile.kind:=File.Kind_Binary;
	bFile.fileName:=outFileName.toLower;
	bFile.shareMode:=File.Share_Exclusive;  // exception handler will detect if bFile is in use
	app.makePathIfPossible(bFile.fileName,false);

	bFile.writeBinary(aFile.readBinary(aFile.fileLength));
	bFile.close;
	aFile.close;

	if errorText=null then  // no exception happened
 		if logMessages then app.logMessage("File copied from "&amp;aFile.fileName&amp;" to "&amp;bFile.fileName); endif;
 		return true;
	else
 		app.logMessage(errorText);
 		app.logMessage("File copy failed from "&amp;aFile.fileName&amp;" to "&amp;bFile.fileName);
 		return false;
 	endif;
end;</source>
        <Parameter name="inFileName" type="String"/>
        <Parameter name="outFileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="11287266-6d8c-4c86-8670-e1f24792dd45">
        <updating/>
        <source>create() updating;

begin
	create folder;
	folder.usePresentationFileSystem:=false;
	create aFile;
	aFile.kind := File.Kind_Binary; // 3/3/16  cnwns1 PAR 36286 unicode version
	aFile.mode := File.Mode_Input;
	aFile.usePresentationFileSystem:=false;
	create bFile;
	bFile.kind := File.Kind_Binary; // 3/3/16  cnwns1 PAR 36286 unicode version
	bFile.mode := File.Mode_Output;
	bFile.usePresentationFileSystem:=false;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="236d45e1-744a-4f60-8c1e-771e5bde0a26">
        <updating/>
        <source>delete() updating;

vars
