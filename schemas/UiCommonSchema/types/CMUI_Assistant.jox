    <JadeMethod name="comboBoxVoyAllocSortOrder" id="0203e567-05e3-47d5-bf98-e33614c9b025">
        <source>comboBoxVoyAllocSortOrder(_cmb : CMUI_ComboBox input; _val : String);
/*
Purpose:			
Date				Who			Reason
MAY 2014		CNWAB1		Initial creation
*/
vars

	idx		: Integer;
	lstIdx	: Integer;
	
begin

	_cmb.clear;
	_cmb.addItem(app.getErrorString(VoyAllocSortByPriority));
	_cmb.addItem(app.getErrorString(VoyAllocSortByDescription) );
	
