	self.setProxyAttribute(_doors20Aft,_doors40Aft,_fortyBack,_fortyFront,_motor20Aft,_motor40Aft,_power,_reefer,_mtOnly,_unavailable,_watercooled, _heavy, _voltage);
	
	self.cellId := _cellId;
	self.ordinalCell := _ordinalCell;
	self.ordinalDeck := _ordinalDeck;
	self.ordinalTier := _ordinalTier;

	self.sequenceNumPortDis := _sequenceNumPortDis;
	self.sequenceNumPortLoad := _sequenceNumPortLoad;
	self.sequenceNumStarDis := _sequenceNumStarDis;
	self.sequenceNumStarLoad := _sequenceNumStarLoad;
	self.tierId := _tierId;
	
	self.is30 := _is30; // PAR 18682
	self.is45 := _is45; // PAR 18682
	self.is53 := _is53; // PAR 18682


end;</source>
