    <JadeMethod name="getWorkOrderDetailTypeFromWle" id="3fc496c6-d3a7-45ad-8ab4-99b2c547e8a9">
        <source>getWorkOrderDetailTypeFromWle(_operationWle : CM_WorkListEntry):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
17 Jul 2023	navma1	ChangeRequest 58342: EUP | Delivery Dispatch Screen - Rail Operation
*/

vars
	operationJob : CM_Job;
begin
	if _operationWle = null then
		return null;
	endif;
	
	operationJob := _operationWle.job;
	
	if operationJob = null then
		return null;
	endif;
	
	if _operationWle.isKindOf(CM_YardWLE) and operationJob.canBeLinkedToWOJob then	//17.07.2023 navma1 #58342
		
		/*
		Receive Road 
		*/
		if _operationWle.CM_YardWLE.isReceipt then
			return WO_TASK_RECEIVE;
		else
			return WO_TASK_RELEASE;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_operationWle" type="CM_WorkListEntry"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
