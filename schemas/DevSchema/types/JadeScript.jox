    </JadeMethod>
    <JadeMethod name="getLibraryUsage" id="124ca3d3-98d4-4f4f-a259-ed24172fba56">
        <source>getLibraryUsage();

vars
	scm:	Schema;
	scmColl:	SchemaColl;
	lib:	Library;
	ep:		Routine;
	scr:	FeatureUsage;
	dups:	ObjectSet;
	recurseLevel:	Integer;
begin
	create scmColl transient;
	create dups transient;
	rootSchema.withAllSubschemas(scmColl);
	foreach scm in scmColl where not scm.isSystemObject do
		foreach lib in scm.getPropertyValue('libraries').LibraryNDict do
			write scm.name &amp; ' ' &amp; lib.name;
			foreach ep in lib.getPropertyValue('entrypoints').EntryPointDict do
				write Tab &amp; ep.sendMsg('__fullyQualifiedName').String;
				if ep.scriptRefs.size = 0 then
					write Tab &amp; Tab &amp; '&lt;none&gt;';
				else	
					dups.clear;
					foreach scr in ep.scriptRefs where not dups.includes(scr.schemaScript) do
						recurseLevel := 0;
						write Tab &amp; Tab &amp; scr.schemaScript.sendMsg('__fullyQualifiedName').String;
						dups.add(scr.schemaScript);
						getRecursiveUsage(scr.schemaScript, recurseLevel);
					endforeach;
				endif;	
			endforeach;	
		endforeach;
	endforeach;	
end;
</source>
    </JadeMethod>
    <JadeMethod name="getRecursiveUsage" id="98533b5c-5f90-41c2-9a64-855a3035458d">
        <source>getRecursiveUsage(script: Script; recurseLevel: Integer io);

constants
	Maximum_Recursion_Level = 5;
vars
	fu:	FeatureUsage;
	l:	Integer;
	dups:	ObjectSet;
	scr:	FeatureUsage;
begin
	create dups transient;
	dups.clear;
	recurseLevel := recurseLevel + 1;
	if recurseLevel &gt; Maximum_Recursion_Level then
		return;
	endif;	
	foreach scr in script.scriptRefs where not dups.includes(scr.schemaScript) do
		write Tab &amp; Tab &amp; Tab &amp; recurseLevel.String &amp; ' ' &amp; scr.schemaScript.sendMsg('__fullyQualifiedName').String;
		dups.add(scr.schemaScript);
		getRecursiveUsage(scr.schemaScript, recurseLevel);
		recurseLevel := recurseLevel - 1;
	endforeach;
epilog
	delete dups;
end;</source>
        <Parameter name="script" type="Script"/>
        <Parameter name="recurseLevel" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="handleCMException" id="6ac2eaff-19c1-4949-87c1-49012e6b7d3c">
        <source>handleCMException(_exc : CM_Exception) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 September 2023	jlier1	Initial creation

*/
vars

begin
	if _exc.isWarning then
		app.myPassport.addWarningFull(_exc.errorCode, _exc.extendedErrorText, _exc.userString, _exc.myUserObject, _exc.mySubject);
		return Ex_Continue;
	else
		abortTransaction;
		abortTransientTransaction;
		app.myPassport.addErrorFull(_exc.errorCode, _exc.extendedErrorText, _exc.userString, _exc.myUserObject, _exc);
		return Ex_Resume_Next;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="CM_Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="iniFileDeleteAll" id="095856fd-a54d-4270-a0b3-1ec4ba75731e">
        <source>iniFileDeleteAll();

