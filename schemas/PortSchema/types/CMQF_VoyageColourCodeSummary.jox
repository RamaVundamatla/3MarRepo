<Class name="CMQF_VoyageColourCodeSummary" id="5b045dea-8bfc-417d-b860-26d69a61f327">
    <superclass name="CMQF_VoyageSummary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="c86a2365-be3e-4a49-8460-9fe66ac63818">
        <updating/>
        <source>filterObjects(_ccSummaryDict: CMIF_VoyageSummaryByValueDict input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     06 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	summaryObj			: CMIF_VoyageSummary;
	bayVoyage			: CM_BayVoyage;
	slotRequest			: CM_SlotRequest;
	querySelf			: CMQF_VoyageColourCodeSummary;
	allCCs				: CM_SlotRequestSet;
	breakOut			: Boolean;
	int					: Integer;
begin
	
	create allCCs transient;
	
	querySelf := self;
	
	querySelf.initFields();
	if querySelf.getMyVoyage.myCellularVoyageStructure &lt;&gt; null then //added by cnwyl1 24052006
		foreach bayVoyage in querySelf.getMyVoyage.myCellularVoyageStructure.allBayVoyagesByOrdinal discreteLock do
			foreach slotRequest in bayVoyage.allSlotRequestByMoveType discreteLock do
				if (querySelf.loadDischargeOption = querySelf.MODE_OPT_LOAD) then
					if (slotRequest.moveType = DISCHARGE_MOVETYPE) or (slotRequest.isRehandle and slotRequest.isDischarge) or slotRequest.isSOB then
				   		continue;
				   	endif;
				elseif (querySelf.loadDischargeOption = querySelf.MODE_OPT_DISCHARGE) then
					if (slotRequest.moveType = LOAD_MOVETYPE) or (slotRequest.isRehandle and slotRequest.isLoad) then
					   continue;
					endif;
				endif;
				
				if slotRequest.moveType = NULL_MOVETYPE then
					continue;
				endif;			
				
				create summaryObj transient;
				int := 1;
				summaryObj.keyValue1 := bayVoyage.id;
				summaryObj.keyValue2 := slotRequest.id &amp; int.String;
				
				while _ccSummaryDict.includesKey(summaryObj.keyValue1, summaryObj.keyValue2) do
					int := int + 1;
					if int &gt; 100 then
						break;
					endif;
					summaryObj.keyValue2 := slotRequest.id &amp; int.String;
				endwhile;
				
				_ccSummaryDict.add(summaryObj);
				
				self.updateMonitor(breakOut);
				summaryObj.setFromSR(slotRequest);
	
			endforeach;
		endforeach;
	endif;//added by cnwyl1 24052006
epilog
	delete allCCs;
end;</source>
        <Parameter name="_ccSummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
