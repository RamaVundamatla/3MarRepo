    <JadeMethod name="getVoyageStats" id="6a060120-d22e-4099-9817-b2468624e367">
        <source>getVoyageStats(_voyageStats : CMIF_VoyageStats io);
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	drawJobControllers : SHP_CraneJobDrawingController;
	obj : Object;
	iter : Iterator;
	x1,y1,x2,y2 ,z: Real;
	startTime,
	endTime : TimeStamp;
	cmifObjectDateRange : CMIF_MyObjectDateRange;
	cmifJobSheetStats : CMIF_JobSheetStats;
	cmifJobStats : CMIF_JobStats;
	jobSheet : CM_JobSheet;
begin

	if _voyageStats = null then
		return;
	endif;
	
	_voyageStats.setActualTime(self.currentTime);
	foreach drawJobControllers in self.allJobDrawControllers do 
		jobSheet:=self.myVoyage.allJobSheets[drawJobControllers.crane.id];
		cmifJobSheetStats:=_voyageStats.allJobSheetStats[jobSheet];		
		if jobSheet.getWorkStarted &lt;&gt; null then
			cmifJobSheetStats.setWorkStarted(jobSheet.getWorkStarted);
		else
			cmifJobSheetStats.setWorkStarted(self.currentTime);
		endif;
		
		iter:=drawJobControllers.allJobObjects.createIterator;
		while iter.next(obj) do
			drawJobControllers.allJobObjects.getIteratorKeys(x1, y1, x2, y2,z, iter);
			startTime:= self.myTimeLineDrawController.getTimeForX(x1);
			endTime:=self.myTimeLineDrawController.getTimeForX(x2);
			create cmifJobStats transient;
			cmifJobStats.setMyJob(obj.CM_Job);
			//epr par 16697 28/5/08
			obj.CM_Job.getJobStats(cmifJobStats,_voyageStats);
			if self.mode = MODE_ACTUAL then
				cmifJobStats.setDetails(cmifJobSheetStats,startTime,endTime,null,null);
				
				cmifJobSheetStats.setEstActualEndTime(endTime);
			else
				cmifJobStats.setDetails(cmifJobSheetStats,null,null,startTime,endTime);			
				cmifJobSheetStats.setEstTargetEndTime(endTime);

			endif;
		endwhile;
		
		_voyageStats.setVoyageStartTime(cmifJobSheetStats.workStarted);
		_voyageStats.setEstActualEndTime(cmifJobSheetStats.estActualEndTime);
		_voyageStats.setEstTargetEndTime(cmifJobSheetStats.estTargetEndTime);
		delete iter;
	endforeach;
	
epilog
	delete iter;

end;</source>
        <Parameter name="_voyageStats" type="CMIF_VoyageStats" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getVoyageTimes" id="f6d151b7-09f7-4a18-b5e0-143d74fd203b">
        <updating/>
        <source>getVoyageTimes(_voyageStats : CMIF_VoyageStats) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.setCurrentTime(_voyageStats.actualTime);
	self.voyageStartTime:=_voyageStats.voyageStartTime;
	if self.mode = MODE_ACTUAL then
		self.voyageEndTime:=_voyageStats.estActualEndTime;		
	else
		self.voyageEndTime:=_voyageStats.estTargetEndTime;
	endif;


epilog

end;</source>
        <Parameter name="_voyageStats" type="CMIF_VoyageStats"/>
    </JadeMethod>
