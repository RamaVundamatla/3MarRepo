 Parameters:  EDI Translation Operator Code

 Returns:     the translation of the consignee code, or orignal if no translation

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
 ---------------------------------------------------------------------------
*/

vars
	xlateOperator 	: CM_Operator;
	foreignCode 	: String;
	foundMatch		: Boolean;
begin
	
	if  pXlateOperator &lt;&gt; null 	and consignee.trimBlanks &lt;&gt; null then
		xlateOperator := app.myRoot.allOperators[pXlateOperator];
		
		if xlateOperator &lt;&gt; null then
			foreignCode := xlateOperator.getXlationForeignCode(consignee, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);
			if foreignCode &lt;&gt; null then
				return foreignCode;
			endif;
		endif;
	endif;
	
	return consignee.trimBlanks;	// default to same code if not translated

end;
</source>
        <Parameter name="pXlateOperator" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
