    <JadeMethod name="setProxyFromObject" id="a7be88c1-cfe7-4e5a-a363-acc766131bd7">
        <updating/>
        <source>setProxyFromObject(_object: CM_InvoiceLineDesc) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2018	jlger1	Initial creation

*/

vars

begin
	inheritMethod(_object);
	self.narration := _object.narration;
	if _object.invoiceType &lt;&gt; null then
		self.invoiceTypeDesc:=_object.invoiceType.description;
	endif;
epilog

end;</source>
