    <JadeMethod name="myGridController" id="a4bc2471-e93c-4519-a62d-5db746f75a29">
        <methodInvocation>mapping</methodInvocation>
        <source>myGridController(set: Boolean; _value: CM_GridController io) mapping;
/*
----------   ----------  --------------------------------------------------
Created:	08 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := self.myLocationsController.CM_GridController;
	endif;



end;</source>
        <Parameter name="set" type="Boolean"/>
