    <JadeMethod name="getAllNonCargoVisibleColumns" id="d6a491d9-b266-48b7-91db-ee21360a87dd">
        <source>getAllNonCargoVisibleColumns( _queryDef : CM_QueryDefinition; colArray : StringArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2019	jlgndl1	Initial creation	TFS 44100
22 Dec 2022 	navhl20 ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
17 Feb 2023		navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
10 May 2023 	navlw1 ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
30 May 2024		jlier1 TFS 64054
*/

vars

	queryType : Integer;
	queryMode : Integer;
	strArray : StringArray;
	deletedObj : Boolean;

begin
	
	if _queryDef = null then
		return;
	endif;
	queryType := _queryDef.type;
	queryMode := _queryDef.mode;
	
	if queryType = CM_QueryDefinition.Transaction_Query_Type
	or queryType = CM_QueryDefinition.Invoicing_Query_Type
	or queryType = CM_QueryDefinition.Cash_Query_Type
	or queryType = CM_QueryDefinition.Audit_Query_Type
	or queryMode = CM_QueryDefinition.VehicleBookingSlot_Query_Type // 10.05.2023 navlw1 #53902
	then
		//All good so far, we know what to do with these types
		if queryMode = CM_QueryDefinition.Audit_Query_Mode
		or queryMode = CM_QueryDefinition.CargoTransaction_Query_Mode
		or queryMode = CM_QueryDefinition.CashPayment_Query_Mode
		or queryMode = CM_QueryDefinition.CashReceipt_Query_Mode
		or queryMode = CM_QueryDefinition.EventTransaction_Query_Mode
		or queryMode = CM_QueryDefinition.Location_Activity_Query_Mode	//13 Apr 2021	NDL	TSF 50906
		or queryMode = CM_QueryDefinition.HMSTransaction_Query_Mode
		or queryMode = CM_QueryDefinition.BOLTransaction_Query_Mode
		or queryMode = CM_QueryDefinition.InvoiceLine_Query_Mode
		or queryMode = CM_QueryDefinition.Invoice_Query_Mode
		or queryMode = CM_QueryDefinition.WorkOrderTrans_Query_Mode //22.12.2022 navhl20 #54350[54269]
		or queryMode = CM_QueryDefinition.VehicleBookingSlot_Query_Mode // 10.05.2023 navlw1 #53902
		or queryMode = CM_QueryDefinition.Contract_Query_Mode //17/02/2023 navmv20 TFS 55626 TASK 55688
		then
			//And, we know what to do with these modes
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Unrecognised Query Definition Mode to get columns for');
			return;
		endif;	
	elseif  _queryDef.isKindOf(CM_QDefTILC)  //TFS 64054 jlier1 30/5/24
		or _queryDef.isKindOf(CM_QDefCar) then
		//do nothing
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unrecognised Query Definition Type to get columns for');
		return;
	endif;
	
	if self.allNonCargoVisibleColumns.size &gt;= queryMode and self.allNonCargoVisibleColumns[ queryMode ] &lt;&gt; null then
		strArray := self.allNonCargoVisibleColumns[ queryMode ].StringArray;
		on Exception do app.handleDeletedObject( exception, strArray, deletedObj); //15 May 2019 NDL	Some idiot is deleting these persitent objects
		if strArray &lt;&gt; null and not strArray.isEmpty then
			strArray.copy( colArray );
			return;
		endif;
	endif;
	
	_queryDef.getSelectorVisibleColumns( colArray );	

epilog

end;</source>
        <Parameter name="_queryDef" type="CM_QueryDefinition"/>
        <Parameter name="colArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getHeading" id="26548d29-c125-454b-88ee-67a27985af1e">
