    <JadeMethod name="setPxyTiFromRealGTE" id="e04ecf66-ae45-4cb8-a7f2-dab92f0849e7">
        <updating/>
        <source>setPxyTiFromRealGTE(_pxyTI: CM_TrackedItem input; _passport: CM_Passport input) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2009	cnwjk3	Initial creation

*/

vars

begin
	inheritMethod(_pxyTI, _passport);
	_pxyTI.setPxyFromCMGTE_Receival(self, _passport);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="40782b6b-58d9-40ca-9c75-ecc93c1f84f6">
        <updating/>
        <source>validateForCreate(_passport: CM_Passport input; _pxyTI : CM_TrackedItem io): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     23 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ti,
	pxyTI 			: CM_TrackedItem;
	theCargoType	: CM_CargoType;
	tiUpdCntrl		: CMIF_TIUpdateController; 
	subItemError 	: Boolean;
begin	

	inheritMethod(_passport, _pxyTI);	// cnwjk3 PAR 22754 11/03/2010
	
	/* cnwjk3 PAR 22754 11/03/2010

	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if theCargoType = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Cargo Type', 'Cargo Type', null);
		return false;
	endif;
	
	pxyTI := self.myTerminal.createTI(theCargoType, true); // Use MASTER TI

	ti := self.myTerminal.allOnsiteTIsByIdCargoType[self.id, self.cargoType];
	if ti &lt;&gt; null then
		app.raiseCMException1(ERR_ALREADY_ONSITE, self.id,  null, null);
		return _passport.noErrors;
	endif;

	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, null, null);
	pxyTI.setPxyFromCMGTE_Receival(self, _passport);
	pxyTI.validateTrackedItem(tiUpdCntrl, _passport);	
	_pxyTI := pxyTI; // return this.  Caller must destroy!
	*/
epilog
	// delete pxyTI; caller will delete
	return _passport.noErrors();
	delete tiUpdCntrl;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
