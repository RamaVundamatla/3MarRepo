    <JadeMethod name="auditId" id="ddb91285-9aed-40c5-b9d3-d1bdb9f8ec3a">
        <source>auditId(): String;
//
//11 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
vars

begin
	return self.sender&amp;' '&amp;self.sender&amp;' '&amp;self.fileType;
end;
</source>
