    <JadeMethod name="doBtnColourPick" id="ce5785b3-cac5-4db2-a3cc-3acf30bc9f73">
        <updating/>
        <source>doBtnColourPick(_btn: Button) updating;
/*
Date		    Who			Reason
08 April 2011	cnwas3	  Initial creation: CCMS 1031
*/
vars
	cmdColor	: CMDColor;
	tmpCell	: JadeTableCell;
	tmpText	: String;
	
	theFrame : CMUI_PointDrawingFrame;
begin	
	create cmdColor transient;
	cmdColor.preventFullOpen := false;
	cmdColor.color := self.myCurrentDeckItemLayout.drawFillColour;
	
	if cmdColor.open = 0 then
		if _btn = self.btnColoursFill then
			self.myCurrentDeckItemLayout.setProxyDrawFillColour(cmdColor.color);
			self.doDrawFills(cmdColor.color);
		else
			self.myCurrentDeckItemLayout.setProxyLineColour(cmdColor.color);
			self.doDrawLines(self.myCurrentDeckItemLayout.drawWidth,cmdColor.color);	
		endif;		
	endif;
	
epilog
	if cmdColor &lt;&gt; null then
	delete cmdColor;
	endif;
end;</source>
        <Parameter name="_btn" type="Button"/>
    </JadeMethod>
    <JadeMethod name="doClickFillColour" id="159046e6-68b4-4d0f-8f5a-cc8b563ae09d">
