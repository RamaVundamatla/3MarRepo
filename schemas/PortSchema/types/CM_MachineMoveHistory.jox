// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result	:CM_ISOType;
	ti 	: CM_TrackedItem;
begin
	
	ti:=self.getTrackedItem;
	
	if ti &lt;&gt; null and ti.isKindOf (CM_Container) then
		result := ti.CM_Container.getISOTypeObject;
	endif;
	
	return result;
epilog

