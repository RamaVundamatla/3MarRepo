<Class name="CM_BOLExtWarehouse" id="9bf6147c-5d22-471e-a693-938e0e5c0bac">
    <superclass name="CM_BOLExtension"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
cnwsb1 17 Jul 2002: This will go when warehousing is integrated at Port Otago.
For now they will free-format enter this data.</text>
    <DbClassMap file="bol"/>
    <PrimAttribute name="containerId" id="dc166389-e1a8-48f4-9eed-5bca959cd8fd">
        <length>12</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="containerTareWeight" id="78e943e2-3688-49d8-be89-4150991621f1">
        <precision>14</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
        <text>29/12/2008 cnwsh3 - SFW CCMS1060 Changed to Decimal[14,4] to allow for accommodating imperial and metric.</text>
    </PrimAttribute>
    <PrimAttribute name="isoType" id="656303b3-e10b-4c9c-bbc2-8c8ad7228ccd">
        <length>5</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="sealNum" id="9a7b57a5-51ff-4213-8764-b7a08c4d3409">
        <length>16</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="shippingLineDescr" id="2fd90876-074f-46be-aeab-c3ad7c1b8bc1">
        <length>41</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="vesselName" id="f93e5c69-37d3-4928-bb61-b8eabc3942ad">
        <length>26</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="voyageCode" id="36128677-648b-4b48-83b9-6336286ff411">
        <length>21</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
</Class>
