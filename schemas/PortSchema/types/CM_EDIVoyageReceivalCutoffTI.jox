    <JadeMethod name="setForUpdate" id="4d6677f0-d9cb-42bb-a57f-1af1a1e43a45">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
//
vars

begin
	inheritMethod(_proxyEDITI);
	self.code := _proxyEDITI.code;
	self.cutoffDateTime := _proxyEDITI.cutoffDateTime;
	self.earliestDateTime := _proxyEDITI.earliestDateTime;
	self.operatorCode := _proxyEDITI.operatorCode;
end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setVoyageProxy" id="c0140bbd-acfb-42ee-8592-9e5f0449bba4">
        <source>setVoyageProxy(_proxyVoyage : CM_Voyage input);
// ---------------------------------------------------------------------------
// Created:	24 March 2010 By Graeme Black cnwgb1
// Purpose:	PAR 23207 Update a Receival Cutoff on the Voyage from EDI
// ---------------------------------------------------------------------------
vars
	proxyCutoff : CM_ReceivalCutoffVoyage;
	cutoffOperator : CM_Operator;
begin
	
	//Transient Check
	_proxyVoyage.raiseExceptionIfNotTransient(method);

	// Check that cutoffs exist for this voyage/terminal
	if _proxyVoyage.allReceivalCutoffs.isEmpty() then
		// There are no cutoffs, try and create them from terminal defaults
		_proxyVoyage.addDefCutoffsForOperator( null );
		// There are no defaults, therefore we cannot set this one
		if _proxyVoyage.allReceivalCutoffs.isEmpty() then
			app.raiseCMException1(CutoffCodeNotInThisTerminal, self.code, null, null);
			return;
		endif;
	endif;

	// Check that our code is valid
	proxyCutoff := _proxyVoyage.allReceivalCutoffs.getAtKey( self.code, null );
	if  proxyCutoff = null then
		app.raiseCMException1(CutoffCodeNotInThisTerminal, self.code, null, null);
		return;
	endif;

	//If operator is specified - check that that cutoffs for that operator exist.
	if self.operatorCode &lt;&gt; null then
		cutoffOperator := _proxyVoyage.allOperators[self.operatorCode];
		//01 Dec 2017	NDL	TFS 7783
		if cutoffOperator = null and _proxyVoyage.myOperator &lt;&gt; null and self.operatorCode = _proxyVoyage.myOperator.code then 
			cutoffOperator := _proxyVoyage.myOperator;
		endif;
		if cutoffOperator = null then 
			app.raiseCMException2(VB_VALID_VOY, self.operatorCode, _proxyVoyage.code, null, null);
		endif;
		proxyCutoff := _proxyVoyage.allReceivalCutoffs.getAtKey( self.code, cutoffOperator );
		// If no defauls have been created then create defaults for that operator
		if proxyCutoff = null then
			_proxyVoyage.addDefCutoffsForOperator( cutoffOperator );
			proxyCutoff := _proxyVoyage.allReceivalCutoffs.getAtKey( self.code, cutoffOperator );
		endif;
	endif;	
	
	// Find and modify the cutoffwith this new information.
	if proxyCutoff &lt;&gt; null then
		proxyCutoff.setForUpdate(self.cutoffDateTime, self.earliestDateTime, 
									null, 	//04/03/2025	navkc1 JIRA Story MTN-34227
									null); 	//04/03/2025	navkc1 JIRA Story MTN-34227
		
	endif; 
epilog
end;</source>
        <Parameter name="_proxyVoyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
</Class>
