	block : CM_DataContainerBlock;
	wag	: CM_Wagon;
begin

	inheritMethod(_dataContainer);

	foreach wag in self.allWagons do

		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Wagon_Number), DC_Label, 1, wag);
		block.addNewItem(wag.id, DC_Data, 1, wag);
	endforeach;
	
end;</source>
