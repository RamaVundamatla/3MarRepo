    <JadeMethod name="isStatusWorking" id="723ebc75-1162-4324-9760-a47d00513856">
        <source>isStatusWorking() : Boolean;
/*
Purpose:			

Date		Who		Reason
08 June 2022	navab1	TFS 53105
*/

vars

begin
	if self.isUsingDefaultProcessJMT then 
		if self.status = Voyage_Status_Loading then 
			return true;
		endif;
	else
		if self.status &gt;= Voyage_Status_VoyageArrived 
		and self.status &lt; Voyage_Status_VesselDeparted then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTaxExempt" id="e71edc64-8f7a-4b47-b0de-434fccb0a7ac">
        <source>isTaxExempt(_invoiceLine : CM_InvoiceLine) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2019	jlger1	Initial creation refactored part of TFS 44550

*/

vars
	hookExempt : Boolean;
	invoice : CM_Invoice;
	pelindoTaxCode : String;
begin
	if self.myHMSVoyageData = null then
		return false;
	endif;
	
	if _invoiceLine &lt;&gt; null then
		invoice:=_invoiceLine.invoice;
	endif;
	
	if invoice &lt;&gt; null then
		pelindoTaxCode:= invoice.getPelindoTaxCode();
		if pelindoTaxCode = "A0"   then		
			return false;
		else
			if pelindoTaxCode &lt;&gt; null then
				return true;
			endif;
		endif;
	endif;
	
	if  self.myHMSVoyageData &lt;&gt; null and self.myHMSVoyageData.isZeroRatedTax then	//12 Jun 2018	NDL	TFS 39141
		if _invoiceLine &lt;&gt; null and _invoiceLine.isVoyageForProforma then
			return true;
		elseif _invoiceLine = null then
			return true;
		endif;
	endif; 
	if self.myHMSVoyageData &lt;&gt; null and self.myHMSVoyageData.isZeroRatedTaxCargo then	// TFS 41949
		return true;																			// TFS 41949
	endif; 																					// TFS 41949
	hookExempt := app.myRoot.getVoyageTaxExempt( self.myTerminal, self ).Boolean;
	if hookExempt then
		return true;
	endif;
	
	
	return false;
epilog

end;</source>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTug" id="e326b635-20ee-4bd7-b5aa-e612f27f0935">
        <source>isTug():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2018	jlgndl1	Initial creation	TFS 41410

*/

vars

begin

	if self.myHMSVoyageData &lt;&gt; null then
		if self.myHMSVoyageData.myVesselType &lt;&gt; null then
			return self.myHMSVoyageData.myVesselType.isTug();
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUniqueJobNum" id="7cc4dd68-d90b-42a1-be00-efcd838645dd">
        <source>isUniqueJobNum(_jobNum : String) : Boolean;
/*

Date		Who		Reason
22 March 2017	cnwer1	Initial creation TFS 830

*/

vars

	jobSheet : CM_VoyageJobSheet;
	vJob : CM_VoyageJob;
begin
	
	foreach jobSheet in self.allJobSheets do
	
		vJob := jobSheet.allJobsByJobNum[_jobNum]; // PAR 36850
		if vJob &lt;&gt; null  then // PAR 36850	
			return false;
		endif;
	endforeach;

	return true;
epilog

end;</source>
        <Parameter name="_jobNum" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUsingCriteriaType" id="88621313-3bd9-4e07-9256-94897b5ba726">
        <source>isUsingCriteriaType(_type : Integer) : Boolean;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars
	yaCriteria : CM_YACriteriaType;
	voyYAConfig : CM_VoyageAllocationConfig;
begin
	voyYAConfig := self.allVoyageAllocationConfigs.first.CM_VoyageAllocationConfig;

	if voyYAConfig &lt;&gt; null then
		if voyYAConfig.allOpCriteria &lt;&gt; null then
			foreach yaCriteria in voyYAConfig.allOpCriteria do
				if yaCriteria.type = _type then
					return true;
				endif;
			endforeach;
		endif;
	endif;
		
	return false;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
