    <JadeMethod name="getDisplayStringForAttribute" id="40cf5cbc-7a4e-400a-b423-9b086bf4849a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     27 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16 Jan 2017	cnwrs1	TFS 3202 Log length not being displayed
// ---------------------------------------------------------------------------
vars

begin
	//28/08/2009 cnwdz2 PAR20519
	if _attrName = ETRow_Operator then
		return self.allOperators.getDisplayCodes(false);	
	elseif _attrName = ETRow_LogSpecies then
		if self.allOperators.size &gt; 0 then
			return self.getAllLogSpecies();
		endif;
		return null;
		
	elseif _attrName = ETRow_LogGrade then
		if self.allOperators.size &gt; 0 then
			if self.allLogSpecies.size &gt; 0 then
				return self.getAllLogGrades();
			endif;
		endif;
		return null;	
	elseif _attrName = ETRow_LogType then
		if self.allOperators.size &gt; 0 then
			if self.allLogSpecies.size &gt; 0 then
				return self.getAllLogTypes();
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_LogTreatment then	
		if self.allOperators.size &gt; 0 then
			if self.allLogSpecies.size &gt; 0 then
				return self.getAllLogTreatments();
			endif;
		endif;
		return null;			
	elseif _attrName = ETRow_LogLength then
		if self.allOperators.size &gt; 0 then
			return self.getAllLogLengths();
		endif;
		return null;		
	elseif _attrName = ETRow_TransportMode then
//		return app.transModeToString(self.transportMode);		
		// Par 10263 - 'ship' can be displayed in thumbnail, choices when setting up transport mode 
		//are 'rail' 'road' or 'both'. Transport mode on log restriction does not have same context 
		// as transport mode on the global sense. Created own method to handle return str HJG 18/06/05
		return self.displayStringForTransportMode();	
	endif;

	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDrawingViewColour" id="e2696a03-162c-43f9-b535-51da56eedb24">
        <source>getDrawingViewColour(_theViewMode: Integer): Integer;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	aColour : Integer;
	theGrade : CM_LogGrade;
begin
	aColour :=  inheritMethod(_theViewMode);

	if _theViewMode = VIEW_LOG_GRADE then
		if self.allLogGrades.size &lt;&gt; 0 then
			theGrade := self.allLogGrades.first.CM_LogGrade;
			aColour := theGrade.CM_LogGrade.colour;
		endif;
	endif;
	
	return aColour;
end;</source>
        <Parameter name="_theViewMode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMaxLength" id="d087f730-2f53-4e47-af19-12dd48340430">
        <source>getMaxLength() : Real;

vars

	length	: CM_Code;
	theMax		: Real;

begin

	foreach length in self.allLogLengths do
		theMax := length.CM_LogLength.sortOrder.Real.max(theMax);
	endforeach;
	return theMax;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getRestrictionAsString" id="b661f145-e54d-4176-bc7c-810d95d5a5ca">
        <source>getRestrictionAsString(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2010	cnwmh5	Initial creation #23957

*/

constants
	DELIM	= ", ";
vars

	operator		: CM_Operator;
	logGrade		: CM_LogGrade;
	logLength		: CM_LogLength;
	logSpecies		: CM_LogSpecies;
	logTreatment 	: CM_LogTreatment;
	logType			: CM_LogType;

	restrictionString : String;
begin
	
	if not self.allOperators.isEmpty() then
		restrictionString := restrictionString &amp; CrLf;
		restrictionString := restrictionString &amp; "Operators:";
		foreach operator in self.allOperators discreteLock do
			restrictionString := restrictionString &amp; operator.code.String &amp; DELIM;
		endforeach;
	endif;
	
	if not self.allLogGrades.isEmpty() then
		restrictionString := restrictionString &amp; CrLf;
		restrictionString := restrictionString &amp; "Log Grades:";
		restrictionString := restrictionString &amp; self.allLogGrades.getEntriesAsString &amp; DELIM;
	endif;
	
	if not self.allLogLengths.isEmpty() then
		restrictionString := restrictionString &amp; CrLf;
		restrictionString := restrictionString &amp; "Log Length:";
		restrictionString := restrictionString &amp; self.allLogLengths.getEntriesAsString &amp; DELIM;
	endif;
	
	if not self.allLogSpecies.isEmpty() then
		restrictionString := restrictionString &amp; CrLf;
		restrictionString := restrictionString &amp; "Log Species:";
		restrictionString := restrictionString &amp; self.allLogSpecies.getEntriesAsString &amp; DELIM;
	endif;
	
	if not self.allLogTreatments.isEmpty() then
		restrictionString := restrictionString &amp; CrLf;
		restrictionString := restrictionString &amp; "Log Treatments:";
		restrictionString := restrictionString &amp; self.allLogTreatments.getEntriesAsString &amp; DELIM;
	endif;
	
	if not self.allLogTypes.isEmpty() then
		restrictionString := restrictionString &amp; CrLf;
		restrictionString := restrictionString &amp; "Log Types:";
		restrictionString := restrictionString &amp; self.allLogTypes.getEntriesAsString &amp; DELIM;
	endif;
	
	restrictionString := restrictionString[1:restrictionString.length - 2]; // remove last comma
	
	return restrictionString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="f43ca5c3-0967-4a57-865c-ef6c18fa08a6">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     12 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	theProxy	: CM_LocationRestrictLog;
	completedOK		: Boolean;
	
begin
	theProxy := inheritMethod();

	self.allLogGrades.copy(theProxy.allLogGrades);
	self.allLogLengths.copy(theProxy.allLogLengths);
	self.allLogSpecies.copy(theProxy.allLogSpecies);
	self.allLogTreatments.copy(theProxy.allLogTreatments);
	self.allLogTypes.copy(theProxy.allLogTypes);

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return theProxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete theProxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreateAuto" id="29fbb026-019e-4931-9f0e-8353d05d9f69">
        <updating/>
        <source>setForCreateAuto(_ta: CM_TerminalArea; _tmpTI: CM_TrackedItem; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     01 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpLog			: CM_Log;
begin
	inheritMethod(_ta, _tmpTI, _passport);

	if (not CM_Log.hasInstance(_tmpTI)) then
		return;
	endif;
	
	tmpLog := _tmpTI.CM_Log;
	
	if tmpLog.myLogSpecies &lt;&gt; null then
		self.allLogSpecies.add(tmpLog.myLogSpecies);
		
		if tmpLog.myLogGrade &lt;&gt; null then
			self.allLogGrades.add(tmpLog.myLogGrade);
			
			if tmpLog.myLogType &lt;&gt; null then
				self.allLogTypes.add(tmpLog.myLogType);
			endif;
			
			if tmpLog.myLogTreatment &lt;&gt; null then
				self.allLogTreatments.add(tmpLog.myLogTreatment);
			endif;
			
			if tmpLog.myLogLength &lt;&gt; null then
				self.allLogLengths.add(tmpLog.myLogLength);
			endif;
			
		endif;
	endif;
	
	
	
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_tmpTI" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f41a7d38-fc67-48fc-b4b1-6771c0d33f5b">
        <updating/>
        <source>setForUpdate(prxyRestriction: CM_LocationRestrictLog) updating;
// ---------------------------------------------------------------------------
// Created:     12 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	code : CM_Code;

begin

	inheritMethod(prxyRestriction);

	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264 - clearing them
		foreach code in self.allLogGrades do
			self.updateObjectEdition(code);
		endforeach;
	endif;
	
	self.allLogGrades.clear;
	self.allLogLengths.clear;
	self.allLogSpecies.clear;
	self.allLogTreatments.clear;
	self.allLogTypes.clear;
	if not prxyRestriction.allOperators.isEmpty then		
		prxyRestriction.allLogGrades.copy(self.allLogGrades);
		prxyRestriction.allLogLengths.copy(self.allLogLengths);
		prxyRestriction.allLogSpecies.copy(self.allLogSpecies);
		prxyRestriction.allLogTreatments.copy(self.allLogTreatments);
		prxyRestriction.allLogTypes.copy(self.allLogTypes);
	endif;
	
	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264 - adding them
		foreach code in self.allLogGrades do
			self.updateObjectEdition(code);
		endforeach;
	endif;
	
	self.estimatedMaxVolume := prxyRestriction.estimatedMaxVolume;
	self.maxLogLength := prxyRestriction.maxLogLength;
	self.mixedRow := prxyRestriction.mixedRow;
	self.transportMode := prxyRestriction.transportMode;
end;</source>
        <Parameter name="prxyRestriction" type="CM_LocationRestrictLog"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF" id="28aab4f7-fd69-424d-8dd4-027cc4ea8e87">
        <updating/>
        <source>setFromCMIF(_cmif : CMIF_LogRowRestriction) updating;



begin

	self.raiseExceptionIfNotTransient(method);
	self.setProxy(0, _cmif.user, _cmif.comment,_cmif.myRowArea, 
				_cmif.allOperators, //26/08/2009 cnwdz2 PAR20519
				_cmif.allSpecies, //26/08/2009 cnwdz2 PAR20519
				_cmif.allGrades, _cmif.allTypes, 
				_cmif.allTreatments, 
				_cmif.allLengths, 
				_cmif.estimatedMaxVolume, 0, 
				_cmif.isMixedRow, _cmif.transport); 
	

end;</source>
        <Parameter name="_cmif" type="CMIF_LogRowRestriction"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="0e1fd434-1328-4df9-a4ee-f5c67f01a60e">
        <updating/>
        <source>setProxy(_colour				: Integer;
		 _user			,
		 _comment				: String;
  	 	 _terminalArea 			: CM_TerminalArea;
		 _operators,				 //26/08/2009 cnwdz2 PAR20519
		 _species,				 //26/08/2009 cnwdz2 PAR20519
		 _allLogGrades,
		 _allLogTypes,
		  _allLogTreatments,
		 _allLogLengths			: ObjectArray;
		 _estimatedMaxVolume	: Decimal;
		 _maxLength				: Integer;
		 _mixedRow				: Boolean;
		 _transportMode			: Integer ) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.setId(_terminalArea);
	self.setForProxyRestriction(_colour, _user, _comment);
	self.myTerminalArea := _terminalArea;
	self.allOperators.clear;
	self.allLogSpecies.clear;
	self.allLogGrades.clear;
	self.allLogLengths.clear;
	self.allLogTreatments.clear;
	self.allLogTypes.clear;

	//26/08/2009 cnwdz2 PAR20519
	//if _operator &lt;&gt; null then
	_operators.copy(self.allOperators);
	//endif;
	
	//26/08/2009 cnwdz2 PAR20519
	//if _species &lt;&gt; null then
	_species.copy(self.allLogSpecies);	
	//endif;
	_allLogGrades.copy(self.allLogGrades);
	_allLogLengths.copy(self.allLogLengths);
	_allLogTreatments.copy(self.allLogTreatments);
	_allLogTypes.copy(self.allLogTypes);
	self.estimatedMaxVolume := _estimatedMaxVolume;
	self.maxLogLength := _maxLength;
	self.mixedRow := _mixedRow;
	self.transportMode := _transportMode;
end;</source>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_user" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_operators" type="ObjectArray"/>
        <Parameter name="_species" type="ObjectArray"/>
        <Parameter name="_allLogGrades" type="ObjectArray"/>
        <Parameter name="_allLogTypes" type="ObjectArray"/>
        <Parameter name="_allLogTreatments" type="ObjectArray"/>
        <Parameter name="_allLogLengths" type="ObjectArray"/>
        <Parameter name="_estimatedMaxVolume" type="Decimal"/>
        <Parameter name="_maxLength" type="Integer"/>
        <Parameter name="_mixedRow" type="Boolean"/>
        <Parameter name="_transportMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setToAllowType" id="ce8ca4f6-bbe5-4032-b44d-7f9fe6f70e8f">
        <updating/>
        <source>setToAllowType(_search: CMIF_SearchTypes) updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSpecies	: CM_LogSpecies;
	tmpGrade	: CM_LogGrade;
	tmpType		: CM_LogType;
	tmpTreat	: CM_LogTreatment;
	tmpLength	: CM_LogLength;
	
begin
	inheritMethod(_search);

	tmpSpecies := _search.mySpecies;
	if (tmpSpecies &lt;&gt; null) and 
	   (not self.allLogSpecies.isEmpty) and
	   (not self.allLogSpecies.includes(tmpSpecies)) then
		self.allLogSpecies.add(tmpSpecies);
	endif;

	tmpGrade := _search.myGrade;
	if (tmpGrade &lt;&gt; null) and 
	   (not self.allLogGrades.isEmpty) and 
	   (not self.allLogGrades.includes(tmpGrade)) then
		self.allLogGrades.add(tmpGrade);
	endif;

	tmpType := _search.myType;
	if (tmpType &lt;&gt; null) and
	   (not self.allLogTypes.isEmpty) and
	   (not self.allLogTypes.includes(tmpType)) then
		self.allLogTypes.add(tmpType);
	endif;

	tmpTreat := _search.myTreatment;
	if (tmpTreat &lt;&gt; null) and 
	   (not self.allLogTreatments.isEmpty) and
	   (not self.allLogTreatments.includes(tmpTreat)) then
		self.allLogTreatments.add(tmpTreat);
	endif;

	tmpLength := _search.myLength;
	if (tmpLength &lt;&gt; null) and 
	   (not self.allLogLengths.isEmpty) and
	   (not self.allLogLengths.includes(tmpLength)) then
		self.allLogLengths.add(tmpLength);
	endif;
	
	if (not self.mixedRow) then
		if self.allOperators.size &gt; 1 or
		   self.allLogSpecies.size &gt; 1 or
		   self.allLogGrades.size &gt; 1 or
		   self.allLogTypes.size &gt; 1 or
		   self.allLogTreatments.size &gt; 1 or
		   self.allLogLengths.size &gt; 1 then
			self.mixedRow := true;
		endif;
	endif;

end;</source>
        <Parameter name="_search" type="CMIF_SearchTypes"/>
    </JadeMethod>
    <JadeMethod name="validate" id="8331a4d6-5ca5-4b94-a201-69a220c0a665">
        <source>validate();
// -------------------------------------------
// Created 03 August 2004 by cnwdvb1
// -------------------------------------------
// 29/12/2014  cnwdb2	PAR 35364
vars

begin
	inheritMethod();
	
	if transportMode = 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Transport Mode', null, null);
		app.raiseCMException(Input_required_field_TransMode, null, null); // cnwdb2	PAR 35364
	endif;
	
	if (self.allOperators.isEmpty) and
	   (not self.allLogSpecies.isEmpty or
	   not self.allLogGrades.isEmpty or
	   not self.allLogTypes.isEmpty or
	   not self.allLogTreatments.isEmpty or
	   not self.allLogLengths.isEmpty) then
	   app.raiseUnexpectedProgramError(class.name, method.name, 'Population of log specs when no supplier selected');
	endif;
end;</source>
    </JadeMethod>
