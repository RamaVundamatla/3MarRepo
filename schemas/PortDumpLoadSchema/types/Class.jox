<Class name="Class">
    <JadeMethod name="getPropertiesAllSuperclassPD" id="a1ca424c-0cad-48c4-9d87-3abbad2afb2a">
        <source>getPropertiesAllSuperclassPD(_propertyDict : PropertyNDict input);
// ---------------------------------------------------------------------------
// Created:     27 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	propDict		: PropertyNDict;
	cls				: Class;
begin
	if (_propertyDict = null)then
		return;
	endif;
	cls := self;
	while cls.name &lt;&gt; Object.name do
		propDict := cls.getProperties();
		propDict.copy(_propertyDict);
		cls := cls.getSuperclass();
	endwhile;

end;</source>
        <Parameter name="_propertyDict" type="PropertyNDict" usage="input"/>
    </JadeMethod>
</Class>
