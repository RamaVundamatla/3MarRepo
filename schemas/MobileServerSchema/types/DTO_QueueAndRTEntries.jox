<Class name="DTO_QueueAndRTEntries" id="a303dd4e-c3d5-465f-9e2c-16856d0df305">
    <superclass name="DTO_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="admin"/>
    <ImplicitInverseRef name="allDTORTQueueEntries" id="a431f2f8-ad9b-4d43-a8ec-37bd028b5a6d">
        <memberTypeInverse/>
        <type name="DTO_RTQueueEntryArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myQueue" id="860bf277-a80f-4d67-aaa0-028701bcb067">
        <embedded/>
        <type name="CM_RadioTelemetryQueue"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="87ea232b-3c84-4a2b-8e8e-51917506c19e">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2010	cnwer1	Initial creation

*/

vars

begin
	allDTORTQueueEntries.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadToTable" id="a1f13974-73ff-4b0f-bee4-7b381e7a8b91">
        <source>loadToTable(_machine : CM_Machine;
			_table: Table input; 
			_view : EntTableView;
			_headerIsTopRow 	: Boolean;
			_startOffset  : Integer );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2010	cnwer1	Initial creation

*/

vars
	isVisible : Boolean;
	newPosition	,
	i,
	order			: Integer;
	dtoRTQueueEntry : DTO_RTQueueEntry;
begin

	if _table = null then
		return;
	endif;
	
	i:=1;
	foreach dtoRTQueueEntry in self.allDTORTQueueEntries do
		order:=_startOffset+i;
	
		isVisible:=true;
		if _headerIsTopRow then
			_table.rows:=_table.rows + 1;
			newPosition:=_table.rows;
			if  _machine.hasAllocatedQueueTasks() then
				if not _machine.isQueueEntryAllocated(dtoRTQueueEntry.myRealQueueEntry.CM_RTQueueEntry) then
			//if   _machine.allAllocatedQueueTasks &lt;&gt; null then
				//if dtoRTQueueEntry.myRealQueueEntry.CM_RTQueueEntry.findControlAllocatedTaskToMach(_machine) = null then
					isVisible:=false;
				endif;
			endif;
		else
			_table.columns:=_table.columns + 1;
			newPosition:=_table.columns;
		endif;

		dtoRTQueueEntry.loadToTable(_table,_view, _headerIsTopRow,newPosition,order,isVisible);
		i:=i+1;
	endforeach;
	
	
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_view" type="EntTableView"/>
        <Parameter name="_headerIsTopRow" type="Boolean"/>
        <Parameter name="_startOffset" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyQueue" id="7717b006-6bd3-47f8-b786-5762408469fb">
        <updating/>
        <source>setMyQueue(_queue : CM_RadioTelemetryQueue input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2010	cnwer1	Initial creation

*/

vars

begin
	self.myQueue:=_queue;
epilog

end;</source>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue" usage="input"/>
    </JadeMethod>
</Class>
