    <JadeMethod name="tblExclude_rowColumnChg" id="2f53904d-ca0a-451d-ba29-e8fbce0a94ce">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExclude_rowColumnChg(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	saveRow		: Integer;
	rowPointer	: Integer;

begin
	saveRow	:=	table.row;

	// compress any blank rows

	rowPointer	:=	table.rows - 1;
	
	while rowPointer &gt;= 2 do
		table.row	:=	rowPointer;
		
		if table.text = null then
			table.deleteRow(rowPointer);
		endif;
		rowPointer	:=	rowPointer - 1;
	endwhile;

	table.row	:=	saveRow;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
