    <JadeMethod name="getVoyageForRelease" id="62e07787-049d-48cf-96a2-61a5e3cdfbae">
        <source>getVoyageForRelease(_realBulkRelease :CM_BulkRelease; _voyage :CM_Voyage output; _voyageCode :String output);
/*

Date		Who		Reason
14 September 2016	cnwer1	Initial creation TFS 2606 moved from CM_EDIDataReleaseRequest
// 13 Dec 2017	jlgrs1	TFS 8281 - SNO - EDI New Coaprn Issues
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/

vars
	ediRelReqTI : CM_EDIReleaseRequestTI;
	operator : CM_Operator;
	defaultVoyage : CM_Voyage;
	voyageCode : String;
	newVoyageCode : String;
	foundMatch : Boolean;
begin
	voyageCode	:=	self.getVoyageCode();

	operator := app.myRoot.allOperators[self.operatorCode];
	if _voyage = null and
	   operator &lt;&gt; null then
		newVoyageCode := operator.getXlationSystemCode_Voyage(voyageCode, self.vesselName, null, null, foundMatch);
		if newVoyageCode &lt;&gt; null and voyageCode &lt;&gt; newVoyageCode then
			ediRelReqTI := self;
			beginTransaction;
			ediRelReqTI.setVoyageCode(newVoyageCode);
			commitTransaction;
			voyageCode := newVoyageCode;
		endif;
	endif;
	if voyageCode &lt;&gt; null then
		_voyage	:= self.getMyTerminal.allVoyagesByCode.getAtKeyGeq(voyageCode, null);
	endif;
	
	if _voyage &lt;&gt; null and _voyage.code &lt;&gt; voyageCode then
		// a different voyage was found
		_voyage := null;
	endif;
			
	if _voyage = null then
	
		defaultVoyage:= self.myEDIData.CM_EDIDataReleaseRequest.getDefaultVoyage(self.senderCode);
		// EDI File did not contain a valid voyage
		if defaultVoyage &lt;&gt; null then
			// we have a default voyage we could use
			if _realBulkRelease = null or _realBulkRelease.myVoyage = defaultVoyage then
				// we are adding a new release or updating a release that is already for the default voyage
				if voyageCode &lt;&gt; null then 
					// just give warning of invalid voyage in file as we will use the default voyage 
					app.raiseCMWarning1(ERR_INVALID_VOYAGE, voyageCode, ETRow_Voyage, self, null);	
				endif;
				// use default voyage instead of voyage from file
				_voyage 	:= defaultVoyage;														
				voyageCode	:= _voyage.code;	
			endif;
		endif;
	endif;

	if voyageCode &lt;&gt; null and _voyage = null then
		// the voyage from the file is invalid and we can't use the default voyage (if there is one)
		app.raiseCMException1(ERR_INVALID_VOYAGE, voyageCode, ETRow_Voyage, self);
	endif;
	_voyageCode := voyageCode;
epilog

end;</source>
        <Parameter name="_realBulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="output"/>
        <Parameter name="_voyageCode" type="String" usage="output"/>
    </JadeMethod>
