    <JadeMethod name="ediFileTypeChange" id="a06d41d6-2c02-4e23-8568-3a48c455b709">
        <updating/>
        <source>ediFileTypeChange() updating;
/*

Purpose:	This method checks for selected edi file type changes on the ui, if we have a change then set the boolean to true		

Parameters:			

Return Value:		

Date				Who		Reason
04 December 2024	navlw1	Jira-14844: MTN - Refinement of EDI Issue Save

*/

vars
	types,
	savedTypes	: CM_EDIFileTypeByNameDict;
	ediFileType	: CM_EDIFileType;
begin

	create types transient;
	create savedTypes transient;
	
	self.msgEDITypes.getSelected(types);
	if self.myCurrentEDIIssue = null then
		return;
	endif;
	self.myCurrentEDIIssue.getEDIFileTypes(savedTypes, self.myTerminal);

	foreach ediFileType in types discreteLock do
		if not savedTypes.includes(ediFileType) then
			self.ediChanged := true;
		endif;
	endforeach;
epilog
	delete types;
	delete savedTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="getEDIDataTypes" id="9ab6d4ba-4344-4a8d-b694-67505911485e">
        <updating/>
        <source>getEDIDataTypes() updating;
/*
Purpose:	

Date		Who		Reason
09 July 2024	navab1	CR 64617 TASK 64638
*/

vars
	ediAgent	: CM_EDIFileTypeAgent;
	ediFileType	: CM_EDIFileType;

begin
	if self.myEDIFilTypeAgent = null then
		create self.myEDIFilTypeAgent transient;
	endif;
	
	ediAgent := self.myEDIFilTypeAgent;
	ediAgent.initForReal(self.myTerminal);
	
	
epilog

end;</source>
