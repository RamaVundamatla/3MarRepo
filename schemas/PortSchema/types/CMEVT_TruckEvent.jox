        <updating/>
        <source>setMyVisit(_visit: CM_VehicleVisitRecord) updating;
/*

Date		Who		Reason
04 December 2014	cnwer1	Initial creation PAR

*/

	
begin
	self.myVisit := _visit;
	if not self.isTransient and self.myVisit &lt;&gt; null then
		self.myVisit.causeEvent(EventTransaction_Create_Event,false,self);
	endif;
epilog

end;</source>
        <Parameter name="_visit" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setMyWOTransaction" id="ad268f4f-aa28-4970-8973-4c84bfb5cd51">
        <updating/>
        <source>setMyWOTransaction(_woTransaction : CM_WOTransaction) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62897: Jade - Job Create Transactions and Events

*/

vars

begin
	self.myWOTransaction := _woTransaction;
epilog

