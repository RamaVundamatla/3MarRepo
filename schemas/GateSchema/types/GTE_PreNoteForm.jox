        <updating/>
        <source>txtTimeOffPower_lostFocus(textbox: TextBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/05/2013	cnwdap1		Initial creation PAR #31574 Allowable Time Off Power editing
//
vars

begin
