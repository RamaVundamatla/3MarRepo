    <JadeMethod name="getDescription" id="a8351eb7-0b6b-4259-821a-e217a6f6636d">
        <source>getDescription(_short : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		19 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	long : String;
begin
	if _short then
		long := self.myDelayType.description;
	else
		if self.myVoyage &lt;&gt; null then
			long := long &amp; " " &amp; self.myVoyage.code;
		endif;
		if self.myMachine &lt;&gt; null then
			long := long &amp; " " &amp; self.myMachine.code &amp; " " &amp; self.myMachine.description;
		endif;
		if self.myDelayType &lt;&gt; null then
			long := long &amp; " " &amp; self.myDelayType.description;
		endif;
	endif;
	return long.trimBlanks();
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="34f89c2c-438f-42f6-aaa9-038abe89db56">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
----------   ----------  --------------------------------------------------
Created:	15 February 2007 By cnwmo1

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	voyage		:CM_Voyage;
	delayType	:CM_DelayType;
	machine		:CM_Machine;
	driver		:CM_User;
	workpoint	:CM_WorkPoint;
begin
	if _attrName = ETRow_MyVoyage  then
		voyage := self.myVoyage;
		
		if voyage &lt;&gt; null then
			return voyage.code &amp; ' - ' &amp; voyage.description ;
		endif;
		
		return null;
	elseif _attrName = ETRow_MyDelayType then
		delayType := self.myDelayType;
		
		if delayType &lt;&gt; null then
			return delayType.description;
		endif;	
		
		return null;
	elseif _attrName = ETRow_CreationTime  then
		return self.systemToLocalTime(self.createdTime).asStringJMT;//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_StartDT  then
		return self.systemToLocalTime(self.startDT).asStringJMT;	//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	elseif _attrName = ETRow_EstEndDT  then
		return self.systemToLocalTime(self.estEndDT).asStringJMT;	//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	elseif _attrName = ETRow_EndDT then
		return self.systemToLocalTime(self.endDT).asStringJMT;		//04 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	elseif _attrName = ETRow_MyMachine  then
		machine := self.myMachine;
		
		if machine &lt;&gt; null then
			return machine.code;	
		endif;
		
		return null;
	elseif _attrName = ETRow_MyDriver then
		driver := self.myDriver;
		
		if driver &lt;&gt; null then
			return driver.code;	
		endif;
		
		return null;
	elseif _attrName = ETRow_MyWorkPoint then
		workpoint := self.myWorkPoint;
		
		if workpoint &lt;&gt; null then
			return workpoint.description;
		endif;
		
		return null;
	elseif _attrName = ETRow_VoyageEvent then	//24 Aug 2018	NDL	TFS 40309
		if self.myVoyageEvent &lt;&gt; null and self.myVoyageEvent.myEventType &lt;&gt;null then
			return self.myVoyageEvent.myEventType.name;
		endif;
		return null;
	endif;
	
	
	return inheritMethod(_attrName, _short);
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDriverWorkPointString" id="a346e01c-cb1e-45f7-8b4f-90452b98afd6">
        <source>getDriverWorkPointString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 June 2012	cnwndl1	Initial creation	Par 29689

*/

vars

	str : String;

begin

	if self.myDriver &lt;&gt; null then
		str := self.myDriver.code;
	endif;
	
	if self.myWorkPoint &lt;&gt; null then 
		if str &lt;&gt; null then
			str := str &amp; " / "; 
		endif;
		str := str &amp; self.myWorkPoint.code;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEndDT" id="829262c9-e50c-4b9e-980b-c6a8ed4423a3">
