    <JadeMethod name="trxSpellWordCreate" id="d0a5420e-0cda-42ce-93d0-a0733d64f0fe">
        <updating/>
        <source>trxSpellWordCreate(	pSpellCheckRootParent : CnEcSpellRoot io;
					pSpellRootObj:CnEcSpellRoot;
					pName:String;
					pSpellWordNew : CnEcSpellWord output): String updating;
// This method created by JediMethodGenerator at 17:00:46 on 07 June 2001
// Please add any validation required then delete this comment.
// --------------------------------------------------------------------------------
// Purpose:		Transaction method to create a SpellWord object.
//
// Parameters:	The object (Parent) that performs the create.
//              The keys and property values of the entity to be created.
//				The newly created object is returned in the output parameter.
//
// Returns:		Null if the transaction is successful, otherwise an error message
//				is returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Validate the request.

	if pSpellCheckRootParent = null then
		return self.agentSetError('No SpellCheckRoot selected to create from  ');
	endif;

	// Start the Transaction.

	beginTransaction;

	// Perform the operation.

	self.lastError := pSpellCheckRootParent.spellwordCreate(pSpellRootObj,
															pName,
															pSpellWordNew);

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error to the caller (which will be null if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pSpellCheckRootParent" type="CnEcSpellRoot" usage="io"/>
        <Parameter name="pSpellRootObj" type="CnEcSpellRoot"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="pSpellWordNew" type="CnEcSpellWord" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxSpellWordDelete" id="d90fc1c3-0678-417b-b847-41e7f8020bc5">
        <updating/>
        <source>trxSpellWordDelete(pSpellWordToDelete : CnEcSpellWord io ): String updating;
// This method created by JediMethodGenerator at 17:00:46 on 07 June 2001
// --------------------------------------------------------------------------------
// Purpose:		Transaction to delete a SpellWord.
//
// Parameters:	The object to be deleted. This will be set to null by the delete.
//
// Returns:		Null if the transaction is successful, otherwise an error message
//				is returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Validate the request.

	if pSpellWordToDelete = null then
		return self.agentSetError("No SpellWord selected to delete  ");
	endif;

	// Start the transaction
	beginTransaction;

	// If the owner object is invalid, then we want our exception handlers to
	// return a message saying so.  After registering the object and a message
	// here, if any subsequent invalid object exceptions occur, the exception
	// handler will then find the registered object and set the "errorMsg"
	// property on the app class.  Therefore, by checking this errorMsg value
	// after performing an operation on the object (app.getLastError), the
	// appropriate error message can be returned for the exception.

	// If a validation method is used, then this step shouldn't be necessary
	// here, since the object will already have been validated.
	self.agentRegisterObjectAndError(pSpellWordToDelete, "Invalid SpellWord object.");
		// The delete will do nothing if the reference is already null.
	delete pSpellWordToDelete;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error to the caller (which will be null if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pSpellWordToDelete" type="CnEcSpellWord" usage="io"/>
        <ReturnType type="String"/>
