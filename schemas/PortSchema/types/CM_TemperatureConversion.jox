    <JadeMethod name="auditId" id="046de82e-00aa-4f34-9d87-04f022fb58f7">
        <source>auditId(): String;
// ---------------------------------------------------------------------------
// Created:     May 2006 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.celsius.String &amp; Degrees_C &amp;  " &gt; " &amp; self.fahrenheit.String &amp; Degrees_F;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
