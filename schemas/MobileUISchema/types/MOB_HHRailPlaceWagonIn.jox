    <JadeMethod name="checkWagonIsForTrain" id="2a1037be-4a58-4fce-a62c-9bd4a585011e">
        <updating/>
        <source>checkWagonIsForTrain( _wagon : CM_Wagon; _updateLabel : Boolean  ):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars
	train : CM_Train;
	train2 : CM_Train;
	trainCode : String;
begin

	train := self.myMobileGenericAgent.myCurrentTrain;
	if train = null then
		if _updateLabel then
			lblMessage.caption := "No train!!";
		endif;
		return false;
	endif;
	
	if not train.allWagonsByOrderInward.includes(_wagon) then
		trainCode := app.getErrorString(Unknown);
		train2 := _wagon.myTrainInwards;
		if train2 &lt;&gt; null then
			trainCode := train2.getCodeDateString;
		endif;
		if _updateLabel then
			if train2 &lt;&gt; null and train2.isNullTrain then
				lblMessage.caption := app.getErrorString1(On_NullTrain_Available_Add,train2.description);
			else
				lblMessage.caption := app.getErrorString1(Wagon_belongs_another_train,trainCode);
			endif;
		endif;
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_updateLabel" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clickBtnAddWagon" id="14a422ae-43e0-4d7b-9f3b-9d0102e90769">
        <updating/>
        <source>clickBtnAddWagon() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215
Apr 2011	cnwjre1	pars 27069, 27015

*/

vars

	newWagonId : String;
	railLine : CM_RailLine;
	index,
	rakePos : Integer;
	currentWagon,
	wagon : CM_Wagon;
	addIt : Boolean;
	changeIt  : Boolean;
	restore	  : Boolean;
	nullTrain : CM_Train;

begin

	app.mousePointer :=	Busy;
	
	newWagonId := cmbWagon.text.trimBlanks.toUpper;
	if newWagonId &lt;&gt; null then
		rakePos := cmbRakePos.itemData[cmbRakePos.listIndex];
		if rakePos &gt; 0 and self.myMobileGenericAgent.myCurrentRailLine.allWagons.size &gt;= rakePos then
			currentWagon := self.myMobileGenericAgent.myCurrentRailLine.allWagons[rakePos];
		endif;
		if currentWagon &lt;&gt; null then
//write "1";
			if newWagonId &lt;&gt; currentWagon.id and
			   cmbWagon.listObject = null then
				// must have no cargo, be for the same train and not already confirmed
				if not currentWagon.hasTrackedItems and
				   self.checkWagonIsForTrain(currentWagon, false) and
				   not currentWagon.confirmed then
					changeIt := true;
				endif;
				if not changeIt then
				// restore the original wagon in the combo
					index := self.cmbWagon.findObject(currentWagon);
					if index &gt; 0 then
						self.cmbWagon.listIndex := index;
						restore := true;
					endif;
				endif;
			endif;
		else
			nullTrain := self.myTerminal.getNullTrain;
			wagon := cmbWagon.listObject.CM_Wagon;
			if wagon = null then
				// No wagon found should be ok to create one.
				addIt := true;
			elseif wagon.myTrainInwards = nullTrain then
				// The wagon is there and available to be changed onto this train.
				addIt := true;
			endif;
		endif;
	endif;	
	
	if addIt then
		railLine := self.myMobileGenericAgent.myCurrentRailLine;
		rakePos := self.cmbRakePos.itemData[self.cmbRakePos.listIndex];
		if rakePos &gt; 0 then
			// user has entered some 'wagon' text, against a position that doesn't have a wagon associated with it.
			// this could be a new wagon or alternatively an existing wagon on the null train.
			if self.createNewWagon( newWagonId ) &lt;&gt; null then
				self.populateAllDynaWagons(); // rebuild the collection it has changed.
				self.populateCmbWagon();
				self.displayWagon();
			endif;
		endif;
	// 27069, 27015 04/2011 allow change of wagon id and refresh the graphic
	elseif changeIt then
		self.updateWagonId(newWagonId, currentWagon);
		self.populateCmbWagon();
		self.displayWagon();
	else
	// 27069 04/2011 show wagon and cargo from explicit action, not automatically from wagon combo change
		self.wagonSelect(restore);
	endif;
	
epilog

	app.mousePointer :=	Idle;

end;</source>
    </JadeMethod>
    <JadeMethod name="createNewWagon" id="a983bd5a-8d9e-4437-bbee-4021d48e5e84">
        <source>createNewWagon( _newWagonId: String) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars
	errorMess : String;
	rakePos : Integer;
	train : CM_Train;
	wagon : CM_Wagon;
begin
	app.mousePointer :=	Busy;

	train := self.myMobileGenericAgent.myCurrentTrain;
	if train = null then
		return false;
	endif;
	
	rakePos := self.cmbRakePos.itemData[self.cmbRakePos.listIndex];
	if rakePos = 0 then
		return false;
	endif;
	
	wagon := train.createOrUpdateWagon(_newWagonId, rakePos, self.myMobileGenericAgent.myCurrentRailLine, errorMess);
	
	if wagon = null and errorMess &lt;&gt; "" then
		app.mousePointer :=	Idle;
		self.msgBox(errorMess ,app.getErrorString(Error), MsgBox_OK_Only, true);
	endif;
	
	return wagon &lt;&gt; null;
epilog
	app.mousePointer :=	Idle;
end;</source>
        <Parameter name="_newWagonId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doConfirm" id="a816014a-4bcd-4530-8407-6c1c844ba883">
        <updating/>
        <source>doConfirm():Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	wagon : CM_Wagon;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	unconfirmed : String;
	mess : String;
	wagonArray : CM_WagonArray;
	returnIndex : Integer;
	control : CMIF_WagonMoveController;
	nullTi : CM_TrackedItem;

begin

	wagon := cmbWagon.listObject.CM_Wagon;
	
	if wagon = null then
		return false;
	endif;
	
	// check that all cargo is already in the confirmed collection.
	create tiArray transient;
	
	if wagon.isBoxcar then
		// no action required //07 June 2013	NDL	Par 31681
	else
		wagon.getAllTrackedItems(true, tiArray, false);
		foreach ti in tiArray do
			if self.myMobileGenericAgent.tiIsConfirmed(ti) then
				continue;
			endif;
			if unconfirmed = null then
				unconfirmed := ti.id;
			else
				unconfirmed := unconfirmed &amp; ", " &amp; ti.id;
			endif;
		endforeach;
	endif;
	
	if unconfirmed &lt;&gt; null then
		app.mousePointer :=	Idle;
		mess := app.getErrorString1(Please_confirm_cargo_items,unconfirmed);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return false;
	endif;
	
	//11 Mar 2015	NDL	Par 35828
	if self.myTerminal.hasNoCargoCheckItemsFor(WAGON_CHECK_CONTEXT_PLACE_IN) then
		// no checks to worry about.
	elseif self.myMobileGenericAgent.isWaitingOnRequiredChecks(WAGON_CHECK_CONTEXT_PLACE_IN, wagon, nullTi) &lt;&gt; null then
		app.mousePointer :=	Idle;
		self.clickBtnWagonChecks;
		return false;
	endif;

	// all OK 
//	self.myHandHeldCheckerAgent.addConfirmedWagonIn( wagon );
	create wagonArray transient;
	wagonArray.add( wagon );
	create control transient;
	//control.doAutoPlanOfCargo := false;
	control.doAutoPlanOfCargo := self.myMobileGenericAgent.autoPlanWagonCargo;	//14 Nov 2011	NDL	Par 28674
	
	app.myPassport.clearErrorsWarnings();

	while true do
		app.myTrxUA.trxUpdateWagonConfirm(wagonArray, true, control, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
			
		else
			returnIndex := app.showErrorWarningDialog(app.getErrorString(Transit_Rail), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and returnIndex = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;

	// 27019 04/2011 After confirm wagon the system is not defaulting to next position
	self.btnRakeForward_click(self.btnRakeForward);
	return true;
	
epilog

	delete wagonArray;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="2a05671b-4718-476b-b667-85f2c0e9100f">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	top : Real;
	left : Real;
	btnWidth : Real;
	height : Real;
	
begin

	self.setResizeableMarginAndFontSize();
	inheritMethod(_initialSetup);
	
	top := self.cmbWagon.top;
	btnWidth := self.getSearcherHeight() + 4;
	
	self.cmbWagon.width := self.cmbWagon.width - btnWidth - self.resizedMargin;
	
	left := self.cmbWagon.left + self.cmbWagon.width + self.resizedMargin;
	height := self.cmbWagon.height;
	
	if _initialSetup then
		self.btnAddWagon.visible := true;
	endif;
	self.btnAddWagon.move(	left,
							top,
							btnWidth,
							height );
	
	if _initialSetup then
		self.setWagonAddBtn();
	endif;
	
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getButtonColour" id="573927ea-3bd3-432c-8c62-1d5e675c85d0">
        <source>getButtonColour( ti : CM_TrackedItem; _wagon : CM_Wagon ): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2010	cnwndl1	Initial creation

*/

vars

begin
	
	if _wagon.confirmed then
		return self.colourConfirmed;
	elseif ( ti &lt;&gt; null and self.myMobileGenericAgent.tiIsConfirmed( ti ) ) then
		return self.colourConfirmed;
	endif;
	
	return self.colourUnConfirmed;

epilog

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
