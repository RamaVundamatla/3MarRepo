<Class name="NR_FileNode" id="92906920-fb00-481d-a152-7184642f986f">
    <superclass name="NR_NodeRequestEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="nodereq"/>
    <PrimAttribute name="baseName" id="6f0cf515-56ab-46aa-b1e9-be9764121309">
        <length>256</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="fileSize" id="4a7ca4d8-05da-446f-9f8f-74006cb9d374">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="lastModified" id="8b735cc8-38b1-452a-a982-cbaf7b77fe22">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myFileRequest" id="8480745a-d316-459b-abda-f8e50d570c29">
        <kind>child</kind>
        <embedded/>
        <type name="NR_NodeFileRequest"/>
        <access>readonly</access>
        <Inverse name="NR_NodeFileRequest::allFileNodesByBaseName"/>
        <Inverse name="NR_NodeFileRequest::allFileNodesByModifiedDT"/>
    </ExplicitInverseRef>
    <PrimAttribute name="pathName" id="2b47615f-6da1-4173-ac85-5fec0a73e139">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="set" id="75bad369-dbc5-4da8-841f-f42b991e9755">
        <updating/>
        <source>set(_file : File; _fileRequest : NR_NodeFileRequest) updating;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.baseName		:= _file.name;
	self.fileSize		:= _file.fileLength();
	self.lastModified	:= _file.lastModified();
	self.pathName		:= _file.fileName;
	
	self.myFileRequest	:= _fileRequest;

end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_fileRequest" type="NR_NodeFileRequest"/>
    </JadeMethod>
</Class>
