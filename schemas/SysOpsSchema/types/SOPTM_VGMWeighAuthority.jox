    <JadeMethod name="create" id="612a458f-1489-4381-b688-0c33c272f21c">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/06/2017	cnwdap1		Initial creation TFS 4492 / 2523 SNO / CPL VERMAS Changes
//
vars

begin
	self.name := SOP_TableMaintForm.Table_WeighAuthority;
	self.permissionView	 := PmAdmWeighAuthView;
	self.permissionMaint := PmAdmWeighAuthMaint;
	self.myDataClass := CM_WeighAuthority;
epilog

end;</source>
