        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="84fd016c-e2bd-40d1-a547-ad449695a71b">
        <source>validateForDelete(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 11 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 08/12/2014   cnwdb2      PAR 35364

vars
	voy : CM_Voyage;
begin

	foreach voy in self.allVoyages do
		voy.validateForDelete(true, _passport);
	endforeach;
	
	if _passport.noErrors then
	//	app.raiseCMWarning2(CONF_DELETE, 'Voyage', self.code, null, null, self);	
		app.raiseCMWarning1(Sure_want_delete_voyage, self.code, null, null, self);	//cnwdb2 PAR 35364	

	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="4ac4f428-d5ba-4318-a37c-33b88590902a">
        <source>validateForUpdate(_passport : CM_Passport input; _voyagesToDelete : CM_VoyageSet);
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwgd1
/* Changes

Date		Name	TFS#		Description
============================================================================
06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
22 Jul 2019 jlgka1	TFS 45620 JMT - Refactor remove remaining  Voyage Commodity  Planning.
============================================================================*/
vars
	vesselObj	: CM_Vessel;
	voyageObj	: CM_VoyageGlobal;	
begin
	if self.code = null then
		app.raiseCMException(Input_required_field_code, ETRow_VoyageCode, null);	 // cnwdb2	PAR 35364
	endif;
	
	if self.numHatches = 0  then //06.10.2017	cnwma1  TFS #7257
		app.raiseCMException(Input_required_field_hatches, ETRow_NumHatches, null);	 // cnwdb2	PAR 35364
	endif;
	
	if self.numHatches &gt; 9 then
		app.raiseCMException1(HatchesExceedMax, 'nine', ETRow_NumHatches, null);
	endif;									

	if self.vesselName = null then
		app.raiseCMException(Input_required_field_vesName, ETRow_VesselName, null);	 // cnwdb2	PAR 35364
	endif;		

	if self.allVoyages.size &lt; 1 then
		app.raiseCMException(Input_required_field_termVoy, null, null); // cnwdb2	PAR 35364
	endif;
	
	//self.validateCargo(_passport); //jlgka1 TFS 45620
	self.validateVoyages(_passport, _voyagesToDelete);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_voyagesToDelete" type="CM_VoyageSet"/>
    </JadeMethod>
    <JadeMethod name="validateMovements" id="94d8ca9d-e8a2-4868-8ebb-ac0cca45d4b8">
        <source>validateMovements(_infoArray : HugeStringArray input);
// --------------------------------------------------------------------------------
// Created:		19 November 2007 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tmpMove,
	prevMove	: HMS_Movement;
	tmpVoyage	: CM_Voyage;
	firstTime	: Boolean;
	errStartPos		: Integer;		
begin

	errStartPos := _infoArray.size;
	firstTime := true;

	foreach tmpVoyage in self.allVoyages do
		if firstTime then
			firstTime := false;
			
			if tmpVoyage.arrivedDT &lt;&gt; self.arrivalDT then
				_infoArray.add('First voyage arrival DT (' &amp; tmpVoyage.arrivedDT.asStringJMT &amp; ')' &amp;
					' &lt;&gt; global voyage arrival DT (' &amp; self.arrivalDT.asStringJMT &amp; ')');
			endif;
		endif;
		
		tmpVoyage.validateMovements(_infoArray);
	endforeach;

	firstTime := true;

	foreach tmpMove in self.allHMSMovements do
		if firstTime then
			firstTime := false;
		else
			if tmpMove.myPreviousMovement = null then
				_infoArray.add('Movement ' &amp; tmpMove.getDescription &amp; ' - myPreviousMovement = null, should be ' &amp;
								prevMove.getDescription);
			elseif tmpMove.myPreviousMovement &lt;&gt; prevMove then
				_infoArray.add('Movement ' &amp; tmpMove.getDescription &amp; ' - myPreviousMovement (' &amp;
								tmpMove.myPreviousMovement.getDescription &amp; ' &lt;&gt; corrrect move, should be ' &amp;
								prevMove.getDescription);
			endif;
		endif;
		
		prevMove	:=	tmpMove;
	endforeach;
	
	if errStartPos &lt;&gt; _infoArray.size then
		// there have been some errors
		_infoArray.insert(errStartPos + 1, '*** Global Voyage ' &amp; self.code &amp; '  ' &amp; self.arrivalDT.asStringJMT);
	endif;

end;</source>
        <Parameter name="_infoArray" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateVoyages" id="124c1a05-7cb6-4690-947e-776bf5e839ba">
        <source>validateVoyages(_passport : CM_Passport input; _voyagesToDelete : CM_VoyageSet)protected;
//--------------------------------------------------------------
//Created: 13 May 2003 By: cnwgd1
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//--------------------------------------------------------------
vars
	realVoy,
	tmpVoy,
	voy 		 : CM_Voyage;
	realVoyGlobal : CM_VoyageGlobal;
	failedDAC  :CM_DataAccessController;

begin
	if _passport.hasErrors then
		return;
	endif;
	realVoyGlobal := app.myRoot.allVoyagesGlobal.getAtKey(self.code);
	if realVoyGlobal = null then
		realVoyGlobal := app.myRoot.allVoyagesGlobalArchived.getAtKey(self.code);		
	endif;
	if realVoyGlobal &lt;&gt; null then
		if self.isTransient and realVoyGlobal &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'Global Voyage', self.code, ETRow_Place, null); //14.06.2022 navds20 53760
			// Global Voyage already exists for %1 : Global_voyagealready_exists
			app.raiseCMException1(Global_voyagealready_exists, self.code, ETRow_Place, null); //14.06.2022 navds20 53760
			return;		
		endif;
	endif;
	
	// Check to see if any duplicate voyages with the same code exist
	// at the terminals where voyage(s) are being added into.
	
	foreach voy in self.allVoyages  do
	
		if _voyagesToDelete &lt;&gt; null and _voyagesToDelete.includes(voy) then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Attempting to validate for update voayge that is being deleted');
			return;
		endif;
		
		if voy.canUserAccessSelf(null, failedDAC, _passport) then 
			//Must validate archived as well
			voy.validateForUpdate(_passport,false);	
		endif;	

		if realVoyGlobal &lt;&gt; null then
			tmpVoy := realVoyGlobal.allVoyages.getAtKey(voy.arrivedDT, voy.myTerminal);
		endif;
		if tmpVoy = null then
			continue;
		endif;
		if tmpVoy = voy then
			continue;
		endif;
		if voy.isTransient then
			realVoy := voy.pxyGetRealObject();
		endif;
		if tmpVoy = realVoy then
			continue;
		endif;					
		if tmpVoy.archived then
			app.raiseCMException1(ERR_IS_ARCHIVED_VOY, tmpVoy.code, null, null);
		else
			//app.raiseCMException2(DuplicateItem, 'Voyage ', voy.getDisplayDetails(true), null, null); //14.06.2022 navds20 53760
			// Voyage already exists for %1 : Voyagealready_exists
			app.raiseCMException1(Voyage_already_exists, voy.getDisplayDetails(true), null, null); //14.06.2022 navds20 53760
		endif;

	endforeach;
	
	// Now validate user allowed to delete any voyages that are being deleted
	if _voyagesToDelete &lt;&gt; null then
		foreach voy in _voyagesToDelete do
			voy.validateDelete(_passport);
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_voyagesToDelete" type="CM_VoyageSet"/>
    </JadeMethod>
</Class>
