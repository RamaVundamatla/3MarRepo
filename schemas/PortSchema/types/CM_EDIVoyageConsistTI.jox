<Class name="CM_EDIVoyageConsistTI" id="6a2798d0-21e6-4bbd-9b99-b68483345cfe">
    <superclass name="CM_EDITrackedItem"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="edi"/>
    <PrimAttribute name="position" id="370cabaa-d740-4f14-989b-becc43e0b6a8">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="voyageCode" id="712cf097-d583-446a-8866-e62941b5cb2d">
        <length>21</length>
        <embedded/>
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="getVoyageCode" id="6c8fbd58-9ddb-4102-a583-27728124333c">
        <source>getVoyageCode() : String;

/*
Purpose:	Return the appropriate VoyageCode to be used in the EDIConfig allEDITrackedItemsByVoyageCode collection.

Date			Who		Reason
03 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
*/
	
vars
	
begin
	return self.voyageCode;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageObject" id="25710c76-059d-449f-b32e-490acffbfa21">
        <source>getVoyageObject() : CM_Voyage;
/*
Purpose:			
Date		Who		Reason
23 July 2012	cnwab1	Initial creation
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	voy : CM_Voyage;
	terminal : CM_Terminal;
begin
	terminal := self.getMyTerminal();

	voy := terminal.allVoyagesByCode.getAtKeyGeq(self.voyageCode,null);
	
	if voy &lt;&gt; null and voy.code = self.voyageCode then
		return voy;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="hasPropVoyageCode" id="cc4a4851-aa1d-424e-8d0e-a7f69990388c">
        <source>hasPropVoyageCode(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading

*/

vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="3f4f06d6-bf32-412d-8ba1-d5d830e93238">
        <updating/>
        <source>setVoyageCode(_value: String) updating;

vars

begin
	//self.voyageCode := _value;
	self.voyageCode := _value.toUpper;	//27 Feb 2018	NDL	TFS 36433
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
</Class>
