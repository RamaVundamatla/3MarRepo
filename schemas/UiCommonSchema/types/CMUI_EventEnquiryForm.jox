    <JadeMethod name="doPrintDetails" id="c46ed7b3-1fff-483a-8ccb-ab82162d785f">
        <source>doPrintDetails() protected;
/* ---------------------------------------------------------------------------
Created:	10 November 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	// checking for CMEVT_InvoiceGeneration event
	if self.myCurrentObject &lt;&gt; null then
		if self.myCurrentObject.isKindOf(CMEVT_InvoiceGeneration) then
			self.myCurrentObject.CMEVT_InvoiceGeneration.printInvoiceGeneration();	//ccms jmt 1772. Printing Invoice Generation details. Nov 2008
		else
			app.raiseUnexpectedProgramError( class.name, method.name, 'There is no print report for the object ' &amp; self.myCurrentObject.String );
		endif;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="68ffef2f-676e-4868-9091-b7be24deeb32">
        <updating/>
        <source>doResize() updating;
/*
----------   ----------  --------------------------------------------------
Created:	10 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
//18 Jan 2017	cnwrs1	TFS 3137 - resize the find/trplace form when show captions is on
*/
vars

begin
	//have to do the below because we aren't using the search filter table, and resize
	//code clobbers the frame otherwise
	self.isSearcherVisible := false;
	self.tblSearch.height := self.WIDTH_SEARCHER;
	inheritMethod();
	
	self.isSearcherVisible := self.frmSearch.visible;
	self.frmSearch.width := self.WIDTH_SEARCHER;
	self.frmSearch.height := self.WIDTH_SEARCHER;
	self.frmSearch.left := (self.width / 2) - (self.WIDTH_SEARCHER /2);
end;

</source>
    </JadeMethod>
    <JadeMethod name="doSelectAllClick" id="32a36d67-d205-4ad2-b75b-a19ee46ce8ed">
        <updating/>
        <source>doSelectAllClick() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	11 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
	sheet			: CMUI_Sheet;

begin

	sheet := self.fldSearch.topSheet.CMUI_Sheet;
	
	if sheet = self.shtEventTypes then
		if self.lstEventTypes.allSelectedObjects.size &gt;= app.myRoot.allEventTypesByType.size then
			self.lstEventTypes.clearSelected();
		else
			self.lstEventTypes.setSelected(app.myRoot.allEventTypesByType);
		endif;
		
	elseif sheet = self.shtEventGroups then
		if self.lstEventGroups.allSelectedObjects.size &gt;= app.myRoot.allEventTypeGroups.size then
			self.lstEventGroups.clearSelected();
		else
			self.lstEventGroups.setSelected(app.myRoot.allEventTypeGroups);
		endif;
		
	elseif sheet = self.shtUsers then
		if self.lstUsers.allSelectedObjects.size &gt;= app.myRoot.allUsers.size then
			self.lstUsers.clearSelected();
		else
			self.lstUsers.setSelected(app.myRoot.allUsers);
		endif;
		
	elseif sheet = self.shtTerminals then
		if self.lstTerminals.allSelectedObjects.size &gt;= self.lstTerminals.rows then
			self.lstTerminals.clearSelected();
		else
			self.lstTerminals.setSelected(app.myRoot.allTerminals);
		endif;
	endif;
	
	
	
end;

</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="d7cbaae5-9e8a-4a30-b8f3-de71aabb4a38">
