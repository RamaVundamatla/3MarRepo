<Class name="CM_EDIStowAdviceTI">
    <JadeMethod name="getColoursForEDITrackedItem" id="14af83b9-e8c4-4828-9c46-a0bd34832945">
        <source>getColoursForEDITrackedItem(_ediData :CM_EDIData; _localPort :String; _foreColor, _backColor :Integer output);
/*
Date		Who		Reason
05 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094
04 Sep 2013	cnwcs5	par 32389 - regression
*/
vars
	
begin
	if self.isForLocal (_localPort) then
		_foreColor	:= Black;
		_backColor	:= CM_BaseForm.ColorGreenLight;
	else
		_foreColor	:= CM_BaseForm.ColorGreyDark;
		_backColor	:= White;
	endif;
epilog

end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_localPort" type="String"/>
        <Parameter name="_foreColor" type="Integer" usage="output"/>
        <Parameter name="_backColor" type="Integer" usage="output"/>
    </JadeMethod>
</Class>
