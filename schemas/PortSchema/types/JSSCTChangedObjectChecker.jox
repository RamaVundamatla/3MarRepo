    <DbClassMap file="jss_interface"/>
    <JadeMethod name="checkObjectUpdated" id="9da7bb03-97c8-4826-8ff1-1a9d8bd738d5">
        <source>checkObjectUpdated(pObject : Object) : TimeStamp;
/*
			JSSChangeTrackingSchema Interface Method - DO NOT CHANGE
			
			This method should be re-implemented on a subclass to enable
			your application to provide more information on the date and
			time of any changes made to an existing object in a class.
			
			This method is only called for a class the first time it is
			initialized by the Change Tracking peer schema. On initialization,
			the Change Tracking peer schema reads through all instances of
			a class, checking if they were created within the time frame being
			tracked, but this process cannot tell when an instance was changed.

			So if there is something in your application that has kept this
			information, re-implement this method and return the timestamp of 
			the change, or null to let the Change Tracking peer schema use the
			creation date of the instance.
*/
begin
	return(null);
end;</source>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
</Class>
