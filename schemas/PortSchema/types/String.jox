    <JadeMethod name="asStringJSON" id="e18452de-972c-4d5b-93ae-54ef13f0134f">
        <source>asStringJSON() : String;
/*

Purpose:			Return the receiver formatted for JSON

Parameters:			None

Return Value:		JSON string representing the receiver

Date		Who		Reason
14 Feb 2017	cnwkpd1	TFS 3369 - Push Events application
11 Sep 2024	navnk30	Bug 63494: SNO - Event Stream JSON doesn't handle new lines in free text fields

*/

vars

begin
	if self = null then
		return "null";
	else
		//return '"' &amp; self.replace('\', '\\').replace('"', '\"') &amp; '"';						//11.09.2024 navnk30 #63494
		return '"' &amp; self.replace('\', '\\').replace('"', '\"').replace(CrLf, "\r\n") &amp; '"';	//11.09.2024 navnk30 #63494
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asStringRESTFUL" id="4f685bfd-53c8-48af-a4c5-ff8e4701e6ac">
        <source>asStringRESTFUL() : String;
/*

Purpose: Can't send \ or / in rest params so they have to encode as spaces aren't allowed in most of our ids 
			so  loooking for hex value between spaces i.e 
				"%2F"  = 	/ 
                "%5C" =  \                               

		   - this method will replace any % and hex value with the character
Parameters:			

Return Value:		

Date		Who		Reason
19 September 2019	jlger1	Initial creation 46632

*/

vars
	newValue : String;
	replacementChar	: Character;
	characterPos,startPos	: Integer;
	byteOne			: Character;			
	byteTwo			: Character;		
	replacementString : String;
begin
	startPos :=1;
	characterPos	:=	self.pos("%", startPos);
	newValue := self;
	while characterPos &gt; 0 do
		if characterPos + 2  &gt; self.length then	
			break;								
		endif;									
		byteOne			:=	newValue[characterPos+1];			
		byteTwo			:=	newValue[characterPos+2];			
		
		if byteOne.isHex and byteTwo.isHex then					
			replacementChar	:=	(byteOne.cnEcHexToInt * 16 + byteTwo.cnEcHexToInt).Character;	
			replacementString := newValue[1 : characterPos -1] &amp; replacementChar ;
			if newValue.length &lt; characterPos+3 then
				newValue:=replacementString;
				break;
			endif;
			newValue:= replacementString &amp;   newValue[characterPos+3 : end] ;
		else											

			startPos	:=	characterPos + 1;	
		endif;
		startPos := characterPos + 1;
		characterPos	:=	newValue.pos("%", startPos);
		if characterPos &lt; 0 then
			break;
		endif;
	endwhile;

	//+ is special because IIS will not accept in URL so have to do out own encoding
	newValue:=newValue.replaceString(" PLUS ","+");
	
	return newValue;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asTextFromXML" id="5576867b-ae96-4f4a-9703-ab0831b768c2">
        <source>asTextFromXML() : String;
// ---------------------------------------------------------------------------
// Created:     11 May 2004 by cnwrs2
//
// Purpose:     Removes the CDATA header around self if it exists
// ---------------------------------------------------------------------------
vars
	tmpStr	: String;
	
begin
	tmpStr := self;
	if tmpStr.length &lt; 9 then
		return tmpStr;
	endif;
	
	if tmpStr[1:9] = "&lt;![CDATA[" then 
		tmpStr := tmpStr[10:(tmpStr.length - 12)];
	endif;
	return tmpStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asTimeFromInaportnet" id="99bf3abb-04d3-4716-98f5-afee08c07679">
        <source>asTimeFromInaportnet() : Time;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2018	jlger1	Initial creation

*/

vars
	time : Time;
	hours : String;
	minutes : String;

begin
	time.setTime(99,99,99,999); 
	
	if self.length &gt;= 5 then	
		hours := self[1:2];
		minutes := self[4:2];
		if  hours.isInteger
		 and  minutes.isInteger then
			time.setTime(hours.Integer,minutes.Integer,00,000);
		endif;
	endif;
	
	return time;
epilog

end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="asTimeFromWebInterface" id="08a85c1b-647c-4ac2-928f-0241305361eb">
        <source>asTimeFromWebInterface():Time;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2012	cnwndl1	Initial creation	Par 30622

				The RIA may be running on a server that uses a different LOCALE than
				the client.  Convert to known format at both ends.
				
				See Time::asStringForWebInterface

*/

vars

	rawString : String;
	hh : String;
	mm : String;
	ss : String;
	ttt : String;
	time : Time;

begin
	
	rawString := self.trimBlanks;
	
	if rawString.length = 4 or rawString.length = 5 then
		//"hhmm" or "hh:mm"
		if rawString.length = 4 then
			hh := self[1:2];
			mm := self[3:2];
		else
			hh := self[1:2];
			mm := self[4:2];
		endif;
		if hh.isInteger and mm.isInteger then
			time.setTime( hh.Integer, mm.Integer, 0, 0 );
			if time.isValid then
				return time;
			endif;
		endif;
		
	elseif rawString.length = 6 or rawString.length = 8 then
		//"hhmmss" or "hh:mm:ss"
		if rawString.length = 6 then
			hh := self[1:2];
			mm := self[3:2];
			ss := self[5:2];
		elseif rawString.length = 8 then
			hh := self[1:2];
			mm := self[4:2];
			ss := self[7:2];
		endif;
		if hh.isInteger and mm.isInteger and ss.isInteger then
			time.setTime( hh.Integer, mm.Integer, ss.Integer, 0 );
			if time.isValid then
				return time;
			endif;
		endif;
	
	elseif rawString.length &gt;= 10  and rawString.length &lt;= 12 then
		//"hh:mm:ss:t" or "hh:mm:ss:tt" or "hh:mm:ss:ttt"
		hh := self[1:2];
		mm := self[4:2];
		ss := self[7:2];
		ttt := self[10:end].padZeros(3);
		if hh.isInteger and mm.isInteger and ss.isInteger and ttt.isInteger then
			time.setTime( hh.Integer, mm.Integer, ss.Integer, ttt.Integer );
			if time.isValid then
				return time;
			endif;
		endif;
	
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="asTimeFromXMLFormat" id="8801e75d-0ec7-4b8e-acc7-ec9db34808fc">
        <source>asTimeFromXMLFormat() : Time;
// ---------------------------------------------------------------------------
// Created:     06 April 2006	cnwrs2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	t	: Time;
begin

	if self.length &lt;&gt; 6 then
		return null;
	endif;

	t.setTime(self[1:2].Integer, self[3:2].Integer, self[5:2].Integer, 0);
	
	return t;

end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="asTimeJMT" id="2121499f-66d7-48d7-9050-259d6bc7c352">
        <source>asTimeJMT() : Time;
//--------------------------------------------------------------
//Created: 27 August 2002 By: cnwgd1
//--------------------------------------------------------------
//Takes hhmmss or hh:mm and converts to hh:mm:ss
// 
vars
	timeResult	: Time;
begin

	if self.length = 5 then
		timeResult.setTime(self[1:2].Integer, self[4:2].Integer, 0, 0);
		return timeResult;
	elseif self.length = 6 then
		timeResult.setTime(self[1:2].Integer, self[3:2].Integer, self[5:2].Integer, 0);
		return timeResult;
// cnwdad1 18/08/2009 - Added handing of 8-character time.
		elseif self.length = 8 then
		timeResult.setTime(self[1:2].Integer, self[4:2].Integer, self[7:2].Integer, 0);
		return timeResult;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="asTimeStampFromInaportnet" id="67b2da25-e76a-414f-8ebf-a537c0fd413e">
        <source>asTimeStampFromInaportnet():TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlger1	Initial creation 38135

*/

vars

rawString : String;
	date : Date;
	time : Time;
	ts : TimeStamp;

begin
	ts.setDate(null);
	ts.setTime(null);
	rawString := self.trimBlanks;
	
	if rawString.length = 10 then
		date := rawString.asDateFromInaportnet();
		if date.isValid then
			time.setTime(0,0,0,0);
			ts.setDate(date);
			ts.setTime(time);
			return ts;
		endif;
		
	elseif  rawString.length &gt; 10 then
		date := rawString[1:10].asDateFromInaportnet();
		time := rawString[11:end].trimBlanks.asTimeFromInaportnet();
		if date.isValid then
			ts.setDate(date);
			if not time.isValid then
				time.setTime(0,0,0,0);
			endif;
			ts.setTime(time);
			return ts;
		endif;
		
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="asTimeStampFromJSON" id="6432e2af-9629-4cf1-a5cf-135a37a8122d">
        <source>asTimeStampFromJSON():TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023	navpw1	Initial creation TFS: 56850 (56871)

*/

vars
	rawString,
	yearStr,
	monthStr,
	dayStr,
	hourStr,
	minuteStr,
	secondStr	: String;
	ts			: TimeStamp;
	date		: Date;
	time		: Time;
	
begin
	rawString := self.trimBlanks;
	
	if rawString = null then
		return null;
	endif;
	
	if rawString.pos("T", 1) &gt; 1 and rawString.pos("Z", 1) &gt; 1 then
		yearStr := rawString[1:4];
		monthStr := rawString[6:2];
		dayStr := rawString[9:2];
		hourStr := rawString[12:2];
		minuteStr := rawString[15:2];
		secondStr := rawString[18:2];
		
		date.setDate(dayStr.Integer, monthStr.Integer, yearStr.Integer);
		time.setTime(hourStr.Integer, minuteStr.Integer, secondStr.Integer, 0);
		
		ts.setDate(date);
		ts.setTime(time);
		
		return ts;
	else
		return null;
	endif;
	
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="asTimeStampFromWebInterface" id="ef127f52-1a47-4395-b04b-aa3cc7663f15">
        <source>asTimeStampFromWebInterface():TimeStamp;
/*

Purpose:			dd/MM/yyyy hh:mm

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2012	cnwndl1	Initial creation	Par 30622

				The RIA may be running on a server that uses a different LOCALE than
				the client.  Convert to known format at both ends.
				
				See TimeStamp::asStringForWebInterface

*/

vars

	rawString : String;
	date : Date;
	time : Time;
	ts : TimeStamp;

begin

	rawString := self.trimBlanks;
	
	if rawString.length = 10 then
		date := rawString.asDateFromWebInterface();
		if date.isValid then
			time.setTime(0,0,0,0);
			ts.setDate(date);
			ts.setTime(time);
			return ts;
		endif;
		
	elseif  rawString.length &gt; 10 then
		date := rawString[1:10].asDateFromWebInterface();
		time := rawString[11:end].trimBlanks.asTimeFromWebInterface();
		if date.isValid then
			ts.setDate(date);
			if not time.isValid then
				time.setTime(0,0,0,0);
			endif;
			ts.setTime(time);
			return ts;
		endif;
		
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="asTimeStampFromXMLFormat" id="d1af86a2-1d9b-4937-ae6e-129ebc9eccbd">
        <source>asTimeStampFromXMLFormat() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     04 April 2006 by cnwrs2
//
// Purpose:     Any changes may need to be refelected in
//					TimeStamp::asXMLFormat()
//				format is yyyymmddhhmmss
// ---------------------------------------------------------------------------
vars
	ts	: TimeStamp;
	d	: Date;
	t	: Time;
begin
	if self.length &lt;&gt; 14 then
		return null;
	endif;
	
	d := self[1:8].asDateFromXMLFormat();
	t := self[9:end].asTimeFromXMLFormat();
	
	ts.setDate(d);
	ts.setTime(t);
	
	return ts;

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="asTimeStampJMT" id="4cb32ceb-6c5c-4609-ad5d-e96fbd9016e3">
        <source>asTimeStampJMT() : TimeStamp;
//--------------------------------------------------
// Created:	16 September 2005 By: cnwgd1
//--------------------------------------------------
// Converts timeStamp formated by TimeStamp.shortCurrentLocaleFormat();
// PAR 18780 Unit Tests at PortSchema::UT_JMT::tStringasTimeStampJMT()
vars
 	pos 	: Integer;
 	date	: Date;
 	time	: Time;
 	str		: String;
	dateTime : TimeStamp;
begin
	date := null;			//PAR 18780 cnwgb1 22.01.2009
	time := null;			//PAR 18780 cnwgb1 22.01.2009
	if self &lt;&gt; null then 	//PAR 18780 cnwgb1 22.01.2009
		pos := 1;
		str := self.cnGetToken(pos, " ");
		if str &lt;&gt; null then
			date := str.asDateJMT();
		endif;

		if pos &gt; 0 then		//PAR 18780 cnwgb1 22.01.2009
			str := null;
			str := self.cnGetToken(pos, " ");
			if str &lt;&gt; null then
				time := str.asTimeJMT();
			endif;
		endif;
		dateTime.setDate(date);
		dateTime.setTime(time);
		
		if dateTime.isValid then
			return dateTime;
		endif;
	endif;
	return null;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="asWeightFromWebInterface" id="1fb29643-db0c-49c4-9bcd-41be26256e6b">
        <source>asWeightFromWebInterface():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2012	cnwndl1	Initial creation	Par 30622

				The RIA may be running on a server that uses a different LOCALE than
				the client.  Convert to known format at both ends.
				
				See Decimal::asStringWeightForWebInterface

*/

vars

begin

	return self.asDecimalJMT();	 // until we decide what the standard for the interface will be....

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="asXML" id="da83e475-6a06-46a1-8796-caf11f13f35d">
        <source>asXML() : String;
// ---------------------------------------------------------------------------
// Created:     11 May 2004 by cnwrs2
//
// Purpose:     As some characters are invalid in XML text we change to
//				use the CDATA construct if these are present
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
20 May 2009	cnwkpd1	CCMS SFW 1073 - PAR #19729 - rewrite to improve performance

*/

constants
	CDATA_Characters	= "&lt;&gt;'&amp;" &amp; '"';
		
vars
	pos			: Integer;
	
begin
	if self = null then
		return self;
	endif;
	
	pos := 1;
	self.scanUntil(CDATA_Characters, pos);
	
	if pos = 0 then
		return self;
	else
		return self.makeXMLCData();
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asXMLTagName" id="dc559ded-590a-48cc-87f5-f5ca352accd4">
        <source>asXMLTagName() : String;
/*

Purpose:			Remove any characters from the receiver which are invalid for an XML tag name

Parameters:			None

Return Value:		Receiver with invalid characters removed

Date		Who		Reason
11 Nov 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

vars

begin
	return self.cnEcRemoveSubstring(" ").cnEcRemoveSubstring("/").cnEcRemoveSubstring(".");
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
