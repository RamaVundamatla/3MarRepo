    <JadeMethod name="setControlsForAddEdit" id="003eec79-4ea2-4cbc-ad1f-d5685afd8deb">
        <updating/>
        <source>setControlsForAddEdit() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 January 2010	cnwas3	Initial creation

*/

vars
	theForm : SOP_TableMaintForm;
	tmpTblInput	: CM_EntryTable;

begin
	theForm := self.myForm;
	tmpTblInput := theForm.tblInput1;
	tmpTblInput.userInputEnabled := true;
	
			
	if theForm.mode = theForm.Mode_Add then
		tmpTblInput.clearValues;
		tmpTblInput.enableRowByName(ETRow_Code);
		tmpTblInput.enableRowByName(ETRow_Description);	
		tmpTblInput.moveFirst();	
		tmpTblInput.gotFocus(tmpTblInput);
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_DocketErrorType);
		// cannot update code
		tmpTblInput.disableRowByName(ETRow_Code);
		tmpTblInput.enableRowByName(ETRow_Description);

	endif;
	tmpTblInput.cnEcResizeContents();

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="0f49817c-2c9c-45fd-a18d-20b54d20c993">
