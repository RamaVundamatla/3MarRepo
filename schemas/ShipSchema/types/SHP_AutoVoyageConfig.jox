    <JadeMethod name="setupCompFieldsDB" id="97dbc9a0-2e85-4aa6-8939-3fce8ca02394">
        <source>setupCompFieldsDB(_autoComp : CM_EDIComparisonConfig);
/*
Purpose - 	
Who - NAVAB1
Date - 16JUL2024
ADO - CR 64614 TASK 64642
*/

vars
	str, description	: String;	
	compItem : CM_StateString;
	int : Integer;
	selectedfields : ObjectSet;
	field : Object;

begin
	create selectedfields transient;

	//foreach str in _autoComp.comparisonFields do					//navra1 - MTN-33038 - 14th Oct 2024
	foreach str in _autoComp.ignoreFields do						//navra1 - MTN-33038 - 14th Oct 2024
		compItem := self.getCompDescForKey(str);
		if compItem &lt;&gt; null then									//navra1 - MTN-33038 - 14th Oct 2024
			selectedfields.add(compItem);
		endif;														//navra1 - MTN-33038 - 14th Oct 2024
	endforeach;

	self.msgCompFields.setSelected(selectedfields);

epilog

end;</source>
