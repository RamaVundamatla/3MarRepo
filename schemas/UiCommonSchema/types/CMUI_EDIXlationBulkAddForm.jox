    <JadeMethod name="buildComboVoyage" id="b5c3c48a-50b3-4991-a3dc-8011315b1268">
        <updating/>
        <source>buildComboVoyage() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 01 April 2022
TFS#		: 53181
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	voyage 			: CM_Voyage;
	terminal 		: CM_Terminal;	
	passport		: CM_Passport;	
	rowStr			: String;
	vessel			: CM_Vessel;
	terminalColl 	: CM_TerminalByCodeDict;
	cmifMonitor		: CMIF_Monitor;
	count			: Integer;
	reachedMaxRows	: Boolean;	
begin
	app.mousePointer := MousePointer_HourGlass;
	self.cmbVoyage.clear();	
	self.cmbVoyage.sorted := false;
	passport := app.myPassport;	
	
	create terminalColl transient;
	app.getMyUser.getTerminals(terminalColl);
	
	// Set up the monitor
	create cmifMonitor transient;
	app.myPassport.setMyCMIFMonitor(cmifMonitor);
	cmifMonitor.myParent := self;
	cmifMonitor.message := "Searching...";
	cmifMonitor.partsInJob := 0; 
	cmifMonitor.partsDone := 0;
	
	
	self.modalDialogShow(null, 'Cancel', null, null, 'Searching for Voyages', cmifMonitor.message);
	self.updateProgress(cmifMonitor);
	self.modalDialogReturnValue := 0;
	
	// 32,000 row limit
	on Exception do app.handleUE14025(exception, reachedMaxRows);
	
	foreach terminal in terminalColl do	

		foreach voyage in terminal.allVoyagesByCode discreteLock do
			// Too many results
			if reachedMaxRows then
				break;
			endif;
									
			if not self.isVoyageIncluded(voyage) then
				continue;
			endif;
			
			rowStr := voyage.code;
			
			vessel := voyage.getMyVessel();
			if vessel &lt;&gt; null then
				rowStr := rowStr &amp; " (" &amp; vessel .name &amp; ") ";
			endif;
			
			if voyage.arrivedDT.isValid() then
				rowStr := rowStr &amp; self.systemToLocalTime(voyage.arrivedDT).asStringJMT; 
			endif;
			rowStr := rowStr &amp; " [" &amp; voyage.getMyTerminal().code &amp; "] ";

			self.cmbVoyage.addItemObject(rowStr, voyage);
			
			cmifMonitor.partsDone := count;
			updateProgress(cmifMonitor);
		endforeach;
	endforeach;
	
	self.cmbVoyage.sorted := false;
	self.cmbVoyage.addItemAt("",1);	
	
epilog
	delete terminalColl;
	delete cmifMonitor;
	
	self.frmModalDialog.visible := false;	
	app.myPassport.setMyCMIFMonitor(null);	
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
