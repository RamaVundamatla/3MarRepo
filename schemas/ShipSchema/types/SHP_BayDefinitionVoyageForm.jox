    <JadeMethod name="bridgeAfterBayChange" id="b3c615e8-4786-488c-97a2-b026d8ee532a">
        <updating/>
        <source>bridgeAfterBayChange() updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theBayOrder : String;
begin
		
	if self.mode = self.Mode_View then
		return;
	endif;
	
	theBayOrder := self.lblBayOrderTxt.caption;
		
	if self.validateTierCellLabels('Physical Bay Order', theBayOrder) then
	
		self.doBuildComboBayString(self.cmbBridgeAftBay, theBayOrder);
		self.doBuildProxyBayList(theBayOrder);
	endif;

end;</source>
    </JadeMethod>
