    </JadeMethod>
    <JadeMethod name="loadTblCargo" id="9fa18574-5f58-43ee-86e8-d5bdcd7b3c58">
        <source>loadTblCargo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	rowIndex : Integer;
	dataValue : String;
	errMsg : String;
	aStupidHack : Object;
	entTableRowTran : EntTableRowTransient;
	excludeAttrArray : StringArray;
	measureTbl : CMUI_MeasurementTable;
	measurementType : CM_MeasurementType;
	cargoType : CM_CargoType;
	prod : CM_Product;

begin

	//epr tfs 1939 5/5/16 now done on setup form
	//self.populateCombos();
	
	//02 Sep 2013	NDL	Par 32368
	if self.lockedDown then
		create excludeAttrArray transient;
		self.getLockDownExclusions( excludeAttrArray );
	endif;
	
	//cnwrd1 ccms 1321
	foreach aStupidHack in self.tblCargo.allEntRowTransients do	
		entTableRowTran := aStupidHack.EntTableRowTransient;	
		
		dataValue := self.getDataFromObject( entTableRowTran, errMsg );

		//02 Sep 2013	NDL	Par 32368
		measureTbl := self.allMeasurementControls[entTableRowTran.controlName].CMUI_MeasurementTable;
		if measureTbl = null or ( self.myTrackedItem &lt;&gt; null and dataValue = null ) then
			self.tblCargo.setValueByName(entTableRowTran.name, dataValue );
		elseif self.myTrackedItem &lt;&gt; null and dataValue.Decimal &lt;&gt; 0 then
			measurementType := self.myTrackedItem.myCargoType.getMeasurementTypeFor(measureTbl.measurementType,true);
			measureTbl.setValues(app.convertMeasurementForDisplay(measurementType.shortName, dataValue.Decimal) &amp; Space &amp; measurementType.shortName);
			measureTbl.lostFocus( measureTbl );
		else
			cargoType := self.getCargoTypeForMeasurementType();
			if cargoType &lt;&gt; null then
				measurementType := cargoType.getMeasurementTypeFor(measureTbl.measurementType,true);
			else
				prod := self.getProductForMeasurementType();
				measurementType := self.getDefaultMeasurementForType( prod, measureTbl.measurementType );
			endif;
			measureTbl.setValues(app.convertMeasurementForDisplay(measurementType.shortName, 0.0) &amp; Space &amp; measurementType.shortName);
			measureTbl.lostFocus( measureTbl );
		endif;
		
		//02 Sep 2013	NDL	Par 32368
		if excludeAttrArray &lt;&gt; null then
			if not excludeAttrArray.includes( entTableRowTran.name ) then
				rowIndex := self.tblCargo.getRow( entTableRowTran.name );
				if rowIndex &gt; 0 and rowIndex &lt;= self.tblCargo.rows then	
					self.tblCargo.accessCell( rowIndex, 2 ).enabled := false;
				endif;
			endif;
		endif;
		
	endforeach;
	
	//30 Aug 2013	NDL	Par 32368
	if self.lockedDown then
		self.lockDownConvertedAttribs( excludeAttrArray );
	endif;
	self.changeQuantity();

	//epr tfs 1939 5/5/16 not needed
	//self.populateSubCargo( cmbType.listObject.CM_CargoType );
	//self.populateCmbDimType( cmbType.listObject.CM_CargoType );	//06 Sep 2013	NDL	Par 32413
	
	
epilog

	delete excludeAttrArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="lockDownConvertedAttribs" id="cd1e8732-8292-49ac-8110-3827e4fef9b4">
        <source>lockDownConvertedAttribs( _attrArray : StringArray io ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2013	cnwndl1	Initial creation	Par 32368

*/

vars

	rowString : String;
	rowIndex : Integer;
	
	product : CM_Product;

begin

	product := self.getProductForMeasurementType();

	rowString := Prefix_Weight &amp; ETRow_TotalWeight &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Weight).shortName;
	if _attrArray = null or not _attrArray.includes( rowString ) then
		rowIndex := self.tblCargo.getRow( rowString );
		if rowIndex &gt; 0 and rowIndex &lt;= self.tblCargo.rows then
			self.tblCargo.accessCell( rowIndex, 2 ).enabled := false;
		endif;
	endif;
	
	rowString := Prefix_Volume &amp; ETRow_TotalVolume &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Volume).shortName;
	if _attrArray = null or not _attrArray.includes( rowString ) then
		rowIndex := self.tblCargo.getRow( rowString );
		if rowIndex &gt; 0 and rowIndex &lt;= self.tblCargo.rows then
			self.tblCargo.accessCell( rowIndex, 2 ).enabled := false;
		endif;
	endif;
	
	rowString := Prefix_Linear &amp; ETRow_Length &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Length).shortName;
	if _attrArray = null or not _attrArray.includes( rowString ) then
		rowIndex := self.tblCargo.getRow( rowString );
		if rowIndex &gt; 0 and rowIndex &lt;= self.tblCargo.rows then
			self.tblCargo.accessCell( rowIndex, 2 ).enabled := false;
		endif;
	endif;
	
	rowString := Prefix_Linear &amp; ETRow_Width &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Width).shortName;
	if _attrArray = null or not _attrArray.includes( rowString ) then
		rowIndex := self.tblCargo.getRow( rowString );
		if rowIndex &gt; 0 and rowIndex &lt;= self.tblCargo.rows then
			self.tblCargo.accessCell( rowIndex, 2 ).enabled := false;
		endif;
	endif;
	
	rowString := Prefix_Linear &amp; ETRow_Height &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Height).shortName;
	if _attrArray = null or not _attrArray.includes( rowString ) then
		rowIndex := self.tblCargo.getRow( rowString );
		if rowIndex &gt; 0 and rowIndex &lt;= self.tblCargo.rows then
			self.tblCargo.accessCell( rowIndex, 2 ).enabled := false;
		endif;
	endif;
	
	rowString := Prefix_Density &amp; ETRow_Density &amp; '_' &amp; self.getDefaultMeasurementForType(product, Type_Density).shortName;
	if _attrArray = null or not _attrArray.includes( rowString ) then
		rowIndex := self.tblCargo.getRow( rowString );
		if rowIndex &gt; 0 and rowIndex &lt;= self.tblCargo.rows then
			self.tblCargo.accessCell( rowIndex, 2 ).enabled := false;
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_attrArray" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="lockDownTheAttributes" id="053077e7-4131-441b-ad05-ffa7c541657f">
        <updating/>
        <source>lockDownTheAttributes( ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	self.cmbBRItem.enabled := false;	//27 Sep 2010	NDL	Par 25744
	self.cmbCommodity.enabled := false;
	self.cmbDestination.enabled := false;
	self.cmbDischarge.enabled := false;
	self.cmbISOType.enabled := false;
	self.cmbOperator.enabled := false;
	self.cmbSubCargo.enabled := false;
	self.cmbType.enabled := false;
	self.cmbType.visible:=false;
	self.cmbVoyage.enabled := false;
	self.cmbDimType.enabled := false;
	self.cmbTrailerType.enabled := false;	//24 Sep 2013	NDL	Par 32556
	self.cmbTrailerType.visible:=false;
	self.cmbVehicleMake.enabled := false;
	self.cmbVehicleMake.visible:=false;
	self.cmbVehicleModel.enabled := false;
	self.cmbVehicleModel.visible:=false;
	self.cmbVehicleType.enabled := false;
	self.cmbVehicleType.visible:=false;
	self.lockedDown := true;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateCmbBRItem" id="ed07c8dc-acf5-460a-afd1-9af62dda6f7d">
        <source>populateCmbBRItem();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 September 2010	cnwndl1	Initial creation	Par 25744

*/

vars

	brefString : String;
	bookingRef : CM_BookingRef;
	term : CM_Terminal;
	brefItemString : String;
	existingBrItem : CM_BookingRefItem;
	brItem : CM_BookingRefItem;
	operatorCode : String;	//05 Oct 2010	NDL	Par 25744

begin

	if self.myBookingRef &lt;&gt; null then
		brefString := self.myBookingRef.bookingReference;
		bookingRef := self.myBookingRef;
		
	else
		brefString := getStringValueFromTable( ETRow_BookingReference );
		if myTrackedItem &lt;&gt; null and myTrackedItem.myBookingRef &lt;&gt; null and brefString = myTrackedItem.bookingReference then
			bookingRef := myTrackedItem.myBookingRef;
		elseif myTrackedItem &lt;&gt; null and myTrackedItem.myBookingRefItem &lt;&gt; null and myTrackedItem.myBookingRefItem.myBookingReference &lt;&gt; null and brefString = myTrackedItem.myBookingRefItem.myBookingReference.bookingReference then
			bookingRef := myTrackedItem.myBookingRefItem.myBookingReference;
		else
			term := self.myMobileDataAgent.myTerminal;
			if term &lt;&gt; null then
				
				if cmbOperator.listObject &lt;&gt; null then//05 Oct 2010	NDL	Par 25744
					operatorCode := cmbOperator.listObject.CM_Operator.code;
				endif;
				bookingRef := term.getBookingReference( operatorCode, brefString, cmbVoyage.listObject.CM_Voyage);
			endif;
		endif;
		
	endif;
	
	if tblCargo.getRow(ETRow_BookingReferenceItem) &gt; 0 then
		brefItemString := getStringValueFromTable( ETRow_BookingReferenceItem );
		existingBrItem := self.cmbBRItem.listObject.CM_BookingRefItem;
		if brefItemString &lt;&gt; null and existingBrItem = null then
			if myTrackedItem &lt;&gt; null then
				existingBrItem := myTrackedItem.myBookingRefItem;
			endif;
		endif;
		
	endif;

	if tblCargo.getRow(ETRow_BookingReferenceItem) &gt; 0 and bookingRef &lt;&gt; null then
		self.cmbBRItem.clear();
		if bookingRef &lt;&gt; null and not bookingRef.allBookingRefItems.isEmpty then
			foreach brItem in bookingRef.allBookingRefItems do
				self.cmbBRItem.itemObject[self.cmbBRItem.addItem(brItem.getDisplayString)] := brItem;
			endforeach;
			if existingBrItem &lt;&gt; null then
				self.cmbBRItem.listIndex := self.cmbBRItem.findObject(existingBrItem);
			elseif brefItemString &lt;&gt; null then	//05 Oct 2010	NDL	Par 25744
				self.cmbBRItem.listIndex := self.cmbBRItem.findStringExact(1,brefItemString);
			endif;
		endif;
		self.tblCargo.setValueByControlName(self.cmbBRItem.name, self.cmbBRItem.text);
		
	endif; 
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbDimType" id="a8700962-6a72-4c44-8d15-394614b0ddc1">
        <source>populateCmbDimType( _cargoType : CM_CargoType ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2013	cnwndl1	Initial creation	Par 32413

*/

vars

	beforeCode : CM_ProductAttributeCode;
	iter : Iterator;
	prod : CM_Product;
	prodAttr : CM_ProductAttr;
	code : CM_ProductAttributeCode;
	
	row : Integer;
	
begin

	beforeCode := cmbDimType.listObject.CM_ProductAttributeCode;
	self.cmbDimType.clear();
	
	if _cargoType &lt;&gt; null then
		prod := _cargoType.mySystemProductType;
	endif;
	if prod &lt;&gt; null then
		prodAttr := prod.myType;
	endif;
		
	if prodAttr &lt;&gt; null then
		foreach code in prodAttr.allCodes do
			if code.notAvailableForEntry  then
				continue;
			endif;
			self.cmbDimType.itemObject[self.cmbDimType.addItem(code.code )] := code;
		endforeach; 
	endif;
	
	if beforeCode &lt;&gt; null then
		self.cmbDimType.listIndex := self.cmbDimType.findObject(beforeCode);
		self.tblCargo.setValueByControlName(self.cmbDimType.name, self.cmbDimType.text);
	endif;
	
	row := self.tblCargo.getRow( ETRow_DimType );
	if row &gt; 0 then
		if self.cmbDimType.listCount = 0 then
			if self.tblCargo.isRowVisible(ETRow_DimType) then
				self.tblCargo.hideRowByName(ETRow_DimType, false);
			endif;
		else
			if not self.tblCargo.isRowVisible(ETRow_DimType) then
				self.tblCargo.showRowByName(ETRow_DimType, false);
			endif;
		endif;
	endif; 
	
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="populateCombos" id="f793bac9-8add-434b-83b8-5f49bda32cc2">
        <source>populateCombos() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	isoType : CM_ISOType;
	cargoType : CM_CargoBOLType;
	voyage : CM_Voyage;
	port : CM_Port;
	consign		: CM_ConsigneeConsignor;//cnwas3 par 23700	
	imex		: CM_IMEXStatus;
	nullVoyage : CM_Voyage;
	term : CM_Terminal;
	
	make : CM_VehicleMake;
	model : CM_VehicleModel;
	vehType : CM_VehicleType;
begin
	//epr tfs 1939 4/5/16
	if self.lockedDown then
		return;
	endif;
	
	self.cmbISOType.clear();
	foreach isoType in app.myRoot.allISOTypes do
		if isoType.isNotAvailableForEntry then
			continue;
		endif;
		self.cmbISOType.itemObject[self.cmbISOType.addItem(isoType.getTableDisplay)] := isoType;
	endforeach;
	
	self.cmbType.clear();
	//foreach cargoType in app.myRoot.allCargoTypesById do
	foreach cargoType in self.myMobileGenericAgent.myTerminal.allCargoBOLTypes do
		if not cargoType.isCargoType then
			continue;
		endif;
		if cargoType.CM_CargoType.isNotAvailableForEntry then
			continue;
		endif;
		self.cmbType.itemObject[self.cmbType.addItem(cargoType.description)] := cargoType;	//getDisplayDetails(false)
	endforeach;
	
	self.cmbVoyage.clear();
	self.myMobileGenericAgent.setCurrentVoyages();
	
	//11 Oct 2011	NDL	Par 28396
	if self.isMOB_HHCargoDisplay then
		term := self.myMobileGenericAgent.getTerminal();
		if term &lt;&gt; null then
			nullVoyage := term.getNullVoyage;
			if nullVoyage &lt;&gt; null then
				self.cmbVoyage.itemObject[self.cmbVoyage.addItem(nullVoyage.code)] := nullVoyage;
			endif;
		endif;
	endif;
	
	foreach voyage in self.myMobileGenericAgent.allCurrentVoyages do
		//cnwmc5 - PAR 32558 - moved this block to here from above..
		if self.myMobileGenericAgent.myTerminal.getConfig(VesselNameOnVoyageCombo).Boolean then //cnwrd1 nfs 31095
			self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code &amp; Tab &amp; voyage.vesselName )] := voyage;
		else
			self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code)] := voyage;
		endif;
	endforeach;
	
	self.cmbDestination.clear();
	foreach port in app.myRoot.allActiveDestinations do
		if port.isNotAvailableForEntry then
			continue;
		endif;
		self.cmbDestination.itemObject[self.cmbDestination.addItem(port.getDisplayFormatted(false) )] := port;
	endforeach; 
	
	self.cmbFreightFwdr.clear();//cnwas3 par 23700 begin
	foreach consign in app.myRoot.allConsigneeConsignors do		
		if consign.isFreightFwdr and not consign.isNotAvailableForEntry then
			self.cmbFreightFwdr.itemObject[self.cmbFreightFwdr.addItem(consign.getYADisplay)] := consign;
		endif;
	endforeach;//cnwas3 par 23700 end
	
	self.cmbConsignee.clear();//36376
	foreach consign in app.myRoot.allConsigneeConsignors do		
		if consign.isConsignee and not consign.isNotAvailableForEntry then
			self.cmbConsignee.itemObject[self.cmbConsignee.addItem(consign.getYADisplay)] := consign;
		endif;
	endforeach;

	//+cnwml2 PAR25745
	self.cmbImexStatus.clear();
	foreach imex in app.myRoot.allImexStatuses do
		self.cmbImexStatus.itemObject[self.cmbImexStatus.addItem(imex.description)] := imex;
	endforeach;
	
	//	23 Sep 2013	NDL	Par 32215
	if app.myDutyDocRoot &lt;&gt; null then
		self.cmbVehicleMake.clear();
		foreach make in app.myDutyDocRoot.allVehicleMakes do
			self.cmbVehicleMake.itemObject[self.cmbVehicleMake.addItem(make.make)] := make;
		endforeach;
		
		self.cmbVehicleModel.clear();
		foreach model in app.myDutyDocRoot.allVehicleModels do
			self.cmbVehicleModel.itemObject[self.cmbVehicleModel.addItem(model.model)] := model;
		endforeach;
		
		self.cmbVehicleType.clear();
		foreach vehType in app.myDutyDocRoot.allVehicleTypes do
			self.cmbVehicleType.itemObject[self.cmbVehicleType.addItem(vehType.type)] := vehType;
		endforeach;
	endif;
	
	self.populateVoyageDependantCombos(); 
	
	self.populateSubCargo( cmbType.listObject.CM_CargoType );
	self.populateCmbDimType( cmbType.listObject.CM_CargoType );	//06 Sep 2013	NDL	Par 32413


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateFromPrenote" id="3c2ea513-7e51-4504-9382-66150a086240">
        <updating/>
        <source>populateFromPrenote(_id: String; _cargoType: Integer) updating;
