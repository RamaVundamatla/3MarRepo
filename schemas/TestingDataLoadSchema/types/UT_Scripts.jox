//18 September 2008	cnwdw1	
//
vars
	terminalAreaName: String;
	ta: CM_TerminalArea;
	prefix: String;
begin
	terminalAreaName := "Enter Terminal Area Name";
	read terminalAreaName;
	if terminalAreaName[terminalAreaName.length] = "*" then
		prefix := terminalAreaName[1:terminalAreaName.length-1];
		foreach ta in self.getTerminal.allTerminalAreas do
			if ta.id.startsWith(prefix) then
				self.logMessage("Delete Terminal: " &amp; ta.id);
				self.deleteTerminalArea(ta.id);
			endif;
		endforeach;
	else		
		self.deleteTerminalArea(terminalAreaName);
	endif;
end;</source>
