    <JadeMethod name="addAttribute" id="600571af-4285-461d-8b1a-02f84e5dafad">
        <updating/>
        <source>addAttribute(pName: String; pValue: String): JSSXmlAttribute updating;
/*
*/
vars
	attribute: JSSXmlAttribute;
begin
	if self.isTransient then
		create attribute transient;
	else
		create attribute persistent;
	endif;
	attribute.createAttribute(pName, pValue, self);

	//	check if this is an "id" attribute, then add to manual collection
	if pName = "id" then
		self.myDocumentForId := self.myDocument;
	endif;
	//	return the newly created attribute for the caller to reference
	return(attribute);
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="JSSXmlAttribute"/>
    </JadeMethod>
    <JadeMethod name="addElement" id="274a7ffa-9410-424c-986b-4f9088d2ade0">
        <updating/>
        <source>addElement(pTagName: String; pTagValue: String): JSSXmlElement updating;
/*
*/
vars
	element: JSSXmlElement;
begin
	if pTagName = "!--" then
		if self.isTransient then
			create element as JSSXmlComment transient;
		else
			create element as JSSXmlComment persistent;
		endif;
		element.createElement("Comment", pTagValue, self.level + 1, self.myDocument, self);
	elseif pTagName = "![CDATA[" then
		if self.isTransient then
			create element as JSSXmlCData transient;
		else
			create element as JSSXmlCData persistent;
		endif;
		element.createElement("CDATA", pTagValue, self.level + 1, self.myDocument, self);
	else
		if self.isTransient then
			create element transient;
		else
			create element persistent;
		endif;
		element.createElement(pTagName, pTagValue, self.level + 1, self.myDocument, self);
	endif;
	//	return the newly created element for the caller to reference
	return(element);
end;</source>
        <Parameter name="pTagName" type="String"/>
        <Parameter name="pTagValue" type="String"/>
        <ReturnType type="JSSXmlElement"/>
    </JadeMethod>
    <JadeMethod name="addElementCData" id="ce34872b-28f7-4d22-be09-40e96e0fb706">
        <updating/>
        <source>addElementCData(pTagValue: String): JSSXmlCData updating;
/*
*/
begin
	//	return the newly created element for the caller to reference
	return (self.addElement("![CDATA[", pTagValue).JSSXmlCData);
end;</source>
        <Parameter name="pTagValue" type="String"/>
        <ReturnType type="JSSXmlCData"/>
    </JadeMethod>
    <JadeMethod name="addElementComment" id="37e3d944-fa92-4863-ae73-23a90d98c5da">
        <updating/>
        <source>addElementComment(pTagValue: String): JSSXmlComment updating;
/*
*/
begin
	//	return the newly created element for the caller to reference
	return (self.addElement("!--", pTagValue).JSSXmlComment);
end;</source>
        <Parameter name="pTagValue" type="String"/>
        <ReturnType type="JSSXmlComment"/>
    </JadeMethod>
    <JadeMethod name="addElementFirst" id="b6af7d5c-da01-40d5-83ed-95069cb17b78">
        <updating/>
        <source>addElementFirst(pTagName: String; pTagValue: String): JSSXmlElement updating;
/*
*/
vars
	element: JSSXmlElement;
begin
	if pTagName = "!--" then
		if self.isTransient then
			create element as JSSXmlComment transient;
		else
			create element as JSSXmlComment persistent;
		endif;
		element.createElement("Comment", pTagValue, self.level + 1, self.myDocument, null);
	elseif pTagName = "![CDATA[" then
		if self.isTransient then
			create element as JSSXmlCData transient;
		else
			create element as JSSXmlCData persistent;
		endif;
		element.createElement("CDATA", pTagValue, self.level + 1, self.myDocument, null);
	else
		if self.isTransient then
			create element transient;
		else
			create element persistent;
		endif;
		element.createElement(pTagName, pTagValue, self.level + 1, self.myDocument, null);
	endif;
	self.allChildElements.insert(1, element);

	//	return the newly created element for the caller to reference
	return(element);
end;</source>
        <Parameter name="pTagName" type="String"/>
        <Parameter name="pTagValue" type="String"/>
        <ReturnType type="JSSXmlElement"/>
    </JadeMethod>
    <JadeMethod name="adjustLevel" id="6549c0c3-f441-43d3-88ab-aa680266babf">
        <updating/>
        <source>adjustLevel(pNewLevel: Integer) updating, protected;
/*
*/
vars
	element: JSSXmlElement;
	newLevel: Integer;
begin
	self.level := pNewLevel;
	newLevel := pNewLevel + 1;
	//	adjust all child elements
	foreach element in self.allChildElements do
		element.adjustLevel(newLevel);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pNewLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="buildXmlString" id="faba465a-d6d3-4b1c-8c36-a3026aed7393">
        <source>buildXmlString(): String;
/*
*/
begin
	//
	self.myDocument.buildXmlBaseLevel := self.level;
	//
	return(self.generateXmlString());
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="changeTagName" id="888fcf33-9282-4792-8eb7-bc1d27f380e1">
        <updating/>
        <source>changeTagName(pNewTagName: String) updating;
/*
*/
vars
	pos: Integer;
begin
	self.tagName := pNewTagName;
	pos := self.tagName.pos(":",1);
	if pos &gt; 0 then
		self.namespace := self.tagName[1:pos - 1];
		self.baseName := self.tagName[pos + 1:end];
		self.tagName := self.tagName[pos + 1:end];
	else
		self.baseName := self.tagName;
	endif;
end;</source>
        <Parameter name="pNewTagName" type="String"/>
    </JadeMethod>
    <JadeMethod name="changeTagValue" id="634a5d36-9bc2-4be6-8b46-bbb017d2abcf">
        <updating/>
        <source>changeTagValue(pNewTagValue: String) updating;
/*
*/
begin
	self.tagValue := pNewTagValue;
end;</source>
        <Parameter name="pNewTagValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="copyAsChildElement" id="38116876-42f8-4bca-856e-d5c9a228243b">
        <updating/>
        <source>copyAsChildElement(pCopyElement: JSSXmlElement): JSSXmlElement updating, protected;
/*
*/
vars
	copyElement: JSSXmlElement;
	copyAttribute: JSSXmlAttribute;
	attributeName: String;
	attributeNumber: Integer;
	newElement: JSSXmlElement;
begin
	//	copy the basic element
	newElement := self.addElement(pCopyElement.fullName(), pCopyElement.tagValue);

	//	copy the attributes
	foreach copyAttribute in pCopyElement.allAttributes do
		attributeName := copyAttribute.attributeName;
		if attributeName.toLower = "id" then
			//	check if we will now have a duplicate "element by id name", which we will need to change
			if myDocument.allElementsByIdAttribute[attributeName] &lt;&gt; null then
				attributeNumber := 1;
				attributeName := attributeName &amp; "_";
				while myDocument.allElementsByIdAttribute[attributeName &amp; attributeNumber.String] &lt;&gt; null do
					attributeNumber := attributeNumber + 1;
				endwhile;
				attributeName := attributeName &amp; attributeNumber.String;
			endif;
		else
			//	check for any attributes referencing an "id" attribute that has been changed

		endif;
		newElement.addAttribute(attributeName, copyAttribute.attributeValue);
	endforeach;

	//	copy the child elements recursively
	foreach copyElement in pCopyElement.allChildElements do
		newElement.copyAsChildElement(copyElement);
	endforeach;

	return(newElement);
end;</source>
        <access>protected</access>
        <Parameter name="pCopyElement" type="JSSXmlElement"/>
        <ReturnType type="JSSXmlElement"/>
    </JadeMethod>
    <JadeMethod name="copyElement" id="d620416a-36a5-4bef-a7a2-d8114668d1d7">
        <updating/>
        <source>copyElement(pCopyElement: JSSXmlElement; pPosition: Integer): JSSXmlElement updating;
/*
*/
vars
	copyElement: JSSXmlElement;
	newElement: JSSXmlElement;
	myPosition: Integer;
begin
	if pPosition = AS_CHILD_OF then

		newElement := self.copyAsChildElement(pCopyElement);

	elseif pPosition = BEFORE_ELEMENT or pPosition = AFTER_ELEMENT then

		if self.myParentElement = null then
			return(null);
		endif;
		myPosition := self.myParentElement.allChildElements.indexOf(self);
		newElement := self.myParentElement.copyAsChildElement(pCopyElement);
		newElement.myParentElement := null;

		if pPosition = AFTER_ELEMENT then
			myPosition := myPosition + 1;
		endif;
		self.myParentElement.allChildElements.insert(myPosition, newElement);
	endif;
	return(newElement);
end;</source>
        <Parameter name="pCopyElement" type="JSSXmlElement"/>
        <Parameter name="pPosition" type="Integer"/>
        <ReturnType type="JSSXmlElement"/>
    </JadeMethod>
    <JadeMethod name="createElement" id="d854115d-3de7-485c-8435-6446888857c9">
        <updating/>
        <source>createElement(pTagName: String; pTagValue: String; pLevel: Integer; pDocument: JSSXmlDocument; pParentElement: JSSXmlElement) updating;
/*
*/
vars
	pos: Integer;
	lTagName: String;
begin
	lTagName := pTagName;
	self.tagName := lTagName;
	pos := lTagName.pos(":",1);
	if pos &gt; 0 then
		self.namespace := lTagName[1:pos - 1];
		self.baseName := lTagName[pos + 1:end];
		self.tagName := lTagName[pos + 1:end];
	else
		self.baseName := lTagName;
	endif;
	self.tagValue := pTagValue;
	self.level := pLevel;
	self.myParentElement := pParentElement;
	self.myDocument := pDocument;
end;</source>
        <Parameter name="pTagName" type="String"/>
        <Parameter name="pTagValue" type="String"/>
        <Parameter name="pLevel" type="Integer"/>
        <Parameter name="pDocument" type="JSSXmlDocument"/>
        <Parameter name="pParentElement" type="JSSXmlElement"/>
    </JadeMethod>
    <JadeMethod name="deleteAttribute" id="38a264a0-6080-4e87-bcca-ed1e4561cb5d">
        <updating/>
        <source>deleteAttribute(pAttributeName: String) updating;
/*
*/
vars
	attribute: JSSXmlAttribute;
begin
	attribute := self.allAttributesByName[pAttributeName];
	if attribute &lt;&gt; null then
		if pAttributeName.toLower = "id" then
			self.myDocumentForId := null;
		endif;
		delete attribute;
	endif;
end;</source>
        <Parameter name="pAttributeName" type="String"/>
    </JadeMethod>
    <JadeMethod name="displayName" id="cb0a3eca-19bc-4980-ba66-1043267f5c53">
        <source>displayName(): String;
/*
*/
begin
	if self.allAttributesByName["id"] = null then
		return(self.fullName());
	else
		return(self.allAttributesByName["id"].attributeValue);
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="escapeTagValue" id="dd3ed38b-fbfb-4510-89f4-ebecf1be1f55">
        <source>escapeTagValue(pValue: String): String protected;
/*
*/
constants
	Amp: String = "&amp;";
	AmpEsc: String = "&amp;amp;";
	Apos: String = "'";
	AposEsc: String = "&amp;apos;";
	Quot: String = '"';
	QuotEsc: String = "&amp;quot;";
	Lt: String = "&lt;";
	LtEsc: String = "&amp;lt;";
	Gt: String = "&gt;";
	GtEsc: String = "&amp;gt;";
vars
	rtnValue: String;
	pos: Integer;
	str1: String;
	str2: String;
begin
	rtnValue := pValue;

	//	replace &amp;amp; with &amp;
	pos := rtnValue.pos(AmpEsc, 1);
	while pos &gt; 0 do
		str1 := rtnValue[1:pos - 1];
		if pos + 5 &lt; rtnValue.length then
			str2 := rtnValue[pos + 5:end];
		else
			str2 := null;
		endif;
		rtnValue := str1 &amp; Amp &amp; str2;
		pos := rtnValue.pos(AmpEsc, pos + 1);
	endwhile;
	//	replace &amp;apos; with '
	pos := rtnValue.pos(AposEsc, 1);
	while pos &gt; 0 do
		str1 := rtnValue[1:pos - 1];
		if pos + 6 &lt; rtnValue.length then
			str2 := rtnValue[pos + 6:end];
		else
			str2 := null;
		endif;
		rtnValue := str1 &amp; Apos &amp; str2;
		pos := rtnValue.pos(AposEsc, pos + 1);
	endwhile;
	//	replace &amp;quot; with "
	pos := rtnValue.pos(QuotEsc, 1);
	while pos &gt; 0 do
		str1 := rtnValue[1:pos - 1];
		if pos + 6 &lt; rtnValue.length then
			str2 := rtnValue[pos + 6:end];
		else
			str2 := null;
		endif;
		rtnValue := str1 &amp; Quot &amp; str2;
		pos := rtnValue.pos(QuotEsc, pos + 1);
	endwhile;
	//	replace &amp;lt; with &lt;
	pos := rtnValue.pos(LtEsc, 1);
	while pos &gt; 0 do
		str1 := rtnValue[1:pos - 1];
		if pos + 4 &lt; rtnValue.length then
			str2 := rtnValue[pos + 4:end];
		else
			str2 := null;
		endif;
		rtnValue := str1 &amp; Lt &amp; str2;
		pos := rtnValue.pos(LtEsc, pos + 1);
	endwhile;
	//	replace &amp;gt; with &gt;
	pos := rtnValue.pos(GtEsc, 1);
	while pos &gt; 0 do
		str1 := rtnValue[1:pos - 1];
		if pos + 4 &lt; rtnValue.length then
			str2 := rtnValue[pos + 4:end];
		else
			str2 := null;
		endif;
		rtnValue := str1 &amp; Gt &amp; str2;
		pos := rtnValue.pos(GtEsc, pos + 1);
	endwhile;

	return (rtnValue);
end;</source>
        <access>protected</access>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findAttribute" id="9334b45b-eda1-4c92-a8f0-9068729b039c">
        <updating/>
        <source>findAttribute(pAttributeName: String): JSSXmlAttribute updating;
/*
*/
begin
	return (self.allAttributesByName[pAttributeName]);
end;</source>
        <Parameter name="pAttributeName" type="String"/>
        <ReturnType type="JSSXmlAttribute"/>
    </JadeMethod>
    <JadeMethod name="findElement" id="d8d26365-8c61-451e-a09a-773b7afa70e0">
        <updating/>
        <source>findElement(pElementName: String): JSSXmlElement updating;
/*
*/
begin
	return (self.allChildElementsByName[pElementName]);
end;</source>
        <Parameter name="pElementName" type="String"/>
        <ReturnType type="JSSXmlElement"/>
    </JadeMethod>
    <JadeMethod name="findElementByAttributeName" id="0a4b1f31-2d75-437e-b8cc-807e410a4d60">
        <updating/>
        <source>findElementByAttributeName(pAttributeName: String; pDirection: Integer): JSSXmlElement updating;
/*
*/
vars
	element: JSSXmlElement;
begin
	if pDirection = UPWARDS then
		element := self;
		//	starting with me, bubble up thru the family tree
		while element &lt;&gt; null do
			if element.allAttributesByName[pAttributeName] &lt;&gt; null then
				return(element);
			endif;
			element := element.myParentElement;
		endwhile;
		return(null);
	elseif pDirection = DOWNWARDS then
		//	check if any immediate children have the attribute
		foreach element in self.allChildElements do
			if element.allAttributesByName[pAttributeName] &lt;&gt; null then
				return(element);
			endif;
		endforeach;
		//	check if any grandchildren have the attribute, recursively
		foreach element in self.allChildElements do
			element := element.findElementByAttributeName(pAttributeName, pDirection);
			if element &lt;&gt; null then
				return(element);
			endif;
		endforeach;
		return(null);
	endif;
	//	must have passed an incorrect direction parameter
	return(null);
end;</source>
        <Parameter name="pAttributeName" type="String"/>
        <Parameter name="pDirection" type="Integer"/>
        <ReturnType type="JSSXmlElement"/>
    </JadeMethod>
    <JadeMethod name="fullName" id="b39a4a09-4373-4bb2-b157-8a2651df699f">
        <source>fullName(): String;
/*
*/
begin
	if namespace &lt;&gt; null then
		return (self.namespace &amp; ":" &amp; self.tagName);
	else
		return (self.tagName);
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateAttributeString" id="07ae6609-7e7f-4fa5-adfc-b77a54e5553b">
        <source>generateAttributeString(): String protected;
/*
*/
vars
	attribute: JSSXmlAttribute;
	returnString: String;
begin
	foreach attribute in self.allAttributes do
		returnString := returnString &amp; attribute.generateXmlString();
	endforeach;

	return(returnString);
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateIndentation" id="e26cdec1-074f-40e8-9d06-095c2420b43d">
        <source>generateIndentation(): String protected;
/*
*/
vars
	index: Integer;
	maxIndex: Integer;
	returnString: String;
begin
	if self.myDocument.noIndentation then
		return(null);
	endif;
	maxIndex := self.level - self.myDocument.buildXmlBaseLevel;
	returnString := CrLf;
	foreach index in 1 to maxIndex do
		returnString := returnString &amp; Tab;
	endforeach;

	return(returnString);
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateXmlString" id="8e93af54-5015-454f-bf58-9cfb37ec6963">
        <source>generateXmlString(): String protected;
/*
*/
vars
	element: JSSXmlElement;
	indentation: String;
	returnString: String;
	rtnString: String;
begin
	indentation := self.generateIndentation();
	//	build the start tag
	if self.allAttributes.isEmpty() then
		returnString := indentation &amp; "&lt;" &amp; self.fullName() &amp; "&gt;" &amp; self.tagValueEscaped();
	else
		returnString := indentation &amp; "&lt;" &amp; self.fullName() &amp; self.generateAttributeString() &amp; "&gt;" &amp; self.tagValueEscaped();
	endif;
	if self.allChildElements.isEmpty() then
		returnString := returnString &amp; "&lt;/" &amp; self.fullName() &amp; "&gt;";
	else
		foreach element in self.allChildElements do
			rtnString := rtnString &amp; element.generateXmlString();
		endforeach;
		returnString := returnString &amp; rtnString &amp; indentation &amp; "&lt;/" &amp; self.fullName() &amp; "&gt;";
	endif;
	//
	return(returnString);
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadListbox" id="1fa0807b-da53-4918-88a9-6c2408af6166">
        <source>loadListbox(pListbox: ListBox input; pIncludeAttributes: Boolean);
/*
*/
vars
	element: JSSXmlElement;
	attribute: JSSXmlAttribute;
	myIndex: Integer;
	index: Integer;
begin
	myIndex := pListbox.addItem(self.displayName());
	pListbox.itemForeColor[myIndex] := self.myDocument.foreColorElement;
	pListbox.itemLevel[myIndex] := self.level + 1;
	pListbox.itemObject[myIndex] := self;

	//	load my attributes
	if pIncludeAttributes and self.allAttributes.size &gt; 0 then
		foreach attribute in self.allAttributes do
			index := pListbox.addItem(attribute.attributeName);
			pListbox.itemForeColor[index] := self.myDocument.foreColorAttribute;
			pListbox.itemLevel[index] := self.level + 2;	//3;
			pListbox.itemObject[index] := attribute;
		endforeach;
	endif;
	//load my child elements
	foreach element in self.allChildElements do
		element.loadListbox(pListbox, pIncludeAttributes);
	endforeach;

	pListbox.itemExpanded[myIndex] := true;
end;</source>
        <Parameter name="pListbox" type="ListBox" usage="input"/>
        <Parameter name="pIncludeAttributes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveElement" id="f0abce16-1760-45e0-9ec2-4720744cd8ea">
        <updating/>
        <source>moveElement(pMoveElement: JSSXmlElement input; pPosition: Integer): Boolean updating;
/*
*/
vars
	myPosition: Integer;
begin
	if pMoveElement = self then
		return(false);
	endif;
	
	if pPosition = AS_CHILD_OF then
		pMoveElement.myParentElement := self;

		//	adjust the level on the moved item (and all child elements) if necessary
		if pMoveElement.level &lt;&gt; self.level + 1 then
			pMoveElement.adjustLevel(self.level + 1);
		endif;
	elseif pPosition = BEFORE_ELEMENT or pPosition = AFTER_ELEMENT then

		if self.myParentElement = null then
			return(false);
		endif;
		myPosition := self.myParentElement.allChildElements.indexOf(self);
		pMoveElement.myParentElement := null;

		if pPosition = AFTER_ELEMENT then
			myPosition := myPosition + 1;
		endif;
		self.myParentElement.allChildElements.insert(myPosition, pMoveElement);

		//	adjust the level on the moved item (and all child elements) if necessary
		if pMoveElement.level &lt;&gt; self.level then
			pMoveElement.adjustLevel(self.level);
		endif;
	endif;
	return(true);
end;</source>
        <Parameter name="pMoveElement" type="JSSXmlElement" usage="input"/>
        <Parameter name="pPosition" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="parseAttributes" id="80a1e2d1-2679-48af-9036-1e584f8d80cc">
        <updating/>
        <source>parseAttributes(pTagString: String) updating, protected;
/*
*/
vars
	pos: Integer;
	posEnd: Integer;
	attributeName: String;
	attributeValue: String;
	quoteChar: String;
begin
	pos := pTagString.pos(" ", 2);
	while true do
		//	step over blanks
		while pTagString[pos:1] = " " do
			pos := pos + 1;
		endwhile;

		//	check if we have hit the end
		if pTagString[pos:1] = "&gt;" or pTagString[pos:1] = "/" then
			break;
		endif;
		//	get the attribute name
		posEnd := pTagString.pos('=', pos);
		if posEnd &gt; 0 and posEnd &gt; pos then
			quoteChar := pTagString[posEnd + 1:1];
			if not (quoteChar = '"' or quoteChar = "'") then
				quoteChar := " ";
			endif;
			attributeName := pTagString[pos:posEnd - pos];
		else
			break;
		endif;
		//	get the attribute value
		pos := posEnd + 2;	//	step over the =" characters
		posEnd := pTagString.pos(quoteChar, pos);
		if posEnd &gt; 0 and posEnd &gt; pos then
			attributeValue := pTagString[pos:posEnd - pos];

			self.addAttribute(attributeName, attributeValue);
		else
			break;
		endif;
		pos := posEnd + 1;	//	step over the " character

	endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="pTagString" type="String"/>
    </JadeMethod>
    <JadeMethod name="parseElement" id="eb2f878d-3baf-4932-81fd-32f5652c51b5">
        <updating/>
        <source>parseElement(pXmlString: String; pPosition: Integer io) updating;
/*
*/
vars
	pos: Integer;
	posEnd: Integer;
	posSpace: Integer;
	posNameEnd: Integer;
	tagEndPos: Integer;
//	xmlString: String;
	endTagString: String;
	nextTagName: String;
	nextTagPos: Integer;
	thisTagValue: String;
	attributesValue: String;
begin
	//	check for attributes
	posEnd := pXmlString.pos("&gt;", pPosition + 1);
	posSpace := pXmlString.pos(" ", pPosition + 1);
	if posSpace &gt; pPosition and posSpace &lt; posEnd then
		attributesValue := pXmlString[pPosition:posEnd - pPosition + 1];
		self.parseAttributes(self.replaceWhiteSpace(attributesValue));
	endif;
	//	look for a tag that is the start and the end tag all in one &lt;blah/&gt;
	if pXmlString[posEnd-1:1] = "/" then
		pPosition := pXmlString.pos("&lt;", posEnd);
		return;
	endif;
	//	look for the next tag; either the start of a new tag, or the end of this one
	nextTagPos := pXmlString.pos("&lt;", posEnd);
	if nextTagPos &gt; pPosition then
		//	grab the tags value between the end of this tag and the start of the next one
		thisTagValue := pXmlString[posEnd + 1:nextTagPos - posEnd - 1];
		if self.replaceWhiteSpace(thisTagValue).trimBlanks = null then
		else
			self.tagValue := self.tagValue &amp; self.escapeTagValue(pXmlString[posEnd + 1:nextTagPos - posEnd - 1].trimBlanks);
		endif;
	endif;
	while nextTagPos &gt; pPosition do

		//	the next tag is the end of this one, so tidy up and return
		if pXmlString[nextTagPos:2] = "&lt;/" then
			posEnd := pXmlString.pos("&gt;", nextTagPos + 2);
			if posEnd &gt; pPosition then
				pPosition := pXmlString.pos("&lt;", posEnd);
			else
				pPosition := 0;
			endif;
			return;
		endif;
		//	get the next tag name, create the element and get it to parse from here on
		posEnd := pXmlString.pos("&gt;", nextTagPos + 1);
		posSpace := pXmlString.pos(" ", nextTagPos + 1);
		if posSpace &gt; 0 and posSpace &lt; posEnd then
			posNameEnd := posSpace;
		else
			if pXmlString[posEnd-1:1] = "/" then
				posEnd := posEnd - 1;
			endif;
			posNameEnd := posEnd;
		endif;
		if pXmlString[nextTagPos:9] = "&lt;![CDATA[" then
			posNameEnd := nextTagPos + 9;
		elseif pXmlString[nextTagPos:4] = "&lt;!--" then
			posNameEnd := nextTagPos + 4;
		endif;
		nextTagName := pXmlString[nextTagPos + 1:posNameEnd - nextTagPos - 1];

		if nextTagName = "!--" then
			posEnd := pXmlString.pos("--&gt;", nextTagPos);
			if posEnd &gt; 0 then
				posEnd := posEnd + ("--&gt;").length;
				self.addElement(nextTagName, null).parseElement(pXmlString, nextTagPos);
				//	look for the next tag
				nextTagPos := pXmlString.pos("&lt;", posEnd);
			endif;
		elseif nextTagName = "![CDATA[" then
			posEnd := pXmlString.pos("]]&gt;", nextTagPos);
			if posEnd &gt; 0 then
				posEnd := posEnd + ("]]&gt;").length;
				self.addElement(nextTagName, null).parseElement(pXmlString, nextTagPos);
				//	look for the next tag
				nextTagPos := pXmlString.pos("&lt;", posEnd);
			endif;
		else
			if posEnd &gt; 0 then
				self.addElement(nextTagName, null).parseElement(pXmlString, nextTagPos);
			endif;
		endif;
	endwhile;
	//	keep the position up to date when we recursively return
	pPosition := nextTagPos;

end;</source>
        <Parameter name="pXmlString" type="String"/>
        <Parameter name="pPosition" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="replaceWhiteSpace" id="1ac9a293-953b-4f86-b8e4-a521bcb51eaf">
        <source>replaceWhiteSpace(pXmlString: String): String protected;
/*
*/
vars
	indx: Integer;
	char: String;
	xmlString: String;
	str1: String;
	str2: String;
begin
	xmlString := pXmlString;

	indx := xmlString.pos(Tab, 1);
	while indx &gt; 0 do
		str1 := xmlString[1:indx-1];
		if indx + 1 &lt; xmlString.length then
			str2 := xmlString[indx+1:end];
		else
			str2 := null;
		endif;
		xmlString := str1 &amp; str2;
		indx := xmlString.pos(Tab, indx);
	endwhile;

	indx := xmlString.pos(Lf, 1);
	while indx &gt; 0 do
		str1 := xmlString[1:indx-1];
		if indx + 1 &lt; xmlString.length then
			str2 := xmlString[indx+1:end];
		else
			str2 := null;
		endif;
		xmlString := str1 &amp; str2;
		indx := xmlString.pos(Lf, indx + 1);
	endwhile;

	return (xmlString);
end;</source>
        <access>protected</access>
        <Parameter name="pXmlString" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setNamespace" id="af02bc05-416c-435b-812e-e7786cec805f">
        <updating/>
        <source>setNamespace(pNamespace: String) updating;
/*
*/
begin
	if self.namespace &lt;&gt; pNamespace then
		self.namespace := pNamespace;
	endif;
end;</source>
        <Parameter name="pNamespace" type="String"/>
    </JadeMethod>
    <JadeMethod name="tagValueEscaped" id="07794112-7c58-496d-9485-6eb95be2bb9c">
        <source>tagValueEscaped(): String protected;
/*
*/
constants
	Amp: String = "&amp;";
	AmpEsc: String = "&amp;amp;";
	Apos: String = "'";
	AposEsc: String = "&amp;apos;";
	Quot: String = '"';
	QuotEsc: String = "&amp;quot;";
	Lt: String = "&lt;";
	LtEsc: String = "&amp;lt;";
	Gt: String = "&gt;";
	GtEsc: String = "&amp;gt;";
vars
	rtnValue: String;
	pos: Integer;
	str1: String;
	str2: String;
begin
	rtnValue := self.tagValue;

	//	replace &amp; with &amp;amp;
	pos := rtnValue.pos(Amp, 1);
	while pos &gt; 0 do
		str1 := rtnValue[1:pos - 1];
		if pos &lt; rtnValue.length then
			str2 := rtnValue[pos + 1:end];
		else
			str2 := null;
		endif;
		rtnValue := str1 &amp; AmpEsc &amp; str2;
		pos := rtnValue.pos(Amp, pos + 5);
	endwhile;
	//	replace ' with &amp;apos;
	pos := rtnValue.pos(Apos, 1);
	while pos &gt; 0 do
		str1 := rtnValue[1:pos - 1];
		if pos &lt; rtnValue.length then
			str2 := rtnValue[pos + 1:end];
		else
			str2 := null;
		endif;
		rtnValue := str1 &amp; AposEsc &amp; str2;
		pos := rtnValue.pos(Apos, pos + 6);
	endwhile;
	//	replace " with &amp;quot;
	pos := rtnValue.pos(Quot, 1);
	while pos &gt; 0 do
		str1 := rtnValue[1:pos - 1];
		if pos &lt; rtnValue.length then
			str2 := rtnValue[pos + 1:end];
		else
			str2 := null;
		endif;
		rtnValue := str1 &amp; QuotEsc &amp; str2;
		pos := rtnValue.pos(Quot, pos + 6);
	endwhile;
	//	replace &lt; with &amp;lt;
	pos := rtnValue.pos(Lt, 1);
	while pos &gt; 0 do
		str1 := rtnValue[1:pos - 1];
		if pos &lt; rtnValue.length then
			str2 := rtnValue[pos + 1:end];
		else
			str2 := null;
		endif;
		rtnValue := str1 &amp; LtEsc &amp; str2;
		pos := rtnValue.pos(Lt, pos + 4);
	endwhile;
	//	replace &gt; with &amp;gt;
	pos := rtnValue.pos(Gt, 1);
	while pos &gt; 0 do
		str1 := rtnValue[1:pos - 1];
		if pos &lt; rtnValue.length then
			str2 := rtnValue[pos + 1:end];
		else
			str2 := null;
		endif;
		rtnValue := str1 &amp; GtEsc &amp; str2;
		pos := rtnValue.pos(Gt, pos + 4);
	endwhile;

	return (rtnValue);
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tagValueQuoted" id="0df9e867-4720-407c-9d7b-811be0998a54">
        <source>tagValueQuoted(): String;
/*
*/
begin
	if self.tagValue.pos('"', 1) &gt; 0 then
		return ("'" &amp; self.tagValue &amp; "'");
	else
		return ('"' &amp; self.tagValue &amp; '"');
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
