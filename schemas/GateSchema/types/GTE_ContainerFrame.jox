    <JadeMethod name="buildSelf" id="c7324d26-99bd-46cc-b1a0-3e369a7913d1">
        <updating/>
        <source>buildSelf() updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	doorsDirBtn	: GTE_DoorsDirMask;	

begin

	self.normalBackColor 	:= 15642292;
	self.selectedBackColor 	:= 11312639;
	
	if self.backColor &lt;&gt; self.selectedBackColor then
		self.backColor := self.normalBackColor;
	endif;

	if self.myDoorsDirBtn = null then
		create doorsDirBtn transient;
		doorsDirBtn.parent := self;
		form.addControl(doorsDirBtn);

		if isInPainter then
			doorsDirBtn.actualEnabled := false;
		endif;
		self.myDoorsDirBtn := doorsDirBtn;
	else
		doorsDirBtn := self.myDoorsDirBtn;
	endif;

	doorsDirBtn.height	:=	20;
	doorsDirBtn.width	:=	50;
	doorsDirBtn.top		:= self.clientHeight - doorsDirBtn.height - 5;
	self.positionDoorsDirBtn();	// sets the left position
	
	doorsDirBtn.foreColor		:=	foreColor;
	doorsDirBtn.fontName		:=	fontName;
	doorsDirBtn.fontSize		:=	fontSize;
	doorsDirBtn.fontBold		:=	fontBold;
	doorsDirBtn.fontItalic		:=	fontItalic;
	doorsDirBtn.fontUnderline	:=	fontUnderline;
	doorsDirBtn.fontStrikethru	:=	fontStrikethru;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearDetails" id="01d76f4c-1f66-4e6c-8d1b-93463cb21f6b">
        <updating/>
        <source>clearDetails() updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	needRefresh	: Boolean;
	
begin

	self.id		:= null;
	self.length := 0;
	self.mySheet := null;
	
	if self.visible then
		needRefresh := true;
	endif;
	
	self.visible := false;
	
	if needRefresh and self.myTruckLayoutFrame &lt;&gt; null then
		self.myTruckLayoutFrame.repositionAfterResize();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="67a63614-62ea-4c2e-8ee5-c91071398788">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.isBuilt := false;
	
	self.alignment			:= Alignment_Center_Top;
	self.bevelInner			:= Bevel_Inset;
	self.bevelInnerWidth	:= 1;
	self.bevelOuter			:= Bevel_Raised;
	self.bevelOuterWidth	:= 1;
	self.boundaryWidth		:= 1;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="dblClick" id="2d78e529-273b-40ad-8576-fd69923e20f8">
        <updating/>
        <source>dblClick(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.mySheet &lt;&gt; null and self.mySheet.myMenuAction &lt;&gt; null then
		self.mySheet.myMenuAction.goToObject(null, null, true, null);
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="deSelect" id="261cd450-959e-4ddb-837b-4b9064c2cf5a">
        <updating/>
        <source>deSelect() updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.backColor := self.normalBackColor;

end;</source>
    </JadeMethod>
    <JadeMethod name="dragDrop" id="6dcca810-4e8d-417e-9f5f-c0631528bb0b">
        <updating/>
        <source>dragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
//	inheritMethod(frame, win, x, y);

	self.myTruckLayoutFrame.dragDropContainer(self);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDoorsDir" id="c28a3dee-5dbd-4212-8c75-4efdf6ef994d">
        <source>getDoorsDir() : Integer;
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.hasDoors) or
	   (not self.myTruckLayoutFrame.myDoorsCheckBox.value) then
		return TI_DOORSDIRN_NULL;
	endif;

	if self.myDoorsDirBtn.doorsRight then
		return TI_DOORSDIRN_AFT;
	else
		return TI_DOORSDIRN_FWD;
	endif;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideDoorsDirBtn" id="2392dd51-8f16-405a-bada-4012a5617dec">
        <source>hideDoorsDirBtn();
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myDoorsDirBtn.visible := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="7e4b7a1b-0d58-4bd2-811b-12a5fd51f52c">
        <updating/>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	inOutForm	: GTE_InOutForm;
	tmpX,
	tmpY		: Real;

begin
//	inheritMethod(frame, button, shift, x, y);

	if button = Window.MouseButton_Left then
		self.myTruckLayoutFrame.selectContainer(self);
		self.dragMode := DragMode_Drag;
	elseif button = Window.MouseButton_Right then
		self.myTruckLayoutFrame.selectContainer(self);
		if self.form.isKindOf(GTE_InOutForm) then
			inOutForm := self.form.GTE_InOutForm;
			
			// convert the x,y position on the frame to the same position
			// relitive to the window.
			tmpX := x;
			tmpY := y;
			frame.windowToScreen(tmpX, tmpY);
			inOutForm.screenToWindow(tmpX, tmpY);
			inOutForm.containerLayoutRightClick(self.mySheet, tmpX.Integer, tmpY.Integer);
		endif;
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="paint" id="5a4538c6-0a3b-457a-bc42-9e6be9eca26d">
        <updating/>
        <source>paint(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(frame);

	if isInPainter then
		if not self.isBuilt then
			self.isBuilt := true;
			self.buildSelf;
		endif;

	elseif not isBuilt then
		self.isBuilt := true;
		self.buildSelf;
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="positionDoorsDirBtn" id="55693c0c-a09c-4ec5-9f6e-f056d3f6a984">
        <source>positionDoorsDirBtn() protected;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myDoorsDirBtn.setWidth(self.clientWidth);
	self.myDoorsDirBtn.left := (self.clientWidth - self.myDoorsDirBtn.width) / 2;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="refresh" id="c5721e55-8d41-4e96-9888-ecc7583bab64">
        <updating/>
        <source>refresh() updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	if not isInPainter then
		self.buildSelf();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="select" id="88a972b1-c698-43f8-9782-89d1ce3bb407">
        <updating/>
        <source>select() updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.backColor := self.selectedBackColor;
	
	if self.mySheet &lt;&gt; null then
		app.myController.selectMenuAction(self.mySheet.myMenuAction);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCaption" id="79be2635-27da-422e-899a-96179c41a207">
        <updating/>
        <source>setCaption() updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lenStr	: String;

begin

	if self.length &lt;&gt; 0 then
		lenStr := self.length.String;
	else
		lenStr := '&lt;unknown&gt;';
	endif;

	self.caption 	:= self.id &amp; CrLf &amp; lenStr;
	self.bubbleHelp	:= self.id &amp; CrLf &amp; 'Length : ' &amp; lenStr;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDetails" id="a52e9134-4e6a-468f-887f-1ae96f827fda">
        <updating/>
        <source>setDetails(pId : String; pLength : Integer; pDoors : Boolean; pSheet : GTE_Sheet) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.id		 := pId;
	self.length	 := pLength;
	self.setHasDoors(pDoors);
	self.mySheet := pSheet;
	
	self.setCaption();
	
	self.visible := true;

end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pLength" type="Integer"/>
        <Parameter name="pDoors" type="Boolean"/>
        <Parameter name="pSheet" type="GTE_Sheet"/>
    </JadeMethod>
    <JadeMethod name="setHasDoors" id="00672223-59a3-44fd-b055-1b0d5fc3aadc">
        <updating/>
        <source>setHasDoors(pValue: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.hasDoors := pValue;
	
	if self.myTruckLayoutFrame.myDoorsCheckBox.value then
		// doors dir is used
		if pValue then
			self.myDoorsDirBtn.visible := true;
		else
			self.myDoorsDirBtn.visible := false;
		endif;
	else
		// doors btn is probably not visible anyway 
		self.myDoorsDirBtn.visible := false;
	endif;
	
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setId" id="9c6bc6ef-ccd4-4d05-88fa-8e74d2fcc44c">
        <updating/>
        <source>setId(pId : String) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.id		 := pId;
	
	self.setCaption();
	
end;</source>
        <Parameter name="pId" type="String"/>
    </JadeMethod>
    <JadeMethod name="setLength" id="b25cc330-f870-4901-85cb-928a2a373d48">
        <updating/>
        <source>setLength(pLength : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.length = pLength then
		return;
	endif;
	
	self.length := pLength;
	
	self.setCaption();
	
	self.myTruckLayoutFrame.displayContainers();

end;</source>
        <Parameter name="pLength" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setWidth" id="5b5731b2-6626-4f91-a766-9a6b2af35a53">
        <updating/>
        <source>setWidth(p10, p20, p40 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.length = 40 then
		self.width := p40;
	elseif self.length = 20 then
		self.width := p20;
	else
		self.width := p20;	// p10 - make 20 the default;
	endif;

	self.positionDoorsDirBtn();

end;</source>
        <Parameter name="p10" type="Integer"/>
        <Parameter name="p20" type="Integer"/>
        <Parameter name="p40" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showDoorsDirBtn" id="91814389-92b6-488c-8143-b295c802e93d">
        <source>showDoorsDirBtn();
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.hasDoors then
		self.myDoorsDirBtn.visible := true;
	else
		self.myDoorsDirBtn.visible := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="752b0f37-072e-459d-87e2-69d489850dce">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	//cnwsh3 21/04/2006 - The selected container was not being highlighted with new skin layout.  Set the control to ignore the skin.
	self.ignoreSkin := true;
	
	self.buildSelf();
	
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
    <DevControlTypes name="GTE_ContainerFrame">
        <bitmap></bitmap>
        <windowClass>AlFrame</windowClass>
        <DevControlProperties name="alignChildren">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Align Width</value>
                <value>2 - All</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="alignContainer">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Align Top</value>
