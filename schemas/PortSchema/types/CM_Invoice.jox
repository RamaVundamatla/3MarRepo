    <JadeMethod name="getDateForStatus" id="9a41ee30-4526-42d2-add4-2bbe0b348730">
        <source>getDateForStatus():TimeStamp;
/*
Purpose:			
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/


vars

	effectiveDT : TimeStamp;

begin

	effectiveDT := null;

	if self.status = INVOICE_PENDING then
		effectiveDT := self.pendingDT;
	elseif self.status = INVOICE_PREPEND then 
		effectiveDT := self.prependDT;
	elseif self.status = INVOICE_POSTED then 
		effectiveDT := self.postedDT;
	elseif self.status = INVOICE_POSTED_REVERSE then
		effectiveDT := self.postedDT;
	elseif self.status = INVOICE_POSTED_CREDIT then 
		effectiveDT := self.postedDT;
	elseif self.status = INVOICE_PENDING_REVERSE then  //31.10.2018 cnwma1 TFS #41703
		effectiveDT := self.pendingDT;
	endif;
	
	return effectiveDT;

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
