    <JadeMethod name="isRunning" id="be098cb5-77a0-41c0-9924-33548d75b503">
        <source>isRunning() : Boolean;

// cnwdvb1 25 October 2002 

vars

	ls : Boolean;
	tmpProcess	: Process;
	controller	: BGP_Controller;

begin

	app.cmsBeginLoad(ls);
//	self.sharedLock(self);
//	tmpProcess := self.myProcess;
//	if (not global.isValidObject(tmpProcess)) then
//		return false;
//	endif;

//	self.sharedLock(tmpProcess);
//	return tmpProcess.signOnTime = self.startTime;*/
	foreach controller in self.allBGPControllers discreteLock do
		if controller.isRunning() then
			return true;
		endif;
	endforeach;
	return false;

epilog
	app.cmsEndLoad(ls);

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8479dddf-d564-4fc4-b8cd-efcc26aa9ab2">
        <updating/>
        <source>setForCreate(_cmif : CMIF_BGPManagerChildren) updating;

// cnwdvb1 24 October 2002 

vars

begin

	self.name 					:= _cmif.managerName.toUpper();	
	self.isRunOnServer			:= _cmif.isServer;
	self.isManagedService		:= _cmif.isFatClientOnly;
	self.machineNameSpecific	:= _cmif.machineNameSpecific;
	self.myRoot					:=  app.myRoot;
	
	self.createChildren(_cmif);
	
	
end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2270fefc-7ac4-4d0b-aa2c-bb84724616a3">
        <updating/>
        <source>setForUpdate(_cmif : CMIF_BGPManagerChildren) updating;

// cnwdvb1 25 October 2002 

vars

	
begin

	self.name 			:= _cmif.managerName.toUpper();	
	self.isRunOnServer	:= _cmif.isServer;
	self.isManagedService		:= _cmif.isFatClientOnly;
	self.machineNameSpecific	:= _cmif.machineNameSpecific;
	self.updateChildren(_cmif);
	self.causeEvent(BGP_Object.BGP_DisplayUpdate, false, null);
end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
    <JadeMethod name="setProcess" id="dc86ea66-cff8-40a9-bcd6-b867bec7163b">
        <updating/>
        <source>setProcess(_process : Process; _startTime : TimeStamp) updating;

// cnwdvb1 12 November 2002 
//14 Jan 2014	cnwrs1	Par 33264 change process usercode to be actiula user code not controller name

vars


begin
	if not app.isSDSSecondaryDB() then	// CCMS1150 cnwrs1 10 June 2011
		self.myProcess := _process;
		self.startTime := _startTime;
	
		if self.myProcess &lt;&gt; null then
			self.machineName := app.computerName();
			process.changeUserCode(self.name[1:30]);
			process.userInfo := self.name;
		else
			self.machineName := null;
		endif;
	endif;
	self.causeEvent(BGP_Object.BGP_DisplayUpdate, false, null);
end;</source>
        <Parameter name="_process" type="Process"/>
        <Parameter name="_startTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="startAllBackGroundApps" id="b5b488bb-dae0-4a19-96e4-dc5ca61a882d">
        <source>startAllBackGroundApps();

vars
	iter 		: Iterator;
	controller	: BGP_Controller;
begin
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	iter := self.allBGPControllers.createIterator;
	while iter.next(controller) do
		if not controller.isRunning() then
			if not app.isSDSSecondaryDB() then	// CCMS1150 cnwrs1 10 June 2011
				app.myTrxUA.trxUpdateBGPControllerProcess(controller, null, null, false, app.myPassport);
				self.startBackGroundApp(controller, false);
			else
				if controller.canRunOnSDSSecondaryDB() then
					self.startBackGroundApp(controller, false);
				endif;
			endif;
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="startBackGroundApp" id="6974f180-45e0-48ec-8162-9aacf46594ee">
        <source>startBackGroundApp(_controller : BGP_Controller input; _useController : Boolean);
/*

Date		Who		Reason
23 Nov 2011	cnwkpd1	PAR #28734 - fix 1090 errors when started from ini file as server app
27 Sep 2018	jlgmd1	TFS 41133 Fix typo preventing correct username logging when terminating

*/
vars
	runningController	: BGP_Controller;
	msg : String;
begin
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	if (not _controller.isRunning()) and _controller.isSetup then	
		if _useController then
			runningController := self.findRunningController();
			if runningController &lt;&gt; null then
				msg := 'Starting controller from controller';
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				runningController.causeEvent(BGP_Object.BGP_ApplicationStartRequest, true, _controller);
				if app.myPassport &lt;&gt; null and app.myPassport.myUser &lt;&gt; null then //cnwrs1 17712 Aug 2008
					app.createActivityHistory(ActivityHistoryGeneral, null, self, app.myPassport.getUserCode&amp;" has started the BGP "&amp;_controller.name&amp;'.' , false, false);
					app.writeLog(app.myPassport.getUserCode&amp;' '&amp;app.name&amp;" has started the BGP "&amp;_controller.name&amp;'.', LogINFO);	//25 Nov 2019	NDL	TFS 47053
				endif;
			endif;
		else
			if _controller &lt;&gt; null then
				msg := 'Starting controller from  manager';
				app.writeLog(msg,LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				app.startApplicationWithParameter(_controller.schemaName, _controller.appName, _controller);
				if app.myPassport &lt;&gt; null and app.myPassport.myUser &lt;&gt; null then //cnwrs1 17712 Aug 2008
					app.createActivityHistory(ActivityHistoryGeneral, null, self, app.myPassport.getUserCode&amp;" has started the BGP "&amp;_controller.name&amp;'.' , false, false);
					app.writeLog(app.myPassport.getUserCode&amp;' '&amp;app.name&amp;" has started the BGP "&amp;_controller.name&amp;'.', LogINFO);	//25 Nov 2019	NDL	TFS 47053
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_controller" type="BGP_Controller" usage="input"/>
        <Parameter name="_useController" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="startSelf" id="dccaefa3-5a2b-4435-bce4-482de83a1830">
        <updating/>
        <source>startSelf() updating;

// cnwdvb1 25 October 2002 

vars
	
begin
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	if not self.isRunning then
		// If we want to start a thin client report session then the starting app needs to be a gui app.
		if node.isApplicationServer and not self.isRunOnServer then
			app.startApplicationWithParameter('UiCommonSchema', 'BGP_ManagerGuiApp', self);
		else
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' start '&amp;'UiCommonSchema'&amp;' '&amp;'BGP_ManagerServerApp', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			app.startApplicationWithParameter('UiCommonSchema', 'BGP_ManagerServerApp', self);	
		endif;
		if app.myPassport &lt;&gt; null and app.myPassport.myUser &lt;&gt; null then //cnwrs1 17712 Aug 2008
			app.createActivityHistory(ActivityHistoryGeneral, null, self, app.myPassport.getUserCode&amp;" has started the BGP "&amp;self.name&amp;'.' , false, false);
			app.writeLog(app.myPassport.getUserCode&amp;" has started the BGP "&amp;self.name&amp;'.', LogINFO);	//25 Nov 2019	NDL	TFS 47053	
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="stopAllBackGroundApps" id="40c92e7a-9e4d-42ee-90f8-77a9d2916786">
        <source>stopAllBackGroundApps(_userCode : String) protected;

vars

	iter 		: Iterator;
	controller	: BGP_Controller;

begin
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053

	iter := self.allBGPControllers.createIterator;
	while iter.next(controller) do
		controller.terminateProcessing(_userCode);
	endwhile;
	
epilog

	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="terminateProcessing" id="8ad4c0aa-b600-4c43-bada-9b375cdd1524">
        <source>terminateProcessing(_userCode : String);
// -------------------------------------------
// Created 10 August 2004 by cnwdvb1
// -------------------------------------------
// 27 Sep 2018	jlgmd1	TFS 41133 Fix typo preventing correct username logging when terminating
vars

	description : String;


begin
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053

	description := app.getErrorString2(Stopping_BGPProcess, self.name &amp; '/' &amp; app.getErrorString(Manager) &amp; '... ', _userCode);
	app.createActivityHistory(ActivityHistoryGeneral, null, self, description, false, false);
	
	self.stopAllBackGroundApps(_userCode);
	
	app.createActivityHistory(ActivityHistoryGeneral, null, self, _userCode&amp;" has stopped the BGP "&amp;self.name&amp;'.' , false, false);
	app.writeLog(_userCode&amp;" has stopped the BGP "&amp;self.name&amp;'.', LogINFO);	//25 Nov 2019	NDL	TFS 47053
end;</source>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateChildren" id="5498a221-5563-422d-9de5-40b4c17d1980">
        <updating/>
        <source>updateChildren(_cmif : CMIF_BGPManagerChildren) protected, updating;

// cnwdvb1 08 July 2003 

/*
Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
14 Aug 2013	cnwrs1	Par 32226 - The Calendar Check and Slot Booking Generator implemenations were incomplete
//28 Apr 2016	cnwrs1	TFS Push Events Geneva
// 10 May 2017	cnwrs1	TFS 3518 remove Push Events
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
*/
vars
	controller	: BGP_Controller;
	extWS,
	generic, 
	report,
	direct, 
	autoTimer,
	futureTimer,
	server,
	client,
	lock,
	locationStatistics,
	workOrderScheduler,
	backupJournal,
	change,
	autoWarning,
	calendarCheck,	//02 Nov 2010	NDL	Par 25530
	vsBookGen,	//15 Apr 2013	NDL	Par 31393
	deferredCharge,	//06 Jul 2021	NDL	TFS 51443
	rfidListen	: DynaDictionary;
begin
	foreach controller in self.allBGPControllers do
		if controller.isKindOf(BGP_BackupJournal) then
			if backupJournal = null then
				create backupJournal transient;
				self.initSortDict(backupJournal);
			endif;
			backupJournal.add(controller);
		elseif controller.isKindOf(BGP_CalendarCheckController) then	//02 Nov 2010	NDL	Par 25530
			if calendarCheck = null then								
				create calendarCheck transient;						
				self.initSortDict(calendarCheck);						
			endif;														
			calendarCheck.add(controller);	//14 Aug 2013	cnwrs1	Par 32226 - The Calendar Check and Slot Booking Generator implemenations were incomplete
		elseif controller.isKindOf(BGP_ChangeTrackerController) then
			if  change = null then
				create change transient;
				self.initSortDict(change);
			endif;
			change.add(controller);
		elseif controller.isKindOf(BGP_ExternalWSController) then
			if  extWS = null then
				create extWS transient;
				self.initSortDict(extWS);
			endif;
			extWS.add(controller);
		elseif controller.isKindOf(BGP_GenericController) then
			if generic = null then
				create generic transient;
				self.initSortDict(generic);
			endif;	
			generic.add(controller);
		elseif controller.isKindOf(BGP_LocationStatistics) then
			if  locationStatistics = null then
				create locationStatistics transient;
				self.initSortDict(locationStatistics);
			endif;
			locationStatistics.add(controller);
		elseif controller.isKindOf(BGP_LockKeeperController) then
			if  lock = null then
				create lock transient;
				self.initSortDict(lock);
			endif;
			lock.add(controller);
		elseif controller.isKindOf(BGP_RFIDListenController) then
			if rfidListen = null then
				create rfidListen transient;
				self.initSortDict(rfidListen);
			endif;
			rfidListen.add(controller);
		elseif controller.isKindOf(BGP_ReportController) then
			if report = null then
				create report transient;
				self.initSortDict(report);
			endif;
			report.add(controller);
		elseif controller.isKindOf(BGP_TCPClient) then
			if  client = null then
				create client transient;
				self.initSortDict(client);
			endif;
			client.add(controller);
		elseif controller.isKindOf(BGP_AutoTimerController) then
			if autoTimer = null then
				create autoTimer transient;
				self.initSortDict(autoTimer);
			endif;
			autoTimer.add(controller);
		elseif controller.isKindOf(BGP_AutoWarningController) then
			if autoWarning = null then
				create autoWarning transient;
				self.initSortDict(autoWarning);
			endif;
			autoWarning.add(controller);
		elseif controller.isKindOf(BGP_DirectoryController) then
			if direct = null then
				create direct transient;
				self.initSortDict(direct);
			endif;
			direct.add(controller);
		elseif controller.isKindOf(BGP_FutureTimerController) then	// CCMS DPH 2278
			if futureTimer = null then
				create futureTimer transient;
				self.initSortDict(futureTimer);
			endif;
			futureTimer.add(controller);
		elseif controller.isKindOf(BGP_VehicleBookingSlotCont) then	//15 Apr 2013	NDL	Par 31393
			if vsBookGen = null then								
				create vsBookGen transient;						
				self.initSortDict(vsBookGen);						
			endif;														
			vsBookGen.add(controller);	//14 Aug 2013	cnwrs1	Par 32226 - The Calendar Check and Slot Booking Generator implemenations were incomplete
		elseif controller.isKindOf(BGP_DeferredChargingController) then	//06 Jul 2021	NDL	TFS 51443
			if deferredCharge = null then								
				create deferredCharge transient;						
				self.initSortDict(deferredCharge);						
			endif;														
			deferredCharge.add(controller);
		elseif controller.isKindOf(BGP_WorkOrderScheduler) then
			if workOrderScheduler = null then
				create workOrderScheduler transient;
				self.initSortDict(workOrderScheduler);
			endif;
			workOrderScheduler.add(controller);
		elseif controller.isKindOf(BGP_XMLListenController) then
			if  server = null then
				create server transient;
				self.initSortDict(server);
			endif;
			server.add(controller);
		endif;
	endforeach;
	
	self.updateControllerType(backupJournal, _cmif.isBackupJournal.Integer, BGP_BackupJournal);		
	self.updateControllerType(calendarCheck, _cmif.isCalendarCheck.Integer, BGP_CalendarCheckController);	//02 Nov 2010	NDL	Par 25530
	self.updateControllerType(change, _cmif.isChangeTracker.Integer, BGP_ChangeTrackerController);		
	self.updateControllerType(extWS, _cmif.numberOfExtWSServices.Integer, BGP_ExternalWSController);		
	self.updateControllerType(generic, _cmif.numberOfRemotes, BGP_GenericController);
	self.updateControllerType(locationStatistics, _cmif.isLocationStatistics.Integer, BGP_LocationStatistics);	
	self.updateControllerType(lock, _cmif.isLockKeeper.Integer, BGP_LockKeeperController);
	self.updateControllerType(rfidListen, _cmif.isRFIDListenController.Integer, BGP_RFIDListenController);	
	self.updateControllerType(report, _cmif.numberOfReports, BGP_ReportController);
	self.updateControllerType(client, _cmif.numberOfTcpIpClients, BGP_TCPClient);		
	self.updateControllerType(autoTimer, _cmif.isAutoTimer.Integer, BGP_AutoTimerController);
	self.updateControllerType(autoWarning, _cmif.isAutoWarning.Integer, BGP_AutoWarningController);		
	self.updateControllerType(direct, _cmif.numberOfDirectories, BGP_DirectoryController);
	self.updateControllerType(futureTimer, _cmif.isFutureTimer.Integer, BGP_FutureTimerController);	// CCMS DPH 2278
	self.updateControllerType(vsBookGen, _cmif.isVSBookGen.Integer, BGP_VehicleBookingSlotCont);	//15 Apr 2013	NLD	Par 31393
	self.updateControllerType(deferredCharge, _cmif.isDeferred.Integer, BGP_DeferredChargingController);	//06 Jul 2021	NDL	TSF 51443
	self.updateControllerType(workOrderScheduler, _cmif.isWorkOrderScheduler.Integer, BGP_WorkOrderScheduler);
	self.updateControllerType(server, _cmif.numberOfTcpIpServers, BGP_XMLListenController);
	
epilog
	delete backupJournal;
	delete calendarCheck;
	delete change;
	delete extWS;
	delete generic;
	delete locationStatistics;
	delete lock;
	delete rfidListen;
	delete report;
	delete client;
	delete autoTimer;
	delete autoWarning;			// PAR #26678
	delete direct;
	delete futureTimer;
	delete vsBookGen;
	delete deferredCharge;
	delete workOrderScheduler;
	delete server;
end;</source>
        <access>protected</access>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
    <JadeMethod name="updateControllerType" id="69a1ff37-bde6-4b8e-8dc3-2460705eb998">
        <updating/>
        <source>updateControllerType(_numberNow : DynaDictionary;  _numberRequired : Integer; _class : Class) updating, protected;

// cnwdvb1 08 July 2003 

vars

	number,
	diff, i,
	count		: Integer;
	controller	: Object;

begin

	if _numberNow &lt;&gt; null then
		number := _numberNow.size();
	endif;
	
	diff := _numberRequired - number;
	
	if diff = 0 then
	elseif diff &gt; 0 then
		foreach i in 1 to diff do
			self.createController(_class);
		endforeach;
	else
		diff := diff * -1;
		foreach controller in _numberNow do
			count := count + 1;
			if count &gt; diff then
				break;
			endif;
			delete controller;
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_numberNow" type="DynaDictionary"/>
        <Parameter name="_numberRequired" type="Integer"/>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="6098141b-279c-4025-acce-46b373fc5509">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars

	controller	: BGP_Controller;
	userStr		: String;
	description	: String;

begin
	if theObject = self then
		if eventType = BGP_Object.BGP_TerminateAppRequest then
			// TFS 41133 jlgmd1 SNO - Make it easier to see who terminated the BGP by sending the usercode through with the notification
			if userInfo &lt;&gt; null then
				userStr := userInfo.String;
			else
				userStr := app.myPassport.getUserCode;
			endif;
			
			
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' BGP_TerminateAppRequest', LogFATAL);	//25 Nov 2019	NDL	TFS 47053
			
			if app.myPassport &lt;&gt; null and app.myPassport.myUser &lt;&gt; null then //cnwrs1 17712 Aug 2008
				app.createActivityHistory(ActivityHistoryGeneral, null, self, userStr&amp;" has stopped the BGP "&amp;self.name&amp;' Manager.' , false, false);
				app.writeLog(userStr&amp;" has stopped the BGP "&amp;self.name&amp;' Manager.', LogFATAL);	//25 Nov 2019	NDL	TFS 47053
			endif;
			
			terminate;
		elseif eventType = BGP_Object.BGP_OutputInfo then
			self.doShowLogName(userInfo.Process);
		endif;
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="6106526b-a3e0-4c5a-ade3-ab916c2ada5e">
        <source>validateForDelete();

// cnwdvb1 25 October 2002 

vars

begin

	self.validateForUpdate();

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="d69ea4ac-8392-4cb3-b754-6938baef7b49">
        <source>validateForUpdate();

// cnwdvb1 25 October 2002 

vars

	iter		: Iterator;
	controller	: BGP_Controller;

begin

	if self.isRunning then
		app.raiseCMException1(BGPAppIsRunning, self.name, null, null);
	endif;
	iter := self.allBGPControllers.createIterator;
	while iter.next(controller) do
		if controller.isRunning() then
			app.raiseCMException1(BGPAppIsRunning, controller.name, null, null);
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
</Class>
