    <JadeMethod name="mnuComplete_click" id="4232038a-11e7-4f72-ac9f-a19e58c334a3">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuComplete_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	cg : CM_CargoGroup;
	theReturn : Integer;

begin

	if menuItem.userObject = null or not menuItem.userObject.isKindOf(CM_CargoGroup) then
		return;
	endif;
	
	cg := menuItem.userObject.CM_CargoGroup;
	
	
	
	while true do
	
		app.myTrxUA.trxCargoGroupComplete( cg, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Complete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
			
		endif;
		
		break;
	
	endwhile;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
