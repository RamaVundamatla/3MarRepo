    <JadeMethod name="setupForm" id="feaf6ec1-6a0d-4a34-b1d4-55c52fcd86be">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	state	:Boolean;
begin
	self.showToolbar 	:= true;
	self.toolbarStyle 	:= self.ToolbarStyle_ShowNoHide;
	
	self.frmProperties.visible	:= false;
	self.frmProperties.zOrder (1);

	inheritMethod();
	
	app.cmsBeginLoad(state);
	
	self.myAgent.setMyFormConfiguration (self.myFormConfiguration);
	self.myAgent.showForm (self, frame1);
	
	frame1.top 			:= frmToolbar.height + 1;
	frame1.left			:= 0;
	frame1.parentAspect	:= Control.ParentAspect_None;
	
	self.clientHeight	:= (frame1.top + frame1.height).Integer;
	self.clientWidth	:= frame1.width.Integer;
	
	frame1.parentAspect	:= Control.ParentAspect_StretchBoth;
epilog
	if state then
		endLoad;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showControlProperties" id="272de247-efd5-4d0f-816c-d298be120ad1">
        <updating/>
        <source>showControlProperties()updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	:Form;
begin
	if self.myPropertiesForm = null then
		form := app.loadForm(SOP_FormConfigPropertiesForm, self.myAssistant.class, false,false ,false ,self.myTerminal, null);
	
		form.setFormParent (self);
		
		self.myPropertiesForm := form.SOP_FormConfigPropertiesForm;
		
		form.show;
	endif;
	
	self.myPropertiesForm.SOP_FormConfigPropertiesForm.displaySelectedControl (self.mySelectedControl);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="17193cb6-d582-47a0-9b7c-06a7804b82b9">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin 
	if eventType = Object_Delete_Event and
		theObject = self.myPropertiesForm then
		self.myPropertiesForm := null;
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9e69ad76-3430-441a-b1b0-53dd0f18131d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009643, locale);
	folder1Sheet2.translateCaption(Xlat_0009644, locale);
	folder1Sheet3.translateCaption(Xlat_0009645, locale);
	label1.translateCaption(Xlat_0009646, locale);
	lblControl.translateCaption(Xlat_0009647, locale);
	mnuPopup.translateCaption(Xlat_0009648, locale);
	mnuPopupProperties.translateCaption(Xlat_0009649, locale);
	shtGeneral.translateCaption(Xlat_0009650, locale);
end;</source>
    </JadeMethod>
</GUIClass>
