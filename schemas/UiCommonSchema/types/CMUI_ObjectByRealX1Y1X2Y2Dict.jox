    <JadeMethod name="getMinMaxY" id="8f6bbe7a-9a02-446e-9655-aa1d2145676e">
        <lockReceiver/>
        <updating/>
        <source>getMinMaxY(_min, _max : Real output) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Real;
	z 			: Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		self.myIterator := self.createIterator();
	endif;

	while tmpIterator.next(tmpObj) do
		self.getIteratorKeys(x1, y1, x2, y2,z, tmpIterator);
		if _min = null then
			_min := y1;
		endif;
		if _max= null then
			_max:=y1;
		endif;
		_min:=_min.min(y2);
		_max:=_max.max(y2);
	endwhile;
epilog

end;</source>
        <Parameter name="_min" type="Real" usage="output"/>
        <Parameter name="_max" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getXRange" id="d9037256-854f-44f6-9577-12f90429d255">
        <source>getXRange( _x : Real; _x1, _x2 : Real output);
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Real;
	z 			: Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
		return;
	endif;
	
	tmpIterator.reset();
	
	while tmpIterator.next(tmpObj) do
		
		self.getIteratorKeys(x1, y1, x2, y2,z, tmpIterator);
		if _x &gt;= x1 and  _x &lt;= x2 then
			if x1 &lt;= 0 then
				_x1 := 1;
				_x2 := x2;
			else
				_x1 := x1;
				_x2 := x2;
			endif;
			return;
		endif;
	endwhile;
	if _x &lt;= 0 then
		_x1 := 1;
		_x2 := 1;
	else
		_x1 := _x;
		_x2 := _x;
	endif;
	
	return;
end;</source>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_x1" type="Real" usage="output"/>
        <Parameter name="_x2" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getYRange" id="0af30314-268f-4056-a63c-c0adbfa6b02d">
        <source>getYRange( _y : Real; _y1, _y2 : Real output);
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpObj		: Object;
	x1, y1,
	x2, y2		: Real;
	z 			: Integer;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
		return;
	endif;
	
	tmpIterator.reset();

	while tmpIterator.next(tmpObj) do
		
		self.getIteratorKeys(x1, y1, x2, y2,z, tmpIterator);
		if _y &gt;= y1 and  _y &lt;= y2 then

			if y1 &lt;= 0 then
				_y1 := 1;
				_y2 := y2;
			else
				_y1 := y1;
				_y2 := y2;
			endif;
			return;
		endif;
	endwhile;

	if _y &lt;= 0 then
		_y1 := 1;
		_y2 := 1;
	else
		_y1 := _y;
		_y2 := _y;
	endif;
	return;
end;</source>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_y1" type="Real" usage="output"/>
        <Parameter name="_y2" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="removeObjectsInDict" id="8b5bf2ab-4ea4-4355-a302-5149d8e3992f">
        <lockReceiver/>
        <updating/>
        <source>removeObjectsInDict( _x1, _y1, _x2,_y2 : Real) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	x1, y1, x2, y2 : Real;
	z			: Integer;
	tmpObj		: Object;
	tmpIterator	: Iterator;
begin
	tmpIterator := self.myIterator;
	
	if tmpIterator = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'myIterator = null');
	endif;


	self.startKeyGeq(_x1, 0, 0, 0,0, tmpIterator);
	
	while tmpIterator.next(tmpObj) do
		self.getIteratorKeys(x1, y1, x2, y2,z, tmpIterator);
		if x1 &gt; _x2 then
			break;
		endif;
		if _x1 &lt;= x1 and
		   _x2 &gt;= x2 and
		   _y1 &lt;= y1 and
		   _y2 &gt;= y2 then
			self.removeKeyEntry(x1, y1, x2, y2,z, tmpObj);
		endif;
	endwhile;

end;</source>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
</CollClass>
