    <JadeMethod name="keyDown" id="afb15002-b616-4545-898c-63520aea7e7f">
        <controlMethod name="Table::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		19 July 2005  By Andrew Bishop cnwab1
//
// Purpose:		
// 01 Apr 2021	cnwma1	ChangeRequest 51055: MTN - Generate quick list of selected items IDs
// 05 May 2022	cnwma1	ChangeRequest 53581: MTN - Copy Table Cell Text to Clipboard using [CTRL + C ] Key Combination
// 24 Jun 2024	navpw1	TFS: 64541 (64542) - Fixing 14051 Invalid Row Exception encountered when copying cells. Not sure why this occurs, unable to reproduce but happens a lot in customer environments
//												This error is silently handled and no error message currently displayed.
// ---------------------------------------------------------------------------

vars
	invalidRowException	: Boolean;
	
begin
	on Exception do app.handleUE14051(exception, invalidRowException);	// ### TFS 64541 (64542) 24Jun2024 NAVPW1
	
	inheritMethod(table, keyCode, shift);
	
	if keyCode = J_key_G and app.isControlKeyDown and app.isShiftKeyDown then  // ### TFS CR 66065 10SEP2024 NAVAB1
		self.doGenerateMultiSelectionColist();
		return;
	endif;

	if keyCode = J_key_G and app.isControlKeyDown then   //01.04.2021 cnwma1 #51055
		self.doGenerateMultiSelectionList();
		return;
	endif;
	
	if keyCode = J_key_C and app.isControlKeyDown then   //05.05.2021 cnwma1 #53581
		if self.accessedCell &lt;&gt; null then
			app.copyStringToClipboard(self.accessedCell.text);
		endif;
		return;
	endif;
	
epilog
	on Exception do null;	// ### TFS 64541 (64542) 24Jun2024 NAVPW1
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
