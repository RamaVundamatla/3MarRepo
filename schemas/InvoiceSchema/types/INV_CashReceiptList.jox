    <JadeMethod name="validateClose" id="7d22cf74-28df-40b5-bab0-413a633d3774">
        <source>validateClose() : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Jul 2012	cnwndl1	Initial creation	Par 29968
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars

	msg,
	text	  : String;
	decimal   : Decimal[23,6];	//21.10.2019 cnwma1 TFS #47081
	returnVal : Boolean;

begin
	if self.myQueryCashReceipt &lt;&gt; null then
		return true;
	endif;
	if self.isInvoiceProforma then
		return true;
	endif;

	text := self.txtCashPayment.text.trimBlanks;
	if text &lt;&gt; null then
		if text.isDecimal then
			decimal := text.asDecimalJMT;
			if decimal &lt;&gt; 0 then
				if msg &lt;&gt; null then
					msg := msg &amp; CrLf;
				endif;
				msg := msg &amp; "Payment Required not saved !";
			elseif self.cashRequiredToClearCharges &gt; 0 then
				if msg &lt;&gt; null then
					msg := msg &amp; CrLf;
				endif;
				msg := msg &amp; "Total Owing is greater than zero !";
			endif;
		endif;
	endif;
	
	if msg = null then
		return true;
	endif;
	
	msg := msg &amp; CrLf &amp; app.getErrorString(Want_close_anyway);
	
	returnVal := app.msgBox( msg, app.getErrorString(DoYouWantToContinue), MsgBox_Yes_No ) = MsgBox_Return_Yes;
	
	return returnVal;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
