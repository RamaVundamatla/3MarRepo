    <JadeMethod name="showSelectedPosDetails" id="e3388acc-01c9-4ebf-8bc1-15f35ae5cdbf">
        <updating/>
        <source>showSelectedPosDetails() updating;
//-----------------------------------------
// Created: May 2004 By: cnwgd1
//-----------------------------------------
vars
	pict	: HMS_GraphicalDragPicture;
begin
	
	if (not self.isReadOnly) then
		self.btnLock.value := false;	
	endif;
	
	//find selected drag pciture
	pict := self.myCurrentDragPicture;
	if pict = null then
		return;
	endif;
	
	//Show ship dimensions and wharf pointer
	pict.myCurrentWharfDrawControl.drawShipMetrics(pict);

	// adjust the pointers that are shown on the wharf and time control	
	self.myDrawTimeLabel.movePointer(true, pict.top, pict.top + pict.height);

	// Update time and position indicators
	self.showTimeAndPositionForSelected(pict.myWorkingMovement);

	// Set lock status for the voyage
	if self.myCurrentWorkingMovement &lt;&gt; null then
		if self.myCurrentWorkingMovement.myWorkingVoyage &lt;&gt; null then
		    if self.myCurrentWorkingMovement.myWorkingVoyage.voyageStatus = HMS_VoyageIsLocked then
				self.btnLock.value := true;
			endif;
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showSpritePositionDetails" id="1cff5757-232b-4f07-a63f-526f163d169b">
        <source>showSpritePositionDetails(pict : HMS_GraphicalDragPicture);
//-----------------------------------------
// Created: May 2004 By: cnwgd1
//
// Changed On	By			Reason
//-----------------------------------------
// 05/09/2023	navdap1		TFS 59472 EUP | FR 56588 Berth planning by bollards Remedial
vars
	ts,ts2			: TimeStamp;
	displayLeftRight,
	onLeft,bowLow	: Boolean;
	wharf			: HMS_Wharf;
	berth 			: HMS_Berth;
	sideTo			: Integer;
	bowMark,
	sternMark,
	leftPos,
	picTop,
	picTop2,	
	picHeight,
	timeHeight		: Decimal[12,2];
	vesselName		: String;
	bowBollard, sternBollard, bridgeBollard				: HMS_Resource;		// TFS 59472
	bowBollardMark, sternBollardMark, bridgeBollardMark,
	aftMark, foreMark, aftOffset, foreOffset			: Decimal [12,2];	// TFS 59472
	bowString, sternString, bridgeString				: String;			// TFS 59472
	aftBollard, foreBollard 							: HMS_Resource;		// TFS 59472
	
begin
	// show the description of the time and meterage position for the sprites current position
	picHeight 		:= pict.height;
	picTop 			:= pict.top;
	picTop2 		:= picTop + picHeight;
	timeHeight 		:= self.myDrawTimeLabel.scaleHeight;
	
	if self.myCurrentVoyageData &lt;&gt; null then
		vesselName := self.myCurrentVoyageData.vesselName;
	endif;

	if self.controlMoveStyle = Move_WE or 
	   self.controlMoveStyle = Move_None then 
 		// Do not update time position if the WE only or Lock buttons are on
 		ts		:= pict.myWorkingMovement.occursOnDT;
 		ts2		:= pict.myNextWorkingMovement.occursOnDT;
		lblShowTime.caption := vesselName &amp; ':  ' &amp; self.systemToLocalTime(ts).shortCurrentLocaleFormat() &amp; '  -  ' &amp; self.systemToLocalTime(ts2).shortCurrentLocaleFormat();	// 1/6/16 cnwmp6 TFS 488 - Multi timezone support
 	else
 	
 		if self.getTimeValuesForPosition(pict, ts, ts2) then
			lblShowTime.caption := vesselName &amp; ':  ' &amp; self.systemToLocalTime(ts).shortCurrentLocaleFormat() &amp; '  -  ' &amp; self.systemToLocalTime(ts2).shortCurrentLocaleFormat();	// 1/6/16 cnwmp6 TFS 488 - Multi timezone support
		else
			lblShowTime.caption := vesselName &amp; ':  ' &amp; OutOfRange_Literal;					
 		endif;

  	endif;

	// show meter information
	pict.myCurrentWharfDrawControl.getBerthBowSternMarks(pict.left, pict.vesselLengthOverall, berth, bowMark, sternMark);

	wharf := pict.myCurrentWharfDrawControl.myWharf;
	if berth &lt;&gt; null then
		lblShowBerth.caption := berth.code;
	else
		lblShowBerth.caption := null;				
	endif;
	
	onLeft	:= wharf.waterOnLeft;
	displayLeftRight := wharf.displayLeftToRight;

	bowLow := true;

	// Set default for vesselSideTo if not currently set
	if self.vesselSideTo = 0 then
		sideTo := OrientPortSideTo;
	else
		sideTo := self.vesselSideTo;
	endif;
	
	if controlMoveStyle=Move_NS or controlMoveStyle=Move_None then 
 		// Do not change posn if lock or NS movement only buttons are on
	else
		// TFS 59472 start of this bit
		bowString := bowMark.asStringJMT;
		sternString := sternMark.asStringJMT;
		if berth &lt;&gt; null then
			wharf := berth.myWharf;
			wharf.getBollardForMark(bowMark, bowBollardMark, bowBollard);
			wharf.getBollardForMark(sternMark, sternBollardMark, sternBollard);
			if bowBollard &lt;&gt; null then
				bowString := bowBollard.code &amp; "+" &amp; bowBollardMark.asStringJMT &amp; "m";
			endif;
			if sternBollard &lt;&gt; null then
				sternString := sternBollard.code &amp; "+" &amp; sternBollardMark.asStringJMT &amp; "m";
			endif;
		endif;
		// TFS 59472 end of this bit
		
		onLeft := pict.bowOnLeft;
		if onLeft and displayLeftRight then
			
			lblShowBow.caption 		:= bowString;				// TFS 59472
			lblShowStern.caption	:= sternString;				// TFS 59472
		elseif onLeft and (not displayLeftRight) then
			
			lblShowBow.caption 		:= sternString;				// TFS 59472
			lblShowStern.caption	:= bowString;				// TFS 59472
			bowLow 					:= false;
		elseif (not onLeft) and displayLeftRight then
			
			lblShowBow.caption 		:= sternString;				// TFS 59472
			lblShowStern.caption	:= bowString;				// TFS 59472
			bowLow					:= false;
		elseif (not onLeft) and (not displayLeftRight) then
			
			lblShowBow.caption 		:= bowString;				// TFS 59472
			lblShowStern.caption	:= sternString;				// TFS 59472
		endif;	
		
		// TFS 59472 show orientation
		if sideTo = OrientPortSideTo then
			self.lblShowOrient.caption := app.getErrorString(PortSideTo);
		else
			self.lblShowOrient.caption := app.getErrorString(StarboardSideTo);
		endif;
		// TFS 59472 end
	endif;

	if btnPosDetail.value then
		aftOffset := pict.myWorkingMovement.myHMSVoyageData.dist_SternToAftContainer;	// TFS 59472
		foreOffset := pict.myWorkingMovement.myHMSVoyageData.dist_BowToFwdContainer;	// TFS 59472
		if bowLow then
			//lblMetricBridge.caption     := (bowMark + pict.bridgeOffset).String;
			lblContainerAft.caption   	:= (bowMark + pict.aftContainerOffset).asStringJMT();	//#24363 18/06/2010
			lblContainerFore.caption    := (bowMark + pict.fwdContainerOffset).asStringJMT();	//#24363 18/06/2010
			// TFS 59472 start of this bit
			wharf.getBollardForMark(bowMark + foreOffset, foreMark, foreBollard);
			wharf.getBollardForMark(sternMark - aftOffset, aftMark, aftBollard);
			if aftBollard &lt;&gt; null then
				self.lblContainerAft.caption := aftBollard.code &amp; " + " &amp; aftMark.asStringJMT;
			endif;
			if foreBollard &lt;&gt; null then
				self.lblContainerFore.caption := foreBollard.code &amp; " + " &amp; foreMark.asStringJMT;
			endif;
			// TFS 59472 end of this bit
		else
			//lblMetricBridge.caption     := (sternMark - pict.bridgeOffset).String;
			lblContainerAft.caption   	:= (sternMark - pict.aftContainerOffset).asStringJMT();	//#24363 18/06/2010
			lblContainerFore.caption    := (sternMark - pict.fwdContainerOffset).asStringJMT();	//#24363 18/06/2010
			// TFS 59472 start of this bit
			wharf.getBollardForMark(sternMark - foreOffset, foreMark, foreBollard);
			wharf.getBollardForMark(bowMark + aftOffset, aftMark, aftBollard);
			if aftBollard &lt;&gt; null then
				self.lblContainerAft.caption := aftBollard.code &amp; " + " &amp; aftMark.asStringJMT;
			endif;
			if foreBollard &lt;&gt; null then
				self.lblContainerFore.caption := foreBollard.code &amp; " + " &amp; foreMark.asStringJMT;
			endif;
			// TFS 59472 end of this bit
		endif;
	endif;
	
	if self.myCurrentVoyageData &lt;&gt; null then
		// TFS 59472 more
		if berth &lt;&gt; null then
			wharf := berth.myWharf;
			if bowLow then
				wharf.getBollardForMark(bowMark + self.myCurrentVoyageData.dist_BridgeToBow, bridgeBollardMark, bridgeBollard);
			else
				wharf.getBollardForMark(sternMark - self.myCurrentVoyageData.dist_BridgeToBow, bridgeBollardMark, bridgeBollard);
			endif;
		endif;
		if bridgeBollard &lt;&gt; null then
			self.lblShowBridge.caption := bridgeBollard.code &amp; "+" &amp; bridgeBollardMark.asStringJMT &amp; "m";
		else
		// TFS 59472 end of this bit
			if bowLow then
				self.lblShowBridge.caption 	:= (bowMark + self.myCurrentVoyageData.dist_BridgeToBow).asStringJMT();	//#24363 18/06/2010				
			else
				self.lblShowBridge.caption 	:= (sternMark - self.myCurrentVoyageData.dist_BridgeToBow).asStringJMT();	//#24363 18/06/2010											
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="pict" type="HMS_GraphicalDragPicture"/>
    </JadeMethod>
    <JadeMethod name="showTidalModel" id="7582ad20-3e4c-4272-99ef-185477d1691e">
        <updating/>
        <source>showTidalModel() updating, protected;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 10/02/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
vars

begin
	if self.myTidalModelForm &lt;&gt; null then																		// PAR #33337
		self.myTidalModelForm.handleNotificationRefreshView(null, self.myCurrentWorkingMovement, null, null);	// PAR #33337
	endif;																										// PAR #33337
	
	//self.myAssistant.showHMSTidalModel(self.myCurrentWorkingMovement, self.myMasterMenuAction);												// PAR #33337
	//self.myTidalModelForm :=app.loadForm(HMS_TidalModelForm, HMS_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).HMS_TidalModelForm;
	
	self.myTidalModelForm := self.myAssistant.showHMSTidalModel(self.myCurrentWorkingMovement, self.myMasterMenuAction).HMS_TidalModelForm;		// PAR #33337
	if self.myTidalModelForm = null then																										// PAR #33337
		return;																																	// PAR #33337
	endif;																																		// PAR #33337
	self.myTidalModelForm.myWorkingMovement := self.myCurrentWorkingMovement;																	// PAR #33337
	self.myTidalModelForm.show();																												// PAR #33337

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showTidalSummary" id="c5a44f63-3a20-4a19-9862-a640f8b1da44">
        <updating/>
        <source>showTidalSummary() updating;

vars

begin

	if self.myTidalSummaryForm &lt;&gt; null then
		self.myTidalSummaryForm.applyMovementChange(self.myCurrentWorkingMovement);
		self.myTidalSummaryForm.setFocus();
		return;
	endif;
	
// cnwdad1 02/03/2005 - Changed to use non-MDI form.
//	self.myTidalSummaryForm := app.loadForm(HMS_TidalSummary, HMS_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).HMS_TidalSummary;
	self.myTidalSummaryForm := app.loadForm(HMS_TidalSummaryNonMDI, HMS_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).HMS_TidalSummary;
	if self.myTidalSummaryForm = null then
		return;
	endif;
	
	self.myTidalSummaryForm.myWorkingMovement := self.myCurrentWorkingMovement;
	self.myTidalSummaryForm.show();
end;</source>
    </JadeMethod>
    <JadeMethod name="showTidalSummaryDockBar" id="f3670c2f-38be-46e7-b2b0-4354c68f33b5">
        <updating/>
        <source>showTidalSummaryDockBar() updating;

vars

begin

	/*if (not self.dkcTidalSummary.visible) then
		self.dkbTidalSummary.setWorkingMovement(self.myCurrentWorkingMovement);
		self.dkcTidalSummary.float((self.left+self.dkcTidalSummary.width).Integer, (self.top+self.dkcTidalSummary.height).Integer, self.dkcTidalSummary.width.Integer, self.dkcTidalSummary.height.Integer);
		self.dkcTidalSummary.visible := true;
	else
		self.dkbTidalSummary.setWorkingMovement(self.myCurrentWorkingMovement);	
	endif;*/

end;</source>
    </JadeMethod>
    <JadeMethod name="showTimeAndPositionForSelected" id="0dc7269e-f845-4033-8754-4cc2f90cdb39">
        <updating/>
        <source>showTimeAndPositionForSelected(_movement : CMIF_HMS_WorkingMovement)updating, protected;
//29 Sep 2022	navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
//21 Sep 2023	navdap1	TFS 59472 EUP | FR 56588 Berth planning by bollards Remedial
vars
	str 	: String;
	loa		: Decimal[6,2];
	ts,
	ts2		:	TimeStamp;
	nextMove : CMIF_HMS_WorkingMovement;
	voyageData : HMS_VoyageData;
	bowMarkIsMinimum : Boolean;
	bollardBowCode,bollardSternCode,bollardBridgeCode: String;
	wharf : HMS_Wharf;									// TFS 59472
	cargoForeBollard, cargoAftBollard : HMS_Resource;	// TFS 59472
	cargoForeMark, cargoAftMark : Decimal [9,2];		// TFS 59472
begin

	if _movement = null then
		return;
	endif;

	voyageData := _movement.myWorkingVoyage.myHMSVoyageData;
	
	// give the current database time and meter position...
	ts := _movement.occursOnDT;
	nextMove := _movement.getMovementNext();

	if nextMove &lt;&gt; null then
		ts2 := nextMove.occursOnDT;
		lblShowTime.caption := voyageData.vesselName &amp; ':  ' &amp; self.systemToLocalTime(ts).shortCurrentLocaleFormat() &amp; '  -  ' &amp; self.systemToLocalTime(ts2).shortCurrentLocaleFormat();	// 1/6/16 cnwmp6 TFS 488 - Multi timezone support
	else
		lblShowTime.caption := voyageData.vesselName &amp; ':  ' &amp; self.systemToLocalTime(ts).shortCurrentLocaleFormat();	// 1/6/16 cnwmp6 TFS 488 - Multi timezone support
	endif;
	// START 29 Sep 2022	navsj20	TFS 54739
	if _movement.myBowBollard &lt;&gt; null then
		lblShowBow.caption := _movement.myBowBollard.code &amp; "+" &amp; _movement.bowToBollard.asStringJMT &amp; "m";
		bollardBowCode:= _movement.myBowBollard.code &amp; ' + ';
	else
		lblShowBow.caption := _movement.bowMarkTo.asStringJMT;
	endif;
	if _movement.myBridgeBollard &lt;&gt; null then
		lblShowBridge.caption := _movement.myBridgeBollard.code &amp; "+" &amp; _movement.bridgeToBollard.asStringJMT &amp; "m";
		bollardBridgeCode:= _movement.myBridgeBollard.code &amp; ' + ';
	else
		lblShowBridge.caption := _movement.getBridgeMarkTo.asStringJMT;
	endif;
	if _movement.mySternBollard &lt;&gt; null then
		lblShowStern.caption := _movement.mySternBollard.code &amp; "+" &amp; _movement.sternToBollard.asStringJMT &amp; "m";
		bollardSternCode:= _movement.mySternBollard.code &amp; ' + ';
	else
		lblShowStern.caption := _movement.sternMarkTo.asStringJMT;
	endif;
	//lblShowBow.caption 		 := bollardBowCode &amp;_movement.bowMarkTo.asStringJMT();				//#24363 18/06/2010			//26 Sep 2022	navsj20	TFS 54739
	//lblShowStern.caption 	 := bollardSternCode &amp;_movement.sternMarkTo.asStringJMT();			//#24363 18/06/2010			//26 Sep 2022	navsj20	TFS 54739
	//lblShowBridge.caption 	 := bollardBridgeCode &amp;_movement.getBridgeMarkTo().asStringJMT();	//#24363 18/06/2010			//26 Sep 2022	navsj20	TFS 54739
	// END 29 Sep 2022	navsj20	TFS 54739
	lblShowBerth.caption	 := _movement.myBerth.code;
	if _movement.bowMarkTo &lt; _movement.sternMarkTo then
		bowMarkIsMinimum := true;
	else
		bowMarkIsMinimum := false;
	endif;

	self.setCaption(voyageData.vesselName &amp; ' ' &amp; self.getViewCaption());			
	
	loa := voyageData.dim_LengthOverall;
	lblShowLoa.caption := loa.asStringJMT();	//#24363 18/06/2010
	
	// TFS 59472 stuff
	wharf := _movement.myBerth.myWharf;
	if _movement.sideTo = 0 or _movement.sideTo = OrientPortSideTo then
		self.lblShowOrient.caption := app.getErrorString(PortSideTo);
	else
		self.lblShowOrient.caption := app.getErrorString(StarboardSideTo);
	endif;
	// TFS 59472

	if self.btnPosDetail.value then
		if bowMarkIsMinimum then
			// TFS 59472 start of bow mark minimum bit
			if (bollardSternCode &lt;&gt; null or bollardBowCode &lt;&gt; null) and wharf &lt;&gt; null then
				wharf.getBollardForMark(_movement.bowMarkTo + voyageData.dist_BowToFwdContainer, cargoForeMark, cargoForeBollard);
				wharf.getBollardForMark(_movement.sternMarkTo - voyageData.dist_SternToAftContainer, cargoAftMark, cargoAftBollard);
				if cargoForeBollard &lt;&gt; null then
					self.lblContainerFore.caption := cargoForeBollard.code &amp; " + " &amp; cargoForeMark.asStringJMT;
				else
					self.lblContainerFore.caption := (_movement.bowMarkTo + voyageData.dist_BowToFwdContainer).asStringJMT;
				endif;
				if cargoAftBollard &lt;&gt; null then
					self.lblContainerAft.caption := cargoAftBollard.code &amp; " + " &amp; cargoAftMark.asStringJMT;
				else
					self.lblContainerAft.caption := (_movement.sternMarkTo - voyageData.dist_SternToAftContainer).asStringJMT;
				endif;
			else
			// TFS 59472 end of bow mark minimum bit
				lblContainerAft.caption :=	(_movement.bowMarkTo + loa - voyageData.dist_SternToAftContainer).asStringJMT();	//#24363 18/06/2010
				lblContainerFore.caption:=	(_movement.bowMarkTo + voyageData.dist_BowToFwdContainer).asStringJMT();			//#24363 18/06/2010
			endif;
		else
			// TFS 59472 start of bow mark maximum bit
			if (bollardSternCode &lt;&gt; null or bollardBowCode &lt;&gt; null) and wharf &lt;&gt; null then
				wharf.getBollardForMark(_movement.bowMarkTo - voyageData.dist_BowToFwdContainer, cargoForeMark, cargoForeBollard);
				wharf.getBollardForMark(_movement.sternMarkTo + voyageData.dist_SternToAftContainer, cargoAftMark, cargoAftBollard);
				if cargoForeBollard &lt;&gt; null then
					self.lblContainerFore.caption := cargoForeBollard.code &amp; " + " &amp; cargoForeMark.asStringJMT;
				else
					self.lblContainerFore.caption := (_movement.bowMarkTo + voyageData.dist_BowToFwdContainer).asStringJMT;
				endif;
				if cargoAftBollard &lt;&gt; null then
					self.lblContainerAft.caption := cargoAftBollard.code &amp; " + " &amp; cargoAftMark.asStringJMT;
				else
					self.lblContainerAft.caption := (_movement.sternMarkTo - voyageData.dist_SternToAftContainer).asStringJMT;
				endif;
			else
			// TFS 59472 end of bow mark maximum bit
				lblContainerAft.caption :=	(_movement.bowMarkTo - loa + voyageData.dist_SternToAftContainer).asStringJMT();	//#24363 18/06/2010
				lblContainerFore.caption:=	(_movement.bowMarkTo - voyageData.dist_BowToFwdContainer).asStringJMT();			//#24363 18/06/2010
			endif;
		endif;	
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_movement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="showToolTipsFrame" id="9f3696ca-206f-431f-bd05-de266b2065fc">
        <source>showToolTipsFrame();
// ---------------------------------------------------------------------------
// Created:     24 August 2005	cnwhjg1
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
//	theForm : HMS_ToolTipsForm;
	entTableDef 	: EntTableDef;
	entRow			: EntTableRow;
	allEntTableRows	: EntTableRowArray;
	theGroupBox		: CMUI_MultiSelectGroupBox;
	
begin
	self.frmToolTips.visible := true;
	self.frmToolTips.centreWindow();
	self.frmToolTips.backColor := self.backColor;
	
	theGroupBox := self.mulToolTips;
	theGroupBox.backColor := self.backColor;
	theGroupBox.multiSelect 	:= ListBox.MultiSelect_Extended;
	theGroupBox.availableHeading := app.getErrorString(Available_tool_tips);
	theGroupBox.selectedHeading := app.getErrorString(Selected_tool_tips);
	theGroupBox.displayOrderBtns(true, true);
	
	theGroupBox.myBaseForm	:= self;
	theGroupBox.mySelectedListBox.sorted := false;
	theGroupBox.cnEcResizeContents();
	theGroupBox.readOnly := false;
	theGroupBox.userInputEnabled := true;
	theGroupBox.formDisplayEntryMethodName := 'displayETRowHeading';
	
	entTableDef	:=	app.myController.getEntTableDef(ETDef_ToolTips);
	
	allEntTableRows	:=	entTableDef.allEntTableRows;


	theGroupBox.setAvailable(allEntTableRows, true);	
	theGroupBox.setSelected(self.allToolTipsEntArray); // pre populated from XML on user window when form opens
end;</source>
    </JadeMethod>
    <JadeMethod name="showVesselDefinCargo" id="05e9715e-0d4c-45d6-8997-84088ebccc8f">
        <source>showVesselDefinCargo()protected;
//-----------------------------------------
// Created: 6 April 2005 By: cnwgd1
//-----------------------------------------
vars
	tmpVessel : CM_Vessel;
begin

	if self.myCurrentWorkingMovement &lt;&gt; null then
		tmpVessel := self.myCurrentWorkingMovement.getMyVessel();
	endif;
	if tmpVessel &lt;&gt; null then
		self.myAssistant.showVesselDefForm(tmpVessel, self.myMasterMenuAction, (tmpVessel &lt;&gt; null and (not self.isReadOnly)));
	elseif self.myCurrentVoyageData &lt;&gt; null then
		self.myAssistant.showVoyageDefForm(self.myCurrentVoyageData.myVoyage, self.myMasterMenuAction, ((not self.isReadOnly) and self.myCurrentVoyageData.myVoyage&lt;&gt;null), false);	
	else
		self.myAssistant.showVesselDefForm(tmpVessel, self.myMasterMenuAction, (tmpVessel &lt;&gt; null and (not self.isReadOnly)));
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showVesselDefinHarbour" id="8a2ce1be-cfa6-4ae2-a3eb-2e8c51b28039">
        <source>showVesselDefinHarbour() protected;
//-----------------------------------------
// Created: April 2005 By: cnwgd1
//-----------------------------------------
vars
	tmpForm : HMS_VesselDefinitionForm;
begin
	tmpForm := app.loadForm(HMS_VesselDefinitionForm, HMS_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).HMS_VesselDefinitionForm;
	
	if tmpForm = null then
		return;
	endif;
	
	if self.myCurrentWorkingMovement &lt;&gt; null then
		tmpForm.myCurrentVessel := self.myCurrentWorkingMovement.getMyVessel();
	endif;

	tmpForm.show;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showVoyageList" id="d2f04ad3-b657-425f-a9d3-ce04f0b63f96">
        <updating/>
        <source>showVoyageList()updating, protected;
//-----------------------------------------
// Created: August 2003 By: cnwgd1
//-----------------------------------------
vars
//	voyageListView : HMS_VoyageListView;
begin
	
	if self.myVoyageList = null then
	  	self.myVoyageList := app.loadForm(HMS_VoyageListView, HMS_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).HMS_VoyageListView;
		
		if self.myVoyageList = null then
			return;
		endif;
		self.myVoyageList.setMyTerminal(self.myTerminal);
	  	self.myVoyageList.initForm(self);
	  	self.myVoyageList.show;
	else
		self.myVoyageList.setFocus();
	endif;	 
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showWharfSelector" id="ddca7add-5f05-496c-bdd9-2d583fd5c1e3">
        <source>
showWharfSelector() protected;
// --------------------------------------------------------------------------------
// Created:		02 October 2006 by cnwdad1
//
// Purpose:		Displays the Wharf selector frame.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
// 07/06/2022  navvt20 TFS53757 - maintaining Sync between msgSelectWharvesBox and SelectWharves
vars
	frameObj	: CMUI_MoveableFrame;
	
begin
	frameObj		:=	self.frmSelectWharves;
	frameObj.centreHorizontallyInParent();
	frameObj.top	:=	100;
	
	frameObj.zOrder(1);
	self.msgSelectWharves.width	:=	427;
	self.showWharfSelectorEnable(true);
	
	//navvt20 07/06/2022 TFS53757 - start
	self.msgSelectWharves.setAvailable(self.aAllAvailableWharves, true);
	self.msgSelectWharves.setSelected(self.aAllSelectedWharves);
	//navvt20 07/06/2022 TFS53757 - end
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showWharfSelectorEnable" id="69b57edb-addc-4983-acb5-b0e0134f624a">
        <source>showWharfSelectorEnable(_isEnabled:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		02 October 2006 by cnwdad1
//
// Purpose:		Enables/disables the appropriate controls depending upon whether
//				the Wharf Selector frame is enabled or disabled.
//
// Parameters:	_isEnabled - True if the Wharf selector frame is to be enabled.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.frmToolbar.enabled			:=	not _isEnabled;
	self.frmSelectWharves.visible	:=	_isEnabled;
end;</source>
        <access>protected</access>
        <Parameter name="_isEnabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showWorkingMovementForm" id="9180370d-ee5b-4da4-a373-f3639b385a94">
        <source>showWorkingMovementForm(_movement : CMIF_HMS_WorkingMovement input; _doEdit : Boolean);
