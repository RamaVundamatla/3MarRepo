    <JadeMethod name="doDelete" id="6cca9c7e-a84c-4159-9da3-58c438ae19b9">
        <source>doDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation	TFS 39140

*/

vars

	terminal : CM_Terminal;
	processTerminal : CM_ProcessTerminal;
	obj: CM_Object;

begin

	terminal := self.cmbTerminal.listObject.CM_Terminal;

	if terminal &lt;&gt; null then
		processTerminal := self.myVoyageProcess.allProcessTerminals.getAtKey( self.myVoyageProcess, terminal );
	endif;
	
	if processTerminal &lt;&gt; null then
		obj := processTerminal;
		app.myTrxDA.trxDeleteCMObject( obj, app.myPassport );
	endif;
	
	self.populateVessels( terminal );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="cc651187-9496-477e-8303-3db9c59c417c">
        <source>doUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation	39140
12 Feb  2019	cnwma1	ChangeRequest 43244: PEL1 - Container Services - Segregation in WP for Depot and Terminal
*/

vars

	terminal : CM_Terminal;
	processTerminal : CM_ProcessTerminal;
	proxy : CM_ProcessTerminal;
	load : Boolean;
	add : Boolean;
	result : Integer;
	selectedVessels : CM_VesselSet;
	wpUpdateIMSR : Boolean;

begin

	terminal := self.cmbTerminal.listObject.CM_Terminal;
	if terminal = null then
		app.msgBox( app.getErrorString(Must_select_valid_term), app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	if self.myVoyageProcess = null then
		app.msgBox( app.getErrorString(Voyage_process_selected), app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	create selectedVessels transient;
	self.mulVessels.getSelected( selectedVessels );
	
	wpUpdateIMSR := self.chkWPUpdateBerth.value;
	
	if selectedVessels.isEmpty and not wpUpdateIMSR then
		app.msgBox( app.getErrorString(No_Vessels_selected), app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	processTerminal := self.myVoyageProcess.allProcessTerminals.getAtKey( self.myVoyageProcess, terminal );
	
	if processTerminal = null then
		add := true;
		create proxy transient;
		proxy.setProxyKeys(	terminal,				//_myTerminal : CM_Terminal;
							self.myVoyageProcess,	//_myVoyageProcess : CM_VoyageProcess
							self.myDepotVoyage      //12.02.2019 cnwma1 TFS #43244
							);
	else
		app.cmsBeginLoad(load);
		proxy := processTerminal.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
	endif;
	
	proxy.setProxyData( selectedVessels, wpUpdateIMSR ,self.myDepotVoyage ,self.myVoyageProcess,terminal);  //12.02.2019 cnwma1 TFS #43244
	
	while true do
		if add then
			app.myTrxCA.trxCreateProcessTerminal( proxy, processTerminal, app.myPassport );
		else
			app.myTrxUA.trxUpdateProcessTerminal( proxy, app.myPassport );
		endif;
	
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog("Process Terminal", app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
		
	endwhile;
	
	self.populateVessels( terminal );

epilog
	delete proxy;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbDepotVoyages" id="e25e24e0-c4bb-464e-ab32-3df49a25a56c">
        <source>populateCmbDepotVoyages(_terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Feb 2019	cnwma1	ChangeRequest 43244: PEL1 - Container Services - Segregation in WP for Depot and Terminal

*/

vars
	aVoyage : CM_Voyage;
	idx     : Integer;
	processTerminal : CM_ProcessTerminal;
begin
	self.cmbDepotVoyage.clear;
	foreach aVoyage in _terminal.allVoyagesByCode discreteLock do
		idx := self.cmbDepotVoyage.addItem(aVoyage.getDisplayDetails(true));
		cmbDepotVoyage.itemObject[idx] := aVoyage;
	endforeach;
	
	self.cmbDepotVoyage.addItemAt(null,1);
	self.cmbDepotVoyage.enabled := true;
	
	if _terminal &lt;&gt; null then
		processTerminal := self.myVoyageProcess.allProcessTerminals.getAtKey( self.myVoyageProcess, _terminal );
	endif;
	if processTerminal &lt;&gt; null then
		if processTerminal.myDepotVoyage &lt;&gt; null then                           //12.02.2019 cnwma1 TFS #43244
			self.cmbDepotVoyage.listIndex := self.cmbDepotVoyage.findObject( processTerminal.myDepotVoyage );
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="populateCmbTerminals" id="e13d914d-5ba9-425b-ba6e-bdd6645941e8">
        <source>populateCmbTerminals();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2022	navma1  ChangeRequest 52510: SAL - Web Portal - Berth display in Cargo Request
31 Aug 2022	jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process

*/

vars
	term 		    : CM_Terminal;
	idx  		    : Integer;
	voyageProcess   : CM_VoyageProcess;
	processTerminal : CM_ProcessTerminal;
	cmb				: CMUI_ComboBox;
begin
	
	cmb := self.cmbTerminal;
	cmb.clear();
	
	//self.cmbTerminal.listCollection( app.myRoot.allTerminals, true, 0 );	//24.01.2022 navma1 #52510
	
	//24.01.2022 navma1 #52510
	voyageProcess := self.myVoyageProcess;
	
	if voyageProcess = null then
		return;
	endif;
	
	foreach term in app.myRoot.allTerminals do
		voyageProcess := term.getDefaultVoyageProcess();
		
		if voyageProcess = null or voyageProcess.code &lt;&gt; self.myVoyageProcess.code then
			continue;
		endif;
		
		processTerminal := voyageProcess.allProcessTerminals.getAtKey( voyageProcess, term );
		
		if processTerminal &lt;&gt; null then
			idx := cmb.addItem(term.name);
			cmb.itemObject[idx] := term;
			cmb.itemBackColor[idx] := LightGreen;
		else
			idx := cmb.addItem(term.name);
			cmb.itemObject[idx] := term;
		endif;
		
	endforeach;
	//24.01.2022 navma1 #52510
	
	self.populateVessels( null );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateVessels" id="91a2598d-84cb-4411-a9a9-0899fa3a6548">
        <source>populateVessels( _terminal : CM_Terminal );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation	TFS 39140
12 Feb  2019	cnwma1	ChangeRequest 43244: PEL1 - Container Services - Segregation in WP for Depot and Terminal
*/

vars

	allAvailableVessels : ObjectSet;
	vessel : CM_Vessel;
	processTerminal : CM_ProcessTerminal;

begin

	
	if _terminal &lt;&gt; null then
		processTerminal := self.myVoyageProcess.allProcessTerminals.getAtKey( self.myVoyageProcess, _terminal );
	endif;

	self.mulVessels.multiClear();
	self.mulVessels.myAvailableListBox.sorted := true;
	self.mulVessels.mySelectedListBox.sorted := true;
	self.mulVessels.availableHeading := app.getErrorString(Available_vessels);
	self.mulVessels.selectedHeading  := app.getErrorString(Selected_vessels);
	self.mulVessels.formDisplayEntryMethodName := SOP_ProcessTerminalForm::vesselDisplayName.name;

	self.btnUpdate.visible := _terminal &lt;&gt; null;
	self.btnUpdate.enabled := allowUpdate and _terminal &lt;&gt; null;
	
	create allAvailableVessels transient;
	
	foreach vessel in app.myRoot.allVessels discreteLock do
		if not vessel.canCreateVoyages then
			continue;
		endif;		
		allAvailableVessels.add( vessel);
	endforeach;
	
	self.mulVessels.setAvailable( allAvailableVessels, true );	
	if processTerminal &lt;&gt; null then	
		self.mulVessels.setSelected( processTerminal.allVessels );
		self.btnDelete.visible := true;
		self.btnDelete.enabled := allowUpdate;
		self.chkWPUpdateBerth.value := processTerminal.allowUpdateOfIMSRBerth;	//15 Oct 2018	NDL	TFS 41404
		if processTerminal.myDepotVoyage &lt;&gt; null then                           //12.02.2019 cnwma1 TFS #43244
			self.cmbDepotVoyage.listIndex := self.cmbDepotVoyage.findObject( processTerminal.myDepotVoyage );
		endif;
	else
		self.btnDelete.visible := false;
		self.btnDelete.enabled := false;
		self.chkWPUpdateBerth.value := false;	//15 Oct 2018	NDL	TFS 41404
	
	endif;
	
	
	
epilog

	delete allAvailableVessels;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
