    <JadeMethod name="helperHmsTransactionMaps" id="afd392a9-cf6d-43b4-8f60-f2d86fce7e4c">
        <source>helperHmsTransactionMaps(_tmType, _test , _subTest : String):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2022		navma1	Initial creation
// ### TFS CR 65336 TASK 65339 09AUG2024 NAVAB1 added new columns to tran map CSV 

*/

vars
	str 		: String;
	fileContent : String;
	header		: String;
	fileName	: String;
	mapName		: String;
	hmsMap		: CM_TranMapVoyage;
	bank		: CM_Bank;
begin
	fileName 	:= UT_DSL.TFS52580;
	mapName 	:= UT_DSL.TFS52580;
	bank 		:= self.getTerminal.getDefaultCompanyBank;
	
	if _tmType = 'HMS' then
		header := 'TranMap Type,TranMap Name,Resource,Debtor,Quantity Type,Quantity Range,In Contract,Cargo Type,Sub Type, Commodity,Vessel Category,Transfer Type,Invoice Line' &amp; CrLf ;
		if _test = UT_DSL.TFS52580 then
			fileContent := header &amp;
					'Voyage,'&amp;_test&amp;',(Default),(Default),(Default) ›,(Default),X,(Default),(Default),(Default),,,VOID' &amp; CrLf &amp;
					'Voyage,'&amp;_test&amp;',(Default),(Default),(Default) ›,(Default),,(Default),(Default),(Default),,,VOID' &amp; CrLf &amp;
					'Voyage,'&amp;_test&amp;','&amp; UT_DSL.TFS52580&amp;',(Default),(Default) ›,(Default),X,(Default),(Default),(Default),,,'&amp; UT_DSL.TFS52580 &amp; CrLf &amp;
					'Voyage,'&amp;_test&amp;','&amp; UT_DSL.TFS52580&amp;',(Default),(Default) ›,(Default),,(Default),(Default),(Default),,,'&amp; UT_DSL.TFS52580 &amp; CrLf;
		else
			return null;
		endif;
	elseif _tmType = 'CARGO' then
		
		
	endif;
	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	hmsMap := bank.allJMHTMs[mapName];
	self.assertNotNullMsg(hmsMap, UT_DSL.TFS52580 &amp; "map should not be null");

	app.myTrxUA.trxUpdateBankTMVActive(hmsMap,app.myPassport);
	
	
epilog

end;</source>
        <Parameter name="_tmType" type="String"/>
        <Parameter name="_test" type="String"/>
        <Parameter name="_subTest" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="rail_ClearRake" id="ee856fd6-4da3-4831-b6a1-3c6956618a61">
        <source>rail_ClearRake(_train : CM_Train; _wagon : CM_Wagon; _clearAll : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	cmifRakeRegion : CMIF_RakeRegion;
	
begin
	self.assertNotNullMsg(_train, method.name &amp; " | train");
	self.assertNotNullMsg(_wagon, method.name &amp; " | wagon");
	
	create cmifRakeRegion transient;	
	cmifRakeRegion.myTrain := _train;
	cmifRakeRegion.allWagons.add(_wagon);
	cmifRakeRegion.clearAll	:= false;
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateRailClearRake(cmifRakeRegion, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNoTrxErrorsOrWarnings();
	
	//Maybe assert rake is empty
	
epilog
	delete cmifRakeRegion;
	
end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_clearAll" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rail_ConfirmTrainOut" id="5d343284-2f3c-456d-b987-12a882861d2f">
        <source>rail_ConfirmTrainOut(_train : CM_Train io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	wagon : CM_Wagon;
	wagonSet : CM_WagonSet;
	
begin
	self.assertNotNullMsg(_train, method.name &amp; " | train");
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, _train, false, app.myPassport);  //iout
	self.assertNoTrxErrorsOrWarnings();
	
	create wagonSet transient;
	_train.allWagonsByIdInward.copyNoDuplicates(wagonSet, false);
	_train.allWagonsByIdOutward.copyNoDuplicates(wagonSet, false);
	
	foreach wagon in wagonSet do
		self.assertTrueMsg(wagon.confirmed, method.name &amp; " | Wagon: '" &amp; wagon.id &amp; "' is not confirmed inwards");
		self.assertTrueMsg(wagon.confirmedOutwards, method.name &amp; " | Wagon: '" &amp; wagon.id &amp; "' is not confirmed outwards");
	endforeach;
	
epilog
	delete wagonSet;
	
end;</source>
        <Parameter name="_train" type="CM_Train" usage="io"/>
    </JadeMethod>
    <JadeMethod name="rail_MoveWLEWithNoAssert" id="e9a447ff-725d-4b34-bb31-a53e0c1df018">
        <source>rail_MoveWLEWithNoAssert(_railJob : CM_RailJob);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

begin
	self.assertNotNullMsg(_railJob, method.name &amp; " | railJob");
	self.assertTrueMsg(_railJob.workListEntries.isNotEmpty, method.name &amp; " | railJob work list entries is null");
	
	self.moveWLEWithNoAssert(_railJob.workListEntries.first);
    self.assertNoTrxErrorsOrWarnings();
	
	//maybe check/assert wle was moved
	
end;</source>
        <Parameter name="_railJob" type="CM_RailJob"/>
    </JadeMethod>
    <JadeMethod name="rail_RailJobWLEsDoMove" id="3409dd27-8efb-45cc-9e4d-08c85d20ed4b">
        <source>rail_RailJobWLEsDoMove(_railJob : CM_RailJob; _ti : CM_TrackedItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	wleArray,
	wlesWithWarnings : CM_WLEArray;
	wle : CM_WorkListEntry;
	
begin
	self.assertNotNullMsg(_railJob, method.name &amp; " | railJob");
	
	create wleArray transient;
	create wlesWithWarnings transient;
	wle := _railJob.workListEntries.first;
	beginTransaction;
	wle.setMyTrackedItem(_ti);
	commitTransaction;
	wleArray.add(wle);
	
	app.myTrxUA.trxUpdateWLEsDoMove(wleArray, wlesWithWarnings, QUEUE_MODE, false, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete wleArray;
	delete wlesWithWarnings;
end;</source>
        <Parameter name="_railJob" type="CM_RailJob"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="rail_TrainDeparture" id="a1668b21-9ce6-43a1-b771-bcdf83b1b05d">
        <source>rail_TrainDeparture(_train : CM_Train);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	trainSet : CM_TrainSet;
	
begin
	self.assertNotNullMsg(_train, method.name &amp; " | train");
	
	create trainSet transient;  
	trainSet.add(_train);
	
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);  
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertNoTrxErrorsOrWarnings();
	
	//maybe check/assert train has departed
	
epilog
	delete trainSet;
	
end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="xAddHmsMovementResource" id="aea55906-aa89-44b3-b4ed-42dc27090d59">
        <source>xAddHmsMovementResource(_voyage 		: CM_Voyage;
						_moveType		: String;
						_resource		: String;
						_resourceType   : String;
						_unitUsed		: Real;
						_fromDateTime,
						_toDateTime		: TimeStamp);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2022		navma1	Initial creation

*/

vars
	movement		: HMS_VoyageMovement;
	pxyResourceUsed : HMS_ResourceUsed;
	proxyMovement	: HMS_VoyageMovement;
	harbour			: HMS_Harbour;
	resourceType	: HMS_ResourceType;
	resource		: HMS_Resource;
begin
	
	
	if _moveType = HMSMovementTypeArrival then
		movement := _voyage.getMovementArrival();
	elseif _moveType = HMSMovementTypeShift then
		movement := _voyage.getMovementShift(1);	
	elseif _moveType = HMSMovementTypeDeparture then
		movement := _voyage.getMovementDeparture();
	endif;
	
	harbour 		:= movement.myHarbour;
	resource	 	:= harbour.allResources[_resource];
	resourceType	:= app.myRoot.allResourceTypes[_resourceType];
	
	create pxyResourceUsed transient;
	pxyResourceUsed.setProxy(harbour,
							 resourceType, 
							 resource,
							 null, 
							 _fromDateTime, 
							 _toDateTime, 
							 _unitUsed, 
							 false,
							 null,
							 null);
							 
	create proxyMovement transient;
	pxyResourceUsed.setPropertyValue("myVoyageMovement", proxyMovement);

	app.myTrxUA.trxAddHMSResourceUsed(pxyResourceUsed, movement, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	
epilog
	delete pxyResourceUsed;
	delete proxyMovement;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_moveType" type="String"/>
        <Parameter name="_resource" type="String"/>
        <Parameter name="_resourceType" type="String"/>
        <Parameter name="_unitUsed" type="Real"/>
        <Parameter name="_fromDateTime" type="TimeStamp"/>
        <Parameter name="_toDateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="xArriveTrain" id="3f168900-2bb5-41f3-8680-2aa419e6a185">
        <source>xArriveTrain(_train : CM_Train io);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	pxyTrain	: CM_Train;
	ts			: TimeStamp;
	
begin
	self.assertNotNullMsg(_train, method.name &amp; " | train");
	
	ts := app.actualTimeServer;
	
	pxyTrain := app.createUpdateProxy(_train).CM_Train;
	pxyTrain.setProxyDetails(ts);
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Update Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(_train.arrivalDT = ts,  method.name &amp; " | Train Arrival Date Time: Expected: " &amp; ts.String &amp; " | Actual: " &amp; _train.arrivalDT.String);
	
epilog
	delete pxyTrain;
	
end;</source>
        <Parameter name="_train" type="CM_Train" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xAssignReleasesToOutwardRail" id="90c366b0-a493-4882-802a-b9ebf9b6c478">
        <source>xAssignReleasesToOutwardRail(_releaseRequest : CM_BulkRelease io; _railIORake : CM_RailJSInOutRake);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	cmifObjects 		: ObjectArray;
	intFaceBP			: CMIF_BuildPriority;
	cmifRequest			: CMIF_Request;
	obj					: Object;
	
begin
	self.assertNotNullMsg(_releaseRequest, method.name &amp; " | releaseRequest");
	self.assertNotNullMsg(_railIORake, method.name &amp; " | railIORake");
	
	create cmifObjects transient;
	create intFaceBP transient;
	
	cmifObjects.add(intFaceBP);
	
	intFaceBP.mode := 1;
	
	_releaseRequest.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	_releaseRequest.setInterfaceBP(intFaceBP, _railIORake);
	
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNullMsg(cmifRequest, method.name &amp; " | cmifRequest");
	
	if cmifRequest.myReserveDetail.myReserveHeader.releaseByType then
		cmifRequest.quantityTxt := cmifRequest.myReserveDetail.totalRequested;
	endif;
	
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, _railIORake, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	if cmifObjects &lt;&gt; null then
		foreach obj in cmifObjects do
			intFaceBP := obj.CMIF_BuildPriority;
			
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
			
		endforeach;
		cmifObjects.purge;
	endif;
	
	delete cmifObjects;
	
end;</source>
        <Parameter name="_releaseRequest" type="CM_BulkRelease" usage="io"/>
        <Parameter name="_railIORake" type="CM_RailJSInOutRake"/>
    </JadeMethod>
    <JadeMethod name="xAssignReleasesToWagons" id="4d9fe3c1-1bdf-4141-9ede-387fb37b0162">
        <source>xAssignReleasesToWagons(_railIORake : CM_RailJSInOutRake; _railJob : CM_RailJob; _wagon : CM_Wagon);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	allRailJobsArray	: CM_RailJobArray;
	wleArray,
	wlesWithWarnings,
	allWleArray			: CM_WLEArray;
	agent				: CM_RailProcessingAgent;
	wagonArray			: CM_WagonArray;
	
begin
	self.assertNotNullMsg(_railIORake, method.name &amp; " | railIORake");
	self.assertNotNullMsg(_railJob, method.name &amp; " | railJob");
	self.assertNotNullMsg(_wagon, method.name &amp; " | wagon");
	
	// get the rail jobs
	create wleArray transient;
	create agent transient;
	create wagonArray transient; 
	
    wagonArray.add(_wagon);
    wleArray.add(_railJob.workListEntries.first);
	
    agent.initialise(self.getTerminal);
    agent.doAssignReleasesToWagons(wleArray, wagonArray, false, true);
    
epilog
	delete wleArray;
	delete agent;
	delete wagonArray;
	
end;</source>
        <Parameter name="_railIORake" type="CM_RailJSInOutRake"/>
        <Parameter name="_railJob" type="CM_RailJob"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="xConfirmTrainIn" id="05cd41d5-f2cb-44b2-80a3-bda89b9fa469">
        <source>xConfirmTrainIn(_train : CM_Train io);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	wagon : CM_Wagon;
	
begin
	self.assertNotNullMsg(_train, method.name &amp; " | train");
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, _train, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertNoTrxErrorsOrWarnings();
	
	foreach wagon in _train.allWagonsByIdInward do
		self.assertTrueMsg(wagon.confirmed,  method.name &amp; " | Wagon Id: " &amp; wagon.id &amp; " Confirmed In: Expected: true | Actual: " &amp; wagon.confirmed.String);
	endforeach;
	
end;</source>
        <Parameter name="_train" type="CM_Train" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xCreateBOL" id="4f26400f-deec-4fe4-8885-edc5c9ae0748">
        <source>xCreateBOL(_bolNumber : String; _voyage : CM_Voyage; _operator : CM_Operator; _notifyParty : String; _terminal : CM_Terminal): CM_BOL;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2023	navpw1	Initial creation TFS: 61364 (61375)

*/

vars
	realBOL	: CM_BOL;
	pxyBOL : CM_BOLIn;
	pxyBOLItem : CM_BOLDtl;
	subTerminal : CM_SubTerminal;
	commodity,
	colour,
	mark: String;
	numItems,
	numbItems,
	volume,
	weight,
	length,
	width,
	height : Integer;
	
begin
	// get the subterminal
	if app.isSubTerminalsOn(self.getTerminal) and not self.getTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		subTerminal := self.getSubTerminal(null);								// 29/04/2014 cnwmh5	
		self.assertNotNull(subTerminal);
	endif;

	numItems := 5;
	if self.opts.includesKey(UT_OPTS_NumItems) then
		numItems := self.opts.int(UT_OPTS_NumItems);
	endif;
	
	create pxyBOL transient;	
	pxyBOL.setProxy(_bolNumber, _voyage, _operator, _notifyParty, numItems, BOLType_GeneralBillOfLading, _terminal, subTerminal, null, null, null, false, null, null, null,
																																							null); //13/07/2022 navgm20 Tfs 54095
	
	commodity := "APPL";
	if self.opts.includesKey(UT_OPTS_Commodity) then
		commodity := self.opts.str(UT_OPTS_Commodity);
	endif;
	
	colour := "colour";
	if self.opts.includesKey(UT_OPTS_Colour) then
		colour := self.opts.str(UT_OPTS_Colour);
	endif;
	
	mark := "mark";
	if self.opts.includesKey(UT_OPTS_Mark) then
		mark := self.opts.str(UT_OPTS_Mark);
	endif;
	
	numbItems := 30;
	if self.opts.includesKey(UT_OPTS_NumbItems) then
		numbItems := self.opts.int(UT_OPTS_NumbItems);
	endif;
	
	volume := 5;
	if self.opts.includesKey(UT_OPTS_Volume) then
		volume := self.opts.int(UT_OPTS_Volume);
	endif;
	
	weight := 6000;
	if self.opts.includesKey(UT_OPTS_Weight) then
		weight := self.opts.int(UT_OPTS_Weight);
	endif;
	
	length := 200;
	if self.opts.includesKey(UT_OPTS_Length) then
		length := self.opts.int(UT_OPTS_Length);
	endif;
	
	width := 200;
	if self.opts.includesKey(UT_OPTS_Width) then
		width := self.opts.int(UT_OPTS_Width);
	endif;
	
	height := 400;
	if self.opts.includesKey(UT_OPTS_Height) then
		height := self.opts.int(UT_OPTS_Height);
	endif;
	
	create pxyBOLItem transient;
	pxyBOLItem.setProxy(pxyBOL, TI_CargoType_Container, commodity, colour, mark, numbItems, volume, weight, length, width, height, "ACDG", "ACDG", "remarks");
	pxyBOL.allBOLDtls.add(pxyBOLItem);
	
	app.myTrxCA.trxCreateBOL(pxyBOL, realBOL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return realBOL;
	
epilog
	delete pxyBOL;
	
end;</source>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_notifyParty" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="xCreateBooking" id="6731d958-7fec-4d78-8883-764b7931155f">
        <source>xCreateBooking(_pxyBooking : CM_BookingRef input) : CM_BookingRef;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2023	navpw1	Initial creation TFS: 57616 (57435)

*/

vars
	realBooking : CM_BookingRef;
	realBulkRelease : CM_BulkRelease;
	
begin
	app.myTrxCA.trxCreateBookingBulkRel(_pxyBooking, realBooking, realBulkRelease, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return realBooking;
	
end;</source>
        <Parameter name="_pxyBooking" type="CM_BookingRef" usage="input"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="xCreateCarrier" id="3a5c7f63-a41d-46fc-a4d9-7393abefbf9e">
        <source>xCreateCarrier(_code, 
				_description			: String;
				_pinEmailAddresses		: CM_EmailEntityByTypeNameDict;
				_isNotAvailableForEntry, 
				_isRail,
				_isRoad					: Boolean; 
				_debtor					: CM_Debtor) : CM_Carrier;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navpw1	Initial creation TFS: 54049 (55844)

*/

vars
	pxyCarrier,
	newCarrier	: CM_Carrier;
	
begin
	self.assertTrueMsg(_code &lt;&gt; null, method.name &amp; " | code is null");
	self.assertNotNullMsg(_description &lt;&gt; null, method.name &amp; " | description");
	
	create pxyCarrier transient;
	
	pxyCarrier.setProxy(_code, _description, _pinEmailAddresses, _isNotAvailableForEntry, _isRail, _isRoad, false, _debtor, null, null, null);

	app.myTrxCA.trxCreateCarrier(pxyCarrier, newCarrier, app.myPassport);

	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(newCarrier, method.name &amp; " | newCarrier");

	return newCarrier;
	
epilog
	delete pxyCarrier;
	
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_pinEmailAddresses" type="CM_EmailEntityByTypeNameDict"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_isRail" type="Boolean"/>
        <Parameter name="_isRoad" type="Boolean"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="xCreateDriverDetails" id="c58c6301-e904-45a8-997a-8fd3647011ee">
        <source>xCreateDriverDetails(_driverCode : String; _terminal : CM_Terminal; _allCarriers : CM_CarrierByCodeDict; _allVehicleMachines : CM_VehicleSet) : CM_DriverDetails;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 August 2023	navpw1	Initial creation TFS: 56796

*/

vars
	pxyDriverDetails	: CM_DriverDetails;
	newDriverDetails	: CM_DriverDetails;
	driverName			: String;
	
begin
	self.assertTrueMsg(_driverCode &lt;&gt; null, method.name &amp; " | driverCode is null");
	self.assertNotNullMsg(_terminal, method.name &amp; " | terminal");
	self.assertNotNullMsg(_allCarriers, method.name &amp; " | allCarriers");
	self.assertNotNullMsg(_allVehicleMachines, method.name &amp; " | _allVehicleMachines");
	
	driverName := _driverCode;
	if self.opts.includesKey(UT_OPTS_DriverName) then
		driverName := self.opts.str(UT_OPTS_DriverName);
	endif;
	
	create pxyDriverDetails transient;
	pxyDriverDetails.setProxy(driverName, _driverCode, null, CM_DriverDetails.Status_Allowed, null, _terminal, _allCarriers, _allVehicleMachines);
	
	app.myTrxCA.trxCreateDriverDetails(pxyDriverDetails, newDriverDetails, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
 	self.assertNotNullMsg(newDriverDetails, method.name &amp; " | newDriverDetails");
	
	return newDriverDetails;
	
epilog
	delete pxyDriverDetails;

end;</source>
        <Parameter name="_driverCode" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_allCarriers" type="CM_CarrierByCodeDict"/>
        <Parameter name="_allVehicleMachines" type="CM_VehicleSet"/>
        <ReturnType type="CM_DriverDetails"/>
    </JadeMethod>
    <JadeMethod name="xCreateGateEntity" id="07285de8-6db5-4ebc-9aee-eac4104dcc77">
        <source>xCreateGateEntity(_vvr : CM_VehicleVisitRecord io; 
					_cargoTypeCode, _containerID : String; _isoCode: String; _operatorCode: String; _commodity: String): CM_VehicleVisitRecord;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navpw1	Initial creation TFS: 54049 (55844)

*/

vars
	pxyVVR			: CM_VehicleVisitRecord; 
	gateEntity		: CMGTE_Entity;
	expectErrors	: Boolean;
	
begin
	expectErrors := self.opts.bool("ExpectErrors");
	
	gateEntity := self.createGateEntity(_vvr, _cargoTypeCode, _containerID, _isoCode, _operatorCode, _commodity, 1);
	if expectErrors and  app.myPassport.hasErrors then
		return _vvr;
	endif;
	
	// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(_vvr).CM_VehicleVisitRecord;
	
	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, _vvr, null, app.myPassport);
	
	if expectErrors then
		return _vvr;
	endif;
	
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIsForTxnOfType(_vvr.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);
	
	return _vvr;
	
epilog
	delete pxyVVR;
	
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="io"/>
        <Parameter name="_cargoTypeCode" type="String"/>
        <Parameter name="_containerID" type="String"/>
        <Parameter name="_isoCode" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="xCreateGateEntityOutRelease" id="798dc8bc-2363-40ad-bcd1-d5f944a420b0">
        <source>xCreateGateEntityOutRelease(_vvr 	: CM_VehicleVisitRecord input; 
						_cargo	: CM_TrackedItem;
						_taId 	: String;
						_qty  	: Integer;
						_release : CM_BulkRelease): CM_VehicleVisitRecord;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 July 2023		navpw1	Initial creation
12 September 2024	navpw1	TFS: 65623 (65624) - Added support for ANy Id Any Amount
20 Dec 2024	navhl20 Bug MTN-33681: MTN - Unexpected Program error on the Road Gate form
11 Jul 2025	navhl20 Bug MTN-35305: MTN - Optimize Saving Road Jobs to Avoid Redundant Yard Allocation Checks
*/

vars
	pxyVVR, 
	vvr		   		: CM_VehicleVisitRecord; 
	controller 		: CMIF_FlexiGateController;
	pxyGateEntity, 
	gateEntity	    : CMGTE_Entity;
	subTerm 		: CM_SubTerminal;
	allTis			: CM_TISet;
	reserve,
	detail			: CM_ReserveDetail;
	isAnyId,
	isAnyAmount,
	isAllLine,
	assertChecks,
	ignoreWarnings	: Boolean;
	
begin
	create allTis transient;  //23/06/2023	navkc1	CR 58406 Task 58408
	
	// Create the GTE Entity and add to VVR
	
	if self.opts.includesKey("both") then																//20.12.2024 navhl20 #33681
		isAllLine := self.opts.bool("both");
	endif;
	
	// ### JIRA: MTN-36370 17Nov2025 NAVPW1
	if self.opts.includesKey(UT_OPTS_AssertChecks) then
		assertChecks := self.opts.bool(UT_OPTS_AssertChecks);
	else
		assertChecks := true;
	endif;
	
	if self.opts.includesKey(UT_OPTS_IgnoreTrxWarning) then
		ignoreWarnings := self.opts.bool(UT_OPTS_IgnoreTrxWarning);
	else
		ignoreWarnings := true;
	endif;
	// ### JIRA: MTN-36370 17Nov2025 NAVPW1
	
	detail := _release.allReserveDetails.first;
	
	foreach reserve in _release.allReserveDetails where (not isAllLine and detail = reserve) or isAllLine do			//20.12.2024 navhl20 #33681
		create controller transient;
		create pxyGateEntity as CMGTE_Release transient;
		
		controller.myTerminal 	 	 	 := self.getTerminal();
		controller.jobType 	  	     	 := CMGTE_Entity.JobType_GeneralOUT; 
		controller.numItems   	     	 := _qty;
		controller.myBulkRelease     	 := _release;
		controller.myReserveDetail 	 	 := reserve;
		controller.operatorCode      	 := _release.myOperator.code;
		controller.cargoType 	     	 := reserve.CM_ReserveSelection.myCargoType.id;
		controller.myProduct 			 := reserve.CM_ReserveSelection.myProduct;
		controller.myVehicleVisitRecord  := _vvr;
		controller.yardLocationTxt 		 :=  _taId;
		if reserve.CM_ReserveSelection.myCargoType.id = TI_CargoType_Container then										//11.07.2025 navhl20 #35305
			controller.isoTypeCode := reserve.CM_ReserveSelection.myISOType.code;
		endif;
		
		if app.isSubTerminalsOn(self.getTerminal) then
			subTerm :=  self.getTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BulkRelease,
																BR_TYPE_ROAD,
																0,
																null,
																false);
			if subTerm &lt;&gt; null then
				controller.subTerminalCode := subTerm.code;
			endif;
		endif;
		
		if self.opts.includesKey(UT_OPTS_Weight) then
			controller.weight := self.opts.dec(UT_OPTS_Weight);
			controller.releaseWeight := self.opts.dec(UT_OPTS_Weight);
		endif;
		
		// ### JIRA: MTN-36370 17Nov2025 NAVPW1
		if self.opts.includesKey(UT_OPTS_IsMT) then
			controller.mtOnly := self.opts.bool(UT_OPTS_IsMT);
		endif;
		
		if self.opts.includesKey(UT_OPTS_BestPick) then
			controller.doISOGroupCheck := self.opts.bool(UT_OPTS_BestPick);
		endif;
		
		if self.opts.includesKey(UT_OPTS_Consignee) then
			controller.consigneeCode := self.opts.str(UT_OPTS_Consignee);
		endif;
		// ### JIRA: MTN-36370 17Nov2025 NAVPW1
		
		pxyGateEntity.CMGTE_Release.setPXYFromBulkRelease(_release, reserve);
		pxyGateEntity.setPXYFromController(controller); 
		pxyGateEntity.CMGTE_Release.setIsReleaseById(false);
		
		isAnyId := self.opts.bool(UT_OPTS_IsAnyId);
		isAnyAmount := self.opts.bool(UT_OPTS_IsAnyAmount);
		
		if _release &lt;&gt; null then 
			if isAnyId then
				pxyGateEntity.CMGTE_Release.setIsAnyId(isAnyId);
				if _release.myOperator &lt;&gt; null then
					pxyGateEntity.setOperator(_release.myOperator.code);
				endif;
				pxyGateEntity.CMGTE_Release.setIsAnyAmount(isAnyAmount);
			endif;
		endif;
		
		if self.opts.includesKey(UT_OPTS_Vbsti) then
			pxyGateEntity.CMGTE_Release.setVbsti(self.opts.obj(UT_OPTS_Vbsti).CM_VehicleBookingTimeSlotItem);
		endif;
		self.ignoreTrxWarnings(ignoreWarnings);
		app.myTrxCA.trxCreateInOutFlexiGateEntity(_vvr, pxyGateEntity, gateEntity, app.myPassport);
		if assertChecks then
			self.assertNoTrxErrorsOrWarnings();
			
		elseif app.myPassport.hasErrorsOrWarnings then
			return _vvr;
			
		endif;
		delete pxyVVR;
		delete pxyGateEntity;
		delete controller;
	endforeach;
	// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(_vvr).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(ignoreWarnings);
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vvr, null,app.myPassport);
	if assertChecks then
		self.assertNoTrxErrorsOrWarnings();
		
	elseif app.myPassport.hasErrorsOrWarnings then
			return vvr;
			
	endif;
	return vvr;
	
epilog
	delete pxyVVR;
	delete allTis;
	
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_taId" type="String"/>
        <Parameter name="_qty" type="Integer"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="xCreateGateEntityRelTemp" id="4aae1e9c-dcfb-440b-ac78-f68ab0f74b80">
        <source>xCreateGateEntityRelTemp(_vvr : CM_VehicleVisitRecord io; 
					_cargoTypeCode, _containerID : String; _isoCode: String; _operatorCode: String; _commodity: String): CM_VehicleVisitRecord;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 July 2024	navpw1	Initial creation TFS: 61525 (61527)

*/

vars
	pxyVVR			: CM_VehicleVisitRecord; 
	gateEntity		: CMGTE_Entity;
	expectErrors	: Boolean;
	
begin
	expectErrors := self.opts.bool("ExpectErrors");
	
	gateEntity := self.xCreateGateEntityTemp(_vvr, _cargoTypeCode, _containerID, _isoCode, _operatorCode, _commodity, 1);
	if expectErrors and  app.myPassport.hasErrors then
		return _vvr;
	endif;
	
	// Complete the Gate In - Road job is created
	pxyVVR := app.createUpdateProxy(_vvr).CM_VehicleVisitRecord;
	
	self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, _vvr, null, app.myPassport);
	
	if expectErrors then
		return _vvr;
	endif;
	
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIsForTxnOfType(_vvr.allReceivedTrackedItems, TRANS_TYPE_REC_ROAD);
	
	return _vvr;
	
epilog
	delete pxyVVR;
	
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="io"/>
        <Parameter name="_cargoTypeCode" type="String"/>
        <Parameter name="_containerID" type="String"/>
        <Parameter name="_isoCode" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="xCreateGateEntityTemp" id="13b23090-9184-4e51-9ed5-88a08f0aad87">
        <source>xCreateGateEntityTemp(_vvr: CM_VehicleVisitRecord input; _cargoType: String; _containerID: String; _isoCode: String; _operatorCode: String; _commodity: String; _totalQuantity: Integer): CMGTE_Entity;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 July 2024	navpw1	Initial creation TFS: 61525 (61527)

*/

//TO BE MERGED WITH xCreateGateEntityOutRelease
vars
	controller : CMIF_FlexiGateController;
	pxyAttachment, pxyGateEntity, gateEntity: CMGTE_Entity;
	attachment: String;
	overDim: String;
	cargoType: CM_CargoType;
	subType			: CM_Product;
	expectErrors : Boolean;
	hazard			: CM_TIHazard;
	preNote : CM_TrackedItem;
	bulkRelease	: CM_BulkRelease;
	reserveDetail	: CM_ReserveDetail;
	relReqValInt	: Integer;
	msg,
	reason			: String;
	isAnyId,
	isAnyAmount		: Boolean;
	
begin

	expectErrors := self.opts.bool("ExpectErrors");
	
	if self.opts.includesKey(UT_OPTS_ReleaseRequest) then
		bulkRelease := self.opts.obj(UT_OPTS_ReleaseRequest).CM_BulkRelease;
	endif;
	
	if self.opts.includesKey(UT_OPTS_ReserveDetail) then
		reserveDetail := self.opts.obj(UT_OPTS_ReserveDetail).CM_ReserveDetail;
	endif;
	
	if _containerID &lt;&gt; null or (bulkRelease &lt;&gt; null or reserveDetail &lt;&gt; null) then
		//13 May 2020	NDL	TFS 49296
		preNote := self.opts.obj("PreNote").CM_TrackedItem;
		if preNote &lt;&gt; null and preNote.id &lt;&gt; _containerID then
			preNote := null;
		endif;
			
		// Create the GTE Entity and add to VVR
		attachment := self.opts.str("Attachment");
		if attachment &lt;&gt; null then
			create controller transient;
			create pxyAttachment as CMGTE_Container transient;
			controller.myTerminal := self.getTerminal();
			if app.myRoot.isAnEmptyCommodity(_commodity, false) then
				controller.jobType := CMGTE_Entity.JobType_EmptyIN;   // MT
			else
				controller.jobType := CMGTE_Entity.JobType_FullIN;   // MT
			endif;
			
			controller.id := attachment;
			controller.isoTypeCode := _isoCode;
			controller.operatorCode := _operatorCode;
			controller.commodity := _commodity;
			controller.weightTotal := 2000;
			controller.carriageTempC :=NULL_TEMPERATURE;
			controller.setCarbonDioxide( NULL_CARBON_DIOXIDE );
			controller.setOxygen( NULL_OXYGEN );
			controller.setHumidity( NULL_HUMIDITY );
			controller.myVehicleVisitRecord := _vvr;
			pxyAttachment.setPXYFromController(controller); 
			delete controller;
		endif;
		
		create controller transient;
		//create pxyGateEntity as CMGTE_Container transient;
		cargoType := getRoot.getCargoTypeFromAbbrevOrDescr( _cargoType );
		controller.cargoType := cargoType.id; 
		if cargoType.id = TI_CargoType_Container then
			create pxyGateEntity as CMGTE_Container transient;
		elseif cargoType.id = TI_CargoType_Generator then
			create pxyGateEntity as CMGTE_Generator transient;
			controller.myGeneratorType := getRoot.allGeneratorTypes.first;
		elseif cargoType.isTrailer then
			create pxyGateEntity as CMGTE_TILC transient;
			controller.myChassisType := getRoot.allTILCTypes.first;
		elseif cargoType.productType = ProductType_Vehicle then
			create pxyGateEntity as CMGTE_Car transient; 
		elseif self.opts.int("_direction") = Release then   // CNWNS1	1/12/16
			create pxyGateEntity as CMGTE_Release transient;	
		else
			create pxyGateEntity as CMGTE_Receival transient;
		endif;
				
		// 26/03/2015 cnwmh5
		if cargoType.isSubCargoTypeRequired then
			if self.opts.includesKey(UTTI_CargoSubType) then
				subType := self.opts.obj(UTTI_CargoSubType).CM_Product;
			elseif self.opts.includesKey("SubType") then
				subType := cargoType.allProducts[null, self.opts.str("SubType")].CM_Product;
			endif;
			if subType &lt;&gt; null then
				controller.myProduct := subType;
			endif;
		endif;
				
		controller.myTerminal := self.getTerminal();
		if pxyGateEntity.isKindOf(CMGTE_Receival) then // General Receival
			controller.jobType := CMGTE_Entity.JobType_GeneralIN;
		elseif pxyGateEntity.isKindOf(CMGTE_Release) then
			if cargoType.isBreakBulk or cargoType.isBulk then
				controller.jobType := CMGTE_Entity.JobType_GeneralOUT;
			elseif app.myRoot.isAnEmptyCommodity(_commodity, false) then
				controller.jobType := CMGTE_Entity.JobType_EmptyOUT;   // MT
			else
				controller.jobType := CMGTE_Entity.JobType_FullOUT;   // MT
			endif;
		elseif app.myRoot.isAnEmptyCommodity(_commodity, false) then
			controller.jobType := CMGTE_Entity.JobType_EmptyIN;   // MT
		else
			controller.jobType := CMGTE_Entity.JobType_FullIN;   // MT
		endif;
		
		controller.id := _containerID;
		controller.numItems :=_totalQuantity.max(1);
		controller.regNo := _vvr.regNumber;
		controller.isoTypeCode := _isoCode;
		controller.operatorCode := _operatorCode;
		controller.commodity := _commodity;
		if attachment &lt;&gt; null then
			controller.weightTotal := 4000;
			controller.weightCargo := 2000;
		else
			controller.weightTotal := 2000;
		endif;
		
		
		if self.opts.includesKey("Temp") then   // CNWMA1 30/05/2014
			controller.carriageTempC := self.opts.real("Temp");
		else
			controller.carriageTempC :=  NULL_TEMPERATURE;
		endif;
		
		if preNote &lt;&gt; null then
			controller.isWeightCertified := true;
		elseif self.opts.includesKey("IsWeightCertified") then   // CNWMK3
			controller.isWeightCertified :=self.opts.bool("IsWeightCertified");
		endif;	
		if preNote &lt;&gt; null then
			controller.weightCertifiedName := preNote.weightCertifiedName;
		elseif self.opts.includesKey("WeightCertBy") then   // CNWMK3
			controller.weightCertifiedName :=self.opts.str("WeightCertBy");
		endif;
		if preNote &lt;&gt; null then
			controller.weightCertifiedReference := preNote.weightCertifiedReference;
		elseif self.opts.includesKey("AuthorisedPerson") then   // CNWMK3
			controller.weightCertifiedReference :=self.opts.str("AuthorisedPerson");
		endif;
				
		// 14/08/2014 cnwmh5
		controller.coolingType := null;
		controller.voltageType := null;
		controller.curtainsIn := null;
		controller.remarks := self.createdByUnitTest(null);							// 07/09/2015 cnwmh5
	
		if self.opts.includesKey("Humidity") then	//09 Apr 2020	NDL	TFS 47958
			controller.setHumidity( self.opts.dec("Humidity") );
		else
			controller.setHumidity( NULL_HUMIDITY );
		endif;
		
		controller.ventilation := NULL_INTEGER;
		
		if self.opts.includesKey("CarbonDioxide") then	//09 Apr 2020	NDL	TFS 47958
			controller.setCarbonDioxide( self.opts.dec("CarbonDioxide") );
		else
			controller.setCarbonDioxide( NULL_CARBON_DIOXIDE );
		endif;
		if self.opts.includesKey("Oxygen") then	//09 Apr 2020	NDL	TFS 47958
			controller.setOxygen( self.opts.dec("Oxygen") );
		else
			controller.setOxygen( NULL_OXYGEN );
		endif;
		controller.voyageCode := self.opts.str("Voyage");
		controller.yardLocationTxt := self.opts.str("Location");
		
		if self.opts.includesKey("PackDate") then						// 14/08/2014 cnwmh5
			controller.packDate := self.opts.str("PackDate").Date;
		else	
			controller.packDate := null;
		endif;
		if self.opts.includesKey("PackTime") then						// 14/08/2014 cnwmh5
			controller.packTime := self.opts.str("PackTime").Time;
		else
			controller.packTime := null;
		endif;
		if self.opts.includesKey("IMEX") then
			controller.imexStatus := self.opts.int("IMEX");
		else
			controller.imexStatus := TI_IMEX_STATUS_STORAGE;
		endif;
		controller.destinationPort := self.opts.str("DestinationPort");
		controller.dischargePort := self.opts.str("DischargePort");
		
		if self.opts.includesKey("AllowableTimeOffPower") then						// 14/08/2014 cnwmh5
			controller.allowableTimeOffPower := self.opts.int("AllowableTimeOffPower").Decimal;
		else
			controller.allowableTimeOffPower := NULL_ALLOWABLE_TIME_OFF_POWER;
		endif;
		
		// 21/07/2015 cnwmh5
		controller.onPowerDuringTransit := self.opts.bool("OnPowerDuringTransit");			
		if self.opts.includesKey("TransitOnPowerDateTime") then
			controller.transitOnPowerDate := self.opts.timestamp("TransitOnPowerDateTime").date;
			controller.transitOnPowerTime := self.opts.timestamp("TransitOnPowerDateTime").time;
		endif;
		if self.opts.includesKey("TransitOnPowerRemarks") then
			controller.transitOnPowerRemarks := self.opts.str("TransitOnPowerRemarks");
		endif;
		if self.opts.includesKey("PackSenderOffPowerDateTime") then
			controller.transitOnPowerDate := self.opts.timestamp("TransitOnPowerDateTime").date;
			controller.transitOnPowerTime := self.opts.timestamp("TransitOnPowerDateTime").time;
		endif;
		
		if self.opts.includesKey("PackTempC") then
			controller.packTempC := self.opts.int("PackTempC").Decimal;
		endif;
		if self.opts.includesKey("CarriageTempC") then
			controller.carriageTempC := self.opts.int("CarriageTempC").Decimal;
		elseif preNote &lt;&gt; null and preNote.isReefer then	//10 Aug 2020	NDL	TFS 49581
			controller.carriageTempC := preNote.getTemperature;
		endif;
		
		controller.shippersSeal := self.opts.str (UTTI_ShipperSeal);	// cnwcs5 June 2012
		
		if controller.shippersSeal &lt;&gt; null then // --&gt; TFS 41215
			controller.setSealNumberValueDirect(app.getMyRoot.allSealTypes.getAtKey("SHIP"), controller.shippersSeal, null);
		endif; // &lt;-- TFS 41215
		
		// do overdimensions
		overDim := self.opts.str("Over Left");
		if overDim &lt;&gt; null then
			controller.dimWidthLeft := overDim.Integer;
			overDim := self.opts.str("Over Right");
			controller.dimWidthRight := overDim.Integer;
			overDim := self.opts.str("Over Front");
			controller.dimLenFront := overDim.Integer;
			overDim := self.opts.str("Over Rear");
			controller.dimLenRear := overDim.Integer;
			overDim := self.opts.str("Over Height");
			controller.height := overDim.Integer;
		endif;
		
		controller.myBookingRefItem := self.opts.obj("BookingItem").CM_BookingRefItem;
		if controller.myBookingRefItem &lt;&gt; null then
			controller.bookingNumber := controller.myBookingRefItem.myBookingReference.bookingReference;
			controller.shippingReference := controller.myBookingRefItem.myBookingReference.shippingReference;
		endif;
		//jlgka1 TFS 48550 --&gt;
		if self.opts.includesKey("BookingNumber") and controller.bookingNumber = null then
			controller.bookingNumber := self.opts.str("BookingNumber");	
		endif;
		//jlgka1 TFS 48550 &lt;--
		if self.opts.includesKey("Hazard") then						// 10/03/2016 cnwmk3
			create hazard transient;
			//hazard.setProxy(self.opts.str("Hazard"), self.opts.strDef("HazardDescription", "Hazardous"), "", null, false, null);		// PAR #36421							// TFS 2842
			hazard.setProxy(self.opts.str("Hazard"), self.opts.strDef("HazardDescription", "Hazardous"), "", null, false, null, NULL_TEMPERATURE, MarinePollutant_Null, null);	// TFS 2842
			controller.allTIHazards.add(hazard);
		endif;
		
		//26 Jan 2021	NDL	TFS 50708
		if self.opts.includesKey(UTTI_BOL) then
			controller.billOfLading := self.opts.str(UTTI_BOL);
		endif;
		
		//13 May 2020	NDL	TFS 49296
		if preNote &lt;&gt; null and pxyGateEntity.isKindOf( CMGTE_Receival ) then
			pxyGateEntity.CMGTE_Receival.setMyTrackedItem( preNote );
			controller.clientRef := preNote.clientRef;	//05 Aug 2020	NDL	TFS 49869
		endif;
		
		
		// ### TFS 61525 (61527) 15Jul2024 NAVPW1
		controller.myBulkRelease := bulkRelease;
		
		if bulkRelease &lt;&gt; null and not bulkRelease.releaseByType then
			controller.myReserveDetail := bulkRelease.getReserveTIforTI(preNote);
		else
			controller.myReserveDetail := reserveDetail;
			
			if reserveDetail &lt;&gt; null and reserveDetail.isKindOf(CM_ReserveSelection) and preNote &lt;&gt; null then
				relReqValInt := self.getTerminal.getConfig(RoadGateRelReqVal).Integer;	
				if relReqValInt = 2 then
					//They don't care if the selected cargo doesn't match the release request, and don't want to know, do nothing.
				else
					//perform the check.
					if not preNote.testAgainstReserveSelection( reserveDetail.CM_ReserveSelection, reason, false, null ) then
						if relReqValInt = 1 then
							//They do care but only want a warning
							msg := app.getErrorString2( Warn_Request_Line_Match, reason, preNote.id ) &amp; CrLf &amp; app.getErrorString(Continue);
							if app.msgBox( msg, app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Default_Second + MsgBox_Question_Mark_Icon ) = MsgBox_Return_No then
								return null;
							endif;
						elseif relReqValInt = 0 then
							//They want to stop cargo that doesn't match being released, so raise an error.
							app.raiseCMException2(Warn_Request_Line_Match, reason, preNote.id, null, preNote);
						endif;
					endif;
				endif;
			endif;
		endif;
		
		// Placed here incase the proxy already exists, but the user has decided they want to release
		// by id, rather than by type.
		if pxyGateEntity.isRelease and controller.id &lt;&gt; null or (controller.myBulkRelease &lt;&gt; null and not controller.myBulkRelease.releaseByType) then
			pxyGateEntity.CMGTE_Release.setIsReleaseById(true);
		elseif pxyGateEntity.isRelease and controller.myBulkRelease &lt;&gt; null and controller.myBulkRelease.releaseByType then
			pxyGateEntity.CMGTE_Release.setIsReleaseById(false);
		endif;
		
		if self.opts.includesKey(UT_OPTS_Vbsti) then
			controller.myVbtsi := self.opts.obj(UT_OPTS_Vbsti).CM_VehicleBookingTimeSlotItem;
		endif;
		
		if self.opts.includesKey(UT_OPTS_ReleaseWeight) then
			controller.releaseWeight := self.opts.dec(UT_OPTS_ReleaseWeight);
		endif;
		
		if self.opts.includesKey(UT_OPTS_ReleaseQuantity) then
			controller.releaseQuantity := self.opts.int(UT_OPTS_ReleaseQuantity);
		endif;
		
		if bulkRelease &lt;&gt; null and reserveDetail &lt;&gt; null then 
			// set proxy from bulk release first and allow overwrite from GUI
			pxyGateEntity.CMGTE_Release.setPXYFromBulkRelease(bulkRelease, reserveDetail);
		endif;
		
		
		// ### TFS 61525 (61527) 15Jul2024 NAVPW1
		
		controller.myVehicleVisitRecord := _vvr;
		pxyGateEntity.setPXYFromController(controller); 
		if pxyAttachment &lt;&gt; null then
			pxyAttachment.setParentObject(pxyGateEntity);
		endif;
		
		// ### TFS 61525 (61527) 19Jul2024 NAVPW1
		if bulkRelease &lt;&gt; null and reserveDetail &lt;&gt; null then 
			if self.opts.includesKey(UT_OPTS_IsAnyId) then
				isAnyId := self.opts.bool(UT_OPTS_IsAnyId);
			endif;
			
			if self.opts.includesKey(UT_OPTS_IsAnyAmount) then
				isAnyAmount := self.opts.bool(UT_OPTS_IsAnyAmount);
			endif;
			
			if isAnyId then
				pxyGateEntity.CMGTE_Release.setIsAnyId(isAnyId);
				if bulkRelease.myOperator &lt;&gt; null then
					pxyGateEntity.setOperator(bulkRelease.myOperator.code);
				endif;
				pxyGateEntity.CMGTE_Release.setIsAnyAmount(isAnyAmount);
			else
				//if not self.tblWeightRequested.isHidden then
				//	self.myPxyGTEEntity.CMGTE_Release.setWeightRequested(self.tblWeightRequested.getString().asCastDecimalJMT());
				//endif;
			endif;
		endif;
		// ### TFS 61525 (61527) 19Jul2024 NAVPW1
		
		//09 Apr 2020	NDL	TFS 47958
		if pxyGateEntity.isCMGTE_Receival then
			self.assertTrueMsg( controller.getCarbonDioxide = pxyGateEntity.CMGTE_Receival.getCarbonDioxide, "CarbonDioxide not updated correctly on CMGTE_Receival from CMIF_FlexiGateController in " &amp; method.qualifiedName );
			self.assertTrueMsg( controller.getHumidity = pxyGateEntity.CMGTE_Receival.getHumidity, "Humidity not updated correctly on CMGTE_Receival from CMIF_FlexiGateController in " &amp; method.qualifiedName );
			self.assertTrueMsg( controller.getOxygen = pxyGateEntity.CMGTE_Receival.getOxygen, "Oxygen not updated correctly on CMGTE_Receival from CMIF_FlexiGateController in " &amp; method.qualifiedName );
		endif;
		
		self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
		app.myTrxCA.trxCreateInOutFlexiGateEntity(_vvr, pxyGateEntity, gateEntity, app.myPassport);
		if not expectErrors then
			self.assertNoTrxErrorsOrWarnings();
		endif;
	endif;
	
	return gateEntity;

epilog
	delete hazard;
	delete pxyGateEntity;
	delete controller;
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_cargoType" type="String"/>
        <Parameter name="_containerID" type="String"/>
        <Parameter name="_isoCode" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_totalQuantity" type="Integer"/>
        <ReturnType type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="xCreateInvoiceLineType" id="65dcf3ea-7681-448a-ae27-dafabfd282ac">
        <source>xCreateInvoiceLineType(_narration 	: String;
					   _calcType  	: String; 
					   _serviceName : String;
					   _invoiceType : String) :CM_InvoiceLineDesc;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2022		navma1	Initial creation
31 Jan 2023	navvt20	TFS CR 56132 Task 56134: UI - Invoice Line Type - UOM
*/

vars
	pxyInvoiceLineDesc,
	newInvLineType		: CM_InvoiceLineDesc;
	calculationType	    : CM_CalculationType;
	debtorType 			: CM_DebtorType;
	service				: CM_Service;
	bank				: CM_Bank;
	services 			: CM_ServiceByNameDict;
	invoiceType			: CM_InvoiceDesc;
begin
	
	bank			:= self.getTerminal().getDefaultCompanyBank();
	calculationType := app.myRoot.allCalculationTypesByCode[_calcType];
	service			:= bank.serviceObjects[_serviceName].CM_Service;
	invoiceType		:= bank.findInvoiceType(_invoiceType);
	
	
	if calculationType.isCargoCalcType then
		debtorType := app.myRoot.allDebtorTypes["SDT6"];	//Customs  Agent
	elseif calculationType.isVoyageCalcType then
		debtorType := app.myRoot.allDebtorTypes["SDT4"];	//Ship Operator
	elseif calculationType.isEventType then
		debtorType := app.myRoot.allDebtorTypes["SDT8"];	//Event Type Debtor
	endif;
	
	create pxyInvoiceLineDesc transient;
	
	pxyInvoiceLineDesc.bank := bank;
	
	create services transient;
	services.add(service);
	
	pxyInvoiceLineDesc.setProxy(false,		
								true,
								0,
								debtorType,
								calculationType,
								invoiceType,
								_narration,
								10,
								"", 
								"Unit Narration",
								services,
								false,
								null, null, null, false, false,null,
								null); // 31 Jan 2023 navvt20 TFS 56134

	
	app.myTrxCA.trxCreateInvoiceLineDesc(pxyInvoiceLineDesc,  newInvLineType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	return newInvLineType;
epilog
	delete pxyInvoiceLineDesc;
	delete services;

end;</source>
        <Parameter name="_narration" type="String"/>
        <Parameter name="_calcType" type="String"/>
        <Parameter name="_serviceName" type="String"/>
        <Parameter name="_invoiceType" type="String"/>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="xCreateInvoiceService" id="6f391006-fb16-4d84-b1dd-8b42e42f98e6">
        <source>xCreateInvoiceService(_serviceName : String ; _calcType : String): CM_Service;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2022		navma1	Initial creation
23 August	2022		navkc1 	ChangeRequest #54569 - Add Service Types
*/

vars
	bank 			: CM_Bank;
	newService, 
	pxyService  	: CM_ServiceObject;
	calculationType : CM_CalculationType;
begin
	
	bank 				:= self.getTerminal().getDefaultCompanyBank();
	calculationType		:= app.myRoot.allCalculationTypesByCode[_calcType];
	
	
	create pxyService as CM_Service transient;
	
	pxyService.setProxy(_serviceName,
					bank,
					_serviceName,
					null,
					bank.getRootServiceGroup(),
					CM_Service.DEFAULT_RATE_TABLE, 
					calculationType,
					bank.allTaxCodes.first(),
					false,null,null,
					null); // 23/08/22	navkc1	#54569

	app.myTrxCA.trxCreateServiceObject(pxyService,newService,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
 	
	return newService.CM_Service;
	
epilog
	delete pxyService;
end;</source>
        <Parameter name="_serviceName" type="String"/>
        <Parameter name="_calcType" type="String"/>
        <ReturnType type="CM_Service"/>
    </JadeMethod>
    <JadeMethod name="xCreateInvoiceServiceLineRate" id="0c91c1ff-a7fb-4c4c-835c-67df016537ee">
        <source>xCreateInvoiceServiceLineRate(_name 		: String;
							  _calcCode		: String;
							  _invoiceType  : String;
							  _eraseLevel	: Integer;
							  _debtor		: CM_DebtorNode io;
							  _rate			: Real;
							  _calcType     : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2022		navma1	Initial creation

*/

vars
	helperSys : UT_HelperAdmSys;
begin
	create helperSys transient ;
	
	self.xDeleteInvoiceService(_name,FORCED_ERASE);
	self.xDeleteInvoiceLineType(_name,FORCED_ERASE);
	
	helperSys.xCreateInvoiceCalcType(_calcType,UT_DSL.TFS52580,false,true,false);
	self.xCreateInvoiceService(_name,_calcCode);
	self.xCreateInvoiceLineType(_name,_calcCode,_name,_invoiceType);
	self.xCreateInvoiceServiceRate(_debtor,_name,_rate);
	
epilog
	delete helperSys;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_calcCode" type="String"/>
        <Parameter name="_invoiceType" type="String"/>
        <Parameter name="_eraseLevel" type="Integer"/>
        <Parameter name="_debtor" type="CM_DebtorNode" usage="io"/>
        <Parameter name="_rate" type="Real"/>
        <Parameter name="_calcType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xCreateInvoiceServiceRate" id="ec48f13c-7cdc-41c0-bc5e-71702093d3a7">
        <source>xCreateInvoiceServiceRate(_debtor	   : CM_DebtorNode io;
						  _serviceName : String; 
						  _rate 	   : Real);
/*

Purpose:			
			Pending
Parameters:			

Return Value:		

Date		Who		Reason
17 February 2022		navma1	Initial creation

*/

vars
	yesterday : Date;
	service   : CM_Service;
	bank	  : CM_Bank;
begin
	bank      := self.getTerminal.getDefaultCompanyBank();
	service	  :=  bank.serviceObjects[_serviceName].CM_Service;
	yesterday := app.cnGetServerTime.Date.addDays(-1);
	
	if _debtor = null then
		_debtor := CM_RootDebtorGroup.firstInstance;
	endif;
	
	beginTransaction;
	delete service.debtorNodeRates.first.rateEntries.first;
	commitTransaction;
	self.setServiceRate(service, _debtor, yesterday, _rate);
epilog

end;</source>
        <Parameter name="_debtor" type="CM_DebtorNode" usage="io"/>
        <Parameter name="_serviceName" type="String"/>
        <Parameter name="_rate" type="Real"/>
    </JadeMethod>
    <JadeMethod name="xCreateInvoiceType" id="69339baa-59bc-48ba-a158-29404773431b">
        <source>xCreateInvoiceType(_invType 	: Integer;
				   _invoiceDesc	: String) : CM_InvoiceDesc;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2022		navma1	Initial creation
15/06/2023	navcs2	ChangeRequest 58434: [58452]: EUP | TAS Invoicing - Invoice Type Configuration

*/

vars
	bank 		: CM_Bank;
	pxyInvoice	: CM_InvoiceDesc;
	invType		: CM_InvoiceDesc;
	invoiceKey  : Integer;
	hgSA		: HugeStringArray;
	isAllowManEditExtRef	: Boolean; //08/12/2025	navkc1 JIRA 36262
begin
	self.opts.purge();
	self.opts.addAssoc('Terminal','UT');
	
	self.xDeleteInvoiceType(_invoiceDesc);
	
	bank := self.getTerminal().getDefaultCompanyBank();
	
	create hgSA transient; 
	hgSA.add("None,!");
	hgSA.add("___field = 0");
	hgSA.add("The Debtors Name");
	hgSA.add("___field = 1");
	hgSA.add("The Voyage Code");
	hgSA.add("___field = 2");
	hgSA.add("The Vessel Name");
	hgSA.add("___field = 3");
	hgSA.add("12/12/2009");
	hgSA.add("___field = 5");
	
	create pxyInvoice transient;
	
	if _invType &lt;&gt; null then
		invoiceKey := _invType;
	else
		invoiceKey := CM_InvoiceDesc.Key_None;
	endif;
	
	//08/12/2025	navkc1 JIRA 36262
	if self.opts.includesKey("AllowManEditExtRef") then
		isAllowManEditExtRef := self.opts.bool("AllowManEditExtRef").Boolean; //08/12/2025	navkc1 JIRA 36262
	endif;
		
	pxyInvoice.setProxy(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
						hgSA,
						_invoiceDesc,
						invoiceKey,
						_invType,											   //InvoiceTypeGeneral,  //or  InvoiceTypeStorage
						app.myRoot.myRootCompany.allFinancialPeriods.first(),  //get first at the moment
						app.myRoot.myRootCompany.allInvoiceTermsOfTrade.first(), //get first at the moment
						true,   //print1LineDay
						InvTypeTrigger_Release,
						null,
						null,
						0,
						null,
						false,
						false,	// 15.06.2023	navcs2	#58434:[58452]
						false, // 15.06.2023	navcs2	#58434:[58452]
						isAllowManEditExtRef //08/12/2025	navkc1 JIRA 36262
						);
	pxyInvoice.setCompany(bank);	

	app.myTrxCA.trxCreateInvoiceDesc(pxyInvoice,  invType, app.myPassport);
	
	return invType;
epilog
	delete pxyInvoice;
	delete hgSA;
end;</source>
        <Parameter name="_invType" type="Integer"/>
        <Parameter name="_invoiceDesc" type="String"/>
        <ReturnType type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="xCreateRailArea" id="bad45ca4-da29-4130-bf26-2c73225c9b5f">
        <source>xCreateRailArea(_railAreaId : String; _numLines, _numPositions : Integer; _terminal : CM_Terminal) : CM_Rail;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	pxyRail,
	realRail	: CM_Rail;
	pDO			: CM_YADeckingOptionsTA;
	realTA		: CM_TerminalAreaMaster;
	
begin
	self.assertTrueMsg(_railAreaId &lt;&gt; null, method.name &amp; " | railAreaId is null");
	self.assertTrueMsg(_numLines &gt; 0, method.name &amp; " | numLines being less than 0 is not valid");
	self.assertTrueMsg(_numPositions &gt; 0, method.name &amp; " | numPositions being less than 0 is not valid");
	self.assertNotNullMsg(_terminal, method.name &amp; " | terminal");
	
	create pxyRail transient;
	pxyRail.setProxy(_railAreaId,
						null,
						TA_TYPE_RAILWAY_TRACK,
						_numLines,
						_numPositions,
						null,
						false,
						false,
						false,
						false,
						_terminal,
						false,
						false,
						null,
						null,
						null);
	
	create pDO transient;
	pDO.setProxy(false, true, pxyRail);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	app.myTrxCA.trxCreateTerminalArea(pxyRail, realTA, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realTA, method.name &amp; " | realTA");
	
	realRail := realTA.CM_Rail;
	
	return realRail;					
	
epilog
	delete pDO;

	if pxyRail &lt;&gt; null and pxyRail.myLayoutGraphic &lt;&gt; null then
		delete pxyRail.myLayoutGraphic;
	endif;
	
	delete pxyRail;
	
end;</source>
        <Parameter name="_railAreaId" type="String"/>
        <Parameter name="_numLines" type="Integer"/>
        <Parameter name="_numPositions" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_Rail"/>
    </JadeMethod>
    <JadeMethod name="xCreateReleaseRequest" id="76cfef5b-f33a-4e18-a8fd-865095441fc6">
        <source>xCreateReleaseRequest(_releaseNumber: String; _releaseType: Integer; _releaseByType: Boolean; _terminal : CM_Terminal; _pxyReserveSelection : CM_ReserveSelection input) : CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2024	navpw1	Initial creation TFS: 59411 (62272)

*/

vars
	pxyReleaseRequest,
	realRelease			: CM_BulkRelease;
	fullRelease			: Boolean;
	canBeHiLoCube 		: Boolean;
	voyage				: CM_Voyage;
	operator 			: CM_Operator;
	carrierId 			: String;
	consignor			: String;
	consignee			: String;
	context				: String;	
	subTerminal			: CM_SubTerminal;
	loadPort,
	destinationPort,
	dischargePort		: CM_Port;
	train				: CM_Train;
	booking				: CM_BookingRef;
	
begin
	self.assertNotNullMsg(_releaseNumber, method.name &amp; " | _releaseNumber");
	self.assertNotNullMsg(_terminal, method.name &amp; " | _terminal");
	
	loadPort	:= _terminal.getDefaultPort;
	subTerminal	:= _terminal.getDefaultSubTerminalForRel(_releaseType);
	
	if self.opts.includesKey(UT_OPTS_DestinationPort) then
		destinationPort := self.opts.obj(UT_OPTS_DestinationPort).CM_Port;
	endif;
	
	if self.opts.includesKey(UT_OPTS_DischargePort) then
		dischargePort := self.opts.obj(UT_OPTS_DischargePort).CM_Port;
	endif;
	
	if self.opts.includesKey(UT_OPTS_Train) then
		train := self.opts.obj(UT_OPTS_Train).CM_Train;
	endif;
	
	if self.opts.includesKey(UT_OPTS_Booking) then
		booking := self.opts.obj(UT_OPTS_Booking).CM_BookingRef;
	endif;
	
	if self.opts.includesKey(UT_OPTS_Context) then
		context := self.opts.str(UT_OPTS_Context);
	endif;
	
	if self.opts.includesKey(UT_OPTS_FullRelease) then
		fullRelease := self.opts.bool(UT_OPTS_FullRelease);
	endif;
	
	if self.opts.includesKey(UT_OPTS_CanBeHiLoCube) then
		canBeHiLoCube := self.opts.bool(UT_OPTS_CanBeHiLoCube);
	endif;
	
	if self.opts.includesKey(UT_OPTS_Voyage) then
		voyage := self.opts.obj(UT_OPTS_Voyage).CM_Voyage;
	endif;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	if self.opts.includesKey(UT_OPTS_Operator) then
		operator := self.opts.obj(UT_OPTS_Operator).CM_Operator; 
	endif;
	
	carrierId := self.getProfileStr(UT_Profile.P_CARRIER);
	if self.opts.includesKey(UT_OPTS_Carrier) then
		carrierId := self.opts.obj(UT_OPTS_Carrier).CM_Carrier.code;
	endif;
	
	if self.opts.includesKey(UTTI_Consignee) then
		consignee := opts.str(UTTI_Consignee);
	endif;
	
	if self.opts.includesKey(UTTI_Consignor) then
		consignor := opts.str(UTTI_Consignor);
	endif;
	
	create pxyReleaseRequest transient;
	pxyReleaseRequest.setProxy(_releaseNumber,			//_releaseNumber			: String;
								_releaseType,			//_type						: Integer;
								_releaseByType,			//_releaseByType			: Boolean;
								BR_ACTIVE,				//_status					: Integer;
								null,					//_allAvailabilityGrades	: IntegerArray;
								null,					//_bookingConfirmation		: String;
								carrierId,				//_carrierId				: String;
								null,					//_cargoRemarks				: String;
								consignee,				//_consigneeCode			: String;
								null,					//_consigneeDesc			: String;
								consignor,				//_consignorCode			: String;
								null,					//_consignorDesc			: String;
								null,					//_consignorVoyageCode		: String;
								app.actualTimeServer(),	//_dateRequested			: TimeStamp;
								null,					//_dateEstimatedRequired	: TimeStamp;
								null,					//_deliveryReasonCode		: Integer;
								null,					//_deliveryReasonDescr		: String;
								null,					//_deliveryReleaseNumber	: String;
								null,					//_doorsDirection			: Integer;
								null,					//_freightPayerCode			: String;
								booking,				//_bookingRef				: CM_BookingRef;
								loadPort,				//_loadPort					: CM_Port;
								destinationPort,		//_destinationPort			: CM_Port;
								dischargePort,			//_dischargePort			: CM_Port;
								null,					//_freightForwarderCode		: String;
								null,					//_transferToTerminal		: CM_Terminal;
								_terminal,				//_terminal					: CM_Terminal;
								operator,				//_operator					: CM_Operator;
								null,					//_operatorGroup			: CM_OperatorGroup;
								voyage,					//_voyage					: CM_Voyage;
								null,					//_businessUnit				: CM_Bank;
								fullRelease,			//_fullRelease				: Boolean;
								null,					//_allPackLocations			: StringArray;
								null,					//_poolPartner				: CM_Operator;
								null,					//_dispatchLocn				: String;
								subTerminal,			//_subTerminal				: CM_SubTerminal;
								null,					//_subTerminalTarget		: CM_SubTerminal;
								train,					//_assignedTrain			: CM_Train;
								false,					//_allowCargoOnMultiRel		: Boolean;
								null,					//_customsAgent				: String;
								false,					//_customsAssistance		: Boolean;
								canBeHiLoCube,			//_canBeHiLoCube			: Boolean;
								false,					//_needsReview				: Boolean;
								false,					//_stopEDIUpdates			: Boolean;
								null,					//_allEDIFiles				: CM_EDIFileArray;
								null,					//_expiryTimeStamp			: TimeStamp;
								null,					//_myBOLIn					: CM_BOLIn;
								context					//_context					: String;
								);
	
	_pxyReserveSelection.setMyHeader(pxyReleaseRequest);
	
	app.myTrxCA.trxCreateBulkRelease(pxyReleaseRequest, realRelease, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return realRelease;
	
epilog
	delete pxyReleaseRequest;
	
end;</source>
        <Parameter name="_releaseNumber" type="String"/>
        <Parameter name="_releaseType" type="Integer"/>
        <Parameter name="_releaseByType" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_pxyReserveSelection" type="CM_ReserveSelection" usage="input"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="xCreateReserveSelection" id="a594f9fd-580a-4170-a6b1-7060e8a74c48">
        <source>xCreateReserveSelection(_cargoType			: CM_CargoType;
						_cargoSubType		: CM_Product;
						_isoType			: CM_ISOType;
						_totalRequested		: Integer;
						_availGrades		: IntegerArray;
						_allTermAreaDict	: CM_TAByIdDict
						) : CM_ReserveSelection;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 February 2024	navpw1	Initial creation TFS: 59411 (62272)

*/

vars
	isoGroup				: CM_ISOTypeGroup;
	bookingItem				: CM_BookingRefItem;
	bol						: CM_BOLIn;
	packType				: Integer;
	color,
	markSelection			: String;
	bestPick,
	fullRelease				: Boolean;
	weightSelection			: Decimal[14,4];
	weightRequested			: Decimal[14,4];
	matchYACriteria			: CM_ReleaseByTypeCriteria;
	measurementType			: CM_MeasurementType;
	cargoGroup				: CM_CargoGroup;
	pxyReserveSelection		: CM_ReserveSelection;
	byTypeByWeight			: Boolean;
	commodity				: CM_Commodity;					// ### JIRA: MTN-36370 07Nov2025 NAVPW1
	
begin
	self.assertNotNullMsg(_cargoType, method.name &amp; " | _cargoType");
	
	if _cargoType.isSubCargoTypeRequired then
		self.assertNotNullMsg(_cargoSubType, method.name &amp; " | _cargoSubType");
	endif;
	
	if _cargoType.isContainer then
		self.assertNotNullMsg(_isoType, method.name &amp; " | _isoType");
		self.assertNullMsg(_cargoSubType, method.name &amp; " | _cargoSubType");
	endif;
	
	if _availGrades &lt;&gt; null then
		self.assertTrueMsg(_availGrades.isNotEmpty, method.name &amp; " | Availability Grades array is empty");
	endif;
	
	if _allTermAreaDict &lt;&gt; null then
		self.assertTrueMsg(_allTermAreaDict.isNotEmpty, method.name &amp; " | Terminal Areas Dictionary is empty");
	endif;
	
	if self.opts.includesKey(UT_OPTS_ISOGroup) then
		isoGroup := self.opts.obj(UT_OPTS_ISOGroup).CM_ISOTypeGroup;
	endif;
	
	if self.opts.includesKey(UT_OPTS_BookingItem) then
		bookingItem := self.opts.obj(UT_OPTS_BookingItem).CM_BookingRefItem;
	endif;
	
	if self.opts.includesKey(UT_OPTS_PackType) then
		packType := self.opts.int(UT_OPTS_PackType);
	endif;
	
	if self.opts.includesKey(UT_OPTS_Colour) then
		color := self.opts.str(UT_OPTS_Colour);
	endif;
	
	if self.opts.includesKey(UT_OPTS_Mark) then
		markSelection := self.opts.str(UT_OPTS_Mark);
	endif;
	
	if self.opts.includesKey(UT_OPTS_Bol) then
		bol :=self.opts.obj(UT_OPTS_Bol).CM_BOLIn;
	endif;
	
	if self.opts.includesKey(UT_OPTS_BestPick) then
		bestPick := self.opts.bool(UT_OPTS_BestPick);
	endif;
	
	if self.opts.includesKey("WeightSelection") then
		weightSelection := self.opts.dec("WeightSelection");
	endif;
	
	if self.opts.includesKey("MeasurementType")then
		measurementType := self.opts.obj("MeasurementType").CM_MeasurementType;
		weightSelection := app.convertMeasurementForStorage(measurementType.shortName, weightSelection);
	endif;
	
	if self.opts.includesKey(ETRow_SetCriteria) then
		matchYACriteria := self.opts.obj(ETRow_SetCriteria).CM_ReleaseByTypeCriteria;
	endif;
	
	if self.opts.includesKey(UT_OPTS_CargoGroup) then
		cargoGroup := self.opts.obj(UT_OPTS_CargoGroup).CM_CargoGroup;
	endif;
	
	if self.opts.includesKey(UT_OPTS_FullRelease) then
		fullRelease := self.opts.bool(UT_OPTS_FullRelease);
	endif;
	
	if self.opts.includesKey(UT_OPTS_Commodity) then
		commodity := self.opts.obj(UT_OPTS_Commodity).CM_Commodity;
	endif;
	
	//18 Jun 2015	NDL	Par 36338
	if matchYACriteria &lt;&gt; null then
		matchYACriteria.setProxyBaseData(pxyReserveSelection);
	endif;
	
	if self.opts.includesKey("weightRequested") then
		weightRequested := self.opts.int("weightRequested");
		byTypeByWeight := true;
	elseif self.opts.includesKey(UT_OPTS_WeightRequested) then
		weightRequested := self.opts.int(UT_OPTS_WeightRequested);
		byTypeByWeight := true;
	endif;
	
	self.assertTrueMsg(_totalRequested &gt; 0 or weightRequested &gt; 0, method.name &amp; " | Total requested or weight requested must be greater then 0");
	
	create pxyReserveSelection transient;
	pxyReserveSelection.setPxyDefaults();

	pxyReserveSelection.setProxy(packType,			//_packtype				: Integer;
								_cargoType,			//_cargoType			: CM_CargoType;
								bookingItem,		//_bookRefItemObj		: CM_BookingRefItem;
								_isoType,			//_isoType				: CM_ISOType;
								isoGroup,			//_isoGroup				: CM_ISOTypeGroup;
								_cargoSubType,		//_product				: CM_Product;
								null,				//_productStr			: String;
								null,				//_remarks				: String;
								_totalRequested,	//_totalRequested		: Integer;
								_availGrades,		//_allAvailGrades		: IntegerArray;
								null,				//_clean				: Boolean;
								null,				//_doISOGroupCheck		: Boolean;
								false,				//_heavyRated			: Boolean;
								null,				//_maskIds				: StringArray;
								0,					//_maxToRelease			: Integer;
								color,				//_color				: String;
								null,				//_descriptionSelection	: String;
								null,				//_heightSelection		: Decimal;
								null,				//_lengthSelection		: Decimal;
								null,				//_markNumber			: String;
								null,				//_quantitySelection	: Integer;
								null,				//_remarksSelection		: String;
								null,				//_volumeSelection		: Decimal;
								weightSelection,	//_weightSelection		: Decimal;
								null,				//_widthSelection		: Decimal;
								markSelection,		//_markSelection		: String;
								null,				//_densitySelection		: Decimal;
								null,				//_typeSelection		: String;
								//ta,				//_terminalArea			: CM_TerminalArea;
								_allTermAreaDict,	//_allTermAreaDict		: CM_TAByIdDict;
								bol,				//_myReceivalBOL		: CM_BOLIn;
								bestPick,			//_bestPick				: Boolean;
								null,				//_sequence				: String;
								null,				//_deliveryParty		: CM_DeliveryParty;
								null,				//_deliveryAddress		: CM_Address;
								null,				//_deliveryInstructions	: String;
								null,				//_deliveryFromDT		: TimeStamp;
								null,				//_deliveryToDT			: TimeStamp;
								false,				//_defaultAnyAmount		: Boolean;
								false,				//_defaultAnyID			: Boolean;
								null,				//_matchClientRef		: String;
								null,				//_matchUNDGCode		: String;
								null,				//_matchOrderNum		: String;
								null,				//_matchPurchaseOrder	: String;
								null,				//_matchReceivedDT		: TimeStamp;
								null,				//_matchReleasedDT		: TimeStamp;
								null,				//_matchRemarks			: String;
								null,				//_matchVesselCode		: String;
								null,				//_maxWeightRequested	: Decimal;
								null,				//_lineNumber			: Integer;
								null,				//_customerReference	: String;
								cargoGroup,			//_cargoGroup			: CM_CargoGroup;
								byTypeByWeight,		//_byTypeByWeight		: Boolean;
								false,				// _locnByOldestDate	: Boolean;
								commodity,			//_commodity			: CM_Commodity;
								null);				//_contentsCargoType	: CM_CargoType;
	if weightRequested &lt;&gt; null then
		pxyReserveSelection.setWeightRequested(weightRequested);
	endif;
	/*if self.opts.includesKey(UT_OPTS_CreateDeliveryRequest) and self.opts.bool(UT_OPTS_CreateDeliveryRequest) then							
		pxyDeliveryRequest := _pxyReleaseRequest.createRequests();
		if not fullRelease then
			pxyDeliveryRequest.setMTCommodity();
		endif;
	endif;
	*/
	
	//app.myTrxUA.trxUpdateBulkRelease(_pxyReleaseRequest, null, app.myPassport);
	//self.assertNoTrxErrorsOrWarnings();
	
	/*if matchYACriteria &lt;&gt; null then
		delRequest := _pxyReleaseRequest.requests.first.CM_DeliveryRequest;
		reserveSel := _pxyReleaseRequest.allReserveDetails.first.CM_ReserveSelection;
		if delRequest &lt;&gt; null then
			beginTransaction;
			delRequest.setReserveDetail( reserveSel ); 
			commitTransaction;
		endif;
	endif;
	
	if isoGroup &lt;&gt; null then
		beginTransaction;
		realRelease.setPropertyValue(CM_BulkRelease::myISOGroup.name, isoGroup);
		commitTransaction;
	endif;*/
	
	return pxyReserveSelection;
	
epilog
	
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_cargoSubType" type="CM_Product"/>
        <Parameter name="_isoType" type="CM_ISOType"/>
        <Parameter name="_totalRequested" type="Integer"/>
        <Parameter name="_availGrades" type="IntegerArray"/>
        <Parameter name="_allTermAreaDict" type="CM_TAByIdDict"/>
        <ReturnType type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="xCreateStevedore" id="4446e702-91d6-41a2-a242-4ef09a040f92">
        <source>xCreateStevedore(_code, _description : String) : CM_Stevedore;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2023	navpw1	Initial creation

*/

vars
	pxyStevedore,
	realStevedore : CM_Stevedore;
	
begin
	self.deleteStevedore(_code);
	
	create pxyStevedore transient;
	pxyStevedore.setProxy(_code, _description, false ,null);
	
	app.myTrxCA.trxCreateStevedore(pxyStevedore, realStevedore, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return realStevedore;
	
epilog
	delete pxyStevedore;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <ReturnType type="CM_Stevedore"/>
    </JadeMethod>
    <JadeMethod name="xCreateTrain" id="474d16cf-cc2b-47d3-99b5-07cc733d3acb">
        <source>xCreateTrain(_trainCode : String; _terminal : CM_Terminal): CM_Train;
/*

Purpose:			

Parameters:			

Return Value:		

Opts Used:		UT_OPTS_Carrier
				UT_OPTS_TrackClearance

Date			Who		Reason
27 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	pxyTrain,
	realTrain		: CM_Train;
	carrier			: CM_Carrier;
	trackClearance	: CM_TrackClearance;
	
begin
	self.assertTrueMsg(_trainCode &lt;&gt; null, method.name &amp; " | trainCode is null");
	self.assertNotNullMsg(_terminal, method.name &amp; " | terminal");
	
	if self.opts.includesKey(UT_OPTS_Carrier) then
		carrier := self.opts.obj(UT_OPTS_Carrier).CM_Carrier;
	else
		carrier := app.myRoot.allCarriers.first.CM_Carrier;
	endif;
	
	if self.opts.includesKey(UT_OPTS_TrackClearance) then
		trackClearance := self.opts.obj(UT_OPTS_TrackClearance).CM_TrackClearance;
	endif;
	
	create pxyTrain transient;
	pxyTrain.setProxy(_trainCode,
						_trainCode,
						null,
						null,
						null,
						null,
						_terminal,
						null,
						null,
						null,
						null,
						null,
						null,
						null,
						null,
						null,
						carrier,
						app.actualTimeServer,
						null,
						null,
						null,
						null,
						trackClearance,	//_myTrackClearance : CM_TrackClearance
						false,
						null,
						null);
	
	app.myTrxCA.trxCreateTrain(pxyTrain, realTrain, false, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realTrain, method.name &amp; " | train");
	
	return realTrain;
	
epilog
	delete pxyTrain;
	
end;</source>
        <Parameter name="_trainCode" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="xCreateVbsTimeSlot" id="668bd289-e141-4579-9255-09c7c9c086a2">
        <source>xCreateVbsTimeSlot(_pxyVbsTimeSlot : CM_VehicleBookingTimeSlot input; _tsStart, _tsEnd : TimeStamp; _vehicleBookingTerminal : CM_VehicleBookingTerminal;
					_carrier, _subCarrier : CM_Carrier; _driver : CM_DriverDetails; _vehicle : CM_Vehicle;
					_remarks : String; _includesDelivering, _includesPickUp : Boolean; _ids : StringArray;
					_vvr : CM_VehicleVisitRecord; _vbsTimeSlotType : CM_VehicleBookingTimeSlotType;
					_id : String; _allBookingRefs : CM_BookingRefSet; _allBulkReleases : CM_BulkReleaseSet;
					_allVbsTimeSlotItems : CM_VehicleBookingTSItemSet; 
					_preGateInCheck, _preGateOutChck, _kioskCheck : Boolean;
					_externalReference : String; _myTILCType: CM_TILCType) : CM_VehicleBookingTimeSlot;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navpw1	Initial creation TFS: 54049 (55844)
24 May 2023 navhl20 Defect 58041: MTN - Unable to copy the slots with the status "Booked - Current"
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
18 Sep 2024	navpw1	TFS: 65623 (65624) - Fixed assigning VBS Items to slot by making proxy created outside this method

*/

vars
	realVbsTimeSlot		: CM_VehicleBookingTimeSlot;
	
begin
	self.assertNotNullMsg(_pxyVbsTimeSlot, method.name &amp; " | _pxyVbsTimeSlot");
	_pxyVbsTimeSlot.setProxy(_tsStart, _tsEnd, _vehicleBookingTerminal, _carrier, _subCarrier, _driver, _vehicle, _remarks, _includesDelivering,
								_includesPickUp, _ids, _vvr, _vbsTimeSlotType, _id, _allBookingRefs, _allBulkReleases, _allVbsTimeSlotItems, 
								_preGateInCheck, _preGateOutChck, _kioskCheck, _externalReference, _myTILCType); // 08 Aug 2024 navcs2	ChangeRequest 63928
	
	app.myTrxCA.trxCreateVehicleBookingAdv(_pxyVbsTimeSlot, realVbsTimeSlot,false, app.myPassport);		//24.5.2023 navhl20 #58041
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realVbsTimeSlot, "realVbsTimeSlot");
	
	return realVbsTimeSlot;
	
end;</source>
        <Parameter name="_pxyVbsTimeSlot" type="CM_VehicleBookingTimeSlot" usage="input"/>
        <Parameter name="_tsStart" type="TimeStamp"/>
        <Parameter name="_tsEnd" type="TimeStamp"/>
        <Parameter name="_vehicleBookingTerminal" type="CM_VehicleBookingTerminal"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_subCarrier" type="CM_Carrier"/>
        <Parameter name="_driver" type="CM_DriverDetails"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_includesDelivering" type="Boolean"/>
        <Parameter name="_includesPickUp" type="Boolean"/>
        <Parameter name="_ids" type="StringArray"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_vbsTimeSlotType" type="CM_VehicleBookingTimeSlotType"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_allBookingRefs" type="CM_BookingRefSet"/>
        <Parameter name="_allBulkReleases" type="CM_BulkReleaseSet"/>
        <Parameter name="_allVbsTimeSlotItems" type="CM_VehicleBookingTSItemSet"/>
        <Parameter name="_preGateInCheck" type="Boolean"/>
        <Parameter name="_preGateOutChck" type="Boolean"/>
        <Parameter name="_kioskCheck" type="Boolean"/>
        <Parameter name="_externalReference" type="String"/>
        <Parameter name="_myTILCType" type="CM_TILCType"/>
        <ReturnType type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="xCreateVbsTimeSlotType" id="44294993-0884-4bd7-b84e-93f0c36dd302">
        <source>xCreateVbsTimeSlotType(_code : String; _desc : String; _terminal : CM_Terminal ) : CM_VehicleBookingTimeSlotType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navpw1	Initial creation TFS: 54049 (55844)
25 Nov 2024	navhl20 CR MTN-33483: TPT | Vehicle Truck Booking Auto Associate with Release Request
*/

vars
	isNotAvailableForEntry	: Boolean;
	proxyType : CM_VehicleBookingTimeSlotType;
	real : CM_VehicleBookingTimeSlotType;
	rtnValue : Boolean;
	starttime: Time;
	duration	: Integer;
	gracePeriod	: Integer;
	entryOutsideSlotType : Integer;
	pregateInCheck : Boolean;
	pregateOutCheck : Boolean;
	kioskCheck	: Boolean;
	externelReference	: Boolean;
	autoAssociateRR		: Boolean;
begin
	isNotAvailableForEntry := false;
	if self.opts.includesKey("AutoAssociateRR") then					//25.11.2024 navhl20 #33483
		autoAssociateRR := self.opts.bool("AutoAssociateRR");
	endif;
	
	create proxyType transient;
	proxyType.setForProxy(	_code,
							_desc,
							isNotAvailableForEntry,
							_terminal,
							starttime,
							duration,
							gracePeriod,
							entryOutsideSlotType,
							pregateInCheck,
							pregateOutCheck,
							kioskCheck,
							externelReference,
							autoAssociateRR);							//25.11.2024 navhl20 #33483

	app.myTrxCA.trxCreateVBTimeSlotType(proxyType, real, app.myPassport);
	self.assertTrueMsg(real &lt;&gt; null, "VehicleBookingTimeSlotype not created for '" &amp; _code &amp; "'  " &amp; app.myPassport.getAllErrorsWarningsAsString);
	
epilog
	delete proxyType;
	return real;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_VehicleBookingTimeSlotType"/>
    </JadeMethod>
    <JadeMethod name="xCreateVehicle" id="f8d515b0-3734-49b8-bff4-ec7e44dfb890">
        <source>xCreateVehicle(_vehicleReg : String ; _carrier : CM_Carrier; _terminal : CM_Terminal) : CM_Vehicle;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 August 2023	navpw1	Initial creation TFS: 56796

*/

vars
	pxyVehicle, 
	realVehicle	: CM_Vehicle;
	
begin
	self.assertTrueMsg(_vehicleReg &lt;&gt; null, method.name &amp; " | vehicleReg is null");
	self.assertNotNullMsg(_carrier, method.name &amp; " | carrier");
	self.assertNotNullMsg(_terminal, method.name &amp; " | terminal");
	
	create pxyVehicle transient;
	
	pxyVehicle.setProxy(_vehicleReg,	//pRegNumber			: String
							'',			//pBatNumber			: String
							2000,		//_tareKilos			: Decimal
							0,			//_maxGrossLadenWeight	: Decimal
							_carrier,	//pCarrier				: CM_Carrier
							'',			//_state				: String
							false,		//isNotAvailableEntry	: Boolean
							_terminal	//_terminal				: CM_Terminal
							);
	
	app.myTrxCA.trxCreateVehicle(pxyVehicle, realVehicle, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realVehicle, method.name &amp; " | realVehicle");
	
	return realVehicle;
	
epilog
	delete pxyVehicle;
	
end;</source>
        <Parameter name="_vehicleReg" type="String"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="xCreateVehicleVisitRecord" id="b7d45ecc-3a42-45d9-b9ad-34cb32186009">
        <source>xCreateVehicleVisitRecord(_vehicleReg, _driverCode, _driverName, _state : String; _terminal : CM_Terminal; _gateName : String): CM_VehicleVisitRecord;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navpw1	Initial creation TFS: 54049 (55844)
22 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

vars
	expectErrors,
	usesRetroDateTime	: Boolean;
	pxyVvr, realVvr		: CM_VehicleVisitRecord; 
	gate				: CM_Gate;
	adminGate			: CM_GateArea;
	now,
	retroDT				: TimeStamp;
	yic					: String;
	subCarrier			: String;
	vbsTS				: CM_VehicleBookingTimeSlot;
	driverCode,
	driverName,
	carrierCode			: String;
	
begin
	self.assertTrueMsg(_vehicleReg &lt;&gt; null, method.name &amp; " | vehicleReg is null");
	self.assertTrueMsg(_driverCode &lt;&gt; null, method.name &amp; " | driverCode is null");
	self.assertTrueMsg(_driverName &lt;&gt; null, method.name &amp; " | driverName is null");
	self.assertNotNullMsg(_terminal, method.name &amp; " | terminal");
	
	expectErrors := self.opts.bool(UT_OPTS_ExpectErrors);
	
	if _gateName = null then
		gate := _terminal.getDefaultGate_IN();
	else
		gate := self.getGate(_gateName);
	endif;
	
	if self.opts.includesKey("RetroDT") then					//22.02.2024 navhl20 #62525
		retroDT := self.opts.timestamp("RetroDT");
		usesRetroDateTime := true;
	endif;
	
	self.assertNotNullMsg(gate, method.name &amp; " | gate");
	
	adminGate := gate.getFirstAGate_IN();
	
	if self.opts.includesKey(UT_OPTS_SubCarrier) then						
		subCarrier := self.opts.str(UT_OPTS_SubCarrier);
	endif;
	
	yic := self.opts.str(UT_OPTS_YardInterchangeArea);
	
	create pxyVvr transient;

	if self.opts.includesKey(UT_OPTS_VehicleBookingTS) then
		vbsTS := self.opts.obj(UT_OPTS_VehicleBookingTS).CM_VehicleBookingTimeSlot;		
		pxyVvr.setVehicleBookingTimeSlot(vbsTS);
	endif;
	
	if self.opts.includesKey(UT_OPTS_DriverCode) then
		driverCode := self.opts.str(UT_OPTS_DriverCode);
	else
		driverCode := _driverCode;
	endif;
	
	if self.opts.includesKey(UT_OPTS_DriverName) then
		driverName := self.opts.str(UT_OPTS_DriverName);
	else
		driverName := _driverName;
	endif;
	
	if self.opts.includesKey(UT_OPTS_Carrier) then
		carrierCode := self.opts.str(UT_OPTS_Carrier);
	else
		carrierCode := self.getProfileStr(UT_Profile.P_CARRIER);
	endif;
	
	pxyVvr.setProxyFlexiGate(driverCode, driverName, carrierCode, subCarrier, _vehicleReg, _state, yic, self.getTerminal(), gate,self.getGateLane(adminGate, 1), "");
	pxyVvr.setAutoComplete(self.opts.bool(UT_OPTS_AutoComplete));
	if retroDT &lt;&gt; null and usesRetroDateTime then										//22.03.2024 navhl20 #62863
		pxyVvr.setTimeIn(retroDT.date, retroDT.time);
	else
		pxyVvr.setTimeIn(now.date, now.time);
	endif;
	
	app.myTrxCA.trxCreateVehicleVisitFlexi(pxyVvr, realVvr, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realVvr, method.name &amp; " | realVvr");
	
	return realVvr;
	
epilog
	delete pxyVvr;
	
end;</source>
        <Parameter name="_vehicleReg" type="String"/>
        <Parameter name="_driverCode" type="String"/>
        <Parameter name="_driverName" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_gateName" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="xCreateWagon" id="40d20a2c-7c4a-49cd-88cd-68b26504a2fc">
        <source>xCreateWagon(_wagonCode, _wagonClassCode : String; _train : CM_Train; _terminal : CM_Terminal) : CM_Wagon;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	pxyWagon,
	realWagon	: CM_Wagon;
	wagonClass	: CM_WagonClass;
	railLine	: CM_RailLine;
	terminal	: CM_Terminal;
	ta			: CM_TerminalArea;
	
begin
	self.assertTrueMsg(_wagonCode &lt;&gt; null, method.name &amp; " | wagonCode is null");
	self.assertTrueMsg(_wagonClassCode &lt;&gt; null, method.name &amp; " | wagonClassCode is null");
	self.assertNotNullMsg(_train, method.name &amp; " | train");
	self.assertNotNullMsg(_terminal, method.name &amp; " | terminal");
	
	wagonClass := app.myRoot.allWagonClasses[_wagonClassCode];
	self.assertNotNullMsg(wagonClass, method.name &amp; " | wagonClass");
	
	if self.opts.includesKey(UT_OPTS_RailLine) then
		railLine := self.opts.obj(UT_OPTS_RailLine).CM_RailLine;
	endif;	
	
	create pxyWagon as wagonClass.getWagonVisitClassToCreate() transient;
	pxyWagon.setProxy(app.myPassport.myTerminal,
						_wagonCode,
						wagonClass,
						_train,
						_train,
						null,
						null,
						null,
						null,
						null,
						null,
						null);
						
	app.myTrxCA.trxCreateWagon(pxyWagon, realWagon, railLine, null, null, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realWagon, method.name &amp; " | realWagon");
	
	return realWagon;
	
epilog
	delete pxyWagon;
	
end;</source>
        <Parameter name="_wagonCode" type="String"/>
        <Parameter name="_wagonClassCode" type="String"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="xCreateWagonMaster" id="2b94c9da-3d23-4d32-a9ee-b57f7253f692">
        <source>xCreateWagonMaster(_wagonClassId : String; _wagonClass : CM_WagonClass) : CM_WagonMaster;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2023	navpw1	Initial creation TFS: 56796 (57081)

*/

vars
	pxyWagonMaster,
	realWagonMaster : CM_WagonMaster;
	carrier			: CM_Carrier;
	
begin
	self.assertTrueMsg(_wagonClassId &lt;&gt; null, method.name &amp; " | wagonClassId is null");
	self.assertNotNullMsg(_wagonClass, method.name &amp; " | wagonClass");
	
	if self.opts.includesKey(UT_OPTS_Carrier) then
		carrier := self.opts.obj(UT_OPTS_Carrier).CM_Carrier;
	else
		carrier := app.myRoot.allCarriers.first;
	endif;
	
	create pxyWagonMaster transient;
	pxyWagonMaster.setProxy(_wagonClassId, _wagonClass, carrier, 450,60000, 15000);
	pxyWagonMaster.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster( pxyWagonMaster, realWagonMaster, app.myPassport );	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realWagonMaster, method.name &amp; " | realWagonMaster");
	
	return realWagonMaster;
	
epilog
	delete pxyWagonMaster;
	
end;</source>
        <Parameter name="_wagonClassId" type="String"/>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
        <ReturnType type="CM_WagonMaster"/>
    </JadeMethod>
    <JadeMethod name="xCreateWoTaskCargo" id="ff1f6bc4-8fb2-4e09-bb62-9551ddfd4bf5">
        <source>xCreateWoTaskCargo(_pxyWorkOrder : CM_WorkOrder;_pxyWod : CM_WorkOrderDtl;_detailType : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI

*/


vars
	terminal 			 : CM_Terminal;
	realWorkOrder,
	pxyWorkOrder		 :  CM_WorkOrderTI;
	pxyWODtl,
	realWODtl 			 : CM_WorkOrderDtl;
	autoQ,
	autoRTQ 			 : Boolean;
	taskType 			 : Integer;
	requiredByDT,
	startByDT			 : TimeStamp;
	toDoTaskID 			 : Integer;
	toDoTask 			 : CM_ToDoTaskDesc;
	root		  		 : CM_Root;
	target,
	unpackLoc			: CM_TerminalArea;
	todoSet 			: CM_ToDoTaskDescSet;
	tiSet				: CM_TISet;
	ti					: CM_TrackedItem;
	vessel				: CM_Vessel;
	voyage 				: CM_Voyage;
	operator			: CM_Operator;
	subTerm1			: CM_SubTerminal;
	workOrderDetailType	: CM_WorkOrderDetailType;
	wodClass   		    : Class;
	lc					: CM_LocationsController;
begin
	
	root 	 := CM_Root.firstInstance;
	terminal := app.myPassport.myTerminal;

	/*
	Work Order DTL
	*/
	
	if self.opts.includesKey("RequiredByDT") then
		requiredByDT := opts.str("RequiredByDT").TimeStamp;
	endif;
	
	if self.opts.includesKey("StartByDT") then
		startByDT := opts.str("StartByDT").TimeStamp;
	endif;
	
	/*
	Move
	*/
	if self.opts.includesKey("AutoRTQ") then
		autoRTQ := opts.bool("AutoRTQ");
	endif;
	
	if self.opts.includesKey("TargetTA") then
		target := terminal.allTerminalAreas[opts.str('TargetTA')].CM_TerminalArea;
	endif;
	
	
	/*
	UnPack
	*/
	if self.opts.includesKey("UnpackTA") then
		unpackLoc := terminal.allTerminalAreas[opts.str('UnpackTA')].CM_TerminalArea;
	endif;
	
	
	if self.opts.includesKey("ToDoTaskID") then
		toDoTaskID:= opts.int("ToDoTaskID");
	endif;
	
	if toDoTaskID &lt;&gt; null then
		toDoTask := root.allToDoTaskDescriptions[toDoTaskID];
	endif;
	
	workOrderDetailType := app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_Cargo,_detailType];
	
	if workOrderDetailType &lt;&gt; null then
		
		wodClass := workOrderDetailType.getWodClass(WorkOrderMode_Cargo);
		
		create pxyWODtl as wodClass transient;
		_pxyWorkOrder.setProxyWorkOrderTask( pxyWODtl, requiredByDT, startByDT, false,_detailType, toDoTask);
		
		if pxyWODtl.isKindOf(CM_WodMove) then
			pxyWODtl.CM_WodMove.setProxyMove(null,target,autoRTQ,lc);
		endif;
	endif;
	

epilog

end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder"/>
        <Parameter name="_pxyWod" type="CM_WorkOrderDtl"/>
        <Parameter name="_detailType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xCreateWorkOrder" id="e9e1f384-c9ad-4c1c-870b-d59387992da6">
        <source>xCreateWorkOrder(_pxyWorkOrder : CM_WorkOrder io;
				_realWorkOrder : CM_WorkOrder io;
				_id 		   : String;
				_woStatus 	   : Integer;
				_tiSet 		   : CM_TISet;
				_allWod		   : CM_WorkOrderDtlArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task

*/

vars
	totalReq      : Integer;
	dtRequired,
	dtStart	      :	TimeStamp;
	remarks       : String;
	emails        : CM_EmailEntityByTypeNameDict;
	pxyWorkOrder  : CM_WorkOrder;
begin
	
	pxyWorkOrder := _pxyWorkOrder;
	
	deleteWorkOrder(_id);
	
	if self.opts.includesKey("TotalRequired") then
		totalReq := self.opts.int("TotalRequired");
	endif;
	
	if self.opts.includesKey("DtRequired") then
		dtRequired := self.opts.str("DtRequired").TimeStamp;
	endif;
	
	if self.opts.includesKey("DtStart") then
		dtStart := self.opts.str("DtStart").TimeStamp;
	endif;
	
	if self.opts.includesKey("Remarks") then
		remarks := self.opts.str("Remarks");
	endif;
	
	create emails transient;
	
	pxyWorkOrder.setProxy(		
			emails, 							//_allEmailAddresses
			null, 								//_customerReference
			false, 								//_emailNotification
			app.actualTimeServer, 				//_enteredByDT
			app.getMyUser(), 					//_enteredByUser 
			'',									//_approvedBy
			app.getMyUser().myOrganisation, 	// _myOrganisation
			app.myPassport.myTerminal, 			//_myTerminal
			remarks,  							//_remarks
			dtRequired,							//_requiredByDT
			dtStart, 							//_startAtDT
			_woStatus 							//_taskStatus    WO_STATUS_USERENTRY
			);
			
			
	pxyWorkOrder.setID( _id );						
	//pxyWorkOrder.CM_WorkOrderTI.setTotalRequired(totalReq);								//08.02.2023 navma1 #56457:[56458]
	app.myTrxCA.trxCreateWorkOrder(pxyWorkOrder, _realWorkOrder, app.myPassport);			//12.01.2023 navma1 #56141 Task#56147
	
epilog
	delete emails;
	_pxyWorkOrder.allWoDtls.purge;
	delete _pxyWorkOrder;
end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WorkOrder" usage="io"/>
        <Parameter name="_realWorkOrder" type="CM_WorkOrder" usage="io"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_woStatus" type="Integer"/>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_allWod" type="CM_WorkOrderDtlArray"/>
    </JadeMethod>
    <JadeMethod name="xDeleteCarrier" id="917ddd9c-f0d1-42e4-a20b-6b213e5d5a3d">
        <source>xDeleteCarrier(_code: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navpw1	Initial creation TFS: 54049 (55844)

*/

vars
	carrier		: CM_Carrier;
	vehicle 	: CM_Vehicle;
	terminal	: CM_Terminal;
	usedCarrier	: String;
	
begin
	carrier := self.getCarrier(_code);
	if carrier = null then
		return;
	endif;
	
	self.opts.addAssoc("DontDeleteCarrier", true);				// 20/08/2012
	foreach vehicle in carrier.vehicles do
		self.deleteVehicle(vehicle);
	endforeach;	
	
	// 03/03/2014 - cnwmh5 - Take into account if used for rail carrier on terminal
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals do
		usedCarrier := terminal.getConfig(DefRailCarrier).String;
		if usedCarrier = carrier.code then
			terminal.setConfig(DefRailCarrier, null);
		endif;
	endforeach;
	commitTransaction;

 	app.myTrxDA.trxDeleteCarrier(carrier, app.myPassport);

	self.assertNoTrxErrorsOrWarnings();
	self.assertIsDeletedMsg(carrier,  method.name &amp; " | carrier");
	
end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="xDeleteDriverDetails" id="791d6f31-eb3b-4590-98a3-11a50a23ded6">
        <source>xDeleteDriverDetails(_driverId : String; _terminal : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 August 2023	navpw1	Initial creation TFS: 56796

*/

vars
	driverDetails 		: CM_DriverDetails;
	
begin
	self.assertTrueMsg(_driverId &lt;&gt; null, method.name &amp; " | driverId is null");
	self.assertNotNullMsg(_terminal, method.name &amp; " | terminal");
	
	driverDetails := _terminal.allDriversByCode[_driverId];
	if driverDetails = null then
		return;
	endif;
	
	app.myTrxDA.trxDeleteDriverDetails(driverDetails, app.myPassport);
