    <JadeMethod name="validateMe" id="dfbbcb12-ca28-4d6b-86b8-9173f8999cc7">
        <source>validateMe();
// ---------------------------------------------------------------------------
// Created:     11 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'terminal', 'myTerminal', null);
		app.raiseCMException(Input_required_field_terminal, 'myTerminal', null); // cnwdb2	PAR 35364
		return;
	endif;

	if self.myUser = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'user', 'myUser', null);
		app.raiseCMException(Input_required_field_Usr, 'myUser', null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if self.mySecurityRole = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Security Role for ' &amp; self.myTerminal.name, null, null);
		app.raiseCMException1(Input_required_field_securRole,  self.myTerminal.name, null, null); // cnwdb2	PAR 35364


	endif;
	
	if self.myDefaultCargoType &lt;&gt; null and 
	   (not self.myTerminal.allCargoBOLTypes.includes(self.myDefaultCargoType)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Default cargo type "' &amp; self.myDefaultCargoType.description &amp; '" is invalid for terminal ' &amp; self.myTerminal.code);
		return;
	endif;
	
	if self.myDefaultBOLType &lt;&gt; null and 
	   (not self.myTerminal.allCargoBOLTypes.includes(self.myDefaultBOLType)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Default BOL type "' &amp; self.myDefaultBOLType.description &amp; '" is invalid for terminal ' &amp; self.myTerminal.code);
		return;
	endif;
	
	if self.myDefaultCargoBOLType &lt;&gt; null and 
	   (not self.myTerminal.allCargoBOLTypes.includes(self.myDefaultCargoBOLType)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Default cargo/BOL type "' &amp; self.myDefaultCargoBOLType.description &amp; '" is invalid for terminal ' &amp; self.myTerminal.code);
		return;
	endif;

end;</source>
    </JadeMethod>
</Class>
