    <JadeMethod name="setQueryPerformanceRatings" id="abbc2fbb-f951-4ceb-8b12-1b7f083523eb">
        <source>setQueryPerformanceRatings( _controller : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2019	jlgndl1	Initial creation	TFS 45891

*/

vars

	root : CM_Root;
	menu : CM_MenuEntity;
	muq : CM_MenuUserQuery;
	queryMode : Integer;
	clh : CM_QueryCriteriaLineHolder;
	cl : CM_SelectorCriteriaLine;
	obj : Object;
	qp : CM_QueryProperty;
	realQueryProperty : CM_QueryProperty;
	qDef : CM_QueryDefinition;
	count : Integer;
	
	objArray : ObjectArray;
	iter : Iterator;
	dynaDict : DynaDictionary;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog( method.qualifiedName &amp; 'Setting Query Property Performance Ratings ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting Query Property Performance Ratings") ;	
	endif;
	
	root := app.myRoot;
	
	if root.myQueryMenuRoot &lt;&gt; null then
		foreach menu in root.myQueryMenuRoot.allMenuUserItemsWithAMenuItem do
			if not menu.isKindOf (CM_MenuUserQuery) then
				continue;
			endif;
			muq := menu.CM_MenuUserQuery;

			queryMode := muq.queryMode;
			
			qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.TrackedItem_Query_Type, queryMode];		
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.BOL_Query_Type, queryMode];
			endif;
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.Snapshot_Query_Type, queryMode];
			endif;
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.Transaction_Query_Type, queryMode];
			endif;
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.Invoicing_Query_Type, queryMode];
			endif;
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.Cash_Query_Type, queryMode];
			endif;
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.Audit_Query_Type, queryMode];
			endif;
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.BookRef_Query_Type, queryMode];
			endif;
			if qDef = null then
				qDef := root.allQueryDefinitionObjects [CM_QueryDefinition.Release_Query_Type, queryMode];
			endif;
				
			if qDef = null then
				continue;
			endif;
			
			foreach clh in muq.allCriteriaLineHolders discreteLock do
				foreach cl in clh.allCriteriaLines do
					obj := cl.myQueryProperty;
					if obj = null then
						continue;
					endif;
					if not obj.isKindOf( CM_QueryProperty ) then
						continue;
					endif;
					qp := cl.myQueryProperty;
					if qp.performanceRating &lt;&gt; 0 then
						continue;
					endif;
					realQueryProperty := qDef.allQueryProperties.getAtKey(qp.propertyName);
					if realQueryProperty &lt;&gt; null
					and realQueryProperty.propertyClassName = qp.propertyClassName
					and realQueryProperty.propertyName = qp.propertyName
					then
						beginTransaction;
						qp.setPerformanceRating( realQueryProperty.performanceRating );
						commitTransaction;
						count := count + 1;
					endif;
				endforeach;
			endforeach;
			
		endforeach;
	endif;
	
	// now go for everything else
	create dynaDict transient;
	dynaDict.setMembership( CM_QueryProperty );
	dynaDict.addMemberKey(CM_QueryProperty::propertyClassName.name, false, false);
	dynaDict.addMemberKey(CM_QueryProperty::propertyName.name, false, false);
	dynaDict.endKeys(true);
	
	create objArray transient;
	CM_QueryProperty.allInstances( objArray, 0, true );
	iter := objArray.createIterator;
	while iter.next( qp ) do
		if qp.performanceRating &lt;&gt; 0 then
			continue;
		endif;
		dynaDict.add( qp );
	endwhile;
	
	foreach obj in dynaDict do
		qDef := null;
		qp := obj.CM_QueryProperty;
		if qp.propertyClassName = CM_Container.name then
				qDef := CM_QDefContainer.firstInstance;
				
		elseif qp.propertyClassName = CM_TrackedItem.name then
			qDef := CM_QDefTrackedItem.firstInstance;
			
		elseif qp.propertyClassName = CM_BreakBulkGeneric.name then
			qDef := CM_QDefBreakBulkGeneric.firstInstance;
			
		elseif qp.propertyClassName = CM_Log.name then
			qDef := CM_QDefLog.firstInstance;
			
		elseif qp.propertyClassName = CM_Car.name then
			qDef := CM_QDefCar.firstInstance;
			
		elseif qp.propertyClassName = CM_TILC.name then
			qDef := CM_QDefTILC.firstInstance;
			
		elseif qp.propertyClassName = CM_TITransaction.name then
			qDef := CM_QDefCargoTransaction.firstInstance;
			
		elseif qp.propertyClassName = CM_EventTransaction.name then
			qDef := CM_QDefEventTransaction.firstInstance;
			
		elseif qp.propertyClassName = HMS_VTMISTransaction.name then
			qDef := CM_QDefHMSTransaction.firstInstance;
			
		elseif qp.propertyClassName = CM_DynamicObject_Snapshot.name then
			qDef := CM_QDef_Snapshot.firstInstance;
			
		else
			write qp.propertyClassName &amp; "::" &amp; qp.propertyName;
			continue;
		endif;
		
		realQueryProperty := qDef.allQueryProperties.getAtKey(qp.propertyName);
		
		//special case
		if realQueryProperty = null
		and ( qp.propertyName = CM_TrackedItem::weightCertifiedName.name or qp.propertyName = CM_TrackedItem::weightCertifiedReference.name )
		then
			beginTransaction;
			qp.setPerformanceRating( CM_QueryProperty.Simple );
			commitTransaction;
			count := count + 1;
			continue;
		endif;
		
		if realQueryProperty &lt;&gt; null
		and realQueryProperty.propertyClassName = qp.propertyClassName
		and realQueryProperty.propertyName = qp.propertyName
		then
			beginTransaction;
			qp.setPerformanceRating( realQueryProperty.performanceRating );
			commitTransaction;
			count := count + 1;
		endif;
		
	endforeach;
	
	
	app.writeLog( method.qualifiedName &amp; 'Completed Setting ' &amp; count.String &amp; ' Query Property Performance Ratings ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry('Completed Setting ' &amp; count.String &amp; ' Query Property Performance Ratings') ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

	delete objArray;
	delete iter;
	delete dynaDict;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setSecondaryCurrencies" id="455dffcf-f5ee-47b7-859b-5a6c4e0f7d19">
        <source>setSecondaryCurrencies(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars
	
	root: CM_Root;
	term : CM_Terminal;
	secCurrencyName : String;
	divideRate : Decimal [16,6];
	multiplyRate : Decimal [16,6];
	cashRoundingType : Integer;
	cashRoundUpAmount : Decimal[12,6];
	newRate : Decimal [16,8];
	realCurrencyType : CM_CurrencyType;
	pxyCurrencyType : CM_CurrencyType;
	pxyCurrencyRate : CM_CurrencyRate;
	realCurrencyRate : CM_CurrencyRate;
	startTS : TimeStamp;
	
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Create Secondary Currencies from existing Config", null);

	root := CM_Root.firstInstance;
	startTS.setDate( "01/01/1900".Date );
	startTS.setTime( "00:00:01".Time );
	
	foreach term in app.myRoot.allTerminals do
		secCurrencyName := term.getConfig(CashSecondPayCurrency).String.trimBlanks;
		divideRate := term.getConfig(CashSecPayDivConvertRate).Decimal;
		multiplyRate := term.getConfig(CashSecondPayConvertRate).Decimal;
		cashRoundingType := term.getConfig(CashRoundingType).Integer;
		cashRoundUpAmount := term.getConfig(CashRoundUpAmount).Decimal;	
		if secCurrencyName = null then
			continue;
		endif;
		if ( not divideRate &gt; 0 ) and ( not multiplyRate &gt; 0 ) then
			continue;
		endif;
		if multiplyRate &gt; 0 then
			newRate := multiplyRate;
		elseif divideRate &gt; 0 then
			newRate := 1 / divideRate;
		endif;
		
		//find currency, if not found create new one and rate.
		realCurrencyType := app.myRoot.allCurrencyTypes.getAtKey( secCurrencyName[1:10] );
		if realCurrencyType &lt;&gt; null then
			continue;
		endif;
		
		create pxyCurrencyType transient;
		pxyCurrencyType.setProxy(	secCurrencyName[1:10],	//_code : String;
									'$',	//_currencySymbol : String;
									secCurrencyName,	//_description : String;
									cashRoundUpAmount,	//_roundingInterval : Decimal;
									cashRoundingType	//_roundingType : Integer
									);
		app.myTrxCA.trxCreateCurrencyType(pxyCurrencyType, realCurrencyType, app.myPassport);
		if realCurrencyType = null then
			app.writeLog(method.qualifiedName &amp; " Failed to convert secondary currency for " &amp; term.code, LogINFO);
			continue;
		endif;
		
		create pxyCurrencyRate transient;
		pxyCurrencyRate.setProxy(	startTS,	//_effectiveDT : TimeStamp;
									realCurrencyType,	//_myCurrencyType : CM_CurrencyType;
									newRate	//_rate : Decimal
									);
		app.myTrxCA.trxCreateCurrencyRate(pxyCurrencyRate, realCurrencyRate, app.myPassport);
		if realCurrencyRate = null then
			app.writeLog(method.qualifiedName &amp; " Failed to convert secondary currency RATE for " &amp; term.code, LogINFO);
			continue;
		else
			app.writeLog(method.qualifiedName &amp; " Created " &amp; realCurrencyType.code &amp; " currency from existing Config", LogINFO);
		endif;
	
	endforeach;

	app.writeLog(method.qualifiedName &amp; " Created Secondary Currencies from existing Config", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Created Secondary Currencies from existing Config") ;	
	endif;
	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setSpecialStowConfigs" id="7b502dab-b995-440b-b2d2-c1556b02681b">
        <source>setSpecialStowConfigs(_controller : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars
	term : CM_Terminal;

begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Setting 'Consider Haz and OD as Special Stow' terminal configs", null);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Setting 'Consider Haz and OD as Special Stow' terminal configs");
	endif;
	
	beginTransaction;
	foreach term in app.myRoot.allTerminals do
		term.setConfig( ConsiderHazAsSpecialStow, true );
		term.setConfig( ConsiderODAsSpecialStow, true );
	endforeach;
	commitTransaction;

	app.writeLog(method.qualifiedName &amp; " Completed Setting 'Consider Haz and OD as Special Stow' terminal configs", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Completed Setting 'Consider Haz and OD as Special Stow' terminal configs");
	endif;
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setUseRelReqAnyVoyLoad" id="8753b8c2-e339-4beb-9835-b7c32bd3494c">
        <source>setUseRelReqAnyVoyLoad(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2018	jlgndl1	Initial creation	TFS 38679

*/

vars

	term : CM_Terminal;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Setting 'Use Release Request Any Order For Voyage Loading'", null);
	
	beginTransaction;
	foreach term in app.myRoot.allTerminals do
		term.setConfig( UseRelReqAnyVoyLoad, true );
	endforeach;
	commitTransaction;

	app.writeLog(method.qualifiedName &amp; " Have set 'Use Release Request Any Order For Voyage Loading'", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Have set 'Use Release Request Any Order For Voyage Loading'") ;	
	endif;
	self.addScriptRun(method.name);

epilog

end;</source>
