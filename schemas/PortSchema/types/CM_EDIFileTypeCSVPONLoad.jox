    <JadeMethod name="getMyOperator" id="6a91110a-cfeb-4a5b-92fd-7a9bb3d1e0a8">
        <source>getMyOperator(): CM_Operator;
//----------------------------------------------------------------
//	Created:	03 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	return app.myRoot.allOperators["PON"];

end;</source>
        <ReturnType type="CM_Operator"/>
