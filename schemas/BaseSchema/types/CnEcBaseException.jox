        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="cnEcIsBaseException" id="86e4a6a4-ce0f-4bdd-9776-0180275a4c47">
        <source>cnEcIsBaseException(): Boolean;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Refer to the superclass implementation on the Exception class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="errorItem" id="ef8568b4-dd4f-4a7a-a758-6c82e24fd9c8">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>errorItem(set: Boolean; _value: String io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Mapping method to ensure that the length of the error item (i.e. the
//				error message) will not exceed the maximum allowable length.  If the
//				message is too long, the remainder will be truncated.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	maximumLength	: Integer;
	
begin
	if set then
		maximumLength	:=	self.class().cnEcGetStringPropertyLength(method.name);
		
		if _value.length &gt; maximumLength then
			self.isErrorTruncated	:=	true;
			self.fullMessage		:=	_value;
			_value	:=	_value[1:(maximumLength - 3)] &amp; "...";
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</ExceptionClass>
