    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myCurrencyFormat" id="ec82f3c4-44da-4f99-9847-e35d3de1667a">
        <embedded/>
        <type name="CurrencyFormat"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="caption" id="de3f0724-b155-460e-aff5-6539b2e80d41">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>caption(set: Boolean; value: String io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		08 October 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	negative	: String;

begin
	if set then
		if self.myCurrencyFormat &lt;&gt; null then
			negative := self.myCurrencyFormat.negativeSign;
		else
			negative := "-";
		endif;
		
		self.cnEcSetPositiveValueColor(value.pos(negative, 1) = 0);
		value	:=	value.Decimal.currencyFormat();		
	else
		value 	:=	value.cnEcAsNumeric(self.myCurrencyFormat);
	endif;
	
	inheritMethod(set, value);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setAlignment" id="04578e20-04da-4154-bb88-ebbcdf9462fd">
        <updating/>
        <source>setAlignment() updating, protected;
// --------------------------------------------------------------------------------
// Created:		19 September 2002 by cnwdad3
//
// Purpose:		Sets the receiver's alignment to be right-aligned, and vertically middle.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.alignment		:=	Label.Alignment_Right_Middle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="b58adcba-a19d-4938-b027-44f738d45582">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		08 October 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);

	self.myCurrencyFormat	:=	app.currentLocaleInfo.currencyInfo;
	self.setAlignment();
	self.caption			:=	self.caption;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
