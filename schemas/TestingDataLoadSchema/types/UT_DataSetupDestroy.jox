    <JadeMethod name="dataNeedsLoading" id="6fc40188-4767-437d-a30a-7ef09bb00269">
        <source>dataNeedsLoading(_xmlElement : JadeXMLElement) : Boolean;
/*

Purpose:		Check to see if the data needs loading

Date			Who		Reason
06/12/2017		jlgmh5	Initial creation

*/

vars

	attribute					: JadeXMLAttribute;
	
	needsLoading 				: Boolean;

begin

	needsLoading := false;
	
	attribute := _xmlElement.getAttributeByName("DontLoad");
	
	needsLoading := attribute = null;
	
	return needsLoading;

end;
</source>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="executeMethod" id="ee61dc1d-51bb-43e9-8c65-47bd93f45163">
        <source>executeMethod(_methodSource : String) : String;

/*

Purpose:		Execute the transient method

Date			Who		Reason
22/02/2012		cnwmh5	Initial creation

*/

vars
	
	methodObj		: JadeMethod;
	exceptionObj	: SystemException;
	
	methodName			: String;
	errorCode			: Integer;
	errorPos			: Integer;
	errorLength			: Integer;
	
	result				: String;
	
begin

	methodName := _methodSource[1:_methodSource.pos("(", 1)-1];

	methodObj := process.createTransientMethod(methodName,
		UT_DSL,
		currentSchema,
		_methodSource,
		false,
		Boolean,
		errorCode,
		errorPos,
		errorLength);
	
	if errorCode &lt;&gt; 0 then
		create exceptionObj transient;
		
		exceptionObj.errorCode	:=	errorCode;
		exceptionObj.errorItem	:=	_methodSource[errorPos:errorLength + 1];
		
		if exceptionObj.text.pos("Undefined message number", 1) &gt; 0 then
			exceptionObj.extendedErrorText	:=	process.getErrorText(errorCode);
		endif;
		
		raise exceptionObj;
		
		return errorCode.String; // null;
	endif;
	
	result := process.executeTransientMethod(methodObj, self).String;
	
	return result;
	
epilog
	if methodObj &lt;&gt; null then
		process.deleteTransientMethod(methodObj);
	endif;
	
end;</source>
        <Parameter name="_methodSource" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleFormatException" id="acf6165e-c905-48f3-8fe7-277ebf3e4f5d">
        <source>handleFormatException(_ex : Exception; _label : String) : Integer;
// ---------------------------------------------------------------------------
// Created:		17 January 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	errorText: String;
begin
	errorText := "Opening the file caused an error";
	errorText := errorText &amp; Lf &amp; _ex.text &amp; Lf &amp; Lf &amp; "Aborting " &amp; _label &amp; " Operation!";
	app.msgBox(errorText, "File Open Error",
		MsgBox_OK_Only  + MsgBox_System_Modal + MsgBox_Exclamation_Mark_Icon);

	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;

	return Ex_Abort_Action;
end;</source>
        <Parameter name="_ex" type="Exception"/>
        <Parameter name="_label" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processActivePorts" id="910e1a6f-b98d-403d-96d3-268e8d8abdcb">
        <source>processActivePorts(_portXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Set the active ports

Date			Who		Reason
07/03/2012		cnwmh5	Initial creation

*/

vars

	obj						: Object;
	xmlElement				: JadeXMLElement;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;

begin

	varsStr := 'port				: CM_Port;' &amp; CrLf;
		
	// set the active ports
	foreach obj in _portXMLElement.childNodes do
		if obj.isKindOf(JadeXMLComment) then
			continue;
		endif;
		xmlElement := obj.JadeXMLElement;
		if not self.dataNeedsLoading(xmlElement) then
			continue;
		endif;
		app.writeLog("Activating port " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Activating port " &amp; xmlElement.tagName &amp; ".  Please wait...";
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'port := app.myRoot.allPorts["' &amp; xmlElement.tagName &amp; '"];' &amp; CrLf &amp;
			Tab &amp; 'beginTransaction;' &amp; CrLf &amp; 
			Tab &amp; 'if port &lt;&gt; null then' &amp; CrLf &amp;
			Tab &amp; Tab &amp; 'port.setPropertyValue("isActive", true);' &amp; CrLf &amp; 
			Tab &amp; 'endif;' &amp; CrLf &amp; 
			Tab &amp; 'commitTransaction;' &amp; CrLf;
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_portXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processAddTerminalToUsers" id="dea5b3e8-fddb-4ac7-8ff3-b0dff4f0c3a6">
        <source>processAddTerminalToUsers(_userXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required users	

Date			Who		Reason
24/03/2018		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	xmlElement3				: JadeXMLElement;
	terminalsElement		: JadeXMLElement;
	rangeAttribute			: JadeXMLAttribute;
	obj						: Object;
	user					: CM_User;
	terminal				: CM_Terminal;
	
	secRoleTerm   			: CM_SecurityRoleTerminal;
	
	tokens					: StringArray;
	userArray				: ObjectArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	password				: String;
	
	userName				: String;
	addToUsers				: String;
	
begin

	varsStr := varsStr &amp; Tab &amp; 'user				: CM_User;' &amp; CrLf &amp;
		Tab &amp; 'pxyUser				: CM_User;' &amp; CrLf &amp;
		Tab &amp; 'terminal				: CM_Terminal;' &amp; CrLf &amp; 
		Tab &amp; 'userTerm 			: CM_UserTerminal;' &amp; CrLf &amp;
		Tab &amp; 'secRoleTerm   		: CM_SecurityRoleTerminal;' &amp; CrLf &amp;
		Tab &amp; 'cargoType			: CM_CargoType;' &amp; CrLf &amp;
		Tab &amp; 'bolType				: CM_BOLType;' &amp; CrLf &amp;
		Tab &amp; 'cargoBOLType			: CM_CargoBOLType;' &amp; CrLf &amp; CrLf;
		
	epilogStr := epilogStr &amp; Tab &amp; 'delete userTerm;' &amp; CrLf &amp;
		Tab &amp; 'pxyUser.allSubSystemStateObjects.removeInvalidObjects();' &amp; CrLf &amp;
		Tab &amp; 'delete pxyUser;' &amp; CrLf;
		
	create tokens transient;
			
	foreach obj in _userXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		self.setupOptsAssoc(xmlElement.getElementByTagName('opts'), codeStr);
	
		
		tokens.clear();
		addToUsers := self.returnElementText(xmlElement.getElementByTagName("addToUsers")).String;
		addToUsers.getTokensForDelimiter(";", tokens);		
	
		foreach user in app.myRoot.allUsers do
		
			password := '"p@s5word1"';
			if user.code.toUpper().cnContains("MH5") then
				password := '"Silver!2"';
			endif;		
		
			if not tokens.includes(user.code[1:3]) and not tokens.includes(user.code) then
				continue;
			endif;
			
			codeStr := codeStr &amp; Tab &amp; 'user := app.myRoot.allUsers["' &amp; user.code &amp; '"].CM_User;' &amp; CrLf;
		
			// add the required terminals to the user
			terminalsElement := xmlElement.getElementByTagName("TerminalsToAdd");
			
				foreach obj in terminalsElement.childNodes do
					xmlElement2 := obj.JadeXMLElement;
				
					// get the terminal
					codeStr := codeStr &amp; Tab &amp; 'terminal := app.myRoot.allTerminals["' &amp; xmlElement2.tagName &amp; '"].CM_Terminal;' &amp; CrLf &amp;
						Tab &amp; 'self.assertNotNull(terminal);' &amp; CrLf &amp;
						Tab &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf;
						
					terminal := app.myRoot.allTerminals[xmlElement2.tagName].CM_Terminal;
					if user.allUserTerminals.includesKey(terminal) then
						continue;
					endif;
					
					// create the pxyuser to update
					codeStr := codeStr &amp;  Tab &amp; 'delete userTerm;' &amp; CrLf &amp;
						Tab &amp; 'delete pxyUser;' &amp; CrLf &amp;
						Tab &amp; 'pxyUser := app.createUpdateProxy(user).CM_User;' &amp; CrLf;
					
					// get the security role
					secRoleTerm := CM_SecurityRoleTerminalRoot.firstInstance;
					xmlElement3 := xmlElement2.getElementByTagName("TermSecurityRole");
					if xmlElement3 &lt;&gt; null then
						codeStr := codeStr &amp; Tab &amp; 'secRoleTerm := app.myRoot.allRoles[' &amp; self.returnElementText(xmlElement3).String &amp; '].CM_SecurityRoleTerminal;' &amp; CrLf;
					endif;
					
					// create user term
					codeStr := codeStr &amp; Tab &amp; 'create userTerm transient;' &amp; CrLf &amp;
						Tab &amp; 'userTerm.setForProxy(terminal, pxyUser, secRoleTerm, cargoType,	bolType, cargoBOLType);' &amp; CrLf &amp;
						Tab &amp; 'app.myTrxUA.trxUpdateUser(pxyUser, ' &amp; password &amp; ', app.myPassport);' &amp; CrLf &amp; CrLf;
					
				endforeach;		
				
			endforeach;
			
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

	delete tokens;

end;
</source>
        <Parameter name="_userXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processAdminDetails" id="d078e21a-1f80-4fb9-bc78-b1b5185871ba">
        <source>processAdminDetails(_adminXMLElement : JadeXMLElement);

/*

Purpose:		Create the Admin Details	

Date			Who		Reason
22/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement		: JadeXMLElement;
	obj				: Object;
	
	methodStr		: String;
	
begin

	foreach obj in _adminXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		methodStr := self.MethodString;
		
		if xmlElement.tagName = "Operator" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Operator");
			//self.processOperator(xmlElement, methodStr);
		elseif xmlElement.tagName = "User" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "User");
			//self.processUser(xmlElement, methodStr);
		elseif xmlElement.tagName = "Organisation" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "Organisation");
			//self.processOrganisation(xmlElement, methodStr);
		elseif xmlElement.tagName = "ShippingLine" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "ShippingLine");
			//self.processShippingLine(xmlElement, methodStr);
		elseif xmlElement.tagName = "UserHookCode" then
			methodStr.cnReplaceString("&lt;^%For^%&gt;", "UserHookCode");
			self.processSystemUserHookCodes(xmlElement, methodStr);
		endif;

		if methodStr.pos("&lt;^%vars^%&gt;", 1) &gt; 0 or methodStr.pos("&lt;^%code^%&gt;", 1) &gt; 0 or 
				methodStr.pos("&lt;^%epilog^%&gt;", 1) &gt; 0 then
			continue;
		endif;
		
		write methodStr &amp; CrLf &amp; CrLf;
		
		// execute the transient method
		self.executeMethod(methodStr);
		
	endforeach;


end;
</source>
        <Parameter name="_adminXMLElement" type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="processAvailGrades" id="3cd94e07-df78-472e-8a23-56b22781d6fa">
        <source>processAvailGrades(_availGradeXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the availability grade

Date			Who		Reason
06/03/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	code					: Integer;
	suitableForRelease		: Boolean;
	
begin
	
	codeStr := codeStr &amp; CrLf;
	
	foreach obj in _availGradeXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		if not self.dataNeedsLoading(xmlElement) then
			continue;
		endif;
		
		code := self.returnElementText(xmlElement.getElementByTagName('code')).Integer;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		suitableForRelease := self.returnElementText(xmlElement.getElementByTagName('suitableForRelease')).Boolean;
		codeStr := codeStr &amp; Tab &amp; 'self.addAvailabilityGrade(' &amp; code.String &amp; ', ' &amp; description &amp; 
			', ' &amp; suitableForRelease.String &amp; ', false);' &amp; CrLf;
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_availGradeXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processBookings" id="284d67c0-4181-45d5-8453-159098b3ceba">
        <source>processBookings(_bookingElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required gate(s)

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	bookingElement			: JadeXMLElement;
	elementItem				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	bookingItemElement		: JadeXMLElement;
	element2				: JadeXMLElement;
	attribute				: JadeXMLAttribute;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	isContainer				: Boolean;
	
begin
	
	varsStr := varsStr &amp; CrLf &amp;	Tab &amp; 'bookingItem	: CM_BRefItemContainer;' &amp; CrLf &amp; 
		Tab &amp; 'operator 				: CM_Operator;' &amp; CrLf &amp;
		Tab &amp; 'terminal					: CM_Terminal;' &amp; CrLf &amp;
		Tab &amp; 'voyage : CM_Voyage;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'bookingItems				: ObjectArray;' &amp; CrLf;
		
	codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'create bookingItems transient;' &amp; CrLf;
	
	epilogStr := epilogStr &amp; 'app.myPassport.setMyTerminal(terminal);' &amp; CrLf &amp; 
		Tab &amp; 'delete bookingItems;' &amp; CrLf;
	
	foreach obj in _bookingElement.childNodes do
		bookingElement := obj.JadeXMLElement;
		
		if not self.dataNeedsLoading(bookingElement) then
			continue;
		endif;
		
		app.writeLog("Creating booking " &amp; bookingElement.tagName &amp; ". Please wait...", LogINFO);
		write "Creating booking " &amp; bookingElement.tagName &amp; ". Please wait...";
		
		bookingItemElement := bookingElement.getElementByTagName("BookingItems");
		if bookingItemElement &lt;&gt; null then
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'bookingItems.clear();' &amp; CrLf;
			foreach obj in bookingItemElement.childNodes do
				elementItem := obj.JadeXMLElement;
				if not self.dataNeedsLoading(elementItem) then
					continue;
				endif;
				
				optsElement := elementItem.getElementByTagName('opts');
				self.setupOptsAssoc(optsElement, codeStr);
				
				attribute := bookingElement.getAttributeByName("Terminal");
				codeStr := codeStr &amp; Tab &amp; "terminal := app.myPassport.myTerminal;" &amp; CrLf &amp; 
					Tab &amp; 'app.myPassport.setMyTerminal(app.myRoot.allTerminals["' &amp; attribute.value &amp; '"]);' &amp; CrLf &amp; CrLf;
				
				codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; attribute.value &amp; '");' &amp; CrLf;
				
				element2 := elementItem.getElementByTagName("CargoType");
				attribute := element2.getAttributeByName("Name");
				
				if attribute.value = "ISO Container" then
					isContainer := true;
					codeStr := codeStr &amp; Tab &amp; 'bookingItem := self.addBookingItemForContainer(' &amp; self.returnElementText(elementItem.getElementByTagName("ISOType")).String &amp; 
						', ' &amp; self.returnElementText(elementItem.getElementByTagName("Commodity")).String &amp;
						', ' &amp; self.returnElementText(elementItem.getElementByTagName("Quantity")).String &amp; ');' &amp; CrLf;
					codeStr := codeStr &amp; Tab &amp; 'bookingItems.add(bookingItem);' &amp; CrLf;
				endif;
				
			endforeach;
		
		endif;
		
		optsElement := bookingElement.getElementByTagName('opts');
		if optsElement = null then
			codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf; // &amp;
		else
			self.setupOptsAssoc(optsElement, codeStr);
		endif;
		attribute := bookingElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; attribute.value &amp; '");' &amp; CrLf;
		
		codeStr := codeStr &amp; Tab &amp; 'operator := self.getOperator(' &amp; self.returnElementText(bookingElement.getElementByTagName("OperatorCode")).String &amp; ');' &amp; CrLf;
		codeStr := codeStr &amp; Tab &amp; 'voyage := self.getVoyage(' &amp;self.returnElementText(bookingElement.getElementByTagName("VoyageCode")).String &amp; ');' &amp; CrLf;
		
		if isContainer then
			codeStr := codeStr &amp; Tab &amp; 'self.addBookingForContainer("' &amp; bookingElement.tagName &amp; '", operator, voyage, ' &amp; 
				self.returnElementText(bookingElement.getElementByTagName("DischargePort")).String &amp; ', bookingItems);' &amp; CrLf;
		endif;
		
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_bookingElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processCargoCheckItems" id="3aac2e37-45ba-4b6c-9101-13f381465748">
        <source>processCargoCheckItems(_checkItemXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the terminal cargo check items

Date			Who		Reason
09/11/2017		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	termAttribute			: JadeXMLAttribute;
	toDoTaskDescElement		: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	required				: Boolean;
	requiresExtractInfo		: String;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'obj				: Object;' &amp; CrLf &amp;
		Tab &amp; 'cargoCheck			: CM_CargoCheck;' &amp; CrLf &amp;
		Tab &amp; 'terminal				: CM_Terminal;' &amp; CrLf &amp;
		Tab &amp; 'toDoTaskDesc			: CM_ToDoTaskDesc;' &amp; CrLf &amp;
		Tab &amp; 'toDoTask				: CM_ToDoTask;' &amp; CrLf &amp; CrLf &amp; 
		Tab &amp; 'objectArray				: ObjectArray;' &amp; CrLf &amp; CrLf &amp; 
		Tab &amp; 'required				: Boolean;' &amp; CrLf &amp;
		Tab &amp; 'requiresExtractInfo		: String;' &amp; CrLf &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'create objectArray transient;' &amp; CrLf;
	
	epilogStr := 'delete objectArray;';
	
	foreach obj in _checkItemXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		app.writeLog("Creating Cargo Check Item " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating Cargo Check Item " &amp; xmlElement.tagName &amp; ".  Please wait...";
		
		// get the terminal
		termAttribute := xmlElement.getAttributeByName("Terminal");
		codeStr := codeStr &amp; Tab &amp; 'self.opts.purge();' &amp; CrLf &amp;
			Tab &amp; 'self.opts.addAssoc("Terminal", "' &amp; termAttribute.value &amp; '");' &amp; CrLf &amp;
			Tab &amp; 'terminal := app.myRoot.allTerminals["' &amp; termAttribute.value &amp; '"].CM_Terminal;' &amp; CrLf &amp; CrLf;
		
		// get the cargo check
		codeStr := codeStr &amp; Tab &amp; 'cargoCheck := terminal.allCargoChecks[' &amp; self.returnElementText(xmlElement.getElementByTagName("cargoCheck")).String &amp; '.Integer].CM_CargoCheck;' &amp; CrLf &amp;
			Tab &amp; 'self.assertNotNull(cargoCheck);' &amp; CrLf &amp; CrLf;
		
		// delete the cargo check item
		codeStr := codeStr &amp; Tab &amp; 'objectArray.clear();' &amp; CrLf &amp; 
			Tab &amp; 'cargoCheck.allCargoCheckItems.copy(objectArray);' &amp; CrLf &amp; 
			Tab &amp; 'foreach obj in objectArray do' &amp; CrLf &amp; 
			Tab &amp; '	if obj.CM_CargoCheckItem.name = "' &amp; xmlElement.tagName &amp; '" then' &amp; CrLf &amp; 
			Tab &amp; '		self.deleteCargoCheckItem(obj.CM_CargoCheckItem);' &amp; CrLf &amp; 
			Tab &amp; '	endif;' &amp; CrLf &amp; 
			Tab &amp; 'endforeach;' &amp; CrLf &amp;  CrLf;
		
		// create the cargo check item
		required := (xmlElement.getElementByTagName("required") &lt;&gt; null);
		toDoTaskDescElement := xmlElement.getElementByTagName("toDoTaskDesc");
		if toDoTaskDescElement &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'toDoTaskDesc := app.myRoot.allToDoTaskDescriptions[' &amp; self.returnElementText(toDoTaskDescElement).String &amp; '.Integer];' &amp; CrLf;
		endif;
		requiresExtractInfo := self.returnElementText(xmlElement.getElementByTagName("requiresExtractInfo")).String;
	
		codeStr := codeStr &amp; Tab &amp; 'self.addCargoCheckItem(cargoCheck, "' &amp; xmlElement.tagName &amp; '", requiresExtractInfo, toDoTaskDesc, toDoTask, required);' &amp; CrLf &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_checkItemXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processCargoTypes" id="4709edb7-7779-4906-9640-0dc56d88cc03">
        <source>processCargoTypes(_cargoTypesXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the cargo Types

Date			Who		Reason
01/03/2012		cnwmh5	Initial creation
						Need to create a delete the allCommodities dict as it
						is passed by opts and the purge is making it invalid

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	allCommodElement		: JadeXMLElement;
	terminalElement			: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	hasSubCargo				: Boolean;
	handlingType			: String;
	trackAs					: String;
	
begin
	
	varsStr := CrLf &amp; Tab &amp; 'terminal			: CM_Terminal;' &amp; CrLf &amp; CrLf &amp; 
		Tab &amp; 'terminalSet			: CM_TerminalSet;' &amp; CrLf &amp; 
		Tab &amp; 'tokens				: StringArray;' &amp; CrLf &amp;
		Tab &amp; 'allCommodities	: CM_CommodityByCodeDict;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'str				: String;' &amp; CrLf &amp; 
		Tab &amp; 'count			: Integer;' &amp; CrLf &amp; CrLf;

	epilogStr := CrLf &amp; Tab &amp; 'delete terminalSet;' &amp; CrLf &amp;	
		Tab &amp; 'delete allCommodities;' &amp; CrLf &amp;
		Tab &amp; 'delete tokens;' &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'create terminalSet transient;' &amp; CrLf &amp; 
		Tab &amp; 'create allCommodities transient;' &amp; CrLf &amp;
		Tab &amp; 'create tokens transient;' &amp; CrLf &amp; CrLf;

	foreach obj in _cargoTypesXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		app.writeLog("Creating Cargo Type " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating Cargo Type " &amp; xmlElement.tagName &amp; ".  Please wait...";
		
		hasSubCargo := self.returnElementText(xmlElement.getElementByTagName('hasSubCargo')).Boolean;
						
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
				
		trackAs := self.returnElementText(xmlElement.getElementByTagName('TrackAs')).String;
		if trackAs &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("TrackAs", ' &amp; trackAs &amp; ');' &amp; CrLf;
		endif;
		
		// get commodities for the cargo
		allCommodElement := xmlElement.getElementByTagName("allCommodities");
		if allCommodElement &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'allCommodities.clear();' &amp; CrLf;
			self.returnArrayDetails(allCommodElement, 'allCommodities', 'root', codeStr);
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("Commodities", allCommodities);' &amp; CrLf;
		endif;
		
		terminalElement := xmlElement.getElementByTagName("Terminals");
		if terminalElement &lt;&gt; null then
			
			codeStr := codeStr &amp; Tab &amp; 'str := ' &amp; self.returnElementText(terminalElement).String &amp; ';' &amp; CrLf &amp;
				Tab &amp; 'str.getTokensForDelimiter(";", tokens);' &amp; CrLf &amp;
				Tab &amp; 'foreach str in tokens do' &amp; CrLf &amp;
				Tab &amp; '	terminal := app.myRoot.allTerminals[str];' &amp; CrLf &amp;
				Tab &amp; '	if terminal &lt;&gt; null then' &amp; CrLf &amp;
				Tab &amp; '		terminalSet.add(terminal);' &amp; CrLf &amp;
				Tab &amp; '	endif;' &amp; CrLf &amp;
				Tab &amp; 'endforeach;' &amp; CrLf &amp;
				Tab &amp; 'self.opts.addAssoc("Terminals", terminalSet);' &amp; CrLf &amp; CrLf;
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addCargoType("' &amp; xmlElement.tagName &amp; '", ' &amp; hasSubCargo.String &amp; '); ' &amp; CrLf &amp; CrLf;
	
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
end;
</source>
        <Parameter name="_cargoTypesXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processCarriers" id="9322d7ea-8338-4ad7-a8db-821bb18be206">
        <source>processCarriers(_carrierXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the carrier details

Date			Who		Reason
27/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	isRoad					: Boolean;
	isRail					: Boolean;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'pinEmailAddresses	: CM_EmailEntityByTypeNameDict;';

	epilogStr := CrLf &amp; Tab &amp; 'delete pinEmailAddresses;' &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'create pinEmailAddresses transient;' &amp; CrLf &amp; CrLf;
			
	foreach obj in _carrierXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		app.writeLog("Creating Carrier " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating Carrier " &amp; xmlElement.tagName &amp; ".  Please wait...";
		
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		xmlElement2 := xmlElement.getElementByTagName('isRail');
		isRail := (xmlElement2 &lt;&gt; null).Boolean;
		xmlElement2 := xmlElement.getElementByTagName('isRoad');
		isRoad	:= (xmlElement2 &lt;&gt; null).Boolean;
		codeStr := codeStr &amp; Tab &amp; 'self.addCarrier("' &amp; xmlElement.tagName &amp; '", ' &amp; description &amp; 
			', pinEmailAddresses, false, ' &amp; isRail.String &amp; ', ' &amp; isRoad.String &amp; ', null);' &amp; CrLf;
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_carrierXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processCommodities" id="65fd46ef-07f6-46a7-88e1-8287dc385957">
        <source>processCommodities(_operatorXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the commodities

Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	cargoType				: CM_CargoType;
	
	cargoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	cargoTypes				: String;
	maxTemp					: String;
	minTemp					: String;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'selectedCargoTypes	: ObjectArray;' &amp; CrLf &amp;
		Tab &amp; 'commodity		: CM_Commodity;' &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'create selectedCargoTypes transient;' &amp; CrLf;
	
	epilogStr := 'delete selectedCargoTypes;';
	
	create cargoTypesArray transient;
	
	foreach obj in _operatorXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		app.writeLog("Creating Commodity " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating Commodity " &amp; xmlElement.tagName &amp; ".  Please wait...";
		
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
		
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		
		//maxTemp :=  self.returnElementText(xmlElement.getElementByTagName('MaxTemp')).String;
		//if maxTemp &lt;&gt; null then
		//	codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("MaxTemp", ' &amp; maxTemp &amp; '.Real);' &amp; CrLf;
		//endif;
		//minTemp :=  self.returnElementText(xmlElement.getElementByTagName('MinTemp')).String;
		//if minTemp &lt;&gt; null then
		//	codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("MinTemp", ' &amp; minTemp &amp; '.Real);' &amp; CrLf;
		//endif;
		
		codeStr := codeStr &amp; Tab &amp; 'selectedCargoTypes.clear();' &amp; CrLf &amp;
			Tab &amp; 'commodity := self.addCommodity("' &amp; xmlElement.tagName &amp; '", "' &amp; description &amp; '", selectedCargoTypes);' &amp; CrLf &amp; 
			Tab &amp; 'beginTransaction;' &amp; CrLf;
		
		cargoTypes := self.returnElementText(xmlElement.getElementByTagName('cargoTypes')).String;
		cargoTypes.cnReplaceString('"', '');
		cargoTypesArray.clear();
		cargoTypes.getTokensForDelimiter(';', cargoTypesArray);
		foreach cargoType in app.myRoot.allCargoTypesById do
			if cargoTypesArray.includes(cargoType.abbreviation) then
				codeStr := codeStr &amp; Tab &amp; 'if not commodity.allCargoTypes.includes(app.myRoot.getCargoTypeForID(' &amp; cargoType.id.String &amp; ')) then' &amp; CrLf &amp;
					Tab &amp; Tab &amp; 'commodity.allCargoTypes.add(app.myRoot.getCargoTypeForID(' &amp; cargoType.id.String &amp; '));' &amp; CrLf &amp; 
					Tab &amp; 'endif;' &amp; CrLf;
			endif;
		endforeach;
	
		codeStr := codeStr &amp; Tab &amp; 'commitTransaction;' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete cargoTypesArray;
end;
</source>
        <Parameter name="_operatorXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processConfigs" id="9a483f3c-be7c-42ae-a5de-0fd9e8664a2d">
        <source>processConfigs(_configElements : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Add required system setConfigs

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	configElement			: JadeXMLElement;
	obj						: Object;
	attribute				: JadeXMLAttribute;

	terminal				: CM_Terminal;
	configDisplayAgent		: CM_ConfigDisplayAgent;
	cmif					: CMIF_ConfigOptionsDisplay;
	
	form					: HiddenDataLoadForm;
	configListBox			: ListBox;
	
	index					: Integer;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	text					: String;
	terminalConfig			: Boolean;
	///value					: Any;
	value					: String;
	value2					: String;
	
begin
	
	varsStr := Tab &amp; 'terminal			: CM_Terminal;' &amp; CrLf &amp;
		Tab &amp; 'value			: Any;' &amp; CrLf &amp;
		Tab &amp; 'configDisplayAgent		: CM_ConfigDisplayAgent;' &amp; CrLf &amp; 
		Tab &amp; 'cmif					: CMIF_ConfigOptionsDisplay;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'form					: HiddenDataLoadForm;' &amp; CrLf &amp; 
		Tab &amp; 'configListBox			: ListBox;' &amp; CrLf &amp; CrLf &amp;
		Tab &amp; 'index					: Integer;' &amp; CrLf &amp; CrLf;
		
	codeStr := codeStr &amp; Tab &amp; 'create configDisplayAgent transient;' &amp; CrLf &amp;
		Tab &amp; 'create form transient;' &amp; CrLf &amp;
		Tab &amp; 'configListBox := form.lstTermConfigs;' &amp; CrLf &amp; CrLf;
		
	epilogStr := epilogStr &amp; CrLf &amp; Tab &amp; 'delete form;' &amp; CrLf &amp; CrLf;
	
	create form transient;
	////configListBox := form.lstTermConfigs;
	
	foreach obj in _configElements.childNodes do
		xmlElement := obj.JadeXMLElement;
		write xmlElement.String &amp; Tab &amp; Tab &amp; xmlElement.tagName;
		
		foreach obj in xmlElement.childNodes do
			configElement := obj.JadeXMLElement;
			write Tab &amp; configElement.String &amp; Tab &amp; Tab &amp; configElement.tagName &amp; Tab &amp; returnElementText(configElement).String;
		
		endforeach;
	
	endforeach;
	
	
	/*
	foreach obj in _configElements.childNodes do
		xmlElement := obj.JadeXMLElement;
		write xmlElement.String &amp; Tab &amp; Tab &amp;xmlElement.tagName;
		
		// check to see if terminal or system config
		terminalConfig := false;
		if xmlElement.tagName.toUpper() = "Terminal".toUpper() then
			terminalConfig := true;
			attribute := xmlElement.getAttributeByName("Code");
			codeStr := codeStr &amp; Tab &amp; 'terminal := app.myRoot.allTerminals["' &amp; attribute.value &amp; '"];' &amp; CrLf &amp; CrLf;
			///terminal := app.myRoot.allTerminals['"' &amp; attribute.value &amp; '"'];
		endif;
		
		foreach obj in xmlElement.childNodes do
			configElement := obj.JadeXMLElement;
			write Tab &amp; configElement.String &amp; Tab &amp; configElement.tagName;
			
			value := configElement.text;
			if value = null then
				continue;
			endif;
			value2 := value;
			value := '"' &amp; value &amp; '"';
			
			codeStr := codeStr &amp; Tab &amp; 'if configDisplayAgent.myTerminal &lt;&gt; terminal then' &amp; CrLf &amp;
				Tab &amp; '	configDisplayAgent.setMyTerminal(terminal);' &amp; CrLf &amp;
				Tab &amp; '	configDisplayAgent.populateDisplayLineObjects();' &amp; CrLf &amp; CrLf &amp;			
				Tab &amp; '	configListBox.clear();' &amp; CrLf &amp;
				Tab &amp; '	foreach cmif in configDisplayAgent.allDisplayLineObjects do' &amp; CrLf &amp;
				Tab &amp; '		configListBox.addItem(cmif.constantName);' &amp; CrLf &amp;
				Tab &amp; '		configListBox.itemObject[configListBox.newIndex] := cmif;' &amp; CrLf &amp;
				Tab &amp; '	endforeach;' &amp; CrLf &amp;
				Tab &amp; 'endif;' &amp; CrLf &amp; CrLf;
			
			codeStr := codeStr &amp; Tab &amp; 'index := 1;' &amp; CrLf &amp;
				Tab &amp; 'index := configListBox.findStringExact(index, "' &amp; configElement.tagName &amp; '");' &amp; CrLf &amp;
				Tab &amp; 'if index &lt; 1 then' &amp; CrLf &amp;
				Tab &amp; '    app.writeLog("Did not find ' &amp; configElement.tagName &amp; '", LogAlways);' &amp; CrLf &amp;
				Tab &amp; '	   write "Did not find ' &amp; configElement.tagName &amp; '";' &amp; CrLf &amp;
				///Tab &amp; '    continue;' &amp; CrLf &amp;
				///Tab &amp; 'endif;' &amp; CrLf &amp; CrLf;
				Tab &amp; "else" &amp; CrLf &amp;
				Tab &amp; '	app.writeLog("Updating ' &amp; configElement.tagName &amp; '", LogAlways);' &amp; CrLf &amp;
				Tab &amp; '	write "Updating ' &amp; configElement.tagName &amp; '    ' &amp; value2 &amp; '.String ";' &amp; CrLf &amp;
				Tab &amp; '	cmif := configListBox.itemObject[index].CMIF_ConfigOptionsDisplay;' &amp; CrLf &amp;
				Tab &amp; '	cmif.setNewCurrentValue(terminal, ' &amp; value &amp; '.String);' &amp; CrLf &amp; 
				Tab &amp; 'endif;' &amp; CrLf &amp; CrLf;
		
		endforeach;
		
	endforeach;
	*/
	
	/*
	foreach obj in _configElements.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		// check to see if terminal or system config
		terminalConfig := false;
		if xmlElement.tagName.toUpper() = "Terminal".toUpper() then
			terminalConfig := true;
			attribute := xmlElement.getAttributeByName("Code");
			codeStr := codeStr &amp; Tab &amp; 'terminal := app.myRoot.allTerminals["' &amp; attribute.value &amp; '"];' &amp; CrLf &amp; CrLf;
			terminal := app.myRoot.allTerminals['"' &amp; attribute.value &amp; '"'];
		endif;
		
		if configDisplayAgent.myTerminal &lt;&gt; terminal then
			configDisplayAgent.setMyTerminal(terminal);
			configDisplayAgent.populateDisplayLineObjects();
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'beginTransaction;' &amp; CrLf;
		
		// read through all the elements and create the cmif
		foreach obj in xmlElement.childNodes do
			configElement := obj.JadeXMLElement;
			
			if configElement.tagName.cnContains("CM_") then
				continue;
			endif;
			
			if configElement.tagName.toUpper() = "RTVehicleConfigs".toUpper() then
				if configElement.childNodes.size = 0 then
					codeStr := codeStr &amp; Tab &amp; 'self.machineTerminalConfig(terminal);' &amp; CrLf &amp; CrLf;
				endif;
				continue;
			endif;
			
			text := self.returnElementText(configElement).String;
			
			if text = null then
				// nothing to do so get the next one
				continue;
			elseif text.cnContains('true') then
				codeStr := codeStr &amp; Tab &amp; 'value := true;' &amp; CrLf;
			elseif text.cnContains('false') then
				codeStr := codeStr &amp; Tab &amp; 'value := false;' &amp; CrLf;
			elseif text.cnIsNumeric() then
				if text.cnContains('.') then
					codeStr := codeStr &amp; Tab &amp; 'value := "' &amp; text &amp; '".Real;' &amp; CrLf;
				else
					codeStr := codeStr &amp; Tab &amp; 'value := "' &amp; text &amp; '".Integer;' &amp; CrLf;
				endif;
			elseif configElement.getAttributeByName("FindObjFromText") &lt;&gt; null then
				// need to work out what to do here
			elseif configElement.getAttributeByName("ForClass") &lt;&gt; null then
				// need to work out what to do here
			else
				codeStr := codeStr &amp; Tab &amp; 'value := ' &amp; text &amp; ';' &amp; CrLf;
			endif;
			
			/*
			if text = null then
				//value := true.Boolean;
				codeStr := codeStr &amp; Tab &amp; 'value := ' &amp; true.String &amp; '.Boolean;' &amp; CrLf;
			elseif text.toUpper() = '&lt;set&gt;'.toUpper() or text.toUpper() = "** not initialised **".toUpper() then
				// don't do anything need to set these
				continue;
			elseif text.cnContains('true') or text.cnContains('false') then
				//value := text.Boolean;
				codeStr := codeStr &amp; Tab &amp; 'value := ' &amp; text &amp; '.Boolean;' &amp; CrLf;
			elseif text.cnIsNumeric() then
				//text := '"' &amp; configElement.text &amp; '"';
				///value := configElement.text.Integer;
				codeStr := codeStr &amp; Tab &amp; 'value := ' &amp; configElement.text &amp; '.Integer;' &amp; CrLf;
			elseif (configElement.tagName = "DefOperator" and text = "****" or 
					configElement.tagName = "DefVoyage" and text = "********************") or 
					configElement.tagName = "CamsFileDirectory" or 
					configElement.tagName = "EDIFileDirectory" or
					configElement.tagName = "InvoiceCurrencySymbol" then
				//value := '"' &amp; configElement.text &amp; '"';
				codeStr := codeStr &amp; Tab &amp; 'value := "' &amp; configElement.text &amp; '";' &amp; CrLf;
			else
				if text.isAlpha() and (text.toUpper() &lt;&gt; "false".toUpper() and text.toUpper() &lt;&gt; "true".toUpper()) then
					//value := '"' &amp; configElement.text &amp; '"';
					codeStr := codeStr &amp; Tab &amp; 'value := "' &amp; configElement.text &amp; '";' &amp; CrLf;
				endif;
			endif;
			if configElement.tagName = "SpecialCharacter" then
				//value := "'" &amp; text &amp; "'";
				codeStr := codeStr &amp; Tab &amp; 'value := "' &amp; text &amp; '";' &amp; CrLf;
			endif;
			
			///if configElement.tagName &lt;&gt; "PortDestCode" then
			///	codeStr := codeStr &amp; Tab &amp; 'delete cmif;' &amp; CrLf &amp;
			///		Tab &amp; 'create cmif transient;' &amp; CrLf &amp;
			///		Tab &amp; 'cmif.setValues(' &amp; terminalConfig.Boolean.String &amp; ', "' &amp; configElement.tagName &amp; 
			///			'", terminal.getConfig("' &amp; configElement.tagName &amp; '").String, null, null, null, null);' &amp; CrLf &amp;
			///		Tab &amp; 'cmif.setNewCurrentValue(terminal, ' &amp; text &amp; ');' &amp; CrLf &amp; CrLf;
			///else
				codeStr := codeStr &amp; Tab &amp; 'terminal.setConfig("' &amp; configElement.tagName &amp; '", value);' &amp; CrLf;
			///endif;			
			*/
		/*	
		endforeach;
		
		codeStr := codeStr &amp; Tab &amp; 'commitTransaction;' &amp; CrLf &amp; CrLf;
		
		
	endforeach;
	*/
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
	//delete dummyTable;
	//delete configDisplayAgent;

end;
</source>
        <Parameter name="_configElements" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processConsigneeors" id="4e1537b6-1a95-47f6-9c0d-26441c84c638">
        <source>processConsigneeors(_consigneeorXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the consignee / consignor

Date			Who		Reason
29/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	isConsignee				: Boolean;
	isConsignor				: Boolean;
	isFreightForwarder		: Boolean;
	
begin
	
	codeStr := codeStr &amp; CrLf;
	
	foreach obj in _consigneeorXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
		
		isConsignee := self.returnElementText(xmlElement.getElementByTagName('isConsignee')).Boolean;
		isConsignor := self.returnElementText(xmlElement.getElementByTagName('isConsignor')).Boolean;
		isFreightForwarder := self.returnElementText(xmlElement.getElementByTagName('isFreightForwarder')).Boolean;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addConsigneeConsignor("' &amp; xmlElement.tagName &amp; '", "' &amp; description &amp; 
			'", ' &amp; isConsignee.String &amp; ', ' &amp; isConsignor.String &amp; ', ' &amp; isFreightForwarder.String &amp; ');' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
end;
</source>
        <Parameter name="_consigneeorXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processCustomsAgents" id="f9ffed37-18ef-48a3-8d81-2837a970bb88">
        <source>processCustomsAgents(_customAgentXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the customs agent

Date			Who		Reason
29/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	
begin

	foreach obj in _customAgentXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
		
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		
		codeStr := codeStr &amp; Tab &amp; 'self.addCustomsAgent("' &amp; xmlElement.tagName &amp; '", "' &amp; description &amp; '");' &amp; CrLf; 
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_customAgentXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processDamageCodes" id="24a16e81-de09-44bf-9216-ada5dd488bcc">
        <source>processDamageCodes(_operatorXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the commodities

Date			Who		Reason
28/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
	cargoType				: CM_CargoType;
	
	cargoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	cargoTypes				: String;
	str						: String;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'selectedCargoTypes	: CM_ObjectSet;' &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'create selectedCargoTypes transient;' &amp; CrLf;
	
	epilogStr := 'delete selectedCargoTypes;';
	
	create cargoTypesArray transient;
	
	foreach obj in _operatorXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		app.writeLog("Creating Damage Code " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating Damange Code " &amp; xmlElement.tagName &amp; ".  Please wait...";

		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
		
		optsElement := xmlElement.getElementByTagName('opts');
		self.setupOptsAssoc(optsElement, codeStr);
		
		codeStr := codeStr &amp; Tab &amp; 'selectedCargoTypes.clear();' &amp; CrLf;
		
		cargoTypes := self.returnElementText(xmlElement.getElementByTagName('cargoTypes')).String;
		cargoTypes.cnReplaceString('"', '');
		cargoTypesArray.clear();
		cargoTypes.getTokensForDelimiter(';', cargoTypesArray);
		foreach str in cargoTypesArray do
			if xmlElement.tagName = "BEER" then
				foreach cargoType in app.myRoot.allCargoTypesById do
					if cargoType.abbreviation = "BARRELSOFS" then
						break;
					endif;
				endforeach;
				if cargoType &lt;&gt; null then
					str := cargoType.id.String;
				endif;
			endif;
			codeStr := codeStr &amp; Tab &amp; 'if not selectedCargoTypes.includes(app.myRoot.getCargoTypeForID(' &amp; str &amp; ')) then' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'selectedCargoTypes.add(app.myRoot.getCargoTypeForID(' &amp; str &amp; '));' &amp; CrLf &amp; 
				Tab &amp; 'endif;' &amp; CrLf;
		endforeach;
		
		codeStr := codeStr &amp; Tab &amp; 'self.addDamageDefinition("' &amp; xmlElement.tagName &amp; '", "' &amp; description &amp; '", selectedCargoTypes);' &amp; CrLf;
		
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete cargoTypesArray;
end;
</source>
        <Parameter name="_operatorXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processDamagePositions" id="02ce3964-4784-4bc4-bf4d-aa6206de04a2">
        <source>processDamagePositions(_damagePositionXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the damage positions

Date			Who		Reason
29/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	cargoType				: CM_CargoType;
	
	cargoTypesArray			: StringArray;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;	
	cargoTypes				: String;
	str						: String;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'selectedCargoTypes	: CM_ObjectSet;' &amp; CrLf &amp;
		Tab &amp; 'machineTypes		: CM_ObjectSet;' &amp; CrLf;
	
	codeStr := CrLf &amp; Tab &amp; 'create selectedCargoTypes transient;' &amp; CrLf &amp; 
		Tab &amp; 'create machineTypes transient;' &amp; CrLf;
	
	epilogStr := 'delete selectedCargoTypes;' &amp; CrLf &amp;
		Tab &amp; 'delete machineTypes;';
	
	create cargoTypesArray transient;
	
	foreach obj in _damagePositionXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		app.writeLog("Creating Damange Position " &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating Damange Position " &amp; xmlElement.tagName &amp; ".  Please wait...";
		
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		description.cnReplaceString('"', '');
				
		codeStr := codeStr &amp; CrLf &amp; Tab &amp; 'selectedCargoTypes.clear();' &amp; CrLf &amp;
			Tab &amp; 'machineTypes.clear();' &amp; CrLf;
			
		cargoTypes := self.returnElementText(xmlElement.getElementByTagName('cargoTypes')).String;
		cargoTypes.cnReplaceString('"', '');
		cargoTypesArray.clear();
		cargoTypes.getTokensForDelimiter(';', cargoTypesArray);
		foreach str in cargoTypesArray do
			if xmlElement.tagName = "BEER" then
				foreach cargoType in app.myRoot.allCargoTypesById do
					if cargoType.abbreviation = "BARRELSOFS" then
						break;
					endif;
				endforeach;
				if cargoType &lt;&gt; null then
					str := cargoType.id.String;
				endif;
			endif;	
			codeStr := codeStr &amp; Tab &amp; 'if not selectedCargoTypes.includes(app.myRoot.getCargoTypeForID(' &amp; str &amp; ')) then' &amp; CrLf &amp;
				Tab &amp; Tab &amp; 'selectedCargoTypes.add(app.myRoot.getCargoTypeForID(' &amp; str &amp; '));' &amp; CrLf &amp; 
				Tab &amp; 'endif;' &amp; CrLf;
		endforeach;	
			
		codeStr := codeStr &amp; Tab &amp; 'self.addDamagePosition("' &amp; xmlElement.tagName &amp; '", "' &amp; description &amp; '", selectedCargoTypes, machineTypes);' &amp; CrLf;
			
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	delete cargoTypesArray;
end;
</source>
        <Parameter name="_damagePositionXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processDangerousGoodsCodes" id="850999bb-a37d-4bdd-aaf8-eb8d3b740bb5">
        <source>processDangerousGoodsCodes(_dangerousGoodsXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the Hazard Classes 

Date			Who		Reason
26/01/2018		jlgmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	xmlElement2				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
begin

	varsStr := CrLf &amp; Tab &amp; 'dangerousGoods				: CM_UNDangerousGoods;' &amp; CrLf &amp; CrLf;
			
	foreach obj in _dangerousGoodsXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		
		app.writeLog("Creating UN Dangerous Goods" &amp; xmlElement.tagName &amp; ".  Please wait...", LogINFO);
		write "Creating UN Dangerous Goods " &amp; xmlElement.tagName &amp; ".  Please wait...";
		
		self.setupOptsAssoc(xmlElement.getElementByTagName('opts'), codeStr);
		
		// hazard class passed as opts
		xmlElement2 := xmlElement.getElementByTagName('hazardClasses');
		if xmlElement2 &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("hazardClasses", ' &amp; self.returnElementText(xmlElement2).String &amp; ');' &amp; CrLf;		
		endif;
		
		// packingGroup passed as opts
		xmlElement2 := xmlElement.getElementByTagName('packingGroups');
		if xmlElement2 &lt;&gt; null then
			codeStr := codeStr &amp; Tab &amp; 'self.opts.addAssoc("packingGroups", ' &amp; self.returnElementText(xmlElement2).String &amp; ');' &amp; CrLf;		
		endif;
		
		codeStr := codeStr &amp; Tab &amp; 'dangerousGoods := self.addUNDangerousGoods("' &amp; self.returnElementText(xmlElement.getElementByTagName('unCode')).String &amp; '", ' &amp;
			self.returnElementText(xmlElement.getElementByTagName('description')).String &amp; ');' &amp; CrLf;
			
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
        <Parameter name="_dangerousGoodsXMLElement" type="JadeXMLElement"/>
        <Parameter name="_methodStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processDebtors" id="53665f49-bc21-4ab3-8bd0-617c78bd2830">
        <source>processDebtors(_debtorXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create the debtor

Date			Who		Reason
29/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	optsElement				: JadeXMLElement;
	obj						: Object;
		
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
begin

	foreach obj in _debtorXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		codeStr := codeStr &amp; Tab &amp; 'self.addDebtor("' &amp; xmlElement.tagName &amp; '");' &amp; CrLf;
	endforeach;
		
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog
	
end;
</source>
