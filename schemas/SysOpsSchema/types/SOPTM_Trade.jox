    <JadeMethod name="setupContextMenuItems" id="c030b7b7-b128-488f-ba7d-6ce87963e33f">
        <updating/>
        <source>setupContextMenuItems( conwin : Window input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2009	cnwer1	Initial creation

*/

vars
	useTranship		: Boolean;
	bItemSelected	: Boolean;
	bItemIsTranship	: Boolean;
	bHasTranship	: Boolean;
	theForm			: SOP_TableMaintForm;
	tmpMenu			: MenuItem;
	listbox			: CMUI_ListBox;
	
begin
	inheritMethod( conwin );
	
	theForm := self.myForm;
	if theForm.mode = SOP_TableMaintForm.Mode_View then
		return;
	endif;
	
	useTranship	:= 	app.myRoot.isTerminal_PortsOfCallTranship( null );
	
	if conwin = theForm.lstSingleSelect1 then			// ie Ports Of Call sheet
		// Establish if a list entry is selected and if it is a tranship port or not.
		bItemSelected	:= false;
		bItemIsTranship	:= false;
		listbox			:= theForm.lstSingleSelect1;
		if listbox.listIndex &gt;= 1 then		// a specific list item has been selected rather than just the listbox
			// If the listbox level is &gt;= 1 then have a tranship port.
			bItemSelected	:= true;
			bItemIsTranship	:= listbox.itemLevel[ listbox.listIndex ] &gt; 1;
			bHasTranship	:= listbox.itemHasSubItems( listbox.listIndex );
		endif;
		
		// now make the context menu dependent on the current state.
		theForm.mnuContext1.visible	:= true;
		theForm.mnuContext1.caption	:= app.getErrorString( Add_Port );
		
		if useTranship then
			theForm.mnuContext5.visible	:= bItemSelected and not bItemIsTranship;
			theForm.mnuContext5.caption	:= app.getErrorString( Add_Tranship_Port );
			
			theForm.mnuContext2.visible	:= bItemSelected and not bItemIsTranship and not bHasTranship;
			theForm.mnuContext2.caption	:= app.getErrorString( Make_Tranship_Port );
			
			theForm.mnuContext3.visible	:= bItemIsTranship;
			theForm.mnuContext3.caption	:= app.getErrorString( Make_Actual_Port_Of_Call );
		endif;
		
		theForm.mnuContext4.visible	:= bItemSelected;
		theForm.mnuContext4.caption	:= app.getErrorString( Remove_Port );
	endif;
	
	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext4, false );
	
	if useTranship then
		tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext3, false );
		tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext2, false );
		tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext5, false );
	endif;
	
	tmpMenu := theForm.cloneMenu( theForm.mnuTblVCloneDataTbl, theForm.mnuContext1, false );
	
epilog
	
end;
</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="52060b62-1659-4d5e-9d8c-4bc057174eff">
        <source>setupThumbnailDetails();
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
	terminology : String;
begin
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_TradeTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Description, false);

	theForm.shtTblInput1.caption := app.getErrorString( Details );
	theForm.initTblInput(theForm.tblInput1, ETDef_TradeMaint);
	theForm.shtTblInput1.visible := true;


end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="dc67a661-ee97-445a-ab19-bbb59e0b69b7">
        <updating/>
        <source>showThumbnail(pTrade : CM_Trade) updating;
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;	
begin
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	// Code not used
	theForm.tblInput1.setValueByName(ETRow_Description,	pTrade.description);
	theForm.tblInput1.setValueByName(ETRow_OrderNo, pTrade.order);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pTrade.isNotAvailableForEntry);
	theForm.mulSelect1.setSelected(pTrade.operators);
	theForm.mulSelect2.setSelected(pTrade.allShippingLines);
	

	self.myForm.myAssistant.listBoxPortsOfCall(self.myForm.lstSingleSelect1,pTrade.allPortRotations);
	
epilog

end;</source>
        <Parameter name="pTrade" type="CM_Trade"/>
    </JadeMethod>
</Class>
