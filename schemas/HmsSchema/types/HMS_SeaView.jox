    <JadeMethod name="setCurrBerthForView" id="d3b09e57-0974-4d3b-a5b8-f0fff0089fdd">
        <updating/>
        <source>setCurrBerthForView(_direction: Integer) updating;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
 	wharf:				HMS_Wharf;
 	berth:				HMS_Berth;
 	nextBerthUp:		HMS_Berth;
 	nextBerthDown:		HMS_Berth;
 	berthChanged:		Boolean;	
	tmpHarbour:			HMS_Harbour;
begin
	
  	// This method sets the current Berth for the logical berths view 'currBerthForView'
	tmpHarbour := self.myTerminal.myHarbour;

  	// Build collection of logical berths (if required)
  	if self.allLogicalBerths.isEmpty
  	and tmpHarbour &lt;&gt; null then
  		foreach wharf in tmpHarbour.allWharves do
  			
			if (not wharf.isLogicalWharf) then
				continue;
			endif;
			foreach berth in wharf.allBerths do
				// Add berth to logical berths collection
				self.allLogicalBerths.add(berth);
				self.beginNotification(berth, Object_Update_Event, Response_Continuous, 0);
				self.beginNotification(berth, Object_Delete_Event, Response_Continuous, 0);						
			endforeach;
			self.beginNotification(wharf, Object_Update_Event, Response_Continuous, 0);
			self.beginNotification(wharf, Object_Delete_Event, Response_Continuous, 0);												
		endforeach;
	endif;

	if self.currBerthForView &lt;&gt; null then
		if (not self.allLogicalBerths.includes(self.currBerthForView)) then
			self.currBerthForView := null;
			berthChanged := true;
		endif;
	endif;
	
	// Set current berth
	if self.allLogicalBerths.size &gt; 0 then
		if self.currBerthForView = null then
			// Set to first berth in list
			self.currBerthForView := self.allLogicalBerths.first;
			berthChanged := true;
		elseif _direction = BerthUp then
			if self.currBerthForView &lt;&gt; null then
				// Get the nextBerth up
				nextBerthUp := self.allLogicalBerths.getAtKeyGtr(self.currBerthForView.code);
				if nextBerthUp = null then
					// this is the last berth in the list - do not change current berth
				else
					self.currBerthForView := nextBerthUp;
					berthChanged := true;
				endif;
			endif;
		elseif _direction = BerthDown then
			if self.currBerthForView &lt;&gt; null then
				// Get the nextBerth down
				nextBerthDown := self.allLogicalBerths.getAtKeyLss(self.currBerthForView.code);
				if nextBerthDown = null then
					// this is the first berth in the list - do not change current berth
				else
					self.currBerthForView := nextBerthDown;
					berthChanged := true;
				endif;
			endif;
		endif;
	else
		self.currBerthForView := null;
		berthChanged := true;	
	endif;

	// Update berth view label
	if self.currBerthForView &lt;&gt; null then
		self.caption := Caption &amp; self.currBerthForView.description;
		self.setNavigatorHeading(self.currBerthForView.description);
	else
		self.caption := Caption;
	endif;

	// Update view if berth has changed
	if berthChanged = true then
		self.getMovementsToAddToList();
	endif;

	if self.allLogicalBerths.size &lt;= 1 then
		self.btnStepForward.enabled := false;
		self.btnStepBack.enabled := false;
	else
		self.btnStepForward.enabled := true;
		self.btnStepBack.enabled := true;	
	endif;			


end;</source>
        <Parameter name="_direction" type="Integer"/>
    </JadeMethod>
