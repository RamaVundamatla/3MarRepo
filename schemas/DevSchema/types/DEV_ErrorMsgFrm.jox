    <JadeMethod name="addEditPermission" id="fccd9583-2188-44d1-9f35-d78725ffa688">
        <updating/>
        <source>addEditPermission() updating;
// ---------------------------------------------------------------------------
// Created:     17 May 2002 by cnwth2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	addPermForm 	 :DEV_AddPermissionForm;
	catagoriesColl	 :StringArray;
	cataStr,
	tmpStr			 :String;
	i				 :Integer;
	permObj, newPerm :CM_PermissionObject;
	hadMenuDtls,
	duplicateFound 	 :Boolean;
	areAdding : Boolean;
begin

	if self.currentMode &lt;&gt; self.Mode_Permissions and
		self.currentMode &lt;&gt; self.Mode_Subscriptions and	//16 Jun 2020	NDL	TFS 49569
	   self.currentMode &lt;&gt; self.Mode_SpecialPermissions then
		app.msgBox('Invalid mode for addEditPermission', 'Error', 0);
		return;
	endif;

	create addPermForm transient;
	addPermForm.myLicensePermissionAgent := self.myLicensePermissionAgent;
//	addPermForm.isSpecialPerm := (self.currentMode = Mode_SpecialPermissions);
	addPermForm.setCurrentMode( self.currentMode ); //16 Jun 2020	NDL	TFS 49569
	create catagoriesColl transient;
	
	//loop through all permission objects, get their catagory string and add it to catagoryColl if it's new
	
	foreach permObj in self.myPermissionAgent.allPermissionsByName do
		tmpStr := permObj.constText.cnEcGetTagValueOfName('Category');
		duplicateFound := false;
		//loop through for a match
		i := 0;
		while i &lt; catagoriesColl.size do
			i:= i +1;
			if tmpStr = catagoriesColl[i] then
				duplicateFound := true;
			endif;
		endwhile;
	
		if (duplicateFound = false) and (tmpStr &lt;&gt; null) then
			catagoriesColl.add(tmpStr.String);
		endif;
	endforeach;
	
	//add catagoriesColl strings to cmbCatagory
	if self.currentMode = self.Mode_Subscriptions then
		addPermForm.cmbCatagory.addItem("Subscription");
	else
		foreach cataStr in catagoriesColl do
			addPermForm.cmbCatagory.addItem(cataStr);	
		endforeach;
	endif;
	
	//create a new permission and set up defaults if no current permission object
	if self.myCurrentPermissionObject = null then
		self.savedRow		:= 0;
		self.savedTopRow 	:= 0;
		
		create newPerm transient;
		newPerm.isInternal := false;
		if self.currentMode = self.Mode_Subscriptions then
			newPerm.category := "Subscription";
			newPerm.permType := PermType_Subscriptions;
		else
			newPerm.category := "Administration";
			newPerm.permType := PermType_Special; // System License Module // ### JIRA 33501 15JAN2025 NAVAB1
		endif;
		newPerm.constValue := self.maxNumber +1;
		newPerm.myPermissionAgent := self.myPermissionAgent; //add to agent's dict
		addPermForm.myPermissionObject := newPerm;					//assign newPerm to the form
		addPermForm.updating := false; // ### JIRA 33501 08JAN2025 NAVAB1
		// ### JIRA 33501 15JAN2025 NAVAB1
		if self.currentMode = self.Mode_Subscriptions then
			addPermForm.caption := "Add Subscription Module ";
		elseif self.currentMode = self.Mode_SpecialPermissions then
			addPermForm.caption := "Add System Module ";
		else
			addPermForm.caption := "Add Permission ";
		endif;
		addPermForm.showModal;
		if addPermForm.modalResult &lt;&gt; IDOK then
			delete newPerm;
			return;
		else
			if newPerm &lt;&gt; null then
			
				self.doSaveToGlobalConstants(newPerm);
				self.myCurrentPermissionObject := newPerm;
			else
				app.msgBox('The new permission object is null for some reason - not saved','Error - permission object is null',0);
				return;
			endif;	
		endif;
	
	else //we are editing an existing permissionObj/permissionConstant
		hadMenuDtls := self.myCurrentPermissionObject.hasMenuDtls;
		addPermForm.myPermissionObject := self.myCurrentPermissionObject;

		// ### JIRA 33501 15JAN2025 NAVAB1
		if self.currentMode = self.Mode_Subscriptions then
			addPermForm.caption := "Edit Subscription Module ";
		elseif self.currentMode = self.Mode_SpecialPermissions then
			addPermForm.caption := "Edit System Module ";
		else
			addPermForm.caption := "Edit Permission ";
		endif;
		
		addPermForm.txtConstName.enabled := false;
		addPermForm.leafPic := self.myCurrentPermissionObject.pictureStringIcon;
		addPermForm.toolbarPic:= self.myCurrentPermissionObject.pictureStringButton;
		addPermForm.toolbarPicDown := self.myCurrentPermissionObject.pictureStringButtonDown;
		addPermForm.updating := true; // ### JIRA 33501 08JAN2025 NAVAB1
		
		addPermForm.showModal;
		
		if addPermForm.modalResult &lt;&gt; IDOK then
			return;
		endif;
	
		if self.myCurrentPermissionObject &lt;&gt; null then
			//update the text of the permission constant - no need to write to schema here
			self.doSaveToGlobalConstants(self.myCurrentPermissionObject);
		else
			app.msgBox('The new permission object is null for some reason - not saved','Error - permission object is null',0);
		endif;
	endif;	

	if self.myCurrentPermissionObject.hasMenuDtls or hadMenuDtls then
		
		//self.myMenuAgent.();
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' &gt;&gt; Reloading menus from global constants');
		self.myMenuAgent.trxLoadJMTNavMenu();
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' &gt;&gt; Reloading system JMT system entity menu');
		self.myMenuAgent.trxLoadJMTSysEntMenu();
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' &gt;&gt; Refreshing toolbar entities');
		self.myMenuAgent.trxRefreshAllToolbarEntities();
	
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' &gt;&gt; Update of menus complete');

	endif;

	if self.currentMode = self.Mode_Subscriptions then
		self.showSubscriptions();
	else
		self.showPermissions();
	endif;
	
	if self.savedRow &lt;&gt; 0 then
		tblData.row 	:= self.savedRow;
		tblData.topRow := self.savedTopRow;
		tblData.setFocus;
		tblData.selected := true;
	endif;	
epilog
	delete catagoriesColl;
end;</source>
    </JadeMethod>
