epilog

end;</source>
        <Parameter name="_proxyWO" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="98a0738f-2249-4ff7-8489-2896aa57fd07">
        <updating/>
        <source>setForUpdate(_proxyWO: CM_WorkOrderVoyage;_updateTasks : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 11 Oct 2021	jlier1		TFS 51963
vars
	detail	 : CM_WorkOrderVoyageDtl;
	invalid	 : Boolean;
	edition  : Integer;
begin
	on Exception do app.handleDeletedObject(exception, _proxyWO.myVoyage, invalid); 
	inheritMethod(_proxyWO,_updateTasks);
	
	//epr TFS 41310 15/10/18
	if _proxyWO.lengthOfTime = null then
		detail := self.allWoDtls.first.CM_WorkOrderVoyageDtl;
		if detail &lt;&gt; null then
			if detail.myRelatedPermitRequest &lt;&gt; null then
				self.setLengthOfTime( detail.myRelatedPermitRequest.myParent.CM_WorkOrderVoyage.lengthOfTime);
			endif;
		endif;
	else
		self.setLengthOfTime( _proxyWO.lengthOfTime );	//18 Jun 2018	NDL	TFS 39267
	endif;
	
	if _proxyWO.myVoyage &lt;&gt; null then
		edition := _proxyWO.myVoyage.edition;
	endif;
	
	if invalid then
		self.myVoyage 			:= null;
	else
		self.myVoyage 			:= _proxyWO.myVoyage;
	endif;
	
	self.voyageCodeExternal := _proxyWO.voyageCodeExternal;
epilog

end;</source>
        <Parameter name="_proxyWO" type="CM_WorkOrderVoyage"/>
        <Parameter name="_updateTasks" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLengthOfTime" id="cfc2eb75-3f0b-443b-aa55-c642bd9706f1">
        <updating/>
        <source>setLengthOfTime( _lengthOfTime : Decimal )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2018	jlgndl1	Initial creation	TFS 39167

*/

vars

begin

	self.lengthOfTime := _lengthOfTime;

epilog

end;</source>
