    <JadeMethod name="getDate" id="82978440-66ac-4d10-870b-a11c5966b62e">
        <updating/>
        <source>getDate(): Date updating;

vars
	date:   Date;
begin
	date.setDate(getDay.Integer,
				 getMonth.Integer,
				 getYear.Integer);

	return date;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
