    <JadeMethod name="setOriginalJobAmount" id="3e59ca0c-aed3-478d-a23a-6ea265acea6e">
        <updating/>
        <source>setOriginalJobAmount(_amount : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
