        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="eba78771-b77b-4f87-8a7d-46cd8cfe618a">
        <source>setListValues(table						: Table input; 
			  queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder;
			  queryOperator				: CM_QReferenceIsOneOf; 
			  passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 11 September 2018
TFS#		: 40735
Function	: Populate Selection List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	selectionValue 	: Integer;
	operatorGroup	: CM_OperatorGroup;
	idx 			: Integer;
begin
	table.clear;
	table.rows := 0;
	table.sortColumn[1] := 2; 


	foreach operatorGroup in app.myRoot.allOperatorGroups do
		selectionValue := 0;
		if queryOperator &lt;&gt; null and queryOperator.allSelectionValues.includes(operatorGroup) then
			selectionValue := 1;
		endif;
		idx := table.addItem(selectionValue.String&amp; Tab &amp; operatorGroup.code &amp; Tab &amp; " (" &amp; operatorGroup.description &amp; ")");
		table.accessRow(idx).itemObject := operatorGroup;
		table.row := idx;
		table.change(table);
	endforeach;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="ce96bc2f-769a-4750-b839-64256cb8dd1e">
        <source>setValuesFromList(table: Table input; queryOperator: CM_QueryOperator input);

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 11 September 2018
TFS#		: 40735

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	object			: Object;
	str				: String;
	numRows			: Integer;
	idx				: Integer;
	objectSet		: ObjectSet;	

begin

	create objectSet transient;
	
	numRows := table.rows;
	foreach idx in (table.fixedRows + 1) to numRows do
		str := table.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			object := table.accessRow(idx).itemObject.CM_OperatorGroup;
			objectSet.add(object);
		endif;
	endforeach;
	
	queryOperator.setSearchValue(objectSet);

epilog
	delete objectSet;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryOperator" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="88023c1b-e3e7-4c17-a024-a74d4e6158a4">
        <source>translateToDisplayValue(anyValue : Any): String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 11 September 2018
TFS#		: 40735

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin 
	if anyValue.isKindOf(CM_OperatorGroup) then
		if anyValue &lt;&gt; null then
			return anyValue.CM_OperatorGroup.code;
		else
			return null;
		endif;
	elseif anyValue.isKindOf( CM_OperatorGroupByCodeDict ) then	//28 Aug 2018	NDL TFS 40400
		return anyValue.CM_OperatorGroupByCodeDict.listAllOperatorGroup();
	else
		return anyValue.String;
	endif;
end;</source>
        <Parameter name="anyValue" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="d12fa4a0-3176-4201-b18c-3f48b45f28a9">
        <source>translateToSearchValue(_value: Any): Any;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 11 September 2018
TFS#		: 40200

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_OperatorGroup) then
			return _value.CM_OperatorGroup;
		endif;
	endif;
	
	return app.myRoot.allOperatorGroups[_value.String];
		
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="f2c12562-20e8-4f3e-a590-11c9ddd47815">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	objSet : ObjectSet;
	object : Object;
	opGroup : CM_OperatorGroup;
	result : String;
	coll : CM_OperatorGroupByCodeDict;
	collStr : String;
	strArray : StringArray;
	str : String;

begin
	if _value.isKindOf(ObjectSet) then
		objSet := _value.ObjectSet;
		foreach object in objSet do
			opGroup := object.CM_OperatorGroup;
			result := result &amp; opGroup.code &amp; CNEC_COMMA &amp; Space;
		endforeach;
		result := result[1:result.length-2];
		return result;
		
	elseif _value.isKindOf(String) then
		collStr := _value.String;
		if collStr.cnContains("|") then
			create coll transient;
			create strArray transient;
			collStr.getTokensForDelimiter("|", strArray);
			foreach str in strArray do
				opGroup := app.myRoot.allOperatorGroups[str];
				if opGroup &lt;&gt; null then
					coll.addNoDuplicates(opGroup, false);
				endif;
			endforeach;
			return coll;
		endif;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
