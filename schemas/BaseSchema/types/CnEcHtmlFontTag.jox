<Class name="CnEcHtmlFontTag" id="b5a5b329-c431-48e2-a29c-b228655c4c53">
    <superclass name="CnEcHtmlBodyTag"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

