    <JadeMethod name="createGCOnShip" id="cb4f49ee-0c2b-4a28-8abb-1878fccc2844">
        <source>createGCOnShip(_contractId,_id : String; _cargoType : CM_CargoType; _operator : CM_Operator; _voyage : CM_Voyage; _port : CM_Port; _weight : Integer) : CM_TrackedItem;
/*
Purpose:			

Date		Who		Reason
26 January 2023	navab1	TFS CR 56446 TASK 56447
*/

vars
	cargo : CM_TrackedItem;
	lc : CM_LocationsController;
	product : CM_Product;
begin
	self.deleteCargo(_id, _cargoType);
	lc := _voyage.myShipBlockStack;
	
	self.opts.purge();
	
	product := _cargoType.getProductFromCode("12POUNDER-12");
	//create cargo on ship
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("TotalQuantity",5000); 
	cargo := lc.createNewCargoForLCDetailed(_cargoType,product, _id, _port.code, TI_IMEX_STATUS_IMPORT, _voyage, _voyage.myOperator, 50, null).CM_Cargo;
	self.assertNotNull(cargo);
	self.opts.addAssoc("Commodity", "COM1");
	self.opts.addAssoc("TotalVolume", 7000);
	self.opts.addAssoc("CargoLength", 111.0);
	self.opts.addAssoc("CargoWidth", 222.0);
	self.opts.addAssoc("CargoHeight", 333.0);
	self.opts.addAssoc("Description", "CargoDesc2");
	self.opts.addAssoc("ClientRef", "ClientRef2");
	self.opts.addAssoc("Consignee", "UTDDC");
	self.opts.addAssoc("Consignor", "UTMO1");
	self.opts.addAssoc("ContractId",_contractId);
	self.opts.addAssoc("TotalWeight", _weight);
	self.updateTI(cargo);
	assertEqual(cargo.totalQuantity, 5000);
	assertEqual(cargo.totalWeight, _weight.Decimal);

	self.assertTrueMsg(cargo.contractId = _contractId, "Cargo Contract Id is wrong");
	
	return cargo;
epilog

end;</source>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_weight" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createImportCargo" id="e61b461e-3f6c-4b2b-a873-92b4ac9b6880">
        <source>createImportCargo(_proforma : Boolean);
// cnwjre1 from 32416
// Test reefer connect and days on power charging.  Revised May 2014 to create cargo onsite directly rather than planned off ship.

constants
	VoyageName = 'UTVOYROR2';
	ShipName = 'UTROR2';
	TestOperator = 'UTOP';
	CargoId1 = "MRKU0910430";
	CargoId2 = "MRKU0910440";
vars
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	terminal	: CM_Terminal;
	bs: CM_BlockStack;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	cargo1,
	cargo2	: CM_TrackedItem;
	tas: StringArray;
	proformaLines	: CM_InvoiceLineBySeqNumDict;
	bank			: CM_Bank;
	tran			: CM_TITransaction;
	invLine			: CM_InvoiceLine;
	tranDate		: Date;
	now				: TimeStamp;
	tranTime		: Time;
	time			: Time;
	tranTS			: TimeStamp;
	txnType			: Integer;
	debtorChanged	: Boolean;
	vvr 			: CM_VehicleVisitRecord;
	singleGate		: CM_Gate;
	agent			: CM_CashInvoiceProformaAgent;

begin
	//set terminal to be cash enabled.
	terminal := self.getTerminal();
	self.enableCashOnlyTerminal( terminal, true );

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	if _proforma then
		self.setDebtorCashOnly(debtor, terminal, true);
	endif;	

	beginTransaction;
	txnType := TRANS_TYPE_ReeferDaily;
	if not debtor.allSpecialReleaseTxnTypes.includes(txnType) then
		debtor.allSpecialReleaseTxnTypes.add(txnType);
		debtorChanged := true;
	endif;
	commitTransaction;

	bs:= self.addBlockStack("UBS1", 100, null);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	vessel := self.addVesselLOLOholdsRORO(ShipName, self.getOperator(TestOperator));
	voyage	:= self.addVoyageWithConRORO(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													null, 10, false, true);

	cargo1 := self.addContainerAtLocnDisch("MRKU0910430", "22R1", "REEF", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, app.myRoot.allPorts["NZPOE"], voyage);
	cargo2 := self.addContainerAtLocnDisch("MRKU0910440", "22R1", "REEF", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, app.myRoot.allPorts["NZPOE"], voyage);

	// back-date both boxes transactions to 10 days ago
	tranDate := tranDate - 9;		// -9 so that first day is relative day 1 and last is day 10
	
	tranTS.setDate(tranDate);
	foreach tran in cargo1.allTransactions do
		tranTime := tran.dateTime.time;
		tranTS.setDate(tranDate);
		tranTS.setTime(tranTime);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	foreach tran in cargo2.allTransactions do
		tranTime := tran.dateTime.time;
		tranTS.setDate(tranDate);
		tranTS.setTime(tranTime);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	beginTransaction;
	cargo1.setReceivedDT(tranTS);
	cargo2.setReceivedDT(tranTS);
	cargo1.setPropertyValue("moveDT", tranTS);
	cargo2.setPropertyValue("moveDT", tranTS);
	commitTransaction;
	tranTS.addMinutes(1);
	
	// connect 10 days ago, disconnect 6 days reconnect 5 days ago
	self.updateTIConnection(cargo1, false, true, tranTS, null);
	self.updateTIConnection(cargo2, false, true, tranTS, null);

	tranDate := tranDate + 4;
	tranTS.setDate(tranDate);
	tranTS.setTime(time);
	self.updateTIConnection(cargo1, false, false, tranTS, null);
	self.updateTIConnection(cargo2, false, false, tranTS, null);
	
	tranDate := tranDate + 1;
	tranTS.setDate(tranDate);
	tranTS.setTime(time);
	self.updateTIConnection(cargo1, false, true, tranTS, null);
	self.updateTIConnection(cargo2, false, true, tranTS, null);
	
	// if cash proforma, do it here
	if _proforma then
		proformaLines := self.createProformaInvoiceLines(now, cargo1, agent);
		self.validateReeferProforma(proformaLines);
		return;
	endif;
	// otherwise do a road release
	// Remove all automatic stops
	self.deleteStops(cargo1);
	self.deleteStops(cargo2);

	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	self.opts.addAssoc("deliveryNumber", "999");	// to prevent more stops being added at release
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo1.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo2.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	self.validateReeferTransactions2(cargo1);
	self.validateReeferTransactions2(cargo2);

epilog
	if debtorChanged then
		beginTransaction;
		txnType := TRANS_TYPE_ReeferDaily;
		if debtor.allSpecialReleaseTxnTypes.includes(txnType) then
			debtor.allSpecialReleaseTxnTypes.remove(txnType);
		endif;
		commitTransaction;
	endif;

	delete agent;
	if proformaLines &lt;&gt; null and not proformaLines.isEmpty then
		proformaLines.purge();
	endif;
	delete proformaLines;

	self.disableAllYA(false);
	self.resetDefaultTranMap();	
	delete tas;
	if _proforma then
		// reset terminal cash option
		self.enableCashOnlyTerminal( self.getTerminal, false );
	endif;

end;</source>
        <Parameter name="_proforma" type="Boolean"/>
    </JadeMethod>
