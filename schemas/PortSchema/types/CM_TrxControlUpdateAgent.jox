<Class name="CM_TrxControlUpdateAgent" id="4f1e0df8-c8a9-4f0c-afba-e7a03895f66e">
    <superclass name="CM_TrxControlAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
