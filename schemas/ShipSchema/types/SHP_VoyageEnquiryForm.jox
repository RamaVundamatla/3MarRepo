vars

begin
	inheritMethod();
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnCrgFcstDef" id="56a8da2f-90dc-4a90-8b3b-742b22e8e3e4">
        <source>doBtnCrgFcstDef();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2022	navak20	Initial creation 	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars
	form : CMUI_CargoForecastForm;
begin
	if self.myCurrentVoyage = null then
		return;
	endif;
	form := app.loadForm(CMUI_CargoForecastForm, SHP_Assistant, false, false, false, self.myTerminal, null).CMUI_CargoForecastForm;	//13.05.2022 navsrk	53142
	//form := app.getForm(CMUI_CargoForecastForm.name).CMUI_CargoForecastForm;		//13.05.2022 navsrk	53142
	if form = null then
		return;		//13.05.2022 navsrk	53142
	endif;
	if form &lt;&gt; null then
		form.setMyObject( self.myCurrentVoyage );
		form.setParentForm(self);
		form.show();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnHoldDef" id="48845bf5-3373-45e7-82e4-15e1d4ac4043">
        <source>doBtnHoldDef();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2013	cnwndl1	Initial creation	Par 31965

*/

vars

