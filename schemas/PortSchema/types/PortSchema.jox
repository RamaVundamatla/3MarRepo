    <JadeMethod name="parseCommandLine" id="e3e9582d-c2c0-4405-a7b9-a5749b45afbb">
        <source>parseCommandLine(_cmdLine : String; _paramNames, _paramValues : StringArray input);
// ---------------------------------------------------------------------------
// Created:     28 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pos,
	newPos,
	idx,
	maxLen	: Integer;
	paramName,
	paramValue	: String;
	doingValue	: Boolean;
	
begin

	maxLen := _cmdLine.length;
	
	pos := 1;
	while (true) do
		if (not doingValue) then
			newPos := _cmdLine.pos('=', pos);
			if newPos = 0 then
				break;
			endif;
			paramName := _cmdLine[pos : (newPos - pos)].trimBlanks;
			doingValue := true;
			pos := newPos + 1;
			if pos &gt; maxLen then
				break;
			endif;
			continue;
		else
			// search for the value
			newPos := _cmdLine.pos(' ', pos);
			if newPos = 0 then
				paramValue := _cmdLine[pos : end].trimBlanks;
				
				_paramNames.add(paramName);
				_paramValues.add(paramValue);
				break;
			endif;
			paramValue := _cmdLine[pos : newPos-pos].trimBlanks;

			_paramNames.add(paramName);
			_paramValues.add(paramValue);

			doingValue := false;
			pos := newPos + 1;
			continue;
		endif;
	endwhile;

end;</source>
        <Parameter name="_cmdLine" type="String"/>
        <Parameter name="_paramNames" type="StringArray" usage="input"/>
        <Parameter name="_paramValues" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="paymentStatusCashEnumToString" id="260fbeae-9d78-4647-b225-90c97e1dd91a">
        <source>paymentStatusCashEnumToString(_paymentStatus : Integer):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Jan 2019	cnwma1	Bug 43124: PEL1 - Container Services - SAP SIT issues

*/

vars

begin
	if _paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED then
		return app.getErrorString(Credit_check_approved);
	elseif _paymentStatus = CM_CashReceipt.CREDIT_CHECK_PENDING then
		return app.getErrorString(Credit_check_pending);
	elseif _paymentStatus = CM_CashReceipt.CREDIT_CHECK_REJECTED then
		return app.getErrorString(Credit_check_rejected);
	elseif _paymentStatus = CM_CashReceipt.CREDIT_CANCEL_PENDING then 
		return app.getErrorString(Credit_check_cancel_pending);
	elseif _paymentStatus = CM_CashReceipt.CREDIT_CANCEL_APPROVED then 
		return app.getErrorString(Credit_check_cancel_approve);
	elseif _paymentStatus = CM_CashReceipt.PAID then 
		return app.getErrorString(Credit_Check_Paid);
	elseif _paymentStatus = CM_CashReceipt.CREDIT_CANCEL_MANUAL then 
		return app.getErrorString(Credit_check_cancell_manual); 
	//5/07/2024	navkc1 CR 64834 Task 64846 Start
	elseif _paymentStatus = CM_CashReceipt.API_RECEIPT_CANCELLED then
		return app.getErrorString(API_Cash_Cancelled);
	elseif _paymentStatus = CM_CashReceipt.API_RECEIPT_DRAFT then
		return app.getErrorString(API_Cash_Draft);
	elseif _paymentStatus = CM_CashReceipt.API_RECEIPT_EXPIRED then
		return app.getErrorString(API_Cash_Expired);
	elseif _paymentStatus = CM_CashReceipt.API_RECEIPT_FINAL then
		return app.getErrorString(API_Cash_Final);
	elseif _paymentStatus = CM_CashReceipt.API_RECEIPT_HOLD then
		return app.getErrorString(API_Cash_Hold);
	elseif _paymentStatus = CM_CashReceipt.API_RECEIPT_PAID then
		return app.getErrorString(API_Cash_Paid);
	//5/07/2024	navkc1 CR 64834 Task 64846 End
	else
		return app.getErrorString(Unknown);
	endif;
epilog

end;</source>
        <Parameter name="_paymentStatus" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="paymentTypeEnumToString" id="943c77d2-a0f3-4c06-aac5-7b50da7d7579">
        <source>paymentTypeEnumToString(_paymentType : Integer) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/04/2018	jlgdap1		Initial creation TFS 37731 PEL1 Debtor Payment Type
//
vars

begin
	if _paymentType = PaymentType_None then
		return app.getErrorString(PaymentType_NoneStr);
	elseif _paymentType = PaymentType_AutoCollection then
		return app.getErrorString(PaymentType_AutoCollectionStr);
	elseif _paymentType = PaymentType_PrePay then
		return app.getErrorString(PaymentType_PrePayStr);
	elseif _paymentType = PaymentType_PostPay then
		return app.getErrorString(PaymentType_PostPayStr);
	elseif _paymentType = PaymentType_NoCharge then
		return app.getErrorString(PaymentType_NoChargeStr);		// 22/6/18 MAP TFS39250
	else
		return app.getErrorString(Unknown);
	endif;
epilog

end;</source>
        <Parameter name="_paymentType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="paymentTypeStringToEnum" id="611339d0-6ffa-4189-b9d3-dda3a68deffd">
        <source>paymentTypeStringToEnum(_paymentType: String): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2018	jlgmp6	Initial creation	TFS39250

*/

vars
	paymentType: String;
	returnVal: Integer;
begin
	paymentType := _paymentType.toUpper();
    
    if paymentType = app.getErrorString(PaymentType_NoneStr).toUpper() then
    	returnVal := PaymentType_None;
	elseif paymentType = app.getErrorString(PaymentType_AutoCollectionStr).toUpper() then
    	returnVal := PaymentType_AutoCollection;
	elseif paymentType = app.getErrorString(PaymentType_PrePayStr).toUpper() then
    	returnVal := PaymentType_PrePay;
	elseif paymentType = app.getErrorString(PaymentType_PostPayStr).toUpper() then
    	returnVal := PaymentType_PostPay;
	elseif paymentType = app.getErrorString(PaymentType_NoChargeStr).toUpper() then
    	returnVal := PaymentType_NoCharge;
	else
//		returnVal := -1;	
		returnVal := PaymentType_None;	//20 Apr 2020	NDL	TFS 49143/48653
	endif;

	return returnVal;
epilog

end;</source>
        <Parameter name="_paymentType" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="planningStateEnumToString" id="899c82c6-34ea-467e-a94c-5aed2a0be938">
        <source>planningStateEnumToString(planningState : Integer):String;

vars
	retStr 		: String;
begin
    
    if planningState = NULL_PLANSTATE then
    	retStr := app.getErrorString(Null);
   
    elseif planningState = NOTIFIED_STATE then 
      retStr := app.getErrorString(Notified);
    
    elseif planningState = RECEIVED_STATE then 
    	retStr := app.getErrorString(Received);
    
    elseif planningState = PLANNED_LOAD_STATE then 
    	retStr := app.getErrorString(Planned_To_Load);
    
    elseif planningState = LOADED_STATE then 
    	retStr := app.getErrorString(Loaded);
    
    elseif planningState = PLANNED_DISCHARGE_STATE then 
    	retStr := app.getErrorString(Planned_To_Discharge);
    
    elseif planningState = DISCHARGED_STATE then 
    	retStr := app.getErrorString(Discharged);
    
    elseif planningState = DELIVERED_STATE then 
    	retStr := app.getErrorString(Delivered);
    
    elseif planningState= PLANNED_SHIFT_STATE	then 
    	retStr := app.getErrorString(Planned_SOB);
    
    elseif planningState = SHIFTED_STATE	then 
    	retStr := app.getErrorString(Shifted_On_Board);
    
    else
    	retStr := app.getErrorString(Unknown);
    	
    endif;
	
	return retStr;
end;</source>
        <Parameter name="planningState" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="planningStateEnumToStringObj" id="7adb4f4f-df30-43e6-b66d-dbb85a95ad72">
        <source>planningStateEnumToStringObj(_value : Integer) : CM_String;
//----------------------------------------------------------------
//	Created:	29 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	cmString	: CM_String;
begin
	//must be cleaned up else where - maybe use _tbl.purgeTableObjects() if going into a table
	
	create cmString transient;
	cmString.string := self.planningStateEnumToString(_value);
	return cmString;
	
end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="CM_String"/>
    </JadeMethod>
    <JadeMethod name="planningStateStringToEnum" id="6ee295de-db15-4592-867b-8185f1002fe6">
        <source>planningStateStringToEnum(_planningStateStr : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     06 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	retState 		: Integer;
	tmpVal	: String;

begin

	tmpVal := _planningStateStr.toUpper;
    
    if tmpVal = app.getErrorString(Null).toUpper() then
    	retState := NULL_PLANSTATE;
    
    elseif tmpVal = app.getErrorString(Notified).toUpper() then 
      retState := NOTIFIED_STATE;
    
    elseif tmpVal = app.getErrorString(Received).toUpper() then 
    	retState := RECEIVED_STATE;
    
    elseif tmpVal = app.getErrorString(Planned_To_Load).toUpper() then 
    	retState := PLANNED_LOAD_STATE;
    
    elseif tmpVal = app.getErrorString(Loaded).toUpper() then 
    	retState := LOADED_STATE;
    
    elseif tmpVal =  app.getErrorString(Planned_To_Discharge).toUpper() then 
    	retState := PLANNED_DISCHARGE_STATE;
    
    elseif tmpVal = app.getErrorString(Discharged).toUpper() then 
    	retState := DISCHARGED_STATE;
    
    elseif tmpVal = app.getErrorString(Delivered).toUpper() then 
    	retState := DELIVERED_STATE;
    
    elseif tmpVal= app.getErrorString(Planned_SOB).toUpper()	then 
    	retState := PLANNED_SHIFT_STATE;
    
    elseif tmpVal = app.getErrorString(Shifted_On_Board).toUpper()	then 
    	retState := SHIFTED_STATE;
    
    else
    	retState := -1;
    	
    endif;
	
	return retState;
end;</source>
        <Parameter name="_planningStateStr" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
