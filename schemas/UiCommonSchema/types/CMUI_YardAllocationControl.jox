end;</source>
        <Parameter name="pIsEnabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDefaultDescription" id="031370ec-c05a-4143-8bcf-541bee149587">
        <source>getDefaultDescription() : String;
// ---------------------------------------------------------------------------
// Created:		July  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	desc		: String;
	aYAP		: CMIF_YACriteriaPriority;
	index		: Integer;
	listCount	: Integer;
	
begin
	if self.myLstCriteria = null then
		return null;
	endif;
	
	listCount	:=	self.myLstCriteria.listCount();
	
	foreach index in 1 to listCount do
		if self.myLstCriteria.itemObject[index].isKindOf(CMIF_YACriteriaPriority) then
			aYAP	:=	self.myLstCriteria.itemObject[index].CMIF_YACriteriaPriority;
			
			if desc = null then
				desc := aYAP.getListDisplay();
			else
				desc := desc &amp; ", " &amp; aYAP.getListDisplay();
			endif;
		endif;
	endforeach;
	
	return desc;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExpiryType" id="aff8d58e-e779-458c-b4df-afe0d7ebc20d">
        <source>getExpiryType():Integer protected;
// --------------------------------------------------------------------------------
// Created:		15 March 2005 by cnwdad1
//
// Purpose:		Returns the value of the relevant YA Expiry Type global constant.
//
// Parameters:	None
//
// Returns:		The global constant value of the selected Expiry Type.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myOptNever.value then
		return YAExpiryType_Never;
	elseif self.myOptVoyageDepart.value then
		return YAExpiryType_VoyageDepart;
	elseif self.myOptWhenEmpty.value then
		return YAExpiryType_WhenEmpty;
	elseif self.myOptSpecifiedDate.value then
		return YAExpiryType_SpecifiedDate;
	else
		return 0;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedBlock" id="fdf7a6dc-d134-4928-8cf9-a96be12e5866">
        <source>getSelectedBlock():CM_YABlock protected;
// --------------------------------------------------------------------------------
// Created:		15 March 2005 by cnwdad1
//
// Purpose:		Returns a reference to the currently selected Yard Allocation Block
//				in the "selected" listbox" control.
//
// Parameters:	None
//
// Returns:		A reference to the selected YA Block, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myLstLocations.listIndex = CNEC_NULL_INDEX then
		return null;
	else
		if self.myLstLocations.listObject.isKindOf(CM_YABlock) then
			return self.myLstLocations.listObject.CM_YABlock;
		else
			return null;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_YABlock"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="cf536487-2575-4846-b655-f1ce7ec9cf57">
        <source>getTerminal():CM_Terminal protected;
// --------------------------------------------------------------------------------
// Created:		06 April 2005 by cnwdad1
//
// Purpose:		Returns a reference to the current Terminal.
//
// Parameters:	None
//
// Returns:		A refeence to the current Terminal.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalObj		: CM_Terminal;
	
begin
	if self.myYardAllocation &lt;&gt; null then
		return self.myYardAllocation.myTerminal;
	else
		terminalObj	:=	app.getMyTerminalDO_NOT_USE();
		
		if app.isDevelopmentSystem() and terminalObj = null then
			terminalObj	:=	CM_Terminal.firstInstance();
		endif;
		
		return terminalObj;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getVoyageColour" id="72c21bbf-a43b-459f-b49c-12a30aad2fa8">
        <source>getVoyageColour(_allTransientCriteriaObj : CMIF_Array) : Integer protected;

vars
	cmifObject		: CMIF_Object;
	criteriaObj		: CMIF_YACriteriaPriority;
	dataObj			: Object;

begin
	foreach cmifObject in _allTransientCriteriaObj do
		criteriaObj	:=	cmifObject.CMIF_YACriteriaPriority;
		
		 if criteriaObj.isDeleted then
		 	continue;
		 endif;
		
		 if criteriaObj.myProxy &lt;&gt; null and criteriaObj.myProxy.myYACriteriaType &lt;&gt; null
		 and criteriaObj.myProxy.myYACriteriaType.type = YACriteriaType_Voyage
		 then
		 	foreach dataObj in criteriaObj.myProxy.myYAData.CM_YADataObjects.allObjects do
		 		if dataObj &lt;&gt; null and app.isValidObject(dataObj) then//par 15229
					return dataObj.CM_Voyage.colour;
				endif;
		 	endforeach;
		 endif;
	endforeach;
	
	return 0;
end;</source>
        <access>protected</access>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="inheritCriteria" id="afca2e1a-5580-47e9-a9d2-b83e7a6b9bd3">
        <source>inheritCriteria() protected;
// --------------------------------------------------------------------------------
// Created:		10 May 2005 by cnwdad1
//
// Purpose:		Inherits the criteria of any other Yard Allocation that uses the
//				first location of this Yard Allocation.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	blockGroupObj			: CM_YABlockGroup;
	blockObj				: CM_YABlock;
	yardControllerObj		: CM_YardController;
	allocationObj			: CM_YardAllocation;
	criteriaObj				: CM_YACriteria;
	transientCriteriaObj	: CMIF_YACriteriaPriority;
//	allUsedCriteriaObj		: CM_YACriteriaSet;
	allUsedTypesObj			: CM_ObjectSet;
	
begin
	// Get the first YA Block.
	
	if self.allBlockGroupsIn.size() &gt; 0 then
		blockGroupObj	:=	self.allBlockGroupsIn.first();
		
		if blockGroupObj.allYABlocksIn.size() &gt; 0 then
			blockObj	:=	blockGroupObj.allYABlocksIn.first();
		else
			return;
		endif;
	elseif self.allBlockGroupsOut.size() &gt; 0 then
		blockGroupObj	:=	self.allBlockGroupsOut.first();
		
		if blockGroupObj.allYABlocksOut.size() &gt; 0 then
			blockObj	:=	blockGroupObj.allYABlocksOut.first();
		else
			return;
		endif;
	else
		return;
	endif;
	
	// Now inherit the YA Block's criteria.
	
	yardControllerObj	:=	blockObj.allYardControllers.first();
	
//	create allUsedCriteriaObj transient;
	create allUsedTypesObj transient;
	
	// CCMS 1013
	//foreach allocationObj in yardControllerObj.allYardAllocations do
	foreach allocationObj in yardControllerObj.allYardAllocations where (not allocationObj.isDisabled and allocationObj.includeInYardDisplays()) do
		foreach criteriaObj in allocationObj.allCriteria do
		/*	if allUsedCriteriaObj.includes(criteriaObj) then
				// We don't want to inherit a Criteria more than once.
				continue;
			endif;*/
			if allUsedTypesObj.includes(criteriaObj.myYACriteriaType) then
				// We don't want to inherit a Criteria more than once.
				continue;
			endif;
			
			transientCriteriaObj	:=	criteriaObj.getTransient();
			transientCriteriaObj.setFlag(true, false, false);
			self.myCtrlCriteria.allSelectedCPs.add(transientCriteriaObj);
			//allUsedCriteriaObj.add(criteriaObj);
			allUsedTypesObj.add(criteriaObj.myYACriteriaType);
		endforeach;
	endforeach;
	
	self.yaRefreshCriteriaPriority(self.myCtrlCriteria.allSelectedCPs.first());
epilog
	delete allUsedTypesObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isLocBlockGroupSelected" id="27f9b002-9939-49e4-b256-60bb207fed89">
