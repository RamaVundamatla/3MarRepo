    <JadeMethod name="setComboValues" id="df92feb8-525f-4f67-b25d-f8a10107d272">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	isoType				: CM_ISOType;
	isoTypeDict			: CM_ISOTypeByCodeDict;
begin
	_combo.clear();
	isoTypeDict := app.myRoot.allISOTypes;
	
	foreach isoType in isoTypeDict do
		_combo.itemObject[_combo.addItem(isoType.code &amp; '   ' &amp; isoType.description)] := isoType;
	endforeach;

	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := isoTypeDict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := isoTypeDict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="showCriteria" id="76f752b8-484d-4551-b208-3cb727ff8340">
        <source>showCriteria(lineHolder: CM_QueryCriteriaLineHolder input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Nov 2019	jlger1	Initial creation  47132

*/

vars

	os : ObjectSet;
	obj : Object;
begin
	
	create os transient;
	lineHolder.getCargoTypes(os);
	
	foreach obj in os discreteLock do
		if obj.CM_CargoType.allISOTypes.first &lt;&gt; null then
			return true;
		endif;
	endforeach;
	
	return false;

epilog
	delete os;

end;</source>
        <Parameter name="lineHolder" type="CM_QueryCriteriaLineHolder" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="3ffcb272-953d-4ed7-b9c1-750a48516e78">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
22 Oct 2008	cnwkpd1	PAR #18099 - Handle null objects in selector queries

*/

vars

begin
	if _value &lt;&gt; null then
		return _value.CM_ISOType.code;
	endif;
	
	return null;


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="c9255a1a-cc50-4a6b-94e8-6c7c2d688d0d">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	invalidObj 		: Boolean;
	object			: CM_ISOType;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_ISOType) then
			object := _value.CM_ISOType;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="c5300854-0244-402f-a3b8-b5efb9d8f145">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	isoType : CM_ISOType;

begin
	if _value.isKindOf(String) then
		isoType := app.myRoot.allISOTypes[_value.String];
		if isoType &lt;&gt; null then
			return isoType.code;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
