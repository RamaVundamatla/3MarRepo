<CollClass name="CM_SubTerminalByCodeDict" id="3274bd39-fe3c-46db-8597-3daf1d9922f8">
    <loadFactor>66</loadFactor>
    <memberType name="CM_SubTerminal"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="terminal"/>
    <MemberKey>
        <property name="CM_SubTerminal::code"/>
    </MemberKey>
    <JadeMethod name="getMatchingDesc" id="6db7fb49-e73f-4e42-8022-b80b114fa25b">
        <source>getMatchingDesc(_desc : String ):CM_SubTerminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2018	jlgndl1	Initial creation	TFS 39338

*/

vars

	subTerm : CM_SubTerminal;

begin

	foreach subTerm in self do
		if subTerm.description = _desc then
			return subTerm;
		endif;
	endforeach;

	return null;

epilog

end;</source>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="CM_SubTerminal"/>
    </JadeMethod>
</CollClass>
