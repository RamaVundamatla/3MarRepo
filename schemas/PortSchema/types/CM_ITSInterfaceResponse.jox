        <embedded/>
        <type name="CM_RTQueueEntry"/>
        <access>readonly</access>
        <Inverse name="CM_RTQueueEntry::allITSInterfaceResponses"/>
    </ExplicitInverseRef>
    <PrimAttribute name="originalMsgNo" id="9884d35d-4bb9-4223-9d0b-74ab70413543">
