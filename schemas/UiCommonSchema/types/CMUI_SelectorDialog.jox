/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/

vars

begin
	self.addCriteriaLine();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnArgFindClose_click" id="9ed06622-09f3-40bf-96ed-895c62e0058d">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnArgFindClose_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/

vars

	persistentProp : CM_QueryProperty;
	tmpProp : CM_QueryProperty;
	persistentOp : CM_QueryOperator;
	tmpOp : CM_QueryOperator;

begin

	self.frmTblArgument.visible := false;
	//self.sptMain.enabled := true;
	
	persistentProp :=cmbAttribute.listObject.CM_QueryProperty;
	persistentOp := cmbOperator.listObject.CM_QueryOperator;
	
	if persistentProp = null or persistentOp = null then
		self.lblargList.caption := null;
		return;
	endif;
	
	tmpProp := persistentProp.cloneSelf(true);
	tmpOp := persistentOp.cloneSelf(true);
	
	tmpProp.setValuesFromList(tblArgument, tmpOp);
	self.lblargList.caption := tmpOp.getSearchValueStr(tmpProp);

epilog

	delete tmpProp;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnArgFind_click" id="41e1c4bb-9898-4668-b85b-34ff369be34c">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnArgFind_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog
*/

vars

begin
	self.frmTblArgument.left := ( self.clientWidth - self.frmTblArgument.width ) / 2;
	self.frmTblArgument.top := ( self.clientHeight - self.frmTblArgument.height ) / 2;

	self.frmTblArgument.visible := true;
	self.txtArgFind.text := null;
	//self.sptMain.enabled := false;
	
	self.frmTblArgument.zOrder(1);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
