    <JadeMethod name="clear" id="59d8ff14-a7ad-4bf8-83d8-648d66c487f9">
        <updating/>
        <source>clear() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
01 Aug 2022	navlw1		Initial creation tfs 53854
08 Jan 2026 navma1 		MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/

vars
	propertyColl : PropertyColl; 
	prop 		 : Property;
begin
	
	propertyColl := class.allProperties;
	
	foreach prop in propertyColl where prop.access = Property.Access_Public do
		self.setPropertyValue(prop.name, null);
	endforeach;
epilog
	delete propertyColl;			//08.01.2026 navma1 #MTN-36897
end;</source>
    </JadeMethod>
    <JadeMethod name="setScopeClaims" id="4457ecd0-616f-4f22-b487-488cf72a6ffc">
        <updating/>
        <source>setScopeClaims(_complexId : String; _terminalId : String; _operatorId : String; _yardId : String) updating;
/*

Purpose: To store the claims from the JWT Token			

Parameters:			

Return Value:		

Date			Who		Reason
27 July 2022	navlw1	Initial creation TFS 53854

*/

vars

begin
	app.writeLog(method.qualifiedName &amp; " _complexId: [" &amp; _complexId &amp; "] _terminalId: [" &amp; _terminalId &amp; "] _operatorId: [" &amp; _operatorId &amp; "] _yardId: [" &amp; _yardId &amp; "]", LogTRACE);
	
	self.complexId := _complexId;
	self.terminalId := _terminalId.toUpper;
	self.operatorId := _operatorId.toUpper;
	self.yardId := _yardId;
epilog

end;</source>
        <Parameter name="_complexId" type="String"/>
        <Parameter name="_terminalId" type="String"/>
        <Parameter name="_operatorId" type="String"/>
        <Parameter name="_yardId" type="String"/>
    </JadeMethod>
</Class>
