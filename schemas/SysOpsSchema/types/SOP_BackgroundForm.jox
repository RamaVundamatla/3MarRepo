    <JadeMethod name="doDebug" id="748ffb64-f860-4ac1-95c5-f762c8958c83">
        <source>doDebug() protected;
// -------------------------------------------
// Created 29 October 2003 by cnwdvb1
// -------------------------------------------
vars
	
	level : Integer;
	
	processObj : Process;
	form : CMUI_SetLoggingLevel;
	result : Integer;

begin

	if not global.isValidObject(self.myBGPObject) or self.myBGPObject.isManager() then
		return;
	endif;
	
	/*
	read level;
	
	if level &lt; LogINFO or level &gt; LogDEBUG then
		app.msgBox('Debug level of ' &amp; level.String &amp; ' is invalid. Value must be 0 - 4','Debug',MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif; 
	
	self.myBGPObject.BGP_Controller.doDebug(level);	
	
	*/
	
	//27 Nov 2019	NDL	TFS 47053
	processObj := self.myBGPObject.BGP_Controller.myProcess;
	if processObj &lt;&gt; null then
		create form transient;
		form.setProcessObject( processObj );
		form.showModal();
		
		result := form.modalResult;
	
		if result &gt;= LogINFO and result &lt;= LogTRACE then
			self.myBGPObject.BGP_Controller.doDebug(result);	
		endif;
		
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="132030fc-f9ca-4ccd-b4f4-03920e54b39d">
        <updating/>
        <source>doDelete() protected, updating;

// cnwdvb1 25 October 2002 

vars

	rtnValue : Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	if global.isValidObject(self.myBGPObject) and self.myBGPObject.isManager() then
		if app.msgBox(app.getErrorString(Delete_Manager_Question),app.getErrorString(Delete_Manager2),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
			
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxDA.trxDeleteBGPManager(self.myBGPObject.BGP_Manager, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog(app.getErrorString(Delete_BGP_Object), app.myPassport, ErrWarnMode_Delete);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
			
		endif;
	endif;
	self.selectedRow := 0;
	self.myBGPObject := null;
	self.doDisplay();
	
epilog

	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDisplay" id="450917be-fad3-4ed2-a484-ae0a6fb88c87">
        <updating/>
        <source>doDisplay() protected, updating;
/*

Purpose:			Reload entire table

Parameters:			None

Return Value:		None

Date		Who		Reason
24 Oct2002 	cnwdvb1 
29 Nov 2011	cnwkpd1	PAR #28752 - BGP form performance issues
	29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	iter,
	iter2		: Iterator;
	manager		: BGP_Manager;
	controller	: BGP_Controller;
	display		: String;
	row			: Integer;

begin
	on Exception do self.xHandler(exception, controller);
	
	// If we're refershing the whole table, then stop the timer and clear any pending object updates
	self.doStopNotesTimer();
	self.allNotifiedBGPObjects.clear();
	
	self.tblDisplay.rows := 1;
	self.tblDisplay.column := 1;
	iter := app.myRoot.allBGPManagers.createIterator;
	while iter.next(manager) do
		self.addDisplayRow(manager, false, 0);
		iter2 := manager.allBGPControllers.createIterator;
		while iter2.next(controller) do
			display := controller.getDisplay();
			self.addDisplayRow(controller, true, 0);
		endwhile;
		delete iter2;
	endwhile;
	if self.selectedRow &gt; self.tblDisplay.fixedRows and self.selectedRow &lt;= self.tblDisplay.rows then
		self.selectObj(self.selectedRow, false);
	else
		self.myBGPObject := null;
		self.doStartStopButtons();
	endif;
	
epilog
	delete iter;
	delete iter2;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDisplayActive" id="ffa8809c-7157-461d-a8d6-480f843650e6">
        <updating/>
        <source>doDisplayActive() updating, protected;
/*

Purpose: Reload Entire Table  			

Parameters: None			

Return Value: None

Date		Who		Reason
23/01/2026	navlw1	JIRA-35644: MTN | BGP Show Only Running and Filtering

*/

vars
	iter		: Iterator;  
	manager 	: BGP_Manager;  
	controller 	: BGP_Controller;  
	display 	: String;  
	row 		: Integer;  
	objectArr 	: ObjectArray;  
begin
	on Exception do self.xHandler(exception, controller);
	self.doStopNotesTimer();
	self.allNotifiedBGPObjects.clear();
	
	self.tblDisplay.rows 	:= 1;
	self.tblDisplay.column 	:= 1;
	
	create objectArr transient;
	
	iter := app.myRoot.allBGPManagers.createIterator;  
	while iter.next(manager) do  
		foreach controller in manager.allBGPControllers where controller.isRunning() do  
			objectArr.add(controller);  
		endforeach;  
	
		if objectArr.size() &gt; 0 then  
			self.addDisplayRow(manager, false, 0);  
		else  
			continue;  
		endif;  
		foreach controller in objectArr as BGP_Controller do  
			display := controller.getDisplay();  
			self.addDisplayRow(controller, true, 0);  
		endforeach;  
		objectArr.clear();  
	endwhile;
	
	if self.selectedRow &gt; self.tblDisplay.fixedRows and self.selectedRow &lt;= self.tblDisplay.rows then  
		self.selectObj(self.selectedRow, false);  
	else  
		self.myBGPObject := null;  
		self.doStartStopButtons();  
	endif;  
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDisplayDoubleClick" id="a254cd84-3797-4021-a89b-d65dd4ad7fe7">
        <updating/>
