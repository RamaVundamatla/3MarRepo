    <JadeMethod name="getPutTime" id="9bd1118d-c416-48c5-87e4-bbe06c3a7e99">
        <source>getPutTime() : TimeStamp;
/*
Purpose:	OPSVIEW		

Date		Who		Reason
13 December 2021	navab1	TFS 51853
*/

vars
	qentry : CM_RTQueueEntry;
	qtask : CM_RTQueueTask;
	compTS : TimeStamp;
begin
	compTS := self.completedDate; // ### TFS 51855 24MAY2022 NAVAB1 get a valid value
	if not compTS.isValid() then // ### TFS 51855 24MAY2022 NAVAB1
		compTS := app.actualTimeAppServer(); // ### TFS 51855 24MAY2022 NAVAB1
	endif;

	qentry := self.allRTQueueEntries.last;
	
	if qentry = null then
		return compTS; // ### TFS 51855 24MAY2022 NAVAB1 self.completedDate;  // ### TFS 51855 24JAN2022 NAVAB1
	endif;
	
	if qentry.areAllTasksEqualStatus(TASK_COMPLETE) then
		qtask := qentry.allTasks.first;
		if qtask &lt;&gt; null then
			if qtask.machineAssignedDT.isValid() then // ### TFS 51855 24MAY2022 NAVAB1
				return qtask.machineAssignedDT;
			endif;
		endif;
	endif;

	return compTS; // ### TFS 51855 24MAY2022 NAVAB1 self.completedDate;  // ### TFS 51855 24JAN2022 NAVAB1
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getQuantity" id="dfda233b-c924-4e2e-a436-0b94a654e37f">
        <source>getQuantity(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2013	cnwrd1	Initial creation
22 September 2022 navmv20 Bug 54686: MTN - Quantity values don't seem to be correct in Hold Job Operations for break-bulk cargo
03 Oct 2024 navah1	Bug 19944: MTN - Work order operation screen doesn't display Work list entry quantity correctly for Cargo with Duplicate Ids
*/

vars
	ti : CM_TrackedItem;
begin

	ti := self.myTrackedItem;
	
	if ti &lt;&gt; null and ti.isBreakBulkGeneric then
		//if self.quantity = 0 then //22/09/2022 navmv20 TFS 54686
		//if self.quantity = 0 or self.status= WLE_COMPLETED then //22/09/2022 navmv20 TFS 54686 //04.10.2024 navah1 #19944
		if self.quantity = 0 then   //04.10.2024 navah1 #19944
			return ti.totalQuantity;
		else
			return self.quantity;
		endif;
	else
		return self.quantity.max(1); 
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRTIcon" id="8bfd393c-8b29-49fa-898b-896bb53cc863">
        <source>getRTIcon() : Binary;
//-----------------------------------------
//Created: June 2003 By: cnwgd1
//-----------------------------------------
vars
	icon 	: Binary;
	rtState	: String;
	
begin
	return null;
	
	// AKBAUG2004 new Q and P icons do not have Q or P on them
	
	
	
	
	if self.myFutureMove &lt;&gt; null then
		if self.myFutureMove.moveType = TI_FutureMoveQueued then
			rtState := PicMoveModeQ;
		elseif self.myFutureMove.moveType = TI_FutureMovePlanned 
		or self.myFutureMove.moveType = TI_FutureMoveDLRDischarge
		or self.myFutureMove.moveType = TI_FutureMoveDLRLoad then
			rtState := PicMoveModeP;
		endif;
	endif;
	if rtState = null and (not self.allRTQueueEntries.isEmpty) then
		rtState := PicTIRT;
	endif;

	if rtState &lt;&gt; null then
		icon := app.myRoot.getConfig(rtState).Binary;	
	endif;

	return icon;

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getRTLetter" id="94dead9a-27b2-449c-816f-b641ce393b79">
        <source>getRTLetter() : String;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	rtState	: String;
	
begin

	if self.myFutureMove &lt;&gt; null then
		if self.myFutureMove.moveType = TI_FutureMoveQueued then
			rtState := "Q";
		elseif self.myFutureMove.moveType = TI_FutureMovePlanned 
		or self.myFutureMove.moveType = TI_FutureMoveDLRDischarge
		or self.myFutureMove.moveType = TI_FutureMoveDLRLoad then
			rtState := "P";
		endif;
	endif;
	if rtState = null and (not self.allRTQueueEntries.isEmpty) then
		rtState := "RT";
	endif;

	
	return rtState;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
