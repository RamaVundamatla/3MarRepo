    <JadeMethod name="getExtVoyageCode" id="c5783e90-2cab-4203-a1d0-6532a1863386">
        <source>getExtVoyageCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2019	jlger1	Initial creation

*/

