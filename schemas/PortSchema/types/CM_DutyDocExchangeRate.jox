<Class name="CM_DutyDocExchangeRate" id="fa2e33c5-1435-44fc-a1eb-a2b64594c686">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dutyDoc"/>
    <PrimAttribute name="code" id="d4244990-3fa6-49af-bcd8-67b2491b6f84">
        <length>6</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="dateChanged" id="41810982-20a8-4aa7-826a-e6ca76d4474a">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myDutyDocRoot" id="6b5d5fce-775e-4a70-980d-e8d541ea2796">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_DutyDocRoot"/>
        <access>readonly</access>
        <Inverse name="CM_DutyDocRoot::allDutyDocExchangeRates"/>
    </ExplicitInverseRef>
    <PrimAttribute name="rate" id="b695d217-753a-4870-bc6a-58b7fcdf107c">
        <precision>8</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setForCreate" id="003b0f78-e4f2-4a87-a4ab-998764bb456e">
        <updating/>
        <source>setForCreate(_proxyDutyDocExchangeRate : CM_DutyDocExchangeRate) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	_proxyDutyDocExchangeRate.raiseExceptionIfNotTransient(method);
	
	self.myDutyDocRoot := _proxyDutyDocExchangeRate.myDutyDocRoot;
	self.setForUpdate(_proxyDutyDocExchangeRate);
epilog

end;</source>
        <Parameter name="_proxyDutyDocExchangeRate" type="CM_DutyDocExchangeRate"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d597e59d-b480-4b2c-a4b8-ca8cc40aeca3">
        <updating/>
        <source>setForUpdate(_proxyDutyDocExchangeRate : CM_DutyDocExchangeRate) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.code		 := _proxyDutyDocExchangeRate.code;
	self.rate 		 := _proxyDutyDocExchangeRate.rate;
	self.dateChanged := _proxyDutyDocExchangeRate.dateChanged;
epilog

end;</source>
        <Parameter name="_proxyDutyDocExchangeRate" type="CM_DutyDocExchangeRate"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="75ac5312-d1bf-49bb-aa04-48385a3de129">
        <updating/>
        <source>setProxy(	_code : String;
			_rate : Decimal;
			_dateChanged : TimeStamp ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.code				:= _code[1:5];
	self.rate		 		:= _rate;
	self.dateChanged		:= _dateChanged;
	self.myDutyDocRoot 		:= app.myDutyDocRoot;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_rate" type="Decimal"/>
        <Parameter name="_dateChanged" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b2475e9c-1a9c-4491-91e3-444e3d7fe37e">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	if app.myDutyDocRoot.allDutyDocExchangeRates[self.code] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
		return;
	endif;
	
	validateMe();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="4ce7ad83-a331-4c86-a767-9397b48ca28c">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	validateMe();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="c16fcd7a-34f4-464e-b414-d9cd555cc5e6">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation  HAT 2189

*/

vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Code), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Code), null, null); // cnwdb2	PAR 35364
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
