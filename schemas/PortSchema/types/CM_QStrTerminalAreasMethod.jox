    <JadeMethod name="create" id="02b09b2d-2887-4773-9888-5c3427a1d03e">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2021	navndl1	Initial creation	TFS	TFS 50906

*/

vars

	oper : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);

epilog

end;</source>
    </JadeMethod>
