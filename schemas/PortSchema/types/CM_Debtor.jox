    <JadeMethod name="getDictObjectDisplay" id="e13e8d25-2159-47ef-9685-33e1b8a41669">
        <source>getDictObjectDisplay(obj : Object): String;
//22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
vars

begin
	if obj.isKindOf(CM_CustomsAgent) then
		return obj.CM_CustomsAgent.code;
	elseif obj.isKindOf(CM_ConsigneeConsignor) then
		return obj.CM_ConsigneeConsignor.code;
	elseif obj.isKindOf(CM_Operator) then
		return obj.CM_Operator.code;
	elseif obj.isKindOf(CM_Carrier) then //+ cnwmd1, CCMS 1067, Par 19913
		return obj.CM_Carrier.code;
	elseif obj.isKindOf(CM_Carrier) then //+ cnwmd1, CCMS 1067, Par 19913
		return obj.CM_Carrier.code;
	elseif obj.isKindOf(CM_Stevedore) then 
		return obj.CM_Stevedore.code;
	elseif obj.isKindOf(CM_DebtorType) then  //22.07.2019 cnwma1 TFS #45577
		return obj.CM_DebtorType.code;
	elseif obj.isKindOf(CM_EmailAddress2) then  //22.07.2019 cnwma1 TFS #45577
		return obj.CM_EmailAddress2.name;
	elseif obj.isKindOf(CM_PackageInvoice) then  //22.07.2019 cnwma1 TFS #45577
		return obj.CM_PackageInvoice.description;
	else
		return '';
	endif;
end;
</source>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayFromDict" id="8a1adc04-6792-4130-94f4-74d0cb227a25">
        <source>getDisplayFromDict(dict : CM_MemberKeyDictionary):String;

vars
	obj : Object;
	tmpStr,
	strObj : String;
	count : Integer;
begin
	foreach obj in dict do
		strObj := getDictObjectDisplay(obj);
		count := count + 1;
		if count &gt; 6 then
			tmpStr := tmpStr &amp; "," &amp; CrLf;
			count := 1;
		endif;
		if tmpStr = "" then
			tmpStr := strObj;
		elseif count = 1 then
			tmpStr := tmpStr &amp; strObj;
		else
			tmpStr := tmpStr &amp; ", " &amp; strObj;
		endif;
	endforeach;
	return tmpStr;
end;
</source>
        <Parameter name="dict" type="CM_MemberKeyDictionary"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f098c953-76c9-4c56-8bf3-850e8b42c410">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _attrName = ETRow_Address then
		return self.getBillingAddressString();
	elseif _attrName = ETRow_Terms  then
		if self.myTermsOfTrade = null then
			return null;
		else
			return self.myTermsOfTrade.description;
		endif;
	elseif _attrName = ETRow_PostingNumber then
		return self.postingNumber.String;
	elseif _attrName = ETRow_PurchaseOrderNumber then
		return self.purchaseOrderCode;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDutyDocExtraCharges" id="5cf12b55-147b-4618-ac91-f0e308f3d3cc">
        <source>getDutyDocExtraCharges( _myTerminal : CM_Terminal; _allExtraCharges : CM_InvoiceSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2013	cnwndl1	Initial creation	Par 30901
04/03/2015			cnwmh5	Transient Leak

*/

vars

	iter : Iterator;
	startObject : CM_Invoice;
	invoice : CM_Invoice;
	
	totalCharges : Decimal [23,6];
	cashAmount	: Decimal [16,4];
	outstandingAmount : Decimal [23,6];

begin

// 3 June 2014 34288
//	if not self.isCashOnlyDebtor(_myTerminal) then
//		return;
//	endif;

	if self.allInvoices.isEmpty then
		return;
	endif;

	startObject := self.allInvoices.getAtKeyGeq(_myTerminal,null,null);
	if startObject = null or startObject.myTerminal &lt;&gt; _myTerminal then
		return;
	endif;
	
	iter := self.allInvoices.createIterator;
	iter.startAtObject(startObject);
	while iter.next( invoice ) do
		if invoice.myTerminal &lt;&gt; _myTerminal then
			break;
		endif;
		if not invoice.isExtraChargeForDutyDocSystem( totalCharges, cashAmount, outstandingAmount) then
			continue;
		endif;
		_allExtraCharges.add( invoice );
	endwhile;
	 

epilog
	delete iter;
end;</source>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
        <Parameter name="_allExtraCharges" type="CM_InvoiceSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEmailAddress" id="ae44d1da-4b2d-4a77-bd7d-376beadd640e">
        <source>getEmailAddress():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 October 2018	jlgma1	ChangeRequest 41462: PEL1 - SAP Integration - Rejection Email

*/

vars
	remarks,
	tmp,
	email : String;
	strArr : StringArray;
begin
	create strArr transient;
	remarks := self.remarks.removeCrLfs();
	remarks.cnEcToStringArray(strArr);

	foreach tmp in strArr do
		if tmp.cnContains('@') then
			email := email &amp;','&amp; tmp  ;
		endif; 
	endforeach;
	
	
	return email[2:email.length];
epilog
 delete strArr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEstimateOpenAmount" id="1e1a007f-299f-4906-a871-d348dc43a585">
        <source>getEstimateOpenAmount(_paymentType : Integer):Integer64;
/*

Purpose:			
	Used To Bring Open Estimate Amount For WSDL:
	
	37189.001 Perform Credit Check for Auto-Collection Customer 
	WSDL 1.1: Auto-Collection - Credit Limit + Hold Amount
	PaymentType_AutoCollection
	
	37189.003 Perform Credit Check for Post-Billing Customer
	WSDL 1.6: Post-Billing - Credit Limit
	PaymentType_PostPay
	
	37189.002 Perform Credit Check for Pre-Billing Customer
	WSDL 1.4: Pre-Billing - Credit Limit + Billing Payment Process
	PaymentType_PrePay
Parameters:			

Return Value:		

Date		Who		Reason
29/01/2019 cnwma1	Bug 43124: PEL1 - Container Services - SAP SIT issues
05/02/2019 cnwma1	Bug 43222: PEL1 - Container Services - WSDL 1.4 Open Estimate amount

*/

vars
	dTerm      : CM_DebtorTerminal;
	cr         : CM_CashReceipt;
	openAmount : Decimal[23,6];
	invoice    : CM_Invoice;
	cmif       : CMIF_SAPWSRequest;
begin
	
	if _paymentType = PaymentType_PrePay then 
	
		foreach invoice in self.allInvoices do
			
			if  invoice.paymentType &lt;&gt; PaymentType_PrePay then
				continue;
			endif;
			
			if not invoice.isPrepend  then
				continue;
			endif;
			
			if not invoice.isPaymentNotPaid then
				continue;
			endif;
			
			if invoice.myCashReceipt &lt;&gt; null then
				if invoice.myCashReceipt.paymentStatus &lt;&gt; CM_CashReceipt.CREDIT_CHECK_APPROVED or
					invoice.myCashReceipt.paymentStatus &lt;&gt; CM_CashReceipt.API_RECEIPT_FINAL //11/07/2024	navkc1 CR 64837 Task 64851
					then
					continue;
				endif;
			endif;
			
			create cmif transient;
			openAmount := openAmount + cmif.getTotalAmtDocCurAR(invoice);
			delete cmif;
			
		endforeach;
	
	else
		foreach dTerm in self.allDebtorTerminals discreteLock do
					
			if dTerm.paymentType &lt;&gt; _paymentType  then          
				continue;
			endif; 
			
			foreach cr in dTerm.allCashReceipts discreteLock do
				
				if cr.paymentStatus &lt;&gt; CM_CashReceipt.CREDIT_CHECK_APPROVED or
					cr.paymentStatus &lt;&gt; CM_CashReceipt.API_RECEIPT_FINAL //11/07/2024	navkc1 CR 64837 Task 64851
					then 					
					continue;
				endif;
				
				openAmount := openAmount + cr.getAmountForCurrencyCode("USD",cr.createdTime);
					
			endforeach;
		endforeach;
	endif;
	return openAmount.Integer64;
epilog

end;</source>
        <Parameter name="_paymentType" type="Integer"/>
        <ReturnType type="Integer64"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="d378b738-3730-4705-be80-cccc9da37314">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		28 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;
	idx, rows, count : Integer;
	tmpStr : String;
	
	aCA : CM_CustomsAgent;
	anOP : CM_Operator;
	anCON : CM_ConsigneeConsignor;

begin
	inheritMethod(_dataContainer);

	rows := self.billingAddress.size;
	if rows &gt; 0 then
		foreach idx in 1 to rows do
			tmpStr := tmpStr &amp; self.billingAddress[idx] &amp; Cr;
		endforeach;
		block := _dataContainer.addNewBlock;
		block.addNewItem("Address", DC_Label, 1, self);
		block.addNewItem(tmpStr, DC_Data, 1, self);
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem("Remarks", DC_Label, 1, self);
	block.addNewItem(self.remarks, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;        //13.8.2018 cnwma1
	block.addNewItem("Code", DC_Label, 1, self);
	block.addNewItem(self.code, DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Account Code", DC_Label, 1, self);
	block.addNewItem(self.decfinName, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Purchase Order Code", DC_Label, 1, self);
	block.addNewItem(self.purchaseOrderCode, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem("External Reference", DC_Label, 1, self);
	block.addNewItem(self.externalReference, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Terms Of Trade", DC_Label, 1, self);
	block.addNewItem(self.getTermsOfTrade(false), DC_Data, 1, self);
	
	// ### CUSTOMS AGENTS
	tmpStr := getDisplayFromDict(self.allCustomsAgents); 
	if tmpStr &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Customs Agents", DC_Label, 1, self);
		block.addNewItem(tmpStr, DC_Data, 1, self);
	endif;

	// ### OPERATORS
	tmpStr := getDisplayFromDict(self.operators); 
	if tmpStr &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Operators", DC_Label, 1, self);
		block.addNewItem(tmpStr, DC_Data, 1, self);
	endif;

	tmpStr := getDisplayFromDict(self.allCarriers);  //+ cnwmd1, CCMS 1067, Par 19913
	if tmpStr &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Carriers", DC_Label, 1, self);
		block.addNewItem(tmpStr, DC_Data, 1, self);
	endif;
	
	// ### CONSIGNORS
	tmpStr := getDisplayFromDict(self.consignors); 
	if tmpStr &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Consignors", DC_Label, 1, self);
		block.addNewItem(tmpStr, DC_Data, 1, self);
	endif;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Bad Credit", DC_Label, 1, self);
	block.addNewItem(self.badDebtor.cnEcGetYesNo(), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	
	block.addNewItem("Zero Rated Tax", DC_Label, 1, self);

	block.addNewItem(self.isZeroRatedTax.cnEcGetYesNo(), DC_Data, 1, self);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Suspended", DC_Label, 1, self);
	block.addNewItem(self.isSuspended.cnEcGetYesNo(), DC_Data, 1, self);
	
	// cnwjk3 PAR 18434 - Date - 07/11/2008
	block := _dataContainer.addNewBlock;
	block.addNewItem("Purchase Order Mandatory", DC_Label, 1, self);
	block.addNewItem(self.isPurchaseOrderMandatory.cnEcGetYesNo(), DC_Data, 1, self);


end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getLastInvoiceForStatus" id="56023f64-c6b0-4f0a-96d8-52320822f047">
        <source>getLastInvoiceForStatus(_param : CMIF_InvoiceSelection input) : CM_Invoice;
// prototype for 31890
vars

	theInvoice	: CM_Invoice;
	iter 		: Iterator;
	tmpStatus : Integer;
begin
	tmpStatus := _param.status;
	
	iter := self.invoicesByStatus.createIterator();
	self.invoicesByStatus.startKeyLss(tmpStatus + 1, iter);
	while iter.back(theInvoice) do

		if theInvoice.status &lt;&gt; tmpStatus then
			break;
		endif;
		
		if not theInvoice.isMatch(_param) then
			continue;
		endif;
				
		return theInvoice;
	endwhile;
	
	return null;
epilog
	delete iter;
end;</source>
