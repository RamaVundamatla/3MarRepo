    </JadeMethod>
    <JadeMethod name="isPreAssigned" id="c3f1dafe-2eb0-45b1-946b-3342d7449208">
        <source>isPreAssigned():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Oct 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	ncg : CM_NotifiedCargoGroup;

begin

	if self.myCargoGroupAssignment &lt;&gt; null then
		return not self.allPreAssignedCargoIdsDict.isEmpty;
	elseif self.getMyCargoGroupAssignment &lt;&gt; null then
		ncg := self.getMyNotifiedGroup;
		if ncg &lt;&gt; null then
			return ncg.isPreAssigned;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
