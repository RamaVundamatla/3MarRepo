    <JadeMethod name="btnSelectVoyOK_click" id="ae8dbec7-67e0-49ce-a7d3-3153a469819d">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSelectVoyOK_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	newVoyage : CM_Voyage;
	aBay : CM_Bay;

begin
	newVoyage := self.cmbVoyage.listObject.CM_Voyage;

	self.frmSelectVoyage.visible := false;

	self.setMyCurrentVoyage(newVoyage, false);
	self.allSelectedHolds.clear();
	
	self.msgHolds.getSelected(self.allSelectedHolds);
	
	if newVoyage &lt;&gt; null  then	//03 Oct 2016	NDL	TFS 2715
		if newVoyage.myShipBlockStack &lt;&gt; null then		// 20/7/16 cnwmp6 TFS 1601
			self.includeShipBlockStack := self.msgHolds.isSelected(newVoyage.myShipBlockStack);
		endif;
	endif;
	
	if (not self.voyageLoad(self.displayMode)) then
		// reshow the selector
		self.frmSelectVoyage.visible := true;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
