    <JadeMethod name="tblExclude_change" id="661c1c49-b7ee-4be8-91f8-d9d0bb44c3a0">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExclude_change(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2003 by cnwdad1
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	table.column	:=	1;

	if table.row = table.rows and table.text &lt;&gt; null then
		table.rows	:=	table.rows + 1;
	endif;
end;</source>
