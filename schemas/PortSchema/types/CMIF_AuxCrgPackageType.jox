    <JadeMethod name="initializeForActivity" id="b2ad3c4a-5ff6-4c24-9f2e-cef5a8bb59bf">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Jun 2022	navsp1	Initial creation TFS#53104

*/

vars
	handType : CM_HandlingType;
begin
	inheritMethod(_any, _ewsOpsView);
	self.tableName		:= self.Aux_crg_package_type;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey		:= self.generateFullGKey(_any, "");
		return;
	endif;
	
	if _any.isKindOf(CM_HandlingType) then
		handType	:= _any.CM_HandlingType;
		handType.initializeForActivity(_ewsOpsView,self);
	endif;
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
