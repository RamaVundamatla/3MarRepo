    <JadeMethod name="updateCriteriaLine" id="bb5d03b4-352a-4f51-a955-911a9807aa54">
        <source>updateCriteriaLine() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog

*/
vars
	row					: Integer;
	criteriaLine		: CM_SelectorCriteriaLine;
begin
	row:=self.tblCriteria.row;
	criteriaLine := self.tblCriteria.accessRow(row).itemObject.CM_SelectorCriteriaLine;
	if criteriaLine = null  or not self.tblCriteria.accessRow(row).selected then
		app.msgBox(app.getErrorString2(CMUI_MustSelect, app.getErrorString(CMUI_Selector_Criteria_Line), app.getErrorString(Update)), app.getErrorString(CMUI_Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if (not self.validateCriteriaLineUpdate(criteriaLine.myQueryProperty.propertyName)) then
		return;
	endif;
	
	self.setPropertyValueAndOperator(criteriaLine);
	self.tblCriteria.removeItem(row);
	self.tblCriteria.addItemAt(criteriaLine.getDescriptionString, row);
	self.tblCriteria.accessRow(row).itemObject := criteriaLine;
	self.tblCriteria.accessRow(row).backColor := criteriaLine.getPerformanceColour;	


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateStatus" id="cc3ce6c4-9bf5-4da0-b4fa-4a3bc18293ce">
        <source>updateStatus() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog

*/
vars
	statusMsg		: String;
	tableObj		: Table;
	selectedCount	: Integer;
	
begin
	tableObj		:=	tblResults;
	statusMsg		:=	(tableObj.rows - tableObj.fixedRows).cnEcNumberFormat() &amp; " Items displayed";
	selectedCount	:=	tableObj.selectedCount();
	
	if selectedCount = 0 then
		statusMsg	:=	statusMsg &amp; " (0 Items selected)";
	else
		statusMsg	:=	statusMsg &amp; " (" &amp; tableObj.getSelectedRowCount.cnEcNumberFormat() &amp; " Items selected)";
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
