    <JadeMethod name="doSave" id="02b5404c-8b84-480e-9ac2-90db4fb2611f">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyDelay	:	HMS_Delay;
	theForm		:	SOP_TableMaintForm;
	
begin
//	return inheritMethod();
	theForm := self.myForm.SOP_TableMaintForm;
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_Delay transient;	
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	endif;
	
	pxyDelay := theForm.myProxyObject.HMS_Delay;
	theForm.tblInput1.setObjectFromTable(pxyDelay, null, false);
	pxyDelay.setProxy(app.myRoot);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyDelay, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyDelay, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name,
										method.name,
										'  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;			
			
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
