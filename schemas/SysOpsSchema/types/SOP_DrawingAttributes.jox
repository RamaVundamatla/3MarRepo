    <JadeMethod name="doResize" id="120020a7-1324-4242-8955-30f3f93f7727">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	inheritMethod();
	self.tblAttributes.move(0, self.frmToolbar.height, self.clientWidth, self.clientHeight - self.frmToolbar.height.Integer);
	self.tblAttributes.setLastColumnMaxWidth();
end;</source>
    </JadeMethod>
    <JadeMethod name="doTableClick" id="0cd64afc-77fb-4ff6-9ff9-a49e285943cf">
        <source>doTableClick();
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19 Jan 2018	cnwma1		Bug 36630: Drawing Attributes screen behaviour different between amast and dmast
// ---------------------------------------------------------------------------

vars

	cmdColor	: CMDColor;
	tmpCell	: JadeTableCell;
	tmpText	: String;
begin

	if self.tblAttributes.row &lt;= self.tblAttributes.fixedRows then
		return;
	endif;
	
	if app.isAllowedToInspect then
		if self.tblAttributes.column = self.Col_Attribute then// JLGAB1 16/10/17
			self.tblAttributes.accessRow(self.tblAttributes.row).itemObject.inspectModal;// JLGAB1 16/10/17
			return;// JLGAB1 16/10/17
		endif;// JLGAB1 16/10/17
	endif;
	
	tmpCell := self.tblAttributes.accessCell(self.tblAttributes.row, Col_Colour).cloneSelf(true);

	if self.tblAttributes.column = self.Col_Colour then
		create cmdColor transient;
		cmdColor.preventFullOpen := false;
		cmdColor.color := tmpCell.backColor;
		if cmdColor.open = 0 then
			tmpCell.backColor := cmdColor.color;
			tmpCell.foreColor := tmpCell.backColor.getInverseColour();
			tmpCell.text := tmpCell.backColor.String;
			self.tblAttributes.accessCell(self.tblAttributes.row, Col_Character).foreColor := tmpCell.backColor;
		endif;
	endif;
epilog
	if cmdColor &lt;&gt; null then
	delete cmdColor;
	endif;



end;</source>
    </JadeMethod>
    <JadeMethod name="initTable" id="b6a97856-1828-4ae9-8554-66a6a28447cf">
        <source>initTable();
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19 Jan 2018	cnwma1		Bug 36630: Drawing Attributes screen behaviour different between amast and dmast
// ---------------------------------------------------------------------------

vars
begin

	self.tblAttributes.rows := 0;
	self.tblAttributes.columns := self.Col_Colour;
	self.tblAttributes.fixedColumns := 0;
	self.tblAttributes.fixed3D := false;
	self.tblAttributes.addItem("Attribute" &amp; Tab &amp; "Code"  &amp; Tab &amp; "Font" &amp; Tab &amp; "Character" &amp; Tab &amp;  "Character" &amp; Tab &amp; "Colour");
	self.tblAttributes.fixedRows := 1;
	self.tblAttributes.accessColumn(self.Col_Attribute).width := 150;
	self.tblAttributes.accessColumn(self.Col_Code).width := 150;
	self.tblAttributes.accessColumn(self.Col_Font).width := 100;
	self.tblAttributes.accessColumn(self.Col_Character).width := 100;
	self.tblAttributes.accessColumn(self.Col_CharacterNumber).width := 50;
	self.tblAttributes.accessColumn(self.Col_CharacterNumber).visible := false;
	self.tblAttributes.accessColumn(self.Col_Colour).width := 100;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="687e932c-76f3-457c-af6a-ee7eae2dcf97">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19 Jan 2018	cnwma1		Bug 36630: Drawing Attributes screen behaviour different between amast and dmast
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();

	self.initTable();
	self.displayTable();
	//self.width := 475; 	//19/01/2018 cnwma1 #36630
	//self.height := 500;   //19/01/2018 cnwma1 #36630

	self.myMasterMenuAction.setHeading(self.caption); 
	self.tblAttributes.readOnly := false;
	self.tblAttributes.userInputEnabled := true;
	self.btnAdd.visible := app.isSpecial();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmToolbar.priorityRight := true;
	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.tblAttributes.readOnly := true;
		self.tblAttributes.userInputEnabled := false;
		self.tblAttributes.selectMode := Table.SelectMode_None;
		self.btnSaveBase.enabled := false;
	endif;

	self.btnPriority.enabled := app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE(), PmAdmDrawAttrPriorityMaint) or app.getMyUser.canDo(app.getMyTerminalDO_NOT_USE(), PmAdmDrawAttrPriorityView);	//14/12/17 MAP TFS7493
end;</source>
    </JadeMethod>
