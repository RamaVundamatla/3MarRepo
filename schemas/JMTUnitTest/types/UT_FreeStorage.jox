    <JadeMethod name="setupStorageConfig2" id="b8a506e6-6912-4cc4-a238-93452ca85398">
        <source>setupStorageConfig2(_calendar : CM_Calendar; _includeFirstDay : Boolean; _includeLastDay : Boolean; _shipReceivalType : Integer; _shipReleaseType : Integer; _chargedDaysWorking : Boolean;
					_freeDaysWorking : Boolean; _deriveDebtorFrom : CM_DebtorType; _triggers : CM_StorageTriggerByType; _createDetails : Boolean; _importDays : Integer; _exportDays : Integer;
					_stopCompletionFreeDays : Integer) : CM_StorageConfig protected;		// TFS 2570
// cnwjre1 CCMS 1295 free storage days
//  storage configuration with entered options, hard-coded calendar and criteria (cargo type and imex), entered import and export days free storage
vars
	storageConfig	: CM_StorageConfig;
	storageDetail	: CM_StorageDetail;
	criteriaTypes : CM_YACriteriaTypeArray;
	firstDayTimeCutoff	: Time;
	lastDayTimeCutoff	: Time;
	nullTime		: Time;
	criteria	: IntegerArray;
	values		: ObjectArray;

begin
	self.deleteStorageConfig( false );
	
	// set up the storage config
	nullTime := "00:00".Time;
	firstDayTimeCutoff := nullTime;
	lastDayTimeCutoff := nullTime;
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus]);

	storageConfig := self.createStorageConfig(criteriaTypes, _triggers, _deriveDebtorFrom, firstDayTimeCutoff, _includeFirstDay, _includeLastDay,
											  lastDayTimeCutoff, _shipReceivalType, _shipReleaseType, _calendar, null,null, -1, -1, -1);

	if not _createDetails then
		return storageConfig;
	endif;

	create criteria transient;
	criteria.add(YACriteriaType_CargoType);
	criteria.add(YACriteriaType_ImexStatus);
	create values transient;
	values.add(self.getCargoType("CONT"));
	values.add(app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT]);

	storageDetail := self.addStorageDetail(storageConfig, "CONT Import", criteria, values, _importDays, 0, _chargedDaysWorking, _freeDaysWorking, _stopCompletionFreeDays,0,false,null);		// TFS 2570   //21.07.2017 cnwma1 TFS #5409
	values.clear();
	values.add(self.getCargoType("CONT"));
	values.add(app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT]);

	storageDetail := self.addStorageDetail(storageConfig, "CONT Export", criteria, values, _exportDays, 0, _chargedDaysWorking, _freeDaysWorking, _stopCompletionFreeDays,0,false,null);		// TFS 2570 //21.07.2017 cnwma1 TFS #5409

	return storageConfig;
epilog
	
	delete criteriaTypes;
	delete criteria;
	delete values;

end;
</source>
