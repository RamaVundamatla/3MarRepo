    <JadeMethod name="updateMethodInputs" id="dc403334-9bf8-4c4d-8fff-3c016e8e6b03">
        <source>updateMethodInputs() protected;
/*

Purpose:			Parses the method signature and returns just the inputs

Parameters:			

Return Value:		

Date			Who		Reason
13 May 2019		jlgmd1	Initial creation TFS 39667 - JMT - API Documentation

*/

constants
	BlankSpace : String = " " &amp; Tab &amp; Cr &amp; Lf &amp; CrLf;
vars
	idx,
	tmpIdx	: Integer;
	param,
	class	: String;
	params	: HugeStringArray;
	feat	: DEV_REOWsdlFeature;
	
begin
	// something(a, b : String; c : Integer input; d : StringArray output) : Boolean;
	// something() : WS_Response;
	// updateOrAddWagon(request : WS_WagonAddOrUpdRequest) : WS_WagonAddOrUpdResponse updating, webService;
	//																						  ^ &lt;-- this!
	
	if self.signature = null then
		return;
	endif;
	
	idx := self.signature.pos("(", 1) + 1;
	
	while idx &lt; self.signature.length do
		
		// Read until the next ';'
		param := self.signature.scanUntil(";", idx);
		if param = null then
			// This is probably just a space at the end of the signature
			idx := idx + 1;
			continue;
		endif;
		
		// Work out the clas
		tmpIdx := param.pos(")",1);
		if tmpIdx &gt; 0 then
			tmpIdx := param.length - tmpIdx + 1;
		else
			tmpIdx := 1;
		endif;
		class := param.reverse.scanUntil(":", tmpIdx).reverse;
		
		// If class is invalid, then that hopefully means we don't have any inputs
		if class = ")" then
			// No inputs, nothing to do
			return;
		endif;
		
		// Ignoring anything after it
		tmpIdx := 1;
		class.scanWhile(" ", tmpIdx);
		class := class.scanUntil(")"&amp;BlankSpace, tmpIdx);
		
		// Handle signatures with commas after the return type
		tmpIdx := 1;
		param := param.scanUntil(")", tmpIdx);
		
		// Split multiple parameters
		if param.pos(",", 1) &gt; 0 then
			create params transient;
			param.getTokensForDelimiterHuge(",", params);
			
			foreach param in params do
				tmpIdx := 1;
				param := param.scanUntil(":", tmpIdx);
				tmpIdx := 1;
				param.scanWhile(BlankSpace, tmpIdx);
				param := param.scanUntil(BlankSpace, tmpIdx);
				create feat transient;
				feat.setForProperty(param, class, self);
			endforeach;
		
			delete params;	
		else
			tmpIdx := 1;
			param := param.scanUntil(":", tmpIdx);
			tmpIdx := 1;
			param.scanWhile(BlankSpace, tmpIdx);
			param := param.scanUntil(BlankSpace, tmpIdx);
			create feat transient;
			feat.setForProperty(param, class, self);
		endif;
	
	endwhile;
	
epilog
	delete params;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
