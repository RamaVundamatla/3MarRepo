    <JadeMethod name="setupForm" id="7329db78-4a18-4a83-acbe-e789526ef967">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     09 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	
	self.createMyAssistant(CMUI_Assistant);
	
	self.doEnableOptions;
	
	self.myAssistant.comboBoxTerminalArea_GateArea (cmbPGate_In, CM_GateArea.AreaType_P);
	self.myAssistant.comboBoxTerminalArea_GateArea (cmbPGate_Out, CM_GateArea.AreaType_P);
	self.myAssistant.comboBoxTerminalArea_GateArea (cmbTrouble_In, CM_GateArea.AreaType_T);
	self.myAssistant.comboBoxTerminalArea_GateArea (cmbTrouble_Out, CM_GateArea.AreaType_T);

	self.modalResult := IDCANCEL;	// incase they close using close button
	
	btnOk.zOrder(1);
	btnCancel.zOrder (1);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="837011eb-902d-4f0f-bec7-ca2b9900dd54">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0011681, locale);
	chkDualGate.translateCaption(Xlat_0011682, locale);
	chkIn.translateCaption(Xlat_0011683, locale);
	chkOut.translateCaption(Xlat_0011684, locale);
	chkPGate_In.translateCaption(Xlat_0011685, locale);
	chkPGate_Out.translateCaption(Xlat_0011686, locale);
	chkTrouble_In.translateCaption(Xlat_0011687, locale);
	chkTrouble_Out.translateCaption(Xlat_0011688, locale);
	grpIn.translateCaption(Xlat_0011689, locale);
	grpOut.translateCaption(Xlat_0011690, locale);
	lblID.translateCaption(Xlat_0011691, locale);
	lblID_InP.translateCaption(Xlat_0011692, locale);
	lblID_InT.translateCaption(Xlat_0011693, locale);
	lblID_OutP.translateCaption(Xlat_0011694, locale);
	lblID_OutT.translateCaption(Xlat_0011695, locale);
	lblName.translateCaption(Xlat_0011696, locale);
	optPNew_In.translateCaption(Xlat_0011697, locale);
	optPNew_Out.translateCaption(Xlat_0011698, locale);
	optPSame_Out.translateCaption(Xlat_0011699, locale);
	optPSelect_In.translateCaption(Xlat_0011700, locale);
	optPSelect_Out.translateCaption(Xlat_0011701, locale);
	optTNew_In.translateCaption(Xlat_0011702, locale);
	optTNew_Out.translateCaption(Xlat_0011703, locale);
	optTSame_Out.translateCaption(Xlat_0011704, locale);
	optTSelect_In.translateCaption(Xlat_0011705, locale);
	optTSelect_Out.translateCaption(Xlat_0011706, locale);
end;</source>
    </JadeMethod>
</GUIClass>
