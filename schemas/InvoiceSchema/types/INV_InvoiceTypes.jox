    <JadeMethod name="addObjectToTable" id="f49567ef-7e50-49a3-9b48-fce59f13cee4">
        <updating/>
        <source>addObjectToTable(_obj: Object; _numItems: Integer io; _breakOut: Boolean io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2015	cnwmc5	Initial creation	PAR 35858

*/

vars

begin
	if not _obj.isKindOf(CM_InvoiceDesc) then
		return;
	endif;
	
	if _obj.CM_InvoiceDesc.company &lt;&gt; null
	and not _obj.CM_InvoiceDesc.company.terminal = self.myTerminal then
		return;
	endif;
	
	inheritMethod(_obj, _numItems, _breakOut);

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTable" id="a305d459-61fe-4874-898d-a91cc2e1dfec">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aInvoiceDesc : CM_InvoiceDesc;
	theInvoiceDescs :	CM_InvoiceTypeByNumber;
	tmpPassport	: CM_Passport;
	breakOut	: Boolean;
begin

	self.setMyDataClass();
	// 35872 do change of business unit
	self.myCurrentBank := self.cmbBank.listObject.CM_Bank;
	if self.myCurrentBank = null then
		return;
	endif;
//	TFS 2682	self.caption := self.myCurrentBank.code &amp; " Invoice Types";
	self.setCaption("Invoice Types " &amp; self.myCurrentBank.code);

	theInvoiceDescs := self.myCurrentBank.invoiceTypes;
	tmpPassport := app.myPassport;
	
	// do need to show all types to maintain the 'not available for entry' option
	foreach aInvoiceDesc in theInvoiceDescs do
		if self.includeObject(aInvoiceDesc, tmpPassport) then
			self.addObjectToTable(aInvoiceDesc, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="97f84f01-cbf4-4c97-a338-593abe182aef">
        <source>addToolbarControls() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2018	jlgndl1	Initial creation

*/

vars
	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;

begin
	inheritMethod();

	toolbar := self.frmToolbar;
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSurcharge, CMUI_Toolbar.Control_Alignment_Left);
/*	//05/06/2024	navkc1 CR 63736 Task 63770 - Relaced with new control
	// ### TFS 51912 14Sep2021 NAVPW1
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left); 				
	toolbar.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left);
	
	// ### TFS 51912 14Sep2021 NAVPW1
	self.txtFilterBox.parent := self.frmFilter;
	self.txtFilterBox.visible := true;
	self.txtFilterBox.left := 0;
	self.txtFilterBox.top := 2;

	// ### TFS 51912 14Sep2021 NAVPW1
	toolbar.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left);
*/
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left); 					//05/06/2024	navkc1 CR 63736 Task 63770
	toolbar.addFrame(self.frmTableFilter, CMUI_Toolbar.Control_Alignment_Left);		//05/06/2024	navkc1 CR 63736 Task 63770
	
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnSurcharge_click" id="d43018d3-b69a-4382-ae57-b7f373f09df1">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSurcharge_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2018	jlgndl1	Initial creation`	TFS 37818

*/

vars

	form : INV_InvTypeSurchargeExemptions;
	
begin

	//19 Jun 2018	NDL	TFS 39296
	if self.myCurrentObject = null then
		app.msgBox(app.getErrorString(Must_select_invoice_type), app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;

	form := app.loadForm(INV_InvTypeSurchargeExemptions, INV_Assistant, false, false, false, self.myTerminal, null).INV_InvTypeSurchargeExemptions;
	if form = null then
		return;
	endif;
	form.setMyInvoiceType( self.myCurrentObject.CM_InvoiceDesc );
	form.show();
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clearFilter" id="6dd32bf6-00a0-47a6-9374-bb486b138410">
        <updating/>
        <source>clearFilter() updating;
/*

Purpose:			Clears the filter text box

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
14 September 2021	navpw1	Initial creation TFS: 51912

*/

begin
	inheritMethod();
	
	//if(self.txtFilterBox.text = "") then
	if self.frmTableFilter.txtFilterBox.text = "" then //25/06/2024	navkc1 CR 64823 Task 64824
		//self.btnClearFilter.enabled := false;
		self.frmTableFilter.btnClearFilter.enabled := false;
		self.zTblDataSortAndShow(true);
	endif;
	
	self.tblData.topRow := 1;
	
end;</source>
    </JadeMethod>
