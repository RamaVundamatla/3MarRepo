/*
Purpose:	When the user resizes a column we save the XML for the table

Date		Who		Reason
04 Mar 2013	cnwcs5	Initial Creation - par 31087 
*/
vars

begin
	if _table.myEntTableDef = null then
		// this can happen for tblEDITI
		return;
	endif;
	
	self.zSetXMLStrForTblColumns(_table, true, self.xmlStrTblEDITI);		// par 31087
epilog

