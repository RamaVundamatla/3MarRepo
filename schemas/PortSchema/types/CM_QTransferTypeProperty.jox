<Class name="CM_QTransferTypeProperty" id="3b0677cf-bc7d-4600-aac3-e45fc80e242e">
    <superclass name="CM_QIntegerLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="50aa679f-b1f1-4529-ab6e-ee3fe3f8f87f">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QIntegerLookupEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
