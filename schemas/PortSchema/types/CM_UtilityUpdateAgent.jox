    <JadeMethod name="utlUpdateDetach" id="8ccdc0c7-8761-42fa-ae2a-b59b4efc2131">
        <updating/>
        <source>utlUpdateDetach(_theConnectParams : CMIF_ConnectParams io; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		The proxy TI is stored in the connect Parameters
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realTrackedItem,aProxyTI :CM_TrackedItem;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();
	
	aProxyTI := _theConnectParams.myTrackedItem;
	
	aProxyTI.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	aProxyTI.pxyGetRealObjectAndEdition(realTrackedItem, expectedEdition);
	
	if realTrackedItem = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return;
	endif;
	app.myValUA.valDetach(realTrackedItem, _theConnectParams);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realTrackedItem);

	if _passport.noErrors and realTrackedItem.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'realTrackedItem', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTrackedItem, true);
	endif;
	if _passport.noErrors then
		_theConnectParams.myTrackedItem := realTrackedItem;
		realTrackedItem.setForDetach(_theConnectParams, _passport);
		// redraw the TI Graphics on screen
		if _passport.noErrors then
			global.causeEvent(_theConnectParams.myTerminal.getTerminalEvent(TIEvent_Connect) ,false, realTrackedItem);	
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTrackedItem, false);
	endif;

end;</source>
        <Parameter name="_theConnectParams" type="CMIF_ConnectParams" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
