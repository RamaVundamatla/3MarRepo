    <JadeMethod name="windowCreated" id="7920ea71-8a11-4025-bceb-71b19ae74b91">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: CMUI_PhotoThumbnailFrame input; persistCntrl: Control) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	#cnwdz2	 par21808

*/

vars

begin
	inheritMethod(cntrl, persistCntrl);

	if (self.isInPainter) then
		return;
	endif;

	// These MUST be called in the following order
	cntrl.createScrollableFrame();
	cntrl.createScrollingFrame();
	
	self.myScrollableFrame.setScrollingFrame(myScrollingFrame);
	self.myScrollableFrame.hideVScroll();
	self.myScrollableFrame.hideHLabels();
	self.myScrollableFrame.hideVLabels();
	
	self.myScrollableFrame.changeBackColor(self.backColor);

	self.bevelInner := Frame.Bevel_None;
	self.bevelOuter := Frame.Bevel_None;
	self.borderStyle := Frame.BorderStyle_None;
	self.boundaryWidth := 0;
epilog

end;</source>
        <Parameter name="cntrl" type="CMUI_PhotoThumbnailFrame" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
