<Class name="CMIF_TrxActionHSCode" id="63460c2c-5393-4784-841e-10ab506c4bd2">
    <superclass name="CMIF_TrxPostAction"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="hsCode" id="4ed1282b-1589-4e56-8484-c8c6e3af4390">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="action" id="aa47f582-42c5-4759-a89c-20e5769e1f33">
        <updating/>
        <source>action(_passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 January 2023		jlier1	Initial creation 55788
04 July 2024		jlizm1	TFS 64736 HS Code edi allow invalid codes

*/

vars
	pxyHS,
	realHS,
	harmonizedSystem : CM_HarmonizedSystem;
	passport: CM_Passport;
	hsCodeLength : Integer;
begin
	if self.hsCode.trimBlanks = null then
		return;
	endif;
	if app.myRoot.allHSCodesActive[self.hsCode] &lt;&gt; null then
		return;
	endif;
	
	harmonizedSystem := app.myRoot.getHarmonizedSystem(self.hsCode);
	passport := _passport;
	passport.setWarningsIgnored(true);
	passport.setWarningsAcknowledged(true);
	
	if harmonizedSystem = null then
		//create it
		
		hsCodeLength:=self.hsCode.trimBlanks.length;
		if hsCodeLength = 2 then
			create pxyHS as CM_HSCodeChapter transient;
		elseif hsCodeLength = 4 then
			create pxyHS as CM_HSCodeHeading transient;
		elseif hsCodeLength = 6 then
			create pxyHS as CM_HSCodeCode transient;
		//elseif hsCodeLength &gt; 6 then
		elseif hsCodeLength = 8 then //26/02/2023	navkc1 CR 59577 Task 62410
			create pxyHS as CM_HSCodeSubCode transient;
		elseif hsCodeLength &gt; 8 then
			create pxyHS as CM_HSCodeTaric transient;
		else
			// is an invalid code, don't create anything
			return;
		endif;
		pxyHS.setProxy(self.hsCode,"Other",true,false,null);
		app.myTrxCA.trxCreateHarmonizedSystem(pxyHS,realHS,passport);
	else
		//update it to active
		beginLoad;
		pxyHS:=harmonizedSystem.pxyCreateUpdateProxy();
		endLoad;
		pxyHS.setIsActive(true);
		
		app.myTrxUA.trxUpdateHarmonizedSystem(pxyHS,passport);
	endif;
		
	passport.clearErrorsWarnings;
	passport.initialiseTransaction;
	passport.finaliseTransaction(TRXStatus_Committed);
	
epilog
	endLoad;
	delete pxyHS;
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="createAction" id="bafd15d0-97ce-49a9-9d9f-7317aed01459">
        <options>4</options>
        <source>createAction(_hsCode : String; _passport : CM_Passport input) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2023	jlier1	Initial creation 55788

*/

vars
	
	trxPA					: CMIF_TrxPostAction;
	hsCodeTrxAction		: CMIF_TrxActionHSCode; 
	harmonizedSystem : CM_HarmonizedSystem;
begin
	if (_hsCode = null)  then
		return;
	endif;
	
	harmonizedSystem:= app.myRoot.getHarmonizedSystem(_hsCode);
	if harmonizedSystem &lt;&gt; null and harmonizedSystem.isActive then
		return;
	endif;
	
	foreach trxPA in _passport.allTrxPostActions where trxPA.isKindOf(CMIF_TrxActionHSCode) do
		if trxPA.CMIF_TrxActionHSCode.hsCode = _hsCode then 
			return;
		endif;
	endforeach;
		
	create hsCodeTrxAction transient;
	hsCodeTrxAction.hsCode := _hsCode;
	
	_passport.addTrxPostAction(hsCodeTrxAction);

epilog

end;</source>
        <Parameter name="_hsCode" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
