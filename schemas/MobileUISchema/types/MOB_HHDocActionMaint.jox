		self.removeSelected(itemSelected);
		self.updated := true;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="ec5b5a6f-e88b-40fd-a4d0-43bf73eeefbf">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2016	cnwndl1	Initial creation	TFS 2918 / 2419

*/

vars

	cTop : Real;
	cLeft : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	tabIndex : Integer;
	frameHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cLeft := self.resizedMargin;
	cWidth := stdWidth;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	cWidth := ( stdWidth / 2 ) - self.resizedMargin;
	if _initialSetup then
		self.optStop.setAndIncrementTabIndex( tabIndex );
		self.optStop.visible := true;
		self.optStop.enabled := true;
	endif;
	self.optStop.move(	cLeft,
						cTop,
						cWidth,
						cHeight );
						
						
	cLeft := self.optStop.left + self.optStop.width + self.resizedMargin;
	if _initialSetup then
		self.optTask.setAndIncrementTabIndex( tabIndex );
		self.optTask.visible := true;
		self.optTask.enabled := true;
	endif;
	self.optTask.move(	cLeft,
						cTop,
						cWidth,
						cHeight );
	
	cTop := self.optStop.top + self.optStop.height + self.resizedMargin;
	cLeft := 0;
	frameHeight := (self.clientHeight - cTop - self.getCMDButtonsHeight() - ( self.resizedMargin * 2 ) );
	if _initialSetup then
		self.frmMain.setAndIncrementTabIndex( tabIndex );
		self.frmMain.visible := true;
		self.frmMain.enabled := true;
	endif;
	self.frmMain.move(	cLeft,
						cTop,
						self.clientWidth,
						frameHeight );
	
	cTop := 1;
	//07 Dec 2016	NDL	TFS 3089
	cWidth := self.frmMain.width - ( self.getSearchButtonSpace() * 2.5 ) - (self.resizedMargin * 3);
	cHeight := stdHeight;
	if _initialSetup then
		self.txtFilter.setAndIncrementTabIndex( tabIndex );
		self.txtFilter.visible := true;
		self.txtFilter.parent := self.frmMain;
	endif;
	
	self.txtFilter.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := ( self.getSearchButtonSpace() * 2.5 );
	if _initialSetup then
		self.btnFilter.setAndIncrementTabIndex( tabIndex );
		self.btnFilter.visible := true;
		self.btnFilter.parent := self.frmMain;
	endif;
	self.btnFilter.move(	self.txtFilter.left + self.txtFilter.width + self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
	
	
	cTop := cTop + self.txtFilter.height + self.resizedMargin;
	cLeft := self.resizedMargin;
	cWidth := (( self.frmMain.width - self.resizedMargin ) / 3 ) - self.resizedMargin;
	cHeight := self.frmMain.height - cTop - self.resizedMargin;
	
	if _initialSetup then
		self.tblAvail.setAndIncrementTabIndex( tabIndex );
		self.tblAvail.visible := true;
		self.tblAvail.parent := self.frmMain;
	endif;
	self.tblAvail.move(	cLeft,
						cTop,
						cWidth,
						cHeight );
						
	cLeft := self.tblAvail.left + self.tblAvail.width + self.resizedMargin;
	cWidth := self.frmMain.width - self.tblAvail.width - ( self.resizedMargin * 3 );
	cHeight := self.tblAvail.height - self.getCMDButtonsHeight() - self.resizedMargin;
	if _initialSetup then
		self.tblSelect.setAndIncrementTabIndex( tabIndex );
		self.tblSelect.visible := true;
		self.tblSelect.parent := self.frmMain;
	endif;
	self.tblSelect.move(	cLeft,
							cTop,
							cWidth,
							cHeight );
	
	cTop := self.tblSelect.top + self.tblSelect.height + self.resizedMargin;
	cWidth := ( self.tblSelect.width - self.resizedMargin ) / 2;
	cHeight := self.getCMDButtonsHeight();
	if _initialSetup then
		self.btnAdd.setAndIncrementTabIndex( tabIndex );
		self.btnAdd.visible := true;
		self.btnAdd.parent := self.frmMain;
	endif;
	self.btnAdd.move(	cLeft,
						cTop,
						cWidth,
						cHeight );
						
	cLeft := self.btnAdd.left + self.btnAdd.width + self.resizedMargin;
	if _initialSetup then
		self.btnRemove.setAndIncrementTabIndex( tabIndex );
		self.btnRemove.visible := true;
		self.btnRemove.parent := self.frmMain;
	endif;
	self.btnRemove.move(	cLeft,
							cTop,
							cWidth,
							cHeight );
	
	if self.tblAvail.columns &gt; 0 then
		self.tblAvail.cnAdjustColumnWidths;
	endif;
	
	if self.tblSelect.columns &gt; 0 then
		self.tblSelect.cnAdjustColumnWidths;
	endif;
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="d6d16ceb-c3f6-4155-9654-2175b7f6075a">
        <updating/>
        <source>doSave():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2016	cnwndl1	Initial creation	TFS 2918 / 2419
23/07/2019 	JLGNS1	Bug 45588: PNL - To Do Task Description no Planning / Queueing when To Do Task Terminals setup

*/

vars

	pxyBooking : CM_BookingRef;
	pxyBookRefItem : CM_BookingRefItem;
	pxyBulkRelease : CM_BulkRelease;
	pxyResDet : CM_ReserveDetail;
	pxyDocAct : CM_DocumentActions;
	load : Boolean;
	result : Integer;
	msg : String;
	stopSet : ObjectSet; 
	taskArray : ObjectArray;
	remarkArray : HugeStringArray;
	rowIndex : Integer;
	
begin

	if self.myBookingRefItem &lt;&gt; null then
		app.cmsBeginLoad(load);
		pxyBooking := app.createUpdateProxy( self.myBookingRefItem.myBookingReference ).CM_BookingRef;
		app.cmsEndLoad(load);
		
		pxyBookRefItem := self.myBookingRefItem.pxyGetProxyObject;
		if pxyBookRefItem = null then
			msg := "Proxy Booking Ref not created!";
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only);
			return false;
		endif;
		
		if self.myDocumentAction &lt;&gt; null then
			pxyDocAct := pxyBookRefItem.myBookingRefItemActions;
		else
			create pxyDocAct as CM_BookingItemActions transient;
			pxyDocAct.CM_BookingItemActions.setMyBookingRefItem( pxyBookRefItem );
		endif;
		
	elseif self.myReserveDetail &lt;&gt; null then
		app.cmsBeginLoad(load);
		pxyBulkRelease := app.createUpdateProxy( self.myReserveDetail.myReserveHeader ).CM_BulkRelease;
		app.cmsEndLoad(load);
		
		pxyResDet := self.myReserveDetail.pxyGetProxyObject;
		if pxyResDet = null then
			msg := "Proxy Reserve Detail not created!";
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only);
			return false;
		endif;
		
		if self.myDocumentAction &lt;&gt; null then
			pxyDocAct := pxyResDet.myReserveDetailActions;
		else
			create pxyDocAct as CM_ReserveDetailActions transient;
			pxyDocAct.CM_ReserveDetailActions.setMyReserveDetail( pxyResDet );
		endif;
	
	endif;
	
	if pxyDocAct = null then
		msg := "Proxy Document Action not created!";
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	on Exception do self.handleInUseEx(exception,myDocumentAction  );//Bug 45588
	
	if self.optStop.value then
		create stopSet transient;
		if self.tblSelect.rows &gt; 1 then
			foreach rowIndex in 2 to self.tblSelect.rows do
				stopSet.add( self.tblSelect.accessRow(rowIndex).itemObject );
			endforeach;
		endif;
		pxyDocAct.setStopTablesToAdd( stopSet );
	elseif self.optTask.value then
		create taskArray transient;
		create remarkArray transient;
		if self.tblSelect.rows &gt; 1 then
			foreach rowIndex in 2 to self.tblSelect.rows do
				taskArray.add( self.tblSelect.accessRow(rowIndex).itemObject );
				remarkArray.add( self.tblSelect.accessCell(rowIndex,2).text );
			endforeach;
		endif;
		pxyDocAct.setTaskDescsToAdd( taskArray, remarkArray );
	endif;
	
	while true do
		if self.myBookingRefItem &lt;&gt; null then
			app.myTrxUA.trxUpdateBookingBulkRel(pxyBooking, app.myPassport);
		
		elseif self.myReserveDetail &lt;&gt; null then
			app.myTrxUA.trxUpdateBulkRelease(pxyBulkRelease, null, app.myPassport);
	
		endif;
		
		if app.myPassport.trxCompletedOK then
			if self.myDocumentAction = null then
				if self.myBookingRefItem &lt;&gt; null then
					self.myDocumentAction := self.myBookingRefItem.myBookingRefItemActions;
				elseif self.myReserveDetail &lt;&gt; null then
					self.myDocumentAction := self.myReserveDetail.myReserveDetailActions;
				endif;
			endif;
			self.updated := false;
			return true;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Document_action), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	
	endwhile;
	
	return false;

epilog

	app.cmsEndLoad(load);
	
	delete pxyDocAct;
	delete pxyBookRefItem;
	delete pxyResDet;
	delete pxyBooking;
	delete pxyBulkRelease;
	
	delete stopSet;
	delete taskArray;
	delete remarkArray;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
