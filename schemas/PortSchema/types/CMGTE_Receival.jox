    <JadeMethod name="clearAmountWhenForceUserEntry" id="175e7c8d-1f9d-4332-b259-57acc3ba5815">
        <updating/>
        <source>clearAmountWhenForceUserEntry() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2016	cnwndl1	Initial creation	TFS 1738 / 1978
23 Oct  2018 jlgrh7 TFS #41058  FW: JMT issue export cargo gate registration
*/

vars

begin
	if self.myTrackedItem &lt;&gt; null then																																							//+TFS41058 Only apply for Bulk/Break Bulk Cargo Type
		if self.myTrackedItem.myCargoType.isBulk() or self.myTrackedItem.myCargoType.isBreakBulk()  then
			if self.myTerminal.getConfig(ForceUEMoveAmountAtGate).Boolean then
				self.totalQuantity := 0;
				self.volumeTotal := 0;
				self.weightTotal := 0;
			endif;
		endif;
	endif;

epilog

end;</source>
