    <JadeMethod name="getTemperatureValue" id="1f3d6d63-d473-40d5-a9a2-4abfdb1512a7">
        <source>getTemperatureValue() : Real;
/*
Purpose: Used for handheld screens where we want to display the last read temperature, but then enter a new
		 reading using the same text box. Therefore we don't want the °C at the end which is added using the
		 display methods above.
		 
Use the display methods for all other uses

Date		Who		Reason
26 January 2009	cnwcp2	Initial creation
*/

vars

begin
	return self.temperature;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
