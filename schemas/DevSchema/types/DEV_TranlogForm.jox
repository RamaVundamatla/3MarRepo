    <JadeMethod name="doClickOptions" id="2d86af5c-5597-4809-adaa-9858996859be">
        <source>doClickOptions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2021	navndl1	Initial creation	TFS 

*/

vars

	tranLogObj : DEV_TranLogObj;
	rowIndex : Integer;
	count : Integer;
	iter : Iterator;
	startTranLogObj : DEV_TranLogObj;
	
	gtrThan1Sec : Boolean;
	splitOff : Boolean;
	showAfter : Boolean;
	showAfterTime : Time;

begin

	splitOff := self.optSplit.value;
	gtrThan1Sec := self.optGTR1.value;
	showAfter := self.optStart.value;
	showAfterTime := self.txtAfterTime.getTime;
	if splitOff then
		self.lblFileDetails.caption := "Splitting out data between the times from " &amp; txtFileName.text &amp; " to a new file!";
		return;
	elseif gtrThan1Sec then
		self.lblFileDetails.caption := "Showing data lines that took longer than a second from " &amp; txtFileName.text;
	elseif showAfter then
		self.lblFileDetails.caption := "Showing data lines after " &amp; showAfterTime.String &amp; " from " &amp; txtFileName.text;
	else
		self.lblFileDetails.caption := "Showing first 32000 lines form " &amp; txtFileName.text;
	endif;

	app.mousePointer := Busy;
	
	if self.allTranLogs.isEmpty then
		return;
	endif;
	
	self.tblDetails.rows := 1;

	iter := self.allTranLogs.createIterator;
	if showAfter and showAfterTime.isValid then
		startTranLogObj := self.allTranLogs.getAtKeyGeq( self.allTranLogs.first.date, showAfterTime, null );
		if startTranLogObj &lt;&gt; null then
			iter.startAtObject( startTranLogObj );
		endif;
	endif;
	while iter.next( tranLogObj ) do
		if gtrThan1Sec then
			if tranLogObj.elapsedSecs &lt; 1 then
				continue;
			endif;
		endif;
		rowIndex := self.tblDetails.addItem( tranLogObj.getDetailLine );
		self.tblDetails.accessRow( rowIndex ).itemObject := tranLogObj;
		count := count + 1;
		if tranLogObj.elapsedSecs &gt; 5 then
			self.tblDetails.accessCell( rowIndex, 2 ).backColor := LightRed;
		endif;
	endwhile;
	
	self.tblDetails.doClearFilters( true );
	
	self.lblFileDetails.caption := count.String &amp; " lines displayed for " &amp; txtFileName.text;

epilog

	delete iter;
	app.mousePointer := Idle;

end;</source>
    </JadeMethod>
    <JadeMethod name="doFindFile" id="06b1103d-97d4-46d9-a898-a2e91eb9a00b">
        <source>doFindFile();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2021	navndl1	Initial creation	TFS 51346

*/

vars

	fileOpen : CMDFileOpen;
	fileName : String;
	

begin

	create fileOpen;
	fileOpen.fileName	:= fileName;
	fileOpen.initDir	:= "c:\temp";
	fileOpen.defaultExt	:= "*.csv";
	
	if fileOpen.open = 0 then
		fileName := fileOpen.fileName;
	endif;
	
	self.txtFileName.text := fileName;

epilog

	delete fileOpen;

end;</source>
    </JadeMethod>
    <JadeMethod name="doProcess" id="894db92a-c1e8-416c-8c46-ca9b8fab220d">
        <source>doProcess();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2021	navndl1	Initial creation	TFS 

*/

vars

	fileName : String;

	inFile : File;
	line : String;
	strArray : CnStringArray;
	timeString : String;
	
	tranLogObj : DEV_TranLogObj;
	
	splitOff : Boolean;
	startTime : Time;
	endTime : Time;	
	outFile : File;
	time : Time;

begin

	app.mousePointer := Busy;

	self.tblDetailsSetup();
	
	splitOff := self.optSplit.value;

	fileName := self.txtFileName.text.trimBlanks;
	if fileName = null then
		self.lblFileDetails.caption := "No file name entered";
		return;
	endif;
	
	create inFile transient;
	inFile.fileName := fileName;
	inFile.mode := File.Mode_Input;
	inFile.kind := File.Kind_Unknown_Text;
	
	if splitOff then
		if self.txtFromTime.getTime = null then
			self.lblFileDetails.caption := "From Time required";
			return;
		endif;
		if self.txtToTime.getTime = null then
			self.lblFileDetails.caption := "To Time required";
			return;
		endif;
		if self.txtFromTime.getTime &gt; self.txtToTime.getTime then
			self.lblFileDetails.caption := "From time after To time";
			return;
		endif;
		
		startTime := self.txtFromTime.getTime;
		endTime := self.txtToTime.getTime;
		create outFile transient;
		outFile.fileName := "C:\Temp" &amp; '/cn_tranlog_' &amp; startTime.format('hhmm') &amp; '_' &amp; endTime.format('hhmm') &amp; '.csv';
		outFile.mode := File.Mode_Output;
	endif;
	
	if inFile.tryOpen then
	
		if splitOff then
			if not outFile.tryOpen then
				self.lblFileDetails.caption := "Failed to open (split out file) " &amp; outFile.fileName;
				return;
			endif;
		endif;
	
		while not inFile.endOfFile() do
			line := inFile.readLine();
			if line.length &lt; 50 then
				continue;
			endif;
			timeString := line[10:6];
			if not timeString.isInteger then
				continue;
			endif;
			if splitOff then
				time.setTime( timeString[1:2].Integer, timeString[3:2].Integer, timeString[5:2].Integer, 0 );
				if time &lt; startTime then
					continue;
				endif;
				if time &gt; endTime then
					continue;
				endif;
				outFile.writeLine( line );
				continue;
			else
				create tranLogObj transient;
				tranLogObj.populateFromTranlogLine( line );
				self.allTranLogs.add( tranLogObj );	
			endif;
		endwhile; 
		inFile.close();
	else
		self.lblFileDetails.caption := "Failed to open " &amp; inFile.fileName;
		return;
	endif;
	
	
	self.doClickOptions();
	
/*	foreach tranLogObj in self.allTranLogs do
		if gtrThan1Sec then
			if tranLogObj.elapsedSecs &lt; 1 then
				continue;
			endif;
		endif;
		rowIndex := self.tblDetails.addItem( tranLogObj.getDetailLine );
		self.tblDetails.accessRow( rowIndex ).itemObject := tranLogObj;
		count := count + 1;
		if tranLogObj.elapsedSecs &gt; 5 then
			self.tblDetails.accessCell( rowIndex, 2 ).backColor := LightRed;
		endif;
	endforeach;
	
	self.tblDetails.doClearFilters( true );
	
	self.lblFileDetails.caption := count.String &amp; " lines displayed for " &amp; inFile.fileName; */

epilog

	delete strArray;
	delete inFile;
	app.mousePointer := Idle;

end;</source>
    </JadeMethod>
