    <JadeMethod name="utlCreateBackupHistory" id="c72230e5-a222-4cd5-8c1a-81b6a5a90b08">
        <source>utlCreateBackupHistory(_proxyBackupHistory:CM_BackupHistory; _newBackupHistory:CM_BackupHistory io; _myBackup: CM_Backup;
