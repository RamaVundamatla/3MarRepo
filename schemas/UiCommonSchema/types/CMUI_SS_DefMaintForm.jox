    <JadeMethod name="cmbMode_click" id="963ea456-5a9b-4861-a6dc-c2828432b058">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbMode_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation

*/

vars
	queryDefinition : CM_QueryDefinition;
begin
	self.loadData();
	// 26813 cnwjre1 May 2011 only enable 'Business Unit for charging' for appropriate modes
	queryDefinition := self.cmbMode.listObject.CM_QueryDefinition;
	if queryDefinition &lt;&gt; null then
		if queryDefinition.type = CM_QueryDefinition.TrackedItem_Query_Type then
			self.cmbBank.enabled := true;
		else
			self.cmbBank.listIndex := 1;
			self.cmbBank.enabled := false;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbMode_lostFocus" id="55dd9085-4e1b-4eff-b283-f71635fb3beb">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbMode_lostFocus(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Name	TFS#	Description
============================================================================
03 Dec 2009	cnwndl1	CCMS1023 Initial creation	
15 May 2019	jlgdi1	44612	Populate the combobox items based on the chosen snapshot mode
============================================================================
*/

vars
	queryDefinition : CM_QueryDefinition;
	
begin
	queryDefinition := self.cmbMode.listObject.CM_QueryDefinition;
	if queryDefinition = null then
		self.myProxyFormat.setModeAndType(0, 0);
	else
		self.myProxyFormat.setModeAndType(queryDefinition.mode, queryDefinition.type);
	endif;
	
	self.loadSelectorComboByMode(queryDefinition);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="002d3ec7-f00d-4931-9f6b-6f6c90128c27">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin

	self.permissionView  := PmAdmSSSumaryView;
	self.permissionMaint := PmAdmSSSumaryMaint;
	self.helpFileName := HelpFile_Voyage;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createMyProxyFormat" id="7bcb4dbe-313a-4db8-b8bf-dc772a558037">
        <updating/>
        <source>createMyProxyFormat( _realFormat : CM_OutputFormat_SS ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

	canSave : Boolean;
	modeString : String;
	
begin

	delete self.myProxyFormat;
	self.currentSSEdition	:= 0;
	
	canSave := app.myPassport.myUser.canDo(app.myPassport.myTerminal, self.permissionMaint);

	if _realFormat &lt;&gt; null then
		self.formMode := Mode_Update;
		self.cmbDefinition.listIndex := self.cmbDefinition.findObject(_realFormat);
		beginLoad;
		sharedLock( _realFormat );
		self.currentSSEdition	:= _realFormat.edition;
		self.myProxyFormat := _realFormat.cloneSelf( true );
		btnSSDefRem.enabled := true;
		if canSave and _realFormat.allSnapshotDatas.isEmpty then
			btnSave.enabled := true;
			modeString := app.getErrorString(UpdateUpper);
		else
			btnSave.enabled := false;
			modeString := app.getErrorString(BR_Status_View);
		endif;
		self.setCaption(app.getErrorString(Snap_shot_def_maint) &amp; " - " &amp; _realFormat.name &amp; " [" &amp; modeString &amp; "] ");
	else
		self.formMode := Mode_Add;
		modeString := app.getErrorString(AddUpper);
		self.cmbDefinition.listIndex := -1;
		create self.myProxyFormat transient;
		btnSSDefRem.enabled := false;
		btnSave.enabled := canSave;
		self.setCaption(app.getErrorString(Snap_shot_def_maint) &amp; " [" &amp; modeString &amp; "] ");
	endif;
	self.enableControls(btnSave.enabled);	// 26608 Dec 2010 snap shot definition form issues
	
	self.lblStatus.caption := self.getStatusCaption(_realFormat);
	
epilog

	endLoad;

end;</source>
        <Parameter name="_realFormat" type="CM_OutputFormat_SS"/>
    </JadeMethod>
    <JadeMethod name="displayAttributeName" id="7cab80e5-4e61-40a7-8fc1-00fd98fd9548">
        <source>displayAttributeName( _prop : CM_QueryProperty ) : String;
/*

Purpose:			called from mltAttributes to display each entry

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars
	attrName	: String;
	propName	: String;
	queryDefinition : CM_QueryDefinition;
begin
	queryDefinition := self.cmbMode.listObject.CM_QueryDefinition;
	if _prop &lt;&gt; null then
		propName := _prop.niceName;
	endif;
	attrName := app.getTerminologyAlternate( self.myCM_CargoBOLType, null, propName, CM_TermExpressionSingular, propName );
	// 26813 cnwjre1 May 2011 show attributes not suitable for use in invoice map with '*' suffix
	if _prop &lt;&gt; null and
	   queryDefinition &lt;&gt; null and
	   queryDefinition.type = CM_QueryDefinition.TrackedItem_Query_Type and
	   _prop.allocationAttribute = 0 then
		attrName := attrName &amp; " *";
	endif;
	return attrName;
end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doAddData" id="605f9519-118e-4ba4-93c6-7e2a90c515b0">
        <updating/>
        <source>doAddData() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

	
	propertyName : String;
	function : Integer; 
	label : String;
	field : CM_XTABField;
	
begin

	if cmbAttribute.listIndex &lt; 1 then
		app.msgBox(app.getErrorString(Please_select_attribute), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		cmbAttribute.setFocus();
		return;
	endif;
	
	if cmbFunction.listIndex &lt; 1 then
		app.msgBox(app.getErrorString(Please_select_function), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		cmbFunction.setFocus();
		return;
	endif;
	
	function := cmbFunction.itemData[ cmbFunction.listIndex ]; // I.e. CM_XTABField.Function_Sum;
	propertyName := self.cmbAttribute.itemObject[ cmbAttribute.listIndex ].CM_QueryProperty.propertyName;
	// 26608 Dec 2010 snap shot definition form issues - CM_XTABField heading is 30 chars
	label := txtLabel.text.trimBlanks[1:30];
	if label = null then
		label := cmbFunction.itemText[cmbFunction.listIndex] &amp; " (";
		if label.length + propertyName.length &lt; 30 then
			label := label &amp; propertyName &amp; ")";
		else
			label := label &amp; propertyName[1:29-label.length] &amp; ")";
		endif;
	endif;
	
	create field transient;
	field.setFunction( function );
	field.setPropertyName( propertyName );
	field.setHeading( label );
	
	self.myProxyFormat.allFields.add( field );
	
	self.populateTbldata();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="879d3359-ce70-412e-a40b-c610cd0d0845">
        <updating/>
        <source>doBaseFormSave() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars
	msg	: String;
	proxy : CM_OutputFormat_SS;
	bank  : CM_Bank;
	selected : CM_QueryPropertyDict;
	selProp : CM_QueryProperty;
	grouping : CM_XTABGrouping;
	result : Integer;
	newIndex : Integer;
	
begin

	proxy := self.myProxyFormat;

	create selected transient;
	self.mltAttributes.getSelected(selected);
	
	if txtName.text = null then
	//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, lblName.caption), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		app.msgBox(app.getErrorString1(Input_required_field_Required, lblName.caption), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon); // cnwdb2	PAR 35364
		txtName.setFocus();
		return;
	endif;
	
	if cmbMode.text = null then
	//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, lblMode.caption), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		app.msgBox(app.getErrorString1(Input_required_field_Required, lblMode.caption), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon); // cnwdb2	PAR 35364
		cmbMode.setFocus();
		return;
	endif;
	
	if cmbSelector.text = null then
	//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, lblSelector.caption), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		app.msgBox(app.getErrorString1(Input_required_field_Required, lblSelector.caption), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon); // cnwdb2	PAR 35364
		cmbSelector.setFocus();
		return;
	endif;
	
	if proxy.allFields.isEmpty then
		app.msgBox(app.getErrorString(Must_select_summar_attribute), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	if self.cmbBank.itemObject[ cmbBank.listIndex ] &lt;&gt; null then
		bank := self.cmbBank.itemObject[ cmbBank.listIndex ].CM_Bank;
	endif;
	proxy.setBank(bank);
	proxy.setSelector(self.cmbSelector.itemObject[ cmbSelector.listIndex ].CM_MenuUserQuery);
	proxy.allGroupings.clear();
	foreach selProp in selected do
		create grouping transient;
		grouping.setPropertyName( selProp.propertyName );
		proxy.allGroupings.add(grouping);
	endforeach;
	
	// 26813 cnwjre1 May 2011 warn if snap shot for charging but no invoicable attributes selected (warning, not error)
	if bank &lt;&gt; null and
	   not proxy.hasSnapShotProperties() then
		msg := app.getErrorString(Select_attrib_notapplic_invoic) &amp; CrLf &amp; app.getErrorString(DoYouWantToContinue);
		result := app.msgBox(msg, app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second);
		if result = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	while true do
		if self.formMode = Mode_Add then
			app.myTrxCA.trxCreateOutputFormatSS(proxy, self.myCM_OutputFormat_SS, app.myPassport);
		elseif self.formMode = Mode_Update then
			app.myTrxUA.trxUpdateOutputFormatSS(proxy, self.myCM_OutputFormat_SS, self.currentSSEdition, app.myPassport);
		endif;

		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		endif;
		
		if self.formMode = Mode_Add then
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
		endif;
		
		if app.myPassport.noErrors and result = IDOK then
			// there must have just been warnings that the user has acknownledged so.
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		return;
	endwhile;
	
	if self.formMode = Mode_Add then
		newIndex := self.cmbDefinition.addItem(self.myCM_OutputFormat_SS.name);
		self.cmbDefinition.itemObject[newIndex] := self.myCM_OutputFormat_SS;
		self.cmbDefinition.listIndex := newIndex;
	endif;
	
	createMyProxyFormat( self.myCM_OutputFormat_SS );
	self.hasChanged := false;
	self.resetFirstChange();
	
	return;

epilog

	delete selected;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteOutputFormatSS" id="97ed976e-353e-413c-b571-b7036e1e3eb8">
        <updating/>
        <source>doDeleteOutputFormatSS() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars
	index : Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	index := cmbDefinition.findObject( self.myCM_OutputFormat_SS );
	if index &lt; 1 then
		return;
	endif;
	if index &lt;&gt; cmbDefinition.listIndex then
		// belt and braces shouldn't be able to happen
		// the selected object isn't the current self.myCM_OutputFormat_SS ????
		return;
	endif;
	
	if not self.confirmDelete(	app.getErrorString( XTAB_SummaryDefinition ), self.myCM_OutputFormat_SS.name.display ) then
		return;
	endif;
	
	self.deleting := true;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteOutputFormat_SS(self.myCM_OutputFormat_SS, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.hasChanged := false;
			self.resetFirstChange();
			
			self.myCM_OutputFormat_SS := null;
			createMyProxyFormat( self.myCM_OutputFormat_SS );
			cmbDefinition.removeItem(index);
			cmbDefinition.listIndex := -1;
			cmbDefinition.click(cmbDefinition);
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog

	self.deleting := false;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOpenAutoScheduler" id="9111132b-d854-4b12-87e1-a6325cbbba47">
        <source>doOpenAutoScheduler() protected;

vars
	cls			: Class;
	scheduler	: CMUI_AutoSchedulerForm;
	task		: CM_AutoTaskSummarySnapShot;
begin
	cls := rootSchema.getSchema(SysOpsSchemaName).getClass("SOP_Assistant");
	scheduler := app.loadForm(CMUI_AutoSchedulerForm, cls, false, false, false, self.myTerminal, null).CMUI_AutoSchedulerForm;

	if scheduler = null then
		return;
	endif;

	scheduler.show;
	foreach task in CM_AutoTaskSummarySnapShot.instances do
		if task.mySSDefinition = self.myCM_OutputFormat_SS then
			break;
		endif;
	endforeach;
	scheduler.showForTask(task);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRemoveData" id="5df11813-da91-448a-9f09-a1c9ebbb0a35">
        <updating/>
        <source>doRemoveData() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars
	saveRow	: Integer;
	field : CM_XTABField;
	
begin

	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;

	field := self.tblData.accessRow(self.tblData.row).itemObject.CM_XTABField;
	
	if field = null then
		return;
	endif;
	
	saveRow := self.tblData.row;
	self.myProxyFormat.allFields.remove(field);
	delete field;

	self.populateTbldata();
	
	self.tblData.setFocus();
	if saveRow &lt;= self.tblData.rows then
		self.tblData.row := saveRow;	// 26608 Dec 2010 snap shot definition form issues
		self.tblData_click(self.tblData);	// to select this row
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="f0c35b40-f4c8-415d-8960-c3d9519242a6">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars
	topOfButtons : Real;
begin

	self.frmMain.width := self.width;
	self.frmMain.height := self.height;
	self.lblStatus.left := 1;
	self.lblStatus.width := self.width - 10;
	self.mltAttributes.width := self.width - 17;
	self.mltAttributes.cnEcResizeContents;
	self.grpData.width := self.mltAttributes.width;
	self.grpData.height := self.height - ( self.grpData.top + 70 );
	self.tblData.width := self.grpData.width - 10;
	self.tblData.height := self.grpData.height - ( self.tblData.top + 5 );
	
	topOfButtons := self.height - ( self.btnSave.height + 40 );
	self.btnSSDefNew.top := topOfButtons;
	self.btnSSDefRem.top := topOfButtons;
	self.btnSave.top := topOfButtons;
	self.btnCancel.top := topOfButtons;
	self.btnSSDefNew.left := 5;
	self.btnSSDefRem.left := self.btnSSDefNew.left + self.btnSSDefNew.width + 5;
	self.btnCancel.left := self.width - ( self.btnCancel.width + 20 );
	self.btnSave.left := self.btnCancel.left - ( self.btnSave.width + 5 );
	self.btnSSDefNew.zOrder(1);
	self.btnSSDefRem.zOrder(1);
	self.btnCancel.zOrder(1);
	self.btnSave.zOrder(1);		// 33245 btnSave zOrder wasn't being set - save button not visible at Ajman; unable to reproduce here so hoping this is the fix ...
	
	inheritMethod();
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="enableControls" id="e17cb362-8a1b-465c-bc21-a4a31fe171c8">
        <updating/>
        <source>enableControls(_enabled : Boolean) updating, protected;
// 26608 Dec 2010 snap shot definition form issues, enable/disable the controls as well as the Save button
vars
	queryDefinition	: CM_QueryDefinition;
begin
	self.txtName.enabled := _enabled;
	self.txtDescription.enabled := _enabled;
	self.cmbMode.enabled := _enabled;
	self.cmbSelector.enabled := _enabled;
	// 26813 cnwjre1 May 2011 only enable 'Business Unit for charging' for appropriate modes
	self.cmbBank.enabled := _enabled;
	queryDefinition := self.cmbMode.listObject.CM_QueryDefinition;
	if queryDefinition &lt;&gt; null then
		if queryDefinition.type = CM_QueryDefinition.TrackedItem_Query_Type then
			self.cmbBank.enabled := _enabled;
		else
			self.cmbBank.listIndex := 1;
			self.cmbBank.enabled := false;
		endif;
	endif;
	self.mltAttributes.readOnly := not _enabled;	// keep enabled so can scroll but don't allow any other activity
	self.btnAttrAdd.enabled := _enabled;
	self.tblData.enabled := _enabled;
end;
</source>
        <access>protected</access>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="firstChange" id="168cd276-34a5-4b36-b224-ab744e05fb39">
        <controlMethod name="Form::firstChange"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>firstChange(cntrl: Control input) updating;
// 26608 Dec 2010 snap shot definition form issues, do change detection
vars

begin
	if cntrl &lt;&gt; self.cmbDefinition then
		self.hasChanged := true;
	endif;
end;
</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getStatusCaption" id="c33d9bda-4bdd-4cef-8aa5-8256eabff03f">
        <source>getStatusCaption( _realFormat : CM_OutputFormat_SS ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 December 2009	cnwndl1	Initial creation

*/

vars
	status : String;
	update : Boolean;
begin
	if _realFormat = null then
		return null;
	else
		update := true;
		if _realFormat.allSnapshotDatas.isEmpty then
			status := "No current snap shot data.";
		else
			status := "Currently has " &amp; _realFormat.allSnapshotDatas.size.String &amp; " snap shot(s)";
			update := false;
		endif;
		status := status &amp; "   ";
		if _realFormat.allBGPSummarySnapshots.isEmpty then
			status := status &amp; "No current BGPs using this definition.";
		else
			status := status &amp; "Currently used by " &amp; _realFormat.allBGPSummarySnapshots.size.String &amp; " BGP(s)";
			update := false;
		endif;
		
		if not update then
			status := status &amp; "   ";
			status := status &amp; "Not updateable";
		endif;
		
		return status;
		
	endif;
	
	
epilog

end;</source>
        <Parameter name="_realFormat" type="CM_OutputFormat_SS"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypes" id="be1917e9-6b59-4eeb-bc02-6b7d74ab719c">
        <source>getTypes( 	_types	: IntegerArray io;
			_checkMode : Boolean output;
			_mode	: Integer output );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

	queryDefinition : CM_QueryDefinition;
	
begin

	_checkMode := false;
	_mode := 0;
	
	queryDefinition := self.myProxyFormat.getQueryDefinition;
	
	if queryDefinition = null or self.myCM_OutputFormat_SS = null then
		_types.add(CM_QueryDefinition.TrackedItem_Query_Type);
		_types.add(CM_QueryDefinition.BOL_Query_Type);
		_types.add(CM_QueryDefinition.BookRef_Query_Type);
		
	else
		if queryDefinition.isBookRefType then
			_types.add(CM_QueryDefinition.BookRef_Query_Type);
			_mode := CM_QueryDefinition.BookRef_Query_Mode;	// 1
			
		elseif queryDefinition.isBookRefItemType then
			_types.add(CM_QueryDefinition.BookRef_Query_Type);
			_checkMode := true;
			_mode := CM_QueryDefinition.BookRefItem_Query_Mode;	// 2
			
		else
			_types.add(CM_QueryDefinition.TrackedItem_Query_Type);
			_types.add(CM_QueryDefinition.BOL_Query_Type);
			
		endif;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_types" type="IntegerArray" usage="io"/>
        <Parameter name="_checkMode" type="Boolean" usage="output"/>
        <Parameter name="_mode" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleNotification" id="d4a054f3-9755-44fd-adae-2e26ff73a0fe">
        <updating/>
        <source>handleNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo : Any) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
04 December 2009	cnwndl1	Initial creation	CCMS 1023
Dec 2010 			cnwjre1 par 26608 snap shot definition form issues, add the selector notification
*/

vars

	formatSS : CM_OutputFormat_SS;
	selector : CM_MenuUserQuery;
	index : Integer;
	currentObject : Object;
	
begin

	if eventType = EVENT_SummaryTable_Update then
		if theObject.isKindOf( CM_OutputFormat_SS ) then
			formatSS := theObject.CM_OutputFormat_SS;
			index := cmbDefinition.findObject(formatSS);
			if index &lt; 1 then
				// this must be a new one.
				if cmbDefinition.listIndex &gt; 0 then
					//get the current one
					currentObject := cmbDefinition.listObject;
				endif;
				index := cmbDefinition.addItem(formatSS.name);
				cmbDefinition.itemObject[index] := formatSS;
				if currentObject &lt;&gt; null then
					//set back to the one we had selected.
					cmbDefinition.listIndex := cmbDefinition.findObject(currentObject);
				endif;
			endif;
		endif;
		
	elseif eventType = EVENT_SummaryTable_Delete then
		if theObject.isKindOf( CM_OutputFormat_SS ) then
			formatSS := theObject.CM_OutputFormat_SS;
			index := cmbDefinition.findObject(formatSS);
			if index &gt; 0 then
				// we have this one in our combo
				if formatSS &lt;&gt; self.myCM_OutputFormat_SS then
					// but it is not the one that is currently selected, get the current one
					cmbDefinition.itemEnabled[index] := false;	// just disable it at present.
				else
					// and its currently selected.
					if not self.deleting then
						// some one else has caused this
						app.msgBox( app.getErrorString1(Format_deleted_by_user, self.caption), app.getErrorString(Warning), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
					endif;
					cmbDefinition.removeItem(index);
					self.myCM_OutputFormat_SS := null;
					self.createMyProxyFormat(null);
					self.loadModeCombo();
					self.loadData();
				endif;
			endif;
		endif;
	
	// 26608 Dec 2010 snap shot definition form issues, update selector combo from selector add/update/delete (mainly add from here)
	elseif eventType = Event_Selector_Create then
		if userInfo.isKindOf( CM_MenuUserQuery ) then
			selector := userInfo.CM_MenuUserQuery;
			index := cmbSelector.findObject(selector);
			if index &lt; 1 then
				// this should be a new one.
				if cmbSelector.listIndex &gt; 0 then
					// get the current one
					currentObject := cmbSelector.listObject;
				endif;
				index := cmbSelector.addItem(selector.heading);
				cmbSelector.itemObject[index] := selector;
				if currentObject &lt;&gt; null then
					// set back to the one we had selected.
					cmbSelector.listIndex := cmbSelector.findObject(currentObject);
				endif;
			endif;
		endif;
	elseif eventType = Event_Selector_Update then
		if userInfo.isKindOf( CM_MenuUserQuery ) then
			selector := userInfo.CM_MenuUserQuery;
			index := cmbSelector.findObject(selector);
			if index &gt; 0 then
				// we have this one in our combo, refresh from the heading, in case it's changed
				cmbSelector.itemText[index] := selector.heading;
			endif;
		endif;
	elseif eventType = Event_Selector_Delete then
		if userInfo.isKindOf( CM_MenuUserQuery ) then
			selector := userInfo.CM_MenuUserQuery;
			index := cmbSelector.findObject(selector);
			if index &gt; 0 then
				// we have this one in our combo, remove it
				cmbSelector.removeItem(index);
			endif;
		endif;

	endif;
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initControls" id="b94542ac-95d6-4d3f-887e-8ab13761f5d2">
        <updating/>
        <source>initControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2009	cnwndl1	Initial creation

*/

vars
	heading	: String;
begin

	frmMain.left := 0;
	frmMain.top := 0;
	frmMain.borderStyle := 0;
	
	self.mltAttributes.userInputEnabled := true;
	self.mltAttributes.formDisplayEntryMethodName := CMUI_SS_DefMaintForm::displayAttributeName.name;
	self.mltAttributes.multiSelect := ListBox.MultiSelect_Extended;
	self.mltAttributes.myAvailableListBox.sorted := true;
	self.mltAttributes.setTabIndex();
	self.mltAttributes.myBaseForm := self;
	
	// 26813 cnwjre1 May 2011 show attributes which can be used in snap shot summary trans map
	heading := app.getErrorString(Heading_Summary_attributes) &amp; " (* " &amp; app.getErrorString(Not_applicable_invoicing) &amp; ")";
	self.mltAttributes.setupControl(	heading,	//_headingName : String; 
										null,	//_collection : Collection; 
										CMUI_SS_DefMaintForm::displayAttributeName.name	//_displayMethodName : String
										);
	self.mltAttributes.width := self.width - 17;									
	self.mltAttributes.cnEcResizeContents;
	
	self.tblData.setCellText(1,1, app.getErrorString(Heading_Label) &amp; Tab &amp; app.getErrorString(Heading_Attribute) &amp; Tab &amp; app.getErrorString(Interface_Function) );
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lblAttribute_click" id="68a5f655-428d-48fd-ba3a-88014946f797">
        <controlMethod name="Label::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lblAttribute_click(label: Label input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation

*/

vars

begin

	populateCmbFunction();
	
epilog

end;</source>
        <Parameter name="label" type="Label" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadData" id="3f74ac7e-34b5-4c48-9348-8e434c7f2440">
        <updating/>
        <source>loadData() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

	queryDefinition : CM_QueryDefinition;
	prop : CM_QueryProperty;
	coll : CM_QueryPropertyDict;
	bolType : CM_CargoBOLType;
	allGroupProps : CM_QueryPropertyArray;
	element : CM_XTABElement;
	
begin

	myCM_CargoBOLType := app.myRoot.getCargoBOLTypeForId( 0 );
	create coll transient;
	
	self.cmbSelector.listIndex := -1;
	if self.myProxyFormat &lt;&gt; null then
	
		self.txtName.text := self.myProxyFormat.name;
		self.txtDescription.text := self.myProxyFormat.description;
		if self.myProxyFormat.myBankToCharge &lt;&gt; null then
			self.cmbBank.listIndex := self.cmbBank.findObject( self.myProxyFormat.myBankToCharge );
		else
			self.cmbBank.listIndex := 1;		// null entry
		endif;
		if self.myProxyFormat.mySelectorQuery &lt;&gt; null then
			self.cmbSelector.listIndex := self.cmbSelector.findObject( self.myProxyFormat.mySelectorQuery );
		endif;
		
		if self.cmbMode.listIndex &gt; 0 then
			queryDefinition := self.cmbMode.listObject.CM_QueryDefinition;
		endif;	
		
		if queryDefinition &lt;&gt; null then
			myCM_CargoBOLType := app.myRoot.getCargoBOLTypeForId( queryDefinition.mode );
			foreach prop in queryDefinition.allQueryProperties do
				if not prop.canBeViewed( app.myPassport ) then
					continue;
				endif;
				coll.add( prop );
			endforeach;
			// 26813 cnwjre1 June 2011 only enable 'Business Unit for charging' for appropriate modes
			if queryDefinition.type = CM_QueryDefinition.TrackedItem_Query_Type then
				self.cmbBank.enabled := true;
			else
				self.cmbBank.listIndex := 1;
				self.cmbBank.enabled := false;
			endif;
		endif;
	
	endif;

	self.mltAttributes.setAvailable(coll, true); 

	if self.myProxyFormat &lt;&gt; null then
		create allGroupProps transient;
		myProxyFormat.getGroupingProperties( allGroupProps );
		self.mltAttributes.setSelected(allGroupProps);
	else
		self.mltAttributes.setSelected(null);
	endif;
	
	self.populateCmbAttribute();
	self.populateTbldata();

epilog

	delete coll;
	delete allGroupProps;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="5933a508-1909-4040-b982-a379df5ebd0b">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Name	TFS#	Description
============================================================================
02 Dec 2009	cnwndl1	CCMS1023 Initial creation	
15 May 2019	jlgdi1	44612	Populate the selecter combobox items based on the chosen snapshot mode
============================================================================
*/

vars
	aTerm : CM_Terminal;
	queryRoot	: CM_MenuRootQuery;
	format_SS : CM_OutputFormat;
	menuEntity	: CM_MenuEntity;
	def,
	co		 : CM_Bank;
	newIndex : Integer;
	queryDefinition : CM_QueryDefinition;
	
begin
	inheritMethod();
	
	self.cmbDefinition.clear();
	foreach format_SS in app.myRoot.allOutputFormats_SS do
		newIndex := self.cmbDefinition.addItem(format_SS.name);
		self.cmbDefinition.itemObject[newIndex] := format_SS;
	endforeach;
	
	if self.myCM_OutputFormat_SS &lt;&gt; null then
		self.cmbDefinition.listIndex := self.cmbDefinition.findObject( self.myCM_OutputFormat_SS );
	endif;
	
	btnSSDefRem.enabled := cmbDefinition.listObject &lt;&gt; null;
	
	if self.cmbSelector.listCount = 0 then
		queryDefinition := self.cmbMode.listObject.CM_QueryDefinition;
		loadSelectorComboByMode(queryDefinition);
	endif;
	
	// loadModeCombo is called before this and may have set up this combo
	if self.cmbBank.listCount = 0 then
		// add an empty entry, bank is optional
		self.cmbBank.itemObject[self.cmbBank.addItem(app.getErrorString(No_Charging))] := null;
		aTerm := self.myTerminal;
		//def := aTerm.getConfig(DefCompany).CM_Bank;
		def := aTerm.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393
		foreach co in aTerm.companies do
			if co.isBusinessUnit and not co.isSuspended then
				self.cmbBank.addItem(co.mailingName);
				self.cmbBank.itemObject[self.cmbBank.newIndex] := co;
			endif;
		endforeach;
		self.cmbBank.listIndex := self.cmbBank.findObject( def );
		if self.cmbBank.listIndex = -1 and self.cmbBank.listCount &gt; 0 then
			self.cmbBank.listIndex := 1;
		endif;
	endif;
	
	if app.myRoot.myQueryMenuRoot &lt;&gt; null then
		beginNotification(app.myRoot.myQueryMenuRoot, Event_Selector_Create, Response_Continuous, null);
		beginNotification(app.myRoot.myQueryMenuRoot, Event_Selector_Update, Response_Continuous, null);
		beginNotification(app.myRoot.myQueryMenuRoot, Event_Selector_Delete, Response_Continuous, null);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadModeCombo" id="e5a0016c-f565-4d00-a01d-9ad680729d5a">
        <source>loadModeCombo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Name	TFS#	Description
============================================================================
02 Dec 2009	cnwndl1	CCMS1023 Initial creation	
15 May 2019	jlgdi1	44612	Populate the selector combobox items based on the chosen snapshot mode
============================================================================
*/

vars
	coll		: CM_QueryDefinitionByModeDict;
	types		: IntegerArray;
	checkMode 	: Boolean;
	mode		: Integer;
	qDef		: CM_QueryDefinition;
	idx			: Integer;
	queryDefinition : CM_QueryDefinition;
	aTerm : CM_Terminal;
	queryRoot	: CM_MenuRootQuery;
	menuEntity	: CM_MenuEntity;
	def,
	co		 : CM_Bank;
	
begin
	self.cmbMode.clear();
	coll := app.myRoot.allQueryDefinitionObjects;
	
	create types transient;
	self.getTypes( types, checkMode, mode);
	
	foreach qDef in coll where types.includes( qDef.type ) and ( not qDef.isBookRefType() and not qDef.isBookRefItemType()) do
		if checkMode then
			if qDef.mode &lt;&gt; mode then
				continue;
			endif;
		endif;
		
		idx := self.cmbMode.addItem(qDef.modeDescription);
		self.cmbMode.itemObject[idx] := qDef;
	endforeach;
	
	if self.myCM_OutputFormat_SS &lt;&gt; null then
		queryDefinition := self.myCM_OutputFormat_SS.getQueryDefinition;
	endif;
	
	if queryDefinition &lt;&gt; null then
		self.cmbMode.listIndex := self.cmbMode.findObject( queryDefinition );	
	endif;
	
	if self.cmbSelector.listCount = 0 then
		loadSelectorComboByMode(queryDefinition);
	endif;
	
	if self.cmbBank.listCount = 0 then
		// add an empty entry, bank is optional
		self.cmbBank.itemObject[self.cmbBank.addItem(app.getErrorString(No_Charging))] := null;
		aTerm := self.myTerminal;
		//def := aTerm.getConfig(DefCompany).CM_Bank;
		def := aTerm.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393
		foreach co in aTerm.companies do
			if co.isBusinessUnit and not co.isSuspended then
				self.cmbBank.itemObject[self.cmbBank.addItem(co.mailingName)] := co;
			endif;
		endforeach;
		self.cmbBank.listIndex := self.cmbBank.findObject( def );
		if self.cmbBank.listIndex = -1 and self.cmbBank.listCount &gt; 0 then
			self.cmbBank.listIndex := 1;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadSelectorComboByMode" id="b8163272-3c2b-4753-b289-9419e8b6a685">
        <source>loadSelectorComboByMode(_queryDefinition : CM_QueryDefinition);
/*

Purpose: Load the saved queries (selector query) filtered by selected snapshot mode

Parameters:	Mode definition

Return Value: None

Date		Name	TFS#	Description
============================================================================
15 May 2019	jlgdi1	TFS 44612 Initial creation
============================================================================
*/

vars
	queryRoot : CM_MenuRootQuery;
	menuEntity : CM_MenuEntity;
	selectorQuery : CM_MenuUserQuery;
	
begin
	self.cmbSelector.clear();
	
	if _queryDefinition = null then
		return;
	endif;
	
	queryRoot := app.myRoot.myQueryMenuRoot;
	foreach menuEntity in queryRoot.allMenuUserItemsWithAMenuItem do
		selectorQuery := menuEntity.CM_MenuUserQuery;
		if selectorQuery.queryMode = _queryDefinition.mode then 
			self.cmbSelector.itemObject[self.cmbSelector.addItem(menuEntity.CM_MenuUserQuery.heading)] := menuEntity;
		endif;
	endforeach;
end;</source>
        <Parameter name="_queryDefinition" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="populateCmbAttribute" id="0fefd838-5e75-4293-a122-b3b761eec7d1">
        <updating/>
        <source>populateCmbAttribute() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation	CCMS 1023
15/02/2010			cnwcs5	ccms 22140 - new functions
*/

vars

	attrName : String;
	saveName	: String;
	prop : CM_QueryProperty;
	index : Integer;
	newIndex : Integer;
	
begin

	if cmbAttribute.listIndex &gt; 0 then
		saveName := cmbAttribute.text;
	endif;
	
	cmbAttribute.clear();
	
	foreach index in 1 to self.mltAttributes.myAvailableListBox.listCount do
		prop := mltAttributes.myAvailableListBox.itemObject[index].CM_QueryProperty;
		// 15/02/2010 cnwcs5 - if prop.isDecimalOrInteger then
		// include all properties not just numerics - count_false, count_null are non-numeric functions
		attrName := mltAttributes.myAvailableListBox.itemText[index];
		// 26813 strip the trailing asterisk - only want it in the attribute list, not the combo
		if attrName.length &gt; 2 and
		   attrName[attrName.length-1:end] = " *" then
			attrName := attrName[1:attrName.length-2];
		endif;
		newIndex := cmbAttribute.addItem( attrName );
		cmbAttribute.itemObject[newIndex] := prop;
		// 15/02/2010 cnwcs5 endif;
	endforeach;
	
	if saveName &lt;&gt; null then
		cmbAttribute.listIndex := cmbAttribute.findStringExact(1, saveName);
	endif;
	
	populateCmbFunction();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbFunction" id="d86384c5-f6b9-465d-825e-bc28e9c2cb3b">
        <source>populateCmbFunction()protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
02 December 2009	cnwndl1	Initial creation	CCMS 1023
12/02/2010	cnwcs5	par 22140 - New functions
*/
vars
	attrName : String;
	property : CM_QueryProperty;
	index : Integer;
begin
	if cmbFunction.listIndex &gt; 0 then
		attrName := cmbFunction.text;
	endif;

	cmbFunction.clear();
	
	if cmbAttribute.listIndex &gt; 0 then
		property := cmbAttribute.itemObject[cmbAttribute.listIndex].CM_QueryProperty;
	endif;
	
	if property &lt;&gt; null then
		self.myAssistant.loadXTABFunctionsForQueryProp (property, cmbFunction);	// 12/02/2010 cnwcs5 par 22140
	endif;
	
	if attrName &lt;&gt; null then
		cmbFunction.listIndex := cmbFunction.findStringExact(1,attrName);
	else
		cmbFunction.listIndex := cmbFunction.findStringExact(1, app.getErrorString( COUNT ) );
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTbldata" id="16f53610-9064-46eb-aa36-793ebb727c26">
        <source>populateTbldata();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation	CCNS 1023

*/

vars

	field : CM_XTABField;
	prop : CM_QueryProperty;
	
	attr : String;
	func : String;
	label : String;
	row : Integer;
	
begin

	self.txtLabel.text := null;
	self.cmbFunction.listIndex := -1;
	self.cmbAttribute.listIndex := -1;
	
	self.tblData.rows := self.tblData.fixedRows;
	
	foreach field in self.myProxyFormat.allFields do
		prop := field.getQueryProperty();
		attr := self.displayAttributeName( prop );
		// 26813 strip the trailing asterisk - only want it in the attribute list, not the table
		if attr.length &gt; 2 and
		   attr[attr.length-1:end] = " *" then
			attr := attr[1:attr.length-2];
		endif;
		func := field.getFunctionAsString;
		label := field.getHeading;
		
		row := self.tblData.addItem( label &amp; Tab &amp; attr &amp; Tab &amp; func );
		self.tblData.accessRow(row).itemObject := field;
	endforeach;
	
	self.btnAttrRem.enabled := false;
	
	self.tblData.selectMode := Table.SelectMode_CurrentRow;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDefaultLabel" id="52a3ca5e-a167-4554-b2da-3cc8f1b659bd">
        <updating/>
        <source>setDefaultLabel() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars
	label	: String;
	propName	: String;
begin

	if cmbFunction.listIndex &lt; 1 then
		return;
	endif;
	if cmbAttribute.listIndex &lt; 1 then
		return;
	endif;
	if txtLabel.text.trimBlanks = null then
		// 26608 Dec 2010 snap shot definition form issues - CM_XTABField heading is 30 chars
		propName := cmbAttribute.itemText[cmbAttribute.listIndex];
		label := cmbFunction.itemText[cmbFunction.listIndex] &amp; " (";
		if label.length + propName.length &lt; 30 then
			label := label &amp; propName &amp; ")";
		else
			label := label &amp; propName[1:29-label.length] &amp; ")";
		endif;
		txtLabel.text := label;
		//txtLabel.text := cmbFunction.itemText[cmbFunction.listIndex] &amp; " (" &amp; cmbAttribute.itemText[cmbAttribute.listIndex] &amp; ")";
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e9730540-d68e-4739-8117-a7a465efa9ba">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin

	self.beginClassNotification( CM_OutputFormat_SS, false, EVENT_SummaryTable_Update, Response_Continuous, null );
	self.beginClassNotification( CM_OutputFormat_SS, false, EVENT_SummaryTable_Delete, Response_Continuous, null );
	
	initControls();

	inheritMethod();
	
	createMyProxyFormat( self.myCM_OutputFormat_SS );
	
	self.loadModeCombo();
	self.loadData();
	self.txtName.setFocus();	// 26608 Dec 2010 snap shot definition form issues
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showSelectorForm" id="38c148f4-2fdc-4b9f-b0ad-d71867e006dd">
        <updating/>
        <source>showSelectorForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	query		: CM_MenuUserQuery;
	theSelector	: CMUI_Selector;
	
begin
	if cmbSelector.listIndex &lt; 1 then
		return;
	endif;

	theSelector := app.getSelectorForm(self, self.myMasterMenuAction);
	
	if theSelector = null then
		return;
	endif;
	
	theSelector.myEnquiryCollectionClass := CM_ObjectSet;
	theSelector.defaultSiteStr := TI_SITE_ONSITE_str;
	theSelector.disableMnuEnquiry := false;							

	query := self.cmbSelector.itemObject[ cmbSelector.listIndex ].CM_MenuUserQuery;
	theSelector.show;
	if query &lt;&gt; null then
		theSelector.showQuery(query);
	endif;
	
end;</source>
    </JadeMethod>
