    <JadeMethod name="erase" id="514f9f2f-5145-412a-abea-5e991e37abaa">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	if self.myTaxCode &lt;&gt; null and
	   not self.isTransient then		// from 37200 review of 'erase' code
		self.myTaxCode.myBank.terminal.causeEvent(self.myTaxCode.myBank.terminal.getTerminalEvent(EVENT_TAXCODE_DELETE), false, self);
	endif;	
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEffectiveDTLocalTZ" id="96e5c15c-e888-42dd-95a9-2c3c99927601">
        <source>getEffectiveDTLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.effectiveDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="21fbffbb-bbe2-4846-ad06-02aee1a82d1f">
        <source>pxyCreateUpdateProxy(): SelfType;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	tmpProxy : SelfType;
	completedOK		: Boolean;
begin
	tmpProxy := inheritMethod();
	tmpProxy.myTaxCode := tmpProxy.myTaxCode;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpProxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpProxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="01d1605f-3f44-479f-8dbc-e351c066f51f">
        <updating/>
        <source>setForCreate(_pxyTaxRate : CM_TaxRate; _passport : CM_Passport input) updating;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	self.raiseExceptionIfTransient(method);
	self.setForUpdate(_pxyTaxRate, _passport);
end;</source>
        <Parameter name="_pxyTaxRate" type="CM_TaxRate"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="062d3e6c-803f-4e20-84f8-016b6e6e29e3">
        <updating/>
        <source>setForUpdate(_pxyTaxRate : CM_TaxRate; _passport : CM_Passport input) updating;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	self.raiseExceptionIfTransient(method);
	self.effectiveDT := _pxyTaxRate.effectiveDT;
	self.rate := _pxyTaxRate.rate;			
	self.myTaxCode := _pxyTaxRate.myTaxCode;	
end;</source>
        <Parameter name="_pxyTaxRate" type="CM_TaxRate"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="59e9ab41-60a2-44b4-a703-16102f2cf0e4">
        <updating/>
        <source>setProxy(_effectiveDT : TimeStamp; _taxCode : CM_TaxCode; _rate : Decimal) updating;
//------------------------------------------------
// Created: 17 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.effectiveDT := _effectiveDT;
	self.myTaxCode := _taxCode;
	self.rate := _rate;		
end;</source>
        <Parameter name="_effectiveDT" type="TimeStamp"/>
        <Parameter name="_taxCode" type="CM_TaxCode"/>
        <Parameter name="_rate" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="6c3ea632-2821-443f-b4f9-c3521f278e96">
        <source>validateCreate(_passport: CM_Passport input);
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	self.validateUpdate(_passport);

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="92094d06-6b6b-49ad-a73a-7a1dad82118c">
        <source>validateDelete(_passport: CM_Passport input);
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
// 08/12/2014 cnwdb2 PAR 35364

vars

begin
//	app.raiseCMWarning2(CONF_DELETE, 'Tax Rate', '(' &amp; self.effectiveDT.shortCurrentLocaleFormat &amp; ' ' &amp; self.rate.String &amp; ')', null, null, self);	
	app.raiseCMWarning1(Sure_want_delete35364f,self.myTaxCode.code &amp; " " &amp; self.effectiveDT.shortCurrentLocaleFormat &amp; self.rate.String, null, null, self);		//cnwdb2 PAR 35364	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="0bbea4a9-b9bf-41b8-aa26-8ccc6d78c819">
        <source>validateUpdate(_passport: CM_Passport input);
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//14/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
//------------------------------------------------
vars
	tmpTaxRate,
	realTaxRate : SelfType;
begin

	if self.myTaxCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Tax Code', null, null);
		app.raiseCMException(Input_required_field_taxCode, null, null); // cnwdb2	PAR 35364


	elseif (not self.effectiveDT.isValid) then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Effective Date', null, null);	
		app.raiseCMException(Input_required_field_effctDate, null, null); // cnwdb2	PAR 35364


	else
		// date is valid and tax code set, check for duplicate rate with same effectiveDT
		tmpTaxRate := self.myTaxCode.allTaxRates[self.effectiveDT];
		if self.isTransient() then
			realTaxRate := self.pxyGetRealObject();
		else
			realTaxRate := self;
		endif;
		if tmpTaxRate &lt;&gt; null
		and realTaxRate &lt;&gt; tmpTaxRate then
			//app.raiseCMException2(DuplicateItem, 'Tax Rate', self.effectiveDT.shortCurrentLocaleFormat, null, null);	 //14.06.2022 navds20 53760
			// Tax Rate already exists for %1 : Rate_already_exists
			app.raiseCMException1(Rate_already_exists, self.effectiveDT.shortCurrentLocaleFormat, null, null);	 //14.06.2022 navds20 53760
		endif;
	endif;
	
	// Zero tax rate is valid (at least for Port Everett);
	if self.rate &lt; 0 then
//		app.raiseCMException1(REQUIRED_FIELD, 'Rate', null, null);
		app.raiseCMException(Input_required_field_rate, null, null); // cnwdb2	PAR 35364
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
