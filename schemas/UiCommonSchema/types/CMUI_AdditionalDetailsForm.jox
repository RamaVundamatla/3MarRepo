        <updating/>
        <source>cmbCustomsAgent_displayEntry(_combobox: CMUI_FieldComboBoxControl input; _obj: Any; _index: Integer):String updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/08/2009	cnwdap1	Initial creation
07/03/2016	cnwdap1	PAR #37606 not available for entry
*/

vars

begin
	if _obj.CM_CustomsAgent.isNotAvailableForEntry then			// PAR #37606
		return null;											// PAR #37606
	endif;														// PAR #37606
	
	return _obj.CM_CustomsAgent.code &amp; "    " &amp; _obj.CM_CustomsAgent.name;
epilog

end;</source>
        <Parameter name="_combobox" type="CMUI_FieldComboBoxControl" usage="input"/>
        <Parameter name="_obj" type="Any"/>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
