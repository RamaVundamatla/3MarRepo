        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmLocn_mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
Purpose:			
Date		Who		Reason
13 February 2012	cnwab1	Initial creation
*/

vars

begin
	if self.polyType = DeckItemLayoutType_Slot then
		if shift.isControlKeyPressed() then
			frame.borderColorSingle := Red;
		elseif shift.isShiftKeyPressed() then
			frame.borderColorSingle := SkyBlue;
		endif;

	endif;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
