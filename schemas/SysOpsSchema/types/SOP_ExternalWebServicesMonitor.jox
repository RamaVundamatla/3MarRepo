    <JadeMethod name="sysNotify" id="7ab03d43-9551-42d5-9de3-87959e023a4d">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*
Purpose:			

Date		Who		Reason
28 Jul 2021	navab1	TFS 50669
14 Feb 2022	navdap1	TFS 52268 AAT 1-Stop VBS Integration
01 Apr 2022	navgm20 TFS 52777  EUP - INT - Generic API: record-scan
08 Dec 2022	navdap1	TFS 55159 MTN Export CAMS to JSON API Endpoint
*/

vars
	idx  : Integer;
	theDataLine : String;
	activity : CM_ExternalWebServiceActivity;

	fromTime, toTime : Time;
	wsDef			: CM_OpsViewServiceDef;
	
begin

	// ### TFS 52925 22FEB2022 NAVAB1 - if OpsView producer is just starting we may re send some messages, there maybe 1000s, so do not update this screen until we have finished resending and the producer status in MTN is running
	if self.isOpsView() then
		wsDef := self.cmbInterfaceName.listObject.CM_OpsViewServiceDef;
		if wsDef &lt;&gt; null 
		and wsDef.status &lt;&gt; EWS_STATUS_RUNNING then
			return;
		endif;
	endif;
	
	if self.mskTimeFrom.getTime().isValid then
		fromTime := self.mskTimeFrom.getTime();
	else
		fromTime.setTime(0,0,0,0);
	endif;
	if self.mskTimeTo.getTime().isValid then
		toTime := self.mskTimeTo.getTime();
	else
		toTime.setTime(23,59,59,999);
	endif;
	

	self.filterDateFrom.setDate(self.mskDateFrom.getDate());
	self.filterDateFrom.setTime(fromTime);
	self.filterDateTo.setDate(self.mskDateTo.getDate());
	self.filterDateTo.setTime(toTime);
	
	if theObject.isKindOf(CM_ExternalWebServiceActivity) then
		activity := theObject.CM_ExternalWebServiceActivity;
		if eventType = Object_Delete_Event then
			if self.tblData.findObjectInRow(activity, idx) then
				self.tblData.removeItem(idx);
			endif;
		else
			if ( self.includeObjectEWS(activity) ) then    //  TFS 55159 //jlier1 TFS 56856 3/4/23
				if eventType = Object_Update_Event then
					if self.tblData.findObjectInRow(activity, idx) then
						self.tblData.removeItem(idx);
					endif;
					theDataLine := activity.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);

					idx := self.tblData.addItemObject(activity, theDataLine);
				elseif eventType = Object_Create_Event then
					theDataLine := activity.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);

					idx := self.tblData.addItemObject(activity, theDataLine);
				endif;
			endif;
		endif;
		
		self.lblQueryLinesValue.caption := (self.tblData.rows - self.tblData.fixedRows).String;
	elseif theObject.isKindOf(CM_OpsViewServiceDef) and self.isOpsView then
		self.getProducerStatusDetails();
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="524d58c1-598c-4684-9b1b-926da90c8a1f">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*
Purpose:			

Date		Who		Reason
23 Jul 2021	navab1	TFS 50669
14 Feb 2022	navdap1	TFS 52268 AAT 1-Stop VBS Integration
27/09/2024	navcs2	ChangeRequest 66181: MTN | External Webservice Monitor - Feedback
*/

vars
	activity : CM_ExternalWebServiceActivity;
	camsHistory : CM_CamTaskHistory;
	invalidObj : Boolean;
begin

	self.mnuInspect.visible := app.isAllowedToInspect();
	//jlier1 TFS 58637 19/6/23
	self.mnuResendMessage.visible:=false;
	self.mnuReprocessMessage.visible:=false;
	
	if self.tblData.row &gt; self.tblData.fixedRows then
		activity := self.tblData.accessRow(self.tblData.row).itemObject.CM_ExternalWebServiceActivity;

		if activity &lt;&gt; null then			
			if activity.isAgGatewayEWSActivity() then		//navra1 - MTN-34782 - 15th July 2025
				self.mnuViewXML.visible := true;			//navra1 - MTN-34782 - 15th July 2025
				if activity.CM_EWSActivityAgGateway.direction = CM_EWSActivityAgGateway.DIRECTION_SEND and activity.responseCode &lt;&gt; 200 then		//navra1 - MTN-35875- 5th Sep 2025-1
					self.mnuResendMessage.visible := true;																							//navra1 - MTN-35875- 5th Sep 2025-1
				endif;																																//navra1 - MTN-35875- 5th Sep 2025-1
			else											//navra1 - MTN-34782 - 15th July 2025
				self.mnuViewJSON.visible := true;
			endif;											//navra1 - MTN-34782 - 15th July 2025
			//jlier1 TFS 58637 19/6/23
			on Exception do app.handleDeletedObject(exception,camsHistory, invalidObj);
			if activity.isCams and activity.CM_EWSActivityCams.myCamTaskHistory &lt;&gt; null then				//27/09/2024	navcs2	ChangeRequest 66181
				camsHistory:=activity.CM_EWSActivityCams.myCamTaskHistory;
				camsHistory.edition;
				if not invalidObj then
					self.mnuReprocessMessage.visible:=app.myPassport.myUser.canDo(null,PmAdmEWSMonitorMaint);  //there is already a maintenance permission for this form that does nothing lets use that
					self.mnuReprocessMessage.userObject:=activity;
					if activity.status =   BGP_OpsViewWSRequest.EWS_STATUS_BGP_SENT_FAILURE or app.isDevelopmentSystem then
						self.mnuResendMessage.visible:=app.myPassport.myUser.canDo(null,PmAdmEWSMonitorMaint) and camsHistory.getRawDataString.length &gt; 0;  //jlier1 TFS 59815 15/8/23	 //there is already a maintenance permission for this form that does nothing lets use that
						self.mnuResendMessage.userObject:=activity;
					endif;
				endif;			
			endif;
			
		else
			self.mnuViewJSON.visible := false;
			self.mnuViewXML.visible := false;			//navra1 - MTN-34782 - 15th July 2025
		endif;
	endif;
	
	
	return self.showContextMenu(self.mnuContext, table, conwin, mouse, x, y);

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="7680fbab-8524-4cc6-8072-f4808bee5baf">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(_table: CM_DataTable input) updating;
/*
Purpose:			

Date			Who		Reason
27 July 2021	navab1	TFS 50669
02 May 2022     navhl20 TFS 52777 EUP - INT - Generic API: record-scan
18 Mar 2023		navmd1	TFS 57092 Refactor for CAMS ExtWS
*/

vars
	messageLogForm	: CMUI_MessageLogForm;
	rowObject		: CM_ExternalWebServiceActivity;
begin

	if _table.row &gt; _table.fixedRows then

		// ### TFS 51855 27JAN2022 NAVAB1
		if self.tblData.row &lt;= self.tblData.fixedRows then
			return;
		endif;
		
		rowObject := self.tblData.accessRow(self.tblData.row).itemObject.CM_ExternalWebServiceActivity;
		if rowObject = null then
			return;
		endif;

		create messageLogForm transient;
		messageLogForm.setMyObject(rowObject);
		messageLogForm.show;
		return;
	
	endif;

	_table.resortTableByColumn(_table.column);

epilog
	
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
