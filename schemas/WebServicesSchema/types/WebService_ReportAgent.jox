    <JadeMethod name="getSelectedStops" id="ba7d933f-68cb-4fb6-8edd-8031205cca17">
        <source>getSelectedStops(_stopTableColl: Collection input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwkao1	Initial creation - based on WebSchema implementation
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars
	tmpStr 		: String;
	huge		: StringArray;
	stopTable	: CM_StopsTable;
	reportParam	: WS_ReportParameter;
	
begin

	reportParam := self.allWSReportParams.getAtKey(ETRow_Stops);
	if reportParam &lt;&gt; null then
		tmpStr := reportParam.value;
	endif;	
	
	_stopTableColl.clear();
	
	if tmpStr.length &gt; 0 then
		create huge transient;
		tmpStr.getTokensForDelimiter("|", huge);
		foreach tmpStr in huge do
			//stopTable := tmpStr.asOid.CM_StopsTable;		//12.08.2022 navtnr20 52451
			stopTable := app.myPassport.getObjectOfTypeFromOid(tmpStr,CM_StopsTable).CM_StopsTable;		////12.08.2022 navtnr20 52451
			if stopTable &lt;&gt; null then
				_stopTableColl.add(stopTable);
			endif;
		endforeach;
	endif;

epilog
	delete huge;
end;</source>
        <Parameter name="_stopTableColl" type="Collection" usage="input"/>
    </JadeMethod>
