    <JadeMethod name="getBlendedAmount" id="8e28fd9b-32ee-4a06-8db7-84d29f57c06d">
        <source>getBlendedAmount() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	ct : CM_CargoType;
	amount : String;
	unit : String;
	
begin
	
	ct := self.myTrackedItem.myCargoType;
	
	if ct &lt;&gt; null then

		if ct.isTrackByVolume then
		
			if ct.myVolumeMeasurementType &lt;&gt; null then
				unit := ct.myVolumeMeasurementType.shortName;		
				amount := app.convertMeasurementForDisplay(unit, self.totalVolume);
				if amount &lt;&gt; null then
					return amount &amp; Space &amp; unit;
				endif;
			else
				return self.totalVolume.asStringJMT &amp; Space &amp; "m3";
			endif;	
		
		elseif ct.isTrackByWeight then
		
			if ct.myWeightMeasurementType &lt;&gt; null then
				unit := ct.myWeightMeasurementType.shortName;		
				amount := app.convertMeasurementForDisplay(unit, self.totalWeight);
				if amount &lt;&gt; null then
					return amount &amp; Space &amp; unit;
				endif;
			else
				return self.totalWeight.asStringJMT &amp; Space &amp; "kg";
			endif;	
		
		else
			return self.totalQuantity.asStringJMT;
		
		endif;
	
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBlendedDescription" id="8bd6c5fe-e09b-4514-aafe-214bb784018a">
        <source>getBlendedDescription():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	blendAmount : String;
	lDetail : String;
	otherTI : CM_TrackedItem;
	theTI : CM_TrackedItem;
	invalid : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, theTI, invalid );
	on Exception do app.handleDeletedObject( exception, otherTI, invalid );

	theTI := self.myTrackedItem;
	otherTI := self.getOtherTrackedItem();

	if self.action = ACTION_BLEND_CHILD then
		lDetail := app.getErrorString(Blended) &amp; " ";
		blendAmount:= self.getBlendedAmount;
		if blendAmount &lt;&gt; null then
			lDetail:=lDetail &amp; blendAmount &amp; " x " &amp; self.getCargoTypeProd() &amp; " ";
		endif;
		if theTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; theTI.id;
		endif;
		lDetail := lDetail &amp; " =&gt; ";
		if otherTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; otherTI.id;
		endif;
		
	elseif self.action = ACTION_BLEND_PARENT then
		lDetail := app.getErrorString(Blended) &amp; " ";
		lDetail := lDetail &amp; " " &amp; self.getOtherTisDetailsString();
		lDetail := lDetail &amp; " =&gt; ";
		if theTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; theTI.id;
		endif;
		blendAmount:= self.getBlendedAmount;
		if blendAmount &lt;&gt; null then
			lDetail := lDetail &amp; " x " &amp; blendAmount;
		endif;
		
		if self.myRecipe &lt;&gt; null then
			lDetail := lDetail &amp; " [" &amp; app.getErrorString1( RecipeEquals, self.myRecipe.code ) &amp; "]";
		else
			lDetail := lDetail &amp; " [" &amp; app.getErrorString( No_Recipe_used ) &amp; "]";
		endif;
		
	endif;

	lDetail := lDetail &amp; " " &amp; self.urNumber.String;			
	
	return lDetail;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeProd" id="f567f4b0-7e95-4260-825b-75b5e6f83339">
        <source>getCargoTypeProd():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	cargoType : CM_CargoType;
	cargoSubType : CM_Product;
	returnStr : String;

begin

	self.getCargoTypeAndSubType( cargoType, cargoSubType );

	if cargoSubType &lt;&gt; null then
		if cargoType &lt;&gt; null then
			returnStr := cargoType.abbreviation &amp; " / " &amp; cargoSubType.code;
		else
			returnStr := cargoSubType.code;
		endif;
	else
		returnStr := cargoType.description;
	endif;
	
	return returnStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="93fff83c-7cd0-4926-a420-121d8334a620">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars
	
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();
			
		else
			return self.getBlendedDescription();
			
		endif;

	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="235265d9-2653-4a0a-8ec8-02d6d94e1a0e">
        <source>getEnquiryRow(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	lDetail : String;

begin

	lDetail := inheritMethod();

	lDetail := lDetail &amp;  self.getBlendedDescription();
	
	return lDetail;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationStr" id="ee82bea3-b4f9-4f26-879a-5d7d4b36e3c4">
        <source>getLocationStr(): String;
/*

Purpose:			

Parameters:			

Return Value:		

