    <JadeMethod name="erase" id="8d5849d1-08fb-4337-8d2b-f9aaa68699fe">
        <updating/>
        <source>erase(_level: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     15 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	usage		:CM_GateAreaUsage;
	int, size	:Integer;
begin
	size := self.allGateAreas_IN.size;
	
	if size &gt; 0 then
		foreach int in size to 1 step -1 do 
			usage := self.allGateAreas_IN[int];
			
			usage.erase (_level);
		endforeach;
	endif;
	
	
	size := self.allGateAreas_OUT.size;
	
	if size &gt; 0 then
		foreach int in size to 1 step -1 do 
			usage := self.allGateAreas_OUT[int];
			
			usage.erase (_level);
		endforeach;
	endif;

	inheritMethod(_level);
epilog

end;</source>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllGALaneControllers" id="79f3154e-f650-4ab6-89bc-b02dc2360981">
        <source>getAllGALaneControllers(_coll : CM_ObjectSetActual input; _direction : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2017	cnwns1	Initial creation
30 May 2022		navpw1	Tidied up Method and fixed issue with not checking for both

*/

vars
	usage			: CM_GateAreaUsage;
	gateArea 		: CM_GateArea;
	laneCont		: CM_LaneController;
	gateAreaSet 	: CM_ObjectSet;
	gridController 	: CM_GridController;
	
begin
	create gateAreaSet transient;
	
	if _direction = IN_YO or _direction = Both then // ### TFS 52773 27May2022 NAVPW1
		foreach usage in self.allGateAreas_IN do
			gateAreaSet.addNoDuplicates (usage.myGateArea, false);
		endforeach;
	endif;
	
	if _direction = OUT_YO or _direction = Both then // ### TFS 52773 27May2022 NAVPW1
		foreach usage in self.allGateAreas_OUT do
			gateAreaSet.addNoDuplicates (usage.myGateArea, false);
		endforeach;
	endif;

	if gateAreaSet.size &gt; 0 then
		foreach gateArea in gateAreaSet as CM_GateArea do : gateAreaLoop
			foreach gridController in gateArea.allGridControllersByName where gridController.isKindOf(CM_GateAreaLaneController) do : gridControllerLoop
				laneCont := gridController.CM_GateAreaLaneController;
				
				if laneCont.isUnavailable then 
					continue;
					
				endif;		
				
				_coll.addNoDuplicates(laneCont, false);
				
			endforeach;
			
		endforeach;
	endif;
	
epilog
	delete gateAreaSet;
	
end;</source>
        <Parameter name="_coll" type="CM_ObjectSetActual" usage="input"/>
        <Parameter name="_direction" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllGateAreas" id="7a1db083-406a-4df4-8da8-90f3eb77165c">
        <source>getAllGateAreas(_coll :CM_ObjectSet input);
// ---------------------------------------------------------------------------
// Created:     11 September 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/06/2010	par 24418 - changed to public from protected
// ---------------------------------------------------------------------------
vars
	usage	:CM_GateAreaUsage;
begin
	foreach usage in self.allGateAreas_IN do
		_coll.addNoDuplicates (usage.myGateArea, false);
	endforeach;
	
	foreach usage in self.allGateAreas_OUT do
		_coll.addNoDuplicates (usage.myGateArea, false);
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="CM_ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="ec035957-2864-45d7-a536-7a602c90d885">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     15 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	txt, tmpStr	: String;
	cnt			: Integer;
	usage 		: CM_GateAreaUsage;
	gateArea	: CM_GateArea;
	
begin
	txt :=  inheritMethod();
	
	foreach usage in self.allGateAreas_IN do
		txt := txt &amp; usage.myGateArea.getAuditText();
	endforeach;
	foreach usage in self.allGateAreas_OUT where not usage.myGateArea.isInGate do
		txt := txt &amp; usage.myGateArea.getAuditText();
	endforeach;
	
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultInterchangeArea_IN" id="9865dfb9-dd39-4ab4-9a2f-30e993e20233">
        <source>getDefaultInterchangeArea_IN(_vehicle :CM_Vehicle):CM_TerminalArea;
// ---------------------------------------------------------------------------
// Created:     17 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     The interchange area the vehciel will be sent to
//				when it enters the yard
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc	:CM_YardController;
	ta	:CM_TerminalArea;
begin
	lc := self.getDefaultYardLocation_IN (_vehicle);
	
	if lc = null then
		return null;
	endif;
	
	ta := lc.myTerminalArea;
	
//	if ta.isInterchangeArea then
//		return ta.CM_InterchangeArea;
//	endif;
	
	//31 Jan 2013	NDL	Par 31102
	if ta.isInterchangeArea or ta.isKindOf(CM_CraneTransferArea) then
		return ta;
	endif;
	
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getDefaultYardLane" id="cd5b8589-1763-4ed3-a63d-b2063a1f1d32">
        <source>getDefaultYardLane(): CM_YardController;
//21 August 2009	cnwdw1	
//
vars

begin
	return self.myDefaultInterchangeArea.CM_InterchangeArea.getLaneByNumber(1);
end;</source>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getDefaultYardLocation_IN" id="197e0119-7e5a-4b08-bc3c-a24839f00653">
        <source>getDefaultYardLocation_IN(_vehicle :CM_Vehicle):CM_YardController;
// ---------------------------------------------------------------------------
// Created:     03 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/02/2010	cnwcs5		CCMS SFW 1071 - allow interchange area to be specified 
//							when they come through the gate
// 27/05/2010	cnwcs5		par24292 - interchange area capacity checking (old code deleted - see history for details)
// 17/06/2010	cnwcs5		par 24418 - be more explicit with interchange areas
// 24/06/2010	cnwcs5		par 24292 - change of paremeters in method being called
// 04/12/2012	cnwer1		par 30385 - handle release by type director tasks 
// ---------------------------------------------------------------------------
vars
	roadJob		: CM_RoadJob;
	icArea		: CM_InterchangeArea;
	ti			: CM_TrackedItem;
	lc_ti		: CM_LocationsController;
	lc			: CM_YardController;	
	wle 		: CM_WorkListEntry;
begin
	roadJob	:= _vehicle.allRoadJobs.first.CM_RoadJob;
	
	if roadJob = null then	
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Method called for vehicle with no road job");
	endif;

	// the interchange area may have been specified when they came in the gate
	// if it is we always move the vehicle to that area of the terminal
	icArea := roadJob.getOverride_YardICArea;			// 17/06/2010 cnwcs5 par 24418
	
	if icArea &lt;&gt; null then 								// cnwrd1 28.5.2010 temp fix
		return icArea.getLocationforVehicleMove;		// 27/05/2010 cnwcs5 par 24292
	endif;

	// now see if we can move the vehicle to an interchange area associated with
	// the first tracked item for the job

	ti := roadJob.allReceiveTrackedItems.first;
	
	if ti &lt;&gt; null then
	
		lc_ti := ti.getPrimaryLocation(QUEUE_MODE);
		
		//30 Jan 2013	NDL	Par 31102
		if ti.directDelivery then
			lc := ti.getYardLocationForVehicleForDD();
			if lc &lt;&gt; null then 
				return lc.CM_YardController;
			endif;
		endif;
		
	else
	
		ti := roadJob.allReleaseTrackedItems.first;

		// PAR 32507 For break-bulk the ti may not be in the allReleaseTrackedItems collection, so have a look at the WLE
		if ti = null then
			wle:=roadJob.workListEntries.first;
			if wle &lt;&gt; null then
				ti := wle.myTrackedItem;
			endif;
		endif;

		if ti &lt;&gt; null then
			lc_ti := ti.myPrimaryActualLocation;
			
			//30 Jan 2013	NDL	Par 31102
			if ti.directDelivery then
				lc := ti.getYardLocationForVehicleForDD();
				if lc &lt;&gt; null then 
					return lc.CM_YardController;
				endif;
			endif;
		
		endif;
		
		if lc_ti = null then
			//no tis to receive or release. Must have release by type
			wle:=roadJob.workListEntries.first;
			if wle &lt;&gt; null then
				lc_ti := wle.getRequestSourceLocnTI(ti);
			endif;
		endif;
	endif;
	
	if lc_ti &lt;&gt; null then
		lc := lc_ti.getLocationForVehicleMove (_vehicle); 
	endif;
	
	if lc &lt;&gt; null then 
		return lc.CM_YardController;
	endif;
	
	// if we get to here we just have to go to the default interchange area for the gate
	icArea := self.myDefaultInterchangeArea;
	
	if icArea = null then
		// don't expect this to happen as property is inversed
		// validation stops you deleting IC area that is a gate default
		return null;	
	endif;
	
	return icArea.getLocationforVehicleMove;	// 27/05/2010 cnwcs5 par 24292
epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getFirstAGateLane_IN" id="80e24b7b-e753-4044-b44a-c848a819b42f">
        <source>getFirstAGateLane_IN(): CM_YardController;
//20 August 2009	cnwdw1	
// Return the location of the first lane in the first A Gate
vars
	usage	:CM_GateAreaUsage;
begin
	foreach usage in self.allGateAreas_IN do
		if usage.myGateArea.areaType = CM_GateArea.AreaType_A then
			return usage.myGateArea.getLaneByNumber(1);
		endif;
	endforeach;
	
	return null;
end;</source>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
