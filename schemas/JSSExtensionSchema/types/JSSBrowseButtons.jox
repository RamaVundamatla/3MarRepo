    <JadeMethod name="browse" id="c6cfc514-b4ca-4ae3-b64e-e809f3c2b0e2">
        <updating/>
        <source>browse(browsebuttons: JSSBrowseButtons input; browseType: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Purpose:		This event is triggered when the user clicks a browse button.
//
// Parameters:	browsebuttons (CnEBrowseButtons) - The control object.
//				browseType (Integer) - Indicates which browse buton was clicked.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// --------------------------------------------------------------------------------
vars
	browseAction	: Integer;

begin
	app.mousePointer		:=	Busy;
	inheritMethod(browsebuttons, browseType);
	self.myCurrentObject	:=	null;
	browseAction			:=	browseType;
	
	if self.myIterator &lt;&gt; null and self.myIterator.getCollection.jssIsNotEmpty() then

		if self.isReversed then
			if browseAction = BrowseButtons.Browse_First then
				browseAction	:=	BrowseButtons.Browse_Last;
			elseif browseType = BrowseButtons.Browse_Prior then
				browseAction	:=	BrowseButtons.Browse_Next;
			elseif browseType = BrowseButtons.Browse_Next then
				browseAction	:=	BrowseButtons.Browse_Prior;
			elseif browseType = BrowseButtons.Browse_Last then
				browseAction	:=	BrowseButtons.Browse_First;
			endif;
		endif;

		if browseAction = BrowseButtons.Browse_First then
			self.myIterator.reset;
			self.myIterator.next(self.myCurrentObject);
			
		elseif browseAction = BrowseButtons.Browse_Prior then
			self.myIterator.back(self.myCurrentObject);

			if self.myCurrentObject = null then
				self.myIterator.reset;
				self.myIterator.next(self.myCurrentObject);
			endif;
			
		elseif (browseAction = BrowseButtons.Browse_Next) then
			self.myIterator.next(self.myCurrentObject);

			if self.myCurrentObject = null then
				self.myIterator.reset;
				self.myIterator.back(self.myCurrentObject);
			endif;
			
		elseif browseAction = BrowseButtons.Browse_Last then
			self.myIterator.reset;
			self.myIterator.back(self.myCurrentObject);
		endif;
	endif;

	self.displayEntry(browsebuttons, browseAction, self.myCurrentObject);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="browsebuttons" type="JSSBrowseButtons" usage="input"/>
        <Parameter name="browseType" type="Integer"/>
    </JadeMethod>
