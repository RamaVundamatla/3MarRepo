    <JadeMethod name="initFromUserWindow" id="dd59b790-79ca-40a4-846d-1b722af86363">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation	par 29968

*/

vars

	xmlText : String;

begin

	inheritMethod(_userWindow);
	
	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkSummary.name);
	self.chkSummary.value := (xmlText = "true").Boolean;
	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkDetail.name);
	self.chkDetail.value := (xmlText = "true").Boolean;

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="3f08eb4b-5f1d-4c87-a369-8e523878b45f">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation

*/

vars

begin

	if keyCode = CMUI_Key_F3 then
		self.showSearchFrame();
	elseif keyCode = CMUI_Key_F5 then
		self.doSearch();
	endif;
		
	inheritMethod(keyCode, shift);

epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mnuInspect_click" id="6e331601-42a1-4af4-bf55-05b79b146590">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuInspect_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	if menuItem.userObject &lt;&gt; null then
		menuItem.userObject.inspect;
	endif;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setInitialControlValues" id="deb430b4-922c-4e7f-bd06-005cd923e708">
        <updating/>
        <source>setInitialControlValues() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	drType : CM_DebtorType;
	dr : CM_DebtorNode;
	index : Integer;
	headings : String;
	term : CM_Terminal;
	terms : CM_TerminalByCodeDict;

begin

	self.setNavigatorHeading( self.caption );

	//self.showToolbar := false;
	self.frmMain.borderStyle := 0;
	self.frmMain.top := 0;
	self.frmMain.left := 0;
	
	self.frmTables.borderStyle := 0;
	
	self.minimumHeight := 400;
	self.minimumWidth := 700;
	
	self.myAssistant.comboBoxCashDebtors( self.cmbDebtors, null, self.myDebtor, true );
	
	self.cmbTerminals.clear();
	self.cmbTerminals.addItem( Any_String );
	
	create terms transient;
	app.getMyUser.getTerminals(terms);
	foreach term in terms do
		if not term.isCashOnlyEnabled then
			continue;
		endif;
		index := self.cmbTerminals.addItem( term.name );
		self.cmbTerminals.itemObject[ index ] := term;
	endforeach;
	
	self.cmbTerminals.listIndex := self.cmbTerminals.findObject( self.myTerminal );
	if self.cmbTerminals.listIndex &lt; 1 then
		self.cmbTerminals.listIndex := 1;
	endif;
	
	self.tblCash.rows := 1;
	self.tblCash.fixedRows := 1;
	self.tblCash.columns := 5;
	self.tblCash.fixedColumns := 0; // TFS 7357
	self.tblCash.selectMode := Table.SelectMode_WholeRows; // TFS 7357
	// 37141 change heading from Unallocated (no longer used) to Credit for credit note totals
	headings := app.getErrorString(Debtor_GC) &amp; Tab &amp; app.getErrorString(Terminal) &amp; Tab &amp; app.getErrorString(Credit) &amp; Tab &amp; app.getErrorString(Proforma) &amp; Tab &amp; app.getErrorString(Balance);
	self.tblCash.setCellText(1,1,headings);
	self.tblCash.accessRow(1).fontBold := true;
	self.tblCash.accessCell(1,3).alignment := Table.Alignment_Left_Middle;
	self.tblCash.accessCell(1,4).alignment := Table.Alignment_Left_Middle;
	self.tblCash.accessCell(1,5).alignment := Table.Alignment_Left_Middle;
	self.tblCash.accessColumn(3).alignment := Table.Alignment_Right_Middle;
	self.tblCash.accessColumn(4).alignment := Table.Alignment_Right_Middle;
	self.tblCash.accessColumn(5).alignment := Table.Alignment_Right_Middle;
	
	self.lblSearchCrit.caption := " ";
	self.showSearchFrame;

epilog

	delete terms;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyDebtor" id="1a5bc99b-1651-47a3-82e0-defa1ec79282">
        <updating/>
        <source>setMyDebtor( _myDebtor : CM_Debtor ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.myDebtor := _myDebtor;

epilog

end;</source>
        <Parameter name="_myDebtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="setSearchCriteriaLabel" id="10f873f8-e912-4450-a618-5965a0835d15">
        <updating/>
        <source>setSearchCriteriaLabel() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2012	cnwndl1	Initial creation	Par 29968

*/

constants
	TAB : String = "      ";
vars

	str : String;

begin

	str := app.getErrorString(Filter_criteria_used);
	if self.cmbDebtors.text &lt;&gt; null then
		str := str &amp; CrLf &amp; TAB &amp; lblCashDebtor.caption &amp; Tab &amp;  " = " &amp; self.cmbDebtors.text;
	endif;
	if self.cmbTerminals.text &lt;&gt; null then
		str := str &amp; CrLf &amp; TAB &amp; lblTerminal.caption  &amp; Tab &amp;   " = " &amp; self.cmbTerminals.text;
	endif;
	if self.chkDetail.value then
		str := str &amp; CrLf &amp; TAB &amp; chkDetail.caption;
	endif;
	if self.chkSummary.value then
		str := str &amp; CrLf &amp; TAB &amp; chkSummary.caption;
	endif;
	
	
	self.lblSearchCrit.caption := str;
	self.doResize();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2478c5f9-8449-4275-a5c1-76cf4b195a0b">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2012	cnwndl1	Initial creation	par 29968

*/

vars

begin

	self.showToolbar := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.myTerminal := null;
	self.mnuContext.visible:=false;
	inheritMethod();
	
	if not app.isCashOnlyEnabled then
		self.unloadForm;
		return;
	endif;
	
	self.setInitialControlValues();
	
	self.addToolbarControls();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showSearchFrame" id="4e418021-09b8-4c67-8cd4-307221bdfb8e">
        <source>showSearchFrame();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation

*/

vars

	theFrame : CMUI_MoveableFrame;

begin

	if self.frmSearch.visible then
		self.hideSearchFrame();
	else
		theFrame := self.frmSearch;
		theFrame.zOrder(1);
		theFrame.centreWindow();
		theFrame.visible := true;
		self.frmMain.enabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblCash_contextMenu" id="591ba2df-01e8-47b6-adc7-42cf3be00ee1">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCash_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2012	cnwndl1	Initial creation

*/

vars

begin

	if self.doMnuContextBuild(table, conwin, mouse, x, y) then
		return self.showContextMenu(mnuContext, table, conwin, mouse, x, y);
	else
		return false;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="bdb90474-f2bb-40a6-9617-cfda1d0caf6f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018191, locale);
	btnClose.translateCaption(Xlat_0018192, locale);
	btnExportCSV.translateBubbleHelp(Xlat_0018193, locale);
	btnExportCSV.translateCaption(Xlat_0018194, locale);
	btnPrintTbl.translateBubbleHelp(Xlat_0018195, locale);
	btnPrintTbl.translateCaption(Xlat_0018196, locale);
	btnSearch.translateBubbleHelp(Xlat_0018197, locale);
	btnSearch.translateCaption(Xlat_0018198, locale);
	btnSearchCancel.translateBubbleHelp(Xlat_0018199, locale);
	btnSearchCancel.translateCaption(Xlat_0018200, locale);
	btnSearcher.translateBubbleHelp(Xlat_0018201, locale);
	btnSearcher.translateCaption(Xlat_0018202, locale);
	chkDetail.translateCaption(Xlat_0018203, locale);
	chkSummary.translateCaption(Xlat_0018204, locale);
	lblCashDebtor.translateCaption(Xlat_0018205, locale);
	lblSearch.translateCaption(Xlat_0018206, locale);
	lblSearchCrit.translateCaption(Xlat_0018207, locale);
	lblTerminal.translateCaption(Xlat_0018208, locale);
	mnuContext.translateCaption(Xlat_0018209, locale);
	mnuInspect.translateCaption(Xlat_0018210, locale);
end;</source>
    </JadeMethod>
</GUIClass>
