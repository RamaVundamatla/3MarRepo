    <JadeMethod name="retainRecDataOnTiTrx" id="f9659716-740c-414e-9bcb-cb2aaa6b7327">
        <source>retainRecDataOnTiTrx(_tiTrans: CM_TITransaction input; _seqNum: Integer; _bookingRef : String) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/01/2020	jlgdap1		Initial creation TFS 48016 SNO Deletion CODECO
// 20/02/2020	jlgka1		TFS 48550 Add booking number.
// 15/05/2020	jlgdap1		TFS 49371 Correct BGM sequence handling to cater for ad-hoc and scheduled runs
//							and messages for more than one voyage
vars
	externalReference : String;
begin
	// only Receive - Road and Receive - Inter Terminal Transfer at this stage
	if _tiTrans.type &lt;&gt; TRANS_TYPE_REC_ROAD and _tiTrans.type &lt;&gt; TRANS_TYPE_REC_ROAD_INTER_TERM then
		return;
	endif;
	
	// if the transaction already has an external ref, don't over-write it
	// We may be rerunning Cams
	if _tiTrans.externalReferenceId &lt;&gt; null then
		return;
	endif;	
	if _bookingRef &lt;&gt; null then
		externalReference :=  _seqNum.String &amp; "||" &amp; _bookingRef;
	else
		externalReference :=  _seqNum.String;
	endif;
	
	if not process.isInTransactionState then																// TFS 49371
		app.myTrxUA.trxUpdateTITransactionExtRef(_tiTrans, externalReference, null, app.myPassport);		// TFS 49371
	else																									// TFS 49371
		app.myUtilityUA.utlUpdateTITransactionExtRef(_tiTrans, externalReference, null, app.myPassport);	// TFS 49371
	endif;																									// TFS 49371
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tiTrans" type="CM_TITransaction" usage="input"/>
        <Parameter name="_seqNum" type="Integer"/>
        <Parameter name="_bookingRef" type="String"/>
    </JadeMethod>
