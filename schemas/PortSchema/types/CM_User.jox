    <JadeMethod name="resetSysEntMenuFromJMTDefault" id="ecd3f86e-000d-4626-a43e-17a6612de82f">
        <updating/>
        <source>resetSysEntMenuFromJMTDefault(_clearFirst : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	userTerm	: CM_UserTerminal;
			
begin
	if self.myMenuRootForSysEntities = null then
		self.createMenuRootForSysEntities();
	endif;
	
	self.myMenuRootForSysEntities.resetMenu(app.myRoot.myMenuRootForSysEntities, _clearFirst);
		
