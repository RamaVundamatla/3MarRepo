    <JadeMethod name="load" id="f2514e6f-6250-467d-8911-be168089d4a7">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	mainForm		: Form;
begin
	inheritMethod();
	
	mainForm := app.mainForm;
	if mainForm &lt;&gt; null then
		self.left := (mainForm.width /2) - (self.width /2);
		self.top := 300;
	endif;
		
	

end;


</source>
    </JadeMethod>
    <JadeMethod name="saveCriteria" id="c9ece302-8d7e-48fc-8323-c24349764a66">
        <updating/>
        <source>saveCriteria() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move

*/

vars
	result : Integer;
begin
	self.applyFormChanges();
	while true do
	
		if self.isUpdate then
			app.myTrxUA.trxUpdateObjMatchCrit(self.myProxyObject, app.myPassport);
		else
			app.myTrxCA.trxCreateObjMatchCrit(self.myProxyObject, self.myNewCriteria, app.myPassport );
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Rail_colour_coding), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

		endif;
		
		return false;
		
	endwhile;
	
	self.myNewCriteria := null;
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
