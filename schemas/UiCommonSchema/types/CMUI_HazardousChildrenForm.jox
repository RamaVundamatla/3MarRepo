    <JadeMethod name="addOrUpdateChildEntityInTable" id="ddd4f554-6be7-4709-992b-77c3360f676a">
        <updating/>
        <source>addOrUpdateChildEntityInTable(_pxyObject : Object) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Material Handling
//
vars
	row : Integer;
	str : String;

begin
	if _pxyObject = null then
		return;
	endif;
	
	self.tblUpdateItemObject(_pxyObject, self.colorRow1, self.colorRow2, app.myPassport);
	if _pxyObject.isKindOf(CMGTE_Receival) and  not self.allProxyChildReceivals.includes(_pxyObject.CMGTE_Receival) then
		self.allProxyChildReceivals.add(_pxyObject.CMGTE_Receival);
	elseif _pxyObject.isKindOf(CMIF_PreNote) and not self.allProxyChildReceivals.includes(_pxyObject.CMIF_PreNote) then
		self.allProxyChildReceivals.add(_pxyObject.CMIF_PreNote);
	endif;
	
	self.clearDetails();
	self.tblChildren.clearAllSelected();
	self.btnUpdate.enabled := false;
	self.btnRemove.enabled := false;
	self.txtUNDG.text := null;
epilog

end;
</source>
        <Parameter name="_pxyObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="btnAdd_click" id="a0eb7886-5ac0-40bb-8d0e-63b04ae16aa7">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2015	cnwdap1		Initial creation PAR #63421 Hazardous Materials Handling
//
vars

begin
	if self.isFromGate then
		if self.isFromPreNote then
			self.doUpdateCMIFAndHazard(true);
		else
			self.doUpdateGTEAndHazard(true);
		endif;
	else
		self.doUpdateTIAndHazard(true);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnRemove_click" id="588627d8-2dc5-47a9-a71e-9657ddd3fbfc">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRemove_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Recording
//
vars

begin
	self.doRemoveHazard();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnUpdate_click" id="d65776cb-2b74-4fc2-96c3-02cd49cb3cb5">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdate_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars

begin
	if self.isFromGate then
		if self.isFromPreNote then
			self.doUpdateCMIFAndHazard(false);
		else
			self.doUpdateGTEAndHazard(false);
		endif;
	else
		self.doUpdateTIAndHazard(false);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clearDetails" id="69796b1b-8b5e-4d90-8c41-390506cbcde5">
        <updating/>
        <source>clearDetails() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars

begin
	self.chkLimitedQty.value := false;
	self.lstSelection.clear;
	self.txtDescription.text := null;
	self.tblWeight.setValueDefault(null);
	self.tblWeight.column := 1;
	self.txtID.text := null;
	self.txtQuantity.text := null;
	
	self.picSymbol1.picture := null;
	self.picSymbol2.picture := null;
	self.picSymbol3.picture := null;
	
	if self.txtID.visible then
		self.txtID.enabled := true;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="ff5778b0-9b9b-471d-8197-4fed1254280f">
        <updating/>
        <source>doOK() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	parentForm : CMUI_ReceiveCargoForm;
	obj : Object;
	proxyGTE : CMGTE_Receival;
	proxyPreNote : CMIF_PreNote;
	hazardsText : String;
	hazards : CM_ObjectSet;

begin	
	if self.isFromGate then
		// Pass all updated attachments back to parent form
		create hazards transient;
		parentForm := self.myParentForm.CMUI_ReceiveCargoForm;
		foreach obj in self.allProxyChildReceivals do
			if obj.isKindOf(CMGTE_Receival) then
				proxyGTE := obj.CMGTE_Receival;
				hazards.add(proxyGTE.allTIHazards.first);
			elseif obj.isKindOf(CMIF_PreNote) then
				proxyPreNote := obj.CMIF_PreNote;
				hazards.add(proxyPreNote.allTIHazards.first);
			endif;
			parentForm.updateAttachments(obj);
		endforeach;
		
		parentForm.lstHazardList.clearSelected();
		parentForm.lstHazardList.setSelected(hazards);
		hazardsText := parentForm.lstHazardList.getSelectedString();
		if hazardsText[hazardsText.length:end] = ';' then
			hazardsText := hazardsText[1:hazardsText.length-1];
		endif;
		parentForm.txtHazards.text := hazardsText;
		
	elseif self.isFromPack then
		// create a new LCL cargo item
		if not self.doSaveForPackForm() then
			return;
		endif;
		
	else
		// coming from the cargo enquiry form - we could have a mixture of new and existing children
		if not self.doSaveForCargoEnquiry() then
			return;
		endif;
		
	endif;
	
	if self.isFromGate or app.myPassport.trxCompletedOK then
		inheritMethod();
	endif;

epilog
	delete hazards;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRemoveHazard" id="584d8126-8358-4738-a31d-00549f2d42fc">
        <updating/>
        <source>doRemoveHazard() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	pxyObject : Object;
	parentForm : CMUI_ReceiveCargoForm;

begin
	if self.tblChildren.row &lt;= self.tblChildren.fixedRows or self.tblChildren.row &gt; self.tblChildren.rows then
		return;
	endif;
	pxyObject := self.tblChildren.accessRow(self.tblChildren.row).itemObject.Object;
	if pxyObject = null then
		return;
	endif;
	
	self.tblChildren.removeItemObject(pxyObject);
	if self.allProxyChildReceivals.includes(pxyObject) then
		self.allProxyChildReceivals.remove(pxyObject);
	endif;
	self.allDeletedProxies.add(pxyObject);
	
	self.clearDetails;
	self.txtUNDG.text := null;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveForCargoEnquiry" id="0bdfbf79-fe1c-4d21-b1b4-075999994be8">
        <updating/>
        <source>doSaveForCargoEnquiry() : Boolean updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	intFaceArray : CMIF_TIObjectArray;
	intFacePreNote : CMIF_PreNote;
	hazard : CM_Hazard;
	newHazard : CM_Hazard;
	row : Integer;
	ti : CM_TrackedItem;
	parentContainer : CM_TrackedItem;
	existingChild : CM_TrackedItem;
	result : Integer;
	errObj : CM_Error;

begin
	create intFaceArray transient;
	parentContainer := self.myProxyTrackedItem.pxyGetRealObject();
	
	foreach row in self.tblChildren.fixedRows + 1 to self.tblChildren.rows do
		ti := self.tblChildren.accessRow(row).itemObject.CM_TrackedItem;
		// is this an existing child item on our TI?
		existingChild := ti.pxyGetRealObject();
		if existingChild &lt;&gt; null then
			continue;
		endif;
		
		create intFacePreNote transient;
		intFacePreNote.setFromTI(ti, self.myTerminal);
	
		intFacePreNote.allTIHazards.clear;
		//foreach hazard in ti.allTIHazards do
		//	create newHazard as CM_TIHazard transient;
		//	newHazard.CM_TIHazard.setProxy(hazard.code, hazard.description, hazard.CM_TIHazard.undgCodes, null, hazard.CM_TIHazard.limitedQuantity, hazard.CM_TIHazard.packingGroup);
		//	intFacePreNote.allTIHazards.add(newHazard);
		//endforeach;
		ti.allTIHazards.copy(intFacePreNote.allTIHazards);
		
		intFaceArray.add(intFacePreNote);
	endforeach;
	
	while true do
		app.myTrxUA.trxUpdateTIHazChildren(intFaceArray, self.myProxyTrackedItem, parentContainer, self.allDeletedProxies, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Prenotes), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			errObj := app.myPassport.getFirstErrorWarning();			
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window

			if errObj &lt;&gt; null then
				self.goToErrorItem(errObj);
			endif;
		endif;
		
		return false;

	endwhile;
	
	return true;
	
epilog
	if intFaceArray &lt;&gt; null then
		intFaceArray.purge;
		delete intFaceArray;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveForPackForm" id="cdcf7296-a17d-4227-a5d5-09279fa30d77">
        <updating/>
        <source>doSaveForPackForm() : Boolean updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
// 09/11/2016	cnwdap1		TFS 2842 Hazardous Details Enhancements
//
vars
	intFaceArray : CMIF_TIObjectArray;
	intFacePreNote : CMIF_PreNote;
	hazard : CM_Hazard;
	newHazard : CM_Hazard;
	row : Integer;
	ti : CM_TrackedItem;
	parentContainer : CM_TrackedItem;
	result : Integer;
	errObj : CM_Error;

begin
	create intFaceArray transient;
	
	foreach row in self.tblChildren.fixedRows + 1 to self.tblChildren.rows do
		ti := self.tblChildren.accessRow(row).itemObject.CM_TrackedItem;
		if ti = null then
			continue;
		endif;
		
		create intFacePreNote transient;
		intFacePreNote.setFromTI(ti, self.myTerminal);
	
		intFacePreNote.allTIHazards.clear;
		foreach hazard in ti.allTIHazards do
			create newHazard as CM_TIHazard transient;
			//newHazard.CM_TIHazard.setProxy(hazard.code, hazard.description, hazard.CM_TIHazard.undgCodes, null, hazard.CM_TIHazard.limitedQuantity, hazard.CM_TIHazard.packingGroup);	// TFS 2842
			newHazard.CM_TIHazard.setProxy(	hazard.code, 									// TFS 2842
											hazard.description, 							// TFS 2842
											hazard.CM_TIHazard.getUndgCodesAsString(false), //25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
											null, 											// TFS 2842
											hazard.CM_TIHazard.limitedQuantity, 			// TFS 2842
											hazard.CM_TIHazard.packingGroup,				// TFS 2842
											hazard.CM_TIHazard.flashpointTemperature,		// TFS 2842
											hazard.CM_TIHazard.isMarinePollutant,			// TFS 2842
											hazard.CM_TIHazard.acidsBases	);				// TFS 2842
			intFacePreNote.allTIHazards.add(newHazard);
		endforeach;
		
		intFaceArray.add(intFacePreNote);
	endforeach;
	
	parentContainer := self.myProxyTrackedItem.pxyGetRealObject();
	
	while true do
		app.myTrxCA.trxCreateTrackedItemsLCL(intFaceArray, null, parentContainer, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Prenotes), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			errObj := app.myPassport.getFirstErrorWarning();			
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window

			if errObj &lt;&gt; null then
				self.goToErrorItem(errObj);
			endif;
		endif;
		
		return false;

	endwhile;
	
	return true;
	
epilog
	if intFaceArray &lt;&gt; null then
		intFaceArray.purge;
		delete intFaceArray;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateCMIFAndHazard" id="adc73e4e-40ba-490c-a028-1a72cd48be27">
        <updating/>
        <source>doUpdateCMIFAndHazard(_add : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
// 09/11/2016	cnwdap1		TFS 2842 Hazardous Details Enhancements
// 01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
vars
	pxyCMIF : CMIF_PreNote;
	pxyHazard : CM_TIHazard;
	hazClass : CM_HazardClass;
	packingGroup : String;
	row : Integer;
	idx : Integer;
	autoIdGen : CM_AutoIdGenerator;
	tiID : String;
	flexiController : CMIF_FlexiGateController;

begin
	if not self.validateDetails then
		return;
	endif;
	
	// are we doing an update or an add?
	if not _add then
		pxyCMIF := self.tblChildren.accessRow(self.tblChildren.row).itemObject.CMIF_PreNote;
	endif;
	if pxyCMIF = null then
		create pxyCMIF transient;
	endif;
	if self.myTerminal.getConfig(AutoGenIDsForChildren).Boolean then
		autoIdGen := self.myTerminal.allAutoIdGenerators[CM_AutoIdGenerator.CargoIdType];
		if autoIdGen = null then
			app.raiseCMException(Must_config_style, "ID", null);
		endif;
		//tiID := autoIdGen.getNextId();   // 1 Sept 2022 navmv20 TFS 54610
		tiID := autoIdGen.getNextId(null, null); //1 Sept 2022 navmv20 TFS 54610
	else
		tiID := self.txtID.text.trimBlanks;
	endif;
	pxyCMIF.id := tiID;
	pxyCMIF.weightTotal := self.tblWeight.getConvertedValue;
	pxyCMIF.numberOfItems := self.txtQuantity.text.trimBlanks.Integer;
	pxyCMIF.quantity := self.txtQuantity.text.trimBlanks.Integer;
	
	pxyCMIF.myTerminal := self.myTerminal;
	pxyCMIF.cargoType := TI_CargoType_LCL;
	pxyCMIF.commodity := self.myTerminal.getConfig(DefHazCommodity).String;
	pxyCMIF.volume := 1;
	pxyCMIF.volumeTotal := 1;
	pxyCMIF.transportMode := TI_TRANSMODE_ROAD_STR;
	
	hazClass := self.lstSelection.listObject.CM_HazardClass;
	pxyHazard := pxyCMIF.allTIHazards[hazClass.code].CM_TIHazard;
	if pxyHazard = null then
		create pxyHazard transient;
	endif;
	
	idx := 1;
	packingGroup := self.lstSelection.text.scanUntil(Space, idx);
	if not packingGroup.isOneOf("I", "II", "III") then
		packingGroup := null;
	endif;
	
	//pxyHazard.setProxy(hazClass.code, self.txtDescription.text.trimBlanks, self.txtUNDG.text.trimBlanks, null, self.chkLimitedQty.value, packingGroup);	// TFS 2842
	pxyHazard.setProxy(	hazClass.code, 								// TFS 2842
						self.txtDescription.text.trimBlanks, 		// TFS 2842
						self.txtUNDG.text.trimBlanks, 				// TFS 2842
						null, 										// TFS 2842
						self.chkLimitedQty.value, 					// TFS 2842
						packingGroup,								// TFS 2842
						NULL_TEMPERATURE,							// TFS 2842
						MarinePollutant_Null,						// TFS 2842
						null	);									// TFS 2842
	if _add then
		pxyCMIF.allTIHazards.add(pxyHazard);
	endif;
	self.addOrUpdateChildEntityInTable(pxyCMIF);
epilog

end;</source>
        <Parameter name="_add" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateGTEAndHazard" id="5a9bbe87-f82f-4b6a-9c3b-a904943dcd04">
        <updating/>
        <source>doUpdateGTEAndHazard(_add : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2015	cnwdap1		Initial creation PAR #63421 Hazardous Materials Handling
// 09/11/2016	cnwdap1		TFS 2842 Hazardous Details Enhancements
//
vars
	pxyGTE : CMGTE_Receival;
	pxyHazard : CM_TIHazard;
	hazClass : CM_HazardClass;
	packingGroup : String;
	row : Integer;
	idx : Integer;
	autoIdGen : CM_AutoIdGenerator;
	tiID : String;
	flexiController : CMIF_FlexiGateController;

begin
	if not self.validateDetails then
		return;
	endif;
	
	// are we doing an update or an add?
	if not _add then
		pxyGTE := self.tblChildren.accessRow(self.tblChildren.row).itemObject.CMGTE_Receival;
	endif;
	if pxyGTE = null then
		create pxyGTE transient;
	endif;
	create flexiController transient;
	self.setFlexiController(flexiController);
	
	hazClass := self.lstSelection.listObject.CM_HazardClass;
	pxyHazard := pxyGTE.allTIHazards[hazClass.code].CM_TIHazard;
	if pxyHazard = null then
		create pxyHazard transient;
	endif;
	
	idx := 1;
	packingGroup := self.lstSelection.text.scanUntil(Space, idx);
	if not packingGroup.isOneOf("I", "II", "III") then
		packingGroup := null;
	endif;
	
	pxyGTE.setPXYFromController(flexiController);
	pxyGTE.setParentObject(self.myParentForm.CMUI_ReceiveCargoForm.myPxyGTEEntity);
	//pxyHazard.setProxy(hazClass.code, self.txtDescription.text.trimBlanks, self.txtUNDG.text.trimBlanks, null, self.chkLimitedQty.value, packingGroup);	// TFS 2842
	pxyHazard.setProxy(	hazClass.code, 								// TFS 2842
						self.txtDescription.text.trimBlanks, 		// TFS 2842
						self.txtUNDG.text.trimBlanks, 				// TFS 2842
						null, 										// TFS 2842
						self.chkLimitedQty.value, 					// TFS 2842
						packingGroup,								// TFS 2842
						NULL_TEMPERATURE,							// TFS 2842
						MarinePollutant_Null,						// TFS 2842
						null	);									// TFS 2842
	pxyGTE.allTIHazards.add(pxyHazard);
	self.addOrUpdateChildEntityInTable(pxyGTE);
epilog

end;</source>
        <Parameter name="_add" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateTIAndHazard" id="6bfc22d2-175d-43be-8fbb-713a471201e6">
        <updating/>
        <source>doUpdateTIAndHazard(_add : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
// 09/11/2016	cnwdap1		TFS 2842 Hazardous Details Enhancements
//
vars
	pxyTI : CM_TrackedItem;
	hazClass : CM_HazardClass;
	pxyHazard : CM_TIHazard;
	idx : Integer;
	packingGroup : String;
	flexi : CMIF_FlexiGateController;

begin
	if not self.validateDetails then
		return;
	endif;
	
	// are we doing an update or an add?
	if not _add then
		pxyTI := self.tblChildren.accessRow(self.tblChildren.row).itemObject.CM_TrackedItem;
	endif;
	if pxyTI = null then
		create pxyTI as CM_LCL transient;
	endif;
	create flexi transient;
	self.setFlexiController(flexi);
	
	hazClass := self.lstSelection.listObject.CM_HazardClass;
	pxyHazard := pxyTI.allTIHazards.first.CM_TIHazard;
	if pxyHazard = null then
		create pxyHazard transient;
	endif;
	
	idx := 1;
	packingGroup := self.lstSelection.text.scanUntil(Space, idx);
	if not packingGroup.isOneOf("I", "II", "III") then
		packingGroup := null;
	endif;
	
	pxyTI.zSetPxyId(flexi.id);
	pxyTI.zSetPxyWeight(flexi.weightTotal);
	pxyTI.setTotalQuantity(flexi.numItems);
	pxyTI.zSetPxyQuantity(flexi.numItems);
	pxyTI.zSetPxyTerminal(flexi.myTerminal);
	pxyTI.zSetPxyCommodity(flexi.commodity);
	pxyTI.zSetPxyTotalVolume(flexi.volumeTotal);
	if not self.myProxyTrackedItem.allChildren.includes(pxyTI) and pxyTI &lt;&gt; self.myProxyTrackedItem then
		pxyTI.setFromParent(self.myProxyTrackedItem, app.myPassport);
	endif;
	pxyTI.changeOperator(self.myProxyTrackedItem.myOperator, app.myPassport);
	//pxyHazard.setProxy(hazClass.code, self.txtDescription.text.trimBlanks, self.txtUNDG.text.trimBlanks, pxyTI, self.chkLimitedQty.value, packingGroup);	// TFS 2842
	pxyHazard.setProxy(	hazClass.code, 									// TFS 2842
						self.txtDescription.text.trimBlanks, 			// TFS 2842
						self.txtUNDG.text.trimBlanks, 					// TFS 2842
						pxyTI, 											// TFS 2842
						self.chkLimitedQty.value, 						// TFS 2842
						packingGroup,									// TFS 2842
						NULL_TEMPERATURE,								// TFS 2842
						MarinePollutant_Null,							// TFS 2842
						null	);										// TFS 2842
	self.addOrUpdateChildEntityInTable(pxyTI);
	
epilog
	delete flexi;
end;</source>
        <Parameter name="_add" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateDetails" id="e0a15544-240a-4dac-a111-9ace0dead870">
        <updating/>
        <source>populateDetails(_pxyObj : Object) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	hazard : CM_TIHazard;
	selection : String;
	undg : CM_UNDangerousGoods;
	idx : Integer;
	id : String;
	weight : Decimal [14,6];
	quantity : Integer;

begin
	if _pxyObj = null then
		return;
	endif;
	
	if _pxyObj.isKindOf(CMGTE_Receival) then
		hazard := _pxyObj.CMGTE_Receival.allTIHazards.first.CM_TIHazard;
		id := _pxyObj.CMGTE_Receival.id;
		weight := _pxyObj.CMGTE_Receival.weightTotal;
		quantity := _pxyObj.CMGTE_Receival.totalQuantity;
	elseif _pxyObj.isKindOf(CM_TrackedItem) then
		hazard := _pxyObj.CM_TrackedItem.allTIHazards.first.CM_TIHazard;
		id := _pxyObj.CM_TrackedItem.id;
		weight := _pxyObj.CM_TrackedItem.totalWeight;
		quantity := _pxyObj.CM_TrackedItem.quantity;
	elseif _pxyObj.isKindOf(CMIF_PreNote) then
		hazard := _pxyObj.CMIF_PreNote.allTIHazards.first.CM_TIHazard;
		id := _pxyObj.CMIF_PreNote.id;
		weight := _pxyObj.CMIF_PreNote.weightTotal;
		quantity := _pxyObj.CMIF_PreNote.quantity;
	endif;
	if hazard = null then
		return;
	endif;
	
	undg := app.myRoot.allUNDangerousGoodsCodes[hazard.allUNDGCodes.first];
	self.showUNDGCode(undg);
	if hazard.packingGroup &lt;&gt; null then
		selection := hazard.packingGroup &amp; Space;
	endif;
	selection := selection &amp; hazard.code &amp; Space &amp; undg.description;
	
	self.txtUNDG.text := hazard.allUNDGCodes.first;
	self.txtUNDG_change(self.txtUNDG);
	self.chkLimitedQty.value := hazard.limitedQuantity;
	idx := self.lstSelection.findStringExact(1, selection);
	if idx &gt; 0 then
		self.lstSelection.itemSelected[idx] := true;
		self.lstSelection.listIndex := idx;
	endif;
	self.txtDescription.text := hazard.description;
	self.tblWeight.setValueDefault(weight.String);
	self.txtID.text := id;
	self.txtQuantity.text := quantity.String;
	
	// this is an existing TI / receival - id cannot be changed
	self.txtID.enabled := false;
epilog

end;</source>
        <Parameter name="_pxyObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setAllProxyChildReceivals" id="70da1973-95dc-42c8-9591-1251601f2e87">
        <source>setAllProxyChildReceivals(_attachments : ObjectArray);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 28/07/2016	cnwdap1		Initial creation TFS #2384 Correct handling of attachments when using new hazardous child form
//							Only items with hazards should be shown on this screen
//
vars
	gteReceival : CMGTE_Receival;
	cmifReceival : CMIF_Receival;
	ti : CM_TrackedItem;
	obj : Object;

begin
	// Filter non-hazardous attachments out of this screen - we're not interested in them
	foreach obj in _attachments do
		if obj.isKindOf(CMGTE_Receival) and obj.CMGTE_Receival.allTIHazards.isEmpty then
			continue;
		elseif obj.isKindOf(CMIF_Receival) and obj.CMIF_Receival.allTIHazards.isEmpty then
			continue;
		elseif obj.isKindOf(CM_TrackedItem) and obj.CM_TrackedItem.allTIHazards.isEmpty then
			continue;
		endif;
		
		self.allProxyChildReceivals.add(obj);
	endforeach;
epilog

end;</source>
        <Parameter name="_attachments" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setFlexiController" id="11b5915b-5f0b-443d-bc82-084cfb989ff3">
        <updating/>
        <source>setFlexiController(_flexi : CMIF_FlexiGateController input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
vars
	autoIdGen : CM_AutoIdGenerator;
	tiID : String;

begin
	if self.isFromGate and self.myTerminal.getConfig(AutoGenIDsForChildren).Boolean then
		autoIdGen := self.myTerminal.allAutoIdGenerators[CM_AutoIdGenerator.CargoIdType];
		if autoIdGen = null then
			app.raiseCMException(Must_config_style, "ID", null);
		endif;
		//tiID := autoIdGen.getNextId();   // 1 Sept 2022 navmv20 TFS 54610
		tiID := autoIdGen.getNextId(null, null); // 1 Sept 2022 navmv20 TFS 54610
	else
		tiID := self.txtID.text.trimBlanks;
	endif;
	_flexi.id := tiID;
	_flexi.weightTotal := self.tblWeight.getConvertedValue;
	_flexi.numItems := self.txtQuantity.text.trimBlanks.Integer;
	_flexi.quantity := self.txtQuantity.text.trimBlanks.Integer;
	
	_flexi.myTerminal := self.myTerminal;
	_flexi.cargoType := TI_CargoType_LCL;
	_flexi.jobType := CMGTE_Entity.JobType_FullIN;
	_flexi.commodity := self.myTerminal.getConfig(DefHazCommodity).String;
	_flexi.volume := 1;
	_flexi.volumeTotal := 1;
	
epilog

end;</source>
        <Parameter name="_flexi" type="CMIF_FlexiGateController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromForm" id="614fe999-5ee8-49cb-8927-99bb68fc2666">
        <updating/>
        <source>setFromForm(_isFromPackingForm, _isFromGateForm, _isFromPreNote : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars

begin
	self.isFromGate := _isFromGateForm;
	self.isFromPack := _isFromPackingForm;
	self.isFromPreNote := _isFromPreNote;
epilog

end;</source>
        <Parameter name="_isFromPackingForm" type="Boolean"/>
        <Parameter name="_isFromGateForm" type="Boolean"/>
        <Parameter name="_isFromPreNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyMasterItems" id="0181bbc1-1cad-4455-850b-79a5a78b3563">
        <updating/>
        <source>setMyMasterItems(_pxyTI : CM_TrackedItem; _pxyGTE : CMGTE_Receival; _booking : CM_BookingRef) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars

begin
	self.myProxyTrackedItem		:= _pxyTI;
	self.myProxyGTEReceival 	:= _pxyGTE;
	self.myBooking 				:= _booking;
epilog

end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
        <Parameter name="_pxyGTE" type="CMGTE_Receival"/>
        <Parameter name="_booking" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3bdfab94-c3d4-4957-a310-442a06ba80f3">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	generateIDs : Boolean;
	obj : Object;
	pxyGTE : CMGTE_Receival;
	pxyTI : CM_TrackedItem;

begin
	inheritMethod();
	
	// do we need to show the ID field, or are we generating it automatically?
	generateIDs := self.myTerminal.getConfig(AutoGenIDsForChildren).Boolean;
	if generateIDs and self.isFromGate then
		self.lblID.visible := false;
		self.txtID.visible := false;
	endif;
	
	self.setupTable();
	self.tblWeight.setup(Type_Weight, self.backColor);
	self.btnUpdate.enabled := false;
	self.btnRemove.enabled := false;
	
	if self.isFromGate then
		foreach obj in self.allProxyChildReceivals do
			self.tblUpdateItemObject(obj, self.colorRow1, self.colorRow2, app.myPassport);
		endforeach;
	elseif not self.isFromPack then
		foreach pxyTI in self.myProxyTrackedItem.allChildren do
			if pxyTI.allTIHazards.isEmpty then
				continue;
			endif;
			self.tblChildren.updateItemObject(pxyTI, self.colorRow1, self.colorRow2, app.myPassport);
		endforeach;
		if self.myProxyTrackedItem.isChild then
			self.tblChildren.updateItemObject(self.myProxyTrackedItem, self.colorRow1, self.colorRow2, app.myPassport);
		endif;
	endif;
	
	if CM_ContainerEnqForm.hasInstance(self.myParentForm) then
		// don't allow delete of existing child cargo items
		self.btnRemove.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTable" id="29a98b31-03f3-41d6-82a7-4c5f7e97e8ba">
        <updating/>
        <source>setupTable() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Material Handling
//
vars
	table : CM_DataTable;
	theDef : EntTableDef;

begin
	table := self.tblChildren;
	table.rows := table.fixedRows;
	
	table.columns := 7;
	theDef := app.myController.getEntTableDef(ETDef_HazardEntry);
	if theDef &lt;&gt; null then
		table.setTblDataEntRowsFromDef(theDef);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "EntTableDef 'Hazard Entry' not found");
	endif;
	table.accessColumn(1).width := 75;
	table.accessColumn(2).width := 50;
	table.accessColumn(3).width := 200;
	table.accessColumn(7).width := 70;
	table.cnEcResizeContents();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showUNDGCode" id="c17916ca-082e-448e-9c45-3bcb54a40d96">
        <updating/>
        <source>showUNDGCode(_undgCode : CM_UNDangerousGoods) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	hazardClass : CM_HazardClass;
	packingGroup : String;
	classCode : String;
	symbols : ObjectArray;

begin
	if _undgCode = null then
		return;
	endif;
	
	self.lstSelection.clear;
	create symbols transient;
	
	// put an entry in the list box for the main hazard class and each packing group
	hazardClass := _undgCode.myHazardClass;
	if hazardClass = null then
		return;
	endif;
	hazardClass.getSymbols(symbols);
	if _undgCode.allPackingGroups.isEmpty then
		self.lstSelection.cnEcAddItemDataObject(hazardClass.code &amp; Space &amp; _undgCode.description, 0, hazardClass);
	else
		foreach packingGroup in _undgCode.allPackingGroups do
			self.lstSelection.cnEcAddItemDataObject(packingGroup &amp; Space &amp; hazardClass.code &amp; Space &amp; _undgCode.description, 0, hazardClass);
		endforeach;
	endif;
	
	// also put an entry in the list box for each other hazard class and each packing group
	foreach classCode in _undgCode.allClassCodes do
		hazardClass := app.myRoot.allHazardClasses[classCode];
		if hazardClass &lt;&gt; null then
			hazardClass.getSymbols(symbols);
			if _undgCode.allPackingGroups.isEmpty then
				self.lstSelection.cnEcAddItemDataObject(hazardClass.code &amp; Space &amp; _undgCode.description, 0, hazardClass);
			else
				foreach packingGroup in _undgCode.allPackingGroups do
					self.lstSelection.cnEcAddItemDataObject(packingGroup &amp; Space &amp; hazardClass.code &amp; Space &amp; _undgCode.description, 0, hazardClass);
				endforeach;
			endif;
		endif;
	endforeach;
	
	// display symbols
	self.picSymbol1.clearGraphics();
	self.picSymbol2.clearGraphics();
	self.picSymbol3.clearGraphics();
	if not symbols.isEmpty then
		self.picSymbol1.picture := symbols[1].CM_Symbol.getPhotoContent;
		if symbols.size &gt; 1 then
			self.picSymbol2.picture := symbols[2].CM_Symbol.getPhotoContent;
			if symbols.size &gt; 2 then
				self.picSymbol3.picture := symbols[3].CM_Symbol.getPhotoContent;
			endif;
		endif;
	endif;
	
epilog
	delete symbols;
end;</source>
        <Parameter name="_undgCode" type="CM_UNDangerousGoods"/>
    </JadeMethod>
    <JadeMethod name="tblChildren_click" id="99e7573c-2414-4677-8a09-51c9adcff8a7">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblChildren_click(table: Table input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	row : Integer;
	pxyObj : Object;

begin
	foreach row in table.fixedRows +1 to table.rows do
		table.accessRow(row).selected := false;
		if table.row = row then
			table.accessRow(row).selected := true;
		endif;
	endforeach;
	
	if table.row &gt; table.fixedRows and table.row &lt;= table.rows then
		if table.accessRow(table.row).itemObject &lt;&gt; null then
			self.btnUpdate.enabled := true;
			self.btnRemove.enabled := true;
			pxyObj := table.accessRow(table.row).itemObject;
			self.populateDetails(pxyObj);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblUpdateItemObject" id="2a952751-b5f3-43d0-a074-dd9a1b3401ab">
        <updating/>
        <source>tblUpdateItemObject(_object : Object; _colour1, _colour2 : Integer; _passport : CM_Passport) : Integer updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	rowIdx : Integer;
	str	: String;
	failedDAC : CM_DataAccessController;
	invalid : Boolean;
	pxyGTE : CMGTE_Entity;
	pxyCMIF : CMIF_Object;

begin
	if _object = null or 
		(self.tblChildren.myDataClass &lt;&gt; null and
		not self.tblChildren.myDataClass.hasInstance(_object)) then
		return 0;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _object, invalid);
	if _object.isKindOf(CM_Object) then
		str := _object.CM_Object.getAttributeStringForDefArray(self.tblChildren.allTblDataEntRows);
	elseif _object.isKindOf(CMIF_Object) then
		str := _object.CMIF_Object.getAttributeStringForDefArray(self.tblChildren.allTblDataEntRows);
	endif;
	
	if invalid then
		return 0;
	endif;
	
	if not self.tblChildren.findObjectInRow(_object, rowIdx) then
		//not in table
		rowIdx := self.tblChildren.addItemObject(_object, str);
		if _colour1 &lt;&gt; null and _colour2 &lt;&gt; null then
			if rowIdx mod 2 = 0 then
				self.tblChildren.accessRow(rowIdx).backColor := _colour1;
			else
				self.tblChildren.accessRow(rowIdx).backColor := _colour2;
			endif;	
		endif;
	else
		self.tblChildren.setCellText(rowIdx, 1, str);
	endif;
	
	return rowIdx;

epilog

end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_colour1" type="Integer"/>
        <Parameter name="_colour2" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="60132186-fe1c-486b-9c57-8ba113112a27">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 August 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020719, locale);
	btnAdd.translateCaption(Xlat_0020720, locale);
	btnRemove.translateCaption(Xlat_0020721, locale);
	btnUpdate.translateCaption(Xlat_0020722, locale);
	chkLimitedQty.translateCaption(Xlat_0020723, locale);
	lblDescription.translateCaption(Xlat_0020724, locale);
	lblID.translateCaption(Xlat_0020725, locale);
	lblNote.translateCaption(Xlat_0020726, locale);
	lblQuantity.translateCaption(Xlat_0020727, locale);
	lblSelection.translateCaption(Xlat_0020728, locale);
	lblSymbols.translateCaption(Xlat_0020729, locale);
	lblUNDG.translateCaption(Xlat_0020730, locale);
	lblWeight.translateCaption(Xlat_0020731, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtUNDG_change" id="100393dd-99be-491d-b17a-eace97831e50">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtUNDG_change(textbox: TextBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10 June 2015	cnwdap1		Initial creation PAR #
//
vars
	undgString : String;
	undgCode : CM_UNDangerousGoods;

begin
	undgString := textbox.text.trimBlanks;
	undgCode := app.myRoot.allUNDangerousGoodsCodes[undgString];
	if undgCode &lt;&gt; null then
		self.showUNDGCode(undgCode);
	else
		self.clearDetails();
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="fa8fc2c4-b400-4cec-b425-cdab0529c247">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>unloadForm(): Boolean updating, clientExecution;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	obj : Object;

begin
	if self.modalResult = IDCANCEL then
		if self.isFromGate then
			if not self.myParentForm.CMUI_ReceiveCargoForm.hasAttachments then
				self.allProxyChildReceivals.purge;
			endif;
		elseif self.myParentForm.isKindOf(CM_ContainerEnqForm) then
			self.allDeletedProxies.purge;
		endif;
	elseif self.modalResult = IDOK then
		foreach obj in self.allDeletedProxies do
			if self.isFromGate then
				self.myParentForm.CMUI_ReceiveCargoForm.removeAttachment(obj);
			elseif CM_ContainerEnqForm.hasInstance(self.myParentForm) then
				self.myProxyTrackedItem.detachChild(obj.CM_TrackedItem);
			endif;
		endforeach;
			
		self.allDeletedProxies.purge;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateDetails" id="2fac7485-e109-44a2-af5b-3b341c3f6204">
        <updating/>
        <source>validateDetails() : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	hazardClass : CM_HazardClass;
	hazard : CM_Hazard;
	found : Boolean;
	result : Integer;

begin
	// validate the input
	// required fields are UNDG code, one selection in the Selection list, weight, id (if not hidden) and quantity
	if self.txtUNDG.text.trimBlanks = null then
		app.raiseCMException(Input_required_field_UN_Number, "UN Number", null);
		self.txtUNDG.setFocus;
		return false;
	endif;
	
	if self.lstSelection.selectedCount = 0 then
		app.raiseCMException(Input_required_Selection, "Selection", null);
		self.lstSelection.setFocus;
		return false;
	endif;
	
	if self.tblWeight.getRawValue() = null then
		app.raiseCMException(Input_required_field_weight, "Weight", null);
		self.tblWeight.setFocus;
		return false;
	endif;
	
	if self.txtID.visible and self.txtID.text.trimBlanks = null then
		app.raiseCMException(Input_required_field_Id, "ID", null);
		self.txtID.setFocus;
		return false;
	endif;
	
	if self.txtQuantity.text.trimBlanks = null then
		app.raiseCMException(Input_required_field_quantity, "Quantity", null);
		self.txtQuantity.setFocus;
		return false;
	endif;
	
	// check that selected hazard class is listed on the booking if we have a booking
	if self.myBooking &lt;&gt; null then
		hazardClass := self.lstSelection.itemObject[self.lstSelection.listIndex].CM_HazardClass;
		found := false;
		foreach hazard in self.myBooking.allTIHazards do
			if hazard.code = hazardClass.code then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			result := app.msgBox(app.getErrorString2(Hazard_Not_Part_Of_Booking, hazardClass.code, self.myBooking.bookingReference), app.getErrorString(Warning), MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon);
			if result = MsgBox_Return_Cancel then
				return false;
			endif;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
