    <DbClassMap file="CnEcXML"/>
    <JadeMethod name="asXMLMessage" id="001890e0-1705-450a-8a57-9beb396fe23b">
        <source>asXMLMessage(): String;
// --------------------------------------------------------------------------------
// Created:		05 February 2009 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	xmlMessage	: String;
	
begin
	if self.tagName = null then
		return null;
	else
		xmlMessage	:=	"&lt;" &amp; self.tagName;
		
		if self.tagAttribute = null then
			xmlMessage	:=	xmlMessage &amp; "&gt;";
		else
			xmlMessage	:=	xmlMessage &amp; " " &amp; self.tagAttribute &amp; "&gt;";
		endif;
		
		xmlMessage	:=	xmlMessage &amp; self.tagData &amp; "&lt;/" &amp; self.tagName &amp; "&gt;";
		return xmlMessage;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="errorFormat" id="f305658c-8f86-449b-923a-6aa650343889">
        <source>errorFormat():String;

vars
	output : String;
	
begin
	output := "&lt;" &amp; self.tagName &amp; "&gt;" &amp; self.tagData &amp; "&lt;/" &amp; self.tagName &amp; "&gt;"; 

	return output;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="findAllStructures" id="2ecff3b4-76b9-4e15-ac95-4725aedd8007">
        <source>findAllStructures(pName: String; pStructureSet: CnEcXmlStructureInstanceSet io);
// Method:	findAllStructures	
// Author:	cnwka1
// Created:	13 June 2000
//
// Purpose:	
//
// Parameters:
//
// Name		Purpose
// ---------------- -----------------------------------------------
//
// Returns:	
//
begin
	if pName = self.tagName then
		pStructureSet.add(self);
	endif;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pStructureSet" type="CnEcXmlStructureInstanceSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="findStructure" id="ffdf6edf-46e2-4899-852a-5174c3730de1">
        <source>findStructure(pName: String): CnEcXmlStructureInstance;
// Method:	findStructure	
// Author:	cnwka1
// Created:	13 June 2000
//
// Purpose:	
//
// Parameters:
//
// Name		Purpose
// ---------------- -----------------------------------------------
//
// Returns:	
//
begin
	if self.tagName = pName then
		return self;
	else
		return null;
	endif;
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="CnEcXmlStructureInstance"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="3c0ff4de-182e-4bc0-a700-643ba989f29a">
        <updating/>
        <source>initializeMe(pName: String; pData: String; pAttrib: String) updating;
// --------------------------------------------------------------------------------
// Created:		21 February 2002 by cnwdad1
//
// Purpose:		Refer to method details on superclass.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(pName, pData, pAttrib);
	self.tagData	:= pData;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pData" type="String"/>
        <Parameter name="pAttrib" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadListBox" id="61e13125-9be6-4de9-9b1d-4cacd5ce7f12">
        <updating/>
        <source>loadListBox(pListBox: ListBox input; pLevel: Integer io) updating;

vars
	showString	: String;
	
begin
	showString := self.tagName &amp; Tab &amp; self.tagData;
	
	if self.tagAttribute &lt;&gt; null then
		showString := showString &amp; Tab &amp; "(" &amp; self.tagAttribute &amp; ")";
	endif;
	
	pListBox.addItem(showString);
	pListBox.itemLevel[pListBox.newIndex] := pLevel;
end;</source>
        <Parameter name="pListBox" type="ListBox" usage="input"/>
        <Parameter name="pLevel" type="Integer" usage="io"/>
    </JadeMethod>
</Class>
