    <JadeMethod name="getWorkOrderTaskIdByClass" id="526b277f-6e50-4315-bf29-60c5819bf741">
        <source>getWorkOrderTaskIdByClass():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	wodTaskId : Integer;
begin
	
	if self.isKindOf(CM_WodMove) then
		wodTaskId := WO_TASK_MOVE;
	elseif  self.isKindOf(CM_WodNullVoyage) then
		wodTaskId := WO_TASK_CHANGEVOYAGE;
	elseif  self.isKindOf(CM_WodPack) then
		wodTaskId := WO_TASK_PACK;
	elseif  self.isKindOf(CM_WodUnpack) then
		wodTaskId := WO_TASK_UNPACK;
	elseif  self.isKindOf(CM_WodReceive) then
		wodTaskId := WO_TASK_RECEIVE;	
	elseif  self.isKindOf(CM_WodRelease) then
		wodTaskId := WO_TASK_RELEASE;	
	elseif  self.isKindOf(CM_WodReleaseExtension) then
		wodTaskId := WO_TASK_RELEASEEXTENSION;	
	elseif  self.isKindOf(CM_WodToDo) then
		wodTaskId := WO_TASK_TODO;	
	elseif  self.isKindOf(CM_WodExportReturn) then
		wodTaskId := WO_TASK_EXPORTRETURN;
	endif;
	
	return wodTaskId;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
