/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 19 December 2018
TFS#		: 40200
Function	:

*** Changes ***
Date			Name		TFS#		Description
30/01/2019		jlgka1		40200		As a result of Peer review change from description to code
										as the query is not working.
****************************************************/
vars
	trans : HMS_VTMISTransaction;
begin

	trans := self.myTransactionHMS;
	if trans = null or trans.myResourceUsed = null then
		return null;
	endif;
	
	return trans.myResourceUsed.code;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
