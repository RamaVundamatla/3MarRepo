    <JadeMethod name="notifyFinishOfTask" id="c854a43e-38bc-43f5-9a48-86820dec1afa">
        <updating/>
        <source>notifyFinishOfTask(pIsSuccessful : Boolean) protected, updating;
// -----------------------------------------------------------------------------
// Created:		19 December 2001 by cnwndl1
//
// Purpose:		Updates the tasks completed timestamp and notifies the monitor.
//
// Parameters:	pIsSuccessful - True if the task completed successfully.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	beginTransaction;
	self.setCompletedTimeStamp(app.actualTimeServer(), pIsSuccessful);// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	commitTransaction;
end;</source>
        <access>protected</access>
        <Parameter name="pIsSuccessful" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="notifyStartOfTask" id="31dbd9a0-5bbe-479c-ad70-cff37f6f4efc">
        <updating/>
        <source>notifyStartOfTask() protected, updating;
// -----------------------------------------------------------------------------
// Created:		19 December 2001 by cnwndl1
//
// Purpose:		Updates the tasks running and scheduled flags.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	beginTransaction;
		self.isRunning		:=	true;
		self.isScheduled	:=	false;
	commitTransaction;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="rescheduleMe" id="2a3b814f-a52d-4edf-b363-bc9a5fcb8e66">
        <updating/>
        <source>rescheduleMe() updating;

begin	
	self.taskComment	:=	"Rescheduled.";
	self.scheduleMe();
end;</source>
    </JadeMethod>
    <JadeMethod name="scheduleMe" id="1df8ec7c-bf7e-41a0-9b3c-b220bf800b2b">
        <updating/>
        <source>scheduleMe() updating;

vars
	now			: TimeStamp;
	nowMinutes	: Integer;
	schedMins	: Integer;
	delay		: Integer;
	
begin
	now := app.actualTimeServer();
	
	if now.Date = self.scheduleTimeStamp.Date then
		nowMinutes	:=	self.getMinutesAfterMidnight(now.Time); 
		schedMins	:=	self.getMinutesAfterMidnight(self.scheduleTimeStamp.Time);
		
		if nowMinutes &gt; schedMins then	// start immediately.
			delay := 2000;			
		else	// start in x mins
			delay := (schedMins - nowMinutes) * 60000;
			
			if delay &lt; 2000 then
				delay := 2000;
			endif;
		endif;
		
		self.beginTimer(delay, Timer_OneShot, self.DO_TASK);
		self.isScheduled := true;
		  
	elseif now.Date &gt; self.scheduleTimeStamp.Date then
		// scheduled for yesterday or earlier - delete it.
		delete self;
		return;
		
	elseif now.Date &gt; self.scheduleTimeStamp.Date then
		// the Mgr will aleady be scheduled to check again at midnight.
		return;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCompletedTimeStamp" id="619f8adb-cfd1-4647-9c0b-2aec8a746385">
        <updating/>
        <source>setCompletedTimeStamp(pCompletedTimeStamp : TimeStamp; pIsSuccessful : Boolean) updating, protected;
// -----------------------------------------------------------------------------
// Created:		17 June 2003 by cnwdad1
//
// Purpose:		Sets a flag to indicate that the task has completed.
//
// Parameters:	None
//
// Returns:		True if the update was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 17/06/2003	cnwdad1		Added the isRescheduleDaily and isRunEveryNMinutes
//							to the CnEcBackShedTask class.
// 09/01/2004	cnwdad1		Changed parameters 4 to 6 to send local property values
//							instead of false.
// -----------------------------------------------------------------------------
vars
	rescheduleTimeStamp	: TimeStamp;
	
begin
	self.completedTimeStamp	:=	pCompletedTimeStamp;
	self.isRunning			:=	false;
	self.isComplete			:=	true;
	
	if pIsSuccessful then
		self.taskComment	:=	self.SUCCESS;
		self.isFailed		:=	false;
		rescheduleTimeStamp	:=	self.getNextScheduleTime();
		
		if rescheduleTimeStamp &lt;&gt; null then
			commitTransaction;
// cnwdad1 09/01/2004 - Changed parameters 4 to 6 to send local property values instead of false.
//			self.myManager.createTask(	self.class(),	//_taskType : Class;
//										self.taskName,	//_taskName : String;
//										rescheduleTimeStamp,	//_startTime : TimeStamp;
//										false,	//_isOneTimeOnly : Boolean;
//										false,	// _isRescheduleDaily
//										false,	// _isRunEveryNMinutes
//										self.isRestartOnFailure,	//_doRestartOnFailure : Boolean;
//										self.daysToExecute,	//_daysToExecute : String;
//										self.daysToExecuteTime,	//_daysToExecuteTime : Time;
//										self.minsBetweenExecution,	//_minsBetweenExecution : Integer
//										self.isCustomSchedule	//_useCustomSchedule : Boolean;
//										);
			self.myManager.createTask(	self.class(),	//_taskType : Class;
										self.taskName,	//_taskName : String;
										rescheduleTimeStamp,	//_startTime : TimeStamp;
										self.isOneTimeOnly,	//_isOneTimeOnly : Boolean;
										self.isRescheduleDaily,	// _isRescheduleDaily
										self.isRunEveryNMinutes,	// _isRunEveryNMinutes
										self.isRestartOnFailure,	//_doRestartOnFailure : Boolean;
										self.daysToExecute,	//_daysToExecute : String;
										self.daysToExecuteTime,	//_daysToExecuteTime : Time;
										self.minsBetweenExecution,	//_minsBetweenExecution : Integer
										self.isCustomSchedule	//_useCustomSchedule : Boolean;
										);
			beginTransaction;
		else
			//write "completed, no reschedule requested";								
		endif;		
	else
		self.isFailed		:=	true;
		
		if self.isRestartOnFailure then
			self.rescheduleMe();
		else
			//write "failed no restart requested";			
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pCompletedTimeStamp" type="TimeStamp"/>
        <Parameter name="pIsSuccessful" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setInterrupted" id="281fb4eb-e64a-4454-9aa7-9958a752905b">
        <updating/>
        <source>setInterrupted() updating;

begin
	self.taskComment	:=	"Background app shutdown during processing";
	self.setCompletedTimeStamp(self.scheduleTimeStamp, false);
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="e74d1085-23e7-477a-9123-1adb6d6a9547">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

begin
	if eventTag = self.DO_TASK then
		self.doTask();
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="0818a7c8-261e-4734-bb39-989e05be1606">
        <updating/>
        <source>updateMe(	pTaskName : String;
			pStartTime : TimeStamp;
			pIsOneTimeOnly : Boolean;
			pIsRescheduleDaily:Boolean;
			pIsRunEveryNMinutes:Boolean;
			pDoRestartOnFailure : Boolean;
			pDaysToExecute : String;
			pDaysToExecuteTime : Time;
			pMinsBetweenExecution : Integer;
			pUseCustomSchedule : Boolean) updating;
// -----------------------------------------------------------------------------
// Created:		15 December 2001 by cnwdad1
//
// Purpose:		Updates the receiver's properties.
//
// Parameters:	Matching property parameters.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 17/06/2003	cnwdad1		Added the isRescheduleDaily and isRunEveryNMinutes
//							attributes.
// -----------------------------------------------------------------------------
begin
	beginTransaction;
	
	self.scheduleTimeStamp		:=	pStartTime;
	self.isOneTimeOnly			:=	pIsOneTimeOnly;
	self.isRescheduleDaily		:=	pIsRescheduleDaily;
	self.isRunEveryNMinutes		:=	pIsRunEveryNMinutes;
	self.isRestartOnFailure		:=	pDoRestartOnFailure;
	self.daysToExecute			:=	pDaysToExecute;
	self.daysToExecuteTime		:=	pDaysToExecuteTime;
	self.minsBetweenExecution	:=	pMinsBetweenExecution;
	self.isCustomSchedule 		:=	pUseCustomSchedule;
	
	self.taskName				:=	pTaskName;
	
	commitTransaction;
end;</source>
        <Parameter name="pTaskName" type="String"/>
        <Parameter name="pStartTime" type="TimeStamp"/>
        <Parameter name="pIsOneTimeOnly" type="Boolean"/>
        <Parameter name="pIsRescheduleDaily" type="Boolean"/>
        <Parameter name="pIsRunEveryNMinutes" type="Boolean"/>
        <Parameter name="pDoRestartOnFailure" type="Boolean"/>
        <Parameter name="pDaysToExecute" type="String"/>
        <Parameter name="pDaysToExecuteTime" type="Time"/>
        <Parameter name="pMinsBetweenExecution" type="Integer"/>
        <Parameter name="pUseCustomSchedule" type="Boolean"/>
    </JadeMethod>
</Class>
