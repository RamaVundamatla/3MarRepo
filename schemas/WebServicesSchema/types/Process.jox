<Class name="Process">
    <JadeMethod name="dumpTransientsDb2" id="56c57b42-02be-4827-bf97-5ea6b359da8e">
        <source>dumpTransientsDb2(_str : String);
/*

Purpose:			
	To assist in finding transient leaks in the webServiceSchema. 
Parameters:			

Return Value:		

Date		Who		Reason
28 January 2015	cnwdb2	Initial creation

*/



vars
	obj 			: Object;
	message 		: String;
	aLock			: Lock;
	objArray		: ObjectArray;
	
begin
	
	create objArray transient;
	
	process.allTransientInstances(objArray, 0);
	
	foreach obj in objArray do
		
		if not obj.isKindOf(WS_BulkReleaseType) then
			continue;
		endif;
		
		write _str &amp; Tab &amp; obj.String;		
		
	endforeach;

epilog
	
	delete objArray;
	
end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setUserInfo" id="112e812e-2c6f-4238-9e5f-56b7d8e2cc8c">
        <updating/>
        <source>setUserInfo(_info : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jul 2019 jlgmd1	TFS 45661 - Add some useful debug info to be able to tell what a web services is doing from monitor

*/

vars

begin
	beginTransaction;
	self.userInfo := _info;
	commitTransaction;
epilog

end;</source>
        <Parameter name="_info" type="String"/>
    </JadeMethod>
</Class>
