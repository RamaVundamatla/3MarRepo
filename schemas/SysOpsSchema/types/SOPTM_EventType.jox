    <JadeMethod name="initShtMultiSelect" id="a9c96366-728a-4083-b2ac-f130631317f0">
        <source>initShtMultiSelect();
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm	: SOP_TableMaintForm;
	
begin

	theForm := self.myForm;
	inheritMethod;
	
	//self.setupMultiSelect1('Error/Warning Messages',null,SOP_TableMaintForm::displayEntryEventType.name);
	self.setupMultiSelect1(app.getErrorString(Error_warning_messages),null,SOP_TableMaintForm::displayEntryEventType.name);
	theForm.mulSelect1.setSorted(true);
	theForm.mulSelect1.availableHeading := app.getErrorString(Available);	// 29 Oct 2009	NDL	Par 21519
	theForm.mulSelect1.selectedHeading := app.getErrorString(Selected);		// 29 Oct 2009	NDL	Par 21519
	
	
	//search messages button
	theForm.btnShowSearchMsg.parent := theForm.shtMultiSelect1;
	theForm.btnShowSearchMsg.top := 5;
	theForm.btnShowSearchMsg.left := 140;
	theForm.btnShowSearchMsg.width := 65;
	theForm.btnShowSearchMsg.visible := true;
	theForm.btnShowSearchMsg.enabled := true;
	
	//Load the multi select box with the exception messages from locale '0000'
	theForm.myAssistant.multiSelectExceptions(theForm.mulSelect1);

end;</source>
    </JadeMethod>
