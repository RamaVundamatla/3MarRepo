<GUIClass name="MB_CalendarButton" id="0ff09239-6a0d-453d-afc5-2059fcc41e0b">
    <superclass name="Button"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myCalendar" id="503a706b-58cb-47f6-a251-d8e963920f3c">
        <embedded/>
        <type name="MB_Calendar"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="click" id="b8b56afc-cb38-4cb0-a8aa-16b71e611b6c">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(btn: Button input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateDay		: Integer;
	dateMonth	: Integer;
	dateYear	: Integer;
	
begin
	inheritMethod(btn);
	
	if self.myCalendar = null then
		if btn.parent &lt;&gt; null then
			if btn.parent.isKindOf(MB_Calendar) then
				self.myCalendar := btn.parent.MB_Calendar;
			endif;
		endif;
	endif;
	
	if self.myCalendar = null then
		return;
	endif;
	
	dateDay		:=	self.myCalendar.date.day;
	dateMonth	:=	self.myCalendar.date.month;
	dateYear	:=	self.myCalendar.date.year;
	
	if btn = self.myCalendar.myPrevMonthButton then
		dateMonth	:=	dateMonth - 1;
		
		if dateMonth &lt; 1 then
			dateMonth	:=	12;
			dateYear	:=	dateYear - 1;
		endif;
		
		self.myCalendar.changeType	:=	self.myCalendar.ChangeType_Month;
		
	elseif btn = self.myCalendar.myNextMonthButton then
		dateMonth	:=	dateMonth + 1;
		
		if dateMonth &gt; 12 then
			dateMonth	:=	1;
			dateYear	:=	dateYear + 1;
		endif;
		
		self.myCalendar.changeType	:=	self.myCalendar.ChangeType_Month;
		
	elseif btn = self.myCalendar.myPrevYearButton then
		dateYear	:=	dateYear - 1;
		self.myCalendar.changeType	:=	self.myCalendar.ChangeType_Year;
		
	else
		dateYear	:=	dateYear + 1;
		self.myCalendar.changeType	:=	self.myCalendar.ChangeType_Year;
	endif;
	
	if (dateDay.String &amp; "/" &amp; dateMonth.String &amp; "/" &amp; dateYear.String).Date.isValid() then
		self.myCalendar.date.setDate(dateDay, dateMonth, dateYear);
	else
		self.myCalendar.date.setDate(1, dateMonth, dateYear);
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCalendar" id="cb23b09a-15a6-4a5a-b231-5478dd635d93">
        <updating/>
        <source>setCalendar(_calendarObj:MB_Calendar) updating;
// --------------------------------------------------------------------------------
// Created:		31 January 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myCalendar	:=	_calendarObj;
end;</source>
        <Parameter name="_calendarObj" type="MB_Calendar"/>
    </JadeMethod>
