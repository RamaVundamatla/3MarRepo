    <JadeMethod name="showSearchCriteria" id="6883356d-1999-46ab-8a31-8b96a7d0cfcd">
        <updating/>
        <source>showSearchCriteria() : String updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	str				: String;
	ts				: TimeStamp;
	
begin

	str := app.getErrorString(Location_activity);
	str := str &amp; ": " &amp; app.getErrorString(Date_range) &amp; ": ";
	if self.filterDateFrom = null then
		str := str &amp; app.getErrorString(None_Lowercase);
	else
		ts.setDate(self.filterDateFrom);
		str := str &amp; self.systemToLocalTime(ts).Date.asStringJMT();
	endif;
	str := str &amp; " - ";
	if self.filterDateTo = null then
		str := str &amp; app.getErrorString(None_Lowercase);
	else
		ts.setDate(self.filterDateTo);
		str := str &amp; self.systemToLocalTime(ts).Date.asStringJMT();
	endif;
	
	str := str &amp; "  " &amp; app.getErrorString(CM_Cargo_Type) &amp; ": ";
	if self.filterCargoType = null then
		str := str &amp; app.getErrorString(Any_LowerCase);
	else
		str := str &amp; self.filterCargoType.description;
	endif;
	
	str := str &amp; "  " &amp; app.getErrorString(Operator_GC) &amp; ": ";
	if self.filterOperator = null then
		str := str &amp; app.getErrorString(Any_LowerCase);
	else
		str := str &amp; self.filterOperator.description;
	endif;
	
	if self.filterTerminalArea &lt;&gt; null then
		str := str &amp; "  " &amp; app.getErrorString(TerminalArea) &amp; ": ";
		str := str &amp; self.cmbLocationArea.text;
		if self.filterLocation &lt;&gt; null then
			str := str &amp; "  " &amp; app.getErrorString(CM_Location) &amp; ": ";
			str := str &amp; self.cmbLocation.text;
		endif;
	elseif self.filterVoyage &lt;&gt; null then
		str := str &amp; "  " &amp; app.getErrorString(Voyage) &amp; ": ";
		str := str &amp; self.cmbLocationArea.text;
	elseif self.filterTrain &lt;&gt; null then
		str := str &amp; "  " &amp; app.getErrorString(Train) &amp; ": ";
		str := str &amp; self.cmbLocationArea.text;
	elseif self.filterVehicleVisitRecord &lt;&gt; null then
		str := str &amp; "  " &amp; app.getErrorString(Vehicle_visit_record) &amp; ": ";
		str := str &amp; self.cmbLocationArea.text;
	endif;
	
	if self.numItemsShown &gt;= JadeTableRowLimit then
		str := str &amp; "  ** " &amp; app.getErrorString1( Unable_To_Display_More_Rows, JadeTableRowLimit.display) &amp; " **";
	elseif self.searchCancelled then
		str := str &amp; "  " &amp; app.getErrorString(TransSearchCancelled);
	endif;
	
	return str;
end;
</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
