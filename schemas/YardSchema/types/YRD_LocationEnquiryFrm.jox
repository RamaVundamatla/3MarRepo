    <JadeMethod name="setFilterTerminalArea" id="51244683-7afb-4b32-b579-4dc4cd4e6cd8">
        <updating/>
        <source>setFilterTerminalArea(_ta: CM_TerminalArea) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2019	jlger1	Initial creation 47132

*/

vars

