	self.lblAgent.backColor := self.backColor;
	self.lblAnd.backColor := self.backColor;
	self.lblAtAfter.backColor := self.backColor;		
	self.lblAtBefore.backColor := self.backColor;	
	self.lblAtBetwnA.backColor := self.backColor;
	self.lblAtBetwnB.backColor := self.backColor;
	self.lblBerth.backColor := self.backColor;		
	self.lblPilot.backColor := self.backColor;			
	self.lblSearch.backColor := self.backColor;
	self.lblSearch_1.backColor := self.backColor;
	self.lblShipLineCo.backColor := self.backColor;		
	self.lblShipName.backColor := self.backColor;	
	self.lblShipType.backColor := self.backColor;
	self.optArrvAfter.backColor := self.backColor;
	self.optArrvBefore.backColor := self.backColor;		
	self.optArrvBetween.backColor := self.backColor;	

end;</source>
