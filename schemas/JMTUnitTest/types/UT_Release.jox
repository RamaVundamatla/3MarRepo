	self.assertTrueMsg( tiArray.includes(ti), "Agent method 'getCargoBasedOnSTW12Rules' should include '" &amp; ti.id &amp; "' for Rule 5");
	
	//21 Jun 2017 NDL
	packTIs.clear;
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "2", childCargoType2.id );
	packTIs.add( ti );
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "4", childCargoType2.id );
	packTIs.add( ti );
	self.packContainer( cont.CM_Container, packTIs);
	self.assertTrueMsg( cont.allChildren.includes(ti), "Packed child '" &amp; ti.id &amp; "' post Rule 5");
	
	selectedResDetail := br.allReservePackingChildren.last;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
	self.assertTrueMsg( tiArray.size = 0, "Agent method 'getCargoBasedOnSTW12Rules' should return 0 cargo, after post rule 5 packing specifying packed Res det.");									
										
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
	self.assertTrueMsg( tiArray.size = 3, "Agent method 'getCargoBasedOnSTW12Rules' should return 3 cargo, after post rule 5 packing for completely packed Res det with unspecifiied res det.");									
										
	packTIs.clear;
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", childCargoType1.id );
	packTIs.add( ti );
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "6", childCargoType1.id );
	packTIs.add( ti );
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "7", childCargoType1.id );
	packTIs.add( ti );
	self.packContainer( cont.CM_Container, packTIs);
	self.assertTrueMsg( cont.allChildren.includes(ti), "Packed child '" &amp; ti.id &amp; "' post Rule 5A");	
	
	selectedResDetail := br.allReservePackingChildren.first;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
	self.assertTrueMsg( tiArray.size = 0, "Agent method 'getCargoBasedOnSTW12Rules' should return 0 cargo, after post rule 5A packing specifying packed Res det.");									
										
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
	self.assertTrueMsg( tiArray.size = 0, "Agent method 'getCargoBasedOnSTW12Rules' should return 0 cargo, after post rule 5A packing for completely packed unspecifiied res det.");									

										
		
	//If we got this far all is good get rid of the data.
	foreach index in 1 to 9 do
		self.deleteCargo( BaseTiId &amp; index.String,  childCargoType1 );
		self.deleteCargo( BaseTiId &amp; index.String,  childCargoType2 );
	endforeach;
	self.deleteContainer( BaseTiId &amp; "A" );
	self.deleteTerminalArea(BlockStack);
	self.deleteTerminalArea(ICArea &amp; "1");
	self.deleteTerminalArea(ICArea &amp; "2");
	self.deleteReleaseRequest(ReleaseCode);

epilog

	self.setTerminalConfig(UseAltSelectRulesTL, false);
	delete agent;
	delete tiArray;
	delete packTIs;

end;</source>
    </JadeMethod>
    <JadeMethod name="tSTW12ReleaseRulesTest" id="2e70ff10-067b-4365-a65c-8040c176bdf7">
        <source>tSTW12ReleaseRulesTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2017	cnwndl1	Initial creation	TFS 4016
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

constants

	ReleaseCode : String = "UT12RULES";
	BaseTiId : String = "UTRL12RULE";
	BlockStack : String = "STWBS";
	ICArea : String = "STW_IC";
	TruckId : String = "12RULES";
	
vars

	br : CM_BulkRelease;
	oper : CM_Operator;
	agent : CMIF_MobileGenericAgent;
	selectedResDetail : CM_ReserveDetail;
	autoSelectedStageArea : CM_LocationsController;
	targetLocation : CM_LocationsController;
	stwRuleNum : Integer;
	tiArray : CM_TIArray;
	bs : CM_BlockStack;
	index : Integer;
	ti : CM_TrackedItem;
	ic1 : CM_YardInterchangeArea;
	ic2 : CM_YardInterchangeArea;
	truck : CM_Vehicle;
	vvr : CM_VehicleVisitRecord;
	gateEntity : CMGTE_Entity;
	term : CM_Terminal;
begin

	create agent transient;
	agent.setDoNotShowMsgBox(true);
	
	// ### Make sure the agent has the same terminal as  this unit test
	term := self.getTerminal();
	if agent.myTerminal &lt;&gt; term then
		agent.setMyTerminal(term);
	endif;

	create tiArray transient;
	oper := app.myRoot.allOperators.getAtKey("260");
	self.assertTrueMsg( oper &lt;&gt; null , " Operator not found pre-test");

	self.setTerminalConfig(UseAltSelectRulesTL, true);
	
	foreach index in 1 to 9 do
		self.deleteContainer( BaseTiId &amp; index.String );
	endforeach;
	
	self.deleteTerminalArea(BlockStack);
	bs := self.addBlockStack(BlockStack, 100, null);
	self.assertTrueMsg( bs &lt;&gt; null , " Block Stack not found pre-test");
	
	self.deleteTerminalArea(ICArea &amp; "1");
	self.deleteTerminalArea(ICArea &amp; "2");
	ic1 := self.addInterchangeArea(ICArea &amp; "1",null);
	ic2 := self.addInterchangeArea(ICArea &amp; "2",null);
	self.assertTrueMsg( ic1 &lt;&gt; null , " Inter change 1 not found pre-test");
	self.assertTrueMsg( ic2 &lt;&gt; null , " Inter change 2 not found pre-test");
	
	self.deleteReleaseRequest(ReleaseCode);
	
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("Number", 3.Integer );
	self.opts.addAssoc("Operator", oper );
	br := self.addReleaseByTypeRequestOpts(ReleaseCode, BR_TYPE_ROAD, TI_CargoType_Container);
	self.assertTrueMsg( br &lt;&gt; null , " Bulk Release not created pre-test");
	self.assertTrueMsg( br.status = BR_ACTIVE , " Bulk Release not active pre-test");
	
	//add 9 containers
	foreach index in 1 to 9 do
		ti := self.addContainer( BaseTiId &amp; index.String, oper, "2200", "MT", TI_IMEX_STATUS_STORAGE );
		self.assertTrueMsg( ti &lt;&gt; null , " Cargo '" &amp; BaseTiId &amp; index.String &amp; "' not created pre-test");
		self.move(ti, bs);
	endforeach;

	//Nothing assigned or staged - a single reserveDetail Should use rule 4.	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 4, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 4.");
	self.assertTrueMsg( autoSelectedStageArea = null, " Agent method 'getCargoStagingDispRuleSTW' should NOT have selected an area for Rule 4.");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 9, "Agent method 'getCargoBasedOnSTW12Rules' should have found all 9 containers, for Rule 4.");
	
	//stage the fifth conatiner - should now get rule 3.
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", TI_CargoType_Container );
	self.doStwStageCargo( ti, br.allReserveDetails.first, ic1.allLocationsControllers.first );
	
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 3, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 3, but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( autoSelectedStageArea = null, " Agent method 'getCargoStagingDispRuleSTW' should NOT have selected an area for Rule 3.");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 9, "Agent method 'getCargoBasedOnSTW12Rules' should have found all 9 containers, for Rule 3.");
	self.assertTrueMsg( tiArray.first.id = ti.id, "Agent method 'getCargoBasedOnSTW12Rules' should listed '" &amp; ti.id &amp; "' first for Rule 3.");
	
	//stage the sixth and seventh in a different area (Now fully staged but to 2 areas).  Should get rule 2
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "6", TI_CargoType_Container );
	self.doStwStageCargo( ti, br.allReserveDetails.first, ic2.allLocationsControllers.first );
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "7", TI_CargoType_Container );
	self.doStwStageCargo( ti, br.allReserveDetails.first, ic2.allLocationsControllers.first );
	
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 2, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 2, but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( autoSelectedStageArea = null, " Agent method 'getCargoStagingDispRuleSTW' should NOT have selected an area for Rule 2.");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 3, "Agent method 'getCargoBasedOnSTW12Rules' should have 3 containers, for Rule 2.");
	
	//2a, 2 with an area selected
	selectedResDetail := null;
	autoSelectedStageArea := ic2.allLocationsControllers.first;
	stwRuleNum := 2;
	tiArray.clear();
		
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 2, "Agent method 'getCargoBasedOnSTW12Rules' should have 2 containers, for Rule 2a.");
	
	//Move the 5th to the same IC as the other two, all in one area now, should get rule 1.
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", TI_CargoType_Container );
	self.move( ti, ic2 );
	
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 1, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 1, but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( autoSelectedStageArea = ic2.allLocationsControllers.first, " Agent method 'getCargoStagingDispRuleSTW' should have selected " &amp; ic2.allLocationsControllers.first.getFullId &amp; " for Rule 1");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 3, "Agent method 'getCargoBasedOnSTW12Rules' should have 3 containers, for Rule 1.");
	
	//Delete all cargo and teh release , and add it back fresh but with 2 reserve details
	foreach index in 1 to 9 do
		self.deleteContainer( BaseTiId &amp; index.String );
	endforeach;
	foreach index in 1 to 9 do
		if index &lt; 5 then
			ti := self.addContainer( BaseTiId &amp; index.String, oper, "4230", "MT", TI_IMEX_STATUS_STORAGE );
		else
			ti := self.addContainer( BaseTiId &amp; index.String, oper, "2200", "MT", TI_IMEX_STATUS_STORAGE );
		endif;
		self.move(ti, bs);
	endforeach;
	
	self.deleteReleaseRequest(ReleaseCode);
	
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("ISOGroup2", "40BX");
	self.opts.addAssoc("Number", 3.Integer );
	self.opts.addAssoc("Operator", oper );
	br := self.addReleaseByTypeRequestOpts(ReleaseCode, BR_TYPE_ROAD, TI_CargoType_Container);
	self.assertTrueMsg( br &lt;&gt; null and br.status = BR_ACTIVE, "Second bulk release not created, or not active");
	self.assertTrueMsg( br.allReserveDetails.size = 2, "Second bulk release should have 2 reserve details");
	selectedResDetail := br.allReserveDetails.last;
	beginTransaction;
	selectedResDetail.setPropertyValue("myISOType",null);
	commitTransaction;
	
	//Rule 12  Nothing staged, one selected
	selectedResDetail := br.allReserveDetails.first;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 12, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 12, but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( autoSelectedStageArea = null, " Agent method 'getCargoStagingDispRuleSTW' should NOT have selected an area for Rule 12.");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 5, "Agent method 'getCargoBasedOnSTW12Rules' should have 5 containers, for Rule 12.");
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", TI_CargoType_Container );
	self.assertTrueMsg( tiArray.first.id = ti.id, "Agent method 'getCargoBasedOnSTW12Rules' should listed '" &amp; ti.id &amp; "' first for Rule 12");
	
	//rule 11. Nothing staged , nothing selected
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 11, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 11, but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( autoSelectedStageArea = null, " Agent method 'getCargoStagingDispRuleSTW' should NOT have selected an area for Rule 11.");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 9, "Agent method 'getCargoBasedOnSTW12Rules' should have 9 containers, for Rule 11.");
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", TI_CargoType_Container );
	self.assertTrueMsg( tiArray.includes(ti), "Agent method 'getCargoBasedOnSTW12Rules' should include '" &amp; ti.id &amp; "' for Rule 11");
	
	//rule 10.  Some fully staged, 1 fully staged to multiple areas id selected
	selectedResDetail := br.allReserveDetails.first;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", TI_CargoType_Container );
	self.doStwStageCargo( ti, br.allReserveDetails.first, ic1.allLocationsControllers.first );
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "6", TI_CargoType_Container );
	self.doStwStageCargo( ti, br.allReserveDetails.first, ic2.allLocationsControllers.first );
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "7", TI_CargoType_Container );
	self.doStwStageCargo( ti, br.allReserveDetails.first, ic2.allLocationsControllers.first );
	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 10, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 10, but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( autoSelectedStageArea = null, " Agent method 'getCargoStagingDispRuleSTW' should NOT have selected an area. for Rule 10");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 3, "Agent method 'getCargoBasedOnSTW12Rules' should have 3 containers, for Rule 10.");
	
	//rule 9.
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 9, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 9, but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( autoSelectedStageArea = null, " Agent method 'getCargoStagingDispRuleSTW' should NOT have selected an area for Rule 9.");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 7, "Agent method 'getCargoBasedOnSTW12Rules' should have 7 containers, for Rule 9.");
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", TI_CargoType_Container );
	self.assertTrueMsg( tiArray.first.id = ti.id, "Agent method 'getCargoBasedOnSTW12Rules' should listed '" &amp; ti.id &amp; "' first for Rule 9");
	
	//rule 8.
	selectedResDetail := br.allReserveDetails.last;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", TI_CargoType_Container );
	self.move( ti,ic2.allLocationsControllers.first );
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "2", TI_CargoType_Container );
	self.doStwStageCargo( ti, br.allReserveDetails.last, ic1.allLocationsControllers.first );
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "3", TI_CargoType_Container );
	self.doStwStageCargo( ti, br.allReserveDetails.last, ic1.allLocationsControllers.first );
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "4", TI_CargoType_Container );
	self.doStwStageCargo( ti, br.allReserveDetails.last, ic1.allLocationsControllers.first );
	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 8, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 8, but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( autoSelectedStageArea = ic1.allLocationsControllers.first, " Agent method 'getCargoStagingDispRuleSTW' should have selected " &amp; ic1.allLocationsControllers.first.getFullId &amp; " for Rule 8");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 3, "Agent method 'getCargoBasedOnSTW12Rules' should have 3 containers, for Rule 8.");
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "2", TI_CargoType_Container );
	self.assertTrueMsg( tiArray.includes(ti), "Agent method 'getCargoBasedOnSTW12Rules' should include '" &amp; ti.id &amp; "' for Rule 8");
	
	
	
	//rule 7.
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 7, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 7, but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( autoSelectedStageArea = null, " Agent method 'getCargoStagingDispRuleSTW' should NOT have selected an area for Rule 7.");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 6, "Agent method 'getCargoBasedOnSTW12Rules' should have 6 containers, for Rule 7.");
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "2", TI_CargoType_Container );
	self.assertTrueMsg( tiArray.includes(ti), "Agent method 'getCargoBasedOnSTW12Rules' should include '" &amp; ti.id &amp; "' for Rule 7");
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", TI_CargoType_Container );
	self.assertTrueMsg( tiArray.includes(ti), "Agent method 'getCargoBasedOnSTW12Rules' should include '" &amp; ti.id &amp; "' for Rule 7");
	
	//rule 6.
	selectedResDetail := br.allReserveDetails.first;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "2", TI_CargoType_Container );
	self.move( ti,ic2.allLocationsControllers.first );
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "3", TI_CargoType_Container );
	self.move( ti,ic2.allLocationsControllers.first );
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "4", TI_CargoType_Container );
	self.move( ti,ic2.allLocationsControllers.first );
	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 6, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 6, but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( autoSelectedStageArea = ic2.allLocationsControllers.first, " Agent method 'getCargoStagingDispRuleSTW' should have selected " &amp; ic1.allLocationsControllers.first.getFullId &amp; " for Rule 6");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 3, "Agent method 'getCargoBasedOnSTW12Rules' should have 3 containers, for Rule 6.");
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", TI_CargoType_Container );
	self.assertTrueMsg( tiArray.includes(ti), "Agent method 'getCargoBasedOnSTW12Rules' should include '" &amp; ti.id &amp; "' for Rule 6");
	
	//rule 5.
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 5, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 5, but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( autoSelectedStageArea = ic2.allLocationsControllers.first, " Agent method 'getCargoStagingDispRuleSTW' should have selected " &amp; ic1.allLocationsControllers.first.getFullId &amp; " for Rule 5");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 6, "Agent method 'getCargoBasedOnSTW12Rules' should have 6 containers, for Rule 5.");
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "2", TI_CargoType_Container );
	self.assertTrueMsg( tiArray.includes(ti), "Agent method 'getCargoBasedOnSTW12Rules' should include '" &amp; ti.id &amp; "' for Rule 5");
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", TI_CargoType_Container );
	self.assertTrueMsg( tiArray.includes(ti), "Agent method 'getCargoBasedOnSTW12Rules' should include '" &amp; ti.id &amp; "' for Rule 5");
	
	// 22 Jun 2017 NDL - Gate in a truck for the release and check the over-riding return nothing when fully loaded rule 
	self.deleteVehicle(TruckId);
	self.opts.purge;
	self.opts.addAssoc("ReleaseRequest", br);
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", TI_CargoType_Container );
	vvr := self.gateOutGC(TruckId, "", "UTDRIVER", ti.CM_Container,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);
	self.workVehicle(vvr); // loads the container

	selectedResDetail := br.allReserveDetails.first;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
	self.assertTrueMsg( stwRuleNum = 6, " Agent method 'getCargoStagingDispRuleSTW' should have returned Rule = 6, (truck load testing 1) but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( tiArray.size = 2, " Agent method 'getCargoStagingDispRuleSTW' should have returned 2 items, (truck load testing 1) but got '" &amp; tiArray.size.String &amp; "'.");
	
	// create the tasks and load the next 2..
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "6", TI_CargoType_Container );
	self.opts.purge;
	self.opts.addAssoc("ReserveDetail", selectedResDetail);
	gateEntity := self.createGTEOut( ti.CM_Container, vvr ); //Creates and loads to the truck.

	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "7", TI_CargoType_Container );
	self.opts.purge;
	self.opts.addAssoc("ReserveDetail", selectedResDetail);
	gateEntity := self.createGTEOut( ti.CM_Container, vvr ); //Creates and loads to the truck.
	
	//check that it considers the selected res detail to be fully loaded
	selectedResDetail := br.allReserveDetails.first;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
	self.assertTrueMsg( stwRuleNum = 0, " Agent method 'getCargoStagingDispRuleSTW' should have returned Rule = 0, (truck load testing 2) but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( tiArray.size = 0, " Agent method 'getCargoStagingDispRuleSTW' should have returned 0 items, (truck load testing 2) but got '" &amp; tiArray.size.String &amp; "'.");
	
	//check that it considers the bulk release NOT to be fully loaded
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( stwRuleNum = 5, " Agent method 'getCargoStagingDispRuleSTW' should have returned Rule = 5, (truck load testing 3) but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( tiArray.size = 3, " Agent method 'getCargoStagingDispRuleSTW' should have returned 3 items, (truck load testing 3) but got '" &amp; tiArray.size.String &amp; "'.");
	
	selectedResDetail := br.allReserveDetails.last;
	beginTransaction;
	selectedResDetail.CM_ReserveSelection.setTotalRequested(3);
	commitTransaction;	
	
	// create the tasks and load the next 2..
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "2", TI_CargoType_Container );
	self.opts.purge;
	self.opts.addAssoc("ReserveDetail", selectedResDetail);
	gateEntity := self.createGTEOut( ti.CM_Container, vvr ); //Creates and loads to the truck.
	
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "3", TI_CargoType_Container );
	self.opts.purge;
	self.opts.addAssoc("ReserveDetail", selectedResDetail);
	gateEntity := self.createGTEOut( ti.CM_Container, vvr ); //Creates and loads to the truck.
	
	//Now check with one left to load
	selectedResDetail := br.allReserveDetails.last;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( stwRuleNum = 6, " Agent method 'getCargoStagingDispRuleSTW' should have returned Rule = 6, (truck load testing 4) but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( tiArray.size = 1, " Agent method 'getCargoStagingDispRuleSTW' should have returned 1 items, (truck load testing 4) but got '" &amp; tiArray.size.String &amp; "'.");
	
	//load the last one
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "4", TI_CargoType_Container );
	self.opts.purge;
	self.opts.addAssoc("ReserveDetail", selectedResDetail);
	gateEntity := self.createGTEOut( ti.CM_Container, vvr ); //Creates and loads to the truck.
	
	//now check with the last reserve detail selected when all loaded
	selectedResDetail := br.allReserveDetails.last;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( stwRuleNum = 0, " Agent method 'getCargoStagingDispRuleSTW' should have returned Rule = 0, (truck load testing 5) but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( tiArray.size = 0, " Agent method 'getCargoStagingDispRuleSTW' should have returned 0 items, (truck load testing 5) but got '" &amp; tiArray.size.String &amp; "'.");
	
	//now check with NO reserve detail selected when all loaded
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( stwRuleNum = 0, " Agent method 'getCargoStagingDispRuleSTW' should have returned Rule = 0, (truck load testing 6) but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( tiArray.size = 0, " Agent method 'getCargoStagingDispRuleSTW' should have returned 0 items, (truck load testing 6) but got '" &amp; tiArray.size.String &amp; "'.");

	self.roadExit(vvr);
	
	//If we got this far all is good get rid of the data.
	foreach index in 1 to 9 do
		self.deleteContainer( BaseTiId &amp; index.String );
	endforeach;
	self.deleteVehicle(TruckId);
	self.deleteTerminalArea(BlockStack);
	self.deleteTerminalArea(ICArea &amp; "1");
	self.deleteTerminalArea(ICArea &amp; "2");
	self.deleteReleaseRequest(ReleaseCode);

epilog

	self.setTerminalConfig(UseAltSelectRulesTL, false);
	delete agent;
	delete tiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tSTW12ReleaseRulesTestRail" id="91ba8e72-13d3-43bd-b274-cab8f72c50bc">
        <source>tSTW12ReleaseRulesTestRail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2020	jlgndl1	Initial creation	TFS 49546
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

constants

	ReleaseCode : String = "UT12RULES";
	BaseTiId : String = "UTRL12RULE";
	BlockStack : String = "STWBS";
	ICArea : String = "STW_IC";
	TrainCode : String = "12RULES";
	Wagonnn : String = "BX43356";
	RailAreaId : String = "UT_JRA1";
	
vars

	br : CM_BulkRelease;
	oper : CM_Operator;
	agent : CMIF_MobileGenericAgent;
	selectedResDetail : CM_ReserveDetail;
	autoSelectedStageArea : CM_LocationsController;
	targetLocation : CM_LocationsController;
	stwRuleNum : Integer;
	tiArray : CM_TIArray;
	bs : CM_BlockStack;
	index : Integer;
	ti : CM_TrackedItem;
	ic1 : CM_YardInterchangeArea;
	ic2 : CM_YardInterchangeArea;
	wagonMaster : CM_WagonMaster;
	wagonId : String;
	train: CM_Train;
	wagon : CM_Wagon;
	railArea : CM_Rail;
	railLine : CM_RailLine;
	obj : Object;
	railIORake : CM_RailJSInOutRake;
	terminal : CM_Terminal;
	trainSet : CM_TrainSet;
	
begin

	terminal := self.getTerminal;
	create agent transient;
	agent.setDoNotShowMsgBox(true);
	
	// ### Make sure the agent has the same terminal as  this unit test
	if agent.myTerminal &lt;&gt; terminal then
		agent.setMyTerminal(terminal);
	endif;

	create tiArray transient;
	oper := app.myRoot.allOperators.getAtKey("260");
	self.assertTrueMsg( oper &lt;&gt; null , " Operator not found pre-test");

	self.setTerminalConfig(UseAltSelectRulesTL, true);
	
	
	//clean up
	foreach index in 1 to 9 do
		self.deleteContainer( BaseTiId &amp; index.String );
	endforeach;
	
	self.deleteRailArea(RailAreaId);
	
	self.deleteTerminalArea(BlockStack);
	bs := self.addBlockStack(BlockStack, 100, null);
	self.assertTrueMsg( bs &lt;&gt; null , " Block Stack not found pre-test");
	
	self.deleteTerminalArea(ICArea &amp; "1");
	self.deleteTerminalArea(ICArea &amp; "2");
	ic1 := self.addInterchangeArea(ICArea &amp; "1",null);
	ic2 := self.addInterchangeArea(ICArea &amp; "2",null);
	self.assertTrueMsg( ic1 &lt;&gt; null , " Inter change 1 not found pre-test");
	self.assertTrueMsg( ic2 &lt;&gt; null , " Inter change 2 not found pre-test");
	
	self.deleteReleaseRequest(ReleaseCode);
	
	//setup
	railArea := self.addRailArea(RailAreaId, 4, 10);
	railLine := railArea.allRailLinesByIndex.first;
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	
	train := terminal.allTrainsOnTerminal.getAtKeyGeq(TrainCode, null);	
	
	if train &lt;&gt; null and train.code = TrainCode then
		foreach wagon in train.allWagonsByIdInward do
			if wagon.confirmed then
				beginTransaction;
				wagon.erase(0);
				commitTransaction;
				continue;
			endif; 
			app.myTrxDA.trxDeleteWagon(wagon, false, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());	
		endforeach;
		
		self.deleteTrain(TrainCode,null);
	endif;
	
	//set up
	
	train := self.addTrain(TrainCode,null);
	self.assertNotNull(train);
	
	foreach index in 1 to 4 do
		wagon := self.addWagonInRailArea(Wagonnn &amp; index.String, "BX", railArea, train);
		railLine.switchPositions(wagon, index);
	endforeach;
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, false, app.myPassport); 
	

	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("Number", 3.Integer );
	self.opts.addAssoc("Operator", oper );
	br := self.addReleaseByTypeRequestOpts(ReleaseCode, BR_TYPE_RAIL, TI_CargoType_Container);
	self.assertTrueMsg( br &lt;&gt; null , " Bulk Release not created pre-test");
	self.assertTrueMsg( br.status = BR_ACTIVE , " Bulk Release not active pre-test");
	
	//add 9 containers
	foreach index in 1 to 9 do
		ti := self.addContainer( BaseTiId &amp; index.String, oper, "2200", "MT", TI_IMEX_STATUS_STORAGE );
		self.assertTrueMsg( ti &lt;&gt; null , " Cargo '" &amp; BaseTiId &amp; index.String &amp; "' not created pre-test");
		self.move(ti, bs);
	endforeach;

	//Nothing assigned or staged - a single reserveDetail Should use rule 4.	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 4, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 4.");
	self.assertTrueMsg( autoSelectedStageArea = null, " Agent method 'getCargoStagingDispRuleSTW' should NOT have selected an area for Rule 4.");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 9, "Agent method 'getCargoBasedOnSTW12Rules' should have found all 9 containers, for Rule 4.");
	
	//stage the fifth conatiner - should now get rule 3.
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "5", TI_CargoType_Container );
	self.doStwStageCargo( ti, br.allReserveDetails.first, ic1.allLocationsControllers.first );
	
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 3, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 3, but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( autoSelectedStageArea = null, " Agent method 'getCargoStagingDispRuleSTW' should NOT have selected an area for Rule 3.");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
										targetLocation,	//_targetLocation : CM_LocationsController;
										stwRuleNum,	//_stwRuleNum : Integer;
										tiArray	//_tiArray : CM_TIArray io
										);
										
	self.assertTrueMsg( tiArray.size = 9, "Agent method 'getCargoBasedOnSTW12Rules' should have found all 9 containers, for Rule 3.");
	self.assertTrueMsg( tiArray.first.id = ti.id, "Agent method 'getCargoBasedOnSTW12Rules' should listed '" &amp; ti.id &amp; "' first for Rule 3.");
	
	//stage the sixth and seventh in a different area (Now fully staged but to 2 areas).  Should get rule 2
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "6", TI_CargoType_Container );
	self.doStwStageCargo( ti, br.allReserveDetails.first, ic2.allLocationsControllers.first );
	ti := self.getTrackedItemByCargoType( BaseTiId &amp; "7", TI_CargoType_Container );
	self.doStwStageCargo( ti, br.allReserveDetails.first, ic2.allLocationsControllers.first );
	
	selectedResDetail := null;
	autoSelectedStageArea := null;
	stwRuleNum := 0;
	tiArray.clear();
	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 2, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 2, but got '" &amp; stwRuleNum.String &amp; "'.");
	self.assertTrueMsg( autoSelectedStageArea = null, " Agent method 'getCargoStagingDispRuleSTW' should NOT have selected an area for Rule 2.");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//_stagedYardLocation : CM_LocationsController io;
