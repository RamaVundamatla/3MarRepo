    <JadeMethod name="add" id="ffd390a5-9102-4d33-b04a-67fa7016e508">
        <lockReceiver/>
        <updating/>
        <source>add(value: MemberType) updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     08 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	key1,
	key2,
	key3	: Any;
	propName	: String;
	numKeys	: Integer;
	
begin
	//inheritMethod(value);

	foreach propName in self.allKeys do
		numKeys := numKeys + 1;
		if numKeys = 1 then
			key1	:= value.getPropertyValue(propName);
		elseif numKeys = 2 then
			key2	:= value.getPropertyValue(propName);
		elseif numKeys = 3 then
			key3	:= value.getPropertyValue(propName);
		endif;
	endforeach;
	
	if numKeys = 1 then
		self.putAtKey(key1, value);
	elseif numKeys = 2 then
		self.putAtKey(key1, key2, value);
	elseif numKeys = 3 then
		self.putAtKey(key1, key2, key3, value);
	endif;

end;</source>
        <Parameter name="value" type="MemberType"/>
    </JadeMethod>
    <JadeMethod name="addExternalKeyForEntRow" id="fe95c5af-e108-4ac4-b5fa-07836ae0a16d">
        <lockReceiver/>
        <updating/>
        <source>addExternalKeyForEntRow(_propertyName: String; _primType : PrimType; _length : Integer; _descending, _caseInsensitive: Boolean) updating, lockReceiver;
//-----------------------------------------
// Created: September 2005 By: cnwgd1
//-----------------------------------------
vars
	sortType : Integer;
begin
	
	if _propertyName = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _propertyName');
		return;
	elseif _primType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _primType');
		return;
	elseif _length &lt; 1
	or _length &gt; 30 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid _length (' &amp; _length.String &amp; ')');
		return;		
	endif;
	
	if _primType = String then
		sortType := Table.SortType_Alpha;
	elseif _primType = Real then
		sortType := Table.SortType_Numeric;			
	elseif _primType = Date then
		sortType := Table.SortType_Date;
	elseif _primType = Time then
		sortType := Table.SortType_Time;
	elseif _primType = TimeStamp then
		sortType := Table.SortType_TimeStamp;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid _primType (' &amp; _primType.String &amp; ')');	
	endif;						
	
	self.addExternalKey(_primType, _length, _descending, _caseInsensitive);
	
	self.allKeys.add(_propertyName);
	
	self.allInputTypes.add(sortType);
	
end;</source>
        <Parameter name="_propertyName" type="String"/>
        <Parameter name="_primType" type="PrimType"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_descending" type="Boolean"/>
        <Parameter name="_caseInsensitive" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addMemberKey" id="ffcc95b8-5cf3-4ea3-8b19-0cd65b25f888">
        <lockReceiver/>
        <updating/>
        <source>addMemberKey(propertyName: String; descending: Boolean; caseInsensitive: Boolean) updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     08 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	prop	: Property;

begin
	//inheritMethod(propertyName, descending, caseInsensitive);

	prop := self.allProperties[propertyName];
	
	if prop = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'You can not sort by (' &amp;
				propertyName &amp; ') as it does not exist on (' &amp; self.myMemberClass.name &amp; ').');
		return;
	endif;
	
	self.addExternalKey(prop.type.PrimType, prop.getLength, false, false);
	
	self.allKeys.add(propertyName);
	
end;</source>
        <Parameter name="propertyName" type="String"/>
        <Parameter name="descending" type="Boolean"/>
        <Parameter name="caseInsensitive" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addObject" id="1004a501-3c37-4824-826a-56e090ef1a7a">
        <lockReceiver/>
        <updating/>
        <source>addObject(_object : Object) updating, lockReceiver;
//-----------------------------------------
// Created: September 2005 By: cnwgd1
//-----------------------------------------
//
//======================================================
// THE CODE HERE IS REPLICATED IN THE removeObject METHOD
// any changes here may need to be done there as well
//======================================================

vars
	keyValue,
	key1,
	key2,
	key3,
	key4,
	key5,
	key6,
	key7,
	key8,
	key9,
	key10,
	key11,
	key12,
	key13,
	key14,
	key15	: Any; // Max number of keys is 15
	displayStr,
	propName : String;
	sortType,
	numKeys	: Integer;
begin

	if _object = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _object');
		return;
	endif;
	
	if self.includes(_object) then
		// key changed no duplicates allowed
		return;
	endif;

	foreach propName in self.allKeys do
		
		if _object.isKindOf(CM_Object) then
			displayStr := _object.CM_Object.getDisplayStringForAttribute(propName, false);
		else
			displayStr := _object.getPropertyValue(propName).String;
		endif;

		numKeys := numKeys + 1;
		
		sortType := self.allInputTypes[numKeys];
		
		if sortType = Table.SortType_Alpha then
			keyValue := displayStr[1:30].String;
		elseif sortType = Table.SortType_Numeric then
			if displayStr.isReal then
				keyValue := displayStr.Real;		
			else
				keyValue := 0.Real; //rs1 marv 2006 was null and caused failure
			endif;
		elseif sortType = Table.SortType_Date then
			keyValue := displayStr.asDateJMT();

		elseif sortType = Table.SortType_Time then
			keyValue := displayStr.asTimeJMT();
			
		elseif sortType = Table.SortType_TimeStamp then
			keyValue := displayStr.asTimeStampJMT();
		else
			keyValue := null; // can't sort
		endif;					
		
		if numKeys = 1 then
			key1 := keyValue;
		elseif numKeys = 2 then
			key2 := keyValue;
		elseif numKeys = 3 then
			key3 := keyValue;
		elseif numKeys = 4 then
			key4 := keyValue;
		elseif numKeys = 5 then
			key5 := keyValue;
		elseif numKeys = 6 then
			key6 := keyValue;
		elseif numKeys = 7 then
			key7 := keyValue;
		elseif numKeys = 8 then
			key8 := keyValue;
		elseif numKeys = 9 then	
			key9 := keyValue;
		elseif numKeys = 10 then
			key10 := keyValue;
		elseif numKeys = 11 then
			key11 := keyValue;
		elseif numKeys = 12 then
			key12 := keyValue;
		elseif numKeys = 13 then
			key13 := keyValue;
		elseif numKeys = 14 then
			key14 := keyValue;
		elseif numKeys = 15 then
			key15 := keyValue;										
		endif;
		
	endforeach;
	
	if numKeys = 1 then
		self.putAtKey(key1, _object);
	elseif numKeys = 2 then
		self.putAtKey(key1, key2, _object);
	elseif numKeys = 3 then
		self.putAtKey(key1, key2, key3, _object);
	elseif numKeys = 4 then
		self.putAtKey(key1, key2, key3, key4, _object);
	elseif numKeys = 5 then
		self.putAtKey(key1, key2, key3, key4, key5, _object);		
	elseif numKeys = 6 then
		self.putAtKey(key1, key2, key3, key4, key5, key6, _object);
	elseif numKeys = 7 then
		self.putAtKey(key1, key2, key3, key4, key5, key6, key7, _object);
	elseif numKeys = 8 then
		self.putAtKey(key1, key2, key3, key4, key5, key6, key7, key8, _object);
	elseif numKeys = 9 then
		self.putAtKey(key1, key2, key3, key4, key5, key6, key7, key8, key9, _object);
	elseif numKeys = 10 then
		self.putAtKey(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, _object);				
	elseif numKeys = 11 then
		self.putAtKey(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, _object);						
	elseif numKeys = 12 then
		self.putAtKey(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, _object);
	elseif numKeys = 13 then
		self.putAtKey(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, _object);		
	elseif numKeys = 14 then
		self.putAtKey(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, key14, _object);
	elseif numKeys = 15 then
		self.putAtKey(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, key14, key15, _object);		
	endif;

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="clearKeys" id="2290429b-98cc-4914-8fbe-281ce27d6db2">
        <lockReceiver/>
        <updating/>
        <source>clearKeys() updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     08 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.allKeys.isEmpty then
		return;
	endif;
	inheritMethod();
	self.allKeys.clear;
	self.allInputTypes.clear; // PAR 11011

end;</source>
    </JadeMethod>
    <JadeMethod name="getEntryForObject" id="18f383f7-8cbe-4a04-a72c-8a461e7164da">
        <source>getEntryForObject(_object : CM_Object) : Object;
//-----------------------------------------
// Created: September 2005 By: cnwgd1
//-----------------------------------------
//
//======================================================
// THE CODE HERE IS REPLICATED IN THE removeObject METHOD
// any changes here may need to be done there as well
//======================================================

vars
	keyValue,
	key1,
	key2,
	key3,
	key4,
	key5,
	key6,
	key7,
	key8,
	key9,
	key10,
	key11,
	key12,
	key13,
	key14,
	key15	: Any; // Max number of keys is 15
	displayStr,
	propName : String;
	sortType,
	numKeys	: Integer;
begin

	if _object = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _object');
		return null;
	endif;
	
//	if (not self.includes(_object)) then
//		// key changed no duplicates allowed
//		return null;
//	endif;

	foreach propName in self.allKeys do
		
		displayStr := _object.getDisplayStringForAttribute(propName, false);

		numKeys := numKeys + 1;
		
		sortType := self.allInputTypes[numKeys];
		
		if sortType = Table.SortType_Alpha then
			keyValue := displayStr[1:30].String;
		elseif sortType = Table.SortType_Numeric then
			if displayStr.isReal then
				keyValue := displayStr.Real;		
			else
				keyValue := 0.Real; //rs1 marv 2006 was null and caused failure
			endif;
		elseif sortType = Table.SortType_Date then
			keyValue := displayStr.asDateJMT();

		elseif sortType = Table.SortType_Time then
			keyValue := displayStr.asTimeJMT();
			
		elseif sortType = Table.SortType_TimeStamp then
			keyValue := displayStr.asTimeStampJMT();
		else
			keyValue := null; // can't sort
		endif;					
		
		if numKeys = 1 then
			key1 := keyValue;
		elseif numKeys = 2 then
			key2 := keyValue;
		elseif numKeys = 3 then
			key3 := keyValue;
		elseif numKeys = 4 then
			key4 := keyValue;
		elseif numKeys = 5 then
			key5 := keyValue;
		elseif numKeys = 6 then
			key6 := keyValue;
		elseif numKeys = 7 then
			key7 := keyValue;
		elseif numKeys = 8 then
			key8 := keyValue;
		elseif numKeys = 9 then	
			key9 := keyValue;
		elseif numKeys = 10 then
			key10 := keyValue;
		elseif numKeys = 11 then
			key11 := keyValue;
		elseif numKeys = 12 then
			key12 := keyValue;
		elseif numKeys = 13 then
			key13 := keyValue;
		elseif numKeys = 14 then
			key14 := keyValue;
		elseif numKeys = 15 then
			key15 := keyValue;										
		endif;
		
	endforeach;

	if numKeys = 1 then
		return self.getAtKey(key1);
	elseif numKeys = 2 then
		return self.getAtKey(key1, key2);
	elseif numKeys = 3 then
		return self.getAtKey(key1, key2, key3);
	elseif numKeys = 4 then
		return self.getAtKey(key1, key2, key3, key4);
	elseif numKeys = 5 then
		return self.getAtKey(key1, key2, key3, key4, key5);		
	elseif numKeys = 6 then
		return self.getAtKey(key1, key2, key3, key4, key5, key6);
	elseif numKeys = 7 then
		return self.getAtKey(key1, key2, key3, key4, key5, key6, key7);
	elseif numKeys = 8 then
		return self.getAtKey(key1, key2, key3, key4, key5, key6, key7, key8);
	elseif numKeys = 9 then
		return self.getAtKey(key1, key2, key3, key4, key5, key6, key7, key8, key9);
	elseif numKeys = 10 then
		return self.getAtKey(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10);				
	elseif numKeys = 11 then
		return self.getAtKey(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11);						
	elseif numKeys = 12 then
		return self.getAtKey(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12);
	elseif numKeys = 13 then
		return self.getAtKey(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13);		
	elseif numKeys = 14 then
		return self.getAtKey(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, key14);
	elseif numKeys = 15 then
		return self.getAtKey(key1, key2, key3, key4, key5, key6, key7, key8, key9, key10, key11, key12, key13, key14, key15);		
	endif;
	
	return null;

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getKeys" id="194e0288-3fd1-4ded-af10-93470ee706ec">
        <lockReceiver/>
        <updating/>
        <source>getKeys(_keys : KeyType; _object : Object) updating ;
// ---------------------------------------------------------------------------
// Created:		19 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
		self.removeKeyEntry(_keys, _object);
end;</source>
        <Parameter name="_keys" type="KeyType"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="listKeys" id="c1ff88db-d254-4daf-b1b6-6990f344816b">
        <source>listKeys() : String;
// ---------------------------------------------------------------------------
// Created:     13 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	s,
	rtnStr	: String;
begin
	foreach s in self.allKeys do
		if rtnStr = null then
			rtnStr := s;
		else
			rtnStr := rtnStr &amp; ', ' &amp; s;
		endif;
	endforeach;
	
	return rtnStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="noKeys" id="d05607e2-b9a7-43e6-864c-87bee9005668">
        <source>noKeys():Boolean;
//--------------------------------------------------
// Created:	09 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.allKeys.isEmpty;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeObject" id="8700f46d-6b56-4138-9044-baf0370d3911">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_object : CM_Object) updating, lockReceiver;
//-----------------------------------------
// Created: September 2005 By: cnwgd1

// Lorcan 21/7/2006 
// There is a problem when you try to remove on object from a DynaDict weith external keys
// and the key values have changed. The dictionary doesn't find it.
//
// So the change made here si to check (using getAtKey) that you can find the entry before attempting to delete
// and if you cant then do an iteratoir search for your object, and if you find it, get the real keyts from the 
// iterator and use those to remove the item. Phew!
//-----------------------------------------
//
//======================================================
// THE CODE HERE IS REPLICATED IN THE addObject METHOD
// any changes here may need to be done there as well
//======================================================
/*

Date		Who		Reason
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	keyValue,
	key1,
	key2,
	key3,
	key4,
	key5,
	key6,
	key7,
	key8,
	key9,
	key10,
	key11,
	key12,
	key13,
	key14,
	key15	: Any; // Max number of keys is 15
	displayStr,
	propName : String;
	sortType,
	numKeys	: Integer;
	iter	: Iterator;
	obj		: MemberType;
	tmpObj 	: Object;
begin

	if _object = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _object');
		return;
	endif;

	// ### PAR  13789
	if not app.isValidObject(_object) then
		return;
	endif;
	
	foreach propName in self.allKeys do
		
		displayStr := _object.getDisplayStringForAttribute(propName, false);
		
		numKeys := numKeys + 1;
		
		sortType := self.allInputTypes[numKeys];
		
		if sortType = Table.SortType_Alpha then
			keyValue := displayStr[1:30].String;
		elseif sortType = Table.SortType_Numeric then
			if displayStr.isReal then
				keyValue := displayStr.Real;		
			else
				keyValue := 0.Real; //rs1 marv 2006 was null and caused failure
			endif;
		elseif sortType = Table.SortType_Date then
			keyValue := displayStr.asDateJMT();

		elseif sortType = Table.SortType_Time then
			keyValue := displayStr.asTimeJMT();
			
		elseif sortType = Table.SortType_TimeStamp then
			keyValue := displayStr.asTimeStampJMT();
		else
			keyValue := null; // can't sort
		endif;					
		
		if numKeys = 1 then
			key1 := keyValue;
		elseif numKeys = 2 then
			key2 := keyValue;
		elseif numKeys = 3 then
			key3 := keyValue;
		elseif numKeys = 4 then
			key4 := keyValue;
		elseif numKeys = 5 then
			key5 := keyValue;
		elseif numKeys = 6 then
			key6 := keyValue;
		elseif numKeys = 7 then
			key7 := keyValue;
		elseif numKeys = 8 then
			key8 := keyValue;
		elseif numKeys = 9 then	
			key9 := keyValue;
		elseif numKeys = 10 then
			key10 := keyValue;
		elseif numKeys = 11 then
			key11 := keyValue;
		elseif numKeys = 12 then
			key12 := keyValue;
		elseif numKeys = 13 then
			key13 := keyValue;
		elseif numKeys = 14 then
			key14 := keyValue;
		elseif numKeys = 15 then
			key15 := keyValue;										
		endif;
		
	endforeach;
	
	if numKeys = 1 then
		tmpObj := self.getAtKey (key1);
		if tmpObj = _object then // PAR 17622 already checked that _object is not null
			self.removeKeyEntry(key1, _object);
		// PAR 16212 and from here
		else
			iter := self.createIterator ();
			
			while iter.next (obj) do
				if obj = _object then
					self.getIteratorKeys (key1, iter );
					self.removeKeyEntry(key1, _object);
					break;
				endif;
			endwhile;
			delete iter;
		
		endif;
		// PAR 16212 to here
	elseif numKeys = 2 then
		tmpObj := self.getAtKey (key1, key2);
		if tmpObj = _object then
			self.removeKeyEntry(key1, key2, _object);
		else
			iter := self.createIterator ();
			while iter.next (obj) do
				if obj = _object then
					self.getIteratorKeys (key1, key2, iter );
					self.removeKeyEntry(key1, key2, _object);
					break;
				endif;
			endwhile;
			delete iter;
		endif;
	elseif numKeys = 3 then
		tmpObj := self.getAtKey (key1, key2, key3 );
		if tmpObj = _object then
			self.removeKeyEntry(key1, key2, key3, _object);
		else
			iter := self.createIterator ();
			while iter.next (obj) do
				if obj = _object then
					self.getIteratorKeys (key1, key2, key3, iter );
					self.removeKeyEntry(key1, key2, key3, _object);
					break;
				endif;
			endwhile;
			delete iter;
		endif;
	elseif numKeys = 4 then
		tmpObj := self.getAtKey (key1, key2, key3, key4);
		if tmpObj = _object then
			self.removeKeyEntry(key1, key2, key3, key4, _object);
		else
			iter := self.createIterator ();
			while iter.next (obj) do
				if obj = _object then
					self.getIteratorKeys (key1, key2, key3, key4, iter );
					self.removeKeyEntry(key1, key2, key3, key4, _object);
					break;
				endif;
			endwhile;
			delete iter;
		endif;
	elseif numKeys = 5 then
		tmpObj := self.getAtKey (key1, key2, key3, key4, key5);
		if tmpObj = _object then
			self.removeKeyEntry(key1, key2, key3, key4, key5, _object);
		else
			iter := self.createIterator ();
			while iter.next (obj) do
				if obj = _object then
					self.getIteratorKeys (key1, key2, key3, key4, key5, iter );
					self.removeKeyEntry(key1, key2, key3, key4, key5, _object);
					break;
				endif;
			endwhile;
			delete iter;
		endif;
	elseif numKeys = 6 then
		tmpObj := self.getAtKey (key1, key2, key3, key4, key5, key6);
		if tmpObj = _object then
			self.removeKeyEntry(key1, key2, key3, key4, key5, key6, _object);
		else
			iter := self.createIterator ();
			while iter.next (obj) do
