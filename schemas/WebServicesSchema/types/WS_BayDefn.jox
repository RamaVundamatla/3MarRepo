    <JadeMethod name="createProxy" id="f6081536-10fe-43a6-862e-3fe9ec79cb22">
        <source>createProxy(_pxyVessel : CM_CellularVesselStructure;
			_pxyHold : CM_Hold;
			_wsHold : WS_HoldDefn) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	realHold : CM_VesselHold;
	realBay,
	pxyBay			: CM_BayDefn;
	wsCell			: WS_CellDefn;
	wsSlot			: WS_SlotDefn;
	wsHatch 		: WS_HatchLidDefn;
	wsTier 			: WS_TierDefn;
	wsLayout 		: WS_Layout;
	fortyID 		: String;
	bayType 		: Integer;
	bayHoldIndex 	: Integer;
	completedOK 	: Boolean;
	isForty : Boolean;
	cellOrdStart, cellOrdEnd : Integer;
	maxPileWeight20OB, maxPileWeight20IB,maxPileWeight40IB, maxPileWeight40OB, maxWeightUD : Integer;
begin
	
	//using 40ft ids by default
	if _wsHold.allBays.size = 1 then
		bayType := BAY_TYPE_SINGLE;
	elseif _wsHold.allBays.size =  2 then
		bayType := BAY_TYPE_TWIN;
		bayHoldIndex:=_wsHold.allBays.indexOf(self);
		if bayHoldIndex = 1 then
			fortyID:= (self.label.Integer + 1).padLeadingWith("0",2);
		endif;
	elseif _wsHold.allBays.size = 3 then
		bayType := BAY_TYPE_TRIPLE;
		bayHoldIndex:=_wsHold.allBays.indexOf(self);
		if bayHoldIndex = 1 or bayHoldIndex = 2  then
			fortyID:= (self.label.Integer + 1).padLeadingWith("0",2);
		endif;
	endif;
	
	// Set Default for is 40 foot bay
	foreach wsSlot in self.allSlots discreteLock do
		if wsSlot.is40 then
			isForty := true;
			break;
		endif;
	endforeach;
	
	// Set Inboard and Outboard weights from cell weights
	cellOrdStart := 9999999;
	foreach wsHatch in self.allHatchLids discreteLock do
		cellOrdStart := cellOrdStart.min(wsHatch.ordinalCellStart);
		cellOrdEnd := cellOrdStart.max(wsHatch.ordinalCellEnd);
	endforeach;
	
	// Inboard  means that the on deck cell in over a hatch lid
	// Outboard means that the cell is not over a hatch lid
	foreach wsCell in self.allCells discreteLock do
		if wsCell.ordinalDeck = DeckUnderDeck then
			maxWeightUD := maxWeightUD.max(wsCell.maxWeight20 * 1000);
			continue;
		endif;
		if wsCell.ordinal &lt; cellOrdStart then
			if maxPileWeight20OB = 0 then
				maxPileWeight20OB := wsCell.maxWeight20 * 1000;
				maxPileWeight40OB := wsCell.maxWeight40 * 1000;
			endif;
		elseif wsCell.ordinal &gt;= cellOrdStart and wsCell.ordinal &lt; cellOrdEnd then
			if maxPileWeight20IB = 0 then
				maxPileWeight20IB := wsCell.maxWeight20 * 1000;
				maxPileWeight40IB := wsCell.maxWeight40 * 1000;
			endif;
		endif;
		
		

	endforeach;

	create pxyBay transient;		

	
	pxyBay.setProxyBay(self.label, //id
						fortyID, // 40 ft id
						null, //cloned for bay
						self.lashFromTier,
						self.unlashFromTier,
						null, //remarks
						self.ordinal,
						bayType,// bayType can derive
						maxPileWeight20IB, // maxPileWeight20IB
						maxPileWeight20OB, //_maxPileWeight20OB
						maxPileWeight40IB, //_maxPileWeight40IB 
						maxPileWeight40OB, //_maxPileWeight40OB
						maxWeightUD, //_maxPileWeightUD
						self.numOfPlugs,
						_pxyHold.ordinalHold,
						false ,// _athwartships
						isForty, //40 ft bay
						false, // 40ft only,
						self.useCellTierODSequencing,
						self.useCellTierUDSequencing,
						self.useCellTierODSequencing40,
						self.useCellTierUDSequencing40,
						self.isTwinLiftOD,
						self.isTwinLiftUD,
						_pxyVessel,
						_pxyHold,
						self.onShipCrane,
						false, // 45ft bay
						false ); //45ft bay only 
	
	foreach wsCell in self.allCells discreteLock do
			wsCell.createProxy(pxyBay);		
	endforeach;
	
	foreach wsTier in self.allTiers discreteLock do
		wsTier.createProxy(pxyBay);
	endforeach;
	
	foreach wsSlot in self.allSlots discreteLock do
		wsSlot.createProxy(pxyBay);
	endforeach;
	
	foreach wsHatch in self.allHatchLids discreteLock do
		wsHatch.createProxy(pxyBay);
	endforeach;
	
	foreach wsLayout in self.allLayouts discreteLock do
		wsLayout.createProxy(pxyBay);
	endforeach;
	completedOK:=true;
epilog
	if not completedOK then	
		delete pxyBay;
	endif;
end;</source>
        <Parameter name="_pxyVessel" type="CM_CellularVesselStructure"/>
        <Parameter name="_pxyHold" type="CM_Hold"/>
        <Parameter name="_wsHold" type="WS_HoldDefn"/>
    </JadeMethod>
    <JadeMethod name="delete" id="ad6b892b-8bac-40bd-a014-db42dcebce94">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlger1	Initial creation 7521

*/

vars

begin
	self.allCells.purge;
	self.allHatchLids.purge;
	self.allLayouts.purge;
	self.allSlots.purge;
	self.allTiers.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyCells" id="5b628b03-c8c3-47cb-a327-ca4fc16f8841">
        <source>setProxyCells(_bay: CM_Bay) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	wsCell : WS_CellDefn;
	cell 	: CM_CellDefn;

begin

	foreach cell in _bay.allCellsOnDeckByOrdinal discreteLock do
		create wsCell transient;
		wsCell.setProxyFromObject(cell);
		self.allCells.add(wsCell);
	endforeach;
	
	foreach cell in _bay.allCellsUnderDeckByOrdinal discreteLock do
		create wsCell transient;
		wsCell.setProxyFromObject(cell);
		self.allCells.add(wsCell);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bay" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="93c11aec-f6e4-4705-a91b-56bd4220ccd8">
        <updating/>
        <source>setProxyFromObject(_bay: CM_Bay) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	
	
begin
	inheritMethod(_bay);
	
	self.label	:= _bay.id;
	self.ordinal := _bay.ordinalBay;
	self.isTwinLiftOD := _bay.isTwinLiftOD;
	self.isTwinLiftUD := _bay.isTwinLiftUD;
	self.lashFromTier := _bay.lashFromTier;
	self.unlashFromTier := _bay.unlashFromTier;
	self.numOfPlugs := _bay.numOfPlugs;
	self.onShipCrane := _bay.onShipCrane;
	
	self.useCellTierODSequencing :=_bay.useCellTierODSequencing;
	self.useCellTierODSequencing40 := _bay.useCellTierODSequencing40;
	self.useCellTierUDSequencing := _bay.useCellTierUDSequencing;
	self.useCellTierUDSequencing40 := _bay.useCellTierUDSequencing40;
	
	self.setProxyHatchLids(_bay);
	self.setProxyCells(_bay);
	self.setProxyTiers(_bay);
	self.setProxySlots(_bay);
	self.setProxyLayouts(_bay);
epilog

end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObjectBay" id="dce5e32c-e2d6-4ff4-98a8-5df6010bd0a5">
        <updating/>
        <source>setProxyFromObjectBay(_bay: CM_Bay) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2015		CNWAB1		Initial creation
*/

vars
	
	
begin
	self.cmObjectEdition	:= _bay.edition();
	self.cmObjectId			:= _bay.getOidAsString();
	
	self.label	:= _bay.id;
	self.ordinal := _bay.ordinalBay;
	self.isTwinLiftOD := _bay.isTwinLiftOD;
	self.isTwinLiftUD := _bay.isTwinLiftUD;
	self.lashFromTier := _bay.lashFromTier;
	self.unlashFromTier := _bay.unlashFromTier;
	self.numOfPlugs := _bay.numOfPlugs;
	self.onShipCrane := _bay.onShipCrane;
	
	self.useCellTierODSequencing :=_bay.useCellTierODSequencing;
	self.useCellTierODSequencing40 := _bay.useCellTierODSequencing40;
	self.useCellTierUDSequencing := _bay.useCellTierUDSequencing;
	self.useCellTierUDSequencing40 := _bay.useCellTierUDSequencing40;
	
epilog

end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="setProxyHatchLids" id="fde5a75f-20bf-49dd-800b-317694790939">
        <source>setProxyHatchLids(_bay: CM_Bay) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	wsHatch : WS_HatchLidDefn;
	hatch	: CM_HatchLid;
begin

	foreach hatch in _bay.allHatchLids discreteLock do
		create wsHatch transient;
		wsHatch.ordinalBay:=self.ordinal;
		wsHatch.setProxyFromObject(hatch);
		self.allHatchLids.add(wsHatch);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bay" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="setProxyLayouts" id="b3af18f5-3008-42cf-8e0c-18379585be6a">
        <source>setProxyLayouts(_bay: CM_Bay) protected;
/*

Date		Who		Reason
16 August 2013	cnwer1	Initial creation PAR

*/

vars
	wsLayout	: WS_Layout;
	layout 		: CM_BayItemLayout;
begin
	foreach layout in _bay.allBayItemLayouts discreteLock do
		create wsLayout transient;
		wsLayout.setProxyFromObject(layout);
		self.allLayouts.add(wsLayout);
	endforeach;
	
	// 32286 - .NET VEssel Defn Part 2
	if self.allLayouts.isEmpty() then
		create wsLayout transient;
		wsLayout.setProxyBayDefault(_bay);
		self.allLayouts.add(wsLayout);
	
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bay" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="setProxySlots" id="ea4ffba7-a7eb-44d5-bcdd-41f561c2a10c">
        <source>setProxySlots(_bay: CM_Bay) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	wsSlot	: WS_SlotDefn;
	slot 	: CM_SlotDefn;
begin
	// PAR 32286	foreach slot in _bay.allSlotsByOrdinal discreteLock do
	foreach slot in _bay.allSlotsByOrdinal discreteLock where slot.unavailable = false do
		create wsSlot transient;
		wsSlot.setProxyFromObject(slot);
		self.allSlots.add(wsSlot);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bay" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="setProxyTiers" id="f96390ad-0f32-4089-9a11-7f7b40bdc17a">
        <source>setProxyTiers(_bay: CM_Bay) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwer1	Initial creation HAT 2189

*/

vars

	wsTier : WS_TierDefn;
	tier 	: CM_TierDefn;
begin

	foreach tier in _bay.allTiersOnDeck discreteLock do
		create wsTier transient;
		wsTier.setProxyFromObject(tier);
		self.allTiers.add(wsTier);
	endforeach;
	
	foreach tier in _bay.allTiersUnderDeck discreteLock do
		create wsTier transient;
		wsTier.setProxyFromObject(tier);
		self.allTiers.add(wsTier);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bay" type="CM_Bay"/>
    </JadeMethod>
</Class>
