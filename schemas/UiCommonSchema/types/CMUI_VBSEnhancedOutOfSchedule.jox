    <JadeMethod name="setupForm" id="d36e0987-e4a1-460b-9968-dec9df6690e0">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Mar 2025	navlc30	Initial creation
31 Mar 2025 navlc30 JIRA 34265 TPT | FR 33661.030 VBS - One Release Request and One VBS slot - Off Schedule
03 Sep 2025 navlc30 JIRA 35531 - Address the Error to allow Processing multiple Release Requests on a single VBS Slot at the Gate

*/

vars
	vbsId : String;
	startTime : TimeStamp;
	rrCode : String;
	relReq	: CM_BulkRelease;
begin
	inheritMethod();
	
	self.maxButton := false;
	self.minButton := false;
	self.width := 530;
	self.height := 170;	
	self.lblMsg.fontSize := 11;

	relReq := self.myReleaseRequest;						//03.09.2025 navlc30 #35531
	if relReq &lt;&gt; null then									//03.09.2025 navlc30 #35531
		relReq.getVBSDetails(vbsId, startTime);
		rrCode := relReq.code;
	endif;
	
	self.lblMsg.caption := app.getErrorString3(Vehicle_booking_outOfSchedule, vbsId, startTime.asStringJMT(), rrCode);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7c2a463f-fc9c-4536-9460-28e8a76533ab">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 01 April 2025 19:33:18.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0027070, locale);
	btnContinue.translateBubbleHelp(Xlat_0027071, locale);
	btnContinue.translateCaption(Xlat_0027072, locale);
	btnReject.translateBubbleHelp(Xlat_0027073, locale);
	btnReject.translateCaption(Xlat_0027074, locale);
	lblMsg.translateCaption(Xlat_0027075, locale);
end;</source>
    </JadeMethod>
</GUIClass>
