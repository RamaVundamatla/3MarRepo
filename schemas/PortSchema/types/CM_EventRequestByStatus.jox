<CollClass name="CM_EventRequestByStatus" id="ed13abf8-c3a0-429f-a015-8d8561e42a8a">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_EventRequest"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="eventRequest"/>
    <MemberKey>
        <property name="CM_EventRequest::status"/>
    </MemberKey>
    <JadeMethod name="includesGtrThanOne" id="7f44f4fc-fba0-4973-a8ed-3c381df9f730">
        <source>includesGtrThanOne( _type : Integer ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	iter : Iterator;
	eventRequestStops : CM_EventRequestStops;
	count : Integer;

begin

	iter := self.createIterator;
	while iter.next( eventRequestStops ) do
		if eventRequestStops.type = _type then
			count := count + 1;
		endif;
	endwhile;

	return count &gt; 1;

epilog

	delete iter;

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
