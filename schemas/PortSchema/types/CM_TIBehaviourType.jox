    <JadeMethod name="getTableViews" id="57685620-1ab0-4b8f-be1a-3a492d09703f">
        <source>getTableViews(_cargoTypeAttributeName : String) : String;
// -------------------------------------------
// Created 05 December 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if _cargoTypeAttributeName = CM_CargoBOLType::mainFormFilterView.name then
		return ETDef_Default;
	elseif _cargoTypeAttributeName = CM_CargoBOLType::maintFormTblDataDef.name then
		return ETDef_DefaultDataTable;
	endif;


end;</source>
        <Parameter name="_cargoTypeAttributeName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="bdc357ca-c1bc-42d2-b946-4b8eabda1922">
        <updating/>
        <source>setForCreate(_pxyTIBehaviourType : SelfType) updating;
// -------------------------------------------
// Created 03 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.behaviourType 		:= _pxyTIBehaviourType.behaviourType;
	self.setForUpdate(_pxyTIBehaviourType);


end;</source>
        <Parameter name="_pxyTIBehaviourType" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="41d5b01a-e232-49db-a472-7e0a11e94f12">
        <updating/>
        <source>setForUpdate(_pxyTIBehaviourType : SelfType) updating;
// -------------------------------------------
// Created 03 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.classNameToCreate	:= _pxyTIBehaviourType.classNameToCreate;
	self.description		:= _pxyTIBehaviourType.description;
	self.isSystemType		:= _pxyTIBehaviourType.isSystemType;
	
	self.myRoot				:= _pxyTIBehaviourType.myRoot;
	
	// PAR 18996 - add in creation of default graphic if not set
	if self.myGraphic = null or
	   (self.myGraphic &lt;&gt; null and self.myGraphic.allCommands.isEmpty) then
		self.createDefaultGraphic();
	endif;


end;</source>
        <Parameter name="_pxyTIBehaviourType" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromXML" id="2eab3b28-3698-4bcb-bbc3-eef5fc4596c7">
        <updating/>
        <source>setProxyFromXML(_behaviourType : Integer; _classNameToCreate, _desc : String; _isSystemType : Boolean; _root : CM_Root) updating;
// -------------------------------------------
// Created 03 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	self.behaviourType		:= _behaviourType;
	self.classNameToCreate	:= _classNameToCreate;
	self.description		:= _desc;
	self.isSystemType		:= _isSystemType;
		
	self.myRoot				:= _root;


end;</source>
        <Parameter name="_behaviourType" type="Integer"/>
        <Parameter name="_classNameToCreate" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_isSystemType" type="Boolean"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="setThumbAndEditDefs" id="52dbb09d-dcb7-403d-9b56-8e5b42a57aeb">
        <source>setThumbAndEditDefs(_allThumbDefs, _allEditDefs : StringArray input);
// -------------------------------------------
// Created 05 December 2005 by cnwdvb1
// -------------------------------------------
vars

begin
app.writeStatement(method.qualifiedName &amp; " 1. ");
	_allThumbDefs.clear();
	_allEditDefs.clear();
	

	_allThumbDefs.add(ETDef_WHGeneralData);
	_allThumbDefs.add(ETDef_BreakBulkEnt);
	_allThumbDefs.add(ETDef_WHReceiveRelease);
	
	_allEditDefs.add(ETDef_WHGeneralData);
	_allEditDefs.add(ETDef_BreakBulkEnt);
	_allEditDefs.add(ETDef_WHReceiveRelease);

end;</source>
        <Parameter name="_allThumbDefs" type="StringArray" usage="input"/>
        <Parameter name="_allEditDefs" type="StringArray" usage="input"/>
    </JadeMethod>
</Class>
