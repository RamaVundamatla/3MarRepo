    <JadeMethod name="setForRedraw" id="d30b7134-025a-4768-beb4-159b76ee48f2">
        <updating/>
        <source>setForRedraw(_obj : Object;x1,y1,x2,y2 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
begin
	self.x1	:= x1;
	self.y1	:= y1;
	self.x2	:= x2;
	self.y2	:= y2;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="x1" type="Integer"/>
        <Parameter name="y1" type="Integer"/>
        <Parameter name="x2" type="Integer"/>
        <Parameter name="y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setIconPositions" id="c20c1160-b98c-41d4-b938-be55c18ac389">
        <updating/>
        <source>setIconPositions(_x1,_y1,_x2,_y2: Real) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*
Date		Who		Reason
05 Dec 2008 consw1	SFW1030 - Yard Allocation enhancements (include extra info with zoom)
*/

constants
	ColWidth		: Integer = 24;

vars
	yOffset,
	theX, theY,theCharacterWidth,theWidth, startX		: Integer; 
	tmpY,
	tmpScaleFactor: Real;
begin
	
	// the passed in _x1 has already been adjusted for 30, 45, 53 footers, else for 20 and 40 footers the _x1 will be the same as the self.x1.
	startX := 2;// + (_x1 - self.x1).Integer;
	
	if self.tiLength &gt;= 4 then
		self.attrMaxNum := 5;		
	else
		self.attrMaxNum := 2;
	endif;

	theCharacterWidth := (self.scaleFactor * 8).Integer; // PAR 18368

	tmpScaleFactor := self.scaleFactor;

	if self.tiHeight = Ti_Half_Height then
		self.setFontDefaults();
		if tmpScaleFactor = ScaleFactor_2 then
			yOffset := 2;
		elseif tmpScaleFactor = ScaleFactor_3 then
			yOffset := 0;
		elseif tmpScaleFactor = ScaleFactor_4 then
			yOffset := 5;
		elseif tmpScaleFactor = ScaleFactor_1_5 then
			yOffset := 5;
		elseif tmpScaleFactor = ScaleFactor_1 then
			yOffset := 1;
		endif;
	else

		if tmpScaleFactor = ScaleFactor_1 then
			yOffset := 0;
		elseif tmpScaleFactor = ScaleFactor_1_5 then
			yOffset := 1;
		elseif tmpScaleFactor = ScaleFactor_2 then
			yOffset := 1;
		elseif tmpScaleFactor = ScaleFactor_3 then
			yOffset := 14;
		elseif tmpScaleFactor = ScaleFactor_4 then
			yOffset := 26;
		elseif tmpScaleFactor = ScaleFactor_6 then    // PAR 36575
			yOffset := 36;
			if self.attrMaxNum = 2 then
				self.attrMaxNum := 3;
			endif;
		elseif tmpScaleFactor = ScaleFactor_9 then
			yOffset := 46;
			if self.attrMaxNum = 2 then
				self.attrMaxNum :=5;
			endif;
		endif;
	endif;
	tmpY := (_y1 - self.y1) + yOffset;
	
	self.attrX1 := startX;
	self.attrY1 := tmpY;
	self.attrX2 := startX + theCharacterWidth;
	self.attrY2 := tmpY;
	self.attrX3 := startX + (theCharacterWidth * 2);
	self.attrY3 := tmpY;
	self.attrX4 := startX + (theCharacterWidth * 3);
	self.attrY4 := tmpY;
	self.attrX5 := startX + (theCharacterWidth * 4);
	self.attrY5 := tmpY;

end;</source>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setIconPositionsEndOn" id="8bd9cfbc-9001-4558-bbba-b5329a975052">
        <updating/>
        <source>setIconPositionsEndOn(_x1: Real; _y1: Real; _x2: Real; _y2: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2010	cnwndl1	Initial creation	Par 24044

*/

vars
	yOffset, xOffset,
	theX, theY,theCharacterWidth,theWidth, startX		: Integer; 
	tmpY,
	tmpScaleFactor,theFontSize: Real;
begin
	startX := 2;
	self.attrMaxNum := 2;
	theCharacterWidth := ((_x2 - _x1) / 2).Integer;
	
	tmpScaleFactor := self.scaleFactor;

	if tmpScaleFactor = ScaleFactor_1 then
		yOffset := 0;
	elseif tmpScaleFactor = ScaleFactor_1_5 then
		yOffset := 1;
	elseif tmpScaleFactor = ScaleFactor_2 then
		xOffset := 2;
		yOffset := 11;
	elseif tmpScaleFactor = ScaleFactor_3 then
		xOffset := 2;
		yOffset := 14;
	elseif tmpScaleFactor = ScaleFactor_4 then
		xOffset := 5;
		yOffset := 18;
	elseif tmpScaleFactor = ScaleFactor_6 then
		xOffset := 5;
		yOffset := 40;
		self.attrMaxNum := 2;
	elseif tmpScaleFactor = ScaleFactor_9 then
		xOffset := 5;
		yOffset := 60;
		self.attrMaxNum := 3;
	endif;

	tmpY := (_y1 - self.y1) + yOffset;
	self.attrX1 := startX;
	self.attrY1 := tmpY;
	self.attrX2 := startX + theCharacterWidth - xOffset;
	self.attrY2 := tmpY;
	self.attrX3 := startX + (theCharacterWidth * 2);
	self.attrY3 := tmpY;
	self.attrX4 := startX + (theCharacterWidth * 3);
	self.attrY4 := tmpY;
	self.attrX5 := startX + (theCharacterWidth * 4);
	self.attrY5 := tmpY;

end;</source>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setIgnoreSkin" id="4597f226-1bd1-4b60-a294-010cf7323050">
        <source>setIgnoreSkin();
// ---------------------------------------------------------------------------
// Created:		11 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	if self.myDrawingFrame &lt;&gt; null then		// PAR 21532 CCMS SFW 1025
