    <JadeMethod name="mnuShowInvoice_click" id="4e3c2fdb-2cf7-4028-b66b-70780a200660">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuShowInvoice_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     26 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	table : Table;
	anObject : Object;
	invoice	: CM_Invoice;
begin
	// PAR 24016
	table := self.tblCharges;
	if table.row &gt; table.fixedRows then
		anObject := table.accessRow(table.row).itemObject;
		if anObject.isKindOf(CM_InvoiceLine) then
			invoice := anObject.CM_InvoiceLine.invoice;
		elseif anObject.isKindOf(CM_CashPayment) then
			invoice := anObject.CM_CashPayment.myInvoice;
		endif;
		if invoice &lt;&gt; null then
			self.myAssistant.showInvoiceLineForm(invoice, self.myMasterMenuAction);
		endif;
	endif;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
