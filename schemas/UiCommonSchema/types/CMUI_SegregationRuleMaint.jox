    <JadeMethod name="addToolbarControls" id="6328b2c9-8770-458e-a81f-e32964997a5b">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	22 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	toolbar		: CMUI_Toolbar;
begin
	
	inheritMethod();
	toolbar := self.frmToolbar;	
	toolbar.addFrame(self.frmMode, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.positionToolbarControls();
	toolbar.showCaptions := false;
	toolbar.visible := true;
	
	toolbar := self.frmToolConds;
	toolbar.addButton(self.btnNewRule, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditRule, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeleteRule, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.showCaptions := false;
	toolbar.visible := true;
	toolbar.top := 17;
	toolbar.left := 5; // ### TFS 50421 27OCT2021 NAVAB1
	
	toolbar := self.frmToolCondEdit;
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelRule, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.showCaptions := false;
	toolbar.visible := true;
	
	toolbar := self.frmToolbarMatrix;
	toolbar.addButton(self.btnEditMatrix, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveMatrix, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelMatrix, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnExportMatrix, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnImportMatrix, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.showCaptions := false;
	toolbar.visible := true;
	toolbar.top := 17;
	toolbar.left := 5; // ### TFS 50421 27OCT2021 NAVAB1
	
	self.btnSaveBase.bubbleHelp := 'Save condition';
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="armNotifications" id="3a3b902f-6132-4cb3-ab93-c8ae502067cf">
        <source>armNotifications() protected;
/*
----------   ----------  --------------------------------------------------
Created:	28 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	self.endNotificationForSubscriber(self);
	self.beginClassNotification(CM_SegregationCondition, false, Any_System_Event, Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(SegMatrix_Update_Event), Response_Continuous, null);
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="assignConditionToCell" id="2ddc214d-6126-4ed5-82ae-2014a0071baa">
        <source>assignConditionToCell(_row, _col, _button : Integer) protected;
/*
----------   ----------  --------------------------------------------------
Created:	28 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	matrixTrans			: CM_SegregationMatrixTrans;
	tbl					: CM_DataTable;
	realSegRule,
	pxySegRule			: CM_SegregationRule;
	
begin
	tbl := self.tblMatrix;
	matrixTrans := tbl.accessCell(_row, _col).itemObject.CM_SegregationMatrixTrans;
	pxySegRule := matrixTrans.myPxySegregationRule;
	realSegRule := self.myTerminal.allSegRulesByEntity1Entity2[self.ruleMode, matrixTrans.myEntity1, matrixTrans.myEntity2];
	
	if _button = self.MouseButton_Left then	
		if pxySegRule &lt;&gt; null and matrixTrans.myPxySegregationRule.mySegregationCondition = self.mySelectedCondition then
			//same condition re-clicked should clear the cell
			delete pxySegRule;
			matrixTrans.myPxySegregationRule := null;
			tbl.accessCell(_row, _col).backColor := White;
			tbl.accessedCell.text := null;
			return;
		endif;
		
		if pxySegRule = null then
			if realSegRule &lt;&gt; null then //user has deleted the rule and put it back where this persistent one is - so create proxy from it
				pxySegRule := app.createUpdateProxy(realSegRule).CM_SegregationRule;
			else
				create pxySegRule transient;//create place holder for new rule
			endif;
		endif;
		matrixTrans.myPxySegregationRule := pxySegRule;
		//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-haz1 = ' &amp; matrixTrans.myEntity1.CM_HazardClass.code);
		//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-haz2 = ' &amp; matrixTrans.myEntity2.CM_HazardClass.code);
		
		matrixTrans.myPxySegregationRule.setProxy(matrixTrans.myEntity1, matrixTrans.myEntity2, self.mySelectedCondition, self.myTerminal);
		
		tbl.accessCell(_row, _col).backColor := self.mySelectedCondition.colour;
		tbl.accessedCell.text := self.mySelectedCondition.code;
	/*	
	elseif _button = self.MouseButton_Right then
		if pxySegRule &lt;&gt; null then
			delete matrixTrans.myPxySegregationRule;
			tbl.accessCell(_row, _col).backColor := White;
		endif;
	*/
	endif;

epilog
	
	tbl.accessCell(_row, _col).selected := false;

end;


</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_button" type="Integer"/>
    </JadeMethod>
