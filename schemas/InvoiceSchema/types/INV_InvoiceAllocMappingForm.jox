        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadStorageTable" id="79d66289-21b4-4d2f-a61a-bda3a245c3a2">
        <updating/>
        <source>loadStorageTable() updating, protected;
/*

Purpose:			TFS 7496

Parameters:			

Return Value:		

Date		Who		Reason
15 Nov 2017	jlgab1	Initial creation
27 Mar 2020 cnwma1  Bug 48558: PRP - Calculation Types   
*/

vars

	row		: Integer;
	table	: CM_DataTable;
	subqrm,
	qrm     : CM_QuantityRangeMap;
begin
	
	self.myQuantityRangeMap := null;
	
	table            := self.tblGroups;
	table.top        := self.lblCriteria.top + 30;
	table.height     := self.btnAdd.top - table.top - 10;
	table.selectMode := Table.SelectMode_CurrentRow;
	table.rows       := 0;
	table.fixedRows  := 1;
	table.columns    := 1;
	table.addItem(app.getErrorString(Invoice_line_mappings));
	
	if self.myInvoiceAlllocation.isKindOf( CM_InvoiceAllocation ) then
		if self.myInvoiceAlllocation.CM_InvoiceAllocation.myQuantityMap &lt;&gt; null then  //27.03.2020 cnwma1 #48558
			foreach qrm in self.myInvoiceAlllocation.CM_InvoiceAllocation.myQuantityMap.allQuantityRanges discreteLock do
				
				/* //09/01/2025	navkc1 JIRA Sub-task MTN-19517
				row := table.addItem(qrm.getFullName());
				table.accessRow(row).itemObject := qrm;
				*/
				
				//09/01/2025	navkc1 JIRA Sub-task MTN-19517
				row := table.addItemObject(qrm, qrm.getFullName());
				if qrm.myChildQuantityMap &lt;&gt; null then
					foreach subqrm in qrm.myChildQuantityMap.allQuantityRanges discreteLock do
						row := table.addItemObject(subqrm, Space.makeString(5) &amp; "&gt;&gt;&gt; " &amp; subqrm.getFullName());
					endforeach;
				endif;
				
				if self.myQuantityRangeMap = null then // default
					self.myQuantityRangeMap := qrm;
				endif;
				
			endforeach;
		endif;
		
	elseif self.myInvoiceAlllocation.myServiceBroker &lt;&gt; null then
		if self.myInvoiceAlllocation.myServiceBroker.myChildQuantityMap &lt;&gt; null then  //27.03.2020 cnwma1 #48558
			foreach qrm in self.myInvoiceAlllocation.myServiceBroker.myChildQuantityMap.allQuantityRanges discreteLock do
			
				row := table.addItem(qrm.getFullName());
				table.accessRow(row).itemObject := qrm;
				if self.myQuantityRangeMap = null then // default
					self.myQuantityRangeMap := qrm;
				endif;
			endforeach;
		endif;
	endif;
	
	//21 Dec 2017	NDL	TFS 8095
	self.btnAudits.enabled := self.myQuantityRangeMap &lt;&gt; null and self.myQuantityRangeMap.hasAudits;	//14 Jan 2021	NDL	TFS 50152

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f9b74f21-e376-412e-89d6-dbb7acf4558c">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			TFS 7496

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlgab1	Initial creation
04 Feb 2019	NDL	TFS 43153
04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions
*/

vars

begin

	
	inheritMethod();
	//09/01/2025	navkc1 JIRA Sub-task MTN-19517 - Display this
	//self.btnAddSub.visible := false;	 // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1
	
	self.caption := app.getErrorString(Cargo_invoice_allocat_mapping);
	
	self.cmbGroup.visible := false;
	self.lblGroup.visible := false;

	if self.myInvoiceAlllocation.isKindOf( CM_InvoiceCargoAllocation ) then
		self.beginNotification(self.myInvoiceAlllocation.CM_InvoiceCargoAllocation.myTransactionMap, self.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_CREATE), Response_Continuous, null); 
		self.beginNotification(self.myInvoiceAlllocation.CM_InvoiceCargoAllocation.myTransactionMap, self.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_UPDATE), Response_Continuous, null); 
		self.beginNotification(self.myInvoiceAlllocation.CM_InvoiceCargoAllocation.myTransactionMap, self.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_DELETE), Response_Continuous, null);
	elseif self.myInvoiceAlllocation.isKindOf( CM_InvoiceInventoryAllocation ) then // ### TFS 51219 25MAY2021 NAVAB1
		self.beginNotification(self.myInvoiceAlllocation.CM_InvoiceInventoryAllocation.myTransactionMap, self.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_CREATE), Response_Continuous, null);  // ### TFS 51219 25MAY2021 NAVAB1
		self.beginNotification(self.myInvoiceAlllocation.CM_InvoiceInventoryAllocation.myTransactionMap, self.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_UPDATE), Response_Continuous, null);  // ### TFS 51219 25MAY2021 NAVAB1
		self.beginNotification(self.myInvoiceAlllocation.CM_InvoiceInventoryAllocation.myTransactionMap, self.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_DELETE), Response_Continuous, null); // ### TFS 51219 25MAY2021 NAVAB1
		self.caption := app.getErrorString(Inventory_allocation_mapping); // ### TFS 51219 25MAY2021 NAVAB1
		
	elseif self.myInvoiceAlllocation.isKindOf( CM_InvoiceAllocation ) then
		self.caption := app.getErrorString(Snapshot_allocation_mapping);
		self.beginNotification(self.myInvoiceAlllocation.CM_InvoiceAllocation.myServiceBroker, self.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE), Response_Continuous, null); 
		self.beginNotification(self.myInvoiceAlllocation.CM_InvoiceAllocation.myServiceBroker, self.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_DELETE), Response_Continuous, null); 
		self.beginNotification(self.myInvoiceAlllocation.CM_InvoiceAllocation.myServiceBroker, self.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_CREATE), Response_Continuous, null);
		
	endif;

	// TFS 7496
	// 04/05/2023	navkc1	Bug 57484
	self.doNoMaintPermDisableControls();
	
	
	self.tblGroups.setFocus;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showStorageDetail" id="2fe8722e-660e-4f88-a94e-925fb1642873">
        <updating/>
        <source>showStorageDetail() updating, protected;
/*

Purpose:			TFS 7496

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlgab1	Initial creation

*/

vars

	str			: String;
begin
	if self.myInvoiceAlllocation = null then
		return;
	endif;

	if self.myInvoiceAlllocation.isKindOf( CM_InvoiceAllocation ) then
		self.lblCriteria.caption := self.myInvoiceAlllocation.CM_InvoiceAllocation.getDisplayDescriptionString;
	else
		self.lblCriteria.caption := self.myInvoiceAlllocation.description;
	endif;



epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="94ff7485-f0ba-4e74-821c-cb97a108d9c8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 16:04:55.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022922, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="0eded6c7-ac30-4a07-87bc-ddc0160346bf">
