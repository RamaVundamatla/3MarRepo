    <JadeMethod name="setTABulk" id="a8fdd884-220d-40b1-97c1-56a83788587e">
        <updating/>
        <source>setTABulk():Boolean updating;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------
// 14/04/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk - create decking options for Bulk areas
vars
	taType 				: CM_TerminalAreaType;
	proxyTA				: CM_BulkArea;
	id					: String;
	type				: Integer;
	colour				: Integer;
	typeString			: String;
	rel					: Boolean;
	max					: Integer;
	comment				: String;
	autoRestrict		: Boolean;
	hide				: Boolean;
	maxVolume			: Decimal[16,4];
	minVolume			: Decimal[16,4];
	maxWeight			: Integer;
	minWeight			: Integer;
	maxQuantity 		: Integer;
	pxyProdMinMax : CM_TerminalAreaProductMinMax;
	aProd : CM_Product;
	tmpInterchange	: String;
	interchangeArea	: CM_InterchangeArea;
	selectedInterchangeAreas : CM_InterchangeAreaArray;	//05 Feb 2016	NDL	Par 37500
	cargoType : CM_CargoType;
begin

	if (not getProxyObject(CM_BulkArea)) then
		return false;
	endif;
	
	taType := getTAStringToType(tblMain.getValueByName(ETRow_Type).String);
	proxyTA := myProxyObject.CM_BulkArea;

	id 			:= tblMain.getValueByName(ETRow_Id).String[1:13];
	type		:= taType.type;
	typeString 	:= tblMain.getValueByName(ETRow_Type).String.trimBlanks;
	rel 		:= tblMain.getValueByName(ETRow_ActAsReleasePoint).Boolean;
	max 		:= tblMain.getValueByName(ETRow_MaxCapacity).Integer;
	hide		:= tblMain.getValueByName(ETRow_HideFromOverView).Boolean;
	autoRestrict:= false; //tblMain.getValueByName(ETRow_AutoRestrictionsEnabled).Boolean;
	colour 		:= tblMain.getValueByName(ETRow_Colour).Integer;
	comment 	:= tblMain.getValueByName(ETRow_Comment).String;
	tmpInterchange	:= tblMain.getValueByName(ETRow_InterchangeArea).String;
	interchangeArea	:= self.myTerminal.allTerminalAreas[tmpInterchange].CM_InterchangeArea;

	create selectedInterchangeAreas transient;
	listsTermAreas.getSelected(selectedInterchangeAreas);
	
	if proxyTA.myLayoutGraphic &lt;&gt; null then
		proxyTA.myLayoutGraphic.setProxyColour(colour, White);
	else
		// 24/06/2009 - added next line to make sure the colour gets saved 
		// to the proxy even for a  new TA
		self.setGraphicLayout(colour);
	endif;
	if mode = Mode_Add then
		proxyTA.setIsEmpty(true);
	endif;	

	aProd := self.cmbProduct.listObject.CM_Product;
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	if cargoType &lt;&gt; null or aProd &lt;&gt; null then
		pxyProdMinMax := proxyTA.getProductMinMaxObject(cargoType,aProd);
		if pxyProdMinMax = null then
			create pxyProdMinMax transient;
		endif;
		
		maxVolume	:= tblExtra.getMeasurementValueByName(ETRow_TaMaxVolume).String.asDecimalJMT;		// 36603 was .Decimal	
		maxWeight	:= tblExtra.getMeasurementValueByName(ETRow_MaxWeight).Decimal.Integer;
		maxQuantity	:= tblExtra.getValueByName(ETRow_MaxQuantity).asStringJMT.Integer;
		pxyProdMinMax.setupProxy(null, cargoType, aProd, proxyTA,minVolume, minWeight, maxVolume, maxWeight,maxQuantity);
		
	endif;
	
	
	proxyTA.setProxy(id, comment, type,  myTerminal, maxVolume, minVolume, maxWeight, minWeight, autoRestrict, hide, null, selectedInterchangeAreas,interchangeArea);
	self.createDeckingOptionsProxy(proxyTA);					// PAR #33606
	
	return true;
epilog
	delete selectedInterchangeAreas;
end;










</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTACrane" id="fb09049e-1792-400e-837c-292a9956f911">
        <updating/>
        <source>setTACrane() : Boolean updating, protected;
// 26/05/2010	cnwcs5	par 24292 - use array instead of set
vars
	pxyLC 					: CM_CraneLaneController;
	proxyTA					: CM_CraneTransferArea;
	theName,
	tmpID					: String;
	tmpType					: Integer;
	tmpHeight				: Integer;
	tmpComment,
	tmpTypeString			: String;
	tmpRel					: Boolean;
	loadCol,
	disCol,
	cageCol,
	tmpNumLanes				: Integer;
	tmpAutoPlanEnabled,
	tmpStockControlled ,tmpHide		: Boolean;
	theLane					: Integer;
	tmpInterchange	: String;
	interchangeArea	: CM_InterchangeArea;
	selectedInterchangeAreas : CM_InterchangeAreaArray;	// par 24292
begin

	if (not self.getProxyObject(CM_CraneTransferArea)) then
		return false;
	endif;

	proxyTA := self.myProxyObject.CM_CraneTransferArea;

	tmpID := tblMain.getValueByName(ETRow_Id).String[1:13];
	tmpType := TA_TYPE_CRANE_TRANS;
	tmpRel := tblMain.getValueByName(ETRow_ActAsReleasePoint).Boolean;
	tmpNumLanes := tblMain.getValueByName(ETRow_NumLanes).Integer;
	tmpAutoPlanEnabled := tblMain.getValueByName(ETRow_AutoPlanEnabled).Boolean;
	tmpStockControlled := tblMain.getValueByName(ETRow_StockControlled).Boolean;
	tmpComment := tblMain.getValueByName(ETRow_Comment).String;
	tmpHide:= tblMain.getValueByName(ETRow_HideFromOverView).Boolean;
	tmpInterchange	:= tblMain.getValueByName(ETRow_InterchangeArea).String;
	interchangeArea	:= self.myTerminal.allTerminalAreas[tmpInterchange].CM_InterchangeArea;
	
	create selectedInterchangeAreas transient;
	listsTermAreas.getSelected(selectedInterchangeAreas);
	
	self.tblGateLanes.getEntRowColumnByRowName(ETRow_IsLoad, loadCol);
	self.tblGateLanes.getEntRowColumnByRowName(ETRow_IsDischarge, disCol);
	self.tblGateLanes.getEntRowColumnByRowName(ETRow_HasCage, cageCol);
	proxyTA.loadLanes.clear;
	proxyTA.dischargeLanes.clear;
	
	foreach theLane in self.tblGateLanes.fixedRows  + 1 to self.tblGateLanes.rows do
		pxyLC:=self.tblGateLanes.accessRow(theLane).itemObject.CM_CraneLaneController;
		if pxyLC &lt;&gt; null then
			pxyLC.setNumberOfTwinLiftCages(self.tblGateLanes.accessCell(theLane,cageCol).text.Integer);
		endif;
		
		if self.tblGateLanes.accessCell(theLane,loadCol).text.Integer.Boolean then
			 proxyTA.loadLanes.add(pxyLC);
		endif;
		
		if self.tblGateLanes.accessCell(theLane,disCol).text.Integer.Boolean then
			proxyTA.dischargeLanes.add(pxyLC);
		endif;
	endforeach;
	

	proxyTA.setProxy(tmpID, 
					tmpComment,
					tmpType, 
					tmpNumLanes,
					tmpRel, 
					self.myTerminal,
					tmpAutoPlanEnabled,
					tmpStockControlled,
					tmpHide,
					selectedInterchangeAreas,
					interchangeArea);
	return true;
epilog
	delete selectedInterchangeAreas;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTADepot" id="c6f59cab-b584-465a-8993-bfb309e9ff98">
        <updating/>
        <source>setTADepot() : Boolean updating, protected;
// 26/05/2010	cnwcs5	par 24292 - use array instead of set
vars

	proxyTA 			: CM_Depot;
	tmpID				: String;
	tmpType				: Integer;
	tmpHeight			: Integer;
	tmpComment,
	tmpTypeString		: String;
