    <JadeMethod name="updateKeywords" id="8b4e627f-79fe-4bb9-9a69-731f6d97ba15">
        <source>updateKeywords(_translation : XLAT_Translation input; _globalConstantName : String);

vars
	keyword : XLAT_Keyword;
	wordsForIndexing : StringArray;
	text : String;
	shouldDelete : Boolean;

begin
	create wordsForIndexing transient;
	_translation.getKeywords(wordsForIndexing);
	
	if _globalConstantName &lt;&gt; null and
	   localeId = StandardTextLocaleStr then
		wordsForIndexing.add(_globalConstantName);
	endif;

	foreach text in wordsForIndexing do

		// is this translation &amp; keyword already indexed?
		if _translation.allKeywords[text] &lt;&gt; null then
			continue;
		endif;

		// find keyword - create if it doesn't exist	
		keyword := allTranslationKeywords[text];
		if keyword = null then
			create keyword persistent;
		endif;

		// set keyword &amp; translation relationship
		keyword.update(text, self, _translation);
	
	endforeach;
	
	foreach keyword in _translation.allKeywords do
		// Assume that the keyword no longer in wordsForIndexing
		// and should therefore be deleted.
		shouldDelete := true;
		foreach text in wordsForIndexing do
			if text.compareEql(keyword.text, true, false, null) then
				shouldDelete := false;
				break;
			endif;
		endforeach;
		if shouldDelete then
			_translation.allKeywords.remove(keyword);
			if keyword.allTranslations.size = 0 then
				delete keyword;
			endif;
		endif;
	endforeach;
	
epilog
	delete wordsForIndexing;
end;</source>
        <Parameter name="_translation" type="XLAT_Translation" usage="input"/>
        <Parameter name="_globalConstantName" type="String"/>
    </JadeMethod>
    <JadeMethod name="vLocaleIdAndDescription" id="09b7dbc5-c21a-487d-8700-701e9118701b">
        <methodInvocation>mapping</methodInvocation>
        <source>vLocaleIdAndDescription(set: Boolean; _value: String io) mapping;

vars

begin
	if localeId.length = 4 then
		_value := "  " &amp; localeId &amp; " - " &amp; localeDescription;
	else
		_value := localeId &amp; " - " &amp; localeDescription;
	endif;
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
