<Class name="CM_QTransportModeProperty" id="9ee327d7-0e3d-45cb-9ffc-322e28655770">
    <superclass name="CM_QIntegerLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="6c38a81f-1806-43aa-ac3a-0de182973898">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QIntegerLookupEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QIntegerIsOneOf persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="29e3b7e3-9ad5-48b7-b571-ea2bb3f55e60">
        <source>getKeyLengthForXTABDictionary(): Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	length	:Integer;
begin
	// just incase the global constant values change !!!
	length := TI_TRANSMODE_SHIP_STR.length;
	length := length.max (TI_TRANSMODE_ROAD_STR.length);
	length := length.max (TI_TRANSMODE_RAIL_STR.length);
	
	return length;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
