    <JadeMethod name="setRequiredByDT" id="8a37eb0f-7ec3-43d7-ac1a-67fed23caaca">
        <updating/>
        <source>setRequiredByDT(_dateTime: TimeStamp) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2018	jlgndl1	Initial creation	TFS 41084 - Tim changing his mind again.

*/

vars

	movement : HMS_VoyageMovement;
	voyage : CM_Voyage;

begin

	inheritMethod(_dateTime);
	
	if self.getMyParent.isComplete then
		voyage := self.getMyVoyageObject;
		if voyage &lt;&gt; null and not self.isTransient then
			movement := voyage.getMovementArrival();
			if movement &lt;&gt; null then
				movement.setOccursOnDT( _dateTime );
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="validate" id="b1bdfbd8-6940-4c4b-8491-f6a9fd24790d">
        <source>validate()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 February 2019	jlgndl1	Initial creation	TFS 43245

*/

