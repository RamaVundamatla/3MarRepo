    <JadeMethod name="setProxyObject" id="a9cb3b15-5209-46dd-abf8-7e20668fb5a1">
        <updating/>
        <source>setProxyObject(_any : Any) updating;
/*
Purpose:			

Date		Who		Reason
10JAN2022	NAVAB1	TFS 51855
*/


vars
	helper 	: CMIF_RailCarVisits;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.tableName	:= helper.tableName;
	self.gkey       := helper.gkey;
	self.active := helper.active;
	self.destination := helper.destination;
	self.fcy_gkey := helper.fcy_gkey;
	self.id := helper.id;
	self.in_seq := helper.in_seq;
	self.origin := helper.origin;
	self.out_seq := helper.out_seq;
	self.rcar_gkey := helper.rcar_gkey;
	self.rv_inbound_gkey := helper.rv_inbound_gkey;
	self.rv_outbound_gkey := helper.rv_outbound_gkey;



epilog
	delete helper;
	delete ewsOpsView;
end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
