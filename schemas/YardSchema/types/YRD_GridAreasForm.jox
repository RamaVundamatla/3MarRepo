    <JadeMethod name="mnuCargoAP_click" id="970d3221-1c33-4b7e-829a-54b6b291a7b2">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCargoAP_click(menuItem: MenuItem input) updating;
// -------------------------------------------
// Created 24 May 2005 by cnwdvb1
// -------------------------------------------
vars

	tiArray	: CM_TIArray;
	ti		: CM_TrackedItem;
	str		: String;
	result	: Integer;
	params : CMIF_AutoplanParams;


begin
	
	tiArray := menuItem.userObject.CM_TIArray;
	
	if tiArray = null then
		return;
	endif;
	// PAR 19450
	create params transient;
	tiArray.copy(params.allTrackedItems);
	params.moveMode := QUEUE_MODE;
	params.myTerminalArea := null;
	params.myJob := null;
	params.showWarningWhenNoPlan := true;

	
	while true do
//		str := app.myTrxUA.trxUpdateAutoplanTrackedItems(tiArray, QUEUE_MODE, null, app.myPassport);
		str := app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

epilog
		delete params;
		delete tiArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
