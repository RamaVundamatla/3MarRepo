<Class name="HMS_ResourceForPilotLaunch" id="86c7caae-415a-4fb1-afca-04bc1d2fd5c5">
    <superclass name="HMS_ResourceForObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <ExplicitInverseRef name="allPilotLaunches" id="ab260a87-fd97-45f3-a0ba-46408898e969">
        <updateMode>manual</updateMode>
        <type name="HMS_PilotLaunchByCodeDict"/>
        <access>readonly</access>
        <Inverse name="HMS_PilotLaunch::allResourcesForPilotLaunch"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myPilotLaunch" id="52584e10-32e9-4188-b1b0-b9ac7831041e">
        <embedded/>
        <type name="HMS_PilotLaunch"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getObjectDescription" id="ea84229b-779b-42c6-b07b-df9e686c3b77">
        <source>getObjectDescription(): String;
// ---------------------------------------------------------------------------
// Created:     22 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	return 	self.myPilotLaunch.getDisplayString;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setPilotLaunch" id="b04e75c6-dedc-43d4-994d-da2c3b59f490">
        <updating/>
        <source>setPilotLaunch(_pilotLaunch : HMS_PilotLaunch)updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myPilotLaunch := _pilotLaunch;
	self.myHMSObject := _pilotLaunch;
	
	if _pilotLaunch &lt;&gt; null and not self.allPilotLaunches.includes(_pilotLaunch) then 
		self.allPilotLaunches.add(_pilotLaunch);
	endif;
end;</source>
        <Parameter name="_pilotLaunch" type="HMS_PilotLaunch"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="d4ca1fca-c7c0-429c-bbcb-c4fafd83516d">
        <updating/>
        <source>setProxy(_obj: HMS_Object; _harbour: HMS_Harbour; _arrivalResource: HMS_Resource; _departResource: HMS_Resource; _shiftResource: HMS_Resource) updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	pilotLaunch	:	HMS_PilotLaunch;
begin
	inheritMethod(_obj, _harbour, _arrivalResource, _departResource, _shiftResource);

	pilotLaunch := _obj.HMS_PilotLaunch;
	
	
	self.myPilotLaunch := pilotLaunch;
	self.myHMSObject := pilotLaunch; 
		
	if pilotLaunch &lt;&gt; null and not self.allPilotLaunches.includes(pilotLaunch) then 
	self.allPilotLaunches.add(pilotLaunch);
	endif;
end;</source>
        <Parameter name="_obj" type="HMS_Object"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_arrivalResource" type="HMS_Resource"/>
        <Parameter name="_departResource" type="HMS_Resource"/>
        <Parameter name="_shiftResource" type="HMS_Resource"/>
    </JadeMethod>
</Class>
