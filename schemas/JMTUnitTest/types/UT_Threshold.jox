    <JadeMethod name="addTaAreas" id="b0e1c951-295e-401b-9915-1da3003c5e33">
        <source>addTaAreas(	_term : CM_Terminal;
			_wash : CM_TerminalAreaMaster output;
			_repair : CM_TerminalAreaMaster output;
			_pretrip : CM_TerminalAreaMaster output
			) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	pxyBlockStack : CM_BlockStack;
	pDO : CM_YADeckingOptionsTA;
	icArray : CM_InterchangeAreaArray;

begin

	create pxyBlockStack transient;
	pxyBlockStack.setProxy(	"UT_WASHTA",	//pID : String; 
							null,	//pComment : String; 
							TA_TYPE_WASH_AREA,	//pType : Integer;
							10,	//pHeight : Integer;
							5,	//pRows : Integer;	//29 Aug 2011	NDL	Par 28076
							5,	//pColumns : Integer;	//29 Aug 2011	NDL	Par 28076
							false,		//29 Aug 2011	NDL	Par 28076
							null,	//pTypeString : String;
							10,	//pMax : Integer;
							true,	//pRel : Boolean;
							null,	//pControllers: CM_LCArray;
							_term,	//pTerm : CM_Terminal;
							false,	//_autoRestrictionEnabled,
							false,	//pAutoPlanEnabled,
							false,	//_stockControlled, 
							false,	//_isOverlapped : Boolean;
							false,	//_hideFromOverView : Boolean;
							icArray,	//_allInterchangeAreas	:CM_InterchangeAreaArray;
							null,	//_defaultInterchangeArea: CM_InterchangeArea
							false
							);
	create pDO transient;
	pDO.setProxy(false, true, pxyBlockStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);

	app.myTrxCA.trxCreateTerminalArea(pxyBlockStack, _wash, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete pxyBlockStack;
	
	
	
	create pxyBlockStack transient;
	pxyBlockStack.setProxy(	"UT_REPAIRTA",	//pID : String; 
							null,	//pComment : String; 
							TA_TYPE_REPAIR,	//pType : Integer;
							10,	//pHeight : Integer;
							5,	//pRows : Integer;	//29 Aug 2011	NDL	Par 28076
							5,	//pColumns : Integer;	//29 Aug 2011	NDL	Par 28076
							false,		//29 Aug 2011	NDL	Par 28076
							null,	//pTypeString : String;
							10,	//pMax : Integer;
							true,	//pRel : Boolean;
							null,	//pControllers: CM_LCArray;
							_term,	//pTerm : CM_Terminal;
							false,	//_autoRestrictionEnabled,
							false,	//pAutoPlanEnabled,
							false,	//_stockControlled, 
							false,	//_isOverlapped : Boolean;
							false,	//_hideFromOverView : Boolean;
							icArray,	//_allInterchangeAreas	:CM_InterchangeAreaArray;
							null,	//_defaultInterchangeArea: CM_InterchangeArea
							false
							);
	create pDO transient;
	pDO.setProxy(false, true, pxyBlockStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);

	app.myTrxCA.trxCreateTerminalArea(pxyBlockStack, _repair, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete pxyBlockStack;
	
	
	
	create pxyBlockStack transient;
	pxyBlockStack.setProxy(	"UT_PRETRIPTA",	//pID : String; 
							null,	//pComment : String; 
							TA_TYPE_PTI,	//pType : Integer;
							10,	//pHeight : Integer;
							5,	//pRows : Integer;	//29 Aug 2011	NDL	Par 28076
							5,	//pColumns : Integer;	//29 Aug 2011	NDL	Par 28076
							false,		//29 Aug 2011	NDL	Par 28076
							null,	//pTypeString : String;
							10,	//pMax : Integer;
							true,	//pRel : Boolean;
							null,	//pControllers: CM_LCArray;
							_term,	//pTerm : CM_Terminal;
							false,	//_autoRestrictionEnabled,
							false,	//pAutoPlanEnabled,
							false,	//_stockControlled, 
							false,	//_isOverlapped : Boolean;
							false,	//_hideFromOverView : Boolean;
							icArray,	//_allInterchangeAreas	:CM_InterchangeAreaArray;
							null,	//_defaultInterchangeArea: CM_InterchangeArea
							false
							);
	create pDO transient;
	pDO.setProxy(false, true, pxyBlockStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);

	app.myTrxCA.trxCreateTerminalArea(pxyBlockStack, _pretrip, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	delete pxyBlockStack;
	

epilog

	delete pxyBlockStack;

end;</source>
