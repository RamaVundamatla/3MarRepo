    <JadeMethod name="getTerminalCode" id="478c839a-1cfd-4f6b-82a6-7b0a8b57fe12">
        <source>getTerminalCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 12th June 2024

*/
vars
	invalid : Boolean;
	code : String;

begin
	on Exception do app.handleDeletedObject(exception, self.myTrackedItem, invalid);	
	
	code := self.myTrackedItem.myTerminal.code;
	
	if invalid then 
		return null;
	endif;
	
	return code;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="cf72cde8-0ec1-4349-8c11-e792ce359795">
        <updating/>
        <source>setMyTrackedItem(_value : CM_TrackedItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2013	cnwjre1	Initial creation

*/

vars

begin
	self.myTrackedItem := _value;
	self.myParentObject := _value;
epilog

end;</source>
        <Parameter name="_value" type="CM_TrackedItem"/>
    </JadeMethod>
