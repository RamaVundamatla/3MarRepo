<Class name="Lock">
    <JadeMethod name="getDisplayDetails" id="3ff61f98-e16c-4bb9-9a3b-ec6b95a04c97">
        <source>getDisplayDetails() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Sep 2009	cnwkpd1	Unit test enhancements

*/

vars
	returnVal		: String;
	lockTarget		: Object;
	lockType,
	lockDuration	: Integer;
	
begin
	lockTarget := self.target();
	if lockTarget = null then
		returnVal := "&lt;null&gt;";
	else
		returnVal := lockTarget.String;
	endif;
	
	returnVal := returnVal &amp; " ";
		
	lockType := self.type.Integer;
	if lockType = Share_Lock then
		returnVal := returnVal &amp; "Share";
	elseif lockType = Exclusive_Lock then
		returnVal := returnVal &amp; "Exclusive";
	elseif lockType = Reserve_Lock then
		returnVal := returnVal &amp; "Reserve";
	else
		returnVal := returnVal &amp; "Unknown type";
	endif;
	
	returnVal := returnVal &amp; " ";
	
	lockDuration := self.duration.Integer;
	if lockDuration = Transaction_Duration then
		returnVal := returnVal &amp; "Transaction";
	elseif lockDuration = Session_Duration then
		returnVal := returnVal &amp; "Session";
	else
		returnVal := returnVal &amp; "Unknown duration";
	endif;

	return returnVal;
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
