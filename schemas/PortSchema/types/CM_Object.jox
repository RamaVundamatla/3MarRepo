    <JadeMethod name="exportAsXMLDocIgnoreAttr" id="5ab903d1-1d0b-4de8-8cf0-d2bb2266eb1d">
        <source>exportAsXMLDocIgnoreAttr(_property : Property input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 March 2011	cnwer1	Initial creation

*/

vars

begin

	if not self.shouldAuditProperty(self.class, _property) then
		//return true;
	endif;

	
	if _property = CM_Object::createdTime then
		return true;
	elseif _property = CM_Object::oidAsBin then
		return true;
	elseif _property = CM_Object::oidAsHex then
		return true;
	endif;
	
	
	return inheritMethod(_property);
	
	
epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocReference" id="a08369bd-ef5d-4f50-aa06-3b92d82b672c">
        <source>exportAsXMLDocReference(_property : Reference input;
						_file : File) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 March 2011	cnwer1	Initial creation

*/

vars

	theCollection : Collection;
	obj 		: Object;
	iter : Iterator;
	classType : Class;
	exportReferenceAs : Integer;
	arrayValue : Any;
	childKeyProperty : Property;
begin
	
	if self.exportAsXMLDocIgnoreAttr(_property) then
		return;
	endif;
	
	classType:=_property.type.class;
	obj:=self.getPropertyValue(_property.name).Object;
	if obj = null then
		return;
	endif;
	
	exportReferenceAs:= self.exportAsXMLInverseRef(_property);
	//if  inverse reference do not export as a default

	if  obj.isKindOf(Btree) or  obj.isKindOf(ObjectArray) then
		// check if we should be exporting this collection reference	
		if exportReferenceAs  = NoExport then
			return;
		endif;	
	
		theCollection:=obj.Collection;
		
		if theCollection.isEmpty then
			return;
		endif;
		_file.writeLine(J_key_LessThan.Character &amp; _property.name &amp; " " &amp; 'type="' &amp;  theCollection.class.name &amp; '"'&amp;J_key_GreaterThan.Character);

		iter:= theCollection.createIterator;		
		while iter.next(obj) do	
			_file.writeLine(J_key_LessThan.Character &amp; obj.class.name &amp; " " &amp; 'type="' &amp;  obj.class.name &amp;  '"'&amp;J_key_GreaterThan.Character);
			if exportReferenceAs =ExportAsParent then
				obj.CM_Object.exportAsXMLDoc(_file);
			elseif exportReferenceAs = ExportAsChild then
				childKeyProperty:=obj.CM_Object.exportAsXMLDocGetChildRefKey(_property);
				_file.writeString(self.formatAsXML(childKeyProperty.name,obj.getPropertyValue(childKeyProperty.name).String));
			endif;
			_file.writeString(self.formatAsXMLSuffix( obj.class.name));
		endwhile;
		
		_file.writeString(self.formatAsXMLSuffix(_property.name));
	elseif obj.isKindOf(CM_Object) then
		//have to specify and make sure only one end is exported
		// if parent will always export
		// if child will never
		// if peer have to specify which ends correctly	
			
		if exportReferenceAs = NoExport then
			return;
		endif;	
	
		if exportReferenceAs =ExportAsParent then
			if  obj.isKindOf(CM_Object) then	
				_file.writeLine(J_key_LessThan.Character &amp; _property.name &amp; " " &amp; 'type="' &amp;  obj.class.name &amp;  '"'&amp; J_key_GreaterThan.Character);
				obj.CM_Object.exportAsXMLDoc(_file);
				_file.writeString(self.formatAsXMLSuffix(_property.name));
			endif;
		elseif exportReferenceAs = ExportAsChild then
			childKeyProperty:=self.exportAsXMLDocGetChildRefKey(_property);
			self.exportAsXMLDocChildRefValue(_property,childKeyProperty,_file);
		endif;

	elseif 	obj.isKindOf(Array) then
	
		if obj.isKindOf(ObjectArray) then	
			return;
		endif;
		if obj.Array.size = 0 then
			return;
		endif;
		
		_file.writeLine(J_key_LessThan.Character &amp; _property.name &amp; " " &amp; 'type="' &amp;  obj.class.name &amp;  '"'&amp;J_key_GreaterThan.Character);
	
		iter:=obj.Array.createIterator;
		while iter.next(arrayValue) do
			_file.writeString(self.formatAsXML(arrayValue.getTypeJMT.name,arrayValue.asStringJMT));
		endwhile;
		_file.writeString(self.formatAsXMLSuffix(_property.name));
	endif;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference" usage="input"/>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
