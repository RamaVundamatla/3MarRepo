    <JadeMethod name="setProxy" id="aab7e536-ba6d-4269-b1f7-8bafd3220a3a">
        <updating/>
        <source>setProxy(pValue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Sets the receiver's property values when the receiver is a transient
//				proxy object.
//
// Parameters:	pValue - The receiver's data value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.value	:=	pValue;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="c81eb133-25a7-4ba2-9054-901fdc4272d5">
        <updating/>
        <source>setValue(pValue: Any) updating;
// --------------------------------------------------------------------------------
// Created:		29 March 2005 by cnwdad1
//
// Purpose:		Sets the receiver's data value.
//
// Parameters:	pValue - The receiver's data value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pValue.Integer = self.VALUE_TRUE
	or pValue.Integer = self.VALUE_FALSE
	or pValue.Integer = self.VALUE_EITHER
	then
		self.value	:=	pValue.Integer;
	else
		app.raiseUnexpectedProgramError(self.class.name, method.name, "Invalid 'value' being set for Boolean YA Data: '" &amp; pValue.String &amp; "'");
	endif;
end;</source>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
</Class>
