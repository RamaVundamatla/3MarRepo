    <JadeMethod name="initializeForActivity" id="3a203395-2092-4acb-aa72-37666e15cbfa">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable: CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
09 May 2022	navab1	TFS 53569
*/

vars
	invWI : CMIF_InvWi;
	invYardVisit : CMIF_InvUnitYrdVisit;	
	roadTruckTran : CMIF_RoadTruckTransactions;
	
	terminal : CM_Terminal;
	machine : CM_Object;
	voyage : CM_Voyage;
	carr : CM_Carrier;
	ti : CM_TrackedItem;
	moveKind : String;
	craneWorkETCTarget : TimeStamp;
	vvr : CM_VehicleVisitRecord;
	isDischarge, isLoad : Boolean;
	mt : CM_MeasurementType;
	mcode : String;
	density : Decimal [23,4];
begin
	if self.job &lt;&gt; null then
		terminal 	:= self.job.getMyTerminal();
	elseif self.myRequest &lt;&gt; null then
		terminal 	:= self.myRequest.getMyTerminal();
	endif;		
	
	ti := self.myTrackedItem;

	if _opsViewTable.isKindOf(CMIF_InvWi) then
		invWI := _opsViewTable.CMIF_InvWi;
		
		invWI.tableName := invWI.Inv_wi;
		invWI.gkey := invWI.generateFullGKey(self, ""); 
		
		invWI.facility_gkey	 := invWI.generateFullGKey(terminal, ""); 
		invWI.uyv_gkey	:= invWI.generateFullGKey(self, ""); 
		
		invWI.wq_pkey := 0;
		invWI.work_queue_gkey := invWI.generateFullGKey(self.job, "");   // updated with job Gkey
		
		machine 	:= invWI.getMachine(self);
		invWI.che_gkey	:= invWI.generateFullGKey(machine, ""); 
		
		//navra1 - TFS 51855 - 13th May 2022
		invWI.nominated_che_gkey := invWI.generateFullGKey(machine, ""); 
		
		invWI.move_kind	 := invWI.n4MoveKind(self);
		invWI.move_stage := invWI.n4MoveStage(self);
		
		invWI.carrier_locid := invWI.n4CarrierLocation(self, "carrier_locid");
		invWI.carrier_loctype := invWI.n4CarrierLocation(self, "carrier_loctype");
		
		moveKind:= invWI.n4MoveKind(self); 
		
		isDischarge := (moveKind = invWI.Move_Kind_Discharge or moveKind = invWI.Move_Kind_DischargeRail or moveKind = invWI.Move_Kind_Received); // ### TFS 51855 17MAY2022 NAVAB1
		isLoad := (moveKind = invWI.Move_Kind_Load or moveKind = invWI.Move_Kind_LoadRail or moveKind = invWI.Move_Kind_Delivered); // ### TFS 51855 17MAY2022 NAVAB1
		
		if isDischarge  // ### TFS 51855 17MAY2022 NAVAB1 moveKind = invWI.Move_Kind_Discharge 
		or  moveKind = invWI.Move_Kind_Sob then 
			invWI.mvhs_t_fetch := self.getFetchTime().asEpochFormat();
			invWI.mvhs_t_discharge := self.completedDate.asEpochFormat();
			invWI.mvhs_t_carry_complete	:= 0;
			
					
			if moveKind = invWI.Move_Kind_Sob then
				invWI.mvhs_t_put := self.completedDate.asEpochFormat();
			endif;
					
		elseif isLoad then  // ### TFS 51855 17MAY2022 NAVAB1 moveKind = invWI.Move_Kind_Load then
			invWI.mvhs_t_put := self.completedDate.asEpochFormat();
		endif;
		
		if self.job &lt;&gt; null then
			if self.job.myJobSheet &lt;&gt; null then
				craneWorkETCTarget:= job.myJobSheet.estimatedTimeToCompletion; // ### TFS 53105 30JUN2022 NAVAB1 job.myJobSheet.getWorkETCTarget();
			endif;
		endif;
		
		if not craneWorkETCTarget.isValid then
			voyage := self.getMyVoyageObject();
			if voyage &lt;&gt; null then 
				craneWorkETCTarget := voyage.departedDT; 
			endif;
		endif;

		if craneWorkETCTarget.isValid then
			invWI.est_move_time :=  craneWorkETCTarget.asEpochFormat();
		endif;		
		
		if machine &lt;&gt; null then // ### UNIT TEST ERROR 20MAY2022 NAVAB1
			if machine.isKindOf(CM_Machine) then // ### TFS 53105 13JUN2022 NAVAB1
				mcode := machine.CM_Machine.code;
			elseif machine.isKindOf(CM_WorkPoint) then // ### TFS 53105 13JUN2022 NAVAB1
				mcode := machine.CM_WorkPoint.code; // ### TFS 53105 13JUN2022 NAVAB1
			endif;
		
		
			if isDischarge then  // ### TFS 51855 17MAY2022 NAVAB1  moveKind = invWI.Move_Kind_Discharge then
				invWI.mvhs_fetch_che_id	:=  mcode.getStringValueAsInteger64; // ### TFS 53105 13JUN2022 NAVAB1
			elseif moveKind = invWI.Move_Kind_Sob then 
				invWI.mvhs_fetch_che_id	:=  mcode.getStringValueAsInteger64; // ### TFS 53105 13JUN2022 NAVAB1
				invWI.mvhs_carry_che_id	:=  mcode.getStringValueAsInteger64;  // ### TFS 53105 13JUN2022 NAVAB1
				invWI.mvhs_put_che_id := mcode.getStringValueAsInteger64; // ### TFS 53105 13JUN2022 NAVAB1
			elseif isLoad then  // ### TFS 51855 17MAY2022 NAVAB1  moveKind = invWI.Move_Kind_Load then
				invWI.mvhs_put_che_id :=  mcode.getStringValueAsInteger64; // ### TFS 53105 13JUN2022 NAVAB1
			endif;
		endif;
		
		invWI.pos_loc_gkey := 0;
		invWI.wi_fetch_time := self.getFetchTime().asEpochFormat();
		invWI.move_put_time := self.getPutTime().asEpochFormat();
		invWI.move_carry_complete_time := self.getCarryComplete().Integer64;
		invWI.move_discharge_time := self.getDischargeTime().asEpochFormat();
		
		
		// ### G E N E R A L   C A R G O
		
		invWI.t_create := self.createdTime.asEpochFormat(); // ### TFS 53105 31MAY2022 NAVAB1
		invWI.t_modified := app.actualTimeAppServer().asEpochFormat(); // ### TFS 53105 31MAY2022 NAVAB1
		
		if ti &lt;&gt; null then // ### TFS 53105 21JUN2022 NAVAB1
			if ti.isBulkByWeight() then // ### TFS 53105 31MAY2022 NAVAB1
				//invWI.cargo_qty := ti.totalWeight.Integer64; // ### TFS 53105 31MAY2022 NAVAB1
				invWI.cargo_qty := self.weight.Real;		// navra1 - 12th Aug 2022 - TFS 53105
				if terminal &lt;&gt; null then // ### TFS 53105 31MAY2022 NAVAB1
					mt := terminal.getDefaultMeasurementForType(Type_Weight); // ### TFS 53105 31MAY2022 NAVAB1
					if mt &lt;&gt; null then // ### TFS 53105 31MAY2022 NAVAB1
						invWI.cargo_qty_unit := mt.shortName; // ### TFS 53105 31MAY2022 NAVAB1
					endif;
				endif;
			
			elseif ti.isBulkByVolume() then // ### TFS 53105 31MAY2022 NAVAB1
				density := self.getDensity(); // ### TFS 53105 15AUG2022 NAVAB1
				
				if density &gt; 0 then
					 // ### TFS 53105 15AUG2022 NAVAB1 invWI.cargo_qty := ti.totalVolume.Integer64; // ### TFS 53105 31MAY2022 NAVAB1
					invWI.cargo_qty := self.weight / density;  // ### TFS 53105 15AUG2022 NAVAB1
				endif;
				if terminal &lt;&gt; null then // ### TFS 53105 31MAY2022 NAVAB1
					mt := terminal.getDefaultMeasurementForType(Type_Volume); // ### TFS 53105 31MAY2022 NAVAB1
					if mt &lt;&gt; null then // ### TFS 53105 31MAY2022 NAVAB1
						invWI.cargo_qty_unit := mt.shortName; // ### TFS 53105 31MAY2022 NAVAB1
					endif;
				endif;
			
			else
				//invWI.cargo_qty := ti.totalQuantity.Integer64; // ### TFS 53105 31MAY2022 NAVAB1
				invWI.cargo_qty := self.quantity.Integer64;		// navra1 - 12th Aug 2022 - TFS 53105
				invWI.cargo_qty_unit := "QTY";  // ### TFS 53105 08JUN2022 NAVAB1
			endif;
		endif;
		
		//invWI.cargo_lot_gkey := 0;  // ### TFS 53105 31MAY2022 NAVAB1IGNORE
		invWI.cargo_qty_claimed := self.myRequest.getTotalMovedAmount(); // ### TFS 53105 16JUN2022 NAVAB1		
				
		// ### TFS 53105 09AUG2022 NAVAB1 - if moved in parts the last part is merged and the TI it is merged into is swapped onto the WLE, 
		//										this means that cargo_qty becomes the full amount when it should be zero
		if self.myRequest.isComplete then 
			invWI.cargo_qty := 0;
		endif;
		
		//navra1 - 6th Sep 2022 - TFS53105
		//OpsView wants the cargo_qty to never change(always have the full qty), so just add the cargo_qty and the cargo_qty_claimed.		
		invWI.cargo_qty := invWI.cargo_qty + invWI.cargo_qty_claimed;
		
		//navra1 - TFS-53105 - 10th Aug 2022
		invWI.claimed_teu	:=	ti.getNumTEUOfQty(invWI.cargo_qty_claimed);
		invWI.planned_teu	:=	ti.getNumTEUOfQty(invWI.cargo_qty);
		
	elseif _opsViewTable.isKindOf(CMIF_InvUnitYrdVisit) then
		invYardVisit := _opsViewTable.CMIF_InvUnitYrdVisit;
		
		invYardVisit.tableName := invWI.Inv_unit_yrd_visit;
		invYardVisit.gkey := invYardVisit.generateFullGKey(self, ""); 
		
		invYardVisit.pkey := invYardVisit.generateFullGKey(ti,"");
		invYardVisit.ufv_gkey := invYardVisit.generateFullGKey(ti,"");
		invYardVisit.yrd_gkey := invYardVisit.generateFullGKey(self, "");
		
	elseif _opsViewTable.isKindOf(CMIF_RoadTruckTransactions) then
		roadTruckTran := _opsViewTable.CMIF_RoadTruckTransactions;
		
		roadTruckTran.tableName := invWI.Road_truck_transactions;
		roadTruckTran.gkey := roadTruckTran.generateFullGKey(ti, ""); 
		
		roadTruckTran.category := roadTruckTran.n4Category(ti.getImExStatus());
		
		roadTruckTran.ctr_id := ti.id;
		roadTruckTran.line_id := ti.operatorCode;
		roadTruckTran.trkco_id :=  ""; // initialise
		
		if self.job &lt;&gt; null then
			if self.job.isRoadJob then
				vvr := job.CM_RoadJob.myVehicleVisit;
				
				if vvr &lt;&gt; null then
					roadTruckTran.status := roadTruckTran.n4TruckVisitStatus(vvr);
					roadTruckTran.stage_id := roadTruckTran.n4StageId(vvr);
					// ### UNIT TEST ERROR 20MAY2022 NAVAB1 roadTruckTran.truck_visit_gkey := invYardVisit.generateFullGKey(vvr,"");
					roadTruckTran.truck_visit_gkey := roadTruckTran.generateFullGKey(vvr,""); // ### UNIT TEST ERROR 20MAY2022 NAVAB1
					
					carr := vvr.getCarrier();
					if carr &lt;&gt; null then
						roadTruckTran.trkco_id :=  carr.code;
					endif;
					
				endif;
			endif;
		endif;
		
		roadTruckTran.sub_type := roadTruckTran.n4SubType(self);
		if self.status = WLE_COMPLETED then
			if self.completedDate.isValid() then 
				roadTruckTran.handled :=  self.completedDate.asEpochFormat(); 
			else
				roadTruckTran.handled :=  app.actualTimeAppServer().asEpochFormat();
			endif;
		endif;
		roadTruckTran.fcy_gkey := roadTruckTran.generateFullGKey(terminal, ""); 
		
	endif;
epilog

end;</source>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
        <Parameter name="_opsViewTable" type="CMIF_OpsViewTables"/>
    </JadeMethod>
    <JadeMethod name="isAnyAmount" id="8318a5cf-a9bf-434f-83c5-0c84447fe96b">
