    <JadeMethod name="trxUpdateJobsRailOps" id="bae9530d-a2d9-45d2-89d7-1b2fdcdeb405">
        <updating/>
        <source>trxUpdateJobsRailOps(pRealJobs : CM_RailJobArray input; pIORake : CM_RailJSInOutRake; pDoAutoPlan : Boolean; 
				pType : Integer; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		Move the job between RAIL OPS areas
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rj : CM_RailJob;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;
	
	foreach rj in pRealJobs do
		//use this util for now
		app.myUtilityUA.utlUpdateJobRailOps(rj, pIORake, pDoAutoPlan,pType, _passport);
		if _passport.hasErrors() then
			return;
		endif;
	endforeach;
	
	//todo JC 15/04/2004
	//single note here to refresh the OutJS and BP once - create a new util above (utlUpdateJobsRailOps) with no notes
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
