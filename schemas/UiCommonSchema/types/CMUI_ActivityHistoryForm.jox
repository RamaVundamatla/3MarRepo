    <JadeMethod name="btnRefresh_click" id="20522060-3294-4a9c-bedd-27de2ff2e2ee">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRefresh_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

	now : TimeStamp;
	msg : String;
	rowIndex : Integer;
	
begin
	
	//27 Oct 2011	NDL	Par 28449
	now := app.actualTimeServer;
	if self.tblQuery.getValueByName(ETRow_DateTo).Date = null then
		self.queryDateTo:=now.date;
		self.queryTimeTo:=now.time;
	endif;
	
	
	if self.queryInitiated.date.isValid and self.queryDateTo.isValid and now.date = self.queryDateTo then
		// the user pressed the refresh button, and was looking at data for today.
		if self.queryTimeTo &lt; now.time then
			// the current time range ends before now
			if self.queryTimeTo.addMinutes(1) &gt;= self.queryInitiated.time then
				// but was previously up to the minute
				msg := app.getErrorString(Increment_To_Current_Time);
				if app.msgBox(msg, app.getErrorString(Query_parameters), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_Yes then
					self.queryTimeTo := app.actualTimeServer.time;
					self.tblQuery.setValueByName(ETRow_TimeTo, self.queryTimeTo);
				endif;
			endif;
		endif;
	endif;	
	
	//20 Sep 2019	NDL TFS 46655
	rowIndex := self.tblQuery.getRowByName(ETRow_SearchString);
	if rowIndex &gt; 1 and self.tblQuery.accessRow( rowIndex ).visible then
		self.queryString := self.tblQuery.getValueByName(ETRow_SearchString).String.trimBlanks;
	else
		self.queryString := null;
	endif;
	
	self.queryInitiated := app.actualTimeServer;
	

	self.doRefresh();
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
