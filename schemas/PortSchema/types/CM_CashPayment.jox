    <JadeMethod name="cashValue" id="a0e23053-dbab-4776-8447-515e28daed8d">
        <methodInvocation>mapping</methodInvocation>
        <source>cashValue(set: Boolean; _value: Decimal io) mapping;
/*
Purpose:	cash and invoice lines get compared and any difference must be paid for, invoice line was using rounding cash needed to as well.

Date		Who		Reason
21 May 2025	navab1	JIRA 34909
*/

vars
	terminal : CM_Terminal;
	blurb : String;
	roundDecimalOpt : Integer;
	canLogExtra : Boolean;
begin

	if not set then
		terminal := self.getMyTerminal();
		canLogExtra	:= app.canLogExtraDetail();	

// ### JIRA 34982 28MAY2025 NAVAB1 actually always round
//		if app.myPassport.context = Context_Pass_InvSplitMerge then	
//			blurb  := blurb &amp; " no rounding for CASH split merge";
//		else
			if terminal &lt;&gt; null then
				roundDecimalOpt := terminal.getConfig(InvoiceRoundLineTotal).Integer;
				if roundDecimalOpt &lt;&gt; CMIF_ConfigTerminal.InvLineRound_Value_NoRound then
					_value := _value.roundedTo(roundDecimalOpt);  
					blurb  := blurb &amp; " rounded to " &amp; roundDecimalOpt.String &amp; " decimal places = " &amp; _value.String;
				endif;
			endif;
//		endif;
	else
		inheritMethod(set, _value);
	endif;


epilog
	if canLogExtra then
		if set then
			blurb := method.qualifiedName &amp; " SET: " &amp; set.String &amp; " _value: " &amp; _value.String;
		else
			blurb := method.qualifiedName &amp; " " &amp; self.String &amp; " SET: " &amp; set.String &amp; " _value: " &amp; _value.String;
		endif;
		
		app.invLog(blurb, LogINFO.String);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceLineFromProforma" id="b66d1046-0fdd-4728-aa22-ca26e9659134">
        <updating/>
        <source>createInvoiceLineFromProforma(_inv : CM_Invoice; _useRate: Boolean) updating;
/*

Purpose:		 // TFS 37964 

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2018	jlgab1	Initial creation

*/

vars
	
begin
	if self.myInvoiceLine &lt;&gt; null then
		return;
	endif;
	
	self.myInvoiceLine := self.myProformaDetail.createInvoiceLineFromProforma(_inv, _useRate);
epilog

end;</source>
        <Parameter name="_inv" type="CM_Invoice"/>
        <Parameter name="_useRate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="f9ea71ca-9f65-402b-bd48-015246c70d34">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
----------------------------------------------------------------------
03 Aug 2018	jlgab1			Initial creation
12 Jul 2019	jlgdi1	45301	Added code for audit purposes
16 Oct 2019 cnwma1	Bug 46974: JMT - Auditing Transients while creating Proforma
----------------------------------------------------------------------
*/

vars
	cr : CM_CashReceipt;
begin
	if self.myCashPaymentForTax &lt;&gt; null then			   // TFS 30349
		if self.isTransient 							   // TFS 44275
		and not self.myCashPaymentForTax.isTransient then  // TFS 44275
		
		else
			delete self.myCashPaymentForTax; 			   // TFS 39349
		endif;
	endif;
	
	if self.allCashCreditDetails.isNotEmpty() then 		 // TFS 44275
		if self.isTransient 							 // TFS 44275
		and self.allCashCreditDetails.isTransient then   // TFS 44275
			self.allCashCreditDetails.purge; 			 // TFS 44275
		endif;
	endif;
	
	
	if self.isTransient then   //16.10.2019 cnwma1 #46974
		return;
	endif;
	
	cr := self.myCashReceipt; //20/08/2025	navkc1 JIRA MTN 35791
	
	if (cr &lt;&gt; null and (not cr.isDraftReceipt() and not cr.isHoldReceipt() and not cr.isCancelled())) then //20/08/2025	navkc1 JIRA MTN 35791
		app.myUtilityDA.myDeleteAuditAgent.audDeleteGeneric(self); // TFS 45301
		self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doAuditSplitMerge" id="03d85adc-afc5-414e-a79e-8481affea4b7">
        <updating/>
        <source>doAuditSplitMerge(_factor :Decimal;_oldValue:Decimal;_newValue:Decimal; _remarks : String; _reason : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2018	jlgns1	Initial creation
//02/02/2018	jlgns1	Bug 36580: ADP - Tax for Cash Module Part 3
*/

vars
	auditCashAdjust	: CM_AuditCashAdjustment;

begin
	create auditCashAdjust persistent;
	auditCashAdjust.auditedFOs.clear;
	auditCashAdjust.unauditedFOs.clear;
	auditCashAdjust.sequenceNum    := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT); // PAR 15036
	auditCashAdjust.datetime 	   := app.serverTimestampAtTrxStart;
	auditCashAdjust.oldCashValue   := _oldValue;
	auditCashAdjust.newCashValue   := _newValue;
	auditCashAdjust.factor 		   := _factor;	
	auditCashAdjust.clearingUserId := app.myPassport.userCode;
	auditCashAdjust.remarks 	   := _remarks &amp; "," &amp; self.myTrackedItem.identity;
	auditCashAdjust.statusChangeReasonCode := _reason;
	auditCashAdjust.auditedFOs.add(self);
	self.updateObjectEdition(self);

epilog

end;</source>
        <Parameter name="_factor" type="Decimal"/>
        <Parameter name="_oldValue" type="Decimal"/>
        <Parameter name="_newValue" type="Decimal"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="expandedRows" id="c3b905f8-9210-4164-bea6-42cc424ab9c6">
        <source>expandedRows(	_numRows : Integer output;
				_type : String output;
				_amount : String output
				);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	size : Integer;
	index : Integer;
	count : Integer;
	strArray : CnStringArray;
	str : String;
	commaPos : Integer;
	amount		: String;
	rawAmount : String;
	int : Integer;
	decimalChar : String;
	decimalString : String;

begin

	_numRows := 1;
	if self.getDebtorTerminal &lt;&gt; null then
		_type := self.getTypeString( self.getDebtorTerminal );
	endif;
	//_amount := ( self.cashValue * -1 ).asCurrencyJMT;
	amount := self.getAmountForBalanceTotal( self.getDebtorTerminal ).asCurrencyJMT;

	if not self.isProformaPayment then
		_amount := amount;
		return;
		
	else
		strArray := _type.cnGetTokensUsingTruthSet( CrLf );
		
		if strArray.size &gt;= 1 then
			decimalChar := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
			_numRows := strArray.size;
			_amount := "";
			_type := "";
			foreach index in 1 to _numRows do
				str := strArray[index];
				rawAmount := null;
				decimalString := null;
				commaPos := str.pos(Tab,1);	//31 Jan 2014	NDL	Par 33181
				if _type &lt;&gt; null then
					_type := _type &amp; CrLf;
					_amount := _amount &amp; CrLf;
				endif;
				if commaPos = 0 then
					_type := _type &amp; str;
				elseif commaPos = str.length then
					_type := _type &amp; str[1:str.length - 1];
				elseif commaPos = 1 then
					rawAmount := str;
				elseif commaPos &gt; 1 and commaPos &lt; str.length then
					_type := _type &amp; str[1 : commaPos - 1];
					rawAmount := str[commaPos + 1 : end];
				endif;
				if rawAmount.trimBlanks &lt;&gt; null then
					foreach int in 1 to rawAmount.length do
						if rawAmount[int].String.isInteger then
							decimalString := decimalString &amp; rawAmount[int];
						elseif rawAmount[int] = decimalChar then
							decimalString := decimalString &amp; rawAmount[int];
						endif;
					endforeach;
					_amount := _amount &amp; ( decimalString.Decimal * -1 ).Decimal.asCurrencyJMT;
				else
					_amount := amount;
				endif;
				
			endforeach;
			if self.taxAmount &lt;&gt; 0 then
				if _type &lt;&gt; null then
					_type := _type &amp; CrLf;
					_amount := _amount &amp; CrLf;
				endif;
				_amount := _amount &amp; ( self.taxAmount * -1 ).Decimal.asCurrencyJMT;
				_type := _type &amp; app.getErrorString(Tax);
				_numRows := _numRows + 1;
			endif;
	
		endif;
		
	endif;

epilog

	delete strArray;

end;</source>
        <Parameter name="_numRows" type="Integer" usage="output"/>
        <Parameter name="_type" type="String" usage="output"/>
        <Parameter name="_amount" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getActualCashValue" id="150874a2-e24e-4e37-9a94-cb3a0c64572a">
        <source>getActualCashValue() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2019	jlgab1	Initial creation
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars
	actualValue : Decimal[23,6];		//21.10.2019 cnwma1 TFS #47081
	creditDetail : CM_CashCreditDetail;
begin

	if self.myTrackedItem &lt;&gt; null // ignore zombies
	and self.myTrackedItem.hasBeenMerged then
		return 0;
	endif;
	
	actualValue := self.cashValue;
	
	if self.isTaxPayment  then           // TFS 45827 this is a tax payment
		return actualValue; 			// we do not credit tax
	endif;
	
	// ### Add the tax
	if self.hasTax  then        //21.10.2019 cnwma1 TFS #47081
		actualValue := actualValue + self.myCashPaymentForTax.cashValue;
	endif;
	
	// ### Remove the credits
	foreach creditDetail in self.allCashCreditDetails	discreteLock do
		if creditDetail.myAppliedToCashCredit &lt;&gt; null then
			actualValue := actualValue - creditDetail.cashValue;
		endif;
	endforeach;
	

	return actualValue;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAmountForBalanceTotal" id="f81c7278-95c5-4d05-9c4b-2467e85764c6">
        <source>getAmountForBalanceTotal(_drTerm: CM_DebtorTerminal): Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars
	//value	: Decimal[16, 6];
	value	: Decimal[23, 6];	//10 May 2018	NDL	TFS 38523
begin

	if not self.voided then
		value := self.cashValue + self.taxAmount;
		// from 37141 show payments from credits as +ve to get the balances correct
		if self.allCashCreditDetails.isEmpty then
			value := value * -1;
		endif;
	endif;
	return value;

epilog

end;</source>
        <Parameter name="_drTerm" type="CM_DebtorTerminal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="8a93b028-3872-40b0-8746-1ffa7a612141">
        <source>getAuditText(): String;
/*
Purpose:	TFS 46032		
Date				Who			Reason
AUGUST 2019		JLGAB1 initial creation
*/


vars
	txt,
	tmpStr	: String;

begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	if self.myDebtorTerminal &lt;&gt; null and self.myDebtorTerminal.myDebtor &lt;&gt; null then // Found in unit testing.
		tmpStr := self.myDebtorTerminal.myDebtor.name;
		txt := txt &amp; 'Debtor' &amp; AuditStringSeparator 
			   &amp; tmpStr.length.String &amp; AuditStringSeparator 
			   &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBOLNumber" id="ac72d040-01cb-44ba-aa66-0a4803591599">
