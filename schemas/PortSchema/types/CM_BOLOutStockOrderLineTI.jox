    <JadeMethod name="getDisplayStringForAttribute" id="a267e1e6-2cd4-4ecb-9f76-dca51f2a8e2a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     11 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
	else
		return null;
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="importMyCollectionsXML" id="acd93ba9-c069-4123-9277-66da7eecc775">
        <updating/>
        <source>importMyCollectionsXML(_collectionsBlock: String) updating;
// ---------------------------------------------------------------------------
// Created:     17 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	trackedItemsBlock,
	tiId				: String;
	blockLength,
	pos					: Integer;
	terminal			: CM_Terminal;
	ti					: CM_TrackedItem;
	foundCargoType,
	cargoType			: CM_CargoType;
	cargoTypeDict		: CM_CargoTypesByIdDict;
begin
	terminal := app.myRoot.allTerminals['POE'];
	cargoTypeDict := app.myRoot.allCargoTypesById;
	foreach cargoType in cargoTypeDict do
		if cargoType.abbreviation = 'BMLT' then
			foundCargoType := cargoType;
			break;
		endif;
	endforeach;
	
	if foundCargoType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Cargo type BMLT not found');
		return;
	endif;
	
	trackedItemsBlock := _collectionsBlock.cnEcGetTagValueOfName(self.class.name &amp; 'allTrackedItems');
	blockLength := trackedItemsBlock.length;
	pos := 1;
	
	while pos &lt; blockLength do
		tiId := trackedItemsBlock.cnEcGetNextTagValueOfName('id', pos);
		if pos &lt; 1 then
			break;
		endif;
		
		if tiId = null then
			continue;
		endif;
		
		ti := terminal.allOnsiteTIsByIdCargoType[tiId, foundCargoType.id];
		if ti = null then
			ti := terminal.allOffsiteTIsByIdCargoType.getAtKeyGeq(tiId, foundCargoType.id, null);
		endif;
//not checking key	
		if ti &lt;&gt; null then
			self.myTrackedItem := ti;
		endif;
	endwhile;

end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="isFulfilled" id="4038196e-5253-47c5-a9bb-213fc7929f3b">
        <methodInvocation>mapping</methodInvocation>
        <source>isFulfilled(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     29 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := (self.myTrackedItem &lt;&gt; null);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="06ba2495-5ed9-482d-8b5e-a22089a6ba13">
        <updating/>
        <source>setForCreate(_bolOut: CM_BOLOut;
			_orderLine: CM_StockOrderLine;
		 	_allocatedTI : CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:     05 July 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.setForUpdate(_bolOut, _orderLine, _allocatedTI);
	
end;</source>
        <Parameter name="_bolOut" type="CM_BOLOut"/>
        <Parameter name="_orderLine" type="CM_StockOrderLine"/>
        <Parameter name="_allocatedTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0b538438-ec57-47e7-b4dd-0fbbf28bec31">
        <updating/>
        <source>setForUpdate(_bolOut : CM_BOLOut;
			_orderLine : CM_StockOrderLine;
			_allocatedTI : CM_TrackedItem input) updating;
// ---------------------------------------------------------------------------
// Created:     17 July 2002 by cnwsb1
// ---------------------------------------------------------------------------
vars

begin

	self.myBOLOut			:= _bolOut;
	self.orderLineType		:= _orderLine.getLineType();
	self.myStockOrderLine	:= _orderLine;
	self.myTrackedItem 		:= _allocatedTI;
	/*if _allocatedTI &lt;&gt; null then
		_allocatedTI.setMyBOLOutStockOrderTI(self);
	else
		self.myTrackedItem := null;
	endif;
	*/
end;



</source>
        <Parameter name="_bolOut" type="CM_BOLOut"/>
        <Parameter name="_orderLine" type="CM_StockOrderLine"/>
        <Parameter name="_allocatedTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
