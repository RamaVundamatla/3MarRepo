<Class name="CM_ReceiveRoadCancelled" id="d5cc8046-e020-47b8-b450-80d6db1abf86">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>TFS 46578 Cancelling Truck Visit</text>
    <DbClassMap file="transact"/>
    <ImplicitInverseRef name="myVehicleVisitRecord" id="1b5bf55a-f5e8-4439-9aef-85561d852295">
        <embedded/>
        <type name="CM_VehicleVisitRecord"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="reason" id="8279e01a-eb8f-4e86-9d69-8beb760c55ab">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getDisplayStringForAttribute" id="49003908-99f5-420e-8d75-710ddfbc75ac">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
31 Oct 2019	jlgdi1	46578	Initial creation

*/
begin
	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();
		else
			return self.reason;
		endif;
	else	
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="8af91bf5-929f-4903-bc6b-89ef12566ad9">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
31 Oct 2019	jlgdi1	46578	Initial creation
*/

begin
	inheritMethod(_tiTransCntrl, _passport);
	self.reason := _tiTransCntrl.CMIF_RcvRoadCancelledCntlr.reason;
	self.myVehicleVisitRecord := _tiTransCntrl.CMIF_RcvRoadCancelledCntlr.myVehicleVisitRecord;	//25 Jun 2020	NDL	TFS 49604
end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
