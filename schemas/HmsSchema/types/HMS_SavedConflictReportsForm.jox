    <JadeMethod name="initTblData" id="4a1767d7-c1cc-4ad2-9202-c9202e069170">
        <source>initTblData();
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin

	self.tblSavedReports.setTblDataEntRowsFromDef(app.myController.getEntTableDef((ETDef_HMSSavedConflictReport)));	

	self.tblSavedReports.setMyDataClass(HMS_SavedConflictReport);
	self.tblSavedReports.userInputEnabled := false;
	self.tblSavedReports.selectMode := Table.SelectMode_CurrentRow;
	self.tblSavedReports.selectionType := CM_DataTable.SelectionType_Row;
	self.tblSavedReports.multiSelect := CM_DataTable.MultiSelect_Simple;


	self.tblConflicts.setTblDataEntRowsFromDef(app.myController.getEntTableDef((ETDef_HMSConflict)));	

	self.tblConflicts.setMyDataClass(HMS_Conflict);
	self.tblConflicts.userInputEnabled := false;
	self.tblConflicts.selectMode := Table.SelectMode_CurrentRow;
	self.tblConflicts.selectionType := CM_DataTable.SelectionType_Row;
	self.tblConflicts.multiSelect := CM_DataTable.MultiSelect_Simple;

epilog

end;</source>
    </JadeMethod>
