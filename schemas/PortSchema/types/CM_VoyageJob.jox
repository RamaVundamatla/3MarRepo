    <JadeMethod name="getCraneMoveRate" id="788b8f93-5255-413d-be0c-3b96beb37ba6">
        <source>getCraneMoveRate(_crane : CM_Crane input) : CM_CraneMoveRates;
/*

Purpose:			


Return Value:		


Date		Who		Reason
19 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	craneMoveRate : CM_CraneMoveRates;
	vessel : CM_Vessel;
begin
	if _crane = null then
		return null;
	endif;
	
	//25988 epr should default to vessel first
	vessel:=self.myVoyage.vessel;
	if vessel &lt;&gt; null then
		craneMoveRate:=vessel.allCraneRates[_crane];
	endif;
	

	if craneMoveRate = null then
		craneMoveRate:=_crane.myMoveRate;
	endif;
	
	return craneMoveRate;

epilog

end;</source>
        <Parameter name="_crane" type="CM_Crane" usage="input"/>
        <ReturnType type="CM_CraneMoveRates"/>
    </JadeMethod>
    <JadeMethod name="getCraneTransAreaLC" id="a35c356f-8f08-484d-a5e3-5b12c8247f51">
        <source>getCraneTransAreaLC() : CM_LocationsController;
//Retrieves the Crane Transfer area LANE 1 LC associated with this job's crane.
vars
	crane :	 CM_Crane;
	cta : CM_CraneTransferArea;
begin
	//Get the crane object.
	crane := self.getJobCrane();
	if crane = null then
		return null;
	endif;
	cta:=crane.transferArea ;
	//We have a crane, get its CTA
	if cta= null then
		return null;
	endif;
	
	//if the job is load then get the first load lane else get the first discharge lane
	//epr par 31205 2/4/13
	if  self.isDischarge then
		if cta.dischargeLanes.size &gt; 0 then
			return cta.dischargeLanes[1];
		endif;		
	else
		if cta.loadLanes.size &gt; 0 then
			return cta.loadLanes[1];
		endif;	
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getCraneTransferArea" id="7c8bab2f-7c22-494d-b27d-2da188ff1ab3">
