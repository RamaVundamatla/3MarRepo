    <JadeMethod name="validateMe" id="e6544227-3514-42f0-90df-fcd18cfd9b38">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Cell Definition Id', null, null);
		app.raiseCMException(Input_required_field_cellDefn, null, null); // cnwdb2	PAR 35364
	endif;
	if self.id.length &gt; 2 then
		app.raiseCMException2(ERR_INVALID_VALUE, 'Cell Definition Id' , "The Length Cannot Be Greater Than 2 Characters", null, null);
	endif;
	if self.myBayOD &lt;&gt; null and self.myBayUD &lt;&gt; null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Both On-deck and Under-deck bay defn refs set');
	endif;
	if self.myBayOD = null and self.myBayUD = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Neither On-deck nor Under-deck bay defn refs set');
	endif;
	// 18 Oct 2010	NDL	Par 26058
	if maxPileWeight20 &gt; 999 then
		if self.myBayOD &lt;&gt; null then
			app.raiseCMException3(MustBeInRange,app.getErrorString(OnDeck20CellMaxPileTons) &amp; " [Bay " &amp; self.myBayOD.id &amp; ", Cell " &amp; self.id &amp; " ] ","0","999",null,null);
		else
			app.raiseCMException3(MustBeInRange,app.getErrorString(UnderDeck20CellMaxPileTons) &amp; " [Bay " &amp; self.myBayOD.id &amp; ", Cell " &amp; self.id &amp; " ] ","0","999",null,null);
		endif;
	endif;
	if maxPileWeight40 &gt; 999 then
		if self.myBayOD &lt;&gt; null then
			app.raiseCMException3(MustBeInRange,app.getErrorString(OnDeck40CellPileTons) &amp; " [Bay " &amp; self.myBayOD.id &amp; ", Cell " &amp; self.id &amp; " ] ","0","999",null,null);
		else
			app.raiseCMException3(MustBeInRange,app.getErrorString(UnderDeck40CellPileTons) &amp; " [Bay " &amp; self.myBayOD.id &amp; ", Cell " &amp; self.id &amp; " ] ","0","999",null,null);
		endif;
	endif;
	if maxHeight &gt; 99.99 then
		if self.myBayOD &lt;&gt; null then
			app.raiseCMException3(MustBeInRange,app.getErrorString(OnDeckCellMaxHeightMetres) &amp; " [Bay " &amp; self.myBayOD.id &amp; ", Cell " &amp; self.id &amp; " ] ","0","99.99",null,null);
		else
			app.raiseCMException3(MustBeInRange,app.getErrorString(UnderDeckCellMaxHeightMetres) &amp; " [Bay " &amp; self.myBayOD.id &amp; ", Cell " &amp; self.id &amp; " ] ","0","99.99",null,null);
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
