    <JadeMethod name="addJobType" id="c54d2f9e-56d2-455f-ba5f-73e4d6c88819">
        <source>addJobType(_jobTypeName : String; _hatchType : Boolean; _timeToComplete : Integer) : CM_JobType;

/*

