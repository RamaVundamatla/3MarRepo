    <JadeMethod name="loadForm" id="7b36fcff-4d12-4e03-ae11-f629e6810716">
        <updating/>
        <source>loadForm() updating;

/*****************************************************
	Written by	:	cnwpra1		06 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	inheritMethod();
	btnNext.caption := 'Finish';
	
	lblWarning.caption := 'When the Save option is selected and the Finish button clicked, then the cells on the "Source data worksheet" are cleared and the workbook is saved and stored in the system. Excel will be automatically closed and any temporary files and directories will be cleaned up.'  &amp; CrLf &amp; CrLf &amp;
							'If you select Discard and click the Finish button, then Excel will be closed without saving the changes in the system. Any temporary files and directories will be cleaned up.';

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProcessingParameters" id="79e1caba-66e7-4514-95e6-14528778278b">
        <updating/>
        <source>setProcessingParameters() updating;

/*****************************************************
	Written by	:	cnwpra1		09 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	myDA.setBlnSaveWorkbook(optSave.value);
	myDA.setBlnDiscardWorkbook(optDiscard.value);

epilog

end;</source>
    </JadeMethod>
</GUIClass>
