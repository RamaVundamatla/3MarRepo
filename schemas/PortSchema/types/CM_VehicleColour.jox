    <JadeMethod name="setForCreate" id="47a6cbc2-f286-46b6-8230-f6f6eaf7555d">
        <updating/>
        <source>setForCreate(_proxyVehicleColour : CM_VehicleColour) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	_proxyVehicleColour.raiseExceptionIfNotTransient(method);
	
	self.myDutyDocRoot := _proxyVehicleColour.myDutyDocRoot;
	self.setForUpdate(_proxyVehicleColour);
epilog

end;</source>
        <Parameter name="_proxyVehicleColour" type="CM_VehicleColour"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b090cc43-316b-41f7-81d8-f7063b05915c">
        <updating/>
        <source>setForUpdate(_proxyVehicleColour : CM_VehicleColour) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.colour := _proxyVehicleColour.colour;
epilog

end;</source>
        <Parameter name="_proxyVehicleColour" type="CM_VehicleColour"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="16571249-ddce-425c-83c5-5757bf1fe121">
        <updating/>
        <source>setProxy( _colour : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.colour 		:= _colour;
	self.myDutyDocRoot 	:= app.myDutyDocRoot;
epilog

end;</source>
        <Parameter name="_colour" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="13f56b2c-2001-4bdc-acdb-c30bb08a2502">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	if app.myDutyDocRoot.allVehicleColours[self.colour] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.colour, null, null);
		return;
	endif;
	
	validateMe();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="a4dbb8e2-1d3f-45ed-b122-3bec66d53eb0">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.validateMe();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="0b30f925-f1b2-45d1-82a4-d2bc4604a80d">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	if self.colour = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Colour), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Colour), null, null); // cnwdb2	PAR 35364
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
