    <JadeMethod name="cnEcGetAttributes" id="26171aa1-8f84-4688-9368-82b53426a0c1">
        <source>cnEcGetAttributes(): String;
// -----------------------------------------------------------------------------
// Created:		18 January 2002 by cnwdad1
//
// Purpose:		Returns a string of the files File System attributes.
//
// Parameters:	None
//
// Returns:		String - A string of one-character attributes.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	attributes	: String;
	fileResult	: Integer;

begin
	if app.isUnicode() then
		fileResult	:=	call cnEcGetFileAttributesW(self.fileName);
	else
		fileResult	:=	call cnEcGetFileAttributesA(self.fileName);
	endif;
epilog
	return attributes;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsFile" id="9f51b714-f850-4f98-8ea7-08c138a66e8f">
        <source>cnEcIsFile(): Boolean;
// -----------------------------------------------------------------------------
// Created:		22 January 2002 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether the receiver is a File object.
//
// Parameters:	None
//
// Returns:		True if the receiver is a file, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
