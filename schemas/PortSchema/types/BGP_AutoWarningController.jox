<Class name="BGP_AutoWarningController" id="2ec2bf75-afc7-4beb-90cd-3be847406cef">
    <superclass name="BGP_TimerController"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;This controller automatically ensures that back ground tasks are processed within a configurable time frame.&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ExplicitInverseRef name="allWarningRequests" id="81df4b9a-4942-4426-832a-d3c4cba2cd74">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_AutoWarningRequestArray"/>
        <access>readonly</access>
        <Inverse name="CM_AutoWarningRequest::myController"/>
    </ExplicitInverseRef>
    <PrimAttribute name="cellAddress" id="59429aec-cc8b-4309-94be-dd6a3f847c0e">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="cellNumbers" id="1bfed7a7-1d3a-4f0c-8289-cd351525b2c9">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="createTimerRequest" id="2bf08354-432f-422d-87e4-8f124c555aab">
        <updating/>
        <source>createTimerRequest(): Boolean updating, protected;
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	// Do nothing.
	return true;


end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessing" id="ce3201b3-f1fe-43e1-a385-a1f9f4567e2c">
        <updating/>
        <source>doProcessing(): Boolean updating, protected;
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
/* This method is called when the timer goes off. Here we want to do the required work. */
vars

begin


	app.myAutoWarningAgent.sendAlertForAllErrors(self.cellAddress, self.cellNumbers);
	// Only want to run once.
	return false;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="finish" id="5a3c000c-14cd-45bf-b5de-ecbe6669079b">
        <updating/>
        <source>finish() updating;
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod();
	delete app.myAutoWarningAgent;


end;</source>
    </JadeMethod>
    <JadeMethod name="getFields" id="ee2c5483-a7ff-42eb-8537-46b390effa5d">
        <source>getFields(_allFields: StringArray input);
// --------------------------------------------------------------------------------
// Created:		23 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_allFields);
	_allFields.add(ETRow_RequestClassName);
	_allFields.add(ETRow_CellAddress);
	_allFields.add(ETRow_CellNumbers);
end;</source>
        <Parameter name="_allFields" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initApp" id="6f8d6d07-e0ef-406e-bf00-684485dc9088">
        <updating/>
        <source>initApp() updating;
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
begin
	inheritMethod();
	
	app.createAutoWarningAgent(self.allWarningRequests);
end;</source>
    </JadeMethod>
    <JadeMethod name="setAttributesForCreate" id="9c63e865-6ca9-43f8-892c-3560d154f0c0">
        <updating/>
        <source>setAttributesForCreate() updating, protected;
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
begin
	inheritMethod();
	
	// Don't need name.
	self.name			:=	'BGP Failure Notification';
		
	self.timerInterval	:=	30;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCMIF" id="e7e03a77-a81f-4b06-87b5-3b2aa31efcfd">
        <source>setCMIF(_cmif: CMIF_BGPManagerChildren input);
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
begin
	inheritMethod(_cmif);
	
	_cmif.cellAddress	:=	self.cellAddress;
	_cmif.cellNumbers	:=	self.cellNumbers;

	_cmif.allAutoWarningItems.clear();
	self.allWarningRequests.copy(_cmif.allWarningRequests);
end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="298c3602-8cc1-49e5-8d4c-18086c079015">
        <updating/>
        <source>setForUpdate(_cmif: CMIF_BGPManagerChildren) updating;
// -------------------------------------------
// Created 15 February 2006 by cnwdvb1
// -------------------------------------------
// 17/03/2015	cnwmh5	Transient Leaks
vars
	itemObj		: CM_AutoWarningItem;
	requestObj	: CM_AutoWarningRequest;
	proxyObj	: CM_AutoWarningRequest;
	
begin
	inheritMethod(_cmif);
	
	self.cellAddress	:= _cmif.cellAddress;
	self.cellNumbers	:= _cmif.cellNumbers;
	
	self.allWarningRequests.purge();
	
	foreach itemObj in _cmif.allAutoWarningItems do
		create proxyObj transient;
		proxyObj.setProxy(itemObj.minutesBeforeAlert, itemObj.alertFrequency, itemObj.className, itemObj.webSiteConfigName, self);
		
		create requestObj persistent;
		requestObj.setForUpdate(proxyObj);
	endforeach;
	
epilog
	delete proxyObj;
end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="547e1637-fb63-4c5c-8929-4ec2be25f2c2">
        <source>validateForUpdate();
// -------------------------------------------
// Created 27 March 2006 by cnwdvb1
// -------------------------------------------
vars

	request : CM_AutoWarningRequest;
	isFound	: Boolean;
begin
	inheritMethod();
	
	if self.cellAddress = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Cell Address', null, null);
		app.raiseCMException(Input_required_field_cellAdd, null, null); // cnwdb2	PAR 35364


	endif;
	
	if self.cellNumbers = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Cell Numbers', null, null);
		app.raiseCMException(Input_required_field_cellNumb, null, null); // cnwdb2	PAR 35364

endif;
	
	foreach request in self.allWarningRequests do
		isFound := true;
		request.validateMe();
	endforeach;
	
	if not isFound then
//		app.raiseCMException1(Full_Replacement_Message, 'Please select as least one task', null, null);
	endif;
	
	
	


end;</source>
    </JadeMethod>
</Class>
