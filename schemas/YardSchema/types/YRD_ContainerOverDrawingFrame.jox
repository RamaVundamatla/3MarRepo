    <JadeMethod name="deleteAllRectFrames" id="f6ecc139-760f-4803-90d0-a3b9b947e0e7">
        <source>deleteAllRectFrames();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2009	cnwjk3	SFW1030

*/

vars
	theRect	: CMUI_ResizableRectFrame;
begin
	
	foreach theRect in self.allRectFrames do
		if theRect.myObject &lt;&gt; null then
			delete  theRect.myObject;
		endif;
	endforeach;
	
	self.allRectFrames.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="4edc7ea2-7e2a-4e1b-b7ce-f4edb38d99f6">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	yrdForm : Form;
	tmpPoint : Point;
	x1,x2,y1,y2,idx : Integer;
	yalColour : Integer;
	aOK : Boolean;
begin
	
	yrdForm := self.getForm();
	if yrdForm  = null then
		return;
	endif;
	
	foreach tmpPoint in self.allPoints do
		idx := idx + 1;
		if idx mod 2 = 0 and aOK then
			x2 := tmpPoint.x;
			y2 := tmpPoint.y;	
			if x2 = self.lastMouseX
			and y2 = self.lastMouseY then
				break;
			else
				x1 := 0;
				y1 := 0;
				x2 := 0;
				y2 := 0;
				aOK := false;
			endif;
		else
			x1 := tmpPoint.x;
			y1 := tmpPoint.y;	
			
			if x1 = self.origXPos 
			and y1 = self.origYPos then
				aOK := true;
			else
				aOK := false;
				x1 := 0;
				y1 := 0;
			endif;
		endif;
	endforeach;		
	
	if aOK then
		tmpPoint.set(x1,y1);
		self.allPoints.remove(tmpPoint);
		if x2 &lt;&gt; 0 and y2 &lt;&gt; 0 then
			tmpPoint.set(x2,y2);
			self.allPoints.remove(tmpPoint);
		endif;
		
		app.isDragging := false;
		self.drawAllFrames();
		if yrdForm.isKindOf(YRD_GridAreasForm) then
			yrdForm.YRD_GridAreasForm.doDOLFMouseUp(self,null,null, null,null);
		elseif yrdForm.isKindOf(YRD_GridAreasOverviewForm) then
			yrdForm.YRD_GridAreasOverviewForm.doDOLFMouseUp(self,null,null, null,null);
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectColumnRow" id="390b73c7-47ea-4ffe-b1f9-708a4ca181ed">
        <updating/>
        <source>doSelectColumnRow(_x1,_y1,_x2,_y2 : Integer; _tryFind : Boolean; _tryCovers : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpPoint,lastPoint : Point;
	yrdForm : Form;
	found1st, found2nd : Boolean;
	idx : Integer;
begin
	
	yrdForm := self.getForm();
	if yrdForm  = null then
		return;
	endif;
	
	if _tryFind then
	
		foreach tmpPoint in self.allPoints do
			if tmpPoint.x = _x1 and tmpPoint.y = _y1 then
				found1st := true;
				lastPoint := tmpPoint;
			endif;
			if tmpPoint.x = _x2 and tmpPoint.y = _y2 then
				found2nd := true;
				break;
			endif;
		endforeach;
	endif;
	
	if found2nd and found1st then
		self.allPoints.remove(lastPoint);
		self.allPoints.remove(tmpPoint);
	else
		tmpPoint.set(_x1,_y1);
		self.allPoints.add(tmpPoint);
		tmpPoint.set(_x2,_y2);
		self.allPoints.add(tmpPoint);
	endif;

	self.drawAllFrames();		
	if yrdForm.isKindOf(YRD_GridAreasForm) then
		yrdForm.YRD_GridAreasForm.doDOLFMouseUp(self,null,null, null,null);
	elseif yrdForm.isKindOf(YRD_GridAreasOverviewForm) then
		yrdForm.YRD_GridAreasOverviewForm.doDOLFMouseUp(self,null,null, null,null);
	endif;

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_tryFind" type="Boolean"/>
        <Parameter name="_tryCovers" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dragDrop" id="c3dd06f0-e286-4391-b8e4-e53068489c72">
        <controlMethod name="Frame::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating, clientExecution;
// TFS 51417 - new method

vars

	cdc : YRD_ContainerDrawingController;
begin
	inheritMethod(frame, win, x, y);

	if self.myContainerViewingFrame&lt;&gt; null then
		cdc := self.myContainerViewingFrame.getDrawingController();
		
		if cdc &lt;&gt; null then	
			if global.isValidObject(app.myMoveController) then 
				if not self.isControlKey and not self.isShiftKey then
					self.myContainerViewingFrame.dragDrop(self.myContainerViewingFrame, win, x, y);
				endif;	
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="6c50dbf4-53c9-4b2a-8252-df1e55376339">
        <controlMethod name="CMUI_GridAreaDrawingFrame::dragOver"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	yrdForm : Form;
begin
	inheritMethod(frame,win,x,y,state);

	// TFS 51417 if dragging from a list table do not draw the drag box graphic
	if not win.isKindOf(YRD_ContainerOverDrawingFrame) then
		return;
	endif;
	// Code added to stop old style rectangles from being created
	yrdForm := self.getForm();
	
	
	if yrdForm  = null or yrdForm.isKindOf(YRD_SatelliteViewForm) then
		self.drawSatViewDragSelectFrame(x,y);
		return;
	endif;
	
	if not self.inEditMode then
		self.drawDragSelectFrame(x,y);
		return;
	endif;

	// Stop drag drop from other forms
	if not win.isKindOf(YRD_ContainerOverDrawingFrame) then 
		return;
	endif;
		
	yrdForm := self.getForm();
	if yrdForm  = null then
		return;
	endif;
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. X: " &amp; x.String &amp; " Y: " &amp; y.String);
	self.drawDragFrame(frame,win,x,y,state );

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawActualFrame" id="3a3aabe2-f5b6-4b89-885e-c66d7c6d6296">
        <updating/>
        <source>drawActualFrame(x1,y1,x2,y2 : Integer; _yalColour : Integer; _grabFill : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	

begin
	self.drawStyle := Frame.DrawStyle_Solid;
	self.drawWidth := self.frameWidth;

	self.drawWidth := self.frameWidth + 2; // PAR 14160
	self.drawFillStyle := Frame.DrawFillStyle_Transparent; // PAR 14160
	//self.drawFillStyle := Frame.DrawFillStyle_DiagonalCross; //cnwrd1 par 28447 20.10.2011 - not needed
	self.drawFillColor := _yalColour;

	self.drawFilledRectangle(x1,y1,x2,y2, _yalColour);

	self.drawWidth := self.frameWidth; // PAR 14160
	self.drawFillStyle := Frame.DrawFillStyle_Solid; // PAR 14160

	self.drawFillColor := _grabFill;

	self.drawFilledRectangle(x1 - self.grabberWidth,y1 - self.grabberWidth,x1 + self.grabberWidth,y1 + self.grabberWidth, _yalColour); // ### TOP LEFT KNOB
	self.drawFilledRectangle(x2- self.grabberWidth,y1- self.grabberWidth,x2 + self.grabberWidth,y1 + self.grabberWidth, _yalColour); // ### TOP RIGHT KNOB
	self.drawFilledRectangle(x2 - self.grabberWidth,y2 - self.grabberWidth,x2 + self.grabberWidth,y2 + self.grabberWidth, _yalColour); // ### BOTTOM RIGHT KNOB
	self.drawFilledRectangle(x1 - self.grabberWidth,y2 - self.grabberWidth,x1 + self.grabberWidth,y2 + self.grabberWidth, _yalColour); // ### BOTTOM RIGHT KNOB

end;</source>
        <Parameter name="x1" type="Integer"/>
        <Parameter name="y1" type="Integer"/>
        <Parameter name="x2" type="Integer"/>
        <Parameter name="y2" type="Integer"/>
        <Parameter name="_yalColour" type="Integer"/>
        <Parameter name="_grabFill" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawAllFrames" id="03b3c1fe-fa2b-4907-a6eb-26492b491f65">
        <updating/>
        <source>drawAllFrames() updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpPoint, topLeft, bottomRight : Point;
	x1,x2,y1,y2,idx : Integer;
	yalColour : Integer;
	obj: Object;
begin
	if global.isValidObject(self.myCurrentYardAllocation) then  // PAR 14545 AKB2007JULY - DCT EXCEPTION
		yalColour := self.myCurrentYardAllocation.color;
	else
		yalColour := Blue;
	endif;
	
	self.clearGraphics;
		
	foreach tmpPoint in self.allPoints do
		idx := idx + 1;
		if idx mod 2 = 0 then
			x2 := tmpPoint.x;
			y2 := tmpPoint.y;	
			
			obj := self.getObjectAndPointsForPosition(x1, y1, topLeft, bottomRight);
			if obj &lt;&gt; null and obj.isKindOf(CM_YardAllocation) then
				yalColour := obj.CM_YardAllocation.color;
			endif;
			self.drawActualFrame(x1,y1,x2,y2,yalColour,White);
		else
			x1 := tmpPoint.x;
			y1 := tmpPoint.y;	
		endif;
	endforeach;		

end;</source>
    </JadeMethod>
    <JadeMethod name="drawAllRectFrames" id="c4d071e7-1bd1-42e7-bec0-0f6333507f51">
        <updating/>
        <source>drawAllRectFrames() updating;
/*
Date		Who		Reason
04 February 2009	cnwjk3	SFW1030
14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming
*/
vars
	tmpPoint, topLeft, bottomRight : Point;
	x1,x2,y1,y2,idx : Integer;
	yalColour : Integer;
	yaBlock : CM_YABlock;
	rect	: CMUI_ResizableRectFrame;
	invalidYABlock : Boolean;
	invalidYA : Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, yaBlock, invalidYABlock);//28/02/2011 cnwdz2 27081

	if self.myCurrentYardAllocation &lt;&gt; null then						// PAR #27142
		on Exception do app.handleDeletedObject(exception, self.myCurrentYardAllocation, invalidYA);
		yalColour := self.myCurrentYardAllocation.color;
	else
		invalidYA := true;
	endif;
	
	if invalidYA then
		yalColour := Blue;
	endif;
	
	// Things can get out of step if we clear the array, but don't delete the control.
	self.deleteAllRectFrames();
	self.allRectFramesByYABlock.clear();
	self.allYABlocksByRectFrame.clear();
	
	self.clearGraphics();
		
	foreach tmpPoint in self.allPoints do
		idx := idx + 1;
		if idx mod 2 = 0 then
			x2 := tmpPoint.x;
			y2 := tmpPoint.y;	
			
			yaBlock := self.allYABlocks[x1, y1, x2, y2].CM_YABlock;
			invalidYABlock := false; //28/02/2011 cnwdz2 27081
			if yaBlock &lt;&gt; null then
				rect := allocateAndDrawRectFrame(x1,y1,x2,y2,yaBlock.getYardAllocation()); 
				if invalidYABlock then 	//28/02/2011 cnwdz2 27081 
					continue;
				endif;
				self.setRectFrameSlotCount(rect, yaBlock, yaBlock.myYardAllocationIn);  // CCMS CPL 2052
				self.allYABlocksByRectFrame[rect] := yaBlock;
				self.allRectFramesByYABlock[yaBlock] := rect;
			endif;
		else
			x1 := tmpPoint.x;
			y1 := tmpPoint.y;	
		endif;
	endforeach;		

end;</source>
    </JadeMethod>
    <JadeMethod name="drawAllYAFrames" id="8d4df2f5-542a-44d8-8990-4eb042bbf871">
        <updating/>
        <source>drawAllYAFrames() updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpPoint : Point;
	x1,x2,y1,y2,idx : Integer;
	yalloc : CM_YardAllocation;
	iterator : Iterator;
	obj : Object;
	yalColour : Integer;
	cdc : YRD_ContainerDrawingController;
	isYADrawn : Boolean;
begin
	cdc := self.getDrawingController(); // PAR 19128

	self.clearGraphics;
	self.drawStyle := Frame.DrawStyle_Solid;
	self.drawFillStyle := Frame.DrawFillStyle_DiagonalCross;
	self.drawWidth := self.frameWidth;
	
	isYADrawn:=false;
	iterator := self.allObjects.createIterator();
	
	while iterator.next(obj) do
		yalloc := obj.CM_YardAllocation;
		if yalloc = self.myCurrentYardAllocation then
			continue;
		endif;
		if yalloc.isDisabled then
			continue;
		endif;
		self.allObjects.getIteratorKeys(x1, y1, x2, y2, iterator);
		self.drawYardAllocation(yalloc,x1, x2, y1, y2, false,(cdc &lt;&gt; null and cdc.isForSatelliteView)); // PAR 19128
		isYADrawn:=true;
	endwhile;		
	
	iterator.reset();
	
	while iterator.next(obj) do
		yalloc := obj.CM_YardAllocation;
		if yalloc &lt;&gt; self.myCurrentYardAllocation then
			continue;
		endif;
		if yalloc.isDisabled then
			continue;
		endif;

		self.allObjects.getIteratorKeys(x1, y1, x2, y2, iterator);
		self.drawYardAllocation(yalloc, x1, x2, y1, y2, false,true);
		isYADrawn:=true;
	endwhile;
epilog
	delete iterator; //epr par 18417 3/11/08
	if isYADrawn then
		//self.refreshNow;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawDragFrame" id="451dfe01-e9aa-4a2b-9090-a6f828cc7cad">
        <updating/>
        <source>drawDragFrame(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpPoint : Point;
	x1,x2,y1,y2,idx : Integer;
	yalColour : Integer;
begin
	

	if self.myCurrentYardAllocation &lt;&gt; null then
		yalColour := self.myCurrentYardAllocation.color;
	else
		yalColour := Blue;
	endif;
	self.getDragXY(x.Integer,y.Integer,self.lastMouseX,self.lastMouseY,true);

	self.drawAllFrames();		

	self.drawActualFrame(self.origXPos.Integer, self.origYPos.Integer,self.lastMouseX, self.lastMouseY,yalColour,Black);
	
	if self.form.isKindOf(YRD_SatelliteViewForm) then
		self.showYALocationText();
	endif;
	
	//self.refreshNow(); // PAR 13106
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawDragSelectFrame" id="e2964b0e-99e5-4765-81c7-7185a066b06e">
        <updating/>
        <source>drawDragSelectFrame(x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
01 December 2008	consw1	SFW1030 - Initial creation

*/

constants
	WIDTH	= 1;
	
vars
	tmpPoint : Point;
	x1,x2,y1,y2,idx : Integer;
	yalColour : Integer;
	
begin
	self.drawAllYAFrames();		

	self.drawStyle := Frame.DrawFillStyle_Transparent;
	self.drawWidth := 1;

	self.drawFillStyle := Frame.DrawFillStyle_Transparent;
	self.drawFillColor := Black;

	self.drawFilledRectangle(self.origXPos.Integer, self.origYPos.Integer,x,y, Black);

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawSatViewDragSelectFrame" id="adc7b143-ba25-4b4d-91bc-3990c7125249">
        <updating/>
        <source>drawSatViewDragSelectFrame(x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2009	cnwjk3	Initial creation

*/

constants
	WIDTH	= 1;
	
vars
	x1,x2,y1,y2 : Integer;
	yalColour : Integer;
begin
	self.clearGraphics();
	
	self.drawStyle := Frame.DrawFillStyle_Transparent;
	self.drawWidth := 1;

	self.drawFillStyle := Frame.DrawFillStyle_Transparent;
	self.drawFillColor := Black;

	self.drawFilledRectangle(self.origXPos.Integer, self.origYPos.Integer,x,y, Black);
	
	
	x1 := self.origXPos.Integer;
	y1 := self.origYPos.Integer;
	x2 := x.Integer;
	y2 :=  y.Integer;
	self.getDrawingController().normaliseRectanglePoints(x1, y1, x2, y2);
	self.showLocationAndNumberOfSlots(x1-2, y1-2, x2+2, y2+2, true, null);

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawYARectFrames" id="14755067-f421-494b-b224-6963353273c2">
        <updating/>
        <source>drawYARectFrames(_ya: CM_YardAllocation) updating;
/*
Purpose: Create and draw all the rect frames for a yard allocation. There is a rect for each yablock in the ya.

Date		Who		Reason
4/5/11	 	cnwdw1	CCMS CPL 2052
*/
vars
	x1,x2,y1,y2,idx : Integer;
	yaBlock : CM_YABlock;
	rect	: CMUI_ResizableRectFrame;
	invalidYABlock : Boolean;
	tmpPoint: Point;
	
begin
	on Exception do app.handleDeletedObject(exception, yaBlock, invalidYABlock);

	foreach tmpPoint in self.allPoints do
		idx := idx + 1;
		if idx mod 2 = 0 then
			x2 := tmpPoint.x;
			y2 := tmpPoint.y;	
			
			yaBlock := self.allYABlocks[x1, y1, x2, y2].CM_YABlock;
			invalidYABlock := false;
			if yaBlock &lt;&gt; null and yaBlock.getYardAllocation() = _ya then
				rect := allocateAndDrawRectFrame(x1,y1,x2,y2, _ya); 
				if invalidYABlock then 	 
					continue;
				endif;
				self.setRectFrameSlotCount(rect, yaBlock, _ya);  // CCMS CPL 2052
				self.allYABlocksByRectFrame[rect] := yaBlock;
				self.allRectFramesByYABlock[yaBlock] := rect;
			endif;
		else
			x1 := tmpPoint.x;
			y1 := tmpPoint.y;	
		endif;
	endforeach;		

end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="drawYardAllocation" id="5f8e7d64-745c-4411-8f83-1e2af4f8980f">
        <updating/>
        <source>drawYardAllocation(_yardAlloc : CM_YardAllocation; _x1, _x2, _y1, _y2 : Integer; _drawKnobs : Boolean; _drawFill : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	yalColour : Integer;
	x1,x2,y1,y2,idx : Integer;
	grabberWidth: Integer;
	cdc : YRD_ContainerDrawingController;
begin

	yalColour := _yardAlloc.color;
	
	self.drawFillColor := yalColour;

	cdc := self.getDrawingController();// PAR 19081
	
	x1 := _x1; x2 := _x2; y1 := _y1; y2 := _y2;
	//self.allObjects.getIteratorKeys(x1, y1, x2, y2, _iter);
	
	if _drawFill then
		self.drawFillStyle := Frame.DrawFillStyle_DiagonalCross;
		if isSlimGraphics() then
			if cdc = null then
				self.drawWidth := self.frameWidth;// PAR 19081
			else
				self.drawWidth := (cdc.scaleFactor.roundedUp() * 2); // PAR 19081
			endif;
		endif;
	else
		self.drawFillStyle := Frame.DrawFillStyle_Transparent;
		if cdc = null then
			self.drawWidth := self.frameWidth;
		else
			self.drawWidth := (cdc.scaleFactor.roundedUp() * 2); // PAR 19081
		endif;
	endif;
	
	grabberWidth := self.grabberWidth;

	self.drawFilledRectangle(x1,y1,x2,y2, yalColour);

	self.drawFillStyle := Frame.DrawFillStyle_Solid;
	self.drawWidth := 1;

	if _drawKnobs then
		self.drawFilledRectangle(x1 - grabberWidth,y1 - grabberWidth,x1 + grabberWidth,y1 + grabberWidth, yalColour); // ### TOP LEFT KNOB
		self.drawFilledRectangle(x2 - grabberWidth,y1 - grabberWidth,x2 + grabberWidth,y1 + grabberWidth, yalColour); // ### TOP RIGHT KNOB
		self.drawFilledRectangle(x2 - grabberWidth,y2 - grabberWidth,x2 + grabberWidth,y2 + grabberWidth, yalColour); // ### BOTTOM RIGHT KNOB
		self.drawFilledRectangle(x1 - grabberWidth,y2 - grabberWidth,x1 + grabberWidth,y2 + grabberWidth, yalColour); // ### BOTTOM RIGHT KNOB
	endif;

end;</source>
        <Parameter name="_yardAlloc" type="CM_YardAllocation"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_drawKnobs" type="Boolean"/>
        <Parameter name="_drawFill" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dump" id="4ab2e6e2-f7c6-423b-acae-c745a551a6d3">
        <source>dump(_title: String);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2011	cnwdw1	Initial creation
*/
vars
	x1,x2,y1,y2,idx : Integer;
	yalloc : CM_YardAllocation;
	iterator : Iterator;
	obj : Object;
	yaBlock: CM_YABlock;
	rect: CMUI_ResizableRectFrame;
	pt: Point;
begin

	write _title;
	iterator := self.allPoints.createIterator();
	write "allPoints";
	foreach pt in self.allPoints do
		write " Point x: " &amp; pt.x.String &amp; " y: " &amp; pt.y.String;
    endforeach;
	delete iterator;		// PAR #27874
	
	iterator := self.allObjects.createIterator();
	write "allObjects";
	while iterator.next(obj) do
		self.allObjects.getIteratorKeys(x1, y1, x2, y2, iterator);
		write " obj: " &amp; obj.String &amp; " x1: " &amp; x1.String &amp; " y1: " &amp; y1.String &amp; " x2: " &amp; x2.String &amp; " y2: " &amp; y2.String;
    endwhile;
	delete iterator;		// PAR #27874
	
	iterator := self.allYABlocks.createIterator();
	write "allYABlocks";
	while iterator.next(obj) do
		self.allYABlocks.getIteratorKeys(x1, y1, x2, y2, iterator);
		write " yaBlock: " &amp; yaBlock.String &amp; " " &amp; obj.CM_YABlock.getYAMLocationsString &amp; " x1: " &amp; x1.String &amp; " y1: " &amp; y1.String &amp; " x2: " &amp; x2.String &amp; " y2: " &amp; y2.String;
    endwhile;
	delete iterator;		// PAR #27874

	iterator := self.allRectFrames.createIterator();
	write "allRectFrames";
	while iterator.next(obj) do
		write " rectFrame: " &amp; obj.String;
    endwhile;
	delete iterator;		// PAR #27874

	iterator := self.allRectFramesByYABlock.createIterator();
	write "allRectFramesByYABlock";
	while iterator.next(obj) do
		self.allRectFramesByYABlock.getIteratorKeys(yaBlock, iterator);
		write " rectFrame: " &amp; obj.String &amp; " yaBlock: " &amp; yaBlock.String &amp; " " &amp; yaBlock.getYAMLocationsString;
    endwhile;
	delete iterator;		// PAR #27874
	
	iterator := self.allYABlocksByRectFrame.createIterator();
	write "allYABlocksByRectFrame";
	while iterator.next(obj) do
		self.allYABlocksByRectFrame.getIteratorKeys(rect, iterator);
		write " yaBlock: " &amp; obj.String &amp; " " &amp; yaBlock.getYAMLocationsString &amp; " rectFrame: " &amp; rect.String;
    endwhile;
	

epilog
	delete iterator;		// PAR #27874
	
end;</source>
        <Parameter name="_title" type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllChangedYAs" id="a1e17d1d-edb1-4fc9-b10d-e2a7515451c9">
        <source>getAllChangedYAs(_yas: CM_YardAllocationSet input);
/*
Purpose: Return a list of YardAllocations that have been changed.			

Date		Who		Reason
28 April 2011	cnwdw1	CCMS CPL 2052
*/
vars
	yaBlock: CM_YABlock;
	rect: CMUI_ResizableRectFrame;
begin
	foreach rect in allRectFrames do
		if rect.hasChanged then
			if rect.myObject &lt;&gt; null and not _yas.includes(rect.myObject.CMIF_YABlock.myYardAllocation) then
				_yas.add(rect.myObject.CMIF_YABlock.myYardAllocation);
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_yas" type="CM_YardAllocationSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBlocks" id="80e8003b-3cd8-4530-8917-b6a0bd5dcb11">
        <updating/>
        <source>getBlocks(_blocks : ObjectArray input; _ydc : YRD_ContainerDrawingController input) updating;
// 9 Sep 2008 CNWDW1
// Build up a collection of blocks that correspond to what the user has drawn on the screen. 
// Each block will have an array of location controllers.

// Caller must delete the blocks arrays.

vars
	locations: CM_LCArray;
	tmpPoint : Point;
	x1,x2,x3,y1,y2,y3,idx : Integer;
begin
	if _ydc = null  or _blocks = null then
		return;
	endif;
	
	foreach tmpPoint in self.allPoints do
		idx := idx + 1;
		if idx mod 2 = 0 then
			x2 := tmpPoint.x;
			y2 := tmpPoint.y;	

			if x1 &gt; x2 then
				x3 := x2;
				x2 := x1;
				x1 := x3;
			endif;
			if y1 &gt; y2 then
				y3 := y2;
				y2 := y1;
				y1 := y3;
			endif;
			create locations transient;
			_ydc.allGridObjects.findObjectsInDict(x1,y1,x2,y2,locations,CM_LocationsController,false,false);
			_blocks.add(locations);
		else
			x1 := tmpPoint.x;
			y1 := tmpPoint.y;	
		
		endif;

	endforeach;
end;</source>
        <Parameter name="_blocks" type="ObjectArray" usage="input"/>
        <Parameter name="_ydc" type="YRD_ContainerDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCurrentAllocPoints" id="48c99840-f543-44f8-8002-ae69379d9a20">
        <updating/>
        <source>getCurrentAllocPoints() updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpPoint : Point;
	x1,x2,y1,y2,idx : Integer;
	yalloc : CM_YardAllocation;
	iterator : Iterator;
	obj : Object;
begin
	
	
	self.allPoints.clear;
	
	iterator := self.allObjects.createIterator();
	
	while iterator.next(obj) do
		yalloc := obj.CM_YardAllocation;
		if yalloc.isDisabled then
			continue;
		endif;
		if self.myCurrentYardAllocation = null or yalloc = self.myCurrentYardAllocation then
			self.allObjects.getIteratorKeys(x1, y1, x2, y2, iterator);
			tmpPoint.set(x1,y1);
			self.allPoints.add(tmpPoint);
			tmpPoint.set(x2,y2);
			self.allPoints.add(tmpPoint);
		endif;

	endwhile;
epilog
	delete iterator; //epr par 18417 3/11/08
end;</source>
    </JadeMethod>
    <JadeMethod name="getDragXY" id="64ba901a-9496-4cd7-a691-a8fc84ccf5f8">
        <source>getDragXY(_xIn,_yIn : Integer; _xOut, _yOut : Integer output; _snapBack : Boolean);
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	x1,x2,x3,y1,y2,y3 : Integer;
	dc : YRD_ContainerDrawingController;
	tmpPoint : Point;
	foundX, foundY : Boolean;
begin
	if self.isSlimGraphics then
		self.snapToLocationCorner(_xIn, _yIn, _xOut, _yOut, _snapBack);
	else
		if _xIn &lt;= YRD_ContainerDrawingController.LABELGAP then
			x1 := YRD_ContainerDrawingController.LABELGAP;
		else
			foreach tmpPoint in self.allColumnPoints do
				x1 := tmpPoint.x;
				x2 := tmpPoint.y;
				if x1 &lt;= _xIn and x2 &gt;= _xIn then
					break;
				endif;
			endforeach;
		endif;	
	
		if _yIn &lt;= YRD_ContainerDrawingController.LABELGAP then
			y1 := YRD_ContainerDrawingController.LABELGAP;
		else
			foreach tmpPoint in self.allRowPoints do
				y1 := tmpPoint.x;
				y2 := tmpPoint.y;
				
				if y1 &lt;= _yIn and y2 &gt;= _yIn then
					break;
				endif;
			endforeach;
		endif;
		
		x3 := (((x2-x1)/2) + x1).Integer; // Half Way
		y3 := (((y2-y1)/2) + y1).Integer; // Half Way
		
		if _snapBack then
			if _xIn &lt; x3 then
				_xOut := x1;
			else
				_xOut := x2;
			endif;
		else
			_xOut := x1;
		endif;	
		if _snapBack then
			if _yIn &lt; y3 then
				_yOut := y1;
			else
				_yOut := y2;
			endif;
		else
			_yOut := y1;
		endif;
	endif;
//write "Xin: " &amp; _xIn.String &amp; " Yin: " &amp; _yIn.String &amp; " Xout: " &amp; _xOut.String &amp; " Yout: " &amp; _yOut.String &amp; " x3: " &amp; x3.String;
end;</source>
        <Parameter name="_xIn" type="Integer"/>
        <Parameter name="_yIn" type="Integer"/>
        <Parameter name="_xOut" type="Integer" usage="output"/>
        <Parameter name="_yOut" type="Integer" usage="output"/>
        <Parameter name="_snapBack" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDrawingController" id="4a0d7fba-731c-4e8b-81a1-1c4f49972d06">
