    <JadeMethod name="create" id="d183716d-aeed-4f32-9a5d-24efa0e81040">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     12/05/2009 cnwdz2 par19585
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
