    <JadeMethod name="resetAuditsDuringDelete" id="c7cdb2e7-bd63-4069-b7f5-ecd90a019614">
        <source>resetAuditsDuringDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

	audit : CM_AuditObject;
	invalid : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, audit, invalid );

	foreach audit in self.allAuditObjectsForClass do
		// Tell the audit that it's subject is about to be deleted
		audit.subjectBeingDeleted();
		// Null the reference back to us
		audit.setSubject(null);
	endforeach; 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="restrictCargoBookingUpdates" id="108488f2-828f-4a47-9733-1c55feb57177">
        <source>restrictCargoBookingUpdates(_terminal : CM_Terminal; _operator : CM_Operator) : Boolean;
// --------------------------------------------------------------------------------
// Created:		10 February 2010 by cnwjo3
//
// Purpose:		Depending if 'Observe Operator Restrictions' has been set for Users security role
//				and the Operators 'Restric Cargo/Booking Edits' is set then return true, else return false
//
vars
	ignoreRestrictionsPermission : Boolean;
	opRestrictCargoBookingEdits : Boolean;
begin
	opRestrictCargoBookingEdits := false;

	//note, even though _terminal has nothing to do with this permission if you send a null value it always returns 'false'!  hmmmmmm
	ignoreRestrictionsPermission := app.getMyUser.canDo(_terminal, PmAdmIgnoreOpRestrictions);
	
	/*
	if _operator &lt;&gt; null then
		opRestrictCargoBookingEdits := _operator.getConfigForTerminal(ETRow_RestrictCargoBookEdits, _terminal).Boolean;
	endif;
	
	if opRestrictCargoBookingEdits and not ignoreRestrictionsPermission then
		return true;
	endif;
	*/
	
	if not ignoreRestrictionsPermission then
		if _operator &lt;&gt; null then
			opRestrictCargoBookingEdits := _operator.getConfigForTerminal(ETRow_RestrictCargoBookEdits, _terminal).Boolean;
		endif;
		if opRestrictCargoBookingEdits then
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAPIJSONRequestData" id="c29c60d3-a570-43f7-873c-559d156ca946">
        <updating/>
        <source>setAPIJSONRequestData(_stateDataDict : CM_StateDataDict; _jsonString : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 July 2024		navmd1	Initial creation TFS 65226 Debug Code of sorts, to keep the initial JSON data somewhere easily findable

*/

vars
	compressedBinary	: Binary;
begin
	if _stateDataDict = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "CM_StateDataDict not provided or null");
		return;
	endif;
	
	if _jsonString &lt;&gt; null then
		compressedBinary := _jsonString.compressToBinary(Binary.Compression_ZLib);
	endif;	
	
	global.setExtraData(_stateDataDict, self, APIRequestJSONData, compressedBinary);
epilog

end;</source>
        <Parameter name="_stateDataDict" type="CM_StateDataDict"/>
        <Parameter name="_jsonString" type="String"/>
    </JadeMethod>
