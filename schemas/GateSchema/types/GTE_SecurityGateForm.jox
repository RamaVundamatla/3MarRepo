    <JadeMethod name="addToolbarControls" id="44a13bdc-c2c0-4803-ba71-1aafb038328f">
        <updating/>
        <source>addToolbarControls() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
// 14/05/2014	cnwdap1		PAR #34117 Security Gate
// 26 Oct 2016	cnwkpd1		TFS #2818 - Improve form performance

vars
	toolbar	: CMUI_Toolbar;

begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	
	// TFS 2734 CNWAB1
	if  app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnExportCSVTV, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);	
		toolbar.addButton(self.btnDeparture, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	endif;

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);							// TFS #2818
	toolbar.addFrame(self.frmSearchDays, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);							// PAR #34117
	toolbar.addFrame(self.frmFindBAT, CMUI_Toolbar.Control_Alignment_Left);				// PAR #34117
	toolbar.addButton(self.btnFind, CMUI_Toolbar.Control_Alignment_Left);				// PAR #34117

	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	// disable the Edit and Delete button for the moment
	self.btnDeparture.enabled := false;
	self.btnDelete.enabled := false;
	if not app.getMyUser.canDo(self.myTerminal, PmGteSecurityGateMaint) then 
		self.btnNew.enabled := false;
		self.btnDeparture.enabled := false;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnDelete_click" id="1c9648f8-6a4c-4b10-972e-41f9784932d5">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelete_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 31/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321
//
vars
	visit : CM_VehicleVisitRecord;

begin
	if not self.tblData.allSelectedObjects.isEmpty then
		visit := self.tblData.allSelectedObjects.first.CM_VehicleVisitRecord;
	endif;
	self.doCancelVisit(visit);
epilog

end;</source>
