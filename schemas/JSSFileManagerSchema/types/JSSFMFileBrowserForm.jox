    <JadeMethod name="tblFilesTop_mouseDown" id="e1cfb91f-039e-48c2-b4df-e2a7d20642a6">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFilesTop_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (not button = Window.MouseButton_Right) then
		self.setState(Busy);
	endif;
	
	self.getServiceInterfaceSettings();
	self.tableMouseDown(table, button, shift, x, y);
epilog
	self.setState(Idle);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
