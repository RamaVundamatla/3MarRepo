/*
----------   ----------  --------------------------------------------------
Created:	04 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	result : Integer;
	f	: CMDFont;

begin
	if app.isSpecial then
		result := app.msgBox('Do you wish to use test level', null, MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if result = MsgBox_Return_Yes then
			app.testLevelLogout();
			return;
		endif;
	endif;
	self.doLock();
end;
