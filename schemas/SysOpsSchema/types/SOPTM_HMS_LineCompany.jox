    <JadeMethod name="doSave" id="e938e80f-b914-44bc-bf3c-e9e433624c7d">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyLineCo	:	HMS_LineCompany;
	theForm		:	SOP_TableMaintForm;
	
begin
//	return inheritMethod();
	theForm := self.myForm.SOP_TableMaintForm;
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_LineCompany transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for object');
			return false;
		endif;
	endif;
	
	pxyLineCo := theForm.myProxyObject.HMS_LineCompany;
	theForm.tblInput1.setObjectFromTable(pxyLineCo, null, false);
	pxyLineCo.setProxy(app.myRoot);
	self.doSaveResourcesTbl(pxyLineCo);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateHMSObject(pxyLineCo, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateHMSObject(pxyLineCo, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name,
										method.name,
										'  Invalid mode (' &amp; theForm.mode.String &amp;')');
		return false;
	endif;	
	
	return app.myPassport.trxCompletedOK;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveResourcesTbl" id="90ca0bd5-10fc-4af6-a6fd-e2ae7d9b74de">
        <source>doSaveResourcesTbl(_pxyLineCompany : HMS_LineCompany);
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

	theForm 	: SOP_TableMaintForm;
	idx			: Integer;
	tmpDataTable	: CM_DataTable;
	obj			: Object;
	harbour		: HMS_Harbour;
	prxyResourceForLineCompany	: HMS_ResourceForLineCompany;
	arrResource,
	depResource,
	shiftResource :	HMS_Resource;
	
begin

	theForm := self.myForm; 

	tmpDataTable := self.myForm.tblData1;
	foreach idx in 2 to tmpDataTable.rows do
		harbour 			:= tmpDataTable.accessRow(idx).itemObject.HMS_Harbour;
		arrResource 		:= tmpDataTable.accessCell(idx, 2).itemObject.HMS_Resource;
		depResource 		:= tmpDataTable.accessCell(idx, 3).itemObject.HMS_Resource;
		shiftResource 		:= tmpDataTable.accessCell(idx, 4).itemObject.HMS_Resource;		

		prxyResourceForLineCompany := _pxyLineCompany.allResourceForLineCompany[harbour,_pxyLineCompany];
		
		if prxyResourceForLineCompany = null then
				create prxyResourceForLineCompany transient;
		endif;
		prxyResourceForLineCompany.setProxy(_pxyLineCompany,harbour,arrResource,depResource,shiftResource);

	endforeach;
end;</source>
        <Parameter name="_pxyLineCompany" type="HMS_LineCompany"/>
    </JadeMethod>
