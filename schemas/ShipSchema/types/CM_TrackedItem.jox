<Class name="CM_TrackedItem">
    <JadeMethod name="addAttribute" id="59440401-12f0-4d5c-8d16-094aa7877e60">
        <source>addAttribute(_bayPoint : SHP_BayPoint input; _attrib : String) ;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _bayPoint.bayActAttribute1 = null then
		_bayPoint.bayActAttribute1 := _attrib;
	elseif _bayPoint.bayActAttribute2 = null then
		_bayPoint.bayActAttribute2 := _attrib;
	elseif _bayPoint.bayActAttribute3 = null then
		_bayPoint.bayActAttribute3 := _attrib;
	elseif _bayPoint.bayActAttribute4 = null then
		_bayPoint.bayActAttribute4 := _attrib;
	elseif _bayPoint.bayActAttribute5 = null then
		_bayPoint.bayActAttribute5 := _attrib;
	elseif _bayPoint.bayActAttribute6 = null then
		_bayPoint.bayActAttribute6 := _attrib;
	endif;
end;</source>
        <Parameter name="_bayPoint" type="SHP_BayPoint" usage="input"/>
        <Parameter name="_attrib" type="String"/>
    </JadeMethod>
    <JadeMethod name="addColours" id="8a390217-4007-4ee2-bc9e-f476afd8fd5f">
        <updating/>
        <source>addColours(_bayPoint : SHP_BayPoint input; _theColour : Integer; _theCode : String; _theObject : Object; _viewModeIndex : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	_bayPoint.displayColoursACT[_viewModeIndex] := _theColour;
	_bayPoint.displayIconsACT[_viewModeIndex] := _theCode;
	_bayPoint.myAttributesActual.allDisplayCodes[_viewModeIndex] := _theCode;
	_bayPoint.myAttributesActual.allDisplayColors[_viewModeIndex] := _theColour;
	_bayPoint.myAttributesActual.allDisplayObjects[_viewModeIndex] := _theObject;

end;</source>
        <Parameter name="_bayPoint" type="SHP_BayPoint" usage="input"/>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_viewModeIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateBayPoint" id="d422846d-561d-4257-95e0-4aa543978600">
        <updating/>
        <source>populateBayPoint(_bayPoint : SHP_BayPoint input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isexport for tranships
vars
	idx				: Integer;
	aVoyage			: CM_Voyage;
	aCommGroup		: CM_CommodityGroup;
	aConsignee		: CM_ConsigneeConsignor;
	aLoadPort		: CM_Port;
	aDishPort		: CM_Port;
	anISOTypeGroup	: CM_ISOTypeGroup;
	anOperator		: CM_Operator;
	productObj		: CM_Product;
	aWeight			: CM_WeightRange;
	
begin
	// ?? Height
	//_bayPoint.bayActIsExport := self.isExport or self.isRehandle or self.isSOB; 							// PAR #25021
	_bayPoint.bayActIsExport := self.isExport or self.isTranshipOutbound or self.isRehandle or self.isSOB; 	// PAR #25021
	_bayPoint.bayActIsImport := not _bayPoint.bayActIsExport;
	_bayPoint.tiInfo40 := self.isAttributeTrue(TI_Attrib_IsForty);
	_bayPoint.tiInfo40BackEnd := null;
	_bayPoint.tiInfoCommodity := self.commodity;
	_bayPoint.tiInfoCommodityGroupCode := self.commodityGroup;
	_bayPoint.tiInfoConsigneeCode := self.consignee;
	_bayPoint.tiInfoDischargePort := self.dischargePort;
	_bayPoint.tiInfoISOTypeGroup := self.isoTypeGroup;
	_bayPoint.tiInfoLoadPort := self.loadPort;
	_bayPoint.tiInfoOperatorCode := self.operatorCode;
	_bayPoint.tiInfoProductCode := self.productCode;
	_bayPoint.tiInfoPlannedLocation := self.plannedLocnId;
	_bayPoint.tiInfoReeferTemp := self.getDisplayTemperature(true, false);
//	_bayPoint.tiInfoStatus := self.statusCode;
	_bayPoint.tiInfoTIID := self.id;
	//_bayPoint.tiInfoWeight := (self.weight/1000).asStringJMT;					//-cnwml2 MSL CCMS 1017
	_bayPoint.tiInfoWeight := (self.totalWeight/1000).asStringWeightJMT();		//+cnwml2 MSL CCMS 1017

	_bayPoint.allTrackedItems.add(self);
//	_bayPoint.allTrackedItemAttributes

	// #######################################
	// ICONS
	// #######################################
	if self.readyToShip then
		self.addAttribute(_bayPoint,PicTIReadyToShip);
	endif;
	if self.isHazardous then
		self.addAttribute(_bayPoint,PicTIHazard);
	endif;
	if self.myMatchedTBA &lt;&gt; null then // PAR 35574
		self.addAttribute(_bayPoint,PicTITBA);
	endif;
	
	if self.myPrimaryQueuedLocation &lt;&gt; null then
		self.addAttribute(_bayPoint,PicTIQueued);
	elseif self.myPrimaryPlannedLocation &lt;&gt; null then
		self.addAttribute(_bayPoint,PicTIPlanned);
	endif;

	// #######################################
	// COLOURS
	// #######################################

	aVoyage := self.myVoyage;
	if aVoyage &lt;&gt; null then
		self.addColours(_bayPoint, aVoyage.colour,aVoyage.code,aVoyage,TI_ColourMode_Voyage);
	endif;
	aCommGroup := self.myCommodityGroup;
	if aCommGroup &lt;&gt; null then
		self.addColours(_bayPoint, aCommGroup.colour,aCommGroup.code,aCommGroup,TI_ColourMode_CommodityGroup);
	endif;
	aConsignee := self.myConsignee;
	if aConsignee &lt;&gt; null then
		self.addColours(_bayPoint, aConsignee.colour,aConsignee.code,aConsignee,TI_ColourMode_Consignee);
	endif;
//	aDishPort := self.dischargePort;
	if aDishPort &lt;&gt; null then
		self.addColours(_bayPoint, aDishPort.colour,aDishPort.code,aDishPort,TI_ColourMode_DischargePort);
	endif;
//	aLoadPort := self.dischargePort;
	if aLoadPort &lt;&gt; null then
		self.addColours(_bayPoint, aLoadPort.colour,aLoadPort.code,aLoadPort,TI_ColourMode_LoadPort);
	endif;
//	anISOTypeGroup := self.isoTypeGroup;
	if anISOTypeGroup &lt;&gt; null then
		self.addColours(_bayPoint, anISOTypeGroup.colour,anISOTypeGroup.code,anISOTypeGroup,TI_ColourMode_ISOTypeGroup);
	endif;
	anOperator := self.myOperator;
	if anOperator &lt;&gt; null then
		self.addColours(_bayPoint, anOperator.colour,anOperator.code,anOperator,TI_ColourMode_Operator);
	endif;
	
	productObj	:=	self.myProduct;
	
	if productObj &lt;&gt; null then
		self.addColours(_bayPoint, productObj.colour, productObj.code, productObj, TI_ColourMode_Product);
	endif;
	
//	aWeight := app.myRoot.;
	if aWeight &lt;&gt; null then
		self.addColours(_bayPoint, aWeight.colour,aWeight.value.String,aWeight,TI_ColourMode_Weight);
	endif;
end;</source>
        <Parameter name="_bayPoint" type="SHP_BayPoint" usage="input"/>
    </JadeMethod>
</Class>
