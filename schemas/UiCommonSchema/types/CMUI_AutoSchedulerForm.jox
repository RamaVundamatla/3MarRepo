//27 May 2015	cnwrs1	Par 36285 Make the BGP Auto Schedule Form multiselect
//
vars
	dataTable : CM_DataTable;
begin
	if app.isAllowedToInspect() and self.mySelectedAutoTask &lt;&gt; null then
		self.mySelectedAutoTask.inspect;
	endif;
	
	dataTable := _table.CM_DataTable;
	if dataTable.row = dataTable.fixedRows then
		dataTable.resortTableByColumn(dataTable.column);
	endif;
end;</source>
