    <JadeMethod name="colourAddedRow" id="cce057e9-125b-4872-a953-d87bf4c9795c">
        <updating/>
        <source>colourAddedRow(_addedRow : Integer; _colour1 : Integer; _colour2 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     30 December 2005	cnwhjg1
//
// Purpose:     Colour a recently added row appropriately. 
//				Pass in the two colours the table uses for colouring rows. 
//				This method will work out what colour the row added should be. 
// ----------   ----------  --------------------------------------------------
vars
	backColour,currentRow, colorOtherRow ,
	idx, idx2: Integer;
	
begin
	currentRow := _addedRow;

	if currentRow &gt; self.rows or currentRow &lt;= self.fixedRows then 
		return; // invalid row number
	endif;
	
	if currentRow = (self.fixedRows + 1) then // is first row so look at row below
		if currentRow = self.rows then // is also last row, so make it the first colour
			//If I'm the last row also then I can't increment to the next row.
			//self.accessRow(currentRow + 1).backColor  := _colour1;
			self.accessRow(currentRow).backColor  := _colour1;
			return;
		else
			// look below and use that colour to decide what colour to make it.
			colorOtherRow := self.accessRow(currentRow + 1).backColor;
		endif;		
	else // can look at row above
		colorOtherRow := self.accessRow(currentRow - 1).backColor; 	
	endif;
	
	if colorOtherRow = _colour1 then 
		self.accessRow(currentRow).backColor := _colour2; 	
	else // default will end up being this colour (if wrong colours passed in etc)
		self.accessRow(currentRow).backColor := _colour1; 	
	endif;
end;</source>
        <Parameter name="_addedRow" type="Integer"/>
        <Parameter name="_colour1" type="Integer"/>
        <Parameter name="_colour2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="colourRows" id="20e56beb-3de0-492d-8e94-0ecb4401f7d7">
        <updating/>
        <source>colourRows(_colour1, _colour2 : Integer)updating;
//--------------------------------------------------------------
//Created: 06 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx, idx2: Integer;
begin
	idx2 := (self.fixedRows + 1);
	
	foreach idx in idx2 to self.rows do
		if idx mod 2 = 0 then
			self.accessRow(idx).backColor := _colour1;
		else
			self.accessRow(idx).backColor := _colour2;
		endif;		

	endforeach;
end;</source>
        <Parameter name="_colour1" type="Integer"/>
        <Parameter name="_colour2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="convertInputTypeToPrimType" id="a1c62659-c837-4b06-a738-294defb72a03">
        <source>convertInputTypeToPrimType(_inputType : Integer) : PrimType;
//-----------------------------------------
// Created: September 2005 By: cnwgd1
//-----------------------------------------
vars

begin

	if _inputType = Table.InputType_TextNumeric 
	or _inputType = Table.InputType_SignedNumeric then
		return Real;
	elseif _inputType = CM_EntryTable.InputType_Date then
		return Date;
	elseif _inputType = CM_EntryTable.InputType_Time then
		return Time;
	elseif _inputType = CM_EntryTable.InputType_TimeStamp then
		return TimeStamp;	
	else
		return String;
	endif;

end;</source>
        <Parameter name="_inputType" type="Integer"/>
        <ReturnType type="PrimType"/>
    </JadeMethod>
    <JadeMethod name="convertInputTypeToSortType" id="e1c4dfc3-2a35-4b1e-9e54-57132a386549">
        <source>convertInputTypeToSortType(_inputType : Integer) : Integer;
// -------------------------------------------
// Created 19 May 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if _inputType = Table.InputType_TextNumeric then
		return Table.SortType_Numeric;
	elseif _inputType = Table.InputType_SignedNumeric then
		return Table.SortType_Numeric;
	elseif _inputType = CM_EntryTable.InputType_Date then
		return Table.SortType_Date;
	elseif _inputType = CM_EntryTable.InputType_Time then
		return Table.SortType_Time;
	elseif _inputType = CM_EntryTable.InputType_TimeStamp then
		return Table.SortType_TimeStamp;		
	else
		return Table.SortType_Alpha;
	endif;

end;</source>
        <Parameter name="_inputType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="copyColumnsToTable" id="74e030df-0b66-4699-99c9-1860759b27e3">
        <updating/>
        <source>copyColumnsToTable(_copyToTable : CM_DataTable io) updating;
/*

Purpose:			This method copy the columns and sorting order from "self" to the "_copyToTable".
					Both tables must have the same EntTableDef;

Parameters:			

Return Value:		

Date		Who		Reason
01/04/2025	navkc1 JIRA Story MTN-33942: MTN | Voyage Ops Column Copy option

*/

vars
	baseForm	: CM_BaseForm;
begin
	if _copyToTable = null then
		return;
	endif;
	
	if self.myEntTableDef &lt;&gt; _copyToTable.myEntTableDef then
		return;
	endif;
	
	_copyToTable.allTblDataSortColumns.clear();
	_copyToTable.allTblDataSortDescending.clear();
	self.allTblDataSortColumns.copy(_copyToTable.allTblDataSortColumns);
	self.allTblDataSortDescending.copy(_copyToTable.allTblDataSortDescending);
	
	_copyToTable.setColumnsFromOrganiser(self.allTblDataEntRows, null);
	
	baseForm := _copyToTable.form.CM_BaseForm;
	
	baseForm.setTableDataFromOrganiser(_copyToTable);
	if _copyToTable.allowsColumnFilters then
		baseForm.applyColumnFilter(_copyToTable);
	endif;
	
epilog

end;</source>
        <Parameter name="_copyToTable" type="CM_DataTable" usage="io"/>
    </JadeMethod>
