    <JadeMethod name="getInvoiceTypeSpecifics" id="968fdfd3-d3f4-49a1-8239-e52b5b076f9e">
        <source>getInvoiceTypeSpecifics() : String;
/*

Purpose:			Gets the invoices Specific information

Parameters:			NONE

Return Value:		String	Representing the invoice separation used on the invoice

Date		Who		Reason
21 September 2022	navpw1	Initial creation TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges

*/

vars
	surchargesAndExemptions		: CM_InvoiceTypeSurchargeExempt;
	invoiceTypeDebtorSeparation	: CM_InvTypeDebtorSeparation;
	returnStr					: String;
	hasSeparations				: Boolean;
	
begin
	if self.detailCode &lt;&gt; null then
		return self.detailCode;
	endif;
	
	if self.invoiceType = null then
		return null;
	endif;
	
	surchargesAndExemptions := invoiceType.mySurchargeAndExemptions;
	if surchargesAndExemptions &lt;&gt; null then
		if not surchargesAndExemptions.allInvoiceTypeDebtorSeparation.isEmpty then
			invoiceTypeDebtorSeparation := surchargesAndExemptions.allInvoiceTypeDebtorSeparation[self.debtor];
			if invoiceTypeDebtorSeparation &lt;&gt; null then
				hasSeparations := invoiceTypeDebtorSeparation.getHasSeparations();
			endif;
		endif;
	endif;
	
	if hasSeparations then
		if invoiceTypeDebtorSeparation.separatedByVoyage then
			if self.myVoyage &lt;&gt; null then
				returnStr &amp;= self.myVoyage.code &amp; " ";
			endif;
		endif;
		
		if invoiceTypeDebtorSeparation.separatedByVoyageGroup then
			if self.myVoyage &lt;&gt; null then
				returnStr &amp;= self.myVoyage.voyageGroupCode &amp; " ";
			endif;
		endif;
		
		if invoiceTypeDebtorSeparation.separatedByCargoId then
			if self.myTrackedItem &lt;&gt; null then
				returnStr &amp;= self.myTrackedItem.getDisplayDetails(true) &amp; " ";
			endif;
		endif;
		
		if invoiceTypeDebtorSeparation.separatedByBillOfLading then
			if self.myBOL &lt;&gt; null then
				returnStr &amp;= self.myBOL.number &amp; " ";
			endif;
		endif;
		
		if invoiceTypeDebtorSeparation.separatedByBooking then
			if self.myBookingRef &lt;&gt; null then
				returnStr &amp;= self.myBookingRef.bookingReference &amp; " ";
			endif;
		endif;
		
		if invoiceTypeDebtorSeparation.separatedByCargoGroupId then
			if self.myCargoGroup &lt;&gt; null then
				returnStr &amp;= self.myCargoGroup.id &amp; " ";
			endif;
		endif;
		
		if invoiceTypeDebtorSeparation.separatedByReleaseRequest then
			if self.myReleaseRequest &lt;&gt; null then
				returnStr &amp;= self.myReleaseRequest.code &amp; " ";
			endif;
		endif;
		
		 // ### BUG 56925 07MAR2023 NAVAB1
		if invoiceTypeDebtorSeparation.separatedByPONumber then
			if self.purchaseOrderNumber &lt;&gt; null then
				returnStr &amp;= self.purchaseOrderNumber &amp; " ";
			endif;
		endif;
		
		
		
		return returnStr;
		
	elseif self.invoiceType.isVoyageSpecific() then
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.code;
		endif;
		
	elseif self.invoiceType.isVoyageGroupSpecific() then
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.voyageGroupCode;
		endif;
		
	elseif self.invoiceType.isCargoItemSpecific() then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayDetails(true);
		endif;
		
	elseif self.invoiceType.isBOLSpecific() then
		if self.myBOL &lt;&gt; null then
			return self.myBOL.number;
		endif;
		
	elseif self.invoiceType.isBookingSpecificDebtor(null) then
		if self.myBookingRef &lt;&gt; null then
			return self.myBookingRef.bookingReference;
		endif;
		
	elseif self.invoiceType.isCargoGroupSpecificDebtor(null) then
		if self.myCargoGroup &lt;&gt; null then
			return self.myCargoGroup.id;
		endif;
		
	elseif self.invoiceType.isReleaseSpecificDebtor(null) then
		if self.myReleaseRequest &lt;&gt; null then
			return self.myReleaseRequest.code;
		endif;
	
	 // ### BUG 56925 07MAR2023 NAVAB1
	elseif self.invoiceType.isPONumberSpecificDebtor(null) then
		return self.purchaseOrderNumber;
	endif;
	
	return null;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoicesCopiedToExtStr" id="f387980b-f153-4245-91ce-9f5da8be4c5b">
        <source>getInvoicesCopiedToExtStr() : String;
/*

Purpose:			//16/10/2024	navkc1	JIRA Bug MTN-12541
					It's changed to be "Copied To Ext", when user select Invoice/Credit Note and Copy as Invoice/Credit Note
					E.g
					Invoice 1
					User select Invoice 1 and copy as Invoice 2
					Invoice 2.myOtherInvoice will have reference to Invoice 1
					Invoice 1.allOtherInvoices will have reference to Invoice 2

Parameters:			

Return Value:		

Date		Who		Reason
//09/08/2024	navkc1 CR 64894 Task 64895: Jade - New Columns for Invoice List

*/

vars
	str 		: String;
	invoice		: CM_Invoice;
	
begin
	
	//foreach invoice in self.allOtherInvoices discreteLock where invoice.isInvoice() do
	foreach invoice in self.allOtherInvoices discreteLock do //16/10/2024	navkc1	JIRA Bug MTN-12541
		//21/08/2024	navkc1 Bug 65741
		if invoice.externalNumber = null then
			continue;
		endif;
		if str = null then
			str := invoice.externalNumber.asStringJMT();
		else
			str &amp;= ", " &amp; invoice.externalNumber.asStringJMT();
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoicesCopiedToStr" id="f10977b5-09f4-46f4-a591-bdcba897ec40">
        <source>getInvoicesCopiedToStr() : String;
/*

Purpose:			//16/10/2024	navkc1	JIRA Bug MTN-12541
					It's changed to be "Copied To", when user select Invoice/Credit Note and Copy as Invoice/Credit Note
					E.g
					Invoice 1
					User select Invoice 1 and copy as Invoice 2
					Invoice 2.myOtherInvoice will have reference to Invoice 1
					Invoice 1.allOtherInvoices will have reference to Invoice 2

Parameters:			

Return Value:		

Date		Who		Reason
//09/08/2024	navkc1 CR 64894 Task 64895: Jade - New Columns for Invoice List

*/

vars
	str		: String;
	invoice : CM_Invoice;
begin

	//foreach invoice in self.allOtherInvoices discreteLock where invoice.isInvoice() do
	foreach invoice in self.allOtherInvoices discreteLock do //16/10/2024	navkc1	JIRA Bug MTN-12541
		if str = null then
			str := invoice.sequenceNum.asStringJMT();
		else
			str &amp;= ", " &amp; invoice.sequenceNum.asStringJMT();
		endif;
	endforeach;

	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKinrjaForInvoice" id="143ff6fd-b3c4-4fc5-a639-62a241369bca">
        <source>getKinrjaForInvoice():CMIF_KinerjaArray;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Dec 2018	cnwma1	ChangeRequest 38638: PEL1 - SAP Send Performance (Kinerja) Data
21 Jan 2019 cnwma1	Bug 42895: PEL1 - Kinerja Change for fields
12 Feb 2019 cnwma1	Bug 43211: PEL1 - Kinerja Issues/Changes
*/

vars
	kinerja,
	kinerjaDWT 		 : CMIF_Kinerja ;
	kinerjaArr	     : CMIF_KinerjaArray;
	checkDT			 : TimeStamp;
	voyage			 : CM_Voyage;
	berth       	 : HMS_Berth;
	movement    	 : HMS_Movement;
	startDate,
	endDate 		 : Date;
	period      	 : Integer;
	lastPostponeTM   : Real;

begin
	
	if self.paymentType = PaymentType_PostPay or self.paymentType = PaymentType_PrePay then
		checkDT := self.pendingDT;
	elseif self.paymentType = PaymentType_PostPay then
		checkDT := self.postedDT;
	endif;
	
	app.myRoot.getPeriodForPleindo(checkDT,startDate,endDate);   //21.01.2019 Bug #42895
	voyage  := self.myVoyage;
	
	if self.invoiceType.externalReference = "4A0" then
		/*
			4A0 - Nota Kapal
		*/
		
		create kinerjaArr transient;
		foreach movement in voyage.myHMSVoyageData.allVoyageMovements do
			if movement.moveType = HMSMovementTypeDeparture then
				continue;
			endif;
			create kinerja transient;
			period := kinerja.getPeriodDays(startDate,endDate);
			berth  := movement.getMyBerth;
			kinerja.setMyVoyage(voyage);
			kinerja.myTerminal := self.myTerminal;
			kinerja.myMovement := movement;
			kinerja.dataSource := "MT";
			kinerja.dateTime   := checkDT;
			kinerja.branchCode  := berth.externalReference1;
			if berth.externalReference4 &lt;&gt; null then
				kinerja.berthID     := berth.externalReference4;
			endif;
			kinerja.berthName  	:= berth.myWharf.description;
			
			kinerja.setMainServiceTM(movement);
			kinerja.setMainUtilization(movement,period);
			if lastPostponeTM = null then
				kinerja.setSTPostponeTM(movement);
			endif;
			kinerja.uOM := Space;
			lastPostponeTM := kinerja.postPoneTM;
			kinerjaArr.add(kinerja);
		endforeach;
		
	elseif (self.invoiceType.externalReference = "4ST" or self.invoiceType.externalReference = "4NL" ) then //12.02.2019 cnwma1 Bug #43211
		/*
			4NL - Nota NonTPK - Operasi Lapangan
			4ST - Nota Jasa Penumpukan
		*/
		
		create kinerjaArr transient;
		create kinerjaDWT transient;
		kinerjaDWT.setMainDwellTM(self);
		kinerjaDWT.dateTime := checkDT;
		kinerjaDWT.dataSource := "MT";
		kinerjaArr.add(kinerjaDWT);
	endif;

	return kinerjaArr;
epilog

end;</source>
        <ReturnType type="CMIF_KinerjaArray"/>
    </JadeMethod>
    <JadeMethod name="getLastModifiedDTLocalTZ" id="5839c240-11da-44fa-93b1-4e151997e232">
        <source>getLastModifiedDTLocalTZ(): TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2018	jlgndl1	Initial creation	TFS 40494

*/

vars

	ts : TimeStamp;
	audit : CM_AuditObject;
	
begin

	audit := self.allAuditObjectsForClass.last();	//21 Jan 2021	NDL	TFS 50152
	if audit &lt;&gt; null then
		ts := audit.createdTime;
	else
		ts := self.createdTime;
	endif;

	return self.systemToLocalTime( ts );

epilog

end;</source>
