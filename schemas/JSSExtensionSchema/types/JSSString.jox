    <DbClassMap file="jssxs_datavalue_primitive"/>
    <PrimAttribute name="patternValue" id="02e233b9-b083-489a-844f-3e2061ce671c">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="stringValue" id="95c9d9aa-218f-48a8-83cb-74dddfea2b6f">
