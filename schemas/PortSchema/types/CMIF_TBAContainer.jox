    <JadeMethod name="setMeasurementValue" id="73f599a5-604c-47eb-9516-9bd8bd36dbdd">
        <updating/>
        <source>setMeasurementValue(_entRowName: String; _value: Decimal) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/09/2014	cnwdap1		Initial creation PAR #33872
//
vars

begin
	if _entRowName = ETRow_TbaWeight then
		self.weight := _value;
	elseif _entRowName = ETRow_TbaH then
		self.height := _value.Integer;
	elseif _entRowName = ETRow_TbaL then
		self.length := _value.Integer;
	elseif _entRowName = ETRow_TbaW then
		self.width := _value.Integer;
	else
		inheritMethod(_entRowName, _value);
	endif;

epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_value" type="Decimal"/>
    </JadeMethod>
</Class>
