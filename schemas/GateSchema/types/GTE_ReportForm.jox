    <JadeMethod name="cmbReports_click" id="1f069f43-9703-4a4e-919e-6df4fcefd430">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbReports_click(combobox: ComboBox input) updating;

vars
	report : JadeReportWriterReport;
begin

	app.mousePointer := MousePointer_HourGlass;
	statusLine.caption := "Getting report profiles and parameters";
	app.doWindowEvents(0);

	report := reportManager.getReport(cmbReports.text);
	
	if report = null then
		app.raiseCMException2(ERR_INVALID_VALUE, "the report name ", "Contact Developer", null,null);
	endif;

	loadReportProfiles(report);
	
	//setParameterControls(report);
	tableMethod;
	
	statusLine.caption := "Please Select a Profile and Enter Report Parameters";
	app.mousePointer := MousePointer_Default;	
epilog
	delete report;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
