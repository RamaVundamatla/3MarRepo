    <JadeMethod name="resizeOverlayFrames" id="30b7153c-fd3f-4bb9-8544-7776dda1caae">
        <source>resizeOverlayFrames(pWidth: Real; pHeight: Real);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myDragSelectFrame.move(0,0,pWidth, pHeight);
	self.myOverlayDrawingFrame.move(0,0,pWidth, pHeight);
	self.myOverlayViewingFrame.move(0,0,pWidth, pHeight);
end;</source>
        <Parameter name="pWidth" type="Real"/>
        <Parameter name="pHeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="selectBlockOfObjectsFromXYs" id="a6abfa1d-45be-4e9d-aabc-aff2b494e1be">
        <updating/>
        <source>selectBlockOfObjectsFromXYs(_frame : CMUI_GridAreaDrawingFrame; _class : Class; _secondClass : Class; _x1,_y1,_x2,_y2 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		29 July 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	objs : ObjectArray ;
	startObj, anObj : Object;
	selectTI : Boolean;
	cdc : YRD_ContainerDrawingController;
	realX1,realX2,realY1,realY2 : Integer;
	tmpRow : CM_GridRow;
	cell : CM_YALocationCell;
begin
	create objs transient;

	cdc := self.myDockBar.myDrawingController;
	
	if cdc = null then
		return;
	endif;
	
	realX1 := _x1;
	realY1 := _y1;
	realX2 := _x2;
	realY2 := _y2;

	if _x1 &gt; _x2 then
		realX1 := _x2;
		realX2 := _x1;
	endif;
	
	if _y1 &gt; _y2 then
		realY1 := _y2;
		realY2 := _y1;
	endif;
	
	cdc.allGridObjects.findObjectsInDict(realX1,realY1,realX2,realY2, objs, _class,true,false);
	
	if objs.isEmpty then
		return;
	endif;

	if _class = CM_TrackedItem then
	
		_frame.reorderSelectedObjects(_x1,_y1,_x2,_y2, objs,1);	
		foreach anObj in objs do
			selectTI := true;
			if cdc.onlySelectSelectorTIs then
				if not cdc.allSelectorTIs.includes(anObj.CM_TrackedItem)  then
					selectTI := false;
				endif;
			endif;
			if selectTI then
				self.selectObject(anObj,startObj,false);	
			endif;
		endforeach;
	elseif _class = CM_IrregularBlockController then
			foreach anObj in objs do
				self.selectObject(anObj,startObj,false);	
			endforeach;
	elseif _class = CM_LocationsController then
		if _secondClass = CM_GridRow then
			foreach anObj in objs do
				if not anObj.isKindOf(CM_GridController) then
					continue;
				endif;
				tmpRow := anObj.CM_GridController.myGridRow;
				if tmpRow &lt;&gt; null then
					if not cdc.allSelectedObjects.includes(tmpRow) then
						cdc.allSelectedObjects.add(tmpRow);
					endif;
				endif;
			endforeach;
			
		elseif _secondClass = CM_YALocationCell then	//24 Aug 2011	NDL	Par 28035
			foreach anObj in objs do
				if not anObj.isKindOf(CM_YardController) then
					continue;
				endif;
				if anObj.CM_YardController.allYAYardLocationCells.isEmpty then
					if anObj.CM_YardController.isAvailForMultiMove then
						if not cdc.allSelectedObjects.includes(anObj) then
							self.selecteObjectGridMultiMove(anObj,startObj,false);
						endif;
					endif;
				else
					foreach cell in anObj.CM_YardController.allYAYardLocationCells do
						if not cdc.allSelectedObjects.includes(cell) then
							if cell.isAvailForMultiMove then
								if not cdc.allSelectedObjects.includes(anObj) then
									self.selecteObjectGridMultiMove(anObj,startObj,false);
								endif;
								self.selecteObjectGridMultiMove(cell,startObj,false);
							endif;
						endif;
					endforeach;
				endif;
			endforeach;
			
		else
			foreach anObj in objs do
				self.selectObject(anObj,startObj,false);	
			endforeach;
		endif;
	endif;
epilog
	delete objs;

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_secondClass" type="Class"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectObject" id="c48b3820-0cda-4d51-bd13-ac4e1686b1cf">
        <updating/>
        <source>selectObject(_obj : Object; _startObj : Object io; _isAlt : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
31 Mar 2009	cnwkpd1	PAR #18982 - Fix Grid Area display and selection issues
					Do not want to select the container "under" a future move, because
					this results in strange GUI behaviour, of "selecting" a box that is
					not clicked

*/


vars
	tmpTI : CM_TrackedItem;
	
begin
	if _obj = null then
		return;
	endif;

	if self.myDockBar.isForOverview then
		if not _obj.isKindOf(CM_LocationsController) 
		and not _obj.isKindOf(CM_TrackedItem) then // PAR 18682
			return;
		endif;
	else
		if not (_obj.isKindOf(CM_TrackedItem) or _obj.isKindOf(CM_FutureMove) or _obj.isKindOf(CM_IrregularBlockController)) then
/* PAR #18982 - removed
			// PAR 18682
			if _obj.isKindOf(CM_FutureMove) then
				tmpTI := _obj.CM_FutureMove.getTrackedItem();
				if tmpTI = null then
					return;
				endif;
				if _isAlt then
					self.myDockBar.myDrawingController.selectObjectAlt(tmpTI, self, true);
				else
					self.myDockBar.myDrawingController.selectObject(tmpTI, self, true);
				endif;
				_startObj := tmpTI;
			endif;
*/
			return;
		endif;
	endif;	
	if _isAlt then
		self.myDockBar.myDrawingController.selectObjectAlt(_obj, self, true);
	else
		self.myDockBar.myDrawingController.selectObject(_obj, self, true);
	endif;
	
	_startObj := _obj;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_startObj" type="Object" usage="io"/>
        <Parameter name="_isAlt" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectObjectRoRo" id="f734084e-9b04-44fc-8526-836d67cda5a0">
        <updating/>
        <source>selectObjectRoRo(_obj : Object; _startObj : Object io; _isAlt : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		December 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	if _obj = null then
		return;
	endif;

	if not _obj.isKindOf(CM_TrackedItem) then
		return;
	endif;
	
	if _isAlt then
		self.myDockBar.myRoRoLaneDrawingController.selectObjectAlt(_obj, self, true);
	else
		//self.myDockBar.myRoRoLaneDrawingController.selectObject(_obj, self, false);	// cnwjk3 PAR 22733 08/03/2010
		self.myDockBar.myRoRoLaneDrawingController.selectObject(_obj, self, true);		// cnwjk3 PAR 22733 08/03/2010
	endif;
	
	_startObj := _obj;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_startObj" type="Object" usage="io"/>
        <Parameter name="_isAlt" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selecteObjectGridMultiMove" id="d5cc51f9-e2e3-4d4c-8e8f-7ea0af8bc473">
        <updating/>
        <source>selecteObjectGridMultiMove(_obj : Object; _startObj : Object io; _isAlt : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	tmpTI : CM_TrackedItem;
	
begin
	if _obj = null then
		return;
	endif;

	if self.myDockBar.isForOverview then
		if not _obj.isKindOf(CM_LocationsController) 
		and not _obj.isKindOf(CM_TrackedItem) then // PAR 18682
			return;
		endif;
	else
		if not _obj.isKindOf(CM_TrackedItem)
		and not _obj.isKindOf(CM_FutureMove)
		and not _obj.isKindOf(CM_LocationsController)
		and not _obj.isKindOf(CM_YALocationCell)
		then
			return;
		endif;
	endif;	
	
	if _isAlt then
		self.myDockBar.myDrawingController.selectObjectAlt( _obj, self, true);
	else
		self.myDockBar.myDrawingController.selectObject( _obj, self, true);
	endif;
	
	_startObj := _obj;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_startObj" type="Object" usage="io"/>
        <Parameter name="_isAlt" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIgnoreSkin" id="a826abe8-86b3-4a88-9294-56f0cb6e124c">
        <updating/>
        <source>setIgnoreSkin() updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.myDockBar.myScrollableFrame.myHLabels.ignoreSkin := true;
	self.myDockBar.myScrollableFrame.myVLabels.ignoreSkin := true;
	self.myDockBar.myScrollableFrame.myTopLeftFillerFrame.ignoreSkin := true;
	self.ignoreSkin := true;
	
	self.myDockBar.ignoreSkin := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="setSwapXY" id="c0949b6c-c8f6-4722-84a8-8543cc155681">
        <updating/>
        <source>setSwapXY( _swapXY : Boolean; _origin : Point; _scaleFactor : Real ) updating;

/*

Purpose:		

Parameters:			

Return Value:		


Date				Who		Reason
26 November 2008	consw1	Initial creation

*/

vars

begin
	self.swapXY := _swapXY;
	
	if _swapXY then
		self.swapXadjustment := (( _origin.y - _origin.x ) * _scaleFactor ).Integer;
		self.swapYadjustment := (( _origin.x - _origin.y ) * _scaleFactor ).Integer;
	else
		self.swapXadjustment := 0;
		self.swapYadjustment := 0;
	endif;

epilog

end;</source>
        <Parameter name="_swapXY" type="Boolean"/>
        <Parameter name="_origin" type="Point"/>
        <Parameter name="_scaleFactor" type="Real"/>
    </JadeMethod>
    <JadeMethod name="showYardGridAreasForm" id="94903434-2110-452e-9274-fece3dd891d5">
        <updating/>
        <source>showYardGridAreasForm( _x1, _y1, _x2, _y2 : Integer ) updating;

/*

Purpose:		Show Yard Grid Areas form

Parameters:		_x1, _y1, _x2, _y2 bound the area to be displayed

Return Value:		


Date				Who		Reason
01 December 2008	consw1	Initial creation
02 July 2009		cnwjo3	updated to show different types of Terminal Areas
*/

vars
	cdc : YRD_ContainerDrawingController;
	objs : ObjectArray;
	yrdForm : CM_BaseForm;

	terminalAreas : ObjectArray;
	termArea : Object;
	yardGridAreaShown : Boolean;
	x1, y1,																							// cnwjk3 PAR 21704	15/02/10
	x2, y2		: Integer;																			// cnwjk3 PAR 21704	15/02/10
begin
	cdc := self.getDrawingController();

	yrdForm := self.form.CM_BaseForm;
	
	create objs transient;
	
	//cdc.allGridObjects.findObjectsInDict( _x1, _y1, _x2, _y2, objs, CM_LocationsController,true);	// cnwjk3 PAR 21704	15/02/10
	x1 := _x1; 																						// cnwjk3 PAR 21704	15/02/10
	y1 := _y1;																						// cnwjk3 PAR 21704	15/02/10
	x2 := _x2;																						// cnwjk3 PAR 21704	15/02/10
	y2 := _y2;																						// cnwjk3 PAR 21704	15/02/10
	self.getDrawingController().normaliseRectanglePoints(x1, y1, x2, y2);							// cnwjk3 PAR 21704	15/02/10
	cdc.allGridObjects.findObjectsInDict(x1, y1, x2, y2, objs, CM_LocationsController, true,false);		// cnwjk3 PAR 21704	15/02/10

	//identify all the terminal areas selected.
	create terminalAreas transient;
	foreach termArea in objs do
		if not terminalAreas.includes(termArea.CM_LocationsController.myTerminalArea) then
			terminalAreas.add(termArea.CM_LocationsController.myTerminalArea);  //this should add all terminal areas
		endif;
	endforeach;
	
	//display each terminal area
	foreach termArea in terminalAreas do
		if termArea.isKindOf(CM_RoRoLaneArea) then
			yrdForm.myAssistant.showRoRoLaneAreasForm(termArea, cdc.getViewMode(), yrdForm.myMasterMenuAction);	 // cnwjk3 ccms 1018 03/12/09
		elseif termArea.isKindOf(CM_IrregularBlockArea) then
			//General Cargo Area
			yrdForm.myAssistant.showGeneralCargoAreaForm(termArea.CM_IrregularBlockArea,yrdForm.myMasterMenuAction,false,true);
		elseif termArea.isKindOf(CM_BlockStack)then
			//Block Stacks....  Fumigation, Generator Area, Repair, etc
			yrdForm.myAssistant.showLocationEnquiryForm(termArea.CM_Object,yrdForm.myMasterMenuAction,false,true);
		elseif termArea.isKindOf(CM_YardInterchangeArea) then
			if termArea.CM_YardInterchangeArea.isGateInterchangeArea then
				yrdForm.myAssistant.YRD_Assistant.showRoadOperations(termArea.CM_Object,yrdForm.myMasterMenuAction);
			else	
				//Block Stacks....  Fumigation, Generator Area, Repair, etc
				yrdForm.myAssistant.showLocationEnquiryForm(termArea.CM_Object,yrdForm.myMasterMenuAction,false,true);
			endif;
		else
			//everything else, display in Yard Grid Areas form cnwjo3
			//only need to show it once since its 'smart' enough to display mutliple areas
			if not yardGridAreaShown then
				yrdForm.myAssistant.showYardGridAreasForm(objs, cdc.getViewMode(), yrdForm.myMasterMenuAction, 0);	// PAR 21532 CCMS SFW 1025 - Added 0 parameter
				yardGridAreaShown := true;
			endif;
		endif;
	endforeach;

epilog
	delete objs;
	delete terminalAreas;
end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
