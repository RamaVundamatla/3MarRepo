    <JadeMethod name="createVoyHoldDischargeJob" id="2df09d25-136c-4ce3-b668-0412d85bf4f8">
        <source>createVoyHoldDischargeJob( _gcController : CM_GeneralCargoController ):CM_VoyageHoldJob;
/*

Purpose:			

Parameters:			creates discharge wle for all cargo in the hold location i.e. the CM_GeneralCargoController

Return Value:		

Date		Who		Reason
19 June 2019	jlgndl1	Initial creation	TFS 42876

*/

vars

	voyage : CM_Voyage;
	jobType : Integer;
	jobId : String;
	pxyJob : CM_VoyageHoldJob;
	allocatedTIs : CM_TISet;
	realJob : CM_VoyageHoldJob;
	holdReq : CM_HoldRequest;
	success : Boolean;

begin

	voyage := _gcController.myVoyage;
	jobType := JOB_TYPE_DISCHARGE;
	jobId := voyage.getNextJobNumber(null,null);
	
	create allocatedTIs transient;
	_gcController.allTrackedItems.copy( allocatedTIs );
	
	create pxyJob transient;
	pxyJob.setProxy( jobId, jobType );
	pxyJob.setProxyVoyage( voyage );
	pxyJob.setProxyVoyageHoldJob(	null,	//_craneID,
									jobId,	//_jobNum,
									null,	//_remarks,	
									null,	//_systemRemarks : String;
									false,	//_isTwinLift	: Boolean;
									jobType,	//_jobType : Integer;
									null,	//_userJobType : CM_JobType;
									0,	//_estimatedTimeToCompleteMins : Integer;
									null,	//_actualStartTs,
									null,	//_actualEndTs : TimeStamp;
									false,	//_outOfSequenceLoading : Boolean;
									null,	//_shift : CM_Shift;
									null,	//_dlrDischargeJob : CM_VoyageHoldJob;
									allocatedTIs,	//_allocatedTIs : CM_TISet;
									null,	//_estimatedStartDT,
									null	//_estimatedEndDT : TimeStamp
									);
									
	beginTransaction;
	
	create realJob;
	realJob.setForCreate( pxyJob, self.getTerminal );
	realJob.setMyVoyage( voyage );
	
	create holdReq;
	holdReq.setJob( realJob );
	holdReq.createWLEs();
	holdReq.setLC(_gcController);
	holdReq.setMoveType(DISCHARGE_MOVETYPE);
	
	commitTransaction;
	
	success := true;
	
	return realJob;
	
epilog

	abortTransaction;
	
	
	delete pxyJob;
	delete allocatedTIs;

	self.assertTrueMsg( success, method.qualifiedName &amp; " failed to create hold job");

end;</source>
        <Parameter name="_gcController" type="CM_GeneralCargoController"/>
        <ReturnType type="CM_VoyageHoldJob"/>
    </JadeMethod>
    <JadeMethod name="createVoyageHoldLoadJob" id="80ae1254-24c2-42cf-8a2f-8f1218e82715">
