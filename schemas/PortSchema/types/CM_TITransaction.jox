    <JadeMethod name="getExportReceivedTransMode" id="e15a11ff-037d-4b92-82f7-8eb616c8233f">
        <source>getExportReceivedTransMode(): String;
//----------------------------------------------------------------
//	Created:	28 June 2005	by Jason Chapman  (cnwjc2)
//
//	Created for the weight report - should return the type of area
//	the container was released from as an export.  E.g. if a STMT
//	is packed for export this should return 'Packed', not the MT's
//	original receipt trans mode.
//
//	Assume the status at the time the box is weighed is correct
//----------------------------------------------------------------
// Changed On 	By			Reason
// ----------	--------	--------------------------------------
// 19/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	
begin
	if self.imExStatus &lt;&gt; TI_IMEX_STATUS_EXPORT 
			and self.imExStatus &lt;&gt; TI_IMEX_STATUS_TRANSHIP then		// PAR #23645 CCMS 1116
		return self.myTrackedItem.getReceiptTransportModeStr();
	endif;

	if self.myTrackedItem.wasPacked then
		return "Packed";
	else
		return self.myTrackedItem.getReceiptTransportModeStr();
	endif;	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraDataComment" id="402a68b1-c1d9-48b0-bcb9-724da425ec7a">
