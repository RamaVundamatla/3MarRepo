    <JadeMethod name="buildIMVTask" id="e2bc4e9b-2ece-4ee2-93b4-607f0b44b547">
        <source>buildIMVTask(_arbiter : CM_RTQueueArbiter input) protected;

// Created by cnwdvb1 on 29 August 2006

vars

	task	: CM_RTQueueTask;
	
begin

	_arbiter.entry.machineTypeGroup := self.type;
	create task;
	task.setDetails(	_arbiter.sourceLocation.getMyLaneController(),
						_arbiter.targetLocation.getMyLaneController(),
						TASK_UNACTIONED,
						TASK_MOVE,
						_arbiter.ti);
						
	_arbiter.entry.addTask(task);

end;</source>
        <access>protected</access>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildQueueTasks" id="a0189205-5be5-40ca-a9a1-2854a51f5c37">
        <source>buildQueueTasks(_arbiter : CM_RTQueueArbiter input);

// Created by cnwdvb1 on 29 August 2006

vars

begin

	if self.type = MACHINETYPEGRP_RTG then
		self.buildRTGQueueTasks(_arbiter);
	elseif self.type = MACHINETYPEGRP_IMV then
		self.buildIMVTask(_arbiter);
	elseif	self.type = MACHINETYPEGRP_LIFTER or 
			self.type = MACHINETYPEGRP_STRADDLE then
		self.buildStandardTasks(_arbiter);
	endif;

end;</source>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildRTGQueueTasks" id="edd8f0e4-47fb-4df2-84a0-e9af5e6e4681">
        <source>buildRTGQueueTasks(_arbiter : CM_RTQueueArbiter input) protected;
 
// Created by cnwdvb1 on 29 August 2006
 
vars
 
	taskPickup,
	taskSetdown : CM_RTQueueTask;
  
begin
 
	_arbiter.entry.machineTypeGroup := self.type;
	create taskPickup;
	create taskSetdown;
 
	taskPickup.setDetails(	_arbiter.sourceLocation,
							_arbiter.targetLocation,
							TASK_UNACTIONED,
							TASK_PICKUP,
							_arbiter.ti);
 
	_arbiter.entry.addTask(taskPickup);
  
	taskSetdown.setDetails(	taskPickup.sourceLocation,
							taskPickup.targetLocation,
							TASK_UNACTIONED,
							TASK_SETDOWN,
							_arbiter.ti);
							

	_arbiter.entry.addTask(taskSetdown);
  
 
end;


 </source>
        <access>protected</access>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildStandardTasks" id="33cdf610-ff6d-483c-b8db-b462ccf5af91">
        <source>buildStandardTasks(_arbiter : CM_RTQueueArbiter input) protected;

// Created by cnwdvb1 on 29 August 2006

vars

	arbiter : CM_RTQueueArbiter;
	task	: CM_RTQueueTask;
	

begin

	arbiter := _arbiter;
	
	arbiter.entry.machineTypeGroup := self.type;

	if arbiter.sourceLocation &lt;&gt; null then
		arbiter.sourceLocation.getQueueTasks(arbiter, true);
	else
		arbiter.ti.getPrimaryLocation(REAL_MODE).getQueueTasks(arbiter, false);
	endif;
	
	if arbiter.targetLocation &lt;&gt; null then
		arbiter.targetLocation.getQueueTasks(arbiter, false);
	else
		arbiter.ti.getLastQueuedLocation().getQueueTasks(arbiter, false);
	endif;
	


end;</source>
        <access>protected</access>
        <Parameter name="_arbiter" type="CM_RTQueueArbiter" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getName" id="ff8fec0a-b743-4eb2-9c92-f62ed56d3ed2">
        <source>getName(): String;

// Created by cnwdvb1 on 28 August 2006

vars

begin
	return inheritMethod() &amp; ' ' &amp; self.description;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="066ab4f4-5f35-41c8-8cf4-d2cfae7d19c7">
        <updating/>
        <source>setForCreate(_proxyMachineTypeGroup : CM_MachineTypeGroup) updating;

// Created by cnwdvb1 on 22 August 2006

vars

begin

	self.setForUpdate(_proxyMachineTypeGroup);
	
	self.type		:= _proxyMachineTypeGroup.type;
	self.myRoot		:= _proxyMachineTypeGroup.myRoot;

end;</source>
        <Parameter name="_proxyMachineTypeGroup" type="CM_MachineTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7b13846d-78f4-4da4-b1a0-d54138b97118">
        <updating/>
        <source>setForUpdate(_proxyMachineTypeGroup : CM_MachineTypeGroup) updating;

// Created by cnwdvb1 on 22 August 2006

vars

begin

	self.description	:= _proxyMachineTypeGroup.description;
	self.allMachineTypes.clear();
	_proxyMachineTypeGroup.allMachineTypes.copy(self.allMachineTypes);

end;</source>
        <Parameter name="_proxyMachineTypeGroup" type="CM_MachineTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromXML" id="d6ea4a83-4746-4000-b0a7-98fd0fa57d9b">
        <updating/>
        <source>setProxyFromXML(_type : Integer; _xmlStr	: String; _root : CM_Root) updating;

// Created by cnwdvb1 on 22 August 2006

vars
	
	theLength,
	pos					: Integer;
	machineTypeStr,
	allMachineTypesStr	: String;
	machineType			: CM_MachineType;
	
begin

	/*&lt;MachineTypeGroup&gt;
	&lt;description&gt;Fork Lift/Side Loader/Top Lift&lt;/description&gt;
	&lt;allMachineTypes&gt;
		&lt;machineType&gt;1&lt;/machineType&gt;
		&lt;machineType&gt;2&lt;/machineType&gt;
		&lt;machineType&gt;3&lt;/machineType&gt;
	&lt;/allMachineTypes&gt;
&lt;/MachineTypeGroup&gt;*/

	self.allMachineTypes.clear();
	self.description	:= _xmlStr.cnEcGetTagValueOfName('description');
	pos := 1;
		
	allMachineTypesStr := _xmlStr.cnEcGetTagValueOfName('allMachineTypes');
	theLength := allMachineTypesStr.length;
	
	while pos &lt;= theLength do
		machineTypeStr := allMachineTypesStr.cnEcGetNextTagValueOfName('machineType', pos);
		if machineTypeStr = null or pos &lt; 1 then
			break;
		endif;
		
		machineType := _root.allMachineTypes[machineTypeStr.Integer];
		if machineType &lt;&gt; null then
			self.allMachineTypes.add(machineType);
		endif;
	endwhile;
	
	self.type			:= _type;
	self.myRoot			:= _root;

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_xmlStr" type="String"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
</Class>
