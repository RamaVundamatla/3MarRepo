    <JadeMethod name="addWLEToTable" id="91e25669-80d6-466e-8581-b0e98c1736e1">
        <source>addWLEToTable(_wle : CM_WorkListEntry; _idx : Integer) protected;
//--------------------------------------------------
// Created:	28 January 2004 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
02 Jun 2010	cnwkpd1	PAR #24334 - Handle invalid objects when loading WLE table

*/

vars
	theDataLine : String;
	foreColour,
	backColour,
	idx : Integer;
	excOccurred : Boolean;
	
begin

	if (not CM_VoyageWLE.hasInstance(_wle)) then
		return;
	endif;

	on Exception do self.handleInvalidWLEAdd(exception, excOccurred);
	
	theDataLine := _wle.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	
	if excOccurred then
		return;
	endif;
	
	if _idx = null then
		idx := self.tblData.addItem(theDataLine);
	else
		self.tblData.addItemAt(theDataLine, _idx);	
		idx := _idx;
	endif;
	
	self.tblData.accessRow(idx).itemObject := _wle;
	self.doNotableAdd(_wle.myTrackedItem);
	self.doNotableAdd(_wle);

	_wle.getRowColour(foreColour, backColour);
	self.tblData.accessedRow.foreColor := foreColour;
	self.tblData.accessedRow.backColor := backColour;
	if backColour = Red then
		self.tblData.accessedRow.fontBold := true;
	else
		self.tblData.accessedRow.fontBold := false;				
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
