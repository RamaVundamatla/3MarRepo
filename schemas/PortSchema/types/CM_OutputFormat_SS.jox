    <JadeMethod name="validateForCreate" id="86fa9137-9082-4eef-ac94-6eee188aee2d">
        <source>validateForCreate( _realFormat : CM_OutputFormat_SS );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars
	tempStr					: String;
	element					: CM_XTABElement;
	cm_OutputFormat_SS		: CM_OutputFormat_SS;
	
begin
	if self.getQueryDefinition = null then
	//	app.raiseCMException1 (REQUIRED_FIELD, 'mode', null, self);
		app.raiseCMException (Input_required_field_mode, null, self); // cnwdb2	PAR 35364


	endif;
	if self.name.trimBlanks = null then
	//	app.raiseCMException1 (REQUIRED_FIELD, 'name', null, self);
		app.raiseCMException (Input_required_field_name, null, self); // cnwdb2	PAR 35364
	else
		// Make sure the name does not contain the default name part of "&lt;New Summary Defn&gt;"
		tempStr		:= app.getString( XTAB_New_Summary_Definition, null ).trimBlanks;
		if self.name.trimBlanks.pos( tempStr, 1 ) &lt;&gt; null then
			app.raiseCMException1( SummaryDefn_InvalidName, tempStr, null, self );
		endif;
		
		// Validate name is not already being used (CCMS SFW 1047 - Totals Only Lists)
		cm_OutputFormat_SS	:= app.myRoot.allOutputFormats_SS[ self.name.trimBlanks ].CM_OutputFormat_SS;
		if cm_OutputFormat_SS &lt;&gt; null then
			// one exists with this name, make sure not attempting to updating same object.
			if _realFormat = null or _realFormat &lt;&gt; cm_OutputFormat_SS then	
				app.raiseCMException2(	Already_exists_valid,
										self.name.trimBlanks.display,
										app.getErrorString( XTAB_SummaryDefinition ),
										null,
										self );
			endif;
		endif;
	endif;
	
	foreach element in self.allFields do
		element.validateForCreate;
	endforeach;
	
	foreach element in self.allGroupings do
		element.validateForCreate;
	endforeach;
	
	if self.allFields.isEmpty then			// must have selected at least one CELL entry.
		app.raiseCMException( XSS_OneFieldRequired, null, self );
	endif;
	
	
epilog
	
end;</source>
        <Parameter name="_realFormat" type="CM_OutputFormat_SS"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="b21d45d6-13d7-4423-80f0-e20bd3cb3307">
        <source>validateForDelete();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars
	task	: CM_AutoTask;
begin

	if self.allSnapshotDatas.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.name, app.getErrorString(Snapshot_data), null, null);
	endif;	
	
	if self.allBGPSummarySnapshots.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.name, app.getErrorString(BGP_Processing), null, null);
	endif;

	// 26605 can't delete if used in BGP Task or invoice transaction map
	if self.allServiceBrokers.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.name, app.getErrorString(Transactio_snapshot_summary), null, null);
	endif;
	
	foreach task in app.myRoot.allAutoTasks discreteLock do
		if task.isKindOf(CM_AutoTaskSummarySnapShot) then
			if task.CM_AutoTaskSummarySnapShot.mySSDefinition = self then
				app.raiseCMException2(ObjectStillHasEntries, self.name, app.getErrorString(Backgro_process_auto_task ), null, null);
				break;
			endif;
		endif;
	endforeach;
	
	inheritMethod(); //10 Nov 2020	NDL	TFS 50279

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="d0c89639-379f-4d92-af00-963ff969a034">
        <source>validateForUpdate( _realFormat : CM_OutputFormat_SS );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation

*/

vars

begin
	self.validateForCreate( _realFormat );
	
	if not self.allSnapshotDatas.isEmpty then
		app.raiseCMException( No_update_snapshot_data_exists, null, self );
	endif;
epilog

end;</source>
        <Parameter name="_realFormat" type="CM_OutputFormat_SS"/>
    </JadeMethod>
</Class>
