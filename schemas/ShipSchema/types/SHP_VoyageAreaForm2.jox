    <JadeMethod name="setComboBackColor" id="9aa1c736-0b9c-4fee-8de4-9699f6aba086">
        <source>setComboBackColor(combobox: ComboBox input) protected;
// ---------------------------------------------------------------------------
// Created:     02 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx		: Integer;

begin

	idx := combobox.listIndex;
	if idx &gt; 0 then
		combobox.backColor := combobox.itemBackColor[idx];
		combobox.foreColor := combobox.itemForeColor[idx];
	else
		combobox.backColor := White;
	endif;

end;</source>
