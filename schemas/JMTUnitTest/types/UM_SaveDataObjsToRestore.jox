<Class name="UM_SaveDataObjsToRestore" id="623451cc-63d8-4c0f-ab53-bc20026a100c">
    <superclass name="UM_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This is used to save off objects (e.g. State Data) that needs
be reset after a test is run.

Terminal / System State Data will be saved off at the start of the run
e.g. when the GUI is opened or when the Overnight tests are run</text>
    <DbClassMap file="unitTest"/>
    <ImplicitInverseRef name="allChangedStateDataDict" id="01a2755e-2a0c-4eb2-b454-aca9f3907113">
