    <JadeMethod name="setComboValues" id="4a66c88f-7220-4a3c-87e2-eb34f80fc813">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/
vars
	grp		: CM_ISOTypeGroup;
	coll	: CM_ISOTypeGroupByCodeDict;
begin
	_combo.clear();
	
	coll := app.myRoot.allISOTypeGroups;
	
	foreach grp in coll do
		_combo.itemObject[_combo.addItem(grp.code &amp; Tab &amp; grp.description)] := grp;
	endforeach;

	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := coll[_queryOperator.CM_QStringLookup.selectionValue];
		
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := coll[_queryOperator.CM_QStringLookupNotEqual.selectionValue];	
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="460a3ec5-321e-4f08-8fd8-a9f0a9b4954b">
        <source>translateToDisplayValue(_value: Any): String;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/
vars

begin
	if _value.isKindOf(CM_ISOTypeGroup) then
		if _value &lt;&gt; null then
			return _value.CM_ISOTypeGroup.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="9e25f87d-245a-4cd1-ad29-5863b83cb177">
        <source>translateToSearchValue(_value: Any): Any;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/
vars
			
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_ISOTypeGroup) then
			return _value.CM_ISOTypeGroup;
		endif;
	endif;
	
	return app.myRoot.allISOTypeGroups[_value.String];
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
