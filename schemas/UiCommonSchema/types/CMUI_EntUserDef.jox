    <JadeMethod name="cmbView_click" id="d8127b17-ec1d-4f25-8976-6c75019adcd7">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbView_click(combobox: ComboBox input) updating;
//-----------------------------------------------------------------------
//	Created:	29 May 2007 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	view	: EntTableView;
	row		: EntTableRow;
begin

	view := self.cmbView.listObject.EntTableView;
	
	if view &lt;&gt; null then
		self.tblDefs.clearAllData();
		foreach row in view.allEntTableRows do
			self.tblDefs.addItemObject(row, row.name);		
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
