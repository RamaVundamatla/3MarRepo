        <source>mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		19 July 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	fileObj		: File;
	
begin
	app.mousePointer	:=	Busy;
	
/*
	create fileObj transient;
	
	if not fileObj.cnEcSetSaveName(	"",
									true,
									true,
									"All Files (*.*)|*.*|CSV Files (*.csv)|*.csv") then
		return;
	endif;
	
	tblData.cnEcExportToCSV(fileObj, true);
*/
	
	inheritMethod(table, button, shift, x, y);
epilog
	delete fileObj;
	app.mousePointer	:=	Idle;
end;</source>
