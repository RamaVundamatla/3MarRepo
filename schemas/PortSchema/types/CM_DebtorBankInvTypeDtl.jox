    <JadeMethod name="auditId" id="04244b4a-e364-4ab5-a04b-a41639fd72fb">
        <source>auditId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

vars

begin
