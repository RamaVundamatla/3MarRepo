    <JadeMethod name="getNumPlannedForLocation" id="a4337edb-6239-42d8-b5bb-791200848bc5">
        <source>getNumPlannedForLocation(_countQuantity, _countWeight : Boolean; _moveTi : CM_TrackedItem) : Decimal;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/04/2021	navdap1		Initial creation TFS 49858 PRP Default Capacity per Location for GC Area
//
vars
	fmp : CM_FutureMove;
	ti : CM_TrackedItem;
	count : Decimal [16,4];

begin
	if not _countQuantity and not _countWeight then
		return null;
	endif;
	
	foreach fmp in self.allPlannedFutureMoves discreteLock do
		ti := fmp.CM_FutureMovePlanned.myTrackedItem;
		if ti = null or ti = _moveTi then
			continue;
		endif;
		if fmp.myWorkListEntry = null then
			continue;
		endif;
		
		if _countQuantity then
			count := count + fmp.myWorkListEntry.quantity;
		elseif _countWeight then
			count := count + fmp.myWorkListEntry.weight;
		endif;
	endforeach;
	
	return count;
epilog

end;</source>
        <Parameter name="_countQuantity" type="Boolean"/>
        <Parameter name="_countWeight" type="Boolean"/>
        <Parameter name="_moveTi" type="CM_TrackedItem"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getNumPlannedForTAProductMax" id="1494aa6a-d4f6-48e8-9fec-3c807ab2ab4b">
        <source>getNumPlannedForTAProductMax(_productMax : CM_TerminalAreaProductMinMax input;
								_moveTI : CM_TrackedItem ) : Decimal;
/*

Date		Who		Reason
01/04/2014	cnwer1	Initial creation CCMS 1366
13/05/2021	navdap1	TFS 49858 PRP Default Capacity per Location for GC Areas
*/

vars
	fmp : CM_FutureMove;
	ti : CM_TrackedItem;
	count, volume : Decimal[14,4];
	countQuantity,
	countVolume,
	countWeight : Boolean;
begin

	if _productMax = null then
		
		return null;
	endif;
	
	countQuantity:=_productMax.isCheckMaxQuantity;
	countVolume:=_productMax.isCheckMaxVolume;
	countWeight:=_productMax.isCheckMaxWeight;
	if not countQuantity and not countVolume and not countWeight then
		return null;
	endif;
	
	
	foreach fmp in self.allPlannedFutureMoves discreteLock do
		ti:=fmp.CM_FutureMovePlanned.myTrackedItem;
		if ti = null then
			continue;
		endif;
		//epr par 37074 17/11/15
		if ti = _moveTI then
			continue;
		endif;
		
		if fmp.myWorkListEntry = null then
			continue;
		endif;
		if ti.myCargoType &lt;&gt; _productMax.myCargoType then
			continue;
		endif;
		if ti.myProduct &lt;&gt; _productMax.myProduct then
			continue;
		endif;
		if countQuantity then
			//count:=count + fmp.myWorkListEntry.quantity;				// TFS 49858
			count:=count + fmp.myWorkListEntry.quantity.max(1);			// TFS 49858
		endif;
		if countWeight then
			count:=count + fmp.myWorkListEntry.weight;
		endif;
		if countVolume then
			volume:=fmp.myWorkListEntry.weight / ti.getDensity;
			count:=count + volume;
		endif;
		
	endforeach;
	
	
	return count;
epilog

end;</source>
        <Parameter name="_productMax" type="CM_TerminalAreaProductMinMax" usage="input"/>
        <Parameter name="_moveTI" type="CM_TrackedItem"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getNumQueuedForLocation" id="3ef2c9eb-0be6-48a2-81ac-8de22e0040e0">
        <source>getNumQueuedForLocation(_countQuantity, _countWeight : Boolean; _moveTi : CM_TrackedItem) : Decimal;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/04/2021	navdap1		Initial creation TFS 49858 PRP Default Capacity per Location for GC Area
//
vars
	fmp : CM_FutureMove;
	ti : CM_TrackedItem;
	count : Decimal [16,4];

begin
	if not _countQuantity and not _countWeight then
		return null;
	endif;
	
	foreach fmp in self.allQueuedFutureMoves discreteLock do
		ti := fmp.CM_FutureMoveQueued.myTrackedItem;
		if ti = null or ti = _moveTi then
			continue;
		endif;
		if fmp.myWorkListEntry = null then
			continue;
		endif;
		
		if _countQuantity then
			count := count + fmp.myWorkListEntry.quantity;
		elseif _countWeight then
			count := count + fmp.myWorkListEntry.weight;
		endif;
	endforeach;
	
	return count;
epilog

end;</source>
        <Parameter name="_countQuantity" type="Boolean"/>
        <Parameter name="_countWeight" type="Boolean"/>
        <Parameter name="_moveTi" type="CM_TrackedItem"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getNumQueuedForTAProductMax" id="63250929-db56-4853-848d-65d2a00ffb92">
        <source>getNumQueuedForTAProductMax(_productMax : CM_TerminalAreaProductMinMax input;
							_moveTI : CM_TrackedItem) : Decimal;
/*

Date		Who		Reason
01/04/2014	cnwer1	Initial creation CCMS 1366
13/05/2021	navdap1	TFS 49858 PRP Default Capacity per Location for GC Areas
*/

vars
	fmp : CM_FutureMove;
	ti : CM_TrackedItem;
	count, volume : Decimal[14,4];
	countQuantity,
	countVolume,
	countWeight : Boolean;
begin

	if _productMax = null then
		
		return null;
	endif;
	
	countQuantity:=_productMax.isCheckMaxQuantity;
	countVolume:=_productMax.isCheckMaxVolume;
	countWeight:=_productMax.isCheckMaxWeight;
	if not countQuantity and not countVolume and not countWeight then
		return null;
	endif;
	
	
	foreach fmp in self.allQueuedFutureMoves discreteLock do
		ti:=fmp.CM_FutureMoveQueued.myTrackedItem;
		if ti = null then
			continue;
		endif;
		//epr par 37074 17/11/15
		if ti = _moveTI then
			continue;
		endif;
		if fmp.myWorkListEntry = null then
			continue;
		endif;
		if ti.myCargoType &lt;&gt; _productMax.myCargoType then
			continue;
		endif;
		if ti.myProduct &lt;&gt; _productMax.myProduct then
			continue;
		endif;
		if countQuantity then
			//count:=count + fmp.myWorkListEntry.quantity;				// TFS 49858
			count:=count + fmp.myWorkListEntry.quantity.max(1);			// TFS 49858
		endif;
		if countWeight then
			count:=count + fmp.myWorkListEntry.weight;
		endif;
		if countVolume then
			volume:=fmp.myWorkListEntry.weight / ti.getDensity;
			count:=count + volume;
		endif;
		
	endforeach;
	
	
	return count;
epilog

end;</source>
        <Parameter name="_productMax" type="CM_TerminalAreaProductMinMax" usage="input"/>
        <Parameter name="_moveTI" type="CM_TrackedItem"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getNumTIs" id="93190908-464d-452d-a7ac-e7382c013989">
        <source>getNumTIs(_mode : Integer): Integer;
// rs oct 2005 par 10886
// return the actual number of TIs in a location 
// ie only return backend of forties. 
// used when adding up the number of tis in an area
vars

begin
	if _mode = REAL_MODE then
		return self.numTIs;
	elseif _mode = PLANNING_MODE then
		return self.numPlannedTIs;
	elseif _mode = QUEUE_MODE then
		return self.numQueuedTIs;
	endif;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
