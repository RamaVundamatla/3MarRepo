    <JadeMethod name="loadAttributePlan" id="3e009d1d-0310-4058-ad90-69ad80924bf5">
        <source>loadAttributePlan(_proxyObject: CM_Object io):Boolean protected;

vars
	realObject, proxyObject: CM_AttributePlan;
	error: CM_Error;
	theUser: CM_User;
	result: Boolean;
begin
	result := false;
	proxyObject := _proxyObject.CM_AttributePlan;
	app.myTrxCA.trxCreateAttributePlan(proxyObject, realObject, app.myPassport);
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" OK";
		result := true;
	else
		foreach error in app.myPassport.allWarnings do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" WARNING: "&amp;error.text;
		endforeach;
		foreach error in app.myPassport.allErrors do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" ERROR: "&amp;error.text;
		endforeach;	
	endif;
epilog
	return result;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyObject" type="CM_Object" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadBerth" id="80342ccf-4131-4b30-83ae-c0b3e14d5633">
        <source>loadBerth(_berthProxy:HMS_Berth io) :Boolean protected;

vars
	realObject, proxyObject: HMS_Berth;
	error: CM_Error;
	countError,countOK: Integer;
begin
	if _berthProxy.myWharf = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_berthProxy.code&amp;" ERROR: "&amp;"No Wharf.",0);
		return false;
	endif;
	realObject := _berthProxy.getHarbourReal().allBerths[_berthProxy.code];
	if realObject = null then
		app.myTrxCA.trxCreateBerth(_berthProxy, realObject, app.myPassport);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_berthProxy.code&amp;" ERROR: "&amp;"Berth already exists.",0);
		return false;
	endif;
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_berthProxy.code&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_berthProxy.code&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_berthProxy" type="HMS_Berth" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadBerthPreferenceVesselData" id="e830f635-c559-439f-918e-27d134edf63c">
        <source>loadBerthPreferenceVesselData(_berthPrefProxy:HMS_BerthPreferenceVesselData io) :Boolean protected;

vars
	realObject: HMS_Object;
	proxyObject: HMS_BerthPreferenceVesselData;
	error: CM_Error;
	countError,countOK: Integer;
begin
	if _berthPrefProxy.myVesselDataHarbour = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_berthPrefProxy.berthName&amp;" ERROR: "&amp;"No vessel.",0);
		return false;
	endif;
	realObject := _berthPrefProxy.myVesselDataHarbour.allBerthPrefByName[_berthPrefProxy.berthName];
	if realObject = null then
		app.myTrxCA.trxCreateHMSObject(_berthPrefProxy, realObject, app.myPassport);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_berthPrefProxy.berthName&amp;" ERROR: "&amp;"Berth Preference already exists.",0);
		return false;
	endif;
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_berthPrefProxy.berthName&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_berthPrefProxy.berthName&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_berthPrefProxy" type="HMS_BerthPreferenceVesselData" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadBlockStack" id="a8699e1e-c233-435d-a6a1-6de31c0ecc15">
        <source>loadBlockStack(_proxyObject:CM_Object io):Boolean protected;

vars
	 proxyObject: CM_TerminalArea;
	error: CM_Error;
	theUser: CM_User;
	result: Boolean;
	yaDeckingOptions: CM_YADeckingOptionsTA;
	controller : CMIF_TerminalArea;
		realObject : CM_TerminalAreaMaster;
begin
	create controller transient;


	result := false;
	proxyObject := _proxyObject.CM_TerminalArea;
	create yaDeckingOptions transient;
	yaDeckingOptions.setProxy(false, true, proxyObject);
	yaDeckingOptions.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	controller.myPxyTerminalAreaMaster := proxyObject;
	app.myTrxCA.trxCreateTerminalArea(proxyObject, realObject,  app.myPassport);
	

	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
//		write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" OK";
		result := true;
	else
		foreach error in app.myPassport.allWarnings do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" WARNING: "&amp;error.text;
		endforeach;
		foreach error in app.myPassport.allErrors do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" ERROR: "&amp;error.text;
		endforeach;
	endif;
epilog
	delete controller;
	return result;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyObject" type="CM_Object" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
