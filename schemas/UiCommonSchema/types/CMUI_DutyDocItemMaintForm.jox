    <JadeMethod name="createReleaseRequest" id="e5c47e6b-8b89-4f32-a7b1-eb5ff4396774">
        <source>createReleaseRequest(_dutyDoc : CM_DutyDoc; _dutyItem : CM_DutyDocItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2014	cnwma1	Initial creation

*/

vars
	theReturn : Integer;
	pxyBulkRelease,bulkRelease : CM_BulkRelease;
	ti : CM_TrackedItem;					   
	reserveTI : CM_ReserveTI;
	ls: Boolean;
begin

	if _dutyDoc.isImport then
		bulkRelease := self.myTerminal.getBulkReleaseFromCode(self.myDutyDoc.id);		 // cnwma1 31/07/2014 PAR 34408
		if bulkRelease &lt;&gt; null then
			ti:= _dutyItem.getMyTrackedItem;
			if not bulkRelease.allTrackedItemsAssigned.includes(ti) then
				
				app.cmsBeginLoad(ls);
				pxyBulkRelease := app.createUpdateProxy(bulkRelease).CM_BulkRelease;
				app.cmsEndLoad(ls);
				create reserveTI transient;
				reserveTI.setMyHeader(pxyBulkRelease);
				reserveTI.allTrackedItems.add(ti);
				pxyBulkRelease.allTrackedItemsAssigned.add(ti);
				while true do
					app.myTrxUA.trxUpdateBulkRelease(pxyBulkRelease, null, app.myPassport);
					if app.myPassport.trxCompletedOK then
						break;
					else
						theReturn := app.showErrorWarningDialog("Duty Documentation Item", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
						if app.myPassport.noErrors and theReturn = IDOK then
							app.myPassport.warningsAcknowledged	:= true;
							continue;							
						endif;
					endif;
					break;
				endwhile;
			endif;
		endif;
	endif;
		  
epilog
	app.cmsEndLoad(ls);	
	delete pxyBulkRelease; 

end;</source>
        <Parameter name="_dutyDoc" type="CM_DutyDoc"/>
        <Parameter name="_dutyItem" type="CM_DutyDocItem"/>
    </JadeMethod>
    <JadeMethod name="doBtnFindClick" id="65dd2b4b-4941-4ce8-8089-0640f424f992">
        <updating/>
        <source>doBtnFindClick() updating;
/*
	Find a container for a consignee  (32036)
	02/09/2014 PAR#34046 Consignee duplicates
*/

vars

	searchId : String;
	tiSet : CM_TISet;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	selectedObject : Object;
	dutyCar : CM_DutyDocCarItem;
	consignee: CM_ConsigneeConsignor;
	dutyDocType : CM_DutyDocType;
	imex 	: Integer;
	voyage, voyage1: CM_Voyage;
	agent: CM_DutyDocAgent;
begin
	
	create agent transient;
	searchId := self.txtID.text.trimBlanks.toUpper;
	
	if self.myDutyDoc &lt;&gt; null then
		dutyDocType:=self.myDutyDoc.getDutyDocTypeObject;
		if dutyDocType &lt;&gt; null then
			imex:=dutyDocType.imex;
		endif;
		voyage := self.myDutyDoc.getMyVoyage;
	endif;
	consignee := self.cmbConsignee.getCurrentItemObject.CM_ConsigneeConsignor;
	create tiSet transient;
	// Ok need to look at all tis prenoted, onsite and onship 
	if voyage &lt;&gt; null then
		voyage.allOnsiteTIsByCargoTypeId.copy(tiSet);
		voyage.allOnshipTIsByCargoTypeId.copy(tiSet);
		voyage.allNotifiedTIsByCargoTypeId.copy(tiSet);
	else
		self.myTerminal.allOnsiteTIsByIdCargoType.copy(tiSet);
		self.myTerminal.allNotifiedTIsByCargoTypeId.copy(tiSet);
		foreach voyage1 in self.myTerminal.allVoyagesByCode do
			if voyage1.hasDepartedWithGracePeriod(-24) then
				continue;
			endif;
			voyage1.allOnshipTIsByIdCargoType.copy(tiSet);
		endforeach;
	endif;
	
	create tiArray transient;
	foreach ti in tiSet do
		if not ti.id.startsWith(searchId) and not ti.id.reverse.startsWith(searchId.reverse) then
			continue;
		endif;
		// PAR 32390 - do not filter my consignee
	//	if consignee &lt;&gt; null and ti.myConsignee &lt;&gt; consignee then
	//		continue;
	//	endif;
		if imex &lt;&gt; null and ti.getImExStatus &lt;&gt; imex then
			continue;
		endif;
		if agent.isAssignedToDutyDoc(ti, self.myDutyDoc) then
			continue;
		endif;
		if self.myDutyDoc &lt;&gt; null then
			if ti.consignee &lt;&gt; null and  ti.consignee &lt;&gt; self.myDutyDoc.consignee then  //2/09/2014 cnwma1 PAR#34046
				continue;
			endif;
		endif;
		tiArray.add(ti);
	endforeach;

	if tiArray.isEmpty then
		ti := null;
	else
		self.myAssistant.pickerWindowForTrackedItem(tiArray, self.myTerminal, null, null, null,false, selectedObject);
		ti := selectedObject.CM_TrackedItem;
	endif;
	
	if ti = null then
		self.txtID.text := searchId;
	else
		self.populateFromTrackedItem( ti );
	endif;
	
	if ti = null or not ti.isCar then
		self.grpCar.visible := false;
	else
		self.grpCar.visible := true;
		create dutyCar transient;
		self.txtVCCNum.text := dutyCar.getNextVCCNo();
	endif;
	
	self.btnAsCar.visible := self.myDutyDocItem = null and (ti &lt;&gt; null and not ti.isCar);	//07 Aug 2013	NDL	Par 31804

epilog
	delete agent;
	delete tiSet;
	delete tiArray;
	app.mousePointer := Window.MousePointer_Default;
	delete dutyCar;
end;</source>
    </JadeMethod>
    <JadeMethod name="doClickDutyExempt" id="699745ee-4618-4381-9e42-a0d8aca8ec8e">
        <source>doClickDutyExempt();
/*

Purpose:			

