    <JadeMethod name="bolTypeAsEnumToString" id="d44185e5-f2db-4fdb-bfb1-929304ad1434">
        <source>bolTypeAsEnumToString(_bolType : Integer) : String;
/*

Purpose:		Converts BOL Type Enum to String	

Parameters:			_bolType	Integer	BOL Type Enum as Integer

Return Value:		String	Representing the bol type

Date		Who		Reason
02 May 2024	navpw1	Initial creation TFS 63819 (63846)

*/

begin
	if _bolType = BOLType_GeneralBillOfLading then
		return "General Bill Of Lading";
		
	elseif _bolType = BOLType_GeneralDocket then
		return "General Docket";
		
	elseif _bolType = BOLType_Log then
		return "Log Docket";
		
	else
		return null;
		
	endif;
	
end;</source>
