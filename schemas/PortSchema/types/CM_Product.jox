/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/03/2010	cnwdap1	Initial creation PAR #22938
*/
vars

begin
	self.isReefer		:= _isReefer;
	self.isPowered		:= _isPowered;
