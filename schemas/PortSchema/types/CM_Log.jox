    <JadeMethod name="setSEDsFromAverages" id="a6e72810-973b-4600-9459-16496631e65d">
        <updating/>
        <source>setSEDsFromAverages(_sedMax, _sedMin, _sedMean, _vol : Decimal; 
				_tiUpdateCntrl : CMIF_TIUpdateController input;
				_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: cnwrs2    Aug 2009
//PAR20040 - need to split so can update without begin/endUpdate calls
//--------------------------------------------------------------
vars

begin

	exclusiveLock(self);

	if (not self.isTransient) then
		self.beginUpdate(_tiUpdateCntrl, _passport);
	endif;	
	
	self.setSEDsFromAveragesInternal(_sedMax, _sedMin, _sedMean, _vol, _tiUpdateCntrl, _passport);

	if (not self.isTransient) then
		self.endUpdate(_tiUpdateCntrl, _passport);
	endif;		

end;</source>
        <Parameter name="_sedMax" type="Decimal"/>
        <Parameter name="_sedMin" type="Decimal"/>
        <Parameter name="_sedMean" type="Decimal"/>
        <Parameter name="_vol" type="Decimal"/>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setSEDsFromAveragesInternal" id="da4d952e-47a2-4a49-843d-0808be69639a">
        <updating/>
        <source>setSEDsFromAveragesInternal(_sedMax, _sedMin, _sedMean, _vol : Decimal; 
				_tiUpdateCntrl : CMIF_TIUpdateController input;
				_passport : CM_Passport input) protected, updating;
//--------------------------------------------------------------
//Created: 24 May 2002 By: cnwgd1
//Updated: cnwrs2    Aug 2009
//PAR20040 - need to split so can update without begin/endUpdate calls
//--------------------------------------------------------------
vars

begin

	// note that these MUST be set in this order because some
	// have mapping methods which recalculate
	self.sedMin 		:= _sedMin;
	self.sedMax 		:= _sedMax; 
	self.sedMean 		:= _sedMean;
//	self.volume			:= _vol;
	self.setMyVolume(_vol);	//03 Jun 2011	NDL	Par 26504
	
	// no children for logs
//	self.totalVolume	:= self.volume;
	self.setMyCargoVolume(_vol); 	//03 Jun 2011	NDL	Par 26504
	self.isAverageScaled := true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_sedMax" type="Decimal"/>
        <Parameter name="_sedMin" type="Decimal"/>
        <Parameter name="_sedMean" type="Decimal"/>
        <Parameter name="_vol" type="Decimal"/>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setScalerCode" id="2c6e758a-772c-4ed0-ac0d-01414650f103">
        <updating/>
        <source>setScalerCode(_scalerCode : String) updating;

// cnwdvb1 02 December 2002 

vars

begin

	self.scalerCode := _scalerCode;

end;</source>
        <Parameter name="_scalerCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="swapWithOnShipLogNoNumber" id="bf47a2fb-575e-424f-b97c-97b39506d49a">
        <updating/>
        <source>swapWithOnShipLogNoNumber(_logNoNumber : CM_LogNoNumber input; _tiUpdCntrl : CMIF_TIUpdateController input;
					_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	moveController 	: CMIF_MoveController;
	cancelSave		: Boolean;
begin
		
	if _logNoNumber = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _logNoNumber. Contact Developer.');
		return;
	endif;

	exclusiveLock(self);
	exclusiveLock(_logNoNumber);
	
	//Set residual logs BOL	and voyage to be that of the No Number Log
	//epr TFS 5282 6/10/17 - logging
	if (_logNoNumber.myReleaseBOL &lt;&gt; null) then
		app.writeLog(method.qualifiedName &amp; " setting release BOL for log" &amp; self.id,  LogINFO);	
	endif;
	self.setMyReleaseBOL(_logNoNumber.myReleaseBOL);
	self.setMyVoyage(_logNoNumber.myVoyage, _passport);
	
	//create self stock movement and corresponding transaction before self is erased.
	_logNoNumber.beginUpdate(_tiUpdCntrl, _passport);
	_logNoNumber.createStockMovementForSwap(self, _tiUpdCntrl, _passport);
	
	//Move the self to the voyage in place of _logNoNumber
	//Don't bother moving _logNoNumber off the voyage as _logNoNumber will just be erased below 
	create moveController transient;
	
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;
	moveController.setMyToPrimaryLocation(self.myReleaseBOL.myPlannedLocation);
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyTrackedItem(self);
		
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	//DONE IN THE MOVE
	//Housekeeping
	//self.releasedTransportMode := TI_TRANSMODE_SHIP;
	/*self.setReleasedTransportMode(TI_TRANSMODE_SHIP);
	if self.myPinNo &lt;&gt; null then
		self.myPinNo.removeItem(self);
	endif;*/
			
	_logNoNumber.erase(NORMAL_ERASE);
	
end;</source>
        <Parameter name="_logNoNumber" type="CM_LogNoNumber" usage="input"/>
        <Parameter name="_tiUpdCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
