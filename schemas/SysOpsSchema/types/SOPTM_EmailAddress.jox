    <JadeMethod name="doSave" id="19456504-1424-49b6-a836-55f4dc6ded1b">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	errObj					: CM_Error;
	ignoreWarnings,rtnValue	: Boolean;
	proxyEmailAddress		: CM_EmailAddress2;
	lEmailAddress, lTitle	: String; 
	theForm					: SOP_TableMaintForm;
begin

  	theForm := self.myForm; 
	lEmailAddress := theForm.tblInput1.getValueByName(ETRow_EmailAddress).String.trimWhiteSpace;
	lTitle := theForm.tblInput1.getValueByName(ETRow_Title).String;
 	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_EmailAddress2 transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyEmailAddress := theForm.myProxyObject.CM_EmailAddress2;
	theForm.tblInput1.setObjectFromTable(proxyEmailAddress, null, false);
	proxyEmailAddress.setProxyForEmailAddress(lTitle, lEmailAddress, theForm.cmbAutoReply.getCurrentItemData);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateEmailAddress2(proxyEmailAddress, theForm.myCurrentObject.CM_EmailAddress2,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateEmailAddress2(proxyEmailAddress, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
