    <JadeMethod name="useNumRowsShown" id="061421b4-f429-4dc9-87d4-80a3abd9aced">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>useNumRowsShown(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     19 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		if (not self.useTblData) then
			// never display numrows found if not using tblData
			_value := false;
		endif;
		self.staMain.visible := _value;
		if _value then
			self.bottomMargin := self.staMain.height;
			self.showNumRowsShown();
		else
			self.bottomMargin := 0;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="useTblData" id="eadc1a2c-77c3-497a-82f5-2f3c37cce6d7">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>useTblData(set: Boolean; _value: Boolean io) mapping, updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		if self.useTblData &lt;&gt; _value then
			self.useTblData := _value;
			
			if _value then
				//lblFiltered.visible	:= true;
				tblData.visible 	:= true;
				self.mnuColumnOrganiser.visible := true;			
				if self.useNumRowsShown then
					self.bottomMargin		:= self.staMain.height;
					self.staMain.visible	:= true;
				else
					self.staMain.visible	:= false;
				endif;
				self.btnShowSearchTV.enabled := self.allowSearch;
				self.btnSelectAllTV.enabled	:= self.allowSelectAll;
				if self.widthUsingTblData &lt;&gt; 0 then
					self.width := self.widthUsingTblData;
				endif;
			else
				self.btnShowSearchTV.enabled := false;
				self.staMain.visible	:= false;
				self.bottomMargin		:= 0;
				self.tblData.visible 	:= false;
				self.mnuColumnOrganiser.visible := false;							
				self.allowSearch		:= false;
				sptMain.hideLeftControl(self.isFirstActivateComplete);
				if self.widthNotUsingTblData &lt;&gt; 0 then
					self.width := self.widthNotUsingTblData;
				endif;
				if (not self.useNumRowsShown) then
					self.staMain.visible := false;				
				endif;
			endif;
		endif;
	else
		_value := self.useTblData;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
