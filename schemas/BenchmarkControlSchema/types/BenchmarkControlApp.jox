    <JadeMethod name="bmkStdRunInit" id="32512c68-15d1-49f5-ade3-983585602a7a">
        <updating/>
        <source>bmkStdRunInit() updating;

begin
	on Exception do app.jtdGlobalExceptionHandler(exception) global;
	app.logMessage(null);
	
	beginTransaction;
	process.userInfo := computerName.toLower;
	commitTransaction;
	
	create myBmkStdRun transient;
	myBmkStdRun.setup;
	process.causeEvent(StartStdRun, true, null);
end;
</source>
    </JadeMethod>
    <JadeMethod name="checkForDumpFiles" id="55022a63-3724-45bc-9697-bba3587b7a3e">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>checkForDumpFiles(mask:String; days:Integer; sa:StringArray256 input) updating, serverExecution;

vars
	i,j:Integer;
	s,t,lines:String;
	ff:FileFolder; fn:FileNode; f:File;
begin
	on FileException do app.logFileException(exception);
	
	create ff transient;
	ff.fileName:=app.getProfileStringAppServer(app.getIniFileNameAppServer, "JadeLog", "LogDirectory", null);
	ff.mask:=mask;
	
	foreach fn in ff.files where fn.lastModifiedTime.date &gt;= app.actualTimeAppServer.date - days do
		f:=fn.File;
		s := null;
		while not f.endOfFile do
			s:=f.readLine;
			if s[1:14] = "Application : " then
				sa.add(fn.name &amp; ":  " &amp; s);
			endif;
		endwhile;
	endforeach;
epilog
	delete ff;
end;
</source>
        <Parameter name="mask" type="String"/>
        <Parameter name="days" type="Integer"/>
        <Parameter name="sa" type="StringArray256" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkJblXml" id="75bd6667-887e-4486-a974-e324f02c4a8c">
        <executionLocation>server</executionLocation>
        <source>checkJblXml(fileName:String):Boolean serverExecution;

vars
	i,j,retCode,result:Integer;
	cmdLine:String;
begin
	cmdLine:='jblcheckxmlconforms.exe "' &amp; fileName &amp; '"';
	result:=node.createExternalProcess(null, cmdLine, null, null, true, true, retCode);
	app.logMessage(method.qualifiedName &amp; "result=" &amp; result.String &amp; ", retCode=" &amp; retCode.String &amp; " for " &amp; cmdLine);
	return result = 4 and retCode = 0;
end;
</source>
        <Parameter name="fileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="creatorFinalize" id="af1e4421-5dc6-47fc-8d77-4345504bef5b">
        <updating/>
        <source>creatorFinalize() updating;

begin
	if name = "CreatorCreator" and process.getUserCode = 'cnwjbl2' then
		myCreator.stopMyChildren;
	endif;

	endNotificationForSubscriber(myCreator);
	delete myCreator;
epilog
	app.logMessage(process.userCode &amp; "@" &amp; process.userInfo &amp; " Finishing");
end;</source>
    </JadeMethod>
    <JadeMethod name="creatorInit" id="bdba9008-4dd5-432f-91d9-c2a259950d24">
        <updating/>
        <source>creatorInit() updating;

vars
	s:String;
	proc:Process;
begin
	on Exception do app.jtdGlobalExceptionHandler(exception) global;
	if app.name = "Creator" then
		terminate;  // obsolete app
	endif;
	/*if name = 'CreatorCreator' then  // don't start if another is already running
		foreach proc in Process.instances 
		where proc.persistentApp.name = 'CreatorCreator'
		and proc.userInfo = process.userInfo  // on same host
		and proc.getUserCode = process.getUserCode  // same usercode
		and proc &lt;&gt; process do  // it's not me
			s:="another CreatorCreator is running on "&amp;computerName.toLower&amp;"... I will exit";
			logMessage(s);
			global.causeEvent(Bmk_Result, true, s);
			process.sleep(1000);  // present splash screen
			terminate;
		endforeach;
	endif;/**/
	create myCreator;
	myCreator.setup;
	myCreator.setSession(name[name.length-1:2].String.Integer);
epilog
	app.logMessage(process.userCode &amp; "@" &amp; process.userInfo &amp; " Starting");
end;</source>
    </JadeMethod>
    <JadeMethod name="disallowMultipleCopies" id="8de6ff62-6ccf-4ccd-b057-16f4f2de8304">
        <updating/>
        <source>disallowMultipleCopies() updating;

vars
	proc:Process;
	error:Boolean;
begin
	on Exception do jtdObjNotFoundExceptionHandler(exception, error);
	foreach proc in Process.instances where proc &lt;&gt; process and proc.persistentApp = process.persistentApp do
		app.logMessage(app.name &amp; " is already running, so this copy will terminate");
		terminate;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCmd" id="a92ec6b7-2417-45b6-9d68-25a306f3cfd4">
        <updating/>
        <source>doCmd(cmd:String; thinClient,modal:Boolean):Integer updating;

vars
	result,cmdLog,retCodeString:String;
	i,j,retCode:Integer;
begin
	cmdLog := ' &gt;&gt; c:\thinbin\logs\doCmd_' &amp; app.actualTimeAppServer.date.format("yyyyMMdd") &amp; '.log';
	
	// echo the cmd to doCmd.log, with a timestamp
	node.createExternalProcess(null, 'cmd /c c:\cardinal\bin\datetime' &amp; cmdLog, null, null, thinClient, true, retCode);
	node.createExternalProcess(null, 'cmd /c echo ' &amp; cmd &amp; cmdLog, null, null, thinClient, true, retCode);
	
	// now execute the cmd
	if modal then
		node.createExternalProcess(null, 'cmd /c ' &amp; cmd &amp; cmdLog, null, null, thinClient, true, retCode);
	else
		node.createExternalProcess(null, 'cmd /c ' &amp; cmd, null, null, thinClient, false, retCode);  // don't log if not modal, as will overwrite other logging
	endif;
	
	// log the result to msg.log
	if modal then
		retCodeString := " retCode=" &amp; retCode.String;
	else
		retCodeString := " (not modal)";
	endif;
	result := cmd &amp; retCodeString &amp; " " &amp; process.userCode &amp; "@" &amp; process.userInfo;
	app.logMessage(method.name &amp; " " &amp; result);
	
	// timestamp the finish of the cmd to doCmd.log
	node.createExternalProcess(null, 'cmd /c c:\cardinal\bin\datetime' &amp; cmdLog, null, null, thinClient, true, j);
	
	return retCode;
end;</source>
        <Parameter name="cmd" type="String"/>
        <Parameter name="thinClient" type="Boolean"/>
        <Parameter name="modal" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCmdWithTimeout" id="3a5e5415-b66c-4a39-b123-e4a09233d11c">
        <updating/>
        <source>doCmdWithTimeout(cmd:String; timeoutMilliseconds:Integer):Integer updating;

vars
	result:String;
	retCode,remain:Integer;
	dcw:DoCmdWorker;
	proc:Process;
begin
	beginTransientTransaction;
	create dcw sharedTransient;
	dcw.cmdLine:=cmd;
	commitTransientTransaction;
	app.logMessage("starting app for &lt;"&amp;cmd&amp;"&gt;");
	proc:=app.startApplicationWithParameter(currentSchema.name, "DoCmdWorker", dcw);
	
	remain:=timeoutMilliseconds;
	while not dcw.finished do
		app.doWindowEvents(remain.min(1000));
		remain:=remain - 1000;
		if remain &lt;= 0 then
			app.logMessage("cmd app "&amp;proc.String&amp;" timed out after "&amp;timeoutMilliseconds.String&amp;" milliseconds &lt;"&amp;cmd&amp;"&gt;");
			return -1;
		endif;
	endwhile;
	return dcw.retCode;
epilog
	beginTransientTransaction;
	delete dcw;
	commitTransientTransaction;
	app.logMessage("finished app for &lt;"&amp;cmd&amp;"&gt;");
end;</source>
        <Parameter name="cmd" type="String"/>
        <Parameter name="timeoutMilliseconds" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCmdWorkerInit" id="a4ad4a88-4600-484e-9ca1-9551f9587c59">
        <updating/>
        <source>doCmdWorkerInit(dcw:DoCmdWorker input) updating;

vars
	cmd,cmdLog,result:String;
	cepRetCode,retCode,retCode2:Integer;
begin
	on Exception do app.jtdGlobalExceptionHandler(exception) global;
	cmd:=dcw.cmdLine;
	cmdLog:=" &gt;&gt; "&amp;app.getProfileString(app.getIniFileNameAppServer, "JadeLog", "LogDirectory", "c:\temp")&amp;"\cmd_"&amp;app.actualTime.date.format("yyyyMMdd")&amp;".log";
	node.createExternalProcess(null,'cmd /c c:\cardinal\bin\datetime'&amp;cmdLog,null,null,true,true,retCode);
	node.createExternalProcess(null,'cmd /c echo '&amp;cmd&amp;cmdLog,null,null,true,true,retCode);
	cepRetCode:=node.createExternalProcess(null,'cmd /c '&amp;cmd&amp;cmdLog,null,null,true,true,retCode);
	result:="&lt;"&amp;cmd&amp;"&gt; createExternalProcess returned "&amp;cepRetCode.String&amp;", the process returned "&amp;retCode.String;
	node.createExternalProcess(null,'cmd /c c:\cardinal\bin\datetime'&amp;cmdLog,null,null,true,true,retCode2);
	app.logMessage(result);
	if (retCode &lt; 0 or retCode &gt; 1) and dcw.cmdLine.contains("jblsvncache") then
		app.raiseNormalException(1234567, method.qualifiedName, "jblsvncache failed", true);
	endif;
epilog
	if app.isValidObject(dcw) then  // dcw will be invalid if we timed out
		beginTransientTransaction;
		dcw.retCode:=retCode;
		dcw.result:=result;
		dcw.finished:=true;
		commitTransientTransaction;
	endif;
	terminate;
end;
</source>
        <Parameter name="dcw" type="DoCmdWorker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCommandCircThinbins" id="34b86349-bd7f-4ceb-8aab-7ee78066221f">
        <executionLocation>server</executionLocation>
        <source>doCommandCircThinbins() serverExecution;

vars
	m:Machine;
begin
	app.logMessage(method.qualifiedName &amp; " circulating creator thinbins to all the machines");
	foreach m in Machine.instances where m.hostName &lt;&gt; "cnwchcs118" do // and m.hostName = "cnwchcs120" do
		app.logMessage(method.qualifiedName &amp; " circulating creator thinbins to " &amp; m.hostName);
		app.doCmd("xcopy c:\thinbin\creator \\"&amp;m.hostName&amp;"\c$\thinbin\creator /f /e /y", true, true);
		app.doCmd("xcopy c:\thinbin\jblpcre \\"&amp;m.hostName&amp;"\c$\thinbin\jblpcre /f /e /y", true, true);
		app.doCmd("dir \\"&amp;m.hostName&amp;"\c$\thinbin\creator\jade.exe", true, true);
		//break;
	endforeach;
	app.logMessage(method.qualifiedName &amp; " done");
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCommandFini" id="90638c08-7f0e-4821-ba07-fcbcd2c5e1a4">
        <source>doCommandFini();

begin
	// do nothing for now
end;</source>
    </JadeMethod>
    <JadeMethod name="doCommandInit" id="c4084ee8-410c-4d9f-9246-e473ded2fbdd">
        <updating/>
        <source>doCommandInit() updating;

vars
	cmd,s,t,path,methud,me:String;
	driveLetter,envid,runid,controlPort,product,rapHost:String;
	runName,archive,developerEmail,numClients,totalRuns:String;
	i,session,retCode,result,appServers:Integer;
	ccf:CreatorControlForm;
	bc:BmkControlSession;
	cre:Creator;
begin
	on Exception do app.jtdGlobalExceptionHandler(exception) global;
	me := app.computerName.toLower &amp; " ";
	cmd:=getUserCmdLine;
	logMessage(me &amp; method.qualifiedName&amp;" &lt;"&amp;cmd&amp;"&gt;" );
	if cmd &lt;&gt; null then  // cmdLine parameters override ini file settings
		cmd:=cmd&amp;";;;;;;;;;";  // avoid UE for badly formed command
		i:=1;   session:=cmd.scanUntil(";",i).Integer;
		i:=i+1; methud:=cmd.scanUntil(";",i);
		if methud.length = 0 then
			i:=1;   session:=cmd.scanUntil(":",i).Integer;
			i:=i+1; methud:=cmd.scanUntil(":",i);
		endif;
	
		if methud = "setParamsShort" then
			i:=i+1; driveLetter	:=	cmd.scanUntil(";",i);
			i:=i+1; envid			:=	cmd.scanUntil(";",i);
			i:=i+1; runid			:=	cmd.scanUntil(";",i);
			i:=i+1; controlPort	:= cmd.scanUntil(";",i);
			i:=i+1; product		:= cmd.scanUntil(";",i);
			i:=i+1; rapHost		:= cmd.scanUntil(";",i);
			i:=i+1; appServers	:= cmd.scanUntil(";",i).Integer;
			bc:=global.allBmkControls[session];
			bc.setParamsShort(driveLetter,envid,runid,controlPort,product,rapHost,appServers);
	
		elseif methud = "InitSession" then
			i:=i+1; product			:=	cmd.scanUntil(";",i);
			i:=i+1; runName			:=	cmd.scanUntil(";",i);
			i:=i+1; envid				:=	cmd.scanUntil(";",i);
			i:=i+1; runid				:=	cmd.scanUntil(";",i);
			i:=i+1; archive				:=	cmd.scanUntil(";",i);
			i:=i+1; developerEmail	:=	cmd.scanUntil(";",i);
			i:=i+1; numClients		:= cmd.scanUntil(";",i);
			i:=i+1; totalRuns			:= cmd.scanUntil(";",i);
			session := app.computerName[8:end].Integer;
			bc:=global.allBmkControls[session];
			bc.initSession(product,runName,envid,runid,archive,developerEmail,numClients,totalRuns);
			
		elseif methud = "saveLogFiles" then
			create cre;
			logMessage(me &amp; method.qualifiedName&amp;" presaveLogFiles");
			cre.saveLogFiles(session);
			logMessage(me &amp; method.qualifiedName&amp;" postsaveLogFiles");
			
		elseif methud = "circCreatorThinbins" then
			doCommandCircThinbins;
		
		elseif methud = "syncCardinalBin" then
			doCommandSyncCardinalBin(me);
		
		else
			create ccf;
			ccf.myBmkControl:=global.allBmkControls[session];
			ccf.sendMsg(methud);
		endif;
	endif;

	doWindowEvents(1000);  // display splash screen long enough to be seen
	
	terminate;
epilog
	delete ccf;
	delete cre;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCommandSyncCardinalBin" id="f5beb9bf-4354-49c0-9e44-2aae6c618a83">
        <updating/>
        <source>doCommandSyncCardinalBin(me:String) updating;

vars
	b:Binary;
	f,g,remoteStartSentinel:File; ff:FileFolder; fn:FileNode;
	users,filesToSync: StringArray;
	perlCacheDirs:StringArray256;
	s,t,user,perlCacheDir,exe,cmd,path,oldQueues,newQueues,jblworkerConf:String;
	retCode,result,files,folders:Integer;
begin
	app.logMessage(me &amp; " starting");

	// remove all perl runtime environments
	create users transient; create perlCacheDirs transient;
	users.add("cnwjbl1");
	users.add("cnwjbl3");
	users.add("cnwjbl6");
	
	foreach user in users do
		perlCacheDirs.add("C:\Users\"&amp; user &amp;"\AppData\Local\Temp\par-"&amp; user);
		perlCacheDirs.add("C:\Users\"&amp; user &amp;"\AppData\Local\Temp\1\par-"&amp; user);
		perlCacheDirs.add("C:\Users\"&amp; user &amp;"\AppData\Local\Temp\2\par-"&amp; user);		
		perlCacheDirs.add("C:\Users\"&amp; user &amp;"\AppData\Local\Temp\3\par-"&amp; user);		
	endforeach;
	
	create ff transient;
	foreach perlCacheDir in perlCacheDirs do
		ff.fileName:= perlCacheDir;
		housekeepingRemoveDir(ff.fileName, files, folders, -1, true);
	endforeach;
	
	// replace any exe's that are the not the right version
	ff.fileName:= "\\cnwchcm24\cnwjbl$\Tools\circ\production";
	create filesToSync transient;
	foreach fn in ff.files do
		filesToSync.add(fn.name);
	endforeach;
	app.logMessage(me &amp; " filesToSync=" &amp; filesToSync.display.replace(CrLf, ""));
	
	create f; create g;
	f.usePresentationFileSystem := false; // 118
	f.kind := File.Kind_Binary;
	f.mode := File.Mode_Input;
	g.usePresentationFileSystem := true; // local machine
	g.kind := File.Kind_Binary;
	g.mode := File.Mode_Output;
	path:= "C:\cardinal\bin\";
	
	foreach exe in filesToSync do
		f.fileName := path &amp; exe;
		g.fileName := f.fileName;
		if not f.isAvailable then
			app.logMessage(me &amp; " can't find " &amp; f.fileName &amp; " on " &amp; app.computerNameAppServer.toLower);
		endif;
		if not g.isAvailable or g.lastModifiedTime &lt;&gt; f.lastModifiedTime then
			b := f.readBinary(f.fileLength);
			if g.isAvailable then
				app.logMessage(me &amp; " replacing executable " &amp; g.fileName &amp; " " &amp; g.lastModifiedTime.String &amp; " with " &amp; f.lastModifiedTime.String);
			else
				app.logMessage(me &amp; " new executable " &amp; g.fileName &amp; " dated " &amp; f.lastModifiedTime.String);
			endif;
			g.writeBinary(b);
			g.lastModifiedTime := f.lastModifiedTime;
			g.close;
			f.close;
		endif;
	endforeach;
	
	// update queues to process
	f.fileName := app.miscPath &amp; "\QueueLists\" &amp; app.computerName.toLower &amp; ".conf";
	f.kind := File.Kind_Unknown_Text;
	g.fileName := "c:\thinbin\tools\jblworker.conf";
	g.kind := File.Kind_Unknown_Text;
	g.mode := File.Mode_Input;
	
	newQueues := f.readString(f.fileLength).getXMLValue("queuestoprocess");
	f.close;
	jblworkerConf := g.readString(g.fileLength);
	oldQueues := jblworkerConf.getXMLValue("queuestoprocess");
	g.close;
	if oldQueues &lt;&gt; newQueues then
		app.logMessage(me &amp; " queues changed from " &amp; oldQueues &amp; " to " &amp; newQueues);
		g.mode := File.Mode_Output;
		g.writeString(jblworkerConf.replace(oldQueues, newQueues));
		g.close;
	else
		app.logMessage(me &amp; " queues unchanged");
	endif;
	
	// edit jblworker.conf file, back it up first
	app.logMessage(me &amp; " backing up jblworker.conf file");
	g.fileName := "c:\thinbin\tools\jblworker.conf";
	g.mode := File.Mode_Input;
	g.kind := File.Kind_Unknown_Text;
	f.fileName := app.miscPath &amp; "\jblworker_backup\jblworker_" &amp; app.computerName.toLower &amp; app.actualTime.date.format("_yyyyMMdd") &amp; app.actualTime.time.format("_HHmmss") &amp; ".conf";
	f.mode := File.Mode_Output;
	f.kind := File.Kind_Unknown_Text;
	f.writeString(g.readString(g.fileLength));  // make backup first
	f.close;
	g.close;
	
	/*f.mode := File.Mode_Input;
	//g.fileName := "c:\thinbin\tools\jblworker_new.conf";  // TEMP - delete this line when doing it for real
	g.mode := File.Mode_Output;
	while not f.endOfFile do
		s := f.readLine;
		if s.contains("&lt;globalsqlcmd&gt;") then  // add the new gflags line
			if app.computerName.toLower = "cnwchcs55" or app.computerName.toLower = "cnwchcs116" then
				g.writeLine("  &lt;gflags&gt;on&lt;/gflags&gt;");
			else
				g.writeLine("  &lt;gflags&gt;off&lt;/gflags&gt;");
			endif;
		endif;
		if s.contains("&lt;antspp&gt;") or s.contains("&lt;consolidatedlog&gt;") or s.contains("&lt;convertdbcopies&gt;") or s.contains("&lt;emailoveride&gt;") 
		or s.contains("&lt;gacutil&gt;") or s.contains("&lt;installutil&gt;") or s.contains("&lt;logdir&gt;") or s.contains("&lt;masterproductdirectory&gt;") or s.contains("&lt;gflags&gt;")
		or s.contains("&lt;maxfilecopythreads&gt;") or s.contains("&lt;nextjobsourceorig&gt;") or s.contains("&lt;sqldatabaselocation&gt;") or s.contains("&lt;tempbuilddrive&gt;") then
			continue;
		endif;
		g.writeLine(s);
	endwhile;
	f.close;
	g.close;/**/
	
	// make a new ToDoList.txt from jblworker.csv
	/*g.fileName := "c:\thinbin\tools\ToDoList.txt";
	if not g.isAvailable then  // don't do this if it has been done before
		app.logMessage(me &amp; " making a new ToDoList.txt file from jblworker.csv");
		g.fileName := "c:\thinbin\tools\jblworker.csv";
		g.mode := File.Mode_Input;
		g.kind := File.Kind_Unknown_Text;
		s := g.readString(g.fileLength);
		g.close;
		g.fileName := "c:\thinbin\tools\ToDoList.txt";
		g.mode := File.Mode_Output;
		g.writeString(s);
		g.close;
	endif;/**/
	
	// put remotestart sentinel file in place so remotestartjblworker doesn't start up
	create remoteStartSentinel transient;
	remoteStartSentinel.usePresentationFileSystem := false;  // s118
	remoteStartSentinel.fileName := "c:\thinbin\tools\remotestart_" &amp; app.computerName &amp; ".jbl";
	remoteStartSentinel.mode := File.Mode_Output;
	remoteStartSentinel.writeString("hi");
	remoteStartSentinel.close;
	app.logMessage(me &amp; " created sentinel file " &amp; remoteStartSentinel.fileName &amp; " remoteStartSentinel.lastModifiedTime=" &amp; remoteStartSentinel.lastModifiedTime.String);
	
	// purge sentinel files
	ff.fileName := "c:\thinbin\tools";
	ff.mask := "*.jbl";
	foreach fn in ff.files where not fn.name.toLower.contains("stopnow") do
		app.logMessage(me &amp; " purging sentinel file " &amp; fn.fileName);
		fn.purge;
	endforeach;
	
	// restart jblworker
	cmd := "c:\cardinal\bin\jblworker.exe";
	result := node.createExternalProcess(null, cmd, null, null, true, false, retCode);
	app.logMessage(me &amp; " executing " &amp; cmd &amp; " result=" &amp; result.String &amp; " " &amp; process.userCode &amp; "@" &amp; app.computerName.toLower);
	
	// wait for jblworker to create jblworker.jbl, then remove the remotestart sentinel
	g.fileName := "c:\thinbin\tools\jblworker.jbl";
	while true do
		if g.isAvailable then
			app.logMessage(me &amp; " purging sentinel file " &amp; remoteStartSentinel.fileName);
			remoteStartSentinel.purge;
			break;
		else
			app.doWindowEvents(1000);
			if app.actualTime.time.second mod 5 = 0 then
				app.logMessage(me &amp; " waiting for jblworker to create jblworker.jbl");
			endif;
		endif;
	endwhile;
	
	app.logMessage(me &amp; " finished");
epilog
	delete filesToSync; delete ff; delete f; delete g; delete remoteStartSentinel; delete users; delete perlCacheDirs;
end;</source>
        <Parameter name="me" type="String"/>
    </JadeMethod>
    <JadeMethod name="executeOnServer" id="4cae2d61-00f3-4f65-a9d3-58962036f5a2">
        <executionLocation>server</executionLocation>
        <source>executeOnServer(obj:Object; meth:String):Any serverExecution;

begin
	return obj.sendMsg(meth);
end;</source>
        <Parameter name="obj" type="Object"/>
        <Parameter name="meth" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="fatClientInit" id="6a3516dc-dbb2-4aaf-8389-11e059c97dee">
        <updating/>
        <source>fatClientInit() updating;

vars
	s,t,cmd,path,envName,iniFile,schemaname,appname:String;
	i,j,retCode,result,queues:Integer;
begin
	on Exception do app.jtdGlobalExceptionHandler(exception) global;
	logMessage(method.qualifiedName&amp;" starting");
	path:=getJadeInstallDirAppServer;

	cmd:=path&amp;"\jade.exe path="&amp;app.dbPath&amp;" ini="&amp;getIniFileNameAppServer&amp;" server=multiuser schema=" &amp; currentSchema.name &amp; " app=" &amp; app.name[4:end];
	result:=node.createExternalProcess(path, cmd, null, null, false, false, retCode);
	logMessage("cmd=&lt;"&amp;cmd&amp;"&gt;, result="&amp;result.String&amp;", retCode="&amp;retCode.String);
	logMessage("finished");
	doWindowEvents(2000);
	terminate;
end;
</source>
    </JadeMethod>
