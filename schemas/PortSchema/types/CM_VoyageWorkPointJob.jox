    <JadeMethod name="pxyCreateUpdateProxy" id="2d0969d3-54f1-48ed-b424-b541a2908e2a">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Nov 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details

*/

vars
	proxy			: SelfType;
	completedOK		: Boolean;
begin
	

	proxy := inheritMethod();
	
	completedOK := true;			
	return proxy;
	
epilog
	if not completedOK then			
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreateVoyage" id="11d9c1a1-d5c9-4cc7-a3dc-7b18b32338f2">
        <updating/>
        <source>setForCreateVoyage(_theJobParams: CMIF_VoyageJobParams input; _allWLEs: CM_WLEArray; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Nov 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
*/

vars

begin
	inheritMethod(_theJobParams, _allWLEs, _passport);
	self.actualStartTs 			:= _theJobParams.myProxyJob.actualStartTs;
	self.actualEndTs			:= _theJobParams.myProxyJob.actualEndTs;
	self.transferType			:= _theJobParams.myProxyJob.transferType;
	self.remarks				:= _theJobParams.myProxyJob.remarks;
	self.myJobSheetForWorkPoint	:= _theJobParams.myProxyJob.myJobSheetForWorkPoint;
	self.externalReference1		:= _theJobParams.myProxyJob.externalReference1;
	self.externalReference2		:= _theJobParams.myProxyJob.externalReference2;
	if _theJobParams.myProxyJob.retrospectiveDT.isValid then						//11.03.2024 navhl20 #60097
		self.retrospectiveDT		:= _theJobParams.myProxyJob.retrospectiveDT;
	endif;
epilog

end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_allWLEs" type="CM_WLEArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForJobUpdate" id="decc3bee-522d-4874-800f-aafac0225d11">
        <updating/>
        <source>setForJobUpdate(_pxyJob	: CM_VoyageWorkPointJob; _hold : CM_GeneralCargoController)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Oct 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details
21 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
21 May 2024 navma1	Bug 64191: EUP - Lock and Freeze issue
*/

vars
	req	: CM_HoldRequest;
begin
	self.actualStartTs 			:= _pxyJob.actualStartTs;
	self.actualEndTs			:= _pxyJob.actualEndTs;
	self.transferType			:= _pxyJob.transferType;
	self.remarks				:= _pxyJob.remarks;
	self.myJobSheetForWorkPoint	:= _pxyJob.myJobSheetForWorkPoint;
	self.externalReference1		:= _pxyJob.externalReference1;
	self.externalReference2		:= _pxyJob.externalReference2;
	req							:= self.allRequests.first.CM_HoldRequest;
	
	if req &lt;&gt; null then
		if _pxyJob.myWODtl.isKindOf(CM_WodReceive) then									//21.12.2023 navhl20 #58400[61617]
			req.setMyHoldDischarge(_hold);
		else
			req.setMyHoldLoad(_hold);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_pxyJob" type="CM_VoyageWorkPointJob"/>
        <Parameter name="_hold" type="CM_GeneralCargoController"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="dc47a4c4-88e5-4a9e-94af-0972639530db">
        <updating/>
        <source>setForUpdate(proxyJob : CM_VoyageWorkPointJob;_theTerminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Oct 2023 navhl20 ChangeRequest 60090: EUP | Ship Operations in DD - [54176.020] -[Receive] Allocate Jobs to Gangs and Gangs to Holds
29 Nov 2023 navhl20 ChangeRequest 61510: EUP | Ship Operations in DD - [54176.020] - [Release] Allocate Jobs to Gangs and Gangs to Holds
*/

vars

begin
	inheritMethod(proxyJob, _theTerminal);
	self.myWorkOrderReceiveJob 	:= proxyJob.myWorkOrderReceiveJob;
	self.myWorkOrderReleaseJob	:= proxyJob.myWorkOrderReleaseJob;			//29.11.2023 navhl20 #61510
	self.requiredByDT			:= proxyJob.requiredByDT;
	self.myJobSheetForWorkOrder	:= proxyJob.myJobSheetForWorkOrder;
epilog
	
end;</source>
        <Parameter name="proxyJob" type="CM_VoyageWorkPointJob"/>
        <Parameter name="_theTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setMyWorkorderJob" id="3c9f254d-aab1-43d3-9daa-7f16e8bba421">
        <updating/>
        <source>setMyWorkorderJob(_job : CM_Job)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Oct 2023 navhl20 ChangeRequest 60090: EUP | Ship Operations in DD - [54176.020] -[Receive] Allocate Jobs to Gangs and Gangs to Holds
29 Nov 2023 navhl20 ChangeRequest 61510: EUP | Ship Operations in DD - [54176.020] - [Release] Allocate Jobs to Gangs and Gangs to Holds
*/

vars

begin
	if _job.isKindOf(CM_WOReceiveCargoJob) then							//29.11.2023 navhl20 #61510
		self.myWorkOrderReceiveJob := _job.CM_WOReceiveCargoJob;
	else
		self.myWorkOrderReleaseJob := _job.CM_WOReleaseCargoJob;
	endif;
epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="setPlannedLocation" id="f06e54e7-1489-4e2b-b53a-fced439c3643">
        <updating/>
        <source>setPlannedLocation(_planLoc : CM_LocationsController)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
04 Jan 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
17 May 2024 navhl20 Bug 64191: EUP - Lock and Freeze issue
25 Sep 2024 navhl20	Bug 66258: MTN - Work Order Job status is not changing to Job Part Complete when completing the part of the job in the Cargo Grouping mode for Release Ship jobs
*/

vars
	ica : CM_InterchangeArea;
begin
	if _planLoc &lt;&gt; null then			//17.05.2024 navhl20 #64191
		//self.plannedLocations 	:= _planLoc.getFullId();
		
		//26/08/2024	navkc1 CR 63588 Task 63589
		ica := _planLoc.getInterChangeArea();
		if ica &lt;&gt; null then
			self.plannedLocation := ica.id;
		elseif _planLoc.terminalAreaId &lt;&gt; null then				//25.09.2024 navhl20 #66258
			self.plannedLocation := _planLoc.terminalAreaId;
		else													//25.09.2024 navhl20 #66258
			self.plannedLocation := _planLoc.getFullId();
		endif;
		
	else
		//self.plannedLocations 	:= null;
		
		//26/08/2024	navkc1 CR 63588 Task 63589
		self.plannedLocation := null;
		self.plannedLocations := null;
		self.plannedTerminalAreas := null;
	endif;
epilog

end;</source>
        <Parameter name="_planLoc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="aa6af055-c5b2-4523-b52e-7718b135c0b8">
