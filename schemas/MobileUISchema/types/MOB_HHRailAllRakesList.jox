    <JadeMethod name="clickBtnTrain" id="aef94327-82af-48ba-9294-26528dc98f68">
        <updating/>
        <source>clickBtnTrain() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

begin
	app.mousePointer :=	Busy;
	self.myMobileGenericAgent.setMyCurrentWagon(null);
	self.gotoForm( MOB_HHRailPlaceTrainForm, false );

epilog
	app.mousePointer :=	Idle;
end;</source>
