    <JadeMethod name="packItem" id="62029641-c28a-40fb-8cee-cd9f1edd8b7f">
        <updating/>
        <source>packItem(_isForRepack : Boolean; _ti : CM_TrackedItem; _contRange : CM_ContRange; _row : Integer) : Boolean protected, updating;
// ---------------------------------------------------------------------------
// Created:     20 February 2003		cnwth2	
//
// Purpose:     _ti is the child cargo to be packed
//			 	self.myTI is the parent cargo
// ----------   ----------  --------------------------------------------------
vars
	cargoType		: CM_CargoType;
	ti				: CM_TrackedItem;
	
begin
	if _ti = null then
		return false;
	endif;
	
	if _ti = self.myTI then
		app.msgBox(app.getString(Cannot_pack_cargo_inside_itsel), 
				app.getString(Physically_impossible), MsgBox_Exclamation_Mark_Icon);
		return false;	
	
	endif;
	
	//+cnwml2 PAR26134
	if _ti.myBookingRef &lt;&gt; null then							//child ti has a booking
		if _ti.myBookingRef.isStockBookingRef then				//child ti is stock booking
			if self.myTI.myBookingRef &lt;&gt; null and not self.myTI.myBookingRef.isStockBookingRef then
				if _ti.myBookingRefItem = null or not _ti.myBookingRefItem.allLinkedExportBookings.includes(self.myTI.myBookingRef) then
					app.msgBox(app.getString(CargoNotPartExBook), app.getString(Wrong_booking), MsgBox_Exclamation_Mark_Icon);
					return false;
				endif;
			endif;
		else													//child ti has an export booking
			if self.myTI &lt;&gt; null 											//cnwmc5 - 4 Dec 2015 - PAR 37213
			and self.myTI.myBookingRef &lt;&gt; null 								//cnwmc5 - 4 Dec 2015 - PAR 37213	
			and self.myTI.myBookingRef.packAs = BOOKING_PACKAS_FCL then		//cnwmc5 - 4 Dec 2015 - PAR 37213
				//cnwmc5 - 4 Dec 2015 - PAR 37213 - if the pack to container has an FCL booking, DO NOT update it..
			else
				self.tblContainer.setValueByName(ETRow_BookingReference, _ti.myBookingRef.bookingReference);
				self.cmbBooking.setIndexFromObject(_ti.myBookingRef);
				if _ti.myBookingRefItem &lt;&gt; null then
					self.tblContainer.setValueByName(ETRow_BookingItem, _ti.myBookingRefItem.getShortDisplay);
				else
					self.tblContainer.setValueByName(ETRow_BookingItem, null);
				endif;
				self.loadBookingItems(_ti.myBookingRef, _ti.myBookingRefItem);
				self.cmbBookingItem.setIndexFromObject(_ti.myBookingRefItem);
			endif;															//cnwmc5 - 4 Dec 2015 - PAR 37213
		endif;
	endif;
	
	//+cnwml2 PAR25677 MSL CCMS 1076 code removed
	
	cargoType := app.myRoot.allCargoTypesById[_ti.cargoType];
	
	// CCMS 1533
	if cargoType = null or not cargoType.allowDuplicates then
		if self.allPackedItems.includesKey(_ti.id) then
			foreach ti in self.allPackedItems do
				if ti.cargoType = _ti.cargoType then
					app.msgBox('Item ' &amp; _ti.id &amp; ' has already been packed into container ' &amp; self.myTI.id, 'Item already packed', MsgBox_Exclamation_Mark_Icon);
					return false;
				endif;
			endforeach;
		endif;
	endif;
	
	if (not self.assignContainerDetails(_ti, _contRange)) then
		self.allWarnings.clear(); // warnings will have been aknowledged so clear to get waringing if same thing attempted again. 
		return false;
	endif;			
	
	self.addTblDataRow(null, _ti, self.tblPacked);
	self.btnCancelBase.enabled := true;		// 28474 disable Cancel until change made
	
	if (not _isForRepack) then
		self.tblUnpacked.removeItem(_row/*self.tblUnpacked.row*/);
	endif;
	
	//if (not self.myContainer.allChildren.includes(_ti)) then//PAR 22954
	if (not self.myTI.hasChild(_ti)) then
		self.allPackedItems.add(_ti);	
	endif;
	
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_isForRepack" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_contRange" type="CM_ContRange"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
