    <JadeMethod name="setForCreate" id="03131b7f-043f-4683-8640-89cc58f14c7e">
        <updating/>
        <source>setForCreate(_pxy : CM_UserTerminal; _realUser : CM_User) updating;
// -----------------------------------------------------------------------------
// Created:		25 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.mySecurityRole		:= _pxy.mySecurityRole;
	self.myTerminal 		:= _pxy.myTerminal;
	self.myUser				:= _realUser;
	self.myDefaultCargoType := _pxy.myDefaultCargoType;
	self.myDefaultBOLType 	:= _pxy.myDefaultBOLType;
	self.myDefaultCargoBOLType := _pxy.myDefaultCargoBOLType;
	
	self.resetNavMenuFromJMTDefault(true);
	self.resetReportMenuFromJMTDefault(false);

end;</source>
        <Parameter name="_pxy" type="CM_UserTerminal"/>
        <Parameter name="_realUser" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="95fd1552-74c9-48a3-85fd-2b0d68175fca">
        <updating/>
        <source>setForProxy(_terminal 		: CM_Terminal; 
			_user 			: CM_User; 
			_role 			: CM_SecurityRole;
			_defCargoType 	: CM_CargoType;
			_defBOLType		: CM_BOLType;
			_defCargoBOLType : CM_CargoBOLType) updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.mySecurityRole		:= _role;
	self.myTerminal			:= _terminal;
	self.myUser				:= _user;
	self.myDefaultCargoType := _defCargoType;
	self.myDefaultBOLType 	:= _defBOLType;
	self.myDefaultCargoBOLType := _defCargoBOLType;
	self.myUser.setLocale(_user.myLocale); 
	
	if _user.code.trimRight = SUPERUSER_Str then
		self.mySecurityRole := CM_SecurityRoleTerminalRoot.firstInstance;
	endif;

/*	
	if _roles &lt;&gt; null then
		self.allSecurityRoles.clear;
		_roles.copy(self.allSecurityRoles);
	endif;
*/
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_role" type="CM_SecurityRole"/>
        <Parameter name="_defCargoType" type="CM_CargoType"/>
        <Parameter name="_defBOLType" type="CM_BOLType"/>
        <Parameter name="_defCargoBOLType" type="CM_CargoBOLType"/>
    </JadeMethod>
