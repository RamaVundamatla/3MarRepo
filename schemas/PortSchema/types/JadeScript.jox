    <JadeMethod name="rel792_par28696" id="d941f896-32cf-47a9-817d-76326461e940">
        <source>rel792_par28696();
/*
Date		Who		Reason
17 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
19 dec 2011 cnwrs1	ver 1.1 of CCMS 2122
21 dec 2011 cnwrs1  ver 1.2 of CCMS 2122 
22 dec 2011 cnwrs1  ver 1.3 of CCMS 2122 
29 dec 2011 cnwrs1  ver 1.4 of CCMS 2122 
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	// *** to be completed ***
	ediFileType : CM_EDIFileType;
	tempStr	: String;
	entTblAgent	: EntTableAgent;
	tmpArray : StringArray;
	transAgent : CM_TranslationAgent;
//	tmpArray : StringArray;
	termRole : CM_SecurityRoleTerminalRoot;
	sysRole : CM_SecurityRoleSystemRoot;
	newPerms : IntegerArray;
	menuAgent : CM_MenuAgent;
begin
	app.initialize;
	app.setupEDICAMS();
	tempStr	:= 'Starting ' &amp; method.qualifiedName &amp; Tab &amp; app.actualTimeServer.asStringJMT;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeStatement(tempStr);
	app.writeLog(tempStr, LogINFO);

	// load new permissions
	create newPerms transient;
	newPerms.add(PmAdmEDIPartyView);
	newPerms.add(PmAdmEDIPartyMaint);
	newPerms.add(PmGteMTReleaseViewUnknown);
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	beginTransaction;
	termRole.setPermissionsFromIntArray(newPerms, false);	//true if terminal permission
	sysRole.setPermissionsFromIntArray(newPerms, true);	//true if system permission
	commitTransaction;
	delete newPerms;

	// ### RESET MENUS
	beginTransaction;
	app.myRoot.resetRootSecurityRoles(null);
	commitTransaction;
	create menuAgent transient;
	menuAgent.resetAllMenuDetails();
	
	// load new ent table deifitions
	create entTblAgent transient;
	create tmpArray transient;
	
	entTblAgent.myEntTableDataRoot	:= app.myRoot.myEntTableDataRoot;
	tmpArray.add('ETRow_EdiReleaseAllowPartial');
	tmpArray.add('ETGrp_ConfigGroup');
	tmpArray.add('ETGrp_EDIPartyMaint');
	tmpArray.add('ETGrp_GateReceivals');
	tmpArray.add('ETRow_AllowCargoMultiReleases');
	tmpArray.add('ETRow_Description');
	tmpArray.add('ETRow_EdiReleaseAllowPartial');
	tmpArray.add('ETRow_FilterNeedsReview');
	tmpArray.add('ETRow_Name');
	tmpArray.add('ETRow_NeedsReview');
	tmpArray.add('ETRow_NeedsReviewCB');
	tmpArray.add('ETRow_ReleaseByType');
	tmpArray.add('ETRow_ReleaseByTypeStr');
	tmpArray.add('ETRow_SenderCode');
	tmpArray.add('ETRow_Senders');
	tmpArray.add('ETRow_ViewEDIMessages');
	tmpArray.add('ETDef_EDIConfig');
	tmpArray.add('ETDef_EDIPartyEnquiry');
	tmpArray.add('ETDef_EDITIReleaseRequest');
	tmpArray.add('ETDef_MTReleaseDataTable');
	tmpArray.add('ETDef_MTReleaseFind');
	tmpArray.add('ETDef_MTReleaseThumb');
	tmpArray.add('ETDef_RequestHeaderInfo');
	entTblAgent.trxUpdateFromConstant(tmpArray);
	entTblAgent.trxUpdateFromConstant(tmpArray);
	// load new translatable strings
	create transAgent transient;
	transAgent.trxLoadXLATsFromGlbConstants(null);
	
	create transAgent transient;
	tmpArray.clear();
	tmpArray.add('Dbl_Click_To_View');
	tmpArray.add('EDI_Party');
	tmpArray.add('EDI_Party_Error1');
	tmpArray.add('EDI_Party_Error2');
	tmpArray.add('EDI_Party_Error3');
	tmpArray.add('EDI_Party_Error4');
	tmpArray.add('EDI_Party_Error5');
	tmpArray.add('EDI_Party_Error6');
	tmpArray.add('EDI_Party_Error7');
	tmpArray.add('EDI_Party_Error8');
	tmpArray.add('EDI_Rule_Item');
	tmpArray.add('EDI_Rule_Value');
	tmpArray.add('EDI_Rule_Function');
	tmpArray.add('Release_Requests_Errors');
	tmpArray.add('ReleaseRequestAlreadyHasBookin');
	tmpArray.add('ReleaseRequestAlreadyHasItems');
	tmpArray.add('Xlat_0017234');
	tmpArray.add('Xlat_0017235');
	tmpArray.add('ERR_RR_Pending_Unknown');
	transAgent.trxLoadSpecificErrors(tmpArray);
	
	// reload query definitions
	
	// sundry
	app.myRoot.createQueryDefinitionObjects;
	ediFileType := CM_EDIFileTypeCoparn.firstInstance;
	beginTransaction;
	ediFileType.setPropertyValue(CM_EDIFileTypeCoparn::name.name, "COPARN - Container Announcement Message");
	commitTransaction;
epilog
	delete entTblAgent;
	delete tmpArray;
	delete transAgent;
	delete menuAgent;
	tempStr	:= 'Finished ' &amp; method.qualifiedName &amp; Tab &amp; app.actualTimeServer.asStringJMT;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.writeStatement(tempStr);
	app.writeLog(tempStr, LogINFO);
return;

	write PmAdmEDIPartyView;
	write PmAdmEDIPartyMaint;
	write PmGteMTReleaseViewUnknown;
	
	write ETDef_EDIConfig;
	write ETDef_EDIPartyEnquiry;
	write ETDef_EDITIReleaseRequest;
	write ETDef_MTReleaseDataTable;
	write ETDef_MTReleaseFind;
	write ETDef_MTReleaseThumb;
	write ETDef_RequestHeaderInfo;
	write ETGrp_ConfigGroup;
	write ETGrp_EDIPartyMaint;
	write ETGrp_GateReceivals;
	write ETRow_AllowCargoMultiReleases;
	write ETRow_Description;
	write ETRow_EdiReleaseAllowPartial;
	write ETRow_FilterNeedsReview;
	write ETRow_Name;
	write ETRow_NeedsReview;
	write ETRow_NeedsReviewCB;
	write ETRow_ReleaseByType;
	write ETRow_ReleaseByTypeStr;
	write ETRow_SenderCode;
	write ETRow_Senders;
	write ETRow_ViewEDIMessages;
// transalatable messages	
	write Dbl_Click_To_View;
	write EDI_Party;
	write EDI_Party_Error1;
	write EDI_Party_Error2;
	write EDI_Party_Error3;
	write EDI_Party_Error4;
	write EDI_Party_Error5;
	write EDI_Party_Error6;
	write EDI_Party_Error7;
	write EDI_Party_Error8;
	write EDI_Rule_Function;
	write EDI_Rule_Item;
	write EDI_Rule_Value;
	write Release_Requests_Errors;
	write ReleaseRequestAlreadyHasBookin;
	write ReleaseRequestAlreadyHasItems;
	write Xlat_0017234;
	write Xlat_0017235;
	write ERR_RR_Pending_Unknown;

	write TE_MAX;
	write EDI_PARTY_UPDATE_EVENT;
	write XLATION_TYPE_MAX;
	write XLATION_TYPE_MTGRADE_BYOP;
	
	write EdiReleaseAllowPartial;
	write ETGrp_ConfigGroup;
	write ETRow_EdiReleaseAllowPartial;
	write ETDef_EDIConfig;

end;
</source>
    </JadeMethod>
