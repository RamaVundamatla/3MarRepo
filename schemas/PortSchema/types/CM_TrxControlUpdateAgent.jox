    <JadeMethod name="trxUpdateTIDamageToDo" id="443e5bb6-94b4-4673-98a0-db0b06da812f">
        <updating/>
        <source>trxUpdateTIDamageToDo(	_pxyTI 				: CM_TrackedItem input; 
						_toDoTask			: Integer;
						//_addingToDo			: Boolean;	
						_addCompRemTodo		: Integer; 
						_passport 			: CM_Passport input) updating;

/*

Date		Who		Reason
12 May 2010	cnwas3	par 24175

*/

vars
	realTI : CM_TrackedItem;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	if _pxyTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "TrackedItem", null, null);
	endif;
	
	// trx uses defered updates
	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;
	
	beginTransaction;	
	
	if _passport.noErrors() and _toDoTask &lt;&gt; null then
		realTI := app.myProxyManager.getRealObject(_pxyTI).CM_TrackedItem;	//16 Mar 2016	NDL TFS 1673
		if _addCompRemTodo = 1 then
			// add the to do task
			app.myUtilityUA.utlUpdateTIToDoTaskAdd(realTI, _toDoTask, _passport);
		elseif _addCompRemTodo = 2 then	//16 Mar 2016	NDL TFS 1673
			// complete the to do task
			app.myUtilityUA.utlUpdateTIToDoTaskComplete(realTI, _toDoTask, _passport);
		elseif _addCompRemTodo = 3 then
			// remove the to do task
			app.myUtilityUA.utlUpdateTIToDoTaskRemove(realTI, _toDoTask, _passport);
		endif;
	endif;
	
	_passport.doDeferredUpdates();
	
epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_toDoTask" type="Integer"/>
        <Parameter name="_addCompRemTodo" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIDamagesAndPhotos" id="f78b9c67-560b-46dc-a72d-65d20b24b40d">
        <updating/>
        <source>trxUpdateTIDamagesAndPhotos(_pxyTI 		: CM_TrackedItem input;
							_passport 	: CM_Passport input;
							_cargoPhotos : ObjectArray input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Dec 2024	navsck1	Initial creation for MTN-33610 Create a new webservice to handle multiple damages and images
27 Dec 2024	navnk30	JIRA 63610: Create a new webservice to handle multiple damages and images

*/

vars
	pxyPhoto,
	realPhoto	: CM_Photo;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	_passport.useTIDictDeferUpdate 			:= true;				
	_passport.useTITransactionDeferUpdate   := true;				
	
	//app.myUtilityUA.utlUpdateTIDamagesAndPhotos(_pxyTI, _passport, _cargoPhotos);		//27.12.2024 navnk30 JIRA #33610 START
	app.myUtilityUA.utlUpdateTIDamage(_pxyTI, _passport);
	foreach pxyPhoto in _cargoPhotos as CM_Photo do
		app.myUtilityCA.utlCreateCargoPhoto(pxyPhoto, realPhoto, app.myPassport);
	endforeach;																			//27.12.2024 navnk30 JIRA #33610 END
	
	if _passport.noErrors then										
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_cargoPhotos" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTIDimensionsToDo" id="eb06c848-ca54-41ed-9e09-acfb52e86ec4">
        <updating/>
        <source>trxUpdateTIDimensionsToDo(	_pxyTI 				: CM_TrackedItem input; 
							_toDoTask			: Integer;
							_addCompRemTodo		: Integer;	// 1 = add, 2 = complete, 3 = remove 16 Mar 2016	NDL TFS 1673
							_comment			: String;
							_updateMode 		: Integer;
							_txnControllerDict 	: CMIF_TITxnContrlrByTypeDTDict;
							_passport 			: CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/02/2010	cnwdap1	Initial creation
04/03/2010	cnwdap1	PAR #22741 New parameter _addingToDo, so we know whether to add or remove the to do task
08/03/2010	cnwdap1	PAR #22656 Was attempting to add/remove a to do task when no to do task description had been supplied
*/
vars
	realTI : CM_TrackedItem;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	if _pxyTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "TrackedItem", null, null);
	endif;
	
	// DVB change trx to use defered updates. 05/04/05
	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;
	
	beginTransaction;

	// update the dimensions from the proxy
	app.myUtilityUA.utlUpdateTrackedItem(_pxyTI, _comment, _updateMode, _txnControllerDict, null, null, _passport);//cnwrd1 28.8.09 par 20545
	
	// PAR #22656 only add/remove to do task if we actually have one
	if _passport.noErrors() and _toDoTask &lt;&gt; null then
		if _addCompRemTodo = 1 then
			// add the to do task
			realTI := app.myProxyManager.getRealObject(_pxyTI).CM_TrackedItem;
			app.myUtilityUA.utlUpdateTIToDoTaskAdd(realTI, _toDoTask, _passport);
		elseif _addCompRemTodo = 2 then	//16 Mar 2016	NDL TFS 1673
			// complete the to do task
			realTI := app.myProxyManager.getRealObject(_pxyTI).CM_TrackedItem;
			app.myUtilityUA.utlUpdateTIToDoTaskComplete(realTI, _toDoTask, _passport);
		elseif _addCompRemTodo = 3 then
			// remove the to do task
			realTI := app.myProxyManager.getRealObject(_pxyTI).CM_TrackedItem;
			app.myUtilityUA.utlUpdateTIToDoTaskRemove(realTI, _toDoTask, _passport);
		endif;
	endif;
	
	_passport.doDeferredUpdates();
	

epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_toDoTask" type="Integer"/>
        <Parameter name="_addCompRemTodo" type="Integer"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_updateMode" type="Integer"/>
        <Parameter name="_txnControllerDict" type="CMIF_TITxnContrlrByTypeDTDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
