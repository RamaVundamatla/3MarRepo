    <JadeMethod name="assignTiAndSplitWle" id="e0940485-0b47-4942-baee-5ec4956a6b4f">
        <updating/>
        <source>assignTiAndSplitWle( 	_wle : CM_WorkListEntry input;
						_moveControl : CMIF_MoveController input;
						_passport : CM_Passport input
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2019	jlgndl1	Initial creation	TFS 46875

*/

vars

	ti : CM_TrackedItem;

begin

	ti := _moveControl.myTrackedItem;

	_wle.setMyTrackedItem( ti );
	if _moveControl.quantity &lt;&gt; 0 then	//09 Jan 2019	NDL	TFS 46875 - found in unit test UT_BtreakBulk::tBreakBulkROROGCJobsWorked
		_wle.setQuantity( _moveControl.quantity );
	endif;
	if _moveControl.weight &lt;&gt; 0 then	//09 Jan 2019	NDL	TFS 46875 - found in unit test UT_BtreakBulk::tBreakBulkROROGCJobsWorked
		_wle.setWeight( _moveControl.weight );
	endif;
	
	self.createSplitWle(); //creates a wle for the remainder if required.
	
	self.setBulkReleaseTI( ti );
	
	if _wle.job &lt;&gt; null then 	// when unplanning a ship job the TI is null. The update collection does not like nulls.
		_wle.job.updateTICollections(ti, _wle);	
		
		//epr par 37028 6/1/16
		if _wle.status = WLE_COMPLETED  and not _wle.isCompleteForJob and _wle.myFutureMove = null then
			//we have re-assigned a ti
			_wle.setStatus(WLE_UNACTIONED);
		endif;
			
	endif;

epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cleanupWLEs" id="8be98b7f-3c06-4ad2-addf-42d7471f3aaa">
        <updating/>
        <source>cleanupWLEs() updating;
/*

Purpose:			Only want one unassigned WLE with the total remaining quantity.
					This method merges any unassigned WLEs together

Parameters:			

Return Value:		

Date			Who		Reason
11 July 2019	jlgzm1	Initial creation

*/

vars
	wle		: CM_WorkListEntry;
	qty		: Integer;
begin
	if self.quantity &gt; 1 and
	   self.allWorkListEntries.size &gt;1 then
		foreach wle in self.allWorkListEntries reversed do
			if wle.myTrackedItem = null then
				qty := qty + wle.quantity;
				if self.myJob &lt;&gt; null then
					app.myEventManager.createSingleObjInfoNoteEvt(self.myJob.getMyVoyageObject, self.myJob.getMyTerminal.getTerminalEvent(WLE_Delete_Event), wle);
				endif;
				self.removeWLE(wle.CM_VoyageWLE, null);
			endif;
		endforeach;
		if qty &gt; 0 then
			create wle as CM_VoyageWLE;
			wle.setForCreate(self.myJob, self);
			wle.setQuantity(qty);
			if self.myJob &lt;&gt; null then
				app.myEventManager.createSingleObjInfoNoteEvt(self.myJob.getMyVoyageObject, self.myJob.getMyTerminal.getTerminalEvent(WLE_Update_Event), wle);
			endif;
		endif;
	
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clearAllocation" id="538fba7b-bd0d-404e-bf86-9c15b9c0d283">
        <updating/>
        <source>clearAllocation(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2013 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.allAllocations.clear();
	self.quantity := 1;
	self.myLayout.setRealDrawFillColour(White);
	
	
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createSplitWle" id="293f46b8-83c1-424a-ba3e-c3e9cc4066d1">
        <source>createSplitWle();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2019	jlgndl1	Initial creation	TFS 46875

*/

vars

	cargoType : CM_CargoType;
	qty : Integer;
	wleQuantity : Integer;
	wleWeight : Decimal [14,4];
	wle : CM_VoyageWLE;

begin

	cargoType := self.getAttrCargoType();
	
	if cargoType = null or not cargoType.isAllowDuplicates then
		return;
	endif;
	
	wleQuantity := self.getWLEQuantity;
	wleWeight := self.getWLEWeight;
	
	//09 Jan 2019	NDL	TFS 46875 - found in unit test UT_BtreakBulk::tBreakBulkROROGCJobsWorked
	if wleQuantity = 0 and wleWeight = 0 then
		return;
	endif;
	
	if cargoType.isTrackByWeight or cargoType.isTrackByVolume then
		if self.weightRequested &lt;= wleWeight then
			return;
		endif;
	else
		if self.quantity &lt;= wleQuantity then
			return;
		endif;
	endif;
		
	create wle as CM_VoyageWLE;
	wle.setForCreate(self.myJob, self);
	wle.setQuantity( ( self.quantity - wleQuantity ).Integer );
	wle.setWeight( ( self.weight - wleWeight ).Integer );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="b9d4d4f2-e76f-4980-a1fc-9a0dc53f62c3">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     13 December 2012 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PAR 30905 - there is a 1 to 1 to 1 with a GC Req to it's single LC and the LCs single Defn. 
// 						So if erasing the req we should erase the LC and the Defn.
// ---------------------------------------------------------------------------

vars
	theGCLC : CM_ROROGCController;
	isLoadRequest : Boolean;
begin

	theGCLC := self.myROROController.CM_ROROGCController;
	isLoadRequest := self.isLoad;
	
	inheritMethod(_eraseLevel);
	
	if theGCLC &lt;&gt; null and isLoadRequest then  //only for load not discharge here, cnwrd1 par 31002 24.1.13
	//if theGCLC &lt;&gt; null then  //only for load not discharge here, cnwrd1 par 31002 24.1.13
	
		if not theGCLC.hasTIs() then // PAR 32732 do not erase the location if there is loaded cargo, just erase the CC
			theGCLC.erase(_eraseLevel); // NOTE. The defn is a child of the LC so will be auto deleted.		
		endif;
	endif;
	

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
