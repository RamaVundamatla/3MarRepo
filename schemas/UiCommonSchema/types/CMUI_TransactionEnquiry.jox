    <JadeMethod name="populateTransactionTable" id="390149f6-4ac0-4240-bb25-4fa4e8d80e3a">
        <updating/>
        <source>populateTransactionTable() updating, protected;
// Jan 2012 CCMS 1262 transaction enquiry, populate after search or table organise etc
vars
	invalidObj	: Boolean;
	ed,
	idx		: Integer;
	fixedRows	: Integer;
	partsInJob,
	partsDone	: Integer;
	enqRow	: String;
	obj		: Object;
	table	: CM_DataTable;
	trn		: CM_Transaction;
begin
	table := self.tblTransactions;
	table.rows := table.fixedRows;
	table.clearAllSelected();
	self.tblCharges.rows := self.tblCharges.fixedRows;
	fixedRows := table.fixedRows;
	partsInJob := self.allTransactions.size;

	self.modalDialogReturnValue := null;
	self.modalDialogShow(null, app.getErrorString(Cancel), null, null, app.getErrorString(CMUI_Displaying_Data), null);
	
	on Exception do app.handleDeletedObject(exception, trn, invalidObj);

	if partsInJob &gt; 2000 and (not self.frmModalDialog.visible) then
		self.frmModalDialog.visible := true;
		self.pbProgressBar.partsInJob := partsInJob;
	endif;

	foreach obj in self.allTransactions do
		trn := obj.CM_Transaction;
		invalidObj := false;
		ed := trn.edition;
		if invalidObj then
			continue;
		endif;
		
		if (partsDone mod 2000) = 0 then
			self.modalDialogUpdateInfo(app.getErrorString2(Displaying_items, partsDone.String, partsInJob.String));
			self.pbProgressBar.partsDone := partsDone;
			self.btnModalOpt2.doWindowEvents(0);
			self.frmModalDialog.refreshNow();
			if self.modalDialogReturnValue = self.ModalDialogReturn_Option2 then
				self.searchCancelled := true;
				break;
			endif;
		endif;
	
		enqRow := trn.getAttributeStringForDefArray(table.allTblDataEntRows);
		idx := table.addItem(enqRow);
		partsDone := partsDone + 1;
		table.accessRow(idx).itemObject := trn;
		if (idx mod 2 = 0) then
			table.accessRow(idx).backColor := self.colorRow1;
		else
			table.accessRow(idx).backColor := self.colorRow2;
		endif;
		
		// 'table limit exceeded' message has already been shown in the query, just stop here, don't get the second message from the table as well
		if partsDone + fixedRows &gt;= JadeTableRowLimit then
			break;
		endif;
	endforeach;
epilog
	self.frmModalDialog.visible := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTransactionTypes" id="4011ce01-e77e-4029-bf0f-ba178fd30af1">
        <updating/>
        <source>populateTransactionTypes(_mode : Integer) updating, protected;
// Feb 2012 CCMS 1262 Transaction Enquiry, setup cargo/event/HMS transaction types
// Note: transaction types were originally filtered to match the types used in the transaction map, but from Mar 2012
//  	all appropriate types are shown to generalise the possible queries
vars
	eventType	: CM_EventType;
	trxType	: CM_TransactionType;
	desc : String;
begin
	self.cmbSearchTranTyp.clear();
	if _mode = self.Mode_Cargo_Transaction_Enquiry then
		self.cmbSearchTranTyp.addItem("");
		foreach trxType in app.myRoot.allTransactionTypes do
			if trxType.trxGroup = TRANS_TYPE_GROUP_TI then
				self.cmbSearchTranTyp.itemObject[self.cmbSearchTranTyp.addItem(trxType.description)] := trxType;
			endif;
		endforeach;

	elseif _mode = self.Mode_Event_Transaction_Enquiry then
		 // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1self.cmbSearchTranTyp.addItem("");
		self.cmbSearchTranTyp.sorted := true; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		foreach eventType in app.myRoot.allEventTypesByType discreteLock do
			if eventType.isLocationActivity then	//14 Apr 2021	NDL	TFS 50906
				continue;
			endif;
			self.cmbSearchTranTyp.itemObject[self.cmbSearchTranTyp.addItem(eventType.name)] := eventType;
		endforeach;
		self.cmbSearchTranTyp.addItemAt("",1); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1

	elseif _mode = self.Mode_HMS_Transaction_Enquiry then
		trxType := app.myRoot.allTransactionTypes[Trans_Type_ResourceCharged];
		self.cmbSearchTranTyp.itemObject[self.cmbSearchTranTyp.addItem(trxType.description)] := trxType;
		
	// ### TFS 39237
	elseif _mode = self.Mode_WO_Transaction_Enquiry then
		 // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1self.cmbSearchTranTyp.addItem("");
		self.cmbSearchTranTyp.sorted := true; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1

		foreach trxType in app.myRoot.allTransactionTypes where trxType.trxGroup = TRANS_TYPE_GROUP_WO do
			self.cmbSearchTranTyp.addItem(trxType.description);
			self.cmbSearchTranTyp.itemObject[self.cmbSearchTranTyp.newIndex] := trxType;
			self.cmbSearchTranTyp.itemData[self.cmbSearchTranTyp.newIndex] := trxType.trxType;
		endforeach;
		self.cmbSearchTranTyp.addItemAt("",1); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	
	elseif _mode = self.Mode_BOL_Transaction_Enquiry then	//04 Nov 2019	NDL	TFS 47100
		self.cmbSearchTranTyp.addItem("");
		foreach trxType in app.myRoot.allTransactionTypes do
			if trxType.trxGroup = TRANS_TYPE_GROUP_BOL then
				self.cmbSearchTranTyp.itemObject[self.cmbSearchTranTyp.addItem(trxType.description)] := trxType;
			endif;
		endforeach;

	endif;
	self.cmbSearchTranTyp.listIndex := 1;
end;
</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateVoyageCombo" id="61beaf6f-d4fa-4d32-8fd8-50bd77373801">
        <source>populateVoyageCombo() protected;
// populate the search voyage combo to match the selector query voyage combos
vars
	idx		: Integer;
	combo	: ComboBox;
	voy		: CM_Voyage;
begin
	combo := self.cmbSearchVoyage;
	combo.sorted := false;
	
	combo.addItem("");
	foreach voy in self.myTerminal.allVoyagesByCode do
		idx := combo.addItem(voy.code &amp; '   ' &amp; voy.description);
		combo.itemObject[idx] := voy;
	endforeach;
		
	combo.addItem(app.getErrorString(ArchivedSeperator));

	foreach voy in self.myTerminal.allVoyagesArchived do
		idx := combo.addItem(voy.code &amp; '   ' &amp; voy.description);
		combo.itemObject[idx] := voy;
	endforeach;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="recolourTransactionTable" id="6f9a99a8-1421-4d8d-84e2-3b144f917b56">
        <source>recolourTransactionTable() protected;
// after column sort etc
vars
	row		: Integer;
	table	: CM_DataTable;
begin
	table := self.tblTransactions;
	foreach row in table.fixedRows to table.rows do
		if (row mod 2 = 0) then
			tblTransactions.accessRow(row).backColor := self.colorRow1;
		else
			tblTransactions.accessRow(row).backColor := self.colorRow2;
		endif;
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resize" id="7f877c45-bdf9-461b-9bdd-dc132101d1d1">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// CCMS CCMS 1262 transaction enquiry only
//20/09/2019 	JLGNS1	Bug 46339 JMT - Event transaction does not resync
constants
	MinWidth = 500;
	MinHeight = 400;
vars
	extraHeight	: Real;
begin
	inheritMethod();
	
	if self.mode = self.Mode_CargoItem_Enquiry 
	or self.mode = self.Mode_BOLItem_Enquiry 
	or self.mode = self.Mode_ContractAccumulation then // ### JIRA 33348 22NOV2024 NAVAB1
		return;
	endif;

	if self.height &lt; MinHeight then
		self.height := MinHeight;
	endif;
	if self.width &lt; MinWidth then
		self.width := MinWidth;
	endif;

	self.doRepositionTables;	//Bug 46339
	
end;
</source>
    </JadeMethod>
