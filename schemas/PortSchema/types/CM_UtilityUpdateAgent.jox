    <JadeMethod name="utlUpdateEventStreamDef" id="03d2cf6b-cf71-496e-9f45-6a46ef6fb2ba">
        <updating/>
        <source>utlUpdateEventStreamDef(_proxyEventStreamDef	: CM_EventStreamDefinition input;
						_pxyESEventTypes		: CM_EventStreamEventTypeDict input;
						_passport 				: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
	realEventStreamDef 	: CM_EventStreamDefinition;
	expectedEdition  	: Integer;
	pxyEventType		: CM_EventStreamEventType;
	realEventType		: CM_EventStreamEventType;
	toBeRemoved			: CM_EventStreamEventTypeDict;
	
begin
	self.initialiseActivity();

	_proxyEventStreamDef.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyEventStreamDef.pxyGetRealObjectAndEdition(realEventStreamDef, expectedEdition);
	
	
	if realEventStreamDef = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_EventStreamDefinition.name, null, null);
		return;
	endif;
	
	app.myValUA.valEventStreamDefinition(_proxyEventStreamDef);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realEventStreamDef);

	if _passport.noErrors and realEventStreamDef.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Event Stream Definition', null, null);
		return;
	endif;

	if _passport.noErrors then
		realEventStreamDef.setForUpdate(_proxyEventStreamDef);
		
		create toBeRemoved transient;
		realEventStreamDef.allEventStreamEventTypes.copy(toBeRemoved);
		
		foreach pxyEventType in _pxyESEventTypes do
			if not realEventStreamDef.allEventStreamEventTypes.includesKey(pxyEventType.category, pxyEventType.name) then
				create realEventType persistent;
				realEventType.setForCreate(pxyEventType, realEventStreamDef);
			else
				toBeRemoved.removeKey(pxyEventType.category, pxyEventType.name);
			endif;
		endforeach;
		
		toBeRemoved.purge();
	endif;
	
epilog
	if toBeRemoved &lt;&gt; null then
		delete toBeRemoved;
	endif;
end;</source>
        <Parameter name="_proxyEventStreamDef" type="CM_EventStreamDefinition" usage="input"/>
        <Parameter name="_pxyESEventTypes" type="CM_EventStreamEventTypeDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEventTransaction" id="c8911c46-8ece-4ffa-b3dc-c7ae03f40750">
        <source>utlUpdateEventTransaction(	_pxyEventTransaction : CM_EventTransaction; 
							_passport 		: CM_Passport input);
/*

Date				Who		Reason
10 December 2014	cnwer1	Initial creation PAR
08 February 2022	jlizm1	TFS 52364 PIBT Audit Details

*/

vars
	realEventTransaction : CM_EventTransaction;
	expectedEdition  	: Integer;
	audit 				: CM_AuditObject;
	oldValue, newValue	: String;
	
begin
	self.initialiseActivity();

	_pxyEventTransaction.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyEventTransaction.pxyGetRealObjectAndEdition(realEventTransaction, expectedEdition);
	
	if realEventTransaction = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_EventType.name, null, null);
		return;
	endif;

	app.myValUA.valCM_Object(_pxyEventTransaction,_passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realEventTransaction);

	if _passport.noErrors and realEventTransaction.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Event Transaction', null, null);
		return;
	endif;
	
	//29 Jan 2021	NDL	TFS 50152
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realEventTransaction, true);
	endif;

	if _passport.noErrors then
		realEventTransaction.setForUpdate(_pxyEventTransaction);
		
	endif;
	
	//29 Jan 2021	NDL	TFS 50152
	if _passport.noErrors then
		audit := self.myUpdateAuditAgent.audUpdateGeneric(realEventTransaction, false);
		
		// TFS 52364
		// Truck events require the terminal to be included on the audit, but if this hasn't changed it won't show
		// so manually add the terminal to both sides of the audit
		if realEventTransaction.isKindOf(CMEVT_TruckEvent) and audit &lt;&gt; null then
			if realEventTransaction.getMyTerminal() &lt;&gt; null and 
			not audit.getOldNewValueForTag(app.getErrorString(Terminal), oldValue, newValue) then
				audit.addToBothText(app.getErrorString(Terminal), realEventTransaction.getMyTerminal().code);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_pxyEventTransaction" type="CM_EventTransaction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEventType" id="37815049-2af7-45ff-b0f6-91fa26800993">
        <source>utlUpdateEventType(_pxyEventType 	: CM_EventType; 
					_passport 		: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave		: Boolean;
	realEventType	: CM_EventType;
