    <JadeMethod name="wsCreateUpdateDeletePreNote" id="fee0d45c-b748-4026-be20-d852d580a9ef">
        <source>wsCreateUpdateDeletePreNote(_id: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2013	cnwndl1	Initial creation	Par 31506
17 Mar 2014 cnwmc5	CCMS SFW 1368 - removing the JMTUpdateService
*/

vars
	ref : String;
	updateRequest : WS_PreNoteUpdateRequest;
	//updateService : JMTUpdateService;
	webService : JMTUserInterfaceService;
	updateResponse : WS_TrackedItemUpdateResponse;
	now : TimeStamp;
	ti : CM_TrackedItem;
	deleteResponse : WS_Response;
	measureType : CM_MeasurementType;
	weigthValue : String;

begin

	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	weigthValue := app.convertMeasurementForDisplay( measureType.shortName, 4000 );

	create updateRequest transient;
	updateRequest.setPropertyValue("idTextBox",_id);
	updateRequest.cargoType := "1";
	updateRequest.bookingReference := "book1";
	updateRequest.setPropertyValue("isoType","2200");
	updateRequest.setPropertyValue("operatorCode","UTOP");
	updateRequest.setPropertyValue("mark","");
	updateRequest.setPropertyValue("sealNum","Seal1");
	updateRequest.setPropertyValue("sealNumCustoms","Cus1,Cus2");
	updateRequest.setPropertyValue("sealNumShippers","Ship1");
	updateRequest.setPropertyValue("sealNumVent","Vent1");	
	updateRequest.setPropertyValue("voyageCode","");
	updateRequest.setPropertyValue("weightTotal",weigthValue);	
	updateRequest.setPropertyValue("transportMode",TI_TRANSMODE_ROAD_STR);
	updateRequest.setPropertyValue("commodity","MT");
	updateRequest.setPropertyValue("remarks","Remarks1");
	updateRequest.setPropertyValue("expectedArrivalDate", now.Date.format("dd MM yyy") );
	updateRequest.setPropertyValue("expectedArrivalTime", now.Time.format("hh mm") );
	updateRequest.setPropertyValue("imexStatusString", "0".String);
	updateRequest.setPropertyValue("warningsAcknowledged", true);
		
	create webService transient;
	updateResponse := webService.createPreNote(updateRequest);
	if updateResponse = null then
		return "test 1, updateResponse not returned.";
	endif;
	if updateResponse.hasErrors then
		return "test 2, " &amp; updateResponse.getErrorsAsStringForTesting;
	endif;
	ti := self.myTerminal.lookupPrenoteByIDExact( _id );
	if ti = null then
		return "test 3, updateResponse pre note not created. " &amp; updateResponse.getErrorsAsStringForTesting;
	endif;	
	delete updateResponse;
	
	
	//Now update the Pre-note
	updateRequest.setPropertyValue("cmObjectId", ti.getOidString);
	updateRequest.setPropertyValue("cmObjectEdition", ti.edition);
	updateRequest.bookingReference := "book2";
	updateResponse := webService.updatePreNote(updateRequest);
	if updateResponse = null then
		return "test 4, updateResponse not returned.";
	endif;
	if updateResponse.hasErrors then
		return "test 5, " &amp; updateResponse.getErrorsAsStringForTesting;
	endif;
	ti := self.myTerminal.lookupPrenoteByIDExact( _id );
	if ti = null then
		return "test 6, updateResponse updated pre note not found.";
	endif;
	if ti.bookingReference &lt;&gt; "book2" then
		return "test 7, updateResponse updating bookingreference id on pre note failed.";
	endif;
	delete updateResponse;
	
	
	//Now delete the prenote
	deleteResponse := webService.deletePreNote(updateRequest);
	if deleteResponse = null then
		return "test 8, deleteResponse not returned.";
	endif;
	if deleteResponse.hasErrors then
		return "test 9, " &amp; deleteResponse.getErrorsAsStringForTesting;
	endif;
	ti := self.myTerminal.lookupPrenoteByIDExact( _id );
	if ti &lt;&gt; null then
		return "test 10, deleteResponse failed pre note not deleted.";
	endif;
	delete deleteResponse;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsCreateUpdateDeletePreNote.name; 

epilog

	delete updateRequest;
	delete webService;
	delete updateResponse;
	delete deleteResponse;

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsDoAutoGateIn" id="fcc1bc91-bd00-4d0f-a54f-0ce93940a07f">
        <source>wsDoAutoGateIn(	_rego : String;
				_state : String;
				_batNum : String;
				_driverCode: String;
				_carrierCode : String;
				_gateName : String;
				_allPins : StringArray input;
				_xtraTestString : String;
				_expectedError : Integer
				) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2015	cnwndl1	Initial creation	Par 36951

*/

vars
	ref : String;
	webService : JMTUserInterfaceService;
	request : WS_AutoGateInRequest;
	response : WS_VehicleVisitResponse; 
	
	pinNo : String;
	
	invalidObject : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, response, invalidObject );


	// Web service call
	create request transient;
	foreach pinNo in _allPins do
		request.allPINs.add(pinNo);
	endforeach;
	request.setPropertyValue(WS_AutoGateInRequest::batNumber.name, _batNum);
	request.setPropertyValue(WS_AutoGateInRequest::driverCode.name, _driverCode);
	request.setPropertyValue(WS_AutoGateInRequest::carrierCode.name, _carrierCode);
	request.setPropertyValue(WS_AutoGateInRequest::gate.name, _gateName);
	request.setPropertyValue(WS_AutoGateInRequest::truckRegistration.name, _rego);
	request.setPropertyValue(WS_AutoGateInRequest::truckState.name, _state);
	
	create webService transient;
	response := webService.doAutoGateIn(request);
	if response = null then
		return _xtraTestString &amp; ", updateResponse not returned.";
	endif;
	if response.hasErrors then
		if _expectedError &gt; 0  and response.allErrors.includesError(_expectedError) then
			return null;
		endif;
		return _xtraTestString &amp; ", " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	if _expectedError &gt; 0 then
		return _xtraTestString &amp; ", Expected error " &amp; _expectedError.String &amp; " but none generated.";
	endif;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsDoAutoGateIn.name; 

epilog

	delete response;
	delete webService;
	delete request;
	
end;
</source>
        <Parameter name="_rego" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_batNum" type="String"/>
        <Parameter name="_driverCode" type="String"/>
        <Parameter name="_carrierCode" type="String"/>
        <Parameter name="_gateName" type="String"/>
        <Parameter name="_allPins" type="StringArray" usage="input"/>
        <Parameter name="_xtraTestString" type="String"/>
        <Parameter name="_expectedError" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsDoAutoGateOut" id="4105d707-8f30-4e9b-936f-b4783a87c6d7">
        <source>wsDoAutoGateOut(	_rego : String;
					_state : String;
					_batNum : String;
					_gateName : String;
					_allReleaseTIs : CM_TISet input;
					_xtraTestString : String;
					_expectedError : Integer
					) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2015	cnwndl1	Initial creation	Par 36951

*/

vars
	ref : String;
	webService : JMTUserInterfaceService;
	request : WS_AutoGateOutRequest;
	response : WS_VehicleVisitResponse; 
	ti : CM_TrackedItem;
	invalidObject : Boolean;
	
	
begin

	on Exception do app.handleDeletedObject( exception, response, invalidObject );


	// Web service call
	create request transient;
	foreach ti in _allReleaseTIs do
		request.addRealTI( ti );
	endforeach;
	request.setPropertyValue(WS_AutoGateInRequest::batNumber.name, _batNum);
	request.setPropertyValue(WS_AutoGateInRequest::gate.name, _gateName);
	request.setPropertyValue(WS_AutoGateInRequest::truckRegistration.name, _rego);
	request.setPropertyValue(WS_AutoGateInRequest::truckState.name, _state);
	
	create webService transient;
	response := webService.doAutoGateOut(request);
	if response = null then
		return _xtraTestString &amp; ", updateResponse not returned.";
	endif;
	if response.hasErrors then
		if _expectedError &gt; 0  and response.allErrors.includesError(_expectedError) then
			return null;
		endif;
		return _xtraTestString &amp; ", " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	if _expectedError &gt; 0 then
		return _xtraTestString &amp; ", Expected error " &amp; _expectedError.String &amp; " but none generated.";
	endif;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsDoAutoGateOut.name; 

epilog

	delete response;
	delete webService;
	delete request;
	
end;
</source>
        <Parameter name="_rego" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_batNum" type="String"/>
        <Parameter name="_gateName" type="String"/>
        <Parameter name="_allReleaseTIs" type="CM_TISet" usage="input"/>
        <Parameter name="_xtraTestString" type="String"/>
        <Parameter name="_expectedError" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsDoRoadExit" id="fba50c53-ae3b-420f-9546-7096624c788b">
        <source>wsDoRoadExit( _rego : String; _state : String; _batNum : String; _xtraTestString : String; _expectedError : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2015	cnwndl1	Initial creation	Par 36946

*/

vars
	ref : String;
	webService 		: JMTUserInterfaceService;
	request			: WS_RoadExitRequest;
	response		: WS_Response; 

begin


	// Web service call
	create request transient;
	request.setPropertyValue(WS_RoadExitRequest::truckRegistration.name, _rego);
	request.setPropertyValue(WS_RoadExitRequest::truckState.name, _state);
	request.setPropertyValue(WS_RoadExitRequest::batNumber.name, _batNum);
	
	create webService transient;
	response := webService.doRoadExit(request);
	if response = null then
		return _xtraTestString &amp; " updateResponse not returned.";
	endif;
	if response.hasErrors then
		if _expectedError &gt; 0  and response.allErrors.includesError(_expectedError) then
			return null;
		endif;
		return _xtraTestString &amp; ", " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	if _expectedError &gt; 0 then
		return _xtraTestString &amp; ", Expected error " &amp; _expectedError.String &amp; " but none generated.";
	endif;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsDoRoadExit.name; 

epilog

	delete response;
	delete webService;
	delete request;
	
end;
</source>
        <Parameter name="_rego" type="String"/>
        <Parameter name="_state" type="String"/>
