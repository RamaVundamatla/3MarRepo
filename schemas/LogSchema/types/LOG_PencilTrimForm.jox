    <JadeMethod name="loadDataForFirstTime" id="fdcbbaa0-76e2-474e-8d6a-9889cb134820">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      30 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
//20 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on

vars
	showCaptions : Boolean;
begin
	if self.frmToolbar.showCaptions then
		showCaptions := self.frmToolbar.showCaptions;
		self.frmToolbar.showCaptions := false;	 //turn it off 
		self.toolbarShowCaptions(showCaptions);	// turn back on and get sizeDeiff in toolbarShowCaptions
	endif;
	self.loadRegradeReasons();
	self.toolbarShowCaptions(self.frmToolbar.showCaptions);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadRegradeReasons" id="18ac350d-4c28-4bb3-b04f-07db66f2ddff">
        <source>loadRegradeReasons() protected;
// ---------------------------------------------------------------------------
// Created:     28 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	regradeDict			: CM_LogRegradeCodeByCodeDict;
	regradeCode			: CM_LogRegradeCode;
begin

	regradeDict := app.myRoot.allLogRegradeCodes;

	if regradeDict.isEmpty then
		return;
	endif;

	foreach regradeCode in regradeDict do
		self.cmbRegrade.itemObject[self.cmbRegrade.addItem(regradeCode.code &amp; ' - ' &amp; regradeCode.description)] := regradeCode;
	endforeach;

	self.cmbRegrade.listIndex := 1;
	self.tblNewSpecs.setValueByName(ETRow_RegradeReason, self.cmbRegrade.text);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
