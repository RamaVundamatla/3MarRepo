    <JadeMethod name="populateCargoBookingItem" id="c9c35826-a8de-4a88-b452-5d8264932168">
        <updating/>
        <source>populateCargoBookingItem() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	selectedBookingItem : CM_BookingRefItem;
	bookingItem : CM_BookingRefItem;
	index : Integer;

begin
	
	if self.myCargoStockBookingRef = null then
		self.cmbCargoBookItem.clear();
		self.setMyCargoStockBookingItem( null );
		
	else
		selectedBookingItem := self.cmbCargoBookItem.listObject.CM_BookingRefItem;
		self.cmbCargoBookItem.clear();
		
		foreach bookingItem in self.myCargoStockBookingRef.allBookingRefItems do
			index := self.cmbCargoBookItem.addItem( bookingItem.getDisplayString );
			self.cmbCargoBookItem.itemObject[index] := bookingItem;
		endforeach;
		
		if selectedBookingItem &lt;&gt; null then
			self.cmbCargoBookItem.listIndex := self.cmbCargoBookItem.findObject( selectedBookingItem );
		endif;
		
		if self.cmbCargoBookItem.listIndex = -1 and self.cmbCargoBookItem.listCount = 1 then
			self.cmbCargoBookItem.listIndex := 1;
		endif;
		
		self.setMyCargoStockBookingItem( self.cmbCargoBookItem.listObject.CM_BookingRefItem );
		
	endif;
	
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateContBookingItem" id="4f1e1ced-99bf-4950-96e0-86ddc1e747f9">
        <updating/>
        <source>populateContBookingItem()updating , protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	selectedBookingItem : CM_BookingRefItem;
	bookingItem : CM_BookingRefItem;
	index : Integer;

begin

	self.cmbContBookItem.clear();
	
	if self.myContBookingRef = null then
		self.cmbContBookItem.clear();
		self.setMyContBookingItem( null );
		
	else
		selectedBookingItem := self.cmbContBookItem.listObject.CM_BookingRefItem;
		self.cmbContBookItem.clear();
		
		foreach bookingItem in self.myContBookingRef.allBookingRefItems do
			index := self.cmbContBookItem.addItem( bookingItem.getDisplayString );
			self.cmbContBookItem.itemObject[index] := bookingItem;
		endforeach;
		
		if selectedBookingItem &lt;&gt; null then
			self.cmbContBookItem.listIndex := self.cmbContBookItem.findObject( selectedBookingItem );
		endif;
		
		if self.cmbContBookItem.listIndex = -1 and self.cmbContBookItem.listCount = 1 then
			self.cmbContBookItem.listIndex := 1;
		endif;
		
		self.setMyContBookingItem( self.cmbContBookItem.listObject.CM_BookingRefItem );
		
	endif;
	
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateContBookingRef" id="452c9822-0d63-482e-9322-2500be897f82">
        <updating/>
        <source>populateContBookingRef() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	selectedBookingRef : CM_BookingRef;
	bookingRef : CM_BookingRef;
	index : Integer;

begin

		
	if self.myCargoStockBookingItem = null or self.myCargoStockBookingItem.allLinkedExportBookings.isEmpty then
		self.cmbContBooking.clear();
	
	else
		selectedBookingRef := self.cmbContBooking.listObject.CM_BookingRef;
		self.cmbContBooking.clear();
	
		foreach bookingRef in self.myCargoStockBookingItem.allLinkedExportBookings do
			index := self.cmbContBooking.addItem( bookingRef.bookingReference );
			self.cmbContBooking.itemObject[index] := bookingRef;
		endforeach;
		
		if selectedBookingRef &lt;&gt; null then
			self.cmbContBooking.listIndex := self.cmbContBooking.findObject( selectedBookingRef );
		endif;
		
		if self.cmbContBooking.listIndex = -1 and self.cmbContBooking.listCount = 1 then
			self.cmbContBooking.listIndex := 1;
		endif;
		
		self.setMyContBookingRef( self.cmbContBooking.listObject.CM_BookingRef );
		
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyCargoStockBookingItem" id="889d5454-096f-4fab-b9f8-cb14b590b194">
        <updating/>
        <source>setMyCargoStockBookingItem( _bookingRefItem : CM_BookingRefItem ) updating, protected;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	if self.myCargoStockBookingItem &lt;&gt; _bookingRefItem then
		self.myCargoStockBookingItem := _bookingRefItem;
		self.cmbCargoBookItem.listIndex := self.cmbCargoBookItem.findObject( _bookingRefItem );
		self.setupContExportBooking();
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bookingRefItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="setMyCargoStockBookingRef" id="f225274b-6082-4fc4-857c-fe202e5b70da">
        <updating/>
        <source>setMyCargoStockBookingRef( _bookingRef : CM_BookingRef ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	if _bookingRef = null then
		self.txtCargoBooking.text := self.lblStockBookEnt.caption;
	else
		self.txtCargoBooking.text := _bookingRef.bookingReference;
	endif;

	if self.myCargoStockBookingRef &lt;&gt; _bookingRef then
		self.myCargoStockBookingRef := _bookingRef;
		self.populateCargoBookingItem();
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setMyContBookingItem" id="ff520460-bb13-4d6a-b055-857607025616">
        <updating/>
        <source>setMyContBookingItem( _bookingRefItem : CM_BookingRefItem ) updating, protected;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	if self.myContBookingItem &lt;&gt; _bookingRefItem then
		self.myContBookingItem := _bookingRefItem;
		self.cmbContBookItem.listIndex := self.cmbContBookItem.findObject( _bookingRefItem );
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bookingRefItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="setMyContBookingRef" id="fd835512-a149-4b17-ad9d-3fcbdb88a69d">
        <updating/>
        <source>setMyContBookingRef( _bookingRef : CM_BookingRef ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	if _bookingRef = null then
		self.txtContBooking.text := self.lblContBookEnt.caption;
	else
		self.txtContBooking.text := _bookingRef.bookingReference;
	endif;

	if self.myContBookingRef &lt;&gt; _bookingRef then
		self.myContBookingRef := _bookingRef;
		self.populateContBookingItem();
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setupContExportBooking" id="a6d31715-8c9d-4612-b393-b849125269c3">
        <updating/>
        <source>setupContExportBooking() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	if self.myCargoStockBookingItem = null or self.myCargoStockBookingItem.allLinkedExportBookings.isEmpty then
		self.txtContBooking.visible := true;
		self.cmbContBooking.visible := false;
		self.cmbContBooking.clear();
	else
		self.txtContBooking.visible := false;
		self.cmbContBooking.visible := true;
		self.populateContBookingRef();
	endif;
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupControls" id="5929e0e3-1ef8-485a-8cf1-39c7e7ae1666">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	transPackComplete : CM_TITransaction;

begin
	
	self.doResizeControls(true);
									
	// If we are returning from creating a pack complete transaction, clear the ref items and the container.
	if self.myMobileGenericAgent.myPackTi &lt;&gt; null then
		transPackComplete := self.myMobileGenericAgent.myPackTi.getLastTransOfType(TRANS_TYPE_PackComplete);
		if transPackComplete &lt;&gt; null then
			self.myTrackedItem := null;
		
			//13 sep 2011	NDl - RW says keep the booking item too... Feed back from Beta testing 6th Sep 2011
			self.myMobileGenericAgent.setPackContainerDetails(	self.myMobileGenericAgent.myPackStockBookingRef,	//_stockBookingRef : CM_BookingRef;
																	self.myMobileGenericAgent.myPackStockBookingItem,	//_stockBookingRefItem : CM_BookingRefItem;
																	self.myMobileGenericAgent.myPackExportBookingRef,	//_exportBookingRef : CM_BookingRef;
																	self.myMobileGenericAgent.myPackExportBookingItem,	//_exportBookingRefItem : CM_BookingRefItem;
																	null	//_trackedItem : CM_TrackedItem
																	);
		endif;
	endif;
	
	// if returning from Pack Container Update form need to populate things.		
	self.myTrackedItem := self.myMobileGenericAgent.myPackTi;
	if self.myTrackedItem = null then
		self.txtContainerId.text := self.lblContEnt.caption;
	else
		self.txtContainerId.text := self.myTrackedItem.id;
	endif;
	
	self.setMyCargoStockBookingRef( self.myMobileGenericAgent.myPackStockBookingRef );
	self.setMyCargoStockBookingItem( self.myMobileGenericAgent.myPackStockBookingItem );
	self.setMyContBookingRef( self.myMobileGenericAgent.myPackExportBookingRef );
	self.setMyContBookingItem( self.myMobileGenericAgent.myPackExportBookingItem );
								
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="61779f26-8f25-4f56-8ba3-c1503eeb4394">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin
	
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;

	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Menu), null, null, null );
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="5ded5229-b9b1-48c6-9a0a-1e3adfc1d83f">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016621, locale);
	lblCargoBooking.translateCaption(Xlat_0016622, locale);
	lblContBookEnt.translateCaption(Xlat_0016623, locale);
	lblContEnt.translateCaption(Xlat_0016624, locale);
	lblContainerId.translateCaption(Xlat_0016625, locale);
	lblStockBookEnt.translateCaption(Xlat_0016626, locale);
	lblStockBooking.translateCaption(Xlat_0016627, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoBooking_gotFocus" id="d37f14be-d529-4684-a916-d6b59239159e">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoBooking_gotFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

begin

	if txtCargoBooking.text.toUpper = lblStockBookEnt.caption.toUpper then
		txtCargoBooking.selStart := 0;
		txtCargoBooking.selLength := lblStockBookEnt.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoBooking_lostFocus" id="25e11c63-9728-427a-a44e-202f59114757">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoBooking_lostFocus(textbox: TextBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	bookingRef : CM_BookingRef;
	msg : String;

begin

	if txtCargoBooking.text.trimBlanks = null then
		txtCargoBooking.text := lblStockBookEnt.caption;
	endif;
	
	txtCargoBooking.selStart := 0;
	txtCargoBooking.selLength := 0;

	bookingRef := self.doFindBooking( textbox.text.toUpper.trimBlanks, true );
	self.setMyCargoStockBookingRef( bookingRef );
	
	if bookingRef = null and ( textbox.text.toUpper.trimBlanks &lt;&gt; null and textbox.text.toUpper.trimBlanks &lt;&gt; lblStockBookEnt.caption.toUpper) then
		msg := app.getErrorString1(Stock_booking_not_found, textbox.text.toUpper.trimBlanks);
		self.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only, false );
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
