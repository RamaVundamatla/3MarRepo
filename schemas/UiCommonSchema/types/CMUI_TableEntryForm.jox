    <JadeMethod name="activate" id="d4d3bb1d-2d00-4774-b721-cd5f2437a0ee">
        <controlMethod name="Form::activate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>activate() updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	isFirstTime	: Boolean;
	
begin
	
	isFirstTime := (not self.isFirstActivateComplete);
	inheritMethod();
	if isFirstTime and self.isBaseFormModal then
		// done in this way due to a problem when
		// showing modally and Jade getting the clientHeight
		// incorrect (due to the menus being hidden).
		self.doResize();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="addExceptionHandler" id="c21f3ac3-d89b-411f-af99-53e668cfb7ed">
        <updating/>
        <source>addExceptionHandler(exObj : Exception; _passport : CM_Passport input) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	index : Integer;
	obj   : Object;

begin

	if exObj.isKindOf(CM_Exception) then
		if exObj.CM_Exception.isWarning then
			app.addWarningFullPassport(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, _passport);
			return Ex_Continue;
		endif;
		
		app.addErrorFullPassport(exObj.errorCode, exObj.extendedErrorText, exObj.CM_Exception.userString, exObj.CM_Exception.myUserObject, _passport);
		
		if exObj.continuable then
			return Ex_Continue;
		endif;
	endif;

	return Ex_Pass_Back;
	
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addItem" id="4dc59baf-ff6b-40eb-a161-18534b318e42">
        <updating/>
        <source>addItem() updating;
//--------------------------------------------------------------
//Created: April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	intFaceAttach	: CMIF_InOutAttachment;
	cargoType,
	theRow			: Integer;
		
begin
	create intFaceAttach transient;
	
	if self.myCurrentView.name = 'Default' then
		intFaceAttach.set(self.myTerminal,
						  cargoType, 
						  tblItem.getValueByName(ETRow_Id).String,
						  tblItem.getValueByName(ETRow_IsoType).String,
						  tblItem.getValueByName(ETRow_WeightTotal).Integer);
	
	elseif self.myCurrentView.name = 'Log' then
		cargoType := TI_CargoType_Log;
		intFaceAttach.myTerminal := self.myTerminal; 
		intFaceAttach.setLog(self.myTerminal,
						     TI_CargoType_Log, tblItem.getValueByName(ETRow_LogId).String,
							 tblItem.getValueByName(ETRow_SedMax).Integer,
							 tblItem.getValueByName(ETRow_SedMin).Integer,
							 tblItem.getValueByName(ETRow_LogCondition).String);
	endif;

	// check all fields have been entered

	on CM_Exception do addExceptionHandler(exception, app.myPassport);

	app.setContinueCMExceptions(true);

	intFaceAttach.checkFieldsNotNull(cargoType);
	self.checkForDuplicates(intFaceAttach);

	if app.myPassport.hasErrors then
		app.showErrorWarningDialog('', app.myPassport, ErrWarnMode_Update);
		delete intFaceAttach;
		return;
	endif;
	//self.allLogs.add(intFaceAttach);
	//self.tblAll_ShowItem(intFaceAttach, 0);
	self.setIntFaceAttach(intFaceAttach);
	tblItem.setFocus();
epilog
	self.tblItem.setFocus;
	if self.myCurrentView.name = 'Log' then	
		self.tblItem.goToRowByName(ETRow_LogId);
	else
		self.tblItem.goToRowByName(ETRow_Id);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="4fd9f9c5-eebb-423a-a6c9-c8a732b74482">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	12 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	toolbar : CMUI_Toolbar;
begin
	inheritMethod();
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
