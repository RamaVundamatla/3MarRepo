    <JadeMethod name="displayLogGradeLegend" id="4ad88256-ec3a-4566-96b7-4ae3a199050e">
        <source>displayLogGradeLegend();
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	lLogGrade	: CM_LogGrade;
	aDict		: CM_LogGrade;
	anObject	: Object;
	anArray		: ObjectArray;
	tmpCodeGrp	: CM_CodeGroup;
	codeGrps		: CM_CodeGroupSet;
	tmpOperator	: CM_Operator;
	dac 		: CM_DataAccessController;
	tmpObj		: Object;
	tmpCode		: CM_Code;
	tmpGrade	: CM_Code;

begin

	create codeGrps transient;
	self.frmColLegendLogs.myLegendTable.rows := 0;

	dac := app.myPassport.allDataAccessControllers[CM_Operator.name];
	if dac &lt;&gt; null then

		// only load valid grades for the valid operators
		foreach tmpObj in dac.allObjects do
			tmpOperator := tmpObj.CM_Operator;
			tmpCodeGrp := tmpOperator.allCodeGroups[CodeGroup_LogSpecs];
			if tmpCodeGrp &lt;&gt; null then
				if (not codeGrps.includes(tmpCodeGrp)) then
					codeGrps.add(tmpCodeGrp);
				endif;
			endif;
		endforeach;
		
		foreach tmpCodeGrp in codeGrps do
			foreach tmpCode in tmpCodeGrp.allCodes do
				foreach tmpGrade in tmpCode.CM_LogSpecies.allLogGrades do
					self.frmColLegendLogs.addRow(tmpGrade.code.trimBlanks, tmpGrade.CM_LogGrade.colour, null,true);
				endforeach;
			endforeach;
		endforeach;

		return;

	endif;

	create anArray transient;
	self.frmColLegendTIs.myLegendTable.rows := 0;
	self.frmColLegendLogs.myLegendTable.rows := 0;
	
	CM_LogGrade.allInstances(anArray, 1000, false);

	foreach anObject in anArray do
//		self.frmColLegendTIs.addRow(anObject.CM_LogGrade.code.trimBlanks,anObject.CM_LogGrade.colour,null);
		self.frmColLegendLogs.addRow(anObject.CM_LogGrade.code.trimBlanks,anObject.CM_LogGrade.colour,null,true);
	endforeach;

epilog
	delete anArray;
	delete codeGrps;
end;</source>
    </JadeMethod>
    <JadeMethod name="displaySelectAreas" id="f67ab3f9-4ff0-4980-99f2-0233ca68fb5f">
        <source>displaySelectAreas(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aBay : CM_Bay;
	aTerminalArea : CM_TerminalArea;
	theString : String;
begin
	
	if _theObject &lt;&gt; null then
		aTerminalArea := _theObject.CM_TerminalArea;
		theString := aTerminalArea.id.trimBlanks &amp; " - " &amp;
		        	aTerminalArea.myType.description.trimBlanks; 
	endif;
	return theString;

end;</source>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBtnAutoMaskClick" id="8836a490-e24f-4448-8a3f-3e1266e1b28b">
        <updating/>
        <source>doBtnAutoMaskClick(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.autoMask := (not self.autoMask);
	if self.autoMask then
		btn.caption		:= 'Auto-Mask is on';
		btn.bubbleHelp 	:= "Auto-Mask is on";
	else
		sdf01.allSelectorTIs.clear;	
		sdf02.allSelectorTIs.clear;	
		sdf03.allSelectorTIs.clear;	
		btn.caption		:= 'Auto-Mask is off';
		btn.bubbleHelp	:= "Auto-Mask is off";
		btn.CMUI_ButtonForToolbar.myToolbarButton.drawButtonUp();
		btn.CMUI_ButtonForToolbar.myToolbarButton.clearGraphics();
		if app.myMoveController &lt;&gt; null then
			app.myMoveController.isAutoMasked := false;
		endif;
		sdf01.drawSelf();
		sdf02.drawSelf();
		sdf03.drawSelf();
	endif;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBtnSelectAreaShow" id="432da4a3-0a5e-4745-b65a-9ab9a2d5e591">
        <updating/>
        <source>doBtnSelectAreaShow() updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	idx : Integer;
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	
	self.allTerminalAreas.clear();
	self.msgSelectAreas.getSelected(self.allTerminalAreas);

	if self.areaType = self.Area_Type_Straddle then
		if self.allTerminalAreas.size &gt; 3  then
			app.msgBox("You have selected more than 3 terminal areas." &amp; Cr &amp; "Only the first 3 will be used.", "Area Select", MsgBox_OK_Only);
			while self.allTerminalAreas.size &gt; 3 do
				self.allTerminalAreas.remove(self.allTerminalAreas.last);
				if self.allTerminalAreas.size &lt;= 3 then
					break;
				endif;
			endwhile;	
		endif;
	endif;
	
	if self.setupFormFromAreaSelector() then
		self.showAreaSelectorEnable(false);
	endif;
	
epilog	
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnToolBarBubbleHelp" id="dbabdb7f-14da-451e-8b9b-733e6ee2a66f">
        <source>doBtnToolBarBubbleHelp(pButtonIndex : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lBubbleHelp : String;
begin

	if pButtonIndex = VIEW_VOYAGE then
		lBubbleHelp := "View By Voyage Colours";
	elseif pButtonIndex = self.BTN_DRAW then
		lBubbleHelp := "Select Terminal Areas";
	elseif pButtonIndex = VIEW_COMMODITY then
		lBubbleHelp := "View By Commodity Colours";
	elseif pButtonIndex = VIEW_CONSIGNEE then
		lBubbleHelp := "View By Consignee Colours";
	elseif pButtonIndex = VIEW_DISPORT then
		lBubbleHelp := "View By Discharge Port Colours";
	elseif pButtonIndex = VIEW_ISOGROUP then
		lBubbleHelp := "View By ISO Group Colours";
	elseif pButtonIndex = VIEW_OPERATOR then
		lBubbleHelp := "View By Operator Colours";
	elseif pButtonIndex = VIEW_STATUS then
		lBubbleHelp := "View By Status Colours";
	elseif pButtonIndex = VIEW_TEMPERATURE then
		lBubbleHelp := "View By Temperature Colours";
	elseif pButtonIndex = VIEW_LOG_GRADE then
		lBubbleHelp := "View By Log Grade";
	elseif pButtonIndex = VIEW_LEFT_TOP then
		lBubbleHelp := "Go to top left of area";
	elseif pButtonIndex = VIEW_RIGHT_TOP then
		lBubbleHelp := "Go to top right of area";
	elseif pButtonIndex = VIEW_LEFT_BOTTOM then
		lBubbleHelp := "Go to bottom left of area";
	elseif pButtonIndex = VIEW_RIGHT_BOTTOM then
		lBubbleHelp := "Go to bottom right of area";
	elseif pButtonIndex = VIEW_AUTO_MASK then
		lBubbleHelp := "Turn Auto Mask On";
	elseif pButtonIndex = VIEW_MULTI_SELECT then
		lBubbleHelp := "Multi Select";
	elseif pButtonIndex = VIEW_FLIP_H then
		lBubbleHelp := "Flip View Horizontally";
	elseif pButtonIndex = VIEW_FLIP_V then
		lBubbleHelp := "Flip View Vertically";
	elseif pButtonIndex = VIEW_REFRESH then
		lBubbleHelp := "Refresh the display of this Area";
	elseif pButtonIndex = VIEW_CARRIERIN then	// 12/6/17 MAP TFS4209
		lBubbleHelp := "View By Receive Carrier";
	elseif pButtonIndex = VIEW_CARRIEROUT then	// 12/6/17 MAP TFS4209
		lBubbleHelp := "View By Release Carrier";
	endif;
	return lBubbleHelp;
end;</source>
        <Parameter name="pButtonIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuLocation" id="b9d872d4-c2d7-46af-8d8a-1e0606e1eb7a">
        <source>doBuildMnuLocation(_termArea : CM_TerminalArea;_gridController : CM_GridController);
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5		par 30475 - remove references to location restrictions
constants
vars
	menuParams : CMIF_MenuParams;
	aSub : CM_BlockStack;
	aLabR : CM_LabourRestriction;
	termArea : CM_TerminalArea;
	gridController : CM_GridController;
	termID,controllerID : String;
	aChildMenuItem : MenuItem;
	aStackController : CM_StackController;
	maxHeight, idx,nuthinIndex : Integer;
begin
	termArea := _termArea;
	maxHeight := termArea.CM_GridArea.heightOfStack;
	gridController := _gridController;
	termID := termArea.id;
	controllerID := gridController.getID;
	
	// ########
	// The Form
	self.mnuLcnAreaMain.visible := true; 
	self.mnuLcnPadMain.visible := true; 
	
	// ##############################
	// ##############################
	// AREA MENU
	// ##############################
	// ##############################
	
	self.mnuLcnAreaMain.caption := termID  &amp; " Location &amp;Maintenance"; 
	create menuParams transient;
	self.mnuLcnAreaMaint.userObject := menuParams;
	menuParams.setForCreate(YRD_PadArea.AreaMode_Height,null,null,termArea,null,null);
	self.mnuLcnAreaMaint.caption := termID  &amp; " Location &amp;Maintenance...";
	self.mnuLcnAreaMaint.visible := false; // do not use?
	
	// ########
	// PAD EDIT
	create menuParams transient;
	self.mnuLcnAreaHeight.userObject := menuParams;
	menuParams.setForCreate(YRD_PadArea.AreaMode_Height,null,null,termArea,null,null);
	self.mnuLcnAreaHeight.caption := termID &amp; " Pad &amp;Edit...";

	// ########
	// LABOUR
	create menuParams transient;
	self.mnuLcnAreaLabour.userObject := menuParams;
	menuParams.setForCreate(YRD_PadArea.AreaMode_Labour,null,null,termArea,null,null);
	self.mnuLcnAreaLabour.caption := termID &amp; " &amp;Labour Restrictions...";

	// ########
	// SUB BLOCK STACKS
	create menuParams transient;
	self.mnuLcnAreaSBS.userObject := menuParams;
	menuParams.setForCreate(YRD_PadArea.AreaMode_SubBlock,null,null,termArea,null,null); // just generally go to SBS
	self.mnuLcnAreaSBS.caption := termID &amp; " &amp;Sub BlockStacks...";

// ############################################################################################################

	// ##############################
	// ##############################
	// PAD MENU
	// ##############################
	// ##############################
	
	aSub := gridController.mySubBlockStack;
	self.mnuLcnPadMain.caption := controllerID  &amp; " Location &amp;Maintenance"; 
	
	// ########
	// PAD EDIT
	create menuParams transient;
	self.mnuLcnPadPad.userObject := menuParams;
	menuParams.setForCreate(YRD_PadArea.AreaMode_Height,null,gridController,termArea,null,null);
	self.mnuLcnPadPad.caption := controllerID &amp; " Pad &amp;Edit...";


	// ########
	// LOCATION RESTRICTIONS
	self.mnuLcnPadLocation.visible := false;

	// ########
	// SUB BLOCK STACKS
	if aSub &lt;&gt; null then
		create menuParams transient;
		self.mnuLcnPadSBS.userObject := menuParams;
		menuParams.setForCreate(YRD_PadArea.AreaMode_SubBlock,null,aSub,termArea,null,null); // just generally go to SBS
		self.mnuLcnPadSBS.visible := true;
		self.mnuLcnPadSBS.caption := aSub.id &amp; " &amp;Sub BlockStack...";
		self.mnuSubBlock.visible := true;
		self.mnuSubBlock.userObject := aSub;
		self.mnuSubBlock.caption := aSub.id &amp; " &amp;View...";
	else
//		create menuParamsSArea transient;
//		self.mnuLcnPadSBS.userObject := menuParamsSArea;
//		menuParamsSArea.setForCreate(YRD_PadArea.AreaMode_SubBlock,null,gridController,termArea,null,null); // just generally go to SBS
		self.mnuLcnPadSBS.visible := false;
//		self.mnuLcnPadSBS.caption := controllerID &amp; " &amp;Sub BlockStacks...";
		self.mnuSubBlock.visible := false;
	endif;

	// #################################
	// DYNAMIC LOCATION CONTROLLER MENUS
	
	// clean up first
	foreach idx in 1 to 8 do
		aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_NOTHING_BASE + idx);
		if aChildMenuItem &lt;&gt; null then
			delete aChildMenuItem;
		endif;
	endforeach;
	foreach idx in 1 to 10 do
		aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_LABOUR_BASE + idx);
		if aChildMenuItem &lt;&gt; null then
			delete aChildMenuItem;
		endif;
	endforeach;
	
	aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_POWER_GOOD);
	if aChildMenuItem &lt;&gt; null then
		delete aChildMenuItem;
	endif;
	aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_POWER_BAD);
	if aChildMenuItem &lt;&gt; null then
		delete aChildMenuItem;
	endif;
	aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_UNAVAIL);
	if aChildMenuItem &lt;&gt; null then
		delete aChildMenuItem;
	endif;
	aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_AVAIL);
	if aChildMenuItem &lt;&gt; null then
		delete aChildMenuItem;
	endif;
	
	// make those menus
	// ########
	// LABOUR
	self.mnuLcnPadLabour.visible := false;
	idx := 0;
	foreach aLabR in gridController.allLabourRestrictions do
		idx := idx + 1;
		create menuParams transient;
		aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_LABOUR_BASE + idx);
		if aChildMenuItem = null then
			aChildMenuItem := self.mnuLcnPadMain.loadSubMenu(MENU_INDEX_LABOUR_BASE + idx);
		endif;
		aChildMenuItem.caption := controllerID &amp; " &amp;" &amp; aLabR.id &amp; " Labour Restriction...";
		aChildMenuItem.userObject := menuParams;
		menuParams.setForCreate(YRD_PadArea.AreaMode_Labour,null,aLabR,termArea,null,null);
	endforeach;

	if CM_StackController.hasInstance(gridController) then
		aStackController := gridController.CM_StackController;
		
		// ### AVAILABLE OR NOT
		if not aStackController.amIAvailable then
			aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_AVAIL);
			if aChildMenuItem = null then
				aChildMenuItem := self.mnuLcnPadMain.loadSubMenu(MENU_INDEX_AVAIL);
			endif;
			aChildMenuItem.caption := controllerID &amp; " Make &amp;Available";
			aChildMenuItem.userObject := aStackController;
			aChildMenuItem.helpContextId := MENU_INDEX_AVAIL;

		else
			if aStackController.availability &lt;&gt; PAD_AVAILABLE then
				aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_AVAIL);
				if aChildMenuItem = null then
					aChildMenuItem := self.mnuLcnPadMain.loadSubMenu(MENU_INDEX_AVAIL);
				endif;
				aChildMenuItem.caption := controllerID &amp; " Make &amp;Available";
				aChildMenuItem.userObject := aStackController;
				aChildMenuItem.helpContextId := MENU_INDEX_AVAIL;
			endif;

			aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_UNAVAIL);
			if aChildMenuItem = null then
				aChildMenuItem := self.mnuLcnPadMain.loadSubMenu(MENU_INDEX_UNAVAIL);
			endif;
			aChildMenuItem.caption := controllerID &amp; " Make &amp;Unavailable";
			aChildMenuItem.userObject := aStackController;
			aChildMenuItem.helpContextId := MENU_INDEX_UNAVAIL;
		endif;
		
		// ### NOTHING FROM... MENUS
		foreach idx in 1 to maxHeight do
			nuthinIndex := MENU_INDEX_NOTHING_BASE + idx;
			aChildMenuItem := self.mnuLcnPadMain.getMenuItem(nuthinIndex);
			if aChildMenuItem = null then
				aChildMenuItem := self.mnuLcnPadMain.loadSubMenu(nuthinIndex);
			endif;
			aChildMenuItem.caption := controllerID &amp; " Nothing From &amp;" &amp; idx.String;
			aChildMenuItem.userObject := aStackController;
			aChildMenuItem.helpContextId := nuthinIndex;
		endforeach;	
	endif;
	
	// ### POWER GOOD OR BAD
	if gridController.hasPower then
		if gridController.powerDamaged then
			aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_POWER_GOOD);
			if aChildMenuItem = null then
				aChildMenuItem := self.mnuLcnPadMain.loadSubMenu(MENU_INDEX_POWER_GOOD);
			endif;
			aChildMenuItem.caption := controllerID &amp; " Power Is &amp;Good";
			aChildMenuItem.userObject := gridController;
			aChildMenuItem.helpContextId := MENU_INDEX_POWER_GOOD;

		else
			aChildMenuItem := self.mnuLcnPadMain.getMenuItem(MENU_INDEX_POWER_BAD);
			if aChildMenuItem = null then
				aChildMenuItem := self.mnuLcnPadMain.loadSubMenu(MENU_INDEX_POWER_BAD);
			endif;
			aChildMenuItem.caption := controllerID &amp; " Power Is &amp;Bad";
			aChildMenuItem.userObject := gridController;
			aChildMenuItem.helpContextId := MENU_INDEX_POWER_BAD;
		endif;
	endif;
	
end;</source>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
        <Parameter name="_gridController" type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="doCompleteRedraw" id="63056491-5f6b-4718-bacc-f00675d924a9">
