03 February 2022	navpw1	Initial creation TFS: 52752

*/

begin
	self.myInvoiceNote := _invoiceNote;

end;</source>
        <Parameter name="_invoiceNote" type="CM_InvoiceNote"/>
    </JadeMethod>
