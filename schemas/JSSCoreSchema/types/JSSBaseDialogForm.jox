    <JadeMethod name="doFormLoad" id="e6949271-a0ea-4a81-9380-daff8f578bf0">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 February 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.getMdiFrame() = null then
		self.centreWindow();
	endif;
	
	inheritMethod();
end;</source>
