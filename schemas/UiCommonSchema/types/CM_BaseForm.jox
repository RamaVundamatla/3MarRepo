    <JadeMethod name="getLocale" id="9058aeb9-b055-40e8-a0ec-b298babdf7fa">
        <source>getLocale() : CM_Locale protected;

/*
Purpose:		This method will return the locale if it set.
Date				Who		Reason
31 July 2009		cnwrl1	Initial creation as part of CCMS 1827 - PAR 20349 - Archive Empty Release Requests
*/
	
vars
	locale : CM_Locale;
	
begin
	// Determine the locale for translations.
	locale		:= app.myCurrentLocale;
	if locale = null then
		locale	:= app.myRoot.getLocale( StandardTextLocale.padLeadingWith( "0", 4 ), false );
	endif;
	
	return locale;
	
epilog
	
end;
