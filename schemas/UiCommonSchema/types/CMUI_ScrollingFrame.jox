    <JadeMethod name="dragOver" id="cf96050f-cbdb-42c6-9734-728d64b8340a">
        <updating/>
        <source>dragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     01 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	scrollableFrame	: CMUI_ScrollableFrame;
begin
	inheritMethod(frame, win, x, y, state);
	scrollableFrame := self.myScrollableFrame;
	if scrollableFrame &lt;&gt; null then
		scrollableFrame.dragOver(scrollableFrame, win, x + self.left, y + self.top, state);
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
