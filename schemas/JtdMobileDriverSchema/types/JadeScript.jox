    <JadeMethod name="atcgConvertClassesFrom11120" id="4445c984-078d-4c56-b85d-5299e4afbff8">
        <source>atcgConvertClassesFrom11120();
//	converts generated profile classes from 1.1.12.0 format and loads them into this database
vars
	s,t,baseFolderName:String;
	ff:FileFolder; fn:FileNode;
	f,g:File;
	ac:AtcgControl;
begin
	baseFolderName:="C:\a\jmt\scalability 2009\schemas\ConvertClasses";  // &lt;&lt;=== change this folder name
	
	app.atcgRunningAtcg:=true;
	create ff transient;
	ff.fileName:=baseFolderName;
	ff.mask:="*.cls";
	create f transient;
	f.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	f.usePresentationFileSystem:=false;  // all files are on the server machine if thin client
	f.mode:=File.Mode_Input;
	create g transient;
	g.mode:=File.Mode_Output;
	g.usePresentationFileSystem:=false;
	create ac transient;
	write "Converting all .cls files in "&amp;ff.fileName;
	foreach fn in ff.files where fn.isKindOf(File) and not fn.name.atcgContains("_converted") do
		f.fileName:=fn.fileName;
		g.fileName:=fn.fileName.atcgReplace(".cls", "_converted.cls");
		write "Converting "&amp;f.fileName;
		while not f.endOfFile do
			s:=f.readLine;
			if s.atcgContains("Controller Version") and not s.atcgContains("1.1.12.0") and not s.atcgContains("1.1.14.0") then
				write s;
				app.msgBox("Only controller Version 1.1.12.0 is supported.", "ATCG Conversion Error", MsgBox_OK_Only);
				return;
			endif;
			s:=s.atcgReplace("getAddedControl", "atcgGetAddedControl");
			s:=s.atcgReplace("recordReplayModalCount", "atcgModalCount");
			s:=s.atcgReplace("cmDialog", "atcgCMD");
			g.writeLine(s);
		endwhile;
		f.close;
		g.close;

		write "Loading "&amp;g.fileName;
		ac.outFile.fileName:=g.fileName;
		ac.loadClassFile;
	endforeach;
	write "Done";
epilog
	delete ff;
	delete f;
	delete g;
	delete ac;
end;
</source>
    </JadeMethod>
