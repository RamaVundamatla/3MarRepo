    <JadeMethod name="setControlsForAddEdit" id="bebc69b7-38ff-4355-b8b7-0ef7450d0734">
        <updating/>
        <source>setControlsForAddEdit() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 04/11/2016	cnwdap1		Initial creation TFS 2861 STWR Hazardous Details Enhancements
//
vars
	form : SOP_TableMaintForm;

begin
  
  form := self.myForm;
	form.tblInput1.userInputEnabled := true;

	if form.mode = form.Mode_Add then
		form.tblInput1.clearValues;
		form.tblInput1.setValueByName(ETRow_Colour, White.String);
		form.tblInput1.setFocus;
		form.tblInput1.moveFirst();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(form.myProxyObject.CM_HazTempRange);
		// cannot update code		
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="e53cf313-e462-48de-927a-6d66df73116d">
        <updating/>
        <source>setupThumbnailDetails() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 04/11/2016	cnwdap1		Initial creation TFS 2841 Hazardous Details Enhancements
//
vars
	form : SOP_TableMaintForm;
	
begin
  	form := self.myForm;
	form.useProxyObject := true;
	form.setTblDataEntRows(ETDef_HazTempRangeMaint);

	form.shtTblInput1.caption := 'Details';
	form.initTblInput(form.tblInput1, ETDef_HazTempRangeMaint);
	form.shtTblInput1.visible := true;

	form.mulSelect1.formDisplayEntryMethodName := null;
	form.mulSelect2.formDisplayEntryMethodName := null;
	self.colourColumn := form.tblData.getColumnByRowName(ETRow_Colour);	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="5aa802de-b2ce-457f-b101-786d8079b69a">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 04 November 2016	cnwdap1		Initial creation PAR #
//
vars
	hazTempRange : CM_HazTempRange;
	cell : JadeTableCell;
	
begin
	hazTempRange := _obj.CM_HazTempRange;
	if(_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then	
			cell := myForm.tblData.accessCell(_idxRow, colourColumn);
			cell.text := null;
			cell.backColor := hazTempRange.colour;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
