    <JadeMethod name="doResize" id="1f243699-3893-4e48-ae4c-8605dab66db3">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

begin

	inheritMethod();
	
	self.grpEventDetail.left := 1;
	self.fldMain.left := 1;
	
	self.grpEventDetail.top := self.frmToolbar.top + self.frmToolbar.height + 2;
	self.fldMain.top := self.grpEventDetail.top + self.grpEventDetail.height;
	self.fldMain.height := ( (self.height - self.fldMain.top ) - 35 );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectEvent" id="f621ab3c-24b7-4c87-b0f9-69460a3adc5a">
        <updating/>
        <source>doSelectEvent( _event : CM_EventTransaction ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06//11/2009	cnwndl1	Initial creation	Par 21519
25/01/2017 	cnwns1  TFS3214 LNX - Voyage Operations Enhancements 
21/04/2017	cnwdap1	TFS 4174 LNX Additional Information on Voyage Events
12/03/2019	jlgns1	TFS 36423 XLAT_FormCaptions need to be sorted out
23/07/2019 	JLGNS1	ChangeRequest 45575: ASPA - Train Events
08/06/2020  cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
29/07/2022	jlizm1	TFS 54165 EDI Voyage Events
20/02/2023	jlizm1	TFS 56675 Truck Events remarks field
*/

vars
	localDateTime	 : TimeStamp;
	localEndDateTime : TimeStamp;
	job 			 : CM_VoyageJob;		// TFS 4174
	jobSheet 		 : CM_VoyageJobSheet;	// TFS 4174
	eventDebtor      : CM_Debtor;
	eventType 		 : CM_EventType;		// TFS 54165
begin
	self.doShowEndDateControls(false);
	self.lblDate.caption := app.getFormCaptionsString(Xlat_0020017);
	self.lblTime.caption := app.getFormCaptionsString(Xlat_0020019);
	self.lblAmount.caption := app.getFormCaptionsString(Xlat_0020198);
	
	

	if _event = null then
		self.clearEditControls();
		self.doShowWeightControls(null);
	else
		localDateTime := self.systemToLocalTime(_event.dateTime);	// 13/6/16 cnwmp6 TFS 488 - Multi timezone support
		eventDebtor	  := _event.myDebtor;							//03/06/2020 cnwma1 TFS #49400
		eventType 	  := _event.myEventType;
		self.btnEditEvent.enabled := true;
		self.btnDelete.enabled := true;
	
		self.tblEvents.selectMode := Table.SelectMode_CurrentRow;
		self.txtAmount.text:=null;
		self.txtAmount.decimals := eventType.amountDecimalPlaces;
		//epr par 37047 16/10/15
		self.txtAmount.maxLength := 8;
		if self.txtAmount.decimals &gt; 0 then
			self.txtAmount.maxLength := 9 + self.txtAmount.decimals;		
		endif;
		self.txtAmount.text := _event.getAmountDisplay;
		
		self.cmbEventType.clear();	//09 Mar 2020	NDL	TFS 48784
		self.myAssistant.comboBoxEventTypeUser(self.cmbEventType,self.eventCategory,self.myTerminal); //09 Mar 2020	NDL	TFS 48784
		
		self.cmbEventType.listIndex := self.cmbEventType.findObject( eventType );
		//09 Mar 2020	NDL	TFS 48784
		if self.cmbEventType.listIndex &lt; 1 then
			 self.cmbEventType.listIndex := self.cmbEventType.addItemObject( eventType.name, eventType );
		endif;
		self.cmbEventType.enabled := false;
		self.txtDate.setDate(localDateTime.Date);
		self.txtTime.setTime(localDateTime.Time);
		self.setupCmbCharge( not _event.noCharge );
		self.doShowWeightControls(eventType);
		
		//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
		if _event.isKindOf(CMEVT_VoyageEvent) then
			txtRemarks.text := _event.CMEVT_VoyageEvent.remarks;
			
			job := self.myCurrentJob;												// TFS 4174
			jobSheet := self.myCurrentJobSheet;										// TFS 4174
			self.myCurrentJob := _event.CMEVT_VoyageEvent.myJob;					// TFS 4174
			self.myCurrentJobSheet := _event.CMEVT_VoyageEvent.myJobSheet;			// TFS 4174
			
			if eventType.isFromToDateTimeRequired then
				localEndDateTime := self.systemToLocalTime(_event.CMEVT_VoyageEvent.dateTimeEnd);
				self.doShowEndDateControls(true);
				self.lblDate.caption := app.getFormCaptionsString(Xlat_0014748); 
				self.lblTime.caption := app.getFormCaptionsString(Xlat_0015903);
				
				if eventType.unitDescription &lt;&gt; "" then
					self.lblAmount.caption := app.getFormCaptionsString(Xlat_0020198) &amp; " (" &amp; eventType.unitDescription &amp; ")";
				endif;
				
				self.txtEndDate.setDate(localEndDateTime.date());
				self.txtEndTime.setTime(localEndDateTime.time());
			endif;	
			
			if eventType.showWeight and eventType.myWeightType &lt;&gt; null then
				self.tblWeight.setValues(app.convertMeasurementForDisplay(eventType.myWeightType.shortName, _event.CMEVT_VoyageEvent.weight ) &amp; Space &amp; eventType.myWeightType.shortName);
			endif;
		
		elseif _event.isKindOf(CMEVT_TruckEvent) then
			self.txtRemarks.text := _event.CMEVT_TruckEvent.remarks;		// TFS 56675
			
		elseif _event.isKindOf(CMEVT_TrainTransaction) then																					//ChangeRequest 45575
			txtRemarks.text := _event.CMEVT_TrainTransaction.remarks;																		//ChangeRequest 45575
			if eventType.isFromToDateTimeRequired then																						//ChangeRequest 45575
				localEndDateTime := self.systemToLocalTime(_event.CMEVT_TrainTransaction.dateTimeEnd);										//ChangeRequest 45575
				self.doShowEndDateControls(true);																							//ChangeRequest 45575
				self.lblDate.caption := app.getFormCaptionsString(Xlat_0014748); 															//ChangeRequest 45575
				self.lblTime.caption := app.getFormCaptionsString(Xlat_0015903);															//ChangeRequest 45575
				if eventType.unitDescription &lt;&gt; "" then																						//ChangeRequest 45575
					self.lblAmount.caption := app.getFormCaptionsString(Xlat_0020198) &amp; " (" &amp; eventType.unitDescription &amp; ")";				//ChangeRequest 45575
				endif;																														//ChangeRequest 45575
				self.txtEndDate.setDate(localEndDateTime.date());																			//ChangeRequest 45575
				self.txtEndTime.setTime(localEndDateTime.time());																			//ChangeRequest 45575
			endif;																															//ChangeRequest 45575							
		endif;	
		//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
		
		if not _event.allInvoiceLines.isEmpty() then //cnwas3 begin
			self.btnInvoiceLine.enabled := true;
		else
			self.btnInvoiceLine.enabled := false;
		endif;										//cnwas3 end
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNewEvent.enabled:= false;
		self.btnEditEvent.enabled:= false;
		self.btnDelete.enabled:= false;
	endif;	
	
	self.setFormTitle();															// TFS 4174
	self.myCurrentJob := job;														// TFS 4174
	self.myCurrentJobSheet := jobSheet;												// TFS 4174
	self.showDebtorCombo(eventDebtor);                                              //03/06/2020 cnwma1 TFS #49400
epilog

end;</source>
        <Parameter name="_event" type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="doShowEndDateControls" id="4ac4f144-032e-4224-9229-d90602f6ae83">
        <source>doShowEndDateControls(_visible : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 January 2017	cnwns1	Initial creation

*/

vars

begin
	lblEndDate.visible := _visible;
	txtEndDate.visible := _visible;
	lblEndTime.visible := _visible;
	txtEndTime.visible := _visible;
epilog

end;</source>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowWeightControls" id="0b9528ba-65db-4dde-b94a-d5965c3eea07">
        <source>doShowWeightControls(_eventType : CM_EventType);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 July 2022		jlizm1	Initial creation TFS 54165 EDI Voyage Events

*/

vars

begin

	if _eventType = null 
	or not _eventType.showWeight 
	or _eventType.myWeightType = null then
		self.tblWeight.visible := false;
		self.lblWeight.visible := false;
		return;
	endif;
	
	self.tblWeight.setup(Type_Weight, self.backColor);
	self.tblWeight.tabKey := J_key_Tab;
	self.tblWeight.visible := true;
	self.lblWeight.visible := true;
	
	self.tblWeight.setValues("" &amp; Space &amp; _eventType.myWeightType.shortName);
	
epilog

end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
    </JadeMethod>
    <JadeMethod name="getBank" id="9fabd7e8-c967-4180-9769-ec21b869cd1d">
        <source>getBank(): CM_Bank;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2020 cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
*/

vars
	bank : CM_Bank;
begin

	if self.myParent &lt;&gt; null then
		if self.myParent.isKindOf(CM_Voyage) then
			bank := self.myParent.CM_Voyage.myDischargeCompany;		
		else
			bank := self.myTerminal.getDefaultCompanyBank();	
		endif;
	endif;
	
	return bank;
epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
