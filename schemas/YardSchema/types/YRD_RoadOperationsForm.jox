    <JadeMethod name="lstJobMoveVehicleContextMenu" id="23447d5d-3fc0-48c6-a31e-1c07974b33b4">
        <source>lstJobMoveVehicleContextMenu(_parentMenu :MenuItem input; i : Integer io; ti : CM_TrackedItem input; _vehicle :CM_Vehicle; _in : Boolean);
/*
Purpose:		Build a context menu to move vehcile to pickup/release _ti (paremeter)		
Return Value:		

Date				Who		Reason
12 September 2006	cnwer1	Initial creation - PAR#xxxx
10/07/2009 			cnwas3 PAR 18260
24/06/2010			cnwcs5	par 24292 - refactoring/new parameter
*/
vars
	location 	: CM_LocationsController;
	ta			: CM_TerminalArea;
	icArea		: CM_YardInterchangeArea;
	subMenu		: MenuItem;
begin
	// where is the tracked item queued to
	if ti &lt;&gt; null then //cnwrd1 29.6.2010 director moves have no ti!
		location := self.getLocationForVehicleMove_TI (ti, _vehicle, _in);
	endif;
	
	if location = null then
		return;
	endif;

	// we are going to let them move the vehicle - show the parent menu item
	self.mnuLstMoveVehicle.visible := true;

	// find a menu item to use		
	subMenu := _parentMenu.getMenuItem(i);	// par 24292
	
	if subMenu = null then
		subMenu := _parentMenu.loadSubMenu(i);	// add new menu item
	endif;
	
	if _in then
		subMenu.caption := app.getErrorString2 (XLAT_MOVE_VEHICLE_IN, ti.id, location.getFullId);
	else
		subMenu.caption := app.getErrorString2 (XLAT_MOVE_VEHICLE_OUT, ti.id, location.getFullId);
	endif;
	
	subMenu.userObject	:= location;
	
	subMenu.setEventMapping(MenuItem::click.name,YRD_RoadOperationsForm::mLstMoveVehicle_click.name);	// par 24292

	subMenu.visible := true;	
	
	i := i + 1;
epilog

end;</source>
        <Parameter name="_parentMenu" type="MenuItem" usage="input"/>
        <Parameter name="i" type="Integer" usage="io"/>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_in" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lstJobsAddRoadJob" id="5248847f-9025-4e72-bb38-ae9c76f28a0a">
        <updating/>
        <source>lstJobsAddRoadJob(_roadJob : CM_RoadJob)updating;
//--------------------------------------------------
// Created:	16 June 2004 By: cnwgd1
//--------------------------------------------------
// 28/01/2022   navlw1	TFS #52455 STWR - Filter Option Vehicle Tree in Road Operations
vars
	idx 			: Integer;
	expand 			: Boolean;
	ta 				: CM_TerminalArea;
	expandedObjects : ObjectSet;
	gate			: CM_Gate;
	operator        : CM_Operator;
begin
	if _roadJob = null then
		return;
	endif;

	//testing JC 15/06/2005
	if app.isSpecial and _roadJob.regNumber = "EDITEST" then
		return;
	endif;
	
	//28 Jan 2022 NAVLW1 TFS# 52455
	if optGate.value then
		gate := _roadJob.myGate;
		if not allGates.includes(gate) then
			return;
		endif;
	elseif self.optOperator.value then
		operator := _roadJob.myOperator;
		if not allOperators.includes(operator) then
			return;
		endif;
	endif;
	
	idx := self.lstJobs.findObject(_roadJob.myVehicle);	
	
	create expandedObjects transient;
	
	if idx &gt; 0 then	
		//add job to vehicle
		expand :=	self.lstJobs.itemExpanded[idx];
		//21 Dec 2016	NDL	TFS 3123
		if expand then
			self.getExpandedForByCriteriaList( expandedObjects, _roadJob.myVehicle, false );
		endif;
		self.lstJobsUpdateVehicle(_roadJob.myVehicle, expand, false, expandedObjects);
	else
		self.lstJobsUpdateVehicle(_roadJob.myVehicle, false, false, expandedObjects);
	endif;
	
epilog

	delete expandedObjects;
	
end;</source>
        <Parameter name="_roadJob" type="CM_RoadJob"/>
    </JadeMethod>
    <JadeMethod name="lstJobsChange" id="c8c3115a-5d86-4824-8f14-d8e42b930dba">
        <updating/>
        <source>lstJobsChange(_object: CM_Object io) updating;
//--------------------------------------------------
// Created:	10 August 2006 cnwer1
//22/11/2017 cnwma1 TFS #7828 QNS - System buffering
//--------------------------------------------------
vars
	vehicle			: CM_Vehicle;
	roadJob 		: CM_RoadJob;
	wle				: CM_WorkListEntry;
	roadOpObject	: CMIF_RoadOpObject;
	invalidObject	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, _object, invalidObject);
	
	if _object &lt;&gt; null then
		self.sharedLock (_object);
	endif;
	
	// if _object is invalid we will get an exception and resume at this point
	if invalidObject then
		_object := null;
	endif;
	
	self.tblMacro.rows := 0;
		
	if _object.isKindOf(CM_Vehicle) then
		vehicle	:= _object.CM_Vehicle;
		
	elseif _object.isKindOf(CM_RoadJob) then
		roadJob	:= _object.CM_RoadJob;
		vehicle	:= roadJob.myVehicle;
		
	elseif _object.isKindOf (CM_WorkListEntry) then
		wle		:= _object.CM_WorkListEntry;
		roadJob	:= wle.job.CM_RoadJob;
		vehicle	:= roadJob.myVehicle;
	endif;
	
	if self.dkbMacro.visible then		 //22/11/2017 cnwma1 TFS #7828
		self.displayExtraInfoForObj(_object);
	endif;
	
	if vehicle &lt;&gt; null then
		self.myCurrentVehicle := vehicle;
	endif;
	
	if roadJob &lt;&gt; null then
		self.myCurrentRoadJob := roadJob;
	endif;
	
	if wle &lt;&gt; null then
		self.myCurrentWLE := wle;
	endif;
	
	roadOpObject := self.myRoadOpController.findCMIF_RoadOpObjWithVehicle(vehicle);	
	
	if roadOpObject  &lt;&gt; null then
		if wle &lt;&gt; null then
			roadOpObject.selectTableRowForWLE(wle);
		else
			roadOpObject.selectTableRowForVehicle(vehicle);
		endif;
	endif;	
		
	self.setStatusBarCaption();
epilog
	if _object &lt;&gt; null then
		self.unlock (_object);
	endif;
end;</source>
        <Parameter name="_object" type="CM_Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="lstJobsContextMenu" id="a280de63-c649-471d-a94c-84f515e56624">
        <updating/>
        <source>lstJobsContextMenu(_listObject: Object io;_left, _top : Integer) updating;
//--------------------------------------------------------------
//Created: 10 August 2006 cnwer1
//--------------------------------------------------------------
// 25/05/2010	cnwcs5	par24292 - allow user to move vehicle within yard
// 24/06/2010	cnwcs5	par 24292 - muinor changes to move menu handling, also change of parameters
// 10/03/2011	cnwmh5	PAR #27142 - Change where handleDeletedObject is armed
//nds TFS 2867 17/01/17 PKT - Bulk Process
// 06/04/2023	jlizm1	TFS 57098 EUP Seal numbers on trucks
vars
	invalidObject	: Boolean;
	roadJob 		: CM_RoadJob;
	vehicle			: CM_Vehicle;
	ti 				: CM_TrackedItem;
	subMenu 		: MenuItem;
	i,j 			: Integer;
	location 		: CM_LocationsController;
	menu, moveMenu	: MenuItem;	// par 24292 25/05/2010 cnwcs5
	isBulkGateVisit	: Boolean;	//nds TFS 2867 17/01/17 PKT - Bulk Process
begin
		
	self.mnuRebuildJobStatus.visible 	:= false;
	self.mnuRebuildJobStatus.userObject := null;
	self.mnuProcessRoadExit.visible 	:= false;
	self.mnuProcessRoadExit.userObject 	:= null;
	self.mnuInspect2.userObject			:= null;
	self.mnuInspect2.visible 			:= app.isAllowedToInspect();
	self.mnuColourLegendLst.visible		:= true;
	self.mnuVehicleVisit.visible		:=false;
	self.mnuVehicleVisit.userObject		:=null;
	self.mnuCheckSeals2.visible			:= false;	// TFS 57098
	self.mnuCheckSeals2.userObject		:= null;	// TFS 57098
	self.mnuMaintainSeals2.visible 		:= false;	// TFS 57098
	self.mnuMaintainSeals2.userObject	:= null;	// TFS 57098
	
	
	if _listObject = null then
		return;
	endif;
	

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuColourLegendLst.visible		:= true;
		self.mnuVehicleVisit.visible		:=true;
		self.mnuLstMoveVehicle.visible := false;
		self.mnuLstMoveVehicle2.visible := false;
		self.popupMenu(mnuListContext, _left, _top);
		return;
	endif;

	

	on Exception do app.handleDeletedObject (exception, _listObject, invalidObject);
	
	// lock for duration of method - if it is a WLE or job it could be deleted any time
	self.sharedLock (_listObject);

	// if _listObject has been deleted we return to here.
	if invalidObject then
		return;
	endif;

	self.mnuInspect2.userObject			:= _listObject;
	
	if _listObject.isKindOf(CM_RoadJob) then
		// won't happen but have left code here in case we change in the future
		roadJob := _listObject.CM_RoadJob;
				
		if roadJob.status = JOB_COMPLETE then
			self.mnuProcessRoadExit.visible 	:= true;
			self.mnuProcessRoadExit.userObject	:= roadJob;
		else
			self.mnuProcessRoadExit.visible 	:= false;
			self.mnuProcessRoadExit.userObject	:= null;
		endif;
		
		vehicle := roadJob.myVehicle;
		
	elseif _listObject.isKindOf(CM_Vehicle) or 
		_listObject.isKindOf (CM_WorkListEntry) then
		
		if _listObject.isKindOf (CM_WorkListEntry) then
			roadJob := _listObject.CM_WorkListEntry.job.CM_RoadJob;
			vehicle := roadJob.myVehicle;
			isBulkGateVisit := _listObject.CM_WorkListEntry.isBulkGateVisit();//nds TFS 2867 17/01/17 PKT - Bulk Process
		else	
			vehicle	:= _listObject.CM_Vehicle;
			roadJob	:= vehicle.allRoadJobs.first.CM_RoadJob;
			if roadJob.myVehicleVisit &lt;&gt; null then // NAVAB1 15SEP2021 - bad data in DMAST
				isBulkGateVisit := roadJob.myVehicleVisit.isBulkGateVVR();		//nds TFS 2867 17/01/17 PKT - Bulk Process
			endif;
		endif;
		
		if not isBulkGateVisit then											//nds TFS 2867 17/01/17 PKT - Bulk Process
			self.mnuProcessRoadExit.visible		:= true;
			self.mnuProcessRoadExit.userObject	:= vehicle;
		else																//nds TFS 2867 17/01/17 PKT - Bulk Process
			self.mnuProcessRoadExit.visible		:= false;					//nds TFS 2867 17/01/17 PKT - Bulk Process
		endif;																//nds TFS 2867 17/01/17 PKT - Bulk Process
	endif;
	
	if roadJob &lt;&gt; null then
		self.mnuRebuildJobStatus.visible	:= true;
		self.mnuRebuildJobStatus.userObject := roadJob;
		
		self.mnuVehicleVisit.visible:=true;
		self.mnuVehicleVisit.userObject:=roadJob.myVehicleVisit;
		
		if roadJob.status = JOB_COMPLETE and roadJob.myVehicleVisit &lt;&gt; null then	// TFS 57098
			self.mnuCheckSeals2.visible			:= true;							// TFS 57098
			self.mnuCheckSeals2.userObject		:= roadJob.myVehicleVisit;			// TFS 57098
			self.mnuMaintainSeals2.visible 		:= true;							// TFS 57098
			self.mnuMaintainSeals2.userObject	:= roadJob.myVehicleVisit;			// TFS 57098
		endif;
	endif;
	
	self.myCurrentVehicle 			:= vehicle;
	
	// hide all entries on the Move Vehicle submenu
	moveMenu 			:= self.mnuLstMoveVehicle;	// par 24292
	moveMenu.visible 	:= false;					// par 24292
	
	self.resetAllSubMenus (moveMenu);				// par 24292
	
	if roadJob &lt;&gt; null then
		// only allow them to move the vehicle to RTG rows to location if in yard
		if self.myRoadJobSheet.allInTerminalVehicles.includes(vehicle) then		
			// vehicle is showing in yard pane
			i := 1;
			
			foreach ti in roadJob.allReceiveTrackedItems do 
				self.lstJobMoveVehicleContextMenu(moveMenu, i, ti , vehicle, true);	// par 24292 24/06/2010
			endforeach;
			
			foreach ti in roadJob.allReleaseTrackedItems do
				self.lstJobMoveVehicleContextMenu(moveMenu, i, ti, vehicle, false);	// par 24292 24/06/2010
			endforeach;
		endif;
	endif;
	
	// par24292 - start
	self.setupMoveSubMenus (moveMenu, self.mnuLstMoveVehicle2, i);	// refactored code
	// par 24292 - end
	
	self.popupMenu(mnuListContext, _left, _top);
epilog
	if _listObject &lt;&gt; null then
		self.unlock (_listObject);
	endif;
end;</source>
        <Parameter name="_listObject" type="Object" usage="io"/>
        <Parameter name="_left" type="Integer"/>
        <Parameter name="_top" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lstJobsExpandAllItems" id="cdc836d1-daeb-414d-af3d-bc4a995baca2">
        <updating/>
        <source>lstJobsExpandAllItems()updating;
//--------------------------------------------------
// Created:	08 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	idx,
	jobListCount : Integer;
begin
	// expand all items when the form is first displayed
	jobListCount := self.lstJobs.listCount;
	foreach idx in 1 to jobListCount do
	//20 Dec 2016	NDL	TFS 3123/2638 - 
	//	if self.lstJobs.itemLevel[idx] &gt; 1 then
	//		self.lstJobs.itemExpanded[idx] := false;
	//	else
			self.lstJobs.itemExpanded[idx] := true;
	//	endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="lstJobsSetBelowLevelAllJobs" id="40bbb012-3701-4a50-a453-130498b62331">
        <source>lstJobsSetBelowLevelAllJobs(_vehicle :CM_Vehicle; _jobIndex, _level : Integer; _expandedObjects : ObjectSet input )protected;
//--------------------------------------------------
// Created:	23 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	listbox		: CMUI_ListBox;
	job			: CM_Job;
	str  		: String;
	jobIndex	: Integer;
	wleArray 	: CM_WLEArray;
	wle			: CM_WorkListEntry;
	dynaDict	: DynaDictionary;
	obj 		: Object;
	critArray	: IntegerArray;
	keysArray	: StringArray;
	allKeysArrays : ObjectArray;
begin
	if _vehicle.allRoadJobs.isEmpty then
		return;
	endif;
	
	listbox		:= self.lstJobs;
	jobIndex 	:= _jobIndex;
	
	create wleArray transient;

	_vehicle.getAllWLEs (wleArray);
	
	if self.chkCargoAttr.value and self.myTerminal.allRoadOpsDisplayCriteria.size &gt; 0 then
		//20 Dec 2016	NDL	TFS 3123/2638
		create dynaDict transient;
		create critArray transient;
		create allKeysArrays transient;
		
		dynaDict.setMembership (CM_WorkListEntry);
		self.myTerminal.setupDynaDictForRoadOps( dynaDict, critArray );
		dynaDict.endKeys(true);
		
		foreach wle in wleArray do
			create keysArray transient;
			allKeysArrays.add( keysArray);
			wle.addToDynaDictForRoadOps( dynaDict, keysArray );
		endforeach;
		
		self.addListBoxItemsSTW( _jobIndex, _level, dynaDict, critArray, allKeysArrays, _expandedObjects );
	
	else
	
		foreach wle in wleArray do
			str 		:= wle.getTreeDescription_Full;
			jobIndex 	:= jobIndex + 1;
			
			listbox.addItemAt(str, jobIndex);
			listbox.itemObject[jobIndex] 	:= wle;
			listbox.itemLevel[jobIndex]		:= _level;
			
			if wle.status = WLE_COMPLETED then
				listbox.itemPicture[jobIndex] := self.picJobComp.picture;
			elseif wle.status = WLE_PART_COMPLETE then
				listbox.itemPicture[jobIndex] := self.picJobPartComp.picture;		
			else //Unactioned
				listbox.itemPicture[jobIndex] := self.picJobWLEs.picture;
			endif;
	
		endforeach;
	
	endif;
epilog
	delete wleArray;
	delete dynaDict;
	delete critArray;
	if allKeysArrays &lt;&gt; null then
		if not allKeysArrays.isEmpty then
			allKeysArrays.purge();
		endif;
		delete allKeysArrays;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_jobIndex" type="Integer"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_expandedObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstJobsUpdateVehicle" id="17e15319-ba0b-4cb9-bd22-2f87de5e4b93">
        <updating/>
        <source>lstJobsUpdateVehicle(_vehicle : CM_Vehicle; _expand, _loading : Boolean; _expandedObjects : ObjectSet input )updating;
//--------------------------------------------------------------
//Created: Feb 2002 By: cnwgd1
//--------------------------------------------------------------
// Parameters	_loading -  if true then we will always add at end of list
//							this will make loading in vehicle order a bit quicker
//							if the numver of vehicles is large
// 07/09/2009	cnwcs5	ccms 1061 - allow for vehicle id order
// 04/07/2014	cnwdap1	PAR #34431 If _vehicle is null, just return - nothing to do
// 22/11/2017   cnwma1  TFS #7828 QNS - System buffering 
// 28/01/2022   navlw1	TFS #52455 STWR - Filter Option Vehicle Tree in Road Operations
// 03/02/2022   navlw1	TFS #52772 STWR - Review of 52455 (Include Gate/Operator in Label Button not working)
// 28/02/2022   navlw1	TFS #52787 STWR - Review of 52455 (Vehicle not added to correct group during live refresh)
// 25/02/2025	naviv1	JIRA-29374- EUP | Transaction Instrumentation - Gate
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
constants
	LEVEL_VEHICLE	= 1;
	LEVEL_JOB		= 2;
	LEVEL_GATE      = 1;
	LEVEL_GATE_VEHICLE = 2;
	LEVEL_GATE_JOB = 3;
	LEVEL_OPERATOR = 1;
	LEVEL_OPERATOR_VEHICLE = 2;
	LEVEL_OPERATOR_JOB = 3;
vars
	idx			: Integer;
	str			: String;
	job			: CM_RoadJob;
	lc			: CM_LocationsController;
	area		: CM_TerminalArea;
	wasExpanded	: Boolean;
	level       : Integer;
begin
	if _vehicle = null then							// PAR #34431
		return;										// PAR #34431
	endif;											// PAR #34431
	
	if not  self.dkcVehicles.visible then           //21.11/2017 7828  cnwma1 
		return;
	endif;
	
	// build up display for vehcile
	str := _vehicle.regNumber.trimBlanks;
	if _vehicle.state &lt;&gt; null then 
		str := str &amp; ' (' &amp; _vehicle.state &amp; ')';
	endif;
	
	job := _vehicle.allRoadJobs.first.CM_RoadJob;
	
	// TFS# 52772 NAVLW 03 Feb 2022
	if job &lt;&gt; null then
		if chkIncludeGateInLabel.value then
			if job.CM_RoadJob.myGate &lt;&gt; null and job.CM_RoadJob.myOperator &lt;&gt; null then
				str := str &amp; "-" &amp; job.CM_RoadJob.myGate.name &amp; "-" &amp; job.CM_RoadJob.myOperator.code &amp; "-";
			elseif job.CM_RoadJob.myGate &lt;&gt; null then
				str := str &amp; "-" &amp; job.CM_RoadJob.myGate.name &amp; "-" ;
			elseif job.CM_RoadJob.myOperator &lt;&gt; null then
				str := str &amp; "-" &amp; job.CM_RoadJob.myOperator.code &amp; "-";
			else
				str := "-";
			endif;
		endif;
	endif;
	
	// append receives/releases
	if job &lt;&gt; null then
		//epr TFS 7828 24/11/17
		if self.checkLogDocket then
			//cnwmc5 - 29 Jan 2015 - PAR 35528
			if job.containsLogDocket() then
				return;
			endif;
		endif;
		
		str := str &amp; ' (' &amp; job.allReceiveTrackedItems.size.String &amp; '/' &amp; job.allReleaseTrackedItems.size.String &amp; ')';
	endif;
	
	// append current terminal area
	lc	:= _vehicle.myPrimaryActualLocation;
	
	if lc &lt;&gt; null then
		area := lc.myTerminalArea;
		
		if area &lt;&gt; null then
			//changed to getNiceName because gantry interchange want there parents id;
			str := str &amp; ' - ' &amp; area.getDisplayName(true);
		endif;
	endif;
	// now add/update the entry in the list
	idx := self.lstJobs.findObject(_vehicle);
	
	if idx &gt; 1 and self.optVehicleID.value then
		// displaying in vehicle order
		if self.lstJobs.itemText[idx] &lt;&gt; str then
			// remove vehicle and re-add it - the rego may have changed
			// so it needs to be in a different place
			wasExpanded := self.lstJobs.itemExpanded [idx];
			
			self.lstJobs.clearBelowLevel(idx);
			self.lstJobs.removeItem(idx);
			
			idx := 0;
		endif;
	endif;
	
	if idx &gt; 0 then 
		self.lstJobs.clearBelowLevel(idx);
		
		if  lstJobs.itemText[idx] &lt;&gt; str then
			lstJobs.itemText[idx] := str;
		endif;
	else
		// TFS 52787 NAVLW1 28FEB2022
		if self.optVehicleID.value then
			// vehicle rego order - need to add in the correct place.
			idx := self.findIndexToAddVehicle (_vehicle);

			if idx &gt; 0 then
				lstJobs.addItemAt (str, idx); 
			else
				// TFS 52787 NAVLW1 28FEB2022
				if _loading then
					idx := lstJobs.addItem(str); // TFS 52787 NAVLW1 04MAR2022
				else
					idx := loadSortListJobsForTerminal(job);
					if idx &gt; 0 then
						lstJobs.addItemAt (str, idx); 
					else
						idx := lstJobs.addItem(str); 
					endif;
				endif;
			endif;
		else
			// TFS 52787 NAVLW1 28FEB2022
			if _loading then
				idx := lstJobs.addItem(str); // TFS 52787 NAVLW1 04MAR2022
			else
				idx := loadSortListJobsForTerminal(job);
				lstJobs.addItemAt (str, idx);
			endif;
		endif;
		
		// 26 Jan 2022 NAVLW1 TFS# 52455
		if optGate.value then
			level := LEVEL_GATE_VEHICLE;
		elseif optOperator.value then
			level := LEVEL_OPERATOR_VEHICLE;
		else
			level := LEVEL_VEHICLE;
		endif;
		
		lstJobs.itemObject[idx]		:= _vehicle;
		lstJobs.itemLevel[idx]		:= level; // navlw 26 Jan 2022 TFS# 52455
		lstJobs.itemPicture[idx]	:= self.picTruck.picture;
	endif;
	
	// 26 Jan 2022 NAVLW1 TFS# 52455
	if optGate.value then
		level := LEVEL_GATE_JOB;
	elseif optOperator.value then
		level := LEVEL_OPERATOR_JOB;
	else
		level := LEVEL_JOB;
	endif;
	
	self.lstJobsSetBelowLevelAllJobs(_vehicle, idx, level, _expandedObjects ); // 26 Jan 2022 navlw TFS# 52455

	// Expand vehicle
	if _expand or wasExpanded then
		self.lstJobs.itemExpanded[idx] := true;
	endif;
epilog
	
end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_expand" type="Boolean"/>
        <Parameter name="_loading" type="Boolean"/>
        <Parameter name="_expandedObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstJobs_click" id="1244e4c5-32f2-42e7-943f-53e8bc964021">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstJobs_click(listbox: ListBox input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars


begin
	if listbox.listObject  &lt;&gt; null then
		self.lstJobsChange(listbox.listObject.CM_Object);
	endif;
	
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstJobs_contextMenu" id="578a10ca-d3ca-415f-9f06-5fd42bcf5c99">
        <controlMethod name="ListBox::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstJobs_contextMenu(listbox: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
10 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	lLeft 	: Real;
	tTop 	: Real;
	obj 	: Object;
begin

	lLeft := x;
	tTop := y;

	conwin.windowToScreen(lLeft, tTop);
	self.screenToWindow(lLeft, tTop);   // convert x, y relative to form
	
	obj:=listbox.listObject;
	
	if obj = null then
		return false;
	endif;

	self.lstJobsContextMenu(obj,x, y);	
		
	return false;

epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lstJobs_pictureClick" id="8f08810a-93e2-4806-b013-47325f56e351">
        <controlMethod name="CM_QueueListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstJobs_pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2016	cnwndl1	Initial creation	TFS 3123/2638

*/

vars

	idx : Integer;
	jobListCount : Integer;
	startIndex : Integer;
	expand :  Boolean;
	startLevel : Integer;

begin

	startIndex := picIndex;
	expand := self.lstJobs.itemExpanded[startIndex];
	startLevel := self.lstJobs.itemLevel[startIndex];
	
	jobListCount := self.lstJobs.listCount;
	foreach idx in startIndex to jobListCount do
		if idx &lt;&gt; startIndex and self.lstJobs.itemLevel[idx] &lt;= startLevel then
			break;
		endif;
		self.lstJobs.itemExpanded[idx] := expand;
	endforeach;
	
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
