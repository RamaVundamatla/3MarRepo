    <JadeMethod name="setFromLocationActivity" id="8b6e2847-8bc8-4363-b091-e26a69b5726e">
        <updating/>
        <source>setFromLocationActivity(	_lc : CM_LocationsController;
							_locAct : CMEVT_LocationActivity;
							_prevLine : CMIF_LocActRepInventoryLine;
							_operator : CM_Operator;
							_cargoType : CM_CargoType
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

begin

	self.myLocationsController := _lc;
	self.myLocationActivity := _locAct;
	
	self.dateTime := _locAct.dateTime;
//	self.id := _locAct.getDisplayString();
	self.id := _locAct.getDisplayStringForLineRep( _lc, false );	//23 Jul 2021	NDL TFS 51616
	
	self.myOperator := _operator;
	self.myCargoType := _cargoType;
	
	if _locAct.isLocationDiscrepancyDecrease 
	or ( _locAct.isLocationMove and _locAct.mySourceLocation = _lc ) then
		self.weightOut :=  _locAct.weight;
	elseif _locAct.isLocationDiscrepancyIncrease
	or ( _locAct.isLocationMove and _locAct.myTargetLocation = _lc ) then
		self.weightIn :=  _locAct.weight;
	endif;
	
	if _prevLine &lt;&gt; null then
		balance := _prevLine.balance + weightIn - weightOut;
	else
		if _locAct.isLocationBalance then
			balance := _locAct.weight;
		else
			balance := weightIn - weightOut;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_locAct" type="CMEVT_LocationActivity"/>
        <Parameter name="_prevLine" type="CMIF_LocActRepInventoryLine"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="writeDebugLine" id="422c71b0-8540-4279-9241-7b67b387335c">
        <source>writeDebugLine():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	str : String;

begin

	str := self.myLocationsController.getFullId &amp; ", " &amp; Tab &amp; 
			self.myOperator.code &amp; ", " &amp; Tab &amp; 
			self.myCargoType.abbreviation &amp; ", " &amp; Tab &amp;
			self.id &amp; ", " &amp; Tab &amp;
			self.dateTime.asStringJMT &amp; ", " &amp; Tab &amp;
			" + " &amp; self.weightIn.asStringJMT &amp; ", " &amp; Tab &amp;
			" - " &amp; self.weightOut.asStringJMT &amp; ", " &amp; Tab &amp;
			self.balance.asStringJMT;
			
	return str;


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
