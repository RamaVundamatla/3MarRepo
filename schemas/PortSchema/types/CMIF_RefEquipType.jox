    <JadeMethod name="initializeForActivity" id="87948c41-2182-4902-b955-b44d1f9190fa">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
27 August 2021	navab1	TFS 51853
31 Aug 2021 navpw1 ChangeRequest 51853: MTN - Opsview Container - Gate
*/

vars
	isoType		: CM_ISOType;
begin

	self.tableName		:= self.Ref_equip_type;
		
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		return;
	endif;

	//navsp1 05MAY2022 TFS#53569
	isoType	:=	_any.CM_ISOType;
	isoType.initializeForActivity(_ewsOpsView,self);
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
