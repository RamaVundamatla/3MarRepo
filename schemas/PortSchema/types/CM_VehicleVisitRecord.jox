    <JadeMethod name="getBatNumber" id="3ebe261d-8c8e-4f1a-9298-9d26abfeaa09">
        <source>getBatNumber() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars
	job 	: CM_Job;
	tag		: CM_RFIDTag;
begin
	//epr par 36908
	// if we have a job, the bat number will be on the job
	job := self.getMyJob;
	if job &lt;&gt; null then
		tag := job.getMyRFIDTag;
		if tag &lt;&gt; null then
			return tag.code;
		endif;
	endif;
	
	//epr par 36441 15/6/15
	return self.getRFIDTag;
	
epilog

end;</source>
