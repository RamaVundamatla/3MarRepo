        <Parameter name="_txt" type="TextBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="179cc3fc-6820-4ef5-84fc-f4e0e87d3550">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

	str : String;
	numRows,
	idx : Integer;
	yardAllocationArray : ObjectSet;
	yardAllocation : Object;

begin

	create yardAllocationArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			yardAllocation := _tbl.accessRow(idx).itemObject;
			yardAllocationArray.add(yardAllocation);
		endif;
	endforeach;
	
	_op.setSearchValue(yardAllocationArray);
	
epilog

	delete yardAllocationArray;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="74bcc308-36f6-44f0-850b-747b531be3e8">
        <source>translateToDisplayValue(_value: Any): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

	dict : CM_YAByPriorityDict;
	ya : CM_YardAllocation;
	str : String;

begin
	
	if _value.isKindOf(CM_YardAllocation) then
		if _value &lt;&gt; null then
			return _value.CM_YardAllocation.getListDisplay;
		else
			return null;
		endif;
	elseif _value.isKindOf(CM_YAByPriorityDict) then
		dict :=  _value.CM_YAByPriorityDict;
		if dict = null or dict.isEmpty then
			return null;
		else
			foreach ya in dict discreteLock do
				if str = null then
					str := ya.getListDisplay;
				else
					str := str &amp; ", " &amp;  ya.getListDisplay;
				endif;
			endforeach;
			return str;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="cbaf60e1-92bb-4015-af6c-600da5a9e8e3">
        <source>translateToSearchValue(_value: Any): Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

	invalidObj 		: Boolean;
	object			: CM_YardAllocation;
	returnVal		: String;
	
begin

	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		elseif _value.isKindOf(CM_YardAllocation) then
			object := _value.CM_YardAllocation;
		else
			returnVal := _value.String;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.getListDisplay;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="e47ae529-8bc4-4350-a1bc-3d67ee500648">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	obj : Object;
	rtnVal, collStr, str : String;
	strArray : StringArray;
	coll : CM_YardAllocationsByCodeDict;
	yardAlloc : CM_YardAllocation;

begin
	if _value.isKindOf(ObjectSet) then
		foreach obj in _value.ObjectSet do
			rtnVal := rtnVal &amp; obj.CM_YardAllocation.getListDisplay &amp; CNEC_COMMA &amp; Space;
		endforeach;
		rtnVal := rtnVal[1:rtnVal.length-2];
		return rtnVal;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			collStr := _value.String;
			create strArray transient;
			create coll transient;
			collStr.getTokensForDelimiter("|", strArray);
			foreach str in strArray do
				yardAlloc := app.myPassport.myTerminal.allYardAllocatonsByCode[str];
				if yardAlloc &lt;&gt; null then
					coll.addNoDuplicates(yardAlloc, false);
				endif;
			endforeach;
			return coll;
		endif;
		
		yardAlloc := app.myPassport.myTerminal.allYardAllocatonsByCode[_value.String];
		if yardAlloc &lt;&gt; null then
			return yardAlloc;
		endif;
		
		return _value.String;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
