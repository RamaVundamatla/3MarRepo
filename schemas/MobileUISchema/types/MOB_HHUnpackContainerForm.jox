    <JadeMethod name="btnDocActions_click" id="c9526cc5-a94a-4714-b5fa-5c6cc3c86792">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDocActions_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2016	cnwndl1	Initial creation	TFS 2654 / 2001

*/

vars
	bookingItemSet : CM_BookingRefItemSet;
	obj : Object;
	docAction : CM_BookingItemActions;

begin
	create bookingItemSet transient;
	foreach obj in self.docActsToDisplay do
		docAction := obj.CM_BookingItemActions;
		bookingItemSet.addNoDuplicates(docAction.myBookingItem, false);
	endforeach;
	
	self.myMobileGenericAgent.setAllBookingRefItems(bookingItemSet);
	self.myMobileGenericAgent.setStringField1( self.fldCargo.topSheet.name );
	self.myMobileGenericAgent.setMyNextTiToAction( null );
	self.gotoForm( MOB_HHDocumentActions, false );
	
epilog
	delete bookingItemSet;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
