    <JadeMethod name="getDiscrepancy" id="ebefc0b5-22e4-47ec-aa76-9a7016d20cce">
        <source>getDiscrepancy(aStr : String output): Boolean;
/*
 ------------------------------------------------------------------------
Created:			07 February 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	aStr := null;
	if self.availability = PAD_USER_UNAVAILABLE then
		aStr := app.getErrorString1(DiscrepancyLocnUnavailable, self.getFullId);
		return true;
	endif;
	return inheritMethod(aStr);	//Also call superclass (cm_gridController's version)
end;</source>
        <Parameter name="aStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
