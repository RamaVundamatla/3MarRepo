    <JadeMethod name="getObjects" id="102adb6c-db7b-46c0-b02c-0a96d9594a69">
        <source>getObjects(objects: ObjectLongNameDict input);
//24 November 2009 cnwjo3 CCMS 1028
// Return a dict of objects for this criteria type
vars
	ss: CM_SpecialStow;
begin
	foreach ss in app.myRoot.allSpecialStows do
		objects[ss.getYAIdentifier] := ss;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
