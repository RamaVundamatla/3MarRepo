<Class name="CM_QDateToDoTaskCompletedProp" id="c9017c1a-f359-4dde-929e-346bf2a90883">
    <superclass name="CM_QDateProperty"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="logObjs"/>
    <Constant name="PREFIX_NICE_NAME" id="46220255-9aac-434c-8680-40255e0ac2d6">
        <source>'ToDo Completed DT - '</source>
        <type name="String"/>
    </Constant>
    <Constant name="PREFIX_PROPERTY_NAME" id="a8cd5669-90a0-444c-876c-9630df7d7535">
        <source>'toDoCompleteDT-'</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="toDoTaskCode" id="1a409859-d996-48a3-ba98-6aefec0b253f">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="getValueForObject" id="321e0ee7-0def-4348-aff1-fff1343cdb53">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;

/*
Date		Who		Reason
03 June 2010	cnwas3	par 24179
14/11/2011		cnwcs5	par 28574 - use code not short description as key
*/

vars	
	ti	: CM_TrackedItem;	
begin	
	ti := _obj.CM_TrackedItem;
	
	return ti.getToDoTaskCompletedDT(self.toDoTaskCode.Integer);	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="isToDoTaskProperty" id="aef5f09d-25bf-4878-a8a1-4fd2c4fa5ab3">
        <source>isToDoTaskProperty():Boolean;
/*
Date		Who		Reason
09 November 2011	cnwcs5	Initial creation - par 28574
*/
vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setup" id="9fe083b9-f4ca-47e0-83a9-893ea70f7b56">
        <updating/>
        <source>setup(_task :CM_ToDoTaskDesc; _className :String)updating;
/*
Date		Who		Reason
09 November 2011	cnwcs5	Initial creation - PAR 28574
*/
vars
	strDesc	:String;
	intCode	:Integer;
begin
	strDesc := _task.shortDescription;
	intCode	:= _task.code;

	// don't let niceName property get to &gt; 30 characters
	// not sure why this is as the property length may be up to 50
	if strDesc.length &gt;= 24 then
		// never will be - short description is max length 15
		strDesc := _task.shortDescription[1:21] &amp; '...';
	endif;
	
	self.set(self.PREFIX_NICE_NAME &amp; strDesc, self.PREFIX_PROPERTY_NAME &amp; intCode.String, _className);
	
	self.toDoTaskCode := _task.code;
	
	self.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
		
epilog

end;</source>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
        <Parameter name="_className" type="String"/>
    </JadeMethod>
</Class>
