    <JadeMethod name="eprTestGetUnpackedCargo" id="38a5ba61-c9e1-45c4-8b3f-4e9bc3ac6f16">
        <source>eprTestGetUnpackedCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2017	jlger1	Initial creation

*/

vars
	oa : ObjectArray;
	container : CM_Container;
	fromTS,toTS 	: TimeStamp;
	childTrans : Object;
	child 		: CM_TrackedItem;
begin
	container :="2367.726252".asOid.CM_Container; //epr09081011 in JBL
	fromTS.setDate("20/9/2017".Date);
	fromTS.setTime("08:00".Time);
	toTS.setDate("1/12/2017".Date);
	toTS.setTime("08:00".Time);
	
	
	
	create oa transient;
	container.getTITxnsByTypeDate(TRANS_TYPE_UNPACK,fromTS,toTS,null,null,oa);
	
	foreach childTrans in oa do
		child:=childTrans.CM_Unpack.getOtherTrackedItem;
		child := child.getMergedIntoCargo;
		if child = null then
			continue;
		endif;
		
		//unpacked then repacked into another container or self 
		if child.isChild then
			continue;
		endif;
		
		if not child.isOnSite then
			continue;
		endif;
		
		write childTrans.CM_Unpack.getUnpackAmount &amp; " " &amp; child.id &amp; " " &amp; child.locationId &amp; " " &amp; childTrans.getOidAsString &amp; " " &amp; child.cargoTypeDescr;
		
		
		write childTrans.CM_Unpack.myTrackedItem.myCargoType.isBreakBulk;
		
	endforeach;
	
	
epilog
	delete oa;
end;</source>
    </JadeMethod>
