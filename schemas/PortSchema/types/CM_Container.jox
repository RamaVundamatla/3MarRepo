    <JadeMethod name="setRemarksDamaged" id="64b78bf4-e044-4909-910f-e8b3b10ad6ff">
        <updating/>
        <source>setRemarksDamaged(_remarks: String; _reeferRmks: String; _damaged: Boolean; 
				_tiUpdateCntrl: CMIF_TIUpdateController input;
				_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 16 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if (not self.isTransient) then
		self.beginUpdate(_tiUpdateCntrl, _passport);
	endif;
	
	self.remarks := _remarks.trimBlanks;
	self.damaged := _damaged;
	self.setReeferRemarks(_reeferRmks.trimBlanks);

	if (not self.isTransient) then	
		self.endUpdate(_tiUpdateCntrl, _passport);
	endif;


end;</source>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_reeferRmks" type="String"/>
        <Parameter name="_damaged" type="Boolean"/>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setSealNum" id="635fe98b-8711-4f33-be03-16d04e6dfb02">
        <updating/>
        <source>setSealNum(_ti: CM_Container) updating;
//----------------------------------------------------------------
//	Created:	09 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
vars

	now : TimeStamp;
	
begin
	
/*	if _ti.sealNum.trimBlanks &lt;&gt; self.sealNum.trimBlanks then
		if _ti.prevSealNum.trimBlanks = null then
			self.prevSealNum := self.sealNum;
		endif;
		self.sealNum := _ti.sealNum;
	endif; */
		now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	//16 Sep 2010	NDL	Par 25608 - Use/update new seals data structure
	if _ti.getSealNum.trimBlanks &lt;&gt; self.getSealNum.trimBlanks then
		if self.isTransient then
			self.createProxySealTIsFromRawData(	_ti.getSealNum,	//_sealNum : String;
												_ti.getPrevSealNum.trimBlanks,	//_prevSealNum : String;
												null,	//_sealNumShippers : String;
												null,	//_sealNumVent : String;
												null,	//_sealNumCustoms : String;
												null,
												null,
												now	//_now : TimeStamp
												);
												
		else
			self.setSealNumOperators(_ti.getSealNum);
			
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_Container"/>
    </JadeMethod>
