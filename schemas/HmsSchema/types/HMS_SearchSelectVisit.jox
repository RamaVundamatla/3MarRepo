    <JadeMethod name="addToolbarControls" id="620d2c08-3f31-4260-8a5c-16a18c4d4f9a">
        <source>addToolbarControls() protected;
//--------------------------------------------------
// Created:	22 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnFind, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnFindAll, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnExportData, CMUI_Toolbar.Control_Alignment_Left);			
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	toolbar.visible := true;
	toolbar.positionToolbarControls();	
end;</source>
        <access>protected</access>
    </JadeMethod>
