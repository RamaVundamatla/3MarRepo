<Class name="CM_Country">
    <JadeMethod name="importPLXMLReference" id="c3f1784f-e0de-4fe4-871b-7f2192acdaed">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_Country::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
