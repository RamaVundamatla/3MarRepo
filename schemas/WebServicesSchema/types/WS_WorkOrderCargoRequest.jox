<Class name="WS_WorkOrderCargoRequest" id="2ff0c17c-7fd9-445f-b54d-95fa2cc9733f">
    <superclass name="WS_WorkOrderDetail"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allDocuments" id="8d0d2b06-d9de-4cdc-bc50-5dd5d0ece6f7">
        <memberTypeInverse/>
        <type name="WS_DocumentArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allHMSResourcesUsed" id="5d7f8c9c-d43f-4e71-804d-8b276440d9ee">
        <memberTypeInverse/>
        <type name="WS_HMSResourceUsedArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myVoyageHoldCargo" id="aa3c1b93-0d2d-4e7e-b5ec-0a95ecd2e1e7">
        <embedded/>
        <type name="WS_VoyageHoldCargo"/>
    </ImplicitInverseRef>
    <JadeMethod name="createProxyWorkOrder" id="52850610-4e85-4284-a0dc-a2d7ecb551fd">
        <source>createProxyWorkOrder(): CM_WodCargoRequest;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2018	jlger1	Initial creation

*/

vars
	pxyWorkOrder : CM_WodCargoRequest;
begin
	
	create pxyWorkOrder transient;	

	return pxyWorkOrder;

epilog

end;</source>
        <ReturnType type="CM_WodCargoRequest"/>
    </JadeMethod>
    <JadeMethod name="delete" id="6c3aae46-4895-4c8b-b1b3-9a74a50ade12">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 June 2018	jlger1	Initial creation

*/

vars

begin
	delete self.myVoyageHoldCargo;
	self.allDocuments.purge;
	self.allHMSResourcesUsed.purge; // TFS 40127
epilog	

end;</source>
    </JadeMethod>
    <JadeMethod name="isVoyageWorkOrder" id="ca44c31e-3ff4-4068-93b3-a6c25a83d186">
