    <JadeMethod name="translateForm" id="cea3617e-a1db-4d1d-aaa2-f11b6efc6d6a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 June 2019 08:16:37.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022046, locale);
	lblComment.translateCaption(Xlat_0023585, locale);
	lblNewHeight.translateCaption(Xlat_0022047, locale);
	lblNewLength.translateCaption(Xlat_0022048, locale);
	lblNewPieces.translateCaption(Xlat_0022049, locale);
	lblNewQty.translateCaption(Xlat_0022050, locale);
	lblNewTotalVolume.translateCaption(Xlat_0022051, locale);
	lblNewWeight.translateCaption(Xlat_0022052, locale);
	lblNewWidth.translateCaption(Xlat_0022053, locale);
	lblReason.translateCaption(Xlat_0022054, locale);
	lblVolumeReadOnly.translateCaption(Xlat_0022055, locale);
end;</source>
    </JadeMethod>
