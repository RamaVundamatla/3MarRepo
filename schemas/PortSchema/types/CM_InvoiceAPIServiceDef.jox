    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>//Created for Invoice API for TFS 58067 - EUP | Invoice Oracle Extract - Invoice Data</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="invoiceLinesPerBatch" id="a3b64ed0-73b0-4e3c-9c0c-cc5c63dda34f">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDisplayStringForAttribute" id="0200fb5f-23fe-43de-b913-4347069a0d1e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2023	navra1	Initial creation for Invoice API for TFS 54090 - EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61355/Task 61370)
 05/09/2024	jlier1 		TFS 65950 - CR 65949 NSW | Dynamic Integration Development
*/
vars

begin
	if _attrName = ETRow_WebServiceType then
		return ExternalWebServiceInvoiceAPI;		
	elseif _attrName = ETRow_InvoiceLinesPerBatch then
		return self.invoiceLinesPerBatch.String;
	endif;
	
	return inheritMethod(_attrName, _short);	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEndpointsView" id="74a22c48-8fc2-48da-a2cb-8d592193e8c3">
        <source>getEndpointsView(): EntTableView;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2024	jlier1	Initial creation

*/

vars
	def : EntTableDef;
begin
	def := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_ExtWebService];
	if def = null then
		return null;
	endif;
	
	return def.allEntTableViews[ETView_EndPointInvoiceAPI]; // ### JIRA 33544 15JAN2025 NAVAB1

epilog

end;</source>
        <ReturnType type="EntTableView"/>
    </JadeMethod>
