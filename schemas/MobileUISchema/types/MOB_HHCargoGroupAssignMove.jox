    <JadeMethod name="txtCGAssign_lostFocus" id="687b4eaa-3916-4904-89c3-cbfd289479c7">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCGAssign_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	cgAssign : CM_CargoGroupAssignment;
	str : String;

begin

	if self.txtCGAssign.text.trimBlanks = null then
		self.txtCGAssign.text := self.lblCGAssign.caption.toUpper;
		self.setMyCargoGroupAssignmentObj( null );
	else
		if self.findCargoGroupAssign( cgAssign ) then
			self.setMyCargoGroupAssignmentObj( cgAssign );
		else
			self.setMyCargoGroupAssignmentObj( null );
		endif;
	endif;
	
	self.txtCGAssign.selStart := 0;
	self.txtCGAssign.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="e2a166a3-eecc-43a2-b916-cfb13a9c3b29">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation

*/

vars

begin

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := self.lblCargoId.caption.length;
	endif;

epilog

end;</source>
