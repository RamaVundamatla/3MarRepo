    <JadeMethod name="mnuFileSaveAsHTML_click" id="d961a9cd-63ee-4aca-a045-a56a1b7164ff">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuFileSaveAsHTML_click(menuItem: MenuItem input) updating;

vars
	errTxt : String;
	errNo : Integer;
	
begin
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);

	if not self.doSetSaveFileName(self.FileTypeHTML) then
		// the user cancelled the save
		return;
	endif;

	if errNo = 0 then
		app.mousePointer := Busy;
		self.doSave(true, true);
	endif;
	
	if errNo &lt;&gt; 0 then
		app.msgBox("Error saving file: " &amp; self.lastSaveFileName &amp; CrLf &amp;
			CrLf &amp; '[' &amp; errNo.String &amp; "] " &amp; errTxt, "Error Saving File",
			MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	endif;

	self.setCaption(false);
		
epilog
	self.enableOpenLastSavedMenuItem;
	app.mousePointer := Idle;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuFileSaveAsText_click" id="90216fb3-2c6f-456c-9fd7-19799ac2fac5">
        <controlMethod name="MenuItem::click"/>
