    <JadeMethod name="initForm" id="c30860fc-60c1-4dcd-bf2b-6a2f577b12b5">
        <updating/>
        <source>initForm() updating;
//10 November 2009	cnwml2


vars
	entDefLeft : EntTableDef;
	entDefRight : EntTableDef;
	entRow : EntTableRow;
begin
	if self.isStock then
		entDefLeft := app.myController.getEntTableDef(ETDef_StockBookingLinked);
		entDefRight := app.myController.getEntTableDef(ETDef_StockBookingLinkedRight);
	else
		entDefLeft := app.myController.getEntTableDef(ETDef_ExportBookingLinked);
		entDefRight := app.myController.getEntTableDef(ETDef_ExportBookingLinkedRight);
	endif;

	self.tblLeft.setTblDataEntRowsFromDef(entDefLeft);
	self.tblRight.setTblDataEntRowsFromDef(entDefRight);
	
	//self.tblLeft.setColumns
	//self.tblLeft.deleteRow(1);//removeItem(1);				//remove heading field
	//self.tblRight.deleteRow(1);//removeItem(1);
	
	self.tblLeft.selectionType := CM_DataTable.SelectionType_Row;
	self.tblLeft.multiSelect := CM_BaseTable.MultiSelect_Simple;
	
	self.tblRight.selectionType := CM_DataTable.SelectionType_Row;
	self.tblRight.multiSelect := CM_BaseTable.MultiSelect_Simple;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="44b47215-a4f2-4c0c-99ae-4286d9e42012">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//28 January 2010	cnwml2


vars

begin
	if keyCode = J_key_Enter then
		self.doOK();
		self.unloadForm;
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadTables" id="d579f89e-de97-4911-a28c-ff2e4aa06cc8">
        <source>loadTables();
//10 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012

vars
	bitem : CM_BookingRefItem;
	book : CM_BookingRef;
	voyage : CM_Voyage;
begin
	if self.isStock then
		//load all stock booking items table
		
		if self.myProxyBooking.myVoyage &lt;&gt; null then
			foreach book in self.myProxyBooking.myVoyage.allBookingRefs do
				if book.isStockBookingRef then
					foreach bitem in book.allBookingRefItems do
						//self.tblLeft.addItemObject(bitem, bitem.getShortDisplay() &amp; " - " &amp; book.bookingReference);
						if not self.myProxyBooking.allLinkedStockBookingItems.includes(bitem) and 
						  (not bitem.myBookingReference.bookingReference = self.myProxyBooking.bookingReference) then
							self.tblLeft.addItemObject(bitem, book.bookingReference &amp; " - " &amp; bitem.getShortDisplay());
						endif;
					endforeach;
				endif;
			endforeach;
		else
			voyage := self.myParentForm.GTE_BookingRequestForm.cmbVoyage.listObject.CM_Voyage;
			foreach book in voyage.allBookingRefs do
				if book.isStockBookingRef then
					foreach bitem in book.allBookingRefItems do
						//self.tblLeft.addItemObject(bitem, bitem.getShortDisplay() &amp; " - " &amp; book.bookingReference);
						if not self.myProxyBooking.allLinkedStockBookingItems.includes(bitem) and 
						  not bitem.myBookingReference.bookingReference = self.myProxyBooking.bookingReference then
							self.tblLeft.addItemObject(bitem, book.bookingReference &amp; " - " &amp; bitem.getShortDisplay());
						endif;					
					endforeach;
				endif;
			endforeach;
		endif;
		
		if tblLeft.rows &gt; 1 then
			self.tblLeft.accessRow(2).selected := true;
			self.tblLeft.allSelectedObjects.add(self.tblLeft.accessRow(2).itemObject);
		endif;
		//load linked stock booking items table
		foreach bitem in self.myProxyBooking.allLinkedStockBookingItems do
			self.tblRight.addItemObject(bitem, bitem.myBookingReference.bookingReference &amp; " - " &amp; bitem.getShortDisplay);
		endforeach;
		
		if tblRight.rows &gt; 1 then
			self.tblRight.accessRow(2).selected := true;
			self.tblRight.allSelectedObjects.add(self.tblRight.accessRow(2).itemObject);
		endif;
	else
		//load All Export Bookings table
		if self.myProxyBookingItem.myBookingReference.myVoyage &lt;&gt; null then
			foreach book in  self.myProxyBookingItem.myBookingReference.myVoyage.allBookingRefs do
				if not book.isStockBookingRef then
					if not self.myProxyBookingItem.allLinkedExportBookings.includes(book) then
						self.tblLeft.addItemObject(book, book.bookingReference);
					endif;
				endif;
			endforeach;
		else
			voyage := self.myParentForm.GTE_BookingRequestForm.cmbVoyage.listObject.CM_Voyage;
			foreach book in  voyage.allBookingRefs do
				if not book.isStockBookingRef then
					if not self.myProxyBookingItem.allLinkedExportBookings.includes(book) then
						self.tblLeft.addItemObject(book, book.bookingReference);
					endif;
				endif;
			endforeach;
		endif;
		
		if tblLeft.rows &gt; 1 then
			self.tblLeft.accessRow(2).selected := true;
			self.tblLeft.allSelectedObjects.add(self.tblLeft.accessRow(2).itemObject);
		endif;
		//load  Linked Export Bookings table
		//foreach bitem in self.myProxyBookingItem.myBookingReference.allBookingRefItems do
			//foreach book in bitem.allLinkedExportBookings do
			foreach book in self.myProxyBookingItem.allLinkedExportBookings do
				self.tblRight.addItemObject(book, book.bookingReference);
			endforeach;
		//endforeach;
		
		if tblRight.rows &gt; 1 then
			self.tblRight.accessRow(2).selected := true;
			self.tblRight.allSelectedObjects.add(self.tblRight.accessRow(2).itemObject);
		endif;
	endif;
			
epilog

end;</source>
    </JadeMethod>
