Date		Who		Reason
06 May 2022	navam1	Initial creation
//TFS 53390
*/

vars

begin
	inheritMethod(_cargoGroup, _realTIToAdd, _moveLocation, _cgsToComplete, _completeAssignment, _passport);


	self.handleCargoGroupDetlGeneration(true);// ### TFS BUG 58853 11JUL2023 NAVAB1

epilog

end;</source>
