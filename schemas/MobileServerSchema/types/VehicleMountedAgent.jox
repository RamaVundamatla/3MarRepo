    <JadeMethod name="createRTGAlert" id="199cfed0-53ed-48d7-9b05-b79da2f60f2b">
        <source>createRTGAlert(_descr : String);
/*
----------   ----------  --------------------------------------------------
Created:	15 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	alertObject : CM_Object;
	rtEntry : CM_RTQueueEntry;
begin
	if app.myPassport.myTerminal = null then
		app.myPassport.setMyTerminal(self.myTerminal);
	endif;

	if self.myMachine.currentQueueTask = null or self.myMachine.currentQueueTask.myEntry = null then
		alertObject:=self.myRTDevice;
	else
		rtEntry:=self.myMachine.currentQueueTask.myEntry;
		if rtEntry.myWorkListEntry &lt;&gt; null then
			alertObject :=self.myMachine.currentQueueTask.myEntry.myWorkListEntry;
		else
			alertObject :=self.myMachine.currentQueueTask.myEntry.myJob;
		endif;
	endif;
	
	app.myPassport.createAlert(SEVERE_ERROR, 
				'Sent from RTG ' &amp; self.myRTDevice.id &amp; ': ' &amp; _descr,
				EVENT_AT_RTGAlert,
				alertObject);

	beginTransaction;
	app.commitAlert();
	commitTransaction;
end;


</source>
        <Parameter name="_descr" type="String"/>
    </JadeMethod>
