<Class name="CM_ITSWorkerController" id="0b78bc32-5b2f-49e6-b029-1b8b4a52e83c">
    <superclass name="CM_InterfaceController"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>CCMS MES 1014 - RDT ITS Interface (Narrowband Radio solution provided International Terminal Solutions).

This class implements the Worker application for the ITS Interface.</text>
    <DbClassMap file="mobileServer"/>
    <ImplicitInverseRef name="myInterfaceAgent" id="21cabfdc-a81e-4ca5-9fe2-f34e4b2e7564">
        <embedded/>
        <type name="CM_ITSWorkerAgent"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myInterfaceDefinition" id="cb1a90bd-6dd7-45bf-9254-6940ceb742cf">
        <embedded/>
        <type name="CM_ITSInterfaceDefinition"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="bb07eb13-30ba-431e-87f7-b079da95b8af">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	// Create the processing agent
	create self.myInterfaceAgent transient;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="297b8227-2591-444a-89b2-b12456046ac2">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.endNotificationForSubscriber(self);
	
	delete self.myInterfaceAgent;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="processRequests" id="cb13fcc2-8ed2-4f8b-a061-999d51ca6e60">
        <source>processRequests();

/*

Purpose:			Process outstanding requests

Parameters:			None

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	on LockException do app.cnGlobalLockExceptionHandler(exception);
	
	while self.myInterfaceAgent.processNextRequest() do
		process.sleep(0);
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyInterfaceDefinition" id="bb879f5d-aeff-4fb6-956e-d58701b54204">
        <updating/>
        <source>setMyInterfaceDefinition(_interface : CM_ITSInterfaceDefinition) updating;

/*

Purpose:			

Parameters:			

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.myInterfaceDefinition	:= _interface;
	
	self.myInterfaceAgent.setMyInterfaceDefinition(_interface);
	
epilog

end;</source>
        <Parameter name="_interface" type="CM_ITSInterfaceDefinition"/>
    </JadeMethod>
    <JadeMethod name="start" id="032e4444-bf02-4d34-b618-b482dfbf806c">
        <updating/>
        <source>start() updating;

/*

Purpose:			Start up for an ITS Work application which will action the outstanding requests

Parameters:			None

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	terminal	: CM_Terminal;

begin
	inheritMethod();
	
	// Set up application environmental stuff from the interface
	app.setMyTerminal(self.myInterfaceDefinition.myTerminal);
	app.setLocale(self.myInterfaceDefinition.myLocale);	

	// Register for ITS Action Request notifications
	terminal := self.myInterfaceDefinition.myTerminal;
	self.beginNotification(terminal, terminal.getTerminalEvent(Event_ITS_ActionRequest), Response_Continuous, 0);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="091189ec-b88f-4ad1-8c66-4b64d7764153">
        <updating/>
        <source>userNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	event	: Integer;

begin
	event := self.myInterfaceDefinition.myTerminal.getEventFromTerminalEvent(_eventType);

	if event = Event_ITS_ActionRequest then
		self.processRequests();
	endif;

epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
</Class>
