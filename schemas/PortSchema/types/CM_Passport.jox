    <JadeMethod name="resetSilentDeadlockHandler" id="efee175a-5d83-450d-8229-f96d56bd7f42">
        <source>resetSilentDeadlockHandler();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2025	navsaa30	Initial creation
7/3/2025 navsaa30 TFS 14818 MTN | Silent Deadlock Retry Technical Debt
*/

vars

begin
	process.setPersistentDeadlockPriority(0);  
	app.myPassport.replayingDeadlocks := false;
	app.myPassport.silentDeadlockLimit := 3;
	app.myPassport.hadDeadlock := false;
epilog

