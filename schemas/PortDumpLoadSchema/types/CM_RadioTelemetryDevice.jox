<Class name="CM_RadioTelemetryDevice">
    <JadeMethod name="exportPDXMLMyReferences" id="a4b7afcf-2280-4538-a6bf-dd28a0c09384">
        <source>exportPDXMLMyReferences(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars

begin
	// before we write out the myRadioTelemetry we write out which terminal we are in
	if _property.name = CM_RadioTelemetryDevice::myRadioTelemetry.name then
		_file.writeLine("&lt;"&amp;CM_RadioTelemetry::myTerminal.name&amp;"&gt;"&amp;self.myRadioTelemetry.myTerminal.theKey&amp;"&lt;/"&amp;CM_RadioTelemetry::myTerminal.name&amp;"&gt;");
	endif;
	inheritMethod(_file, _objArray, _property, _object);
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</Class>
