    <JadeMethod name="cmbBolItems_click" id="8f0f60c5-3722-4088-8ad4-165fffa5eec5">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBolItems_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2023	navlw1	ChangeRequest 58730: EUP | Link bill of lading item to Receive work orders
07 Jul 2023	navhl20	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
11 Jul 2023 navhl20 Defect 59092: EUP - On the Add Cargo form the Cargo SubType list is empty
15 Sep 2023 navhl20 Bug 60510: MTN - Work Order Enquiry Release Cargo Rail not populating release request details
*/

vars
	bolDetail : CM_BOLDtl;
begin
	bolDetail := combobox.listObject.CM_BOLDtl;
	if bolDetail &lt;&gt; null then
		self.btnSelectCargo.enabled := not isApproved;
		self.btnCreateCargo.enabled := not isApproved;			//15.9.2023 navhl20 #60510
	endif;
	self.doSelectItem(bolDetail);								//11.7.2023 navhl20 #59092
	self.maintainBtnAttachCargo();
	self.tblSelectedCargo.clearAllData();
	if self.myPxyTask.isKindOf(CM_WodReceive) and self.myPxyTask.CM_WodReceive.myBillOfLadingDtl &lt;&gt; bolDetail then				//07.7.2023 navhl20 #58952
		self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs.clear();
		self.updateCargoTabNumber();
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbBol_click" id="54e24f8e-940e-422e-8906-8b51e38af1fd">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBol_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Mar 2023	navhl20	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
17 Apr 2023 navhl20 ChangeRequest 57322:[57323] EUP - VAS Task linked with Receive Cargo work Order
27 Jun 2023	navlw1	ChangeRequest 58730: EUP | Link bill of lading item to Receive work orders
07 Jul 2023	navhl20	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
19 Jul 2023 navhl20 Bug 59175: MTN - Issues with selected cargo items when Loading cargo Receive and Release work orders 
25 Jul 2023 navma1	Bug 59315: MTN - For the Ship Receive work orders there is no button to add the created cargo on ship
15 Sep 2023 navhl20 Bug 60510: MTN - Work Order Enquiry Release Cargo Rail not populating release request details
23 Dec 2024	navbs1	Bug MTN-33524: MTN - Notifications in the work order details screen update the release request assigned as a new work order is created
*/

vars
	term : CM_Terminal;
begin
	term := self.myTerminal;
	
	//self.beginClassNotification(CM_BOL, false, 		  term.getTerminalEvent(Event_BOLAdd), Response_Continuous, 0);				//19.7.2023 navhl20 #59175			//23.12.2024 navbs1 #33524
	//self.beginClassNotification(CM_BOL, false, 		  term.getTerminalEvent(Event_BOLUpdate), Response_Continuous, 0);			//23.12.2024 navbs1 #33524
	//self.beginNotification(term, 					  term.getTerminalEvent(Event_BOLUpdate), Response_Continuous, null);			//23.12.2024 navbs1 #33524
	//self.beginClassNotification(CM_TrackedItem, false,term.getTerminalEvent(TIEvent_PreNote_Add), Response_Continuous, 0);		//23.12.2024 navbs1 #33524
	
	if app.myCurrentUserCan(self.myTerminal, PmAdmBOLMaint) then						//07.4.2023 navhl20	#55443[54991]
		self.btnMaintainBooking.enabled := true;
	endif;
	if self.myPxyTask.isKindOf(CM_WodReceive) and self.cmbBol.listObject = null then
		self.btnAttachCargo.enabled := false;											//25.07.2023 navma1 #59315
		self.btnCreateCargo.enabled := false;											//07.4.2023 navhl20	#55443[54991]
		self.btnMaintainBol.caption := app.getErrorString(Add_Bill_lading);				//07.4.2023 navhl20	#55443[54991]
	else
		self.btnSelectCargo.enabled := not isApproved;
		self.btnCreateCargo.enabled := not isApproved;
		self.btnMaintainBol.caption := app.getErrorString(Edit_bill_lading);			//07.4.2023 navhl20	#55443[54991]
	endif;
	
	// 27/06/2023 navlw1 tfs 58730
	self.buildCmbBolItems(self.cmbBol.listObject.CM_BOL);
	self.initTableItems(ETDef_BOLItems);
	self.loadItemTable(combobox.listObject);
	self.doSelectItem(self.cmbBolItems.listObject.CM_BOLDtl);
	self.tblSelectedCargo.clearAllData();
	
	/*
	Only clear if the user change bill of lading 
	*/
	if self.myPxyTask.isKindOf(CM_WodReceive) and self.myPxyTask.CM_WodReceive.myBillOfLading &lt;&gt; self.cmbBol.listObject.CM_BOL then				//07.7.2023 navhl20 #58952
		self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs.clear();
		self.updateCargoTabNumber();
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbBookingItem_click" id="daa9803e-55eb-488d-b862-052f3018f1fa">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBookingItem_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2023	navhl20	ChangeRequest 57322:[57323] EUP - VAS Task linked with Receive Cargo work Order
20 Apr 2023 navma1  ChangeRequest 57324:[57325] EUP - VAS Task linked with Release Cargo Work Order
09 Jun 2023 navhl20 ChangeRequest 57745: EUP - Delivery Dispatch – Allocation List - Road
07 Jul 2023	navhl20	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
*/

vars
	bookingItem 	: CM_BookingRefItem;
	cargoType		: CM_CargoType;
	isChanged		: Boolean;
begin
	
	bookingItem := combobox.listObject.CM_BookingRefItem;					//17.04.2023 navma1 #57324:[57325]
	if bookingItem &lt;&gt; null then
		self.btnSelectCargo.enabled := not isApproved;
		cargoType 					:= bookingItem.myCargoType;				//17.04.2023 navma1 #57324:[57325]
		self.doSelectItem(bookingItem);										//08.6.2023 navhl20 #57745
	endif;
	
	self.tblSelectedCargo.clearAllData();
	if self.myPxyTask.isKindOf(CM_WodReceive) and self.myPxyTask.CM_WodReceive.myBookingRefItem &lt;&gt; bookingItem then				//07.7.2023 navhl20 #58952
		isChanged := true;
	elseif self.myPxyTask.isKindOf(CM_WodRelease) and self.myPxyTask.CM_WodRelease.myBookingRefItem &lt;&gt; bookingItem then
		isChanged := true;
	endif;
	if isChanged then																//07.7.2023 navhl20 #58952
		self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs.clear();
		self.updateCargoTabNumber();
	endif;
	self.maintainBtnAttachCargo();
	
	/*
	17.04.2023 navma1 #57324:[57325]
	Filter todo list based on the booking item cargo type 
	*/
	self.buildListToDoTasks(cargoType);

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbBooking_click" id="ba6fbfb5-a55d-4cf9-8092-5ee4f12d3fd0">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBooking_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2022	navcs2	Initial creation
25 Jan 2022	navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
17 Apr 2023	navhl20 ChangeRequest 57322:[57323] EUP - VAS Task linked with Receive Cargo work Order
09 Jun 2023	navhl20 ChangeRequest 57745: EUP - Delivery Dispatch – Allocation List - Road
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
15 Sep 2023 navhl20 Bug 60510: MTN - Work Order Enquiry Release Cargo Rail not populating release request details
*/

vars
	bookingRef 	: CM_BookingRef;
	isChanged	: Boolean;
begin
	bookingRef				    := self.cmbBooking.listObject.CM_BookingRef;		//04.07.2023 navma1 #58952
	self.btnAttachCargo.enabled := false; 											//3.2.2023 navhl20 #55443:[54991]	
	
	if app.myCurrentUserCan(self.myTerminal, PmGteBookingRefNonPendMaint) and 
	  app.myCurrentUserCan(self.myTerminal, PmGteBookingRefMaint) then			    //29.3.2023 navhl20	#55443:[54991]
		self.btnMaintainBooking.enabled := true;
	endif;
	if bookingRef = null then
		self.btnMaintainBooking.caption := app.getErrorString(Create_booking);		//29.3.2023 navhl20	#55443[54991]
	else
		self.btnMaintainBooking.caption := app.getErrorString(Update_booking);		//29.3.2023 navhl20	#55443[54991]
		self.btnCreateCargo.enabled := true;										//15.9.2023 navhl20 #60510
	endif;
	
	self.maintainBtnAttachCargo();													//30.3.2023 navhl20	#55443[54991]
	self.buildCmbBookingItem(bookingRef);											//17.4.2023 navhl20 #57322[57323]
	self.initTableItems(ETDef_BookReqItem);
	self.loadItemTable(combobox.listObject);										//25.1.2023 navhl20 #55443[54991]
	self.doSelectItem(self.cmbBookingItem.listObject.CM_BookingRefItem);			//09.6.2023 navhl20 #57745
	self.tblSelectedCargo.clearAllData();											//17.4.2023 navhl20 #57322[57323]
	if self.myPxyTask.isKindOf(CM_WodReceive) and self.myPxyTask.CM_WodReceive.myBookingRef &lt;&gt; bookingRef then				//07.7.2023 navhl20 #58952
		isChanged := true;
	elseif self.myPxyTask.isKindOf(CM_WodRelease) and self.myPxyTask.CM_WodRelease.myBookingRef &lt;&gt; bookingRef then
		isChanged := true;
	endif;
	if isChanged then																//07.7.2023 navhl20 #58952
		self.myPxyTask.CM_WorkOrderTIDtl.allSelectedTIs.clear();
		self.updateCargoTabNumber();
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
