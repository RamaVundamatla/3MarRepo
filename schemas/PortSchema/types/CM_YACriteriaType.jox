    </JadeMethod>
    <JadeMethod name="resolveTransportModePattern" id="857eb656-5511-4ff7-bd21-407303709e1f">
        <source>resolveTransportModePattern(_pattern: String; _valueArray: IntegerArray input);
//01 August 2008	cnwdw1	
// If the pattern has no wildcards, then resolve the transport modes into objects and add to _objectSet
