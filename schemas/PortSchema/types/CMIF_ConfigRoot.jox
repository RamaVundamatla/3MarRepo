end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updatePersistentObject" id="706c80d9-204f-43ef-b762-9df02359e6da">
        <source>updatePersistentObject(_root : CM_Root input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     08 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	propCol	: PropertyColl;
	prop	: Property;
	keyStr	: String;
	
begin
	inheritMethod(_root, _passport);
	propCol := self.class.allPropertiesUpTo(CMIF_Config);
	
	foreach prop in propCol do
		if self.isPropertyToIgnore(prop) then
			continue;
		endif;

		keyStr := self.getKeyStringForProperty(prop.name);

		if keyStr &lt;&gt; null then
			if keyStr = ConsigneeConsignorCmbOrdDescr then
				app.myUtilityUA.utlUpdateConsigneeCmbOrderFlag(self.consigneeConsignorCmbOrdDescr, _passport);
			else
				_root.setConfig(keyStr, self.getPropertyValue(prop.name), true);
			endif;
		else
			// need to handle as a special
			executeWhen JMTDevelopmentEnvironment;
			app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '&gt;&gt;&gt;&gt; special ' &amp; prop.name);
			endExecuteWhen;
		endif;
	endforeach;
epilog
	delete propCol;
end;</source>
        <Parameter name="_root" type="CM_Root" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
