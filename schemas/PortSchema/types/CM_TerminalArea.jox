    <JadeMethod name="getAttachmentsAuditText" id="eaeb02d2-e1bd-401a-93d6-23fba942e0de">
        <source>getAttachmentsAuditText(_onlyPhotos : Boolean) : String;
/*
Purpose - 	
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61457
*/

vars
	attachment : CM_Attachment;
	desc, str, rtnStr : String;
begin
	if _onlyPhotos then
		foreach attachment in self.allAttachments where attachment.type = CM_Attachment.Type_Photo do
			if attachment.description &lt;&gt; null then
				desc := attachment.description &amp; " (" &amp; attachment.CM_Photo.filename &amp;")";
			else
				desc := attachment.CM_Photo.filename;
			endif;
			str := str &amp; desc &amp; ',';
		endforeach;
		if str[str.length] = ',' then
			str := str[1:str.length-1];					
			return str;
		endif;
	else
		foreach attachment in self.allAttachments do
			if attachment.isKindOf(CM_Photo) then
				if attachment.description &lt;&gt; null then
					desc := attachment.description &amp; " (" &amp; attachment.CM_Photo.filename &amp;")";
				else
					desc := attachment.CM_Photo.filename;
				endif;
			else
				desc := attachment.description;
			endif;
			str := str &amp;desc &amp; ',';
		endforeach;
		if str[str.length] = ',' then
			str := str[1:str.length-1];
		endif;		
	endif;
	rtnStr :=  "Map File" &amp;  AuditStringSeparator &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;
	
	return rtnStr;
epilog

end;</source>
        <Parameter name="_onlyPhotos" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="62f651bd-db64-4dec-8a63-1600a87baa5f">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     03 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	auditTxt		: String;
	tmpLabRestrict	: CM_LabourRestriction;
	reeferWalk	: CM_ReeferBlock;
begin
	auditTxt[10000] := '*';
	auditTxt := null;
	auditTxt := inheritMethod();
	
	foreach tmpLabRestrict in self.allRestrictionsLabour do
		auditTxt := auditTxt &amp; tmpLabRestrict.getAuditTextDescription();
	endforeach;
	
	//09 July 2020	NDL	TFS 49579
	foreach reeferWalk in self.allReeferBlocks do
		auditTxt := auditTxt &amp; reeferWalk.getAuditTextDescription();
	endforeach;
	
	// ### TFS CR 58499 TASK 61457 28DEC2023 NAVAB1
	auditTxt := auditTxt &amp; self.getAttachmentsAuditText(false);
	
	return auditTxt;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="7efbc0ff-690e-4080-82ca-6586100a5a1b">
        <source>getAuditTextForProperty(_property: Property): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/06/2020	jlgdap1		Initial creation TFS 49453 ASPA satellite View Screen for Flexible Terminal Areas
//
vars
	propName : String;
	propValue : String;

begin
	propName := _property.name;
	
	if propName = CM_TerminalAreaMaster::allProductMinMax.name then
		return self.formatAuditText(propName, self.getProductMinMaxAuditText);
	endif;
		
	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAutoMaskTIs" id="02967cc2-419b-49df-bed9-f5ab83e1f428">
        <source>getAutoMaskTIs(_dict : Collection input; _mode : Integer; _dischargePort, _commodityGroup, _voyageCode : String);
//--------------------------------------------------------------
//Created: September 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	lc	: CM_LocationsController;
	lcSet : CM_LCSet;
begin

	if _dischargePort = null and 
		_commodityGroup = null and 
		_voyageCode = null then
		return;
	endif;
	
	lcSet := self.allLocationsControllers;
	if lcSet = null then
		return;
	endif;
	
	foreach lc in lcSet do
		lc.getAutoMaskTIs(_dict, _mode, _dischargePort, _commodityGroup, _voyageCode);
	endforeach;

end;</source>
        <Parameter name="_dict" type="Collection" usage="input"/>
