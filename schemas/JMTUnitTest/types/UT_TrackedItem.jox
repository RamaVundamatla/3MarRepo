    <JadeMethod name="tReeferExternallyMonitored" id="a4758376-104b-4551-8fcf-327c620e7f72">
        <source>tReeferExternallyMonitored();
/*

Purpose:	Check externally monitored works		

Date		Who		Reason
19/11/2015	cnwmh5	Initial creation

*/

vars

	bs						: CM_BlockStack;
	bs2						: CM_BlockStack;
	bs3						: CM_BlockStack;
	ti						: CM_TrackedItem;
	cargoMap				: CM_TranMap;
	tempReadTI				: CM_TemperatureReading;
	yaExternal				: CM_YardAllocation;
	yaNotExternal			: CM_YardAllocation;
	
	tiArray					: CM_TIArray;
	locations				: CM_LCArray;
	
	reeferExterCauseError	: Boolean;

begin

	self.deleteYA("IExternalMon");
	self.deleteYA("INotExternalMon");

	cargoMap := self.getTerminal().getDefaultCompanyBank().myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);
	self.deleteTransactionMaps();

	create tiArray transient;
	
	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadMDHReeferMon();
	
	bs := self.addBlockStack("UTMHBD", 500, null);
	self.assertNotNull(bs);
	
	bs2 := self.addBlockStack("UTMHBD2", 500, null);
	self.assertNotNull(bs2);
	
	bs3 := self.addBlockStack("UTMHBD3", 500, null);
	self.assertNotNull(bs3);

	// create reefer container x5  (not connected)
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2231");
	self.opts.addAssoc("Commodity", "REEF");
	self.opts.addAssoc("ReturnTIs", true);
	self.addQuickCargo(bs, null, 5, tiArray);
	self.assertEqual(tiArray.size, 5);
	
	ti := tiArray[1];
	
	// Connect the container
	self.opts.purge();
	app.myMobileAgent.updateTIConnection(ti, false, true, null);
	self.assertEqualMsg(ti.isConnected, true, "TI not connected");
	
	// Reefer Readings... not set should not cause error when adding temp reading external not set
	self.addTempReading(ti, 4.00, true);
	
	// Reefer Readings... set should not cause error when adding temp reading external not set
	self.setTerminalConfig(ReeferExternalCauseError, true); 
	self.addTempReading(ti, 5.00, false);
	self.setTerminalConfig(ReeferExternalCauseError, false); 
	
	// set ti externally monitored on
	self.opts.purge();
	self.opts.addAssoc("ExternallyMonitored", true);
	self.updateTI(ti);
	self.assertEqualMsg(ti.myReeferProperties.hasExternalMonitoring, true, "TI's external monitoring not set");
	
	// Reefer Readings... not set should not cause error when adding temp reading external  set
	self.addTempReading(ti, 6.00, true);

	// Reefer Readings... set should cause error when adding temp reading external set
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Temp_not_recorded_external);
	self.setTerminalConfig(ReeferExternalCauseError, true); 
	self.addTempReading(ti, 7.00, true);
	self.assertEqual(ti.myReeferProperties.allTemperatureReadings.size, 3);
	self.clearExpectedTrxErrors();
	
	self.setTerminalConfig(ReeferExternalCauseError, false); 
	
	self.addTempReading(ti, 8.00, false);
	self.assertEqual(ti.myReeferProperties.allTemperatureReadings.size, 4);	
	self.assertEqual(ti.getAllTransactions().last.isKindOf(CM_TemperatureReading), true);
	tempReadTI := ti.getAllTransactions().last.CM_TemperatureReading;
		
	// set ti externally monitored off
	self.opts.purge();
	self.opts.addAssoc("ExternallyMonitored", false);
	self.updateTI(ti);
	self.assertEqualMsg(ti.myReeferProperties.hasExternalMonitoring, false, "TI's external monitoring set");	
	
	self.setTerminalConfig(AutoNormalReefers, true);
	self.setTerminalConfig(AutoVoidExternalReefers, true);	
	
	// set ti externally monitored on
	self.opts.purge();
	self.opts.addAssoc("ExternallyMonitored", true);
	self.updateTI(ti);
	self.assertEqualMsg(ti.myReeferProperties.hasExternalMonitoring, true, "TI's external monitoring not set");
	self.assertEqual(ti.invoiceLines.first.status, CM_InvoiceLine.STATUS_VOIDED);
	
	// set ti externally monitored off
	self.opts.purge();
	self.opts.addAssoc("ExternallyMonitored", false);
	self.updateTI(ti);
	self.assertEqualMsg(ti.myReeferProperties.hasExternalMonitoring, false, "TI's external monitoring set");	
	self.assertEqual(ti.invoiceLines.first.status, CM_InvoiceLine.STATUS_NORMAL);
	
	// yard allocation test
	self.disableAllYA(true);
	
	create locations transient;
	bs2.allLocationsControllers.copy(locations);
	
	yaExternal := self.addYA("IExternalMon", YACriteriaType_HasExternalMon, CM_YADataBoolean.VALUE_TRUE, null, null, null, null, locations, null);
	self.assertNotNull(yaExternal);
	
	locations.clear();
	bs3.allLocationsControllers.copy(locations);
	
	yaNotExternal := self.addYA("INotExternalMon", YACriteriaType_HasExternalMon, CM_YADataBoolean.VALUE_FALSE, null, null, null, null, locations, null);
	self.assertNotNull(yaNotExternal);
	
	self.opts.purge();
	self.opts.addAssoc("MoveMode", QUEUE_MODE);
	self.move(ti, bs2.allLocationsControllers.first);
	self.assertEqual(ti.myPrimaryQueuedLocation.getID(), bs2.getID);
	
	self.deleteYA("IExternalMon");
	
	ti := tiArray[2];
	
	self.opts.purge();
	self.opts.addAssoc("ExternallyMonitored", true);
	self.updateTI(ti);
	self.assertEqualMsg(ti.myReeferProperties.hasExternalMonitoring, true, "TI's external monitoring not set");
	
	// Connect the container
	self.opts.purge();
	app.myMobileAgent.updateTIConnection(ti, false, true, null);
	self.assertEqualMsg(ti.isConnected, true, "TI not connected");
	
	self.opts.purge();
	self.opts.addAssoc("MoveMode", QUEUE_MODE);
	self.move(ti, bs3.allLocationsControllers.first);
	self.assertEqual(ti.myPrimaryQueuedLocation.getID(), bs3.getID);
	
epilog

	self.disableAllYA(false);

	delete tiArray;
	delete locations;
	
	// delete this tran map so following tests can delete the invoice line descs etc
	cargoMap := self.getTerminal().getDefaultCompanyBank().myCurrentTranMapCargo['Default'];
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	self.deleteInvoiceTransactionMap(1, 'MDHReefer');
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5

end;</source>
    </JadeMethod>
    <JadeMethod name="tShiftTranshipInROROLane" id="f8849500-97f7-4281-a539-822fe47e8037">
        <updating/>
        <source>tShiftTranshipInROROLane() updating;
/*

Purpose:			TFS 1718

Date		Who		Reason
06 April 2016	cnwmk3	Initial creation

*/
constants
	VoyageNameImport 	= 'VOY_TSHIP1';
	VoyageNameExport 	= 'VOY_TSHIP2';
	ShipNameImport 		= 'IMP_SHIP';
	ShipNameExport 		= 'EXP_SHIP';
	TestOperator 		= 'MSK';
	ContainerID1 		= "CONTR00001";
	CraneId				= "CRN5";
	CTAId				= "UT_CTA";
vars
	voyageImport 	: CM_Voyage;
	voyageExport 	: CM_Voyage;
	vessel 			: CM_Vessel;
	pxyTI, ti, ti2	: CM_TrackedItem;
	controller		: CMIF_TranshipTIController;
	roroArea		: CM_RoRoLaneArea;
	cta				: CM_CraneTransferArea;
	tas				: StringArray;
	crane			: CM_Machine;
	slotsFrom		: CM_SlotControllerArray;
	tmpLoadCC		: CMIF_LoadColorCode;
	voyageDischJob	: CM_VoyageJob;
	requireDischarge: CM_TISet;
	tis				: CM_TIArray;
	request			: CM_Request;
	wle				: CM_WorkListEntry;
	lc				: CM_LocationsController;
	ti1				: CM_Container;
	tiArray			: CM_TIArray;
	
	rtqEntry		: CM_RTQueueEntry;
	qTIArray		: CM_TIArray;
	item			: CM_TrackedItem;
begin
	self.deleteTerminalArea("RORO10");
	roroArea := self.addROROArea("RORO10", 5, 20);
	self.assertNotNull(roroArea);
	
	self.deleteVoyage(VoyageNameImport);
	voyageImport := self.getVoyage(VoyageNameImport);
	self.assertIsDeleted(voyageImport);
	
	self.deleteVoyage(VoyageNameExport);
	voyageExport := self.getVoyage(VoyageNameExport);
	self.assertIsDeleted(voyageExport);
	
	self.deleteVessel(ShipNameImport);
	vessel := self.getVessel(ShipNameImport);
	self.assertIsDeleted(vessel);
	
	self.deleteVessel(ShipNameExport);
	vessel := self.getVessel(ShipNameExport);
	self.assertIsDeleted(vessel);
	
	// Create import voyage
	vessel := self.addVesselCellular(ShipNameImport, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add import vessel failed');

	voyageImport := self.addVoyageWithContainerStructur(VoyageNameImport,
													ShipNameImport,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg(voyageImport, 'Add import voyage failed');
	voyageImport := self.getVoyage(VoyageNameImport);
	self.assertNotNull(voyageImport);

	// Create Export voyage
	vessel := self.addVesselCellular(ShipNameExport, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add export vessel failed');

	voyageExport := self.addVoyageWithContainerStructur(VoyageNameExport,
													ShipNameExport,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg(voyageExport, 'Add export voyage failed');
	voyageExport := self.getVoyage(VoyageNameExport);
	self.assertNotNull(voyageExport);
	
	// delete container if left onsite by incomplete last run of the test
	
	self.deleteContainer(ContainerID1);
	ti := self.getTrackedItem(ContainerID1);
	self.assertNull(ti);
	
	// create container on import voyage
	self.deleteContainerOnVoyage(ContainerID1, VoyageNameImport);
	
	pxyTI := self.createContainer(ContainerID1, "2010", "FOIL", app.myRoot.allOperators[TestOperator], true);
	pxyTI.setTotalWeight(12000, null, null);
	pxyTI.setWeightTare(2000);
	pxyTI.setDischargePort('NZPOE');
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_REMAINONBOARD);
	pxyTI.setMyVoyage(voyageImport, app.myPassport);
	pxyTI.changeState(TI_STATE_ONSHIP, app.myPassport);
	ti := self.addContainerFromProxyToLC(pxyTI, VoyageNameImport&amp;' 010682');
	
	// now make it a tranship
	create controller transient;
	controller.allTrackedItems.add(ti);
	controller.myExportDestPort 	:= app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort 		:= app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage 		:= voyageExport;
	controller.remarks 				:= "UT Tranship";
	//controller.removeStops 			:= true; // TFS 47222 jlgzm1 20/11/2019
	self.makeTrackedItemTranship(controller);
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item is not Tranship");
	self.assertEqualMsg(ti.myExportVoyage, voyageExport, "TI has wrong export voyage:1");
	self.assertEqualMsg(ti.myImportVoyage, voyageImport, "TI has wrong import voyage:1");
	self.assertEqualMsg(ti.myVoyageTranshipExport, voyageExport, "TI has wrong myVoyageTranshipExport:1");
	self.assertEqualMsg(ti.myVoyageTranshipImport, voyageImport, "TI has wrong myVoyageTranshipImport:1");
	self.assertEqualMsg(ti.myVoyage, voyageImport, "TI myVoyage reference is not the import voyage");
	
	
	// create the crane transfer area
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CTAId);
	cta := self.addCraneTransferArea(CTAId);
	self.assertNotNull(cta);
	
	// add the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	//self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(voyageImport.code, "01", DeckOnDeck, 1, 1, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	
	voyageDischJob := self.addVoyageJob(voyageImport, crane.id, slotsFrom, true);
	assertTrue(voyageDischJob &lt;&gt; null);
	
	// discharge the following slots
	self.loadAllJobsToOps(voyageImport, true);
	
	// queue the cargo
	create requireDischarge transient;
	requireDischarge.add(voyageImport.allOnshipTIsByCargoTypeId[1, ContainerID1]);
	
	// Queue the required containers
	slotsFrom.clear();
	foreach request in voyageDischJob.allRequests do
		foreach wle in request.allWorkListEntries do
			if wle.CM_VoyageWLE.myRequest.CM_SlotRequest.isDischarge then
				if requireDischarge.includes(wle.myTrackedItem) then
					slotsFrom.add(wle.CM_VoyageWLE.myRequest.CM_SlotRequest.mySlotController);
					self.autoplanWLE(wle);
					self.deleteStops(wle.myTrackedItem);
					self.moveQueuedCargo(wle);
				endif;
			endif;
		endforeach;
	endforeach;
	
	// move first container to RORO area
	self.move(ti, roroArea);
	
	// create another container in RORO area
	self.deleteContainer("CONTR00002");
	ti1 := self.addContainerAtLocation("CONTR00002", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", "APPL", TI_IMEX_STATUS_EXPORT, roroArea.allLocationsControllers.first);
	
	// shuffle the two containers in RORO area
	create tiArray transient;
	tiArray.add(ti);
	app.myTrxUA.trxUpdateSlotControllerShuffle(tiArray, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	
	// actual test - voyage outbound is still set on Tranship container after shuffle
	self.assertEqual(ti.voyageOutbound(), voyageExport);
	delete tiArray;
	
	// Shuffle two containers onship and test that containers are all still  'site' = 'on ship'			TFS 2050	cnwmk3/14/06/2016
	self.deleteContainerOnVoyage("CONTR002050", VoyageNameExport);
	
	pxyTI := self.createContainer("CONTR002050", "2010", "FOIL", app.myRoot.allOperators[TestOperator], true);
	pxyTI.setTotalWeight(12000, null, null);
	pxyTI.setWeightTare(2000);
	pxyTI.setDischargePort('NZPOE');
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_REMAINONBOARD);
	pxyTI.setMyVoyage(voyageImport, app.myPassport);
	pxyTI.changeState(TI_STATE_ONSHIP, app.myPassport);
	ti := self.addContainerFromProxyToLC(pxyTI, VoyageNameExport&amp;' 010682');
	
	self.deleteContainerOnVoyage("CONTR002051", VoyageNameExport);
	
	pxyTI := self.createContainer("CONTR002051", "2010", "FOIL", app.myRoot.allOperators[TestOperator], true);
	pxyTI.setTotalWeight(12000, null, null);
	pxyTI.setWeightTare(2000);
	pxyTI.setDischargePort('NZPOE');
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_REMAINONBOARD);
	pxyTI.setMyVoyage(voyageImport, app.myPassport);
	pxyTI.changeState(TI_STATE_ONSHIP, app.myPassport);
	ti2 := self.addContainerFromProxyToLC(pxyTI, VoyageNameExport&amp;' 010684');
	
	create tiArray transient;
	tiArray.add(ti);
	tiArray.add(ti2);
	app.myTrxUA.trxUpdateSlotControllerShuffle(tiArray, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti.site, TI_SITE_ONSHIP);
	self.assertEqual(ti2.site, TI_SITE_ONSHIP);
epilog
	delete controller;
	delete tas;
	delete requireDischarge;
	delete slotsFrom;
	delete tiArray;
	delete qTIArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTestTranshipLifecycle" id="07af357d-eca0-49f3-b421-913eaa4644f5">
        <updating/>
        <source>tTestTranshipLifecycle() updating;
// cnwdap1
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/06/2010	cnwdap1	Initial creation CCMS 1116 Tranship changes
04/04/2012	cnwdap1	PAR #29378 include check for planning from import voyage to export voyage and unplanning again
10 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
*/
constants
	VoyageNameImport 	= 'VOY01TSHIP';
	VoyageNameExport 	= 'VOY02TSHIP';
	ShipNameImport 		= 'IMPSHIP';
	ShipNameExport 		= 'EXPSHIP';
	TestOperator 		= 'MSK';
	UserDefinedTranship	= 'Unit Test Tranship';
	ContainerID1 		= "UTTR0000001";
	ContainerID2 		= "UTTR0000002";
vars
	voyageImport 	: CM_Voyage;
	voyageExport 	: CM_Voyage;
	vessel 			: CM_Vessel;
	pxyTI, ti		: CM_TrackedItem;
	controller		: CMIF_TranshipTIController;
	locations 		: CM_LCArray;
	ya				: CM_YardAllocation;
	location		: CM_LocationsController;
	ta				: CM_GridArea;
	slots 			: CM_SlotControllerArray;
	tmpLoadCC		: CMIF_LoadColorCode;
	voyageJob 		: CM_VoyageJob;
	tis				: CM_TIArray;
	wlesToMove, 
	wlesWithWarning : CM_WLEArray;
	completedDate 	: TimeStamp;
	job				: CM_Job;
	wle				: CM_WorkListEntry;
	trxn			: CM_TITransaction;
	allowRTS		: Boolean;
begin

	allowRTS := self.setTerminalConfig(AllowRTSwithoutVGM, true).Boolean;
	
	self.deleteVoyage(VoyageNameImport);
	voyageImport := self.getVoyage(VoyageNameImport);
	self.assertIsDeleted(voyageImport);
	
	self.deleteVoyage(VoyageNameExport);
	voyageExport := self.getVoyage(VoyageNameExport);
	self.assertIsDeleted(voyageExport);
	
	self.deleteVessel(ShipNameImport);
	vessel := self.getVessel(ShipNameImport);
	self.assertIsDeleted(vessel);
	
	self.deleteVessel(ShipNameExport);
	vessel := self.getVessel(ShipNameExport);
	self.assertIsDeleted(vessel);
	
	// Create import voyage
	vessel := self.addVesselCellular(ShipNameImport, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add import vessel failed');

	// Note: This picks up the profile system Trade eg "Unit Test Trade"
	voyageImport := self.addVoyageWithContainerStructur(VoyageNameImport,
													ShipNameImport,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg(voyageImport, 'Add import voyage failed');
	voyageImport := self.getVoyage(VoyageNameImport);
	self.assertNotNull(voyageImport);

	// Create Export voyage
	vessel := self.addVesselCellular(ShipNameExport, self.getOperator(TestOperator));
	self.assertNotNullMsg(vessel, 'Add export vessel failed');

	voyageExport := self.addVoyageWithContainerStructur(VoyageNameExport,
													ShipNameExport,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
	self.assertNotNullMsg(voyageExport, 'Add export voyage failed');
	voyageExport := self.getVoyage(VoyageNameExport);
	self.assertNotNull(voyageExport);

	// create container on import voyage
	self.deleteContainerOnVoyage(ContainerID1, VoyageNameImport);
	
	pxyTI := self.createContainer(ContainerID1, "2010", "FOIL", app.myRoot.allOperators[TestOperator], true);
	pxyTI.setTotalWeight(12000, null, null);
	pxyTI.setWeightTare(2000);
	pxyTI.setDischargePort('NZPOE');
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_REMAINONBOARD);
	pxyTI.setMyVoyage(voyageImport, app.myPassport);
	pxyTI.changeState(TI_STATE_ONSHIP, app.myPassport);
	ti := self.addContainerFromProxyToLC(pxyTI, VoyageNameImport&amp;' 010682');
	
	// now make it a tranship
	create controller transient;
	controller.allTrackedItems.add(ti);
	controller.myExportDestPort 	:= app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort 		:= app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage 		:= voyageExport;
	controller.remarks 				:= "UT Tranship";
	//controller.removeStops 			:= true; // TFS 47222 jlgzm1 20/11/2019
	self.makeTrackedItemTranship(controller);
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item is not Tranship");
	self.assertEqualMsg(ti.myExportVoyage, voyageExport, "TI has wrong export voyage:1");
	self.assertEqualMsg(ti.myImportVoyage, voyageImport, "TI has wrong import voyage:1");
	self.assertEqualMsg(ti.myVoyageTranshipExport, voyageExport, "TI has wrong myVoyageTranshipExport:1");
	self.assertEqualMsg(ti.myVoyageTranshipImport, voyageImport, "TI has wrong myVoyageTranshipImport:1");
	self.assertEqualMsg(ti.myVoyage, voyageImport, "TI myVoyage reference is not the import voyage");
	
	// PAR #29378 now test planning the tranship to the export voyage
	// create export voyage job and slots
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType := true;
	tmpLoadCC.myDischargePort := app.myRoot.allPorts["NZAKL"];
	self.getJobSlotControllers(voyageExport.code, "01", DeckOnDeck, 1, 1, 1, slots);
	self.markSlotsAsLoadJob(slots, tmpLoadCC);
	voyageJob := self.addVoyageJob(voyageExport, "CRN1", slots, false);
	assertTrue(voyageJob &lt;&gt; null);
	// plan item
	self.planLoadItem(voyageExport, "CRN1");
	// check voyage is still the import voyage
	assertTrueMsg(ti.myVoyage = ti.myImportVoyage, "planning TI to export voyage - has wrong voyage");
	// unplan the TI
	self.unplanTI(ti);
	// PAR #29378 end of planning and unplanning to export voyage
	
	// now plan and move the TI to the yard
	deleteTerminalArea("UTSTRD");
	ta := addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");
	
	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, TestOperator, locations);
	
	location := app.autoPlanTiYA(self.getTerminal, ta, ti);
	self.assertEqualMsg(location, locations.first, "Did not autoplan ti");
	self.opts.purge();																					// 15/10/2013 cnwmh5
	self.opts.addAssoc('isForcedMove', true);															// 15/10/2013 cnwmh5
	self.move(ti, location);
	self.assertEqualMsg(ti.myPrimaryActualLocation, location, "Did not move ti");
	self.assertEqualMsg(ti.myVoyage, voyageExport, "TI myVoyage reference is not the export voyage");
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item is not Tranship after plan/move off import voyage");
	self.assertEqualMsg(ti.myExportVoyage, voyageExport, "TI has wrong export voyage:2");
	self.assertEqualMsg(ti.myImportVoyage, voyageImport, "TI has wrong import voyage:2");
	self.assertEqualMsg(ti.myVoyageTranshipExport, voyageExport, "TI has wrong myVoyageTranshipExport:2");
	self.assertEqualMsg(ti.myVoyageTranshipImport, voyageImport, "TI has wrong myVoyageTranshipImport:2");
	self.opts.purge();																					// 15/10/2013 cnwmh5
	
	// now plan and move the TI to the export voyage
	// remove stops
	opts.addAssoc("CENum", "123");
	self.deleteStops(ti);
	// mark as ready to ship
	create tis transient;
	voyageExport.allOnsiteTIsByCargoTypeId.copy(tis);
	app.myTrxUA.trxUpdateTIsReadyToShip(tis, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());
	// create voyage job and slots - PAR #29378 don't need to do this here any more, we've already done it
	//create slots transient;
	//create tmpLoadCC transient;
	//tmpLoadCC.overrideMoveType := true;
	//tmpLoadCC.myDischargePort := app.myRoot.allPorts["NZAKL"];
	//self.getJobSlotControllers(voyageExport.code, "01", DeckOnDeck, 1, 1, 1, slots);
	//self.markSlotsAsLoadJob(slots, tmpLoadCC);
	//voyageJob := self.addVoyageLoadJob(voyageExport, "CRN1", slots, false);
	assertTrue(voyageJob &lt;&gt; null);
	// plan item
	self.planLoadItem(voyageExport, "CRN1");
	// now move it
	create wlesToMove transient;
	create wlesWithWarning transient;
	foreach job in voyageExport.allVoyageJobs discreteLock do
		if job.CM_VoyageJob.isHatchLidJob() then
			continue;
		endif;
		foreach wle in job.workListEntries discreteLock do
			wlesToMove.clear();
			wlesWithWarning.clear();
			wlesToMove.add(wle);
			app.myTrxUA.trxUpdateWLEsDoMove(wlesToMove, wlesWithWarning, REAL_MODE, true, null,app.myPassport);

			self.assertTrueMsg(wlesWithWarning.isEmpty(), "Not all jobs completed &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
			process.sleep(5000);
		endforeach;
		beginTransaction;
		job.CM_VoyageJob.updateActualAndEndTs(completedDate);
		commitTransaction;
	endforeach;
	self.assertEqualMsg(ti.myVoyage, voyageExport, "TI myVoyage reference is not the export voyage after move to export voyage");
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_TRANSHIP, "Tracked item is not Tranship after plan/move on to export voyage");
	self.assertEqualMsg(ti.myExportVoyage, voyageExport, "TI has wrong export voyage:3");
	self.assertEqualMsg(ti.myImportVoyage, voyageImport, "TI has wrong import voyage:3");
	self.assertEqualMsg(ti.myVoyageTranshipExport, voyageExport, "TI has wrong myVoyageTranshipExport:3");
	self.assertEqualMsg(ti.myVoyageTranshipImport, voyageImport, "TI has wrong myVoyageTranshipImport:3");
	
	self.assertEqualMsg(countTransactionsOfType(ti, TRANS_TYPE_REL_SHIP), 1, "No ReleaseShip transaction");		//06/04/2016	cnwmk3	TFS 1697
	foreach trxn in ti.allTransactions do
		if trxn.isKindOf(CM_ReleaseShip) then
			self.assertEqual(trxn.getMyVoyage(), voyageExport);
			self.assertEqual(trxn.voyageCode, voyageExport.code);
		endif;
	endforeach;
epilog
	delete controller;
	//delete pxyTI;		pxyTI is deleted inside utlCreateTrackedItem when CMIF_TIUpdateController is deleted
	delete locations;
	delete slots;
	delete tmpLoadCC;
	delete tis;
	delete wlesToMove;
	delete wlesWithWarning;
	self.setTerminalConfig(AllowRTSwithoutVGM, allowRTS);
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;fails16092014&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;fails16092014_2&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
