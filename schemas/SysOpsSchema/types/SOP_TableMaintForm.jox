    <JadeMethod name="getTableItemForClass" id="1c8ac0ff-4bb6-4f5a-9b91-918aa9af6b90">
        <source>getTableItemForClass(_class : Class) : SOP_TableMaintItem;
// ---------------------------------------------------------------------------
// Created:     22 July 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpTableItem : SOP_TableMaintItem;
	
begin

	if self.allTableItems.isEmpty then
		return null;
	endif;

	foreach tmpTableItem in self.allTableItems do
		if _class.inheritsFrom(tmpTableItem.myDataClass) then
			return tmpTableItem;
		endif; 
	endforeach;

	return null;
	
end;</source>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="SOP_TableMaintItem"/>
    </JadeMethod>
    <JadeMethod name="getWeighFormObjects" id="1eaaa321-d1b3-45ce-ab82-6c302eb7570b">
