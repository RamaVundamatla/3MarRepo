    <JadeMethod name="getDisplayStringForAttribute" id="3ddbe8ba-70f1-43d4-966f-dd5d5a147dac">
        <source>getDisplayStringForAttribute(_name: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _name = ETRow_Description then
		return self.getSubjectIdString;
	elseif _name = ETRow_AuditType then
		return self.typeCode;
	elseif _name = ETRow_DateTime then
		return self.systemToLocalTime(self.timestamp).shortCurrentLocaleFormatSecs;	// 5/5/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _name = ETRow_UserCode then
		return self.userCode; 
	elseif _name = ETRow_UserName then
		return self.getUserName;
	elseif _name = ETRow_UpdateType then
		return self.locationUpdateTypeStr;
	elseif _name = ETRow_UpdateMode then
		return self.getLocationUpdateModeStr;
	elseif _name = ETRow_Locations then
		return self.locationStr;
	elseif _name = ETRow_Details then
		return self.locationUpdateDetails;
	elseif _name = ETRow_Comment then
		return self.remarks;
	endif;
	
	return inheritMethod(_name, _short);

epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationUpdateModeStr" id="49f9f70e-2212-4cd4-b37b-a26ab375ec35">
        <source>getLocationUpdateModeStr():String protected;
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.locationUpdateMode = AuditCreated then
		return app.getErrorString (Added_InitCaps);
	elseif self.locationUpdateMode = AuditUpdated then
		return app.getErrorString (Updated);
	elseif self.locationUpdateMode = AuditDeleted then
		return app.getErrorString (Removed);
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationUpdateTypeStr" id="a17782d4-f7ae-4a55-8dd2-041267e001ea">
        <source>getLocationUpdateTypeStr(_type :Integer):String protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2011 by cnwcs5 CCMS CPL 2027/PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _type = self.LocnTypeUpdate_HeightRestrict then
		return app.getErrorString (XLAT_LU_HeightRestriction);
	elseif _type = self.LocnTypeUpdate_PowerAvail then
		return app.getErrorString (XLAT_LU_PowerAvailability);
	elseif _type = self.LocnTypeUpdate_PowerDamage then
		return app.getErrorString (XLAT_LU_PowerDamage);
	elseif _type = self.LocnTypeUpdate_TwinLiftDefn then
		return app.getErrorString (XLAT_LU_TwinLiftDef);
	elseif _type = self.LocnTypeUpdate_ContainerLength then
		return app.getErrorString (XLAT_LU_StrictGridCL);
	elseif _type = self.LocnTypeUpdate_Overlapping then
		return app.getErrorString (XLAT_LU_BlockStackOL);
	elseif _type = self.LocnTypeUpdate_DoorDirRules then
		return app.getErrorString (XLAT_LU_DoorDirRules);
	elseif _type = self.LocnTypeUpdate_ReeferGantry then
		return app.getErrorString (XLAT_LU_ReeferGantry);
	elseif _type = self.LocnTypeUpdate_LabRestrict then
		return app.getErrorString (XLAT_LU_LabourRestriction);
	elseif _type = self.LocnTypeUpdate_LocationAvail then
		return app.getErrorString (XLAT_LU_LocationAvailability);
	elseif _type = self.LocnTypeUpdate_LocationUnavail then
		return app.getErrorString (XLAT_LU_LocationUnavailable);
	else
		return app.getErrorString (Unknown);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationsString" id="ab622396-d4f9-4745-91cf-f145089a5f4f">
        <source>getLocationsString(_locations :CM_LCSet):String protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2011 by cnwcs5 CCMS CPL 2027/PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	subject, obj	:Object;
	loc, prevLoc	:CM_LocationsController;
	str, id,
	range1, range2	:String;
	gotException	:Boolean;
	dd				:DynaDictionary;
begin
	if self.locationUpdateType = self.LocnTypeUpdate_Overlapping then
		return app.getErrorString (CM_LIT_ALL);
	endif;
	
	on Exception do app.handleDeletedObject (exception, loc, gotException);

	subject := self.mySubject;
	
	// if it is not a gridded area then we just concatentat all the locations - quicker.
	if subject = null or 
		not subject.isKindOf (CM_TerminalArea) or
		not subject.CM_TerminalArea.isGridArea then 
		foreach loc in _locations do
			if str = null then
				str := loc.ident;
			else
				str := str &amp; ", " &amp; loc.getID;
			endif;
		endforeach;
		
	else 
		create dd transient;
		dd.setMembership (CM_LocationsController);
		dd.addExternalKey (String, 30, false, true);
		dd.endKeys (true);
		
		foreach loc in _locations do
			dd[loc.getID] := loc;
		endforeach;
		
		foreach obj in dd do
			loc 	:= obj.CM_LocationsController;

			if prevLoc &lt;&gt; null then 
				if not loc.isKindOf (CM_GridController) or
					loc.CM_GridController.myPreviousController &lt;&gt; prevLoc then
					// starting new range - append old range
					if range1 = range2 then
						id := range1;
					else
						id := range1 &amp; '-' &amp; range2;
					endif;
					
					if str = null then
						str := id;
					else
						str := str &amp; ", " &amp; id;
					endif;		
					// start new range
					range1 := loc.getID;
				endif;
			else
				// start first range
				range1 := loc.getID;
			endif;
			prevLoc := loc;
			range2  := loc.getID;
		endforeach;
		// output final range
		if prevLoc &lt;&gt; null then
			if range1 = range2 then
				id := range1;
			else
				id := range1 &amp; '-' &amp; range2;
			endif;
			
			if str = null then
				str := id;
			else
				str := str &amp; ", " &amp; id;
			endif;	
		endif;
	endif;
	
	return str;
epilog
	delete dd;
end;</source>
        <access>protected</access>
        <Parameter name="_locations" type="CM_LCSet"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="locationUpdateTypeStr" id="8bd73fb8-20b9-4880-aff4-60df7478f7a5">
        <methodInvocation>mapping</methodInvocation>
        <source>locationUpdateTypeStr(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     01 March 2011 by cnwcs5  CCMS CPL 2027/PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if set then
		// set code here
	else
		// get code here
		_value := self.getLocationUpdateTypeStr (self.locationUpdateType)[1:100];
	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3a125df2-9577-4ea2-aea0-8d1785da63dc">
        <updating/>
        <source>setForCreate(_subject: CM_TerminalAreaMaster; _type: Integer; _config : CM_AuditConfig;
				_locations :CM_LCSet; _locType, _locMode :Integer; _details :String)updating;
// ---------------------------------------------------------------------------
// Created:     02 March 2011 by cnwcs5 CCMS CPL 2027/PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/03/2019	jlgzm1		TFS43830 no details visible on Audit details form
// ---------------------------------------------------------------------------
vars
	loc				: CM_LocationsController;
	strLoc			: String;
	beforeStr 		: String; //tfs43830
	afterStr 		: String; //tfs43830
	auditDetails 	: String; //tfs43830
begin
	// first set all the superclass fields
	self.updateForCreate (_subject, _type, _config);

	self.locationUpdateDetails 	:= _details;
	self.locationUpdateType		:= _locType;
	self.locationUpdateMode		:= _locMode;

	_locations.copy (self.allLocations);

	self.locationStr := self.getLocationsString (self.allLocations);
	
	//tfs43830 start
	//Set Before Audit text
	//don't know subject's previous state so just adding location ids and leaving rest blank
	beforeStr[10000] := '*';
	beforeStr := null;
	self.auditText	:= beforeStr &amp; self.locationStr  &amp;  AuditStringSeparator &amp; "0"  &amp; AuditStringSeparator &amp; "" &amp; AuditStringSeparator;
	
	//after audit
	//set locations and details string
	afterStr[10000] := '*';
	afterStr := null;
	auditDetails := self.getLocationUpdateTypeStr(_locType) &amp; " - " &amp; self.getLocationUpdateModeStr &amp; " - " &amp;_details;
	self.postAuditText	:= afterStr &amp; self.locationStr  &amp;  AuditStringSeparator &amp; auditDetails.length.String  &amp; AuditStringSeparator &amp; auditDetails &amp; AuditStringSeparator;
	//tfs43830 end
	
epilog

end;</source>
        <Parameter name="_subject" type="CM_TerminalAreaMaster"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_config" type="CM_AuditConfig"/>
        <Parameter name="_locations" type="CM_LCSet"/>
        <Parameter name="_locType" type="Integer"/>
        <Parameter name="_locMode" type="Integer"/>
        <Parameter name="_details" type="String"/>
    </JadeMethod>
    <JadeMethod name="setRemarks" id="040431e7-f937-492a-97ed-effe08192ec5">
        <updating/>
        <source>setRemarks(_remarks :String)updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
