    <JadeMethod name="getDisplayStringForAttribute" id="ece2ea90-ecde-4d93-a7b4-1e35437d9916">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2023 navtnr20	TFS CR 58224	Task 58225: UI - Change of Ownership Enquiry
30/11/2023	navkc1 ChangeRequest 58254 Task 61099: UI - Ownership Change Approved
*/

vars
	cooFinancial 	: CM_OwnershipChangeFinancial;
	invoiceLine		: CM_InvoiceLine;
	invoice			: CM_Invoice;
	bank		 	: CM_Bank;
	debtor		 	: CM_Debtor; 
	ti				: CM_TrackedItem;
	stoDtl			: CM_StorageDetail;
	str				: String;
	type 			: String;
begin
	cooFinancial := self.allFinancialIssues.first(); //19/08/2024	navkc1 CR 65246  Task 65697
	if cooFinancial &lt;&gt; null then
		invoiceLine := cooFinancial.myInvoiceLine;
		if invoiceLine &lt;&gt; null then
			invoice := invoiceLine.invoice;
		endif;
		if invoice &lt;&gt; null then
			debtor := invoice.debtor;
			bank := invoice.bank;
		endif;
	endif;
	
	if _attrName = ETRow_ReferenceNumber then
		return self.refNumber.asStringJMT;
	elseif _attrName = ETRow_DateTime  then
		return self.systemToLocalTime(self.dateTimeCOO).asStringJMT();
	elseif	_attrName = ETRow_OperatorOldCode then
		if self.myOperatorOld &lt;&gt; null then
			return self.myOperatorOld.code;
		endif;
	elseif	_attrName = ETRow_OperatorOldDesc then
		if self.myOperatorOld &lt;&gt; null then
			return self.myOperatorOld.description;
		endif;
	elseif	_attrName = ETRow_OperatorNewCode then
		if self.myOperatorNew &lt;&gt; null then
			return self.myOperatorNew.code;
		endif;
	elseif	_attrName = ETRow_OperatorNewDesc then
		if self.myOperatorNew &lt;&gt; null then
			return self.myOperatorNew.description;
		endif;
	elseif	_attrName = ETRow_OperatorForStorageCode then
		if self.myOperatorStorage &lt;&gt; null then
			return self.myOperatorStorage.code;
		endif;
	elseif	_attrName = ETRow_OperatorForStorageDesc then
		if self.myOperatorStorage &lt;&gt; null then
			return self.myOperatorStorage.description;
		endif;
	elseif	_attrName = ETRow_FreightForwarderCode then
		if  self.myFreightForwarder &lt;&gt; null then
			return self.myFreightForwarder.code;
		endif;
	elseif	_attrName = ETRow_FreightForwarderDesc then
		if  self.myFreightForwarder &lt;&gt; null then
			return self.myFreightForwarder.description;
		endif;
	elseif	_attrName = ETRow_IncoTermCode then
		if self.myIncoterm &lt;&gt; null then
			return self.myIncoterm.code;
		endif;
	elseif	_attrName = ETRow_IncoTermDesc then
		if self.myIncoterm &lt;&gt; null then
			return self.myIncoterm.description;
		endif;
	elseif	_attrName = ETRow_Condition then
		return self.condition;
	elseif	_attrName = ETRow_OperatorNewFreedays then
		return self.freeDaysOperatorNew.String;
	elseif	_attrName = ETRow_StorageExpiryOperatorNew then
		// ### TFS BUG 64680 17JUNE024 NAVAB1 return self.systemToLocalTime(self.getFreeStorageExpiry).asStringJMT;
		return self.systemToLocalTime(self.storageExpiryOperatorNew).asStringJMT;
	elseif	_attrName = ETRow_Approved then
		return self.isApproved().getYes(); // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
	elseif	_attrName = ETRow_ApprovedDate then
		return self.dateTimeApproved.asStringJMT;
	elseif	_attrName = ETRow_FreeDaysOperatorOld then
		// ### TFS BUG 64126 14MAY2024 NAVAB1
		if self.freeDaysOperatorOld &gt; 0 then
			return freeDaysOperatorOld.asStringJMT();
		else
			return self.getFreeStorage();
		endif;
	elseif	_attrName = ETRow_FreeDaysAdditional then
		return self.freeDaysAdditional.String;
	elseif	_attrName = ETRow_HasAttachment then
		return self.hasAttachements().asStringJMT();
	elseif	_attrName = ETRow_Remarks then
		return self.remarks;
	elseif	_attrName = ETRow_CargoTypeCode then
		return self.getCargoTypeCode();
	elseif	_attrName = ETRow_CargoTypeDescription then
		return self.getCargoTypeDesc();
	elseif	_attrName = ETRow_CargoSubtypeCode then
		return self.getCargoSubTypeCode();
	elseif	_attrName = ETRow_CargoSubtypeDescr then
		return self.getCargoSubTypeDesc();
	elseif	_attrName = ETRow_Commodity then
		return self.getCommodityCode();
	elseif	_attrName = ETRow_CommodityDesc then
		return self.getCommodityDesc();
	elseif _attrName = ETRow_UserCodeApproved then
		return self.userCodeApproved; //30/11/2023	navkc1 ChangeRequest 58254 Task 61099
	//19/08/2024	navkc1 CR 65246  Task 65697 - Start
	elseif _attrName = ETRow_BusinessUnit then
		if bank &lt;&gt; null then
			return bank.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_DebtorCode then
		if debtor &lt;&gt; null then
			return debtor.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_DebtorLong then
		if debtor &lt;&gt; null then
			return debtor.longName;
		else
			return null;
		endif;
	elseif _attrName = ETRow_DebtorAddInfo1 then
		if debtor &lt;&gt; null then
			return debtor.additionalInformation1;
		else
			return null;
		endif;
	elseif _attrName = ETRow_DebtorAddInfo2 then
		if debtor &lt;&gt; null then
			return debtor.additionalInformation2;
		endif;
	elseif _attrName = ETRow_DebtorAccount then
		if debtor &lt;&gt; null then
			return debtor.decfinName;
		endif;
	elseif _attrName = ETRow_OwnershipChangeNo then
		return self.refNumber;
	elseif _attrName = ETRow_OwnershipChangeDt then
		return self.dateTimeCOO.asStringJMT();
	elseif _attrName = ETRow_CooIncotermCode then
		return self.getINCOTermCode();
	elseif _attrName = ETRow_PreviousOperatorCode then
		if self.myOperatorOld &lt;&gt; null then
			return self.myOperatorOld.code;
		endif;
	elseif _attrName = ETRow_OriginalOperatorCode then
		if self.myOperatorOrig &lt;&gt; null then
			return self.myOperatorOrig.code;
		endif;
	elseif _attrName = ETRow_CooIncotermDesc then
		return self.getINCOTermDesc();
	elseif _attrName = ETRow_PreviousOperatorDesc then
		if self.myOperatorOld &lt;&gt; null then
			return self.myOperatorOld.description;
		endif;
	elseif _attrName = ETRow_OriginalOperatorDesc then
		if self.myOperatorOrig &lt;&gt; null then
			return self.myOperatorOrig.description;
		endif;
	elseif _attrName = ETRow_StorageChargeOprCode then
		if self.myOperatorStorage &lt;&gt; null then
			return self.myOperatorStorage.code;
		endif;
	elseif _attrName = ETRow_StorageChargeOprDesc then
		if self.myOperatorStorage &lt;&gt; null then
			return self.myOperatorStorage.description;
		endif;
	elseif _attrName = ETRow_ImporterBuyerFreeDays then
		//19/08/2024	navkc1 CR 65246  Task 65697
		return self.freeDaysOperatorNew.asStringJMT();
	elseif _attrName = ETRow_FreeStorageDays then
		return self.freeDaysOperatorOld.asStringJMT();
	elseif _attrName = ETRow_CooFreeDays then
		//19/08/2024	navkc1 CR 65246  Task 65697
		//return self.freeDaysOperatorNew.asStringJMT(); 
		ti := self.getMyTrackedItem();
		if ti &lt;&gt; null then
			stoDtl := ti.getMatchingFreeStorageDetail(null);
		endif;
		
		if stoDtl &lt;&gt; null then
			return stoDtl.getCooFreeStorageDays();
		else
			return null;
		endif;
	elseif _attrName = ETRow_FreeStorageExpiryDate then
		return self.systemToLocalTime(self.storageExpiryOperatorNew).asStringJMT();
	elseif _attrName = ETRow_FutureStorageAnniversary then
		//19/08/2024	navkc1 CR 65246  Task 65697
		ti := self.getMyTrackedItem();
		if ti &lt;&gt; null then
			return ti.getFutureStorageAnniversary().asStringJMT();
		else
			return null;
		endif;
	//19/08/2024	navkc1 CR 65246  Task 65697 - End
	//23/10/2024	navkc1 JIRA Task MTN-19369 - Start
	elseif _attrName = ETRow_TransferQuantity then
		return self.getTransferQtyAccum().asStringJMT();
	elseif _attrName = ETRow_CurrentTotalQuantity then
		return self.getCurrentQtyAccum().asStringJMT();
	//23/10/2024	navkc1 JIRA Task MTN-19369 - End
	
	
	
	
	// #########################################################
	// ###### DO NOT PUT ANY NEW ETROWS AFTER THE FOLLOWING MEASUREMENT TYPE CODE
	// ###### ADD NEW ETROWS ABOVE THIS MEASUREMENT TYPE STATEMENT
	// #########################################################
	elseif _attrName.isMeasurementType() then //23/10/2024	navkc1 JIRA Task MTN-19369
		_attrName.getRowNameMeasureType(str, type);
		return self.getMeasurementStringForAttrib(str, type, _short);
	else
		return inheritMethod(_attrName, _short);
	endif;
	

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
