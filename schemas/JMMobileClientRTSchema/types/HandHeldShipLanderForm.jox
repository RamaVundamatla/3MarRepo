    <JadeMethod name="setLogicalFocus" id="e2ec2993-3dd8-4027-9806-fd98955bd00d">
        <source>setLogicalFocus() protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.fldMain.topSheet = self.shtError then
		self.txtWrongData.setFocus;
	elseif self.frmMain.visible then
		if self.txtVoyage.text = null then
			self.txtVoyage.setFocus();
		else
			self.txtVehicle.setFocus();
		endif;
	elseif self.frmFowardCont.visible then
		if self.txtIdFoward.text = null then
			self.txtIdFoward.setFocus();
		elseif self.txtSealCustFowar.text = null then
			self.txtSealCustFowar.setFocus();
		elseif self.txtSealOpFoward.text = null then
			self.txtSealOpFoward.setFocus();
		elseif self.txtSealShipFowar.text = null then
			self.txtSealShipFowar.setFocus();
		else
			self.txtIdFoward.setFocus();
		endif;
		
	elseif self.frmAftCont.visible then
		if self.txtIdAft.text = null then
			self.txtIdAft.setFocus();
		elseif self.txtSealCustAft.text = null then
			self.txtSealCustAft.setFocus();
		elseif self.txtSealOpAft.text = null then
			self.txtSealOpAft.setFocus();
		elseif self.txtSealShipAft.text = null then
			self.txtSealShipAft.setFocus();
		else
			self.txtIdAft.setFocus();
		endif;
	elseif self.frmDamage.visible then
		self.tblDamage.setFocus();
	endif;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="afd6eabb-1c1e-4399-b15b-f5bf426ad364">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	12 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
// 24 Jun 2009	epr 	Par 20080
*/
vars

begin
	inheritMethod();
	self.frmMain.zOrder(1);
	self.left := 0;
	self.top := 0;
	
	self.loadCmbRemarks();
	self.clearAllInfo(false);
	self.doShowFrmMain();
	
	self.shtExports.visible := false;
	
	self.caption := 'SHIP CHECKER';
	if not app.isRunningOnCE then 
		self.borderStyle := self.BorderStyle_Single;
		self.caption := 'SHIP CHECKER Dev mode ';
		self.height := self.height + 30;
	else
		self.borderStyle :=self.BorderStyle_None;
	endif;
	
	self.txtSealCustAft.maxLength := 35;
	self.txtSealCustAft.scrollVertical := true;
	self.txtSealOpAft.maxLength := 35;
	self.txtSealOpAft.scrollVertical := true;
	self.txtSealShipAft.maxLength := 35;
	self.txtSealShipAft.scrollVertical := true;

	self.txtSealCustFowar.maxLength := 35;
	self.txtSealCustFowar.scrollVertical := true;
	self.txtSealOpFoward.maxLength := 35;
	self.txtSealOpFoward.scrollVertical := true;
	self.txtSealShipFowar.maxLength := 35;
	self.txtSealShipFowar.scrollVertical := true;


end;


</source>
    </JadeMethod>
