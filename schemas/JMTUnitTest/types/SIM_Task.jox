    <JadeMethod name="getPrevMachineLastTask" id="0658dc72-574d-49b5-8d90-9f6a3a485039">
        <source>getPrevMachineLastTask(): SIM_Task;

vars
	prevTask: SIM_Task;
begin
	
	prevTask := self.myPrevTask;
	while prevTask &lt;&gt; null do
		if prevTask.getMachine &lt;&gt; self.getMachine then
			break;
		endif;
		prevTask := prevTask.myPrevTask;
	endwhile;
	return prevTask;
	
epilog

end;</source>
        <ReturnType type="SIM_Task"/>
    </JadeMethod>
