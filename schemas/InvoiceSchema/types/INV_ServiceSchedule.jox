    <JadeMethod name="setEnableControlsForObject" id="a371c3af-9135-40b6-b14e-5fb814e59b2e">
        <updating/>
        <source>setEnableControlsForObject(_servObj : CM_ServiceObject) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//	16/06/2022	jlizm1	TFS 52495 Disable editing of void service and invoice lines
// ---------------------------------------------------------------------------

vars
	theBank : CM_Bank;
	rootSG : CM_ServiceGroup;
begin
	theBank := _servObj.bank;
	if _servObj.isKindOf(CM_Service) then
		self.mnuServiceNew.enabled := true;
	
		self.mnuNewService.enabled := false;
		self.btnNew.enabled := false;
		self.mnuNewGroup.enabled := false;
		self.btnNewGroup.enabled := false;
	
		self.btnAudits.enabled := true;
		if _servObj.CM_Service.brokers.size &gt; 0 or _servObj.CM_Service.charges.size &gt; 0 then
			self.mnuServiceDelete.enabled := false;
			self.btnDelete.enabled := false;
		else
			self.mnuServiceDelete.enabled := app.myPassport.myUser.canDo(app.myPassport.myTerminal,PmAdmServicescheduleMaint);
			self.btnDelete.enabled := self.mnuServiceDelete.enabled;
		endif;
		
		if _servObj.isKindOf(CM_VoidService) then
			self.mnuServiceDelete.enabled := false;
			self.btnDelete.enabled := false;
			self.mnuServiceProperties.enabled := false;
			self.btnProperties.enabled := false;
		else
			self.mnuServiceProperties.enabled := true;
			self.btnProperties.enabled := true;
		endif;

	else
		self.mnuServiceNew.enabled := true;
		self.btnAudits.enabled := false;
	
		self.mnuNewService.enabled := true;
		self.btnNew.enabled := true;
		self.mnuNewGroup.enabled := true;
		self.btnNewGroup.enabled := true;
	
		if _servObj.CM_ServiceGroup.groupMembers.size = 0 then
			rootSG := theBank.getRootServiceGroup();
			if _servObj = rootSG then
				self.mnuServiceDelete.enabled := false;
				self.btnDelete.enabled := false;
			else
				self.btnDelete.enabled := app.myPassport.myUser.canDo(app.myPassport.myTerminal,PmAdmDebtorregisterMaint);
				self.mnuServiceDelete.enabled := self.btnDelete.enabled;
			endif;
		else
			self.mnuServiceDelete.enabled := false;
			self.btnDelete.enabled := false;
		endif;
		self.mnuServiceProperties.enabled := true;
		self.btnProperties.enabled := true;
	
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnProperties.enabled := false;
		self.mnuNewService.enabled := false;
		self.btnNew.enabled := false;
		self.mnuNewGroup.enabled := false;
		self.btnNewGroup.enabled := false;
		self.mnuServiceDelete.enabled := false;
		self.btnDelete.enabled := false;

	endif;
	
end;</source>
        <Parameter name="_servObj" type="CM_ServiceObject"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="4e90ad75-8e12-4c36-b883-1f0771b225d9">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	
	self.setNavigatorHeading(self.caption);
	self.frmProperties.height := PROPHEIGHT;
	inheritMethod();
	self.doCmbBankBuild;
	self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();			// 35872
//	TFS 2682	self.caption := self.myCurrentBank.code &amp; " Service Schedule";
	self.setCaption("Service Schedule " &amp; self.myCurrentBank.code);
	
	self.lstData.defaultLineHeight := 30; // ### TFS 50421 27OCT2021 NAVAB1
	self.lstData.fontSize := 10; // ### TFS 50421 27OCT2021 NAVAB1

	self.initPropertyTable(ETDef_InvMaint_Service);
	
	self.doBuildCmbGL();
	self.doBuildCmbRateType();
	self.doBuildCmbTax();
	self.doCmbCalcTypesBuild();
	
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_SERVICE_CREATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_SERVICE_DELETE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_SERVICE_UPDATE), Response_Continuous, null);
	self.loadServiceSchedule(false); // ### TFS 51912 14Sep2021 NAVPW1
	
//	if (not app.myCurrentUserCan(self.myTerminal, PmAdmServicescheduleMaint)) then
//		self.viewOnly := true;
//	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.viewOnly := true;
	
		self.btnProperties.enabled := false;
		self.mnuNewService.enabled := false;
		self.btnNew.enabled := false;
		self.mnuNewGroup.enabled := false;
		self.btnNewGroup.enabled := false;
		self.mnuServiceDelete.enabled := false;
		self.btnDelete.enabled := false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showAuditForm" id="37c7c8da-b38d-494e-a4d9-156abd1948a1">
        <source>showAuditForm();
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	cma : INV_AuditsInvoices;

begin

	app.mousePointer := MP_HOURGLASS;

	create cma;
	cma.myCurrentService := self.myCurrentServiceObject.CM_Service;
	cma.myTerminal := self.myTerminal;
	cma.createMyAssistant(INV_Assistant);
	cma.show;

epilog
	app.mousePointer := MP_DEFAULT;

end;</source>
    </JadeMethod>
    <JadeMethod name="showHookCodeMaintForm" id="2011181b-d9ec-43e6-81fd-275a65051dc0">
        <updating/>
        <source>showHookCodeMaintForm() updating;
// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice rate, allow edit
// 31451 May 2103 edit here is confusing and had bugs - make it readonly
vars
	rateHook	: Integer;
	hookType	: CM_HookType;
	calcType	: CM_CalculationType;
	source		: String;
	constantText	: String;
	methodName	: String;
	parentClass	: Class;
	formCaption	: String;
begin

	if self.myCurrentServiceObject = null then
		return;
	endif;
	if not self.myCurrentServiceObject.isKindOf(CM_Service) then
		return;
	endif;
	calcType :=	self.myCurrentServiceObject.CM_Service.myCalculationType;
	if calcType &lt;&gt; null and
	   calcType.myHookCodeRate &lt;&gt; null then
		source := calcType.myHookCodeRate.getCurrentJadeCode();
		if calcType.isVoyageCalcType then
			rateHook := HookType_HMSInvoiceRate;
		else
			rateHook := HookType_InvoiceRate;
		endif;
	else
		return;
	endif;
	
	hookType := app.myRoot.allHookTypes[rateHook];
	if hookType = null then
		return;
	endif;

	// show the calculation type in the header to make it clear this is not hook code for the service
	formCaption := "Calculation Type '" &amp; calcType.description &amp; "'";

	if calcType.isVoyageCalcType then
		constantText := app.getGlobalConstantText(HookTypes, "HookType_HMSInvoiceRate");
	else
		constantText := app.getGlobalConstantText(HookTypes, "HookType_InvoiceRate");
	endif;
	methodName := constantText.cnEcGetTagValueOfName('hookMethodName');
	parentClass := rootSchema.getSchema(PortSchemaName).getClass(constantText.cnEcGetTagValueOfName('hookClassType'));
	
	app.showHookCodeMaintForm2(hookType, source, true, methodName, parentClass, formCaption, false);

end;</source>
    </JadeMethod>
    <JadeMethod name="showProperties" id="e20acb83-2b79-4b5c-8bd1-83043183cc2e">
        <source>showProperties(_servObj : CM_ServiceObject);
// ---------------------------------------------------------------------------
// Created:		25 July 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 27/03/2018	jlgdap1		TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
// 29/3/22  jlier1	TFS 53286
vars
	hasHookCode	: Boolean;
	source	: String;
	theTable : CM_EntryTable;
begin
	theTable := self.tblProperties;

	theTable.setValueByName(ETRow_Name60, _servObj.name);
	theTable.setValueByName(ETRow_Remarks, _servObj.remarks);
	// don't show 'not available' for service groups or void service, just for regular CM_Service
	if _servObj.class.name = CM_Service.name then
		theTable.showRowByName(ETRow_IsNotAvailableForEntryCk, false);
		theTable.setValueByName(ETRow_IsNotAvailableForEntryCk, _servObj.isNotAvailableForEntry);
	else
		theTable.hideRowByName(ETRow_IsNotAvailableForEntryCk, false);
	endif;
	theTable.hideRowByName(ETRow_TaxCode, false);
	
	self.cmbGL.listObject := _servObj.genLCode;
	if _servObj.genLCode = null then
		self.cmbGL.listIndex := 1;
	endif;
	self.cmbGL.lostFocus(self.cmbGL);
	self.tblProperties.userInputEnabled := not self.viewOnly;

	if _servObj.isKindOf(CM_Service) then
		theTable.showRowByName(ETRow_TaxCode, false);
		if _servObj.CM_Service.defaultRateTable = CM_Service.DEFAULT_RATE_TABLE then
			self.cmbRateTypes.listIndex := 1;
		elseif _servObj.CM_Service.defaultRateTable = CM_Service.TRADE_RATE_TABLE then							//07.06.2018 cnwma1 ChangeRequest #38953
			self.cmbRateTypes.listIndex := self.cmbRateTypes.findString(1, app.getErrorString(Shipping_line_rate));
		elseif _servObj.CM_Service.defaultRateTable = CM_Service.VESSEL_RATE_TABLE then							// TFS 37794
			self.cmbRateTypes.listIndex := self.cmbRateTypes.findString(1, app.getErrorString(Vessel_rate));	// TFS 37794
		elseif _servObj.CM_Service.defaultRateTable = CM_Service.BERTH_RATE_TABLE then								//07.06.2018 cnwma1 ChangeRequest #38953
			self.cmbRateTypes.listIndex := self.cmbRateTypes.findString(1, app.getErrorString(Berth_rate));
		elseif _servObj.CM_Service.defaultRateTable = CM_Service.VESSELTYPE_RATE_TABLE then							//07.06.2018 cnwma1 ChangeRequest #38953
			self.cmbRateTypes.listIndex := self.cmbRateTypes.findString(1, app.getErrorString(VesselType_rate));
		elseif _servObj.CM_Service.defaultRateTable = CM_Service.VISITTYPE_RATE_TABLE then				//07.06.2018 cnwma1 ChangeRequest #38953
			self.cmbRateTypes.listIndex := self.cmbRateTypes.findString(1, app.getErrorString(VisitType_rate));
		else
			if self.cmbRateTypes.listCount =  2 then
				self.cmbRateTypes.listIndex := 2;
			else
				self.cmbRateTypes.listIndex := 1;
			endif;
		endif;
		self.cmbRateTypes.lostFocus(self.cmbRateTypes);
		
		if _servObj.CM_Service.myCalculationType &lt;&gt; null then

			self.addCurrentCT2Combo();
			// ### handle the calc type combo
			self.cmbCalcTypes.listObject := _servObj.CM_Service.myCalculationType;
			self.tblProperties.setValueByControlName(self.cmbCalcTypes.name,self.cmbCalcTypes.text);
			if _servObj.CM_Service.myCalculationType &lt;&gt; null and
			   _servObj.CM_Service.myCalculationType.myHookCodeRate &lt;&gt; null then
				source := _servObj.CM_Service.myCalculationType.myHookCodeRate.getCurrentJadeCode();
				if source &lt;&gt; null then
					theTable.setValueByName(ETRow_RateHookCode, app.getErrorString(Doubleclick_view));
					hasHookCode := true;
					theTable.showRowByName(ETRow_RateHookCode, false);
				endif;
			endif;
		endif;
		// 31451 May 2013 calc type hook code is view-only now
		if not hasHookCode then
			theTable.hideRowByName(ETRow_RateHookCode, false);
		endif;

		self.cmbTaxCode.listObject := _servObj.myTaxCode;
		if _servObj.myTaxCode = null then
			self.cmbTaxCode.listIndex := 1;
		endif;
		self.cmbTaxCode.lostFocus(self.cmbTaxCode);
		
		theTable.setValueByName(ETRow_ExternalReference1, _servObj.CM_Service.externalReference1);
		theTable.setValueByName(ETRow_ExternalReference2, _servObj.CM_Service.externalReference2);

	endif;
	
	
end;</source>
        <Parameter name="_servObj" type="CM_ServiceObject"/>
    </JadeMethod>
    <JadeMethod name="showPropertyFrame" id="f276cc3e-eb80-4f8a-b28d-9468e8d43ff3">
        <updating/>
        <source>showPropertyFrame(_entTableView: String; _mode: Integer; _actualHeight: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/3/22  jlier1	TFS 53286
vars

begin
	inheritMethod(_entTableView, _mode, _actualHeight);
	
	// TFS 2065 for a new service the remarks was aligned in the middle of the text box but when displayed with data were aligned at top/left (from table setValue)
	//   so align it top/left here for consistency
	self.tblProperties.optimiseHeadingColumn();
	self.lstData.enabled := false;
	self.frmToolbar.enabled := false;
	
end;</source>
        <Parameter name="_entTableView" type="String"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_actualHeight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showSearchFrame" id="ebbb6a00-6e48-4de4-a43c-4f9380b95d65">
        <updating/>
        <source>showSearchFrame() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.lblSearch.caption := "Service";
	// 35872 only show Business Unit if more than one
	if self.cmbBank.listCount &lt; 2 then
		self.lblBank.visible := false;
		self.cmbBank.visible := false;
		self.lblSearch.top := self.lblBank.top;
		self.txtSearch.top := self.cmbBank.top;
		self.frmSearch.height := 82;
		
		
	endif;
	
	self.lblBank.top := self.frmSeachToolbar.height; // ### TFS 50421 17SEP2021 NAVAB1
	self.cmbBank.top := self.lblBank.top + self.lblBank.height; // ### TFS 50421 17SEP2021 NAVAB1
	self.lblSearch.top := self.cmbBank.top  + self.lblBank.height; // ### TFS 50421 17SEP2021 NAVAB1
	self.txtBank.visible := false; // ### TFS 50421 17SEP2021 NAVAB1

	inheritMethod();

end;</source>
    </JadeMethod>
