    <JadeMethod name="doMaintainBOL" id="504573c4-4576-406e-a4ae-af4c2bd5c0ee">
        <source>doMaintainBOL() : String;

/*

Purpose:		This does the actual work (TRX) for maintaing the bol.	

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2012	cnwrd1	Initial creation

*/

vars
	xmlParser 			: CnEcXmlParser;
	xmlStruct 			: CnEcXmlStructureInstance;
	intFaceCommon		: CMIF_InOutCommon;
	terminal			: CM_Terminal;
	passport			: CM_Passport;
	err					: CM_Error;
	rtnStr				: String;
	error				: Integer;
	bolIn,		
	pxyBOLIn			: CM_BOLIn;
	intFaceObj			: CMIF_BOLIn;
	ext					: CM_BOLExtLogIn;
	pxyDocketError 		: CM_DocketError;
	tmpDocketErrorType	: CM_DocketErrorType;
	loadStateSet		: Boolean;
	bolOID 				: String;
	structureObj	: CnEcXmlStructureInstance;
begin

	/* so here we want to go:
	1) find the BOL
	2) Create an update proxy for it 
	3) Do some validation on the state of the BOL, only update if we are allowed - this may be done in the trx
	4) create a CMIF_BolIn interface object for updating the proxty
	5) update only fields we have XML values for on the CMIF
	6) set the proxy from the CMIF
	7) fire the trx - app.myTrxUA.trxUpdateBOL(pxyBOL, false, app.myPassport);
	*/
	
	app.writeLog(method.name &amp; ' start processing BOL Update', LogINFO);
	
	passport := app.myPassport;
	terminal := passport.myTerminal;
	
	create intFaceCommon transient;
	
	create xmlParser transient;
	create xmlStruct as CnEcXmlGroupInstance transient;

	xmlParser.parseToMsgStructure(self.xmlString, xmlStruct);
	

	// go look for the OID in the XML - due to some duplication of ID's par 30447 cnwrd1 9.10.12
	structureObj :=	xmlStruct.findStructure(XML_DOCKETOID);
	if structureObj &lt;&gt; null then
		bolOID := structureObj.tagData;
	endif;
	

	bolIn := self.getBOL( bolOID, self.bolNoLookup, BOLType_Log, self.operatorLookup, terminal).CM_BOLIn;
	
	if bolIn = null then
		//throw exception		
		error := Err_BOLNotFound;
		rtnStr := app.getErrorString1(Err_BOLNotFound, self.bolNoLookup);
		return rtnStr;
	endif;
	
	app.cmsBeginLoad(loadStateSet);
	pxyBOLIn := bolIn.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadStateSet);

	ext := pxyBOLIn.myExtension.CM_BOLExtLogIn;
	
	create intFaceObj as CMIF_BOLIn transient;
	
	//do what 	tblMain.setObjectFromTable(intFaceObj, null, false); would do from here!
	
	intFaceObj.numItems  := pxyBOLIn.numItems;	
	intFaceObj.bolType := pxyBOLIn.bolType;
	intFaceObj.consigneeCode := pxyBOLIn.consignee;
	intFaceObj.consignorCode := pxyBOLIn.consignor;
	intFaceObj.myVoyage := pxyBOLIn.myVoyage;
	intFaceObj.notifyPartyCode := pxyBOLIn.notifyParty;
	intFaceObj.destinationPort := pxyBOLIn.destinationPort;
	intFaceObj.dischargePort :=	pxyBOLIn.dischargePort;
	intFaceObj.handlingSubContractor1 := pxyBOLIn.handlingSubContractor1Code;
	intFaceObj.noCharge := not pxyBOLIn.isCharged;
	intFaceObj.loadPortCode := pxyBOLIn.loadPortCode;
	intFaceObj.myManifest := pxyBOLIn.myManifest;
	intFaceObj.myPlannedLocation := pxyBOLIn.myPlannedLocation;
	intFaceObj.myTerminal := pxyBOLIn.myTerminal;
	intFaceObj.processOption := pxyBOLIn.processOption;
	intFaceObj.referenceDate := pxyBOLIn.referenceDate;
	
	intFaceObj.transportMode := pxyBOLIn.transportMode;
	intFaceObj.mySubTerminal := pxyBOLIn.mySubTerminal;
	intFaceObj.myOperator := pxyBOLIn.myOperator;
	
	intFaceObj.jasScaled := ext.jasScaled;
	intFaceObj.percentScaled :=  ext.percentScaled;
	intFaceObj.ticketedAll := ext.ticketedAll;
	intFaceObj.lengthRandom := ext.lengthCode;
	intFaceObj.logGradeCode := ext.logGradeCode;
	intFaceObj.logSpeciesCode := ext.logSpeciesCode;
	intFaceObj.logTreatmentCode := ext.logTreatmentCode;
	intFaceObj.logTypeCode := ext.logTypeCode;
	intFaceObj.numberOfLifts := ext.numberOfLifts;
	intFaceObj.scalerCode := ext.scalerCode;
	
	if self.isFieldForUpdate( XML_CARRIERID, xmlStruct) then
		intFaceObj.carrierCode := self.carrierCode;
	else
		intFaceObj.carrierCode := pxyBOLIn.carrierCode;
	endif;
	
	
	if self.isFieldForUpdate( XML_VEHICLEID , xmlStruct) then
		intFaceObj.regNumber := self.vehicle;
	else
		intFaceObj.regNumber := pxyBOLIn.vehicle;
	endif;
		
	if self.isFieldForUpdate( XML_TRUCKNO , xmlStruct) then
		intFaceObj.truckNumber := self.truckNumber;
	else
		intFaceObj.truckNumber := pxyBOLIn.truckNumber;
	endif;
		
	if self.isFieldForUpdate(XML_TRAILERNO , xmlStruct) then
		intFaceObj.trailerNumber := self.trailerNumber;
	else
		intFaceObj.trailerNumber := pxyBOLIn.trailerNumber;
	endif;
		
	if self.isFieldForUpdate(XML_OPID , xmlStruct) then
		intFaceObj.opid := self.opid;	
	else
		intFaceObj.opid := pxyBOLIn.opid;	
	endif;
		
	if self.isFieldForUpdate(XML_LOGGINGORG , xmlStruct) then
		intFaceObj.loggingOrganisation := self.loggingOrg;
	else
		intFaceObj.loggingOrganisation := pxyBOLIn.loggingOrganisation;
	endif;
		
	if self.isFieldForUpdate( XML_LOGGINGOP , xmlStruct) then
		intFaceObj.loggingOperation := self.loggingOperation;
	else
		intFaceObj.loggingOperation := pxyBOLIn.loggingOperation;
	endif;
		
	if self.isFieldForUpdate(XML_UNLOADPOINT , xmlStruct) then
		intFaceObj.unloadPoint := self.unloadPoint;
	else
		intFaceObj.unloadPoint := pxyBOLIn.unloadPoint;
	endif;
		
	if self.isFieldForUpdate(XML_BOLNO , xmlStruct) then
		intFaceObj.bolNumber := self.number;
	else
		intFaceObj.bolNumber := pxyBOLIn.number;
	endif;
		
	if self.isFieldForUpdate(XML_GROSSWEIGHT , xmlStruct) then
		intFaceObj.weightGrossTonnes := self.grossWeight;
	else
		intFaceObj.weightGrossTonnes := pxyBOLIn.weightGrossTonnes; //cnwrd1 30634 23.11.2012
	endif;
		
	if self.isFieldForUpdate( XML_NETWEIGHT, xmlStruct) then
		intFaceObj.weightNetTonnes := self.netWeight;
	else
		intFaceObj.weightNetTonnes := pxyBOLIn.weightNetTonnes; //cnwrd1 30634 23.11.2012
	endif;
		
	if self.isFieldForUpdate( XML_TAREWEIGHT, xmlStruct) then
		intFaceObj.weightTareTonnes := self.tareWeight;
	else
		intFaceObj.weightTareTonnes := pxyBOLIn.weightTareTonnes;//cnwrd1 30634 23.11.2012
	endif;
		
	if self.isFieldForUpdate(XML_REMARKS , xmlStruct) then
		intFaceObj.remarks := self.remarks;		
	else
		intFaceObj.remarks := pxyBOLIn.remarks;	
	endif;
		
	
	if self.isFieldForUpdate( XML_ACTIVITY, xmlStruct) then
		intFaceObj.activity := self.activity ;
	else
		intFaceObj.activity := ext.activity ;
	endif;
		
	if self.isFieldForUpdate(XML_BACKLOAD , xmlStruct) then
		intFaceObj.backload := self.backLoad ;
	else
		intFaceObj.backload := ext.backload;
	endif;
		
	if self.isFieldForUpdate( XML_CHHSUPPLIER, xmlStruct) then
		intFaceObj.chhSupplier := self.chhSupplier ;
	else
		intFaceObj.chhSupplier := ext.chhSupplier ;
	endif;
		
	if self.isFieldForUpdate( XML_FELLINGDATE , xmlStruct) then
		intFaceObj.fellDate := self.fellDate ;
	else
		intFaceObj.fellDate := ext.fellDate ;
	endif;
		
	if self.isFieldForUpdate( XML_GANG , xmlStruct) then
		intFaceObj.gangNumber := self.gang ;
	else
		intFaceObj.gangNumber := ext.gangNumber ;
	endif;
		
	if self.isFieldForUpdate( XML_LOADERNO, xmlStruct) then
		intFaceObj.loaderNumber := self.loaderNumber ;
	else
		intFaceObj.loaderNumber := ext.loaderNumber ;
	endif;
		
	if self.isFieldForUpdate( XML_NIGHTSHIFT, xmlStruct) then
		intFaceObj.nightshift := self.isNightShift ;
	else
		intFaceObj.nightshift := ext.nightshift;
	endif;
	
	if self.isFieldForUpdate(XML_PICKUPPOINT , xmlStruct) then
		intFaceObj.pickupPoint := self.pickupPoint ;
	else
		intFaceObj.pickupPoint := ext.pickupPoint ;
	endif;
		
	if self.isFieldForUpdate(XML_WEIGHBRIDGE , xmlStruct) then
		intFaceObj.weighbridge := self.weighBridge ;
	else
		intFaceObj.weighbridge := ext.weighbridge ;
	endif;
		
	if self.isFieldForUpdate( XML_FSC , xmlStruct) then
		intFaceObj.isFSC := self.isFSC ;
	else
		intFaceObj.isFSC := ext.isFSC ;
	endif;
	
	
	if self.isFieldForUpdate( XML_FOREST , xmlStruct) then
		intFaceObj.sourceLocation := self.forest ;
	else
		intFaceObj.sourceLocation :=  pxyBOLIn.sourceLocation;
	endif;
	
	if self.isFieldForUpdate( XML_COMPARTMENT , xmlStruct) then
		intFaceObj.sourceSubLocation := self.compartment ;
	else
		intFaceObj.sourceSubLocation :=  pxyBOLIn.sourceSubLocation;
	endif;
	
	
	if self.isFieldForUpdate( XML_STAND , xmlStruct) then
		intFaceObj.sourceSubSubLocation := self.stand ;
	else
		intFaceObj.sourceSubSubLocation :=  pxyBOLIn.sourceSubSubLocation;
	endif;	
	
	if self.isFieldForUpdate( XML_CUSTOMER , xmlStruct) then
		intFaceObj.customer := self.customer ;
	else
		intFaceObj.customer :=  ext.customer;
	endif;

	/*XML_DRIVERID*/  /* not using this here yet?*/
	
	if self.isFieldForUpdate( XML_LOGGINGCONT , xmlStruct) then
		intFaceObj.handlingContractor1 := self.loggingContractor ;
	else
		intFaceObj.handlingContractor1 :=  pxyBOLIn.handlingContractor1Code ;
	endif;
	
	if self.isFieldForUpdate( XML_LOADINGCONT , xmlStruct) then
		intFaceObj.handlingContractor2 := self.loadingContractor ;
	else
		intFaceObj.handlingContractor2 :=  pxyBOLIn.handlingContractor2Code;
	endif;
	
	if self.isFieldForUpdate( XML_SUBSUPPLIER , xmlStruct) then
		intFaceObj.handlingSubContractor1 := self.subSupplier ;
	else
		intFaceObj.handlingSubContractor1 :=  pxyBOLIn.handlingSubContractor1Code;
	endif;

	
	if self.isFieldForUpdate( XML_DRIVERSPIECECOUNT , xmlStruct) then
		intFaceObj.driversPieceCount := self.driversPieceCount.Integer ;
	else
		intFaceObj.driversPieceCount :=  ext.getActualPieceCountError;
	endif;

	
// self.getTagDataFromXML(XML_PIECECOUNTERROR, _bolMaintObj), - this is virtual based on method on driversPieceCount/actualPieceCountError

	
	if self.isFieldForUpdate( XML_DOCKETERROR , xmlStruct) then
		if self.docketError = null then
			pxyBOLIn.allDocketErrors.purge;
		else
			tmpDocketErrorType := app.myRoot.allDocketErrorTypes[self.docketError];
			if tmpDocketErrorType = null then
				error := Docket_error_code_not_found;
				rtnStr := app.getErrorString1(Docket_error_code_not_found, self.docketError);
			else		
				pxyDocketError := pxyBOLIn.allDocketErrors.first;	// if proxy docket error exists, then we will update existing real docket error
				if pxyDocketError = null then	// if proxy docket error = null, it means - user created a new docket error
					create pxyDocketError as CM_DocketError transient;
					pxyDocketError.setMyBol(pxyBOLIn);
				endif;
				pxyDocketError.setMyDocketErrorType(tmpDocketErrorType);		
			endif;
		endif;	
	endif;
	
	
	pxyBOLIn.allTrackedItems.copy(intFaceObj.allTrackedItems);
	pxyBOLIn.allDocketErrors.copy(intFaceObj.allDocketErrors);	
	
	
	intFaceObj.updateFromBolInXML := true;
	pxyBOLIn.setPxyFromCMIF_BOL(intFaceObj, app.myPassport);
	//pxyBOLIn.setPropertyValue('origLocationControllerId',bolIn.origLocationControllerId);
	//pxyBOLIn.setPropertyValue('origTerminalAreaId',bolIn.origTerminalAreaId);
	
	
	app.writeLog('Before trxUpdateBOL', LogINFO);
	app.myTrxUA.trxUpdateBOL(pxyBOLIn, false, null, app.myPassport);
	
	if passport.trxCompletedOK() then
		app.writeLog('After trxUpdateBOL successful', LogINFO); 
		return null;
	else
		app.writeLog('After trxUpdateBOL unsuccessful', LogINFO); 
		foreach err in passport.allErrors do
			if rtnStr = null then
				rtnStr	:=	rtnStr &amp; "BOL " &amp; self.number.toUpper() &amp; ", " &amp; err.text;
			else
				rtnStr	:=	rtnStr &amp; ", BOL " &amp; self.number.toUpper() &amp; ", " &amp; err.text;
			endif;
		endforeach;
		if rtnStr.length &gt; 1 then
			app.writeLog(rtnStr, LogINFO);
			return rtnStr;
		endif;
	endif;
	

epilog
	delete intFaceCommon;	
	delete xmlParser;
	delete xmlStruct;
	delete pxyBOLIn;
	delete intFaceObj;	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBOL" id="06a180df-3fab-41e1-ba9b-d7db893c12d7">
        <source>getBOL(_bolOID : String; _bolCode : String; _bolType : Integer; _operatorCode : String; _terminal : CM_Terminal) : CM_BOL;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 June 2012	cnwrd1	Initial creation

*/



vars
	bolTerm : CM_BOLTerminal;
	operator : CM_Operator;
	iter	: Iterator;
begin
	operator := app.myRoot.allOperators[_operatorCode];
	if operator &lt;&gt; null then
	
		iter := _terminal.allBOLTermsByTypeOpNum.createIterator;
		_terminal.allBOLTermsByTypeOpNum.startKeyGeq(_bolType, operator, _bolCode, iter);		
		//bolTerm := _terminal.allBOLTermsByTypeOpNum.getAtKey(_bolType, operator, _bolCode);
		
		while iter.next(bolTerm) do
		
		if bolTerm.myBOL = null then
			return null;
		endif;
		
		if bolTerm.myBOL.bolType &lt;&gt; _bolType then
			return null;
		endif;
		
		if bolTerm.myBOL.myOperator &lt;&gt; operator then
			return null;
		endif;
		
		if bolTerm.myBOL.number &lt;&gt; _bolCode then
			return null;
		endif;
		
		if _bolOID &lt;&gt; null then
			if bolTerm.myBOL.getOidAsString = _bolOID then
				return bolTerm.myBOL;
			else
				continue;
			endif;
		endif;
		
		return bolTerm.myBOL;
		
		endwhile;
	endif;	
	
	
	return null;
epilog
	delete iter;
end;
</source>
        <Parameter name="_bolOID" type="String"/>
        <Parameter name="_bolCode" type="String"/>
        <Parameter name="_bolType" type="Integer"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="isFieldForUpdate" id="9dd4c4db-fdd8-4a6e-8c31-952268afb592">
        <source>isFieldForUpdate(_tagName:String; _xmlObj:CnEcXmlStructureInstance):Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 June 2012	cnwrd1	Initial creation

*/

vars
	structureObj	: CnEcXmlStructureInstance;
begin
	structureObj	:=	_xmlObj.findStructure(_tagName);
	
	return not structureObj = null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tagName" type="String"/>
        <Parameter name="_xmlObj" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b42d93cc-8a6e-4dc8-99fb-c1eccef29e74">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteBOLMaintDtl; _realRemoteHdr: CM_RemoteDataHdr) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2012	cnwrd1	Initial creation

*/

vars

begin
	inheritMethod(_proxy, _realRemoteHdr);

	self.activity				:= _proxy.activity;
	self.backLoad				:= _proxy.backLoad;
	self.bolNoLookup			:= _proxy.bolNoLookup;
	self.carrierCode			:= _proxy.carrierCode;
	self.chhSupplier			:= _proxy.chhSupplier;
	self.compartment			:= _proxy.compartment;
	self.customer				:= _proxy.customer;
	self.docketError			:= _proxy.docketError;
	self.driverId				:= _proxy.driverId;
	self.driversPieceCount		:= _proxy.driversPieceCount;
	self.fellDate				:= _proxy.fellDate;
	self.forest					:= _proxy.forest;
	self.gang					:= _proxy.gang;
	self.grossWeight			:= _proxy.grossWeight.Real;	
	self.isFSC					:= _proxy.isFSC.Boolean;
	self.isNightShift			:= _proxy.isNightShift.Boolean;		
	self.loaderNumber			:= _proxy.loaderNumber;
	self.loadingContractor		:= _proxy.loadingContractor;
	self.loggingContractor		:= _proxy.loggingContractor;
	self.loggingOperation		:= _proxy.loggingOperation;
	self.loggingOrg				:= _proxy.loggingOrg;
	self.netWeight				:= _proxy.netWeight.Real;
	self.number					:= _proxy.number;
	self.operatorLookup			:= _proxy.operatorLookup;
	self.opid					:= _proxy.opid;
	self.pickupPoint			:= _proxy.pickupPoint;
	self.remarks				:= _proxy.remarks;
	self.stand					:= _proxy.stand;
	self.subSupplier			:= _proxy.subSupplier;
	self.tareWeight				:= _proxy.tareWeight.Real;
	self.trailerNumber			:= _proxy.trailerNumber;
	self.truckNumber			:= _proxy.truckNumber;
	self.unloadPoint			:= _proxy.unloadPoint;
	self.vehicle				:= _proxy.vehicle;
	self.weighBridge			:= _proxy.weighBridge;
	self.xmlString				:= _proxy.xmlString;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_RemoteBOLMaintDtl"/>
        <Parameter name="_realRemoteHdr" type="CM_RemoteDataHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxyForBOLMaint" id="7362b192-9428-4a49-aec0-c6999294d7ed">
        <updating/>
        <source>setProxyForBOLMaint(	_activity, 		
						_backLoad,		
						_bolNoLookup,
						_carrierCode,		
						_chhSupplier,		
						_compartment,			
						_customer,		
						_docketError,
						_driverId,	
						_pieceCountError,
						_driversPieceCount,
						_fellDate,			
						_forest,			
						_gang,							
						_grossWeight,	
						_isFSC,
						_isNightShift,		
						_loaderNumber,
						_loadingContractor,
						_loggingContractor,
						_loggingOperation,
						_loggingOrg,
						_netWeight,
						_number,
						_operatorLookup,
						_opid,
						_pickupPoint,
						_remarks,
						_stand,
						_subSupplier,
						_tareWeight,
						_trailerNumber,
						_truckNumber,
						_unloadPoint,
						_vehicle,
						_weighBridge,
						_xmlString			: String;
						_remoteHeader 		: CM_RemoteDataHdr) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2012	cnwrd1	Initial creation

*/

vars

begin

	self.activity				:= _activity;
	self.backLoad				:= _backLoad;
	self.bolNoLookup			:= _bolNoLookup;
	self.carrierCode			:= _carrierCode;
	self.chhSupplier			:= _chhSupplier;
	self.compartment			:= _compartment;
	self.customer				:= _customer;
	self.docketError			:= _docketError;
	self.driverId				:= _driverId;
	self.pieceCountError		:= _pieceCountError.Boolean;
	self.driversPieceCount		:= _driversPieceCount;
	self.fellDate				:= self.convertDate(_fellDate);
	self.forest					:= _forest;
	self.gang					:= _gang;
	self.grossWeight			:= _grossWeight.Real;	
	self.isFSC					:= _isFSC.Boolean;
	self.isNightShift			:= _isNightShift.Boolean;		
	self.loaderNumber			:= _loaderNumber;
	self.loadingContractor		:= _loadingContractor;
	self.loggingContractor		:= _loggingContractor;
	self.loggingOperation		:= _loggingOperation;
	self.loggingOrg				:= _loggingOrg;
	self.netWeight				:= _netWeight.Real;
	self.number					:= _number;
	self.operatorLookup			:= _operatorLookup;
	self.opid					:= _opid;
	self.pickupPoint			:= _pickupPoint;
	self.remarks				:= _remarks;
	self.stand					:= _stand;
	self.subSupplier			:= _subSupplier;
	self.tareWeight				:= _tareWeight.Real;
	self.trailerNumber			:= _trailerNumber;
	self.truckNumber			:= _truckNumber;
	self.unloadPoint			:= _unloadPoint;
	self.vehicle				:= _vehicle;
	self.weighBridge			:= _weighBridge;
	self.xmlString				:= _xmlString;
	

	self.setProxy(_remoteHeader);
	

epilog

end;</source>
