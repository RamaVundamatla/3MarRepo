    <JadeMethod name="addLogsFromScaleData" id="b1de05f9-df2a-4b4f-aba8-a6683ee490b1">
        <updating/>
        <source>addLogsFromScaleData(_logScalingHdr : CM_LogScalingHdr; _passport : CM_Passport input) : Boolean updating;
// -----------------------------------------------------------------------------
// Created:		09 April 2002 by cnwka1
//
// Purpose:		Create Logs (Tracked items) from scale data that has been captured by the
//				Hand held. Validation is performed on the first log and then rest are "cloned".
//
// IMPORTANT	This should ONLY be called from CM_LogScalingHdr.attemptMatch
// ---------------------------------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	idStr				: String;
	idArray				: CM_StringArray;
	logScalingDetail 	: CM_LogScalingDtl;	
	iter 				: Iterator;
	tiSet				: CM_TISet;
	pxyLog,	
	realLog, clonedLog	: CM_Log;
	ti					: CM_TrackedItem;
	wle					: CM_WorkListEntry;
	toDoRequest			: CM_Request;
	numScaled,
	pieceCount			: Integer;
	theBOLIn			: CM_BOLIn;	
	applyAverages		: Boolean;
	tiUpdateCntrl		: CMIF_TIUpdateController;
	terminal			: CM_Terminal;
	aveMeanSed			: Decimal[6,2];
	aveVolume,
	totVolume			: Decimal[16,4];
	theJob				: CM_RoadJob;
	tSequence			: CM_TicketSequence;
	lcController		: CM_LocationsController;
	moveController		: CMIF_MoveController;
	
begin

	iter := _logScalingHdr.allLogScalingDtls.createIterator();
	if not iter.next(logScalingDetail) then
		return false;
	endif;

	theBOLIn := self.myBOL.CM_BOLIn;

	if theBOLIn = null then
		app.raiseUnexpectedProgramError(class.name, method.name, self.String &amp; ' myBOL is null');
		return false;
	endif;
	
	terminal := theBOLIn.myTerminal;
	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	create pxyLog transient;
	pxyLog.setFromBOLInLogScaleDtl(theBOLIn, logScalingDetail, null, tiUpdateCntrl, null, _passport);
	
	create tiSet transient;
	tiSet.add(pxyLog);	
	tiUpdateCntrl.setMyTransientTIs(tiSet);	

	app.myUtilityCA.utlCreateTrackedItems(tiUpdateCntrl, _passport);
	if (not _passport.noErrors) then
		return false;
	endif;

	realLog := tiUpdateCntrl.allPersistentTIs.first.CM_Log;
	create idArray transient;	
	idArray.add(realLog.id);
	
	theJob := theBOLIn.myYardJob.CM_RoadJob;
	//Set the master ti on the CM_YardWLE (and CM_ToDoWle if there is one)
	foreach wle in theJob.workListEntries do
		if wle.myBOL &lt;&gt; null and wle.myBOL.number = theBOLIn.number then
			wle.setMyTrackedItem(realLog);
			if wle.myRequest.isKindOf(CM_ToDoRequest) then
				toDoRequest := wle.myRequest;
			endif;
		endif;
	endforeach;
	
	lcController := theJob.myVehicle.locationsController;
	
	//realLog.moveToLocation(lcController, theJob, null, null, REAL_MODE, true, true, false, false, false, false, null,null,_passport);		// TFS 2651
	realLog.moveToLocation(lcController, theJob, null, null, REAL_MODE, true, true, false, false, false, false, null,null,null,null,null,_passport);	// TFS 2651
	totVolume := totVolume + realLog.getMyTotalVolume;
	numScaled := numScaled + 1;	
	
	pieceCount := (theBOLIn.numItems - 1); //Less the one created above
	tiUpdateCntrl.transactionType := TRANS_TYPE_CREATED;	

	create moveController transient;
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyToPrimaryLocation(lcController);

	while iter.next(logScalingDetail) do
		clonedLog := realLog.cloneSelf(false); 
		clonedLog.setFromBOLInLogScaleDtl(null, logScalingDetail, realLog, tiUpdateCntrl, moveController, _passport);		
		clonedLog.copyReceivedRoadTransFromReal( realLog );	//Par 15436
		pieceCount := (pieceCount - 1);
		totVolume := totVolume + clonedLog.getMyTotalVolume;
		numScaled := numScaled + 1;
		idArray.add(logScalingDetail.logID);
	endwhile;

	if self.jasScaled then
		applyAverages := true;
		aveVolume := self.getVolumeForAveragedLogs(totVolume, numScaled);	// #24214	25/05/2010
		aveMeanSed	:= global.calcSEDMeanFromVolume(aveVolume, realLog.logLength);				
	endif;
	
	// Use the Ticket Sequences supplied and set averages.
	if pieceCount &gt; 0 and self.percentScaled &lt; 100 and self.ticketedAll then
		if (not self.allTicketSequences.isEmpty) then
			//need to use the ticket sequences suppiled first.
			foreach tSequence in self.allTicketSequences do
				if pieceCount = 0 then
					break;
				endif;
				foreach idStr in tSequence.allTicketIds do
					if pieceCount = 0 then
						break;
					endif;
					// Check to see if the ID has already been used
					if idArray.includes(idStr) then
						continue;
					endif;
					clonedLog := realLog.cloneSelf(false); 
					
					if applyAverages then
						clonedLog.setClonedRefsAndSEDAvg(idStr, realLog, false,
													  _logScalingHdr.averageMaxSed,
													  _logScalingHdr.averageMinSed,
													  aveMeanSed, aveVolume, tiUpdateCntrl,
													  moveController, _passport);		
					else
						clonedLog.setClonedRefsAndSEDAvg(idStr, realLog, false,
													  NULL_NEVERSCALED_LOG_SED,
													  NULL_NEVERSCALED_LOG_SED,
													  aveMeanSed, aveVolume, tiUpdateCntrl,
													  moveController, _passport);
					endif;
					
					/*
					clonedLog.setCloneIdReferences(idStr, realLog, false, tiUpdateCntrl, moveController, _passport);
					if applyAverages then
						clonedLog.setSEDsFromAveragesInternal(_logScalingHdr.averageMaxSed,
													  _logScalingHdr.averageMinSed,
													  aveMeanSed, aveVolume, tiUpdateCntrl,
													  _passport);		
					else
						clonedLog.setSEDsFromAveragesInternal(NULL_NEVERSCALED_LOG_SED,
													  NULL_NEVERSCALED_LOG_SED,
													  aveMeanSed, aveVolume, tiUpdateCntrl,
													  _passport);
					endif;
					*/
					pieceCount := (pieceCount - 1);
				endforeach;
			endforeach;			
		endif;
	endif;

	// Not all be ticketed so create remaining balance, apply systemID and set averages.
	while pieceCount &gt; 0 do
		clonedLog := realLog.cloneSelf(false); 
		
		if applyAverages then
			clonedLog.setClonedRefsAndSEDAvg(terminal.logNextSeqNumber, realLog, false,
										  _logScalingHdr.averageMaxSed,
										  _logScalingHdr.averageMinSed,
										  aveMeanSed, aveVolume, tiUpdateCntrl,
										  moveController, _passport);		
		else
			clonedLog.setClonedRefsAndSEDAvg(terminal.logNextSeqNumber, realLog, false,
										  NULL_NEVERSCALED_LOG_SED,
										  NULL_NEVERSCALED_LOG_SED,
										  aveMeanSed, aveVolume, tiUpdateCntrl,
										  moveController, _passport);
		endif;

		/*
		if applyAverages then
			clonedLog.setSEDsFromAveragesInternal(_logScalingHdr.averageMaxSed,
										  _logScalingHdr.averageMinSed,
										  aveMeanSed, aveVolume, tiUpdateCntrl,
										  _passport);		
		else
			clonedLog.setSEDsFromAveragesInternal(NULL_NEVERSCALED_LOG_SED,
										  NULL_NEVERSCALED_LOG_SED,
										  aveMeanSed, aveVolume, tiUpdateCntrl,
										  _passport);
		endif;
		*/

		pieceCount := (pieceCount - 1);

	endwhile;
	
	if toDoRequest &lt;&gt; null then //Update the toDoRequest to complete if there is one.
		app.myUtilityUA.utlUpdateToDoRequestStatus(toDoRequest, STATUS_COMPLETE, _passport);
		if (not _passport.noErrors) then
			return false;
		endif;
	endif;	
	
	if (not _passport.noErrors) then
		return false;
	endif;	
	
	if theBOLIn.numItems &lt;&gt; theBOLIn.numTIs then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, theBOLIn.number &amp;
							  ' number of Logs created does not match piece count.', null, null);
	endif;			
		
	if (not _passport.noErrors) then
		return false;
	endif;
	
	theBOLIn.createScalerTransactions(_logScalingHdr);		// cnwdad1 22/06/2006 - PAR #11958.
	//self.setJasVolume(_passport.myTerminal);
	self.setJasVolume(theBOLIn.myTerminal);			// #25482 20/10/2010
	self.setWeightForLogs(tiUpdateCntrl, _passport);
	return _passport.noErrors;

epilog
	delete tiUpdateCntrl;
	delete iter;
	delete tiSet;
	delete idArray;
	delete moveController;

end;</source>
        <Parameter name="_logScalingHdr" type="CM_LogScalingHdr"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addUnscaledLogs" id="529a44a2-ba00-43ba-9b6b-56a30c84e011">
        <updating/>
        <source>addUnscaledLogs(_passport : CM_Passport input) : Boolean updating;
//--------------------------------------------------------------
//Created: May 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	iter				: Iterator;
	tiSet				: CM_TISet;
	pxyLog,
	realLog, clonedLog	: CM_Log;
	ti					: CM_TrackedItem;
	wle					: CM_WorkListEntry;
	ticketSeq			: CM_TicketSequence;
	pieceCount			: Integer;
	useSystemId			: Boolean;
	bolIn				: CM_BOLIn;
	thisTerminal		: CM_Terminal;
	roadJob				: CM_RoadJob;
	tiUpdateCntrl		: CMIF_TIUpdateController;
	newId, str, conditionDefault	: String;
	coll				: Collection;
	moveController		: CMIF_MoveController;
	toLocn				: CM_LocationsController;
begin

	bolIn := self.myBOL.CM_BOLIn;			
	if bolIn = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'BOL In is null');
		return false;
	endif;
	thisTerminal := bolIn.myTerminal;

	// &lt; 100 % scaled use system ID
	if (not self.allTicketSequences.isEmpty) and self.ticketedAll then
		ticketSeq := self.allTicketSequences.first;
		str := ticketSeq.fromId;
	else
		str := thisTerminal.logNextSeqNumber;
		useSystemId := true;
	endif;

	conditionDefault := thisTerminal.getConfig(LogDefaultConditionCode).String;
	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);		
	tiUpdateCntrl.transactionType := TRANS_TYPE_CREATED;
	
	//To speed things up we create one log first and validate it. If all OK then the rest are cloned.
	create pxyLog transient;
	pieceCount := (bolIn.numItems - 1); //Less the first log created
	pxyLog.setLogUnscaledNoNumber(bolIn, NULL_UNSCALED_LOG_SED, conditionDefault, str, null, tiUpdateCntrl, null, _passport);		

	create tiSet transient;
	tiSet.add(pxyLog);	
	tiUpdateCntrl.setMyTransientTIs(tiSet);	
	app.myUtilityCA.utlCreateTrackedItems(tiUpdateCntrl, _passport);
	if (not _passport.noErrors) then
		return false;
	endif;
	
	realLog := tiUpdateCntrl.allPersistentTIs.first.CM_Log;
	roadJob := bolIn.myYardJob.CM_RoadJob;
	//set the master ti on the associated CM_YardWLE and CM_ToDoWLE
	foreach wle in roadJob.workListEntries do
		if wle.myBOL &lt;&gt; null and wle.myBOL.number = bolIn.number then
			wle.setMyTrackedItem(realLog);
			break;
		endif;
	endforeach;
	
	toLocn := roadJob.myVehicle.locationsController;

	if toLocn = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Cannot move to vehicle. Location is null');
	endif;	
	//realLog.moveToLocation(toLocn, roadJob, null, null, REAL_MODE, true, true, false, false, false,  false,null,null, _passport);		// TFS 2651
	realLog.moveToLocation(toLocn, roadJob, null, null, REAL_MODE, true, true, false, false, false, false, null, null, null, null, null, _passport);	// TFS 2651
	if (not _passport.noErrors) then
		return false;
	endif;

	create moveController transient;
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyToPrimaryLocation(toLocn);

	if (not useSystemId) then		//We have tickets so use them first
		foreach ticketSeq in self.allTicketSequences do
			foreach str in ticketSeq.allTicketIds do
				if str = realLog.id then
					continue;
				endif;
				clonedLog := realLog.cloneSelf(false);
				clonedLog.setLogUnscaledNoNumber(null, NULL_UNSCALED_LOG_SED,
												conditionDefault, str,
												realLog, tiUpdateCntrl,
												moveController,
												_passport);
				if _passport.hasErrors then
					return false;
				endif;															 				 
				pieceCount := (pieceCount - 1);				
			endforeach;
		endforeach;
	endif;

	while pieceCount &gt; 0 do		//Not all ticketed so assign system id to balance
		clonedLog := realLog.cloneSelf(false);
		clonedLog.setLogUnscaledNoNumber(null, NULL_UNSCALED_LOG_SED,
										 conditionDefault,
										 thisTerminal.logNextSeqNumber,
										 realLog, tiUpdateCntrl,
										 moveController,
										 _passport);
		if (not _passport.noErrors) then
			return false;
		endif;										 
		pieceCount := (pieceCount - 1);
	endwhile;	
	
	// No longer needed as the bols planned location is used to move the logs
	//Now go and update the planned location for all the logs
	//bolIn.doUpdateLocation(PLANNING_MODE, bolIn.myPlannedLocation, app.myPassport);
	
	if bolIn.numItems &lt;&gt; bolIn.numTIs then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, bolIn.number &amp;
							  ' number of Logs created does not match piece count.', null, null);
	endif;			

	if not _passport.noErrors() then
		return false;
	endif;

	return true;
epilog
	delete tiUpdateCntrl;
	delete iter;
	delete tiSet;
	delete moveController;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="attemptMatch" id="5d78447a-37bc-42f9-90ac-e8c6669e4c9a">
        <updating/>
        <source>attemptMatch(_passport : CM_Passport input) : Boolean updating;
//--------------------------------------------------------------
//Created: 16 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	terminal	: CM_Terminal;
	scaleHdr	: CM_LogScalingHdr;
	ext			: CM_BOLExtLogIn;
	bol			: CM_BOL;
	operCode, 
	bolNum 		: String;
	
begin
	bol 		:= self.myBOL;
	operCode 	:= bol.getOperatorCode();
	bolNum		:= bol.number;
	terminal 	:= bol.myTerminal;
	scaleHdr 	:= terminal.allLogScalingHdrsUnmatched.getAtKeyGtr(operCode, bolNum, null);
	
	if scaleHdr &lt;&gt; null then
		return scaleHdr.attemptMatch(self.myBOL.CM_BOLIn,false, _passport); //epr TFS 3769 3/4/17
	endif;
	
	return false;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="averageSED" id="53c2bfa0-8232-4de8-91d9-3175f197f9c8">
        <methodInvocation>mapping</methodInvocation>
        <source>averageSED(set: Boolean; _value: Decimal io) mapping;
// -----------------------------------------------------------------------------
// Created:		17 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	vol		: Decimal[16,4];
	log 	: CM_Log;
	iter 	: Iterator;
	cnt		: Integer;
	ls		: Boolean;
	coll	: Collection;
	obj		: Any;
	tmpBOL	: CM_BOL;

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);	
	else
		tmpBOL := self.myBOL;
		coll := tmpBOL.getTICollectionForTerminal(tmpBOL.myTerminal);
		app.cmsBeginLoad(ls);
		iter := coll.createIterator();
		
		while iter.next(obj) do
			log := obj.CM_Log;
			if log.sedMean &lt;&gt; NULL_UNSCALED_LOG_SED then
				cnt := cnt + 1;
				// 29387 May 2012 use original volume before any regrading
				//vol := vol + log.getMyTotalVolume;
			endif;
		endwhile;
		if cnt &gt; 0 then
			// 29387 May 2012 use original volume before any regrading
			vol := self.jasVolume;
			_value := global.calcAverageSEDMean(self.lengthCode.Real, vol, cnt);
		endif;
	endif;
epilog
	app.cmsEndLoad(ls);
	delete iter;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="a684307e-3e90-4aa9-bc21-d9ef9b747ae7">
        <updating/>
        <source>cloneReferences(_ext: CM_BOLExtLog) updating;

// cnwdvb1 14 October 2002 

vars

begin

	inheritMethod(_ext);


end;</source>
        <Parameter name="_ext" type="CM_BOLExtLog"/>
    </JadeMethod>
    <JadeMethod name="completeRoadInProcess" id="0b87b3b9-582b-42ac-9a3b-401a1401ad76">
        <updating/>
        <source>completeRoadInProcess(_passport : CM_Passport input) : Boolean updating;
//--------------------------------------------------
// Created:	18 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	rtnValue : Boolean;
	bol		: CM_BOL;
	job		: CM_YardJob;
	toLocn 	: CM_LocationsController;
begin
	
	if self.myTerminalIfUnmatched = null then
		// must have been matched and moved OK
		return true;
	endif;

	bol := self.myBOL;
	
	toLocn := bol.myPlannedLocation;
	if toLocn = null then
		// must be there already
		rtnValue := true;
	endif;
	job := bol.myYardJob;
	if job = null then
		// truck must have already been processed and left the terminal
		rtnValue := true;
	endif;
	
	if (not rtnValue) then
		if bol.doesAllowType(_passport, true) then
			job.doMove(REAL_MODE, _passport);
			if job.status = JOB_COMPLETE then
				job.departureProcess(_passport);
			endif;
			rtnValue := true;
		endif;
	endif;
	
	if rtnValue then
		self.myTerminalIfUnmatched := null;
	endif;
	
	return rtnValue;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="completeRoadInProcessForBOL" id="f0c160a1-9419-4f48-8eaa-0cb2fb0338b6">
        <updating/>
        <source>completeRoadInProcessForBOL(_passport : CM_Passport input) : Boolean updating;
//--------------------------------------------------
// Created:	19 March 2004 By: cnwdvb1
//--------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	rtnValue		: Boolean;
	bol				: CM_BOL;
	job				: CM_YardJob;
	toLocn			: CM_LocationsController;
	wle				: CM_WorkListEntry;
	moveController	: CMIF_MoveController;
	tmpTI			: CM_TrackedItem;
begin

	// DVB 22/03/04
	// THIS METHOD SHOULD ONLY BE CALLED AFTER LOGS HAVE BEEN MATCHED AND ARE READY
	// TO BE MOVE INTO YARD. THE METHOD DOES THE MOVE AND ROAD COMPLETION STUFF
	// FOR A SINGLE WLE RATHER THAN PROCESSING THE WHOLE JOB AT ONCE.

	if self.myTerminalIfUnmatched = null then
		// must have been matched and moved OK
		return true;
	endif;

	bol := self.myBOL;
	
	toLocn := bol.myPlannedLocation;
	if toLocn = null or bol.CM_BOLIn.origTerminalAreaId &lt;&gt; null then
		// must be there already
		bol.sendNoteOnMoveCompletion(_passport);
		rtnValue := true;
	endif;
	job := bol.myYardJob;
	if job = null then
		// truck must have already been processed and left the terminal
		rtnValue := true;
	endif;
	if (not rtnValue) then
		
		if bol.doesAllowType(_passport, true) then
			wle := job.getWLEForBOL(bol);
			if wle &lt;&gt; null then
				tmpTI := wle.myTrackedItem;
				if tmpTI = null then
					app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'WLE Tracked Item is null', null, null);
					return false;
				endif;
				self.exclusiveLock(tmpTI);
				if tmpTI.getPrimaryLocation(REAL_MODE) = toLocn then
					//Already there 
					rtnValue := true;
				else
					// need to lock vehicle.myTerminalArea.allLocations set (ie VTA) to avoid a deadlock here
					if CM_RoadJob.hasInstance(job) then
						// to avoid deadlock(s)
						job.CM_RoadJob.lockVehicleTerminalAreaLocns();
					endif;
					
					create moveController transient;
					moveController.setMoveMode(REAL_MODE);	
					moveController.setMyToPrimaryLocation(toLocn);
					wle.doMoveToLocn(moveController, _passport);
					if _passport.noErrors() and job.status = JOB_COMPLETE then
						job.departureProcess(_passport);
					endif;
					rtnValue := _passport.noErrors();
				endif;
			endif;
		endif;
	endif;
	
	if rtnValue then
		self.myTerminalIfUnmatched := null;
	endif;
	
	return rtnValue;
epilog	
	delete moveController;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyLogOrgFromMyBOLIn" id="ea391919-e275-4ea6-8fa0-2910e7fbaaff">
