    <JadeMethod name="displayEntTableRow" id="7b00cb6a-3195-42cd-84be-57aa56259624">
        <source>displayEntTableRow(pRow : EntTableRow; pLong : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 12 Jan 2026  navlc30     JIRA 36954 Story MTN | Highlight Mandatory fields
// ---------------------------------------------------------------------------
vars
	str	: String;

begin
	if pRow = null then
		return null;
	endif;

	str := pRow.getName &amp; Tab &amp;
		   pRow.getPropertyValue('heading').String;//return un-altered heading
		   
	if pLong then
		str := str &amp; Tab &amp;
		   pRow.shortHeading &amp; Tab &amp;
		   self.inTypeEnumToString(pRow.inputType) &amp; Tab &amp;
		   pRow.controlName &amp; Tab &amp;
		   self.inputTypeWebEnumToString(pRow.inputTypeForWeb) &amp; Tab &amp;
		   pRow.terminologyTypeName &amp; Tab &amp;
		   pRow.visible.Integer.String &amp; Tab &amp;
		   pRow.displayNullIfZero.Integer.String &amp; Tab &amp;
		   pRow.clickMethodName &amp; Tab &amp;
		   pRow.gotFocusMethodName &amp; Tab &amp;
		   pRow.lostFocusMethodName &amp; Tab &amp;
		   pRow.errorReturnString &amp; Tab &amp;
		   pRow.measurementType  &amp; Tab &amp;					// PAR #31155
		   pRow.isMandatoryField.Integer.String;			//12.01.2026 navlc30 #36954
	endif;
	
	return str;

end;</source>
        <Parameter name="pRow" type="EntTableRow"/>
        <Parameter name="pLong" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doAddDefinition" id="2d7719d6-7f6e-49fd-8d80-66870bb84354">
