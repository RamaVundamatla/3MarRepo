    <JadeMethod name="updateRemoveJadeFromTooltips" id="6299679f-a079-4341-9576-73df1c021a75">
        <source>updateRemoveJadeFromTooltips(_controller : CnEcReleaseController);
/*
Purpose - 	
Who - NAVAB1
Date - 01SEP2025
ADO - JIRA 35719
*/


vars
       iter01 : Iterator;
       menuItem : CM_MenuUserToolbar;
       oArray : ObjectArray;
       newTooltip : String;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Remove 'JADE' from tooltips", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Remove 'JADE' from tooltips") ;	
	endif;
	
    create oArray transient;	
    CM_MenuUserToolbar.allInstances(oArray,0,false);
    iter01 := oArray.createIterator;
	
	beginTransaction;
	
      while iter01.next(menuItem) do
		  if menuItem.toolTip.pos("Jade",1) &gt; 0 then
			 newTooltip := menuItem.toolTip.removeSubstringPlusExtraChars("Jade",0);
			 menuItem.setPropertyValue("toolTip", newTooltip);
		  endif;

       endwhile;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " all tooltips cleansed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all tooltips cleansed") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
   delete oArray;
   delete iter01;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
</Class>
