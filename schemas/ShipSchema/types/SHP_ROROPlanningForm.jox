    <JadeMethod name="doMnuAutoplan" id="dd0a3d5b-8c2d-4890-8393-41945356fdc0">
        <source>doMnuAutoplan();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2012	cnwer1	Initial creation PAR 29007

*/

vars
	result ,idx: Integer;
	wlesWithWarnings, theWLEs,tmpWles : CM_WLEArray; 
	aTI : CM_TrackedItem;
	str : String;
	tmpWLE : CM_WorkListEntry;
	selectedRequests : CM_ObjectSet;
	obj : Object;
begin
	
	if self.myROROPlanDrawController.allSelectedObjects.isEmpty then
		return;
	endif;
	
	create tmpWles transient;
	self.getWlesForSelectedArea( tmpWles );

	
	create theWLEs transient;
	foreach tmpWLE in tmpWles do
		if tmpWLE.myFutureMove &lt;&gt; null then
			continue;
		endif;
		aTI := tmpWLE.myTrackedItem;
		if aTI &lt;&gt; null then
			idx := idx + 1;
			if str = null then
				str := aTI.id;
			else
				if idx mod 3 = 0 then
					str := str &amp; ", " &amp; Cr &amp; aTI.id;
				else
					str := str &amp; ", " &amp; aTI.id;
				endif;
			endif;
			theWLEs.add(tmpWLE);
		endif;
	endforeach;

	if theWLEs.isEmpty() then
		app.msgBox(app.getErrorString(Please_select_cargo_autoplan),app.getErrorString(Error),MsgBox_OK_Only);
		return;
	else
		if app.msgBox(app.getErrorString(Autoplan) &amp; " " &amp; str &amp; "?", app.getErrorString(Confirm_autoplan_cargo),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			global.beep;
			return;
		endif;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	create wlesWithWarnings transient;	
	
	while true do
		app.myTrxUA.trxUpdateWLEsAutoplan(theWLEs, wlesWithWarnings, PLANNING_MODE, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			if app.myPassport.allErrorWarnings.size = 1 and app.myPassport.returnCode = INFO_NO_AUTOPLAN then
				//do show it here, ask Q below.
				result := 1;				
			else
				result := app.showErrorWarningDialog('Voyage Auto-Planning', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			endif;
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				theWLEs.clear;
				wlesWithWarnings.copy(theWLEs);
				wlesWithWarnings.clear;	
				continue;
			endif;
		endif;
		break;
	endwhile;	

	if app.myPassport.returnCode = INFO_NO_AUTOPLAN then
		if app.msgBox(app.getErrorString(app.myPassport.returnCode), "Information",
					 MsgBox_Information_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			app.showSystemAlertsWindow(self.myMasterMenuAction, self.myTerminal, null);			
		endif;
	endif;
epilog
	delete selectedRequests;
	delete wlesWithWarnings;
	delete theWLEs;
	delete tmpWles;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuCargoEraseClick" id="d721571e-0f56-4202-a5b8-bb54872edfc8">
        <updating/>
        <source>doMnuCargoEraseClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
vars
	theTI : CM_TrackedItem;
	theReturn : Integer;
begin
	if menuItem.userObject &lt;&gt; null then
		if menuItem.userObject.isKindOf(CM_DeckItem) then
		
			theTI := menuItem.userObject.CM_DeckItem.getFirstTI();
			if theTI &lt;&gt; null then
				while true do // PAR 8920 added a TRX LOOP
					app.myTrxDA.trxDeleteTI(theTI, true, app.myPassport);
					if app.myPassport.trxCompletedOK then
						global.beep;
						break;
					else
						theReturn := app.showErrorWarningDialog(app.getErrorString(Delete).cnEcFirstToUpper &amp; " " &amp; app.getErrorString(Cargo), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
						if app.myPassport.noErrors and
						   theReturn = IDOK then
							// there must have just been warnings that the user has acknoledged so ..
							app.myPassport.warningsAcknowledged	:= true;
							continue;
						endif;
						return;
					endif;
					break;
				endwhile;
			else
				while true do
					app.myTrxDA.trxDeleteRORODeckItem(menuItem.userObject.CM_DeckItem,app.myPassport);
					if app.myPassport.trxCompletedOK then
						global.beep;
						break;
					else
						theReturn := app.showErrorWarningDialog(app.getErrorString(Delete).cnEcFirstToUpper &amp; " " &amp; app.getErrorString(Deck_item), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
						if app.myPassport.noErrors and
						   theReturn = IDOK then
							// there must have just been warnings that the user has acknoledged so ..
							app.myPassport.warningsAcknowledged	:= true;
							continue;
						endif;
						return;
					endif;
					break;
				endwhile;
			endif;
		endif;
	endif;
epilog
	self.myCurrentDeckItem := null; // PAR 29990
	self.myCurrentItemLayout := null;  // PAR 29990 
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuDeselectAll" id="dfce8b00-5523-4626-bc83-ccf54f007c00">
        <updating/>
        <source>doMnuDeselectAll() updating;
/*
Purpose:			
Date		Who		Reason
13 April 2011	cnwab1	Initial creation
*/

vars
	layerFrame : CMUI_PointDrawingFrame;
	invalidObj : Boolean;
begin
	
//	self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.doBtnClearClick(true);
	self.doClearTopDrawingFrame(true);
	if self.addPillarsToTopFrame() then
		self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.drawAllPolygons(White);
	endif;
	
	// this draws all the polygons on the background frame, makes it easier to line up what you are drawing
	// container layer  does not need to be re drawn
	if self.myCurrentLayer &lt;&gt; null and self.myCurrentLayer.isPlanningRedrawable() then
		self.doDrawCurrentLayer();
	endif;

	if self.modeWork = self.WorkMode_Job then
		if self.mySideViewForm &lt;&gt; null then
			self.mySideViewForm.doDeselectAll();
		endif;
		self.cmbWorkPoint.listIndex := -1;
		self.cmbWPJob.listIndex := -1;
		self.myCurrentJob := null; // PAR 31652
		self.chkOutOfSequence.value := self.myCurrentVoyage.createOutOfSequenceLoadJobs(); //cnwrd1 par 30626 ccms 2209 23.10.12
	endif;
	
	// PAR 28336
	if self.modeWork = self.WorkMode_Plan then
		on Exception do app.handleDeletedObject(exception, app.myMoveController, invalidObj);
		if app.myMoveController &lt;&gt; null then
			app.myMoveController.myVoyageRequest := null;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuLinkDelinkClick" id="84a9ab90-e16e-4a9f-8842-1a0bfd7613cd">
        <updating/>
        <source>doMnuLinkDelinkClick() updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	obj			: Object;
	tmpSlotController	: CM_VoyageROROController;
	aLeftReq	: CM_Request;
	theLeftRequests: CM_RequestArray;
	aRequest : CM_RORORequest;
	theReturn : Integer;
	msgString : String;
	tmpSlots	: CM_LCArray;
	isDischarge	: Boolean;
	tmpDrawController	: SHP_ROROPlanDrawingController;
	expectedEditions : CM_ObjectByOidEditionDict;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	tmpDrawController := self.myROROPlanDrawController;
	isDischarge := (self.modeView = ShpDisplayMode_ColCodeDisch);

	create tmpSlots transient;
	create theLeftRequests transient;
	create expectedEditions transient;
	
	//cnwmc5 - 1 August 2013 - PAR 31651
	if self.mySideViewForm &lt;&gt; null then
		self.mySideViewForm.myROROLocnDrawingController.getSelectedDLRItems(theLeftRequests);
		self.mySideViewForm.myROROLocnDrawingController.allObjectEditions.copyNoDuplicates(expectedEditions, false);
	endif;
	if theLeftRequests.isEmpty() then
		self.myROROPlanDrawController.getSelectedDLRItems(theLeftRequests);
		self.myROROPlanDrawController.allObjectEditions.copyNoDuplicates(expectedEditions, false);
	endif;
	
	foreach aLeftReq in theLeftRequests discreteLock do
		if not tmpSlots.includes(aLeftReq.getLC()) then
			tmpSlots.add(aLeftReq.getLC());
		endif;
	endforeach;
	
	if (not tmpSlots.isEmpty) then
		theReturn := app.msgBox(app.getErrorString(Sure_that_want_link_selec_link),app.getErrorString(Confirm_delink), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if theReturn = MsgBox_Return_Yes then
		
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxUA.trxUpdateROROReqLinkSOBDLR(tmpSlots, null, expectedEditions, isDischarge, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog(app.getErrorString(Linking_requests), app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;

		endif;
	endif;

epilog
	delete tmpSlots;
	delete theLeftRequests;
	delete expectedEditions;
	
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuLoadQtyClick" id="e200a0f5-9bdf-420d-a956-9eb164dc0a09">
        <updating/>
        <source>doMnuLoadQtyClick(menuItem: MenuItem input) updating;
/*
Purpose:			
Date		Who		Reason
19 January 2012	cnwab1	Initial creation
*/

vars
	aReq : CM_RORORequest;
	voyAlloc : CM_VoyageAllocation;
begin
	if not menuItem.userObject.isKindOf(CM_RORORequest) then
		return;
	endif;

	aReq := menuItem.userObject.CM_RORORequest;
	if aReq = null then
		return;
	endif;
	
	voyAlloc := aReq.allAllocations.first.CM_VoyageAllocation;
	if voyAlloc = null then
		return;
	endif;
	
	self.doGetQuantity(voyAlloc, self.GetData_QuantityUpdate, aReq);
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuPointRemoveClick" id="85927246-a576-45ff-895b-8c10d42aef85">
        <updating/>
        <source>doMnuPointRemoveClick(theMenuItem: MenuItem) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	thePoint : Point;
	theFrame : CMUI_PointDrawingFrame;
	theReturn : Integer;
begin

	theFrame := self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame;
	//thePoint :=  theFrame.getDragPoint2(); 
	thePoint := theFrame.getDragLastPoint(); // 28920
	while true do
		app.myTrxUA.trxUpdateROROPointRemove(thePoint,theFrame.theGraphic, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			theFrame.setDragLastPoint(null); // PAR 28920
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Remove) &amp; " " &amp; app.getErrorString(New_point), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMoveFromGridAreaForm" id="bda5ead5-c77e-4fc0-be8d-071f3cc70ab9">
        <updating/>
        <source>doMoveFromGridAreaForm(_roroController : CM_VoyageROROController; _isSideViewDrop : Boolean) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	tmpObj		: Object;
	aSlotController : CM_VoyageROROController;
	aLabel, moveString : String;
	jobOne, jobTwo : CM_Job;
	tmpDrawController	: SHP_ROROPlanDrawingController;
	tmpMoveController	: CMIF_MoveController;
	moveControllerMoveMode	: Integer;
	isShip2Ship : Boolean;
	aReq : CM_RORORequest;
	is40 : Boolean;
	form : CMUI_MoveAmountForm;
	ti : CM_TrackedItem;
	quantity : Integer;
	reqMaxQty : Integer;	//09 Dec 2019	NDL	TFS 46875
	
begin
	tmpMoveController := app.myMoveController;
	
	if tmpMoveController = null then
		return;
	endif;
	if tmpMoveController.myTrackedItem = null then
		return;
	endif;
	
	ti := tmpMoveController.myTrackedItem;	//06 Dec 2019	NDL	TFS 46875

	isShip2Ship := tmpMoveController.myOriginatingLocation &lt;&gt; null and tmpMoveController.myOriginatingLocation.isVoyageController() and _roroController.isVoyageController();	//29 Mar 2012	NDL	Par 29187
	aSlotController := _roroController ;

	
	if  (_isSideViewDrop and self.mySideViewForm.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeLoad) // PAR 32149 only look at the 40 foot load CC if we are viewing load CC
	or (not _isSideViewDrop and self.modeView = ShpDisplayMode_ColCodeLoad) then // PAR 32149
		// PAR 28993 - if the drop was on the aft position, switch to forward position, cos the poor user cannot remember to drop on the forward position.
		aReq := aSlotController.myRORORequestLoad;
		if aReq &lt;&gt; null then
			is40 := aReq.getAttrIsNOT20(); // PAR 30253
			if is40  // PAR 30022 
			and aReq.getAttrIsBackend() then
			
				aReq := aReq.getFwdSlotReq().CM_RORORequest;
				aSlotController := aReq.myROROController;	
			endif;
		endif;
	endif;
	
	//06 Dec 2019	NDL	TFS 46875
	if ti.myCargoType.allowDuplicates then
	
		if aReq &lt;&gt; null then
			if aReq.getQuantityOnRequest.Integer &gt; 0 then
				reqMaxQty := ( aReq.getQuantityOnRequest.Integer - aReq.getWLEQuantityTIAssigned( null ) ).max(0);
				if reqMaxQty &lt;= 0 then
					app.msgBox( app.getErrorString1(Request_fully_planned, aReq.code), app.getErrorString1(Dragging_from_error,aLabel), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
					return;
				endif;
			endif;
		endif;
		
		tmpMoveController.setWeight( ti.totalWeight );											
		tmpMoveController.setQuantity( ti.totalQuantity.max(1) );
		create form transient;
		form.myTrackedItem := ti;
		form.myRequest := aReq;
		if ti.canMergeBreakBulk then													
			form.myWorkListEntry := tmpMoveController.myWorkListEntry;					
		endif;																			
		if tmpMoveController.myToPrimaryLocation &lt;&gt; null then
			form.targetLocation := tmpMoveController.myToPrimaryLocation.getFullId;
		endif;
			
		if form.showModal &lt;&gt; IDOK then
			return;
		endif;
		if form.byQuantity then
			quantity := form.getQuantity;	
			tmpMoveController.setWeight( tmpMoveController.weight / tmpMoveController.quantity * quantity);											
			tmpMoveController.setQuantity( quantity);													
		else
			tmpMoveController.setWeight( form.getWeightMovedKgs);
		endif;
	endif;
	if aReq &lt;&gt; null then
		if aReq.quantity &gt; 0 and tmpMoveController.quantity &gt; aReq.quantity then
			app.msgBox(app.getErrorString1(Exceeds_amount_requested, tmpMoveController.quantity.asStringJMT),app.getErrorString1(Dragging_from_error,aLabel),
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		elseif aReq.weightRequested &gt; 0 and tmpMoveController.weight &gt; aReq.weightRequested then
			app.msgBox(app.getErrorString1(Exceeds_amount_requested, tmpMoveController.weight.asStringJMT),app.getErrorString1(Dragging_from_error,aLabel),
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;	
	
	tmpDrawController	:=	self.myROROPlanDrawController;
	tmpMoveController.ignoreWeightValidation	:=	false; //self.chkIgnoreWeightV.value;

	moveControllerMoveMode := tmpMoveController.moveMode;
	
	tmpMoveController.setMyToPrimaryLocation(aSlotController);
	tmpMoveController.mySlotRequest := null;

	if moveControllerMoveMode = REAL_MODE then
		tmpMoveController.myVoyageRequest := null;
		tmpMoveController.setMyWorkListEntry(null);
	elseif moveControllerMoveMode = PLANNING_MODE then
		if tmpMoveController.myTrackedItem.isRehandle 
		and self.modeView = ShpDisplayMode_ColCodeLoad then
			tmpMoveController.myVoyageRequest := aSlotController.myRORORequestLoad;
		elseif   self.modeView = ShpDisplayMode_ColCodeLoad 
		and not  tmpMoveController.isMoveAnExportRePlan()  
		and not  tmpMoveController.myTrackedItem.isSOB then
			tmpMoveController.myVoyageRequest := aSlotController.myRORORequestLoad;
		endif;
	endif;

	if moveControllerMoveMode = QUEUE_MODE then
		app.msgBox(app.getErrorString1(Cannot_drag_drop_mode,app.getErrorString(Queue)),app.getErrorString1(Dragging_from_error,aLabel),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if not isShip2Ship and moveControllerMoveMode = REAL_MODE then
		app.msgBox(app.getErrorString1(Cannot_drag_drop_mode,app.getErrorString(Instant)),app.getErrorString1(Dragging_from_error,aLabel),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if moveControllerMoveMode = PLANNING_MODE then
	
	
		// if we are dropping in planning mode then this must be a load.
		if self.modeView = ShpDisplayMode_ColCodeDisch then
			app.msgBox(app.getErrorString1(Cannot_drop_mode,app.getErrorString(SHP_Discharge_Colour_Coding) &amp; " " &amp; app.getErrorString(SHP_PLANNING)), app.getErrorString(Planne_discha_drag_drop_error),
							MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		else
			if aSlotController.myRORORequestLoad = null then
				app.msgBox(app.getErrorString1(Cannot_drop_mode,app.getErrorString(SHP_PLANNING).toUpper) &amp; ". " &amp; app.getErrorString1(There_load_colour_coding_slot,aSlotController.getFullId)  &amp; ".", app.getErrorString(Planned_load_drag_drop_error),
								MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			else
			
				if aSlotController.myRORORequestLoad.myBulkReleaseReserveDetail &lt;&gt; null then //cnwrd1 par 30865 11.1.13
					app.raiseCMException1(Slot_alread_alloca_releas_requ, aSlotController.myRORORequestLoad.myBulkReleaseReserveDetail.myReserveHeader.code , null, null);
				endif;
				
				jobOne := aSlotController.myRORORequestLoad.myJob;
				if tmpMoveController.myVoyageRequest &lt;&gt; null then
					jobTwo :=  tmpMoveController.myVoyageRequest.myJob;
				endif;
				if jobOne = null then
					app.msgBox(app.getErrorString1(Cannot_drop_mode,app.getErrorString(SHP_PLANNING).toUpper) &amp; ". " &amp; app.getErrorString1(There_defin_load_colou_codin_s,aSlotController.getFullId)  &amp; "."
								,app.getErrorString(Planned_load_drag_drop_error),
									MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					return;
				else
					if jobTwo &lt;&gt; jobOne and jobTwo &lt;&gt; null then
						app.msgBox(app.getErrorString1(Cannot_drop_mode,app.getErrorString(SHP_PLANNING).toUpper) &amp; ". " 
									&amp; app.getErrorString3(Cannot_drag_between_job_job,tmpMoveController.myTrackedItem.id,jobTwo.id,jobOne.id),app.getErrorString(Planned_load_drag_drop_error),
										MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
						return;
					endif;
				endif;
			endif;
		endif;
	endif;

	self.moveTrackedItemTarget(aSlotController); 
	tmpMoveController.ignoreWeightValidation	:=	false;		// cnwdad1 02/08/2010 - PAR #24045.
epilog
	app.myDraggedTrackedItem := null;
	if app.myMoveController &lt;&gt; null then
		delete app.myMoveController;
	endif;
end;</source>
        <Parameter name="_roroController" type="CM_VoyageROROController"/>
        <Parameter name="_isSideViewDrop" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNotesForLegend" id="16999d9c-aa93-4bd9-8d67-218e6bf84048">
        <source>doNotesForLegend(_startNote : Boolean) protected;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/


vars
	anObject : Object;
	idx, numRows : Integer;
	theTable : Table;
begin
	theTable := self.frmColLegendTIs.myLegendTable;
	numRows := theTable.rows;
	foreach idx in 2 to numRows do
		anObject := theTable.accessRow(idx).itemObject;
		if anObject &lt;&gt; null then
			if _startNote then
				self.beginNotification(anObject, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			else
				self.endNotification(anObject, EVENT_CODE_COLOUR_CHANGE);
			endif;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_startNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNotesForLegendStartStop" id="07861723-95ff-40da-97f2-5025fcee7e63">
        <updating/>
        <source>doNotesForLegendStartStop(_view : Integer) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	drawingAttr : CMIF_DrawingAttrController;
begin
	if self.myCurrentVoyage = null then
		return;
	endif;

	self.doNotesForLegend(false);
	
	drawingAttr:=self.setUpDrawAttribute();
	if (not self.frmColLegendTIs.displayCodesForMode(_view,drawingAttr )) then //VIEW_DISPORT
		// could not find any codes/colours in controller so display them all
		self.frmColLegendTIs.doChangeViewMode(_view);
	endif;
	self.doNotesForLegend(true);
epilog
	delete drawingAttr;
	
end;</source>
        <Parameter name="_view" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doNotesOnTimer" id="f0498e77-e64a-4d93-9842-f2e0d3662a9b">
        <updating/>
        <source>doNotesOnTimer(_noteLC : CM_LocationsController) updating;
/*
Purpose:	// PAR 28544 noticed that 40 footers were drawing wrong on note		
Date		Who		Reason
05 December 2011	cnwab1	Initial creation
*/

constants
	MinimumTimerDelay	= 1000;
	
vars
	randomNumber : Integer;
	job			 : CM_Job;
	theTI		 : CM_TrackedItem;	
	theWLE		 : CM_WorkListEntry;	
	aReq : CM_RORORequest;
	defn : CM_DeckItem;
	roroLC : CM_VoyageROROController;
	roroReq : CM_RORORequest;
	locnDefn : CM_ROROLocnDefnVoyage;
	isBE : Boolean;
begin


	if not self.startedTimer then
		randomNumber := 0;
		randomNumber := app.random(10) * 100;
		
		randomNumber := MinimumTimerDelay + randomNumber;
				
		self.beginTimer(randomNumber, Timer_OneShot, 1);
		self.startedTimer := true;
	endif;
	// 28750 Dec 2011 refresh Deck Jobs table
	if _noteLC.isKindOf(CM_ROROSlotController) then
		if _noteLC.CM_ROROSlotController.myRORORequestLoad &lt;&gt; null then
			roroReq := _noteLC.CM_ROROSlotController.myRORORequestLoad;
			job := roroReq.myJob;
		// 28888 Dec 2011 for discharge jobs as well as load
		elseif _noteLC.CM_ROROSlotController.myRORORequestDischarge &lt;&gt; null then
			roroReq := _noteLC.CM_ROROSlotController.myRORORequestDischarge;
			job := roroReq.myJob;
		endif;
		if job &lt;&gt; null then
			if not self.allJobsForNotes.includes(job) then
				self.allJobsForNotes.add(job);
			endif;
		endif;
	endif;	

	if _noteLC.isROROVoyageLanePos then
		defn := _noteLC.CM_ROROLanePositionController.myLanePositionDefn;
	else
		defn := _noteLC.getDefn();
	endif;
	if defn = null then
		return;
	endif;
	
	// ### For CC as this is top down, we mix 20 and 40. If tehre is any 40 then ignore backends
	if  self.modeView = ShpDisplayMode_ColCodeDisch or self.modeView = ShpDisplayMode_ColCodeLoad then
		aReq := defn.getFirst40Request((self.modeView = ShpDisplayMode_ColCodeLoad));
		if aReq &lt;&gt; null then // We have a40 req in this location so use that
			if  aReq.isBackEndRequest() then
				isBE := true;// PAR 28939
				if aReq = roroReq then// PAR 28939
					return;
				endif;
			endif;
		endif;
	elseif  self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_Proposed then

	endif;
	
	// PAR 32021 - If the note is for a linked SOB and we are viewing Discharge, we will get the notes for the load side as well, and we need to ignore them
	if  self.modeView = ShpDisplayMode_ColCodeDisch then
		if defn.isOnLayerLoad then

			return;
		endif;
		
		// 32021 first move to an OOTL load will move it to the actual layer so ignore
		if self.myROROPlanDrawController.modeViewSubSub = ShpDisplayModeSub_ExportsHide then
			if defn.isLocnContainer() then // PAR 32158
				if defn.CM_ROROLocnDefn.isOOTLLocn then // PAR 32158
					if defn.getFirstRequest(false) = null then
						return;
					endif;
				endif;
			endif;
		endif;
	endif;

	// PAR 28939
	if isBE and defn.isLocnContainer() then
		if defn.CM_ROROLocnDefn.myAdjacentSlotFwd &lt;&gt; null then
			defn := defn.CM_ROROLocnDefn.myAdjacentSlotFwd;
		endif;
	endif;
	
	if not self.allLocnsForNotes.includes(defn) then
		self.allLocnsForNotes.add(defn);
	endif;

epilog

end;</source>
        <Parameter name="_noteLC" type="CM_LocationsController"/>
    </JadeMethod>
