    <JadeMethod name="setCCScreenAttributes" id="c60fd263-6d94-4fdc-b528-40fed5071d39">
        <source>setCCScreenAttributes();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 January 2010	cnwas3	Initial creation

*/

vars

	ccScreen : CMUI_YAMaintVoyForm;
	
begin

	if self.myParentForm &lt;&gt; null then
		if self.myParentForm.isKindOf(CMUI_GridAreaForm2) then // PAR 27749
			ccScreen := self.myParentForm.CMUI_GridAreaForm2.getCCScreen();
		elseif parentIsROROplanningForm then
			ccScreen := self.myParentForm.sendMsgWithParams("getCCScreen").CMUI_YAMaintVoyForm;
		endif;
	endif;
	
	if ccScreen &lt;&gt; null and global.isValidObject(ccScreen) then		
		ccScreen.reloadCCVoyageData(self.myCurrentVoyageAllocation);
	endif;
	
epilog

end;</source>
    </JadeMethod>
