    <JadeMethod name="create" id="9f1ac044-e81f-49bf-8620-108a985d8d82">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2014	cnwndl1	Initial creation	Par 34660

*/

vars

begin

	self.idType := CargoIdType;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCargoLabelFormat" id="e02553ab-3d19-43ac-b29f-6f553adbae7a">
        <source>getCargoLabelFormat():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2014	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

begin

	if self.cargoLabelFormat = null then
		return self.DefaultFormat;
	else
		return self.cargoLabelFormat;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
