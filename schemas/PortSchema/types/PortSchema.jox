    <JadeMethod name="sendHeartbeatIfRequired" id="a9a10220-4fa5-4b08-a410-51e9c9c55e98">
        <updating/>
        <source>sendHeartbeatIfRequired() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2017	jlgmp6	Initial creation

*/
constants
	Interval: Integer = 30000;
vars
	elapsed: Decimal[20];
begin
	elapsed := app.relativeMachineTime() - self.lastHeartbeatSent;
	if elapsed.abs() &gt;= Interval then
		self.cnSendHeartbeat();
		self.lastHeartbeatSent := app.relativeMachineTime();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sendMessageToUsers" id="bfa9e3d6-d87a-4772-8e72-d07ef2d28912">
        <updating/>
        <source>sendMessageToUsers(_details : String; _allExtraDetail : StringArray) updating;
// -------------------------------------------
// Created 09 March 2004 by cnwdvb1
// -------------------------------------------
vars
	str,
	msg,
	user,
	fullMsg,
	userNames	: String;
	i 			: Integer;
	ts 			: TimeStamp;
	cancelSend	: Boolean;
begin

	
	ts := app.actualTimeServer();	
	if not app.adminMsgAlertTs &gt; ts.cnEcAddSeconds(1) and app.adminMsgAlertStr = _details  then
		cancelSend := true;
	endif;
	app.adminMsgAlertTs := ts;
	app.adminMsgAlertStr := _details[1:30];

	if cancelSend then
		return;
	endif;
	
	msg := _details &amp; CrLf;
	if _allExtraDetail &lt;&gt; null then
		foreach str in _allExtraDetail do
			msg := msg &amp; str &amp; CrLf;
		endforeach;
	endif;

	if msg = null then
		return;
	endif;
		
	userNames := app.myRoot.getConfig(BGPUsersForMsg).String;

	if userNames = null then
		return;
	endif;
	userNames := '&amp;&amp;' &amp; userNames &amp; '&amp;&amp;' &amp; '%^%';	//We look for this tag in the receival event, if its there it means
																				//the event is for specific users, else we display to all users
																				//(as long as they are running JMTerminal)
	fullMsg := userNames &amp; app.getErrorString2(Send_MessageSentBy, process.userCode, ts.String) &amp; msg;

	system.causeEvent(Event_SendMessage, true, fullMsg);
end;</source>
        <Parameter name="_details" type="String"/>
        <Parameter name="_allExtraDetail" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setAsWebApp" id="9be17e5f-5dab-458c-a234-4e31600fe25b">
