    <JadeMethod name="addContainer" id="4ef7c75d-f6e3-459d-9225-be7040aac1d5">
        <updating/>
        <source>addContainer(ti : CM_TrackedItem) updating;
//Adds the details of this container to our current totals.
vars
	fortyFooter : Boolean;
	empty : Boolean;
begin
	//TI is locked by calling routine
	if ti = null then
		return;
	endif;
	// Determine if empty
	empty := ti.isEmpty;
	// Determine if forty footer
	fortyFooter := (ti.sizeAttributes.bitAnd(ISO_LEN_40) &gt; 0 or ti.sizeAttributes.bitAnd(ISO_LEN_45) &gt; 0);

	if empty then
		if fortyFooter then
			num40Empty := num40Empty + 1;
		else
			num20Empty := num20Empty + 1;
		endif;
		return;
	endif;
	//--------------------
	//NOT MT.
	//--------------------
	if ((ti.typeAttributes.bitAnd(ISO_REEFER) &gt; 0) or 
		 (ti.typeAttributes.bitAnd(ISO_PORTHOLE) &gt; 0)) then
		//These are REEFERS!!
		if ti.isAttributeTrue(TI_Attrib_RequiresTemperature) then
			if fortyFooter then
				num40Reefer := num40Reefer + 1;
			else
				num20Reefer := num20Reefer + 1;
			endif;
		else
			if fortyFooter then
				num40General := num40General + 1;
			else
				num20General := num20General + 1;
			endif;
		endif;
		return;
	endif;
	//----------------
	//These are GENERALS!!
	//----------------
	if fortyFooter then
		num40General := num40General + 1;
	else
		num20General := num20General + 1;
	endif;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
