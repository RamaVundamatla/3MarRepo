    <JadeMethod name="getAuditText" id="8fcf4ab4-2de0-44fe-9cf7-bc0c8b99970a">
        <source>getAuditText(): String;
/*
Purpose:			

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55785
*/

vars
	txt,
	tmpStr	: String;

begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	
	tmpStr := null;
	if self.myBusinessUnit &lt;&gt; null then
		tmpStr :=self.myBusinessUnit.code;
		txt := txt &amp;'Business Unit'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myVessel &lt;&gt; null then
		tmpStr :=self.myVessel.name;
		txt := txt &amp;'Vessel'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myVoyage &lt;&gt; null then
		tmpStr :=self.myVoyage.code;
		txt := txt &amp;'Voyage'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="78e567cc-068c-4707-b15e-06bc86138b4a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Mar 2023 navtnr20	TFS CR 55647 Task 55697: UI - Volume Based Enquiry of Accumulations
07 Apr 2024 navrv30	CR 63386: FR - 54089 - Invoice contract - Accumulations screen details.
11 Oct 2024 navrv30	MTN 33004 Contract Accumulations Add Invoice Line Type
*/

vars
	type 			: String;
	str				: String;
begin
	if _attrName = ETRow_ContractId then
		return self.myContractByVolume.myInvoiceContract.contractId;
	elseif _attrName = ETRow_DebtorName then
		if self.myContractByVolume.myInvoiceContract.myDebtor.name &lt;&gt; null then
			return self.myContractByVolume.myInvoiceContract.myDebtor.name;
		endif;
		
		return null;
	elseif _attrName = ETRow_DateTimeAccum then
		return self.systemToLocalTime(self.createdDateTime).asStringJMT(); // ### TFS BUG 57503 04APR2023 NAVAB1
	elseif _attrName = ETRow_Criteria then
		if  self.myContractByVolume.myInvoiceContractCriteria &lt;&gt; null then
			return self.myContractByVolume. myInvoiceContractCriteria. getCriteriaSummary(",");
		endif;
		return null;
	elseif _attrName = ETRow_Quantity then
		return self.accumulatedQuantity.asStringJMT();
	elseif _attrName = ETRow_ToTS then								//07 Apr 2024 navrv30	CR 63386
		return self.systemToLocalTime(self.myContractByVolume.toTS).asStringJMT();
	elseif _attrName = ETRow_FromTS then							//07 Apr 2024 navrv30	CR 63386
		return self.systemToLocalTime(self.myContractByVolume.fromTS).asStringJMT();
	elseif _attrName = ETRow_TEU then								//07 Apr 2024 navrv30	CR 63386
		return self.accumulatedTEU.asStringJMT();
	elseif _attrName = ETRow_Type then
		if  self.accumulationType = INV_VOL_BASED_PERIOD then // ### TFS BUG 57504 14APR2023 NAVAB1
			return  INV_VOL_BASED_PERIOD_STR; // ### TFS BUG 57504 14APR2023 NAVAB1
		else
			return INV_VOL_BASED_VOYAGE_STR; // ### TFS BUG 57504 14APR2023 NAVAB1
		endif;
	elseif _attrName = ETRow_Voyage then
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.code;
		endif;
		return null;
	elseif _attrName = ETRow_Vessel then
		if self.myVessel &lt;&gt; null then
			return self.myVessel.code;
		endif;
		return null;
	elseif _attrName = ETRow_BusinessUnit then
		if self.myBusinessUnit &lt;&gt; null then
			return self.myBusinessUnit.code;
		endif;
		return null;
	elseif _attrName = ETRow_ForRail then
		return self.myContractByVolume.accumulateForRailReceival.getYes();
	elseif _attrName = ETRow_ForRoad then
		return self.myContractByVolume.accumulateForRoadReceival.getYes();
	elseif _attrName = ETRow_Forship then
		return self.myContractByVolume.accumulateForShipReceival.getYes();
	elseif _attrName = ETRow_InvoiceLineType then	//11 Oct 2024 navrv30	MTN 33004
		return self.myContractByVolume.myInvoiceLineType.narration;
	elseif _attrName.isMeasurementType then		//07 Apr 2024 navrv30	Bug 63386
		_attrName.getRowNameMeasureType(str, type);
		return self.getMeasurementStringForAttrib(str, type, _short);
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="413087e6-ab75-4ed9-8ae4-5485e91da3bf">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Apr 2024 navrv30	CR 63386: FR - 54089 - Invoice contract - Accumulations screen details.

*/
vars

begin
	if _attrName = ETRow_Weight then
		return app.convertMeasurementForDisplay(_measureType, self.accumulatedWeight);
	elseif _attrName = ETRow_Volume then
		return app.convertMeasurementForDisplay(_measureType, self.accumulatedVolume);	
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="276c921a-5c83-49f1-a965-3885e8f3f64b">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2023	navkc1	CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations

*/

vars
	proxy	: SelfType;
begin
	
	proxy := inheritMethod();
	proxy.myBusinessUnit := self.myBusinessUnit;
	proxy.myContractByVolume := self.myContractByVolume;
	proxy.myVessel := self.myVessel;
	proxy.myVoyage := self.myVoyage;
	
	return proxy;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="88820ee1-e130-46f6-914c-ccc947252004">
        <updating/>
        <source>setForCreate(_pxyInvContractAccumulate : CM_InvoiceContractAccumulate) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
