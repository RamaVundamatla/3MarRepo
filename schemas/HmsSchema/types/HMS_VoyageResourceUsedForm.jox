    <JadeMethod name="create" id="3f81c1df-313b-4759-8a98-75dd7c13e081">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		11 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.permissionMaint := PmHMSVoyResUsedMaint; // TFS 2198
	self.permissionView := PmHMSVoyResUsedView;	
	self.helpFileName := HelpFile_Harbour;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnVoyInvStatus" id="94c7b997-a409-4dd9-9067-bba2ad312a8c">
        <updating/>
        <source>doBtnVoyInvStatus() updating;
// ---------------------------------------------------------------------------
// Created:		17 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	theReturn : Integer;
	pxyVoy : CM_Voyage;
	ls : Boolean;
	str : String;
begin
	if self.myCurrentVoyage = null then
		app.msgBox("Please select a voyage","Harbour Invoice Generation Error",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.myCurrentVoyage.statusInvoice = Voyage_Invoice_Status_FullGen then
		if app.msgBox("Invoices for voyage " &amp; self.myCurrentVoyage.code &amp; " have already been generated." &amp; Cr
						&amp; " Are you sure that you want to continue?", "Harbour Invoice Generation", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	else
		str := self.myCurrentVoyage.getMovesReadyForInvoicingStr();
		if str = null then
			app.msgBox("Invoices cannot be generated. Check movement status and occurs on date.", "Harbour Invoice Generation", MsgBox_Question_Mark_Icon);
			return;
		else
			if app.msgBox("Are you sure that you want to"  &amp; Cr 
					&amp; "GENERATE INVOICES"  &amp; Cr  &amp;"for " &amp; str &amp; " for voyage "&amp; self.myCurrentVoyage.code &amp; "?", "Harbour Invoice Generation", 
					MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
				return;
			endif;
		endif;
	endif;
	app.mousePointer := Window.MousePointer_HourGlass;
	app.cmsBeginLoad(ls);
	pxyVoy := app.createUpdateProxy(self.myCurrentVoyage).CM_Voyage;
	app.cmsEndLoad(ls);
	
	while true do
		app.myTrxUA.trxUpdateVoyageInvoiceGen(pxyVoy, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Generate Harbour Invoicing", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	if pxyVoy &lt;&gt; null then
		delete pxyVoy.myShipBlockStack;
	endif;
	delete pxyVoy;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuContextLocateClick" id="b86e9b38-9184-4443-bf55-805b81a91b61">
        <updating/>
        <source>doMnuContextLocateClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		12 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	inv : CM_Invoice;
	invLine : CM_InvoiceLine;
begin
	inv := menuItem.userObject.CM_Invoice;
	
	// PAR 11643 want to see the invoice header, not all the lines
	self.myAssistant.showInvoiceForm(inv, self.myMasterMenuAction);
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTIEdit" id="0794ee96-70a6-4be8-b6d4-66ba81f7df42">
        <updating/>
        <source>doMnuTIEdit(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		12 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aResUsed : HMS_ResourceUsed;
	aMove : HMS_VoyageMovement;
begin
	if menuItem.userObject.isKindOf(HMS_ResourceUsed) then
		aResUsed := menuItem.userObject.HMS_ResourceUsed;
		aMove := aResUsed.myVoyageMovement;
	else
		aMove := menuItem.userObject.HMS_VoyageMovement;
	
	endif;
	if app.getMyUser.canDo(self.myTerminal, PmHMSMovementsMaint) then
		self.myAssistant.showVoyageMovementsForm(aMove, aResUsed, true, self.myTerminal, null);			
	else
		self.myAssistant.showVoyageMovementsForm(aMove, aResUsed, false, self.myTerminal, null);		
	endif;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="3839d670-468d-4a2c-8606-d3c4659fa237">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		if anObject.isKindOf(CM_Voyage) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(EVENT_PLANNING_TI_UNPLANNED));
			endNotification(anObject, self.myTerminal.getTerminalEvent(EVENT_PLANNING_TI_PLANNED));
			endNotification(anObject, self.myTerminal.getTerminalEvent(TIEvent_Transit_Status_Update));
			removedNotification := removedNotification + 1;
		elseif anObject.isKindOf(HMS_ResourceUsed) then
			endNotification(anObject, Object_Update_Event);
			endNotification(anObject, Object_Delete_Event);
			endClassNotification(HMS_ResourceUsed,true,Object_Create_Event);
			removedNotification := removedNotification + 1;
		endif;
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="d6a72d9b-cd88-4f74-8047-5ae8fa4fa626">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:		11 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	header, theType, theCode :String;
begin
//./	if self.myCurrentCellularVoyage = null then
//		app.msgBox("Please select an item from the list.", "No Item Selected", MsgBox_OK_Only);
//		return;
//	endif;

	header := self.caption;
	self.doPrintOutTable(self.tblData,header,(self.isBaseFormModal = false),false, true, false);

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="1b410638-1d0f-4a40-8d93-96e4a3faeb32">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		11 August 2005  By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 24/04/2013	cnwcs5	par 30652 - remove resynch/resynchObject method calls
// 17/01/2019	jlgdap1	TFS 42987 PNL Harbour resoruces displayed with no units and no date/time
vars

	theTable 				: CM_DataTable;
	i : Integer;
	aResUsed, pxyResUsed : HMS_ResourceUsed;
	obj : Object;
	theVoy : CM_Voyage;
	ls, tugsCharged,pilotCharged,linesCharged,launchCharged,wharfCharged : Boolean;
	aVoyMove :	HMS_VoyageMovement;
	gotException	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, theVoy, gotException); // PAR 35940

	self.allResUsed.purge;
	theVoy := self.myCurrentVoyage;
	if theVoy = null then
		return;
	endif;
	if theVoy.myHMSVoyageData = null then
		return;
	endif;
	if gotException then // unit test  // PAR 35940
		return;
	endif;
	
	self.cmbQueryVoyage.listIndex := self.cmbQueryVoyage.findObject(theVoy);
	
	if theVoy = null then
		app.msgBox("Please select a voyage","Query Error",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	self.caption := theVoy.code &amp; " " &amp; theVoy.vesselName &amp; " - " &amp; app.getErrorString(HMS_Voyage_Resources_Used);
	self.tblInfo.rows := 0;
	self.myCurrentResUsed := null;
	theTable := self.tblData;
	theTable.rows := theTable.fixedRows;

	inheritMethod();
	app.cmsBeginLoad(ls);
	foreach aVoyMove in theVoy.myHMSVoyageData.allVoyageMovements discreteLock do

		// ### PAR 11707
		tugsCharged := false;
		pilotCharged := false;
		launchCharged := false;
		linesCharged := false;

		self.doNotableAdd(aVoyMove);
		i := self.tblData.addItem(aVoyMove.getResUsedDescription());
		self.tblData.accessRow(i).itemObject := aVoyMove;
		if aVoyMove.moveStatusNEW = MovementStatus_Actual then
			self.tblData.accessedRow.backColor := Green; //self.ColourLightGreen;
			self.tblData.accessedRow.foreColor := White;
		else
			self.tblData.accessedRow.backColor := Red; //self.ColourLightRed;
			self.tblData.accessedRow.foreColor := Black;
		endif;
		// ### get rid of the check boxes
		
		//par 19980 cnwjo3
		if self.tblData.getColumnByRowName(ETRow_CreateCharge).Integer &lt;&gt; 0 then
			self.tblData.accessCell(i,self.tblData.getColumnByRowName(ETRow_CreateCharge)).inputType := Table.InputType_None ;
		endif;
		
		if self.tblData.getColumnByRowName(ETRow_PartOfContract).Integer &lt;&gt; 0 then
			self.tblData.accessCell(i,self.tblData.getColumnByRowName(ETRow_PartOfContract)).inputType := Table.InputType_None ;
		endif;
		
		foreach aResUsed in aVoyMove.allResourceUsed do
			pxyResUsed := aResUsed.cloneMySelf(true);
			pxyResUsed.setVTMISTransaction4Proxy(aResUsed.myVTMISTransaction);
			self.allResUsed.add(pxyResUsed);
			// ### PAR 11643 do not need to dummy up if has been charged. If has been charged all info is correct
			
			// TFS 41411 self.doQueryAddItem(aResUsed,pxyResUsed,(aResUsed.myVTMISTransaction = null));
			// TFS 42987 put this back in again for JMT default voyage processes
			if theVoy.isUsingDefaultProcessJMT then													// TFS 42987
				self.doQueryAddItem(aResUsed,pxyResUsed,(aResUsed.myVTMISTransaction = null));		// TFS 42987
			else																					// TFS 42987
				self.doQueryAddItem(aResUsed,pxyResUsed,false); // TFS 41411 we have real actual res used so DO NOT dummy up the numbers
			endif;																					// TFS 42987

			if pxyResUsed.myResource &lt;&gt; null then
				if pxyResUsed.myResource.isResourceForClass(HMS_ResourceForTug) then
					tugsCharged := true;
				elseif pxyResUsed.myResource.isResourceForClass(HMS_ResourceForPilot) then
					pilotCharged := true;
				elseif pxyResUsed.myResource.isResourceForClass(HMS_ResourceForPilotLaunch) then
					launchCharged := true;
				elseif pxyResUsed.myResource.isResourceForClass(HMS_ResourceForLineCompany) then
					linesCharged := true;
				endif;
			endif;
		endforeach;
		if not tugsCharged then
			self.dummyUpTugs(aVoyMove);
		endif;
		if not pilotCharged then
			self.dummyUpPilot(aVoyMove);
		endif;
		if not launchCharged then
			self.dummyUpLaunch(aVoyMove);
		endif;
		if not linesCharged then
			self.dummyUpShipLines(aVoyMove);
		endif;
		self.dummyUpWharf(aVoyMove);
	endforeach;
	app.cmsEndLoad(ls);

	if theTable.rows &gt; theTable.fixedRows then
		self.frmQuery.visible := false;
	endif;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="a1c923c9-091a-4aa7-9db8-94bb480eaff3">
        <updating/>
        <source>doQueryAddItem(_realResUsed, _pxyResUsed : HMS_ResourceUsed input;_amend : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		August 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aResUsed : HMS_ResourceUsed;
	theDataLine : String;
	idx, colNumber,backColour : Integer;
	tmpTable : Table;
begin
		
	if not global.isValidObject(_realResUsed) then
//		return;
	endif;
	aResUsed := _realResUsed; 
	
	tmpTable := self.tblData;

	if _amend then
		self.amendPxyResourceUsed(_pxyResUsed); // dummy proxy for display purposes only
	endif;
	theDataLine := _pxyResUsed.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);

	idx := tmpTable.addItem(theDataLine);
	tmpTable.accessRow(idx).itemObject := aResUsed;
	
	tmpTable.accessRow(idx).inputType := Table.InputType_None; //false;

	backColour := self.ColourLightGreen;
	if aResUsed &lt;&gt; null 
	and (aResUsed.myResourceType &lt;&gt; null and not aResUsed.myResourceType.isMarineService) then
		if aResUsed.requiresInput() then
			backColour := self.ColourLightRed;
		endif;
		if aResUsed.myVTMISTransaction &lt;&gt; null then
			//Already invoiced, disable row as cannot change once invoiced
			backColour := self.ColourLightLightGray; 
		endif;
	
	else
		if _pxyResUsed.myVTMISTransaction &lt;&gt; null then
			//Already invoiced, disable row as cannot change once invoiced
			backColour := self.ColourLightLightGray; 
		else
//			if (_pxyResUsed.myResourceType &lt;&gt; null and not _pxyResUsed.myResourceType.isMarineService) then
				if _pxyResUsed.requiresInput() then
					backColour := self.ColourLightRed;
				endif;
//			endif;
		endif;
	
	endif;
	
	tmpTable.accessRow(idx).backColor := backColour;	

	// setup note for this item
	self.doNotableAdd(aResUsed);
	

end;</source>
        <Parameter name="_realResUsed" type="HMS_ResourceUsed" usage="input"/>
        <Parameter name="_pxyResUsed" type="HMS_ResourceUsed" usage="input"/>
        <Parameter name="_amend" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSystemNotification" id="7a71885b-50fc-49d2-99e2-df9a68b258ec">
        <updating/>
        <source>doSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		19 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	inheritMethod(eventType, theObject, eventTag);

	// ### I have my reasons for this....
	self.doQuery();

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="1e08e7c7-05a9-49ba-9bf8-f0649c21ceef">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		11 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	resUsed : HMS_ResourceUsed;
	obj : Object;
	invLine : CM_InvoiceLine;
	aMove : HMS_VoyageMovement;
begin


	obj := cntrl.accessRow(cntrl.row).itemObject;

	self.mnuContextTIEdit.caption :=  "Movement Maintenance...";
	self.mnuContextTIEdit.visible := false;

	if self.isBaseFormModal then
//		return false;
	endif;
	if obj.isKindOf(HMS_ResourceUsed) then
		resUsed := obj.HMS_ResourceUsed;
		if resUsed = null then
			return false;
		endif;
	elseif obj.isKindOf(HMS_VoyageMovement) then
		aMove := obj.HMS_VoyageMovement;
	else
		return false;
	endif;
			
	if resUsed &lt;&gt; null then
		self.mnuContextTIEdit.visible := true;
		
		self.mnuContextLocate.visible :=  false;
		if resUsed.myVTMISTransaction &lt;&gt; null then
			invLine := resUsed.myVTMISTransaction.allInvoiceLines.first;
			if invLine  &lt;&gt; null then
				self.mnuContextLocate.visible := app.getMyUser.canDo(self.myTerminal,PmAdmInvoicelistView);
				self.mnuContextLocate.caption := "Invoice " &amp; invLine.invoice.sequenceNum.String &amp; "...";
				self.mnuContextLocate.userObject := invLine.invoice;
			endif;
		endif;
		if resUsed.myVoyageMovement &lt;&gt; null then
			self.mnuContextTIEdit.userObject := resUsed;
			self.mnuContextTIEdit.caption := self.myCurrentVoyage.code &amp; " " &amp; resUsed.myVoyageMovement.moveType &amp; " " &amp; self.mnuContextTIEdit.caption;
		endif;
	elseif aMove &lt;&gt; null then
		self.mnuContextTIEdit.visible := true;
		self.mnuContextTIEdit.userObject := aMove;
		self.mnuContextTIEdit.caption := self.myCurrentVoyage.code &amp; " " &amp; aMove.moveType &amp; " " &amp; self.mnuContextTIEdit.caption;
	endif;	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuContextTIEdit.enabled := true;
		self.mnuContextLocate.enabled := false;
	endif;
	
	return inheritMethod(cntrl, conwin, mouse, x, y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dummyUpAddToList" id="c14c4321-5a07-4908-8997-84f9604ffe45">
        <updating/>
        <source>dummyUpAddToList(hmsResourceUsedProforma : CMIF_HMSResourceUsedProforma; _move : HMS_VoyageMovement input) updating;
/*
Purpose:			
Date		Who		Reason
06/01/2015	cnwab1	Initial creation
06/11/2015	cnwdap1	PAR #37067 Don't double up on resources (from voyage/vessel resources and wharf resources)
31/03/2020	jlgdap1	TFS 48975 ASPA HMS Charging for Shifts - show all shift movements
*/

vars
	obj : Object;
	existingObj	 : Object;									// PAR #37067
	pxyResUsed : HMS_ResourceUsed;
	existingResUsed : HMS_ResourceUsed;						// PAR #37067

begin
	// PAR #37067 Rewrite so as to not double up on berthage 24 hour resources
	// (one from Berthage resource on voyage, one from Berthage resource on wharf)
	foreach obj in hmsResourceUsedProforma.allResUsed discreteLock do : outerLoop
		foreach existingObj in self.allResUsed do
			existingResUsed := existingObj.HMS_ResourceUsed;
			if ((existingResUsed.myResource &lt;&gt; null and existingResUsed.myResource = obj.HMS_ResourceUsed.myResource)
			or (existingResUsed.myResource = null and existingResUsed.myResourceType = obj.HMS_ResourceUsed.myResourceType))
			and existingResUsed.myVoyageMovement = obj.HMS_ResourceUsed.myVoyageMovement then			// TFS 48975
				continue outerLoop;
			endif;
		endforeach;
		
		pxyResUsed := obj.HMS_ResourceUsed;
		self.doQueryAddItem(pxyResUsed,pxyResUsed,false);
		// ### bodge the object so that the context menu link to MoveMaint can work.
		self.tblData.accessRow(self.tblData.rows).itemObject := _move;
	endforeach;
	
	//hmsResourceUsedProforma.allResUsed.copy(self.allResUsed);
	//foreach obj in hmsResourceUsedProforma.allResUsed discreteLock do
	//	pxyResUsed := obj.HMS_ResourceUsed;
	//	self.doQueryAddItem(pxyResUsed,pxyResUsed,false);
	//	// ### bodge the object so that the context menu link to MoveMaint can work.
	//	self.tblData.accessRow(self.tblData.rows).itemObject := _move;
	//endforeach;
epilog

end;</source>
        <Parameter name="hmsResourceUsedProforma" type="CMIF_HMSResourceUsedProforma"/>
        <Parameter name="_move" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dummyUpLaunch" id="d29d9365-c2f4-4b37-b1a2-e21fa5a5ab68">
        <updating/>
        <source>dummyUpLaunch(_move : HMS_VoyageMovement input) updating;
// ---------------------------------------------------------------------------
// Created:		27 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
