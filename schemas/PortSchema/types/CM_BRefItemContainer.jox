    <JadeMethod name="getDataForDefSpecial" id="64c77c79-5d35-4eca-a25a-fced08456eee">
        <source>getDataForDefSpecial(_attrName: String; _heading: String; _headings: StringArray input; _data: HugeStringArray input): Boolean protected;
/*
	Created on 11 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	tmpStr			: String;

begin
	if _attrName = ETRow_Temperature then
		if self.getTemperature() = NULL_TEMPERATURE then
			tmpStr := null;
		else
			tmpStr := self.getTemperature.String;
		endif;
		_headings.add(_heading);
		_data.add(tmpStr);
		return true;
	else
		return inheritMethod(_attrName, _heading, _headings, _data);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayObject" id="329e7796-9c7e-4435-acd1-441d36eb2ace">
        <source>getDisplayObject(): CM_DisplayObject;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2008	cnwer1	Initial creation

*/

vars

	displayObject : CM_DisplayObject;

begin

	create displayObject transient;
	displayObject.myDisplayClass:=self.class;
	
	displayObject.addDisplayProperty(CM_BRefItemContainer::quantity,null,"Quantity");
	displayObject.addDisplayProperty(CM_BRefItemContainer::weight,null,"Weight");
	displayObject.addDisplayProperty(CM_BRefItemContainer::isoType,null,"ISO Type");
	displayObject.addDisplayProperty(CM_BRefItemContainer::commodity,null,"Commodity");
	displayObject.addDisplayProperty(CM_BRefItemContainer::description,null,"Description");
	displayObject.addDisplayProperty(CM_BRefItemContainer::allTIHazards ,CM_BRefItemContainer::getTIHazardsDesc,"Hazards");
	displayObject.addDisplayProperty(CM_BRefItemContainer::clean,null,"Is Clean");
	displayObject.addDisplayProperty(CM_BRefItemContainer::myReeferProperties,CM_ReeferProperties::getHumidityAsString,"Humidity");
	displayObject.addDisplayProperty(CM_BRefItemContainer::myReeferProperties,CM_ReeferProperties::getTemperature,"Temp");
	displayObject.addDisplayProperty(CM_BRefItemContainer::myReeferProperties,CM_ReeferProperties::getVentilation,"Ventilation");
	displayObject.addDisplayProperty(CM_BRefItemContainer::myReeferProperties,CM_ReeferProperties::getVentilationUnits,"Ventilation Unit");
//	displayObject.addDisplayProperty(CM_BRefItemContainer::carbonDioxide,null,"CO2");
	displayObject.addDisplayProperty(CM_BRefItemContainer::myReeferProperties,CM_BRefItemContainer::getCarbonDioxide,"CO2");
	displayObject.addDisplayProperty(CM_BRefItemContainer::myReeferProperties,CM_BRefItemContainer::getOxygen,"O2");
//	displayObject.addDisplayProperty(CM_BRefItemContainer::curtainsIn,null,"Curtains In");
	displayObject.addDisplayProperty(CM_BRefItemContainer::myReeferProperties,CM_BRefItemContainer::getCurtainsIn,"Curtains In");

	
	return displayObject;

epilog

end;</source>
        <ReturnType type="CM_DisplayObject"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="fc0e52e7-6cd4-4415-a1b6-4f146e10675b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
	Created on 11 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	tmpStr	: String;
	tmpReal : Real;
begin
	if _attrName = ETRow_Temperature then //par15242 cnwrs1 Nov 2007
		tmpReal := self.getTemperature();
		if tmpReal &lt;&gt; NULL_TEMPERATURE then
			tmpStr := app.temperatureDisplayString(tmpReal);
		else
			tmpStr := "";
		endif;
		return tmpStr;
	elseif _attrName = ETRow_Stevedore then // ### TFS 50421 17SEP2021 NAVAB1
		return ""; // ### TFS 50421 17SEP2021 NAVAB1
	endif;
	
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="23d1c5c9-1257-4ab6-9ada-71188e80c74e">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwml2	Initial creation

*/

vars
	block : CM_DataContainerBlock;

begin
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(CargoType), DC_Label, 1, null);
	block.addNewItem(self.cargoTypeDescr, DC_Data, 1, null);
	
	if self.myProduct &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getString(SubCargoType), DC_Label, 1, null);
		block.addNewItem(self.myProduct.code, DC_Data, 1, null);
	else
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getString(ISO_Group), DC_Label, 1, null);
		block.addNewItem(self.isoTypeGroup, DC_Data, 1, null);
	
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getString(ISO_Type), DC_Label, 1, null);
		block.addNewItem(self.isoType, DC_Data, 1, null);
	endif;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(CM_Commodity_GC), DC_Label, 1, null);
	block.addNewItem(self.commodity, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(NumberOfItems), DC_Label, 1, null);
	block.addNewItem(self.getQuantity.asStringJMT, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(CM_Total_Weight), DC_Label, 1, null);
	block.addNewItem(self.weight.asStringJMT(), DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getString(Description), DC_Label, 1, null);
	block.addNewItem(self.description, DC_Data, 1, null);
	
	if self.myProduct &lt;&gt; null then
		if self.myCargoType.allAttributesOnProduct.includes(ETRow_MyWeight) then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getString(Weight_sub_cargo), DC_Label, 1, null);
			block.addNewItem(self.productWeight.asStringJMT(), DC_Data, 1, null);
		endif;
		
		if self.myCargoType.allAttributesOnProduct.includes(ETRow_MyLength) then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getString(Length_sub_cargo), DC_Label, 1, null);
			block.addNewItem(self.lengthString, DC_Data, 1, null);
		endif;
		
		if self.myCargoType.allAttributesOnProduct.includes(ETRow_MyWidth) then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getString(Width_sub_cargo), DC_Label, 1, null);
			block.addNewItem(self.widthString, DC_Data, 1, null);
		endif;
		
		if self.myCargoType.allAttributesOnProduct.includes(ETRow_MyHeight) then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getString(Height_sub_cargo), DC_Label, 1, null);
			block.addNewItem(self.heightString, DC_Data, 1, null);
		endif;
		
		if self.myCargoType.allAttributesOnProduct.includes(ETRow_MyVolume) then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getString(Volume_sub_cargo), DC_Label, 1, null);
			block.addNewItem(self.productVolume.asStringJMT(), DC_Data, 1, null);
		endif;
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getString(CM_Type), DC_Label, 1, null);
		block.addNewItem(self.typeString, DC_Data, 1, null);
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getString(CM_ID), DC_Label, 1, null);
		block.addNewItem(self.id, DC_Data, 1, null);
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getString(Marks), DC_Label, 1, null);
		block.addNewItem(self.shippingMarks, DC_Data, 1, null);
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getString(Mark_Number), DC_Label, 1, null);
		block.addNewItem(self.markNumber, DC_Data, 1, null);
		
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getString(Colour), DC_Label, 1, null);
		block.addNewItem(self.colour, DC_Data, 1, null);
	endif;
	
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
