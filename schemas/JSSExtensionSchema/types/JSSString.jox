    <JadeMethod name="getPatternMatch" id="b7c5d1de-7899-4894-ba96-ea8f4707a022">
        <source>getPatternMatch(pIsCaseInsensitive:Boolean; pIsCheckLength:Boolean):Integer;
// --------------------------------------------------------------------------------
// Created:		29 June 2001 by cnwdad1
//
// Purpose:		Validate a string value against a string format mask.
//
// Parameters:	pIsCaseInsensitive (Boolean) - Indicates whether upper and lower
//				case is significant.
//				pIsCheckLength (Boolean) - Indicates whether the string being
//				compared can be longer than the length of the mask string.
//
// Returns:		Integer - The position of an invalid character, or zero if the
//				string successfully matches the mask.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.stringValue.jssCompareToMask(self.patternValue, pIsCaseInsensitive, pIsCheckLength);
end;</source>
        <Parameter name="pIsCaseInsensitive" type="Boolean"/>
        <Parameter name="pIsCheckLength" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPatternOccurrences" id="0b3c71d3-c1eb-4c7e-9530-c73b34042714">
        <source>getPatternOccurrences(pAllSubstrings:JSSSubstringArray io);
// --------------------------------------------------------------------------------
// Created:		29 June 2001 by cnwdad1
//
// Purpose:		Returns an array (JSSSubstringArray) of all occurrences of the
//				pattern value within the string value.
//
// Parameters:	pArray - An array with one element for each occurrence of the
//				pattern value.  Each element contains the pattern value, and its
//				(starting) position within the string value.
//
// Returns:		pAllSubstrings - The IO array of substrings.
//
// ***************************************************************************
// * NOTE: The members of the array will be instances of JSSSubstringObject. *
// ***************************************************************************
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	substringIndex	: Integer;
	dataString		: String;
	dataLength		: Integer;
	maskString		: String;
	position		: Integer;
	maskLength		: Integer;
	
begin
	pAllSubstrings.purge();
	
	dataString	:=	self.stringValue;
	dataLength	:=	dataString.length();
	maskString	:=	self.patternValue;
	maskLength	:=	maskString.length();
	position	:=	1;
	
	while true do
		position	:=	dataString.pos(maskString, position);
		
		if position = 0 then
			break;
		endif;
		
		substringIndex	:=	pAllSubstrings.addString(maskString);
		pAllSubstrings[substringIndex].setPosition(position);
		
		position	:=	position + maskLength;
		
		if position &gt; dataLength then
			break;
		endif;
	endwhile;
end;</source>
        <Parameter name="pAllSubstrings" type="JSSSubstringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setPatternValue" id="801dde1f-6388-42ea-98d1-16413f03a655">
        <updating/>
        <source>setPatternValue(pPatternValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		29 June 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.patternValue &lt;&gt; pPatternValue
	and self.validatePattern(pPatternValue)
	then
		self.patternValue	:=	pPatternValue;
	endif;
end;</source>
        <Parameter name="pPatternValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="baa0ab7b-2b82-4cd6-9011-737973ab3d95">
        <updating/>
        <source>updateMe(pStringValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		29 June 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.stringValue &lt;&gt; pStringValue then
		self.stringValue	:=	pStringValue;
	endif;
end;</source>
        <Parameter name="pStringValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="validatePattern" id="596ae0fc-08a0-4bdb-97e5-32af4be49f05">
        <source>validatePattern(pPatternValue:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		29 June 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	matchResult	: Integer;
	
begin
	matchResult	:=	pPatternValue.jssValidateAsMask;
	
	if matchResult = 0 then
		return true;
	else
		JSSException.raise_(JSS_X_03007, "Invalid pattern mask character at position " &amp; matchResult.String &amp; ".");
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pPatternValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
