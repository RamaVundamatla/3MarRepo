        <updating/>
        <source>bOk_click(btn: Button input) updating;

vars
	
begin
	self.doLogon(false);
epilog
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnExit_click" id="187b5605-5478-4f24-99db-da979148b44e">
        <controlMethod name="Picture::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExit_click(pict: Picture input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 March 2024		jlizm1	Initial creation TFS 54869 Exit button on login screen

*/

vars
	i : Integer;
	
begin
	i := app.msgBox(app.getErrorString(WARN_CLOSEDOWN),
	                "Closing Down",
	                MB_CRITICAL + MB_YESNO);
					
	if i = MB_YES then
		self.modalResult:=IDCANCEL;
		self.unloadForm;
	endif;
	
epilog

end;</source>
        <Parameter name="pict" type="Picture" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnLoginMTN_click" id="8d534288-18a1-4e8e-a05d-acad754d3a68">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnLoginMTN_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 August 2022	navmd1	Initial creation TFS 52824
25 Aug 2025 	navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client

*/

vars

begin
	btn.visible := false;
	self.btnLoginSSO.visible := false;
	self.btnLoginOktaSSO.visible := false;
	
	// try catch block, try to set Okta SSO in-flight to off, skip any exception
	on Exception do self.skipOktaException(exception);
	app.mySSOAgent.setOktaSsoInFlightOff(); // in case Okta Sso is running, stop the listener
	on Exception do null; // reset exception handler
	
	self.showHideLoginControls(true);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnLoginOktaSSO_click" id="e7eebed4-d932-427f-bac4-54aa9fb20ec8">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnLoginOktaSSO_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
01 Sept  2025 	navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client

*/

vars

begin
	self.doLogon(true);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnLoginSSO_click" id="6c6aeebe-447e-47f8-b85b-15dca312480b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnLoginSSO_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2022 navam1 ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN

*/

vars
	
begin
	self.doLogon(true);
epilog
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
