    <JadeMethod name="btnOnHold_click" id="21c1c5f6-781e-4fe1-b221-5dcf3c164c1a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOnHold_click(btn: Button input) updating;
// -------------------------------------------
// Created 01 February 2006 by cnwdvb1
// -------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.aIsOnHold then
		if self.doResetFromOnHold() then
			self.setOnHoldBtn(false);
		endif;
	else
		if self.doPlaceOnHold() then
			self.setOnHoldBtn(true);
		endif;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
