<GUIClass name="CMUI_ComboBoxBookRefItem" id="34a2fcc7-ef70-46a7-acaf-6da2e2e8c1ac">
    <superclass name="CMUI_ComboBoxObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myBookingRef" id="fdde5cf4-3a58-4c7d-a534-24364450ddbd">
        <embedded/>
        <type name="CM_BookingRef"/>
    </ImplicitInverseRef>
    <JadeMethod name="clear" id="3dfa3111-e0c5-4ed0-a12f-cc1089159ac1">
        <updating/>
        <source>clear() updating;
/*
	Created on 28 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	inheritMethod();
	setMyBookingRef(null);
end;</source>
    </JadeMethod>
    <JadeMethod name="displayEntry" id="ad83ba1a-971c-4b75-a86a-597187179e62">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; brItem : CM_BookingRefItem; lstIndex: Integer): String updating, clientExecution;
/*
	Created on 26 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	return brItem.getShortDisplay();
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="brItem" type="CM_BookingRefItem"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="37534aa5-2920-47f5-a67b-1449888d0ef4">
        <source>getCollectionJMT(): Collection protected;
/*
	Created on 26 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if self.myBookingRef = null then 
		return null;
	else 
		return self.myBookingRef.allBookingRefItems;
	endif;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setMyBookingRef" id="8df7d465-9bb7-4972-854b-88a94ca62758">
        <updating/>
        <source>setMyBookingRef(br : CM_BookingRef)updating;
/*
	Created on 28 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	self.myBookingRef := br;
	self.init();
end;</source>
        <Parameter name="br" type="CM_BookingRef"/>
    </JadeMethod>
