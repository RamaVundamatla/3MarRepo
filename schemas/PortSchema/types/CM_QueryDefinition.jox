    <JadeMethod name="createCriteriaLine" id="1012417e-e0ed-4db1-a00f-5d7d44735e09">
        <source>createCriteriaLine(_propName : String; _qOperatorStr : String; _value : Any) : CM_SelectorCriteriaLine;
// ---------------------------------------------------------------------------
// Created:     03 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	criteria 			: CM_SelectorCriteriaLine;
	clonedProp,
	existingProp		: CM_QueryProperty;
	clonedOp,
	existingOp			: CM_QueryOperator;
	value				: Any;
begin
	
	existingProp := self.allQueryProperties[_propName];
	if existingProp = null then
		app.raiseUnexpectedProgramError(class.name, method.name, _propName &amp; ' query property was not created!');
		return null;
	endif;
	
	existingOp := existingProp.allAllowedOperators[_qOperatorStr];
	
	// 08 Dec 2016	NDL	special case for Hand Held TFS 3024 / 2370
	if existingOp = null then
		if _propName = CM_TrackedItem::getColour.name and _qOperatorStr = CM_QueryOperator.Operator_IsOneOf and _value &lt;&gt; null and _value.isKindOf( StringArray ) then
			existingOp := CM_QStringIsOneOf.firstInstance;
		endif;
	endif;
		
	if existingOp = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Query Operator object is not allowable for this property');
		return null;
	endif;
	clonedProp := existingProp.cloneSelf(true);
	clonedOp := existingOp.cloneSelf(true);
	
	value := clonedProp.translateToSearchValue(_value);
	clonedOp.setSearchValue(value);
	
	create criteria transient;
	criteria.set(clonedProp, clonedOp, false);
	return criteria;
	
end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_qOperatorStr" type="String"/>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="CM_SelectorCriteriaLine"/>
    </JadeMethod>
    <JadeMethod name="createMeasurementProperties" id="7685652a-933c-461a-bcc7-95d53b58dd67">
        <source>createMeasurementProperties(_queryClass : Class; _measureType, _niceName, _propertyName, _className : String; _allocationAttrib : Integer) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/08/2014	cnwdap1		Initial creation PAR #33235 Measurement types in Summaries
// 03/12/2014   cnwma1      PAR #35298 Cannot specify ranges for "Total Weight (kg)" and "Total Weight (MT)" in Selector Query
//12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields
vars
	property : CM_QRefMeasurementProperty;
	measure : CM_MeasurementType;

begin
	foreach measure in app.myRoot.allMeasurementTypesByShortName discreteLock where measure.measurementType = _measureType do
		if not measure.isDisplay or not measure.isAvailableForEntry then
			continue;
		endif;
		//create property persistent;
		if _measureType = Type_Weight then       // 03/12/2014  cnwma1 PAR #35298
			//12/11/2023 navmv20 Bug 61113 - start
			if _queryClass = CM_QRefMeasureWtsProperty then
				create property as CM_QRefMeasureWtsProperty persistent;
			else
				create property as CM_QRefMeasureWeightProperty persistent;
			endif;
		elseif _measureType = Type_Volume and _queryClass = CM_QRefMeasureVolsProperty then
			create property as CM_QRefMeasureVolsProperty persistent;
			//create property as CM_QRefMeasureWeightProperty persistent;
			//12/11/2023 navmv20 Bug 61113 - end	
		else
			create property persistent;
		endif;
		
		property.set(_niceName &amp; Space &amp; Left_Round_Bracket &amp; measure.shortName &amp; Right_Round_Bracket, measure.shortName &amp; CN_UNDERSCORE &amp; _propertyName, _className);
		if _allocationAttrib &lt;&gt; null then
			property.allocationAttribute := _allocationAttrib;
		endif;
		property.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
		self.allQueryProperties.add(property);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_queryClass" type="Class"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_niceName" type="String"/>
        <Parameter name="_propertyName" type="String"/>
        <Parameter name="_className" type="String"/>
        <Parameter name="_allocationAttrib" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createProperties" id="e898d813-e336-4803-8249-79ea76595a60">
        <source>createProperties();
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	tmpProp		: CM_QueryProperty;
	
begin
	//must re-implement
	create tmpProp as CM_QRefTerminalProperty persistent;
	tmpProp.set('Terminal', 'myTerminal', self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
end;</source>
    </JadeMethod>
