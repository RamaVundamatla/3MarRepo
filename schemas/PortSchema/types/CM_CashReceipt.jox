    <JadeMethod name="setCashInvoice" id="259e2f9a-0e43-4c18-80bb-4d8c86fce20c">
        <updating/>
        <source>setCashInvoice(_invoice : CM_Invoice) updating;

vars
	finIO : CM_ExtFinanceIO;
	terminal : CM_Terminal;
begin
	self.myCashInvoice := _invoice;
	
	
	// TFS 38682 - ADP need the cash invoice for their number so that it is the same on the cash invoice and the cash recipt
	// For ADP at this point the externalInvoiceNumberis blank, but now we have the invoice we can re call the standard code to 
	// get the invoice's number.
	if self.externalInvoiceNumber = null and
		not self.paymentStatus = CM_CashReceipt.API_RECEIPT_DRAFT then //11/07/2024	navkc1 CR 64839 Task 64856

		terminal := self.getDebtorTerminal().myTerminal;
		if terminal &lt;&gt; null then
			finIO := terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
			
			if finIO &lt;&gt; null then
				self.externalInvoiceNumber := finIO.getExternalReciptNumber(self);				
			endif;
		endif;
	endif;
end;
</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="setDDOtherReceipts" id="037a7e57-2238-4cd4-83b7-29d7870629fe">
        <source>setDDOtherReceipts( _value : ObjectArray );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2014	cnwndl1	Initial creation	Par 33181

*/

vars

	obj : Object;
	str : String;

begin

	if _value = null or _value.isEmpty then
		global.setExtraData (self.allExtraData, self, self.DD_OtherReceipts, null);
		return;
	endif;

	foreach obj in _value do
		if obj &lt;&gt; self then
			if str &lt;&gt; null then
				str := str &amp; ",";
			endif;
			str := str &amp; obj.getOidString;
		endif;
	endforeach;
	
	if str.trimBlanks = null then
		global.setExtraData (self.allExtraData, self, self.DD_OtherReceipts, null);
		return;
	endif;

	global.setExtraData (self.allExtraData, self, self.DD_OtherReceipts, str);

epilog

end;</source>
        <Parameter name="_value" type="ObjectArray"/>
    </JadeMethod>
