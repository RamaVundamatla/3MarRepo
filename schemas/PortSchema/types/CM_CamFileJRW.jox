    <JadeMethod name="setMessageCount" id="77a53ef2-136d-4a0b-bfad-b3435b448ddf">
        <updating/>
        <source>setMessageCount(_value :Integer)updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2010 by cnwcs5
// Purpose:     Used to set the number of transactions in a user defined CAM file
// Parameters:  _value - the number of transactions included in the file
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//				cnwcs5		PAR 23967 - initial version
// ---------------------------------------------------------------------------
vars

begin
	self.messageCount := _value;
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateFileContentFromFile" id="ef7e6791-322c-4e18-8e71-290ce2c2818e">
        <updating/>
        <source>updateFileContentFromFile() : Boolean updating;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     Open and red in the file content of the file created by the JRW. 
			  Assumpetion is that the record lines won't be longer than 2047 which is max allowed in huge string array

 Parameters:  None

 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 //06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
 //31 Mar 2017  cnwma1  TFS #3756:MSL - Fw: CAMS (1035). (String too long)
 ---------------------------------------------------------------------------
*/

vars
	infile : File;
	s,
	fileData : String; 
	theLines : HugeStringArray;
	
begin
	
	//epr TFS 2434 27/7/16 in File::readline was always returning null string and an entry in jom if we had illegal utf character  now reading binary
	self.myFileDataStorageHeader := app.writeFileToBinary(self.jrwFilename, false, self.isTransient, null,false);
	
	if self.myFileDataStorageHeader = null then
		app.writeLog(method.name &amp; Space &amp; DoubleQuote &amp; jrwFilename &amp; DoubleQuote &amp; ' output file not found', LogINFO);
		return false;
		
	else
		/* //31/03/2017 cnwma1 TFS #3756
		fileData:=self.myFileDataStorageHeader .getDataAsBinary.String;
		fileData := fileData.replaceString(CrLf, Cr);
		fileData := fileData.replaceString(Lf, Cr);
		fileData.getTokensForDelimiterHugeNoNul(Cr,self.allFileContent);
		*/
		
		return true;
	endif;
	
/*		
	create infile transient;
	infile.fileName 	:= jrwFilename;
	infile.mode 		:= File.Mode_Input;
	infile.kind			:= File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version

	if infile.tryOpen  then
		while not infile.endOfFile do
			s := infile.readLine;
			self.allFileContent.add (s[1:2047]);
		endwhile;
	
		infile.close;
		
		// the max in a hugeStringArray is 2047. Just in case they use a slob in the JRW we need to allow for more. So we 
		// will also store in these classes which handle this. They also handle slobs &gt; 500000 bytes.
		if  allFileContent.size &gt; 0 then
		
			infile.kind := File.Kind_Binary;
			
			if self.isTransient then
				create myFileDataStorageHeader transient;
			else
				create myFileDataStorageHeader persistent;
			endif;
			myFileDataStorageHeader.set (infile.fileName , 0);
			myFileDataStorageHeader.setDetailsFromFile ( infile, null, null);
		endif;
				
		return true;
	else
		
		
		// cnwrl1 13/10/2010 PAR 23667 - start of replacement coding
		// Do not need to raise an exception here - just return false
		app.writeLog(method.name &amp; Space &amp; DoubleQuote &amp; jrwFilename &amp; DoubleQuote &amp; ' output file not found', LogAlways);
		return false;
		// cnwrl1 13/10/2010 PAR 23667 - end of coding
	endif;
	*/
epilog
	delete infile;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
