    <JadeMethod name="translateForm" id="571621b8-e30a-4b15-a0e6-62f2dec5d3db">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010926, locale);
	btnCancel.translateCaption(Xlat_0010927, locale);
	btnOK.translateCaption(Xlat_0010928, locale);
	lDestination.translateCaption(Xlat_0010929, locale);
	lDischarge.translateCaption(Xlat_0010930, locale);
	lHeader1.translateCaption(Xlat_0010931, locale);
	lHeader2.translateCaption(Xlat_0010932, locale);
	lSubHeader1.translateCaption(Xlat_0010933, locale);
	lSubHeader2.translateCaption(Xlat_0010934, locale);
	lVoyage.translateCaption(Xlat_0010935, locale);
end;</source>
    </JadeMethod>
</GUIClass>
