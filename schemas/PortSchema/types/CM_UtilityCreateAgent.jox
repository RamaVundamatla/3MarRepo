    <JadeMethod name="utlCreateDutyDoc" id="c8000a0a-99c2-4654-930c-e6bd0dbad9d3">
        <source>utlCreateDutyDoc(_proxyDutyDoc : CM_DutyDoc; _newDutyDoc : CM_DutyDoc output; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

	dutyDeposit : Decimal [16,4];
	debtor : CM_Debtor;

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCM_Object(_proxyDutyDoc, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	create _newDutyDoc persistent;
	_newDutyDoc.setForCreate(_proxyDutyDoc);
	
	if not _passport.noErrors then
		return;
	endif;
	
	debtor := _newDutyDoc.getMyDebtor();
	if _newDutyDoc.docDeposit and debtor &lt;&gt; null then
		//generate the doc deposit inv line
		self.utlCreateDutyDocDocDepositChg(_newDutyDoc, _passport);
	endif;
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _newDutyDoc.dutyDeposit &gt; 0 and debtor &lt;&gt; null then
		//generate the duty deposit inv line
		dutyDeposit := _newDutyDoc.dutyDeposit;
		self.utlCreateDutyDocDutyDepositChg(_newDutyDoc, dutyDeposit, _passport);
	endif;
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newDutyDoc);
	endif;
epilog

end;</source>
        <Parameter name="_proxyDutyDoc" type="CM_DutyDoc"/>
        <Parameter name="_newDutyDoc" type="CM_DutyDoc" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateDutyDocChargeTrans" id="0441b8d8-695a-437f-9e00-05dec5546f5c">
        <source>utlCreateDutyDocChargeTrans(_dutyDoc : CM_DutyDoc;_ti: CM_TrackedItem input; _charge: Decimal; _void:Boolean;  _txn: CM_TITransaction output; _passport: CM_Passport input);
// 31-JUL-2014 cnwma1 PAR 34408 Credit Customer current charges
//22.06.2024 navrv30 Task 64598: Jade - ReserveLock on Invoice
vars
	txnController: CMIF_TITransactionController;
	txn: CM_TITransaction;
	invoiceLine, pxyInvoiceLine: CM_InvoiceLine;
	pxyCharge: CM_Charge;
	invoiceStatus : CMIF_InvoiceStatus;

	invoices : CM_InvoiceSet;
	inv : CM_Invoice;
begin
	
	create invoices transient; // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1

	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	create txnController transient;
	txnController.noCharge := false;
	txnController.type 		:= TRANS_TYPE_DUTY_CHARGE;
	txnController.myTrackedItem := _ti;
	
	app.myUtilityCA.utlCreateTITransaction(txnController, txn, _passport);
	
	if not _passport.noErrors or txn.allInvoiceLines.size = 0 or txn.allInvoiceLines.first.charges.size = 0 then
		return;
	endif;
	
	if _charge &gt; 0 then
	// Update the charge
		invoiceLine := txn.allInvoiceLines.first;
		if invoiceLine &lt;&gt; null then
			if invoices.tryAddIfNotNull(invoiceLine.invoice) then   // ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
				reserveLock(invoiceLine.invoice);					//22.06.2024 navrv30 Task 64598
			endif;
		endif;
		
		if _void then
			pxyInvoiceLine := app.createUpdateProxy(invoiceLine).CM_InvoiceLine;
			
			//epr par 36958 29/9/15
			create invoiceStatus transient;
			invoiceStatus.newStatus:= CM_InvoiceLine.STATUS_VOIDED;
			
			app.myUtilityUA.utlUpdateInvoiceLineStatus( pxyInvoiceLine,invoiceStatus, _passport);
		endif;
		pxyCharge := app.createUpdateProxy(invoiceLine.charges.first).CM_Charge;
		pxyCharge.setProxyRateNew(_charge);
		//app.myUtilityUA.utlUpdateChargesManual(pxyCharge, _passport); 			//- cnwma1 31/07/2014 PAR 34408
		 app.myUtilityUA.utlUpdateDutyChargesManual(_dutyDoc,pxyCharge, _passport); //+ cnwma1 31/07/2014 PAR 34408
	endif;	
	
	_txn := txn;
	
	// ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
	foreach inv in invoices do
		inv.setTaxDetailsFromLines();
		inv.setTotalAmountFromLines();
	endforeach;
epilog
	delete invoices;
	delete txnController;
	delete pxyCharge;
	delete pxyInvoiceLine;
	delete invoiceStatus;
end;</source>
        <Parameter name="_dutyDoc" type="CM_DutyDoc"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_charge" type="Decimal"/>
        <Parameter name="_void" type="Boolean"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateDutyDocDocDepositChg" id="265a2a39-55b1-433c-979d-1565a5562d37">
        <source>utlCreateDutyDocDocDepositChg(_dutyDoc: CM_DutyDoc input; _passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2013	cnwndl1	Initial creation	Par 30901
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type

*/

vars

	debtor: CM_Debtor;
	manController : CMIF_InvoiceLineManual;
	now: Date;
	time: Time;
	businessUnit: CM_Bank;
	invoiceLine: CM_InvoiceLine;
	invoiceLineDesc : CM_InvoiceLineDesc;

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	debtor := _dutyDoc.getMyDebtor();
	businessUnit := _dutyDoc.getBank;
	invoiceLineDesc := businessUnit.invoiceLineDescriptors["Duty Documentation Deposit"];
	if invoiceLineDesc = null then
		app.raiseCMException1(Inv_line_type_not_set_up,"Duty Documentation Deposit",null,null);
		return;
	endif;
	
	create manController transient;
	manController.quantity := 1;
	manController.chargeTime.setDate(now);
	manController.chargeTime.setTime(time);
	manController.remarks := _dutyDoc.id.String; // ### JIRA 33007 10DEC2024 NAVAB1
	//manController.myInvoiceLineType := invoiceLineDesc; //10 March 2023  navmv20 TFS 56128 Task 56129
	manController.allInvoiceLineTypes.add(invoiceLineDesc); //10 March 2023  navmv20 TFS 56128 Task 56129
	manController.myInvoice := businessUnit.getAutoInvoice(invoiceLineDesc.getInvoiceType(debtor), invoiceLineDesc, null, debtor, false);
	
	app.myUtilityCA.utlCreateInvoiceLineManual(manController, invoiceLine, app.myPassport);
	

epilog

end;</source>
        <Parameter name="_dutyDoc" type="CM_DutyDoc" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateDutyDocDutyDepositChg" id="ebf28f8a-4cc8-4024-8992-74352732a0b0">
        <source>utlCreateDutyDocDutyDepositChg(_dutyDoc: CM_DutyDoc input; _charge: Decimal; _passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2013	cnwndl1	Initial creation	Par 30901
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
*/

vars

	debtor: CM_Debtor;
	manController : CMIF_InvoiceLineManual;
	now: Date;
	time: Time;
	businessUnit: CM_Bank;
	invoice: CM_Invoice;
	invoiceLineDesc : CM_InvoiceLineDesc;
	invoiceLine, pxyInvoiceLine: CM_InvoiceLine;
	pxyCharge: CM_Charge;
	ti: CM_TrackedItem;
	tis: CM_TISet;
	voidStatus : CMIF_InvoiceStatus; 
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	debtor := _dutyDoc.getMyDebtor();
	businessUnit := _dutyDoc.getBank;
	invoiceLineDesc := businessUnit.invoiceLineDescriptors["Duty Deposit"];
	if invoiceLineDesc = null then
		app.raiseCMException1(Inv_line_type_not_set_up,"Duty Deposit",null,null);
		return;
	endif;
	
	create manController transient;
	manController.quantity := 1;
	manController.chargeTime.setDate(now);
	manController.chargeTime.setTime(time);
	manController.remarks := _dutyDoc.id.String; // ### JIRA 33007 10DEC2024 NAVAB1
	//manController.myInvoiceLineType := invoiceLineDesc; //10/03/2023  navmv20 TFS 56128 Task 56129
	manController.allInvoiceLineTypes.add(invoiceLineDesc); //10/03/2023  navmv20 TFS 56128 Task 56129
	manController.myInvoice := businessUnit.getAutoInvoice(invoiceLineDesc.getInvoiceType(debtor), invoiceLineDesc, null, debtor, false);
	
	app.myUtilityCA.utlCreateInvoiceLineManual(manController, invoiceLine, app.myPassport);
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _charge &gt; 0 and invoiceLine &lt;&gt; null then
	// Update the charge
		pxyCharge := app.createUpdateProxy(invoiceLine.charges.first).CM_Charge;
		pxyCharge.setProxyRateNew(_charge);
		app.myUtilityUA.utlUpdateChargesManual(pxyCharge, _passport); 
	
		//epr par 36958 30/9/15
		create voidStatus transient;
		voidStatus.newStatus:=CM_InvoiceLine.STATUS_VOIDED;
		// Void Duty charges on the cargo
		create tis transient;
		_dutyDoc.getTIsFor(_dutyDoc.allDutyDocItems, tis);
		foreach ti in tis do
			invoice := ti.allInvoices.last;
			if invoice &lt;&gt; null then
				foreach invoiceLine in invoice.invoiceLines do
					if invoiceLine.voided then
						continue;
					endif;
					if invoiceLine.myTransactionTI &lt;&gt; null and invoiceLine.myTransactionTI.isKindOf(CM_DutyCharge) then
						pxyInvoiceLine := app.createUpdateProxy(invoiceLine).CM_InvoiceLine;
						app.myUtilityUA.utlUpdateInvoiceLineStatus( pxyInvoiceLine, voidStatus, _passport);
					endif;
				endforeach;
			endif;
		endforeach;
	endif;	

	// ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
	if invoice &lt;&gt; null then
		invoice.setTaxDetailsFromLines();
		invoice.setTotalAmountFromLines();
	endif;
epilog
	delete tis;
	delete pxyInvoiceLine;
	delete voidStatus;
end;</source>
        <Parameter name="_dutyDoc" type="CM_DutyDoc" usage="input"/>
        <Parameter name="_charge" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
