*				a new value in the timeouts table
*
* Parameters :	comPassword
*
* Return :		None
*
* History :		rmb	17/12/96	Initial version
*
*******************************************************/
tabTimeouts_lostFocus(table: Table input) updating;

begin
	// Update the timeout default values (column 2) from the database
	self.updateTimeoutsTable();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
