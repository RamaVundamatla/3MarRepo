    <JadeMethod name="activityCaptureEnd" id="c5f616db-b6e9-4a54-8c41-96952ac2cb5b">
        <updating/>
        <source>activityCaptureEnd() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	12 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.optListenMy.value then
		self.myActivityCapture.causeEvent(EVENT_ACTCAP_STOP, true, null);
	elseif self.optListenAll.value then
		system.causeEvent(EVENT_ACTCAP_STOP, true, null);	
	endif;
	
	self.btnStartCapture.enabled := true;
	self.btnEndCapture.enabled := false;
	self.optListenMy.enabled := true;
	self.optListenAll.enabled := true;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="activityCaptureStart" id="45abf33b-975c-4c41-9775-410f6853f58b">
        <source>activityCaptureStart() protected;
/*
----------   ----------  --------------------------------------------------
Created:	09 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myActivityCapture.enabled then
		app.msgBox("YIKES!: This session's activity capture object is already listening! It must have been started by " &amp; CrLf &amp;
					"another superuser from another node request form", 'ERROR: Already capturing', MsgBox_OK_Only + MsgBox_Stop_Icon);

		return;
	endif;
	
	self.saveActivityCapture();
	if self.optListenMy.value then
		self.myActivityCapture.causeEvent(EVENT_ACTCAP_START, true, self.myActivityCapture.getParamsDelimited());
	elseif self.optListenAll.value then
		system.causeEvent(EVENT_ACTCAP_START, true, self.myActivityCapture.getParamsDelimited());	
	endif;
										
	self.btnStartCapture.enabled := false;
	self.btnEndCapture.enabled := true;
	self.optListenMy.enabled := false;
	self.optListenAll.enabled := false;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addFileNodeToTable" id="b59a8f3f-8610-4c1f-a0cb-eb9be9a35891">
        <source>addFileNodeToTable(_fileNode : NR_FileNode; _tbl : Table input) protected;
// ---------------------------------------------------------------------------
// Created:     07 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
	
begin

	idx := _tbl.addItem(_fileNode.baseName &amp; Tab &amp;
						_fileNode.lastModified.String &amp; Tab &amp;
						_fileNode.fileSize.String &amp; Tab &amp;
						_fileNode.pathName);
	_tbl.accessRow(idx).itemObject := _fileNode;

end;</source>
        <access>protected</access>
        <Parameter name="_fileNode" type="NR_FileNode"/>
        <Parameter name="_tbl" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="beginSysActivityNotification" id="d3db8665-b6e7-422b-b7dd-bc04150cc71a">
        <updating/>
        <source>beginSysActivityNotification() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	
	self.endNotificationForSubscriber(self);
	if self.optListenMy.value then
		self.beginNotification(self.myActivityCapture, EVENT_ACTCAP_PROFILE, Response_Continuous, null);
		self.beginNotification(self.myActivityCapture, EVENT_ACTCAP_DIAGNOSTIC, Response_Continuous, null);
		self.beginNotification(self.myActivityCapture, EVENT_ACTCAP_SECURITY, Response_Continuous, null);
		self.beginNotification(self.myActivityCapture, EVENT_ACTCAP_ENTDEF, Response_Continuous, null);
		self.beginNotification(self.myActivityCapture, EVENT_ACTCAP_CONFIG, Response_Continuous, null);
		self.beginNotification(self.myActivityCapture, EVENT_ACTCAP_MISC, Response_Continuous, null);
		
	else
		self.beginNotification(system, EVENT_ACTCAP_PROFILE, Response_Continuous, null);
		self.beginNotification(system, EVENT_ACTCAP_DIAGNOSTIC, Response_Continuous, null);
		self.beginNotification(system, EVENT_ACTCAP_SECURITY, Response_Continuous, null);
		self.beginNotification(system, EVENT_ACTCAP_ENTDEF, Response_Continuous, null);
		self.beginNotification(system, EVENT_ACTCAP_CONFIG, Response_Continuous, null);
		self.beginNotification(system, EVENT_ACTCAP_MISC, Response_Continuous, null);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
