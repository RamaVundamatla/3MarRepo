    <JadeMethod name="doBrowse" id="d7441fd2-427c-466b-a0f9-9b0f4b522139">
        <updating/>
        <source>doBrowse() updating, protected;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	file : CMDFileOpen;
begin
	create file transient;
	file.createPrompt := false;
	file.fileMustExist := false;
	file.defaultExt := self.cmbFileFormat.text.toLower;
	file.filter := 'All Files|*.*|(*.csv)|*.csv|(*.txt)|*.txt';
	if file.open = 0 then
	    self.txtFileName.text := file.fileName;
	endif;
epilog
	delete file;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="83e3857b-d0f4-49f4-ab49-b153e217bf95">
        <updating/>
        <source>doOK() updating;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.doReport() then
		inheritMethod();	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintPreview" id="e520ca94-75ee-4d25-879e-021a5cd26de8">
        <updating/>
        <source>doPrintPreview() updating, protected;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpReport	: JadeReport;
	tiReport	: CM_TIEnquiryOutput;
	progress	: CMS_Progress;
	now			: TimeStamp;
	ti 			: CM_TrackedItem;
	tp			: CM_GenericTablePrint;
begin

	if optUsePrintOutTable then
		// Lorcan Some use the BaseForm prining - this is to allos them to keep using it
		self.doPrintOutTable (self.myDataTable, hdrString , true, false, false, app.printer.orientation = Print_Portrait);
	else
	
		if self.myDataTable = null then
			//Can't have been called directly for a data table
			return;
		endif;
		
		app.mousePointer := MP_HOURGLASS;
		now := self.systemToLocalTime(app.actualTimeServer());	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
		create tmpReport transient;
		
		tmpReport.description := self.reportDescription;
			
		app.printer.setMargins(Print_Landscape,0,0,10,10);
		app.printer.topOfPage := 1;
		app.printer.bottomOfPage := 1;
		app.printer.setReport(tmpReport);	//Capture for print preview.
	
		create tiReport transient;
		tiReport.initReport;
		tiReport.initReportForLandscape();	
		app.printer.setHeader(tiReport.frHeader);
		app.printer.setFooter(null);
		tiReport.lblPrintedBy.caption := app.getMyUserCode &amp; " - " &amp; now.String;
		tiReport.picLogo.picture := app.getPicLogoPort; 
		tiReport.lblPrintedBy.caption := app.getMyUserCode &amp; " - " &amp; now.String;
		tiReport.lblCargoType.caption := self.reportDescription;
		tiReport.lblCargoTypeLbl.visible := false;
		tiReport.lblTIIDlbl.visible := false;
		tiReport.lblTIID.visible := false;
			
		create tp transient;
		create progress transient;
		tp.setHeaders(hdrString, null );
		tp.printTable(self.myDataTable, true, progress);
		
		self.printExtraFrames();	//22 Feb 2012	NDL	Par 29120
			
		app.printer.close;
		app.printPreview(tmpReport, true);
	endif;
	
epilog
	delete progress;
	delete tp;
	delete tiReport;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPrintToFileAndEmail" id="309d0a09-65d7-4196-8618-45fd609db995">
        <updating/>
        <source>doPrintToFileAndEmail() : Boolean updating, protected;
//--------------------------------------------------
// Created:	25 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpFile : File;
	fileName : String;
	cmifMonitor	: CMIF_Monitor;
	rtnValue : Boolean;
begin
	app.mousePointer := MousePointer_HourGlass;	
	
	fileName := self.txtFileName.text.trimBlanks;
	
	if fileName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'File Name', null, null);
		app.raiseCMException(Input_required_field_fileName, null, null); // cnwdb2	PAR 35364
		return false;
	endif;
	
	if self.chkEmailFile.value
	and self.txtToAddress.text = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Email To Address', null, null);	
		app.raiseCMException(Input_required_field_email2Add, null, null); // cnwdb2	PAR 35364
	endif;
	
	create tmpFile transient;
	tmpFile.fileName := fileName;
	tmpFile.mode := File.Mode_Output;
	tmpFile.open;
			
   	create cmifMonitor transient;
   	app.myPassport.setMyCMIFMonitor(cmifMonitor);
   	cmifMonitor.myParent := self;
	cmifMonitor.message := 'Printing to file';
	self.modalDialogShow(null, null, null, null, self.reportDescription, cmifMonitor.message);
	
   	self.pbProgressBar.visible := true;

   	if self.myDataTable &lt;&gt; null then
   		if self.cmbFileFormat.text = 'CSV' then 	
			self.myDataTable.outputCSVToFile(tmpFile, app.myPassport);
		endif;
	endif;
	
	tmpFile.close();
	
	rtnValue := self.sendEmailRequest(fileName);

	
	return rtnValue;
	
epilog
	delete tmpFile;
	self.frmModalDialog.visible := false;
	delete cmifMonitor;
   	app.myPassport.setMyCMIFMonitor(null);
	app.mousePointer := MousePointer_Default;		
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doReport" id="3dd7c437-4132-42a6-9bc1-52e049941f14">
        <updating/>
        <source>doReport() : Boolean updating, protected;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	app.mousePointer := MP_HOURGLASS;
	
	if self.optPrintPreview.value then
		if self.myDataTable &lt;&gt; null then
			self.doPrintPreview();
			return true;
		endif;
	elseif self.optPrintToFile.value then
		return self.doPrintToFileAndEmail();
	elseif self.optEmailReport.value then
		return self.sendEmailRequest(null);
	endif;	

	return false;		
epilog
	app.mousePointer := MP_DEFAULT;	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="optEmailReport_click" id="cf612abd-ebc7-42d9-9270-29f4029f2b10">
