    <JadeMethod name="doSummarise" id="58a6b1c4-f653-4dcb-9e91-970612e4cdfc">
        <source>doSummarise(_in : Boolean);
// ---------------------------------------------------------------------------
// Created:     28 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	train : CM_Train;
	wagon : CM_Wagon;
	obj : Object;
	objArray : CM_TIArray;
begin


	create objArray transient;
	
	train := self.mySelectedTrain;
	if train = null then
