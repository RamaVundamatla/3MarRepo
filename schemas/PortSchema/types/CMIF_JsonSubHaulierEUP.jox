<Class name="CMIF_JsonSubHaulierEUP" id="4cc8d4cb-922b-4a1b-8147-19557fca9ffd">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cams"/>
    <PrimAttribute name="code" id="0eb33123-1816-454d-b44a-9f6d07e4afaa">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="name" id="9bdbd0d2-4474-4117-92ec-b603dd7b2406">
        <length>71</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setFromCarrier" id="19500192-dea3-4ee0-aa6a-335d2b2de318">
        <updating/>
        <source>setFromCarrier(carrier : CM_Carrier; _translationOperator : CM_Operator) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 23 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	foundMatch : Boolean;
begin
	self.code := carrier.code;
	self.name := carrier.description;
	
	if _translationOperator &lt;&gt; null then
		self.code := _translationOperator.getXlationForeignCode(self.code, XLATION_TYPE_CARRIER_BYOP, foundMatch);
	endif;
end;</source>
        <Parameter name="carrier" type="CM_Carrier"/>
        <Parameter name="_translationOperator" type="CM_Operator"/>
    </JadeMethod>
</Class>
