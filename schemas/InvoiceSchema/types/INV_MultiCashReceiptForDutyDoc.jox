    <JadeMethod name="addChargesLine" id="1887b209-621e-44c4-8c9f-920562d9813b">
        <source>addChargesLine( _obj : Object; _dutyDoc : CM_DutyDoc ): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2013	cnwndl1	Initial creation	Par 32668

*/

vars

	row : Integer;
	agent : CM_CashInvoiceProformaAgent;
	extraCharges : Decimal [16,4];
	numRows : Integer;
	descriptions : String;
	amounts : String;
	allExtraChargeInvLines : ObjectArray;

begin

	if _obj = null then
		return 0;
	endif;
	
	if _obj.isKindOf( CM_DutyDoc ) then
	
		row := self.tblCharges.addItem(self.selectedString &amp; Tab &amp; self.Expand &amp; Tab &amp; _obj.CM_DutyDoc.id );
		self.tblCharges.accessRow(row).itemObject:= _obj;
		self.tblCharges.accessCell(row,ColumnDutyDocId).mergeCells:=Table.MergeCells_Merge;
		self.tblCharges.accessCell(row,ColumnInclude).inputType:=Table.InputType_CheckBox;
	
	elseif _obj.isKindOf( CM_CashInvoiceProformaAgent ) then
	
		agent := _obj.CM_CashInvoiceProformaAgent;
		row := self.tblCharges.addItem(self.selectedString &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; self.Collapse );
		self.tblCharges.accessRow(row).itemObject:= agent;
		
		self.tblCharges.accessCell(row,ColumnInclude).backColor := self.tblCharges.gridColor;
		self.tblCharges.accessCell(row,ColumnInclude).foreColor := self.tblCharges.gridColor;
		self.tblCharges.accessCell(row,ColumnExpandDutyDoc).backColor := self.tblCharges.gridColor;
		self.tblCharges.accessCell(row,ColumnExpandDutyDoc).foreColor := self.tblCharges.gridColor;
		self.tblCharges.accessCell(row,ColumnDutyDocId).backColor := self.tblCharges.gridColor;
		self.tblCharges.accessCell(row,ColumnDutyDocId).foreColor := self.tblCharges.gridColor;
		self.tblCharges.accessCell(row,ColumnInclude).inputType := Table.InputType_None;
		
		self.tblCharges.row := row;
		self.expandCollapseRow(false);
			
	elseif _obj.isKindOf( CM_Debtor ) then
	
		create allExtraChargeInvLines transient;
		extraCharges := self.getExtraCharges( _dutyDoc, numRows, descriptions, amounts, allExtraChargeInvLines );
		
		if extraCharges = 0 then
			return 0;
		endif;
		
		//yep we do.  So display them
		row := self.tblCharges.addItem(self.selectedString &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; self.Collapse );
		self.tblCharges.accessRow(row).itemObject:= _obj.CM_Debtor;
		self.tblCharges.accessCell(row,ColumnExpandDutyDoc).itemObject:= _dutyDoc;
		
		self.tblCharges.accessCell(row,ColumnInclude).backColor := self.tblCharges.gridColor;
		self.tblCharges.accessCell(row,ColumnInclude).foreColor := self.tblCharges.gridColor;
		self.tblCharges.accessCell(row,ColumnExpandDutyDoc).backColor := self.tblCharges.gridColor;
		self.tblCharges.accessCell(row,ColumnExpandDutyDoc).foreColor := self.tblCharges.gridColor;
		self.tblCharges.accessCell(row,ColumnDutyDocId).backColor := self.tblCharges.gridColor;
		self.tblCharges.accessCell(row,ColumnDutyDocId).foreColor := self.tblCharges.gridColor;
		self.tblCharges.accessCell(row,ColumnInclude).inputType := Table.InputType_None;
		
		self.tblCharges.row := row;
		self.expandCollapseRow(false);
	
	endif;
	
	return row;

epilog

	delete allExtraChargeInvLines;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_dutyDoc" type="CM_DutyDoc"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
