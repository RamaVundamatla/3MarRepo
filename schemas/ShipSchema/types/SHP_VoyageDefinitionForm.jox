    <JadeMethod name="optBerthPref_click" id="f1f41be9-9b00-4898-982d-6a13d7b7da66">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optBerthPref_click(optionbutton: OptionButton input) updating;
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
 	if self.cmbBerthPref.listCount &gt; 0 then
	 	if self.mode = self.Mode_Add then 
			// cannot update berth here - only update via graphical view	 		
	 		self.optBerthPref.value := true;
 			self.cmbBerthPref.enabled := true;
 		endif;
 		self.optBerth.value := false;
 		self.cmbBerth.listIndex := -1;
 		self.cmbBerth.enabled := false;
 	else
	  	self.optBerthPref.value := false;
 		self.cmbBerthPref.listIndex := -1;	  	
 		self.cmbBerthPref.enabled := false;
	 	if self.mode = self.Mode_Add then
			// cannot update berth here - only update via graphical view	 	
		 	self.optBerth.value := true;	 	
	 		self.cmbBerth.enabled := true;
	 	endif;
 	endif;
end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="optBerth_click" id="315116f0-68c8-438b-b182-8194bbafd902">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optBerth_click(optionbutton: OptionButton input) updating;
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
  	self.optBerthPref.value := false;
	self.cmbBerthPref.listIndex := -1;	  	  	
 	self.cmbBerthPref.enabled := false;
 	if self.mode = self.Mode_Add then 
		// cannot update berth here - only update via graphical view 		
	 	self.optBerth.value := true;
 		self.cmbBerth.enabled := true;
 	endif;
end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pilotExemptEnable" id="c6ba65fc-f9ed-4884-bffe-9c8598b1c182">
        <source>pilotExemptEnable() protected;
//-----------------------------------------------------------------------
//	Created:	12 October 2007 by cnwvu1
//-----------------------------------------------------------------------

vars

begin

	if (self.mode = self.Mode_Add) or (self.mode = self.Mode_Update) then
		
		self.cmbPilot.enabled := not self.ckbPilotExempt.value;
		if self.ckbPilotExempt.value then
			self.cmbPilot.listIndex := -1;
		endif;
		
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
