    <JadeMethod name="deleteTrain" id="6cf544d6-b489-4fe1-b350-d6866626ac7d">
        <source>deleteTrain(_trainCode : String; _train : CM_Train);
//09 July 2009	cnwmd1
// 12 Oct 2016	cnwrs1	TFS 2829 Cams processing failure with Train Events
//
vars
	train : CM_Train;
	trans : CM_EventTransaction;
	more : Boolean;
begin
//	train := app.myPassport.myTerminal.allTrainsOnTerminal[_trainCode,null];
	more := true;
	while more do
	more := false;
	if _train = null then
		train := app.myPassport.myTerminal.allTrainsOnTerminal.getAtKeyGeq(_trainCode,null);
		if train &lt;&gt; null and 
		   train.code &lt;&gt; _trainCode then
			train := app.myPassport.myTerminal.allTrainsDeparted.getAtKeyGeq(_trainCode, null);
			if train &lt;&gt; null and train.code = _trainCode then
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;train.String&amp;' '&amp;train.code&amp;' '&amp;_trainCode&amp;' '&amp;train.departureDT.String;
				self.deleteTrainAndAssociatedObjs(train);
				self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
				more := true;
				continue;
			endif;
		endif;
	else
		train := _train;
	endif;
	if train &lt;&gt; null then
		if _train &lt;&gt; null or train.code = _trainCode then
			self.ignoreTrxWarnings(true);
			//app.myPassport.setWarningsIgnored(true);
			foreach trans in train.allTransactions do
				app.myTrxDA.trxDeleteTrainEvent(trans, app.myPassport);
			endforeach;
			app.myTrxDA.trxDeleteTrain(train, false, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		endif;
	endif;
	endwhile;
end;</source>
        <Parameter name="_trainCode" type="String"/>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="deleteTrainAndAssociatedObjs" id="c3a9d691-1971-4786-b3bc-87d33285e5fd">
        <source>deleteTrainAndAssociatedObjs( _train : CM_Train io );

/*

Purpose:			Deletes Train, wagons, cargo, jobs, audits, non-invoiced transactions

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2011	cnwndl1	Initial creation

*/

vars

	wagons : CM_WagonSet;
	iter : Iterator;
	wagon : CM_Wagon;
	invalidWagon : Boolean;
	invalidTi : Boolean;
	invalidBulk : Boolean;
	edition : Integer;
	trx : CM_EventTransaction;
	audit : CM_AuditObject;
	ti : CM_TrackedItem;
	bulk : CM_BulkRelease;
	msg : String;
	now : TimeStamp;
	yaType : CM_YATypeTrain;
	
begin

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if _train = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, wagon, invalidWagon );
	create wagons transient;

	iter := _train.allWagonsByIdInward.createIterator;
	while iter.next( wagon ) do
		invalidWagon := false;
		edition := wagon.edition;
		if not invalidWagon then
			wagons.addNoDuplicates(wagon,false);
		endif;
	endwhile;
	
	delete iter;
	iter := _train.allWagonsByIdOutward.createIterator;
	while iter.next( wagon ) do
		invalidWagon := false;
		edition := wagon.edition;
		if not invalidWagon then
			wagons.addNoDuplicates(wagon,false);
		endif;
	endwhile;
	
	delete iter;
	iter := wagons.createIterator;
	while iter.next( wagon ) do
		self.deleteWagonAndAssociatedObjs(wagon);
	endwhile;
	
	
	beginTransaction;
	
	on Exception do app.handleDeletedObject( exception, ti, invalidTi );
	foreach ti in _train.allAssignedTIs do
		ti.setMyTrainAssigned(null,null);
	endforeach;
	
	on Exception do app.handleDeletedObject( exception, bulk, invalidBulk );
	foreach bulk in _train.allBulkReleases do
		bulk.setPropertyValue("myAssignedTrain",null);
	endforeach;
	
	foreach audit in _train.allAuditObjects do
		audit.setPropertyValue("myAuditConfig",null);
		audit.setPropertyValue("mySubject",null);
		audit.setPropertyValue("myUser",null);
		delete audit;
	endforeach;
	
	foreach trx in _train.allTransactions where trx.allInvoiceLines.isEmpty do
		delete trx;
	endforeach;
	
	_train.setPropertyValue("myTrackClearance",null);
	_train.setPropertyValue("myTerminalDeparted",null);
	_train.setPropertyValue("myTerminal",null);
	
	
	yaType := CM_YATypeTrain.firstInstance();
		
	if yaType &lt;&gt; null then
		yaType.removeMyDataObject(_train);
	endif;
	
	delete _train;
	
	commitTransaction;
	

epilog

	delete wagons;
	delete iter;

end;</source>
        <Parameter name="_train" type="CM_Train" usage="io"/>
    </JadeMethod>
    <JadeMethod name="deleteTrainAndWagons" id="f8a44073-e713-45ed-b7b7-62f065ca5e06">
        <source>deleteTrainAndWagons(_trainCode : String);
//09 July 2009	cnwmd1
//
vars
	train : CM_Train;
	wagon : CM_Wagon;
	trans : CM_EventTransaction;
begin
//	train := app.myPassport.myTerminal.allTrainsOnTerminal[_trainCode,null];
	train := app.myPassport.myTerminal.allTrainsOnTerminal.getAtKeyGeq(_trainCode, null);
	if train &lt;&gt; null then
		foreach wagon in train.allWagonsByIdInward do
			app.myTrxDA.trxDeleteWagon(wagon, false, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		endforeach;
		if train.code = _trainCode then
			self.ignoreTrxWarnings(true);
			//app.myPassport.setWarningsIgnored(true);
			foreach trans in train.allTransactions do
				app.myTrxDA.trxDeleteTrainEvent(trans, app.myPassport);
			endforeach;
			app.myTrxDA.trxDeleteTrain(train, false, app.myPassport);
			self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		endif;
	endif;
end;
</source>
        <Parameter name="_trainCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteTransactionMapVoyage" id="9873befd-a721-4853-8359-a55a79afb667">
        <source>deleteTransactionMapVoyage( _tranMap : String; _bu : CM_Bank input) : Boolean;
/*
Purpose:			
Date		Who		Reason
31 December 2014	cnwab1	Initial creation
*/

vars
	tranMapVoyage : CM_TranMapVoyage;
begin

	tranMapVoyage := _bu.allJMHTMs[_tranMap];
	if tranMapVoyage = null then
		return false;
	endif;

	beginTransaction;
	_bu.myCurrentTranMapVoyage := null;
	commitTransaction;
	
 	app.myTrxDA.trxDeleteInvoiceTranMapVoyage(tranMapVoyage, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();							// 07/02/2017 cnwmh5 - Should now catch errors
	
	return app.myPassport.trxCompletedOK;
epilog

end;</source>
        <Parameter name="_tranMap" type="String"/>
        <Parameter name="_bu" type="CM_Bank" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteTransactionMaps" id="984a0f5a-fc94-4f86-882a-3d09d77c6843">
        <source>deleteTransactionMaps();
// delete all invoice transaction maps other than the default one, so other invoice objects can be deleted
vars
	tm	: CM_TranMap;
	bank	: CM_Bank;
begin
	bank := self.getTerminal().getDefaultCompanyBank();
	self.resetDefaultTranMap();
	foreach tm in bank.myCurrentTranMapCargo do
		if tm.name &lt;&gt; "Default" and not tm.isActive then
			self.deleteInvoiceTransactionMap(1, tm.name);
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
