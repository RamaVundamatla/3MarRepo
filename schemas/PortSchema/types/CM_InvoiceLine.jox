    <JadeMethod name="getTransactionColumnDisplay" id="8e73b158-2168-4239-b08a-da52fea128de">
        <source>getTransactionColumnDisplay():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2019	jlgndl1	Initial creation	TFS 43882  - So its available for Column Organiser and RWR.

*/

vars

	returnStr : String;

begin

	if not manual then
		if self.myTransactionTI &lt;&gt; null then
			if self.myResourceTypeUsage &lt;&gt; null then
				return self.myTransactionTI.class.name[4:end] &amp; " - " &amp; self.myResourceTypeUsage.myResourceType.description;
			endif;
			return self.myTransactionTI.getTypeString();  // ### TFS 58790 26JUN2023 NAVAB1
			// ### TFS 58790 26JUN2023 NAVAB1 return self.myTransactionTI.class.name[4:end];
		elseif self.myTransactionHMS &lt;&gt; null and self.myTransactionHMS.myResourceUsed &lt;&gt; null then
			return self.myTransactionHMS.myResourceUsed.myResource.code;
		elseif self.myTransactionEvent &lt;&gt; null and self.myTransactionEvent.myEventType &lt;&gt; null then
			return self.myTransactionEvent.getEventTypeName();  // ### TFS 51219 10JUN2021 NAVAB1
		elseif self.mySnapShotData &lt;&gt; null then
			return self.mySnapShotData.mySnapshotData.myOutputFormat_SS.name;
		elseif self.myTransactionBOL &lt;&gt; null then	//08 Nov 2019	NDL	TFS 47100
			return self.myTransactionBOL.class.name[4:end];
		elseif self.myTransactionWO &lt;&gt; null then // ### TFS 58790 26JUN2023 NAVAB1
			return self.myTransactionWO.getTypeString();  // ### TFS 58790 26JUN2023 NAVAB1
		else
			return "";
		endif;
	else
		if self.myTransactionTI = null then
			returnStr := app.getErrorString(Manual);
		else
			returnStr :=  app.getErrorString(Manual) &amp; ": " &amp; self.myTransactionTI.class.name[4:end];
		endif;
		return returnStr;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransactionDate" id="106d39f2-e863-40d0-b2eb-5f8b645929f3">
        <source>getTransactionDate() : TimeStamp;
/*
Purpose - 	
Who - NAVAB1
Date - 08JAN2024
ADO -  CR 58085 TASK 61342
*/

vars

	returnStr : String;

begin

	if self.myTransactionTI &lt;&gt; null then
		return self.myTransactionTI.dateTime;
	elseif self.myTransactionHMS &lt;&gt; null then
		return self.myTransactionHMS.transactionDT;
	elseif self.myTransactionEvent &lt;&gt; null then
		return self.myTransactionEvent.dateTime;
	elseif self.mySnapShotData &lt;&gt; null then
		return self.mySnapShotData.getRunDateTime();
	elseif self.myTransactionBOL &lt;&gt; null then	
		return self.myTransactionBOL.dateTime;
	elseif self.myTransactionWO &lt;&gt; null then
		return self.myTransactionWO.dateTime; 
	else
		return self.createdTime;
	endif;

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getTransactionOID" id="ad12f7cc-e6ea-44e9-9e80-af62e4bf483d">
        <source>getTransactionOID():String;
/*
Purpose - 	
Who - NAVAB1
Date - 08JAN2024
ADO -  CR 58085 TASK 61342
*/

vars

	returnStr : String;

begin

	if not manual then
		if self.myTransactionTI &lt;&gt; null then
			if self.myResourceTypeUsage &lt;&gt; null then
				return self.myTransactionTI.getOidAsString() &amp; " - " &amp; self.myResourceTypeUsage.myResourceType.getOidAsString();
			endif;
			return self.myTransactionTI.getOidAsString(); 
		elseif self.myTransactionHMS &lt;&gt; null and self.myTransactionHMS.myResourceUsed &lt;&gt; null then
			return self.myTransactionHMS.getOidAsString() &amp; " - " &amp; self.myTransactionHMS.myResourceUsed.myResource.getOidAsString();
		elseif self.myTransactionEvent &lt;&gt; null and self.myTransactionEvent.myEventType &lt;&gt; null then
			return self.myTransactionEvent.getOidAsString();  
		elseif self.mySnapShotData &lt;&gt; null then
			return self.mySnapShotData.mySnapshotData.getOidAsString();
		elseif self.myTransactionBOL &lt;&gt; null then	
			return self.myTransactionBOL.getOidAsString();
		elseif self.myTransactionWO &lt;&gt; null then
			return self.myTransactionWO.getOidAsString(); 
		else
			return "";
		endif;
	else
		if self.myTransactionTI = null then
			returnStr := app.getErrorString(Manual);
		else
			returnStr :=  app.getErrorString(Manual) &amp; ": " &amp; self.myTransactionTI.class.name[4:end];
		endif;
		return returnStr;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
