    <JadeMethod name="isEmpty_Match" id="e8e55512-a986-4885-9420-6f02ed39a4c7">
        <source>isEmpty_Match(_yaData: CM_YADataBoolean): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 06/11/2014	cnwdap1		Initial creation PAR #35092 For "Allocation Only" Empty Release Strategy, defaulting to
//							parent class method always returned false - use criteria on yard allocation to see if 
//							a match can be found.
//
vars
	criteriaType 	: CM_YACriteriaType;
	iter			: Iterator;
	criteria		: CM_YACriteria;

begin
	criteriaType := _yaData.myYAParent.myYACriteriaType;
	iter := _yaData.myYAParent.CM_YACriteria.myYardAllocation.allCriteriaByType.createIterator;
	_yaData.myYAParent.CM_YACriteria.myYardAllocation.allCriteriaByType.startKeyGeq(criteriaType.type, iter);
	
	while iter.next(criteria) do
		if criteria.myYACriteriaType &lt;&gt; criteriaType then
			break;
		endif;
		
		if criteria.myYAData.doDataComparison(_yaData) then
			return true;
		endif;
	endwhile;
	
	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_yaData" type="CM_YADataBoolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFiftyThree_Match" id="bb05de4c-adc2-45cd-a7be-840276588c6f">
        <source>isFiftyThree_Match(_yaData: CM_YADataBoolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 March 2015	cnwndl1	Initial creation	NDL	Par 35886

*/

vars

	isoType	: CM_ISOType;
	is53	: Boolean;
	yaData : CM_YAData;
	yaDataBoolean : CM_YADataBoolean;
	booleanValue : Boolean;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_IsFiftyThree );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataBoolean) then
		yaDataBoolean := yaData.CM_YADataBoolean;
		if yaDataBoolean &lt;&gt; null then
			if yaDataBoolean.value =  CM_YADataBoolean.VALUE_EITHER then
				return true;
			endif;
			booleanValue := yaDataBoolean.getValueAsBoolean();
			return _yaData.doesValueMatch( booleanValue );
		endif;
	endif;
		
	isoType := self.getISOTypeFromRequest();
	
	if isoType = null then
		is53:= false;
	else
		is53 := (isoType.is53ftLong());
	endif;
	
	return _yaData.doesValueMatch(is53);


end;</source>
