        <source>refresh() updating, clientExecution;
/*

Date		    Who			Reason
27 October 2010	cnwas3	  Initial creation

*/

vars

begin
	inheritMethod();
	if not isInPainter then
		self.buildSelf();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetValuesToDate" id="e215e168-9339-4dc5-a3df-dcbe5a27ed50">
        <updating/>
        <source>resetValuesToDate(_date : Date) updating;
/*

Date		    Who			Reason
28 October 2010	cnwas3	  Initial creation
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	self.selectedDate := _date;
	self.myMonthLabel.text := _date.format("MMMM");
	self.setYear(_date.year());
	if app.name = "JadePainter" then
		self.maximumYear := app.actualTimeServer().date.year;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		self.maximumYear := self.systemToLocalTime(app.actualTimeServer()).date.year;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
epilog

end;</source>
        <Parameter name="_date" type="Date"/>
    </JadeMethod>
