    <JadeMethod name="getNumberOfMappings" id="4015b1c8-1469-45d7-88d5-1f2c28f60d8b">
        <source>getNumberOfMappings() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 August 2017	jlgab1	Initial creation

*/

vars
	size : Integer;
	range : CM_QuantityRangeMap;
	invline : CM_InvoiceLineDesc;
	invalid : Boolean;
	mapping : CM_TranMapInvoiceLineMapping;
begin

	on Exception do app.handleDeletedObject( exception, invline, invalid );	// 18 Oct 2017 - TFS 7032
	
	size :=0;
	if self.myServiceBroker &lt;&gt; null 
	and self.myServiceBroker.myChildQuantityMap &lt;&gt; null then
		foreach range in self.myServiceBroker.myChildQuantityMap.allQuantityRanges do
//			foreach invline in range.allInvoiceLineMaps do
			foreach mapping in range.allTMInvoiceLineMappings do // TFS 40620
				invline := mapping.myTMInvoiceLineDesc; // TFS 40620


				invalid := false; // 18 Oct 2017 - TFS 7032 - reset in case its been set (following 'isVoid' de-refernec will set it if necessary )
				if not invline.isVoid and not invalid then
					size := size + 1;
				endif;
			endforeach;
		
		endforeach;
	endif;
	return size;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
