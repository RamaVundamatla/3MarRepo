    <JadeMethod name="trxDeleteDBPurgeUnknTrucks" id="43cc3898-f270-44cb-9970-a3cc2d2eded0">
        <updating/>
        <source>trxDeleteDBPurgeUnknTrucks(_unknwTrucks : DynaDictionary input; _agent : CM_DBPurgeAgent input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2021	navpw1	Initial creation TFS: 51994

*/

vars

	iter			: Iterator;
	count			: Integer;
	vehicle			: CM_Vehicle;
	setAll,
	setErrors		: CM_ObjectSetActual;
	currentRecordCount,					//Used to track whether we have met our block size
	totalRecordCount,
	theSize,
	completed		: Integer;
	activityResults : String;
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on LockException do app.alertLockExceptionHandler(exception);
	// SPECIAL TRX FOR GARBAGE COLLECTION.
	// EXCEPTION HANDLER ARMED OUTSIDE OF TRX
	
	if _agent.abort() then	
		return;
	endif;

	create setAll transient;
	create setErrors transient;
	
	theSize := _unknwTrucks.size();
	iter := _unknwTrucks.createIterator();
	
	while iter.next(vehicle) do
		currentRecordCount := currentRecordCount + 1;
		setAll.add(vehicle);
		if currentRecordCount = _agent.Commit_Block_Size_Small then
			if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
				return;
			endif;
			completed := completed + setAll.size;
			setAll.clear();
			totalRecordCount := totalRecordCount + currentRecordCount;
			currentRecordCount := 0;
			if _agent.abort() then
				return;
			endif;
			if totalRecordCount mod _agent.Activity_Progress_Count_Medium = 0 then
				_agent.createActivityHistory(app.getErrorString2(Progress, app.getErrorString(Purged)&amp; ' ' &amp; totalRecordCount.String, theSize.String &amp; ' ' &amp; app.getErrorString(Available)), false, true);
			endif;
		endif;
	endwhile;
	
	if not setAll.isEmpty() then
		if not _agent.doEraseBlockOfObjects(setAll, setErrors) then
			return;
		endif;
		completed := completed + setAll.size;
	endif;
	
	//Sets our activity result message
	activityResults := "Results: " &amp; app.getErrorString(Purged)&amp; ' ' &amp; completed.String &amp; ' ' &amp; app.getErrorString(Security_Gate_Unknown_Trucks) &amp; ' ' &amp; setErrors.size.String &amp; ' ' &amp; app.getErrorString(Errors);
	
	_agent.setStats(activityResults);
	_agent.createActivityHistory(activityResults, false, true);
	
epilog		

	delete iter;
	delete setAll;
	delete setErrors;
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_unknwTrucks" type="DynaDictionary" usage="input"/>
        <Parameter name="_agent" type="CM_DBPurgeAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
