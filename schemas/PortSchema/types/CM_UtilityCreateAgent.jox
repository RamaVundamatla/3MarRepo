    <JadeMethod name="utlCreateWagon" id="73f6c03a-5e1d-4f43-9301-32b918d90438">
        <source>utlCreateWagon(pProxyWagon:CM_Wagon input; pNewWagon:CM_Wagon output; 
			pRailLine : CM_RailLine input; pIndex : Integer; 
			_wagonContainers : CMIF_TIWagonPositionArray;
			_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	aTIWagonPosition	: CMIF_TIWagonPosition;
	lTIArray	: CM_TIArray;
	lPreviousController,lNewController : CM_WagonController;
	lLoc, numUnits : Integer;
	wellDef : CM_WagonWellDefinition;
	well : CM_WellcarWellVisit;
	wagMoveController : CMIF_WagonMoveController;

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valWagon(pProxyWagon);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	//26 Feb 2021	NDL	TFS 50837
	create wagMoveController transient;
	wagMoveController.autoSetEffectiveTimeStamp();

	create pNewWagon as pProxyWagon.class persistent;
	pNewWagon.setForCreate( wagMoveController, pProxyWagon); 
	if pRailLine &lt;&gt; null then	//14 Dec 2010	NDL Par 26549
		app.myUtilityUA.utlUpdateWagonPosition(null, pRailLine, pNewWagon, pIndex, _passport);
	endif;
	
	// Create Controllers for each wagon...
	lPreviousController := null;
	numUnits := pNewWagon.myWagonClass.getLenInUnits;
		
	if pNewWagon.isWellcarVisit then	//10 Dec 2014	NDL	Par 35346
		foreach wellDef in pNewWagon.myWagonClass.allWagonWellDefArray do
			well := pNewWagon.CM_WellcarVisit.createWellFromDef( wellDef );
		endforeach;
		numUnits := pNewWagon.allLocationsControllersArray.size;
		
	else
		foreach lLoc in 1 to numUnits  do
			create lNewController as pNewWagon.getLocationContClassToCreate persistent;
			lNewController.setForCreate(pNewWagon.id &amp; pNewWagon.myWagonClass.locationIds[lLoc].trimBlanks,true, pNewWagon, lPreviousController);
			lPreviousController := lNewController;
		endforeach;
		
	endif;
	
	if _wagonContainers &lt;&gt; null then
		foreach aTIWagonPosition in _wagonContainers do
			// this position indicate the index of the controller
			if aTIWagonPosition.position &gt; 0 then 
			//	if aTIWagonPosition.position &lt;= pNewWagon.myWagonClass.lenInUnits then
				if aTIWagonPosition.position &lt;= numUnits then
					self.utlCreateWagonContainer(pNewWagon, aTIWagonPosition, _passport);
				endif;
			endif;
		endforeach;
	endif;

	

	pNewWagon.causeEvent(pNewWagon.myTerminal.getTerminalEvent(Wagon_Create_Event), false, pNewWagon);			
epilog
	delete wagMoveController;
end;</source>
        <Parameter name="pProxyWagon" type="CM_Wagon" usage="input"/>
        <Parameter name="pNewWagon" type="CM_Wagon" usage="output"/>
        <Parameter name="pRailLine" type="CM_RailLine" usage="input"/>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="_wagonContainers" type="CMIF_TIWagonPositionArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
