    <JadeMethod name="getDescription" id="a7d6b83e-97dd-4a7d-b890-0909d03d42d1">
        <source>getDescription() : String;
/*
----------   ----------  --------------------------------------------------
Created:	07 May 2007 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
27/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk 
20/6/2014	cnwer1		PAR 34406 more bulk changes
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight

*/
vars
	str		: String;
	isForBulk : Boolean;
	weightReleased : String;
	weightPacked : String;
	ct  : CM_CargoType;
begin
	ct := self.myCargoType;
	isForBulk:= ct &lt;&gt; null and ct.isBulkMulti;		
																						// PAR #33606	
	str := self.getTotalRequestedDisplay() &amp; ' x ' &amp; self.getProductISOTypeDescr();
	
	if ct = null then	
		str := str &amp; " " &amp; app.getErrorString(Unspecified_Cargo_Type);
	endif;
	
	if self.isPackingChild then	//11 Dec 2015	NDL	Par 37288
		if isForBulk or self.byTypeByWeight then			// 6/12/2023 navcs2 ChangeRequest 57537
			weightPacked := ct.getBulkTrackByDisplayForWeight( self.getWeightPacked, self.getDensity, true );
			str := str &amp; " (" &amp; weightPacked &amp; " packed )";
		else
			str := str &amp; " (" &amp; self.getTotalPacked.asStringJMT &amp; " packed )";
		endif;
	
	else
		if isForBulk or self.byTypeByWeight and ct &lt;&gt; null then			// 6/12/2023 navcs2 ChangeRequest 57537
			weightReleased	:=ct.getBulkTrackByDisplayForWeight(self.getWeightReleased,self.getDensity,true);
			str := str &amp; " (" &amp; weightReleased &amp; " released )";
		else
			str := str &amp; " (" &amp; self.getTotalReleased.asStringJMT &amp; " released )";
		endif;
	
	endif;
	
	
	return str;

end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionForSummary" id="0113896d-f167-4f29-adfc-e8b8b8ffa3ab">
        <source>getDescriptionForSummary(): String;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
11 February 2010		cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/

vars
	str	:String;
begin
	str	:= self.descriptionSelection;
	
	if str.length &gt; 30 then
		str := str [1:30];
	endif;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionSTW" id="cef6e57b-a093-4d0a-9b0e-f15f39a303c2">
        <source>getDescriptionSTW(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jan 2019	jlgndl1	Initial creation	TFS 40479
30 Jun 2025 navma1  MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
*/

vars
	str			   : String;
	isForBulk 	   : Boolean;
	weightReleased : String;
	weightPacked   : String;
	extraString    : String;
	cType		   : CM_CargoType;
begin

	extraString := getExtraCritForRoadGateSTW();
	
	if extraString = null then
		return inheritMethod();
	else
		cType := self.myCargoType;								//30.06.2025 navma1 #MTN-34090
		
		isForBulk	:= cType &lt;&gt; null and cType.isBulkMulti;		
		str 		:= self.getTotalRequestedDisplay() &amp; ' x ' &amp; self.getProductISOTypeDescr();
		
		if cType = null then	
			str := str &amp; " " &amp; app.getErrorString(Unspecified_Cargo_Type);
		endif;
		
		str := str &amp; " " &amp; extraString;
		
		if self.isPackingChild then	
			if isForBulk then
				weightPacked := cType.getBulkTrackByDisplayForWeight( self.getWeightPacked, self.getDensity, true );
				str 		 := str &amp; " (" &amp; weightPacked &amp; " packed )";
			else
				str := str &amp; " (" &amp; self.getTotalPacked.asStringJMT &amp; " packed )";
			endif;
		else
			if isForBulk then
				weightReleased	:= cType.getBulkTrackByDisplayForWeight(self.getWeightReleased,self.getDensity,true);
				str 			:= str &amp; " (" &amp; weightReleased &amp; " released )";
			else
				str := str &amp; " (" &amp; self.getTotalReleased.asStringJMT &amp; " released )";
			endif;
		endif;
		return str;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescriptionShort" id="ab5b48bb-f27c-4076-966c-d29bc03cdbb1">
