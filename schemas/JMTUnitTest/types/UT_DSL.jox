    <JadeMethod name="addToDoTemplate" id="beca2950-b01b-4931-ad3f-11dcb26ba80f">
        <source>addToDoTemplate(_id : String ) : CM_ToDoTemplate;
/*

Purpose:	Create To Do Template		

Date		Who		Reason
10/04/2014	cnwma1	Initial creation

*/

vars
	pxyToDoTemplate : CM_ToDoTemplate;
	toDoTemplate	: CM_ToDoTemplate;
	operatorDict	: CM_OperatorByCodeDict;
	todoTasksDict	: CM_ToDoTaskDescByCode;
	availDict		: CM_MTGradeByCodeDict;
	isoGroupDict		: CM_ISOTypeGroupByCodeDict;
	isoTypeDict     : CM_ISOTypeByCodeDict;
begin

	// Delete ToDo Terminal 
	
	deleteToDoTemplate(_id);
	
	// create operator
	create operatorDict transient;
	operatorDict.add(self.getOperator("APL"));
	operatorDict.add(self.getOperator("CMA"));
	
	// create ToDo Task
	create todoTasksDict transient;
	todoTasksDict.add(app.myRoot.allToDoTaskDescriptions[10]);
	
	// create AvailabilityGrades
	create availDict transient;
	availDict.add(app.myRoot.allAvailabilityGrades[66]);
	
	// create ISOGroup
	create isoGroupDict transient;
	isoGroupDict.add(app.myRoot.allISOTypeGroups["GEN4"]);
	
	// create ISO Type
	create isoTypeDict transient;

	
	create pxyToDoTemplate transient;
	pxyToDoTemplate.setProxy(_id,  		// ID
							false,      // Empties
							false, 		// Exports
							true, 		// Imports
							true,  		// Full 
							false, 		// Storage
							false,	    // tranships
							availDict,  		// AvailabilityGrades
							isoGroupDict,  		// Iso Groups
							isoTypeDict,       // ISo Types
							operatorDict,   // Opreators
							todoTasksDict , // To Do Tasks
							null);		// MT Grade
	
	app.myTrxCA.trxCreateToDoTemplate(pxyToDoTemplate,toDoTemplate,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return toDoTemplate;
epilog

	delete pxyToDoTemplate;
	delete operatorDict;
	delete todoTasksDict;
	delete availDict;
	delete isoGroupDict;
	delete isoTypeDict;

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_ToDoTemplate"/>
    </JadeMethod>
    <JadeMethod name="addToDoTemplate2" id="2cab3c82-0edf-4650-bbf4-89f40776080a">
        <source>addToDoTemplate2(_id : String ) : CM_ToDoTemplate;
/*

Purpose:	Create To Do Template		

Date		Who		Reason
9/12/2014	cnwjre1	Initial creation for 35362
					Template that applies to Storage empties, operators
*/

vars
	pxyToDoTemplate : CM_ToDoTemplate;
	toDoTemplate	: CM_ToDoTemplate;
	operatorDict	: CM_OperatorByCodeDict;
	todoTasksDict	: CM_ToDoTaskDescByCode;
	availDict		: CM_MTGradeByCodeDict;
	isoGroupDict	: CM_ISOTypeGroupByCodeDict;
	isoTypeDict     : CM_ISOTypeByCodeDict;
begin

	// Delete ToDo Terminal 
	
	deleteToDoTemplate(_id);
	
	// create operators, 
	create operatorDict transient;
	operatorDict.add(self.getOperator("APL"));
	operatorDict.add(self.getOperator("CMA"));
	operatorDict.add(self.getOperator("MSK"));
	
	// create ToDo Task, Survey
	create todoTasksDict transient;
	todoTasksDict.add(app.myRoot.allToDoTaskDescriptions[10]);
	
	// create AvailabilityGrades, none
	create availDict transient;
	
	// create ISOGroup, none
	create isoGroupDict transient;
	
	// create ISO Type, none
	create isoTypeDict transient;

	
	create pxyToDoTemplate transient;
	pxyToDoTemplate.setProxy(_id,  		// ID
							false,      // Empties
							false, 		// Exports
							true, 		// Imports
							true,  		// Full 
							false, 		// Storage
							false,	    // tranships
							availDict,  		// AvailabilityGrades
							isoGroupDict,  		// Iso Groups
							isoTypeDict,       // Iso Types
							operatorDict,   // Operators
							todoTasksDict , // To Do Tasks
							null);		// MT Grade
	
	app.myTrxCA.trxCreateToDoTemplate(pxyToDoTemplate,toDoTemplate,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return toDoTemplate;
epilog

	delete pxyToDoTemplate;
	delete operatorDict;
	delete todoTasksDict;
	delete availDict;
	delete isoGroupDict;
	delete isoTypeDict;

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_ToDoTemplate"/>
    </JadeMethod>
    <JadeMethod name="addTrackClearance" id="7c846780-0d2a-4c5c-b89e-d56a6e4a5ba1">
        <source>addTrackClearance( gcId : String ) : CM_TrackClearance;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwndl1	Initial creation

*/
vars
	existingGaugeClearance : CM_TrackClearance;
	loadState : Boolean;
	
	trackClearance : CM_TrackClearance;
	proxyGaugeClearance : CM_TrackClearance;
	
	
begin


	existingGaugeClearance := app.myRoot.allTrackClearances.getAtKey(gcId);
	self.assertTrueMsg(existingGaugeClearance = null, "Track clearance '" &amp; gcId &amp; "' already exists !!");
	
	app.cmsBeginLoad(loadState);
	
	create proxyGaugeClearance transient;
	
	proxyGaugeClearance.setProxy(	false,	//_allowHiCube : Boolean;
									gcId,	//_code : String;
									"Test track clearance",	//_description : String;
									450,	//_maxHeight : Decimal;
									20000,	//_maxWeightWagon : Decimal;
									260,	//_maxWidth : Decimal;
									false,	//_isNotAvailableForEntry : Boolean
									0, // max weight for train
									false // no empty wagons
									);
								
	app.myTrxCA.trxCreateTrackClearance(proxyGaugeClearance, trackClearance, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertTrueMsg(trackClearance &lt;&gt; null, "Track Clearance '" &amp; gcId &amp; "' not created.");

	
	
	
	
epilog

	app.cmsEndLoad(loadState);
	delete proxyGaugeClearance;
	return trackClearance;

end;</source>
        <Parameter name="gcId" type="String"/>
        <ReturnType type="CM_TrackClearance"/>
    </JadeMethod>
    <JadeMethod name="addTrade" id="ca66ca98-867c-4da5-9be4-db03c03bccb7">
        <source>addTrade(_tradeId, _tradeDesc: String; _notAvailable : Boolean; _shippingLines : CM_ShippingLineByCodeDict; _operatorArray : ObjectArray) : CM_Trade;

/*

Purpose:		Add a Trade

Date			Who		Reason
30/11/2011		cnwmh5	Initial creation

*/

vars

	pxyTrade				: CM_Trade;
	trade					: CM_Trade;
	obj						: Object;
	portRotation			: CM_PortRotation;
	
	portArray				: ObjectArray;
	debtorArray				: ObjectArray;
	
begin

	self.deleteTrade(_tradeDesc);

	create pxyTrade transient;
		
	pxyTrade.setProxy(_tradeId,				 		// id/code
					  _tradeDesc, 					// desription
					  0,							// order
					  _operatorArray,				// operatorArray
					  _notAvailable,
					  _shippingLines);						// shipping lines
	
	app.myTrxCA.trxCreateTrade(pxyTrade, trade, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyTrade;
						  
	if self.opts.includesKey("PortsOfRotation") then
		portArray := self.opts.obj("PortsOfRotation").ObjectArray;
		create debtorArray transient;
		beginTransaction;
		trade.setCopyToTrade(trade, portArray, debtorArray);
		commitTransaction;
	endif;
	
	return trade;

epilog
	delete pxyTrade;
	delete debtorArray;
end;</source>
        <Parameter name="_tradeId" type="String"/>
        <Parameter name="_tradeDesc" type="String"/>
        <Parameter name="_notAvailable" type="Boolean"/>
        <Parameter name="_shippingLines" type="CM_ShippingLineByCodeDict"/>
        <Parameter name="_operatorArray" type="ObjectArray"/>
        <ReturnType type="CM_Trade"/>
    </JadeMethod>
    <JadeMethod name="addTrailerAtLocation" id="50bc55c8-61a4-4e9f-a3c3-b7eda2f16404">
        <source>addTrailerAtLocation(_id: String;
					_cargoType: CM_CargoType;
					_trailerType : CM_TILCType;
					_operator: CM_Operator; 
					_location: CM_LocationsController) : CM_TILC;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2013	cnwer1	Initial creation CCMS DPH 2274
10 March 2023	jlika1	Add width to trailer.
*/

vars
	pxyTI , realTI: CM_TrackedItem;
	moveController : CMIF_MoveController;
begin
	
	if _cargoType = null or _trailerType = null then
		return null;
	endif;
	
	if _cargoType.myClassToCreate &lt;&gt; CM_TILC then
		return null;
	endif;	
	
	pxyTI := self.getTerminal.createTI(_cargoType, true);
	self.assertTrue(pxyTI.isKindOf(CM_TILC));
	pxyTI.setPxyFromDefaultTI(self.getTerminal, _cargoType.id, _id, null, _operator);
	pxyTI.changeState(TI_STATE_NORMAL, app.myPassport);
	pxyTI.setTotalWeight(4000, null, null);	
	pxyTI.CM_TILC.setMyType(_trailerType);
	pxyTI.setWidth(_trailerType.width);
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_STORAGE);
	pxyTI.zSetPxyRemarks(self.createdByUnitTest(null));					// 10/09/2015 cnwmh5
	
	//jlier1 TFS 54675 31/10/22
	if self.opts.includesKey("ContentsStatus") then
		pxyTI.setContentsStatus(self.opts.int("ContentsStatus"));
	endif;
	
	self.ignoreTrxWarnings(true);
	create moveController transient;
	moveController.isForcedMove := true;
	moveController.setMyToPrimaryLocation( _location);
	moveController.setMoveMode(REAL_MODE);
	
	app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, app.myPassport);

	self.assertNoTrxErrors();
	self.assertNotNull(realTI);
	self.assertTrue(realTI.isKindOf(CM_TILC));
	self.assertEqual(realTI.CM_TILC.allLCs.size, _trailerType.numControllers);
	return realTI.CM_TILC;
epilog

	delete moveController;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_trailerType" type="CM_TILCType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="CM_TILC"/>
    </JadeMethod>
    <JadeMethod name="addTrailerType" id="a32ccc6e-2da9-4951-a0f0-60aebb15959b">
        <source>addTrailerType(_tilcTypeCode, 
				_tilcTypeDesc : String; 
				_tilcCargoType : CM_CargoType; 
				_length,
				_numControllers,
				_maxHeight, 
				_maxWeight, 
				_tareWeight : Integer;
				_height : Decimal;
				_category : Integer;
				_width : Decimal) : CM_TILCType;

/*

Purpose:			Add a tailer type

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2010	cnwndl1	Initial creation
27 Oct 2022	jlier1 TFS 54675 - added height and category
10/03/2023	jlika1	Add width to Trailer Type
*/

vars

	pxyTrailerType		: CM_TILCType;
	trailerType			: CM_TILCType;
	allowUpdateTotWeight : Boolean; //15/10/2025	navkc1 JIRA 36057
begin

	if _tilcCargoType = null then
		return null;
	endif;
	
	//15/10/2025	navkc1 JIRA 36057
	if self.opts.includesKey('allowUpdateTotalWeight') &lt;&gt; null then
		allowUpdateTotWeight := self.opts.bool('allowUpdateTotalWeight');
	endif;
	
	//trailerType := _tilcCargoType.allTILCTypes[_tilcTypeCode];
	trailerType := app.myRoot.allTILCTypes[null, _tilcTypeCode];
	self.deleteTrailerType(trailerType);
	trailerType := null;

	create pxyTrailerType transient;
	pxyTrailerType.setProxy(_tilcTypeCode,										// code : String;
							_tilcTypeDesc,										// description : String;
							_tilcCargoType,										// cargoType : CM_CargoType;
							_length,											// length : Integer;
							_numControllers,									// numControllers : Integer
							_maxHeight,											// maxHeight : Integer;
							_maxWeight, 										// maxWeight : Integer;
							_tareWeight, 										
							null,												// colour : Integer
							false,
							_height,
							_category,
							_width,
							null,												// par 30852 Dec 2012
							allowUpdateTotWeight								//15/10/2025	navkc1 JIRA 36057
							);
	app.myTrxCA.trxCreateTILCType(pxyTrailerType, trailerType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return trailerType;

epilog

	delete pxyTrailerType;

end;</source>
        <Parameter name="_tilcTypeCode" type="String"/>
        <Parameter name="_tilcTypeDesc" type="String"/>
        <Parameter name="_tilcCargoType" type="CM_CargoType"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_numControllers" type="Integer"/>
        <Parameter name="_maxHeight" type="Integer"/>
        <Parameter name="_maxWeight" type="Integer"/>
        <Parameter name="_tareWeight" type="Integer"/>
        <Parameter name="_height" type="Decimal"/>
        <Parameter name="_category" type="Integer"/>
        <Parameter name="_width" type="Decimal"/>
        <ReturnType type="CM_TILCType"/>
    </JadeMethod>
    <JadeMethod name="addTrain" id="ef1c04a4-aadf-44dc-9a7b-0c6df8452def">
        <source>addTrain(	_code: String;	// mandatory
			_myTrackClearance : CM_TrackClearance // optional
			): CM_Train;
//09 July 2009	cnwmd1	
//
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
vars
	proxyTrain, train : CM_Train;
	carrier : CM_Carrier;
begin
	carrier := app.myRoot.allCarriers.first.CM_Carrier;
	
	create proxyTrain transient;
	proxyTrain.setProxy(_code,
						_code,
						null,
						null,
						null,
						null,
						app.myPassport.myTerminal,
						null,
						null,//navsp1 17MAY2022 TFS#53619
						null,
						null,
						null,
						null,
						null,
						null,
						null,
						carrier,
						app.actualTimeServer,	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
						null,
						null,
						null,
						null,
						_myTrackClearance,	//_myTrackClearance : CM_TrackClearance
						false,
						null,               //02.10.2020 cnwma1 TFS #50112
						null);              //02.10.2020 cnwma1 TFS #50112
						
	
	app.myTrxCA.trxCreateTrain(proxyTrain, train, false, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	return train;
	
epilog
	delete proxyTrain;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_myTrackClearance" type="CM_TrackClearance"/>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="addTrainBreakBulkPrenoteRec" id="45e17883-6e03-47e8-80f9-8b27796b943f">
        <source>addTrainBreakBulkPrenoteRec(_trainCode, _railAreaId, _wagonClass, _wagonMasterCode : String; _allTrackedItemIds : StringArray; 
							_cargoType : CM_CargoType; _cargoSubType : CM_Product; _operator : CM_Operator) : CM_TIByIdDups;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2022	navpw1	Initial creation TFS: 54032

*/

constants
	STOP_CSI		: Integer = 5;
	DO_AUTO_PLAN	: Boolean = true;
	
vars
	trainObj		: CM_Train;
	railAreaObj		: CM_Rail;
	wagonObj		: CM_Wagon;
	wagonClass		: CM_WagonClass;
	allTrackedItems	: CM_TIByIdDups;
	tiObj			: CM_TrackedItem;
	pxyMasterObj	: CM_WagonMaster;
	wagonMasterObj	: CM_WagonMaster;
	railLineObj		: CM_RailLine;
	allWagons		: CM_WagonArray;
	trackedItemId 	: String;
	
begin
	// ****** ADD NEW TRAIN
	trainObj :=	self.addTrain(_trainCode, null);
	self.assertNotNullMsg(trainObj, UT_DSL::addTrainContainerPrenoteRec.cnGetMethodName() &amp; ": Train is null");
	
	// ****** ADD NEW RAIL AREA
	railAreaObj	:= self.addRailArea(_railAreaId, 4, 5);
	self.assertNotNullMsg(railAreaObj, UT_DSL::addTrainContainerPrenoteRec.cnGetMethodName() &amp; ": Rail Area is null");
	
	railLineObj	:= railAreaObj.allRailLinesByIndex[1];
	
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "250".Decimal);
	
	wagonClass := self.addWagonClass(_wagonClass);
	
	// ****** CREATE MASTER FOR SOME REASON
	create allWagons transient;
	create pxyMasterObj transient;
	pxyMasterObj.setProxy(	_wagonMasterCode,	//_id : String;
							wagonClass,	//_myWagonClass : CM_WagonClass;
							CM_Carrier.firstInstance(),	//_myCarrier : CM_Carrier;
							450,	//_maxCargoHeight	: Decimal; 
							60000,	//_maxCargoWeight	: Decimal;
							15000);	//_tareWeight	: Decimal
	
	pxyMasterObj.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster(pxyMasterObj, wagonMasterObj, app.myPassport);
	
	// ****** ADD PLACE CONTAINERS ON WAGONS
	
	self.opts.addAssoc( UTTI_State, 0 );
	
	self.opts.addAssoc(UTTI_State,TI_STATE_NOTIFIED ); // Make this a PRENOTE
	self.opts.addAssoc(UTTI_ReceiptMode, TI_TRANSMODE_RAIL);
	self.opts.addAssoc(UTTI_MyProduct, _cargoSubType.code);
	self.opts.addAssoc(UTTI_TotalWeight, 268);
	self.opts.addAssoc(UTTI_TareWeight, 13);
	self.opts.addAssoc(UTTI_CargoWeight, 255);
	self.opts.addAssoc("totalQuantity", 1);
	
	create allTrackedItems transient;
	
	foreach trackedItemId in _allTrackedItemIds do
		tiObj := self.addCargoOpts(trackedItemId, null, null, _operator, _cargoType.id);
		allTrackedItems.add(tiObj);
	endforeach;
	
	wagonObj := self.addWagonToTrainOption2(trainObj, wagonMasterObj, allTrackedItems, false);
	allWagons.add(wagonObj);
	app.myTrxUA.trxUpdateWagonPosition(railLineObj, wagonObj, 1, app.myPassport);

	self.opts.addAssoc( UTTI_State, 0 );
	self.opts.addAssoc(UTTI_ReceiptMode, 0);
	
	return allTrackedItems;
	
epilog
	delete allWagons;
	delete pxyMasterObj;

end;</source>
        <Parameter name="_trainCode" type="String"/>
        <Parameter name="_railAreaId" type="String"/>
        <Parameter name="_wagonClass" type="String"/>
        <Parameter name="_wagonMasterCode" type="String"/>
        <Parameter name="_allTrackedItemIds" type="StringArray"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_cargoSubType" type="CM_Product"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_TIByIdDups"/>
    </JadeMethod>
    <JadeMethod name="addTrainContainerPrenoteRec" id="fba43e75-646c-4ed3-9337-b9fbc615cd4b">
        <source>addTrainContainerPrenoteRec(_trainCode, _railAreaId, _wagonClass, _wagonMasterCode : String; _allTrackedItemIds : StringArray; 
							_isoType, _commodity : String; _operator : CM_Operator) : CM_TIByIdDups;
/*

Purpose:			Creates a Train, Rail Area, Wagon Class, Wagon Master and adds containers to wagons as prenotes
					Transients Created and Returned: allTrackedItems

Parameters:			_trainCode			String		Train code to use for creating a train
					_railAreaId			String		Rail area id used to create rail area
					_wagonClass			String		Wagon class used to create wagon
					_wagonMasterCode	String		Wagon master code used to create a wagon master
					_allTrackedItemIds	StringArray	All tracked item ids used to attach containers to wagon
					_isoType			String		Iso type used to assign containers to wagon
					_commodity			String		Commodity used to assign containers to wagon
					_operator			CM_Operator	Operator used to assign containers to wagon

Return Value:		CM_TIByIdDups	Used to return a collection of created Tracked Items

Date		Who		Reason
07 June 2022	navpw1	Initial creation TFS: 53764

*/

constants
	STOP_CSI		: Integer = 5;
	DO_AUTO_PLAN	: Boolean = true;
	
vars
	trainObj		: CM_Train;
	railAreaObj		: CM_Rail;
	wagonObj		: CM_Wagon;
	wagonClass		: CM_WagonClass;
	allTrackedItems	: CM_TIByIdDups;
	tiObj			: CM_TrackedItem;
	pxyMasterObj	: CM_WagonMaster;
	wagonMasterObj	: CM_WagonMaster;
	railLineObj		: CM_RailLine;
	allWagons		: CM_WagonArray;
	trackedItemId 	: String;
	
begin
	// ****** ADD NEW TRAIN
	trainObj :=	self.addTrain(_trainCode, null);
	self.assertNotNullMsg(trainObj, UT_DSL::addTrainContainerPrenoteRec.cnGetMethodName() &amp; ": Train is null");
	
	// ****** ADD NEW RAIL AREA
	railAreaObj	:= self.addRailArea(_railAreaId, 4, 5);
	self.assertNotNullMsg(railAreaObj, UT_DSL::addTrainContainerPrenoteRec.cnGetMethodName() &amp; ": Rail Area is null");
	
	railLineObj	:= railAreaObj.allRailLinesByIndex[1];
	
	// ****** ADD NEW WAGON CLASS AND WAGON, THEN ATTACH TO TRAIN
	self.opts.purge();
	self.opts.addAssoc("MaxPosiWeight", "4500".Decimal);
	self.opts.addAssoc("MaxPosiHeight", "250".Decimal);
	
	wagonClass := self.addWagonClass(_wagonClass);
	
	// ****** CREATE MASTER FOR SOME REASON
	create allWagons transient;
	create pxyMasterObj transient;
	pxyMasterObj.setProxy(	_wagonMasterCode,	//_id : String;
							wagonClass,	//_myWagonClass : CM_WagonClass;
							CM_Carrier.firstInstance(),	//_myCarrier : CM_Carrier;
							450,	//_maxCargoHeight	: Decimal; 
							60000,	//_maxCargoWeight	: Decimal;
							15000);	//_tareWeight	: Decimal
	
	pxyMasterObj.setPropogateChanges(false);
	app.myTrxCA.trxCreateWagonMaster(pxyMasterObj, wagonMasterObj, app.myPassport);
	
	// ****** ADD PLACE CONTAINERS ON WAGONS
	
	self.opts.addAssoc( UTTI_State, 0 );
	
	self.opts.addAssoc(UTTI_State,TI_STATE_NOTIFIED ); // Make this a PRENOTE
	self.opts.addAssoc(UTTI_ReceiptMode, TI_TRANSMODE_RAIL);
	
	create allTrackedItems transient;
	
	foreach trackedItemId in _allTrackedItemIds do
		tiObj := self.addContainerOpts(trackedItemId, _isoType, _commodity, _operator);
		self.addStopById(tiObj, STOP_CSI);
		allTrackedItems.add(tiObj);
	endforeach;
	
	wagonObj := self.addWagonToTrainOption2(trainObj, wagonMasterObj, allTrackedItems, false);
	allWagons.add(wagonObj);
	app.myTrxUA.trxUpdateWagonPosition(railLineObj, wagonObj, 1, app.myPassport);

	self.opts.addAssoc( UTTI_State, 0 );
	self.opts.addAssoc(UTTI_ReceiptMode, 0);
	
	return allTrackedItems;
	
epilog
	delete allWagons;
	delete pxyMasterObj;
	
end;</source>
        <Parameter name="_trainCode" type="String"/>
        <Parameter name="_railAreaId" type="String"/>
        <Parameter name="_wagonClass" type="String"/>
        <Parameter name="_wagonMasterCode" type="String"/>
        <Parameter name="_allTrackedItemIds" type="StringArray"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_TIByIdDups"/>
    </JadeMethod>
    <JadeMethod name="addTrainUserEvent" id="4b17440b-6429-46d8-a26a-76177262a46b">
        <source>addTrainUserEvent(_train : CM_Train io; _eventTypeNo : Integer) : Boolean;
// --------------------------------------------------------------------------------
// Created:		03 November 2009 by cnwjo3
//
// Purpose:		Add Train User Event
vars
	now : TimeStamp;
	success : Boolean;
	firstEventType : CM_EventType;
	eventType : CM_EventType;
	iter : Iterator;
	foundEventType : Boolean;
	//pxyET : CM_EventType;
	pxyET : CM_Object;
	realTransaction : CM_EventTransaction;
begin

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	iter := app.myRoot.allEventTypesByCategory.createIterator;
	firstEventType := app.myRoot.allEventTypesByCategory.getAtKeyGeq(CM_EventType.TRAIN_EVENT,null);

	if firstEventType &lt;&gt; null then
		iter.startAtObject(firstEventType);
		while iter.next( eventType ) do
			if eventType.category &lt;&gt; CM_EventType.TRAIN_EVENT then
				break;
			endif;
			
			if eventType.type = _eventTypeNo then
				foundEventType := true;
				break;
			endif;
		endwhile;
	endif;	
	
	if foundEventType then
		create pxyET as eventType.myClassToCreate transient;  //don't like doing it this way, but i have no choice
		pxyET.CM_EventTransaction.setDetails(eventType, now, _train.getTerminal(), app.myPassport.myUser.code, false,0);
		
		app.myTrxCA.trxCreateTrainEvent(pxyET.CM_EventTransaction, realTransaction, _train, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			success := true;
		endif;
	endif;
	
	return success;
	
epilog

	delete pxyET;
	delete iter;
	
end;
</source>
        <Parameter name="_train" type="CM_Train" usage="io"/>
        <Parameter name="_eventTypeNo" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addTransactionType" id="111d0cbe-7816-4cd6-94e4-27c2a560dcc2">
        <source>addTransactionType(_transactionTypeDesc, _classNameToCreate	: String; _type, _group : Integer; _canCompleteToDoTask : Boolean) : CM_TransactionType;

/*

Purpose:		Add Transaction Type

Date			Who		Reason
15/02/2012		cnwmh5	Initial creation

*/

vars
	
	pxyTransactionType			: CM_TransactionType;
	transactionType				: CM_TransactionType;
	
begin

	self.deleteTransactionType(_type);

	create pxyTransactionType transient;
	pxyTransactionType.setProxy(_transactionTypeDesc, 			// description
								_type,							// Type
								_group,							// group : Integer
								_classNameToCreate,				// class name to create : String
								_canCompleteToDoTask, 			// can complete to do task : Boolean
								app.myRoot);
								
	app.myTrxCA.trxCreateTransactionType(pxyTransactionType, transactionType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return transactionType;
	
epilog

	delete pxyTransactionType;

end;</source>
        <Parameter name="_transactionTypeDesc" type="String"/>
        <Parameter name="_classNameToCreate" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_group" type="Integer"/>
        <Parameter name="_canCompleteToDoTask" type="Boolean"/>
        <ReturnType type="CM_TransactionType"/>
    </JadeMethod>
    <JadeMethod name="addUser" id="748beb07-9a2d-4d78-bb88-db7a5763094e">
        <source>addUser(_name, _code: String): CM_User;
/*

Purpose:			Add User	

Date				Who		Reason
28 November 2011	cnwmh5	Initial creation

*/
vars
	pxyUser,
	user			: CM_User;
	sysSecurityRole	: CM_SecurityRoleSystem;
	organisation	: CM_Organisation;
	
	daSet 			: CM_DataAccessControllerSet; 
	passedInDACSet : CM_DataAccessControllerSet; 
	
	password		: String;
	
begin
	
	self.deleteUser(_code);							// 14/09/2012 cnwmh5
	
	create daSet transient;
	create pxyUser transient;
	
	organisation := app.myRoot.allOrganisations["UnitTestTerminal"];
	if organisation = null then
		organisation := app.myRoot.allOrganisations["UNIT TEST"];
	endif;
	if self.opts.includesKey("Organisation") then
		organisation := app.myRoot.allOrganisations[self.opts.str("Organisation")];
	endif;
	if self.opts.includesKey("DAC") then
		passedInDACSet := self.opts.obj("DAC").CM_DataAccessControllerSet;
		if passedInDACSet &lt;&gt; null then
			passedInDACSet.copy( daSet );
		endif;
	endif;
	
	// 18/05/2015 cnwmh5
	password := "u^1tTest";
	if self.opts.includesKey("UserPassword") then
		password := self.opts.str("UserPassword");
	endif;
	
	sysSecurityRole := app.myRoot.allRoles['System Root'].CM_SecurityRoleSystem;
	if self.opts.includesKey("SysSecurityRole") then					// 03/02/2016 cnwmh5
		sysSecurityRole := self.opts.obj("SysSecurityRole").CM_SecurityRoleSystem;
	endif;	
	
	pxyUser.setProxy(_code, 
					 _name,									// Name 
					 EnabledNormalUser,						// Status
					 organisation, 							// Organisation;
					 app.myRoot,							// Root
					 true,									// Persistent Password
					 false,									// Radio Telemetry Only
					 false,									// Is Not Available For Entry
					 false,									// Allow Automatic Disability
					 null, 									// Last Log in TS
					 daSet,									// Data Access Controller Set
					 sysSecurityRole, 						// Security Role System
					 null,									// Email Entity
					 app.myRoot.allEmailEntities,			// Email Entity By Type Name Dict
					 null, 									// System Alert Types 
					 null, 									// Event Types
					 app.myRoot.getDefaultLocale(true),		// Locale
					 false,									// single user signon only (Single User Session)
					 false									// Single User Session Allow Override
					 );
	
	app.myTrxCA.trxCreateUser(pxyUser, password, user, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	return user;
epilog
	delete pxyUser;
	delete daSet;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="addUserHookCode" id="4e0247ec-3c4e-4688-88fc-02250b8b5e3b">
        <source>addUserHookCode(_userHookCode, _jadeCode : String; _userHookCodeType : Integer) : CM_HookCode;

/*

Purpose:		Add User Hook Code	

Date			Who		Reason
31/01/2012		cnwmh5	Initial creation

*/

vars

	pxyUserHookCode				: CM_HookCode;
	cmifHookCode				: CMIF_HookCode;
	userHookCode				: CM_HookCode;
	userHookCodeType			: CM_HookType;
	
begin

	self.deleteUserHookCode(_userHookCode);

	userHookCodeType := app.myRoot.allHookTypes[_userHookCodeType];

	create pxyUserHookCode transient;
	create cmifHookCode transient;
	cmifHookCode.myProxyHookCode := pxyUserHookCode;
	cmifHookCode.code := "Fonterra";
	cmifHookCode.allLinkObjects.add(CM_Root.firstInstance);
	cmifHookCode.myHookType := userHookCodeType;
	cmifHookCode.jadeCode := _jadeCode;	
	
	cmifHookCode.allLinkObjects.add(self.getTerminal());
	cmifHookCode.setForUpdate();
	
	app.myTrxCA.trxCreateHookCode(cmifHookCode, userHookCode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
//	beginTransaction;
//	userHookCode.createProxyHookLinkForParent(_userHookCodeType, self.getTerminal());
//	commitTransaction;
	
	return userHookCode;
	
epilog

	delete pxyUserHookCode;
	delete cmifHookCode;

end;</source>
        <Parameter name="_userHookCode" type="String"/>
        <Parameter name="_jadeCode" type="String"/>
        <Parameter name="_userHookCodeType" type="Integer"/>
        <ReturnType type="CM_HookCode"/>
    </JadeMethod>
    <JadeMethod name="addUserTerminalToUser" id="3e2b6d08-2789-472f-9e18-8143013ebdbb">
        <source>addUserTerminalToUser(_cargoType: CM_CargoType);
/*
Adds a user terminal reference to the current user if required

Date		Who		Reason
18 February 2009	cnwcp2	Initial creation
18/05/2015	cnwmh5	CHnage to allow passing of user via opts
20/04/2022	navmd1	*Actually* user the passed in password, rather than just "password"
*/

vars
	term : CM_Terminal;
	userTerm : CM_UserTerminal;
	pxyUser : CM_User;
	found : Boolean;
	user		: CM_User;
	obj			: Object;
	secRoleTerm   : CM_SecurityRoleTerminal;
	
	objArray	: ObjectArray;
	
	userId		: String;
	password	: String;
begin

	
	// 08/05/2015 cnwmh5
	if self.opts.includesKey("RequestedUser") then
		userId := self.opts.str("RequestedUser");
		self.assertNotNull(userId);
		user := app.myRoot.allUsers[userId].CM_User;
		self.assertNotNull(user);
	else
		user := app.getMyUser();
	endif;
	
	// 18/05/2015 cnwmh5
	term := self.getTerminal();
	self.assertNotNull(term);
	
	// 18/05/2015 cnwmh5
	password := "password"; 
	if self.opts.includesKey("UserPassword") then
		password := self.opts.str("UserPassword");
	endif;
	
	// Need to see if the current user has a User Terminal for the current terminal
	//foreach userTerm in app.getMyUser.allUserTerminals do
	//	if userTerm.myTerminal = self.getTerminal then
	foreach userTerm in user.allUserTerminals do
		if userTerm.myTerminal = term then
			found := true;
			break;
		endif;
	endforeach;

	if not found then
		///pxyUser := app.createUpdateProxy(app.getMyUser).CM_User;
		pxyUser := app.createUpdateProxy(user).CM_User;
		///term := self.getTerminal();//app.createUpdateProxy(self.getTerminal).CM_Terminal;
		app.myPassport.setMyTerminal(term);
		create userTerm transient;
		
		// 03/02/2016 cnwmh5
		secRoleTerm := CM_SecurityRoleTerminalRoot.firstInstance;
		if self.opts.includesKey("TermSecurityRole") then
			secRoleTerm := self.opts.obj("TermSecurityRole").CM_SecurityRoleTerminal;
		endif;
		
		//userTerm.setForProxy(self.getTerminal,pxyUser, CM_SecurityRoleTerminalRoot.firstInstance, 
		userTerm.setForProxy(term, pxyUser, secRoleTerm, 
			_cargoType,	CM_BOLType.firstInstance, CM_CargoBOLType.firstInstance);
		
		app.myTrxUA.trxUpdateUser(pxyUser,password,app.myPassport);
	endif;
epilog
	if not found then
		delete userTerm;
		pxyUser.allSubSystemStateObjects.removeInvalidObjects();
		create objArray transient;
		pxyUser.allSubSystemStateObjects.copy(objArray);
		foreach obj in objArray do
			delete obj;
		endforeach;
		delete objArray;
		delete pxyUser;
	endif;
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="addVbsTimeslotType" id="0f5d298e-d78c-434e-a8f2-371bc5560641">
        <source>addVbsTimeslotType( _code : String; _desc : String ): CM_VehicleBookingTimeSlotType;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
21 October 2014	cnwndl1	Initial creation	Par 35008
21 Jun 2022 	navsrk20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
04 July 2023	jlizm1	TFS 53901 EUP VBS EDI
23 Aug 2023		navlw1 ChangeRequest 59180:[59931] EUP - Fixing Vehicle Booking Unit Test
25 Nov 2024		navhl20 CR MTN-33483: TPT | Vehicle Truck Booking Auto Associate with Release Request
*/

vars
	isNotAvailableForEntry	: Boolean;
	proxyType : CM_VehicleBookingTimeSlotType;
	real : CM_VehicleBookingTimeSlotType;
	rtnValue : Boolean;
	term	 : CM_Terminal;			//21.06.2022 navsrk20 TFS 53697
	starttime: Time;				//22.06.2022 navtnr20 TFS 53697
	duration	: Integer;
	gracePeriod	: Integer;
	entryOutsideSlotType : Integer;
	pregateInCheck : Boolean;
	pregateOutCheck : Boolean;
	kioskCheck	: Boolean;
	externelReference	: Boolean;

begin
	
	if self.opts.includesKey("PreGateInCheck") then						
		pregateInCheck := self.opts.bool("PreGateInCheck");
	endif;
	if self.opts.includesKey("PreGateOutCheck") then						
		pregateOutCheck := self.opts.bool("PreGateOutCheck");
	endif;
	if self.opts.includesKey("KioskCheck") then						
		kioskCheck := self.opts.bool("KioskCheck");
	endif;
	
	// 23.08.2023 navlw1 #59931
	if self.opts.includesKey("ExternalReference") then
		externelReference := self.opts.bool("ExternalReference");
	endif;
	
	isNotAvailableForEntry := false;
	term := self.getTerminal();		//21.06.2022 navsrk20 TFS 53697
	
	create proxyType transient;
	proxyType.setForProxy(	_code,	//_code : String;
							_desc,	//_description : String;
							isNotAvailableForEntry,	//_notAvailableForEntry : Boolean
							term,			//21.06.2022 navsrk20 TFS 53697
							starttime,	//22.06.2022 navtnr20 TFS 53697
							duration,
							gracePeriod,
							entryOutsideSlotType,
							pregateInCheck,
							pregateOutCheck,
							kioskCheck,
							externelReference,	//22.06.2022 navtnr20 TFS 53697
							false);				//25.11.2024 navhl20 #33483

	app.myTrxCA.trxCreateVBTimeSlotType(proxyType, real, app.myPassport);
	self.assertTrueMsg(real &lt;&gt; null, "VehicleBookingTimeSlotype not created for '" &amp; _code &amp; "'  " &amp; app.myPassport.getAllErrorsWarningsAsString);
	
epilog
	delete proxyType;
	return real;

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="CM_VehicleBookingTimeSlotType"/>
    </JadeMethod>
    <JadeMethod name="addVehicle" id="f69f3d12-bbef-4f45-a29c-a5b63551ae41">
        <source>addVehicle( _regNo : String ; _carrier : CM_Carrier; _term : CM_Terminal) : CM_Vehicle;

/*

Purpose: for inter terminal stuff

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwrd1	Initial creation

*/

vars
	pProxyVehicle, 
	pNewVehicle :CM_Vehicle;
begin

	create pProxyVehicle transient;
		
	pProxyVehicle.setProxy(
							_regNo,
							'',
							2000, //tareweight
							0, // max laden weight
							_carrier,
							'', //state
							false, //isavail
							_term
							);
	
	app.myTrxCA.trxCreateVehicle(pProxyVehicle, pNewVehicle, app.myPassport);

	return pNewVehicle;
epilog
	delete pProxyVehicle;
end;
</source>
        <Parameter name="_regNo" type="String"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="addVehicleBookingAdv" id="080e0952-5553-40f1-8cba-30657b26711a">
        <source>addVehicleBookingAdv(_id : String): CM_VehicleBookingTimeSlot;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 oct 2022			navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
24 May 2023 		navhl20 Defect 58041: MTN - Unable to copy the slots with the status "Booked - Current"
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot

*/

constants

	
	
vars
	realVbsTimeSlot,
	proxyVbsTimeSlot		: CM_VehicleBookingTimeSlot;
	vbsSlotType				: CM_VehicleBookingTimeSlotType;
	reference,
	carrierCode,
	subCarrierCode,
	driverId,
	vehicleId,
	id,						
	externalReference		: String;
	date					: Date;
	startTime,
	endTime					: TimeStamp;
	vbsTimeSlotItem			: CM_VehicleBookingTimeSlotItem;
	vbsTimeSlotITemsArray	: CM_ObjectArray;
	trackedItem				: CM_TrackedItem;
	tiStringArray			: StringArray;
	vehicleBookingTerminal	: CM_VehicleBookingTerminal;
	carrier					: CM_Carrier;
	subCarrier				: CM_Carrier;
	driver					: CM_DriverDetails;
	vehicle					: CM_Vehicle;
	preGateInCheck,
	postGateCheck,
	kioskCheck				: Boolean;
	allCarriers 			: CM_CarrierByCodeDict;	
	allVehicleMachines 		: CM_VehicleSet; 
	email					: CM_EmailEntityByTypeNameDict;
	releaseRequests			: CM_BulkReleaseSet;
begin

	carrierCode := _id[1:6] &amp; "CARR";
	subCarrierCode := _id[1:6] &amp; "SUB";
	driverId := _id[1:24] &amp; "DRIVER";
	vehicleId := _id[1:5] &amp; "VEHICLE";
	
	// Delete the Vehicle early to avoid any VVR warnings
	self.deleteVehicle(vehicleId);
	
	self.deleteVbsTimeSlotAdv(_id);
	self.deleteVbsTimeslotType(_id);
	
	vehicleBookingTerminal := self.getMyTerminal.myVehicleBookingTerminal;
	vbsSlotType 		   := self.addVbsTimeslotType(_id, "Slot Type Create" &amp; _id); 
	
	create proxyVbsTimeSlot transient;
	
	// create carrier and subcarrier
	create email transient;
	self.deleteCarrier(carrierCode);
	self.deleteCarrier(subCarrierCode);

	carrier := self.addCarrier(carrierCode, carrierCode, email, false, true, true, null);
	subCarrier := self.addCarrier(subCarrierCode, subCarrierCode, email, false, true, true, null);

	// create vehicle
	vehicle := self.addVehicle( vehicleId, carrier, self.getTerminal());
	self.assertNotNull(vehicle);
	
	// create driver details
	self.deleteDriverDetails(driverId);
	create allCarriers transient;
	allCarriers.add(carrier);
	create allVehicleMachines transient;
	allVehicleMachines.add(vehicle);
	driver := self.createDriverDetails(driverId, allCarriers, allVehicleMachines);
	
	startTime.setTime(vbsSlotType.startTime);
	startTime.setDate(date.addDays(1));
	
	endTime.setTime(vbsSlotType.startTime.addMinutes(15));
	endTime.setDate(date.addDays(1));
	
	create releaseRequests transient;
	if self.opts.includesKey("ReleaseRequest") then
		releaseRequests.add(self.opts.obj("ReleaseRequest").CM_BulkRelease);
	endif;
	
	proxyVbsTimeSlot.setProxy(startTime, endTime, vehicleBookingTerminal, carrier, subCarrier, driver, vehicle, null, true, false, tiStringArray, null, vbsSlotType, _id, null, releaseRequests, null, vbsSlotType.preGateInCheck, vbsSlotType.preGateOutCheck, vbsSlotType.kioskCheck, null, null ); // 08 Aug 2024 navcs2	ChangeRequest 63928
	
	app.myTrxCA.trxCreateVehicleBookingAdv(proxyVbsTimeSlot, realVbsTimeSlot,false, app.myPassport);			//24.5.2023 navhl20 #58041
	
	return realVbsTimeSlot;
epilog
	delete tiStringArray;
	delete allCarriers;
	delete email;
	delete allVehicleMachines;
	delete proxyVbsTimeSlot;
	delete releaseRequests;
end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="addVehicleVisitItem" id="9afa2a36-ff24-4c35-8b84-a7a0946e48c6">
        <source>addVehicleVisitItem(_vvr: CM_VehicleVisitRecord io; _container: CM_Container; _empty: Boolean; _taId : String): CM_VehicleVisitRecord;
//30 July 2009	cnwdw1	
// 08/02/2010 	cwjre1 terminal area id parameter added for CCMS 1101 MT release handling
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
vars
	controller : CMIF_FlexiGateController;
	pxyGateEntity, gateEntity: CMGTE_Entity;
	release: CM_BulkRelease;
	gateName: String;
	releaseType : Integer;
	bestPick: Boolean;
	customsNumber : String;
	deliveryNumber : String;
	operImportReleasePin : String;
	releaseByType : Boolean;
	clientRef: String;
	reserveDetail: CM_ReserveDetail;
	reserveTI: CM_ReserveTI;
	relRemarks : String;
	subTerm : CM_SubTerminal;
	firstTi	: CM_TrackedItem;
begin
	
	bestPick := self.opts.bool("BestPick");

	// Create the GTE Entity and add to VVR
	create controller transient;
	create pxyGateEntity as CMGTE_Release transient;
	controller.myTerminal := self.getTerminal();
	if _empty then
		controller.jobType := CMGTE_Entity.JobType_EmptyOUT;   // MT
	else
		controller.jobType := CMGTE_Entity.JobType_FullOUT;   // MT
	endif;
	
	controller.numItems := 1;
	
	if _container &lt;&gt; null then
		controller.id := _container.id;
		controller.isoTypeCode := _container.isoType;
		controller.operatorCode := _container.operatorCode;
		controller.consigneeCode	:= _container.consignee;	// par 29480 April 2012
		if self.opts.includesKey("RelRemarks") then    //cnwma1 30/10/2014 PAR #35088
			controller.remarks :=self.opts.str("RelRemarks");
		endif;
		
	
	endif;
	controller.cargoType := TI_CargoType_Container;
	controller.myVehicleVisitRecord := _vvr;
	controller.yardLocationTxt :=  _taId;
	
	releaseType := null;
	release := self.opts.obj("release").CM_BulkRelease;
	if release &lt;&gt; null then 
		controller.myBulkRelease := release;
		if _container &lt;&gt; null then
			// Release by Id so try to find a matching reserve TI
			foreach reserveDetail in release.allReserveDetails do
				if reserveDetail.isKindOf(CM_ReserveTI) then
					reserveTI := reserveDetail.CM_ReserveTI;
					firstTi := reserveTI.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
					//if reserveTI.allTrackedItems.first &lt;&gt; null and reserveTI.allTrackedItems.first.id = _container.id then
					if firstTi &lt;&gt; null and firstTi.id = _container.id then //23/06/2023	navkc1	CR 58406 Task 58408
						controller.myReserveDetail := reserveDetail;
						break;
					endif;
				endif;
			endforeach;
		endif;
		if controller.myReserveDetail = null then
			controller.myReserveDetail := release.allReserveDetails.first;
		endif;
		controller.deliveryReason	:= release.deliveryReasonDescr;	// cnwcs5 June2012
		
		if controller.myReserveDetail &lt;&gt; null then
			controller.isoTypeCode := controller.myReserveDetail.getISOTypeCode;
			controller.isoGroup := controller.myReserveDetail.getISOGroupCode;
			controller.operatorCode := controller.myReserveDetail.getOperatorCode;
			if release.myVoyage &lt;&gt; null then
				controller.voyageCode := release.myVoyage.code;
			endif;
			if controller.myReserveDetail.isKindOf(CM_ReserveSelection) then
				controller.myReserveDetail.CM_ReserveSelection.allTerminalAreas.copy(controller.allSourceTAs);
				controller.billOfLading := controller.myReserveDetail.getBOLNumber;
			endif;
			if not opts.includesKey("BestPick") then
				bestPick := controller.myReserveDetail.bestPick;
			endif;
		endif;
		
		controller.mtOnly := not release.fullRelease;
		if controller.mtOnly then
			controller.commodity := "MT";
		endif;
		releaseType := release.type;
		releaseByType := release.releaseByType;
	endif;
	
	if app.isSubTerminalsOn(self.getTerminal) then
		subTerm := self.getTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BulkRelease,
															releaseType,	// cnwdad1 27/01/2010 - PAR #22205.
															0,
															null,
															false);
		if subTerm &lt;&gt; null then
			controller.subTerminalCode := subTerm.code;
		endif;
	endif;

	pxyGateEntity.setPXYFromController(controller); 
	if _container &lt;&gt; null or not releaseByType then
		pxyGateEntity.CMGTE_Release.setIsReleaseById(true);
	else
		pxyGateEntity.CMGTE_Release.setIsReleaseById(false);
	endif;
	pxyGateEntity.CMGTE_Release.setBestPick(bestPick);
	
	//+cnwml2 PAR25757
	customsNumber := self.opts.str("customsNumber");
	if customsNumber &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setCustomsEntryNumber(customsNumber);
	endif;
	
	//+cnwml2 PAR25757
	deliveryNumber:= self.opts.str("deliveryNumber");
	if deliveryNumber &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setDeliveryNumber(deliveryNumber);
	endif;
	
	// cnwrl1 07/10/2010 PAR 25958 - start of coding
	operImportReleasePin	:= self.opts.str("operImportReleasePin");
	if operImportReleasePin &lt;&gt; null then
		pxyGateEntity.CMGTE_Release.setImportReleasePIN( operImportReleasePin );
	endif;
	// cnwrl1 07/10/2010 PAR 25958 - end of coding

	clientRef	:= self.opts.str("clientRef");
	if clientRef &lt;&gt; null then
		pxyGateEntity.setClientRef( clientRef );
	endif;
	
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiGateEntity(_vvr, pxyGateEntity, gateEntity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyGateEntity;
	delete controller;
	
	return _vvr;

epilog
	delete pxyGateEntity;
	delete controller;
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="io"/>
        <Parameter name="_container" type="CM_Container"/>
        <Parameter name="_empty" type="Boolean"/>
        <Parameter name="_taId" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="addVehicleVisitRecord" id="a3dda4c5-4aba-44fe-b7f8-b40edb870d9c">
        <source>addVehicleVisitRecord(_truck, _state, _driver, _gateName: String): CM_VehicleVisitRecord;
//30 July 2009	cnwdw1	
//13/05/2022 	navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
//11/05/2023	navdap1	TFS 56801 EUP - EDI Message Type - Transport Status Message Processing
//22 Feb 2024 	navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
//21 Jan 2026	navbs1	Story MTN-36661: MTN | KPI REST API - Truck Turn Around
vars
	pxyVVR, vVR: CM_VehicleVisitRecord; 
	gate: CM_Gate;
	adminGate: CM_GateArea;
	now: TimeStamp;
	yic: String;
	subCarrier : String;
	vbsTS : CM_VehicleBookingTimeSlot;
	driverCode : String;				// TFS 56801
	retroDT	: TimeStamp;
	carrier : String;
begin

	// Create the Vehicle Visit Record
	gate := self.getGate(_gateName);
	if gate &lt;&gt; null then
		adminGate := gate.getFirstAGate_IN();
	endif;
	
	if self.opts.includesKey("Carrier") then					//21.01.2026 navbs1 #36661													
		carrier := self.opts.str("Carrier");	
	else
		carrier := self.getProfileStr(UT_Profile.P_CARRIER);
	endif;
	
	if self.opts.includesKey("SubCarrier") then					//03/06/2022 navhl20 TFS 53430							
		subCarrier := self.opts.str("SubCarrier");				//03/06/2022 navhl20 TFS 53430	
	endif;														//03/06/2022 navhl20 TFS 53430	
	yic := self.opts.str("YardInterchangeArea");
	create pxyVVR transient;
	if self.opts.includesKey("VehicleBookingTS") then			//14Dec2022 navsp1 TFS 55580
		vbsTS := self.opts.obj("VehicleBookingTS").CM_VehicleBookingTimeSlot;		
		pxyVVR.setVehicleBookingTimeSlot(vbsTS);
	endif;
	// TFS 56801 start
	if self.opts.includesKey("DriverCode") then
		driverCode := self.opts.str("DriverCode");
	else
		driverCode := _driver;
	endif;
	
	if self.opts.includesKey("RetroDT") then					//22.02.2024 navhl20 #62525
		retroDT := self.opts.timestamp("RetroDT");
	endif;
	// TFS 56801 end
	//pxyVVR.setProxyFlexiGate(_driver, _driver, self.getProfileStr(UT_Profile.P_CARRIER), subCarrier, _truck, _state, yic, self.getTerminal(), gate,self.getGateLane(adminGate, 1), "");	//13/05/2022 navhl20 TFS 53430
	//pxyVVR.setProxyFlexiGate(driverCode, _driver, self.getProfileStr(UT_Profile.P_CARRIER), subCarrier, _truck, _state, yic, self.getTerminal(), gate,self.getGateLane(adminGate, 1), "");	// TFS 56801			//21.01.2026 navbs1 #36661	
	pxyVVR.setProxyFlexiGate(driverCode, _driver, carrier, subCarrier, _truck, _state, yic, self.getTerminal(), gate,self.getGateLane(adminGate, 1), ""); 									//21.01.2026 navbs1 #36661			
	pxyVVR.setAutoComplete(self.opts.bool("AutoComplete"));
	if retroDT &lt;&gt; null then										//22.02.2024 navhl20 #62525
		pxyVVR.setTimeIn(retroDT.date, retroDT.time);
	else
		pxyVVR.setTimeIn(now.date, now.time);
	endif;
	app.myTrxCA.trxCreateVehicleVisitFlexi(pxyVVR, vVR, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return vVR;

epilog
	delete pxyVVR;
end;</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_driver" type="String"/>
        <Parameter name="_gateName" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="addVesselBasic" id="0c91f9ac-8d29-45a7-a1bc-c6e0f8240e40">
        <source>addVesselBasic(_vesselName : String;_operator : CM_Operator; _includeHarbour: Boolean; _includeHolds, _includeRORO, _includeLOLO : Boolean)  : CM_Vessel;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2023	jlier1	Initial creation

*/

vars
	vessel					: CM_Vessel;
	pxyVessel				: CM_Vessel;
	pxyROROVessel 			: CM_ROROVesselStructure;
	pxyCellVessel			: CM_CellularVesselStructure;
	pxyHMSVesselData		: HMS_VesselData;
	hms_VesselDataHarbour	: HMS_VesselDataHarbour;
	tidalClassArrival		: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	tidalClassDept			: HMS_TidalClass;
	conflictManager			: CMIF_HMS_ConflictsManager;
	pxyHolds 				: CM_GeneralCargoVesselStructure;
begin
	create pxyVessel transient;
	pxyVessel.setProxyForVessel(null,
								_vesselName,
								_vesselName,
								self.opts.str( ETRow_CallSign ),
								"",
								"",	
								"",
								self.opts.str( ETRow_LloydsNumber ),
								1,
								0,
								0,
								null,
								2000,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								true,
								false,
								_operator,
								null,
								false);
								
	if _includeRORO then
		create pxyROROVessel transient;
		pxyVessel.setMyROROVesselStructure(pxyROROVessel);
	endif;
	
	
	if _includeHolds then
		create pxyHolds transient;
	endif;
	
	if _includeLOLO then
		create pxyCellVessel transient;
	endif;
	
	pxyVessel.setProxyVesselStructures(pxyHolds, pxyCellVessel, null);
	
		create pxyHMSVesselData transient;
		pxyVessel.setHMSVesselData(pxyHMSVesselData);
		pxyHMSVesselData.setProxy(app.myRoot,
								false,
								false,
								false,
								false,
								false,
								false,
								false,
								false,
								"",
								"",
								"",
								0,
								0,
								0,
								100,
								20000,
								20000,
								19000,
								0,
								0,
								0,
								0,
								0,
								null,
								null);	
	if _includeHarbour then	
		create hms_VesselDataHarbour transient;
		tidalClassArrival	:= app.myRoot.allTidalClasses[ 'B' ];
		tidalClassDept		:= app.myRoot.allTidalClasses[ 'E' ];
	
	hms_VesselDataHarbour.setProxy(	null,
									false,
									false,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									self.getTerminal().myHarbour,
									null,
									null,
									null,
									null,
									tidalClassArrival,
									tidalClassDept );
		pxyHMSVesselData.allVesselDataForHarbour.add( hms_VesselDataHarbour );
	endif;
	
	app.myTrxCA.trxCreateVessel(pxyVessel, vessel, conflictManager, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	return vessel;
	
epilog
	delete pxyVessel;
	//delete pxyCellularVessel;
end;</source>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_includeHarbour" type="Boolean"/>
        <Parameter name="_includeHolds" type="Boolean"/>
        <Parameter name="_includeRORO" type="Boolean"/>
        <Parameter name="_includeLOLO" type="Boolean"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselBays" id="e7a98d6e-3ae2-418e-8fd7-5292c5d3d8e2">
        <source>addVesselBays(_vesselName : String) : CM_Vessel;
//26 March 2010 cnwrs1	
// 29/07/2011	cnwmh5	Change to use UT_UnitTest.opts
// 17/8/11 NAVAB1 add in decks
//
vars
	vessel					: CM_Vessel;
	pxyCellularVessel		: CM_CellularVesselStructure;
	pxyCellDefn				: CM_CellDefn;
	pxyTierDefn				: CM_TierDefn;
	bay						: CM_BayDefn;
	bays, b, b1, b2 : Integer;
	vesselName, baysString: String;
	big: Boolean;
begin
	vesselName:=_vesselName ;	
	vessel	:= self.getVessel( vesselName );

	assertNotNull(vessel);

	// Create the Bays
	pxyCellularVessel := app.createUpdateProxy(vessel.myCellularVesselStructure).CM_CellularVesselStructure;
	
	pxyCellularVessel.setProxyCellularVessel(null, true, true, false, 0); // PAR 32286
	
	// pxyCellularVessel.createProxyBaysFromString("01 03" &amp; CM_CellularVesselStructure.HoldSeperator &amp; "05 07"&amp; CM_CellularVesselStructure.HoldSeperator &amp; "09 11");
	
	big := self.opts.bool("big");
	bays := self.opts.intDef( "Bays" , 3);
	foreach b in 1 to bays do
		if b &gt; 1 then
			baysString := baysString &amp; CM_CellularVesselStructure.HoldSeperator;
		endif;
		b1 := ((b - 1) * 4) + 1;
		b2 := b1 + 2;
		baysString := baysString &amp; b1.stringWithLeadingZeros(2) &amp; " " &amp; b2.stringWithLeadingZeros(2);
	endforeach;
	pxyCellularVessel.createProxyBaysFromString(baysString);
	
	foreach bay in pxyCellularVessel.allBaysByOrdinal do
		// OD Cells
		if big then
			bay.allCellsOnDeck.purge;
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("08", 1, 1, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("06", 2, 2, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("04", 3, 3, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("02", 4, 4, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("01", 5, 5, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("03", 6, 6, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("05", 7, 7, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("07", 8, 8, bay, null, 0);
			// UD Cells
			bay.allCellsUnderDeck.purge;
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("08", 1, 1, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("06", 2, 2, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("04", 3, 3, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("02", 4, 4, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("01", 5, 5, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("03", 6, 6, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("05", 7, 7, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("07", 8, 8, null, bay, 0);
	
			// OD Tiers
			bay.allTiersOnDeck.purge;
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("82", 1, 1, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("84", 2, 2, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("86", 3, 3, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("88", 4, 4, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("90", 5, 5, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("92", 6, 6, bay, null);
	
			// UD Tiers
			bay.allTiersUnderDeck.purge;
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("02", 1, 1, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("04", 2, 2, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("06", 3, 3, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("08", 4, 4, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("10", 5, 5, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("12", 6, 6, null, bay);
		else
			bay.allCellsOnDeck.purge;
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("06", 1, 1, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("04", 2, 2, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("02", 3, 3, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("01", 4, 4, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("03", 5, 5, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("05", 6, 6, bay, null, 0);
			// UD Cells
			bay.allCellsUnderDeck.purge;
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("04", 1, 1, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("02", 2, 2, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("01", 3, 3, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("03", 4, 4, null, bay, 0);
	
			// OD Tiers
			bay.allTiersOnDeck.purge;
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("82", 1, 1, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("84", 2, 2, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("86", 3, 3, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("88", 4, 4, bay, null);
	
			// UD Tiers
			bay.allTiersUnderDeck.purge;
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("02", 1, 1, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("04", 2, 2, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("06", 3, 3, null, bay);
		endif;
	endforeach;

	app.myTrxUA.trxUpdateVesselStructure(pxyCellularVessel, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	return vessel;
	
epilog

	delete pxyCellularVessel;
	
end;
</source>
        <Parameter name="_vesselName" type="String"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselCellular" id="60cbaf61-6710-4f7f-9584-7e76594982b7">
        <source>addVesselCellular( _name : String; _operator : CM_Operator ) : CM_Vessel;
//29 August 2008	cnwdw1	
//
vars

begin
	return self.addVesselCellularWithCode(_name, _name, _operator); 
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselCellularNoHMS" id="af6ba253-b2a4-4b51-bda9-8050551d765f">
        <source>addVesselCellularNoHMS( _name : String; _operator : CM_Operator) : CM_Vessel;
/* Changes

Date		Name	TFS#		Description
============================================================================
29/08/2008	cnwdw1	
12 2010		cnwgb1 				Modified 
29/07/2011	cnwmh5				Change to use UT_UnitTest.opts
04/03/2019	jlgka1	37102		STWR CAMS STANDARD CODECO Add isBarge Flag.
============================================================================*/

vars
	vessel					: CM_Vessel;
	pxyVessel				: CM_Vessel;
	pxyCellVessel			: CM_CellularVesselStructure;
	//pxyHMSVesselData		: HMS_VesselData;
	pxyCellularVessel		: CM_CellularVesselStructure;
	pxyCellDefn				: CM_CellDefn;
	pxyTierDefn				: CM_TierDefn;
	bay						: CM_BayDefn;
	conflictManager			: CMIF_HMS_ConflictsManager;
	tidalClassArrival		: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	tidalClassDept			: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	hms_VesselDataHarbour	: HMS_VesselDataHarbour;		// cnwrl1 20/05/2010 PAR 24012
	hlid : CM_HatchLidVessel;
	allHolds : CM_VesselHoldSet; 
	baySet: CM_BaySet;
begin
	
	create pxyVessel transient;
	
	pxyVessel.setProxyForVessel(null,
								_name,
								_name,
								self.opts.str( ETRow_CallSign ),
								"",
								self.createdByUnitTest(null),							// 18/08/2015 cnwmh5
								"",
								self.opts.str( ETRow_LloydsNumber ),
								1,
								0,
								0,
								VESSEL_TYPE_LOLO,
								2000,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								true,
								false,
								_operator,
								null,
								false);

	create pxyCellVessel transient;
	pxyVessel.setProxyVesselStructures(null, pxyCellVessel, null);

	//create pxyHMSVesselData transient;
	//pxyVessel.setHMSVesselData(pxyHMSVesselData);
	
	// cnwrl1 20/05/2010 PAR 24012 - start of coding
	/*
	create hms_VesselDataHarbour transient;	// NOTE: the delete is handled by the delete on the pxyVessel
	
	tidalClassArrival	:= app.myRoot.allTidalClasses[ 'A' ];
	tidalClassDept		:= app.myRoot.allTidalClasses[ 'C' ];
	
	hms_VesselDataHarbour.setProxy(	null,
									false,
									false,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									self.getTerminal().myHarbour,
									null,
									null,
									null,
									null,
									tidalClassArrival,
									tidalClassDept );
	pxyHMSVesselData.allVesselDataForHarbour.add( hms_VesselDataHarbour );
	// cnwrl1 20/05/2010 PAR 24012 - end of coding
	
	pxyHMSVesselData.setProxy(app.myRoot,
							false,
							false,
							false,
							false,
							false,
							false,
							"",
							"",
							"",
							0,
							0,
							0,
							100,
							20000,
							20000,
							0,
							0,
							0,
							0,
							0,
							null,
							app.myRoot.allVesselTypes["C"]);
	*/
	app.myTrxCA.trxCreateVessel(pxyVessel, vessel, conflictManager, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	delete pxyVessel;
	
	// Create the Bays
	pxyCellularVessel := app.createUpdateProxy(vessel.myCellularVesselStructure).CM_CellularVesselStructure;
	
	pxyCellularVessel.setProxyCellularVessel(null,true,true,false, 0); // PAR 32286
	pxyCellularVessel.createProxyBaysFromString("01 03" &amp; CM_CellularVesselStructure.HoldSeperator &amp; "05 07"&amp; CM_CellularVesselStructure.HoldSeperator &amp; "09 11");

	create allHolds transient;
	create baySet transient;

	foreach bay in pxyCellularVessel.allBaysByOrdinal do
	
		bay.setForUpdateWeights(999000,999000,999000,999000,999000);
		// OD Cells
		bay.allCellsOnDeck.purge;
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("06", 1, 1, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("04", 2, 2, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("02", 3, 3, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("01", 4, 4, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("03", 5, 5, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("05", 6, 6, bay, null, 0);

		// UD Cells
		bay.allCellsUnderDeck.purge;
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("04", 1, 1, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("02", 2, 2, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("01", 3, 3, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("03", 4, 4, null, bay, 0);

		// OD Tiers
		bay.allTiersOnDeck.purge;
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("82", 1, 1, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("84", 2, 2, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("86", 3, 3, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("88", 4, 4, bay, null);

		// UD Tiers
		bay.allTiersUnderDeck.purge;
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("02", 1, 1, null, bay);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("04", 2, 2, null, bay);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("06", 3, 3, null, bay);

		// HATCH LID
		create hlid transient;
		allHolds.clear;
		baySet.clear;
		allHolds.add(bay.myHold);
		baySet.add(bay);
		hlid.setProxy(bay.ordinalBay, bay.ordinalBay, 1,6,1,4,false, false,allHolds, baySet);
		hlid.setMyVessel(pxyCellularVessel);
	endforeach;

	app.myTrxUA.trxUpdateVesselStructure(pxyCellularVessel, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	return vessel;
	
epilog
	delete pxyVessel;
	delete pxyCellularVessel;
	delete allHolds;
	delete baySet;

end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselCellularWithCode" id="76c642b7-84bc-48db-9775-e37c75e97d14">
        <source>addVesselCellularWithCode(_code, _name : String; _operator : CM_Operator) : CM_Vessel;

/* Changes

Date		Name	TFS#		Description
============================================================================
29/08/2008	cnwdw1	
11/02/2014	cnwma1				Add missing details for clone test
04/03/2019	jlgka1	37102		STWR CAMS STANDARD CODECO Add isBarge Flag.
============================================================================*/
vars
	vessel						: CM_Vessel;
	pxyVessel					: CM_Vessel;
	pxyCellVessel				: CM_CellularVesselStructure;
	pxyCellularVessel			: CM_CellularVesselStructure;
	pxyCellDefn					: CM_CellDefn;
	pxyTierDefn					: CM_TierDefn;
	bay							: CM_BayDefn;
	hlid 						: CM_HatchLidVessel;
	allHolds 					: CM_VesselHoldSet; 
	conflictManager				: CMIF_HMS_ConflictsManager;
	groupLabelCriteriaColl  	: CM_YACriteriaTypeArray;
	pxyStructuralElements		: CM_VesselStructuralElements;
	vslSection 			    	: CM_VesselSectionVessel;
	vslrealSection				: CM_VesselSection;
	vslTank						: CM_VesselTankVessel;
	vslRealTank 				: CM_VesselTank;
	pxyVoyageAllocationConfig 	: CM_VoyageAllocationConfig;
	harbour					 	: HMS_Harbour;
	tidalClassArrival			: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	tidalClassDept				: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	hms_VesselDataHarbour		: HMS_VesselDataHarbour;		// cnwrl1 20/05/2010 PAR 24012
	resourceType				: HMS_ResourceType;
	pxyResourceType				: HMS_ResourceTypeForMovement;
	pxyVesselDataHarbour 	 	: HMS_VesselDataHarbour;
	pxyHMSVesselData			: HMS_VesselData;
	realHarbourBerthPreference  : HMS_BerthPreferenceVesselData;
	harbourBerthPrefArray		: ObjectArray;
	objj						: Object;
	coll	 					: ObjectArray;
	resourceTypeArray			: StringArray;
	baySet						: CM_BaySet;
	holds 						: Integer;
	idx 						: Integer;
	str 						: String;
	name						: String;
	yearOfBuild					: Integer;
	lengthOverall				: Decimal[6,2];
	deadWeight					: Integer;
	grossRegTonnes				: Integer;
	tmpStr						: String;
	numTugs 					: Integer;
	moveType 					: String;
	remarks : String;
begin
	
	remarks := self.createdByUnitTest(null); // TFS 52425 NAVAB1 23NOV2021
	if self.opts.includesKey("VesselRemarks") then
		remarks := self.opts.str("VesselRemarks");
	endif;
	
	name := _name;
	if self.opts.includesKey("VesselName") then
		name := self.opts.str("VesselName");
	endif;
	
	yearOfBuild := 2000;
	if self.opts.includesKey("YearOfBuild") then
		yearOfBuild := self.opts.int("YearOfBuild");
	endif;
	
	create pxyVessel transient;
	
	pxyVessel.setProxyForVessel(null,
								_code,
								name,
								self.opts.str(ETRow_CallSign),
								self.opts.str("ClassLabel"),
								remarks, // TFS 52425 NAVAB1 23NOV2021 was self.createdByUnitTest(null),							// 18/08/2015 cnwmh5
								"",
								self.opts.str(ETRow_LloydsNumber),
								1,
								self.opts.int("DispatchRate"),
								self.opts.int("CraneClearance"),
								VESSEL_TYPE_LOLO,
								yearOfBuild,
								self.opts.dec("LOAWithRampsDown"),
								self.opts.dec("AirDraft"),
								self.opts.dec("MaxVesselBeam"),
								self.opts.dec("DraftBow"),
								self.opts.dec("DraftStern"),
								null,
								null,
								true,
								false,
								_operator,
								self.opts.obj("VesselTrade").CM_Trade,
								self.opts.bool("isBarge")
								);

	create pxyCellVessel transient;
	pxyVessel.setProxyVesselStructures(null, pxyCellVessel, null);

	create pxyHMSVesselData transient;
	pxyVessel.setHMSVesselData(pxyHMSVesselData);
	
	// cnwrl1 20/05/2010 PAR 24012 - start of coding
	create hms_VesselDataHarbour transient;	// NOTE: the delete is handled by the delete on the pxyVessel
	
	tidalClassArrival	:= app.myRoot.allTidalClasses[ 'A' ];
	if self.opts.includesKey("TidalClassDept") then
		tidalClassDept := app.myRoot.allTidalClasses[self.opts.str("TidalClassDept")];
	else
		tidalClassDept		:= app.myRoot.allTidalClasses[ 'C' ];
	endif;
	
	if self.opts.includesKey("Harbour") then
		harbour := self.opts.obj("Harbour").HMS_Harbour;
	else	
		harbour := self.getTerminal().myHarbour;
	endif;
	
	hms_VesselDataHarbour.setProxy(	self.opts.str("PilotRemarks"),
									false,
									false,
									self.opts.int("EstTieUpTime"),
									self.opts.int("CrewLetGo"),
									self.opts.int("CrewTieUp"),
									self.opts.int("NoTugsIn"),
									self.opts.int("NoTugsOut"),
									self.opts.int("BerthPriority"),
									self.opts.int("NumHistVst"),
									harbour,
									self.opts.obj("LineCompany").HMS_LineCompany,
									self.opts.obj("ShippingAgent").CM_ShippingAgent,
									self.opts.obj("CategoryIn").HMS_VesselCategory,
									self.opts.obj("CategoryOut").HMS_VesselCategory,
									tidalClassArrival,
									tidalClassDept );
	pxyHMSVesselData.allVesselDataForHarbour.add( hms_VesselDataHarbour );
	// cnwrl1 20/05/2010 PAR 24012 - end of coding
	
	if self.opts.includesKey("DimLengthOverall") then
		lengthOverall := self.opts.dec("DimLengthOverall");
	else
		lengthOverall := 100;
	endif;
	
	if self.opts.includesKey("DeadWeight") then
		deadWeight := self.opts.int("DeadWeight");
	else	
		deadWeight := 20000;
	endif;
	
	if self.opts.includesKey("GrossRegTonnes") then
		grossRegTonnes := self.opts.int("GrossRegTonnes");
	else	
		grossRegTonnes := 20000;
	endif;
	
	pxyHMSVesselData.setProxy(app.myRoot,
							self.opts.bool("coastalService"),
							false,
							false,
							false,
							false,
							false,
							false,
							false,
							self.opts.str("RemarksGeneral"),
							self.opts.str("PreviousName"),
							self.opts.str("CountryCode"),
							self.opts.dec("DimBeam"),
							self.opts.dec("DimDraftAft"),
							self.opts.dec("DimDraftFore"),
							lengthOverall,
							deadWeight,
							grossRegTonnes,
							19000,
							0,
//							150,							// TFS 54739
//							50,								// TFS 54739
							(lengthOverall / 10).Integer,	// TFS 54739
							(lengthOverall / 5).Integer,	// TFS 54739
							0,
							0,
							self.opts.obj("ShippingLine").CM_ShippingLine,
							app.myRoot.allVesselTypes["C"]);
							
							
							
	if self.opts.includesKey("VoyageAllocationsCriteria") then
		create pxyVoyageAllocationConfig transient;
		create groupLabelCriteriaColl transient;
		pxyVoyageAllocationConfig.setProxyVoyage(self.opts.obj("VoyageAllocationsCriteria").CM_YACriteriaTypeArray,
			groupLabelCriteriaColl, Red, CM_YATypeCommodityGroup.firstInstance, null, null);
		pxyVessel.setVoyageAllocationConfig(pxyVoyageAllocationConfig);
	endif;
	
	
	// create the resource type coll
	if self.opts.includesKey("ResourceTypes") then
		// setup resource types we want
		create resourceTypeArray transient;
		resourceTypeArray.add("TUGS");
		resourceTypeArray.add("PILOT");
		
		create coll transient; 
		foreach tmpStr in resourceTypeArray do
			resourceType := app.myRoot.allResourceTypes[tmpStr];
			if resourceType &lt;&gt; null then
				coll.add(resourceType);
			endif;
		endforeach;
		
		// set default resources for the arrival movement
		moveType := HMSMovementTypeArrival;
		numTugs := 3;
		//harbour := hms_VesselDataHarbour.myHarbour;
		pxyResourceType := hms_VesselDataHarbour.allMovementResourcesByMovement[moveType];
		if pxyResourceType = null then
			create pxyResourceType transient;
			hms_VesselDataHarbour.allMovementResourcesByMovement.add(pxyResourceType);  
			//coll.add(_resourceType);
		endif;
		pxyResourceType.setProxy(moveType, numTugs, harbour, coll);
	endif;
	
	
	create pxyStructuralElements transient;
	pxyVessel.setMyStructuralElements(pxyStructuralElements);
	
	
	app.myTrxCA.trxCreateVessel(pxyVessel, vessel, conflictManager, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	delete pxyVessel;
	
	
	// Add Vessel Section
	if self.opts.includesKey("VesselSection") then
	pxyStructuralElements:=vessel.myStructuralElements;
	create vslSection transient;
	vslSection.setProxy( self.opts.str("vslSectionCode"), self.opts.dec("vslSectionPostion") , self.opts.str("vslSectionDesc"));
	vslSection.setMyVesselStructure(pxyStructuralElements);
	app.myTrxCA.trxCreateVesselSection(vslSection,vslrealSection,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	endif;

	// Add Vessel Tank
	if self.opts.includesKey("VesselTank") then
	create vslTank transient;
	vslTank.setProxy( self.opts.str("VslTankCode"), self.opts.str("VslTankDesc"), self.opts.str("VslTankRemarks"), self.opts.dec("VslTankVolume") ,  self.opts.obj("vslTankContentType").CM_VesselTankContentsType );
	vslTank.setMyVesselStructure(pxyStructuralElements);
	app.myTrxCA.trxCreateVesselTank(vslTank,vslRealTank,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	endif;
	
	
	
	
	
	// Create Berth Prefrences 
	if self.opts.includesKey("HarbourPrefrencesArray") then
	
		pxyHMSVesselData := vessel.myHMSVesselData;
		if 	pxyHMSVesselData = null then
			create pxyHMSVesselData transient;
			vessel.setHMSVesselData(pxyHMSVesselData);
		endif;
				
		pxyVesselDataHarbour := pxyHMSVesselData.allVesselDataForHarbour[harbour];
		if pxyVesselDataHarbour = null then
			create pxyVesselDataHarbour transient;
			pxyHMSVesselData.allVesselDataForHarbour.add(pxyVesselDataHarbour);
		endif;
		
		beginTransaction;
		harbourBerthPrefArray := self.opts.obj("HarbourPrefrencesArray").ObjectArray;
		foreach objj in harbourBerthPrefArray do
			create realHarbourBerthPreference persistent;
			realHarbourBerthPreference.setForCreate(objj.HMS_BerthPreferenceVesselData, app.myPassport); 
			pxyVesselDataHarbour.addBerthPreference(realHarbourBerthPreference);
		endforeach;
		commitTransaction;
		self.assertNoTrxErrorsOrWarnings();	
	endif;
	

	
	
	// Create the Bays
	if not self.opts.includesKey("NoBays") then
		pxyCellularVessel := app.createUpdateProxy(vessel.myCellularVesselStructure).CM_CellularVesselStructure;
		
		pxyCellularVessel.setProxyCellularVessel(null, true, true, false, 0); // PAR 32286
		if self.opts.includesKey(UTVS_Bays) then
			holds := self.opts.int(UTVS_Bays);
			foreach idx in 1 to holds step 4 do
				if str = null then
					str := idx.padLeadingWith("0",2)&amp;' '&amp;(idx+2).padLeadingWith("0",2);
				else
					str := str &amp; CM_CellularVesselStructure.HoldSeperator &amp; idx.padLeadingWith("0",2)&amp;' '&amp;(idx+2).padLeadingWith("0",2);
				endif;
			endforeach;
			pxyCellularVessel.createProxyBaysFromString(str);
		else
			pxyCellularVessel.createProxyBaysFromString("01 03" &amp; CM_CellularVesselStructure.HoldSeperator &amp; "05 07"&amp; CM_CellularVesselStructure.HoldSeperator &amp; "09 11");
		endif;
	
		create allHolds transient;
		create baySet transient;
	
		foreach bay in pxyCellularVessel.allBaysByOrdinal do
		
			bay.setForUpdateWeights(999000,999000,999000,999000,999000);
			// OD Cells
			bay.allCellsOnDeck.purge;
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("06", 1, 1, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("04", 2, 2, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("02", 3, 3, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("01", 4, 4, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("03", 5, 5, bay, null, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("05", 6, 6, bay, null, 0);
	
			// UD Cells
			bay.allCellsUnderDeck.purge;
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("04", 1, 1, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("02", 2, 2, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("01", 3, 3, null, bay, 0);
			create pxyCellDefn transient;
			pxyCellDefn.setProxy("03", 4, 4, null, bay, 0);
	
			// OD Tiers
			bay.allTiersOnDeck.purge;
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("82", 1, 1, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("84", 2, 2, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("86", 3, 3, bay, null);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("88", 4, 4, bay, null);
	
			// UD Tiers
			bay.allTiersUnderDeck.purge;
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("02", 1, 1, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("04", 2, 2, null, bay);
			create pxyTierDefn transient;
			pxyTierDefn.setProxy("06", 3, 3, null, bay);
	
			// HATCH LID
			create hlid transient;
			allHolds.clear;
			baySet.clear;
			allHolds.add(bay.myHold);
			baySet.add(bay);
			hlid.setProxy(bay.ordinalBay, bay.ordinalBay, 1,6,1,4,false, false,allHolds, baySet);
			hlid.setMyVessel(pxyCellularVessel);
		endforeach;
	
		app.myTrxUA.trxUpdateVesselStructure(pxyCellularVessel, app.myPassport);
		assertNoTrxErrorsOrWarnings();
	endif;
	
	return vessel;
	
epilog
	delete pxyVessel;
	delete pxyCellularVessel;
	delete allHolds;
	delete baySet;
	delete pxyVoyageAllocationConfig;
	delete groupLabelCriteriaColl;
	delete resourceTypeArray;
	delete vslSection;
	delete vslTank;
	delete coll;
end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselCellularWithCode_OLD" id="8a226ef1-becf-4b5d-a6f2-4bb77567bc0a">
        <source>addVesselCellularWithCode_OLD(_code, _name : String; _operator : CM_Operator) : CM_Vessel;
/* Changes

Date		Name	TFS#		Description
============================================================================
29/08/2008	cnwdw1	
04/03/2019	jlgka1	37102		STWR CAMS STANDARD CODECO Add isBarge Flag.
============================================================================*/
vars
	vessel					: CM_Vessel;
	pxyVessel				: CM_Vessel;
	pxyCellVessel			: CM_CellularVesselStructure;
	pxyHMSVesselData		: HMS_VesselData;
	pxyCellularVessel		: CM_CellularVesselStructure;
	pxyCellDefn				: CM_CellDefn;
	pxyTierDefn				: CM_TierDefn;
	bay						: CM_BayDefn;
	conflictManager			: CMIF_HMS_ConflictsManager;
	tidalClassArrival		: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	tidalClassDept			: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	hms_VesselDataHarbour	: HMS_VesselDataHarbour;		// cnwrl1 20/05/2010 PAR 24012
	hlid : CM_HatchLidVessel;
	allHolds : CM_VesselHoldSet; 
	baySet: CM_BaySet;
	holds : Integer;
	idx : Integer;
	str : String;
begin
	
	create pxyVessel transient;
	
	pxyVessel.setProxyForVessel(null,
								_code,
								_name,
								self.opts.str(ETRow_CallSign),
								"",
								self.createdByUnitTest(null),							// 18/08/2015 cnwmh5
								"",
								self.opts.str(ETRow_LloydsNumber),
								1,
								0,
								0,
								VESSEL_TYPE_LOLO,
								2000,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								true,
								false,
								_operator,
								null,
								false);

	create pxyCellVessel transient;
	pxyVessel.setProxyVesselStructures(null, pxyCellVessel, null);

	create pxyHMSVesselData transient;
	pxyVessel.setHMSVesselData(pxyHMSVesselData);
	
	// cnwrl1 20/05/2010 PAR 24012 - start of coding
	create hms_VesselDataHarbour transient;	// NOTE: the delete is handled by the delete on the pxyVessel
	
	tidalClassArrival	:= app.myRoot.allTidalClasses[ 'A' ];
	tidalClassDept		:= app.myRoot.allTidalClasses[ 'C' ];
	
	hms_VesselDataHarbour.setProxy(	null,
									false,
									false,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									self.getTerminal().myHarbour,
									null,
									null,
									null,
									null,
									tidalClassArrival,
									tidalClassDept );
	pxyHMSVesselData.allVesselDataForHarbour.add( hms_VesselDataHarbour );
	// cnwrl1 20/05/2010 PAR 24012 - end of coding
	
	pxyHMSVesselData.setProxy(app.myRoot,
							false,
							false,
							false,
							false,
							false,
							false,
							false,
							false,
							"",
							"",
							"",
							0,
							0,
							0,
							100,
							20000,
							20000,
							19000,
							0,
							0,
							0,
							0,
							0,
							null,
							app.myRoot.allVesselTypes["C"]);
	
	app.myTrxCA.trxCreateVessel(pxyVessel, vessel, conflictManager, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	delete pxyVessel;
	
	// Create the Bays
	pxyCellularVessel := app.createUpdateProxy(vessel.myCellularVesselStructure).CM_CellularVesselStructure;
	
	pxyCellularVessel.setProxyCellularVessel(null, true, true, false, 0); // PAR 32286
	if self.opts.includesKey(UTVS_Bays) then
		holds := self.opts.int(UTVS_Bays);
		foreach idx in 1 to holds step 4 do
			if str = null then
				str := idx.padLeadingWith("0",2)&amp;' '&amp;(idx+2).padLeadingWith("0",2);
			else
				str := str &amp; CM_CellularVesselStructure.HoldSeperator &amp; idx.padLeadingWith("0",2)&amp;' '&amp;(idx+2).padLeadingWith("0",2);
			endif;
		endforeach;
		pxyCellularVessel.createProxyBaysFromString(str);
	else
		pxyCellularVessel.createProxyBaysFromString("01 03" &amp; CM_CellularVesselStructure.HoldSeperator &amp; "05 07"&amp; CM_CellularVesselStructure.HoldSeperator &amp; "09 11");
	endif;

	create allHolds transient;
	create baySet transient;

	foreach bay in pxyCellularVessel.allBaysByOrdinal do
	
		bay.setForUpdateWeights(999000,999000,999000,999000,999000);
		// OD Cells
		bay.allCellsOnDeck.purge;
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("06", 1, 1, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("04", 2, 2, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("02", 3, 3, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("01", 4, 4, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("03", 5, 5, bay, null, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("05", 6, 6, bay, null, 0);

		// UD Cells
		bay.allCellsUnderDeck.purge;
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("04", 1, 1, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("02", 2, 2, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("01", 3, 3, null, bay, 0);
		create pxyCellDefn transient;
		pxyCellDefn.setProxy("03", 4, 4, null, bay, 0);

		// OD Tiers
		bay.allTiersOnDeck.purge;
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("82", 1, 1, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("84", 2, 2, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("86", 3, 3, bay, null);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("88", 4, 4, bay, null);

		// UD Tiers
		bay.allTiersUnderDeck.purge;
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("02", 1, 1, null, bay);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("04", 2, 2, null, bay);
		create pxyTierDefn transient;
		pxyTierDefn.setProxy("06", 3, 3, null, bay);

		// HATCH LID
		create hlid transient;
		allHolds.clear;
		baySet.clear;
		allHolds.add(bay.myHold);
		baySet.add(bay);
		hlid.setProxy(bay.ordinalBay, bay.ordinalBay, 1,6,1,4,false, false,allHolds, baySet);
		hlid.setMyVessel(pxyCellularVessel);
	endforeach;

	app.myTrxUA.trxUpdateVesselStructure(pxyCellularVessel, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	return vessel;
	
epilog
	delete pxyVessel;
	delete pxyCellularVessel;
	delete allHolds;
	delete baySet;

end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselDeckLayerLayoutCargo" id="956054a5-e9d6-45c8-9540-df0d188d643c">
        <source>addVesselDeckLayerLayoutCargo(_deck : CM_DeckVessel; _locations : Boolean);
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	pxyLayerLayout, realLayerLayout: CM_DeckLayerLayout;
	newDeckItems : ObjectArray;
	obj : Object;
	itemLayout : CM_DeckItemLayout;
begin
	// ## PROXY
	create pxyLayerLayout transient;
	if _locations then
		pxyLayerLayout.setProxy("Containers", "Layer Containers", null, _deck.myDeckLayout, true,ROROLayerType_Cargo);
	else	
		pxyLayerLayout.setProxy("Lanes", "Layer Lanes", null, _deck.myDeckLayout, true,ROROLayerType_Lanes);
	endif;
	self.assertNotNullMsg(pxyLayerLayout.myDeckLayout,_deck.code &amp;  " pxyLayerLayout myDeckLayout ");
	
	// ## CREATE
	app.myTrxCA.trxCreateDeckLayerLayout(pxyLayerLayout, realLayerLayout, false, app.myPassport); 
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realLayerLayout, _deck.code &amp; " realLayerLayout ");
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realLayerLayout.myDeckLayout,_deck.code &amp;  " myDeckLayout ");
	
	app.myTrxUA.trxUpdateROROLayerToTop(realLayerLayout, app.myPassport); 
	
	self.assertNoTrxErrorsOrWarnings();
	
	create newDeckItems transient;
	pxyLayerLayout := app.createUpdateProxy(realLayerLayout).CM_DeckLayerLayout;
	
	if _locations then
		app.myTrxUA.trxUpdateROROLayerQuickDraw(pxyLayerLayout, 100, 100, 7, 5, true, DeckItemLayoutType_Locn, 1, newDeckItems, app.myPassport);
		foreach obj in newDeckItems do
			itemLayout := obj.CM_DeckItemLayout;
			itemLayout.setMyDeckLayer(null);
		endforeach;
		app.myTrxUA.trxUpdateROROLayerQuickDraw(pxyLayerLayout, 450, 100, 7, 5, false, DeckItemLayoutType_Locn, 1, newDeckItems, app.myPassport); 
	else
		app.myTrxUA.trxUpdateROROLayerQuickDraw(pxyLayerLayout, 50, 100, 5, 1, true, DeckItemLayoutType_Lane, 1, newDeckItems, app.myPassport); 
	endif;
	
	self.assertNoTrxErrorsOrWarnings();
	

epilog
	delete pxyLayerLayout;
	delete newDeckItems;

end;</source>
        <Parameter name="_deck" type="CM_DeckVessel"/>
        <Parameter name="_locations" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addVesselDecks" id="13887e7b-a7aa-4754-86ad-0dd114cc9d72">
        <source>addVesselDecks(_vesselName : String);
/*
Purpose:			
Date		Who		Reason
17 August 2011	NAVAB1	Initial creation
*/

vars

	vessel : CM_Vessel;
	vesselName : String;
	pxyDeck, parentDeck  : CM_DeckVessel;
	pxySubDeck : CM_DeckVesselSub;
	realDeck : CM_Deck;
	code : String;
	description : String;
	remarks : String;
	maxClearHeight,
	totalArea : Decimal[12,2];
	ordinal: Integer;
	totalVolume : Decimal[12,2];
	totalTEU : Integer;
	totalLM,
	maxLoadStack20,
	maxLoadStack40,
	maxLoadAxel,
	maxLoadM2   : Decimal[12,2];
	numTier : Integer;
	heightFromBL : Decimal[12,2];
	newDeckItems : ObjectArray;
	pxyLayerLayout : CM_DeckLayerLayout;
begin
	vesselName:=_vesselName ;	
	vessel	:= self.getVessel( vesselName );

	assertNotNull(vessel);
	
	create pxyDeck transient;
	
	code:=DECK1;
	description:="DECK1 Description";
	remarks:="Some decking remarks";
	maxClearHeight:=20.5;
	totalArea:=30000.67;
	totalVolume:=234.89;
	totalTEU:=10000;
	totalLM:=23423.45;
	maxLoadStack20:=50000;
	maxLoadStack40:=80000;
	maxLoadAxel:=87534.45;
	maxLoadM2:=234.56;
	numTier:=3;
	heightFromBL:=63455.67;
	ordinal:=1;
	
	pxyDeck.setProxy(	code ,
						description,
						remarks,
						maxClearHeight,
						totalArea,
						totalVolume,
						totalTEU,
						totalLM,
						maxLoadStack20,
						maxLoadStack40,
						maxLoadAxel,
						maxLoadM2 ,
						numTier ,
						heightFromBL );
	pxyDeck.setMyROROStructure(vessel.myROROVesselStructure);
	
	
	
	app.myTrxCA.trxCreateRORODeck(pxyDeck,realDeck,false,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realDeck, " Real deck = null");
	self.assertTrueMsg(realDeck.isKindOf(CM_DeckVessel),"real deck created class not CM_DeckVessel"); 
	self.assertEqualMsg(realDeck.CM_DeckVessel.myROROStructure, vessel.myROROVesselStructure, " myROROStructure ref = null");
	self.assertEqualMsg(realDeck.code, code,"code !=");
	self.assertEqualMsg(realDeck.description, description,"description !=");
	self.assertEqualMsg(realDeck.remarks, remarks,"remarks !=");
	self.assertEqualMsg(realDeck.maxClearHeight, maxClearHeight,"maxClearHeight !=");
	self.assertEqualMsg(realDeck.totalArea, totalArea,"totalArea !=");
	self.assertEqualMsg(realDeck.ordinal, ordinal,"ordinal !=");
	self.assertEqualMsg(realDeck.totalVolume, totalVolume,"totalVolume !=");
	self.assertEqualMsg(realDeck.totalTEU, totalTEU,"totalTEU !=");
	self.assertEqualMsg(realDeck.totalLM, totalLM,"totalLM !=");
	self.assertEqualMsg(realDeck.maxLoadStack20, maxLoadStack20,"maxLoadStack20 !=");
	self.assertEqualMsg(realDeck.maxLoadStack40, maxLoadStack40,"maxLoadStack40 !=");
	self.assertEqualMsg(realDeck.maxLoadAxel, maxLoadAxel,"maxLoadAxel !=");
	self.assertEqualMsg(realDeck.maxLoadM2, maxLoadM2,"maxLoadM2 !=");
	self.assertEqualMsg(realDeck.numTier, numTier,"numTier !=");
	self.assertEqualMsg(realDeck.heightFromBL, heightFromBL,"heightFromBL !=");
	self.assertNotNullMsg(realDeck.myDeckLayout, "d1 myDeckLayout ");

	delete pxyDeck;
	
	pxyDeck := app.createUpdateProxy(realDeck).CM_DeckVessel;
	
	self.addVesselDeckLayerLayoutCargo(pxyDeck.CM_DeckVessel, true); // container positions
 	
	
	delete pxyDeck;
	
	
// ############
	parentDeck := realDeck.CM_DeckVessel;
	create pxySubDeck transient;
	pxySubDeck.setMyParentDeck(parentDeck);

	code:=DECK1 &amp; "S";
	description:="DECK1 SUB Description";
	remarks:="Some SUB decking remarks";
	maxClearHeight:=20.5;
	totalArea:=30000.67;
	totalVolume:=234.89;
	totalTEU:=10000;
	totalLM:=23423.45;
	maxLoadStack20:=50000;
	maxLoadStack40:=80000;
	maxLoadAxel:=87534.45;
	maxLoadM2:=234.56;
	numTier:=3;
	heightFromBL:=63455.67;
	ordinal:=1;
	
	pxySubDeck.setProxy(	code ,
						description,
						remarks,
						maxClearHeight,
						totalArea,
						totalVolume,
						totalTEU,
						totalLM,
						maxLoadStack20,
						maxLoadStack40,
						maxLoadAxel,
						maxLoadM2 ,
						numTier ,
						heightFromBL );
	pxySubDeck.setMyROROStructure(vessel.myROROVesselStructure);
	
	
	
	app.myTrxCA.trxCreateRORODeck(pxySubDeck,realDeck,false,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realDeck, " Real deck = null");
	self.assertTrueMsg(realDeck.isKindOf(CM_DeckVessel),"real deck created class not CM_DeckVessel"); 
	self.assertEqualMsg(realDeck.CM_DeckVessel.myROROStructure, null, " myROROStructure ref should be null"); // SUB DECKS DO NOT HAVE THIS REF
	self.assertEqualMsg(realDeck.CM_DeckVesselSub.myParentDeck, parentDeck, " myParentDeck ref = null");
	self.assertEqualMsg(realDeck.code, code,"code !=");
	self.assertEqualMsg(realDeck.description, description,"description !=");
	self.assertEqualMsg(realDeck.remarks, remarks,"remarks !=");
	self.assertEqualMsg(realDeck.maxClearHeight, maxClearHeight,"maxClearHeight !=");
	self.assertEqualMsg(realDeck.totalArea, totalArea,"totalArea !=");
	self.assertEqualMsg(realDeck.ordinal, ordinal,"ordinal !=");
	self.assertEqualMsg(realDeck.totalVolume, totalVolume,"totalVolume !=");
	self.assertEqualMsg(realDeck.totalTEU, totalTEU,"totalTEU !=");
	self.assertEqualMsg(realDeck.totalLM, totalLM,"totalLM !=");
	self.assertEqualMsg(realDeck.maxLoadStack20, maxLoadStack20,"maxLoadStack20 !=");
	self.assertEqualMsg(realDeck.maxLoadStack40, maxLoadStack40,"maxLoadStack40 !=");
	self.assertEqualMsg(realDeck.maxLoadAxel, maxLoadAxel,"maxLoadAxel !=");
	self.assertEqualMsg(realDeck.maxLoadM2, maxLoadM2,"maxLoadM2 !=");
	self.assertEqualMsg(realDeck.numTier, numTier,"numTier !=");
	self.assertEqualMsg(realDeck.heightFromBL, heightFromBL,"heightFromBL !=");
	self.assertNotNullMsg(realDeck.myDeckLayout, "d1 myDeckLayout ");
	
	delete pxySubDeck;
// ############	
	
	
	// AKB added this - 17/6/11
	pxyDeck := app.createUpdateProxy(realDeck).CM_DeckVessel;
	
	self.addVesselDeckLayerLayoutCargo(pxyDeck.CM_DeckVessel, true); // container positions
 	
	
	delete pxyDeck;
	
	create pxyDeck transient;
	code:=DECK2;
	description:="DECK2 Description";
	remarks:="Some deck 2 remarks";
	ordinal:=2;
	pxyDeck.setProxy(	code ,
						description,
						remarks,
						maxClearHeight,
						totalArea,
						totalVolume,
						totalTEU,
						totalLM,
						maxLoadStack20,
						maxLoadStack40,
						maxLoadAxel,
						maxLoadM2 ,
						numTier ,
						heightFromBL );
	pxyDeck.setMyROROStructure(vessel.myROROVesselStructure);
	
	app.myTrxCA.trxCreateRORODeck(pxyDeck,realDeck,false,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNullMsg(realDeck, " Real deck2 = null");
	self.assertEqualMsg(realDeck.CM_DeckVessel.myROROStructure, vessel.myROROVesselStructure, "d2 myROROStructure ref = null");
	self.assertEqualMsg(realDeck.code, code,"d2 code !=");
	self.assertEqualMsg(realDeck.description, description,"d2 description !=");
	self.assertEqualMsg(realDeck.remarks, remarks,"d2 remarks !=");
	self.assertEqualMsg(realDeck.maxClearHeight, maxClearHeight,"d2 maxClearHeight !=");
	self.assertEqualMsg(realDeck.totalArea, totalArea,"d2 totalArea !=");
	self.assertEqualMsg(realDeck.ordinal, ordinal,"d2 ordinal !=");
	self.assertEqualMsg(realDeck.totalVolume, totalVolume,"d2 totalVolume !=");
	self.assertEqualMsg(realDeck.totalTEU, totalTEU,"d2 totalTEU !=");
	self.assertEqualMsg(realDeck.maxLoadStack20, maxLoadStack20,"d2 maxLoadStack20 !=");
	self.assertEqualMsg(realDeck.maxLoadStack40, maxLoadStack40,"d2 maxLoadStack40 !=");
	self.assertEqualMsg(realDeck.maxLoadAxel, maxLoadAxel,"d2 maxLoadAxel !=");
	self.assertEqualMsg(realDeck.maxLoadM2, maxLoadM2,"d2 maxLoadM2 !=");
	self.assertEqualMsg(realDeck.numTier, numTier,"d2 numTier !=");
	self.assertEqualMsg(realDeck.heightFromBL, heightFromBL,"d2 heightFromBL !=");
	self.assertNotNullMsg(realDeck.myDeckLayout, "d2 myDeckLayout ");
	
	delete pxyDeck;
	// AKB added this - 17/6/11
	pxyDeck := app.createUpdateProxy(realDeck).CM_DeckVessel;
	self.assertNotNullMsg(pxyDeck.myDeckLayout, "d2 proxy myDeckLayout ");
	
	self.addVesselDeckLayerLayoutCargo(pxyDeck.CM_DeckVessel, false); // container positions
 	
epilog
	delete pxyDeck;
	delete pxySubDeck;
	delete newDeckItems;
end;</source>
        <Parameter name="_vesselName" type="String"/>
    </JadeMethod>
    <JadeMethod name="addVesselDefnReefer40" id="4e814f56-6721-4538-99ee-b44b236b9057">
        <updating/>
        <source>addVesselDefnReefer40(_vessel : CM_Vessel) updating;
// ---------------------------------------------------------------------------
// Created:     31 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theStructure : CM_CellularVesselStructure;
	theBay : CM_Bay;
	theSlot : CM_SlotDefn;
	tmp : String;
begin
	tmp := CM_SlotRequest.Attribute_Forty;
	
	theStructure := _vessel.myCellularVesselStructure;
	
	foreach theBay in theStructure.allBaysByOrdinal discreteLock do
		beginTransaction;
		foreach theSlot in theBay.allSlotsByOrdinal discreteLock do
		
			theSlot.setPropertyValue("reefer",true);
			theSlot.setPropertyValue("power",true);
			
			// ### BACKEND
			if theBay.isAftBay then
				theSlot.setPropertyValue("fortyFront",false);
				theSlot.setPropertyValue("fortyBack",true);
				if theSlot.ordinalTier = 4 or theSlot.ordinalTier = 1 then
					theSlot.setPropertyValue("is30",true);
					theSlot.setPropertyValue("isBackend",true);
				endif;
				if theSlot.ordinalTier = 3 then
					theSlot.setPropertyValue("is45",true);
					theSlot.setPropertyValue("isBackend",true);
				endif;
				if theSlot.ordinalTier = 2 then
					theSlot.setPropertyValue("is53",true);
					theSlot.setPropertyValue("isBackend",true);
				endif;
			// ### FORWARD
			else
				theSlot.setPropertyValue("fortyFront",true);
				theSlot.setPropertyValue("fortyBack",false);
 				if theSlot.ordinalTier = 4 or theSlot.ordinalTier = 1 then
					theSlot.setPropertyValue("is30",true);
					theSlot.setPropertyValue("isBackend",false);
				endif;
				if theSlot.ordinalTier = 3 then
					theSlot.setPropertyValue("is45",true);
					theSlot.setPropertyValue("isBackend",false);
				endif;
				if theSlot.ordinalTier = 2 then
					theSlot.setPropertyValue("is53",true);
					theSlot.setPropertyValue("isBackend",false);
				endif;
			endif;
		endforeach;
		commitTransaction;
	
	endforeach;
	
	assertNoTrxErrorsOrWarnings();

epilog
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselGeneralCargo" id="cece274f-94c3-4b5b-ac46-71676617be91">
        <source>addVesselGeneralCargo( _name : String; _operator : CM_Operator; _numberOfHatches : Integer) : CM_Vessel;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		29 October 2009
//
// Implemented version: JMT 7.7.3
/* Changes

Date		Name	TFS#		Description
============================================================================
29/07/2011	cnwmh5				Change to use UT_UnitTest.opts
04/03/2019	jlgka1	37102		STWR CAMS STANDARD CODECO Add isBarge Flag.
============================================================================*/
vars
	pxyVessel,
	vessel					: CM_Vessel;
	pxyGCVesselStructure 	: CM_GeneralCargoVesselStructure;
	conflictManager			: CMIF_HMS_ConflictsManager;
	pxyHMSVesselData		: HMS_VesselData;				// cnwrl1 21/05/2010 PAR 24012
	tidalClassArrival		: HMS_TidalClass;				// cnwrl1 21/05/2010 PAR 24012
	tidalClassDept			: HMS_TidalClass;				// cnwrl1 21/05/2010 PAR 24012
	hms_VesselDataHarbour	: HMS_VesselDataHarbour;		// cnwrl1 21/05/2010 PAR 24012
	yearOfBuild					: Integer;
begin

	yearOfBuild := 2000;
	if self.opts.includesKey("YearOfBuild") then
		yearOfBuild := self.opts.int("YearOfBuild");
	endif;
	
	create pxyVessel transient;
	
	pxyVessel.setProxyForVessel(null,
								_name,
								_name,
								self.opts.str(ETRow_CallSign),
								"",
								"",	
								"",
								self.opts.str(ETRow_LloydsNumber),
								1,
								0,
								0,
								VESSEL_TYPE_LOLO,
								yearOfBuild,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								true,
								false,
								_operator,
								self.opts.obj("VesselTrade").CM_Trade,
								self.opts.bool("isBarge")
								);
								
	
	// cnwrl1 21/05/2010 PAR 24012 - start of coding
	create pxyHMSVesselData transient;
	pxyVessel.setHMSVesselData(pxyHMSVesselData);
	
	create hms_VesselDataHarbour transient;	// NOTE: the delete is handled by the delete on the pxyVessel
	
	tidalClassArrival	:= app.myRoot.allTidalClasses[ 'E' ];
	tidalClassDept		:= app.myRoot.allTidalClasses[ 'C' ];
	
	hms_VesselDataHarbour.setProxy(	null,
									false,
									false,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									self.getTerminal().myHarbour,
									null,
									self.opts.obj("ShippingAgent").CM_ShippingAgent,
									null,
									null,
									tidalClassArrival,
									tidalClassDept );
	pxyHMSVesselData.allVesselDataForHarbour.add( hms_VesselDataHarbour );
	
	pxyHMSVesselData.setProxy(	app.myRoot,
								false,
								false,
								false,
								false,
								false,
								false,
								false,
								false,
								"",
								"",
								"",
								0,
								0,
								0,
								100,
								20000,
								20000,
								19000,
								0,
								0,
								0,
								0,
								0,
								self.opts.obj("ShippingLine").CM_ShippingLine,
								app.myRoot.allVesselTypes["G"] );
	// cnwrl1 21/05/2010 PAR 24012 - end of coding
	
	create pxyGCVesselStructure transient;
	pxyGCVesselStructure.setProxyGCVessel(self.getRoot(), _numberOfHatches);
	
	pxyVessel.setProxyVesselStructures(pxyGCVesselStructure, null, null);
	app.myTrxCA.trxCreateVessel(pxyVessel, vessel, conflictManager, app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	
	return vessel;
	
epilog
	delete pxyVessel;
	
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_numberOfHatches" type="Integer"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselHolds" id="50ed2c27-b949-48b2-ba1c-7d5d8276e254">
        <source>addVesselHolds(_vesselName : String);
/*
Purpose:			
Date		Who		Reason
05/02/2014	NAVAB1	Initial creation
27/08/2015	cnwdap1	PAR #36766 CCMS SFW 1334 Bulk Graphical Representation - new parameters
*/

vars	

	vessel : CM_Vessel;
	vesselName : String;
	gcHoldLocnDefn : CM_GCHoldLocationDefn;
	gcVesselStructure : CM_GeneralCargoVesselStructure;
	i, j, holds, decks: Integer;
	loadState : Boolean;
begin
	vesselName:=_vesselName ;	
	vessel	:= self.getVessel( vesselName );

	assertNotNull(vessel);
	
	gcVesselStructure := vessel.myGeneralCargoVesselStructure;
	if gcVesselStructure = null then
		self.addGCStructureDefn(vessel);
		gcVesselStructure := vessel.myGeneralCargoVesselStructure;
	endif;
	
	holds := 4;
	decks := 3;
	
	foreach i in 1 to holds do
		foreach j in 1 to decks do
			self.addGCHoldDefn(gcVesselStructure,	
						i,	//_holdNum: Integer;
						j,	//_placeNum: Integer;
						false,	//_isOnDck : Boolean;			// PAR #36766
						null, 	// _maxWeight : Integer;		// PAR #36766
						null,	// _maxVolume: Decimal;			// TFS 1601
						0,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
						1,		// _onShipCrane: Integer;		// TFS 1601
						"Hold" &amp; i.String &amp; " Deck" &amp; j.String
						);
		endforeach;
	endforeach;
	


epilog

end;</source>
        <Parameter name="_vesselName" type="String"/>
    </JadeMethod>
    <JadeMethod name="addVesselLOLOholdsRORO" id="0d87e050-3a77-41cc-b807-13b30cf52d45">
        <source>addVesselLOLOholdsRORO( _name : String; _operator : CM_Operator) : CM_Vessel;

/* Changes

Date		Name	TFS#		Description
============================================================================
26/03/2010 	cnwrs1	
29/07/2011	cnwmh5				Change to use UT_UnitTest.opts
17/08/2011	NAVAB1 				add in decks
04/03/2019	jlgka1	37102		STWR CAMS STANDARD CODECO Add isBarge Flag.
============================================================================*/
vars
	vessel					: CM_Vessel;
	pxyVessel				: CM_Vessel;
	pxyCellVessel			: CM_CellularVesselStructure;
	pxyHMSVesselData		: HMS_VesselData;
	pxyCellularVessel		: CM_CellularVesselStructure;
	pxyCellDefn				: CM_CellDefn;
	pxyTierDefn				: CM_TierDefn;
	bay						: CM_BayDefn;
	conflictManager			: CMIF_HMS_ConflictsManager;
	tidalClassArrival		: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	tidalClassDept			: HMS_TidalClass;				// cnwrl1 20/05/2010 PAR 24012
	hms_VesselDataHarbour	: HMS_VesselDataHarbour;		// cnwrl1 20/05/2010 PAR 24012
	pxyROROVessel 			: CM_ROROVesselStructure;
	pxyStructElements		: CM_VesselStructuralElements;
	bays, b, b1, b2 : Integer;
	baysString: String;
	big: Boolean;
begin
	create pxyVessel transient;
	big := self.opts.bool("Big");
	
	pxyVessel.setProxyForVessel(null,
								_name,
								_name,
								self.opts.str( ETRow_CallSign ),
								"",
								"",	
								"",
								self.opts.str( ETRow_LloydsNumber ),
								1,
								0,
								0,
								VESSEL_TYPE_LOLO,
								2000,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								true,
								false,
								_operator,
								null,
								false);
	
	create pxyCellVessel transient;
	pxyCellVessel.setType(CellularStructureRORO);
	pxyCellVessel.setPropertyValue("isImported",true); // AKB do not set default cell weights and heights
	pxyVessel.setProxyVesselStructures(null, pxyCellVessel, null);

	create pxyROROVessel transient;
	pxyVessel.setMyROROVesselStructure(pxyROROVessel);
	
	create pxyStructElements transient;
	pxyVessel.setMyStructuralElements(pxyStructElements);
	
	create pxyHMSVesselData transient;
	pxyVessel.setHMSVesselData(pxyHMSVesselData);
	pxyHMSVesselData.setProxy(app.myRoot,
							false,
							false,
							false,
							false,
							false,
							false,
							false,
							false,
							"",
							"",
							"",
							0,
							0,
							0,
							100,
							20000,
							20000,
							19000,
							0,
							0,
							0,
							0,
							0,
							null,
							app.myRoot.allVesselTypes["CONRO"]);
	
	// cnwrl1 20/05/2010 PAR 24012 - start of coding
	create hms_VesselDataHarbour transient;	// NOTE: the delete is handled by the delete on the pxyVessel
	
	tidalClassArrival	:= app.myRoot.allTidalClasses[ 'B' ];
	tidalClassDept		:= app.myRoot.allTidalClasses[ 'E' ];
	
	hms_VesselDataHarbour.setProxy(	null,
									false,
									false,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									self.getTerminal().myHarbour,
									null,
									null,
									null,
									null,
									tidalClassArrival,
									tidalClassDept );
	pxyHMSVesselData.allVesselDataForHarbour.add( hms_VesselDataHarbour );
	// cnwrl1 20/05/2010 PAR 24012 - end of coding
	
	app.myTrxCA.trxCreateVessel(pxyVessel, vessel, conflictManager, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	delete pxyVessel;

	// Create Decks
	self.addVesselDecks(_name);
	// Create the Bays
	self.addVesselBays(_name);
	// Create Holds
	self.addVesselHolds(_name);
	

	assertNoTrxErrorsOrWarnings();
	
	return vessel;
	
epilog
	delete pxyVessel;
	delete pxyCellularVessel;
	
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselRamp" id="9b465af0-1b04-44db-bda8-bd1d33a6fe68">
        <source>addVesselRamp(_vesselStructure :  CM_VesselStructuralElements; _code : String) : CM_RORORampExternalVessel;
// ---------------------------------------------------------------------------
// Created:     27 January 2014 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
	pxyRamp, realRamp : CM_RORORampExternalVessel;
	realDeckItem : CM_DeckItem;
	
	description,
	remarks  :String;
	isMovable : Boolean;
	length,
	maxClearHeight,
	maxLoadAxel ,
	maxLoadM2,
	maxLoadTotal ,
	width : Decimal[12,2];

begin
	create pxyRamp transient;
	description :="External Ramp description";
	remarks:="Some External Ramp remarks blah blah blah";
	pxyRamp.setProxyDeckItem(_code,description,remarks,null,null);
	
	isMovable :=false;
	length :=23123;
	maxClearHeight:=2341;
	maxLoadAxel:=456.34;
	maxLoadM2:=234.11;
	maxLoadTotal:=2134.66;
	width:=1234.12;
	
	pxyRamp.setProxyRamp(isMovable,length,maxClearHeight,maxLoadAxel,maxLoadM2,maxLoadTotal,width);
	
	pxyRamp.setMyRampPosition(null);
	pxyRamp.setMyROROStructure(_vesselStructure);
	
	app.myTrxCA.trxCreateRORODeckItem(pxyRamp,realDeckItem,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realDeckItem,"realRamp is null");
	self.assertTrueMsg(realDeckItem.isKindOf(CM_RORORampExternalVessel), "realRamp is kindOf CM_RORORampExternalVessel");
	realRamp:=realDeckItem.CM_RORORampExternalVessel;
	
	return realRamp;
epilog
	delete pxyRamp;
end;</source>
        <Parameter name="_vesselStructure" type="CM_VesselStructuralElements"/>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_RORORampExternalVessel"/>
    </JadeMethod>
    <JadeMethod name="addVesselSection" id="24fc7a05-1ac3-44a9-9f5f-4c3f1ef0a0e3">
        <source>addVesselSection(_vesselStructure :  CM_VesselStructuralElements; _code : String; _pos : Real) : CM_VesselSection;
// ---------------------------------------------------------------------------
// Created:     27 January 2014 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
	pxySection, realSection : CM_VesselSection;
	
	description,
	remarks  :String;

begin
	create pxySection as CM_VesselSectionVessel transient ;
	

	description :="Section description";
	remarks:="Some Section remarks blah blah blah";
	
	pxySection.setProxy(_code,_pos,remarks);

	pxySection.CM_VesselSectionVessel.setMyVesselStructElements(_vesselStructure);
	
	app.myTrxCA.trxCreateVesselSection(pxySection,realSection,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realSection,"realSection is null");
	self.assertTrueMsg(realSection.isKindOf(CM_VesselSectionVessel), "realSection is kindOf CM_VesselSectionVessel");
	

	

	
	return realSection;
epilog
	delete pxySection;
end;</source>
