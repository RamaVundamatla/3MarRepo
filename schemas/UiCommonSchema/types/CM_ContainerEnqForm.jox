    <JadeMethod name="doShowRepairDetailsForm" id="ad3f282c-bb97-4e10-96eb-626c4c7cb86e">
        <source>doShowRepairDetailsForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
11/07/2023	navcs2	Bug 59045: FR | 54536 EUP - Repair Data Processing Timing - Old Weights for Repair Messages
02/08/2023	navcs2	ChangeRequest 59569: EUP - Damage | Cargo Saving and Discrepancy order
*/

vars
	realTi	: CM_TrackedItem;
	form 	: CMUI_RepairDetailsForm;
	mode 	: Integer;
begin
	app.mousePointer := Idle;
	
	realTi := self.myCurrentObject.CM_TrackedItem;

	if form = null then
		form := app.loadForm (CMUI_RepairDetailsForm, CMUI_Assistant, false, false, self.mode = Mode_View , self.myTerminal, null).CMUI_RepairDetailsForm; 
	endif;
	
	if form = null then
		return;
	endif;
	
	// 01/08/2023 navcs2 ChangeRequest 59569
	if self.mode = Mode_View then
		mode := Mode_Update;
	elseif self.mode = Mode_Update then
		mode := Mode_View;
	endif;
	
	form.mode := mode;
	
	form.setMyTrackedItem(realTi);			// 11/07/2023	navcs2	Bug 59045

	form.setParentForm(self);

	form.showModal();
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doTableCellInputReady" id="5cd9d1f7-e483-4400-9da8-6e2d4154bda7">
        <updating/>
        <source>doTableCellInputReady(table : CM_EntryTable; inputControl: Control input; _left, _top, _width, _height: Real io) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 09 December 2003
//
//********************************************************************
// 15/06/2010			cnwcs5	par 24342 - no longer using CMUI_StopsListTable
// 13/02/2013			cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements - handle measurement controls and 
//						changed order of table and inputControl in signature and added rest of standard 
//						cellInputReady parameters - done so we can handle measurement table cell input ready
// 						stuff centrally on CM_BaseForm
// 17/05/2013			cnwdap1 PAR #31574 Allowable time off power editing
// 13/08/2013			cnwdap1	PAR #32123 Added Colour Picker
// 23/06/2015			cnwdap1	PAR #36421 Hazardous Materials Handling
// 15/11/2016			cnwdap1	TFS 2842 STWR Hazardous Details Enhancements
// 18/07/2017			cnwdap1	TFS 4492 SNO VERMAS Changes
// 31/08/17		jlgns1		6735 POL - [Fwd: ##5431## : 8.5.1.090 Not saving VGM authorised details]
//30/12/19 		jlger1 TFS 47132 - removed lstHazList
vars
	tbl			: CM_EntryTable;	
begin
	tbl := table;
	
	if inputControl = self.tblDamage and not self.doingMultiEdit then
		tbl.accessRow(table.row).height := 120;
	endif;
	
	if inputControl = self.lstTblSpecialLif then
		self.myAssistant.listTableCellInputReady(tbl, _height, self.saveRowHeight);
		tbl.adjustHeight(1000);
	endif;
	
	
	if inputControl = self.lstColour then															// PAR #32123
		self.myAssistant.listTableCellInputReady(tbl.CM_EntryTable, _height, self.saveRowHeight);	// PAR #32123
		tbl.adjustHeight(1000);																		// PAR #32123
	endif;																							// PAR #32123
	
	if inputControl = self.tblCustEntry then
		self.tblCustEntry.rows := 10;  //par #17007 cnwrd1 18.6.2008 - limit table to 10 rows incase its been expanded past 10 previously.
		self.tblCustEntry.selectMode := self.tblCustEntry.SelectMode_CurrentRow;  //par #17007 cnwrd1 18.6.2008 - set to single row select.
		// PAR 16824 - allow Cust Entry No. to be updated in bulk edit
		//if not self.doingMultiEdit then
			self.setCustEntryTable(tbl.CM_EntryTable.getValueByName(ETRow_CustomsEntryNumber).String);
			tbl.accessRow(table.row).height := 120;
			tbl.accessRow(table.row).maxLength := 30;
		//endif;
		
	endif;	
	//added by cnwyl1 100506
	
	// PAR #31155 measurement tables
	if CMUI_MeasurementTable.hasInstance(inputControl) and not inputControl = self.tblMeasurement then	// PAR #31155
		app.doMeasureTableCellInputReady(tbl, inputControl);											// PAR #31155
	endif;																								// PAR #31155
	
	if inputControl = self.txtTimeOffPower then																// PAR #31574
		self.txtTimeOffPower.text := tbl.CM_EntryTable.getValueByName(ETRow_AllowableTimeOffPower).String;	// PAR #31574
	endif;																									// PAR #31574
	
	//TFS 6735 jlgns1 31/08/2017 
	//	if inputControl = self.cmbCertName then																									// TFS 4492
	//		self.cmbCertName.listIndex := self.cmbCertName.findString(1, tbl.CM_EntryTable.getValueByName(ETRow_WeightCertifiedBy).String);		// TFS 4492
	//	endif;																																	// TFS 4492
	

end;</source>
        <Parameter name="table" type="CM_EntryTable"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="_left" type="Real" usage="io"/>
        <Parameter name="_top" type="Real" usage="io"/>
        <Parameter name="_width" type="Real" usage="io"/>
        <Parameter name="_height" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDragDropEvent" id="1a1c09c3-9cbc-4ffe-bc0d-5ffeb8a379dd">
        <updating/>
        <source>doTblDataDragDropEvent(table: Table input; win: Window input; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 24 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	toLocation : CM_LocationsController;
begin

	if win &lt;&gt; null then
		if win.userObject &lt;&gt; null then
			if win.userObject.class.name = "SHP_LoadList" then
				app.raiseCMException1(INVALID_MOVE_REQUEST, 'Cannot drag drop from Load List form.', null, null);
				return;
			endif;
		endif;
	endif;

	if self.filterYardLocation &lt;&gt; null and self.filterYardLocation.isKindOf(CM_BoxcarWagonController) then	//22 Mar 2013	NDL	Par 31278
		toLocation := self.filterYardLocation;
	elseif self.filterTerminalArea &lt;&gt; null then
		// If it's a blockstack or depot then a single controller will be returned.
		toLocation := self.filterTerminalArea.getLocationsController();
		if toLocation = null then
			// may be a grid area then
			toLocation := self.filterYardLocation;
		endif;
	endif;
	
	if self.myCurrentObject &lt;&gt; null and self.myCurrentObject.isKindOf(CM_TILC) then
		toLocation:=self.myCurrentObject.CM_TILC.getNextFreeLC();
	endif;
		
	
	if toLocation &lt;&gt; null then
		//+cnwml2 MSL CCMS 1111 PAR23758
		if toLocation.isKindOf(CM_GridController) and toLocation.CM_GridController.getMyGridArea.isKindOf(CM_InterchangeArea) and toLocation.CM_GridController.getMyGridArea.numberOfRows &gt; 1 then
			app.raiseCMException1(INVALID_MOVE_REQUEST, app.getErrorString(Null_Target_Drop_Location), null, null);
		else
			self.moveTrackedItemTarget(toLocation);
		endif;	//cnwth2 - changed to be a bit more helpful
	elseif self.cmbFiltTermArea.listObject &lt;&gt; null then
		app.raiseCMException1(INVALID_MOVE_REQUEST, app.getErrorString(Null_Target_Drop_Location), null, null);
	
	endif;	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDragTrackedItem" id="17d51f26-9291-46d0-8d03-3b4f02a67482">
        <updating/>
        <source>doTblDataDragTrackedItem()updating;
//--------------------------------------------------------------
//Created: 24 February 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 17/01/2018	jlgdap1		TFS 36658 STWR Cargo Scanning Enhancements
vars
	theTI,
	ti		: CM_TrackedItem;
	pic		: Picture;
	theBOL	: CM_BOL;
//	notifiedCG : CM_NotifiedCargoGroup;				// TFS 36658
begin

	if self.myCurrentObject &lt;&gt; null and
	   self.myCurrentObject.isKindOf(CM_BOL) then
	   theTI := self.myCurrentObject.CM_BOL.allTrackedItems.first();
	   theBOL := self.myCurrentObject.CM_BOL;
	elseif (not self.allowUpdate) then
		app.raiseCMException1(NoPermission, 'drag from here.', null, null);
		return;
	endif;
	
	if self.myCurrentObject &lt;&gt; null and
	   self.myCurrentObject.isKindOf(CM_TrackedItem) then
	   theTI := self.myCurrentObject.CM_TrackedItem;
	endif;
	
	if theTI = null then
		return;
	endif;
	
	// TFS 36658 if the current cargo item is a cargo group, the only valid drag/drop
	// is if we're in Planning Mode and the cargo group has a matching Notified Cargo Group
	if theTI.isCargoGroupItem then
		if self.getMoveMode &lt;&gt; PLANNING_MODE then
			return;
		endif;
	// 01 Oct 2018	NDL	TFS 39186
	//	notifiedCG := self.myTerminal.getNotifiedGroupForCargoGroup(theTI.CM_CargoGroup);
	//	if notifiedCG = null then
	//		return;
	//	endif;
	endif;
	// TFS 36658 end
		
	app.myDraggedTrackedItem := theTI;
	self.moveTrackedItem(theTI, self.tblData);
	if theBOL &lt;&gt; null then
		foreach ti in theBOL.allTrackedItems do
			app.myMoveController.allOtherTrackedItems.addNoDuplicates(ti, false);
		endforeach;
	endif;
	self.tblData.dragMode := DragMode_Drag;

	create pic transient;
	self.setPictureDragCursor(pic);
	if pic.picture &lt;&gt; null then
		self.tblData.dragCursor := pic.picture;
		app.isDragging := true;	//11 Feb 2015	NDL	Par 34146
	endif;

epilog
	if pic &lt;&gt; null then
		delete pic;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTblEditDblClick" id="3db513ba-efa3-4a2c-935c-90bf24877113">
        <updating/>
        <source>doTblEditDblClick() protected, updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2003		cnwth2	
//
// Purpose:     For editing transactions, we keep a transient collection of transaction controllers belonging to the TI
//				we are editing, on the form for the duration of the edit. The txn controllers are maintained from the 
//				TITransaction form - run with a different flag to handle these transients only.
//				
/* Changes

Date		Name	TFS#		Description
============================================================================
09/06/2010	cnwcs5	ar 24342 	stops maintenance
23/06/2015	cnwdap1	PR #36421	Hazardous Materials Handling
08/08/2016	cnwma1	TFS #2467 	PAR #38101 PEN - Mass Edit Free Storage Time
14/11/2016	cnwdap1	TFS 2842 	STWR Hazardous Details Enhancements
28/05/2019	jlgka1	TFS 43346	LNX - Multiple Hazardous Details with same Hazardous Class.
01/06/2022	navak20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
19/12/2022	jlika1	TFS 55584 HS Code Combobox Usage
12/12/2023	jlizm1	TFS 61665 	Display RTL Reason
04/07/2024	jlizm1	TFS 64736 	HS Code edi allow invalid codes
============================================================================*/
vars
	tbl				: CM_EntryTable;
	entRowName		: String;	
	row				: Integer;
	reason			: String;
	carrier 		: CM_Carrier;
	vvr 			: CM_VehicleVisitRecord;
	proxyTI			: CM_TrackedItem;							// PAR #36421
	deleteProxy		: Boolean;									// PAR #36421
	handlingType	: CM_HandlingType;
	trailer	 		: CM_TILC;
	hsCode			: CM_HarmonizedSystem;
begin
	tbl := self.getEditTableForSheet(self.fldEdit.topSheet.CMUI_Sheet);
	entRowName := tbl.getAttrName(tbl.row);
	
	if entRowName = ETRow_ToDoTasks then
		self.showToDoTasksForm();
	elseif (entRowName = ETRow_MyParent) or (entRowName = ETRow_Parent) then
		self.showParentTI(tbl, entRowName);
	elseif (entRowName = ETRow_Generator) then // PAR 17703
		self.showGenerators(tbl, entRowName); // PAR 17703
	elseif (entRowName = ETRow_Children) then
		self.showChildTIs(tbl, entRowName);
	elseif (entRowName = ETRow_IsAvailable) then
		reason := self.myCurrentObject.CM_TrackedItem.isAvailableErrorReason;
		if reason &lt;&gt; null then
			app.msgBox(reason, "Not Available Reason", MB_OK);
		endif;
	elseif (entRowName = ETRow_Location) then
		self.showLocationForCurrentObject();
	elseif (entRowName = ETRow_BillOfLading) or 
	   (entRowName = ETRow_Bol) or
	   (entRowName = ETRow_Number) then
		self.showParentBOL(tbl, entRowName);
	elseif (entRowName = ETRow_CargoOnboard) then
		self.showOnboardCargo(tbl,REAL_MODE);	
	elseif (entRowName = ETRow_CargoQueuedOnboard) then
		self.showOnboardCargo(tbl,QUEUE_MODE);
	elseif (entRowName = ETRow_CargoPlannedOnboard) then
		self.showOnboardCargo(tbl,PLANNING_MODE);
	elseif (entRowName = ETRow_DamageDetail) then
	//27/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
		self.doShowDamageInstancesForm();
	
	// 26.07.2022 navak20 TFS 53862
	elseif entRowName = ETRow_RepairDetail then			
		if self.myCurrentObject.CM_TrackedItem.canGetRepairedDetails() then
			self.doShowRepairDetailsForm();			
		endif;
	// 26.07.2022 navak20 TFS 53862
	
	elseif entRowName = ETRow_AllStops then		// 09/06/0210 cnwcs5 par24342
		// will only happen for tracked items, not BOLs
		self.showStopsForm_TI;					// 09/06/0210 cnwcs5 par24342
	// ### TFS 55215 18Nov2022 NAVPW1
	elseif entRowName = ETRow_AllCustomsReferences then
		self.showCustomsReferencesForm_TI;
	// ### TFS 55215 18Nov2022 NAVPW1
	elseif entRowName = ETRow_AdditionalStorageDays then
		if not self.doingMultiEdit then       // 09/08/2016 cnwma1 TFS #2467 PAR #38101
			self.showAdditionalStorageDays;
		endif;
	elseif entRowName = ETRow_LastReeferReading then
		self.showLastReeferReading(); // 8/11/12 cnwer1 PAR 30531 
	elseif entRowName = ETRow_VsBookingSlot then	//29 Apr 2013	NDL	Par 31393
		if not self.myTerminal.isVehicleBookingEnabled then
			return;
		endif;
		if self.myProxyObject &lt;&gt; null and self.myProxyObject.isKindOf(CM_TrackedItem) then
			carrier := self.cmbCarrier.listObject.CM_Carrier;
			self.myAssistant.showVehicleBookingAssociation( self, null, self.myProxyObject.CM_TrackedItem, carrier ); 
			tbl.setValueByName(ETRow_VsBookingSlot, self.myProxyObject.getDisplayStringForAttribute(ETRow_VsBookingSlot,false));
		endif;
	elseif entRowName = ETRow_ReadyToLoad then	// TFS 61665
		if not self.myCurrentObject.CM_TrackedItem.evaluateReadyToLoadReason(reason) then
			app.msgBox(reason, app.getErrorString(Not_RTL_reason), MB_OKONLY);
		endif;
	elseif entRowName = ETRow_ReceiveVisit and self.myCurrentObject.isKindOf(CM_TrackedItem) then			
		//epr CCMS 1409 par 35553 22/1/15
		vvr := self.myCurrentObject.CM_TrackedItem.getVehicleVisitReceival;
		if vvr &lt;&gt; null then
			self.myAssistant.showVehicleVisitForm(vvr,self.myMasterMenuAction);
		endif;
	elseif entRowName = ETRow_ReleaseVisit and self.myCurrentObject.isKindOf(CM_TrackedItem) then			
		//epr CCMS 1409 par 35553 22/1/15
		vvr := self.myCurrentObject.CM_TrackedItem.getVehicleVisitRelease;
		if vvr &lt;&gt; null then
			self.myAssistant.showVehicleVisitForm(vvr,self.myMasterMenuAction);
		endif;
	elseif (entRowName = ETRow_AssignedCargo) then	//03 Jun 2015	NDL	Par 36338
		self.showAssignedcargo(tbl, entRowName);	

	elseif entRowName = ETRow_AllTIHazardsNew then													// PAR #36421																								
		if self.myProxyObject &lt;&gt; null and self.myProxyObject.isKindOf(CM_TrackedItem) then			// PAR #36421
			proxyTI := self.myProxyObject.CM_TrackedItem;											// PAR #36421
		elseif self.myProxyObject = null and self.myCurrentObject.isKindOf(CM_TrackedItem) then		// PAR #36421
			proxyTI := app.createUpdateProxy(self.myCurrentObject.CM_TrackedItem).CM_TrackedItem;	// PAR #36421
			deleteProxy := true;																	// PAR #36421
		endif;																						// PAR #36421
		
		if proxyTI &lt;&gt; null then																			// PAR #36421			
			//jlgka1 TFS 43346 --&gt;
			// only open the hazardous cargo form if we're in view mode									// PAR #36421
			if self.mode = self.Mode_Update and (proxyTI.allChildren.size &gt; 0 or proxyTI.isChild) then	// PAR #36421
				return;																					// PAR #36421
			endif;				
			
			if proxyTI.allChildren.size &gt; 0 then
				self.myAssistant.showHazardousChildrenForm(self.myTerminal, false, false, false, proxyTI, null, proxyTI.myBookingRef, null, self, self.myMasterMenuAction);	// PAR #36421				
			else
				if self.mode &lt;&gt; self.Mode_Update and proxyTI.allTIHazards.size = 0 then
					self.myAssistant.showHazardousChildrenForm(self.myTerminal, false, false, false, proxyTI, null, proxyTI.myBookingRef, null, self, self.myMasterMenuAction);	// PAR #36421									
				else
					if proxyTI.allChildren.size &gt; 0 or proxyTI.isChild then
						self.myAssistant.showHazardousChildrenForm(self.myTerminal, false, false, false, proxyTI, null, proxyTI.myBookingRef, null, self, self.myMasterMenuAction);	// PAR #36421
					else
						self.myAssistant.showHazardousDetailsForm(self.myTerminal, proxyTI, null, null, null, self.mode = self.Mode_View, self, self.myMasterMenuAction);	
					endif;
				endif;				
			endif;
			//jlgka1 TFS 43346 &lt;--
		endif;																						// PAR #36421
		
	elseif entRowName = ETRow_AllTIHazards then																				// TFS 2842
		if self.myProxyObject &lt;&gt; null and self.myProxyObject.isKindOf(CM_TrackedItem) then									// TFS 2842
			proxyTI := self.myProxyObject.CM_TrackedItem;																	// TFS 2842
		elseif self.myProxyObject = null and self.myCurrentObject.isKindOf(CM_TrackedItem) then								// TFS 2842
			proxyTI := app.createUpdateProxy(self.myCurrentObject.CM_TrackedItem).CM_TrackedItem;							// TFS 2842
			deleteProxy := true;																							// TFS 2842
		endif;																												// TFS 2842
		if proxyTI &lt;&gt; null then																								// TFS 2842
			self.myAssistant.showHazardousDetailsForm(self.myTerminal, proxyTI, null, null, null, self.mode = self.Mode_View, self, self.myMasterMenuAction);	// TFS 2842
		endif;																												// TFS 2842
	
	//06 Apr 2017	NDL	TFS 3424
	elseif entRowName = ETRow_HandlingType and self.myCurrentObject.isKindOf(CM_BreakBulkGeneric) then	
		handlingType := self.myCurrentObject.CM_TrackedItem.getHandlingType();
		if handlingType &lt;&gt; null and handlingType.hasSubTypes() then
			if self.myProxyObject &lt;&gt; null then								
				proxyTI := self.myProxyObject.CM_BreakBulkGeneric;																	
			elseif self.myProxyObject = null then								
				proxyTI := app.createUpdateProxy(self.myCurrentObject.CM_BreakBulkGeneric).CM_BreakBulkGeneric;							
				deleteProxy := true;																							
			endif;																												
			if proxyTI &lt;&gt; null then																								
				self.myAssistant.showHandlingTypeTi(self.myTerminal, proxyTI.CM_BreakBulkGeneric, self.mode = self.Mode_View, self, self.myMasterMenuAction);	
			endif;
		endif;
	elseif entRowName = ETRow_TrailerID then
		//jlier1 TFS 54700 7/3/22
		if self.myCurrentObject.CM_TrackedItem &lt;&gt; null then
			trailer:=self.myCurrentObject.CM_TrackedItem.getCurrentTrailer;
			if trailer &lt;&gt; null then
				self.myAssistant.showCargoEnquiryForm(trailer, self.myMasterMenuAction, true, false);
			endif;
		endif;
	elseif entRowName = ETRow_HsCodeSearcher then				
		//only open searcher mode when not in view mode.
		if self.mode = self.Mode_View then	
			return;																				
		endif;	
		hsCode := self.doShowHSCodeSearcherForm();	
	
		if hsCode &lt;&gt; null then									
			self.cmbHsCode.listObject := hsCode;			
			tbl.setValueByName(ETRow_HsCode, hsCode.getDisplayString);
		endif;
	else 
		self.showTransactionsEdit(tbl, entRowName);
	endif;
	
epilog
	if deleteProxy then										// PAR #36421
		delete proxyTI;										// PAR #36421
	endif;													// PAR #36421
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblEditDragDopEvent" id="467bf7e5-25f2-4ae9-921a-7b8604cc1f4e">
        <updating/>
        <source>doTblEditDragDopEvent(table: Table input; win: Window input; x: Real; y: Real) updating;
/*

Date		Who		Reason
01 August 2014		cnwer1	Initial creation PAR
13 March  2018		jlgsl4	TFS 37573 no pack/unpack for cargo on transport
31 Dec    2019      cnwma1	Bug 48169: SNO - Re: Issue with DLR and flat bundle
19 Mar 2024 		navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
*/

vars
	moveCargo 		   : CM_TrackedItem;
	selectedContainer  : CM_Container;
	result 			   : Integer;
	setParentFromChild : Boolean;	//24 Apr 2015	NDL	Par 36111
	cargoGroup 		   : CM_CargoGroup;
	msg 			   : String;
begin
	if app.myMoveController = null then
		return;
	endif;
	
	moveCargo := app.myMoveController.myTrackedItem;
	
	if moveCargo = null then
		return;
	endif;
	
	if not moveCargo.isFlat then  		 //31.12.2019 cnwma1 #48169
		if moveCargo.isOnTransport then  // TFS 37573
			return; 					 // TFS 37573
		endif; 							 // TFS 37573
	endif;
	
	//Cargo Group - NDL	Par 36338
	if app.isCargoGroupEnabled then
		if self.myCurrentObject.isKindOf(CM_TrackedItem) then
			if self.myCurrentObject.CM_TrackedItem.isCargoGroupItem then
			
				cargoGroup := self.myCurrentObject.CM_CargoGroup;
				msg := app.getErrorString2( Assign_to_cargo_group, moveCargo.id, cargoGroup.id );
				if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No ) &lt;&gt; MsgBox_Return_Yes then
					return;
				endif;
				
				while true do
			
					app.myTrxUA.trxCargoGroupAddTi(cargoGroup, moveCargo, app.myPassport);
					
						if app.myPassport.trxCompletedOK() then
							break;
							
						else
							result := app.showErrorWarningDialog(app.getErrorString(PackUnpack), app.myPassport,ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); // ErrWarnMode_Update); ErrWarnMode_AddUpdate
							if app.myPassport.noErrors()
							and result = IDOK
							then
								// there must have just been warnings that the user has acknoledged so ..
								app.myPassport.warningsAcknowledged	:= true;
								continue;
							endif;
							
							break;
						endif;
						
				endwhile;
				
				return;
				
			endif;
		endif;
	endif;
	
	if moveCargo.isKindOf(CM_Container) and not moveCargo.isFlat() then //31.12.2019 cnwma1 #48169
		return; //can't pack container into container
	endif;
	
	if  app.myMoveController.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;
	
	//can't pack cargo that is already a child
	if moveCargo.isChild then
		return;
	endif;
	
	if self.myCurrentObject = null then
		return;
	endif;
	
	if self.myCurrentObject.isKindOf(CM_Container) then
		selectedContainer :=self.myCurrentObject.CM_Container;
	endif;
	
	if selectedContainer = null then
		return;
	endif;
	
	if moveCargo.isFlat and not selectedContainer.isFlat then    //31.12.2019 cnwma1 #48169
		return;
	endif;
	
	setParentFromChild := ( selectedContainer.allChildren.isEmptyOrContainsOnlyEquipment and selectedContainer.isStorage );	//24 Apr 2015	NDL	Par 36111
	
	if moveCargo.isBulkByVolume or moveCargo.isBulkByWeight or moveCargo.isBulkByQuantity then
		self.myAssistant.showPackUnpackAmountForm(true,moveCargo,selectedContainer,null);
	else
	
		while true do
		
			app.myTrxUA.trxUpdatePackCargo(selectedContainer, moveCargo, moveCargo.totalQuantity, moveCargo.totalWeight, setParentFromChild,null, null,false,null, app.myPassport);	//19.03.2024 navhl20 #62863
			
				if app.myPassport.trxCompletedOK() then
					break;
					
				else
					result := app.showErrorWarningDialog(app.getErrorString(PackUnpack), app.myPassport,ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); // ErrWarnMode_Update); ErrWarnMode_AddUpdate
					if app.myPassport.noErrors()
					and result = IDOK
					then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					
					break;
				endif;
				
		endwhile;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblEditQueryRowColChg" id="e7533b3f-21c1-42b2-ab75-73f75643f1dc">
        <updating/>
        <source>doTblEditQueryRowColChg(table: CM_EntryTable input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 November 2006 By cnwth2

Purpose:	Done here rather than lost focus because the damage table has
			itself has cell controls which make the damage table loose focus.

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
26/06/2008	cnwkpd1	 	PAR #17183 - refactored strings table handling methods
18/07/2017	cnwdap1		TSF 4492 SNO VERMAS Changes
 31/08/17		jlgns1		6735 POL - [Fwd: ##5431## : 8.5.1.090 Not saving VGM authorised details]
 // 20 may 2022 navgm20  ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
*/

vars

begin
	if self.mode &lt;&gt; self.Mode_View then
		if table.row = table.getRowByControlName(self.tblDamage.name) then
			self.myAssistant.damageTableLostFocus(table, self.saveRowHeight, self.tblDamage);
		elseif table.row = table.getRowByName(ETRow_BookingReference) then // dh 27/2/2008 for ccms 1004
			self.doBookingRefRowChange(table);											// dh 27/2/2008 for ccms 1004
		elseif table.row = table.getRowByName(ETRow_MyOperator) then // dh 27/2/2008 for ccms 1004
			self.doBookingRefRowChange(table);											// dh 27/2/2008 for ccms 1004
		
		elseif table.row = table.getRowByName(ETRow_ShippingLine) then 	//20 may 2022 navgm20 TFS 53204
			self.doBookingRefRowChange(table);							// 20 may 2022 navgm20 TFS 53204
			
		elseif table.row = table.getRowByName(ETRow_CustomsEntryNumber) then // AKB PAR 16184
//			self.myAssistant.stringsTableLostFocus(table, self.saveRowHeight, self.tblCustEntry);			// PAR #17183
			self.myAssistant.stringsTableQueryRowChange(table, self.saveRowHeight, self.tblCustEntry);
			self.tblCustEntry.height := 20;
			table.cnEcResizeContents();
		elseif table.row = table.getRowByName(ETRow_WagonNumber) then
			self.setWagonClassOnWagonIdChg();		
		elseif table.row = table.getRowByName(ETRow_CargoGroup) then	//04 Jun 2015	NDL	Par 36338
			self.doCargoGroupRowChange(table);		
			
		elseif table.row = table.getRowByName(ETRow_IsWeightCertified) then			// TFS 4492
			if table.getValueByName(ETRow_IsWeightCertified).Boolean = false then	// TFS 4492
			//TFS 6735 jlgns1 31/08/2017 
			//	self.cmbAuthName.clear;												// TFS 4492
			//	self.cmbCertName.listIndex := -1;									// TFS 4492
				table.setValueByName(ETRow_WeightCertifiedBy, null);				// TFS 4492
				table.setValueByName(ETRow_WeightCertifiedPerson, null);			// TFS 4492
			endif;																	// TFS 4492
		
		//13 Jan 2020	NDL	TFS 48256
		elseif table.row = table.getRowByName(ETRow_Id) then
			table.setValueByName( ETRow_HasValidId, app.checkDigitContainerId( table.getValueByNameIfVisible(ETRow_Id).String.toUpper ).getYesNo );
		endif;
	endif;
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblEditRowColChange" id="f73d406f-1313-40b5-8a59-503529e4b495">
        <updating/>
        <source>doTblEditRowColChange(table : CM_EntryTable input) protected, updating;
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	idx					: Real;
	tmpCntrl			: Control;
begin

	if (not table.userInputEnabled) then
		return;
	endif;

	if table.column &lt;&gt; table.ColumnValue then
		table.column := table.ColumnValue;
		tmpCntrl := table.accessCell(table.row, table.ColumnValue).cellControl;		
		if tmpCntrl &lt;&gt; null and tmpCntrl.name[1] &lt;&gt; '_' then
			table.cellInputReady(table, tmpCntrl, idx, idx, idx, idx);
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTempCLostFocus" id="35485b94-d334-497e-baef-15d2bf0e278e">
        <source>doTempCLostFocus() protected;
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 07/12/2009	cnwdap1		CCMS MES 1007 - dynamically get reefer table rather than using hard-coded (Container-position) table
vars
	oldFinC,
	tempF,
	tempC		: Real;
	tbl			: CM_EntryTable;
	strEntry	: String;
begin
	if self.isShowingAlphabetised then
		tbl := self.tblAlpha;
	else
		tbl := self.getTableForRow(ETRow_Temperature);
	endif;
	
	strEntry := self.txtTempC.text;
	tempC := strEntry.asDecimalJMT();
	tempF := app.myRoot.convCelsiusToFahrenheit(tempC);//.rounded;
	tbl.setValueByName(ETRow_Temperature, strEntry);
	
	if strEntry = null then
		//update F and get out
		tbl := self.getTableForRow(ETRow_TemperatureInFahrenheit);
		if tbl &lt;&gt; null then	//23 Dec 2013	NDL	Par 33185
			tbl.setValueByName(ETRow_TemperatureInFahrenheit, null);
		endif;
		return;
	endif;
	
	oldFinC := app.myRoot.convFahrenheitToCelsius(self.txtTempF.text.asRealJMT());
	//only update F if converted temp would be different
	if oldFinC &lt;&gt; tempC then
		self.txtTempF.text := tempF.asStringJMT();
		tbl := self.getTableForRow(ETRow_TemperatureInFahrenheit);
		if tbl &lt;&gt; null then	//23 Dec 2013	NDL	Par 33185
			tbl.setValueByName(ETRow_TemperatureInFahrenheit, tempF.asStringJMT);
		endif;
	endif;

	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTempFLostFocus" id="b4d222b4-e17c-4f03-9ac9-a9fbc8fe180e">
        <source>doTempFLostFocus() protected;
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 07/12/2009	cnwdap1		CCMS MES 1007 - dynamically get reefer table rather than using hard-coded (Container-position) table
vars
	oldCinF,
	tempF,
	tempC		: Real;
	tbl			: CM_EntryTable;
	strEntry	: String;
	isCelsiusUpdated	: Boolean;
begin
	if self.isShowingAlphabetised then
		tbl := self.tblAlpha;
	else
		tbl := self.getTableForRow(ETRow_TemperatureInFahrenheit);
	endif;
	
	strEntry := self.txtTempF.text;
	
	tempF := strEntry.asDecimalJMT();
	tempC := app.myRoot.convFahrenheitToCelsius(tempF);//.rounded;
	tbl.setValueByName(ETRow_TemperatureInFahrenheit, strEntry);
	
	if strEntry = null then
		//update C and get out
		// the lostFocus call here will update the table
		// and cause the hasChanged to be set correctly
		self.txtTempC.text := null;
		self.txtTempC.lostFocus(self.txtTempC);
		return;
	endif;

	oldCinF := app.myRoot.convCelsiusToFahrenheit(self.txtTempC.text.asRealJMT());
	
	//only update C if converted temp would be different
	if oldCinF &lt;&gt; tempF then
		// the lostFocus call here will update the table
		// and cause the hasChanged to be set correctly
		self.txtTempC.text := tempC.asStringJMTWithPrecision(self.txtTempC.decimals, false);
		self.txtTempC.lostFocus(self.txtTempC);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTestAutoPlan" id="26e795a1-4a7b-4af2-a91e-99682fafd562">
        <source>doTestAutoPlan(_ti	: CM_TrackedItem; _childrenOnly : Boolean );
