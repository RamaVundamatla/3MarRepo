    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="id" id="73d5b8ed-36db-4d81-9eb9-6d58cef7bbe6">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="name" id="548547f5-03b7-4e79-9408-0adaaa68ed67">
