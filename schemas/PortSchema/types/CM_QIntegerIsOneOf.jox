<Class name="CM_QIntegerIsOneOf" id="1f2d5426-90af-4a90-9383-ebdd6776ff45">
    <superclass name="CM_QueryLookupOperators"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <CompAttribute name="allSelectionValues" id="06864602-846c-4d72-9000-b42d8e5b4931">
        <type name="IntegerArray"/>
        <access>readonly</access>
    </CompAttribute>
    <JadeMethod name="create" id="31c27240-8aa5-4726-870c-eae80de9b376">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		09 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.description := self.Operator_IsOneOf;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMatch" id="e708c437-043b-4158-9149-83cf4a12470a">
        <source>doMatch(
//_value: Integer //16/10/2023	navmv20	Bug 60677
_value : Any //16/10/2023	navmv20	Bug 60677
): Boolean;
// -----------------------------------------------------------------------------
// Created:		09 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//16 October 2023	navmv20	Bug 60677: FR | EUP 54086 - Invoicing Maintenance enhancements - Selector Query - Invoice mode
// -----------------------------------------------------------------------------
begin
	//return self.allSelectionValues.includes(_value); //16/10/2023	navmv20	Bug 60677
	return self.allSelectionValues.includes(_value.Integer); //16/10/2023	navmv20	Bug 60677
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaLineDefinitionForRT" id="43f0ca51-ae03-4a3a-925e-4181ce602b1e">
        <source>getCriteriaLineDefinitionForRT( _prop : CM_QueryProperty;
								_searchValueA, _searchValueB : String output; _searchValueBoolean : Boolean output;
								_isStringProperty, _isStringBetweenProperty, _isBooleanProperty : Boolean output);
// -------------------------------------------
// Created 03 may 2008 by cnwvu1
// -------------------------------------------

vars

begin

	app.raiseCMException1( ERR_QueryForRTMustUseEqualTo, '"'&amp; self.description &amp;'"', null, null);

end;
</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <Parameter name="_searchValueA" type="String" usage="output"/>
        <Parameter name="_searchValueB" type="String" usage="output"/>
        <Parameter name="_searchValueBoolean" type="Boolean" usage="output"/>
        <Parameter name="_isStringProperty" type="Boolean" usage="output"/>
        <Parameter name="_isStringBetweenProperty" type="Boolean" usage="output"/>
        <Parameter name="_isBooleanProperty" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSearchValue" id="47b2c6f1-a101-4208-9253-9ef0f9041b5e">
        <source>getSearchValue(): Any;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.allSelectionValues;

end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueAsIntegerArr" id="ee6c942f-1c16-4288-a4fa-84f40293fbc0">
        <source>getSearchValueAsIntegerArr(_arr: IntegerArray input);
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.allSelectionValues.copy(_arr);

end;</source>
        <Parameter name="_arr" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="27b84c3e-55cd-483f-bc5d-56b1adc079cd">
        <source>getSearchValueStr(_prop : CM_QueryProperty): String;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	i	: Integer;
	str	: String;
	
begin

	foreach i in self.allSelectionValues do
		if str = null then
			str := _prop.translateToDisplayValue(i);
		else
			str := str &amp; ', ' &amp; _prop.translateToDisplayValue(i);
		endif;
	endforeach;
	
	return str;

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidForRT" id="0046cbb3-f86e-4732-9e28-7dc88a52e13e">
        <source>isValidForRT(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin

	//Queries for RT must only use the operations having only one searching value.
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="67fc219c-c3bc-46f5-a905-5571855af2e9">
        <updating/>
        <source>setSearchValue(_value: Any) updating;
// -----------------------------------------------------------------------------
// Created:		09 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars

begin

	self.allSelectionValues.clear;
	if _value &lt;&gt; null then      // par 18123
		if _value.isKindOf(IntegerArray) then	//17 Jun 2015	NDL	Par 36338
			_value.IntegerArray.copy(self.allSelectionValues);
		elseif _value.isKindOf(Integer) then
			self.allSelectionValues.add(_value.Integer);
		endif;
	endif;

end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateForRT" id="fbc33872-ddcc-45d3-88ee-d5ea939b71f6">
        <source>validateForRT( _queryName, _propName : String );
// -------------------------------------------------------------------------------------
// Created:	28 April 2008 by cnwvu1
//
// Purpose:	Queries for RT must only use the operations having only one searching value.
//			A set of selected values is not valid for the RT Drivers screen. 
// -------------------------------------------------------------------------------------

vars
	str		: String;
	intValue: Integer;
	
begin
	
	foreach intValue in self.allSelectionValues do
		str := str &amp; intValue.String &amp; ', ';
	endforeach;
	str := str[1 : str.length()-2];		// removing the last comma
	
	//26 Jul 2011	NDL	Par 27890
	//app.raiseCMException1( ERR_QueryForRTMustUseEqualTo, _queryName &amp;': "'&amp; _propName &amp;' '&amp; self.description &amp;' '&amp; str &amp;'"', null, null);
	app.raiseCMWarning1( ERR_QueryForRTMustUseEqualTo, _queryName &amp;': "'&amp; _propName &amp;' '&amp; self.description &amp;' '&amp; str &amp;'"', null, null, null);
	
end;
</source>
        <Parameter name="_queryName" type="String"/>
        <Parameter name="_propName" type="String"/>
    </JadeMethod>
</Class>
