    <JadeMethod name="doGetWagonDetailsIn" id="46e5f934-ec53-4058-b6b9-71533ed96a23">
        <updating/>
        <source>doGetWagonDetailsIn(_wagonId : String) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	//errorMsgs			: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	//errorMsg			: MobileHandHeldThin::DTO_HandHeldGateError;
	dtoContainer		: MobileHandHeldThin::DTO_ContainerInfo;
	inJob				: Boolean;
	infoStr				: String;
	
begin
	self.lblJobInfoIn.caption 		:= 'Waiting for wagon ID match...';
	self.myDTOWagonIn.wagonID 		:= self.txtWagonIn.text.trimBlanks.toUpper;
	self.myDTOWagonIn.myTrain	:= self.cmbTrain.listObject.CM_Train; // PAR 19710
	self.myDTOWagonIn.myRailLine	:= self.cmbRailLine.listObject.CM_RailLine;
	self.myDTOWagonIn.position		:= self.txtWagonPos.text.Integer;
	
	app.myHandHeldRailGuiAgent.doGetWagonDetailsIn(self.myDTOWagonIn, infoStr);

	self.lblJobInfoIn.caption := infoStr;
	self.txtWagonPos.text := self.myDTOWagonIn.position.String;
	self.txtWagonIn.text:=self.myDTOWagonIn.wagonID;
	self.cmbRailLine.listIndex := self.cmbRailLine.findObject(self.myDTOWagonIn.myRailLine);
	
	self.spawnEntryButtons(self.myDTOWagonIn.allDTOWagonPositions, self.btnCloneIn, self.maxCloneButtonsIn);
	
	
epilog
	
end;


</source>
        <access>protected</access>
        <Parameter name="_wagonId" type="String"/>
    </JadeMethod>
