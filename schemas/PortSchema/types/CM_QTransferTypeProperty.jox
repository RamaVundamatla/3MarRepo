    <JadeMethod name="setComboValues" id="908ff2c6-8014-4e1f-be3f-de55a70db9bf">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*
----------   ----------  --------------------------------------------------
Created:	06 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	voyageJobTransferType : CM_VoyageJobTransferType;

begin

	_combo.clear;
//	_combo.addItem(app.vesselAccessTypeEnumToStr(VESSEL_TYPE_LOLO));
//	_combo.addItem(app.vesselAccessTypeEnumToStr(VESSEL_TYPE_RORO));
	//12 Mar 2018	NDL TFS 37444
	foreach voyageJobTransferType in app.myRoot.allVoyageJobTransferTypes do
		_combo.addItem(voyageJobTransferType.description);
	endforeach;

	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := app.vesselAccessTypeEnumToStr(_queryOperator.CM_QIntegerLookupEqual.searchValue);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := app.vesselAccessTypeEnumToStr(_queryOperator.CM_QIntegerLookupNotEqual.searchValue);
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="ce766555-40ea-4919-9591-d882c3cdc442">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 12 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	vesselTransferType	: Integer;

begin

	if _value.String.isInteger then
		return _value;
	endif;
	
	vesselTransferType := app.vesselAccessTypeStrToEnum(_value.String);
	
	if vesselTransferType = null then
		if _value = null then
		//	app.raiseCMException1( REQUIRED_FIELD, _criteriaLine.myQueryProperty.niceName, null, self );
			app.raiseCMException1( Input_required_field_Required, _criteriaLine.myQueryProperty.niceName, null, self ); // cnwdb2	PAR 35364


		else
			app.raiseCMException2( ERR_FIELD_VALUE, _value.String, _criteriaLine.myQueryProperty.niceName, null, self );
		endif;
	endif;
	
	return vesselTransferType;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
