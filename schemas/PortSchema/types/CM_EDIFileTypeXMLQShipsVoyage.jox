<Class name="CM_EDIFileTypeXMLQShipsVoyage" id="814b7654-df42-45f8-acf5-20e3a596ec51">
    <superclass name="CM_EDIFileTypeXML"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <ImplicitInverseRef name="myTerminal" id="96f62072-5033-455b-bcb7-be9819df70f3">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="5edb6334-2179-4e5e-b9b8-ccce7392a5ae">
        <updating/>
        <source>create() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 March 2023
TFS#		: 57276
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	self.name := "Qships XML Voyages Request";
	self.type := EDIFileType_XMLQShipsVoyage;
end;</source>
    </JadeMethod>
    <JadeMethod name="createAlert" id="dbec4f19-e9db-4b27-a3cb-8401b829840d">
        <source>createAlert(_alertMsg: String; _severity: Integer);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 21 March 2023
TFS#		: 57276
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	alert: CM_SystemAlert;
	msg : String;
begin
	app.writeLog(_alertMsg, LogERROR);
	
	create alert transient;
	alert.details := _alertMsg;
	alert.setSeverity(_severity);
	alert.addLogEntry(_alertMsg);
	alert.add;
	app.commitAlert();
end;</source>
        <Parameter name="_alertMsg" type="String"/>
        <Parameter name="_severity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="dae0f91d-78d4-4cc1-b505-1d27d4c354f2">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType: Integer io; _fileTypeCode: Integer io);
/***************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 March 2023
TFS#		: 57276
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	_ediDataClass := CM_EDIDataVoyageQships;
	_dataType := EDIDataType_Voyage;
	_fileTypeCode := self.type;
end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="7e01f52f-b288-4774-8844-b178d04fa929">
        <source>getEDIBundle(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2025	navkc1	JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/

vars

begin
	
	return self.EDI_Bundle_CUSTOM;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExistingVoyageInEDIData" id="298e9cf5-26a9-4785-a3f2-51ba756f47e5">
        <source>getExistingVoyageInEDIData(_ediData : CM_EDIData; _voyageId : String) : CM_EDIQshipsVoyageTI;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 28 March 2023
TFS#		: 57276
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	voyageTI : CM_EDITrackedItem;
begin
	
	foreach voyageTI in _ediData.allEDITrackedItems do
		if voyageTI.isKindOf(CM_EDIQshipsVoyageTI) then
			if voyageTI.CM_EDIQshipsVoyageTI.voyageId = _voyageId then
				return voyageTI.CM_EDIQshipsVoyageTI;
			endif;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_voyageId" type="String"/>
        <ReturnType type="CM_EDIQshipsVoyageTI"/>
    </JadeMethod>
    <JadeMethod name="getISO8601ToUTCTimeStamp" id="5d4a3dc3-30f4-4b51-b4f4-8dd9ce558120">
        <source>getISO8601ToUTCTimeStamp(_isoDate : String) : TimeStamp;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 06 September 2023
TFS#		: 59852
Function	: This function does not convert the value rather just get the actual date and time from the string disregarding the Local time with offset to UTC +10:00

*** Changes ***
Date			Name		JIRA#		Description
06 Mar 2025		naviv1		34263		POB | QSHIPS - Shipping Agent Or Shipping Line Error Stopping QShips Response from Verifying
****************************************************/

vars
	index		: Integer;	
	strDate		: String;
	strTime		: String;
	returnValue	: TimeStamp;
begin
	strDate := _isoDate.replace("+10:00", "");
	index := strDate.pos("T", 1);
	strTime := strDate[index + 1:end];
	
    strTime := strTime[1:5];  //JIRA-34263 - Remove seconds and milliseconds by keeping only HH:mm
	
	strDate := strDate[1: index-1];
	returnValue.setDate(strDate.Date);
	returnValue.setTime(strTime.Time);
	
	return returnValue;	
end;</source>
        <Parameter name="_isoDate" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getPortsCodeFromDesc" id="2cd42704-eeb2-410c-8e6c-2fc36bc6db35">
        <source>getPortsCodeFromDesc(_desc : String) : String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 28 March 2023
TFS#		: 57276
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	port : CM_Port;
begin
	foreach port in app.myRoot.allActivePorts do
		if port.description = _desc then
			return port.code;
		endif;
	endforeach;
	
	return "";
end;</source>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processCreateCollection" id="98ac4a93-6e27-45e8-ad4d-0d6f19f04388">
        <updating/>
        <source>processCreateCollection(countryColl: DynaDictionary io; 
						countryIter: Iterator io;
						pilotColl: DynaDictionary io; 
						pilotIter: Iterator io;
						vesselTypeColl: DynaDictionary io;
						vesselTypeIter: Iterator io) updating, protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 March 2023
TFS#		: 57276
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	countryColl.setMembership(CM_Country);
	countryColl.addMemberKey(CM_Country::description.name, false, false);					
	countryColl.endKeys(true);					
	app.myRoot.allCountries.copy(countryColl);
	countryIter := countryColl.createIterator;

	pilotColl.setMembership(HMS_Pilot);
	pilotColl.addMemberKey(HMS_Pilot::description.name, false, false);					
	pilotColl.endKeys(true);					
	app.myRoot.allPilots.copy(pilotColl);
	pilotIter := pilotColl.createIterator;
	
	vesselTypeColl.setMembership(HMS_VesselType);
	vesselTypeColl.addMemberKey(HMS_VesselType::description.name, false, false);					
	vesselTypeColl.endKeys(true);					
	app.myRoot.allVesselTypes.copy(vesselTypeColl);
	vesselTypeIter := vesselTypeColl.createIterator;
end;</source>
        <access>protected</access>
        <Parameter name="countryColl" type="DynaDictionary" usage="io"/>
        <Parameter name="countryIter" type="Iterator" usage="io"/>
        <Parameter name="pilotColl" type="DynaDictionary" usage="io"/>
        <Parameter name="pilotIter" type="Iterator" usage="io"/>
        <Parameter name="vesselTypeColl" type="DynaDictionary" usage="io"/>
        <Parameter name="vesselTypeIter" type="Iterator" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="6270cd05-fc61-485c-ada1-41e923516418">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 March 2023
TFS#		: 57276
Function	:

*** Changes ***
Date			Name		TFS#		Description
19/04/2023		jlika1		57622		POB - QShips Response Received but no Voyages Created in EDI Operations		
19/04/2023		jlika1		57614		POB - QShips Agent Voyage Number as Voyage External Reference in MTN (agent_voyage_number mapped to external reference.)
08/06/2023		jlika1		TFS 58180 	POB - QShips - Vessel Type EDI Data Translations Not Being Applied
11/08/2023 		navra1		TFS 59763   POB - Object Not Found Error When Processing QSHIPS Response
17/08/2023		jlika1		TFS 59533	59168 - 55715.010 -  Update of Movement Status Based on the Value in the STATUS_TYPE_NAME Field
21/08/2023		jlika1		TFS 59852	59168 - 55715.020 Dates and Times of Voyage Movements
25/09/2023		jlika1		TFS 60540	POB - STATUS_TYPE_NAME "CANC" shown as Planned in MTN
06/10/2023		jlika1		TFS 60754	POB | QShip 55715.070 - Default Vessel Type 
19/10/2023	 	navdap1		TFS 60921	POB - QShips External Web Service Last Successful Date Time
22/11/2023		navsaa30    Bug 61281	POB - QShips - Country Code Received in Ship Flag Field - Translations
03/02/2025		navdap1		MTN-33805	POB | QSHIPS - Error Preventing Verification of File
06/03/2025		naviv1		34263		POB | QSHIPS - Shipping Agent Or Shipping Line Error Stopping QShips Response from Verifying
02/06/2025		navcs2		MTN-34943 	POB - QShips feed not flowing to EDI Operations
****************************************************/

vars
	response 			: String;	
	theXMLStr 			: String;
	countryXlation		: String;
	operator			: CM_Operator;
	found				: Boolean;
	xmlDoc 				: JadeXMLDocument;
	element, 
	child, 
	attribute 			: JadeXMLElement;
	childNode, 
	attributeNode 		: JadeXMLNode;
	ediDataVoyage		: CM_EDIData;
	ediFile				: CM_EDIFile;	
	ediVoyageTI			: CM_EDIQshipsVoyageTI;	
	movement 			: CM_EDIQshipsMovementTI;
	vessel 				: CM_EDIQshipsVesselTI;
	voyageObj			: CM_Voyage;
	ediVoyageTIExist 	: CM_EDIQshipsVoyageTI;
	vesselTypeColl		: DynaDictionary;
	vesselTypeIter		: Iterator;
	vesselType			: HMS_VesselType;
	pilotColl			: DynaDictionary;
	pilotIter			: Iterator;
	pilot				: HMS_Pilot;
	countryColl			: DynaDictionary;
	countryIter			: Iterator;
	country				: CM_Country;	
	foundMatch			: Boolean;
	vesselTypeObj		: HMS_VesselType;
	vesselTypeXlation	: String;
	vesselTypeDesc		: String;
	index				: Integer;
	pilotCode			: String;	
	webService			: CM_QshipsWebServiceDef;
	extWebDef			: CM_ExternalWebServiceDef;
	agencyCode			: String;			// TFS 60921
	truncated			: Boolean;
begin
	ediFile := _ediFile;
	
	if self.myTerminal = null then
		self.setMyTerminal(app.myPassport.myTerminal);
	endif;	
		
	if self.myTerminal.myHarbour = null then		
		app.writeLog(app.getErrorString(Termina_default_harbour_null), LogINFO);
		app.raiseCMException(Termina_default_harbour_null, null, null );
		return;
	endif;
	
	if self.myTerminal.myHarbour.defaultDepartBerth = null then
		app.writeLog(app.getErrorString(Termi_harbo_defau_depar_berth), LogINFO);
		app.raiseCMException(Termi_harbo_defau_depar_berth, null, null );			
		return;
	endif;	
	
	if app.myPassport.myCMIFMonitor &lt;&gt; null then
		app.myPassport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", 4, 3, "Loading EDI file Step 3 of 3.");
	endif;
	
	foreach extWebDef in app.myRoot.allExternalWebServices discreteLock where extWebDef.active do
		if extWebDef.isKindOf(CM_QshipsWebServiceDef)  then
			webService := extWebDef.CM_QshipsWebServiceDef;
			break;
		endif;
	endforeach; 
		
	response := ediFile.getRawDataString();	
	
	theXMLStr := response.extractXML();
    if theXMLStr &lt;&gt; null then
	
		create xmlDoc transient;
		xmlDoc.parseString(theXMLStr);				
		element := xmlDoc.getElementByTagName("NewDataSet");
		
		if element &lt;&gt; null then
			
			create countryColl transient;
			create pilotColl transient;
			create vesselTypeColl transient;
			
			self.processCreateCollection(countryColl, countryIter, pilotColl, pilotIter, vesselTypeColl, vesselTypeIter);			
			
			ediDataVoyage := ediFile.ediData;
			
			foreach childNode in element.childNodes do
				child := childNode.JadeXMLElement;
				
				create ediVoyageTI persistent;
				create movement persistent;
				create vessel persistent;					
				
				foreach attributeNode in child.childNodes do
					attribute := attributeNode.JadeXMLElement;
					
					executeWhen JMTDevelopmentEnvironment;
					write attribute.tagName &amp; Tab &amp; attribute.textData;
					endExecuteWhen;
					
					if attribute.tagName = "id" then
						vessel.myQshipsVoyageTI := ediVoyageTI;
						movement.myQshipsVoyageTI := ediVoyageTI;
						ediVoyageTI.qshipid := attribute.textData;									
						ediVoyageTI.id := attribute.textData;
					elseif attribute.tagName = "voyage_id" then
						ediVoyageTIExist := self.getExistingVoyageInEDIData(ediDataVoyage, attribute.textData);
						
						if ediVoyageTIExist &lt;&gt; null then									
							movement.myQshipsVoyageTI := null;
							vessel.myQshipsVoyageTI := null;
							delete ediVoyageTI;									
							delete vessel;
							ediVoyageTI := ediVoyageTIExist;
							vessel := ediVoyageTI.myQshipsVesselTI;
							movement.myQshipsVoyageTI := ediVoyageTI;
						endif;
						
						ediVoyageTI.voyageId := attribute.textData;
						ediVoyageTI.setVoyageCode(attribute.textData);
						
						voyageObj := self.myTerminal.lookupVoyage(ediVoyageTI.voyageId, null, false);
						if voyageObj = null then
							ediVoyageTI.messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
						else	
							ediVoyageTI.messageMode := CM_EDITrackedItem.EDI_ACTION_UPDATE;
						endif;
						
					elseif attribute.tagName = "JOB_TYPE_NAME" then
						ediVoyageTI.jobTypeName := attribute.textData;
						if attribute.textData = "ARR" then
							movement.moveType := HMSMovementTypeArrival;
						elseif attribute.textData = "REM" then
							movement.moveType := HMSMovementTypeShift;
						elseif attribute.textData = "DEP" then
							movement.moveType := HMSMovementTypeDeparture;
						else //  ignore any other movement type it is creating an empty ediVoyageTI if the job type within the range is EXT only
							if ediVoyageTIExist &lt;&gt; null then
								movement.myQshipsVoyageTI := null;
								delete movement;
							else
								movement.myQshipsVoyageTI := null;
								vessel.myQshipsVoyageTI := null;
								delete movement;
								delete vessel;
								delete ediVoyageTI;
							endif;
							break;
						endif;
					elseif attribute.tagName = "status_type" then
						ediVoyageTI.statusType := attribute.textData;
					elseif attribute.tagName = "STATUS_TYPE_NAME" then						
						if attribute.textData.isOneOf("PLAN", "SCHD", "CONF", "ACTV") then
							movement.qshipStatus := MovementStatus_Planned;
						elseif attribute.textData.isOneOf("COMP", "RELS", "INVC", "CLOS") then
							movement.qshipStatus := MovementStatus_Actual;						
						elseif attribute.textData = "CANC" then
							movement.qshipStatus := MovementStatus_Actual;
							
							if movement.moveType = HMSMovementTypeArrival then								
								movement.moveType := HMSMovementTypeCanceledArrival;
							elseif movement.moveType = HMSMovementTypeShift then
								movement.moveType := HMSMovementTypeCanceledShift;
							elseif movement.moveType = HMSMovementTypeDeparture then
								movement.moveType := HMSMovementTypeCanceledDepart;
							endif;
						else
							movement.qshipStatus := MovementStatus_Planned;
						endif;
					elseif attribute.tagName = "hazardous" and attribute.textData.toUpper = "TRUE" then
						ediVoyageTI.remarks := ediVoyageTI.remarks &amp; "HAZARDOUS" &amp; CrLf;							
					elseif attribute.tagName = "midships_draft" then
						vessel.draftMid := attribute.textData.Integer;
					elseif attribute.tagName = "fore_draft" then
						vessel.draftFore := attribute.textData.Integer;
					elseif attribute.tagName = "aft_draft" then
						vessel.draftAft := attribute.textData.Integer;
					elseif attribute.tagName = "remarks" then
						ediVoyageTI.remarks := ediVoyageTI.remarks &amp; attribute.textData;
					elseif attribute.tagName = "ETD" then
						if movement.moveType = HMSMovementTypeDeparture then							
							ediVoyageTI.scheduledDepartureDT := self.getISO8601ToUTCTimeStamp(attribute.textData);
						endif;
					elseif attribute.tagName = "ETA" then
						if movement.moveType = HMSMovementTypeArrival then							
							ediVoyageTI.scheduledArrivalDT := self.getISO8601ToUTCTimeStamp(attribute.textData);
						endif;											
					elseif attribute.tagName = "START_TIME" then
						if movement.moveType = HMSMovementTypeDeparture or movement.moveType = HMSMovementTypeCanceledDepart then							
							ediVoyageTI.departureDT := self.getISO8601ToUTCTimeStamp(attribute.textData);
							movement.occursOnDT := self.getISO8601ToUTCTimeStamp(attribute.textData);
						endif;	
						if movement.moveType = HMSMovementTypeShift or movement.moveType = HMSMovementTypeCanceledShift then
							movement.occursOnDT := self.getISO8601ToUTCTimeStamp(attribute.textData);
						endif;											
					elseif attribute.tagName = "END_TIME" then
						if movement.moveType = HMSMovementTypeArrival or movement.moveType = HMSMovementTypeCanceledArrival then
							// MTN-33805 if this is a cancel, but the ediVoyageTI.arriveTime is valid, this means we already processed
							// a replacement arrival, so don't overwrite the arriveTime with teh cancelled date/time because
							// otehrwise we don't find the arrival movement later when we need to find it
							if not ediVoyageTI.arriveTime.isValid then
								ediVoyageTI.arriveTime := self.getISO8601ToUTCTimeStamp(attribute.textData);
							endif;
							movement.occursOnDT := self.getISO8601ToUTCTimeStamp(attribute.textData);
						endif;						
					elseif attribute.tagName = "agent_voyage_number" then						
						ediVoyageTI.externalRef := attribute.textData;
					elseif attribute.tagName = "VESSEL_ID" then						
						ediVoyageTI.vesselId := attribute.textData;
						ediVoyageTI.vesselCode := attribute.textData;
						vessel.id := attribute.textData;
					elseif attribute.tagName = "VESSEL_NAME" then
						ediVoyageTI.vesselName := attribute.textData[1:25];	//limit it to 25 chars	//navra1 - TFS 59763 - 11th Aug 2023
						vessel.vesselName := attribute.textData;
					elseif attribute.tagName = "VESSEL_LRN" then
						ediVoyageTI.lloydsNumber := attribute.textData;
						vessel.lloydsNumber := attribute.textData;					
					elseif attribute.tagName = "AGENCY_CODE" then
						agencyCode := attribute.textData;														// TFS 60921
						agencyCode := app.myRoot.getXlationSystemOperatorCode(null, agencyCode, foundMatch);	// TFS 60921
						if agencyCode.length &gt; 4 then																																												// 03/06/2025 navcs2 MTN-34943
							ediDataVoyage.addWarningMessageInProcess("The agency code '" &amp; agencyCode &amp; "' has been truncated to '" &amp; agencyCode[1:4] &amp; "' as it exceeded the maximum length of 4", ediVoyageTI, app.myPassport);	// 03/06/2025 navcs2 MTN-34943
							agencyCode := agencyCode[1:4];																																											// 03/06/2025 navcs2 MTN-34943
						endif;																																																		// 03/06/2025 navcs2 MTN-34943
						ediVoyageTI.operatorCode := agencyCode;													// TFS 60921
					elseif attribute.tagName = "FROM_LOCATION_CODE" then
						movement.fromBerth := attribute.textData.toUpper;			//JIRA-34263		
					elseif attribute.tagName = "TO_LOCATION_CODE" then
						movement.toBerth := attribute.textData.toUpper;				//JIRA-34263		
					elseif attribute.tagName = "LOA" then
						vessel.loa := attribute.textData.Decimal;
					elseif attribute.tagName = "VESSEL_BEAM" then
						vessel.beam := attribute.textData.Decimal;
					elseif attribute.tagName = "VESSEL_DWT" then						
						vessel.deadWeight := attribute.textData.Decimal;
					elseif attribute.tagName = "VESSEL_GRT" then
						vessel.grt := attribute.textData.Decimal;					
					elseif attribute.tagName = "VESSEL_MAIN_TYPE" then 		
						vesselTypeDesc := attribute.textData.toUpper();						
						vesselTypeXlation := app.myRoot.getXlationSystemCode(vesselTypeDesc, XLATION_TYPE_VESSEL_TYPE, foundMatch);	
						if foundMatch then
							vesselTypeObj := app.myRoot.allVesselTypes[vesselTypeXlation];
							vessel.vesselType := vesselTypeObj.code;
						endif;						
						if vessel.vesselType = null then
							vesselType := vesselTypeColl[attribute.textData].HMS_VesselType;
							if vesselType &lt;&gt; null then
								vessel.vesselType := vesselType.code;
							else
								 vessel.vesselType := attribute.textData;
							endif;
						endif;						
					elseif attribute.tagName = "TO_ORIENTATION_NAME" then							
						if attribute.textData.isOneOf("P", "PI", "PP") then
							movement.sideTo := OrientPortSideTo;
						elseif attribute.textData.isOneOf("S", "SI", "SP") then
							movement.sideTo := OrientStarboardSideTo;
						else// HU and HD stand for Head Up and Head Down and the same pattern of I for imperative and P for preferred applies to those too. They would go with Port Side To
							movement.sideTo := OrientPortSideTo;
						endif;
					elseif attribute.tagName = "TUG_COUNT" then
						movement.tugCount := attribute.textData.Integer;
					elseif attribute.tagName = "PILOT_NAMES" then // need to have data with brackets
						index := attribute.textData.pos("(", 1);
						if index &gt; 0 then
							pilotCode := attribute.textData[1: index-3];
						else
							pilotCode := attribute.textData;
						endif;
						pilotColl.startKeyGeq(pilotCode, pilotIter);
						while pilotIter.next(pilot) do
							if pilot.description = pilotCode then
								movement.pilotCode := pilot.code;
							else
								movement.pilotCode := attribute.textData;	
							endif;
							break;
						endwhile;					
					elseif attribute.tagName = "voyage_status_type" then
						if movement.moveType = HMSMovementTypeCanceledArrival then
							ediVoyageTI.voyageStatusType := CM_EDIQshipsVoyageTI.VoyageStatusType_CANC;
						else
							ediVoyageTI.voyageStatusType := attribute.textData.Integer;							
						endif;
					elseif attribute.tagName = "last_port_name" then							
						ediVoyageTI.lastPort := self.getPortsCodeFromDesc(attribute.textData);
					elseif attribute.tagName = "next_port_name" then
						ediVoyageTI.nextPort := self.getPortsCodeFromDesc(attribute.textData);
					elseif attribute.tagName = "ship_flag" then							
						countryColl.startKeyGeq(attribute.textData.toUpper(), countryIter);
						operator := app.myRoot.allOperators[ediVoyageTI.operatorCode];					// 22 Nov 2023 navsaa30 #61281
						while countryIter.next(country) do
							if country.description = attribute.textData.toUpper() then 							
								vessel.countryCode := country.code;
							elseif operator &lt;&gt; null then     											// 22 Nov 2023 navsaa30 #61281
								countryXlation := operator.getXlationSystemCode_Country(attribute.textData, found); 
								if found then
									vessel.countryCode := countryXlation;
								else
									vessel.countryCode := attribute.textData;
								endif;
							else
								vessel.countryCode := attribute.textData;
							endif;
							break;
						endwhile;													
					endif;
				endforeach;
				// Set EDIDATA Relationship			
				if ediVoyageTIExist = null and ediVoyageTI &lt;&gt; null then
					ediVoyageTI.setMyEDIConfig(self.myTerminal.myEdiConfig);
					ediVoyageTI.setMyEDIFile(ediFile);
					ediVoyageTI.setMyEDIData(ediDataVoyage);							
				endif;
				
				if movement &lt;&gt; null and movement.myEDIData = null then 
						movement.setMyEDIConfig(self.myTerminal.myEdiConfig);
						movement.setMyEDIFile(ediFile);
						movement.setMyEDIData(ediDataVoyage);						
					endif;
					
					if vessel &lt;&gt; null and vessel.myEDIData = null then
						vessel.setMyEDIConfig(self.myTerminal.myEdiConfig);
						vessel.setMyEDIFile(ediFile);
						vessel.setMyEDIData(ediDataVoyage);
						if vessel.vesselType = null and webService &lt;&gt; null then
							vessel.vesselType := webService.myVesselType.code;
						endif;						
					endif;
			endforeach;
			
			self.processUpdateEDIStatus(ediFile, app.myPassport);
			self.processVoyageMovement(ediFile, ediDataVoyage, self.myTerminal);


		endif;		
	endif;				
epilog
	self.setMyTerminal(null);
	delete xmlDoc;
	delete vesselTypeColl;
	delete vesselTypeIter;
	delete pilotColl;
	delete pilotIter;
	delete countryColl;
	delete countryIter;	
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processUpdateEDIStatus" id="6453fe7e-d9cc-40e8-87e1-17950759539b">
        <updating/>
        <source>processUpdateEDIStatus(_ediFile : CM_EDIFile input; _passport : CM_Passport input) updating, protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 March 2023
TFS#		: 57276
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	status : Integer;
begin
	if _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE then
		if app.myPassport.allErrors.size = 0 then
			status := CM_EDIFile.EDI_STATUS_LOADED;
		else
			status := CM_EDIFile.EDI_STATUS_LOADED_ERRORS;
		endif;
		if not process.isInTransactionState then         //if there has been an exception
			status := CM_EDIFile.EDI_STATUS_LOADED_ERRORS;				
		endif;
		app.myUtilityUA.utlUpdateEDIFileStatus(_ediFile, status, _passport);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processVoyageMovement" id="1a0a9cb4-ffe3-4fd8-91c6-1a2e65235c56">
        <updating/>
        <source>processVoyageMovement(_ediFile : CM_EDIFile input; _ediDataVoyage : CM_EDIData input; _terminal : CM_Terminal) updating, protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 March 2023
TFS#		: 57276
Function	: This method make sure that there is a Arrival and Departure movement.

*** Changes ***
Date			Name		TFS#		Description
17/08/2023		jlika1		TFS 59533	59168 - 55715.010 -  Update of Movement Status Based on the Value in the STATUS_TYPE_NAME Field
21/08/2023		jlika1		TFS 59853 	59168 - 55715.030 Creation of Voyages Based on a Single Movement Received from QShips
01/09/2023		jlika1		TFS 59854	59168 - 55715.040 Addition of Movements to Existing Voyages
20/09/2023		jlika1		60515		POB - Unable to create a Shift Movement by loading the edi file
25/09/2023		jlika1		TFS 60540	POB - STATUS_TYPE_NAME "CANC" shown as Planned in MTN
19/10/2023		navdap1		TFS 60921	POB - QShips External Web Service Last Successful Date Time
29/11/2023		navdap1		TFS 61530	POB - QSHIPS - Error When Voyage Movements Updated
11/12/2023		navdap1		TFS 61727	POB - QSHIPS - Same Departure Movement Being Added to Multiple Voyages
18/12/2023		navdap1		TFS 61783	POB - QShips - Very Large Overhang Required to Create Voyage and Movements
08/02/2024		navdap1		TFS 62133	POB - QShips - Error Preventing Data Being Shown in EDI Ops
20/02/2024		navsp1		TFS 61982   POB - Error on verifying Qships file with multiple shift movements
20/02/2024      navsp1		TFS 61984   POB - Qships - Error on receiving voyage Shift and Departure but no arrival for an existing voyage and the new movements have date/time prior to existing Arrival
03/09/2024		navdap1		TFS 65955	POB - QSHIPS - Error 4 Preventing Voyages Loading to EDI Operations
09/10/2024		navcs2		MTN-32967	POB - QSHIPS - Completed Arrival Movements Get Updated and Revert to Planned
04/12/2024		mavdap1		MTN-33405	POB - QSHIPS - Processing Shift Movements with no arrival/departure in the file
****************************************************/

vars
	movement 			: CM_EDIQshipsMovementTI;
	addMovement 		: CM_EDIQshipsMovementTI;
	updMovement 		: CM_EDIQshipsMovementTI;	
	trackedItem			: CM_EDITrackedItem;
	voyageTI			: CM_EDIQshipsVoyageTI;
	isArrivalFound		: Boolean;
	isDepartureFound	: Boolean;
	isShiftFound		: Boolean;						// TFS 61530
	shiftOccursOn		: TimeStamp;					// TFS 61530
	firstShift,											// TFS 61982
	lastShift			: CM_EDIQshipsMovementTI;		// TFS 61530
	arrival, 
	departure			: CM_EDIQshipsMovementTI;		// TFS 61530
	vessel 				: CM_EDIQshipsVesselTI;
	voyageObj			: CM_Voyage;	
	gracePeriod			: Integer;
	checkDT				: TimeStamp;
	shiftCounter		: Integer;						// TFS 61982
	onlyShiftInMessage	: Boolean;		// MTN-33405
begin
		
	foreach trackedItem in _ediDataVoyage.allEDITrackedItems where trackedItem.isKindOf(CM_EDIQshipsVoyageTI) do
		voyageTI :=  trackedItem.CM_EDIQshipsVoyageTI;
		if voyageTI.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD then			
			//Check if there is Arrival and Departure Movement
			isArrivalFound := false;
			isShiftFound := false;				// TFS 61530
			isDepartureFound := false;
			shiftCounter:= 0;					//TFS 61982
			firstShift 	:= null;				//TFS 61982
			lastShift	:= null;				//TFS 61982
			foreach movement in voyageTI.allQshipsMovementTIs do
				if movement.moveType = HMSMovementTypeArrival then 
					isArrivalFound := true;
				endif;
				
				// TFS 61783 Shift movements - keep last shift date
				if movement.moveType = HMSMovementTypeShift then
					
					//Find the first and last shift movements		//TFS 61982
					if shiftCounter = 0 then
						firstShift 	:= movement;
					else
						lastShift 	:= movement;
					endif;
					shiftCounter := shiftCounter + 1;
					
					isShiftFound := true;
					shiftOccursOn := movement.occursOnDT;
				endif;
				// TFS 61783 end of this bit
				
				if movement.moveType = HMSMovementTypeDeparture then 
					isDepartureFound := true;
				endif;
			endforeach;
			
			//Default the shifts if not found	//TFS 61982
			if firstShift = null then
				firstShift := movement;
			endif;
			if lastShift = null then
				lastShift := movement;
			endif;
			
			/* if Arrival movement exist and no departure movement - create a departure movement*/			
			if (isArrivalFound and not isDepartureFound) then 
				create addMovement persistent;
				addMovement.toBerth := _terminal.myHarbour.defaultDepartBerth.code;						
				addMovement.fromBerth := lastShift.toBerth;					//TFS 61982				
				addMovement.moveType := HMSMovementTypeDeparture;
				addMovement.myQshipsVoyageTI := voyageTI;
				addMovement.occursOnDT := lastShift.occursOnDT.addDays(2);	//TFS 61982
				// TFS 61783 If there was a shift after the arrival, use the shift date as the basis for the departure date
				if isShiftFound and shiftOccursOn &gt; lastShift.occursOnDT then
					addMovement.occursOnDT := shiftOccursOn.addDays(2);
				endif;
				// TFS 61783 end
				addMovement.pilotCode := lastShift.pilotCode;				//TFS 61982
				addMovement.qshipStatus := MovementStatus_Planned;
				addMovement.sideTo := lastShift.sideTo;						//TFS 61982
				addMovement.tugCode := lastShift.tugCode;					//TFS 61982
				addMovement.tugCount := lastShift.tugCount;					//TFS 61982
				
				addMovement.setMyEDIConfig(_terminal.myEdiConfig);
				addMovement.setMyEDIFile(_ediFile);
				addMovement.setMyEDIData(_ediDataVoyage);		
				
				voyageTI.scheduledDepartureDT := addMovement.occursOnDT;						
				voyageTI.departureDT := addMovement.occursOnDT;
				
			/* if Departure movement exist and no Arrival movement - create an Arrival movement, the arrival 
			   date and time for that voyage should be initially set as the date and time 48 hours before the departure date and time.*/				
			elseif (not isArrivalFound and isDepartureFound) then //we are creating a data from departure movement
				//Arrival Movement
				create addMovement persistent;						
				addMovement.toBerth := firstShift.fromBerth;						//TFS 61982
				addMovement.fromBerth := _terminal.myHarbour.defaultArrvBerth.code;						
				addMovement.moveType := HMSMovementTypeArrival;
				addMovement.myQshipsVoyageTI := voyageTI;
				addMovement.occursOnDT := firstShift.occursOnDT.addDays(-2);		//TFS 61982
				addMovement.pilotCode := firstShift.pilotCode;						//TFS 61982
				addMovement.qshipStatus := MovementStatus_Planned;
				addMovement.sideTo := firstShift.sideTo;							//TFS 61982
				addMovement.tugCode := firstShift.tugCode;							//TFS 61982
				addMovement.tugCount := firstShift.tugCount;						//TFS 61982
				
				addMovement.setMyEDIConfig(_terminal.myEdiConfig);
				addMovement.setMyEDIFile(_ediFile);
				addMovement.setMyEDIData(_ediDataVoyage);		
				
				voyageTI.scheduledArrivalDT := addMovement.occursOnDT;		
				voyageTI.arriveTime := addMovement.occursOnDT;
				
			/* if no Departure movement and no Arrival movement - create both the Arrival and Departure movement. The arrival/departure 
			   date and time for that voyage should be initially set as the date and time 24 hours before and after the movement date and time.*/
			elseif not (isArrivalFound and isDepartureFound) then 
				//Arrival Movement
				create addMovement persistent;			
				addMovement.toBerth := firstShift.fromBerth;						//TFS 61982
				addMovement.fromBerth := _terminal.myHarbour.defaultArrvBerth.code;						
				addMovement.moveType := HMSMovementTypeArrival;
				addMovement.myQshipsVoyageTI := voyageTI;
				addMovement.occursOnDT := firstShift.occursOnDT.addDays(-1);		//TFS 61982
				addMovement.pilotCode := firstShift.pilotCode;						//TFS 61982
				addMovement.qshipStatus := MovementStatus_Planned;
				addMovement.sideTo := firstShift.sideTo;							//TFS 61982			
				addMovement.tugCode := firstShift.tugCode;							//TFS 61982
				addMovement.tugCount := firstShift.tugCount;						//TFS 61982
				
				addMovement.setMyEDIConfig(_terminal.myEdiConfig);
				addMovement.setMyEDIFile(_ediFile);
				addMovement.setMyEDIData(_ediDataVoyage);		
				
				voyageTI.scheduledArrivalDT := addMovement.occursOnDT;		
				voyageTI.arriveTime := addMovement.occursOnDT;
				
				//Departure Movement
				create addMovement persistent;						
				addMovement.toBerth := _terminal.myHarbour.defaultDepartBerth.code;				
				addMovement.fromBerth := lastShift.toBerth;							//TFS 61982			
				addMovement.moveType := HMSMovementTypeDeparture;
				addMovement.myQshipsVoyageTI := voyageTI;
				addMovement.occursOnDT := lastShift.occursOnDT.addDays(1);			//TFS 61982
				addMovement.pilotCode := lastShift.pilotCode;						//TFS 61982
				addMovement.qshipStatus := MovementStatus_Planned;
				addMovement.sideTo := lastShift.sideTo;								//TFS 61982
				addMovement.tugCode := lastShift.tugCode;							//TFS 61982
				addMovement.tugCount := lastShift.tugCount;							//TFS 61982
				
				addMovement.setMyEDIConfig(_terminal.myEdiConfig);
				addMovement.setMyEDIFile(_ediFile);
				addMovement.setMyEDIData(_ediDataVoyage);		
				
				voyageTI.scheduledDepartureDT := addMovement.occursOnDT;	
				voyageTI.departureDT := addMovement.occursOnDT;				
				
			endif;						
		
		elseif voyageTI.messageMode = CM_EDITrackedItem.EDI_ACTION_UPDATE then			// TFS 61530
			voyageObj := _terminal.lookupVoyage(voyageTI.voyageId, null, false);
			isArrivalFound := false;									//TFS 61984
			isDepartureFound := false;													// TFS 61530
			if voyageObj.myHMSVoyageData &lt;&gt; null then									// 09/10/2024 navcs2 MTN-32967
				if voyageObj.myHMSVoyageData.hasArrivalMovement then					// 09/10/2024 navcs2 MTN-32967
					isArrivalFound := true;												// 09/10/2024 navcs2 MTN-32967											
				endif;																	// 09/10/2024 navcs2 MTN-32967
			endif;
			lastShift := null;											// TFS 61727
			arrival := null;											// TFS 61727
			shiftCounter:= 0;											//TFS 61984
			firstShift := null;											//TFS 61984
			onlyShiftInMessage := true;									// MTN-33405
			foreach updMovement in voyageTI.allQshipsMovementTIs do
				if updMovement.moveType = HMSMovementTypeDeparture then
					isDepartureFound := true;							// TFS 61727
					voyageTI.arriveTime := voyageObj.arrivedDT;
					voyageTI.scheduledArrivalDT := voyageObj.arrivedDT;
					if updMovement.occursOnDT &gt; voyageTI.scheduledArrivalDT then			// TFS 60921
						voyageTI.scheduledDepartureDT := updMovement.occursOnDT;						
					endif;																	// TFS 60921
					departure := updMovement;		//TFS 61984
					onlyShiftInMessage := false;						// MTN-33405
				endif;				
				if updMovement.moveType = HMSMovementTypeShift then
					if updMovement.occursOnDT &gt; voyageObj.departedDT then
						//voyageTI.arriveTime := voyageObj.arrivedDT;					// TFS 61530	
						//voyageTI.scheduledArrivalDT := voyageObj.arrivedDT;			// TFS 61530
						voyageTI.scheduledDepartureDT := updMovement.occursOnDT.addDays(1);
					else 
						voyageTI.arriveTime := voyageObj.arrivedDT;
						voyageTI.scheduledArrivalDT := voyageObj.estimatedArrivalDT;	// TFS 61530
						voyageTI.scheduledDepartureDT := voyageObj.estimatedDepartureDT;// TFS 61530
					endif;
					
					//Find the first shift
					if shiftCounter = 0 then											//TFS 61984
						firstShift := updMovement;
					endif;
					shiftCounter := shiftCounter + 1;
					
					lastShift := updMovement;											// TFS 61530
					
				endif;
				if updMovement.moveType = HMSMovementTypeArrival then
					isArrivalFound := true;			//TFS 61984
					voyageTI.scheduledArrivalDT := updMovement.occursOnDT;
					// TFS 60921 Updated arrival movement is on or after the existing voyage's departure date	// TFS 60921
					if updMovement.occursOnDT &gt;= voyageObj.departedDT then										// TFS 60921
						voyageTI.departureDT := updMovement.occursOnDT.cnEcAddDays(2);							// TFS 60921
						voyageTI.scheduledDepartureDT := updMovement.occursOnDT.cnEcAddDays(2);					// TFS 60921
					else																						// TFS 60921
						voyageTI.departureDT := voyageObj.departedDT;
						voyageTI.scheduledDepartureDT := voyageObj.departedDT;
					endif;																						// TFS 60921
					arrival := updMovement;												// TFS 61530
					onlyShiftInMessage := false;						// MTN-33405	
				endif;
				
				if updMovement.moveType = HMSMovementTypeCanceledShift or updMovement.moveType = HMSMovementTypeCanceledArrival then
					isDepartureFound := true;
					voyageTI.arriveTime := voyageObj.arrivedDT;
					voyageTI.scheduledArrivalDT := voyageObj.arrivedDT;
					voyageTI.scheduledDepartureDT := voyageObj.departedDT;					
					onlyShiftInMessage := false;						// MTN-33405	
				endif;
				
				//Cancelled Departure Movement need to add 2 days to the Cancelled Departure Movement occursdate and set that as the Voyage New Departure Date
				if updMovement.moveType = HMSMovementTypeCanceledDepart then
					isDepartureFound := true;	
					if not app.isJMTUnitTest and voyageObj.hasDeparted then
						app.writeLog("Voyage " &amp; voyageTI.getVoyageCode() &amp; " has departed. Excluding Movement" , LogINFO);
						updMovement.myQshipsVoyageTI := null;														
						delete updMovement;	
						if voyageTI.allQshipsMovementTIs.size = 0 then
							vessel := voyageTI.myQshipsVesselTI;
							vessel.myQshipsVoyageTI := null;
						
							delete vessel;
							delete trackedItem;
							// TFS 62133 We've just deleted trackedItem, which is also the voyageTI we've just been using
							// to foreach through its allQshipsMovementTIs. So we have to break at this point otherwise
							// an error 4 gets raised when Jade tries to automatically foreach again
							break;
						endif;						
					elseif not app.isJMTUnitTest then
						gracePeriod := _terminal.getConfig(VoyDepartedGracePeriod).Integer;
						if gracePeriod = null then
							gracePeriod := 24;
						endif;
						checkDT := app.actualTimeAppServer.changeByXXHours(gracePeriod);
						if updMovement.occursOnDT.cnEcIsLessThanOrEqual(checkDT) then 
							voyageTI.arriveTime := voyageObj.arrivedDT;
							voyageTI.scheduledArrivalDT := voyageObj.arrivedDT;
							voyageTI.scheduledDepartureDT := updMovement.occursOnDT.addDays(2);
						else 
							app.writeLog("Cancelled Voyage Movement for Voyage " &amp; voyageTI.getVoyageCode() &amp; " has passed the grace period. Excluding Movement" , LogINFO);
							updMovement.myQshipsVoyageTI := null;														
							delete updMovement;	
							if voyageTI.allQshipsMovementTIs.size = 0 then
								vessel := voyageTI.myQshipsVesselTI;
								vessel.myQshipsVoyageTI := null;
							
								delete vessel;
								delete trackedItem;
							endif;						
						endif;
					else
						voyageTI.arriveTime := voyageObj.arrivedDT;
						voyageTI.scheduledArrivalDT := voyageObj.arrivedDT;
						voyageTI.scheduledDepartureDT := updMovement.occursOnDT.addDays(2);
					endif;
					departure := updMovement;//28.May.24 navsp1 UT fixes
					onlyShiftInMessage := false;						// MTN-33405	
				endif;			
			endforeach;			
			
			// TFS 65955 If trackedItem is null, that means we've deleted it above
			// We didn't want to do anything with it (it relates to cancelling an already departed
			// voyage, or changing movement details on an already departed voyage), so just continue
			// with the next EDI voyage
			if trackedItem = null then
				continue;
			endif;
			
			// TFS 61530 If no departure found, create one
			if not isDepartureFound then
				// TFS 61783 Use last Shift if found, otherwise use Arrival
				if lastShift &lt;&gt; null then
					movement := lastShift;
				else
					movement := arrival;
				endif;
				// TFS 61783 end
				create addMovement persistent;						
				addMovement.toBerth := _terminal.myHarbour.defaultDepartBerth.code;				
				addMovement.fromBerth := movement.toBerth;						
				addMovement.moveType := HMSMovementTypeDeparture;
				addMovement.myQshipsVoyageTI := voyageTI;
				addMovement.occursOnDT := movement.occursOnDT.addDays(1);
				addMovement.pilotCode := movement.pilotCode;
				addMovement.qshipStatus := MovementStatus_Planned;
				addMovement.sideTo := movement.sideTo;
				addMovement.tugCode := movement.tugCode;
				addMovement.tugCount := movement.tugCount;
				
				addMovement.setMyEDIConfig(_terminal.myEdiConfig);
				addMovement.setMyEDIFile(_ediFile);
				addMovement.setMyEDIData(_ediDataVoyage);		
				
				voyageTI.scheduledDepartureDT := addMovement.occursOnDT;	
				voyageTI.departureDT := addMovement.occursOnDT;				
			endif;
			// TFS 61530 end of this bit
			
			//If no arrival shift found, create a new one											//TFS 61984
			if not isArrivalFound then
				if firstShift &lt;&gt; null then
					movement := firstShift;
				else
					movement := departure;
				endif;
				//Arrival Movement
				create addMovement persistent;						
				addMovement.toBerth := movement.fromBerth;
				addMovement.fromBerth := _terminal.myHarbour.defaultArrvBerth.code;						
				addMovement.moveType := HMSMovementTypeArrival;
				addMovement.myQshipsVoyageTI := voyageTI;
				addMovement.occursOnDT := movement.occursOnDT.addDays(-2);
				addMovement.pilotCode := movement.pilotCode;
				addMovement.qshipStatus := MovementStatus_Planned;
				addMovement.sideTo := movement.sideTo;
				addMovement.tugCode := movement.tugCode;
				addMovement.tugCount := movement.tugCount;
				
				addMovement.setMyEDIConfig(_terminal.myEdiConfig);
				addMovement.setMyEDIFile(_ediFile);
				addMovement.setMyEDIData(_ediDataVoyage);		
				
				voyageTI.scheduledArrivalDT := addMovement.occursOnDT;		
				voyageTI.arriveTime := addMovement.occursOnDT;
			endif;
			
			// MTN-33405 If there's only a Shift movement in the file, but we already have an arrival,
			// update the voyageTI arrival date (this hasn't been set by anything yet)
			if onlyShiftInMessage and not voyageTI.arriveTime.isValid() then
				voyageTI.arriveTime := voyageObj.arrivedDT;
				voyageTI.scheduledArrivalDT := voyageObj.arrivedDT;
			endif;
		endif;
	endforeach;			
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediDataVoyage" type="CM_EDIData" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="rawDataToHSA" id="19032064-b620-4acc-9ba8-f93fec509640">
        <source>rawDataToHSA(_ediFile: CM_EDIFile; _theLines: HugeStringArray input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 28 March 2023
TFS#		: 57276
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	ediFile 	: CM_EDIFile;
	fileLine 	: String;
	pos 		: Integer;
	str 		: String;	
begin

	_theLines.clear;
	fileLine := self.rawDataToString(_ediFile);
	if fileLine = null then
		self.compressedDataToHSD(_ediFile, _theLines);		
	else
		//may have one Cr if it includes an &lt;?xml statement
		pos := fileLine.pos(Cr, 1);
		if pos &gt; 0 and pos &lt; 2047 and pos &lt; fileLine.length then
			str := fileLine[1:pos];
			fileLine := fileLine[pos+1:end];
			_theLines.add(str);
		endif;

		while fileLine.length &gt; 0 do
			if fileLine.length &gt; 2047 then
				str := fileLine[1:2047];
				fileLine := fileLine[2048:end];
			else
				str := fileLine;
				fileLine := null;
			endif;
			_theLines.add(str);
		endwhile;
		
	endif; 
epilog

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_theLines" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="3eb2bb2f-7b31-4450-a03d-0614cc928b71">
        <updating/>
        <source>setMyTerminal(_terminal : CM_Terminal) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 19 April 2023
TFS#		: 57622
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	self.myTerminal := _terminal;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
