    <JadeMethod name="pxyCreateUpdateProxy" id="685fcc75-ed26-4913-be29-1535d190c901">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/05/2018	jlgndl1	Initial creation	TFS 38560
17/09/2018	jlgdap1	TFS 40488 PEL1 Resources for Shift Movements
13 Nov 2018	NDL	TFS 41980 - Remove use of some local resource refs
*/

vars
	proxy 	: CM_ProcessHarbour;
	completedOK		: Boolean;
	
begin

	proxy := inheritMethod();
	
//	proxy.myHMSResourceForCancel := self.myHMSResourceForCancel;
//	proxy.myHMSResourceForDeparture := self.myHMSResourceForDeparture;
	proxy.myHMSResourceForExtension := self.myHMSResourceForExtension;
//	proxy.myHMSResourceForShift := self.myHMSResourceForShift;
//	proxy.myHMSResourceForUpdate := self.myHMSResourceForUpdate;
	proxy.myHMSResourceForWater := self.myHMSResourceForWater;
//	proxy.myHMSResourceForEquipment := self.myHMSResourceForEquipment;	//20 Aug 2018	NDL	TFS 40127
	
	self.allHMSResourcesForShift.copy(proxy.allHMSResourcesForShift);		// TFS 40488
	
	self.allHMSResourcesForExt.copy(proxy.allHMSResourcesForExt);	//18 Feb 2019	NDL	TFS 43374
	
	self.allHMSResourceTypeForEquip.copy(proxy.allHMSResourceTypeForEquip);	//23 Nov 2018	NDL	TFS 41980

	completedOK := true;			
	return proxy;
	
epilog
	if not completedOK then			
		delete proxy;
	endif;	
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="444b77a7-d71a-4850-a775-7984b86b9a95">
        <updating/>
        <source>setForCreate( _pxy : CM_ProcessHarbour ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgndl1	Initial creation	TFS 38560

*/

vars

begin

	self.setForUpdate( _pxy );
	
	self.myHarbour := _pxy.myHarbour;
	self.myVoyageProcess := _pxy.myVoyageProcess;

epilog

end;</source>
        <Parameter name="_pxy" type="CM_ProcessHarbour"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a1b3eae8-a7f3-4bd0-bbfa-38582cbb3fdf">
        <updating/>
        <source>setForUpdate( _pxy : CM_ProcessHarbour ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/05/2018	jlgndl1	Initial creation	TFS 38560
17/09/2018	jlgdap1	TFS 40488 PEL1 Resources for Shift Movements
13 Nov 2018	NDL	TFS 41980 - Remove use of some local resource refs
*/

vars

begin

//	self.myHMSResourceForCancel := _pxy.myHMSResourceForCancel;
//	self.myHMSResourceForDeparture := _pxy.myHMSResourceForDeparture;
	
	// ##### WE ARE ACTUALLY USING THIS ONE NOW
	self.myHMSResourceForExtension := _pxy.myHMSResourceForExtension; // TFS 42241
//	self.myHMSResourceForShift := _pxy.myHMSResourceForShift;
//	self.myHMSResourceForUpdate := _pxy.myHMSResourceForUpdate;
	self.myHMSResourceForWater := _pxy.myHMSResourceForWater;
//	self.myHMSResourceForEquipment := _pxy.myHMSResourceForEquipment;	//20 Aug 2018	NDL	TFS 40127
	
	self.allHMSResourcesForShift.clear;											// TFS 40488
	_pxy.allHMSResourcesForShift.copy(self.allHMSResourcesForShift);			// TFS 40488
	
	//23 Nov 2018	NDL	TFS 41980
	self.allHMSResourceTypeForEquip.clear;										
	_pxy.allHMSResourceTypeForEquip.copy(self.allHMSResourceTypeForEquip);
	
	//18 Feb 2019	NDL	TFS 43374
	self.allHMSResourcesForExt.clear;	
	_pxy.allHMSResourcesForExt.copy(self.allHMSResourcesForExt);

epilog

end;</source>
        <Parameter name="_pxy" type="CM_ProcessHarbour"/>
    </JadeMethod>
    <JadeMethod name="setProxyData" id="750ebfaf-55fc-468c-9323-f62fdd5c63e5">
        <updating/>
        <source>setProxyData(	_myHMSResourceForWater : HMS_ResourceType;
				_allHMSResourcesForShift : HMS_ResourceByTypeDict;			// TFS 40488
				_allHMSResourceTypeForEquip : HMS_ResourceTypeByCodeDict;		//23 Nov 2018	NDL	TFS 41980
				_allHMSResourcesForExt : HMS_ResourceByTypeDict;	//18 Feb 2019	NDL	TFS 43374
				_myHMSResourceForExtension : HMS_Resource // TFS 42241
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/05/2018	jlgndl1	Initial creation	TFS 38560
27/08/2018	jlgdap1	TFS 40488 PEL1 Resources for Shift Movements - changed _myHMSResourceForShift to HMS_ResourceType
17/09/2018	jlgdap1	TFS 40488 PEL1 Resources for Shift Movements - added _allHMSResourcesForShift
13 Nov 2018	NDL	TFS 41980 - Remove use of some local resource refs
*/

vars

begin

//	self.myHMSResourceForCancel := _myHMSResourceForCancel;
//	self.myHMSResourceForDeparture := _myHMSResourceForDeparture;
	self.myHMSResourceForExtension := _myHMSResourceForExtension; // TFS 42241
//	self.myHMSResourceForShift := _myHMSResourceForShift;
//	self.myHMSResourceForUpdate := _myHMSResourceForUpdate;
	self.myHMSResourceForWater := _myHMSResourceForWater;
//	self.myHMSResourceForEquipment := _myHMSResourceForEquipment;	//17 Aug 2018	NDL	TFS 40127
	
	self.allHMSResourcesForShift.clear;										// TFS 40488
	_allHMSResourcesForShift.copy(self.allHMSResourcesForShift);			// TFS 40488
	
	//18 Feb 2019	NDL	TFS 43374
	self.allHMSResourcesForExt.clear;
	_allHMSResourcesForExt.copy(self.allHMSResourcesForExt);
	
	//23 Nov 2018	NDL	TFS 41980
	self.allHMSResourceTypeForEquip.clear;										
	_allHMSResourceTypeForEquip.copy(self.allHMSResourceTypeForEquip);
	
epilog

end;</source>
        <Parameter name="_myHMSResourceForWater" type="HMS_ResourceType"/>
        <Parameter name="_allHMSResourcesForShift" type="HMS_ResourceByTypeDict"/>
        <Parameter name="_allHMSResourceTypeForEquip" type="HMS_ResourceTypeByCodeDict"/>
        <Parameter name="_allHMSResourcesForExt" type="HMS_ResourceByTypeDict"/>
        <Parameter name="_myHMSResourceForExtension" type="HMS_Resource"/>
    </JadeMethod>
