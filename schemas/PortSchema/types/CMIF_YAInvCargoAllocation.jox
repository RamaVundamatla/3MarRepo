    <JadeMethod name="isRepairActivity_Match" id="7fd68837-61fe-4f1c-b355-43005394a348">
        <source>isRepairActivity_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose - 	
Who - NAVAB1
Date - 14AUG2024
ADO - CR 65144 TASK 65396
*/

vars
	numRepaired : Integer;
	activity : CM_RepairReason;
	repair : CM_RepairDetail;
begin
	if _yaData.isEmpty() then
		return true;
	endif;

	if self.myTransaction = null then
		return false;
	endif;

	if self.myTransaction.isKindOf(CM_RepairDetail) then
		repair := self.myTransaction.CM_RepairDetail;
		if repair.myRepairReason &lt;&gt; null then
			activity := repair.myRepairReason; // DEFECT 65736 NAVAB1 23AUG2024
		endif;
	endif;

	
	if activity = null then
		return inheritMethod(_yaData);
	endif;
	
	return _yaData.matches(activity);
epilog

end;</source>
