    <JadeMethod name="setupForm" id="b3076f93-e2e9-459f-8404-d71ce20e1e47">
        <updating/>
        <source>setupForm() updating;
/*

Date		    Who			Reason
25 March 2011	cnwas3	  Initial creation

*/

vars



begin
	
	inheritMethod();
	
	
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar 	:= true;	
	
	self.height := self.FORM_HEIGHT;
	self.width :=  self.DECK_LAYER_WIDTH;// windows 7 with display size medium font this doesn't work self.grpLayers.clientWidth + 5;//
	
	self.btnLayerItems.caption := self.EXPAND_STRING;
	self.btnItemDimension.caption := self.EXPAND_STRING;	
	// PAR 27501 self.doBuildRealItems();
	self.doCmbLayerTypeBuild();
	//self.doBuildRealItems();
	self.grpLayerItems.visible := false;
	self.grpItemDimension.visible := false;
	self.mnuFile.visible := false;
	self.mnuHelp.visible := false;
	self.mnuOptions.visible := false;
	self.mnuWindows.visible := false;
	self.mnuTerminal.visible := false;
	self.mnuView1.visible := false;
	self.mnuContextMain.visible := false;// PAR 27643
	
	self.backColor := self.frmToolbar.backColor;
	self.doInitDimensions();

	self.doDisplayLayers();

	self.beginNotification(self, EVENT_RORO_ITEM_SELECT, Response_Continuous, null);
epilog

end;

</source>
    </JadeMethod>
    <JadeMethod name="showContextMenu" id="3b26ea1b-994c-4609-b582-5210822aa6f4">
        <updating/>
        <source>showContextMenu(pMenuItem: MenuItem; cntrl: Control input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*
Purpose:			
Date		Who		Reason
18 May 2011	cnwab1	Initial creation
*/

