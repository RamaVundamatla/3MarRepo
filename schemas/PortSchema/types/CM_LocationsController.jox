    <JadeMethod name="getLocationActivity" id="e717f52f-9d13-447e-bbc7-7e05a04ca891">
        <source>getLocationActivity( _cargoTypeId : Integer; _operatorCode : String; _type : Integer; _dateTime : TimeStamp ):CMEVT_LocationActivity;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2021	navndl1	Initial creation	TFS	50906 

*/

vars

	iter : Iterator;
	la : CMEVT_LocationActivity;
	startAtObject : CMEVT_LocationActivity;

begin

	if _dateTime = null
	or _cargoTypeId = null
	or _operatorCode = null
	or _type = null
	then
		return null;
	endif;

	iter := self.allLocationActivity.createIterator;
	startAtObject := self.allLocationActivity.getAtKeyGeq( _dateTime );
	if startAtObject &lt;&gt; null then
		iter.startAtObject( startAtObject );
	else
		return null;
	endif;
	
	while iter.next( la ) do	 //going forward oldest to newest
		if la.dateTime &lt;&gt; _dateTime then
			break;
		endif;
		if la.type &lt;&gt; _type then
			continue;
		endif;
		if la.cargoType &lt;&gt; _cargoTypeId then
			continue;
		endif;
		if la.operatorCode &lt;&gt; _operatorCode then
			continue;
		endif;
		return la;
	endwhile;
	
	return null;
	

epilog

	delete iter;

end;</source>
        <Parameter name="_cargoTypeId" type="Integer"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <ReturnType type="CMEVT_LocationActivity"/>
    </JadeMethod>
