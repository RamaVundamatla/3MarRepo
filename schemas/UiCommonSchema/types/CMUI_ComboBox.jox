    <JadeMethod name="addItemObject" id="4190f08a-debe-4076-8b17-a889f8f966a4">
        <updating/>
        <source>addItemObject(_text : String; _obj : Object) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx	: Integer;

begin

	idx := self.addItem(_text);
	self.itemObject[idx] := _obj;
	
	return idx;

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
