<Class name="CM_Machine">
    <JadeMethod name="exportPDXMLMyCollections" id="e75769b1-66c9-4aa1-9668-ea1f9e167964">
        <source>exportPDXMLMyCollections(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars
	cargoType: CM_CargoType;
	termArea: CM_TerminalArea;
begin
	if _property.name = CM_Machine::allAllowedCargoTypes.name then
		_file.writeLine('&lt;'&amp;CM_Machine::allAllowedCargoTypes.name&amp;'&gt;');
		foreach cargoType in self.allAllowedCargoTypes do
			_file.writeLine('&lt;class&gt;' &amp; cargoType.class.name &amp; '&lt;/class&gt;');
			_file.writeLine('&lt;theKey&gt;' &amp; cargoType.theKey &amp; '&lt;/theKey&gt;');
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_Machine::allAllowedCargoTypes.name&amp;'&gt;');
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLCollections" id="04cc56ee-6eeb-4a6e-a5e8-0decfc67a45b">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);

vars
	aClass: Class;
	objBlock, nameBlock, theCode, theKey: String;
	blockLength, pos: Integer;
	cargoType: CM_CargoType;
	termArea: CM_TerminalArea;
begin
	if _name = CM_Machine::allAllowedCargoTypes.name then
		objBlock := _collectionsBlock.cnEcGetTagValueOfName(CM_Machine::allAllowedCargoTypes.name);
		if objBlock = null then
			return;
		endif;
		pos := 1;
		blockLength := objBlock.length;
		while pos &lt; blockLength do
			theCode := objBlock.cnEcGetNextTagValueOfName('class', pos);
			if pos &lt; 1 then
				break;
			endif;
			theKey := objBlock.cnEcGetNextTagValueOfName('theKey', pos);
			
			if theCode = null then
				continue;
			endif;
			aClass := currentSchema.getClass(theCode);
			if aClass &lt;&gt; null then
				cargoType := app.myRoot.allCargoTypesById[theKey.Integer];
				if cargoType &lt;&gt; null then
					self.allAllowedCargoTypes.add(cargoType);
				endif;				
			endif;
		endwhile;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="949406ba-c303-432c-9023-3758927d3182">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_Machine::myRoot.name then
		return app.myRoot;
	elseif _name = CM_Machine::myTerminal.name then
		return app.myRoot.allTerminals[_theCode];
//	elseif _name = CM_Machine::myRTDevice.name then
//		return app.getMyTerminal.radioTelemetry.allRTDevices[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
