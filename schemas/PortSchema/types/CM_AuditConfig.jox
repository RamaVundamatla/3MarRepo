    <JadeMethod name="getDescription" id="2c0938c7-143f-428b-8fb4-eefce5c30291">
        <source>getDescription() : String;
// ---------------------------------------------------------------------------
// Created:     10 February 2004 by cnwrs2
// 09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up
// Purpose:     
// ---------------------------------------------------------------------------
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
// 24-JAN-2023 navtnr20	TFS 55622 Task 55692: UI - Shipping Terms Maint
vars
	aClass : Class;
begin
	if className = CM_EmailAddress2.name then
		return app.getErrorString(EmailAddresses);
	elseif className = CM_MTGrade.name then
		return app.getErrorString(AvailabilityGrade);
	elseif className = CM_LogController.name then
		return app.getErrorString(LogRow);
	elseif className = CM_EventRequestStops.name then
		return app.getErrorString(Cargo_update_request);
	elseif className = CM_Bank.name then										// 09/01/2017 cnwma1 TFS #2712
		return app.getErrorString(CM_Business_Unit);
	elseif className = CM_DebtorBankInvTypeDtl.name then 						// 09/01/2017 cnwma1 TFS #2712
		return app.getFormCaptionsString(Xlat_0015107);
	elseif className = CM_DebtorInvoiceLineDesc.name then 						// 09/01/2017 cnwma1 TFS #2712
		return app.getFormCaptionsString(Xlat_0006203);
	elseif className = CM_InvoiceDesc.name then 					   		    // 09/01/2017 cnwma1 TFS #2712
		return app.getErrorString(Invoice_type);
	elseif className = CM_TIServiceMap.name then 					   		    // 09/01/2017 cnwma1 TFS #2712
		return "Cargo Type Map";
	elseif className = CM_ImexServiceMap.name then 					   		    // 09/01/2017 cnwma1 TFS #2712
		return "Imex Map";
	elseif className = CM_ProductMap.name then 					   		        // 09/01/2017 cnwma1 TFS #2712
		return "Cargo SubType Map";
	elseif className = CM_TransServiceBroker.name then 					   		 // 09/01/2017 cnwma1 TFS #2712
		return "Transaction Type Map";
	elseif className = CM_TransResourceServiceBroker.name then 					 // 09/01/2017 cnwma1 TFS #2712
		return "Cargo Resource Map";
	elseif className = CM_MoveServiceBroker.name then 					   		 // 09/01/2017 cnwma1 TFS #2712
		return "Transaction Type [Move] Map";
	elseif className = CM_TranMap.name then 					   		         // 09/01/2017 cnwma1 TFS #2712
		return "Tran Map Cargo";
	elseif className = CM_ResourceServiceBroker.name then 					     // 09/01/2017 cnwma1 TFS #2712
		return "Voyage Resource Map";
	elseif className = CM_Edit.name then	//01 Feb 2021	NDL	TFS 50152
		return app.getErrorString(Tracked_item_edit);
	elseif className = CM_InvoiceContractShipTerm.name then		//24-02-2023 navtnr20  Task 55692
		return "Invoice Contract Shipping Terms";
	elseif className = CM_InvoiceShipTermMapping.name then		//24-02-2023 navtnr20  Task 55692
		return "Invoice Contract Shipping Terms Mapping";
	endif;
	aClass := currentSchema.getClass(className);
	if aClass &lt;&gt; null then
		return aClass.getUserFriendlyName();
	else
		return className;
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="cc605c85-6a48-4482-96a5-fb2e8e7716d5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

begin

//	ETRow_ClassName
//	ETRow_IsEnabled

	if _attrName = ETRow_ClassName then
		return self.getDescription;
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="448b4f27-1af5-49c9-97a6-3be38d13e3bf">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return inheritMethod() &amp; ' (' &amp; self.getDescription() &amp; ')';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasDataDumpClass" id="5dbd1bf3-deb5-430e-b6c3-b37d4ffbab49">
        <source>hasDataDumpClass() : Boolean;
/*

Purpose:			Returns true if the Audit config has a data dump class
					This is to determine if it can be used in event stream/push events

Parameters:			

Return Value:		

Date				Who		Reason
24 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
	ddClass		: CM_DataDumpClass;
	cls			: Class;
	
begin
	cls := currentSchema.getClass(self.className);
	if cls = null then
		return false;
	else
		while cls &lt;&gt; null do
			ddClass := app.myRoot.allDataDumpClasses[cls.name];
			if ddClass &lt;&gt; null then
				return true;
			endif;
			
			// Try the superclasses, up to CM_Object, in case one of them is exposed
			if cls.name = CM_Object.name then
				return false;
			endif;
						
			cls := cls.getSuperclass;
		endwhile;
	endif;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsEnabled" id="25566c89-4e50-48f3-9814-544cdf37d086">
        <updating/>
        <source>setIsEnabled( _isEnabled : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

begin

	if self.isEnabled &lt;&gt; _isEnabled then
		self.isEnabled := _isEnabled;
	endif;

epilog

end;</source>
        <Parameter name="_isEnabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateForCreate" id="eeb428c6-8f84-4738-bcee-9ba7bd898619">
        <updating/>
        <source>updateForCreate(pClass : Class; pRoot : CM_Root) updating;

// Should be called only on a create.
// Auditing of individual property values is not required on a create.

begin

	self.raiseExceptionIfTransient(method);
	
	if not pClass.inheritsFrom(CM_Object) then	//21 Jan 2021	NDL	TFS 50152
		app.setContinueCMExceptions(false);
		app.raiseCMException1(AttemptToAuditUnauditableClass, pClass.name, null, null);
		return;
	endif;
		
	self.className 			:= pClass.name;
	self.myRoot 			:= pRoot;

end;</source>
        <Parameter name="pClass" type="Class"/>
        <Parameter name="pRoot" type="CM_Root"/>
    </JadeMethod>
</Class>
