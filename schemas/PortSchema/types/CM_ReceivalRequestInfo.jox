    <JadeMethod name="getBookingReference" id="ee92bb5a-d972-43ee-b3fb-43b1d25c6fb0">
        <source>getBookingReference() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	cnwas3	par 23700

*/

vars

begin
	if self.myBooking &lt;&gt; null then
		return self.myBooking.getBookingRefString();
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="dfc8c6b2-d0ee-4ad9-820a-8a0fbf91f0fc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2017	cnwndl1	Initial creation	TFS 3758
07/05/2017			cnwrh7     TFS4725  Problem with Truck Unloader app

*/

vars

begin

	if _attrName = ETRow_Booking then
		if self.myBooking &lt;&gt; null then
			return self.myBooking.bookingReference;
		endif;
		return null;
		
	elseif _attrName = ETRow_BookingItem then
		if self.myBookingItem &lt;&gt; null then
			return self.myBookingItem.getShortDisplay;
		endif;
		return null;
		
	elseif _attrName = ETRow_Quantity then
		return self.quantity.asStringJMT;
		
	elseif _attrName = ETRow_Bol then	//17 Mar 2017	NDL	TFS 3758																//+cnwml2 PAR21090
		return null;
	
	elseif _attrName = ETRow_Hazard then																													//+TFS4725
		return self.myReceivalRequest.getAttrHazardousList();
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
