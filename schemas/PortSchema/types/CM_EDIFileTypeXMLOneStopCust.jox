    <JadeMethod name="getEdiAction" id="4ed0c8b5-10fb-41fa-ae6f-a5231d246c41">
        <source>getEdiAction( _keyFileSegment : String; _keyword : String; _context : Object; _raiseWarning : Boolean ):CM_EDIAction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2016	cnwndl1	Initial creation	TFS 2278 / 2670

				If there is one with an exact match of the segment (one stop's, &lt;DocumentName&gt; ) and the keyword (one stop's &lt;Status Type&gt;)
				we will return that, other wise if we find a match on segment where the keyword is null we will return that
				otherwise return null;

*/

vars

	iter : Iterator;
	ediAction : CM_EDIAction;
	alternateAction : CM_EDIAction;
	isForBol : Boolean;	//28 Mar 2017	NDL	TFS 3857
	isBolStr : String;

begin

	isBolStr := "";
	if _context &lt;&gt; null and _context.isKindOf( CM_BOL ) then	//28 Mar 2017	NDL	TFS 3857
		isForBol := true;
		isBolStr := "[BOL type]";
	elseif _context &lt;&gt; null and _context = CM_BOL then	//16 Jun 2017	NDL	TFS 4844
		isForBol := true;
		isBolStr := "[BOL type]";
	endif;

	iter := self.allEDIActions.createIterator;
	while iter.next( ediAction ) do
		if ediAction.keyFileSegment &lt;&gt; _keyFileSegment then
			continue;
		endif;
		if ediAction.isForBol() &lt;&gt; isForBol then	//28 Mar 2017	NDL	TFS 3857
			continue;
		endif;
		if ediAction.keyword = null then
			alternateAction := ediAction;
			continue;
		endif;
		if ediAction.keyword &lt;&gt; null and ediAction.keyword &lt;&gt; _keyword then
			continue;
		endif;
		
		//this one is an exact match on the segment and keyword.  Use this
		return ediAction;
	endwhile;
	
	if _raiseWarning and alternateAction = null then
	//Unable to find a valid EDI Action for '%1' and '%2'  %3
		app.raiseCMWarning3(Unable_find_valid_action, _keyFileSegment, _keyword, isBolStr, null, null, null);
	endif;
	
	//use the one that had a null keyword, and matched teh segment
	return alternateAction;

epilog

	delete iter;

end;</source>
        <Parameter name="_keyFileSegment" type="String"/>
        <Parameter name="_keyword" type="String"/>
        <Parameter name="_context" type="Object"/>
        <Parameter name="_raiseWarning" type="Boolean"/>
        <ReturnType type="CM_EDIAction"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="032a04ab-d93e-4eed-ac50-35c6c15bc1d6">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2016	cnwndl1	Initial creation	TFS 2278 / 2670
08 February 2017	cnwjre1 Modified for TFS 2945 to use the tag names and document structure from the supplied .xsd file, not the original sample data
15 Jun 2017			NDL 	TFS 4844 - generic canging of how, where what produces errors to allow partial processing and creation
							of incomplete edi trackeditems.
03 Aug 2017			NDl		Consolidate 'CM_EDICustomStopTI', always log the errors
08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
28 Jun 2018	jlgkpd1		TFS 39157 - Protect again null CM_Voyage::myVessel
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/

vars
	message : String;
	xmlDoc : CM_XMLDocument;
	rootElement : JadeXMLElement;
	xmlElements : JadeXMLElementArray;

	xmlElementMH : JadeXMLElement;
	xmlElementRD : JadeXMLElement;
	xmlElementRH : JadeXMLElement;
	xmlElementResp : JadeXMLElement;

	theXMLStr : String;
	documentName : String;
	oneStopStatus : String; // only used for Bols.

	ediAction : CM_EDIAction;
	ti : CM_TrackedItem;
	selectedBol : CM_BOLIn;	//24 Mar 2017	NDL	TFS 3857
	term : CM_Terminal;
	voyage : CM_Voyage;
	fileTs : TimeStamp;
	
	customStopTI : CM_EDICustomStopTI;
	bolQty : Integer;
	
	rawVoyageNumber : String;
	vessel : CM_Vessel;
	vesselName : String;
	actionKeyword : String;
	keyFileSegment : String;
	rawId : String;
	cargoType : CM_CargoType;
	
	commonTIErrors : HugeStringArray;
	ediTIErrors : HugeStringArray;
	bolStr : String;
	parseError : Boolean;

begin
	on JadeXMLException do self.handleXMLException(exception,parseError);
	create xmlDoc transient;
	create commonTIErrors transient;
	
	message := _ediFile.getRawDataString();
	
	if app.myPassport.myCMIFMonitor &lt;&gt; null then
		app.myPassport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", 4, 3, "Loading EDI file Step 3 of 3.");
	endif;
	
	theXMLStr := message.extractXML();
	if theXMLStr = null then	//05 Apr 2017	NDL	TFS 3971 - The raw message didn't have an XML header record on it.
		theXMLStr := message;
	endif;
	
	if theXMLStr &lt;&gt; null then
	
		xmlDoc.parseString(theXMLStr);
		
		if parseError then
			return;
		endif;
		
		if xmlDoc.rootElement.tagName = self.TagCustomsResponseOneStop then
			rootElement := xmlDoc.rootElement;
		else
			rootElement := xmlDoc.rootElement.getElementByTagName(self.TagCustomsResponseOneStop);
		endif;
		
		if rootElement &lt;&gt; null then
		
			xmlElementMH := rootElement.getElementByTagName(self.TagMessageHeader);
			if xmlElementMH = null then
				self.addErrorMessTagSetMissing( self.TagCustomsResponseOneStop, self.TagMessageHeader, _ediFile, null );
				return;
			endif;
			
			if not self.processMessageHeader( xmlElementMH, _ediFile, fileTs ) then
				fileTs := app.actualTimeServer;
			endif;
			
			xmlElementRD := rootElement.getElementByTagName(self.TagResponseDetail);
			if xmlElementRD = null then
				//we are buggered if the response detail is missing 
				self.addErrorMessTagSetMissing( self.TagCustomsResponseOneStop, self.TagResponseDetail, _ediFile, null );
				return;
			endif;
			xmlElementRH := xmlElementRD.getElementByTagName(self.TagResponseHeader);
			if xmlElementRH = null then
				//we are buggered if the response header is missing 
				self.addErrorMessTagSetMissing( self.TagCustomsResponseOneStop, self.TagResponseHeader, _ediFile, null );
				return;
			endif;
			term := _ediFile.ediData.ediConfig.myTerminal;
			
			//process the header and get what we can from it
			self.processResponseHeader( xmlElementRH, _ediFile, term, documentName, voyage, oneStopStatus, rawVoyageNumber, vessel, commonTIErrors );
			
			create xmlElements transient;
			// there are one or more &lt;ReponseLine&gt; elements within a &lt;ResponseLines&gt; parent, each with the cargo details
			rootElement.getAllElementsByTagName(self.TagResponseLine, xmlElements);
			foreach xmlElementResp in xmlElements do
				 create ediTIErrors transient;
				if not commonTIErrors.isEmpty then
					commonTIErrors.copy( ediTIErrors );
				endif;
				
				self.processResponses( xmlElementResp, ediTIErrors, ediAction, ti, term, documentName, voyage, selectedBol, oneStopStatus, bolQty, rawId, cargoType, bolStr );
				
				create customStopTI;
				customStopTI.setMyEDIData( _ediFile.ediData );
				customStopTI.setMyEDIFile( _ediFile );
					
		//		if ti = null and selectedBol = null then
				if ( ti = null and selectedBol = null ) or ediAction = null then	//05 Oct 2017	NDL	TFS 7287 Tracker 674324
				//Something went ka-thunk, but we will do our best to build an edi trackeditem anyway.
					if ediAction &lt;&gt; null then
						actionKeyword := ediAction.keyword;
						keyFileSegment := ediAction.keyFileSegment;
					else
						actionKeyword := oneStopStatus;
						keyFileSegment := documentName;
					endif;
					if vessel &lt;&gt; null then
						vesselName := vessel.name;
					else
						vesselName := null;
					endif;
					
					customStopTI.setId(rawId);
					customStopTI.setBillOfLading( bolStr );
					customStopTI.setPackCount( bolQty );
					
					customStopTI.setVoyage( voyage );	//13 Jul 2017	NDL	TFS 5366
					if cargoType = null then
						customStopTI.setCargoType( TI_CargoType_BreakBulk );
					else
						customStopTI.setCargoType( cargoType.id );
					endif;
					customStopTI.setCSTIDetails( 	rawVoyageNumber,	//_voyageCode,
													vesselName,	//_vesselName,
													null,	//_entryNumber,
													null,	//_entryNumberEdition,
													EDIFileType_XMLOneStopCust.String,	//_responseStatus,
													actionKeyword,	//_desc,
													null,	//_consignor,
													null,	//_consignee,
													null,	//_customsAgent,
													keyFileSegment,	//_clientRef			: String;
													fileTs.Date,	//_fileDate			: Date;
													fileTs.Time,	//_fileTime			: Time;
													null,	//_seqNumber,
													null	//_msgRef				: String
													);
													
		
				elseif ti &lt;&gt; null then
					// Its a goody we seem to have everything we need and it is related to a trackeditem
					customStopTI.setId(ti.id);
					customStopTI.setBillOfLading( null );
					customStopTI.setPackCount( 0 );
					customStopTI.setCargoType(ti.cargoType);
					customStopTI.setCSTIDetails( 	ti.voyageCode,	//_voyageCode,
													ti.vesselName,	//_vesselName,
													null,	//_entryNumber,
													null,	//_entryNumberEdition,
													EDIFileType_XMLOneStopCust.String,	//_responseStatus,
													ediAction.keyword,	//_desc,
													ti.consignor,	//_consignor,
													ti.consignee,	//_consignee,
													ti.getMyCustomsAgentDesc(false),	//_customsAgent,
													ediAction.keyFileSegment,	//_clientRef			: String;
													fileTs.Date,	//_fileDate			: Date;
													fileTs.Time,	//_fileTime			: Time;
													null,	//_seqNumber,
													null	//_msgRef				: String
													);
												
				elseif selectedBol &lt;&gt; null then		//24 Mar 2017	NDL	TFS 3857
					// Its a goody and is related to a BOL
					customStopTI.setId(selectedBol.number);
					customStopTI.setBillOfLading( selectedBol.number );
					customStopTI.setPackCount( bolQty );
					customStopTI.setVoyage( selectedBol.myVoyage );
					customStopTI.setCargoType(null);
					customStopTI.setCSTIDetails( 	selectedBol.myVoyage.code,	//_voyageCode,
													selectedBol.myVoyage.vesselName,	//_vesselName,
													null,	//_entryNumber,
													null,	//_entryNumberEdition,
													EDIFileType_XMLOneStopCust.String,	//_responseStatus,
													ediAction.keyword,	//_desc,
													selectedBol.consignor,	//_consignor,
													selectedBol.consignee,	//_consignee,
													null,	//_customsAgent,
													ediAction.keyFileSegment,	//_clientRef			: String;
													fileTs.Date,	//_fileDate			: Date;
													fileTs.Time,	//_fileTime			: Time;
													null,	//_seqNumber,
													null	//_msgRef				: String
													);
				
				endif;
				
				if not ediTIErrors.isEmpty then
					customStopTI.setParserWarnings( ediTIErrors );
				endif;
				
				delete ediTIErrors;
				
			endforeach;
			
		endif;
		
	endif;

epilog

	delete xmlDoc;
	delete xmlElements;
	delete ediTIErrors;
	delete commonTIErrors;

end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processMessageHeader" id="10ad9c4e-eecf-409f-bdf5-71015c357ae7">
        <source>processMessageHeader(	_xmlElementMH : JadeXMLElement;
						_ediFile: CM_EDIFile input;
						_fileTs : TimeStamp output
						): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2016	cnwndl1	Initial creation	TFS 2278 / 2670
08 February 2017	cnwjre1 Modified for TFS 2945 to use the tag names from the supplied .xsd file, not the original sample data
*/

vars

	xmlSubElement : JadeXMLElement;
	str : String;
	parentTagSet	: String;
	sentDate : Date;
	sentTime : Time;
	

begin
	parentTagSet := self.TagMessageHeader;

	xmlSubElement := null;
	// xsd documentation: Local - date and time the message was sent from 1-Stop.  Format - CCYYMMDDHHMMSS
	xmlSubElement := _xmlElementMH.getElementByTagName(self.TagLocalDateTimeSent);
	if xmlSubElement = null then
		_fileTs := app.actualTimeServer;
	else
		str := xmlSubElement.textData.trimBlanks;
		if str.length = 14 then
			sentDate.setDate( str[7:2].Integer, str[5:2].Integer, str[1:4].Integer);
			sentTime.setTime( str[9:2].Integer, str[11:2].Integer, str[13:2].Integer, 0);
			_fileTs.setDate(sentDate);
			_fileTs.setTime(sentTime);
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementMH" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_fileTs" type="TimeStamp" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processResponseHeader" id="b027d65c-183b-48c0-97ab-ace6fd23379a">
        <source>processResponseHeader(	_xmlElementResp : JadeXMLElement;
						_ediFile: CM_EDIFile input;
						_term : CM_Terminal;
						_documentName : String output;
						_voyage : CM_Voyage output;
						_oneStopStatus : String output;
						_voyageNumber : String output;
						_vessel : CM_Vessel output;
						_commonTIErrors : HugeStringArray input
						): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
08 February 2017	cnwjre1 TFS 2945 to use the tag names and XML structure from the supplied .xsd file, not the original sample data
11 February 2019    jlggb1	42598 Handle Underbond Movement Requests
*/

vars

	xmlSubElement : JadeXMLElement;
	str : String;
	parentTagSet : String;
	voyage : CM_Voyage;
	lloydsNumber : String;
//	vessel : CM_Vessel;
	operator : CM_Operator;
	xlVoyageCode : String;
	foundMatch : Boolean;
	
begin

	parentTagSet := self.TagResponseHeader;
	xmlSubElement := null;
	// DocumentName is in the response header
	xmlSubElement := _xmlElementResp.getElementByTagName(self.TagDocumentName);
	if xmlSubElement = null then
		self.addErrorMessTagSetMissing( parentTagSet, self.TagDocumentName, _ediFile, null );
		return false;
	else
		str := xmlSubElement.textData.trimBlanks;
		if str = null then
			self.addErrorMessEmptyTag( parentTagSet, self.TagDocumentName, _ediFile, null );
			return false;

		elseif (		str &lt;&gt; EDIKeySegment_CARST
					and str &lt;&gt; EDIKeySegment_CTORECR
					and str &lt;&gt; EDIKeySegment_SEAOUTR
					and str &lt;&gt; EDIKeySegment_AQISHOLD
					and str &lt;&gt; EDIKeySegment_XRAYADV
					and str &lt;&gt; EDIKeySegment_CTOREMR
					and str &lt;&gt; EDIKeySegment_UBMREQR // 42598 UBMREQR jlggb1 11/02/2019
					) then
			self.addFileErrors("&lt;" &amp; self.TagDocumentName &amp; "&gt; within &lt;" &amp; parentTagSet &amp; "&gt; unrecognised value. [" &amp; str &amp; "]", 1, _ediFile);
			return false;
		endif;
		
		_documentName := str;
		
	endif;
	
	//13 Mar 2017	NDL	TFS 3710
	xmlSubElement := null;
	xmlSubElement := _xmlElementResp.getElementByTagName(self.TagVesselID);
	if xmlSubElement &lt;&gt; null then
		lloydsNumber := xmlSubElement.textData.trimBlanks;
		//20 Mar 2017	NDL	TFS 3710 - get the vessel operator for potential transalation
		if lloydsNumber &lt;&gt; null then
			_vessel := app.myRoot.allVesselsByLloydsNumber.getAtKey( lloydsNumber );
			if _vessel &lt;&gt; null then
				operator := _vessel.myOperator;
			endif;
		endif;
	endif;
	
	// Voyage details are in the response header, and is optional
	xmlSubElement := _xmlElementResp.getElementByTagName(self.TagVoyageNumber);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		_voyageNumber := str;	//15 Jun 2017	NDL	TFS 4844
		if str &lt;&gt; null then 
		//	voyage := _term.allVoyagesByCode.getAtKeyGeq(str, null);
		//	if voyage &lt;&gt; null and voyage.code &lt;&gt; str then
		//		voyage := null;
		//	endif;
			//12 July 2017	NDL	TFS 5366
			voyage := _term.allVoyagesNew.getAtKeyGeq(str, null);
		//	if voyage.code &lt;&gt; str and voyage.inwardCode &lt;&gt; str then
			if voyage &lt;&gt; null and voyage.code &lt;&gt; str and voyage.inwardCode &lt;&gt; str then //01 Nov 2017	NDL	 tracker 679625
				voyage := null;
			endif;
			if voyage = null and operator &lt;&gt; null then	//20 Mar 2017	NDL	TFS 3710 - Try and find translated voyage code.
				xlVoyageCode := operator.getXlationSystemCode_Voyage(str, null, lloydsNumber, null, foundMatch);
			//	voyage := _term.allVoyagesByCode.getAtKeyGeq(xlVoyageCode, null);
			//	if voyage &lt;&gt; null and voyage.code &lt;&gt; xlVoyageCode then
			//		voyage := null;
			//	endif;
				//12 July 2017	NDL	TFS 5366
				voyage := _term.allVoyagesNew.getAtKeyGeq(xlVoyageCode,null);
				if voyage.code &lt;&gt; xlVoyageCode and voyage.inwardCode &lt;&gt; xlVoyageCode then
					voyage := null;
				endif;
			endif;
			_voyage := voyage;
			if voyage = null then
				self.addErrorMessNoMatchingObj( "Voyage", parentTagSet, self.TagVoyageNumber, str, null, _commonTIErrors );
			endif;
		endif;
	endif;
	
	if _documentName = EDIKeySegment_CARST then	//06 Apr 2017	NDL	TFS 3950
		xmlSubElement := null;
		xmlSubElement := _xmlElementResp.getElementByTagName(self.TagOneStopStatus);
		if xmlSubElement = null then
			self.addErrorMessTagSetMissing( parentTagSet, self.TagOneStopStatus, null, _commonTIErrors );
		else
			str := xmlSubElement.textData.trimBlanks;
			if str = null then
				self.addErrorMessEmptyTag( parentTagSet, self.TagOneStopStatus, null, _commonTIErrors );
			endif;
			_oneStopStatus := str;
		endif;
	elseif _documentName = EDIKeySegment_UBMREQR then // 42598 jlggb1 11/02/2019
		xmlSubElement := null;
		xmlSubElement := _xmlElementResp.getElementByTagName(self.TagResponseStatusType);
		if xmlSubElement = null then
			self.addErrorMessTagSetMissing( parentTagSet, self.TagResponseStatusType, null, _commonTIErrors );
		else
			str := xmlSubElement.textData.trimBlanks;
			if str = null then
				self.addErrorMessEmptyTag( parentTagSet, self.TagResponseStatusType, null, _commonTIErrors );
			endif;
			_oneStopStatus := str;
		endif;
	endif;

	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementResp" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_documentName" type="String" usage="output"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="output"/>
        <Parameter name="_oneStopStatus" type="String" usage="output"/>
        <Parameter name="_voyageNumber" type="String" usage="output"/>
        <Parameter name="_vessel" type="CM_Vessel" usage="output"/>
        <Parameter name="_commonTIErrors" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processResponses" id="2db51282-5af2-4ca5-9d67-fa040e925160">
        <source>processResponses(	_xmlElementResp : JadeXMLElement;
					_ediTIErrors : HugeStringArray input;
					_ediAction : CM_EDIAction output; 
					_ti : CM_TrackedItem output;
					_term : CM_Terminal;
					_documentName : String;
					_voyage : CM_Voyage;
					_selectedBol : CM_BOLIn output;
					_oneStopStatus : String io;
					_bolQty : Integer output;
					_rawId : String output;
					_cargoTypeObj : CM_CargoType output;
					_bolStr : String output
					): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2016	cnwndl1	Initial creation	TFS 2278 / 2670
06 Sep 2016			cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
08 February 2017	cnwjre1 Modified for TFS 2945 to use the tag names from the supplied .xsd file, not the original sample data
11 February 2019	jlggb1	42598 Underbond Movement Request Response handling
*/

vars

	xmlElement,
	xmlSubElement : JadeXMLElement;
	xmlSubElements : JadeXMLElementArray;
	str : String;
	parentTagSet : String;
	
	allTis : CM_TISet;
	voyage : CM_Voyage;
	cargoId : String;
//	cargoTypeObj : CM_CargoType;
	oidString : String;
	obj : Object;

	statusType : String;
	
	bolSet : CM_BOLSet;
	bol : CM_BOL;
	selectedBol : CM_BOLIn;
	startSize : Integer;
	bolCargoCount : Integer;
	bolTi : CM_TrackedItem;
	ediActionContext : Object;
	cargoTypeId : Integer;
	invalidObj : Boolean;
	edition : Integer;
	statusTagName : String;
	cargoTypeTagName : String;
	
begin

	//11 Dec 2019	NDL	TFS 47895 - different behaviour for UBMREQR split off to its own method
	if _documentName = EDIKeySegment_UBMREQR then
		return self.processUnderBondResponses(	_xmlElementResp,	// _xmlElementResp : JadeXMLElement;
												_ediTIErrors,	// _ediTIErrors : HugeStringArray input;
												_ediAction,	// _ediAction : CM_EDIAction output; 
												_ti,	// _ti : CM_TrackedItem output;
												_term,	// _term : CM_Terminal;
												_documentName,	// _documentName : String;
												_voyage,	// _voyage : CM_Voyage;
												_selectedBol,	// _selectedBol : CM_BOLIn output;
												_oneStopStatus,	// _oneStopStatus : String io;
												_bolQty,	// _bolQty : Integer output;
												_rawId,	// _rawId : String output;
												_cargoTypeObj,	// _cargoTypeObj : CM_CargoType output;
												_bolStr	// _bolStr : String output
												);
	endif;

	startSize := _ediTIErrors.size;
	parentTagSet := self.TagResponseLine;
	
	//get the cargo id
	xmlSubElement := null;
	xmlSubElement := _xmlElementResp.getElementByTagName(self.TagCargoNumber);
	
	if xmlSubElement = null then
	
		//24 Mar 2017	NDL	TFS 3857
		if _documentName = EDIKeySegment_CARST
		or _documentName = EDIKeySegment_AQISHOLD
		or _documentName = EDIKeySegment_XRAYADV
		then
			xmlSubElement := null;
			xmlSubElement := _xmlElementResp.getElementByTagName(self.TagOceanBill);
			if xmlSubElement = null then	//07 Apr 2017	TFS 3950
				self.addErrorMessTagSetMissing( parentTagSet, self.TagOceanBill, null, _ediTIErrors );
				self.addErrorMessTagSetMissing( parentTagSet, self.TagCargoNumber, null, _ediTIErrors );
				return false;
			else
				_bolStr := xmlSubElement.textData.trimBlanks;
				if _bolStr.trimBlanks = null then	//07 Apr 2017	TFS 3950
					self.addErrorMessEmptyTag( parentTagSet, self.TagOceanBill, null, _ediTIErrors );
				endif;
				_cargoTypeObj := app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk]; 
				_rawId := _bolStr;	//15 Jun 2017	NDL	TFS 4844
				voyage := _voyage;
				if voyage = null then
					_ediTIErrors.add("Voyage not found to identify BOL '" &amp; _bolStr &amp; "'." );
				else
					create bolSet transient;
					voyage.getBOLInsFromNumber( bolSet, BOLType_GeneralBillOfLading, _bolStr, true, null );
					foreach bol in bolSet do
						if bol.number.toUpper = _bolStr.toUpper then
							selectedBol := bol.CM_BOLIn;
							break;
						endif;
					endforeach;
				endif;
			endif;
			
			if selectedBol = null then	//07 Apr 2017	TFS 3950
				if voyage &lt;&gt; null then
					_ediTIErrors.add("BOL '" &amp; _bolStr &amp; "' not found on identified voyage. '" &amp; voyage.code &amp; "'" );
				endif;
			endif;
			
			xmlSubElement := null;
			xmlSubElement := _xmlElementResp.getElementByTagName(self.TagLineItems);
			if xmlSubElement &lt;&gt; null then
				create xmlSubElements transient;
				xmlSubElement.getAllElementsByTagName(self.TagPackages,xmlSubElements);
				if not xmlSubElements.isEmpty then
					foreach xmlSubElement in xmlSubElements do
						str := xmlSubElement.textData.trimBlanks;
						if str.isInteger then
							_bolQty := _bolQty + str.Integer;
						endif;
					endforeach;
				endif;
				//16 Jun 2017	NDL	TFS 4866 - 9 months after asking the question, (sum of total quantity or number of cargo items) we get feedback.....
				if selectedBol &lt;&gt; null then
					bolCargoCount := 0;
					foreach bolTi in selectedBol.allTrackedItems do
						bolCargoCount := bolCargoCount + bolTi.totalQuantity.max(1);
					endforeach;
					if bolCargoCount &lt;&gt; _bolQty then
						_ediTIErrors.add("BOL found but &lt;" &amp; self.TagPackages &amp; "&gt; doesn't match cargo count on BOL &lt;" &amp; parentTagSet &amp; "&gt;." );
						selectedBol := null;
					endif;
					delete xmlSubElements;
				endif;
			endif;
			
			xmlSubElement := _xmlElementResp.getElementByTagName(self.TagPackages);
			
		endif;
	
		if _rawId &lt;&gt; null then	//24 Mar 2017	NDL	TFS 3857
			// OK we will be using the BOL
		else
			self.addErrorMessTagSetMissing( parentTagSet, self.TagCargoNumber, null, _ediTIErrors );
		endif;
	else
		str := xmlSubElement.textData.trimBlanks;
		cargoId := str;
		_rawId := str;	//15 Jun 2017	NDL	TFS 4844
	endif;
	
	//24 Mar 2017	NDL	TFS 3857
	if cargoId = null and ( selectedBol &lt;&gt; null or _bolStr &lt;&gt; null ) then
		_selectedBol := selectedBol;
	
	else
	
		// get the cargo type if we are not being passed the oid...
		if _documentName = EDIKeySegment_CARST
		or _documentName = EDIKeySegment_AQISHOLD
		or _documentName = EDIKeySegment_XRAYADV
		then
			voyage := _voyage;
			
			xmlSubElement := null;

			//11 Dec 2019	NDL	TFS 47895
			cargoTypeTagName := self.TagCargoType;
			xmlSubElement := _xmlElementResp.getElementByTagName(cargoTypeTagName);
			if xmlSubElement = null then // try the other one
				cargoTypeTagName := self.TagImportCargoType;
				xmlSubElement := _xmlElementResp.getElementByTagName(cargoTypeTagName);
				if xmlSubElement = null then
					//still nothing, set teh tag back to raise the error with
					cargoTypeTagName := self.TagCargoType;
				endif;
			endif;
			
			if xmlSubElement = null then
				self.addErrorMessTagSetMissing( parentTagSet, cargoTypeTagName, null, _ediTIErrors );
				return false;
			else
				str := xmlSubElement.textData.trimBlanks;
				if str = null then 
					self.addErrorMessEmptyTag( parentTagSet, cargoTypeTagName, null, _ediTIErrors );
					return false;
				else
					if str.toUpper = "C" then
						_cargoTypeObj := app.myRoot.allCargoTypesById.getAtKey(1); // container
					elseif str.isInteger then
						_cargoTypeObj := app.myRoot.allCargoTypesById.getAtKey(str.Integer);
					else
						_cargoTypeObj := app.myRoot.getCargoTypeFromAbbrevOrDescr(str);
					endif;
					
					if _cargoTypeObj &lt;&gt; null then
						cargoTypeId := _cargoTypeObj.id;
					else
						cargoTypeId := TI_CargoType_Null;
					endif;
					
					create allTis transient;
					if voyage &lt;&gt; null then
						voyage.allOnshipTIsByIdCargoType.lookupAllTIsUsingIdCargoType(cargoId, cargoTypeId, allTis, null);
						if allTis.isEmpty then
							voyage.allOnsiteTIsByIdCargoType.lookupAllTIsUsingIdCargoType(cargoId, cargoTypeId, allTis, null);
						endif;
						if allTis.isEmpty then
							_ti := voyage.allNotifiedTIsByIdCargoType.getAtKeyGeq( cargoId, cargoTypeId );
							if _ti &lt;&gt; null and (  (_ti.id &lt;&gt; cargoId ) or  ( cargoTypeId &lt;&gt; TI_CargoType_Null and _ti.cargoType &lt;&gt; cargoTypeId ) ) then
								_ti := null;
							endif;
						elseif not allTis.isEmpty then
							_ti := allTis.first;
						endif;
					else
						_term.lookupAllOnsiteTrackedItems(cargoTypeId, cargoId, allTis, false, null);
						if allTis.isEmpty then
							_ti := _term.allNotifiedTIsByIdCargoType.getAtKeyGeq( cargoId, cargoTypeId );
							if _ti &lt;&gt; null and (  (_ti.id &lt;&gt; cargoId ) or  ( cargoTypeId &lt;&gt; TI_CargoType_Null and _ti.cargoType &lt;&gt; cargoTypeId ) ) then
								_ti := null;
							endif;
						else
							_ti := allTis.first;
						endif;
					endif;
					
					if _ti &lt;&gt; null and _cargoTypeObj = null  then
						_cargoTypeObj := _ti.myCargoType;
					endif;
					
					if _cargoTypeObj = null then
						self.addErrorMessNoMatchingObj( "Cargo Type", parentTagSet, cargoTypeTagName, str, null, _ediTIErrors );
					endif;
					
					if _ti = null then
						_ediTIErrors.add("&lt;" &amp; cargoTypeTagName &amp; "&gt; and &lt;" &amp; self.TagCargoNumber &amp; "&gt; within &lt;" &amp; parentTagSet &amp; "&gt; failed to identify a cargo item in JMT." );
					endif;
				endif;
			endif;
		
		else
			xmlSubElement := null;
			xmlSubElement := _xmlElementResp.getElementByTagName(self.TagCTO_ReferenceKey);
			if xmlSubElement = null then
				self.addErrorMessTagSetMissing( parentTagSet, self.TagCTO_ReferenceKey, null, _ediTIErrors );
				return false;
			else
				str := xmlSubElement.textData.trimBlanks;
				oidString := str;
				obj := oidString.asOid;
				if obj &lt;&gt; null and obj.isKindOf( CM_TrackedItem ) then
					_ti := obj.CM_TrackedItem;
				endif;
				on Exception do app.handleDeletedObject( exception, _ti, invalidObj );
				if _ti&lt;&gt; null then
					edition := _ti.edition;
					if invalidObj then
						_ti := null;
						_ediTIErrors.add("&lt;" &amp; self.TagCTO_ReferenceKey &amp; "&gt; within &lt;" &amp; parentTagSet &amp; "&gt; failed to identify a valid cargo item in JMT. [" &amp; str &amp; "]" );
						return false;	//06 Jul 2017	NDL	
					endif;
				endif;
				if _ti = null then
					_ediTIErrors.add("&lt;" &amp; self.TagCTO_ReferenceKey &amp; "&gt; within &lt;" &amp; parentTagSet &amp; "&gt; failed to identify an existing cargo item in JMT. [" &amp; str &amp; "]" );
					return false;	//06 Jul 2017	NDL	
				elseif _ti.id &lt;&gt; cargoId then
					_ediTIErrors.add("&lt;" &amp; self.TagCTO_ReferenceKey &amp; "&gt; and &lt;" &amp; self.TagCargoNumber &amp; "&gt; within &lt;" &amp; parentTagSet &amp; "&gt; identify different cargo items in JMT." );
					return false;	//06 Jul 2017	NDL	
				endif;
			endif;
			
		endif;
	
	endif;
	
	//06 Apr 2017	- Another change of rules from One STop, sometime we do sometimes we don't....
	
	
	//16 Jun 2017	NDL	TFS 4844
	if _ti &lt;&gt; null then
		ediActionContext := null;
	else
		ediActionContext := _selectedBol;
		if ediActionContext = null and _bolStr &lt;&gt; null then
			ediActionContext := CM_BOL;
		endif;
	endif;
	
	
	if _documentName = EDIKeySegment_CARST then	//11 Dec 2019	NDL	TFS 47895
		// So as of 6th April 2017, One Stop says - Recorded in TFS 3950 / See History 6th change by RAMESH a quote from One STop
		/*
		It seems that for the CARST message, our system will send out the status &lt;OneStopStatus&gt;
		This is generally used for 1 Cargo
		There will always be one status &lt;OneStopStatus&gt;
		&lt;OneStopStatus&gt; is the status from the Customs
		*/
		statusType := _oneStopStatus;
		_ediAction := self.getEdiAction( _documentName, statusType, ediActionContext, false );
		if _ediAction = null then
			_ediTIErrors.add("&lt;" &amp; self.TagDocumentName &amp; "&gt; '" &amp; _documentName &amp; "' and &lt;" &amp; self.TagOneStopStatus &amp; "&gt; within &lt;" &amp; self.TagResponseHeader &amp; "&gt; do not identify a 'Customs Action' in JMT." );
		endif;
		
	else
		/*
		For all other custom responses (AQISHOLD, XRAYADV, etc), our system will send out the status &lt;StatusType&gt;
		This can be used for more than 1 line items
		There can be more than one &lt;statusType&gt; in the message
		*/
		xmlSubElement := null;
		xmlSubElement := _xmlElementResp.getElementByTagName(self.TagStatusType);
		if xmlSubElement &lt;&gt; null then
			str := xmlSubElement.textData.trimBlanks;
			statusType := str;
			_ediAction := self.getEdiAction( _documentName, statusType, ediActionContext, false );
			if _ediAction = null then
				_oneStopStatus := statusType; //05 Oct 2017	NDL	TFS 7287
				_ediTIErrors.add("&lt;" &amp; self.TagDocumentName &amp; "&gt; '" &amp; _documentName &amp; "' and &lt;" &amp; self.TagStatusType &amp; "&gt; within &lt;" &amp; parentTagSet &amp; "&gt; do not identify a 'Customs Action' in JMT." );
			endif;
		
		else
			_ediAction := self.getEdiAction( _documentName, null, ediActionContext, false );
			if _ediAction = null then
				_ediTIErrors.add("&lt;" &amp; self.TagDocumentName &amp; "&gt; '" &amp; _documentName &amp; "' alone within &lt;" &amp; parentTagSet &amp; "&gt; does not identify a 'Customs Action' with no key-segment in JMT." );
			endif;
		endif;
		
	endif;
	
	return startSize = _ediTIErrors.size;
	
epilog

	delete allTis;
	delete bolSet;
	delete xmlSubElements;

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementResp" type="JadeXMLElement"/>
        <Parameter name="_ediTIErrors" type="HugeStringArray" usage="input"/>
        <Parameter name="_ediAction" type="CM_EDIAction" usage="output"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_documentName" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_selectedBol" type="CM_BOLIn" usage="output"/>
        <Parameter name="_oneStopStatus" type="String" usage="io"/>
        <Parameter name="_bolQty" type="Integer" usage="output"/>
        <Parameter name="_rawId" type="String" usage="output"/>
        <Parameter name="_cargoTypeObj" type="CM_CargoType" usage="output"/>
        <Parameter name="_bolStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processUnderBondResponses" id="ab9d5527-e580-40e7-838f-d85204bbec39">
        <source>processUnderBondResponses(	_xmlElementResp : JadeXMLElement;
							_ediTIErrors : HugeStringArray input;
							_ediAction : CM_EDIAction output; 
							_ti : CM_TrackedItem output;
							_term : CM_Terminal;
							_documentName : String;
							_voyage : CM_Voyage;
							_selectedBol : CM_BOLIn output;
							_oneStopStatus : String io;
							_bolQty : Integer output;
							_rawId : String output;
							_cargoTypeObj : CM_CargoType output;
							_bolStr : String output
							): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2019	jlgndl1	Initial creation	TFS 47895

*/

vars

	xmlElement,
	xmlSubElement : JadeXMLElement;
	xmlSubElements : JadeXMLElementArray;
	str : String;
	parentTagSet : String;
	
	allTis : CM_TISet;
	voyage : CM_Voyage;
	cargoId : String;
	oidString : String;
	obj : Object;

	statusType : String;
	
	bolSet : CM_BOLSet;
	bol : CM_BOL;
	selectedBol : CM_BOLIn;
	startSize : Integer;
	bolCargoCount : Integer;
	bolTi : CM_TrackedItem;
	ediActionContext : Object;
	cargoTypeId : Integer;
	invalidObj : Boolean;
	edition : Integer;
	
	mustHaveBol : Boolean;
	mustHaveCargoId : Boolean;
	mess : String;
	
begin

	if _documentName &lt;&gt; EDIKeySegment_UBMREQR then
		return false;
	endif;

	startSize := _ediTIErrors.size;
	parentTagSet := self.TagResponseLine;
	
	
	//get the cargo type
	xmlSubElement := null;				
	xmlSubElement := _xmlElementResp.getElementByTagName(self.TagImportCargoType);
	if xmlSubElement = null then
		self.addErrorMessTagSetMissing( parentTagSet, self.TagImportCargoType, null, _ediTIErrors );
		return false;
	else
		str := xmlSubElement.textData.trimBlanks;
		if str = null then 
			self.addErrorMessEmptyTag( parentTagSet, self.TagImportCargoType, null, _ediTIErrors );
			return false;
		else
			if  str.toUpper.isOneOf('C','LCL', 'FCL', 'FCX') then
				_cargoTypeObj := app.myRoot.allCargoTypesById.getAtKey(TI_CargoType_Container);
				mustHaveCargoId := true;
			elseif str.toUpper.isOneOf('B/B', 'BLK') then
				_cargoTypeObj := app.myRoot.allCargoTypesById.getAtKey(TI_CargoType_BreakBulk);
				mustHaveBol := true;
			else
				mess := "&lt;" &amp;  self.TagImportCargoType &amp; "&gt; contains unrecognised value '" &amp; str &amp; "' should be one of 'C', 'LCL', 'FCL', 'FCX', 'B/B' or 'BLK'.";
				_ediTIErrors.add( mess );
				return false;
			endif;
		endif;
	endif;
	
	//get the cargo id
	xmlSubElement := null;
	xmlSubElement := _xmlElementResp.getElementByTagName(self.TagCargoNumber);
	if xmlSubElement = null then
		if mustHaveCargoId then
			self.addErrorMessTagSetMissing( parentTagSet, self.TagCargoNumber, null, _ediTIErrors );
			return false;
		endif;
	else
		str := xmlSubElement.textData.trimBlanks;
		if str = null then 
			self.addErrorMessEmptyTag( parentTagSet, self.TagCargoNumber, null, _ediTIErrors );
			return false;
		else
			cargoId := str;
			_rawId := str;
		endif;
	endif;
	
	voyage := _voyage;
	
	//get the bol for the _voyage
	if mustHaveBol then	
	
		xmlSubElement := null;
		xmlSubElement := _xmlElementResp.getElementByTagName(self.TagOceanBill);
		if xmlSubElement = null then	
			self.addErrorMessTagSetMissing( parentTagSet, self.TagOceanBill, null, _ediTIErrors );
			return false;
		else
			_bolStr := xmlSubElement.textData.trimBlanks;
			if _bolStr.trimBlanks = null then	
				self.addErrorMessEmptyTag( parentTagSet, self.TagOceanBill, null, _ediTIErrors );
			endif;
			_rawId := _bolStr;		
			if voyage = null then
				_ediTIErrors.add("Voyage not found to identify BOL '" &amp; _bolStr &amp; "'." );
			else
				create bolSet transient;
				voyage.getBOLInsFromNumber( bolSet, BOLType_GeneralBillOfLading, _bolStr, true, null );
				foreach bol in bolSet do
					if bol.number.toUpper = _bolStr.toUpper then
						selectedBol := bol.CM_BOLIn;
						break;
					endif;
				endforeach;
			endif;
		endif;
		
		if selectedBol = null then	
			if voyage &lt;&gt; null then
				_ediTIErrors.add("BOL '" &amp; _bolStr &amp; "' not found on identified voyage. '" &amp; voyage.code &amp; "'" );
			endif;
		endif;
		
		xmlSubElement := null;
		xmlSubElement := _xmlElementResp.getElementByTagName(self.TagLineItems);
		if xmlSubElement &lt;&gt; null then
			create xmlSubElements transient;
			xmlSubElement.getAllElementsByTagName(self.TagPackages,xmlSubElements);
			if not xmlSubElements.isEmpty then
				foreach xmlSubElement in xmlSubElements do
					str := xmlSubElement.textData.trimBlanks;
					if str.isInteger then
						_bolQty := _bolQty + str.Integer;
					endif;
				endforeach;
			endif;
			
			if selectedBol &lt;&gt; null then
				bolCargoCount := 0;
				foreach bolTi in selectedBol.allTrackedItems do
					bolCargoCount := bolCargoCount + bolTi.totalQuantity.max(1);
				endforeach;
				if bolCargoCount &lt;&gt; _bolQty then
					_ediTIErrors.add("BOL found but &lt;" &amp; self.TagPackages &amp; "&gt; doesn't match cargo count on BOL &lt;" &amp; parentTagSet &amp; "&gt;." );
					selectedBol := null;
				endif;
				delete xmlSubElements;
			endif;
		endif;
		
		xmlSubElement := _xmlElementResp.getElementByTagName(self.TagPackages);
		
	endif;
	

	if mustHaveCargoId then
			
		xmlSubElement := null;

		create allTis transient;
		if voyage &lt;&gt; null then
			voyage.allOnshipTIsByIdCargoType.lookupAllTIsUsingIdCargoType(cargoId, cargoTypeId, allTis, null);
			if allTis.isEmpty then
				voyage.allOnsiteTIsByIdCargoType.lookupAllTIsUsingIdCargoType(cargoId, cargoTypeId, allTis, null);
			endif;
			if allTis.isEmpty then
				_ti := voyage.allNotifiedTIsByIdCargoType.getAtKeyGeq( cargoId, cargoTypeId );
				if _ti &lt;&gt; null and ( _ti.id &lt;&gt; cargoId or  _ti.cargoType &lt;&gt; cargoTypeId ) then
					_ti := null;
				endif;
			elseif not allTis.isEmpty then
				_ti := allTis.first;
			endif;
		else
			_term.lookupAllOnsiteTrackedItems(cargoTypeId, cargoId, allTis, false, null);
			if allTis.isEmpty then
				_ti := _term.allNotifiedTIsByIdCargoType.getAtKeyGeq( cargoId, cargoTypeId );
				if _ti &lt;&gt; null and (  (_ti.id &lt;&gt; cargoId ) or  ( cargoTypeId &lt;&gt; TI_CargoType_Null and _ti.cargoType &lt;&gt; cargoTypeId ) ) then
					_ti := null;
				endif;
			else
				_ti := allTis.first;
			endif;
		endif;
		
		if _ti = null then
			_ediTIErrors.add("&lt;" &amp; self.TagImportCargoType &amp; "&gt; and &lt;" &amp; self.TagCargoNumber &amp; "&gt; within &lt;" &amp; parentTagSet &amp; "&gt; failed to identify a cargo item in JMT." );
		endif;
				
	endif;
	
	
	if _ti &lt;&gt; null then
		ediActionContext := null;
	else
		ediActionContext := _selectedBol;
		if ediActionContext = null and _bolStr &lt;&gt; null then
			ediActionContext := CM_BOL;
		endif;
	endif;
	
	statusType := _oneStopStatus;
	_ediAction := self.getEdiAction( _documentName, statusType, ediActionContext, false );
	if _ediAction = null then
		_ediTIErrors.add("&lt;" &amp; self.TagDocumentName &amp; "&gt; '" &amp; _documentName &amp; "' and &lt;" &amp; self.TagResponseStatusType &amp; "&gt; within &lt;" &amp; self.TagResponseHeader &amp; "&gt; do not identify a 'Customs Action' in JMT." );
	endif;
		
	
	return startSize = _ediTIErrors.size;
	
epilog

	delete allTis;
	delete bolSet;
	delete xmlSubElements;

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementResp" type="JadeXMLElement"/>
        <Parameter name="_ediTIErrors" type="HugeStringArray" usage="input"/>
        <Parameter name="_ediAction" type="CM_EDIAction" usage="output"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_documentName" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_selectedBol" type="CM_BOLIn" usage="output"/>
        <Parameter name="_oneStopStatus" type="String" usage="io"/>
        <Parameter name="_bolQty" type="Integer" usage="output"/>
        <Parameter name="_rawId" type="String" usage="output"/>
        <Parameter name="_cargoTypeObj" type="CM_CargoType" usage="output"/>
        <Parameter name="_bolStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
