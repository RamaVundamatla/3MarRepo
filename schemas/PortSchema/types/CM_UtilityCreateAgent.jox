    <JadeMethod name="utlCreateTBAContainer" id="75f8a6be-8a15-40ee-82a9-a4d114201230">
        <updating/>
        <source>utlCreateTBAContainer(_tbaController : CMIF_TBAContainer input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	pxyTI, newTI : CM_TrackedItem;
	theMoveController : CMIF_MoveController;
	theSlotController : CM_SlotController;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
//	app.myValCA.valISOType(pProxyISOType);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		create pxyTI as CM_Container transient;

		pxyTI.setPxyFromCMIF_TBAContainer(_tbaController);

		self.utlCreateTrackedItem(pxyTI, newTI,_passport);		

		if newTI &lt;&gt; null then
			self.myCreateAuditAgent.audCreateGeneric(newTI);
		endif;
		
		// ### Place in yard
		if _passport.noErrors 
		and newTI &lt;&gt; null then
		
			_tbaController.myTrackedItem := newTI;
			
			create theMoveController transient;
			theMoveController.setMyTrackedItem(newTI);
			theMoveController.setMyToPrimaryLocation(_tbaController.myLocationSource);
			theMoveController.setMoveMode(REAL_MODE);	
			theMoveController.isSystemMove := true;
			
			app.myUtilityUA.utlUpdateMoveTrackedItem(theMoveController, _passport);
			app.myEventManager.createSingleObjInfoNoteEvt(newTI.myVoyage,newTI.myTerminal.getTerminalEvent(Event_TBA_Create), newTI);
	
			if _tbaController.myLocationTarget.isKindOf(CM_SlotController) then
				theSlotController := _tbaController.myLocationTarget.CM_SlotController;
			endif;
			// ### Plan to ship
			if _passport.noErrors 
			and _tbaController.planContainer 
			and theSlotController &lt;&gt; null then
			
				delete theMoveController;
				create theMoveController transient;
				theMoveController.setMyTrackedItem(newTI);
				theMoveController.setMyToPrimaryLocation(_tbaController.myLocationTarget);
				theMoveController.setMoveMode(PLANNING_MODE);	
				theMoveController.isSystemMove := true;
				theMoveController.mySlotRequest := theSlotController.mySlotRequestLoad;	
				
				if theMoveController.mySlotRequest &lt;&gt; null then
					theMoveController.setMyWorkListEntry(theMoveController.mySlotRequest.allWorkListEntries.first);
					if theMoveController.myWorkListEntry &lt;&gt; null then
						app.myUtilityUA.utlUpdateWLEAssignTI(theMoveController, _passport);
					endif;
				endif;
			
			endif;
		endif;
		
	endif;
epilog
//	delete pxyTI;
	delete theMoveController;
end;</source>
        <Parameter name="_tbaController" type="CMIF_TBAContainer" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateTCPConnectionDetails" id="1188342f-aa04-482a-b1f3-94d7194e032c">
