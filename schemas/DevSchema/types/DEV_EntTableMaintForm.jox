    <JadeMethod name="btnDefExclOne_click" id="724003b9-11ce-4fb4-933b-149aa0731c24">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDefExclOne_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if tblDef.row &gt; 1 and tblDef.row &lt;= tblDef.rows then
		tblDef.deleteRow(tblDef.row);
	endif;
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
