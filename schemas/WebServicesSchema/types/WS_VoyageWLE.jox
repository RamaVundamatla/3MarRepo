    <JadeMethod name="setProxyFromObject" id="0e916ebd-2eeb-4111-8136-a83c35f0cd24">
        <updating/>
        <source>setProxyFromObject(_wle: CM_VoyageWLE) updating;
/*

Date				Who		Reason
28 November 2016	cnwer1	Initial creation TFS 2732
19 November 2021	jldzm1	TFS 52028 Work hold jobs in handheld app

*/

vars
	targetLC : CM_LocationsController;
	voyage : CM_Voyage;
	location : String;
	foundHeight : Integer;
begin
	inheritMethod(_wle);
	
	if _wle = null then
		return;
	endif;
	
	if _wle.myTrackedItem &lt;&gt; null then
		self.cargoUid := _wle.myTrackedItem.getOidString();	// tfs 52028
		self.cargoID := _wle.myTrackedItem.id;				// tfs 52028
	endif;
	
	self.isDischarge := _wle.isReceipt;
	self.jobID := _wle.job.id;
	
	voyage :=_wle.getVoyage();
	if voyage &lt;&gt; null then
		self.voyageCode := voyage.code;
	endif;
	
	targetLC:= _wle.getTargetLocation;
	if targetLC &lt;&gt; null then
		if self.isDischarge then
			self.targetLocationID := targetLC.getFullId();
		else
			self.targetLocationID := targetLC.getStowageId(_wle.myTrackedItem);
		endif;
	endif;
	
	self.rtLetter:= _wle.getRTLetter();
	self.moveAmount :=_wle.getMoveAmountDisplay(true);
	
	if targetLC &lt;&gt; null then
		location := targetLC.getFullId();
	elseif _wle.status = WLE_PART_COMPLETE and _wle.locationTarget &lt;&gt; null then
		_wle.getMyTerminal.findLocationFromString(_wle.locationTarget,true,targetLC,foundHeight);
		location := _wle.locationTarget;
	endif;
	
	if location &lt;&gt; null then
		if (_wle.quantity &gt; 1) then
			if _wle.subSeqNum &lt;&gt; null and _wle.subSeqNum &lt;&gt; _wle.quantity then
				location := location &amp; " (" &amp; _wle.subSeqNum.asStringJMT &amp; ")";
			else
				location  := location &amp; " (" &amp; _wle.quantity.asStringJMT &amp; ")";
			endif;
		endif;
		self.locationDesc := location;		
	
	endif;
	
	//jlier1 TFS 53766 12/7/22
	if targetLC &lt;&gt; null and targetLC.isKindOf(CM_IrregularBlockController) and _wle.getMyTerminal.getAutoPlanAllowFullGCArea then
		self.plannedWarehouseArea:=targetLC.getLocationArea();
	endif;
	
	
epilog

end;</source>
        <Parameter name="_wle" type="CM_VoyageWLE"/>
    </JadeMethod>
</Class>
