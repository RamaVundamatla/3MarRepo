    <JadeMethod name="utlMachineAcceptTask" id="6d4451a1-221c-4d38-8f2b-48b92e10ef89">
        <updating/>
        <source>utlMachineAcceptTask(_machine : CM_Machine input;_rtQueueTask : CM_RTQueueTask input; _passport : CM_Passport input) updating;
/*

Date		Who		Reason
09 May 2017	cnwer1	Initial creation TFS  VMT project refactor 995 MobileServerSchema CM_UtilityRTAgent:: utlAcceptSpecifiedTask

*/

vars

aTask : CM_RTQueueTask;
	rtEntry : CM_RTQueueEntry;
	ti : CM_TrackedItem;
begin
	self.initialiseActivity();

	if _rtQueueTask.isPlanOnPickupNoTarget then//cnwrd1 par 26734 CCMS 2014 plan on pickup
		_rtQueueTask.ti.autoPlanOnPickup( _rtQueueTask.myEntry.myWorkListEntry ,app.myPassport);//need to autoplan this box NOW. This should autoplan and create setdown &amp; other tasks as needed
		//now need to validate the new locations for the machine , par 27641 30.5.2011 cnwrd1
		ti := _rtQueueTask.ti;
		aTask := _rtQueueTask.getNextMachineTask();
		
		_machine.validateForMove( aTask.targetLocation, ti,true);
		
		if _passport.hasErrors() then
			return;
		endif;
	endif; //should still validate below
	

	
	self.utlChangeTaskStatus(_rtQueueTask, _machine, TASK_ACCEPTED, _passport);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	//CCMS 1025 change the setdown location if needs to be changed

	self.utlAutoResequenceOnPickup(_machine,_rtQueueTask.myEntry,app.myPassport);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	if _machine.machineStatus &lt;&gt; STATUS_WORKING then
		if _machine.machineStatus = STATUS_IDLE then
			self.utlUpdateMachineStatus(_machine, STATUS_ASSIGNED, "", false, _passport);	
		endif;
		if _passport.hasErrors() then
			return;
		endif;
		self.utlUpdateMachineStatus(_machine, STATUS_WORKING, "", false, _passport);
		if _passport.hasErrors() then
			return;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineBestPickAssignTI" id="9e5e0c60-9c5e-4e53-9863-e4e4aa15ca68">
        <source>utlMachineBestPickAssignTI(_rtQueueTask : CM_RTQueueTask input ;
							_rtTandemTask  : CM_RTQueueTask input ;
							_machine : CM_Machine input; _passport : CM_Passport input);
/*

Date		Who		Reason
09 May 2017	cnwer1	Initial creation TFS 995 VMT project refactor moved from MobileServerSchema CM_UtilityRTAgent:: utlDoBestPickAssignTI
16 Sep 2021 jlier1	TFS 51580 - if best pick tandem try and use the box on top of the first selected
*/

vars

	ti, tandemTI,otherTI : CM_TrackedItem;
	mediator : CM_RTConnectMediator;
	ta		: CM_TerminalArea;
	agent: CM_YAAutoplanAgent;
	terminal : CM_Terminal;
	pickupTask : CM_RTQueueTask;
	lc		: CM_LocationsController;
	index 	: Integer;
	haveOtherTI : Boolean;
begin
	self.initialiseActivity();
	terminal := _rtQueueTask.getMyTerminal();

	agent := app.myYAAgent;
	if agent = null then
		app.initialiseForStartAutoPlan(_passport);
		agent := app.myYAAgent;
	endif;
	
	if agent = null then
		return;
	endif;
	
	ti := agent.sourceTIForBestPickDirector(_rtQueueTask);
	if ti = null then
		return;
	endif;
	app.setContinueCMExceptions(true); //set to true so we can clear errors if needed 
	self.utlMachineDirectorCheckTI(ti, _machine, _rtQueueTask, _passport);
	if _passport.hasErrors then 
		//check if there is another suitable - only likely if grid stack where access is both ends
		ti := agent.sourceTIForBestPickDirector(_rtQueueTask);
		haveOtherTI:=true;
		if ti &lt;&gt; null then
			app.myPassport.clearErrorsWarnings;
		endif;
	endif;
	//if still has errors can return 
	if _passport.hasErrors then 
		return;
	endif;
	
	// check if can find suitable tandem ti TFS 51580 jlier1 14/9/21
	if _rtTandemTask &lt;&gt; null and _machine.isTandemLift and _rtTandemTask.checkAssignBestPickTIToWLE  then
		//check if the container underneath is suitable
		lc:=ti.myPrimaryActualLocation;
		if lc &lt;&gt; null and lc.isKindOf(CM_GridController) then
			index:=lc.allTrackedItems.indexOf(ti);
			if index &gt; 1 then
				tandemTI:=lc.allTrackedItems[index-1];
				if tandemTI &lt;&gt; null then	
					//check suitable
					self.utlMachineDirectorCheckTI(tandemTI, _machine, _rtTandemTask, _passport);
					if _passport.hasErrors then
						tandemTI:=null;
						app.myPassport.clearErrorsWarnings;
					endif;
				endif;
			endif;
		endif;
		if tandemTI = null and not haveOtherTI then
			//potentinally there might be another accessable container lets check
			otherTI := agent.sourceTIForBestPickDirector(_rtQueueTask);
			if otherTI &lt;&gt; null and otherTI &lt;&gt; ti then
				//check if this one is suitable for the tandem if so use that
				lc:=ti.myPrimaryActualLocation;
				if lc &lt;&gt; null and lc.isKindOf(CM_GridController) then
					index:=lc.allTrackedItems.indexOf(ti);
					if index &gt; 1 then
						tandemTI:=lc.allTrackedItems[index-1];
						if tandemTI &lt;&gt; null then	
						//check suitable
						self.utlMachineDirectorCheckTI(tandemTI, _machine, _rtTandemTask, _passport);
							if _passport.hasErrors then
								tandemTI:=null;
								app.myPassport.clearErrorsWarnings;
							endif;
						endif;
					endif;		
				endif;	
				if tandemTI &lt;&gt; null then
					ti:=otherTI;
				endif;
			endif;
		endif;
		
	endif;
	app.setContinueCMExceptions(false);

	self.utlMachineDirectorCheckTI(ti, _machine, _rtQueueTask, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	//------------------
	//Perform the relationship magic.
	//Update the director task with the TI
	//----------------
	_rtQueueTask.addTIToDirectorTaskForBP(ti,terminal);
	if _passport.hasErrors then
		return;
	endif;
	//----------------
	//Convert it to a assigned move task for this machine
	//----------------
	_rtQueueTask.myEntry.convertDirectorTaskToMove(_rtQueueTask, true,_passport);
	
	//----------------
	//Reset the allocated TI reference to null on machine
	//----------------
	_machine.nextAllocatedDirectorTI := null;

	if tandemTI &lt;&gt; null then
		self.utlMachineDirectorConvert(_rtTandemTask, _machine,tandemTI , _passport);
	endif;
	
epilog
	
end;</source>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_rtTandemTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineCancelDirectorTask" id="232cf3ce-33aa-445d-8c29-d9a95228905f">
        <updating/>
        <source>utlMachineCancelDirectorTask(	_rtQueueTask : CM_RTQueueTask input;
								_machine 	: CM_Machine input;
								_passport : CM_Passport  input) updating;
/*

Date		Who		Reason
09 May 2017	cnwer1	Initial creation TFS  TFS 995 VMT project refactor moved from MobileServerSchema CM_UtilityRTAgent:: utlCancelDirectorWithTITask

*/

vars

	invalidTask 	: Boolean;
	entry 			: CM_RTQueueEntry;
	wle					: CM_WorkListEntry;
	lMoveControl		: CMIF_MoveController;
	theTI				: CM_TrackedItem;
begin	
	self.initialiseActivity();
	
	
	on Exception do app.handleDeletedObject(exception, _rtQueueTask, invalidTask);
	
	exclusiveLock(_rtQueueTask);
	if invalidTask then
		return;
	endif;
	
	entry := _rtQueueTask.myEntry;
	exclusiveLock(entry);
	wle := entry.myWorkListEntry;
	theTI := _rtQueueTask.ti;
	// here we want to undo all the stuff we did when we picked and assigned a TI - see utlDoBestPickAssignTI
	_rtQueueTask.setStatusUnactioned;
	_rtQueueTask.getNextMachineTask.setStatusUnactioned;
	

	create lMoveControl transient;
	lMoveControl.setMoveMode(QUEUE_MODE);
	lMoveControl.setMyTrackedItem(theTI);
	lMoveControl.setMyWorkListEntry(wle);	
	lMoveControl.setMyMachine( _machine);
	lMoveControl.isDirectorWithTIUndo := true;
	self.utlUpdateMoveTIUndo(lMoveControl, _passport);	
	
	self.utlMachineAcceptTask( _machine , entry.allTasks.first, _passport);

epilog
	delete lMoveControl;
end;</source>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineCheckUpdateTarget" id="df341e6a-3682-4847-99cc-0fee0dc6eee4">
        <source>utlMachineCheckUpdateTarget(_rtTask : CM_RTQueueTask input;
							_trackedItem : CM_TrackedItem;
							_locationStr : String; 
							_validateMachineTypeGroups : Boolean;
							_swapping : Boolean;									// PAR #33427
							_passport : CM_Passport) : CM_LocationsController;
/*

Date		Who		Reason
09 May 2017	cnwer1	Initial creation TFS 995 mobileServerSchema CM_UtilityRTAgent::  utlValAndUpdateTargetLocation
30 Oct 2023 jlier1 TFS 60822 - was annoyed by double up of error messages
*/

vars
	terminal 	: CM_Terminal;
	location	: CM_LocationsController;
	foundHeight	: Integer;
	moveController : CMIF_MoveController;
	relatedQE	: CM_RTQueueEntry;
	machineConfig : CM_RTVehicleConfig;
	moveTask 	: CM_RTQueueTask;
	machine		: CM_Machine;
	currentWarnings : ObjectSet;
	warning : CM_Error;
begin
	self.initialiseActivity();
	
	if _locationStr = null then
		app.raiseCMException(Input_required_field_LocnFld ,null, null); // cnwdb2	PAR 35364
		return null;
	endif;
	
	terminal:=_rtTask.getMyTerminal();
	
	terminal.findLocationFromString(_locationStr, false, location, foundHeight);
	
	if _rtTask.isUPSPWagon() then			// 7/4/17 MAP TFS3927 under UPSP, location codes change dynamically according to tracked items loaded so far
		location := _rtTask.targetLocation;	// an empty wagon simply has location 1, preventing loading of any container other than leftmost position
	endif;

	if location = null then
		app.raiseCMException1(Err_LocationNotFound, _locationStr ,null, null);
		return null;
	endif;
	
	if _rtTask &lt;&gt; null and _validateMachineTypeGroups then
		if location = _rtTask.targetLocation then
			return null;
		endif;
		relatedQE := _rtTask.myEntry.getNextRelatedEntry;
		if relatedQE &lt;&gt; null then
		   	if location.isKindOf(CM_MachineController) then
				machine:=location.CM_MachineController.myMachine;
				if relatedQE.machineTypeGroup = MACHINETYPEGRP_IMV then
					//epr par 35702 9/3/15
			//		if _trackedItem &lt;&gt; null and _trackedItem.myCargoType.isBreakBulkMulti or _trackedItem.myCargoType.isBulkMulti then
					if _trackedItem &lt;&gt; null and ( _trackedItem.myCargoType.isBreakBulkMulti or _trackedItem.myCargoType.isBulkMulti ) then	//22 Apr 2020	NDL	TFS 49174/48549
						moveTask:=_rtTask.myEntry.getNextEntryFirstMoveTask;
						if moveTask &lt;&gt; null and moveTask.myMachine &lt;&gt; null and moveTask.myMachine &lt;&gt;  location.CM_MachineController.myMachine then
							app.raiseCMException2(Machi_not_allow_chang_targe_lo,_rtTask.targetLocationId,location.getFullId,  null, null);
							return null;
						endif;
					endif;
					machine.validateForMove(location,_trackedItem,true);
					_rtTask.setTargetLocation(location);
					return location;
				endif;
				app.raiseCMException(Task_move_task_type_must_move_, null, null);
				return null;
			endif;
			if relatedQE.machineTypeGroup = MACHINETYPEGRP_IMV then
				app.raiseCMException(IMV_Must_entered, null, null);
				return null;
			endif;
		endif;
	endif;
	
	//epr par 32307 21/8/13
	machineConfig := terminal.getRTVehicleConfigForObject(_rtTask.myMachine);
	//cnwrd1 par 31620 - if machine is not allowed to change target location lets validate that here.
	if machineConfig &lt;&gt; null and
		//location &lt;&gt; _rtTask.targetLocation			//- 11/12/2014 cnwma1 PAR #35335
		location.getFullId &lt;&gt; _rtTask.targetLocationId  //+ 11/12/2014 cnwma1 PAR #35335 
		and not location.isYardInterchangeAreaLocation
		and app.isRTApp 
		and _rtTask.isSetDown 		
		and not _swapping												// PAR #33427
		and not _rtTask.isOverstowTask and
			not (_rtTask.myEntry.isMachineInitiatedMove and _rtTask.targetLocationId = null) then //epr TFS 6846 8/9/17
			if not machineConfig.allowChangeSetdown and not location.isVoyageController then
				app.raiseCMException2(Machi_not_allow_chang_targe_lo,_rtTask.targetLocation.getFullId,location.getFullId,  null, null);
			endif;
	endif;
	
	create moveController transient;
	moveController.setMoveMode(REAL_MODE);
	moveController.isRadioTelemetryMove := true;
	moveController.setMyTrackedItem(_trackedItem);
	moveController.setMyToPrimaryLocation(location);
	moveController.updatePassportAndUser(_passport);
	moveController.setMyMachine( _rtTask.myMachine );	//24 Mar 2020	NDL	TFS 48893 - So overstow checking can know what machine its got

	create currentWarnings transient;
	app.myPassport.allWarnings.copy(currentWarnings);
	location.validateMoveTo(moveController);
	
	//remove any new warnings because when the cargo gets moved this code gets done again resulting in double up of warnings
	foreach warning in app.myPassport.allWarnings discreteLock do 
		if not currentWarnings.includes(warning) then
			delete warning;
		endif;
	endforeach;
	
	if _rtTask &lt;&gt; null then
		moveController.setMoveMode(QUEUE_MODE);
		_rtTask.changeTargetLocation(moveController,false);
	endif;
	
	return location;
	
epilog
	delete moveController;
	delete currentWarnings;
end;</source>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_locationStr" type="String"/>
        <Parameter name="_validateMachineTypeGroups" type="Boolean"/>
        <Parameter name="_swapping" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="utlMachineCranePickup" id="10000f31-c2a7-4757-a951-d054aa1a39a8">
        <source>utlMachineCranePickup(_ti,
						_twinTi : CM_TrackedItem input;
						_machine : CM_Machine input;
						_acceptTask : Boolean; 
						_doPickup : Boolean; 
						_passport : CM_Passport input);
/*

Date		Who		Reason
11 May 2017	cnwer1	Initial creation TFS 995 refactored from MobileServerSchema::CM_TrxControlRTAgent trxActionCranePickup

*/

vars
	task,
	tiTask,
	twinTask 		: CM_RTQueueTask;
begin
	self.initialiseActivity();
	
	if _twinTi = null then
		// Find or create task for a single TI
		task:=app.myUtilityUA.utlMachineCranePickupTask(_ti, _machine, _passport);
	else
		// This is a twin, so do both at once, because we need to very they can be planned to 
		// twinnable locations
		app.myUtilityUA.utlMachineCranePickupTwinTask(_machine,
											 _ti,
											 _twinTi,
											 tiTask,
											 twinTask,
											 _passport);
	endif;		
		
	if _passport.hasErrors() then
		return;
	endif;

	// Accept the task(s) if required
	if _acceptTask then
		//epr par 35702 27/2/15 CCMS 1457
		if task &lt;&gt; null and task.taskType = TASK_BREAKBULK then
			app.myUtilityUA.utlMachineValidateAcceptTask(_machine,task,_passport);
		else
		
			_machine.executeAcceptTasks(null);
			
		endif;
		if _passport.hasErrors() then
			return;
		endif;
	endif;

	// Do the pickup if required
	if _doPickup then
		app.myUtilityUA.utlMachinePickupTask(_machine,null,null,null);
		if _passport.hasErrors() then
			return;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_twinTi" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_acceptTask" type="Boolean"/>
        <Parameter name="_doPickup" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineCranePickupTask" id="7a3f5a15-5f3a-48a2-95eb-b3851fe78141">
        <source>utlMachineCranePickupTask(_ti : CM_TrackedItem input;
					 _machine : CM_Machine input;
					 _passport : CM_Passport input) : CM_RTQueueTask;
/*

Date		Who		Reason
10 May 2017	cnwer1	Initial creation TFS 995 refactor moved from MobileServerSchema::CM_UtilityRTAgent ::utlActionCranePickup
14 Jan 2020	jlgka1	TFS 48284 	PRP PRP - Vehicle App unable to discharge cargo from vessel. (Re-use NWNP depends on code path)
*/

vars

	currentLocation	: CM_LocationsController;
	itsAvailable,
	nwnp			: Boolean;
	task,
	queueTask		: CM_RTQueueTask;
	job				: CM_VoyageJob;
	queue			: CM_RadioTelemetryQueue;
	alert			: CM_SystemAlert;
	messageLogger 	: CM_MachineRTQueueEntryLogger;
	wle 			: CM_WorkListEntry;
	jobId 			: String;
	state 			: Integer;
	queuedLoc 		: CM_LocationsController;
begin
	self.initialiseActivity();
	
	exclusiveLock(_ti);  //cnwjo3 par 19837, placing lock earlier
	self.raiseExceptionIfNull(_machine,app.getErrorString(Machine));
	self.raiseExceptionIfNull(_ti, app.getErrorString(Cargo));
	
	app.myValUA.valCargoForCranePickup(_ti,_machine.myPrimaryQueue,job,state,queuedLoc, true);
	
	if _passport.hasErrors then
		return null;
	endif;

	// ----------------------------------------------------------------------------------
	// If we get to here, then do the pickup
	// ----------------------------------------------------------------------------------
	queue := _machine.myPrimaryQueue;		
	task := _ti.locateTaskInQueue(queue);
	
		
	// Still no task found
	if task = null then		
		
		app.myUtilityUA.utlDischargeCargoAutoPlan(_machine,_ti,0,0,job,wle,_passport);
		
		if _ti.getPrimaryLocation(QUEUE_MODE) = null then
				if job &lt;&gt; null then
					jobId:=job.jobId;
				endif;
				// Couldn't autoplan!
				create alert;
				alert.details := app.getErrorString1(ERR_NO_AUTOPLAN, _ti.id.trimBlanks &amp; " in Discharge Job " &amp; jobId);
				alert.setSeverity(SEVERE_INFO);
				alert.add;

				app.raiseCMException1(ERR_NO_AUTOPLAN, _ti.id.trimBlanks &amp; " in Discharge Job " &amp; jobId, null, null);
				return null;
			endif;
		//----------------
		//Reattempt to locate task
		//----------------
		task := _ti.locateTaskInQueue(queue);
		if task = null then
			// Still could NOT locate the TI in the Queue....
			create alert;
			alert.details := app.getErrorString2(ERR_NOTASKOFTYPE, TASK_PICKUP_DESC &amp; " for " &amp; _ti.id.trimBlanks, queue.id.trimBlanks);
			alert.setSeverity(SEVERE_INFO);
			alert.add;
				
			app.raiseCMException2(ERR_NOTASKOFTYPE, TASK_PICKUP_DESC &amp; " for " &amp; _ti.id.trimBlanks, queue.id.trimBlanks, null, null);
			return null;
		endif;
	endif;
	
	exclusiveLock(task);  //cnwjo3 par 19837, locking task so its Status cannot be updated until this method exits
	
	app.myValUA.valRTTaskForCranePickup(task,_ti,_machine);	
	
	if _passport.hasErrors then
		return null;
	endif;
	
	// 27/2/15 par 35702 CCMS 2457 if task type don't offer to machine just return task method calling this will then do break bulk accept stuff
	if task.taskType = TASK_BREAKBULK then
		return task;
	endif;
	
	// Allocate the task to this machine
	_machine.checkAndResetStatus();
	task.setMachine(_machine);
	_machine.workingInQueue := task.queue;
	
	task.setStatus(TASK_OFFERED);
	return task;
epilog
	delete messageLogger;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="utlMachineCranePickupTwinTask" id="a4cb5536-ad4a-4e24-b29a-2cbee66c8de2">
        <source>utlMachineCranePickupTwinTask(	_machine : CM_Machine input;
							_ti,
							_twinTI: CM_TrackedItem input;
							_tiTask,
							_twinTask : CM_RTQueueTask output;
							_passport : CM_Passport input);
/*

Purpose:			Action a pickup of the specified container from a crane - will validate the container,
					auto plan it, create a queue entry for it, and assign it to the passed in machine
					(Code based on CM_TeklogixNarrow methods validateCranePickup and receiveCranePickup)


Date		Who		Reason
10 May 2017	cnwer1	Initial creation TFS 995 refactor moved method from MobileServerSchema::CM_UtilityRTAgent ::utlActionCranePickupTwin
14 Jan 2020	jlgka1	TFS 48284 	PRP PRP - Vehicle App unable to discharge cargo from vessel. (Re-use NWNP depends on code path)
*/

vars
	laneLC,
	twinLaneLC,
	tiQdLoc,
	twinQdLoc	: CM_LocationsController;	
	job,
	twinJob		: CM_VoyageJob;
	crane,
	twinCrane	: CM_Crane;
	queue		: CM_RadioTelemetryQueue;
	
	alert		: CM_SystemAlert;
	
	wle,
	twinWLE 	: CM_WorkListEntry;	
	tiState,
	twinState	: Integer;
	task 		: CM_RTQueueTask;
begin
	self.initialiseActivity();

	
	// Make sure TI is a DISCHARGE TI, this means that its either ON the ship, OR
	// Sitting in a locations controller that is part of a CTA. (it can be moved here
	// by the code below, when offered to a machine (who rejects it, and leaves the TI
	// there).
	self.raiseExceptionIfNull(_machine,app.getErrorString(Machine));
	self.raiseExceptionIfNull(_ti, app.getErrorString(Cargo));
	
	if _ti = null or _twinTI = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name, "Can not twin plan with only one container",null,null);
	endif;
	
	// Get the queue
	queue := _machine.myPrimaryQueue;
	
	//check it is in the appropriate place to plan from ship to yard and doesn't already have a queue entry
	app.myValUA.valCargoForCranePickup(_ti,queue,job,tiState,tiQdLoc, false);
	if app.myPassport.hasErrors then
		return;
	endif;
	
	app.myValUA.valCargoForCranePickup(_twinTI,queue,twinJob,twinState,twinQdLoc, false);
	if app.myPassport.hasErrors then
		return;
	endif;


	// if there is any planned then queue it 
	if tiState = PLANNING_MODE then
		_ti.doQueuedMoveToPlan(null,_passport);
		if app.myPassport.hasErrors then
			return;
		endif;
	endif;
	
	// epr 29930 20/8/12 only get the target for the task
	task := _ti.locateTaskInQueue(queue);
	if task &lt;&gt; null then							// PAR #30853
		tiQdLoc:=task.targetLocation;
	endif;											// PAR #30853
	
	if twinState = PLANNING_MODE then
		_twinTI.doQueuedMoveToPlan(null,_passport);// ### TFS 51988 17SEP2021 NAVAB1
		if app.myPassport.hasErrors then
			return;
		endif;
	endif;
	// epr 29930 20/8/12 only get the target for the task
	task := _twinTI.locateTaskInQueue(queue);
	if task &lt;&gt; null then							// PAR #30853
		twinQdLoc:=task.targetLocation;
	endif;											// PAR #30853
	
	//epr par 19097 make sure can pickup if the containers are already planned or queued
	app.myValUA.valTwinCargoForCranePickup(_ti,_twinTI,tiQdLoc,twinQdLoc);
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	// Set up the default lane controller(s)
	crane := job.getJobCrane();
	if crane = null then
		laneLC := null;
	else
		// OK, supply a default lane
		laneLC := crane.transferArea.getFirstAvailableDischLane();
	endif;
	
	// Twin TI Job will normally be the same one, but not always - PAR #19141
	if twinJob = job then
		twinCrane := crane;
		twinLaneLC := laneLC;
	else
		twinCrane := twinJob.getJobCrane();
		if twinCrane = null then
			twinLaneLC := null;
		else
			// OK, supply a default lane
			twinLaneLC := twinCrane.transferArea.getFirstAvailableDischLane();
		endif;
	endif;

	// Need to return an error if there is no default lane
	if laneLC = null then
		create alert;
		alert.details := app.getErrorString2(ERR_INV_LANE, job.craneId, "setup");
		alert.setSeverity(SEVERE_INFO);
		alert.add;

		app.raiseCMException2(ERR_INV_LANE, job.craneId, "setup", null, null);
		return;
	endif;
	
	if twinLaneLC = null then
		create alert;
		alert.details := app.getErrorString2(ERR_INV_LANE, twinJob.craneId, "setup");
		alert.setSeverity(SEVERE_INFO);
		alert.add;

		app.raiseCMException2(ERR_INV_LANE, twinJob.craneId, "setup", null, null);
		return;
	endif;
	
	//at this stage both boxes should be either queued or not even planned
	//if they are both queue then get the tasks and return 
	if _ti.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null and
		_twinTI.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null then
		_tiTask:=_ti.locateTaskInQueue(queue);
		_twinTask:=_twinTI.locateTaskInQueue(queue);
		
		app.myValUA.valMachineAcceptTask(_machine,_tiTask,_twinTask,false,true,true);
		if app.myPassport.hasErrors then
			return;
		endif;
	
	else
	
		// ----------------------------------------------------------------------------------
		// If we get to here, then do the pickup
		// ----------------------------------------------------------------------------------	
		
		// Lock the tis
		exclusiveLock(_ti);
		exclusiveLock(_twinTI);
		
		wle := job.getWLEForTI(_ti);
		twinWLE := twinJob.getWLEForTI(_twinTI);
		
		if wle = null or twinWLE = null then
			app.raiseCMException(UNEXPECTED_PROGRAM_ERROR,"Can not twin plan one or both containers do not have a work list entry for the job",null);
			return;
		endif;
		
		app.myUtilityUA.utlUpdateAutoplanTwin(_ti,
											  _twinTI,
											  job,
											  twinJob,
											  null,
											  null,
											  QUEUE_MODE,
											  app.myPassport);
		
		if _ti.myPrimaryQueuedLocation = null or _twinTI.myPrimaryQueuedLocation = null then
			app.raiseCMException2(ERR_TWIN_PLAN_FAILED, _ti.id, _twinTI.id, null, _ti);
			return;
		endif;
		
		if app.myPassport.hasErrors then
			return;
		endif;
				
		_tiTask:=_ti.locateTaskInQueue(wle.queue);
		_twinTask:=_twinTI.locateTaskInQueue(twinWLE.queue);
		
		// Update the Tasks' location with the ref of the new lane. (if its on the ship)
		if _tiTask.sourceLocation.isKindOf(CM_SlotController) then
			_tiTask.setSourceLocation( laneLC);
		endif;
		
		app.myValUA.valRTTaskForCranePickup(_tiTask,_ti,_machine);
		
		if app.myPassport.hasErrors then
			return;
		endif;
		
		// Update the Tasks' location with the ref of the new lane. (if its on the ship)
		if _twinTask.sourceLocation.isKindOf(CM_SlotController) then
			_twinTask.setSourceLocation( twinLaneLC);
		endif;
		
		app.myValUA.valRTTaskForCranePickup(_twinTask,_twinTI,_machine);
		
		if app.myPassport.hasErrors then
			return;
		endif;
		
		//par 26240 epr 25/11/10
		app.myValUA.valMachineAcceptTask(_machine,_tiTask,_twinTask,false,false,true);
		if app.myPassport.hasErrors then
			return;
		endif;
	
	endif;
	
	_ti.receiveFromShip(crane, laneLC,null,null,null,  _passport); //epr par 35702 3/3/15 
	// Allocate the task to this machine
	_machine.checkAndResetStatus();
	_tiTask.setMachine(_machine);
	_tiTask.machine.workingInQueue := _tiTask.queue;
	_tiTask.setStatus(TASK_OFFERED);
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	_twinTI.receiveFromShip(crane, twinLaneLC,null,null, null, _passport); // ### TFS 51988 17SEP2021 NAVAB1
	// Allocate the task to this machine
	_machine.checkAndResetStatus();
	_twinTask.setMachine(_machine);
	_twinTask.machine.workingInQueue := _twinTask.queue;
	_twinTask.setStatus(TASK_OFFERED);

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_twinTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_tiTask" type="CM_RTQueueTask" usage="output"/>
        <Parameter name="_twinTask" type="CM_RTQueueTask" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineCreateInitiatedMove" id="c59826d6-c954-4f13-b37f-ab36c09c5aa4">
        <updating/>
        <source>utlMachineCreateInitiatedMove(	_ti 		  : CM_TrackedItem input;
								_twinTI 	  : CM_TrackedItem input;
								_machine      : CM_Machine input;						  
								_moveQuantity : Integer;
								_moveWeight   : Decimal;
								_autoplan     : Boolean;
								_overstowMove : Boolean;
								_passport     : CM_Passport input) : CM_RTQueueTask updating;
/*

Date		Who		Reason
16 May 2017	cnwer1	Initial creation TFS 995 16/5/17
15 Aug 2017 jlger1	TFS 5787 some changes to handle twin driver initiated moves
14 May 2019 cnwma1	Bug 44062: JMT - Vehicle App - Tandem Driver Move
10 Jan 2020 jlgka1	TFS 48160: Web Apps - Tandem mode not working on driver mode (Auto planning failed). 
22 Jan 2020 jlgka1	TFS 47394: Web Apps - To be able to switch error message for twin lift and tandem lift as we use only one error code for both. 
21 Apr 2020 cnwma1  Bug 48757: SNO - Power disconnection
08 Jul 2021	navdap1	TFS 51409 PNL Queued Moves in Driver Mode
12 Dec 2022	navmk20	Bug 55781: PNL - Unable to move over stowed &amp; connected queued reefers - Vehicle Apps
*/

vars
	entry			: CM_RTQueueEntry;
	newBBTask,
	twinTask, 
	task			: CM_RTQueueTask;
	invalidTI		: Boolean;
	terminal		: CM_Terminal;
	machineConfig,
	terminalConfig	: CM_RTVehicleConfig;
	cmifAutoPlan	: CMIF_YAAutoPlanNormal;
	crit			: CM_YARTVConfigCriteria;
	moveLocn,
	twinMoveLocn 	: CM_LocationsController;
	moveController	: CMIF_MoveController;
	messageLogger 	: CM_MachineRTQueueEntryLogger;
	tandemLocId		: String;
	alreadyQueued	: Boolean;			// TFS 51409
	pinStatus		: Integer;			// TFS 51409
	twinPinStatus	: Integer;			// TFS 51409
begin	

	// Start by locking the Tracked Item		
	on Exception do app.handleDeletedObject(exception, _ti, invalidTI);
	self.exclusiveLock(_ti);
	
	if invalidTI then
		app.raiseCMException1(ERR_DEL_NOTFOUND, app.getErrorString(TrackedItem), null, null);
		return null;
	endif;
	on Exception do null; //12.12.2022 navmk20 TFS 55781
	// TFS 51409 moved these lines up so the queue check can use the machine RT config
	terminal	  := _machine.getMyTerminal();
	machineConfig := terminal.getRTVehicleConfigForObject(_machine);
	
	// First check that it is not already queued
	task := _ti.getQueueTask;
	//if task &lt;&gt; null then												// TFS 51409
	if task &lt;&gt; null and not machineConfig.allowNonRTQMoves then			// TFS 51409
		app.raiseCMException1(Tracked_item_already_queued, _ti.id, null, null);
		return null;
	endif;
	
	alreadyQueued := task &lt;&gt; null and machineConfig.allowNonRTQMoves;	// TFS 51409
	if _ti.myPinNo &lt;&gt; null then											// TFS 51409
		pinStatus := _ti.myPinNo.status;								// TFS 51409
	endif;																// TFS 51409
	if _twinTI &lt;&gt; null and _twinTI.myPinNo &lt;&gt; null then					// TFS 51409
		twinPinStatus := _twinTI.myPinNo.status;						// TFS 51409
	endif;																// TFS 51409
	
	// Then check that the machine is allowed to initiate new moves
	//epr TFS 5254 10/7/17 if this is an overstow manual move then we an create this without the config
	if not _overstowMove then
		if   not machineConfig.allowNonRTMoves then
			app.raiseCMException1(ERR_MACH_NO_INITIATE, _machine.id, null, null);
			return null;
		endif;
		// Check the TI against the terminal RT config criteria (if there are any)
		terminalConfig := terminal.getRTVehicleConfigForObject(terminal);
		if not terminalConfig.allCriteria.isEmpty then
			create cmifAutoPlan transient;
			cmifAutoPlan.attachTI(_ti);
			
			foreach crit in terminalConfig.allCriteria do
				if not crit.isCMIFAutoPlanDataMatch(cmifAutoPlan) then
					app.raiseCMException1(Item_failed_match_criteri, crit.getDescription(), null, null);
					return null;
				endif;
			endforeach;
			
			if _twinTI &lt;&gt; null then
				cmifAutoPlan.attachTI(_twinTI);
				foreach crit in terminalConfig.allCriteria do
					if not crit.isCMIFAutoPlanDataMatch(cmifAutoPlan) then
						app.raiseCMException1(Item_failed_match_criteri, crit.getDescription(), null, null);
						return null;
					endif;
				endforeach;
			endif;
		endif;
	endif;
	
	if _twinTI &lt;&gt; null then
		//check source locations can twin 
		if _machine.isTwinLift then            //14.05.2019 cnwma1 Bug #44062
			app.myValUA.valTwinCargoForCranePickup(_ti,_twinTI,_ti.myPrimaryActualLocation,_twinTI.myPrimaryActualLocation);
		
		elseif _machine.isTandemLift then      //14.05.2019 cnwma1 Bug #44062
			if _ti.myPrimaryActualLocation &lt;&gt; _twinTI.myPrimaryActualLocation  then
				if  _twinTI.myPrimaryActualLocation &lt;&gt; null then
					tandemLocId := _twinTI.myPrimaryActualLocation.getFullId;
				endif;
				app.raiseCMException4(Twin_lift_locations,"Tandem", _ti.myPrimaryActualLocation.getFullId, tandemLocId, "TANDEM Locations are different", null, null); //jlgka1 TFS 47394		
			endif;
		endif;
		
		if _passport.hasErrors then
			return null;
		endif;
	endif;
	
	if _autoplan then
	// Autoplan and queue the TI
		if _twinTI = null then
			moveLocn := app.autoPlanTiYA(terminal, null, _ti);												// PAR #26113, #26438		
		else
			if _machine.isTandemLift then																	//jlgka1 TFS 48160
				app.myYAAgent.autoPlanTandemTiYA(terminal, null, _ti, _twinTI, moveLocn, twinMoveLocn);		//jlgka1 TFS 48160		
			else
				app.myYAAgent.autoPlanTwinTi(terminal, null,  _ti, _twinTI);
				moveLocn     := app.myYAAgent.myCMIFYAAutoPlan.allFoundLCs.first;
				twinMoveLocn := app.myYAAgent.myLinkedYAAutoPlan.allFoundLCs.first;			
			endif;
		endif;
		if moveLocn = null then
			app.raiseCMException1(Failed_auto_plan, _ti.id, null,null);
			return null;
		endif;
		
		if _twinTI &lt;&gt; null and twinMoveLocn = null then
			app.raiseCMException1(Failed_auto_plan, _twinTI.id, null,null);
			return null;
		endif;
	else
		//jlier1 TFS 54516 11/8/22
		if _ti.myPrimaryPlannedLocation &lt;&gt; null then
			moveLocn:=_ti.myPrimaryPlannedLocation;
		endif;
	endif;
	
	
	
	// Create the RT Queue entry
	if not alreadyQueued then	
		//tfs 52869 jlier1 16/2/22
		if moveLocn = null and not machineConfig.allowChangeSetdown then
			app.raiseCMException(Failed_queue_location,null,null);
			return null;
		endif;	
		
		// TFS 51409
		create moveController transient;
		moveController.setMyTrackedItem(_ti);
		moveController.setMyToPrimaryLocation(moveLocn);
		moveController.setMoveMode(QUEUE_MODE);
		moveController.isRadioTelemetryMove := true;
		moveController.setMyMachine(_machine);
		moveController.isDriverInitiatedMove:=true;
		moveController.setQuantity(_moveQuantity);
		moveController.setWeight(_moveWeight);
		moveController.machineTypeGrp := _machine.getMachineTypeGroup.type; //epr TFS 6846 8/9/17
		
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		
		// TFS 51409 if the queued move above reset the pin status on the TI
		// reset it to 0 (this queued move is an internal one only, not an 
		// actual queued move)
		if _ti.myPinNo &lt;&gt; null and _ti.myPinNo.status = PIN_InProcess and pinStatus = PIN_Normal then
			_ti.myPinNo.updateStatus(PIN_Normal);
		endif;
		// TFS 51409 end of this bit

	endif;																// TFS 51409

	if _passport.hasErrors then
		return null;
	endif;
	
	// Check that the TI queued OK
	task := _ti.getQueueTask;
	if task = null then
		app.raiseCMException1(Failed_auto_plan, _ti.id, null, null);
		return null;
	endif;
	
	// Set the isMachineInitiatedMove on the created queue entry
	// Check that the machine can move the TI
	entry := task.myEntry;
	entry.setIsMachineInitiatedMove(true);
	
	if task.taskType = TASK_BREAKBULK then
		app.myUtilityUA.utlBreakBulkMasterAccept(task,newBBTask);
		if _passport.hasErrors then
			return null;
		endif;
		task:=newBBTask;
	endif;

	//if not _autoplan then								// TFS 51409
	if not _autoplan and not alreadyQueued then			
		if not _machine.myPrimaryQueue.isKindOf(CM_VoyageQueue) then //jlier1 JIRA #27015 23/12/24
			_machine.myPrimaryQueue.addQueueEntry(entry); // TFS 51409
			if newBBTask &lt;&gt; null then
				_machine.myPrimaryQueue.addQueueEntry(newBBTask.myEntry);
			endif;
		endif;
	endif;
	
	create messageLogger transient;
	if not task.queryMachineAssign(_machine, true, true, false, true, true,messageLogger) then
		//21.04.2020 cnwma1 #48757
		if messageLogger.allErrorCodesUsed.size = 1 and  messageLogger.allErrorCodesUsed.includes(MACH_LIFT_POWER) then
			app.raiseCMException2(MACH_LIFT_POWER, _machine.id, _ti.id,null ,null);
		else
			app.raiseCMException1(Suita_this_check_machi_area_ac, _machine.id, null, null);
		endif;
		return null;
	endif;
			
	// Accept the pickup task
	self.utlMachineAcceptTask(_machine, task, _passport);
	
	if _twinTI &lt;&gt; null then
		twinTask := _twinTI.getQueueTask();												// TFS 51409
		if twinTask &lt;&gt; null and not machineConfig.allowNonRTQMoves then					// TFS 51409
			app.raiseCMException1(Tracked_item_already_queued, _ti.id, null, null);		// TFS 51409
			return null;																// TFS 51409
		endif;																			// TFS 51409
		if twinTask = null then															// TFS 51409
			delete moveController;
			// Create the RT Queue entry
			create moveController transient;
			moveController.setMyTrackedItem(_twinTI);
			moveController.setMyToPrimaryLocation(twinMoveLocn);
			moveController.setMoveMode(QUEUE_MODE);
			moveController.isRadioTelemetryMove := true;
			moveController.setMyMachine(_machine);
			moveController.isDriverInitiatedMove:=true;
			moveController.setQuantity(_moveQuantity);
			moveController.setWeight(_moveWeight);
			moveController.machineTypeGrp := _machine.getMachineTypeGroup.type; //epr TFS 6846 8/9/17
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		endif;																			// TFS 51409
	
		if _passport.hasErrors then
			return null;
		endif;
		
			// Check that the TI queued OK
		twinTask := _twinTI.getQueueTask;
		if twinTask = null then
			app.raiseCMException1(Failed_auto_plan, _twinTI.id, null, null);
			return null;
		endif;
		
		// TFS 51409 again, with the twin lift TI, if the queue above changed the pin status
		// reset it to Normal here
		if _twinTI.myPinNo &lt;&gt; null and _twinTI.myPinNo.status = PIN_InProcess and twinPinStatus = PIN_Normal then
			_twinTI.myPinNo.updateStatus(PIN_Normal);
		endif;
		// TFS 51409 end of this bit
		
		// Set the isMachineInitiatedMove on the created queue entry
		// Check that the machine can move the TI
		entry := twinTask.myEntry;
		entry.setIsMachineInitiatedMove(true);
		if not _autoplan then
			if not _machine.myPrimaryQueue.isKindOf(CM_VoyageQueue) then //jlier1 JIRA #27015 23/12/24
				_machine.myPrimaryQueue.addQueueEntry(entry);
			endif;
		endif;
		if not twinTask.queryMachineAssign(_machine, true, true, false, true, true,messageLogger) then
			app.raiseCMException1(Suita_this_check_machi_area_ac, _machine.id, null, null);
			return null;
		endif;
		
		// Accept the pickup task
		self.utlMachineAcceptTask(_machine, twinTask, _passport);
	endif;
	
	if _passport.hasErrors then
		return null;
	endif;
	
	// And return the created pickup task for the caller
	return task;
	
	
epilog
	delete cmifAutoPlan;
	delete moveController;
	delete messageLogger;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_twinTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_moveQuantity" type="Integer"/>
        <Parameter name="_moveWeight" type="Decimal"/>
        <Parameter name="_autoplan" type="Boolean"/>
        <Parameter name="_overstowMove" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="utlMachineDirectorAssignCargo" id="f90e2490-c1be-4464-82cd-5bfe98237210">
        <source>utlMachineDirectorAssignCargo(	_ti 	 : CM_TrackedItem input;
							   _machine  : CM_Machine input;
							   _task 	 : CM_RTQueueTask input;
							   _passport : CM_Passport input) protected;
/*
Purpose:			Assign the passed in TI (which has already been allocated a queued location)
					to the passed in Director task
					
Date		Who		Reason
10 May 2017	cnwer1	Initial creation TFS 995  TFS 995 VMT project refactor moved from MobileServerSchema CM_UtilityRTAgent:: utlActionDirectorAssignAndMove
*/

vars
	wle				: CM_WorkListEntry;
	fm				: CM_FutureMoveQueued;
	lc				: CM_LocationsController;
begin
	self.raiseExceptionIfNull(_machine,app.getErrorString(Machine));
	self.raiseExceptionIfNull(_ti, app.getErrorString(Cargo));
	self.raiseExceptionIfNull(_task, "_task");
	
	if _task.taskType &lt;&gt; TASK_DIRECTOR then
		app.raiseCMException(ERR_DIRECTOR_CONVERT, null, null);
		return;
	endif;
	
	lc := _ti.myPrimaryQueuedLocation;
	
	if lc = null then
		app.raiseCMException1(ERR_TI_NO_QUEUELOCN, _ti.id, null, null);
		return;
	endif;
	
	// Update the target location of the director task from the TI before assigning it
	// to prevent single autoplanning from occurring
	_task.setTargetLocation( lc);
	
	// Assign container to Director task
	_task.addTIToDirectorTask(_ti);
	
	// PAR #25841 - Need to ensure WLE has reference to Queued Move
	wle := _task.myEntry.myWorkListEntry;
	if wle &lt;&gt; null and wle.myFutureMove = null then
		fm := _task.getFutureMoveForTI(_ti);
		if fm &lt;&gt; null then
			fm.setMyWorkListEntry(wle, false);
		endif;
	endif;		
	
	// And convert the task to a Move
	_ti.copyReleaseJobToTI(_task.myEntry.myWorkListEntry);
	
	// Remove the TI ref.  If we dont do this, then the TI gets unqueued before we get a chance to work it
	_task.ti := null;	
	
	// Mark the Director task as complete
	_task.setStatusComplete();
	
	//22 Apr 2020	NDL	TFS 49174/48549 - Conversion of Twin Lift Director task for multi machine move still need to sort out the other downstream related legs.
	_task.completeReplacedNextRelated();  // I.e. director task of FL-&gt;IMV
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineDirectorCheckTI" id="098ac419-6283-4140-a253-64c2ca7c4d4d">
        <source>utlMachineDirectorCheckTI(_ti : CM_TrackedItem input;
						_machine : CM_Machine input;
						_task : CM_RTQueueTask input;
						_passport : CM_Passport input);
/*

Date		Who		Reason
09 May 2017	cnwer1	Initial creation TFS 995 VMT project refactor   MobileServerSchema CM_UtilityRTAgent:: utlActionDirectorCheckTI

*/

vars

	allocatedTI			: CM_TrackedItem;
	dTask				: CM_RTQueueTask;
	isGood,
	isSourceLocationOK	: Boolean;
	tmpLC				: CM_LocationsController;
	yc1,
	yc2					: CM_YardController;
	sb1,
	sb2					: CM_SubBlockStack;
	alert				: CM_SystemAlert;
	request				: CM_Request;
	parentObject		: CM_Object;
begin
	self.raiseExceptionIfNull(_ti, "_ti");
	self.raiseExceptionIfNull(_machine, "_machine");
	self.raiseExceptionIfNull(_task, "_task");
	
	if _task.taskType &lt;&gt; TASK_DIRECTOR then
		app.raiseCMException(ERR_DIRECTOR_CONVERT, null, null);
		return;
	endif;
	
	//-------------------------
	//Test for an allocated TI
	//-------------------------
	exclusiveLock(_machine);
	allocatedTI := _machine.nextAllocatedDirectorTI;

	if allocatedTI &lt;&gt; null then
    	if allocatedTI &lt;&gt; _ti then
			dTask := allocatedTI.getQueueTask;
			if dTask = null then
				//-----------------
				//Could not locate a task for this TI in the queue
				//Kill him!
				//-----------------
				_machine.nextAllocatedDirectorTI := null;
				allocatedTI := null;
			else				
				//------------------
				//Wrong TI!!!
				//------------------
				app.setContinueCMExceptions(false);
				app.raiseCMException1(ERR_DIRECTOR_ASSIGN, allocatedTI.id.trimRight, null, null);
				return;
			endif;
    	endif;
	endif;
	//-----------------
	//Is TI valid for task/Job?
	//-----------------
	//-------------------
	//Is the TI is the area we are hunting from?
	//-------------------
	if not _task.sourceIncludesTI(_ti, REAL_MODE ) then	// 23099 handle gridded area source
		isSourceLocationOK := false;
		tmpLC := _ti.getPrimaryLocation(REAL_MODE);
		if tmpLC = _task.sourceLocation then
			isSourceLocationOK := true;
		else
			if tmpLC.isKindOf(CM_YardController) and _task.sourceLocation.isKindOf(CM_YardController) then
				yc1 := tmpLC.CM_YardController;
				yc2 := _task.sourceLocation.CM_YardController;
				if yc1.myTerminalArea.isKindOf(CM_SubBlockStack) and yc2.myTerminalArea.isKindOf(CM_SubBlockStack) then
					sb1 := yc1.myTerminalArea.CM_SubBlockStack; 
					sb2 := yc2.myTerminalArea.CM_SubBlockStack;
					if sb1.myParent = sb2.myParent then //check that they belong to the same yard area!
						isSourceLocationOK := true;
					endif;
				endif;
			endif;
		endif;
		if _task.isAnyId() then	//04 Aug 2014	NDL	Par 34675
			// don't check location for these suckers
		else
			if not isSourceLocationOK then
				//cnwjo3 par 26118
				if _machine.myTerminal.getConfig(AllowDTSourceOverride).Boolean = true then
					//do nothing.  raising warnings causes errors to be raised later on.
				else
					app.raiseCMException2(ERR_TI_NOTINAREA, _ti.id.trimRight, _task.sourceLocationId.trimRight(), null, null);
					return;
				endif;
			endif;
	
			create alert;
			alert.details := "Location conflict: " &amp; _ti.id &amp; " should be in " &amp; _task.sourceLocationId
			&amp; " but machine " &amp; _machine.id &amp; " has found it in area " &amp; _ti.locationId
			&amp; ". [ Information only]" ;
			alert.setSeverity(SEVERE_WARNING);
			alert.add;				
			app.commitAlert;			//commit the alert..		// PAR #19100
		endif;
	endif;

	isGood := true;
	if allocatedTI = null then
		//---------------------
		//Test the rest of its attributes
		//---------------------
		request := _task.myEntry.myWorkListEntry.myRequest;
		isGood := request.testCandidateTI(_ti, _machine, _task);
	endif;

	//--------------
	//Force an abort, so we get the logs if any
	//--------------
	if isGood then
		if allocatedTI &lt;&gt; null then
			app.raiseCMWarning(WARN_RT_TI_SUITABLE_BY_CONTROL, null, null, allocatedTI);
			if not _passport.warningsIgnored then
				return;
			endif;
		else
			// PAR 25283 Why would they want to know it is ok?
			//app.raiseCMWarning(WARN_RT_TI_SUITABLE, null, null, allocatedTI);
			//if not _passport.warningsIgnored then
			//	return;
			//endif;
		endif;
	else
		app.raiseCMException(ERR_RT_TI_UNSUITABLE, null, null);
		return;
	endif;
	//-----------------
	//Are we testing FIFO? If so, then check this is OLDEST
	//-----------------
	parentObject := _ti.getPrimaryLocation(REAL_MODE).getParent;
	if parentObject.isKindOf(CM_TerminalArea) and
	   isGood and (not parentObject.CM_TerminalArea.isOldestInStack(_ti)) then
		//--------------------
		//Not the oldest, warn the user. Not a big deal really...
		//--------------------
		if allocatedTI = null then
			app.raiseCMWarning(NotOldest, null, null, allocatedTI);
			if not _passport.warningsIgnored then
				return;
			endif;
		endif;
	endif;

		
epilog
	self.unlock(_machine);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineDirectorConvert" id="a287f137-b80d-4a5c-8026-3f06576955a1">
        <source>utlMachineDirectorConvert(	_directorTask : CM_RTQueueTask input;
							_machine : CM_Machine input;
							_ti : CM_TrackedItem input;
							_passport : CM_Passport input);
/*

Date		Who		Reason
11 May 2017	cnwer1	Initial creation TFS 995
09 Sep 2021	jlier1	TFS 51580 
*/

vars
	
begin
		
	// PAR #18743 - factored code out to new method
	self.utlMachineDirectorCheckTI(_ti, _machine, _directorTask, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	//------------------
	//Perform the relationship magic.
	//Update the director task with the TI
	//----------------
	_directorTask.addTIToDirectorTask(_ti);

	//----------------
	//Convert it to a assigned move task for this machine
	//----------------
	_directorTask.myEntry.convertDirectorTaskToMove(_directorTask, true,_passport);
	
	_machine.nextAllocatedDirectorTI := null;
		
epilog
	
	self.unlock(_machine);

end;</source>
        <Parameter name="_directorTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineDirectorConvertTwin" id="295accc5-0b68-4458-b84b-78752368839e">
        <source>utlMachineDirectorConvertTwin(_ti,
							  _twinTi : CM_TrackedItem input;
							  _machine : CM_Machine input;
							  _passport : CM_Passport input) protected;
/*

Date		Who		Reason
11 May 2017	cnwer1	Initial creation TFS 996 11/5/17

*/

vars

	task,
	twinTask,
	pickupTask		: CM_RTQueueTask;
	entry,
	twinEntry		: CM_RTQueueEntry;
	terminal		: CM_Terminal;
	pickupTasks		: CM_RTQueueTaskArray;
	messageLogger 	: CM_MachineRTQueueEntryLogger;
	firstTaskIsDirector,
	twinTaskIsDirector : Boolean;
	
begin

	
	if _ti = null or _twinTi = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name, "Can not twin plan with only one container",null,null);
	endif;
	
	task := _machine.currentQueueTask;
	twinTask := _machine.getCurrentTwinTask();

	if task = null or twinTask = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name, "Can not twin lift without two director tasks",null,null);
	endif;
	
	terminal := _machine.myTerminal;
	
	
	firstTaskIsDirector := task.taskType = TASK_DIRECTOR; //cnwrd1 par 32293
	twinTaskIsDirector := twinTask.taskType = TASK_DIRECTOR; //cnwrd1 par 32293
	
	// First validate the containers against the two tasks
	if firstTaskIsDirector then
		self.utlMachineDirectorCheckTI(_ti, _machine, task, _passport);
	endif;
	if twinTaskIsDirector then
		self.utlMachineDirectorCheckTI(_twinTi, _machine, twinTask, _passport);
	endif;
	
	//epr TFS 5720 23/8/17 both are director we twin autoplan only if machine is twin lift if it is a tandem no need
	if firstTaskIsDirector and twinTaskIsDirector and _machine.isTwinLift then 
		app.autoPlanAlertOverride(terminal);
		
		// Check and autoplan two containers to a twin location
		entry := task.myEntry;
		twinEntry := twinTask.myEntry;
		app.myUtilityUA.utlUpdateAutoplanTwin(_ti,
											  _twinTi,
											  entry.myJob,
											  twinEntry.myJob,
											  entry,
											  twinEntry,
											  QUEUE_MODE,
											  _passport);
		
		if _ti.myPrimaryQueuedLocation = null or _twinTi.myPrimaryQueuedLocation = null then
			app.raiseCMException2(ERR_TWIN_PLAN_FAILED, _ti.id, _twinTi.id, null, _ti);
			return;
		endif;	

		self.utlMachineDirectorAssignCargo(_ti, _machine, task, _passport);
		self.utlMachineDirectorAssignCargo(_twinTi, _machine, twinTask, _passport);

	elseif firstTaskIsDirector then
	
		task.addTIToDirectorTask(_ti);
		task.myEntry.convertDirectorTaskToMove(task,false, _passport);
		//epr TFS 5720 23/8/17 
		if twinTaskIsDirector and _machine.isTandemLift then
			twinTask.addTIToDirectorTask(_twinTi);
			twinTask.myEntry.convertDirectorTaskToMove(twinTask,false, _passport);
		endif;
	else
		twinTask.addTIToDirectorTask(_twinTi);
		twinTask.myEntry.convertDirectorTaskToMove(twinTask,false, _passport);
	endif;
	

	// And now check and assign the new Pickup tasks to the machine
	create pickupTasks transient;
	if firstTaskIsDirector then
		pickupTasks.add(task.myEntry.getTaskOfType(TASK_PICKUP, null));
	else
		pickupTasks.add(task);
	endif;
	
	if twinTaskIsDirector then
		pickupTasks.add(twinTask.myEntry.getTaskOfType(TASK_PICKUP, null));
	else
		pickupTasks.add(twinTask);
	endif;
	
	// Need to check machine first for both tasks, before assigning either of them
	create messageLogger transient;
	messageLogger.myMachine:=_machine;
	foreach pickupTask in pickupTasks do
		if pickupTask = null then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, "Create Pickup tasks failed to complete", null, null);
		endif;
	
		if not pickupTask.queryMachineAssign(_machine, true, false,false,true, true,messageLogger) then
			//----------------
			//Error! Machine cannot pickup
			//----------------
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_MACH_ASSIGN, _machine.id.trimRight, "Machine is unsuitable, see Alert Log for details...", null, null);
			return;
		endif;
	endforeach;
	
	// Allocate the new tasks to this machine
	_machine.checkAndResetStatus();
	foreach pickupTask in pickupTasks do
		pickupTask.setMachine(_machine);
		pickupTask.machine.workingInQueue := pickupTask.queue;
		pickupTask.setStatus(TASK_OFFERED);
		pickupTask.setStatus(TASK_ACCEPTED);
	endforeach;

	// Machine is now Assigned
	//epr par 25917 1/10/10
	if _machine.machineStatus = STATUS_IDLE then
		_machine.setMachineStatus(STATUS_ASSIGNED , "", false);
	endif;
	// And finally reset the allocated TI reference to null on machine
	_machine.nextAllocatedDirectorTI := null;
		
	
epilog
	delete pickupTasks;
	delete messageLogger;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_twinTi" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineDirectorTask" id="e62751e9-ab7d-4c16-9ba0-1b6c790ecdf1">
        <updating/>
        <source>utlMachineDirectorTask(_ti,
						_twinTi: CM_TrackedItem;
						_machine : CM_Machine input;					
						_doPickup : Boolean; 
						_moveQuantity : Integer;
						_moveWeight : Decimal;
						_passport : CM_Passport input) updating;
/*

Date		Who		Reason
11 May 2017	cnwer1	Initial creation TFS
14 Sep 2017 cnwer1	TFS 6863 changed to use objects instead of ids so break bulk works correctly
09 Sep 2021	jlier1	TFS 51580  - param change in utlMachineDirectorConvert
*/

vars
	bbTask,
	task,
	twinTask		: CM_RTQueueTask;
	bbTI,
	ti,
	twinTi			: CM_TrackedItem;
	terminal		: CM_Terminal;
	fm :CM_FutureMove;
	allBRTIsAssigned : CM_TISet;
	machineWLE,
	bbWLE 		: CM_WorkListEntry;
	request 		: CM_Request;
	br : CM_BulkRelease;
	notInBR 	: Boolean;
	errorString		: String;	
begin
	self.initialiseActivity();
	
	twinTask := _machine.getCurrentTwinTask();
	terminal := _machine.getMyTerminal();
	// If a second ID is provided, then validate it too
	//if not _passport.hasErrors() and _twinTiId &lt;&gt; null then
	//	twinTi := app.myValUA.valRTTaskFindTrackedItem(_twinTiId, twinTask,terminal);
	//endif;
	twinTi:=_twinTi;
	// PAR #20369 - If we have been given two Director tasks, but two TIs have been provided, then
	// return an error
	if twinTask = null and twinTi &lt;&gt; null then
		app.raiseCMException1(ERR_TWIN_INVALID_SINGLE_DIR, twinTi.id, null, null);
		return;
	endif;
	
	// If we have been given two Director tasks, but only one TI is provided, then release the
	// second one before accepting anything
	if twinTi = null and twinTask &lt;&gt; null then
		app.myUtilityUA.utlChangeTaskStatus(twinTask,
										null,
										TASK_UNACTIONED,
										_passport);
		if _passport.hasErrors() then
			return;
		endif;
	endif;
		
	// Need to get tasks again, they may have changed
	task := _machine.currentQueueTask;

	// Accept current task(s)
	//if task.status = TASK_OFFERED then
	if task &lt;&gt; null and  task.status = TASK_OFFERED then	// ### Tracker 1028253 08Mar2023 NAVPW1
		_machine.executeAcceptTasks(null);
		if _passport.hasErrors() then
			return;
		endif;
	endif;
	// Need to get tasks again, they may have changed
	task := _machine.currentQueueTask;

	//epr par 32408 10/9/13
	if task &lt;&gt; null and task.myEntry.myBreakBulkMaster &lt;&gt; null then
		bbTask :=task;
	endif;

	ti:=_ti;
	if ti = null then
		app.raiseCMException1(Err_TrackedItemsNotFound, null, null, null);
		return;
	endif;
	
	// A problem with either of the container IDs, so bail
	if _passport.hasErrors() then
		return;
	endif;
	
	twinTask := _machine.getCurrentTwinTask();

	create allBRTIsAssigned transient;
	//epr 32408 10/9/13 par 33175
	if bbTask &lt;&gt; null then
		bbWLE:=bbTask.myEntry.myWorkListEntry;
		if bbWLE &lt;&gt; null and bbWLE.myRequest &lt;&gt; null then
			request:=bbWLE.myRequest;
			br:=request.getBulkRelease();
			if br &lt;&gt; null then
				br.allTrackedItemsAssigned.copy(allBRTIsAssigned);
			endif;
		endif;
	endif;
	
		//epr par 35108 22/10/14
	notInBR:=false;
	if br &lt;&gt; null and not br.allTrackedItemsAssigned.includes(ti) then
		notInBR:=true;
	endif;
	
	
	if twinTask = null then
		self.utlMachineDirectorConvert(_machine.currentQueueTask,_machine,ti, _passport);	
	else
		self.utlMachineDirectorConvertTwin(ti, twinTi, _machine, _passport);
	endif;


	if _passport.hasErrors() then
		return;
	endif;
	
	//cnwrd1 par 32293 twin lift straddle directors
	if twinTask &lt;&gt; null then	
		task := task.myEntry.getDirectorOrPickupTask();
		twinTask := twinTask.myEntry.getDirectorOrPickupTask();
		if _machine.isTwinLift and not _machine.checkTwinCarryTwoTasks(task,twinTask,true,errorString) then		
			if errorString &lt;&gt; null then
				app.raiseCMException2(ERR_MACH_ASSIGN, _machine.id.trimRight, errorString, null, null);  // 27090
				return;
			endif;
		endif;
	endif;	
	
	if _doPickup and not _passport.hasErrors() then
		self.utlMachinePickupTask(_machine,null,_moveQuantity,_moveWeight);
		//epr par 35116 23/10/14
		//epr 32408 10/9/13 if it was split set the orginal wle ti back to null to allow users to select a different ti
		//epr par 35043 5/11/14
		if not _passport.hasErrors() and bbWLE &lt;&gt; null then	
			machineWLE:=_machine.currentQueueTask.myEntry.myWorkListEntry;
			if bbWLE &lt;&gt; machineWLE then		
				bbTI:=bbWLE.myTrackedItem;			
				bbWLE.setMyTrackedItem(null);	
				if bbWLE.job &lt;&gt; null then
					bbWLE.job.updateTICollectionsUnassign(bbTI);
				endif;
			
			
				fm:= bbWLE.myFutureMove;
				if fm &lt;&gt; null then			
					delete fm;
				endif;
			endif;
				
		endif;
		
			//epr par 35108 22/10/14
		if br &lt;&gt; null and ti &lt;&gt; task.ti  and notInBR and request &lt;&gt; null then	
			request.removeBulkReleaseTI(ti);	
		endif;
	endif;
	
		
epilog
	delete allBRTIsAssigned;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_twinTi" type="CM_TrackedItem"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_doPickup" type="Boolean"/>
        <Parameter name="_moveQuantity" type="Integer"/>
        <Parameter name="_moveWeight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineGetTask" id="0b00a7d9-14dd-469a-b08f-4701526c78ab">
        <source>utlMachineGetTask(	_machine : CM_Machine input;
					_passport : CM_Passport input);
/*

Date		Who		Reason
11 May 2017	cnwer1	Initial creation TFS 995 

*/

vars

begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_machine,app.getErrorString(Machine));
	_machine.executeGetNextTask(true);
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineMoveOverstow" id="0b0acafb-adf8-4912-8c4a-433308a58d60">
        <source>utlMachineMoveOverstow(	_machine : CM_Machine input; 
						_ti : CM_TrackedItem input;
						_toLocation : CM_LocationsController; 
						_passport : CM_Passport input);
/*

Date		Who		Reason
10 May 2017	cnwer1	Initial creation TFS 995 refactored from MobileServerSchema::CM_UtilityRTAgent::utlRTGMoveTI

*/

vars
	sourceLocation : CM_LocationsController;
		
	sourceLocationId	: String;
	moveController 		: CMIF_MoveController;
	moveHistory,
	pickupHistory,
	setDownHistory   	: CM_MachineMoveHistory;	
begin
	self.initialiseActivity();

	
	sourceLocation  	:= _ti.getPrimaryLocation(REAL_MODE);
	sourceLocationId 	:= _ti.getPrimaryLocationId(REAL_MODE);
	
	exclusiveLock(_ti);

	//didn't use the generic ti move method so i could set .isRTMultiMove on the move controller
	create moveController transient;

	moveController.isRehandleMove 	:= _ti.isRehandle;
	moveController.setJobForMove(null);			
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyTrackedItem(_ti);
	
	moveController.isOverstowMove 		:= true;
	moveController.isRadioTelemetryMove := true;
	moveController.setMyMachine(_machine);
	moveController.setMyToPrimaryLocation(_toLocation);
	
	moveController.isForcedMove	:=	false;	// par 17123
	
	// if we are moving overstowed cargo and have no RTQ task then
	// we may still want to record seperate pickup/setdown machine history
	if _toLocation = _machine.myMachineController then
		// it is a PICKUP by the machine
		pickupHistory := _machine.addPickupToHistoryLoc (sourceLocationId, _ti);
	elseif _ti.myPrimaryActualLocation = _machine.myMachineController then
		// it is a SETDOWN from the machine
		setDownHistory := _machine.addSetdownToHistoryLoc (_toLocation.getFullId(), _ti);
	else
		moveHistory := _machine.addMoveToHistoryLoc(sourceLocationId, _toLocation.getFullId(), _ti);
	endif;	
		
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, app.myPassport);
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	if _toLocation.isKindOf(CM_RTGController) then
		_machine.setMyLastKnowLocation(_toLocation);
	elseif sourceLocation.isKindOf(CM_RTGController) then
		_machine.setMyLastKnowLocation(sourceLocation);
	endif;
	
	// 18/11/2010 cnwcs5 par 23714/ccms 1132 - start
	if pickupHistory &lt;&gt; null then
		pickupHistory.setMyMoveTransaction(moveController.myMoveTransaction);
	endif;
	if setDownHistory &lt;&gt; null then	
		setDownHistory.setMyMoveTransaction(moveController.myMoveTransaction);
	endif;
	if moveHistory &lt;&gt; null then	
		moveHistory.setMyMoveTransaction(moveController.myMoveTransaction);
	endif;
	
epilog
	delete moveController;

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineMoveTI" id="344cee29-7699-483d-89bb-49eb0e903e8c">
        <source>utlMachineMoveTI(	_machine : CM_Machine input;
					_ti,
					_tandemTi		: CM_TrackedItem input;		
					_toLocation		: CM_LocationsController; 
					_wle 			: CM_WorkListEntry input;
					_weight 		: Decimal;
					_quantity 		: Integer;
					_isForced 		: Boolean;
					_passport 		: CM_Passport input);
/*

Date		Who		Reason
17 May 2017	cnwer1	Initial creation TFS

*/

vars
	sourceLocationId	: String;
	histEntry,
	histEntry2 : CM_MachineMoveHistory;
	moveTransaction 	: CM_Move;
	moveController 	: CMIF_MoveController;
	
begin
	self.initialiseActivity();

	sourceLocationId := _ti.getPrimaryLocationId(REAL_MODE);
	
	
	histEntry := _machine.addMoveToHistoryLoc(sourceLocationId, _toLocation.getFullId(), _ti);
	if _tandemTi &lt;&gt; null then
		histEntry2:= _machine.addMoveToHistoryLoc(_tandemTi.getPrimaryLocationId(REAL_MODE), _toLocation.getFullId(), _tandemTi);
	endif;
	
	create moveController transient;

	if  _machine.currentQueueTask &lt;&gt; null then
	   //epr par 35702 CCMS 2457 17/2/15
		moveController.myRTQueueEntry := _machine.currentQueueTask.myEntry;
		if moveController.myRTQueueEntry.isMultiMachineMove() then
			moveController.isRTMultiMove	:= true;
		endif;
	endif;
	
	moveController.isForcedMove		:= _isForced;
	moveController.isSystemMove 	:= true;
	moveController.isRehandleMove 	:= _ti.isRehandle;
	moveController.setMyWorkListEntry(_wle);		
	moveController.setMoveMode(REAL_MODE);
	moveController.setMyTrackedItem(_ti);
	moveController.isOverstowMove 		:= false;
	moveController.isRadioTelemetryMove := true;
	if _toLocation = _machine.myMachineController then
		moveController.isRTPickupTask:=true;
	endif;
	moveController.setMyMachine(_machine);
	moveController.setMyToPrimaryLocation(_toLocation);
	if _tandemTi &lt;&gt; null then
		moveController.allOtherTrackedItems.add(_tandemTi);
	endif;
	if _ti.myCargoType.isBulkMulti then
		moveController.setWeight(_weight); //epr CCMS 1366 BULK changes
	else
		moveController.setQuantity(_quantity); //cnwrd1 ccms 2274
	endif;
	
	if _wle &lt;&gt; null and _ti.canSplitTotalQuantity then
		moveController.myBreakBulkSecondaryFM := _wle.myFutureMove;
	endif;
	
	self.utlUpdateMoveTrackedItem(moveController, _passport);
	
	
	if moveController &lt;&gt; null then
		moveTransaction := moveController.myMoveTransaction; //rs1 feb 2006 ccms 1416
	endif;
	
	histEntry.setMoveTrnsFromController(moveController);
	if histEntry2 &lt;&gt; null then
		histEntry2.setMoveTrnsFromController(moveController);
	endif;
epilog
	delete moveController;
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_tandemTi" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_isForced" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachinePickupMultiTask" id="9dadf2da-773f-4f0e-b966-c2b951d1f7c8">
        <source>utlMachinePickupMultiTask(_machine      : CM_Machine io;
						  _allMoveItems : CMIF_Array;
						  _passport     : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Aug 2021 navma1 ChangeRequest 51485: PRP - Multi-Roll Pickup Enhancement
*/

vars

	obj  : CMIF_Object;
	task : CM_RTQueueTask;
begin

	exclusiveLock(_machine);
	
	_machine.setMachineStatus(STATUS_WORKING , "", false);
	
	foreach obj in _allMoveItems discreteLock do
		
		task := obj.CMIF_MultiMoveItem.myRTQTask;
		if task &lt;&gt; null then
			_machine.executePickupSingleTask(task,null,null,null,_passport);
			if  app.myPassport.hasErrors then
				return;
			endif;
		endif;
	endforeach;
end;
</source>
        <Parameter name="_machine" type="CM_Machine" usage="io"/>
        <Parameter name="_allMoveItems" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachinePickupTask" id="c60bebc1-b89e-47ac-bfb9-9087e2435da9">
        <source>utlMachinePickupTask(_machine : CM_Machine input;
					_tandemTI : CM_TrackedItem;
					_primaryQuantity : Integer;
					_weight : Decimal);
/*

Date		Who		Reason
11 May 2017	cnwer1	Initial creation TFS 995 vmt generic 

*/

vars

begin
	self.initialiseActivity();

	_machine.executePickupTask( _tandemTI, _primaryQuantity,_weight);	
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_tandemTI" type="CM_TrackedItem"/>
        <Parameter name="_primaryQuantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="utlMachineRejectTasks" id="1f16f9b8-7f5b-4637-a4a8-29c9325fb9b3">
        <source>utlMachineRejectTasks(	_rtQueueTasks :  CM_RTQueueTaskArray input;
						_machine : CM_Machine input;
						_addToRejectList : Boolean;
						_passport : CM_Passport input);
/*

Date		Who		Reason
18 May 2017	cnwer1	Initial creation TFS 995 

*/

vars
	invalidTask : Boolean;
	rtEntry : CM_RTQueueEntry;
	rtQueueTask : CM_RTQueueTask;
	ed 			: Integer;
	allRTQueueTasks :   CM_RTQueueTaskArray;
	deleteTasksColl	: Boolean;
begin
	self.raiseExceptionIfNull(_machine,app.getErrorString(Machine));
		
	allRTQueueTasks :=_rtQueueTasks;
	if allRTQueueTasks = null then
		//just cancel all current tasks if not specified;
		allRTQueueTasks:=_machine.allCurrentQueueTasks.cloneSelf(true);
		deleteTasksColl:=true;
	endif;
	
	
	foreach rtQueueTask in allRTQueueTasks do
		//epr par 34879 11/9/14
		ed:=rtQueueTask.edition;
		if invalidTask then
			invalidTask:=false;
			continue;
		endif;
		
		if rtQueueTask.isDirectorWithAssignedTI() then //cnwrd1 par 28628 22.11.11
			app.myUtilityUA.utlMachineCancelDirectorTask(rtQueueTask,_machine,_passport);
		else
			//app.myUtlRT.utlCancelTask(rtQueueTask,_machine,_addToRejectList);
			//epr CCMS 1391 refactored utlRejectTask does the same as cancel tasks 
			app.myUtilityUA.utlRejectTask(_machine,rtQueueTask,_addToRejectList,_passport);
		endif;
		if app.myPassport.hasErrors then
			return;
		endif;
	endforeach;
	
epilog
	if deleteTasksColl then
		delete allRTQueueTasks;
	endif;
end;</source>
        <Parameter name="_rtQueueTasks" type="CM_RTQueueTaskArray" usage="input"/>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_addToRejectList" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineSetTaskStates" id="617833a6-89e7-41c0-9783-78de7380ec87">
        <source>utlMachineSetTaskStates(_machine : CM_Machine input;
						 _availableTasks : CM_RTQueueTaskArray input;
						 _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2019	jlgzm1	Initial creation TFS 44769 Error 4, improve exception handling

*/

vars
	queueTask : CM_RTQueueTask;
	machineTaskState : CM_MachineTaskState;
	invalidTask : Boolean;
begin
	self.initialiseActivity();
	
	on Exception do app.handleDeletedObject(exception, queueTask, invalidTask);
	
	_machine.allMachineTaskStates.purge;
	
	if _availableTasks = null or _availableTasks.isEmpty then
		return;
	endif;
	
	foreach queueTask in _availableTasks discreteLock do
		queueTask.edition();
		if invalidTask then
			invalidTask := false;
			continue;
		endif;
		create machineTaskState;
		machineTaskState.setDetails(_machine,queueTask);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_availableTasks" type="CM_RTQueueTaskArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineSetdownTask" id="e9d9385f-bbb3-448d-81fd-a95b64fbdb39">
        <updating/>
        <source>utlMachineSetdownTask(	_machine : CM_Machine input;
						_rtTask,
						_rtTwinTask: CM_RTQueueTask input;
						_setDownLocation,
						_rtTwinSetdownLocation : String; 
						_overrideToInterchange : Boolean;
						_passport : CM_Passport input) updating;
/*

Date		Who		Reason
09 May 2017	cnwer1	Initial creation TFS 995 VMT project refactor   MobileServerSchema CM_TRxConttolRTAgent:: trxSetdownTaskTwin
16/10/2019	JLGNS1	ChangeRequest 46451: JMT - Tandem Lift moves - Order of selecting and set down items using Vehicle App
22 Jan 2020 jlgka1	TFS 47394: Web Apps - To be able to switch error message for twin lift and tandem lift as we use only one error code for both. 
23 Jul 2021	navdap1	TFS 51409 PNL Queued Jobs in Driver Mode
27 Jul 2021 navmd1	TFS 51260 PNL Allow Tandem setdown tasks to go to different locations if config allows
*/

vars
	direction	: Integer;
	reasonString,twinLocId : String;
	ultimateTargetLocation,
	ultimateTwinTargetLoc: CM_LocationsController;
	moveController 	: CMIF_MoveController;
	taskTI,
	twinTI			: CM_TrackedItem;
	taskWLE,
	twinWLE		: CM_WorkListEntry;//epr par 2/8/10 25236
	twinVoyageWLE,
	voyageWLE		: CM_VoyageWLE;
	twinPFM,
	plannedFutureMove	: CM_FutureMovePlanned;
	swapping,
	invalidWLE 			: Boolean;
	newTarget 			: String;
	config				: CM_RTVehicleConfig;
	allowedDifferentTargets,
	differentLocation	: Boolean;
	setDownLC, twinSetDownLC : CM_LocationsController;			// TFS 51409
	height, twinHeight : Integer;								// TFS 51409
begin
	self.initialiseActivity();
	app.writeLog(_rtTask.targetLocationId &amp; Tab &amp; _setDownLocation, LogINFO);
	//grap the ultimate target loaction while the wle &amp; task exist
	if _overrideToInterchange then
		ultimateTargetLocation:=_rtTask.myEntry.getFinalTargetLocation();
		if ultimateTargetLocation = null then		
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Ultimate target location is null', null, null);
		endif;
		taskTI:=_rtTask.ti;
		taskWLE:=_rtTask.myEntry.myWorkListEntry;//epr par 2/8/10 25236
		if _rtTwinTask &lt;&gt; null then
			ultimateTwinTargetLoc:=_rtTwinTask.myEntry.getFinalTargetLocation();
			if ultimateTwinTargetLoc = null then		
				app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Ultimate twin target location is null', null, null);
			endif;
			twinTI:=_rtTwinTask.ti;
			twinWLE:=_rtTwinTask.myEntry.myWorkListEntry;//epr par 2/8/10 25236
		endif;
	endif;

	if _passport.hasErrors() then
		return;
	endif;
	
	// PAR #33427 Are we doing a swap of a twin lift?																	// PAR #33427
	if _rtTask &lt;&gt; null and _rtTwinTask &lt;&gt; null and _machine.isTwinLift then												// PAR #33427
		// twin task setdown location = task target location and task setdown location = twin target location			// PAR #33427
		// - this twin lift has had the "Swap" button pressed on the RT app												// PAR #33427
		if _setDownLocation = _rtTwinTask.targetLocationId and _rtTwinSetdownLocation = _rtTask.targetLocationId then	// PAR #33427
			swapping := true;																							// PAR #33427
		endif;																											// PAR #33427
	endif;		
	
	// TFS 51409 start
	if _machine.myRTVehicleConfig &lt;&gt; null and _machine.myRTVehicleConfig.allowChangeQSetdown then
		_machine.myTerminal.findLocationFromString(_setDownLocation, true, setDownLC, height);
		if _rtTwinTask &lt;&gt; null then
			_machine.myTerminal.findLocationFromString(_rtTwinSetdownLocation, true, twinSetDownLC, height);
		endif;
		if not swapping and _rtTask.targetLocation &lt;&gt; setDownLC and _rtTask.targetLocation &lt;&gt; null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "warnings raised at " &amp; "not swapping and '" &amp; _rtTask.targetLocationId &amp; "' &lt;&gt; '" &amp; _setDownLocation &amp; "'", LogINFO);
			app.raiseCMWarning2(Setdown_location_differs, _setDownLocation, _rtTask.targetLocationId, null, null, null);
		endif;
		if not swapping and _rtTwinTask &lt;&gt; null and _rtTwinTask.targetLocation &lt;&gt; twinSetDownLC and _rtTwinTask.targetLocation &lt;&gt; null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "warnings raised at " &amp; "not swapping and _rtTwinTask &lt;&gt; null and _rtTwinTask.targetLocationId &lt;&gt; _rtTwinSetdownLocation", LogINFO);
			app.raiseCMWarning2(Setdown_location_twin_differs, _rtTwinSetdownLocation, _rtTwinTask.targetLocationId, null, null, null);
		endif;
		if swapping and _rtTask.targetLocation &lt;&gt; twinSetDownLC and _rtTask.targetLocation &lt;&gt; null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "warnings raised at " &amp; "swapping and _rtTask.targetLocation.getFullId &lt;&gt; _rtTwinSetdownLocation", LogINFO);
			app.raiseCMWarning2(Setdown_location_differs, _rtTwinSetdownLocation, _rtTask.targetLocationId, null, null, null);
		endif;
		if swapping and _rtTwinTask.targetLocation &lt;&gt; setDownLC and _rtTwinTask.targetLocation &lt;&gt; null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "warnings raised at " &amp; "swapping and _rtTwinTask.targetLocation.getFullId &lt;&gt; _setDownLocation", LogINFO);
			app.raiseCMWarning2(Setdown_location_twin_differs, _setDownLocation, _rtTwinTask.targetLocationId, null, null, null);
		endif;
	endif;
	// TFS 51409 end
	
	//epr par 25061
	if _rtTask.isVoyageLoadToCTA then
		if _rtTask.myEntry.myWorkListEntry.isKindOf(CM_VoyageWLE) then
			voyageWLE:=_rtTask.myEntry.myWorkListEntry.CM_VoyageWLE;
			if voyageWLE.myFutureMove.isKindOf(CM_FutureMoveQueued) then
				plannedFutureMove:= voyageWLE.myFutureMove.CM_FutureMoveQueued.myFutureMovePlanned;
				voyageWLE.myFutureMove.CM_FutureMoveQueued.setMyFutureMovePlanned(null);
			endif;
		endif;
	else 
		newTarget := _rtTask.checkVoyageOutOfOrderLoad(); //cnwrd1 par 30626 ccms 2209 23.10.12
	endif;

	if newTarget &lt;&gt; null then //cnwrd1 par 30626 ccms 2209 23.10.12		
		self.utlMachineCheckUpdateTarget(_rtTask, _rtTask.ti,newTarget,_overrideToInterchange = false, swapping, _passport);				// PAR #33427
	else
		if	_rtTask.targetLocation = null or
			not _rtTask.ultimateTargetLocationId.trimRight() = _setDownLocation then
			// Need transaction state here!			// PAR #33427
			self.utlMachineCheckUpdateTarget(_rtTask, _rtTask.ti,_setDownLocation,_overrideToInterchange = false, swapping, _passport);	// PAR #33427
		endif;
	endif;
		
	if _passport.hasErrors() then
		return;
	endif;

	
	
	if  _rtTwinTask &lt;&gt; null then
		//epr par 36517 7/7/15
		if  _rtTwinTask.isVoyageLoadToCTA then
			if _rtTwinTask.myEntry.myWorkListEntry.isKindOf(CM_VoyageWLE) then
				twinVoyageWLE:=_rtTwinTask.myEntry.myWorkListEntry.CM_VoyageWLE;
				if twinVoyageWLE &lt;&gt; null and twinVoyageWLE.myFutureMove.isKindOf(CM_FutureMoveQueued) then
					twinPFM:=twinVoyageWLE.myFutureMove.CM_FutureMoveQueued.myFutureMovePlanned;
					twinVoyageWLE.myFutureMove.CM_FutureMoveQueued.setMyFutureMovePlanned(null);
				endif;
			endif;
		endif;
		
		if	_rtTwinTask.targetLocation = null or
			not _rtTwinTask.ultimateTargetLocationId.trimRight() = _rtTwinSetdownLocation then
			// Need transaction state here!	
			self.utlMachineCheckUpdateTarget(_rtTwinTask, _rtTwinTask.ti,_rtTwinSetdownLocation,_overrideToInterchange = false, swapping, _passport);	// PAR #33427
		endif;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	
	//have to validate that the updated setdown locations are still next to each other 
	//and at the same height
	
	if _rtTwinTask &lt;&gt; null then
		if _machine.isTwinLift then
			//don't pass through the ti because we just want to check that height of both tasks location is the same
			if not _rtTask.targetLocation.canTwinLiftWithLocation(_rtTwinTask.targetLocation,null,null,QUEUE_MODE,direction,reasonString) then
				if _rtTwinTask.targetLocation &lt;&gt; null then
					twinLocId:=_rtTwinTask.targetLocation.getFullId;
				endif;
					//need to change the error but the tracked items should be in the same job since they should be twin
				app.raiseCMException4(Twin_lift_locations, "Twin", _rtTask.targetLocation.getFullId, twinLocId, reasonString, null, null); // jlgka1 TFS 47394
				return;	
			endif;
		endif;
		
		if _machine.isTandemLift then
			config := _machine.myTerminal.getRTVehicleConfigForObject(_machine);
			if config &lt;&gt; null then
				allowedDifferentTargets := config.allowTandemToDiffTargets;
			endif;
			
			differentLocation := _rtTask.targetLocation &lt;&gt; _rtTwinTask.targetLocation;
			if differentLocation and not allowedDifferentTargets then
				if  _rtTwinTask.targetLocation &lt;&gt; null then
					twinLocId:=_rtTwinTask.targetLocation.getFullId;
				endif;
					//need to change the error but the tracked items should be in the same job since they should be twin
				app.raiseCMException4(Twin_lift_locations, "Tandem", _rtTask.targetLocation.getFullId, twinLocId, "TANDEM Locations are different", null, null);  // jlgka1 TFS 47394
				return;	
			endif;
			
			if _rtTwinTask &lt;&gt; null then																														//ChangeRequest 46451
				if _machine.allCurrentQueueTasks.size &gt;= 2 and _machine.allCurrentQueueTasks[1] &lt;&gt; null and _machine.allCurrentQueueTasks[2] &lt;&gt; null then 	//ChangeRequest 46451
					if _machine.allCurrentQueueTasks[1] &lt;&gt; _rtTask and _machine.allCurrentQueueTasks[2] &lt;&gt; _rtTwinTask then									//ChangeRequest 46451
						if _machine.allCurrentQueueTasks[2] = _rtTask and _machine.allCurrentQueueTasks[1] = _rtTwinTask then								//ChangeRequest 46451
							_rtTwinTask.setMachine(null);																									//ChangeRequest 46451
							_rtTwinTask.setMachine(_machine);																								//ChangeRequest 46451
						endif;
					endif;
				endif;
			endif;
		endif;
		
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	// Can't guarantee which passport we are working with.
	//epr TFS47394  4/12/19 - Tandem move can setdown seperate tasks 
	if _rtTwinTask &lt;&gt; null then
		_machine.executeSetDownTask(null, null);
	else
		if _machine.myPrimaryQueue &lt;&gt; _rtTask.myEntry.myQueue then
			app.myEventManager.createSingleObjInfoNoteEvt(_machine.myPrimaryQueue , _machine.myTerminal.getTerminalEvent(Event_Update_Queue_Entry), _rtTask.myEntry );		
		endif;
		
		_machine.executeSetDownSingleTask(_rtTask,null,app.myPassport);
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception,taskWLE,invalidWLE);
	invalidWLE:=false;
	
	if _overrideToInterchange then
		create moveController transient;
		moveController.setMyToPrimaryLocation(ultimateTargetLocation);
		moveController.setMoveMode(QUEUE_MODE);
		moveController.setMyTrackedItem(taskTI);
		/*if it is release we want to set the interchange move to the same wle so that the wle is completed
			when we move to the target release
			for receipt as soon as its moved from the source can complete the wle and potentially the job
		*/
		
		if 	not taskWLE.isReceipt  then
			//epr par 25522 if wle is completed set it back to unactioned - note there is not WLE_PART_COMPLETE status that would of been better suited
			//because we want to to use the same wle so the job can not be completed until all the containers are moved to the target location
			if taskWLE.status = WLE_COMPLETED then
				taskWLE.setStatus(WLE_UNACTIONED);
			endif;
			moveController.setMyWorkListEntry(taskWLE);
		endif;
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController,_passport);
		
		if _passport.hasErrors() then
			return;
		endif;
		if _rtTwinTask &lt;&gt; null then
			invalidWLE:=false;
			delete moveController;
			create moveController transient;
			moveController.setMyToPrimaryLocation(ultimateTwinTargetLoc);
			moveController.setMoveMode(QUEUE_MODE);
			moveController.setMyTrackedItem(twinTI);
			taskWLE:=twinWLE;
			if not taskWLE.isReceipt then
				if taskWLE.status = WLE_COMPLETED then
					taskWLE.setStatus(WLE_UNACTIONED);
				endif;
				moveController.setMyWorkListEntry(taskWLE);
			endif;
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController,_passport);
			
			if _passport.hasErrors() then
				return;
			endif;
		endif;
	endif;
	
	//epr par 25061
	if voyageWLE &lt;&gt; null and plannedFutureMove &lt;&gt; null then
		plannedFutureMove.setMyWorkListEntry(voyageWLE,false);
	endif;
	if twinVoyageWLE &lt;&gt; null and twinPFM &lt;&gt; null then
		twinPFM.setMyWorkListEntry(twinVoyageWLE,false);
	endif;
	
	_passport.doDeferredUpdates();
	
	
epilog
	delete moveController;

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_rtTwinTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_setDownLocation" type="String"/>
        <Parameter name="_rtTwinSetdownLocation" type="String"/>
        <Parameter name="_overrideToInterchange" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineSwapTwinTargets" id="b6803666-1ff4-476f-ad6f-75d4ac35a581">
        <source>utlMachineSwapTwinTargets(_task, 
					   _twinTask : CM_RTQueueTask input; 
					   _passport : CM_Passport input);

/*

Purpose:			Swap the target locations of the two passed in tasks (which will be twinned tasks)

Parameters:			Two Tasks to swap locations

Return Value:		None


Date		Who		Reason
20 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
13 Feb 2014	cnwdap1	PAR #33427 New parameter for utlValAndUpdateTargetLocation method so it knows whether we're doing a swap on a twin lift
18 May 2016 cnwer1 	TFS 995 moved from MobileServerSchema ::CM_UtilityRTAgent utlSwapTargetLocations
*/

vars
	taskLocationString,
	twinTaskLocationString	: String;
	
begin
	self.raiseExceptionIfNull(_task, "Primary Task");
	self.raiseExceptionIfNull(_task.ti, "Primary Task Container");
	self.raiseExceptionIfNull(_twinTask, "Twin Task");
	self.raiseExceptionIfNull(_twinTask.ti, "Twin Task Container");

	taskLocationString := _task.ultimateTargetLocationId.trimRight;
	twinTaskLocationString := _twinTask.ultimateTargetLocationId.trimRight;
	
	// Set primary task location to twin's location
	self.utlMachineCheckUpdateTarget(_task,
									   _task.ti,
									   twinTaskLocationString,
									   true,
									   true, 							// PAR #33427
									   _passport);
	
	// And if there are no errors, update the twin task
	if _passport.noErrors then
		self.utlMachineCheckUpdateTarget(_twinTask,
										   _twinTask.ti,
										   taskLocationString,
										   true,
										   true, 						// PAR #33427
										   _passport);
	endif;


epilog

end;</source>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_twinTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineUpdateFaultResponse" id="769fe00d-ad83-437d-acdd-ed51a06d0166">
        <source>utlMachineUpdateFaultResponse(	_machine : CM_Machine input;
								_index : Integer;
								_response : String;
								_passport : CM_Passport input);
/*
Purpose:			Set the mediator response value at the index passed in to the value passed in.
					If this is the final pending response, then create the fault responses for
					the receiver machine, and set the "outstanding question flag to false.

Parameters:			Mediator to update
					Index into fault question array
					Response from driver (Yes/No)
					
Date		Who		Reason
22 May 2017	cnwer1	Initial creation TFS 995 based on the utlUpdateMediatorResponseValue

*/

vars

	responseStr		: String;
	faultQuestion	: CM_FaultQuestion;
	faultResponse	: CM_FaultResponse;
	faultArray		: CM_FaultResponseArray;
	index			: Integer;
	stillOutstanding	: Boolean;
	now				: TimeStamp;
	invalidFault	: Boolean;
	
begin
	self.initialiseActivity();
	// Validate index first
	if _index &lt; 1 or _index &gt; _machine.allCurrentFaultResponses.size then
		app.raiseCMException(ERR_MACH_INVALIDQUESTIONID, null, null);
	endif;
	
	// Validate response
	if _response &lt;&gt; AuditStringValue_Yes and _response &lt;&gt; AuditStringValue_No then
		app.raiseCMException1(ERR_MACH_INVALIDFAULTRESP, _response, null, null);
	endif;
	
	// Set the response from the input
	 _machine.allCurrentFaultResponses[_index] := _response;
	
	// If we have just set the last response, then create the persistent fault(s) required
	if not _machine.isFaultQuestionOutstanding then
	
		now := app.actualTimeServer;
	
		on Exception do app.handleDeletedObject(exception, faultQuestion, invalidFault);
		
		create faultArray transient;
		foreach index in 1 to _machine.allCurrentFaultQuestions.size do
			faultQuestion := _machine.allCurrentFaultQuestions[index];
			responseStr := _machine.allCurrentFaultResponses[index];
			
			// Have we still got at least one unanswered question?
			if responseStr = null then
				stillOutstanding := true;
				break;
			endif;
			
			invalidFault := false;
			
			// Create proxy ready for fault create if required
			create faultResponse transient;
			faultResponse.setProxy(_machine,				// _machine : CM_Machine;
								   _machine.user,					// _reportedUser : CM_User;		
								   null,							// _previousUser : String;
								   faultQuestion,					// _faultQuestion : CM_FaultQuestion;
								   faultQuestion.description,		// _question :String;
								   now,								// _reportedTS : TimeStamp;
								   responseStr);					// _response : String) updating;

			// If a question has been deleted, then just ignore it
			if invalidFault then
				delete faultResponse;
			else
				faultArray.add(faultResponse);
			endif;
		endforeach;
		
		// If we now have all the responses, then create any faults
		if not stillOutstanding then
			app.myUtilityCA.utlCreateFaultResponses(faultArray,
													_machine.getMyTerminal(),
													_passport);
		endif;
		
	endif;
	
	
epilog
	if faultArray &lt;&gt; null then
		faultArray.purge();
		delete faultArray;
	endif;

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_response" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMachineValidateAcceptTask" id="13181877-7fea-49f0-9db3-ff5d3bc43691">
        <updating/>
        <source>utlMachineValidateAcceptTask(	_machine : CM_Machine input;
								_rtTask : CM_RTQueueTask input;							
								_passport : CM_Passport input) updating;
/*

Date		Who		Reason
10 May 2017	cnwer1	Initial creation TFS 995 refactor moved from MobileServerSchema::CM_UtilityRTAgent::utlAcceptRTQueueEntry

*/

vars

	firstTask,
	rtQueueTask : CM_RTQueueTask;
	messageLogger 	: CM_MachineRTQueueEntryLogger;
	str : String;
begin
	self.initialiseActivity();
		
	if _rtTask.taskType = TASK_BREAKBULK then
		self.utlBreakBulkMasterAccept( _rtTask, rtQueueTask);
	
		if _passport.hasErrors() then
			return;
		endif;
	endif;
	
		
	if _rtTask.checkAssignBestPickTIToWLE then	
		self.utlMachineBestPickAssignTI( _rtTask ,null,_machine,  _passport);
	endif;	
	
	
	if rtQueueTask = null then
		create messageLogger transient;
		_rtTask.myEntry.getATaskForMachine(rtQueueTask,_machine,null,null,messageLogger);
		
		if _passport.hasErrors() then
			return;
		endif;
	endif;
	
	app.myValUA.valMachineAcceptTask(_machine,rtQueueTask,null,false,messageLogger=null,true);
	
	
	
	if _passport.hasErrors() then
		return;
	endif;
	
	self.utlMachineAcceptTask(_machine,rtQueueTask,_passport);

epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMergeBreakBulk" id="48089c7b-0bc5-4544-bbcd-98721b8e5549">
        <updating/>
        <source>utlMergeBreakBulk( _targetTi : CM_Cargo io; _cargoToMerge : CM_Cargo input; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

begin

	if _targetTi.isKindOf(CM_Bulk) then
		_cargoToMerge.CM_Bulk.mergeIntoDifferentId(_targetTi.CM_Bulk,_passport);
	elseif _targetTi.isKindOf(CM_BreakBulkGeneric) then
		_cargoToMerge.CM_BreakBulkGeneric.mergeIntoDifferentId(_targetTi.CM_BreakBulkGeneric,_passport);
	endif;

epilog
	
end;</source>
        <Parameter name="_targetTi" type="CM_Cargo" usage="io"/>
        <Parameter name="_cargoToMerge" type="CM_Cargo" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMoveTrackedItemsToPlannedLC" id="eabdd43f-ac8f-45a0-b4da-d2845a5465ad">
        <source>utlMoveTrackedItemsToPlannedLC(_tis : CM_TISet; _passport : CM_Passport input); 
//-----------------------------------------
//Created: May 2003 By: cnwgd1
//-----------------------------------------
vars
	control : CMIF_MoveController;
	ti		: CM_TrackedItem;
	newLocn : CM_LocationsController;
begin

	self.initialiseActivity();
	
	create control transient;
	control.setMoveMode(REAL_MODE);	
	control.isSystemMove := true;
		
	foreach ti in _tis do
		newLocn := ti.getPrimaryLocation(QUEUE_MODE);
		if newLocn = null then
			newLocn := ti.getPrimaryLocation(PLANNING_MODE);		
		endif;
		if newLocn = null then
			continue;
		endif;
		control.setMyTrackedItem(ti);
		control.setMyToPrimaryLocation(newLocn);		
		self.utlUpdateMoveTrackedItem(control, _passport);
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	
epilog
	delete control;
end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMoveTrackedItemsToShip" id="42733f3c-881f-48ad-a448-c4cc9b0b5e46">
        <source>utlMoveTrackedItemsToShip(	_trackedItems : CM_TIArray input; 
							_job : CM_VoyageJob input; 
							_slotControllers : CM_LCArray;
							_passport : CM_Passport input);
/*

Date		Who		Reason
16 May 2017	cnwer1	Initial creation TFS

*/

vars
	ti : CM_TrackedItem;
	i : Integer;
	slotController : CM_SlotController;
		sourceLocationId	: String;
	histEntry 			: CM_MachineMoveHistory;
	moveTransaction 	: CM_Move;
	machine 		: CM_Machine;
begin
	self.initialiseActivity();
	
	foreach ti in _trackedItems discreteLock do
		i := i + 1;
		slotController := _slotControllers[i].CM_SlotController;
		if slotController = null or _job = null then
		//	app.raiseCMException1(REQUIRED_FIELD, "Tracked Item, job or slotController", null, self);
			app.raiseCMException(Input_required_field_trkdJbSlt, null, self); // 10/12/2014  cnwdb2	PAR 35364
			return;
		endif;
		
		self.reserveLock(slotController);
		
		if ti.isJobOutOfSequence(slotController) then
			self.utlSwapTIPlannedLocations(ti, slotController);
		endif;
		if app.myPassport.hasErrors() then
			return;
		endif;

		sourceLocationId := ti.getPrimaryLocationId(REAL_MODE);
	
		machine:= _job.getJobCrane();
		histEntry := machine.addMoveToHistoryLoc(sourceLocationId, slotController.getFullId(), ti);
		
		moveTransaction := ti.moveToLocation(slotController, null, _job.getWLEForTI(ti),machine, REAL_MODE, false, true, false, true, false, false, null,null,null,null,null,app.myPassport);	// TFS 2651
	
		histEntry.setMyMoveTransaction(moveTransaction);
		if app.myPassport.hasErrors() then
			return;
		endif;
		
		self.unlock(slotController);
		
	endforeach;
epilog

end;</source>
        <Parameter name="_trackedItems" type="CM_TIArray" usage="input"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_slotControllers" type="CM_LCArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMoveUserReport" id="3724239b-eab4-499d-8156-8f718160e7d1">
        <source>utlMoveUserReport(_userReport : CM_MenuUserReport input);

// cnwdvb1 31 October 2002 

vars
	menuRoot	: CM_MenuRootUserBackgroundReps;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(false);
	self.exclusiveLock(_userReport);		
	_userReport.moveToSaved();
	
end;</source>
        <Parameter name="_userReport" type="CM_MenuUserReport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlMoveVehicle" id="22d122eb-1914-495d-a647-2406c8912530">
        <source>utlMoveVehicle(	_vehicle :CM_Vehicle input; _newLocation : CM_YardController input;_passport : CM_Passport);
/*

Date			Who		Reason
15 August 2006	cnwer1	Initial creation - PAR#xxxx
21 May 2009		concms1	Par 19715 - changed to use VisitRecord_ constantes instead of VTA_constants	when comparing with recordType
25 August 2009	cnwcs5	ccms 1061 - road ops form changes
28/06/2010		cnwcs5	par 24418 - move vehicle B4 doing the queuing
25/06/2012		cnwjre1	par 29712 - allow vehicle move from yard to gate and pre-gate
09Dec2022		navsp1  TFS - ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
17 June 2024	jlier1 TFS 64018
10 Jul 2025	navhl20 Bug MTN-35305: MTN - Optimize Saving Road Jobs to Avoid Redundant Yard Allocation Checks
*/
vars
	oldLocation				: CM_YardController;
	job 					: CM_RoadJob;
	rtArbiter 				: CM_RTQueueArbiter;
	wle 					: CM_WorkListEntry;
	rtQueueEntry 			: CM_RTQueueEntry;
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	ti						: CM_TrackedItem;		//navra1 - 18th March 2024 - BUG 62962
	plannedLocn,
	actualLocn				: CM_LocationsController;
	now						: TimeStamp;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(false);
	
	//do validation
	self.raiseExceptionIfNull(_vehicle, 'Vehicle');
	self.raiseExceptionIfNull(_newLocation,'Location');
	
	//check self not already at this location 
	if _newLocation.allVehicleMachines.includes(_vehicle) then
		return;
	endif;
	
	terminal 	:= _passport.myTerminal;
	oldLocation	:= _vehicle.myPrimaryActualLocation;
	
	if not _vehicle.allRoadJobs.isEmpty then
		// we may be getting called from a method that is creating the job
		if _vehicle.allRoadJobs.size &gt; 1 then
			app.raiseUnexpectedProgramError (self.class.name, method.name, "Vehicle " &amp; _vehicle.code &amp; " can not be moved because it has more than one job associated to it"); return;
		endif;

		job := _vehicle.allRoadJobs.first.CM_RoadJob;

		if	oldLocation &lt;&gt; null and oldLocation.isInsideYard() and _newLocation.isInsideYard() then
			// they are moving around the yard - no checking to do
			
		elseif oldLocation &lt;&gt; null and oldLocation.isInterchangeAreaLocation and 	// was ITI, ITF or anywhere in Yard
				not _newLocation.isInsideYard() then
			// 29712 allow moves back from yard to inward gate lanes and pre-gate
			if (_newLocation.isKindOf(CM_BlockController) and _newLocation.CM_BlockController.isInTransitTo()) then	// moving back to inward pre-gate - allow this
			elseif (_newLocation.isPGateLane and _newLocation.CM_LaneController.isIn()) then	// moving back to inward p-gate lane - allow this
			else
			// moving out of yard into outward gate lane or in-transit-to an outward p-gate
			// or in-transit-from interchange area. The job must be complete
				if job.status &lt;&gt; JOB_COMPLETE then
					app.raiseCMException1(ERR_JOB_NOT_COMPLETE,job.jobId, "Road Job", job); return;
				endif;	
			endif;
		elseif (_newLocation.isPGateLane and _newLocation.CM_LaneController.isIn) or	// moving into inward p-gate lane 
				_newLocation.isInTransitTo or											// transiting into terminal
				_newLocation.isInsideYard then											// coming into yard 
				
			//navra1 - 18th March 2024 - BUG 62962 - start			
			//you are moving into the yard, dont queue if you can be autocompleted			
			if _newLocation.isYardLocation() and not _newLocation.isGateAreaLocation() then
				now	:= app.actualTimeAppServer;																							//10.07.2025 navhl20 #35305
				foreach ti in job.allReceiveTrackedItems do
					if job.canBeAutoCompleted(ti, null,false) then
						
						plannedLocn := ti.myPrimaryPlannedLocation;
						
						if plannedLocn = null then				
							ti.autoPlan(PLANNING_MODE, job, null, null, app.myPassport);				
						endif;
						if plannedLocn &lt;&gt; null then
							
							ti.moveToLocation(plannedLocn, job, null, null, REAL_MODE, true, true, false, false, false, false, 
														null, null, null,now, job.myVehicleVisit, app.myPassport);		//navra1 - BUG 63359 - 2nd Apr 2024
							if app.myPassport.hasErrors then
								return;
							endif;
						endif;
					endif;
				endforeach;
				
				//17 June 2024	jlier1 TFS 64018
				foreach wle in job.workListEntries where not wle.isReceipt and wle.status = WLE_UNACTIONED do
					ti:=wle.myTrackedItem;
					if ti &lt;&gt; null then
						if job.canBeAutoCompleted(ti,null,true) then
							plannedLocn := ti.myPrimaryPlannedLocation;
							
							if plannedLocn = null and wle &lt;&gt; null then
								plannedLocn := wle.getRoadReleaseLC();  
							endif;
							
							if plannedLocn &lt;&gt; null then
								ti.moveToLocation(plannedLocn, job, wle, null, REAL_MODE, false, true, false, false, false, false, 
															null, null, null,now, job.myVehicleVisit, app.myPassport);
								if app.myPassport.hasErrors then
									return;
								endif;							
							endif;
						endif;
					endif;
				endforeach;
			
			endif;
			//navra1 - 18th March 2024 - BUG 62962 - end
			
			// If the vehicle is not mvoing from the AGate, check the job has been queued PAR 21068
			if oldLocation = null or not oldLocation.isAGateLane then
				foreach wle in  job.workListEntries discreteLock do
					if wle.myTrackedItem = null then
						continue;	// release by ISO type WLE may have not TI
					endif;
					if wle.status = WLE_COMPLETED then
						continue;	// belts and braces - no point queuing a completed WLE
					endif;
					if wle.myTrackedItem.directDelivery then
						continue;	// Direct deliveries are not queued
					endif;
					if wle.isReceiptToUnpack then
						continue;
					endif;
					if wle.isReleaseToPack then
						continue;
					endif;
					
					actualLocn := wle.myTrackedItem.myPrimaryActualLocation;							//10.07.2025 navhl20 #35305
					//ti is on a chassis then can continue
					if actualLocn.isKindOf(CM_TILCController) then
						if wle.isReceipt then
							continue;
						else
							if actualLocn.CM_TILCController.myTILC.id = job.getChassisID(false) then
								continue;
							endif;
						endif;
					endif;
					if wle.myTrackedItem.myPrimaryQueuedLocation = null then
						if not job.canBeAutoCompleted(wle.myTrackedItem,null,not wle.isReceipt) then
							app.raiseCMException2(Error_Move_Vehicle_Not_Queued, _vehicle.code, _newLocation.getID , app.getErrorString (Error), _vehicle); 
							return;
						endif;
					endif;					
				endforeach;				
			endif;
			
			//09Dec2022 navsp1 TFS 55580
			//validation to prevent moving to the Yard if pregate IN check is required and not done. 
			if oldLocation &lt;&gt; null and not oldLocation.isInsideYard and _newLocation.isInsideYard then
				vvr := job.myVehicleVisit;	
				if vvr &lt;&gt; null then
					if vvr.gateInCheckStatus = vvr.InspectionPending then
						app.raiseCMException2(Vehicle_cannot_move_to_yard, _vehicle.regNumber, vvr.InspectionPending, null, _vehicle);
					
					//28.Mar.2023 navsp1 TFS 57268
					elseif vvr.gateInCheckStatus = vvr.InspectionFailed then
						app.raiseCMException2(Vehicle_cannot_move_to_yard, _vehicle.regNumber, vvr.InspectionFailed, null, _vehicle);
					endif;
				endif;				
			endif;
			
		/* par24418 - we used to reevaluate q entries here but now we wait until after vehicle has been moved */
		
		endif;
	endif;
	
	//epr par 37060 20/1/16
	if _newLocation &lt;&gt; null and _newLocation.isKindOf(CM_YardICAreaLaneController) then
		if _newLocation.CM_YardICAreaLaneController.capacity &gt; 0 then
			if _newLocation.allVehicleMachines.size = _newLocation.CM_YardICAreaLaneController.capacity then
				app.raiseCMException1(Move_WillBeOverCap,_newLocation.getFullId,null,null);
			endif;
		endif;
	endif;
		
	
	
	self.exclusiveLock(_vehicle);
	
	/*	if the vehicle was at a gate lane and is going some where else
		then if the lane direction was changed while the vehicle was in the lane, we
		will change the lane direction now */
	if oldLocation.isKindOf (CM_GateAreaLaneController) then					// ccms 1061 - 25/08/2009
		oldLocation.CM_GateAreaLaneController.performDelayedDirectionChange; 	// ccms 1061 - 25/08/2009
	endif;																		// ccms 1061 - 25/08/2009
	
	_vehicle.setMyPrimaryActualLocation(_newLocation,false);
	
	// par 24418 - start 28/06/2010
	// we need to do the queuing AFTER the vehicle has been moved - that way CM_SubQueue::evaluateMatchPriority will know the 
	// new location of the vehicle
	if job &lt;&gt; null then
		if _newLocation.isInsideYard then //epr par 20797 only when moving to the yard not when in transit to the p gate
			// moving around yard
			// if we are coming from p-gate into yard this will move jobs from gate Q into yard Q
			// if we are just moving around yard then probably no change to Q
			create rtArbiter transient;
			rtArbiter.reset; 
			foreach wle in job.workListEntries discreteLock do
				// if wle complete then there will be no Q entry for it :-)
				foreach rtQueueEntry in wle.allRTQueueEntries do
					//epr par 30385 4/12/12 needed to handle director tasks aswell	
					rtArbiter.moveEntryBasedOnToLocation(rtQueueEntry, terminal);	
				endforeach;
			endforeach;
		endif;
	endif;
	// par 24418 - end 28/06/2010
epilog
	
	delete rtArbiter;
	
end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
        <Parameter name="_newLocation" type="CM_YardController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlMoveWagons" id="fc4a2a7e-8c04-461a-912c-49ca7c44a2cf">
        <updating/>
        <source>utlMoveWagons(control : CMIF_WagonMoveController input; _passport : CM_Passport input) updating;

/*

Purpose:			Performs move of wagons for trains / rail areas

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2009	consw1	PAR 19710 - SFW1067 Rail Simplifications
27 Jun 2022 jlika1	TFS 53971 - MTN - Rail Confirm App to React
12 Sep 2023 navrv30 TFS 57744: EUP -FR 53740 | Wagon Track Planning - Error 1300
*/

vars
	wagonAtSamePos : CM_Wagon;
	wagonOrginalPos : Integer;
	allWagonsSize : Integer;
begin
	self.initialiseActivity();
	if control.myTargetRailLine &lt;&gt; null then
		allWagonsSize := control.myTargetRailLine.allWagons.size();
	endif;
	if control.swapWagons then
		if control.myTargetRailLine &lt;&gt; null and  allWagonsSize &gt; 0 and control.targetPosition &lt;= allWagonsSize then   //12 Sep 2023 navrv30 #57744
			wagonAtSamePos := control.myTargetRailLine.allWagons[control.targetPosition];   
		endif;
		if control.allWagons.size() = 1 then
			wagonOrginalPos := control.allWagons.first.getWagonPosition().asIntegerJMT();
		endif;
	endif;
	
	control.executeMove(_passport);
	
	if app.myPassport.noErrors then
		if wagonAtSamePos &lt;&gt; null then
			control.targetPosition := wagonOrginalPos;
			control.allWagons.clear();
			control.allWagons.add(wagonAtSamePos);
			control.executeMove(_passport);
		endif;
	endif;
		
epilog

end;</source>
        <Parameter name="control" type="CMIF_WagonMoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlOOWRejection" id="0e82f5a9-53e9-4a22-8fef-4ac296e41a6e">
        <source>utlOOWRejection(	_workOrder : CM_WorkOrder input;
					_remark : CM_PredefinedRemark;
					_lengthOfTime : Decimal;
					_passport : CM_Passport input
					);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2018	jlgndl1	Initial creation	TFS 37928
18 Jun 2018	NDL	TFS 39167
18/10/2018	cnwer1	TFS 41310 
25/01/2019	jlger1	TFS 42924
*/

vars
	remarkDesc : String;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	if _remark &lt;&gt; null then
		remarkDesc :=_remark.description;
	endif;
	
	
	if _workOrder = null then
		return;
	endif;
	
	if _passport.noErrors then
		
		self.myUpdateAuditAgent.audUpdateGeneric(_workOrder, true);
		//epr TFS 41310 18/10/18
		_workOrder.setNotApproved( app.myPassport.myUser.code,remarkDesc, _lengthOfTime );		
		
		//jlier1 29/5/25 MTN-34591 
		_workOrder.causeTerminalEvent(Event_WorkOrder_Update);
		
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(_workOrder, false);
		endif;
				
	endif;

epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_remark" type="CM_PredefinedRemark"/>
        <Parameter name="_lengthOfTime" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlPackageBulk" id="8e47f900-cf67-44c7-be86-13c2aa016334">
        <source>utlPackageBulk( _sourceTi : CM_Bulk input;
				_newTiId : String;
				_quantity : Integer;
				_itemNettWeight : Decimal;
				_pkgingWeight : Decimal;
				_cargoType : CM_CargoType;
				_product : CM_Product;
				_operator : CM_Operator;
				_lc : CM_LocationsController;
				_passport : CM_Passport input
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2014	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	breakBulkTi : CM_BreakBulkGeneric;
	iter : Iterator;
	bbIsNew : Boolean;	//18 Feb 2020	NDL	TFS 48532

begin

	iter := _lc.allTrackedItems.createIterator;
	while iter.next(ti) do
		if ti.id &lt;&gt; _newTiId then
			continue;
		endif;
		if ti.myCargoType &lt;&gt; _cargoType then
			continue;
		endif;
		if _product &lt;&gt; null and ti.myProduct &lt;&gt; _product then
			continue;
		endif;
		if ti.myOperator &lt;&gt; _operator then
			continue;
		endif;
		if not ti.isKindOf( CM_BreakBulkGeneric ) then
			continue;
		endif;
		breakBulkTi := ti.CM_BreakBulkGeneric;
	endwhile;

	if breakBulkTi = null then
		breakBulkTi := _lc.createNewCargoForLocation(_cargoType, _product, _newTiId, _operator).CM_BreakBulkGeneric;
		bbIsNew := true;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;

	_sourceTi.packageBulk(	breakBulkTi,	//_breakBulkTi : CM_BreakBulkGeneric;
							bbIsNew,	//_bbIsNew : Boolean;
							_quantity,	//_quantity : Integer;
							_itemNettWeight,	// _itemNettWeight : Decimal;
							_pkgingWeight,	// _pkgingWeight : Decimal;
							_passport	//_passport : CM_Passport input
							);

epilog

	delete iter;

end;</source>
        <Parameter name="_sourceTi" type="CM_Bulk" usage="input"/>
        <Parameter name="_newTiId" type="String"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_itemNettWeight" type="Decimal"/>
        <Parameter name="_pkgingWeight" type="Decimal"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlPackingType" id="f369ec07-d392-47ee-98e9-51b760376332">
        <source>utlPackingType();
// ---------------------------------------------------------------------------
// Created:     16 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin

end;</source>
    </JadeMethod>
    <JadeMethod name="utlPortCodeMakeActiveInactive" id="86f48bf2-8614-4a96-abdb-27d8470142ea">
        <source>utlPortCodeMakeActiveInactive(pProxyPort:CM_Port; _isActive : Boolean; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2016	cnwma1	TFS #2645:PAR38195 DPH - Discharge Port not found

*/

vars
	cancelSave :Boolean;
	realPort:CM_Port;
	expectedEdition:Integer;
	eventStr : String;
	codeChanged:Boolean;
	theTerminal : CM_Terminal;
begin

	self.initialiseActivity();

	pProxyPort.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyPort.pxyGetRealObjectAndEdition(realPort, expectedEdition);
	
	if realPort = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Port.name, null, null);
		return;
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realPort);

	if _passport.noErrors and realPort.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Port', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realPort, true);
	endif;
	
	if _passport.noErrors then

		realPort.setIsActive(_isActive);
		if _isActive then
			realPort.CM_Port.setIsNotAvailableForEntry(false);
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realPort, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyPort" type="CM_Port"/>
        <Parameter name="_isActive" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlProcessEDIBOLConsist" id="4b9b6b2a-e469-4660-a6cd-fd0608b4704b">
        <updating/>
        <source>utlProcessEDIBOLConsist(_ediData :CM_EDIDataBOL input; _validateOnly : Boolean; _passport : CM_Passport input)updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
19 Jun 2012	cnwcs5 	par 29747  	refactor to enable linking EDI Tracked Items to all CM_Error objects
08 Oct 2015	cnwrs1	Par 36863  	make EDI consistant times when refreshing progress bar
16 May 2016	cnwns1	TFS 488  	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
29 Oct 2019	cnwrs1	TFS 47281
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/
vars
	dynaDict			: DynaDictionary;
	iter				: Iterator;
	ediTI				: CM_EDITrackedItem;
	ediBOLHeader		: CM_EDIBOLHdrTI;
	proxy				: CM_BOLIn;
	realBOL				: CM_BOL;
	mode				: String;
	dummy				: CM_ObjectArrayActual;
	count, total		: Integer;
	errorSet			: CM_ErrorSet;
	progressTS 			: TimeStamp;
	updateStr			: String;
begin
	create errorSet transient;
	create dummy transient;
	create dynaDict transient;
	
	dynaDict.setMembership(CM_EDITrackedItem);
	dynaDict.addMemberKey(CM_EDITrackedItem::id.name, false, false);
	dynaDict.addMemberKey(CM_EDITrackedItem::messageNum.name, true, false);
	dynaDict.endKeys(true);
	
	_ediData.allEDITrackedItems.copy(dynaDict);
	total := dynaDict.size();
	
	updateStr := "Processing BOLs " &amp; count.String &amp; "/" &amp; total.String;
	
	progressTS := app.actualTimeServer();
	_ediData.updateProgress(progressTS, updateStr, total, count, true, _passport); 
	
	iter	:=	dynaDict.createIterator();
	
	on CM_Exception do _ediData.xHandlerCMExceptionUserObject (exception, ediTI);

	while iter.next(ediTI) do
		count := count + 1;
		
		_ediData.updateProgress(progressTS, updateStr, total, count, false, _passport);
		
		if not ediTI.isKindOf(CM_EDIBOLHdrTI) then
			// when the file is loaded all the BOL dtls get linked to the bol headers
			continue;
		endif;
		// the utls  we call have code that assumes passport contains only errors generted during that utl
		_passport.moveErrorsToSet (errorSet);
		
		ediBOLHeader	:= ediTI.CM_EDIBOLHdrTI;
		mode			:= ediTI.messageMode;
		
		if mode = CM_EDITrackedItem.EDI_ACTION_DELETE then
			realBOL	:=	_ediData.getRealBOL (ediTI.CM_EDIBOLHdrTI);		
			
			if realBOL &lt;&gt; null then
				app.myUtilityDA.utlDeleteBOL(realBOL, _passport);	
			endif;

		elseif mode = CM_EDITrackedItem.EDI_ACTION_ADD or mode = CM_EDITrackedItem.EDI_ACTION_UPDATE	then
			
			//epr par 37090 CCMS 2538 29/10/15
			ediBOLHeader.verifySelf();
			
			proxy 	:= ediBOLHeader.createProxy (null, realBOL);
			
			if realBOL = null then
				dummy.clear();
				app.myUtilityCA.utlCreateBOL(proxy, _passport, null, realBOL, dummy);
			else
				app.myUtilityUA.utlUpdateBOLIn(proxy, _passport);
			endif;
			
			delete proxy;	// wont need it again
		endif;
		// did the add/update/delete get any errors
		if not _validateOnly and _passport.hasErrors then
			return;
		endif;			
	endwhile;
	
	_ediData.updateProgress(progressTS, updateStr, total, count, true, _passport);
	
epilog
	_passport.addErrorsFromSet (errorSet);
	
	delete proxy;	// incase of exception
	delete dummy;
	delete dynaDict;
	delete iter;
	delete errorSet;
end;
</source>
        <Parameter name="_ediData" type="CM_EDIDataBOL" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlProcessEDICargo" id="aa17fa73-2f1f-4be8-9424-0d03ea917f40">
        <source>utlProcessEDICargo(_ediData :CM_EDIDataCargoBySite input; _validateOnly : Boolean; _passport : CM_Passport input);
/* Changes

Date		Name	TFS#		Description
============================================================================
20 Jun 2012	cnwcs5	par 29747 	refactor to enable linking EDI Tracked Items to all CM_Error objects
26 Jun 2012	cnwcs5	par 29747:1 fix problem with errors
09 May 2013	cnwcs5	par 31521  
09 Dec 2014 cnwdb2 	PAR 35364
08 Oct 2015	cnwrs1	Par 36863 	make EDI consistant times when refreshing progress bar
16 May 2016	cnwns1	TFS 488  	Multi Timezone Support
15 Jun 2017	cnwrs1	TFS 4462 	SNO add Terminal Operator, Unknown Seal and support multiple seals
08 Jan 2018	jlgrs1	TFS 36430 	Penn Ship Manifest too many locks
03 Aug 2017	jlgrh7 TFS 39461 	STWR - EDI - 1309 when loading Hazards Details
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
10 Nov 2022	navkc1	Bug 55382: MTN - Cargo Group Details recalculated after each change to TI when bulk editing
11 Mar 2025 navhn30 Bug MTN-34307: TPT - Code 88820 when loading cargo onsite (Same ID, Different Cargo Type/Subtype)
19 Nov 2025 navhl20 Bug MTN-36492: TPA - Overall System Slowness
============================================================================*/
vars
	terminal				: CM_Terminal;
	dynaDict				: DynaDictionary;
	total, count			: Integer;
	obj						: Object;
	mode, lastID			: String;
	lastCargoType			: CM_CargoType;
	realTI					: CM_TrackedItem;
	updateController		: CMIF_TIUpdateController;
	ediTI					: CM_EDICargoTI;
	errorSet				: CM_ErrorSet;
	cargoType				: CM_CargoType;
	
	//cnwmc5 - 10 Dec 2013 - PAR 32547
	parentTI				: CM_TrackedItem;
	tiColl					: CM_TIByCargoTypeIdDict;

	voyage 					: CM_Voyage;
	progressTS 				: TimeStamp;
	allEDISealDetails		: DynaDictionary;
	sealIter 				: Iterator;
	sealObj 				: CM_EDITrackedItem;
	ediCargo, otherCargo	: CM_EDICargoTI;
	cargoTIs 				: CM_EDITIById;
	
	allEDIHazDetails 		: DynaDictionary;	//18 Nov 2016	NDL	TFS 2843 / 2604
	hazIter 				: Iterator;	//18 Nov 2016	NDL	TFS 2843 / 2604
	startObject 			: Object;	//18 Nov 2016	NDL	TFS 2843 / 2604
	hazObj 					: Object;	//18 Nov 2016	NDL	TFS 2843 / 2604
	edi 					: CM_EDITrackedItem;	//18 Nov 2016	NDL	TFS 2843 / 2604
	ediHazDetails 			: CM_EDIHazDetailsTI;	//18 Nov 2016	NDL	TFS 2843 / 2604
	pxyTiHazard 			: CM_TIHazard;	//18 Nov 2016	NDL	TFS 2843 / 2604
	processedHazards 		: CM_EDITIById;	//18 Nov 2016	NDL	TFS 2843 / 2604
	cm_CargoGroup			: CM_CargoGroup; //TFS 53390
	cargoGroupSiteTrxAction : CMIF_TrxActionCargoGroup; //TFS 53390
	cargoSubType			: CM_Product;
	lastCargoSubType		: CM_Product;
	
begin
	progressTS := app.actualTimeAppServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support	//19.11.2025 navhl20 #36492
	terminal	:= _ediData.getMyTerminal;
	voyage := _ediData.getMyVoyageObject(); // PAR 34535
	
	updateController := _ediData.createTIUpdateController();
	if _validateOnly then
		//epr par 37446 1/2/16
		//we are aborting so don't audit for performance if validating only
		updateController.isAuditTextRequired := false;
		updateController.dontCreateTransCM_Edit:=true;
	endif;
		
	create errorSet transient;
	create dynaDict transient;
	create tiColl transient;
	create processedHazards transient;
	create cargoTIs transient;

	
	//18 Nov 2016	NDL	TFS 2843 / 2604
	create allEDIHazDetails transient;
	allEDIHazDetails.setMembership(CM_EDIHazDetailsTI);
	allEDIHazDetails.addMemberKey( CM_EDIHazDetailsTI::id.name, false, true ); 
	allEDIHazDetails.addMemberKey( CM_EDIHazDetailsTI::cargoTypeDescr.name, false, true ); 
	allEDIHazDetails.addMemberKey( CM_EDIHazDetailsTI::cargoSubType.name, false, true ); 
	allEDIHazDetails.endKeys(true);
	
	create allEDISealDetails transient;
	allEDISealDetails.setMembership(CM_EDISealTI);
	allEDISealDetails.addMemberKey( CM_EDISealTI::id.name, false, true ); 
	allEDISealDetails.endKeys(true);

	dynaDict.setMembership(CM_EDICargoTI);
	dynaDict.addMemberKey(CM_EDICargoTI::parentCargoID.name, false, false);	// so we process parents before children Par 32854
	dynaDict.addMemberKey(CM_EDICargoTI::locationId.name, false, false);
	dynaDict.endKeys(true);

	//_ediData.allEDITrackedItems.copy(dynaDict);
	//18 Nov 2016	NDL	TFS 2843 / 2604
	foreach edi in _ediData.allEDITrackedItems do
		if edi.isEDIHazDetails then
			allEDIHazDetails.add(edi);
			continue;
		endif;
		if edi.isEDISealDetails then
			allEDISealDetails.add(edi);
			continue;
		endif;
		dynaDict.add(edi); 
		cargoTIs.add(edi);
	endforeach;
	
	if not allEDISealDetails.isEmpty then
		sealIter := allEDISealDetails.createIterator;
		while sealIter.next(sealObj) do
			ediCargo := cargoTIs[sealObj.id].CM_EDICargoTI;
			if ediCargo = null then
				continue;
			endif;
			app.myUtilityUA.utlUpdateEDITIParent(sealObj, ediCargo, _passport);
//			app.myTrxUA.trxUpdateEDITIParent(sealObj, ediCargo, _passport);
//			sealType := app.myRoot.getSealType(sealObj.CM_EDISealTI.sealEDIType);
//			if sealType = null then
//				sealType := app.myRoot.getSealType(SealType_Unknown);
//			endif;
		endwhile;
		delete sealIter;
	endif;
	
	on CM_Exception do _ediData.xHandlerCMExceptionUserObject (exception, ediTI);

	// we expect everything to be NEW cargo and
	// we don't expect the same cargo item to be in the file more then once (even tho technically we can handle it)

	_ediData.verifyUniqueness();// ### TFS BUG 58101 22MAY2023 NAVAB1
	
	foreach obj in _ediData.allEDITrackedItems do
		if not obj.isKindOf(CM_EDICargoTI) then
			continue;
		endif;
		ediTI	:= obj.CM_EDICargoTI;
		
		_passport.moveErrorsToSet (errorSet);
		
		
		//18 Nov 2016	NDL	TFS 2843 / 2604
		if not allEDIHazDetails.isEmpty then
			hazIter := allEDIHazDetails.createIterator;
			startObject := allEDIHazDetails.getAtKey( ediTI.id, ediTI.cargoTypeDescr, ediTI.product );//17.May.24 navsp1 TFS 62254 - product included
			if startObject &lt;&gt; null then
				hazIter.startAtObject( startObject);
				while hazIter.next( hazObj ) do
					ediHazDetails := hazObj.CM_EDIHazDetailsTI;
					if ediHazDetails.id &lt;&gt; ediTI.id then
						break;
					endif;
					if ediHazDetails.cargoTypeDescr &lt;&gt; ediTI.cargoTypeDescr then
						break;
					endif;
					//processedHazards.add( ediHazDetails );													//-TFS39461
					processedHazards.addNoDuplicates( ediHazDetails,false );				//+TFS39461
					if ediHazDetails.myParent = ediTI then 
						continue;
					endif;
					app.myUtilityUA.utlUpdateEDITIParent(ediHazDetails, ediTI, _passport);
				endwhile;
			endif;
			delete hazIter;
		endif;
		
		ediTI.CM_EDICargoTI.verifySelf();	
		
		if _passport.hasErrors then	
			if  _validateOnly then
				// any errors during load - we give up
				return;
			endif;
		endif;		
		
		// 32476 - Break-Bulk cargo can be spread over multiple locations 
		cargoType := terminal.myRoot.allCargoTypesById[ediTI.cargoType];
		//11.03.25	 navhn30	MTN-34307	start
		if cargoType = null or not cargoType.isAllowDuplicates  then	
			if lastID &lt;&gt; null then  
				if ediTI.id = lastID and lastCargoType = cargoType then
				//	app.raiseCMException3(ERR_DUPLICATE_KEY, ediTI.id, ' in file ', null, ETRow_Id, ediTI);
					app.raiseCMException1(Already_exists_ediTI, ediTI.id, ETRow_Id, ediTI); //cnwdb2	PAR 35364
				endif;
			endif;
		else
			cargoSubType := cargoType.allProducts.getAtKey(null,ediTI.product);
			if cargoType.useCargoSubtypeForUniqueness then
				if ediTI.id = lastID and lastCargoType = cargoType and cargoSubType = lastCargoSubType then
					app.raiseCMException1(Already_exists_ediTI, ediTI.id, ETRow_Id, ediTI);
				endif;
			endif;
			lastCargoSubType := cargoSubType;
		endif;
		lastID := ediTI.id;
		lastCargoType := cargoType;
		//11.03.25	 navhn30	MTN-34307	end
	endforeach;
	
	//18 Nov 2016	NDL	TFS 2843 / 2604
	if processedHazards.size &lt;&gt; allEDIHazDetails.size then
		delete hazIter;
		hazIter := allEDIHazDetails.createIterator;		
		while hazIter.next( hazObj ) do
			ediHazDetails := hazObj.CM_EDIHazDetailsTI;
			if processedHazards.includes( ediHazDetails ) then
				continue;
			endif; 
			app.raiseCMException1(Hazar_detai_recor_not_loade_ca, ediHazDetails.id.toUpper,ETRow_CargoID,ediHazDetails); // //epr TFS 4139 27/4/17 changed from parent Cargo id	
		endwhile;
		delete hazIter;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	total			:= dynaDict.size;
	count 			:= null;
	_ediData.updateProgress(progressTS, "Processing Cargo " &amp; count.String &amp; "/" &amp; total.String, total, count, true, _passport);
	
	foreach obj in dynaDict do
		ediTI	:= obj.CM_EDICargoTI;
		mode	:= ediTI.messageMode;
		
		count := count + 1;
		_ediData.updateProgress(progressTS, "Processing Cargo " &amp; count.String &amp; "/" &amp; total.String, total, count, false, _passport);
		
		_passport.moveErrorsToSet (errorSet);

		if mode = CM_EDITrackedItem.EDI_ACTION_DELETE then
			realTI := _ediData.getRealCargoItem(ediTI);
			
			if realTI &lt;&gt; null then 
				cm_CargoGroup := realTI.myCargoGroup; //TFS 53390
				app.myUtilityDA.utlDeleteTI(realTI, false, _passport); 
				
				if not _validateOnly and _passport.hasErrors then	
					// any errors during load
					break;
				endif;
				
				CMIF_TrxActionCargoGroup@createAction(null, cm_CargoGroup, _passport); // 10/11/2022	navkc1	#55382
				
				/* // 10/11/2022	navkc1	#55382 Moved to CMIF_TrxActionCargoGroup@createAction
				//TFS 53390
				if _passport.noErrors() and cm_CargoGroup &lt;&gt; null then
					create cargoGroupSiteTrxAction transient;
					//cargoGroupSiteTrxAction.setMyCargoGroup(realTI.myCargoGroup,CM_TrxControlAgent.Trx_Delete);
					cargoGroupSiteTrxAction.setMyCargoGroup(cm_CargoGroup);
					_passport.addTrxPostAction(cargoGroupSiteTrxAction);
				endif;
				*/	// 10/11/2022	navkc1	#55382
			endif;
			continue;
		endif;
		
		if (mode = CM_EDITrackedItem.EDI_ACTION_ADD or mode = CM_EDITrackedItem.EDI_ACTION_UPDATE or mode = CM_EDITrackedItem.EDI_ACTION_MODIFY) then			//cnwmc5 - 15 April 2014 - CCMS 2352
			//cnwmc5 - 10 Dec 2013 - PAR 32547
			if ediTI.parentCargoID &lt;&gt; null and ediTI.parentCargoType &lt;&gt; null then
				/* PAR 34535 WAS
				parentTI := terminal.searchForOnsiteTI(ediTI.parentCargoID, matches, app.myRoot.getCargoTypeFromAbbrevOrDescr(ediTI.parentCargoType).type());
				NOW */
				parentTI := _ediData.getParentTI(ediTI); // PAR 34535 handle on site and on ship

				if parentTI &lt;&gt; null then
					tiColl.addNoDuplicates(parentTI,false);
				endif;
			endif;
			
			realTI := ediTI.createUpdateTrackedItem (terminal, tiColl, _validateOnly, updateController, _passport);	// par 31521		//cnwmc5 - 10 Dec 2013 - PAR 32547
			
			if not _validateOnly and _passport.hasErrors then
				return;
			endif;
			
			CMIF_TrxActionCargoGroup@createAction(realTI, null, _passport); // 10/11/2022	navkc1	#55382
			
			/*
			//TFS 53390	// 10/11/2022	navkc1	#55382 Moved to CMIF_TrxActionCargoGroup@createAction
			if _passport.noErrors() and realTI.myCargoGroup &lt;&gt; null then
				create cargoGroupSiteTrxAction transient;
				cargoGroupSiteTrxAction.setMyCargoGroup(realTI.myCargoGroup);
				_passport.addTrxPostAction(cargoGroupSiteTrxAction);
			endif;
			*/	// 10/11/2022	navkc1	#55382
		endif;
	endforeach;
	
	_ediData.updateProgress(progressTS, "Processing Cargo " &amp; count.String &amp; "/" &amp; total.String, total, count, true, _passport);
epilog
	// if we get a non-continuable exception we will end up here so need to
	// make sure we have all our errors
	_passport.addErrorsFromSet (errorSet);
	delete errorSet;
	delete dynaDict;
	delete updateController;
	delete tiColl;				//cnwmc5 - 10 Dec 2013 - PAR 32547
	delete allEDIHazDetails;	//18 Nov 2016	NDL	TFS 2843 / 2604
	delete hazIter;				//18 Nov 2016	NDL	TFS 2843 / 2604
	delete processedHazards;	//18 Nov 2016	NDL	TFS 2843 / 2604
	delete cargoTIs;
	delete allEDISealDetails;
	delete sealIter;

end;</source>
        <Parameter name="_ediData" type="CM_EDIDataCargoBySite" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlProcessEDIPrenote" id="cf5da99e-c901-4531-ada8-c26a77d35c49">
        <source>utlProcessEDIPrenote(_interFace : CMIF_PreNote; _validateOnly : Boolean; _ediData : CM_EDIData input; _passport : CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		27 July 2010 by cnwdad1
//
// Purpose:		Takes an array of CM_InterfaceObjects(all members should be instances
//				of CM_IntFaceReceival) and creates/update/delete pre-notified tracked
//				items from these.
//
// Parameters:	_intFaceArray - A reference to an array of CMIF TO Objects.
//				_validateOnly - True if we are validating only.
//				_passport - A reference to the current user's passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 18/09/2012	cnwcs5		par 30316 - link errors to EDI TI so Jump to Line works in EDI Ops Form
//									  - also re-work trx/utl so all transaction control etc is in trx not utl
//									  - also use standard approach for saving/restoring passport errors
// 25/07/0213	cnwcs5		CCMS POL 2221 / par 32094 - use CM_EDITrackedItem constants
// 14/12/2015   cnsgb1      PAR 37172 - Allow "Modify" as well as "Update"
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
// --------------------------------------------------------------------------------
vars
	itemObj : CMIF_TIObject;
	obj : Object;
	ediTI : CM_EDIPrenoteTI;
	errorSet : CM_ErrorSet;
begin
	self.initialiseActivity();

	on CM_Exception do _ediData.xHandlerCMExceptionUserObject(exception, ediTI);

	create errorSet transient;
	itemObj := _interFace;
	obj := itemObj.myUserObject;
	if obj &lt;&gt; null and obj.isKindOf(CM_EDIPrenoteTI) then
		ediTI := obj.CM_EDIPrenoteTI;
	else
		ediTI := null;
	endif;
	if itemObj.action = CM_EDITrackedItem.EDI_ACTION_ADD then
		app.myUtilityCA.utlCreatePreNote(itemObj.CMIF_PreNote, false, false, _passport);
		
	elseif itemObj.action = CM_EDITrackedItem.EDI_ACTION_UPDATE or
		   itemObj.action = CM_EDITrackedItem.EDI_ACTION_MODIFY then
		app.myUtilityUA.utlUpdatePreNote(itemObj.CMIF_PreNote, false, false, false, _passport);
		
	elseif itemObj.action = CM_EDITrackedItem.EDI_ACTION_DELETE then
		app.myUtilityDA.utlDeletePreNote(itemObj.CMIF_PreNote, false, false, _passport);
	endif;
	
	if _passport.noErrors then
		if ediTI &lt;&gt; null then								
			ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED);
		endif;
	else
		// we've had some errors
		_passport.moveErrorsToSet(errorSet);
	endif;
epilog
	_passport.addErrorsFromSet(errorSet);
	delete errorSet;
end;</source>
        <Parameter name="_interFace" type="CMIF_PreNote"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlProcessEDIPrenotes" id="fc36868b-dbd7-454b-a311-916a9cf9e7c6">
        <updating/>
        <source>utlProcessEDIPrenotes(_intFaceArray : CMIF_PrenoteSet; _validateOnly : Boolean; _ediData : CM_EDIData input; _passport : CM_Passport input) updating ;
// --------------------------------------------------------------------------------
// Created:		27 July 2010 by cnwdad1
//
// Purpose:		Takes an array of CM_InterfaceObjects (all members should be instances
//				of CM_IntFaceReceival) and creates/update/delete pre-notified tracked
//				items from these.
//
// Parameters:	_intFaceArray - A reference to an array of CMIF TO Objects.
//				_validateOnly - True if we are validating only.
//				_passport - A reference to the current user's passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 18/09/2012	cnwcs5		par 30316 - link errors to EDI TI so Jump to Line works in EDI Ops Form
//									  - also re-work trx/utl so all transaction control etc is in trx not utl
//									  - also use standard approach for saving/restoring passport errors
// 25/07/0213	cnwcs5		CCMS POL 2221 / par 32094 - use CM_EDITrackedItem constants
// 14/12/2015   cnsgb1      PAR 37172 - Allow "Modify" as well as "Update"
// 13 Oct 2017	jlgrs1		TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 19 Spe 2018  jlgrh7 		TFS 39839    POL - [Fwd: ##RE-8414## : Error in prenoting PONU2919363]    
// 29 Jan 2019	jlgzm1		TFS 41915 Update status of child EDI TIs
// 20 Oct 2020	jlgmd1		TFS 50204	Refactor progress updates to superclass method
// --------------------------------------------------------------------------------
vars
	itemObj				: CMIF_TIObject;
	childItemObj		: CMIF_TIObject;
	obj					: Object;
	childObj			: Object;
	ediTI				: CM_EDIPrenoteTI;
	childEDITI			: CM_EDIPrenoteTI;
	errorSet			: CM_ErrorSet;
	gotLockException 	: Boolean; 					//+TFS39839
	error 				: CM_Error;					//+TFS39839
	
	partsDone,
	partsInJob			: Integer;
	progressTS 			: TimeStamp;
	progressStr			: String;
begin
	self.initialiseActivity();

	on CM_Exception do _ediData.xHandlerCMExceptionUserObject (exception, ediTI);		// par 30316 Sept 2012
	on LockException do agtPassportSilLckExHandlerFlg(exception, 0, gotLockException, _passport);            //+TFS39839 Arm Lock Exception to get Lock Flag
	on DeadlockException do agtPassportSilDLckExHandlerFlg(exception, gotLockException, _passport); //tfs41915
	
	create errorSet transient;															// par 30316 Sept 2012
	
	partsInJob	:= _intFaceArray.size();
	partsDone	:= null;
	
	progressTS	:= app.actualTimeServer();
	progressStr	:= app.getString(Loading_EDI_Data_Total, partsInJob.display);
	
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	foreach itemObj in _intFaceArray do
		partsDone := partsDone + 1;
		_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		
		obj := itemObj.myUserObject;												// par 30316 Sept 2012
		
		if obj &lt;&gt; null and obj.isKindOf (CM_EDIPrenoteTI) then						// par 30316 Sept 2012
			ediTI := obj.CM_EDIPrenoteTI;											// par 30316 Sept 2012
		else																		// par 30316 Sept 2012
			ediTI := null;															// par 30316 Sept 2012
		endif;																		// par 30316 Sept 2012
	
		if not itemObj.isKindOf(CMIF_PreNote) then
			// never going to happen
			app.raiseUnexpectedProgramError(class.name, method.name, "Item is not a preNote (" &amp; itemObj.String &amp; ")");
			return;
		endif;
		
		if itemObj.action = CM_EDITrackedItem.EDI_ACTION_ADD then
			app.myUtilityCA.utlCreatePreNote(itemObj.CMIF_PreNote, false, false, _passport);
			
		elseif  itemObj.action = CM_EDITrackedItem.EDI_ACTION_UPDATE or
		       itemObj.action = CM_EDITrackedItem.EDI_ACTION_MODIFY  then //PAR 37172 cnwgb1 14/12/2015
			app.myUtilityUA.utlUpdatePreNote(itemObj.CMIF_PreNote, false, false, false, _passport);
			
		elseif itemObj.action = CM_EDITrackedItem.EDI_ACTION_DELETE then
			app.myUtilityDA.utlDeletePreNote(itemObj.CMIF_PreNote, false, false, _passport);
		endif;
		
		if _passport.noErrors then
			if ediTI &lt;&gt; null then										// par 30316 Sept 2012									
				ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED);	// par 30316 Sept 2012
				//also update status of any children //tfs41915
				foreach childItemObj in itemObj.allSubItems do
					childObj := childItemObj.myUserObject;
					if childObj &lt;&gt; null and childObj.isKindOf (CM_EDIPrenoteTI) then						
						childEDITI := childObj.CM_EDIPrenoteTI;											
						childEDITI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED);
					endif;			
				endforeach;
			endif;														// par 30316 Sept 2012
		else
			// we've had some errors
			_passport.moveErrorsToSet (errorSet);					// par 30316 Sept 2012
		endif;
	
		if gotLockException then																							//+TFS39839
			beginTransaction;
					ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_LOCKERROR);
			commitTransaction;
			break;																														//Only update all or none
		endif;
		
	endforeach;
	
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
epilog
	_passport.addErrorsFromSet (errorSet);							// par 30316 Sept 2012
	
	 if _passport.hasErrors then                                                                                                                    //+TFS38667
				foreach error in _passport.allErrorWarnings do
						if error.myUserObject = null then
							error.setMyUserObject(ediTI);
						endif;
				endforeach;
	endif;
	delete errorSet;
end;</source>
        <Parameter name="_intFaceArray" type="CMIF_PrenoteSet"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlProcessEDIShipManifest" id="d0e64ffb-1467-4a56-b7ef-e0d22635788f">
        <updating/>
        <source>utlProcessEDIShipManifest(_ediData :CM_EDIDataShipManifest input; _validateOnly : Boolean; _passport : CM_Passport input)updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
19/06/2012	cnwcs5 	par 29747 - refactor to enable linking EDI Tracked Items to all CM_Error objects
26/06/2012	cnwcs5	par 29747:1 - fix problem with errors
09/05/2013	cnwcs5	par 31521 -
09/12/2014  cnwdb2  PAR 35364
08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
05 Jul 2017	jlgrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
30 Nov 2022 navma1  ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
16 Jan 2023	jlier1	TFS 55788 - Ship Manifest for IFCSUM can be onship or on site cargo 
20 Mar 2023	navdap1	TFS 56793 PRP - Suzano EDI - Shipment Download
07 Aug 2023	jlirs1	TFS 59324 (58026) Sea Manifest for non partial	EUP
08 Aug 2023	navdap1	TFS 59721 EUP Mainfest Verify of Work Orders
15 Aug 2023	navdap1	TFS 59844 EUP FR | 53824 - Manifest EDI - Work order must have at least one tracked item error
15 Nov 2023	navcs2	ChangeRequest 60866: EUP | Manifest - Single Work Order per transport
04 Mar 2024	navdap1	TFS 62676 EUP - Cargo Group list is not visible in Voyage Ops after uploading of EDIs
14 Aug 2024 navmd1	TFS 61725 Further changes to only go into the Work Order utl if we're not doing validation
============================================================================*/

vars
	terminal			: CM_Terminal;
	ediTI				: CM_EDITrackedItem;
	ediCargoTI			: CM_EDICargoTI;
    ediToDoTask         : CM_EDIToDoTaskTI;
	ediBOLHeader		: CM_EDIBOLHdrTI;
	ediHazDetail 		: CM_EDIHazDetailsTI;//22 Nov 2016	NDL	TFS 2843 / 2604
	lastID, mode		: String;
	realTI				: CM_TrackedItem;
    childTI             : CM_TrackedItem;
	updateController	: CMIF_TIUpdateController;
	errorSet			: CM_ErrorSet;
	bolDD, tiDD, tdDD	: DynaDictionary;	// to hold BOL Headers
	thDD				: DynaDictionary;	//22 Nov 2016	NDL	TFS 2843 / 2604
	obj					: Object;
	realBOL				: CM_BOL;
	pxyBOL				: CM_BOLIn;
    toDoTaskDesc        : CM_ToDoTaskDesc;
	dummy				: CM_ObjectArrayActual;
	tiColl				: CM_TIByCargoTypeIdDict;	// keep track of all ti's on manifest
    total, count        : Integer;
    action              : String;
	oldWarningsIgnored	: Boolean;				//cnwmc5 - 14 Oct 2014 - PAR 34952
	cargoType 			: CM_CargoType;
	progressTS 			: TimeStamp;
	startTS 			: TimeStamp;
	previousRealTI		: CM_TrackedItem; //22 Nov 2016	NDL	TFS 2843 / 2604
	tiHaz				: CM_TIHazard; //22 Nov 2016	NDL	TFS 2843 / 2604
	tiHazDict			: CM_HazardByCodeDict; //22 Nov 2016	NDL	TFS 2843 / 2604
	cargoTIs 			: CM_EDITIById;
	allEDISealDetails 	: DynaDictionary;
	sealIter 			: Iterator;
	sealObj 			: CM_EDITrackedItem;
	ediCargo 			: CM_EDICargoTI;
	root				: CM_Root;
//	replace : Boolean;
//	workOrder : CM_WorkOrder;
//	cargoGroup : CM_CargoGroup;
	voyage : CM_Voyage;
	manifestNumber : String;
	objArray : CM_ObjectArray;
	cgTISet : CM_TISet;
	cgItem	 : CM_CargoGroup;
	controller : CMIF_CargoGroupDtlController;	// TFS 62676
begin
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	startTS := progressTS;
	
	if _validateOnly then
        action := "Validating ";
    else
        action := "Updating ";
    endif;
	
	terminal	:= _ediData.getMyTerminal;
	root		:= terminal.myRoot;
	
	updateController := app.createTIUpdateControl(TI_UPDMODE_BAYPLAN, null, null);
		
	create errorSet transient;
	create tiColl transient;
	create cgTISet transient;
	
	_ediData.verifyFileCountAndOperator(errorSet, _passport);		// TFS 56793
	
	create bolDD transient;
	bolDD.setMembership(CM_EDITrackedItem);
	bolDD.addMemberKey(CM_EDITrackedItem::id.name, false, false);
	bolDD.addMemberKey(CM_EDITrackedItem::messageNum.name, true, false);
	bolDD.endKeys(true);

	create tiDD transient;
	tiDD.setMembership(CM_EDICargoTI); //jlier1 TFS 55788 16/1/22
	tiDD.addMemberKey(CM_EDICargoTI::parentCargoID.name, false, false);	// so we process parents before children
	tiDD.endKeys(true);
    
    create tdDD transient;
	tdDD.setMembership(CM_EDIToDoTaskTI);
	tdDD.addMemberKey(CM_EDITrackedItem::id.name, false, false);
	tdDD.endKeys(true);
	
	//22 Nov 2016	NDL	TFS 2843 / 2604
	create thDD transient;
	thDD.setMembership(CM_EDIHazDetailsTI);
	thDD.addMemberKey(CM_EDITrackedItem::id.name, false, false);
	thDD.endKeys(true);

	create cargoTIs transient;
	create allEDISealDetails transient;
	allEDISealDetails.setMembership(CM_EDISealTI);
	allEDISealDetails.addMemberKey( CM_EDISealTI::id.name, false, true ); 
	allEDISealDetails.endKeys(true);
	
	on CM_Exception do _ediData.xHandlerCMExceptionUserObject (exception, ediTI);

	/*
	30.11.2022 navma1 #52499
	foreach ediTI in _ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDICargoOnShipTI) do
		cargoTIs.add(ediTI);
	endforeach;
	foreach ediTI in _ediData.allEDITrackedItems where ediTI.isEDISealDetails do
		allEDISealDetails.add(ediTI);
	endforeach;
	*/
	
	//30.11.2022 navma1 #52499
	
	foreach  ediTI in _ediData.allEDITrackedItems do
		
		if ediTI.isEDICargo then //jlier1 TFS 55788 16/1/22
			cargoTIs.add(ediTI);
		
		elseif ediTI.isEDISealDetails then
			allEDISealDetails.add(ediTI);
		
		elseif ediTI.isEDIToDoTaskTI then
			tdDD.add(ediToDoTask );
		
		elseif ediTI.isEDIHazDetails then
			thDD.add( ediTI );
		endif;
	endforeach;
	
	if not allEDISealDetails.isEmpty then
		sealIter := allEDISealDetails.createIterator;
		while sealIter.next(sealObj) do
			ediCargo := cargoTIs[sealObj.id].CM_EDICargoTI;
			if ediCargo = null then
				continue;
			endif;
			app.myUtilityUA.utlUpdateEDITIParent(sealObj, ediCargo, _passport);
		endwhile;
	endif;

	total := _ediData.allEDITrackedItems.size;
    count := 0;
	
	_ediData.updateProgress(progressTS, "Collecting Items " &amp; count.String &amp; "/" &amp; total.String, total, count, true, _passport);
	
	foreach ediTI in _ediData.allEDITrackedItems do	
        count := count + 1;
		_ediData.updateProgress(progressTS, "Collecting Items " &amp; count.String &amp; "/" &amp; total.String, total, count, false, _passport);
		
        if ediTI.isEDIBOLHdrTI then											//30.11.2022 navma1 #52499
			// save off BOL headers as we will process them later
			bolDD.add (ediTI);
			
			ediTI.CM_EDIBOLHdrTI.verifySelf();
			
		elseif ediTI.isEDIBOLDtlTI then										//30.11.2022 navma1 #52499
			ediTI.CM_EDIBOLDtlTI.verifySelf();
			
		elseif ediTI.isEDICargo then				//jlier1 TFS 55788 16/1/22					//30.11.2022 navma1 #52499
			ediCargoTI := ediTI.CM_EDICargoTI;
			
			ediCargoTI.verifySelf(); 
			
			// we can't process the same TI twice it would seem
			//epr par 35952 29/4/15
			cargoType := root.allCargoTypesById[ediTI.cargoType];
			if cargoType = null or not cargoType.isAllowDuplicates then
				if lastID &lt;&gt; null then  
					if ediCargoTI.id = lastID then
						app.raiseCMException1(Already_exists_ediTI, ediCargoTI.id, ETRow_Id, ediCargoTI); //cnwdb2	PAR 35364
	
					endif;
				endif;
			endif;
			lastID := ediCargoTI.id;   
			
			tiDD.add (ediCargoTI);
		
		/*
		30.11.2022 navma1 #52499
        elseif ediTI.isKindOf(CM_EDIToDoTaskTI) then
            // At this stage the Todo Task is only against the BOL. We don't know what containers that 
            // corresponds to, so just add to the list for later processing
            ediToDoTask :=  ediTI.CM_EDIToDoTaskTI;
            tdDD.add(ediToDoTask );
			
		elseif ediTI.isEDIHazDetails then//22 Nov 2016	NDL	TFS 2843 / 2604
			thDD.add( ediTI );
		*/
		
		endif;
		
		if not _validateOnly and _passport.hasErrors then	
			return;
		endif;
		
	endforeach;
	
	_ediData.updateProgress(progressTS, "Collecting Items " &amp; count.String &amp; "/" &amp; total.String, total, count, true, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	total := tiDD.size;
    count := 0;
	_ediData.updateProgress(progressTS, action &amp; "Cargo Items " &amp; count.String &amp; "/" &amp; total.String, total, count, true, _passport);
	
	// if processing EDIDataTransportManifest then need some additional processing 58056 (57074)
//	if not _validateOnly and
	if app.myPassport.isVASEnabled and	// 25 Jul 2023 jlirs1	NFS 59324 (58026) Sea Manifest for non partial	EUP
	   _ediData.myTransportManifest &lt;&gt; null and		// 27 Jul 2023	jlirs1	TFS 59324 (58026) replace not removing cargoGroups and workorders EUP
	   (_ediData.myTransportManifest.statusString = CMIF_JsonHeaderEUP.Status_Replace or
	   _ediData.myTransportManifest.statusString = CMIF_JsonHeaderEUP.Status_Cancel) then		//07 Aug 2023	jlirs1	TFS 59324 (58026) Sea Manifest for non partial	EUP
		app.myUtilityDA.utlCleanupSeaManifest(_ediData.myTransportManifest, _passport);
	endif;
	
	foreach obj in tiDD do
        count := count + 1;
		_ediData.updateProgress(progressTS, action &amp; "Cargo Items " &amp; count.String &amp; "/" &amp; total.String, total, count, false, _passport);
		
        _passport.moveErrorsToSet (errorSet);

		ediTI		:= obj.CM_EDITrackedItem;	// so exception handling works
		ediCargoTI 	:= obj.CM_EDICargoTI;	 //jlier1 TFS 55788 16/1/22
		mode 		:= ediCargoTI.messageMode;																	
		
		if mode = CM_EDITrackedItem.EDI_ACTION_DELETE then
			realTI := _ediData.getRealCargoItem (ediCargoTI);
						
			if realTI &lt;&gt; null then
				app.myUtilityDA.utlDeleteTI(realTI, false, _passport); 
			endif;
				
			if not _validateOnly and _passport.hasErrors then	
				return;
			endif;
			// nothing more to do for deletes
			continue;
		endif;
		
		if mode = CM_EDITrackedItem.EDI_ACTION_ADD or mode = CM_EDITrackedItem.EDI_ACTION_UPDATE or mode = CM_EDITrackedItem.EDI_ACTION_MODIFY then			//cnwmc5 - 15 April 2014 - CCMS 2352
			realTI := ediCargoTI.createUpdateTrackedItem (terminal, tiColl, _validateOnly, updateController, _passport);	// par 31521
		
			if not _validateOnly and _passport.hasErrors then
				return;
			endif;
			
			//cnwmc5 - 22 May 2014 - PAR 34191 - this most likely means that they are doing a 'Modify' for cargo that doesn't exist..
			if realTI = null then
				return;
			endif;
			voyage := realTI.myVoyage;		//25 Jul 2023	jlirs1	NFS 59324 (58026) Sea Manifest for non partial	EUP
			// we need to keep track of all TIs for when we create the BOLs
			tiColl.addNoDuplicates (realTI, false); 
		endif;
		
		if not _validateOnly and _passport.hasErrors then	
			return;
		endif;
	endforeach;
	
	_ediData.updateProgress(progressTS, action &amp; "Cargo Items " &amp; count.String &amp; "/" &amp; total.String, total, count, true, _passport);

	_passport.addErrorsFromSet (errorSet);
	errorSet.clear;    

	if _passport.hasErrors then 
		// we have to stop here if there are errors
		return;
	endif;
   	
	oldWarningsIgnored := _passport.warningsIgnored;		//cnwmc5 - 14 Oct 2014 - PAR 34952
	_passport.setWarningsIgnored(true);						//cnwmc5 - 14 Oct 2014 - PAR 34952
	
	create dummy transient;
	
	total := bolDD.size;
    count := 0;
	_ediData.updateProgress(progressTS, action &amp; "Bills of Lading " &amp; count.String &amp; "/" &amp; total.String, total, count, true, _passport);
	
	foreach obj in bolDD do
        count := count + 1;
		_ediData.updateProgress(progressTS, action &amp; "Bills of Lading " &amp; count.String &amp; "/" &amp; total.String, total, count, false, _passport);
		
		ediTI			:= obj.CM_EDITrackedItem;
		// the utls  we call have code that assumes passport contains only errors generted during that utl
		_passport.moveErrorsToSet (errorSet);
		
		ediBOLHeader	:= ediTI.CM_EDIBOLHdrTI;
		mode			:= ediTI.messageMode;
		
		if mode = CM_EDITrackedItem.EDI_ACTION_DELETE then
			realBOL	:=	_ediData.getRealBOL (ediBOLHeader);		

			if realBOL &lt;&gt; null then
				app.myUtilityDA.utlDeleteBOL(realBOL, _passport);	
			endif;

		elseif mode = CM_EDITrackedItem.EDI_ACTION_ADD or mode = CM_EDITrackedItem.EDI_ACTION_UPDATE	then		
			pxyBOL 	:= ediBOLHeader.createProxy(tiColl, realBOL);
			// 25 Jul 2023	jlirs1	NFS 59324 (58026) Sea Manifest for non partial	EUP
			foreach realTI in tiColl do		
				// We need the real TI here so we can attach it to the BOL Detail.
				if realTI &lt;&gt; null and
				   realTI.billOfLading = pxyBOL.number then
					pxyBOL.allTrackedItems.addNoDuplicates(realTI, false);
				endif;
			endforeach;
			
			if realBOL = null then 
				dummy.clear();
				app.myUtilityCA.utlCreateBOL(pxyBOL, _passport, null, realBOL, dummy);
			else
				app.myUtilityUA.utlUpdateBOLIn(pxyBOL, _passport);
			endif;
			
			delete pxyBOL;	// wont need it again
		endif;
		// did the add/update/delete get any errors
		if not _validateOnly and _passport.hasErrors then
			return;
		endif;			
	endforeach;
	
	_ediData.updateProgress(progressTS, action &amp; "Bills of Lading " &amp; count.String &amp; "/" &amp; total.String, total, count, true, _passport);
	
	_passport.setWarningsIgnored(oldWarningsIgnored);		//cnwmc5 - 14 Oct 2014 - PAR 34952

	//Process any TODO Tasks on the BOLS PAR 34110 CCMS 2352 cnwgb1 
	total := tdDD.size;
    count := 0;
	_ediData.updateProgress(progressTS, action &amp; "To Do Tasks " &amp; count.String &amp; "/" &amp; total.String, total, count, true, _passport);
	
	foreach obj in tdDD do
        count := count + 1;
		_ediData.updateProgress(progressTS, action &amp; "To Do Tasks " &amp; count.String &amp; "/" &amp; total.String, total, count, false, _passport);
		
        ediTI := obj.CM_EDITrackedItem;
        ediToDoTask := obj.CM_EDIToDoTaskTI;
 		_passport.moveErrorsToSet (errorSet);
        // Find the BOL
		ediBOLHeader := bolDD[ediToDoTask.id, 1 ].CM_EDIBOLHdrTI;
		if ediBOLHeader = null then	//16 May 2017	TFS 4282
			app.raiseCMException2(BOL_Number_not_found, ediToDoTask.id, ediToDoTask.taskCode,null,null);
			return;
		else
			realBOL := _ediData.getRealBOL (ediBOLHeader);
			if realBOL = null then	//16 May 2017	TFS 4282
				app.raiseCMException2(BOL_not_found_voyage, ediToDoTask.id, null,null,null);
				return;
			else
				// Now need to find all the containers than need to be unpacked
				foreach childTI in realBOL.allTrackedItems do
					realTI := childTI.myParent;
					if realTI &lt;&gt; null then
						toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ ediToDoTask.taskCode ];
						if toDoTaskDesc = null then
						   app.raiseCMException1(ERR_NO_TODO_TASK, ediToDoTask.taskCode,null,null);
						   return;
						endif;
						if ediToDoTask.messageMode = "D" then
							app.myUtilityUA.utlUpdateTIToDoTaskRemove(realTI, toDoTaskDesc.code, _passport);
						elseif ediToDoTask.isComplete then
							app.myUtilityUA.utlUpdateTIToDoTaskComplete(realTI, toDoTaskDesc.code, _passport);
						else
							app.myUtilityUA.utlUpdateTIToDoTaskAdd(realTI, toDoTaskDesc.code, _passport);
						endif;
					endif;
				endforeach;
			endif;
		endif;
	endforeach;
	
	_ediData.updateProgress(progressTS, action &amp; "To Do Tasks " &amp; count.String &amp; "/" &amp; total.String, total, count, true, _passport);
	
	//22 Nov 2016	NDL	TFS 2843 / 2604
	create tiHazDict transient;
	
	total := thDD.size;
	count := 0;
	_ediData.updateProgress(progressTS, action &amp; "Hazards " &amp; count.String &amp; "/" &amp; total.String, total, count, true, _passport);
	tiColl.removeInvalidObjects();		//07 Aug 2023	jlirs1	TFS 59324 (58026) Sea Manifest for non partial	EUP
	
	foreach obj in thDD do
	// there can be multiple haz's per tracked item, so only process the collection on change of ti.
		count := count + 1;
		_ediData.updateProgress(progressTS, action &amp; "Hazards " &amp; count.String &amp; "/" &amp; total.String, total, count, false, _passport);
		
        ediTI := obj.CM_EDITrackedItem;
        ediHazDetail := obj.CM_EDIHazDetailsTI; 
		
		realTI := tiColl.getAtKey( ediHazDetail.cargoType, ediHazDetail.id );
		if realTI = null then
			app.raiseCMWarning1(Hazar_detai_recor_not_loade_ca, ediHazDetail.id, null, ediHazDetail, ediHazDetail);
			continue;
		endif;
		
		if previousRealTI &lt;&gt; null and previousRealTI &lt;&gt; realTI then
			_passport.moveErrorsToSet (errorSet);
			app.myUtilityUA.utlUpdateTIHazards( previousRealTI, tiHazDict, _passport );
			tiHazDict.purge();
		endif;
		
		create tiHaz transient;
		tiHaz.setPxyFromEDI(ediHazDetail);
		tiHaz.validateTIHazard( _passport.myTerminal );
		tiHazDict.add( tiHaz );
		
        previousRealTI := realTI;
		
	endforeach;
	
	_ediData.updateProgress(progressTS, action &amp; "Hazards " &amp; count.String &amp; "/" &amp; total.String, total, count, true, _passport);
	
	if not tiHazDict.isEmpty then
		// if any were found there will still be at least one left to process.
		_passport.moveErrorsToSet (errorSet);
		app.myUtilityUA.utlUpdateTIHazards( previousRealTI, tiHazDict, _passport );
		tiHazDict.purge();
	endif;
 
	if app.myPassport.isVASEnabled and	// 25 Jul 2023 jlirs1	NFS 59324 (58026) Sea Manifest for non partial	EUP
	   voyage &lt;&gt; null then
	   if _ediData.myTransportManifest &lt;&gt; null then
			manifestNumber := _ediData.myTransportManifest.manifestNumber;
			if _ediData.myTransportManifest.statusString = CMIF_JsonHeaderEUP.Status_Cancel then
				app.myUtilityDA.utlCleanupSeaManifest(_ediData.myTransportManifest, _passport);
			else
				create objArray transient;
				
				foreach realTI in tiColl do		                       //02.Nov.2023 navsp1 TFS 61067
					if realTI &lt;&gt; null then
						//cgItem := terminal.getCargoGroupItemForOperator(realTI.getMyCargoGroupId, realTI.operatorCode, null); //14.Nov.2023 navsp1 TFS 61127
						cgItem   := terminal.getCargoGroupItem( realTI.getMyCargoGroupId );										//14.Nov.2023 navsp1 TFS 61127
						if cgItem &lt;&gt; null and not objArray.includes(cgItem) then
							objArray.add(cgItem);
						endif;
					endif;
				endforeach;
				
				// TFS 62676 update cargo group details and send a cargo group update notification to the Voyage Operations screen
				if not _validateOnly then
					foreach obj in objArray do
						cgItem := obj.CM_CargoGroup;
						app.writeLog(method.qualifiedName &amp; Tab &amp; "Creating Cargo Group Details for " &amp; cgItem.id, LogDEBUG);
						controller := create CMIF_CargoGroupDtlController(cgItem) transient;
						controller.purgeExisting := true;
						app.myUtilityCA.utlCreateCargoGroupDetails(controller, _passport);
						delete controller;
						app.writeLog(method.qualifiedName &amp; Tab &amp; "Finished Creating Cargo Group Details for " &amp; cgItem.id, LogDEBUG);
						app.writeLog(method.qualifiedName &amp; Tab &amp; "Sending EVENT_CARGOGROUP_UPDATE otification for " &amp; cgItem.id, LogDEBUG);
						voyage.causeEvent(terminal.getTerminalEvent(EVENT_CARGOGROUP_UPDATE), true, cgItem);
					endforeach;
				endif;
				// TFS 62676 end
				/*                                                       02.Nov.2023 navsp1 TFS 61067
				foreach bolIn in voyage.allBOLInByTypeStatusNumDT do
					foreach ti in bolIn.allTrackedItems do
						if ti.isKindOf(CM_CargoGroup) then
					if not objArray.includes(ti) then
						objArray.add(ti);
					endif;
						endif;
					endforeach;
				endforeach;
				foreach cargoGroupDtl in voyage.allCargoGroupDetails do
					ti := cargoGroupDtl.myCargoGroup;
					if not objArray.includes(ti) then
						objArray.add(ti);
					endif;
				endforeach;	
				// TFS 59844 Also check the tis just created for cargo groups (because we might not have done a deferred 
				// update to add things to voyage collections yet)
				foreach ti in tiColl where ti.isCargoGroupItem do
					if not objArray.includes(ti) then
						objArray.add(ti);
					endif;
				endforeach;*/
				// TFS 59721 for a replace, when in verify mode, we get here with no BOLs and no cargo groups and no TIs
				// In verify mode, the trx does an abort transaction, so throws all the updates away, so it didn't really 
				// matter that we were creating a work order in verify mode, except the work order validation was failing
				// So don't do a work order if we have nothing in objArray
				if not _validateOnly then
					//app.myUtilityCA.utlCreateWOForManifest(manifestNumber, WO_TASK_RECEIVE, objArray, voyage);		// TFS 59844
					app.myUtilityCA.utlCreateWOForShipManifest(_ediData.myTransportManifest, WO_TASK_RECEIVE, objArray, voyage, tiColl);	// TFS 59844 		//15/11/2023 navcs2 ChangeRequest 60866
				endif;
			endif;
		endif;
	endif; 

epilog
	_passport.addErrorsFromSet (errorSet);
	delete cgTISet;
	delete tiColl;
	delete errorSet;
	delete updateController;
	delete bolDD;
	delete tiDD;
    delete tdDD;
	delete dummy;
	delete thDD;	//22 Nov 2016	NDL	TFS 2843 / 2604
	if tiHazDict &lt;&gt; null and not tiHazDict.isEmpty then		// TFS 2566 cnwdap1 30/11/2016
		tiHazDict.purge();
	endif;
	delete tiHazDict;	//22 Nov 2016	NDL	TFS 2843 / 2604
	delete cargoTIs;
	delete allEDISealDetails;
	delete sealIter;
	delete objArray;
	delete controller;			// TFS 62676
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataShipManifest" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlProcessEDITICargo" id="b05d8621-5ff6-4659-bceb-02650d4272dc">
        <updating/>
        <source>utlProcessEDITICargo(_ediTI : CM_EDICargoTI input; _updateController : CMIF_TIUpdateController input; _realTI : CM_TrackedItem output; _coll : CM_TIByCargoTypeIdDict; _validateOnly : Boolean; _passport : CM_Passport input) updating;
//
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
//
// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 17 Jun 2020	jlgmd1	TFS 49599 STWR Cargo Update EDI messages locking
//
vars
	terminalObj : CM_Terminal;
begin
	terminalObj := _ediTI.getMyTerminal();
	
	// TFS 49599 17/06/2020
	// Disabled, in favour of the web service retry loop taking care of any exceptions instead - as this was causing too many deadlocks by locking allOnsiteTIsByIdCargoType.
	// The deadlocks were between CargoOnSite and CargoFieldUpdate messages (CM_EDICargoTI::createUpdateTrackedItem)
	
	// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
	/*if _passport.useTITransactionDeferUpdate then
		if not self.tryLock(terminalObj.allTITransactions, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(terminalObj.allTITransactions);
		endif;
		if not self.tryLock(terminalObj.allTITransactionsByTypeDate, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(terminalObj.allTITransactionsByTypeDate);
		endif;
		if not self.tryLock(terminalObj.allTITransactionsByCamsTS, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(terminalObj.allTITransactionsByCamsTS);
		endif;
	endif;*/

	_realTI := _ediTI.createUpdateTrackedItem(terminalObj, _coll, _validateOnly, _updateController, _passport);	// par 31521

	/*if _passport.useTIDictDeferUpdate and
	   _realTI &lt;&gt; null then
		if _realTI.state = TI_STATE_NOTIFIED then
			if not self.tryLock(terminalObj.allNotifiedTIsByIdCargoType, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				self.exclusiveLock(terminalObj.allNotifiedTIsByIdCargoType);
			endif;
		elseif _realTI.state = TI_STATE_NORMAL then
			if not self.tryLock(terminalObj.allOnsiteTIsByIdCargoType, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				self.exclusiveLock(terminalObj.allOnsiteTIsByIdCargoType);
			endif;
		endif;
	endif;*/
epilog

end;</source>
        <Parameter name="_ediTI" type="CM_EDICargoTI" usage="input"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_coll" type="CM_TIByCargoTypeIdDict"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlProcessEDIToDoTask" id="fbced86a-90a4-4373-bcf9-70b8b618abb2">
        <source>utlProcessEDIToDoTask(_cmif : CMIF_EDIToDoTask; _isValidate : Boolean; _ediData : CM_EDIDataToDoTask; _updateController : CMIF_TIUpdateController input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:	22 February 2010 By Graeme Black cnwgb1 PAR 22022 MSL CCMS 1069 CR 06
// Purpose:	Update a single TI with altered todo tasks
// ---------------------------------------------------------------------------
//15/07/2019 	JLGNS1	Bug 45588: PNL - To Do Task Description no Planning / Queueing when To Do Task Terminals setup
vars
	cargo : CM_TrackedItem;
	toDoStr : String;
	toDoTaskDesc : CM_ToDoTaskDesc;
begin
	cargo := _ediData.findMyTrackedItem( _cmif.id, _cmif.cargoType, true, true, true );
	if cargo = null then
		app.raiseCMException1(ERR_CARGO_NOT_FOUND,_cmif.id,null,null);
		if not _isValidate then
			return;
		endif;
	endif;
	
	
	foreach toDoStr in _cmif.allTasksToAdd do
		toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ toDoStr ];
		if toDoTaskDesc = null then
			app.raiseCMException1(ERR_NO_TODO_TASK, toDoStr, null, null);
			if not _isValidate then
				return;
			endif;
		elseif cargo &lt;&gt; null then		// cnwdad1 08/03/2010 - PAR #22711. Changed from "if" to "elseif".
			cargo.addToDoTask( toDoTaskDesc.description, _passport );
		endif;
	endforeach;
	
	foreach toDoStr in _cmif.allTasksToComplete do
		toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ toDoStr ];
		if toDoTaskDesc = null then
			app.raiseCMException1(ERR_NO_TODO_TASK, toDoStr,null,null);
			if not _isValidate then
				return;
			endif;
		elseif cargo &lt;&gt; null then		// cnwdad1 08/03/2010 - PAR #22711. Changed from "if" to "elseif".
			cargo.setToDoTaskComplete( toDoTaskDesc.code, _passport );
			_passport.doPostUpdateAutoPlansFor( cargo );	//Bug 45588
		endif;
	endforeach;
	
	foreach toDoStr in _cmif.allTasksToRemove do
		toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ toDoStr ];
		if toDoTaskDesc = null then
			app.raiseCMException1(ERR_NO_TODO_TASK, toDoStr,null,null);
			if not _isValidate then
				return;
			endif;
		elseif cargo &lt;&gt; null then		// cnwdad1 08/03/2010 - PAR #22711. Changed from "if" to "elseif".
			cargo.removeToDoTask(toDoTaskDesc.description, _passport );
		endif;
	endforeach;
end;</source>
        <Parameter name="_cmif" type="CMIF_EDIToDoTask"/>
        <Parameter name="_isValidate" type="Boolean"/>
        <Parameter name="_ediData" type="CM_EDIDataToDoTask"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlProcessEDITrainConsist" id="ec515efb-f000-4744-88b8-805e67bd0352">
        <source>utlProcessEDITrainConsist(	_cmifConsist : CMIF_TrainConsist input;
							_isValidate : Boolean;
							_passport : CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		17 February 2010 by cnwdad1
//
// Purpose:		Transaction utility method to add, delete or update a Train Consist,
//				i.e. A Train and one or more Wagons and Prenotes.
//
// It is important that the cmifConsist data is processed in the following order:
//
//	1. Train - Add
//	2. Train - Update
//	3. Wagons - Add
//	4. Wagons - Update
//	5. Prenotes - Add,Update,Delete
//	6. Wagons - Delete
//	7. Train - Delete
//
// Parameters:	_cmifConsist - A reference to the CMIF object carrying the data to maintain.
//				_isValidate - True if objects are to be validated only.
//				_passport - A reference to the current User's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/06/2023	navdap1		TFS 58813 EUP Manifest Instructions and corrections
// 27/02/2024	navcs2		ChangeRequest 62250: EUP | FR 53824 - Transport Manifest - Multiple Manifests For a Single Wagon Need to be Possible. 
// --------------------------------------------------------------------------------
vars
	pxyObject			: Object;
	pxyTrain			: CM_Train;
	realTrain			: CM_Train;
	wagonTrain			: CM_Train;
	pxyWagon			: CM_Wagon;
	realWagon			: CM_Wagon;
	wagonUpdCtrl		: CMIF_WagonUpdateController;
	cmifTI				: CMIF_TIObject;
	cmifPrenote			: CMIF_PreNote;
	allWagonsToDelete	: CM_WagonSet;
	expectedEdition		: Integer;
	
	ediWagon : CM_EDIWagonTI;	//17 Mar 2015	NDL	Par 35828
	
begin
	self.initialiseActivity();
	
	pxyTrain	:=	_cmifConsist.myProxyTrain;
	
	self.raiseExceptionIfNull(pxyTrain, "Train proxy");
	
	// TFS 58813 update the train arfrival date if set from the manifest message
	if pxyTrain.code &lt;&gt; NULL_TRAIN_CODE 
	and _cmifConsist.myEDIDataTrainConsist &lt;&gt; null 
	and _cmifConsist.myEDIDataTrainConsist.isTransportManifestRelated then
		pxyTrain.setScheduledArrivalDT(_cmifConsist.myEDIDataTrainConsist.myTransportManifest.estimatedDateTimeOfArrival);
	endif;
	// TFS 58813 end
	
	// Do the Train update.
	
	if _cmifConsist.trainAction = CM_EDITrackedItem.EDI_ACTION_ADD then
		app.myUtilityCA.utlCreateTrain(pxyTrain, realTrain, _isValidate, false, _passport);
		_cmifConsist.myRealTrain	:=	realTrain;
	elseif _cmifConsist.trainAction = CM_EDITrackedItem.EDI_ACTION_UPDATE then
		app.myUtilityUA.utlUpdateTrain(pxyTrain,_isValidate, false, _passport);
	endif;
	
	// Next step, do the Wagons.
	
	// Note that we'll delay the deletion of any Wagons until after the Prenotes are
	// processed, in case there are any Prenotes that need to be deleted first.
	
	if realTrain = null then
		if _cmifConsist.myRealTrain = null then
			wagonTrain	:=	pxyTrain;
		else
			wagonTrain	:=	_cmifConsist.myRealTrain;
		endif;
	else
		wagonTrain	:=	realTrain;
	endif;
	
	foreach pxyObject in _cmifConsist.allWagonsToAddUnsorted do //cnwgb1 11.2.2011 PAR 26930
		pxyWagon := pxyObject.CM_Wagon;
		if pxyWagon = null then
			continue;
		endif;
		if wagonTrain &lt;&gt; pxyTrain then
			if pxyWagon.myTrainInwards = pxyTrain then
				pxyWagon.setMyTrain(true, wagonTrain);
			endif;
			
			if pxyWagon.myTrainOutwards = pxyTrain then
				pxyWagon.setMyTrain(false, wagonTrain);
			endif;
		endif;
		
		create wagonUpdCtrl transient;
		wagonUpdCtrl.setBasicDetails(	CMIF_WagonUpdateController.Mode_Add,
										null,
										wagonTrain,
										wagonTrain.allWagonsByIdInward.size() + 1,
										true);
		wagonUpdCtrl.myProxyWagon	:=	pxyWagon;
		
		if _cmifConsist.myEDIDataTrainConsist.isTransportManifestRelated then										// 27/02/2024	navcs2		ChangeRequest 62250
			wagonUpdCtrl.populateFromExistingWagonAddTi( realWagon, null, 0 );										// 27/02/2024	navcs2		ChangeRequest 62250
		endif;																										// 27/02/2024	navcs2		ChangeRequest 62250
		
		app.myUtilityCA.utlCreateWagonFromCMIF(wagonUpdCtrl, realWagon, _isValidate, false, _passport);
		
		//17 Mar 2015	NDL	Par 35828
		if realWagon &lt;&gt; null then
			ediWagon := _cmifConsist.getEDIWagonMatching( realWagon );
			if ediWagon &lt;&gt; null and ediWagon.hasSealData then
				ediWagon.doUpdateWagonSeals( realWagon );
			endif;
		endif;
		
		if wagonUpdCtrl.allWagonPositions &lt;&gt; null and wagonUpdCtrl.allWagonPositions.size() &gt; 0 then
			wagonUpdCtrl.allWagonPositions.purge();
		endif;
		delete wagonUpdCtrl;
	endforeach;
	
	foreach pxyWagon in _cmifConsist.allWagonsToUpdate do
		pxyWagon.pxyGetRealObjectAndEdition(realWagon, expectedEdition);
		self.raiseExceptionIfNull(realWagon, "Wagon");
		
		if wagonTrain &lt;&gt; pxyTrain then
			if pxyWagon.myTrainInwards = pxyTrain then
				pxyWagon.setMyTrain(true, wagonTrain);
			endif;
			
			if pxyWagon.myTrainOutwards = pxyTrain then
				pxyWagon.setMyTrain(false, wagonTrain);
			endif;
		endif;
		
		create wagonUpdCtrl transient;
		wagonUpdCtrl.setBasicDetails(	CMIF_WagonUpdateController.Mode_Update,
										null,
										wagonTrain,
										wagonTrain.allWagonsByIdInward.size() + 1,
										true);
										
		if _cmifConsist.myEDIDataTrainConsist.isTransportManifestRelated then										// 27/02/2024	navcs2		ChangeRequest 62250
			wagonUpdCtrl.populateFromExistingWagonAddTi( realWagon, null, 0 );										// 27/02/2024	navcs2		ChangeRequest 62250
		endif;																										// 27/02/2024	navcs2		ChangeRequest 62250
		
		wagonUpdCtrl.myProxyWagon			:=	pxyWagon;
		wagonUpdCtrl.expectedEditionWagon	:=	realWagon.edition;
		app.myUtilityUA.utlUpdateWagonFromCMIF(wagonUpdCtrl, _isValidate, false, _passport);
		
		//17 Mar 2015	NDL	Par 35828
		if pxyWagon &lt;&gt; null then
			realWagon := null;
			pxyWagon.pxyGetRealObjectAndEdition(realWagon, expectedEdition);
			if realWagon &lt;&gt; null then
				ediWagon := _cmifConsist.getEDIWagonMatching( realWagon );
				if ediWagon &lt;&gt; null and ediWagon.hasSealData then
					ediWagon.doUpdateWagonSeals( realWagon );
				endif;
			endif;
		endif;
		
		if wagonUpdCtrl.allWagonPositions &lt;&gt; null and wagonUpdCtrl.allWagonPositions.size() &gt; 0 then
			wagonUpdCtrl.allWagonPositions.purge();
		endif;
		delete wagonUpdCtrl;
	endforeach;
	
	if realWagon  &lt;&gt; null then															// 27/02/2024	navcs2		ChangeRequest 62250
		_cmifConsist.myEDIDataTrainConsist.setCurrentWagonCode(realWagon.id);			// 27/02/2024	navcs2		ChangeRequest 62250
	endif;																				// 27/02/2024	navcs2		ChangeRequest 62250
	
	// Next step, do the Prenotes.
	
	foreach cmifTI in _cmifConsist.allPrenotesToProcess do
		cmifPrenote := cmifTI.CMIF_PreNote;
		if cmifPrenote &lt;&gt; null then
			if cmifPrenote.action = CM_EDITrackedItem.EDI_ACTION_ADD then
				app.myUtilityCA.utlCreatePreNote(cmifPrenote, _isValidate, false, _passport);
		//	elseif cmifPrenote.action = CM_EDITrackedItem.EDI_ACTION_UPDATE then
			elseif ( cmifPrenote.action = CM_EDITrackedItem.EDI_ACTION_UPDATE or cmifPrenote.action = CM_EDITrackedItem.EDI_ACTION_MODIFY ) then	//03 Jan 2020	NDL	TFS 47190
				app.myUtilityUA.utlUpdatePreNote(cmifPrenote, _isValidate, false, false, _passport);
			elseif cmifPrenote.action = CM_EDITrackedItem.EDI_ACTION_DELETE then
				app.myUtilityDA.utlDeletePreNote(cmifPrenote, _isValidate, false, _passport);
			endif;
		endif;
	endforeach;
	
	// Now we'll do any the Wagon deletes here, intentionally after any Prenotes
	// that may have been deleted.
	
	create allWagonsToDelete transient;
	
	foreach pxyWagon in _cmifConsist.allWagonsToDelete do
		pxyWagon.pxyGetRealObjectAndEdition(realWagon, expectedEdition);
		self.raiseExceptionIfNull(realWagon, "Wagon");
		
		app.myUtilityDA.utlDeleteWagon(realWagon, _isValidate, true, false, _passport);
		allWagonsToDelete.add(realWagon);
	endforeach;
	
	// Lastly, delete the Train if required.
	
	if _cmifConsist.trainAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
		pxyTrain	:=	_cmifConsist.myProxyTrain;
		pxyTrain.pxyGetRealObjectAndEdition(realTrain, expectedEdition);
		self.raiseExceptionIfNull(realTrain, "Train");
		app.myUtilityDA.utlDeleteTrain(realTrain, allWagonsToDelete, true, _isValidate, false, _passport);
	endif;
epilog
	delete wagonUpdCtrl;
	delete allWagonsToDelete;
end;</source>
        <Parameter name="_cmifConsist" type="CMIF_TrainConsist" usage="input"/>
        <Parameter name="_isValidate" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlProcessEDITransactions" id="3ff13cd8-22b5-417a-8f80-6e4aee3b6990">
        <source>utlProcessEDITransactions(_ediData :CM_EDIDataTransaction input; _validateOnly : Boolean; _passport : CM_Passport input);
//
//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
//
//18 Oct 2012	cnwrs1		CCMS SFW 1290 Transaction file
vars
	ediTI : CM_EDITrackedItem;
	ediTransactionTI : CM_EDITransactionTI;
	cmifTrans : CMIF_MoveTransactionController;//CMIF_TITransactionController;
	ti : CM_TrackedItem;
	terminalObj : CM_Terminal;
	tiTrans : CM_TITransaction;
	errorSet : CM_ErrorSet;
begin
	create errorSet transient;
	terminalObj := _ediData.getMyTerminal();
	create cmifTrans transient;
	foreach ediTI in _ediData.allEDITrackedItems do
		_passport.moveErrorsToSet(errorSet); //save off all current errors
		ediTransactionTI := ediTI.CM_EDITransactionTI;
		ti := terminalObj.lookupTrackedItem(ediTransactionTI.id, ediTransactionTI.cargoType, TI_STATE_UNDEFINED, null, false);
		if ti = null then
			app.raiseCMException3(Specfied_Cargo_DoesNotExist, ediTransactionTI.id, ediTransactionTI.cargoTypeDescr, terminalObj.code, ETRow_Id, ediTransactionTI);
			continue;
		endif;
		cmifTrans.reset();
		ediTransactionTI.setupCMIF(cmifTrans, ti);
		if ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD then
			tiTrans :=  _ediData.getTransaction(ediTransactionTI, ti);
			if tiTrans &lt;&gt; null then
				app.raiseCMException3(Specified_Trans_Already_Exists, ediTransactionTI.id, ediTransactionTI.transactionTime.asStringJMT, ediTransactionTI.transactionType.String, ETRow_Id, ediTransactionTI);
				continue;
			endif;
			tiTrans := ti.createTransaction(cmifTrans, app.myPassport);
			if ediTransactionTI.orderNumber &lt;&gt; 0 then
				tiTrans.setOrderNo(ediTransactionTI.orderNumber);
			endif;
			tiTrans.setNoCharge(not ediTransactionTI.chargeable);
			tiTrans.updatePropertiesFromEDI(ediTI.CM_EDITransactionTI);
		elseif ediTransactionTI.messageMode = CM_EDITrackedItem.EDI_ACTION_UPDATE or
		   ediTransactionTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
			tiTrans := _ediData.getTransaction(ediTransactionTI, ti);
			if tiTrans = null then 
				app.raiseCMException3(Speci_trans_dated_type_invalid, ediTransactionTI.id, ediTransactionTI.transactionTime.asStringJMT, ediTransactionTI.transactionType.String, ETRow_Id, ediTransactionTI);
				continue;
			endif;
			exclusiveLock(tiTrans);
			if _passport.noErrors then
				self.myUpdateAuditAgent.audUpdateGeneric(tiTrans, true);
			endif;
			if ediTransactionTI.messageMode = CM_EDITrackedItem.EDI_ACTION_UPDATE then
				if _passport.noErrors then
					tiTrans.updatePropertiesFromEDI(ediTI.CM_EDITransactionTI);
				endif;
			elseif ediTransactionTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
				if _passport.noErrors then
					tiTrans.setForDelete(null);
				endif;
			endif;
			if _passport.noErrors then
				self.myUpdateAuditAgent.audUpdateGeneric(tiTrans, false);
			endif;
		endif;
	endforeach;
epilog
	_passport.addErrorsFromSet(errorSet);	//restore current errors back to
	delete cmifTrans;
	delete errorSet;
end;
</source>
        <Parameter name="_ediData" type="CM_EDIDataTransaction" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlProcessEDIVBSSlot" id="4ebf412d-9823-46e2-af41-7c637fb62d28">
        <source>utlProcessEDIVBSSlot(_ediData :CM_EDIDataVBSSlot input; _validateOnly : Boolean; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI
22 Aug 2023 navhl20 Defect 59930: MTN - VBS Slot items are duplicated when performing EDI update 
*/

vars
	progressTS 		: TimeStamp;
	terminal		: CM_Terminal;
	allSlotHdrs		: DynaDictionary;
	allSlotItems 	: DynaDictionary;
	hdrIter			: Iterator;
	itemIter		: Iterator;
	edi 			: CM_EDITrackedItem;
	slotHdr			: CM_EDIVBSSlot;
	slotItem		: CM_EDIVBSSlotItem;
	obj				: CM_Object;
	
	pxySlotHeadersById : CM_VehicleBookingTimeSlotById;
	pxySlotHeadersByRef : CM_VBSTimeSlotByExtRef;
	allPxyHeaders	: CM_ObjectSetActual;
	allHeaderToDelete : CM_VehicleBookingTimeSlotById;
	proxySlotItems	: CM_VehicleBookingTSItemSet;
	realSlotItems	: CM_VehicleBookingTSItemSet;
	
	pxyHeader 		: CM_VehicleBookingTimeSlot;
	realHeader 		: CM_VehicleBookingTimeSlot;
	headerToDelete	: CM_VehicleBookingTimeSlot;
	pxyItem,
	vbsItem			: CM_VehicleBookingTimeSlotItem;

begin
	progressTS := app.actualTimeServer();
	terminal	:= _ediData.getMyTerminal;

	create allSlotHdrs transient;
	allSlotHdrs.setMembership(CM_EDIVBSSlot);
	allSlotHdrs.addMemberKey(CM_EDIVBSSlot::id.name, false, true);
	allSlotHdrs.endKeys(true);
	
	create allSlotItems transient;
	allSlotItems.setMembership(CM_EDIVBSSlotItem);
	allSlotItems.addMemberKey(CM_EDIVBSSlotItem::id.name, false, true);
	allSlotItems.endKeys(true);
	
	// sort ediTI types into separate collections
	foreach edi in _ediData.allEDITrackedItems do
		if edi.isEDIVBSSlotItem then
			allSlotItems.add(edi);
			continue;
		endif;
		
		allSlotHdrs.add(edi);
	endforeach;
	
	create pxySlotHeadersById transient;
	create pxySlotHeadersByRef transient;
	create allPxyHeaders transient;
	create allHeaderToDelete transient;
	
	// process header objects
	if not allSlotHdrs.isEmpty then
		hdrIter := allSlotHdrs.createIterator;
		while hdrIter.next(slotHdr) do
			if (slotHdr.id &lt;&gt; null and pxySlotHeadersById.includesKey(slotHdr.id)) then
				app.raiseCMException2(Duplicate_ID_For, slotHdr.id, app.getErrorString(Vehicle_booking_slot_header), ETRow_Id, null);
				return;
			endif;
			if (slotHdr.externalReference &lt;&gt; null and pxySlotHeadersByRef.includesKey(slotHdr.externalReference)) then
				app.raiseCMException2(Duplicate_ID_For, slotHdr.externalReference, app.getErrorString(Vehicle_booking_slot_header), ETRow_ExternalReference, null);
				return;
			endif;
			
			if slotHdr.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
				headerToDelete := slotHdr.findRealVehicleBooking();
				if headerToDelete &lt;&gt; null then
					allHeaderToDelete.add(headerToDelete);
				endif;
				continue;
			endif;
			
			pxyHeader := slotHdr.createProxy();
			allPxyHeaders.add(pxyHeader);
			if pxyHeader.id &lt;&gt; null then
				pxySlotHeadersById.add(pxyHeader);
			endif;
			if pxyHeader.externalReference &lt;&gt; null then
				pxySlotHeadersByRef.add(pxyHeader);
			endif;
			
			// if real header exisits
			if pxyHeader.pxyIsProxy then
				// if ADD mode then clear out all items to create new ones from scratch
				if slotHdr.messageMode = CM_EDITrackedItem.EDI_ACTION_ADD then
					pxyHeader.allVehicleBookingItems.purge();
				endif;
			endif;
		endwhile;
	endif;

	create proxySlotItems transient;
	
	// procress item objects
	if not allSlotItems.isEmpty then
		itemIter := allSlotItems.createIterator;
		while itemIter.next(slotItem) do
			pxyHeader := pxySlotHeadersById[slotItem.id];
			if pxyHeader = null then
				pxyHeader := pxySlotHeadersByRef[slotItem.externalReference];
				if pxyHeader = null then
					continue;
				endif;
			endif;
			
			if slotItem.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
				pxyHeader.removePxySlotItem(slotItem.sequence);
				continue;
			endif;
			
			pxyItem := slotItem.createProxy(pxyHeader);
			if pxyItem = null then
				continue;
			endif;
			
			pxyHeader.removeslotItemIfPresent(pxyItem);												//22.8.2023 navhl20 #59930
			
			proxySlotItems.addNoDuplicates(pxyItem, false);
			
			if pxyItem.myVehicleBookingSlot &lt;&gt; null then
				continue;
			endif;
			pxyHeader.addSlotItem(pxyItem);
		endwhile;
	endif;
	
	if _validateOnly then
		return;
	endif;
	
	create realSlotItems transient;
	
	foreach obj in allPxyHeaders do
		pxyHeader := obj.CM_VehicleBookingTimeSlot;
		if pxyHeader.pxyIsProxy then
			app.myUtilityUA.utlUpdateVehicleBookingAdv(pxyHeader, null, null, null, _passport);
		else
			app.myUtilityCA.utlCreateVehicleBookingAdv(pxyHeader, realHeader, realSlotItems, false, _passport);
		endif;
	endforeach;
	
	foreach headerToDelete in allHeaderToDelete do
		app.myUtilityDA.utlDeleteVVSBooking(headerToDelete, _passport);
	endforeach;
	
epilog
	delete allSlotHdrs;
	delete allSlotItems;
	delete hdrIter;
	delete itemIter;
	if allPxyHeaders &lt;&gt; null then
		allPxyHeaders.purge();
		delete allPxyHeaders;
	endif;

	delete pxySlotHeadersById;
	delete pxySlotHeadersByRef;
	
	if proxySlotItems &lt;&gt; null then
		proxySlotItems.purge();
		delete proxySlotItems;
	endif;
	
	delete realSlotItems;
	delete allHeaderToDelete;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataVBSSlot" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlPropagateWorkPointRates" id="361dc647-af18-4d6b-aab3-3317957bad7f">
        <updating/>
