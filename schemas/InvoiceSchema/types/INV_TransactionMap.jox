    <JadeMethod name="getCurrentMapName" id="95807695-ad25-4e4d-a029-22cc086576bb">
        <source>getCurrentMapName() : String;
// to display in the Invoice Line Mapping form
vars
	mapName	: String;
begin
	if self.myCurrentMapTM &lt;&gt; null then
		mapName := self.myCurrentMapTM.name;
	elseif self.myCurrentMapTMEvent &lt;&gt; null then
		mapName := self.myCurrentMapTMEvent.name;
	elseif self.myCurrentMapTMWorkOrder &lt;&gt; null then // TFS 39236
		mapName := self.myCurrentMapTMWorkOrder.name; // TFS 39236
	elseif self.myCurrentMapTMBOL &lt;&gt; null then // 01 Nov 2019	NDL	TFS 47100
		mapName := self.myCurrentMapTMBOL.name; //01 Nov 2019	NDL	TFS 47100
	elseif self.myCurrentMapTMSS &lt;&gt; null then
		mapName := self.myCurrentMapTMSS.name;
	elseif self.myCurrentMapTMCargoAllocation &lt;&gt; null then // PAR 35833
		mapName := self.myCurrentMapTMCargoAllocation.name; // PAR 35833
	elseif self.myCurrentMapTMInventory &lt;&gt; null then  // ### TFS 51219 25MAY2021 NAVAB1
		mapName := self.myCurrentMapTMInventory.name; // ### TFS 51219 25MAY2021 NAVAB1
	elseif self.myCurrentMapTMVoyage &lt;&gt; null then
		mapName := self.myCurrentMapTMVoyage.name;
	endif;
	return mapName;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIndexInList" id="ee7bc5b8-1618-4c99-b992-c2e769947778">
        <source>getIndexInList(_parentObject : Object; _level : Integer; _index : Integer io) : CMIF_TMCGroup;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------

vars
	tmcGroup : CMIF_TMCGroup;
	stL, endL,idx : Integer;
	anObject : Object;
begin
	stL := 1;
	stL := _index + 1;
	endL := self.lstData.itemLevel.size;
	foreach idx in stL to endL do
		if self.lstData.itemLevel[idx] = _level then
			anObject := self.lstData.itemObject[idx];
			if anObject.isKindOf(CMIF_TMCInvLineDesc) then
				if anObject.CMIF_TMCInvLineDesc.myInvoiceLineDesc = _parentObject then
					_index := idx;
					return null;
				else
					continue;
				endif;
			endif;
			tmcGroup := anObject.CMIF_TMCGroup;
		
			if _parentObject.isKindOf(CMIF_TMCMoveGroup) 
			and _level = CMIF_TranMapController.TM_Level_14_InvoiceLine
			and tmcGroup.getRealMapObject() = _parentObject then
				_index := idx;
				return tmcGroup;
				
			elseif _parentObject.isKindOf(CMIF_TMCMoveGroup) and tmcGroup = _parentObject then
				_index := idx;
				return tmcGroup;
			
			elseif _parentObject.isKindOf(CMIF_TMCType) and tmcGroup = _parentObject then		//par 22970
				_index := idx;
				return tmcGroup;
				
			//12 Jan 2009	NDL	CCMS MES 1006
			elseif _parentObject.isKindOf(CM_TransResourceServiceBroker) then
				if _level = CMIF_TranMapController.TM_Level_11_ResourceMapHeader then
					if tmcGroup.isKindOf(CMIF_TMCTaskResourceTypeHeader)
					and anObject.CMIF_TMCTaskResourceTypeHeader.myTransServiceBroker = _parentObject.CM_TransResourceServiceBroker.myTransServiceBroker then
						_index := idx;
						return tmcGroup;
					endif;
				elseif tmcGroup.getRealMapObject() = _parentObject then
					_index := idx;
					return tmcGroup;
				endif;
			elseif _parentObject.isKindOf(CM_ToDoResourceServiceBroker) then // 15/05/2023	navkc1	CR 57927 Task 54268
				if _level = CMIF_TranMapController.TM_Level_05_ResourceMapHeader then // 15/05/2023	navkc1	CR 57927 Task 54268
					if tmcGroup.isKindOf(CMIF_TMCTaskResourceTypeHeader) and anObject.CMIF_TMCTaskResourceTypeHeader.myTransServiceBroker = _parentObject.CM_ToDoResourceServiceBroker.myServiceBroker then
						_index := idx;
						return tmcGroup;
					endif;
				elseif tmcGroup.getRealMapObject() = _parentObject then
					_index := idx;
					return tmcGroup;
				endif;
			elseif tmcGroup.getRealMapObject() = _parentObject then
				_index := idx;
				return tmcGroup;
			endif;
		endif;
	endforeach;
	_index := 0;
	return null;
end;</source>
        <Parameter name="_parentObject" type="Object"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_index" type="Integer" usage="io"/>
        <ReturnType type="CMIF_TMCGroup"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="3d8f2d66-2b94-4c71-9831-9396b8aa57a4">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// save show bubble help and show pictures options
vars
	str : String;
begin
	str	:=	inheritMethod();
	str := str &amp; global.formatAsXML("ShowPic", self.showPictures.String) 
			   &amp; global.formatAsXML("ShowCargo", self.chkTranMapCargo.value.String) // PAR 25833
			   &amp; global.formatAsXML("ShowCAlloc", self.chkTranMapCAlloc.value.String) // PAR 25833
			   &amp; global.formatAsXML("ShowEvents", self.chkTranMapEvents.value.String) // PAR 25833
			   &amp; global.formatAsXML("ShowSnap", self.chkTranMapSnap.value.String) // PAR 25833
			   &amp; global.formatAsXML("ShowVoyage", self.chkTranMapVoyage.value.String) // PAR 25833
			   &amp; global.formatAsXML("ShowWO", self.chkTranMapWO.value.String) // TFS 39236
			   &amp; global.formatAsXML("ShowBOL", self.chkTranMapBOL.value.String)	//31 Oct 2019	NDL	TFS 47100
			   &amp; global.formatAsXML("ShowInventory", self.chkTranMapInventory.value.String)	// TFS 51219 25MAY2021 NAVAB1
			   &amp; global.formatAsXML("ShowBubble", self.showBubbleHelp.String);
	return str;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="7a2b810e-e29e-4415-9ec1-b3394e664a9b">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

vars
	option	: String;
begin
	inheritMethod(_userWindow);
	
	option := _userWindow.xmlInfo.cnEcGetTagValueOfName("ShowPic");
	if option &lt;&gt; null then
		self.showPictures := option.Boolean;
	endif;
	option := _userWindow.xmlInfo.cnEcGetTagValueOfName("ShowBubble");
	if option &lt;&gt; null then
		self.showBubbleHelp := option.Boolean;
	endif;
	
	 // PAR 25833
	option := _userWindow.xmlInfo.cnEcGetTagValueOfName("ShowCargo");
	if option &lt;&gt; null then
		self.chkTranMapCargo.value := option.Boolean;
	endif;
	option := _userWindow.xmlInfo.cnEcGetTagValueOfName("ShowCAlloc");
	if option &lt;&gt; null then
		self.chkTranMapCAlloc.value := option.Boolean;
	endif;
	option := _userWindow.xmlInfo.cnEcGetTagValueOfName("ShowEvents");
	if option &lt;&gt; null then
		self.chkTranMapEvents.value := option.Boolean;
	endif;
	option := _userWindow.xmlInfo.cnEcGetTagValueOfName("ShowSnap");
	if option &lt;&gt; null then
		self.chkTranMapSnap.value := option.Boolean;
	endif;
	option := _userWindow.xmlInfo.cnEcGetTagValueOfName("ShowVoyage");
	if option &lt;&gt; null then
		self.chkTranMapVoyage.value := option.Boolean;
	endif;
	// TFS 39236
	option := _userWindow.xmlInfo.cnEcGetTagValueOfName("ShowWO");
	if option &lt;&gt; null then
		self.chkTranMapWO.value := option.Boolean;
	endif;
	//31 Oct 2019	NDL	TFS 47100
	option := _userWindow.xmlInfo.cnEcGetTagValueOfName("ShowBOL");
	if option &lt;&gt; null then
		self.chkTranMapBOL.value := option.Boolean;
	endif;
	
	// TFS 51219 25MAY2021 NAVAB1
	option := _userWindow.xmlInfo.cnEcGetTagValueOfName("ShowInventory");
	if option &lt;&gt; null then
		self.chkTranMapInventory.value := option.Boolean;
	endif;
	
end;
</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="isEditing" id="f9b1dddc-8c0b-452b-91df-ebd67d3e641a">
        <source>isEditing() : Boolean protected;
// 33535 control more than one user maintaining the same transaction map
vars

begin
	if self.frmList.visible or
	   self.frmListMoves.visible or
	   self.frmDebtors.visible or
	   self.frmPropQty.visible or
	   self.frmPropQtyRange.visible then
		return true;
	else
		return false;
	endif;
end;
</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="cde297bd-a174-406f-8c26-31705e4b5856">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		14 November 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	start : Integer;
begin
//	if keyCode = 78 and shift.isAltKeyPressed and not shift.isControlKeyPressed and not shift.isShiftKeyPressed then	what it was
	// alt+N pressed
	if keyCode = J_key_N and shift.isAltKeyPressed and not shift.isControlKeyPressed and not shift.isShiftKeyPressed then
		if self.modePropertyNew = self.ModeProperty_QuantityRange then
			if self.frmPropQtyRange.visible then
				start := self.txtQtyEnd.text.Integer + 1;
				self.doBtnListSaveClick();
				self.txtQtyStart.text := start.String;
				self.txtQtyEnd.text := "";
				self.displayQuantityRange();
			endif;
		endif;
	else
		inheritMethod(keyCode, shift);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="3371fa8e-04b8-4de7-b548-295c7eda5dd9">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	regKeys : IntegerArray;

begin
	inheritMethod();
	self.splMain.hideRightControl(true);
	
	create regKeys transient;
	regKeys.add(J_key_N);
	self.addRegisteredKeys(regKeys);
epilog
	delete regKeys;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadMoveMappings" id="dedb775d-a053-4283-a242-fef0e3696300">
        <source>loadMoveMappings();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	ta : CM_TerminalArea;

begin
	// 36460 add 'Nowhere'
	//epr TFS 4135 1/5/17
	self.lstListMVFrom.clear;
	self.lstListMVTo.clear;
	
	self.lstListMVFrom.addItem(GROSSAREA_ROAD);
	self.lstListMVFrom.addItem(GROSSAREA_RAIL);
	self.lstListMVFrom.addItem(GROSSAREA_YARD);
	self.lstListMVFrom.addItem(GROSSAREA_SHIP);
	self.lstListMVFrom.addItem(GROSSAREA_NOWHERE);

	self.lstListMVTo.addItem(GROSSAREA_ROAD);
	self.lstListMVTo.addItem(GROSSAREA_RAIL);
	self.lstListMVTo.addItem(GROSSAREA_YARD);
	self.lstListMVTo.addItem(GROSSAREA_SHIP);
	self.lstListMVTo.addItem(GROSSAREA_NOWHERE);

	foreach ta in self.myTerminal.allTerminalAreas do
		self.lstListMVFrom.addItem(ta.id);
		self.lstListMVTo.addItem(ta.id);
	endforeach;

	self.lstListMVFrom.listIndex := 1;
	self.lstListMVTo.listIndex := 1;
	self.lstListMVFrom.click(self.lstListMVFrom);
	self.lstListMVTo.click(self.lstListMVTo);

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTransactionMaps" id="8df24d44-1ebc-4265-b033-5c071d0ad797">
        <updating/>
        <source>loadTransactionMaps() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	itemExpandedArr : IntegerArray;
	itemExpandedCount, count : Integer;

begin
	// 35872 do change of business unit
	self.myCurrentBank := self.cmbBank.listObject.CM_Bank;
	if self.myCurrentBank = null then
		return;
	endif;
//	TFS 2682	self.caption := self.myCurrentBank.code &amp; " " &amp; app.getErrorString(Transaction_Map) &amp; " " &amp; self.myTerminal.code;
	self.setCaption(app.getErrorString(Transaction_Map) &amp; " " &amp;  self.myCurrentBank.code);
	
	count := 1;
	itemExpandedCount := self.lstData.listCount ();
	// save and restore the current list box expanded status
	create itemExpandedArr transient;
	while count &lt;= itemExpandedCount do
		if self.lstData.itemExpanded[count] = true then
			itemExpandedArr.add (count);
		endif;
		count := count + 1;
	endwhile;

	self.lstData.clear;
	delete self.myTMCRoot;
	
	create self.myTMCRoot;
	self.myTMCRoot.myBank := self.myCurrentBank;			// 35872
	self.myTMCRoot.itemName := self.myCurrentBank.code;
	self.myTMCRoot.extractName := self.myTMCRoot.itemName;	// 23659
	self.myTMCRoot.hidePictures := not self.showPictures;

	self.myTMCRoot.showCargo := self.chkTranMapCargo.value; // PAR 25833
	self.myTMCRoot.showEvent := self.chkTranMapEvents.value; // PAR 25833
	self.myTMCRoot.showVoyage := self.chkTranMapVoyage.value; // PAR 25833
	self.myTMCRoot.showSnapShot := self.chkTranMapSnap.value; // PAR 25833
	self.myTMCRoot.showCargoAlloc := self.chkTranMapCAlloc.value;	 // PAR 25833
	self.myTMCRoot.showWO := self.chkTranMapWO.value;	 // TFS 39236
	self.myTMCRoot.showBOL := self.chkTranMapBOL.value;	//31 Oct 2019	NDL	TFS 47100
	self.myTMCRoot.showInventory := self.chkTranMapInventory.value;	// TFS 51219 25MAY2021 NAVAB1
	
	if not self.myTMCRoot.showCargo then // PAR 25833
		self.myTMCRoot.showCargo := (	not self.myTMCRoot.showEvent  
										and not self.myTMCRoot.showVoyage  
										and not self.myTMCRoot.showSnapShot  
										and not self.myTMCRoot.showCargoAlloc  // PAR 25833
										and not self.myTMCRoot.showWO // TFS 39236
										and not self.myTMCRoot.showBOL		//31 Oct 2019	NDL	TFS 47100
										and not self.myTMCRoot.showInventory	// TFS 51219 25MAY2021 NAVAB1
										);
		self.chkTranMapCargo.value := self.myTMCRoot.showCargo; // PAR 25833
	endif;
	
	self.myTMCRoot.initialise(self.myTMCRoot.groupCount);
	self.myTMCRoot.loadList(self.lstData, 1);

	//epr TFS 4135 1/5/17 move loadMoveMappings to showMoveFrame
	
	if itemExpandedArr.isEmpty() then
		itemExpandedArr.add(1);
	endif;

	foreach	count in itemExpandedArr do
		if count &lt;= self.lstData.itemExpanded.size then
			if top = 0 then top := count; endif;
			self.lstData.itemExpanded[count] := true;
		endif;
	endforeach;
	
	if count &gt; 0 then  //par 18539, select first line
		self.lstData.listIndex := 1;
	endif;
epilog
	delete itemExpandedArr;
end;</source>
    </JadeMethod>
