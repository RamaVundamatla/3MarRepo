    <JadeMethod name="tblCGN_dblClick" id="f3ec97f1-d8da-4fe4-8d74-b695ec36184d">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCGN_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	theRow	: Integer;
	idx,
	startRow,
	endRow,
	sortColNo	: Integer;
	sortColName	: String;
	descending	: Boolean;
	obj			: Object;

begin

	theRow := table.row;
	
	if theRow &lt;= 0 then
		return;
	endif;

	if theRow = 1 then
		sortColNo := tblData.column;
	
		if sortColNo &lt;= 0
		or sortColNo &gt; tblData.columns then
			return;
		endif;
		
		if table.CM_DataTable.allTblDataColPropertyNames.size &gt;= sortColNo then	
			// look in the data table collection
			sortColName := table.CM_DataTable.allTblDataColPropertyNames[sortColNo];
		endif;
	
		if sortColName = null then
			app.msgBox(app.getErrorString(Not_Able_To_Sort_By_Column), app.getErrorString(Info), MsgBox_OK_Only + MsgBox_Information_Icon);
			return;
		endif;
		
		table.CM_DataTable.resortTableByColumn(sortColNo);
		
		startRow := table.fixedRows + 1;
		endRow	:= table.rows;
		foreach idx in startRow to endRow do
			if (idx mod 2 = 0) then
				table.accessRow(idx).backColor := self.colorRow1;
			else
				table.accessRow(idx).backColor := self.colorRow2;
			endif;
			obj := table.accessRow(idx).itemObject;
		endforeach;
	
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="bec544c4-0b27-40d8-9046-1abbe6fb0fa2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 October 2018 08:43:40.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023051, locale);
	btnGroupMaint.translateBubbleHelp(Xlat_0023052, locale);
	btnGroupMaint.translateCaption(Xlat_0023053, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="zTblDataSelectRow" id="3a34bec0-37cb-448d-846b-49317f856e88">
        <updating/>
        <source>zTblDataSelectRow( _row : Integer) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	cgAssign : CM_CargoGroupAssignment;

begin

	inheritMethod(_row);
	
	if _row &gt; self.tblData.fixedRows then
		cgAssign := self.tblData.accessRow( _row ).itemObject.CM_CargoGroupAssignment;
	endif;
	
	self.btnGroupMaint.enabled := cgAssign &lt;&gt; null;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zTblDataSysNotifyUpdate" id="c2cc6690-b3f1-4582-b222-90df592fb94a">
        <updating/>
        <source>zTblDataSysNotifyUpdate(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	invalid : Boolean;
	edition : Integer;
	cga : CM_CargoGroupAssignment;
	rowIndex : Integer;
	cg : CM_CargoGroup;
	string : String;

begin

	rowIndex := self.tblCGN.row;

	inheritMethod(eventType, theObject, eventTag);
	
	if theObject &lt;&gt; null and theObject.isKindOf( CM_CargoGroupAssignment ) then
		cga := theObject.CM_CargoGroupAssignment;
		on Exception do app.handleDeletedObject( exception, cga, invalid );
		edition := cga.edition;
		if invalid then 
			return;
		endif;
		if not self.tblData.allSelectedObjects.includes( cga ) then
			return;
		endif;
		on Exception do null;
		
		if rowIndex &lt;= self.tblCGN.fixedRows or rowIndex &gt; self.tblCGN.rows then
			return;
		endif;
		
		self.tblCGN.column := 1;
		self.tblCGN.row := rowIndex;
		self.tblCGN.click( self.tblCGN );
		
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
