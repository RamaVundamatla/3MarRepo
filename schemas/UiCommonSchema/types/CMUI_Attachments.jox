    <JadeMethod name="displayMyCurrentItem" id="11747778-2095-4124-8dd6-861b9988229d">
        <updating/>
        <source>displayMyCurrentItem() updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entDef 		:EntTableDef;
	entRow		:EntTableRow;
	viewName	:String;
	currentObj	:CMIF_InOutAttachment;
	entView		:EntTableView;
	isoType		: CM_ISOType;
begin
	self.myCurrentObj := tblAll.accessRow(tblAll.row).itemObject.CMIF_InOutAttachment;

	if self.myCurrentObj = null then 
		return;
	endif;
	
	currentObj := self.myCurrentObj;
	entDef := app.myController.getEntTableDef(ETDef_Attachment);
	
	if currentObj = null then
		return;
	endif;
	if (currentObj.myCargoType &lt;&gt; null) and (currentObj.myCargoType.id = TI_CargoType_Log) then
		viewName := 'LogAttachment';
	else
		viewName := 'Default';
	endif;
		
	entView := entDef.allEntTableViews.getAtKey(viewName);
		
	foreach entRow in entView.allEntTableRows do
		tblItem.setValueByName(entRow.name, currentObj.getDisplayStringForAttribute(entRow.name,false));
	endforeach;

	isoType := app.myRoot.allISOTypes[currentObj.getDisplayStringForAttribute(ETRow_IsoType,false)];
	if isoType &lt;&gt; null then
		self.cmbISOType.listIndex := self.cmbISOType.findObject(isoType);
		self.cmbISOType.lostFocus(self.cmbISOType);
	endif;

	btnUpdate.enabled := true;
	btnRemove.enabled := true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="24e768ac-e7c1-4322-94fc-922403ed8833">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	12 September 2003 By: cnwgd1
//--------------------------------------------------
constants
	RowHeight	: Integer = 20;
vars

begin
	if self.windowState = WindowState_Minimized then
		return;
	endif;
	inheritMethod();
/*	// Group Box and child controls
	
	grpDetail.top	:= WinTopMargin;
	grpDetail.left	:= WinLeftMargin;
	grpDetail.width	:= self.width - WinLeftMargin - WinRightMargin;
	
	tblItem.top 	:= grpDetail.top + VerticalSpacing;
	tblItem.left	:= grpDetail.left + HorizontalSpacing;
	tblItem.height := (5 * RowHeight);
	tblItem.width	:= grpDetail.width - (VerticalSpacing * 2);
	
	btnRemove.top	:= tblItem.top + tblItem.height + VerticalSpacing;
	btnRemove.left	:= tblItem.left + tblItem.width - btnRemove.width;

	btnUpdate.top	:= btnRemove.top;
	btnUpdate.left	:= btnRemove.left - HorizontalSpacing - btnAdd.width;
	
	btnAdd.top		:= btnRemove.top;
	btnAdd.left		:= btnUpdate.left - HorizontalSpacing - btnAdd.width;
	
	grpDetail.height := btnRemove.top + btnRemove.height + VerticalSpacing;

	tblItem.parentTopMargin		:= tblItem.top;
	tblItem.parentBottomMargin	:= grpDetail.height - btnRemove.top + VerticalSpacing;

	// Fit tblAll into whats left
	tblAll.top	:= grpDetail.top + grpDetail.height + VerticalSpacing;
	tblAll.left	:= grpDetail.left;
	
	tblAll.height	:= self.clientHeight - grpDetail.height - grpDetail.top - (VerticalSpacing * 2);
	tblAll.width	:= grpDetail.width;
	
	tblItem.cnEcResizeContents;
	tblAll.cnEcResizeContents;*/
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="fd18fff8-e5f5-4c70-a590-819060e47484">
        <updating/>
        <source>initForm(_cargoType : Integer; _terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     13 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.myTerminal := _terminal;
	self.createMyAssistant(CMUI_Assistant);
	self.handleMenusForModalDisplay();
	self.initTable(_cargoType);
	showTablesForAttachmentType(_cargoType);
end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="5be040a0-6290-423d-bdd0-eccb32a252c8">
        <updating/>
        <source>initTable(pCargoType : Integer) updating;
//--------------------------------------------------------------
//Created: 01 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entTableDef 	: EntTableDef;
	intFaceAttach	: CMIF_InOutAttachment;
	tmpRow			: Integer;

begin
	
	txtQuantity.automaticCellControl := true;
	tblAll.selectionType := CM_BaseTable.SelectionType_Row; 
	tblItem.warningMethod := 'entTableWarning';
	entTableDef := app.myController.getEntTableDef('Attachment');
	tblItem.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');

	if pCargoType = BOLType_Log then
		self.myCurrentView := entTableDef.allEntTableViews['Log'];	
		if self.myCurrentView &lt;&gt; null then
			tblItem.showHideRowsByView(self.myCurrentView, CM_EntryTable.ShowHideRows, false);
		else
			tblItem.showHideRowsByList(null, CM_EntryTable.ShowHideRows, false);
		endif;
		tblAll.addItemAt('Number' &amp; Tab &amp; 'Min SED' &amp; Tab &amp; 'Max SED' &amp; Tab &amp; 'Condition', 1);
		tblAll.rows := 1;
		self.caption := "Log Details";	

	else
		self.myCurrentView := entTableDef.allEntTableViews['Default'];
		if self.myCurrentView &lt;&gt; null then
			tblItem.showHideRowsByView(self.myCurrentView, CM_EntryTable.ShowHideRows, false);
		else
			tblItem.showHideRowsByList(null, CM_EntryTable.ShowHideRows, false);
		endif;

		self.myAssistant.comboBoxISOType(cmbISOType, null);
		self.myAssistant.comboBoxCargoBolType(cmbTiType, TI_CargoType_Container, true, true, true, true);
		tblItem.setValueByName('tiType', cmbTiType.text);
		tblAll.addItemAt('Cargo Type' &amp; Tab &amp; 'Number' &amp; Tab &amp; 'Description' &amp; Tab &amp; 'Weight', 1);
		tblAll.rows := 1;
	endif;

	foreach intFaceAttach in self.allAttachments do
		tmpRow := self.tblAll_ShowAttachment(intFaceAttach, 0);
		if intFaceAttach = self.mySelectedItem then
			self.tblAll.accessRow(tmpRow).selected := true;
			self.selectedRow := tmpRow;
			tblAll.row:=tmpRow;
		endif;
	endforeach;
	
	btnAdd.default := true;
	btnUpdate.enabled := false;
	btnRemove.enabled := false;
	tblItem.setFocus();
	tblItem.moveFirst();
	
	if self.mySelectedItem &lt;&gt; null then
		self.displayMyCurrentItem();
	endif;
	
	self.doResize();
	
end;</source>
        <Parameter name="pCargoType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadLogConditions" id="0a8e2da2-7f2f-4320-9b2d-ecc8b1ae6ae1">
        <source>loadLogConditions(_tbl : CM_EntryTable input; _attrName : String);
// ---------------------------------------------------------------------------
// Created:     22 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpCondition	: CM_Code;
	str			: String;
begin
	foreach tmpCondition in app.myRoot.allLogConditionCodes do
		str := str &amp; tmpCondition.code &amp; Tab;
	endforeach;
	
	_tbl.setComboValues(_tbl.getRow(_attrName), str);
						
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
    </JadeMethod>
    <JadeMethod name="removeItem" id="5d7d453b-5eb8-4f85-b6d0-4e79b3fabd5d">
        <updating/>
        <source>removeItem() updating, protected;
//--------------------------------------------------------------
//Created: 19 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj		: Object;
	intFaceAttach : CMIF_InOutAttachment; 
	row ,original : Integer;

begin
	if tblAll.row &gt; 1 and tblAll.row &lt;= tblAll.rows then
		obj := tblAll.accessRow(tblAll.row).itemObject;
		row:=tblAll.row;
		if obj &lt;&gt; null then
			self.allAttachments.remove(obj.CMIF_InOutAttachment);
			delete obj;
		endif;
		tblAll.removeItem(tblAll.row);
	  if tblAll.rows&lt;&gt;1 then
	     original:= tblAll.rows+1;
	     if row=original then	        
	        row:=2;
	     endif;   
	     self.mySelectedItem := tblAll.accessRow(row).itemObject.CMIF_InOutAttachment;
	     tblAll.accessRow(row).selected := true;
			 selectedRow := row;
			 if self.mySelectedItem &lt;&gt; null then
	      	self.displayMyCurrentItem();
	     endif;
	  else 
	     tblItem.clear;   
	  endif;  
	endif;
	
	tblItem.setFocus();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="saveOriginalAttachments" id="773730a4-9752-4945-bb52-91060363e900">
        <updating/>
        <source>saveOriginalAttachments() updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpAttach,
	intFaceAttach	: CMIF_InOutAttachment;

begin

	foreach intFaceAttach in self.allAttachments do
		tmpAttach := intFaceAttach.cloneSelf(true);
		self.allOrigAttachments.add(tmpAttach);
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setItem" id="b231ec27-a574-4092-af7d-031fcab3925d">
        <updating/>
        <source>setItem(pAttachArray : CMIF_InOutAttachmentArray; pSelectedAttach : CMIF_InOutAttachment) updating;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpAttach,
	intFaceAttach	: CMIF_InOutAttachment;

begin

	foreach intFaceAttach in pAttachArray do
		self.allOrigAttachments.add(intFaceAttach);

		tmpAttach := intFaceAttach.cloneSelf(true);
		
		tmpAttach.setInOutReferences(intFaceAttach.myTerminal,
								intFaceAttach.myTerminalArea,
								intFaceAttach.myLocationsController,
								intFaceAttach.myProduct, 
								intFaceAttach.myMasterObject, 
								intFaceAttach.myProxyTrackedItem);
								
		self.allAttachments.add(tmpAttach);
		
		if intFaceAttach = pSelectedAttach then
			self.mySelectedItem := tmpAttach;
		endif;
		
	endforeach;
	
end;</source>
        <Parameter name="pAttachArray" type="CMIF_InOutAttachmentArray"/>
        <Parameter name="pSelectedAttach" type="CMIF_InOutAttachment"/>
    </JadeMethod>
    <JadeMethod name="showTablesForAttachmentType" id="d908ed80-c2fd-4d63-b984-2760d41a8ccf">
        <updating/>
        <source>showTablesForAttachmentType(pCargoType : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     22 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableDef 	: EntTableDef;
	intFaceAttach	: CMIF_InOutAttachment;
	tmpRow			: Integer;
begin
	
	tblItem.warningMethod := 'entTableWarning';
	entTableDef := app.myController.getEntTableDef(ETDef_Attachment);
	

	if pCargoType = BOLType_Log then
		self.myCurrentView := entTableDef.allEntTableViews['LogAttachment'];	
		if self.myCurrentView &lt;&gt; null then
			tblItem.showHideRowsByView(self.myCurrentView, CM_EntryTable.ShowHideRows, false);
		else
			tblItem.showHideRowsByList(null, CM_EntryTable.ShowHideRows, false);
		endif;
		self.loadLogConditions(tblItem, ETRow_LogCondition);
	else
		self.myCurrentView := entTableDef.allEntTableViews['Default'];
		if self.myCurrentView &lt;&gt; null then
			tblItem.showHideRowsByView(self.myCurrentView, CM_EntryTable.ShowHideRows, false);
		else
			tblItem.showHideRowsByList(null, CM_EntryTable.ShowHideRows, false);
		endif;
	endif;

//	self.resize();
	tblItem.cnEcResizeContents;
//	tblAll.cnEcResizeContents;

	
end;</source>
        <Parameter name="pCargoType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblAll_ShowAttachment" id="b0a9d63b-7488-4ade-a005-c56604fe7d41">
        <updating/>
        <source>tblAll_ShowAttachment(pIntFaceAttach : CMIF_InOutAttachment; pRow : Integer) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//Log display Order: Log Id/SEDMin/SEDMax/Condition
//Attachment Order: CargoType/Number(id)/ISOType/Weight
// ---------------------------------------------------------------------------
vars
	str		: String;
	theRow	: Integer;
	
begin

	if pIntFaceAttach.myCargoType &lt;&gt; null then
		if pIntFaceAttach.myCargoType.id = TI_CargoType_Log then
			str := str &amp; "Log: ID=" &amp; pIntFaceAttach.id &amp; Tab;	//Log trackedItem Id
		else			
			str := pIntFaceAttach.myCargoType.description &amp; Tab;	//Attachment CargoType
			str := str &amp; pIntFaceAttach.id &amp; Tab;					//Attachment trackedItem Id
		endif;
	else
		str := Tab;
	endif;
	
	if pIntFaceAttach.myCargoType.id = TI_CargoType_Log then
		str := str &amp; pIntFaceAttach.id &amp; Tab &amp; 
							pIntFaceAttach.sedMin.String &amp;'/' &amp; pIntFaceAttach.sedMax.String &amp; '/' &amp; //sedMax &amp; min now in same cell
							 pIntFaceAttach.condition.String;		//Log condition
					
	else str := str &amp; pIntFaceAttach.isoType &amp; Tab &amp;	//Attachment ISOType
				pIntFaceAttach.weight.asStringWeightJMT();			//Attachment Weight
	endif;

	if pRow = 0 then
		theRow := tblAll.addItem(str);
	else
		theRow := pRow;
		tblAll.accessCell(theRow, 1).text := str;
	endif;
	
	tblAll.accessRow(theRow).itemObject := pIntFaceAttach;
	return theRow;

end;</source>
        <access>protected</access>
        <Parameter name="pIntFaceAttach" type="CMIF_InOutAttachment"/>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8dd068ea-08d9-4bc2-a15e-9bf42d74d407">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007259, locale);
end;</source>
    </JadeMethod>
