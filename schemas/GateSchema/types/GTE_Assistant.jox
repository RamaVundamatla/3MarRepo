    <JadeMethod name="setCertified" id="296e0704-51e1-462a-823b-826843ebc389">
        <source>setCertified( _entryTable : CM_EntryTable input; _sourceLocation: CM_SourceLocation; _sourceSubLocation: CM_SourceSubLocation; _sourceSubSubLocation: CM_SourceSubSubLocation);
/* ---------------------------------------------------------------------------
Created:	05 November 2009	by cnwvu1

Purpose:	CCMS JML 1105, PAR 21535. FSC is set by default from Source Locations,
			defined in the System Ops / Code Groups Maintenance
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if _sourceSubSubLocation &lt;&gt; null then
		_entryTable.setValueByName(ETRow_IsFSC, _sourceSubSubLocation.isCertified() );
		return;
	endif;

	if _sourceSubLocation &lt;&gt; null then	// default FSC from sourceLocation
		_entryTable.setValueByName(ETRow_IsFSC, _sourceSubLocation.isCertified() );
		return;
	endif;
	
	if _sourceLocation &lt;&gt; null then	// default FSC from sourceLocation
		_entryTable.setValueByName(ETRow_IsFSC, _sourceLocation.isCertified() );
		return;
	endif;

	_entryTable.setValueByName(ETRow_IsFSC, false );
	
end;</source>
        <Parameter name="_entryTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="_sourceLocation" type="CM_SourceLocation"/>
        <Parameter name="_sourceSubLocation" type="CM_SourceSubLocation"/>
        <Parameter name="_sourceSubSubLocation" type="CM_SourceSubSubLocation"/>
    </JadeMethod>
    <JadeMethod name="setDefaultCommodity" id="5813aa88-7b21-4b10-98b9-b46b8473be49">
        <source>setDefaultCommodity(_commodityCode : String; _cmb : CMUI_ComboBoxObject input) : String;
// ---------------------------------------------------------------------------
// Created:     02 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCommodity	: CM_Commodity;
	
begin

	if _commodityCode &lt;&gt; null then
		tmpCommodity := app.myRoot.allCommodities[_commodityCode];
	endif;
	_cmb.setObject(tmpCommodity);
	
	return _cmb.text;

end;</source>
        <Parameter name="_commodityCode" type="String"/>
        <Parameter name="_cmb" type="CMUI_ComboBoxObject" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDefaultDischargePort" id="9e0521e1-e469-45a5-a2f2-624ffc60559e">
        <updating/>
        <source>setDefaultDischargePort(_portCode : String; _cmb : ComboBox input; _voyage : CM_Voyage) : String updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpPort		: CM_Port;
	
begin

	if _portCode &lt;&gt; null then
		tmpPort := app.myRoot.allPorts[_portCode];
	endif;
	self.comboBoxDischarge(_cmb, _voyage, tmpPort);

	return _cmb.text;

end;</source>
        <Parameter name="_portCode" type="String"/>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFieldsFromContainerRange" id="c4de0f96-8bda-45fc-b17e-0300096f4bd8">
        <source>setFieldsFromContainerRange(pId : String; pTblMain, pTblExtra : CM_EntryTable io; pCmbIsoType : GTE_ComboISOType io);
// ---------------------------------------------------------------------------
// Created:     26 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contRange	: CM_ContRange;
	entryTable	: CM_EntryTable;
	row			: Integer;
		
begin

	contRange := app.myRoot.lookupContainerRange(pId);
	if contRange &lt;&gt; null then
		row := self.mainExtraGetTableAndRow(pTblMain, pTblExtra, ETRow_IsoType, entryTable);
		if row &gt; 0 
		and entryTable.getValue(row) = null then	//only set if not already PAR 10749
			entryTable.setValue(row, contRange.isoType);
			if pCmbIsoType &lt;&gt; null then
				pCmbIsoType.setObject(app.myRoot.allISOTypes[contRange.isoType]);
//				pCmbIsoType.listObject := app.myRoot.allISOTypes[contRange.isoType];
//				pCmbIsoType.text := self.displayEntryISOType(pCmbIsoType.listObject.CM_ISOType);
			endif;
		endif;

		row := self.mainExtraGetTableAndRow(pTblMain, pTblExtra, ETRow_WeightTotal, entryTable);
		if row &gt; 0 
		and entryTable.getValue(row) = null then	//only set if not already PAR 10749
			entryTable.setValue(row, contRange.tareKilos);
		endif;
	
		row := self.mainExtraGetTableAndRow(pTblMain, pTblExtra, ETRow_CoolingType, entryTable);
		if row &gt; 0 then
			entryTable.showRow(row);
			entryTable.setValue(row, app.coolingTypeENumToString(contRange.coolingType, false));
		endif;			
		row := self.mainExtraGetTableAndRow(pTblMain, pTblExtra, ETRow_VoltageType, entryTable);
		if row &gt; 0 then
			entryTable.showRow(row);
			entryTable.setValue(row, app.voltageTypeENumToString(contRange.voltageType, false));
		endif;			
		/*row := self.mainExtraGetTableAndRow(pTblMain, pTblExtra, ETRow_HasCoolingWaterConn, entryTable);
		if row &gt; 0 then
			entryTable.showRow(row);
			entryTable.setValue(row, contRange.hasCoolingWaterConnection);
		endif;*/							
	endif;

end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="io"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="io"/>
        <Parameter name="pCmbIsoType" type="GTE_ComboISOType" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setIntFaceObjectDecimal" id="54de84dd-856d-4c10-8c63-9b1c2a9d6029">
        <source>setIntFaceObjectDecimal(_intFaceObject : CMIF_TIObject io; _tblMain, _tblExtra : CM_EntryTable input; 
							_fieldName : String; _nullValue : Decimal);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 May 2009	cnwrd1	Initial creation

*/

vars
	tmpStr : String;
	
begin

	tmpStr := self.mainExtraGetValue(_tblMain, _tblExtra, _fieldName).String;
	if tmpStr.trimRight = null then
		_intFaceObject.setPropertyValue(_fieldName, _nullValue);
	else
		_intFaceObject.setPropertyValue(_fieldName, tmpStr.Decimal);
	endif;

end;</source>
        <Parameter name="_intFaceObject" type="CMIF_TIObject" usage="io"/>
        <Parameter name="_tblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="_tblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_nullValue" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setIntFaceObjectInteger" id="28c6a246-e807-4b6e-a118-3164579912f3">
        <source>setIntFaceObjectInteger(pIntFaceObject : CMIF_TIObject io; pTblMain, pTblExtra : CM_EntryTable input; 
							pFieldName : String; pNullValue : Integer);
//----------------------------------------------------------------
