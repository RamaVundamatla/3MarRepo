    <JadeMethod name="setFromRealWSObject" id="55620a30-6e83-4681-8846-e7c3a28ad059">
        <updating/>
        <source>setFromRealWSObject(_realWSObject: KRF_ResultStatus) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Feb 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars
	realMessage : KRF_Message;
begin
	inheritMethod(_realWSObject);
	self.status := _realWSObject.status;
	foreach realMessage in _realWSObject.messages do // Not using KRF_Message here, currently only description
		self.messages.add(realMessage.description.String); // returned by KiwiRail w/s
	endforeach;
epilog

end;</source>
        <Parameter name="_realWSObject" type="KRF_ResultStatus"/>
    </JadeMethod>
</Class>
