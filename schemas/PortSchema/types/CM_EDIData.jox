    <JadeMethod name="addEDIConfigToEDITis" id="78727cc0-0413-4c61-8750-4ac423f7bfff">
        <source>addEDIConfigToEDITis(_ediUserDefinedAssist  : CMIF_EDIUserDefinedAssist input);
/*
17 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
21 Nov 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
*/
vars
	ediTI  			: CM_EDITrackedItem;
	ediTI2 			: CM_EDITrackedItem;
	xlationOperator	: CM_Operator;
	
begin
	xlationOperator := self.getXlationOperator();						//01.12.2022 navma1 #55424	
	
	foreach ediTI in self.allEDITrackedItems do
		ediTI.setMyEDIConfig(self.ediConfig);
		ediTI.doTranslations(xlationOperator);							//21.11.2022 navma1 #55424
		foreach ediTI2 in ediTI.myAttachedItems do
			ediTI2.setMyEDIConfig(self.ediConfig);
			ediTI2.doTranslations(xlationOperator);						//21.11.2022 navma1 #55424
		endforeach;
		ediTI.processAttributeDependencies(_ediUserDefinedAssist, null, true, null); 
	endforeach;
epilog

end;</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addEDIErrorsToPassport" id="baf31fb6-f4ba-40c4-b6e2-df6c7b5937d2">
        <source>addEDIErrorsToPassport();
//
//09 July 2018	jlgrs1	Initial creation
//
vars
	trxError : CM_Error;
	existingErr : CM_Error;
	ediError : CM_EDIError;
begin
	foreach ediError in self.allErrorWarnings do
//		existingErr := app.myPassport.findMatchingError(trxError);
//		if existingErr &lt;&gt; null then
//		   continue;
//		endif;
		create trxError;
		trxError.set(ediError.errorCode, ediError.text, ediError.warningOnly, ediError.fieldName, ediError.myUserObject, null);
		if trxError.warningOnly then
			trxError.setMyWarningPassport(app.myPassport);
		else
			trxError.setMyErrorPassport(app.myPassport);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="addPassportToEDIErrors" id="178d8194-ab81-4487-9568-4b03c0f2d0cc">
        <source>addPassportToEDIErrors();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2016	cnwndl1	Initial creation	TFS 2004
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/

vars

	trxError : CM_Error;
	existingErr : CM_EDIError;
	ediError : CM_EDIError;
	
	dynaDict : DynaDictionary;	//03 Apr 2019	NDL	TFS 44194
	startObject : CM_EDIError;	//03 Apr 2019	NDL	TFS 44194
	iterObject : CM_EDIError;	//03 Apr 2019	NDL	TFS 44194
	iter : Iterator;	//03 Apr 2019	NDL	TFS 44194
	
begin

	//03 Apr 2019	NDL	TFS 44194 - dyna dict should be more efficient than trawling through all existing errors
	create dynaDict transient;
	dynaDict.setMembership( CM_EDIError );
	dynaDict.addMemberKey( CM_EDIError::myUserObject.name, false, false );
	dynaDict.addMemberKey( CM_EDIError::errorCode.name, false, false );
	dynaDict.addMemberKey( CM_EDIError::warningOnly.name, false, false );
	dynaDict.endKeys( true );
	
	self.allErrorWarnings.copy( dynaDict );
	iter := dynaDict.createIterator;

	//epr TFS 6980 26/9/17 so we don't see errors that are no longer there after a re verify
//	self.allErrorWarnings.purge();	// not necassary as findMatchingError removes duplicates and purge removes skip messages
	// for each passport error create a persistent edi error (provided we don't already have one.)
	foreach trxError in app.myPassport.allErrorWarnings do
		
	//	existingErr := self.allErrorWarnings.findMatchingError( trxError );
		
		//03 Apr 2019	NDL	TFS 44194
		existingErr := null;
		startObject := dynaDict.getAtKey( trxError.myUserObject, trxError.errorCode, trxError.warningOnly ).CM_EDIError;
		if startObject &lt;&gt; null then
			iter.reset();
			iter.startAtObject( startObject );
			while iter.next( iterObject ) do
				if trxError.myUserObject &lt;&gt; iterObject.myUserObject then
					break;
				endif;
				if trxError.errorCode &lt;&gt; iterObject.errorCode then
					break;
				endif;
				if trxError.warningOnly &lt;&gt; iterObject.warningOnly then
					break;
				endif;
				if trxError.text &lt;&gt; iterObject.text then
					continue;
				endif;
				existingErr := iterObject;
				break;
			endwhile;
		endif;
		
		if existingErr &lt;&gt; null then
		   continue;
		endif;
			
		create ediError;
		ediError.set(trxError.errorCode, trxError.text, trxError.warningOnly, trxError.fieldName, trxError.myUserObject);
		self.allErrorWarnings.add(ediError);
		dynaDict.add( ediError );	//03 Apr 2019	NDL	TFS 44194
	endforeach;

epilog

	delete dynaDict;	//03 Apr 2019	NDL	TFS 44194
	delete iter;	//03 Apr 2019	NDL	TFS 44194

end;</source>
    </JadeMethod>
    <JadeMethod name="addSkipErrorMessage" id="4df01647-d150-4647-a0f5-9ded22824ae4">
        <source>addSkipErrorMessage(	_errorMessage : String; _ediTI : CM_EDITrackedItem; _passport : CM_Passport );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2016	cnwndl1	Initial creation	TFS 2004

*/

vars

	ediTIError: CM_EDIError;

begin

	if self.allErrorWarnings.includesError( _errorMessage, false ) then
		return;
	endif;

	beginTransaction;
	
	create ediTIError;				
	
	ediTIError.set(	0,	//pErrorCode : Integer;
					_errorMessage,	//pText : String;
					false,	// pWarning : Boolean;
					null,	// pField : String;
					self	//_ediTI.myEDIData	// pObject : Object;
					);
	self.allErrorWarnings.add(ediTIError);
	
	commitTransaction;
	
epilog

end;</source>
        <Parameter name="_errorMessage" type="String"/>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="addWarningMessage" id="65d1cee7-4fb3-477d-9076-d376d3ff5e00">
        <source>addWarningMessage(_errorMessage : String; _ediTI : CM_EDITrackedItem; _passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 July 2023	navsp1	Initial creation TFS 59265

*/

vars
	ediTIError: CM_EDIError;
begin

	if self.allErrorWarnings.includesError( _errorMessage, false ) then
		return;
	endif;

	beginTransaction;
	
	create ediTIError;				
	
	ediTIError.set(	0,	//pErrorCode : Integer;
					_errorMessage,	//pText : String;
					true,	// pWarning : Boolean;
					null,	// pField : String;
					self	//_ediTI.myEDIData	// pObject : Object;
					);
	self.allErrorWarnings.add(ediTIError);
	
	commitTransaction;
epilog

end;</source>
        <Parameter name="_errorMessage" type="String"/>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="addWarningMessageInProcess" id="6443177d-603f-44ad-95bf-f3a8d5cb7776">
        <source>addWarningMessageInProcess(_errorMessage : String; _ediTI : CM_EDITrackedItem; _passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 June 2025	navcs2	MTN-34943 POB - QShips feed not flowing to EDI Operations

*/

vars
	ediTIError: CM_EDIError;
begin

	if self.allErrorWarnings.includesError( _errorMessage, false ) then
		return;
	endif;
	
	create ediTIError;				
	
	ediTIError.set(	0,	//pErrorCode : Integer;
					_errorMessage,	//pText : String;
					true,	// pWarning : Boolean;
					null,	// pField : String;
					self	//_ediTI.myEDIData	// pObject : Object;
					);
	self.allErrorWarnings.add(ediTIError);
	
epilog

end;</source>
        <Parameter name="_errorMessage" type="String"/>
