    <JadeMethod name="delete" id="f5996672-eba2-4365-bdf1-743f6b24a851">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2013	cnwer1	Initial creation 31289

*/

vars

begin
	delete self.myProxyObject;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="c6e7618b-6889-4c1c-8bb2-0e983829b8ef">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation 31289

*/

vars
	result : Integer;
	row : Integer;
	pxyDeck : CM_DeckVessel;
begin
	
	if self.tblBays.rows = self.tblBays.fixedRows then
		app.msgBox(app.getErrorString(Must_EnterValid_FileName_First),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass; // PAR 28513
	
	
	while true do
		app.myTrxUA.trxUpdateVesselStructure(self.myProxyObject.CM_CellularVesselStructure, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog('Vessel Bays Definition Import', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	if app.myPassport.trxCompletedOK then
		inheritMethod();
	endif;
epilog
	app.mousePointer := Window.MousePointer_Default; // PAR 28513
end;	</source>
    </JadeMethod>
    <JadeMethod name="doSelectXMLFile" id="e376275c-58d4-4671-b468-7655e2682b31">
        <updating/>
        <source>doSelectXMLFile() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation 31289

*/

vars
	theFileName : String;
	pxyObj : CM_Object;
begin
	app.mousePointer := Window.MousePointer_HourGlass; // PAR 28513
	
	pxyObj:=app.importVesselDefnXMLCreateProxy(false,true,false,theFileName);
	if pxyObj = null then
		app.raiseCMException1(Invalid_XML_need_tag,CM_CellularVesselStructure.name,null,null);
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_Default; 
	
	self.tblBays.rows:=self.tblBays.fixedRows;
	delete self.myProxyObject;
		
	self.txtFileName.text:=theFileName;
	self.myProxyObject:=pxyObj;
	app.myProxyManager.createProxyLink(self.myLOLOVesselStructure, pxyObj);
	self.loadFromProxy();
	
epilog
	app.mousePointer := Window.MousePointer_Default; // PAR 28513

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadFromProxy" id="71d991e3-6fcc-4c84-96c7-38a583b589e1">
        <source>loadFromProxy() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2013	cnwer1	Initial creation 31289

*/

vars
	pxyBay : CM_Bay;
begin
	if self.myProxyObject = null then
		return;
	endif;
	
	if self.myProxyObject.isKindOf(CM_CellularVesselStructure) then
		foreach pxyBay in self.myProxyObject.CM_CellularVesselStructure.allBaysByOrdinal  discreteLock do
			self.addToTable(pxyBay);
		
		endforeach;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDetails" id="db29286b-5c28-4f4f-b3a6-185376ef92b7">
        <updating/>
        <source>setDetails(	_loloVesselStructure : CM_CellularVesselStructure;
			_pxyStructure : CM_Object;
			_fileName : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2013	cnwer1	Initial creation 31289

*/

vars

begin
	self.myLOLOVesselStructure := _loloVesselStructure;
	self.myProxyObject:=_pxyStructure;
	self.txtFileName.text:=_fileName;
	
	if self.myProxyObject &lt;&gt; null and self.myProxyObject.isKindOf(CM_CellularVesselStructure) then
		app.myProxyManager.createProxyLink(self.myLOLOVesselStructure, self.myProxyObject);
	endif;
epilog

end;</source>
        <Parameter name="_loloVesselStructure" type="CM_CellularVesselStructure"/>
        <Parameter name="_pxyStructure" type="CM_Object"/>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b95f90f3-33ac-480c-af61-ad61dce4dc62">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation 31289

*/

vars

begin
	inheritMethod();
	self.caption :=self.caption &amp; " "  &amp; self.myLOLOVesselStructure.myVessel.code;
	self.setupTable();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTable" id="de2b0f51-ec27-4d21-9ac2-45e64489bad4">
        <source>setupTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation 31289

*/

vars

begin
	self.tblBays.columns:=1;
	self.tblBays.row:=1;
	self.tblBays.text:="Bay Id";// &amp; Tab &amp; "New Bay Id";
	self.tblBays.accessMode:= Table.AccessMode_Cell;
	self.tblBays.accessColumn(1).enabled:=false;
	self.tblBays.row:=2;
	self.tblBays.rows:=1;
	self.loadFromProxy();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="259f22db-01a4-411e-9af4-abc0c29a1d29">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 May 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019069, locale);
	btnFileOpen.translateCaption(Xlat_0019070, locale);
	lblDescription.translateCaption(Xlat_0019071, locale);
	lblFileName.translateCaption(Xlat_0019072, locale);
end;</source>
    </JadeMethod>
</GUIClass>
