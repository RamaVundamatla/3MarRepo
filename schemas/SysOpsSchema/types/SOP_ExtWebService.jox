    <JadeMethod name="toolbarShowCaptions" id="1b56d43f-0c41-46dc-b239-92ef6b01e05c">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
/*
Purpose:			

Date		Who		Reason
29 October 2021	navab1	TFS 51853
*/

vars
	topY : Real;
begin
	inheritMethod(_showCaptions);
	
	topY := self.frmToolbar.height;
	
	self.frmForm.borderStyle := Frame.BorderStyle_None;
	
	self.frmForm.top := topY;
	self.tblEventMappings.top := topY + self.frmForm.height;
	
	self.tblEventMappings.parentAspect := Frame.ParentAspect_None;
	
	self.height := self.tblEventMappings.top + self.tblEventMappings.height + 80;
	self.tblEventMappings.parentAspect := Frame.ParentAspect_StretchBoth;
epilog

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="29e27a25-9b63-46b6-9a56-eea3b1200e34">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 25 January 2019 09:28:07.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023130, locale);
	btnDelete.translateCaption(Xlat_0023131, locale);
	btnEdit.translateCaption(Xlat_0023132, locale);
	btnNew.translateCaption(Xlat_0023134, locale);
	btnSave.translateCaption(Xlat_0023135, locale);
	lblBusinessUnit.translateCaption(Xlat_0023176, locale);
	lblCargoChainFunction.translateCaption(Xlat_0023136, locale);
	lblEventName.translateCaption(Xlat_0023137, locale);
	lblInvoiceLineType.translateCaption(Xlat_0023177, locale);
	lblTerminal.translateCaption(Xlat_0023178, locale);
end;</source>
    </JadeMethod>
</GUIClass>
