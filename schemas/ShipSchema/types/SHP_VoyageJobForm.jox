    </JadeMethod>
    <JadeMethod name="doDelete" id="db0eb689-05b7-49c9-a618-6385e371f0d0">
        <updating/>
        <source>doDelete(): Boolean updating;
//--------------------------------------------------------------
//Created: 05 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteJob(self.myCurrentObject.CM_Job, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Voyage Job', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
  	
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="3baa4fd3-8246-445c-8bfe-2db7db718452">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 23 April 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 07/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
vars
	craneId,
	systemRemarks,
	remarks,
	newID		: String;
	pxyJob		: CM_VoyageJob;
	result, theJobTypeNum,
	estimatedTimeToCompleteMins		: Integer;
	isTwinLift,
	autoSortIntoOrderOfWorks,
	rtnValue	: Boolean;
	theJobType : CM_JobType;
	workPoint		: CM_WorkPoint;
	jobController : CMIF_VoyageJobParams;
	startTs,
	endTs		: TimeStamp;
	cmbCraneObj	: Object;
	outOfSequenceLoading : Boolean;
	holdJob : CM_VoyageHoldJob;							// TFS 3516
	wle : CM_WorkListEntry;								// TFS 3516
	shift : CM_Shift;									// TFS 3516
	dischargeJob : CM_VoyageHoldJob;					// TFS 3516
begin
	pxyJob := self.myProxyObject.CM_VoyageJob;
	
	theJobType := self.cmbJobType.listObject.CM_JobType;

	if self.mode = Mode_Add then // can only create user jobs - hatch lids jobs etc.
		theJobTypeNum := JOB_TYPE_USER;
		create pxyJob as CM_VoyageHatchLidJob transient;
		self.myProxyObject := pxyJob;
		pxyJob.setProxyVoyage(self.filterVoyage);
		if theJobType &lt;&gt; null then
			estimatedTimeToCompleteMins := self.tblJobEdit.getValueByName(ETRow_TimeToComplete).Integer;
		endif;
	elseif self.mode = Mode_Update then // can update user jobs and jobs created by painting on the voyage
		if self.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
		theJobTypeNum := pxyJob.jobType;
		estimatedTimeToCompleteMins := self.tblJobEdit.getValueByName(ETRow_TimeToComplete).Integer;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled mode (' &amp; self.mode.String &amp; ')');
		return false;
	endif;

	self.tblJobEdit.setObjectFromTable(pxyJob, null, false);
	newID := self.tblJobEdit.getValueByName(ETRow_NewJobID).String;
	
	cmbCraneObj:= self.cmbCrane.listObject;
	if cmbCraneObj &lt;&gt; null then
		if cmbCraneObj.isKindOf(CM_Crane) then
			craneId := self.tblJobEdit.getValueByName(ETRow_CraneId).String;
		elseif cmbCraneObj.isKindOf(CM_WorkPoint) then
			workPoint:=cmbCraneObj.CM_WorkPoint;
			craneId:=workPoint.code;
		endif;
	endif;
	
	
	isTwinLift := self.tblJobEdit.getValueByName(ETRow_IsTwinLift).Boolean;
	autoSortIntoOrderOfWorks := self.tblJobEdit.getValueByName(ETRow_AutoSortIntoOrderOfWorks).Boolean;
	systemRemarks := self.tblJobEdit.getValueByName(ETRow_SystemRemarks).String;
	remarks := self.tblJobEdit.getValueByName(ETRow_Remarks).String;
	outOfSequenceLoading := self.tblJobEdit.getValueByName(ETRow_LoadOutOfSequence).Boolean; //cnwrd1 par 30626 ccms 2209 23.10.12
	
	self.getActualStartTS(startTs); 
	
	self.getActualEndTS(endTs);
	
	create jobController transient;
	if theJobTypeNum = JOB_TYPE_USER then
		if self.tblJobEdit.isRowVisible(ETRow_BayId) then
			jobController.myBay := self.cmbBayId.listObject.CM_Bay;
		endif;
		if self.tblJobEdit.isRowVisible(ETRow_DeckId) then
			jobController.myDeck := self.cmbDeckId.listObject.CM_DeckVoyage;
		endif;
		self.cmbHatchLids.allSelectedObjects.copy(jobController.allHatchLids);
	else
		if self.myCurrentObject.isKindOf(CM_VoyageDeckJob) then
			self.myCurrentObject.CM_VoyageJob.allRequests.copy(jobController.allRORORequests);
		elseif self.myCurrentObject.isKindOf(CM_VoyageHoldJob) then										// TFS 3516
			self.myCurrentObject.CM_VoyageHoldJob.allRequests.copy(jobController.allHoldRequests);		// TFS 3516
			holdJob := self.myCurrentObject.CM_VoyageHoldJob;											// TFS 3516
			foreach wle in holdJob.workListEntries do													// TFS 3516
				jobController.myLocation := wle.getTargetLocation;										// TFS 3516
				break;																					// TFS 3516
			endforeach;																					// TFS 3516
			shift := self.myCurrentObject.CM_VoyageHoldJob.myShift;										// TFS 3516
			dischargeJob := self.myCurrentObject.CM_VoyageHoldJob.myDLRDischargeJob;					// TFS 3516
		else
			self.myCurrentObject.CM_VoyageJob.allRequests.copy(jobController.allSlotRequests);
		endif;
	endif;
	
	if self.myCurrentObject.isKindOf(CM_VoyageHoldJob) then												// TFS 3516
		pxyJob.CM_VoyageHoldJob.setProxyVoyageHoldJob(craneId,newID, remarks, systemRemarks,  isTwinLift, theJobTypeNum,theJobType, estimatedTimeToCompleteMins, startTs, endTs,outOfSequenceLoading, shift, dischargeJob, null,null,null);	// TFS 3516
	else																								// TFS 3516
		pxyJob.setProxyVoyageJob(craneId,newID, remarks, systemRemarks,  isTwinLift, theJobTypeNum,theJobType, estimatedTimeToCompleteMins, startTs, endTs,outOfSequenceLoading);//cnwrd1 par 30626 ccms 2209 23.10.12
	endif;																								// TFS 3516
	
	jobController.myVoyage := pxyJob.myVoyage;
	jobController.myProxyJob := pxyJob;
	jobController.autoSortIntoOOW := autoSortIntoOrderOfWorks;
	jobController.craneID := craneId;
	jobController.myJobType := theJobType;
	jobController.remarks := remarks;
	jobController.myWorkPoint:=workPoint; //epr 28/7/11 ccms 1033 
	jobController.allowOutOfOrderLoading := outOfSequenceLoading;

	
	while true do
		if self.mode = Mode_Add then // can only create user jobs - hatch lids jobs etc.
			jobController.myVoyage := self.filterVoyage;
			app.myTrxCA.trxCreateVoyageJob(jobController, self.myCurrentObject,app.myPassport);
		else
			app.myTrxUA.trxUpdateVoyageJob(jobController, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			rtnValue := true;
			break;
		else
			result := app.showErrorWarningDialog('Voyage Job Maintenance', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		rtnValue := false;
		break;
	endwhile;

	
	return rtnValue;
epilog
	delete jobController;
	if rtnValue and self.amInitialisingWithObject then
		self.unloadForm;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetInitProperties" id="444408c0-2d97-4501-bf96-a84a7dcff6fb">
        <updating/>
        <source>doSetInitProperties(_initBay : CM_Bay; _initHatchLids : CM_HatchLidSet) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myInitBay := _initBay;
	_initHatchLids.copy(self.allInitHatchLids);
end;</source>
