    <JadeMethod name="validateMe" id="c0244157-4e71-4703-aa54-42973fdab7ff">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

	realObj : CM_ReportFormatMatchCriteria;
	repFormatDict : CM_ReportFormatMatchCritDict;
	iter : Iterator;
	testObj : CM_ReportFormatMatchCriteria;
	jrwReport	: JadeReportWriterReport;

begin

	if self.myTerminal = null then
		app.raiseCMException(Terminal_reference_set, null, null);
	endif;
	
	jrwReport := self.validateReportName();
	
	inheritMethod();
	
	if self.priority &lt; 0 then
		app.raiseCMException2( Must_greater_than, app.getErrorString(SequenceNumber), "1", null, null );
	endif;
	
	if self.isTransient then
		realObj := self.pxyGetRealObject;
	else
		realObj := self;
	endif;
	
	create repFormatDict transient;
	self.myTerminal.getAlternateFormatsByContext( repFormatDict, self.reportType );
	
	iter := repFormatDict.createIterator;
	while iter.next( testObj ) do
		if testObj = realObj then
			continue;
		endif;
		if testObj.priority = self.priority then
			app.raiseCMException1( VB_DUPLICATED_ITEM, app.getErrorString(SequenceNumber), null, null);
			return;
		endif;
	endwhile;
	
epilog

	delete repFormatDict;
	delete iter;
	delete jrwReport;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateReportName" id="9fa6d467-d42b-408e-9279-a621123371c5">
        <source>validateReportName():JadeReportWriterReport;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2013	cnwndl1	Initial creation	Par 33184

*/

vars

	jrwManager	: JadeReportWriterManager;
	jrwReport	: JadeReportWriterReport;

begin

	if self.reportName = null then
		app.raiseCMException(Report_name_maynot_blank, null, null);
	endif;

	jrwManager := app.createReportWriterManager();
	jrwReport  := jrwManager.getReport(self.reportName);
	if jrwReport = null then
		app.raiseCMException1(Report_not_found, self.reportName, null, null);
	endif;
	
	return jrwReport;

epilog

	delete jrwManager;

end;</source>
        <ReturnType type="JadeReportWriterReport"/>
    </JadeMethod>
</Class>
