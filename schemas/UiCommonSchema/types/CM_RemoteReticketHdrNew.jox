<Class name="CM_RemoteReticketHdrNew">
    <JadeMethod name="loadRemoteTable" id="949e738e-cd73-40a3-be3b-2aedbabedebd">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

// cnwdvb1 12 June 2003 

vars

	detail	: CM_RemoteDataDtl;
	count	: Integer;

begin

	inheritMethod(_table);
	foreach detail in self.allRemoteDataDtl do
		count := count + 1;
		self.addRemoteRow(_table, 'Reticketing Detail ' &amp; count.String, Click, detail);
	endforeach;

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
