    <JadeMethod name="txtDefAutoPing_change" id="f23516a5-5851-417d-8bcd-eba40973c483">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtDefAutoPing_change(textbox: TextBox input) updating;

vars
	n : Integer;
	
begin
	n := textbox.text.Integer;
	
	if n &gt; 999999 then
		self.jtdDefaultAutoPingInterval := 999999; // maximum ping interval
	else
		self.jtdDefaultAutoPingInterval := n;
	endif;

	self.jtdUnsavedChanges := true;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
