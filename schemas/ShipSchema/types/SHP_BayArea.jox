    <JadeMethod name="updateFromNote" id="e7b63c1b-770b-4b56-aeff-1097a9b65f19">
        <source>updateFromNote(_theRow: Integer; _theColumn: Integer; _controller: CM_LocationsController);
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	lRow, lCol : Integer;
	lGridPoint : CMUI_GridPoint;
	numGridTI : Integer;
	droppedTI : CM_TrackedItem;
	myParentForm : Form;
	myDrawingAttrController : CMIF_DrawingAttrController;
begin
	if self.allGridPoints.isEmpty then
		return;
	endif;
	
	if _controller.CM_SlotController.myBayVoyage &lt;&gt; self.myBay then
		return;
	endif;
	
	myParentForm := self.mySDF.myParentForm;
	myDrawingAttrController := self.mySDF.myDrawingAttrController;
	lRow := _theRow;
	lCol := _theColumn;

	lGridPoint := self.allGridPoints[lRow,lCol];
	if lGridPoint &lt;&gt; null then
		if lGridPoint.myLocationsController = _controller then
			// update the point
			lGridPoint.setForUpdate(myDrawingAttrController); // update all the attributes for this point - mainly TI properties
			lGridPoint.drawSelf(self.myGridAreaFrame);
			lGridPoint.setForUpdateAssociatedPoint(myDrawingAttrController);
		endif;
	endif;

end;</source>
        <Parameter name="_theRow" type="Integer"/>
        <Parameter name="_theColumn" type="Integer"/>
        <Parameter name="_controller" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="useTransitColour" id="1998c58c-8f2d-4cef-be32-d5b6b52097f0">
        <source>useTransitColour() : Boolean;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	return (self.transitColour &gt; -1);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateALTAttribute" id="622e59cd-ab47-45a3-812c-746cf1064f5c">
        <updating/>
        <source>validateALTAttribute() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		If we are auto colour coding the opposite of the load or discharge then check that there is no cc there
// ---------------------------------------------------------------------------
vars

	aPoint : CMUI_GridPoint;
	bayPoint : SHP_BayPoint;
	theReturn : Integer;
	trxUpdateOK : Boolean;

	theLocations, ccType,errStr  : String;
begin
	trxUpdateOK := true;
	if self.allSelectedPointsAlt.isEmpty then
		return true;
	endif;

	foreach aPoint in self.allSelectedPointsAlt do
		if aPoint.isKindOf(SHP_BayPoint) then
			bayPoint := aPoint.SHP_BayPoint;
			
			if self.displayMode = ShpDisplayMode_ColCodeLoad then			
			// ##################################
			// LOAD COLOUR CODE
				if bayPoint.colDischMyDischPort &lt;&gt; null or bayPoint.colDischMyJob &lt;&gt; null then
					ccType := "Discharge";
					trxUpdateOK := false;
					theLocations := theLocations &amp; bayPoint.myLocationsController.getFullId() &amp; " " ;
				endif;
			elseif self.displayMode = ShpDisplayMode_ColCodeDisch then			
			// ##################################
			// DISCHARGE COLOUR CODE
				if bayPoint.colLoadMyDischPort &lt;&gt; null or bayPoint.colLoadMyJob &lt;&gt; null or bayPoint.colLoadMyCommodityGroup &lt;&gt; null then
					ccType := "Load";
					trxUpdateOK := false;
					theLocations := theLocations &amp; bayPoint.myLocationsController.getFullId() &amp; " " ;
				endif;
				
			endif;
			
		endif;
	endforeach;
	
	if not trxUpdateOK then
		errStr := app.getErrorString2(WARN_ALREADY_COLOUR_CODED, ccType,theLocations);
		theReturn := app.msgBox(errStr,"Auto Colour Coding",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		return (theReturn = MsgBox_Return_Yes);
	endif;
	return true;
	
epilog
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
