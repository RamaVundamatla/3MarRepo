        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAdhocCams_click(menuItem: MenuItem input) updating;
/*

Date		Who		Reason
08 September 2015	cnwer1	Initial creation PAR

*/

vars
	form : CMUI_CamsAdhocRun;
begin
	if self.myCurrentTableItem = null then
		return;
	endif;
	
	if self.myCurrentObject = null then
		return;
	endif;
	
	if not self.myCurrentObject.isKindOf(CM_CamProtocol) then
		return;
	endif;
	
	form :=app.loadForm(CMUI_CamsAdhocRun,CMUI_Assistant,false,false,true,self.myTerminal,null).CMUI_CamsAdhocRun;
	form.myCamsProtocol:=self.myCurrentObject.CM_CamProtocol;
	form.showModal;
epilog

end;</source>
