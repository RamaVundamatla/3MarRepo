    <JadeMethod name="getDRFutureMove" id="8f52cacd-1700-4de8-9b80-137e7199cfa1">
        <source>getDRFutureMove() : CM_FutureMove;
/*

Purpose:			Gets the future move object being used to connect the WLEs used
					in the direct release move
					
Parameters:			

Return Value:		The FutureMove used for the direct release; Null if not a direct release

Date				Who		Reason
05 July 2019		jlgzm1	TFS 42863 MSL - Direct Release Between RORO Voyages and Rail - Break Bulk

*/

vars

begin
	if self.isDRLinkedByFM then
		if self.myFutureMove &lt;&gt; null then
			return self.myFutureMove;
		else
			return self.myFutureMoveDR;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_FutureMove"/>
    </JadeMethod>
    <JadeMethod name="getDRLinkedVoyageJob" id="3c92c2f2-f78f-41c0-8022-ade6caf4d02e">
        <source>getDRLinkedVoyageJob() : CM_VoyageJob;
/*

Purpose:			

Parameters:			

Return Value:		The VoyageJob linked to the direct release 

Date		Who		Reason
21 May 2019	jlgzm1	TFS 42840 MSL Direct Release between Voyages and Rail
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
*/

vars
	vwle 				: CM_VoyageWLE;
	futureMoveDR,
	futureMove			: CM_FutureMove;
begin
	
	futureMoveDR := self.myFutureMoveDR;									//05.06.2025 navma1 #MTN-34114
	
	if futureMoveDR &lt;&gt; null then											
		if futureMoveDR.myWorkListEntry &lt;&gt; null then
			if futureMoveDR.myWorkListEntry.isKindOf(CM_VoyageWLE) then
				vwle := futureMoveDR.myWorkListEntry.CM_VoyageWLE;
			endif;
		endif;
	endif;
	
	futureMove := self.myFutureMove;
	
	if futureMove &lt;&gt; null then
		if futureMove.myWorkListEntryDR &lt;&gt; null then
			if futureMove.myWorkListEntryDR.isKindOf(CM_VoyageWLE) then
				vwle := futureMove.myWorkListEntryDR.CM_VoyageWLE;
			endif;
		endif;
	endif;
	if vwle = null then
		return null;
	endif;
	
	return vwle.job.CM_VoyageJob;
epilog

end;</source>
        <ReturnType type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="getDRLinkedWLE" id="a51aebb1-17ca-41dc-af52-df6e485cd732">
        <source>getDRLinkedWLE() : CM_WorkListEntry;
/*

Purpose:			Get the other wle linked to us for direct release

Parameters:			

Return Value:		Direct Release linked wle, null if not a direct release

Date		Who		Reason
31 May 2019	jlgzm1	TFS 42840 MSL Direct Release between Voyages and Rail

*/

vars
	
begin
	if self.myFutureMoveDR &lt;&gt; null then
		return self.myFutureMoveDR.myWorkListEntry;
	elseif self.myFutureMove &lt;&gt; null then
		return self.myFutureMove.myWorkListEntryDR;
	endif;
epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getDeliveryAddressCode" id="c05881df-c19f-47ca-9535-2ba5dda23e9c">
        <source>getDeliveryAddressCode() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 October 2023			jlizm1	Initial creation TFS 59730 Kiosk Load Sequence

*/

vars
	resDet : CM_ReserveDetail;
	address : CM_Address;
	
begin
	if self.myRequest = null then	
		return null;
	endif;
	
	resDet := self.myRequest.myReserveDetail;
	
	if resDet = null then
		return null;
	endif;
	
	address := resDet.myDeliveryAddress;
	
	if address = null then
		return null;
	endif;
	
	return address.code;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDeliveryRequest" id="92234ea7-352d-48ef-8619-4da37d0a108d">
        <source>getDeliveryRequest() : CM_DeliveryRequest;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
30 October 2024	navpw1	Initial creation JIRA: MTN-14770

*/

vars
	wleRequest : CM_Request;
	
begin
	wleRequest := self.myRequest;
	
	if wleRequest = null then
		return null;
	endif;
	
	if not wleRequest.isDeliveryRequest then
		return null;
	endif;
	
	return wleRequest.CM_DeliveryRequest;
	
end;</source>
        <ReturnType type="CM_DeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="getDensity" id="f5d54677-3dd9-4a22-9980-a508a234711a">
        <source>getDensity() : Decimal;
/*

Date		Who		Reason
08 April 2014	cnwer1	Initial creation PAR

*/

vars
	ti 			: CM_TrackedItem;
	ct			: CM_CargoType;
	product	 	: CM_Product;
	density 		: Decimal[14,4];
begin
	ti:=self.getMyTrackedITem;
	if ti &lt;&gt;  null then
		ct:=ti.myCargoType;
		product:=ti.myProduct;
		density:=ti.getDensity;
	else
		//epr par 34406 25/6/14
		if self.myRequest &lt;&gt; null then
			density:= self.myRequest.getDensityFromCargoType();
		endif;
	endif;
	
	return density;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDetailForRemoteQuery" id="34b5a5fd-6231-4e24-a42a-ec6a3599d445">
        <source>getDetailForRemoteQuery(_type : String) : String;

vars

	lift,
	drop,
	response	: String;
	docket		: CM_BOL;
	controller	: CM_LocationsController;

begin

	
	if self.myTrackedItem &lt;&gt; null then
		controller := self.myTrackedItem.getPrimaryLocation(QUEUE_MODE);
		if controller &lt;&gt; null then
			drop := controller.getID();
			lift := drop;
		endif;
		if _type = CM_RemoteDataObject.Type_Full then
			response := self.myTrackedItem.getDetailForWLE();
			return lift &amp; ',' &amp; drop &amp; ',' &amp; response;
		endif;		
	endif;
	return lift &amp; ',' &amp; drop;

end;</source>
        <Parameter name="_type" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDischargeTime" id="eab081a9-c9c9-4161-8e86-7c502777feda">
        <source>getDischargeTime() : TimeStamp;
/*
Purpose:		OPSVIEW	

Date		Who		Reason
13 December 2021	navab1	TFS 51853
*/

vars
	job : CM_Job;
begin
	job := self.job;
	
	if job = null then
		return null;
	endif;
	
	if job.isRelease() then
		return null;
	endif;
	if not self.isCompleteForJob() then
		return null;
	endif;
	
	if job.isRoadJob()
	or job.isRail()
	or job.isVoyageTypeJob() then
		// completed receive road, rail or voyage type job
		return self.completedDate;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b5e00621-1806-4cca-ac5e-7977e5994275">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 13 May 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		 Reason
12 jan 2009	cnwkpd1  PAR #18735 - Handle invalid object references using	exception handler
21/02/2010 	cnwcs5	 par22193 - inlcude isoGroup
15/11/2010	cnwdap1	 PAR #23794 CCMS MES 1102 Show wagon if tracked item is a TBA item
01/12/2010	cnwdap1	 PAR #26477 Get release number from self if tracked item is a TBA item
07/03/2011	cnwdap1	 PAR #27153 CCMS POL 2000 Add Load Port and Load Voyage to Rail Operations screen
08/03/2011	cnwmh5	 PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
29/04/2013	cnwdap1	 PAR #31155 CCMS SFW 1321 Imperial Measurements
05/04/2016	cnwdap1	 PAR #37738 Special location ID code for well car wagons
21/05/2019	jlgzm1	 TFS 42840 MSL Direct Release between Voyages and Rail
18/09/2019	jlgka1	 TFS 46566 JMT - Invalid property value 'markNumber' related to TFS 46472 changes.
09/02/20200	jlika1	 TFS 52109 CPL - Job Operations screen - Adding Two more columns in available
15/03/2022	navsrk20 TFS #53013 - Column Organiser - Booking 
15/03/2022	navsrk20 TFS #53016 - MTN - Rail Ops - Temperature in Column Organiser
18/05/2022  navhl20	 TFS 53430  EUP - Sub Carrier registration in MTN
31/05/2022 	navtnr20 3204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
01/0/2022	navma1	 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
21/06/2022  navsj20  TFS 53911 MTN - Hold Job Ops Moved Quantity
19 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
19/10/2022	jlizm1	 TFS 54118 Assigning Releases to Wagons
22 May 2023 navhl20  ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
29 May 2023 navhl20	 Defect 58179: MTN - Road Operations - Commodity column details has changed from Code to Description
06 Jun 2023 navhl20  ChangeRequest 57762: EUP - Delivery Dispatch – Pack/UnPack
07 Jun 2023 navhl20  ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
03 Jul 2023 navma1  ChangeRequest 58849: EUP | Delivery Dispatch Screen - Unpack Operation
18 Sep 2023	navlw1	Bug 60382: MTN - The Work Order Operations form's column organizer is missing some fields.
27/09/2023	navkc1	CR 60428 Task 60701: UI - Customs Status on Transport UI
16 Oct 2023 navhl20 Bug 60863: EUP - Delivery Dispatch Remedial [1]
18 Oct 2023 navhl20 Bug 60931: EUP - Delivery Dispatch Remedial [2]
08 Nov 2023 navnk30 Bug 61032: MTN - Creating an Internal Move from a Release is no longer displaying the Operator in the Yard Operations Work List view
22 Nov 2023 navhl20 Bug 61048: EUP - Spinning wheel appears when performing the Rail Load using WO Operations app.
28 Nov 2023 navhl20 ChangeRequest 61508: EUP | Ship Operations in DD - [54176.010] - [Release] Ship Job List 
29 Nov 2023 navhl20 ChangeRequest 61510: EUP | Ship Operations in DD - [54176.020] - [Release] Allocate Jobs to Gangs and Gangs to Holds
18 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
18 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
26 Aug 2024	navbs1	Bug 65777: EUP | 53729 - Delivery Dispatch Screen - wrong WO info when multiple in one Job
17 Oct 2024 navpw1	JIRA: MTN-33053 - Added any amount return for Total QUantity if it is an Any Id Any Amount
11 Nov 2024	navdap1	MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
31 Jan 2025	navhl20 Bug MTN-33648: EUP - Partial move by weight is not working in Work Order Operation screen - Release
13 Aug 2025	naviv1	MTN-35710 : Release No disappears when a cargo item is assigned to the release job
10 Nov 2025	navdap1	MTN-36554 MTN | Cargo Type for Contents field missing on Prenote Enquiry and Road Operations screens
*/

vars
	trainStr, 
	rtStr		: String;
	queueStatus : Integer;
	theLocation : CM_LocationsController;
	br			: CM_BulkRelease;
	entry		: CM_RTQueueEntry;
	invalidObj	: Boolean;
	futureMove	: CM_FutureMove;
	bol			: CM_BOL;
	rfid 		: CM_RFIDTag;
	type 		: String;					// PAR #31155
	str			: String;					// PAR #31155
	wagonCntlr 	: CM_WagonController;
	workOrder	: CM_WorkOrder;
	ti			: CM_TrackedItem;
	
begin
	if _attrName = ETRow_MachineId then
		return self.getWorkingMachineID(); 			// cnwrd1 9.11.2010 par 26261  
	elseif _attrName = ETRow_QueueId then
		return self.queueId;		
	elseif _attrName = ETRow_WorkOrder then			//01.06.2022 navma1 #52351
		workOrder := self.getWorkOrder();			//11.09.2024 navma1 #65777
		if workOrder &lt;&gt; null then
			return workOrder.id;
		endif;
		return null;
	elseif _attrName = ETRow_TaskType then
		return self.getTaskTypeDesc();					
	elseif _attrName = ETRow_WleCount then
		return self.getNumberInWleSet.String &amp; '/' &amp;  self.job.workListEntries.size.String;
	elseif _attrName = ETRow_RadioTelemetry then
		rtStr := self.getRTLetter();
		entry := self.allRTQueueEntries.first;
		if entry &lt;&gt; null then					// PAR #18735
			on Exception do app.handleDeletedObject(exception, entry, invalidObj);		// PAR #18735
			queueStatus := entry.status;
			if queueStatus = ENTRY_USER_HELD or queueStatus = ENTRY_SYSTEM_HELD then	//22 Apr 2015	NDL	Par 36014
				rtStr := rtStr &amp;  ' H';
			endif;
		elseif self.myBOL &lt;&gt; null then
			bol := self.myBOL;
			if bol &lt;&gt; null then
				on Exception do app.handleDeletedObject(exception, bol, invalidObj);	// PAR #18735
				
				rtStr := rtStr &amp;  bol.getDisplayStringForAttribute(_attrName, _short);
			endif;
		endif;
		return rtStr;

	elseif _attrName = ETRow_RegNumber or	   
	   _attrName = ETRow_CarrierId or
	   _attrName = ETRow_JobNumber or
	   _attrName = ETRow_BatNumber or 
	   _attrName = ETRow_BatNo or
	   _attrName = ETRow_Crane or
	   _attrName = ETRow_SubCarrierCodeDesc then			//02/06/2022 navhl20 TFS 53430 
		return self.job.getDisplayStringForAttribute(_attrName, _short);	
	elseif _attrName = ETRow_DwellTimeStr then //This is the visible column in mins
		return self.dwellTime.String;
	elseif _attrName = ETRow_DwellTime then //This is the hidden sort column
		return self.dwellTimeAsString();
	elseif  _attrName = ETRow_PlannedRakeId then
		theLocation := self.getLocationForMode(PLANNING_MODE);
		if theLocation &lt;&gt; null then
			if CM_WellcarWagonController.hasInstance(theLocation) 									// PAR #37738
			and self.getMyTerminal.getConfig(RailDefaultWCIdFormat).Integer = Rail_UPSP_Int then	// PAR #37738
				return theLocation.CM_WellcarWagonController.getIdUPSPformat(self.myTrackedItem);	// PAR #37738
			elseif CM_WagonController.hasInstance(theLocation) then									// PAR #37738
			//if CM_WagonController.hasInstance(theLocation) then									// PAR #37738
				return theLocation.getFullId();
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_CargoDetails then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.id;
		else
			return self.myRequest.getDisplayStringForAttribute(ETRow_CargoDetails, _short);   // CCMS 1071
		endif;
	elseif _attrName = ETRow_JobId then
		return self.id;
	elseif _attrName =  ETRow_CarrierCode then
		 return null;
	elseif _attrName =  ETRow_JobStatus then
		 return null;
	elseif _attrName =  ETRow_CreationDateTime then
		 return null;
	elseif _attrName = ETRow_PlannedLocnAuto then
		futureMove := self.myFutureMove;		// PAR #18735
		if futureMove &lt;&gt; null then		
		// and global.isValidObject(self.myFutureMove) then
			on Exception do app.handleDeletedObject(exception, futureMove, invalidObj);
			rtStr := futureMove.getPrimaryLocationId();
			return rtStr;
  		endif;
  		
	elseif _attrName = ETRow_MyPlannedLocation or
	   _attrName = ETRow_PlannedLocnId or		
	   _attrName = ETRow_PlannedLocn then
	   
	   	futureMove := self.myFutureMoveDR;			// TFS 42840
		if futureMove = null then 					// TFS 42840
			futureMove := self.myFutureMove;		// PAR #18735
		endif;
		if futureMove &lt;&gt; null then	
			on Exception do app.handleDeletedObject(exception, futureMove, invalidObj);
			
			// MTN-18897
			if futureMove.isMoveToFullGCArea and futureMove.getPrimaryLocation &lt;&gt; null then
				theLocation := futureMove.getPrimaryLocation;
				rtStr := theLocation.myTerminalArea.id;
			else
				rtStr := futureMove.getPrimaryLocationId();
			endif;
			return rtStr;
  		endif;
   		
	   	if self.myBOL &lt;&gt; null then
			bol := self.myBOL;
			if bol &lt;&gt; null then
				on Exception do app.handleDeletedObject(exception, bol, invalidObj);	// PAR #18735
				rtStr := bol.getPlannedLocnDesc();
			endif;
			return rtStr;
		endif;
		// 3494 and 3504 show planned location from the tracked item 
		if self.myTrackedItem &lt;&gt; null then
			if self.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; null then
				rtStr := self.myTrackedItem.myPrimaryPlannedLocation.getFullIdForTI(true)  &amp; "(" &amp; self.getMoveAmountDisplay(true) &amp; ")";
				return rtStr;
			endif;
		endif;

	elseif _attrName = ETRow_QueuedLocnId then
		
	   	futureMove := self.myFutureMove;		// PAR #18735
		if futureMove &lt;&gt; null then			
			on Exception do app.handleDeletedObject(exception, futureMove, invalidObj);
	    	if futureMove.moveType = TI_FutureMoveQueued then
				//epr par 32261 22/08/13 - this a queued location id only show that actual queued location when its queued not what it might be when it is eventually queued
				//  #26230 - want to show the position to be put on the truck i.e if first release cargo would be TRUCK(1) Road
				theLocation:=futureMove.getPrimaryLocation;
				
				//16Feb2023 navsp1 TFS 56543
				//Return only Terminal Area ID/Name if the configuration allows entire area in yard allocation".
				//Over-ridden by MTN-18897
				if futureMove.isMoveToFullGCArea then
					rtStr := theLocation.myTerminalArea.id;
					
				elseif theLocation &lt;&gt; null and theLocation.isKindOf(CM_VehicleController) and not self.isReceipt  then
					rtStr := self.getVehicleWLELocationID();
				else	
					rtStr := futureMove.getPrimaryLocationId();
				endif;
	   		endif;
			return rtStr;
		else
			//if no future move this means there is no cargo i.e. director task just return target locatin from self
			if self.allRTQueueEntries.size &gt; 0 and self.locationTarget &lt;&gt; null then
				return self.locationTarget;
			endif;
   		endif;
		return null;
	elseif _attrName = ETRow_ElapsedTime then
		if job &lt;&gt; null and job.isKindOf(CM_RoadJob) then
			if self.job.CM_RoadJob.myVehicleVisit &lt;&gt; null then
				return self.job.CM_RoadJob.myVehicleVisit.getElapsedTime.asStringJMT();		// PAR 16390
			endif;
		endif;

		return self.dwellTime.String;
	elseif _attrName = ETRow_ElapsedTimeArea then
		if job &lt;&gt; null and job.isKindOf(CM_RoadJob) then
			if self.job.CM_RoadJob.myVehicleVisit = null then
				return null;
			else
				return self.job.CM_RoadJob.myVehicleVisit.getElapsedMinsCurrentStage.String;
			endif;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_DoorDirection or 
		_attrName = ETRow_DoorsForward then
		//Door Direction is never stored on the TI so has to be done before the 
		// if ti &lt;&gt; null get info from the ti
		if self.myRequest &lt;&gt; null then 
			return self.myRequest.getDoorDirectionDescription(self.getTargetLocation(), self.myTrackedItem);
		endif;
		return null;
		
	elseif _attrName = ETRow_RfidTag then	//23 Apr 2012	NDL	Par 29417
		rfid := self.getMyRFIDTag;
		if rfid &lt;&gt; null then
			return rfid.code;
		else
			return null;
		endif;
		
	//jlgka1 TFS 46566 --&gt;	Code has been moved here because if there is a BOL then all other fields below will be bypass
	elseif _attrName = ETRow_MarkNumber then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.markNumber;
		elseif self.myRequest &lt;&gt; null and self.myRequest.isKindOf(CM_DeliveryRequest) then
			return self.myRequest.CM_DeliveryRequest.markNumber;
		else
			return null;
		endif;
	//jlgka1 TFS 46566 &lt;--	
	elseif self.myBOL &lt;&gt; null then
		bol := self.myBOL;
		if bol &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, bol, invalidObj);	// PAR #18735
			//and global.isValidObject(self.myBOL)  then
			rtStr := bol.getDisplayStringForAttribute(_attrName, _short);
		endif;
		return rtStr;
	elseif _attrName = ETRow_Train then // PAR 19710
		trainStr :=  self.getTrainString(); // PAR 20341
		return trainStr;
	elseif _attrName = ETRow_User then
		if self.myRequest &lt;&gt; null then
			return self.myRequest.userCode;
		endif;
		return null;
	elseif _attrName = ETRow_Quantity then
		//epr par 33221 3/3/14
		return self.getQuantity().asStringJMT;
		
	elseif _attrName = ETRow_TotalQuantity then
		//05 Mar 2014	NDL	Par 33596
		if self.myRequest &lt;&gt; null then
			if self.myRequest.isKindOf( CM_ReceivalRequest ) then
				return self.myRequest.getDisplayStringForAttribute(ETRow_TotalQuantity, _short);
			elseif self.myRequest.isKindOf(CM_DeliveryRequest) and self.isAnyAmount() and self.status &lt;&gt; WLE_COMPLETED then	// TFS 54118
				//return null;
				return app.getErrorString(AnyAmount);	// ### JIRA: MTN-33053 16Oct2024 NAVPW1
			endif;
		endif;
		//epr par 33221 3/3/14
		return self.getQuantity().asStringJMT;
	elseif _attrName = ETRow_MoveAmount then
		return self.getMoveAmountDisplay(true);
		
	elseif _attrName = ETRow_Bol then											//Start 22.5.2023 navhl20 #57714[57764]
		if self.myBOL &lt;&gt; null then 												//Start 19.09.2023 navlw1 #60382
			return self.myBOL.number;
		elseif self.myRequest &lt;&gt; null and self.myRequest.isKindOf(CM_WOReleaseCargoRequest) then
			if self.myRequest.CM_WOReleaseCargoRequest.myReserveDetail &lt;&gt; null and self.myRequest.CM_WOReleaseCargoRequest.myReserveDetail.myBOLIn &lt;&gt; null then
				bol := self.myRequest.CM_WOReleaseCargoRequest.myReserveDetail.myBOLIn;
				if bol &lt;&gt; null then
					return bol.number;
				endif;
			endif;
			return null;
		endif; 																	//End 19.09.2023 navlw1 #60382
		ti := self.getTi();														//06.6.2023 navhl20 #57762			
		if ti &lt;&gt; null then
			return ti.getReceivalBOLNumber();
		endif;
		return null;
	elseif _attrName = ETRow_Booking then
		ti := self.getTi();														//06.6.2023 navhl20 #57762						
		if ti &lt;&gt; null then
			return ti.getBookingReference();
		endif;
		return null;
	elseif _attrName = ETRow_CargoGroupId then												
		if self.myRequest &lt;&gt; null then 											//Start 18.09.2023 navlw1 #60382
			if self.myRequest.myReserveDetail &lt;&gt; null and self.myRequest.myReserveDetail.myCargoGroup &lt;&gt; null then
				return self.myRequest.myReserveDetail.myCargoGroup.id;
			endif;
		endif;																					//End 18.09.2023 navlw1 #60382
		ti := self.getTi();
		if ti &lt;&gt; null then
			return ti.getMyCargoGroupId();
		endif;
		return null;
	elseif _attrName = ETRow_Contact then
		return self.getEmailStrings();
	elseif _attrName = ETRow_IntRemarks then	
		ti := self.getTi();															//06.6.2023 navhl20 #57762						
		if ti &lt;&gt; null and ti.allBulkReleasesAssigned.isNotEmpty() then
			return ti.allBulkReleasesAssigned.first.remarksAdditional1;
		endif;
		return null;
	elseif _attrName = ETRow_LoadSequence then				
		return self.getLoadSequence();
	elseif _attrName = ETRow_Locations then	
		return self.getLocationId();												//18.10.2023 navhl20 #60931
	elseif _attrName = ETRow_PlannedLocation then
		ti := self.getTi();															//06.6.2023 navhl20 #57762							
		if ti &lt;&gt; null then
			return ti.getPlannedLocationDisplay();
		endif;
		return null;
	elseif _attrName = ETRow_ReleaseRequest then
		ti := self.getTi();															//06.6.2023 navhl20 #57762							
		if ti &lt;&gt; null and ti.allBulkReleasesAssigned.isNotEmpty() then
			return ti.allBulkReleasesAssigned.first.code;
		endif;
		if self.myRequest &lt;&gt; null and self.myRequest.myReserveDetail &lt;&gt; null then	//16.10.2023 navhl20 #60863
			return self.myRequest.myReserveDetail.myReserveHeader.code;
		endif;
		return null;
	elseif _attrName = ETRow_RequiredByDate then		
		if self.job &lt;&gt; null then
			return self.job.getRequiredByDT().asStringJMT;
		endif; 
		return null;
	elseif _attrName = ETRow_Instructions then
		return self.getInstruction();					//07.6.2023 navhl20 #58543
	elseif _attrName = ETRow_JobType then
		return self.getActivityType();					//End 22.5.2023 navhl20 #57714[57764]
		
	elseif (self.myTrackedItem &lt;&gt; null) and not(_attrName.isMeasurementType and self.weight &lt;&gt; null) then		//31.01.2025 navhl20 #33648
		//if _attrName = ETRow_WagonNumber then // CCMS 1067					//22.11.2023 navhl20 #61048
		if _attrName = ETRow_WagonNumber or _attrName = ETRow_Wagon then		//22.11.2023 navhl20 #61048
			// PAR #23794 if the TI is a TBA, get the wagon number from my location controller
			if self.myTrackedItem.isTBAorIsRRP and self.isYardReleaseAssigned then
				return self.CM_YardWLE.allLocationControllers.first.myWagon.id;
			endif;
			// PAR #23794 end
			
			wagonCntlr := self.getWagonController();
			
			// PAR 34417 if not planned look at where we are
			if  self.isReceipt and wagonCntlr = null then
				theLocation := self.myTrackedItem.allLocations.first;
				if theLocation &lt;&gt; null and theLocation.isWagon then						// 03/07/2014 cnwmh5 #34496
					wagonCntlr := theLocation.CM_WagonController;
				endif;
			endif;
			
			if wagonCntlr &lt;&gt; null then
				return wagonCntlr.myWagon.getDisplayStringForAttribute(ETRow_WagonNumber,_short);
			else
				theLocation := self.getLocationForMode(PLANNING_MODE);
				if theLocation &lt;&gt; null then
					if CM_WagonController.hasInstance(theLocation) then
						return theLocation.CM_WagonController.myWagon.id;
					endif;
				endif;
			
				return null;
			endif;
				
			
		else
			// PAR #26477 get release number from self if TI is a TBA
			if (_attrName = ETRow_ReleaseNumber or _attrName = ETRow_ReleaseNo) then
				if self.myTrackedItem.isTBAorIsRRP or self.isRailBreakBulkRelease then
					if self.myRequest &lt;&gt; null then
						return self.myRequest.getDisplayStringForAttribute(_attrName, _short);
					endif;
				elseif self.myTrackedItem.releaseRequest = null and self.myRequest &lt;&gt; null then		//13-Aug-2025 naviv1 #MTN-35710
					return self.myRequest.getDisplayStringForAttribute(_attrName,_short);
				endif;
			endif;
			// PAR #26477 end
			
			// PAR #27153 CCMS POL 2000 added Load Port and Load Voyage - these come from the WLE, not the TI
			if _attrName = ETRow_LoadPort then
				return self.getLoadPortForDisplay();
			elseif _attrName = ETRow_LoadVoyage then
				return self.getLoadVoyageForDisplay();
			// PAR #27153 CCMS POL 2000 end
			endif;
			
			if _attrName.isMeasurementType and self.isAnyAmount() and self.status &lt;&gt; WLE_COMPLETED then
				_attrName.getRowNameMeasureType(str, type);
				if str.isOneOf(ETRow_TotalWeight, ETRow_WeightTotal, ETRow_TotalVolume) then
					return null;
				endif;
			endif;
			
			return self.myTrackedItem.getDisplayStringForAttribute(_attrName, _short);
		endif;
	
	elseif _attrName = ETRow_DocketNumber then
		return null;		
	elseif _attrName = ETRow_ReleaseNumber or
		_attrName = ETRow_ReleaseNo or
		_attrName = ETRow_AvailabilityGradeCode or
		_attrName = ETRow_CargoTypeDescr or						
		_attrName = ETRow_Consignee or
		_attrName = ETRow_Commodity or		
		_attrName = ETRow_IsHazardous or
		_attrName = ETRow_IsOverDimensions or						
		_attrName = ETRow_DestinationPort or		
		_attrName = ETRow_DischargePort or				
		_attrName = ETRow_OperatorCode or			
		_attrName = ETRow_IsoGroup or	// 21/02/2010 	cnwcs5	par22193
		_attrName = ETRow_IsoType or
		_attrName = ETRow_CargoSubType then
		if self.myRequest &lt;&gt; null then 
			return self.myRequest.getDisplayStringForAttribute(_attrName, _short);
		endif;
		return null;
	elseif _attrName = ETRow_LocationId then
		return null;
	elseif _attrName = ETRow_Location then
		return null;
	elseif _attrName = ETRow_Id then //This is the TrackedItem ID and if we get here then TI is null
		if self.myRequest &lt;&gt; null then
			return self.myRequest.getDisplayStringForAttribute(ETRow_Id, _short);
		endif;
		return null;
	elseif _attrName = ETRow_HasStops then
		return null;
	elseif _attrName = ETRow_IsChilled then
		return null;		
	elseif _attrName = ETRow_AvailabilityGrade then
		return null;		
	elseif _attrName = ETRow_ImexStatus then		
		return null;
	elseif _attrName = ETRow_Inspected or
		_attrName = ETRow_ToBeInspected then									
		return null;
	elseif _attrName = ETRow_Temperature then		
		return null;				
	elseif _attrName = ETRow_IsConnected then		
		return null;
	elseif _attrName = ETRow_IsTranshipItem then		
		return null; // CCMS tranship: TI must be null
	//elseif _attrName = ETRow_WagonNumber then	//TI must be null			//22.11.2023 navhl20 #61048
	elseif _attrName = ETRow_WagonNumber or _attrName = ETRow_Wagon then	//22.11.2023 navhl20 #61048
		//21 Aug 2009	NDL	CCMS 1094
	//	if self.isYardReleaseAssigned then
	//		return self.CM_YardWLE.allLocationControllers.first.myWagon.id;
	//	else
	//		return null;
	//	endif;
		wagonCntlr := self.getWagonController();
		if wagonCntlr &lt;&gt; null then
			return wagonCntlr.myWagon.getDisplayStringForAttribute(ETRow_WagonNumber,_short);
		else
			return null;
		endif;
			
	elseif _attrName = ETRow_ReeferRemarks or //TI must be null

		_attrName = ETRow_CargoTypeDescr or				
	   _attrName = ETRow_RailRake then
	   return null;
	elseif _attrName = ETRow_OperatorCode or
	   _attrName = ETRow_MyOperator then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.myOperator.code;
		else
			if self.myRequest &lt;&gt; null then
				br := self.myRequest.myOriginatingBulkRelease;
				if br = null and self.myRequest.myReserveDetail &lt;&gt; null then		//18.01.2024 navhl20 #62066
					br := self.myRequest.myReserveDetail.myReserveHeader;
				endif;
				if br &lt;&gt; null and br.myOperator &lt;&gt; null then
					return br.myOperator.code;
				endif;
			endif;
			return null;
		endif;
	elseif _attrName = ETRow_SourceLocationId then
		return null;		
	elseif _attrName = ETRow_Specifications then
		return null;
	elseif _attrName = ETRow_VoyageCode then
		return null;		
	elseif _attrName = ETRow_WeightTotal or
		_attrName = ETRow_TotalWeight then
		return null;				
	elseif _attrName = ETRow_PriorLocation then
		return null;	
	elseif _attrName = ETRow_TargetLocation then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.locationId;
		elseif self.myRequest &lt;&gt; null and self.myRequest.isKindOf(CM_TIRequest) and self.myRequest.CM_TIRequest.trackedItem &lt;&gt; null then
			return self.myRequest.CM_TIRequest.trackedItem.locationId;
		endif;
		return null;
	elseif _attrName = ETRow_Source then //cnwrd1 par 22331 11.02.2010
		return null;
	elseif _attrName = ETRow_Target then//cnwrd1 par 22331 11.02.2010
		return null;
	elseif _attrName = ETRow_TranshipDischargePort then		//+cnwml2 PAR24791
		if self.myTrackedItem &lt;&gt; null then
			if self.myTrackedItem.isTranshipItem then
				if self.myTrackedItem.myTranshipDetail &lt;&gt; null and self.myTrackedItem.myTranshipDetail.myDischargePort &lt;&gt; null then
					return self.myTrackedItem.myTranshipDetail.myDischargePort.code;	
				endif;
			endif;
		endif;
		return null;
		
	// PAR #27153 CCMS POL 2000 added Load Port and Load Voyage
	elseif _attrName = ETRow_LoadPort then
		return self.getLoadPortForDisplay();
	elseif _attrName = ETRow_LoadVoyage then
		return self.getLoadVoyageForDisplay();
	// PAR #27153 CCMS POL 2000 end
	
	elseif _attrName = ETRow_DirectDelivery then
		return self.isDirectDelivery().getYes.asStringJMT;
	elseif _attrName = ETRow_Colour then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getColour;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_CargoSubType then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getCargoSubTypeDescr;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_Mark then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.mark;
		elseif self.myRequest &lt;&gt; null and self.myRequest.isKindOf(CM_DeliveryRequest) then
			return self.myRequest.CM_DeliveryRequest.mark;
		else
			return null;
		endif;	
	//30 May 2017	NDL	TFS 4587
	elseif _attrName = ETRow_AllTIHazards then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDisplayStringForAttribute( ETRow_AllTIHazards, _short );
		endif;
		return null;
	elseif _attrName = ETRow_Site then // TFS 45590
		return ""; // TFS 45590
	elseif _attrName = ETRow_State then // TFS 45590
		return ""; // TFS 45590
	elseif _attrName = ETRow_ImexStatusString then // TFS 45590
		return ""; // TFS 45590
	elseif _attrName = ETRow_Remarks then 
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.remarks;													//11.09.2024 navma1 #6577
		endif;
		return null;
	elseif _attrName = ETRow_IntendedReleaseMode then 
		if self.myTrackedItem &lt;&gt; null then
			return app.intendedReleaseModeEnum2String(self.myTrackedItem.intendedReleaseMode);	//11.09.2024 navma1 #65777
		endif;
		return null;
	elseif _attrName = ETRow_Booking then	//TFS 53013
		return null;						//TFS 53013
	elseif _attrName = ETRow_CarriageTempC then		//TFS 53016
		return null;								//TFS 53016
	//navtnr20 53204 start	
	elseif _attrName = ETRow_ShippingLineCode then				
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getShippingLineCode();		//11.09.2024 navma1 #65777
		endif;
		return null;
	elseif _attrName = ETRow_ShippingLineDesc then				
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getShippingLineDesc();		//11.09.2024 navma1 #65777
		endif;
		return null;
		//navtnr20 53204 END
		//start	19.08.2022 navtnr20 54441
	elseif _attrName = ETRow_CountryOfOriginCode then				
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getCountryOfOriginCode();		//11.09.2024 navma1 #65777
		endif;
		return null;
	elseif _attrName = ETRow_CountryOfOriginDesc then				
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getCountryOfOriginDesc();		//11.09.2024 navma1 #65777
		endif;
		return null;
		//end	19.08.2022 navtnr20 54441
	elseif _attrName = ETRow_TrailerID then
		//jlier1 TFS 54700 13/9/22
		if self.myTrackedItem &lt;&gt; null then	
			return  self.myTrackedItem.getCurrentTrailerID();
		endif;
		return null;
	elseif _attrName = ETRow_TrailerLocation then
		//jlier1 TFS 54700 13/9/22
		if self.myTrackedItem &lt;&gt; null then	
			return  self.myTrackedItem.getCurrentTrailerLocationID();
		endif;
		return null;
	elseif _attrName = ETRow_TrailerOperator then
		if self.myTrackedItem &lt;&gt; null then	
			return  self.myTrackedItem.getCurrentTrailerOperatorDisp();
		endif;
		return null;
	elseif _attrName = ETRow_CustomStatus then
		return self.getCustomStatus(); //27/09/2023	navkc1	CR 60428 Task 60701
	
	// MTN-36554 MTN | Cargo Type for Contents field missing on Prenote Enquiry and Road Operations screens
	elseif _attrName = ETRow_CargoTypeCodeForCntnt then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getCargoTypeCodeForContents();
		endif;
		return null;
		
	/*Always needs to be last if statment*/
	elseif _attrName.isMeasurementType then											// PAR #31155
		_attrName.getRowNameMeasureType(str, type);									// PAR #31155
		return self.getMeasurementStringForAttrib(str, type, _short);				// PAR #31155
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDoorDirDescrForSeqReport" id="04a27569-e666-40f5-96bc-d41fcfa4fd1b">
        <source>getDoorDirDescrForSeqReport() : String;
// ---------------------------------------------------------------------------
// Created:     31 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	
begin
	if self.myRequest &lt;&gt; null then
		return self.myRequest.getDoorDirectionDescription(self.getTargetLocation(), self.myTrackedItem); 
	endif;
	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEmailStrings" id="7990bf8d-9a0b-4b4a-9373-57836dd4969b">
        <source>getEmailStrings():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate

*/

vars

begin
	if self.job &lt;&gt; null and self.job.myWODtl &lt;&gt; null and self.job.myWODtl.getMyParent() &lt;&gt; null then
		return self.job.myWODtl.getMyParent().getEmailsString();
	endif;
	if self.job &lt;&gt; null and self.job.myWorkOrderDtlToDo &lt;&gt; null and self.job.myWorkOrderDtlToDo.getMyParent() &lt;&gt; null then
		return self.job.myWorkOrderDtlToDo.getMyParent().getEmailsString();
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="55d1cbb7-8e5a-4db0-b292-093b7239387f">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	block : CM_DataContainerBlock;

begin
	inheritMethod(_dataContainer);

	if self.myTrackedItem &lt;&gt; null then
		self.myTrackedItem.getExtraInfo(_dataContainer);
	endif;
	
	//epr par 33221 3/3/14
	if self.myRequest &lt;&gt; null then
		self.myRequest.getExtraInfo(_dataContainer);
	endif;
	
	if app.isSpecial() then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Load WLE", DC_Label, 1, self);
		block.addNewItem(self.String, DC_Data, 1, self);
	endif;
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFetchTime" id="831a90f4-f38f-48bf-b98e-28a87f86c2a4">
        <source>getFetchTime() : TimeStamp;
/*
Purpose:	OPSVIEW		

Date		Who		Reason
13 December 2021	navab1	TFS 51853
*/

vars
	qentry : CM_RTQueueEntry;
	qtask : CM_RTQueueTask;
	compTS : TimeStamp;
begin
	compTS := self.completedDate; // ### TFS 51855 24MAY2022 NAVAB1 get a valid value
	if not compTS.isValid() then // ### TFS 51855 24MAY2022 NAVAB1
		compTS := app.actualTimeAppServer(); // ### TFS 51855 24MAY2022 NAVAB1
	endif;
	
	qentry := self.allRTQueueEntries.first;
	
	if qentry = null then
		return compTS;  // ### TFS 51855 24MAY2022 NAVAB1 self.completedDate;  // ### TFS 51855 24JAN2022 NAVAB1
	endif;
	
	if qentry.areAllTasksEqualStatus(TASK_COMPLETE) then
		qtask := qentry.allTasks.first;
		if qtask &lt;&gt; null then
			if qtask.machineAssignedDT.isValid() then // ### TFS 51855 24MAY2022 NAVAB1
				return qtask.machineAssignedDT;
			endif;
		endif;
	endif;

	return compTS;  // ### TFS 51855 24MAY2022 NAVAB1 self.completedDate;  // ### TFS 51855 24JAN2022 NAVAB1
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getFinalTaskTargetLoc" id="645d53dd-d05a-48d5-87af-aead8e165257">
        <source>getFinalTaskTargetLoc(): CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2011	cnwer1	Initial creation

*/

vars
	lastRTEntry : CM_RTQueueEntry;
	setdownTask : CM_RTQueueTask;
begin
	if self.allRTQueueEntries.isEmpty then
		return null;
	endif;
	
	lastRTEntry:=self.allRTQueueEntries.last;
	
	
	setdownTask:=lastRTEntry.getDirectorOrSetDownTask();
	

	if setdownTask = null then
		return null;
	endif;
	
	return setdownTask.targetLocation;

epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getFinalTaskTargetLocId" id="362fbb5f-193d-4769-8154-5399b6f0b42e">
        <source>getFinalTaskTargetLocId() : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
10 August 2010		cnwer1	Initial creation 25392
01 November 2023	jlizm1	TFS 60985 MAFI queueing behaviour configuration

*/

vars
	lastRTEntry : CM_RTQueueEntry;
	setdownTask : CM_RTQueueTask;
begin
	if self.allRTQueueEntries.isEmpty then
		return null;
	endif;
	
	lastRTEntry:=self.allRTQueueEntries.last;
	
	setdownTask:=lastRTEntry.getDirectorOrSetDownTask(); //lastRTEntry.findTaskOfType(TASK_SETDOWN,NULL_INTEGER);
	if setdownTask = null then
		if lastRTEntry.isBreakBulkGenericMaster then
			setdownTask := lastRTEntry.findTaskOfType(TASK_BREAKBULK, NULL_INTEGER);
			if setdownTask = null then
				return null;
			endif;
		else
			return null;
		endif;
	endif;
	
	return setdownTask.targetLocationId;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstChild" id="1b98324d-6405-437c-b184-febe0ee39944">
        <source>getFirstChild():CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jul 2023 navma1 ChangeRequest 58849: EUP | Delivery Dispatch Screen - Unpack Operation

*/

vars
	child : CM_TrackedItem;
	ti 	  : CM_TrackedItem;
begin
	ti := self.getTi();
	
	if ti &lt;&gt; null and ti.hasChildren then
		child := ti.getFirstChild();
	endif;
	
	return child;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getFirstUncompleteRTEntry" id="222034d9-d05c-446b-b14f-89531ad90a5c">
        <source>getFirstUncompleteRTEntry() : CM_RTQueueEntry;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2011	cnwer1	Initial creation

*/

vars
	rtQueueEntry : CM_RTQueueEntry;
begin
	foreach rtQueueEntry in self.allRTQueueEntries discreteLock do
		if rtQueueEntry.status &lt;&gt; ENTRY_COMPLETE then
			return rtQueueEntry;
		endif;
	endforeach;

	return null;
epilog

end;</source>
        <ReturnType type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="getFullDescription" id="d89c456e-95d6-46cc-8c7e-b997a4eafbee">
        <source>getFullDescription() : String;
//--------------------------------------------------------------
//Created: 05 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tiId,
	str : String;
begin
	
	if self.myTrackedItem &lt;&gt; null then
		tiId := self.myTrackedItem.id;
	endif;
	
	//str := self.statusString &amp; ' ' &amp; self.getRequestTypeString() &amp; ' ' &amp; tiId &amp; ' ' &amp; self.typeString;
	//str := 'Status ' &amp; self.statusString &amp; ': ' &amp; self.getRequestTypeString() &amp; ' ' &amp; tiId &amp; ' ' &amp; self.typeString;
	str := self.getRequestTypeString() &amp; ' ' &amp; tiId &amp; ' ' &amp; self.typeString &amp; ', Status ' &amp; self.statusString;		
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInTargetOrOutSourceForRoad" id="0424ce6b-cc8a-4925-bf9c-91d143ae7272">
        <source>getInTargetOrOutSourceForRoad():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2017	jlgndl1	Initial creation	TFS 5312

*/

vars

begin

	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInstruction" id="ad53c840-c22e-40da-862a-51215ee6035b">
        <source>getInstruction():String;
/*

Purpose:	

Returns instruction type description in the following priority
trackedItem &gt; reserveDetail/BOLDetail/BookingItem &gt; bulkRelease/BOL/Booking &gt; WorkOrderDetail &gt;WorkOrder		

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2023	navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
16 Jun 2023 navhl20 Defect 58687: MTN - Job's Cargo details are not populating correctly on the Work Order Operations form
02 Dec 2024	navhl20 Bug MTN-33558: EUP | 53127 - Wrong Instructions shown in WO Ops Thin Client and Mobile Apps
06 Mar 2025	navah1	Bug 34283: EUP | Additional Operational Instructions - further issues
08 Apr 2025	navbs1	Bug MTN-34396: EUP | Additional Operational Instructions - more issues (part 2)
*/

vars
	instruction : CM_InstructionsIssued;
	trackedItem : CM_TrackedItem;
	woDtl 		: CM_WorkOrderDtl;
	relReq		: CM_BulkRelease;
	resDtl		: CM_ReserveDetail;
	book		: CM_BookingRef;
	bookDtl		: CM_BookingRefItem;
	bol			: CM_BOL;
	bolDtl		: CM_BOLDtl;
	workOrder	: CM_WorkOrder;
	woJob 		: CM_Job;
	woWle		: CM_WorkListEntry;
begin
	trackedItem := self.myTrackedItem;
	if trackedItem &lt;&gt; null then
		instruction := trackedItem.getInstructions();
	endif;
	if instruction &lt;&gt; null then	 
		//return instruction.internalInstructions; //10.03.2025 navah1 #34283
		return instruction.getInstructionDesc();   //10.03.2025 navah1 #34283
	endif;
	
	//reserveDetail/BOLDtl/BookingItem
	woDtl := self.job.myWODtl;											//14.04.2025 navbs1 #34396
	if woDtl = null  then
		woWle := self.myWorkOrderWLE;
		if woWle &lt;&gt; null then 
			woJob :=  self.myWorkOrderWLE.job;
		endif;
		if woJob &lt;&gt; null  then
			woDtl:= woJob.myWODtl;
		endif;
	endif;
	
	//08.04.2025 navbs1 #34396 START
	if woDtl &lt;&gt; null then									
		workOrder := woDtl.myParent;
		if woDtl.isKindOf(CM_WodRelease) then
			relReq := woDtl.CM_WodRelease.myReleaseRequest;
			resDtl := woDtl.CM_WodRelease.myReserveDetail;
			book	:= woDtl.CM_WodRelease.myBookingRef;
			bookDtl	:= woDtl.CM_WodRelease.myBookingRefItem;
		elseif woDtl.isKindOf(CM_WodReceive) then
			book := woDtl.CM_WodReceive.myBookingRef;
			bookDtl	:= woDtl.CM_WodReceive.myBookingRefItem;
			bol	:= woDtl.CM_WodReceive.myBillOfLading;
			bolDtl := woDtl.CM_WodReceive.myBillOfLadingDtl; 
		endif;
	endif;
	

		if resDtl &lt;&gt; null then
			instruction := resDtl.getInstructions();
			if instruction &lt;&gt; null then
				return instruction.getInstructionDesc(); 
			endif;
		endif;
		
		if bolDtl &lt;&gt; null then
			instruction := bolDtl.getInstructions();
			if instruction &lt;&gt; null then
				return instruction.getInstructionDesc();
			endif;
		endif;
		
		if bookDtl &lt;&gt; null then
			instruction := bookDtl.getInstructions();
			if instruction &lt;&gt; null then
				return instruction.getInstructionDesc();
			endif;
		endif;
		
		if relReq &lt;&gt; null then
			instruction := relReq.getInstructions();
			if instruction &lt;&gt; null then
				return instruction.getInstructionDesc();
			endif;
		endif;
		
		if bol &lt;&gt; null then
			instruction := bol.getInstructions();
			if instruction &lt;&gt; null then
				return instruction.getInstructionDesc();
			endif;
		endif;
		
		if book &lt;&gt; null then
			instruction := book.getInstructions();
			if instruction &lt;&gt; null then
				return instruction.getInstructionDesc();
			endif;
		endif;
		
		if woDtl &lt;&gt; null then								
			instruction := woDtl.getInstructions();
			if instruction &lt;&gt; null then
				return instruction.getInstructionDesc();
			endif;
		endif;
		
		if workOrder &lt;&gt; null then
			instruction := workOrder.getInstructions();
			if instruction &lt;&gt; null then
				return instruction.getInstructionDesc();
			endif;
		endif;
		//08.04.2025 navbs1 #34396 END
		
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvMoveSourceString" id="e950ce5b-70af-4436-9f5b-8552ccbb5e14">
        <source>getInvMoveSourceString() : String;
// ---------------------------------------------------------------------------
// Created:     May 2012 ANDREW BISHOP PAR 29570
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpFoundLC : CM_LocationsController;
	tmpFoundHeight : Integer;
	locationType	: Integer;
	ta : CM_TerminalArea;
	term : CM_Terminal;
	
begin

	term := self.getMyTerminal();
	
	term.findLocationFromString(self.locationSource, true, tmpFoundLC, tmpFoundHeight);
	if tmpFoundLC = null and
	   self.myTrackedItem &lt;&gt; null and
	   self.myTrackedItem.isOffSite then
		locationType := term.findLocationWhenOffsite(self.locationSource);
		if locationType = 1 then
			return GROSSAREA_RAIL;
		endif;
	endif;
	
	if tmpFoundLC &lt;&gt; null then
		if tmpFoundLC.isVoyageController() then
			return GROSSAREA_SHIP;
		elseif tmpFoundLC.isVehicle() then
			return GROSSAREA_ROAD;
		elseif tmpFoundLC.isWagon then	
			return GROSSAREA_RAIL;
		else
			ta := tmpFoundLC.getMyTerminalArea();
			if ta &lt;&gt; null then
				return ta.id;
			else
				return null;
			endif;
		endif;
	else
		if self.locationSource = GROSSAREA_NOWHERE or self.locationSource = "" then
			return GROSSAREA_NOWHERE;
		endif;
		return null;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvMoveTargetString" id="f9e568de-3f63-49a2-84ab-459534c106fd">
