    <JadeMethod name="resize" id="70f02018-5de7-4b50-9026-83fc2637ca4b">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;

/*
Date			Who		Reason
05 August 2016	cnwar2	Initial creation

*/
vars

begin
	if self.windowState = WindowState_Minimized then
		return;
	endif;

	inheritMethod();
	
	self.doResize();
