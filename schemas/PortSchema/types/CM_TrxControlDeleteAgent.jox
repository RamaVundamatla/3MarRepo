        <updating/>
        <source>trxDeleteKioskObject(_object : CM_KioskObject input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions
28 August 2023		jlizm1	TFS 59551 Kiosk Additional Question
*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	exclusiveLock(_object);
	
	_object.erase(NORMAL_ERASE);

epilog		
	self.finaliseActivityWithPassport(_passport);

end;</source>
