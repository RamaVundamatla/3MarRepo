    <JadeMethod name="doKeyMovement" id="5e871e2a-a0b1-4048-8c40-3267c7efc970">
        <updating/>
        <source>doKeyMovement(keyCode: Integer) updating;

constants
	WM_KEYUP   = #0101;
	WM_KEYDOWN = #0100;

	VK_RETURN  = #000D;
	VK_SHIFT   = #0010;  // shift key
	VK_CONTROL = #0011;  // control key
	VK_MENU    = #0012;  // alt key
	VK_SPACE   = #0020;
	VK_PRIOR   = #0021;
	VK_NEXT    = #0022;
	VK_END     = #0023;
	VK_HOME    = #0024;
	VK_LEFT    = #0025;
	VK_UP      = #0026;
	VK_RIGHT   = #0027;
	VK_DOWN    = #0028;
vars

begin
	if not bAlt then
		if inputType = InputType_TextBox or 
			inputType = InputType_TextNumeric then
			if keyCode = VK_END or
				keyCode = VK_HOME or
				keyCode = VK_LEFT or
				keyCode = VK_HOME or
				keyCode = VK_RIGHT or
				keyCode = VK_RETURN then
				return;
			endif;
		elseif inputType = InputType_ComboBox then
			if keyCode = VK_PRIOR or
				keyCode = VK_NEXT or
				keyCode = VK_UP or
				keyCode = VK_DOWN or
				keyCode = VK_RIGHT or
				keyCode = VK_RETURN then
				return;
			endif;
		endif;
 	endif;

	if keyCode = VK_SPACE then
		// do nothing
		moveToCurrentCell;
	elseif keyCode = VK_PRIOR then
		// pageUp
		row := nextPageRow(false);
		moveToCurrentCell;
	elseif keyCode = VK_NEXT then
		// pageDown
		row := nextPageRow(true);
		moveToCurrentCell;
	elseif keyCode = VK_END then
		// End
		row := rows;
		moveToCurrentCell;
	elseif keyCode = VK_HOME then
		// Home
		if rows &gt; fixedRows then
			row := fixedRows + 1;
		endif;
		moveToCurrentCell;
	elseif keyCode = VK_LEFT then
		// Left
		if column - 1 &gt; fixedColumns then
			column := column - 1;
		endif;
		moveToCurrentCell;
	elseif keyCode = VK_UP then
		// Up
		if row - 1 &gt; fixedRows then
			row := row - 1;
		endif;
		moveToCurrentCell;
	elseif keyCode = VK_RIGHT then
		// Right
		if column + 1 &lt;= columns then
			column := column + 1;
		endif;
		moveToCurrentCell;
	elseif keyCode = VK_RETURN or keyCode = VK_DOWN then
		// Down
		if row + 1 &lt;= rows then
			row := row + 1;
		endif;
		moveToCurrentCell;
	endif;

	if row &lt;&gt; prevRow or column &lt;&gt; prevColumn then
		rowColumnChg(self);
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doPrintTable" id="276f9d68-bb1f-4c64-9be0-d4f518ebaecf">
        <updating/>
        <source>doPrintTable(pFrame : Frame input; pLabel : Label input; pTitle : String) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lRow, lCol, idx, lLeft : Integer;
	lLine : String;
	lControl : Control;
	lNow : TimeStamp;
	lFontSize, lScale2, lWidth, lWidth2 : Real;
	lScale : Decimal[9,6];
	pxyJadeReport : JadeReport;
	gotToOutput : Boolean;
begin
	lNow := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	create pxyJadeReport transient;
	app.printer.printPreview := false;
	app.printer.setReport(pxyJadeReport);

	pFrame.width := 690;
	pFrame.height := 25;
	pFrame.top := 0;
	pFrame.left := 0;
	pFrame.visible := true;
	pFrame.backColor := White;
	pFrame.boundaryWidth := 0;

	pLabel.width := pFrame.width;
	pLabel.top := 0;
	pLabel.left := 0;
	pLabel.height := pFrame.height;
	pLabel.visible := true;
	pLabel.caption := lNow.String &amp; " " &amp; pTitle &amp; " " &amp; app.getMyUserCode;
	pLabel.fontBold := true;
	pLabel.backColor := White;
	pLabel.foreColor := Black;
	app.printer.print(pFrame);
	pLabel.caption := null;
	app.printer.print(pFrame);
	pLabel.visible := false;

	lLeft := 0;
	foreach lCol in 1 to self.columns do
		lLeft := lLeft + self.accessColumn(lCol).width;
	endforeach;
	if lLeft &lt;= pFrame.width then
		lFontSize := self.fontSize;
		lScale := 1;
	else
		lFontSize := self.fontSize;
		lScale := 1;
	endif;

	lLeft := 0;
	foreach lCol in 1 to self.columns do
		lControl :=  pLabel.getControl(lCol);
		if lControl = null then
			lControl := pLabel.loadControl(lCol);
		endif;
		lControl.width := self.accessColumn(lCol).width * lScale;
		lControl.left := lLeft;
		lLeft := lLeft + lControl.width.Integer;
		lControl.height := 20; //self.accessRow(1).height;
		lControl.top := 1;
		lControl.fontName := self.fontName;
		lControl.fontSize := lFontSize * lScale;
		lControl.visible := true;
		lControl.enabled := true;
		lControl.backColor := White;
		lControl.foreColor := Black;
	endforeach;

	foreach lRow in 1 to self.rows do
		lLine := null;
		foreach lCol in 1 to self.columns do
			lControl := pLabel.getControl(lCol);
			lControl.Label.caption := self.accessCell(lRow,lCol).text;
			if lRow &lt;= self.fixedRows then
				lControl.fontBold := true;
			else
				lControl.fontBold := false;
			endif;
		endforeach;
		app.printer.print(pFrame);
	endforeach;
	pFrame.visible := false;
	app.printer.close;
	gotToOutput := true;
	app.printPreview(pxyJadeReport, true);
epilog
	if gotToOutput = false then
		delete pxyJadeReport;
	endif;
end;</source>
        <Parameter name="pFrame" type="Frame" usage="input"/>
        <Parameter name="pLabel" type="Label" usage="input"/>
        <Parameter name="pTitle" type="String"/>
    </JadeMethod>
    <JadeMethod name="doResort" id="42b2fca7-2542-46d6-9e20-d7c7e69bf548">
        <updating/>
        <source>doResort() updating;

vars
	firstColumn:    Integer;
	secondColumn:   Integer;
	theRow:         Integer;
	theColumn:      Integer;
	str1:           String;
	str2:           String;
	useSelected:    Boolean;
	currentMP:      Integer;
begin
	currentMP := app.mousePointer;
	app.mousePointer := MousePointer_HourGlass;

	// attempt to maintain the current row properly.
	getRowIdColumns(firstColumn, secondColumn);
	if firstColumn &gt; 0 and firstColumn &lt; columns then
		str1 := getCellText(row, firstColumn);
		if secondColumn &gt; 0 and secondColumn &lt; columns then
			str2 := getCellText(row, secondColumn);
		endif;

		theColumn := fixedColumns + 1;
		while theColumn &lt;= columns do
			if getCellSelected(row, theColumn) then
				useSelected := true;
				break;
			endif;
			theColumn := theColumn + 1;
		endwhile;

		resort;

		// now locate the row
		if useSelected then
			theRow := fixedRows + 1;
			theColumn := 0;
			while selectedNext(theRow, theColumn) do
				if getCellText(theRow, firstColumn) = str1 then
					if str2 &lt;&gt; null then
						if getCellText(theRow, secondColumn) = str2 then
							row := theRow;
							break;
						endif;
					else
						row := theRow;
						break;
					endif;
				endif;
				theRow := theRow + 1;
				theColumn := 0;
			endwhile;
		else
			theRow := fixedRows + 1;
			while theRow &lt;= rows do
				if getCellText(theRow, firstColumn) = str1 then
					if str2 &lt;&gt; null then
						if getCellText(theRow, secondColumn) = str2 then
							row := theRow;
							break;
						endif;
					else
						row := theRow;
						break;
					endif;
				endif;
				theRow := theRow + 1;
			endwhile;
		endif;

	else
		resort;
	endif;

epilog
	app.mousePointer := currentMP;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="665f47a1-0a70-4e79-bb5a-5f5f5d0b04b3">
        <updating/>
        <source>doSearch( _searchStr : String; _columnNumber : Integer ) : Object updating;

/*

Purpose:		Pass in a search string, keystroke, and a column number and this will search for the
				first matching string. Then use that rows OBJECT to selct the row use self.registerFormKeys( null )
				in the gotFocus and lostFocus to allow key presses, and add the reference to this in the keyDown event.
				[This is a copy of the DoSearch from CM_DataTable by Andrew Bishop cnwab1]
	
Date				Who		Reason
22 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	theObject	: Object;
	startRow	: Integer;
	endRow		: Integer;
	tmpCol		: Integer;
	idx			: Integer;
	
begin
	tmpCol		:= _columnNumber;
	if tmpCol = 0 or tmpCol &gt; self.columns then
		tmpCol := 1;
	endif;
	startRow	:= self.fixedRows + 1;
	endRow 		:= self.rows;
	
	foreach idx in startRow to endRow do
		if self.accessCell( idx, tmpCol ).text.startsWith( _searchStr ) then
			self.clearAllSelected();
			theObject := self.accessRow( idx ).itemObject;
			self.selectObject( theObject, true );
			break;
		endif;
	endforeach;
	
	return theObject;
	
epilog
	
end;</source>
        <Parameter name="_searchStr" type="String"/>
        <Parameter name="_columnNumber" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="evaluateSelection" id="e85bf614-962a-4a95-8a86-79b3b0a40958">
        <updating/>
        <source>evaluateSelection(keyCode: Integer) updating;

constants
	VK_SPACE   = #0020;
	VK_PRIOR   = #0021;
	VK_NEXT    = #0022;
	VK_END     = #0023;
	VK_HOME    = #0024;
	VK_LEFT    = #0025;
	VK_UP      = #0026;
	VK_RIGHT   = #0027;
	VK_DOWN    = #0028;
vars
	wasSelected:  Boolean;
begin

	if explorerStyle then
		if row &gt; fixedRows then
			if bShift then
				clearAllSelected;
				selectCells(anchorRow, anchorColumn, row, column);
			elseif bControl then
				if not multiSelect then
					wasSelected := isInSelectedCells(row, column);
					clearAllSelected;
					if not wasSelected then
						// should be selected now
						toggleCell(row, column);
					endif;
				else
					// should the selection be toggled ?
					// only space and mouse cause a toggle, others do nothing
					if (keyCode = VK_SPACE) or (keyCode = 0) then
						toggleCell(row, column);
					endif;
				endif;
				//toggleCell(row, column);
				anchorRow := row;
				anchorColumn := column;
				if not readOnly then
					refreshSelection;
				endif;
			else
				clearAllSelected;
				selectCell(row, column);
				anchorRow := row;
				anchorColumn := column;
			endif;
		endif;
	endif;

	prevColumn := column;
	prevRow := row;

end;</source>
        <Parameter name="keyCode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findObjectInRow" id="f242bce9-a167-44df-9754-26a1e99044ef">
        <updating/>
        <source>findObjectInRow( _obj : Object; _rowIdx : Integer io ) : Boolean updating;
	
/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
22 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
							This is a copy of the method on CM_DataTable by cnwrs2.

*/
	
vars
	idx,
	startPos,
	numRows		: Integer;
	found		: Boolean;
	rowObj		: Object;
	
begin
	if _obj = null then
		return found;
	endif;
	
	numRows := self.rows;
	if _rowIdx &gt; numRows then
		return found;
	endif;
	
	startPos := (self.fixedRows + 1).max(_rowIdx);
	if startPos &gt; numRows then
		return found;
	endif;
	
	foreach idx in startPos to numRows do
		rowObj := self.accessRow(idx).itemObject;
		if rowObj = _obj then
			found 	:= true;
			_rowIdx := idx;
			break;
		endif;
	endforeach;
	
epilog
	return found;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="flushSortColumn" id="1667b326-fc5e-468a-a400-2b6db1433baf">
        <updating/>
        <source>flushSortColumn() updating;

vars

begin
	// cancel the sort column
	sortColumn[1] := 0;
	sortColumn[2] := 0;
	sortColumn[3] := 0;
	// reset the ascending flag
	sortAsc[1] := true;
	sortAsc[2] := true;
	sortAsc[3] := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="getMappedSortColumn" id="d6545df9-56e1-46c9-84f1-8153fdfc9a4e">
        <source>getMappedSortColumn(col: Integer): Integer;

vars
	value:   Integer;
begin
	if col &gt; 0 and col &lt;= columnSortMapping.size and columnSortMapping[col] &lt;&gt; 0 then
		value := columnSortMapping[col];
	else
		value := col;
	endif;

	return value;
end;</source>
        <Parameter name="col" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMouseAndKeyStatus" id="deda562b-8bfa-4cb9-91b4-beccbf2a2dc3">
        <updating/>
        <source>getMouseAndKeyStatus() updating;

constants
	VK_LBUTTON = #0001;  // left mouse button
	VK_RBUTTON = #0002;  // right mouse button
	VK_SHIFT   = #0010;  // shift key
	VK_CONTROL = #0011;  // control key
	VK_MENU    = #0012;  // alt key
	HIGH       = 2^15;
vars
	state:  Integer;
begin

	state := call getKeyState(VK_LBUTTON);
	bLMouse := state.bitAnd(HIGH) = HIGH;

	state := call getKeyState(VK_RBUTTON);
	bRMouse := state.bitAnd(HIGH) = HIGH;

	state := call getKeyState(VK_SHIFT);
	bShift := state.bitAnd(HIGH) = HIGH;

	state := call getKeyState(VK_CONTROL);
	bControl := state.bitAnd(HIGH) = HIGH;

	state := call getKeyState(VK_MENU);
	bAlt := state.bitAnd(HIGH) = HIGH;

end;</source>
    </JadeMethod>
    <JadeMethod name="getRowIdColumns" id="a736c85e-1496-46f0-b777-630209bf016d">
        <updating/>
        <source>getRowIdColumns(firstColumn: Integer output; secondColumn: Integer output) updating;

constants
	TWO_BYTE_SHIFT = 2^16;
vars

begin
	firstColumn := rowIdColumns mod TWO_BYTE_SHIFT;
	secondColumn := rowIdColumns div TWO_BYTE_SHIFT;
end;</source>
        <Parameter name="firstColumn" type="Integer" usage="output"/>
        <Parameter name="secondColumn" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="isInSelectedCells" id="ad20ff56-0afa-4954-be90-8cf1f35b645b">
        <updating/>
        <source>isInSelectedCells(r: Integer; c: Integer): Boolean updating;

constants
	TWO_BYTE_SHIFT = 2^16;
vars
	hashInt:   Integer;
begin
	if not readOnly then
		if selectRows then
			hashInt := r;
		else
			hashInt := c * TWO_BYTE_SHIFT + r;
		endif;

		return selectedCells.includes(hashInt);
	else
		if c &lt;= 0 then
			return getCellSelected(r, columns);
		else
			return getCellSelected(r, c);
		endif;
	endif;
end;</source>
        <Parameter name="r" type="Integer"/>
        <Parameter name="c" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyAndMouseStatus" id="e8db04a3-5309-4e90-b912-8fa457dca0d5">
        <updating/>
        <source>keyAndMouseStatus(shift: Integer; button: Integer) updating;

vars

begin
	bShift   := (shift mod 2 = 1);
	bControl := ( (shift div 2) mod 2 = 1 );
	bAlt     := (shift div 4 = 1);

	bLMouse  := (button = MouseButton_Left);
	bRMouse  := (button = MouseButton_Right);
end;</source>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="button" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="39c9d157-e987-4277-adb9-671efae5c5d7">
        <updating/>
        <source>keyDown(table : Table input; keyCode : Integer io; shift : Integer) updating;

constants
	WM_KEYUP   = #0101;
	WM_KEYDOWN = #0100;

	VK_RETURN  = #000D;
	VK_SHIFT   = #0010;  // shift key
	VK_CONTROL = #0011;  // control key
	VK_MENU    = #0012;  // alt key
	VK_SPACE   = #0020;
	VK_PRIOR   = #0021;
	VK_NEXT    = #0022;
	VK_END     = #0023;
	VK_HOME    = #0024;
	VK_LEFT    = #0025;
	VK_UP      = #0026;
	VK_RIGHT   = #0027;
	VK_DOWN    = #0028;
vars
	currentAccessMode:  Integer;
begin
	
	if explorerStyle then
		//doLateSelectionEvaluation := false;
		keyAndMouseStatus(shift, 0);

		// to see if this key down causes a cell change
		prevColumn := column;
		prevRow := row;

		if keyCode = VK_SPACE or
			keyCode = VK_PRIOR or
			keyCode = VK_NEXT or
			keyCode = VK_END or
			keyCode = VK_HOME or
			keyCode = VK_LEFT or
			keyCode = VK_UP or
			keyCode = VK_RIGHT or
			keyCode = VK_RETURN or
			keyCode = VK_DOWN then
			if readOnly then
				doKeyMovement(keyCode);
				evaluateSelection(keyCode);
			else
				causeEvent(Selection_Event, true, keyCode);
			endif;
		endif;
	endif;

	inheritMethod(table, keyCode, shift);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyUp" id="65de6b2d-30c5-485c-8a3f-8510c65f8110">
        <updating/>
        <source>keyUp(table : Table input; keyCode : Integer io; shift : Integer) updating;

constants
	WM_KEYDOWN = #0100;
	WM_KEYUP   = #0101;

	VK_SHIFT   = #0010;  // shift key
	VK_CONTROL = #0011;  // control key
	VK_MENU    = #0012;  // alt key
	VK_SPACE   = #0020;
	VK_PRIOR   = #0021;
	VK_NEXT    = #0022;
	VK_END     = #0023;
	VK_HOME    = #0024;
	VK_LEFT    = #0025;
	VK_UP      = #0026;
	VK_RIGHT   = #0027;
	VK_DOWN    = #0028;
vars

begin
	

epilog
	inheritMethod(table, keyCode, shift);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mapSortColumn" id="8cd82429-deed-4f23-9375-6640ffe440ad">
        <updating/>
        <source>mapSortColumn(fromColumn: Integer; toColumn: Integer) updating;

vars

begin
	columnSortMapping[fromColumn] := toColumn;
end;</source>
        <Parameter name="fromColumn" type="Integer"/>
