	elseif _attr.compareGeneric(HhShowUnplanOptions, true, false, null) = 0 then				// 8/9/17 MAP TFS6818
		return config.hhShowUnplanOptions.String;
	elseif _attr.compareGeneric(NoVoyTradeVal, true, false, null) = 0 then	//06 Jun 2018	NDL	TFS 38905
		return config.noVoyTradeVal.String;
	elseif _attr.compareGeneric(ShowOnlyDoorDirections, true, false, null) = 0 then	//06 Jun 2018	NDL	TFS 38905
		return config.showOnlyDoorDirections.String;
	elseif _attr.compareGeneric(TotDaysReqAddForCargo, true, false, null) = 0 then	//27 Aug 2018	NDL	TFS 40267
		return config.totDaysReqAddForCargo.String;
	elseif _attr.compareGeneric(TotDaysReqRoundedToHours, true, false, null) = 0 then	//27 Aug 2018	NDL	TFS 40267
		self.cmbRoundHrs.clear();
		self.cmbRoundHrs.itemData[ self.cmbRoundHrs.addItem("1") ] := 1;
		self.cmbRoundHrs.itemData[ self.cmbRoundHrs.addItem("2") ] := 2;
		self.cmbRoundHrs.itemData[ self.cmbRoundHrs.addItem("3") ] := 3;
		self.cmbRoundHrs.itemData[ self.cmbRoundHrs.addItem("4") ] := 4;
		self.cmbRoundHrs.itemData[ self.cmbRoundHrs.addItem("6") ] := 6;
		self.cmbRoundHrs.itemData[ self.cmbRoundHrs.addItem("8") ] := 8;
		self.cmbRoundHrs.itemData[ self.cmbRoundHrs.addItem("12") ] := 12;
		if config.totDaysReqRoundedToHours &gt; 0 then
			self.cmbRoundHrs.listIndex := self.cmbRoundHrs.findStringExact( 1, config.totDaysReqRoundedToHours.String );
		else
			self.cmbRoundHrs.listIndex := -1;
		endif;
		return self.cmbRoundHrs.text.String;
	elseif _attr.compareGeneric(ETRow_ShipCraneOpHrsSecRole, true, false, null) = 0 then					// TFS 44554
		self.myAssistant.comboBoxSecurityRoleTerminal(self.cmbCraneOpSR, config.shipCraneOpHrsSecRole);		// TFS 44554
		self.cmbCraneOpSR.addItem(null);																	// TFS 44554
		return config.shipCraneOpHrsSecRoleDesc;															// TFS 44554
	elseif _attr.compareGeneric(ETRow_MandatoryOneStevedore, true, false, null) = 0 then					// TFS 44554
		return config.mandatoryOneStevedore.String;															// TFS 44554
	elseif _attr.compareGeneric(DefaultTBAYardLocation, true, false, null) = 0 then
		return config.defaultTBAYardLocation.String;
	//TFS 46405 start
	elseif _attr.compareGeneric(ConsiderHazAsSpecialStow, true, false, null) = 0 then
		return config.considerHazAsSpecialStow.String;
	elseif _attr.compareGeneric(ConsiderODAsSpecialStow, true, false, null) = 0 then
		return config.considerODAsSpecialStow.String;
	//TFS 46405 end
	elseif _attr.compareGeneric(VoyageRetroDefault, true, false, null) = 0 then	//17 May 2021	NDL	TFS 51199
		return config.voyageRetroDefault.String;
	elseif _attr.compareGeneric(ETRow_ShipCutoffsForPrenotes, true, false, null) = 0 then // #JIRA-34230 navlw1 11/03/2025
		return config.shipCutoffsForPrenotes.String;
	elseif _attr.compareGeneric(ETRow_ShipCutoffsAutoAdjust, true, false, null) = 0 then // #JIRA-34523 navlw1 04/04/2025
		return config.shipCutoffsAutoAdjust.String;
	else
		if app.isDevelopmentSystem() then
			write "'" &amp; _attr &amp; "' needs to be implemented in " &amp; self.name &amp; "::" &amp; method.name &amp; " and " &amp; self.name &amp; "::doBaseFormSave";   //if for some reason some one has added a property to Ship Sequence and hasn't updated this method then will write this out.
		endif;
		return null;
	endif;
end;</source>
        <Parameter name="_attr" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYACriteriaTypeByDescription" id="48c69d1f-0ec8-4c79-a4c5-b6c3209bd6b9">
        <source>getYACriteriaTypeByDescription(_description : String) : CM_YACriteriaType;
// --------------------------------------------------------------------------------
// Created:		3 December 2009 by cnwjo3
//
// Purpose:		Returns the CM_YACriteriaType object from the _description.
//
vars
	ct : CM_YACriteriaType;
begin
	foreach ct in self.allYACriteriaTypesForVoyages do
		if ct.description = _description then
			return ct;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_description" type="String"/>
        <ReturnType type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="9444cf6a-96db-4223-bb16-0bb8bc9ca545">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//
//20 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
//
vars
	showCaptions : Boolean;
begin
	if self.frmToolbar.showCaptions then
		showCaptions := self.frmToolbar.showCaptions;
		self.frmToolbar.showCaptions := false;
		self.toolbarShowCaptions(showCaptions);
	endif;
	inheritMethod();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadEntTable" id="0398e45b-7c36-4a4e-a535-fd07b164183f">
        <updating/>
        <source>loadEntTable() updating;
// --------------------------------------------------------------------------------
// Created:		30 November 2009 by cnwjo3
//
// Purpose:		set up EntTable table used for Terminal Configuration
//
vars
	entTableDef		: EntTableDef;
	tableRowObj		: EntTableRow;
	displayValue	: String;
	constantValue	: String;
	row				: Integer;
	i 				: Integer;
	term			: CM_Terminal;
begin
	self.tblConfigTerm.clearValues();
	self.tblConfigTerm.clearAllSelected();

	entTableDef := app.myController.getEntTableDef(ETDef_ShipSettings);
	self.tblConfigTerm.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');  //this is where the magic happens

	//change to standard colours for table cells
	self.tblConfigTerm.backColor := self.backColor;
	self.tblConfigTerm.accessColumn(CM_EntryTable.ColumnHeading).backColor := self.colorHeadingColumn;
	self.tblConfigTerm.accessColumn(CM_EntryTable.ColumnValue).backColor 	:= self.colorValueColumn;	
	
	i := 1;
	row := 1;
	while row &lt;&gt; 0 do
		row := self.tblConfigTerm.getRowByName("zTableBreak" &amp; i.String);
		if row = 0 then
			continue;
		endif;
		self.tblConfigTerm.accessCell(row,1).fontBold := true;
		self.tblConfigTerm.accessCell(row,1).mergeCells := Table.MergeCells_Merge;
		self.tblConfigTerm.accessCell(row,2).backColor := self.colorHeadingColumn;
		i := i + 1;
	endwhile;
	
	//if user has cancelled an edit we delete the transient value so it can be created again from scratch	
	if self.cmif_ConfigTerminal &lt;&gt; null then
		delete self.cmif_ConfigTerminal;
	endif;
	
	//this automagically sets all the values of the CMIF_ConfigTerminal object
	create self.cmif_ConfigTerminal transient;
	self.cmif_ConfigTerminal.setFromPersistentData(self.myTerminal);
	
	//set the values in the table
	foreach tableRowObj in entTableDef.allEntTableRows do
		displayValue := self.getConfigTerminalProp(tableRowObj.name);
		self.tblConfigTerm.setValueByName(tableRowObj.name, displayValue);
		
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setEditViewMode" id="8e79b138-f24e-4ad0-af40-452191bd818a">
        <updating/>
        <source>setEditViewMode() updating;
// --------------------------------------------------------------------------------
// Created:		30 November 2009 by cnwjo3
//
// Purpose:		set the view mode for the current sheet to either edit or view only
//
vars
	entTableDef		: EntTableDef;
	tableRowObj		: EntTableRow;
	row				: Integer;
begin
	self.btnCancelBase.enabled := (self.mode=self.ModeEdit);
	self.btnSaveBase.enabled := (self.mode=self.ModeEdit);
	self.btnEdit.enabled := not (self.mode=self.ModeEdit);

	if self.currentSheet = shtConfigTerm then
		entTableDef := app.myController.getEntTableDef(ETDef_ShipSettings);
		foreach tableRowObj in entTableDef.allEntTableRows do
			row := tblConfigTerm.getRowByName(tableRowObj.name);
			if row &gt; 0 then
				tblConfigTerm.accessCell(row,2).enabled := (self.mode=self.ModeEdit);
			endif;
		endforeach;
	endif;
	
	self.mulYACriteria.enabled:= (self.mode=self.ModeEdit);
	self.cmbDefaultColour.enabled := (self.mode=self.ModeEdit);
	
	//need to do this on every sheet change at this point.....
	if (not app.getMyUser.canDo(self.myTerminal, PmVoyageConfigurationMaint)) then	
		self.btnEdit.enabled := false;
	endif;		
	
	//check that we are in edit mode // TFS 52235 2NOV2021 NAVLW1
	if (self.mode=self.ModeEdit) and self.selectedConfigRow &gt; 0 then // TFS 52235 2NOV2021 NAVLW1
		tblConfigTerm.accessRow(self.selectedConfigRow).selected := true; // TFS 52235 2NOV2021 NAVLW1
		tblConfigTerm.cnEcSetCellBackColor(self.selectedConfigRow, 1, LightRed); // TFS 52235 2NOV2021 NAVLW1
	elseif (self.mode=self.ModeEdit) and self.currentSelectedRow &gt; 0 then
		tblConfigTerm.accessRow(self.currentSelectedRow).selected := true; // TFS 52235 2NOV2021 NAVLW1
		tblConfigTerm.cnEcSetCellBackColor(self.currentSelectedRow, 1, LightRed); // TFS 52235 2NOV2021 NAVLW1
	endif;
	
	self.tblConfigTerm.refresh();  //we do a refresh here because Jades table operations are a little weird and allows for editing when its readonly
end;</source>
    </JadeMethod>
    <JadeMethod name="setupAllAvailableAndSelected" id="092a37b6-d86a-4c24-a08c-31ba0372277d">
        <updating/>
        <source>setupAllAvailableAndSelected() updating;
// --------------------------------------------------------------------------------
// Created:		2 December 2009 by cnwjo3
//
// Purpose:		Set up Available and Selected list boxes.  Use Strings at this time.  A little easier to work with
//
vars
	voyageConfig : CM_YAVoyageConfig;
	yaConfig : CM_YAConfig;
	ct : CM_YACriteriaType;
	o : Object;
begin
	self.allYACriteriaTypesForVoyages.clear();
	foreach o in app.myRoot.allYACriteriaTypes do
		if o.isKindOf(CM_YACriteriaType) then
			ct := o.CM_YACriteriaType;
			if ct.isVoyageAllocationCT then
				self.allYACriteriaTypesForVoyages.add(ct);
			endif;
		endif;
	endforeach;

	yaConfig := self.myTerminal.myYAConfig;
	if yaConfig = null then
		yaConfig := self.createYAConfig();
	endif;
	if self.myYAVoyageConfig = null then
		self.myYAVoyageConfig := yaConfig.allYAVoyageConfigs[TI_IMEX_STATUS_EXPORT].CM_YAVoyageConfig;
	endif;	
	
	if self.myYAVoyageConfig = null then	//cnwas3 ccms 1028 begin
		beginTransaction;
			create voyageConfig persistent;
			voyageConfig.setForCreate(yaConfig, TI_IMEX_STATUS_EXPORT, null);
		commitTransaction;	
		self.myYAVoyageConfig := yaConfig.allYAVoyageConfigs[TI_IMEX_STATUS_EXPORT].CM_YAVoyageConfig;		
	endif;									//cnwas3 ccms1028 end
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupCmbDefaultColour" id="4772c5ec-0ff5-481e-9fde-f81f5f78d48d">
        <source>setupCmbDefaultColour();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 May 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	selectedCriteria : ObjectArray;
	criteria : Object;
	indx : Integer;
	myText : String;
begin
	myText := self.cmbDefaultColour.text;
	self.cmbDefaultColour.clear();
	create selectedCriteria transient;
	self.mulYACriteria.getSelected(selectedCriteria);
	foreach criteria in selectedCriteria where criteria.CM_YACriteriaType.hasColourOption do
		self.cmbDefaultColour.addItem(criteria.CM_YACriteriaType.description);	
	endforeach;
	
	indx := self.cmbDefaultColour.findString(1,myText);

	if indx &gt; 0 then
		self.cmbDefaultColour.listIndex := indx;
	endif;
epilog
	delete selectedCriteria;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d88dbfdb-9f8a-44b3-b1f2-8b64eb869655">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		27 November 2009 by cnwjo3
//
// Purpose:		set up form.  NOTE:  Permissions should be reviewed at this point since we are mixing terminal config and voyage allocations in same form
//
//20 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
vars

begin
	//this form does not access multiple terminals so can set 'myTerminal'
	//just once.  app.getMyTerminal() losing cm_terminal reference after
	//edit.  cm_baseform::activate continues to reset passport myterminal!
	if self.myTerminal = null then
		self.myTerminal := app.getMyTerminalDO_NOT_USE();
	endif;
	self.expectedEdition := self.myTerminal.edition;

	self.createMyAssistant(CMUI_Assistant);	
	
	self.frmToolbar.visible := true;
	self.addToolbarControls();
	
	self.loadEntTable();  //load all values into the table
	
	self.caption := app.getString(Terminal);// &amp; " " &amp; self.myTerminal.code;
	self.setNavigatorHeading(self.caption);
	
	self.setupVoyageColorCodeSheet();
	//self.setupDefaultColourCombo(true);
	
	//using currentSheet so we can have extra tables for future use
	self.currentSheet := shtColorCoding;
	self.mode := self.ModeView;
	
	setEditViewMode();

	self.setFocus();
	
	self.minimumHeight := 400;
	self.minimumWidth := 400;

	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="setupVoyageColorCodeSheet" id="c69e5837-f7fc-4549-b6f1-322ccb5e5fc3">
        <updating/>
        <source>setupVoyageColorCodeSheet() updating;
// --------------------------------------------------------------------------------
// Created:		1 December 2009 by cnwjo3
//
// Purpose:		setup the two listboxes, their items, and the buttons between them
//
//20 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
vars
	selected : ObjectArray;
	ct : CM_YACriteriaType;
	indx : Integer;
begin
	self.doResize();
	
	self.setupAllAvailableAndSelected();
	self.mulYACriteria.caption:=null;
	self.mulYACriteria.setupControl("Criteria",self.allYACriteriaTypesForVoyages,SHP_VoyageConfiguration::displayYACriteria.name);
	self.mulYACriteria.myBaseForm:=self;
	self.frmYACriteria.visible:=true;
	self.mulYACriteria.visible:=true;
	self.mulYACriteria.multiSelect:=ListBox.MultiSelect_Extended;
	self.mulYACriteria.setVisibleButtons(true,true,true);
	self.mulYACriteria.mySelectedListBox.sorted:=false;
	create selected transient;
	if self.myYAVoyageConfig &lt;&gt; null then
		foreach ct in self.myYAVoyageConfig.allOpCriteria do
			selected.add(ct);
		endforeach;
	endif;
	self.mulYACriteria.setSelected(selected);
	self.setupCmbDefaultColour();
	if self.myYAVoyageConfig.myYACriteriaTypeForColour &lt;&gt; null then
		indx := self.cmbDefaultColour.findString(1,self.myYAVoyageConfig.myYACriteriaTypeForColour.description);
		if indx &gt; 0 then
			self.cmbDefaultColour.listIndex := indx;
		endif;
	endif;
	self.cmbDefaultColour.parent:=self.shtColorCoding;
	self.cmbDefaultColour.top:=self.mulYACriteria.clientHeight + 10;
	self.cmbDefaultColour.parentAspect:=Control.ParentAspect_AnchorBottom;
	self.lblDefaultColour.parent:=self.shtColorCoding;
	self.lblDefaultColour.top:=self.cmbDefaultColour.top;
	self.lblDefaultColour.parentAspect:=Control.ParentAspect_AnchorBottom;
epilog
	delete selected;
end;</source>
    </JadeMethod>
    <JadeMethod name="sheetChange" id="9dcc8e8c-8b0d-417d-aafd-972ad70ddb29">
        <updating/>
        <source>sheetChange(newSheet : CMUI_Sheet) : Boolean updating;
// --------------------------------------------------------------------------------
// Created:		30 November 2009 by cnwjo3
//
// Purpose:		deal with sheet change event
//
vars

begin
	//IF CAN DO (PERMISSIONS) THEN ENABLE/DISABLE EDIT BUTTON HERE


	if self.mode = self.ModeEdit then
		if app.msgBox(app.getErrorString(EditChangedAndClosing),'',MsgBox_Yes_No) = MB_YES then
			self.mode := self.ModeView;
			self.setEditViewMode();
			return true;
		else
			return false;
		endif;
	else
		self.currentSheet := newSheet.CMUI_Sheet;
		self.setEditViewMode();
	endif;
	
	return true;
end;</source>
        <Parameter name="newSheet" type="CMUI_Sheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="skipToAttribute" id="33fc54be-ecdd-4568-9a02-a8d271d2921e">
        <updating/>
        <source>skipToAttribute(_attributeName: String; _shtName: String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2012	cnwndl1	Initial creation

*/

vars

	index : Integer;
	control : Control;
	tmpSheet : CMUI_Sheet;
	folder : Folder;
	tbl : CM_EntryTable;
	entRow : EntTableRow;
	row : Integer;

begin

	foreach index in 1 to self.controlCount do
		control := self.controls(index);
		if control.isKindOf( CMUI_Sheet ) then
			tmpSheet := control.CMUI_Sheet;
		else
			continue;
		endif;
		if _shtName &lt;&gt; tmpSheet.caption then
			continue;
		endif;
		folder := tmpSheet.parent.Folder;
		folder.topSheet := tmpSheet;
		
		self.currentSheet := tmpSheet;
		self.setEditViewMode();	//06 May 2016	NDL	TFS 1960
		
		if _attributeName &lt;&gt; null then
			tbl := self.tblConfigTerm;
			entRow := tbl.myEntTableDef.getEntTableRowByHeading(_attributeName);
			if entRow &lt;&gt; null then
				row := tbl.myEntTableDef.allEntTableRows.indexOf(entRow);
				break;
			endif;
		endif;
		break;
		
	endforeach;
	
	if tbl &lt;&gt; null and  row &gt; tbl.fixedRows and row &lt;= tbl.rows then
		tbl.accessRow(row).selected := true;
		tbl.topRow := row;
		self.selectedConfigRow := row; // TFS 52235 2NOV2021 NAVLW1
	endif;

epilog

end;</source>
        <Parameter name="_attributeName" type="String"/>
        <Parameter name="_shtName" type="String"/>
    </JadeMethod>
