        <source>tblJobSheet_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Apr 2024 navhl20 ChangeRequest 63636: EUP | 53729 - Delivery Dispatch Screen - initial feedback

*/

vars
	job			: CM_Job;
begin
	if button &lt;&gt; 1 or (not app.dragDetected(x, y, self.origXPos, self.origYPos)) then
		return;
	endif;
	
	if button = Window.MouseButton_Left 
	and app.dragDetected(x, y, self.origXPos, self.origYPos) 
	and y &gt; 15 then
		self.dragMode := DragMode_Drag;
		self.dragCursor := self.picCtrlScroll.dragCursor;
		self.myDraggedTable := table.CM_DataTable;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
