    <JadeMethod name="addResourceType" id="0065bb16-a523-4bcc-8de7-6f2528d5c9b2">
        <source>addResourceType(_type:CM_ResourceType);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2010	#cnwdz2	 

*/

vars
	index : Integer;
begin
	index := self.cmbResourceType.addItem(_type.description);
	self.cmbResourceType.itemObject[index] := _type;
epilog

end;</source>
        <Parameter name="_type" type="CM_ResourceType"/>
