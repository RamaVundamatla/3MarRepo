    <JadeMethod name="isReleaseShip" id="3917006b-8041-4b0f-9373-ebccad1d310d">
        <source>isReleaseShip(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2024	navcs2	Initial creation

*/

vars

begin
