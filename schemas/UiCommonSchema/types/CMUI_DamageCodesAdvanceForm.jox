    <JadeMethod name="btnAdd_click" id="35517c58-5e06-418d-853f-129e7f7dfc25">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(btn: Button input) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		04 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 04/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
// 26 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
//----------------------------------------------------------------------
vars

begin
	self.addItem();
	self.isDamageChanged := true;	// 26.07.2022 navak20 TFS 53862
epilog
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNew_click" id="527b3f05-a5da-4f63-8054-a2050e75533b">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNew_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
27 September 2023	navcs2	ChangeRequest 60694: EUP | FR 54536 - Damage and Repair Thin Client UI changes
*/

vars
	result: Integer;
begin
	if 	app.msgBox('You will lose your changes to the current object if create a new one, do you want to continue?', 'Are you sure?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
		return;
	endif;
	
	self.clearItem();
	self.btnUpdate.enabled := false;
	self.btnRemove.enabled := false;
	self.btnAdd.enabled := true;		// 27/09/2023 navcs2 ChangeRequest 60694
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnRemove_click" id="972b8980-6211-4997-a9c4-6f20315542fd">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRemove_click(btn: Button input) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		13 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 13/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
// 26 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
// 27 September 2023	navcs2	ChangeRequest 60694: EUP | FR 54536 - Damage and Repair Thin Client UI changes
//----------------------------------------------------------------------
vars

begin
	self.removeItem();
	self.isDamageChanged := true;	// 26.07.2022 navak20 TFS 53862
	if self.tblDamage.rows = 1 then			// 27/09/2023 navcs2 ChangeRequest 60694
		self.btnAdd.enabled := true;		// 27/09/2023 navcs2 ChangeRequest 60694
	else									// 27/09/2023 navcs2 ChangeRequest 60694
		self.btnAdd.enabled := false;		// 27/09/2023 navcs2 ChangeRequest 60694
	endif;									// 27/09/2023 navcs2 ChangeRequest 60694
epilog
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnUpdate_click" id="fab2037e-15bc-4b84-b074-657d1591b6bd">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdate_click(btn: Button input) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		06 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 06/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
// 26 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
//----------------------------------------------------------------------
vars
begin
	self.doBtnUpdateClick();
	self.isDamageChanged := true;	// 26.07.2022 navak20 TFS 53862
epilog
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="clearItem" id="7b5e93c7-ebb6-46b0-a426-5bec5c2b69b3">
        <source>clearItem();
/*

Date		Who		Reason
29 April 2016	cnwer1	Initial creation TFS 1923 29/4/16
06 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
07 Nov 2022	navak20 Bug 55274: MTN - Damage Date/Time not showing current date/time as defaultr
*/

vars
	dateTime : TimeStamp;	// 07.11.2022 navak20 TFS 55274
	defaultSeverity : CM_DamageSeverity;
begin
	self.cmbDamage.listIndex := -1;
	self.cmbPosition.listIndex := -1;
	self.cmbSeverity.listIndex := -1;
	self.txtQuantity.text := 1.String;		// 02.08.2022 navak20 TFS 53862
	self.optYes.value:=true;
	
	self.txtDamageRemarks.text:=null;		// July 6, 2022 navak20 TFS 53862
	self.cmbStatus.listIndex := -1;			// July 6, 2022 navak20 TFS 53862
	self.cmbResponsible.listIndex := -1;	// July 6, 2022 navak20 TFS 53862
	self.cmbLocation.listIndex := -1;		// July 6, 2022 navak20 TFS 53862
	self.cmbDamageReason.listIndex := -1;	// July 6, 2022 navak20 TFS 53862
	//self.damageDate.text := null;				// July 6, 2022 navak20 TFS 53862	// 07.11.2022 navak20 TFS 55274
	self.damageTime.text := null;				// July 6, 2022 navak20 TFS 53862	// 07.11.2022 navak20 TFS 55274
	self.txtSize.text := null;					// July 6, 2022 navak20 TFS 53862
	self.enableDisableRepairField(false);		// 08.07.2022 navak20 TFS 53862
	
	//Start 07.11.2022 navak20 TFS 55274
	dateTime := self.systemToLocalTime(app.actualTimeServer);
	self.damageDate.setDate(dateTime.date());
	self.damageTime.setTime(dateTime.time());
	//End 07.11.2022 navak20 TFS 55274
	
	 // ### TFS BUG 58862 27JUN2023 NAVAB1
	defaultSeverity  := self.myTerminal.getConfig(DamageSeverityDefault).CM_DamageSeverity;
	if defaultSeverity &lt;&gt; null then
		self.cmbSeverity.listObject := defaultSeverity;
	endif;
	
	self.initForTesting();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbStatus_click" id="b5649a20-849b-47ba-8bd3-16e1cc5b407d">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbStatus_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if self.cmbStatus.text = app.damageStatusEnumToString(DamageStatusRepaired) then
		self.enableDisableRepairField(true);
	else
		self.enableDisableRepairField(false);
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDamageSize" id="dee16a9c-9c3d-469e-a5ff-8628a20da93c">
        <source>comboBoxDamageSize();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details

*/

vars
	measurementType : CM_MeasurementType;
begin
	self.txtSize.setup(Type_Length, self.backColor);
	self.txtSize.tabKey := J_key_Tab;

	if self.myTerminal.getConfig(DamageSizeDMType) &lt;&gt; null then
		measurementType := self.myTerminal.getConfig(DamageSizeDMType).CM_MeasurementType;	
	else
		measurementType := app.myRoot.getDefaultMeasurementForType(Type_Length);
	endif;
	
	// ### TFS BUG 58861 27JUN2023 NAVAB1
	self.txtSize.setMeasurementType(measurementType.measurementType);
	self.txtSize.setValues("0 " &amp; measurementType.shortName);
// ### TFS BUG 58861 27JUN2023 NAVAB1		self.txtSize.setValueDefault(measurementType.shortName);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="3b8dba1f-f3bb-4f17-a8f9-917072093e03">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwmd1	Initial creation
14/09/2016  cnwma1  TFS #2673:PAR38205 MSL - Damage details
30/09/2022	navkc1	ChangeRequest #54463: MTN - Subscription License, New Feature Support Phase 1
*/

vars

begin
	//self.permissionView  := PmAdmTIDamageView; //14/09/2016 TFS #2673:PAR38205 
	//self.permissionMaint := PmAdmTIDamageMaint; //14/09/2016 TFS #2673:PAR38205 
	
	self.permissionView  := PmAdmDamageCodeAdvancedView;	// navkc1	30/09/2022	#54463
	self.permissionMaint := PmAdmDamageCodeAdvancedMaint; 	// navkc1	30/09/2022	#54463
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySelectedItem" id="d9a2cb9f-fc93-4eb4-bdf0-00118282c1a5">
        <updating/>
        <source>displaySelectedItem() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		31 July 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 31/07/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//   						Display a selected item from the table and populate the controls on the form.
// 06 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
//----------------------------------------------------------------------
vars
	damageInstance : CM_DamageInstance;
	dsLevel : CM_DamageSeverity;	// 11.07.2022 navak20 TFS 53862
	sizeType : CM_MeasurementType;	// 06.07.2022 navak20 TFS 53862
begin
	if self.tblDamage.row &lt;= self.tblDamage.fixedRows then
		return;
	endif;
	
	damageInstance := self.tblDamage.accessRow(self.tblDamage.row).itemObject.CM_DamageInstance;
	if damageInstance = null then
		return;
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.frmControls.enabled:= false;
	endif;
	
	// 08.07.2022 navak20 TFS 53862
	if damageInstance.status = DamageStatusRepaired then
		self.enableDisableRepairField(true);
		self.cmbRepairedReason.listIndex := self.cmbRepairedReason.findObject(damageInstance.myRepairReason);
		self.txtRepairedRemarks.text := damageInstance.repairRemarks;
		self.repairedTime.setTime(damageInstance.repairedDateTime.time);
		self.repairedDate.setDate(damageInstance.repairedDateTime.date);
	else
		self.enableDisableRepairField(false);
	endif;
	// 08.07.2022 navak20 TFS 53862
	
	self.cmbDamage.listIndex := self.cmbDamage.findObject(damageInstance.myDamageDefinition);
	self.cmbPosition.listIndex := self.cmbPosition.findObject(damageInstance.myDamagePosition);
	self.txtQuantity.text := damageInstance.quantity.String;
	
	//Start 06.07.2022 navak20 TFS 53862
	self.cmbSeverity.listIndex := self.cmbSeverity.findObject(damageInstance.myDamageSeverity);				
	self.txtDamageRemarks.text := damageInstance.remarks;													
	self.cmbStatus.text := app.damageStatusEnumToString(damageInstance.status);								
	self.cmbResponsible.listIndex := self.cmbResponsible.findObject(damageInstance.myDamageParty);			
	self.cmbLocation.listIndex := self.cmbLocation.findObject(damageInstance.myDamagePlace);				
	self.cmbDamageReason.listIndex := self.cmbDamageReason.findObject(damageInstance.myDamageReason);	
	self.damageTime.setTime(damageInstance.damageDateTime.time());
	self.damageDate.setDate(damageInstance.damageDateTime.date());														

	if self.myTerminal.getConfig(DamageSizeDMType) &lt;&gt; null then
		sizeType := self.myTerminal.getConfig(DamageSizeDMType).CM_MeasurementType;	
	else
		sizeType := app.myRoot.getDefaultMeasurementForType(Type_Length);
	endif;
	self.txtSize.setValues(app.convertMeasurementForDisplay(sizeType.shortName, damageInstance.CM_DamageInstance.damageSize) &amp; Space &amp; sizeType.shortName);
	
	/*if damageInstance.severity &gt; 0 then
		self.cmbSeverity.listIndex := damageInstance.severity + 1;
	endif;*/
	//End 06.07.2022 navak20 TFS 53862
	self.setOptIsNewDamage(damageInstance);
	self.setSelectedItem(damageInstance);
	
	self.btnRemove.enabled := (self.mode = Mode_Add) or (self.mode = Mode_Update);
	self.btnUpdate.enabled := (self.mode = Mode_Add) or (self.mode = Mode_Update);
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUpdateClick" id="96275480-fa24-41e7-901a-71af242d3f59">
        <source>doBtnUpdateClick();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		13 October 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars
	str : String;
begin
	str := self.hasInfoEntered();
	if str &lt;&gt; null then
		app.msgBox(app.getErrorString1(RequiredFields, str),null , MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.updateItem();
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doCancel" id="4dc9d0a4-0f15-444b-b5bf-2cfee5fdaf56">
        <updating/>
        <source>doCancel() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		06 August 2009
//
// Implemented version: JMT 7.7.3
/* Changes

Date		Name	TFS#		Description
============================================================================
06/08/2009 	cnwsh3 	CCMS SFW1066 
					PAR20321 	Recording Damage Details Changes.
06/05/2019	jlgka1	44287		Damage Refactoring. Add a confirmation message
								that any unsaved entry will be lost.
============================================================================*/
vars
	invalidProcess 		: Boolean;
	withUnsavedChanges	: Boolean;
	damageInstance		: CM_DamageInstance;	//jlgka1 TFS 44287
	realObject			: Object;				//jlgka1 TFS 44287
begin
	on Exception do app.handleDeletedObject(exception, self.myParentForm, invalidProcess); // PAR 34997
	
	//jlgka1 TFS 44287 --&gt;
	foreach damageInstance in self.allProxyDamageInstances do		
		realObject := app.myProxyManager.getRealObject(damageInstance);
		if realObject = null then		
			withUnsavedChanges := true;
			break;
		endif;		
	endforeach;
	
	if withUnsavedChanges then
		if 	app.msgBox('You are currently editing an object that has not been saved. Do you want to abandon your changes?', 'Are you sure?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
			return;
		endif;
		
		foreach damageInstance in self.allProxyDamageInstances do
			realObject := app.myProxyManager.getRealObject(damageInstance);
			if realObject = null then	
				delete damageInstance;	
			endif;
		endforeach;
	endif;
	//jlgka1 TFS 44287 &lt;--
	
	if not self.isParentFormUpdate  and  self.myDamageInterface =  null then //epr par 31845 
		if self.myProxyMasterItem &lt;&gt; null then
			delete self.myProxyMasterItem;
		endif;
		self.allProxyDamageInstances.purge();
	endif;
	
	if self.myParentForm.isKindOf(CMUI_MasterGeneratorMaintForm) then
		self.myParentForm.CMUI_MasterGeneratorMaintForm.setIsDamageFormInitialised(true);
	elseif self.myParentForm.isKindOf(CMUI_MasterContainerMaintForm) then
		self.myParentForm.CMUI_MasterContainerMaintForm.setIsDamageFormInitialised(true);
	elseif self.myParentForm.isKindOf(CMUI_TIMasterMaintForm) then
		self.myParentForm.CMUI_TIMasterMaintForm.setIsDamageFormInitialised(true);
	endif;
		
	inheritMethod();

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuFormContextMenu" id="eb865bc8-ebd5-47a0-96be-8ca89d636f83">
        <updating/>
        <source>doMnuFormContextMenu(table : CM_DataTable input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 30 April 2019
TFS#		: 44287
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	isShowDataMenus		: Boolean;
	isDataValidRow		: Boolean;
	x1, y1				: Real;
begin
	if app.isAllowedToInspect() then
		self.mnuTblInspectObject.visible	:=	true;
	else
		self.mnuTblInspectObject.visible	:=	false;
	endif;

	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	table.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	self.popupMenu(mnuTblViewContext, x1.Integer, y1.Integer);
	return false;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="1addc96f-666b-4b62-a472-234c46cb5268">
        <updating/>
        <source>doOK() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		06 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 06/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
// 26 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
// 01/08/2023	navcs2	ChangeRequest 59569: EUP - Damage | Cargo Saving and Discrepancy order
// 05 Feb 2025	navnk30	JIRA 33887: MTN | Road Gate In Checks throws error for damage check that is Inappropriate.
//----------------------------------------------------------------------
vars

begin
	if CM_ContainerEnqForm.hasInstance(self.myParentForm)  then
		self.myParentForm.CM_ContainerEnqForm.setIsDamageChanged(self.isDamageChanged);	//26.07.2022 navsrk20 TFS53862
		self.doSaveTrackedItem();																		// 01/08/2023	navcs2	ChangeRequest 59569
		self.myParentForm.CM_ContainerEnqForm.openDiscrepanciesForm(self.newRepair);					// 01/08/2023	navcs2	ChangeRequest 59569
	elseif self.myRealMasterItem.isKindOf(CM_TrackedItem)  then //cwnrd1 par 29415 23.5.2012
		self.doSaveTrackedItemGeneric();		
	elseif self.myRealMasterItem.isKindOf(CM_Wagon) then
		self.doSaveWagon();
	elseif self.myRealMasterItem.isKindOf(CM_WagonMaster) then
		self.doSaveWagonMaster();
	elseif self.myRealMasterItem.isKindOf(CM_TIMaster) then
		self.doSaveTIMaster();
	elseif self.myParentForm.isKindOf(CMUI_CargoChecksForm) then		//05.02.2025 navnk30 JIRA 33887
		self.doSaveForCargoCheckForm();
	elseif self.myDamageInterface &lt;&gt; null then
		 //epr par 31845 
		self.doSaveIF_DamageDetails();	
	endif;
	self.isDamageChanged := false;	//26.07.2022 navsrk20 TFS53862
	inheritMethod();
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveForCargoCheckForm" id="69e45d34-3362-4ced-bd7c-10e6900ce66a">
        <source>doSaveForCargoCheckForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Feb 2025	navnk30	JIRA 33887: MTN | Road Gate In Checks throws error for damage check that is Inappropriate.

*/

vars
	pxyDamage		: CM_DamageInstance;
	pxyGTEEntity	: CMGTE_Entity;
begin
	pxyGTEEntity := self.myProxyMasterItem.CMGTE_Entity;
	foreach pxyDamage in pxyGTEEntity.allDamageInstancesByPos do
		if not self.allProxyDamageInstances.includes(pxyDamage) then
			pxyDamage.setMySubject(null);
		endif;
	endforeach;
	
	foreach pxyDamage in self.allProxyDamageInstances do
		pxyDamage.setMySubject(pxyGTEEntity);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveIF_DamageDetails" id="e4f4c175-f21b-49ba-92d9-119a298b821a">
        <source>doSaveIF_DamageDetails() protected;
/*

Date		Who		Reason
23 October 2013	cnwer1	Initial creation PAR 31845
*/

vars
	di : CM_DamageInstance;
	coll : CM_DamageInstanceByDmgePos;
	form : CMUI_RepairDetailsForm;
begin
	if self.myParentForm = null then
		return;
	endif;
	
	if self.myDamageInterface = null then
		return;
	endif;
	
	
	coll:=self.myParentForm.IF_DamageDetails.getDamageInstances;
	coll.clear;
	foreach di in self.allProxyDamageInstances do
		if not coll.includesObject(di) then
			coll.add(di);
		endif;
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveTIMaster" id="04cd833c-d8c4-467e-a55e-8673dc4b28b4">
        <updating/>
        <source>doSaveTIMaster() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		21 September 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars
	di : CM_DamageInstance;
	collection : CM_DamageInstanceByDmgePos;
	invalidProcess : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myParentForm, invalidProcess); // PAR 34997

	if self.myParentForm.isKindOf(CMUI_MasterContainerMaintForm) then
		collection := self.myParentForm.CMUI_MasterContainerMaintForm.allDamageInstancesByPos;
		self.myParentForm.CMUI_MasterContainerMaintForm.setIsDamageFormInitialised(true);
	elseif self.myParentForm.isKindOf(CMUI_MasterGeneratorMaintForm) then
		collection := self.myParentForm.CMUI_MasterGeneratorMaintForm.allDamageInstancesByPos;
		self.myParentForm.CMUI_MasterGeneratorMaintForm.setIsDamageFormInitialised(true);
	elseif self.myParentForm.isKindOf(CMUI_TIMasterMaintForm) then
		collection := self.myParentForm.CMUI_TIMasterMaintForm.allDamageInstancesByPos;
		self.myParentForm.CMUI_TIMasterMaintForm.setIsDamageFormInitialised(true);
	endif;
	
	foreach di in self.allProxyDamageInstances do
		if not collection.includesObject(di) then
			collection.add(di);
		endif;
	endforeach;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveTrackedItem" id="695c2249-9813-4f80-8d9d-db3f1bc50bf6">
        <updating/>
        <source>doSaveTrackedItem() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		18 September 2009
//
// Implemented version: JMT 7.7.3
/* Changes

Date		Name	TFS#	Description
============================================================================
14/05/2019	jlgka1	44287	JMT - Damage Refactoring. If all damage instancer	has been deleted, reset damaged flag to false.		
27/07/2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
17/07/2023	navcs2	Bug 59045: FR | 54536 EUP - Repair Data Processing Timing - Old Weights for Repair Messages	
02/08/2023	navcs2	ChangeRequest 59569: EUP - Damage | Cargo Saving and Discrepancy order	
04/08/2023	navcs2	ChangeRequest 59565: EUP - Damage | Discrepancy form fields overhaul	
30/08/2023  navma1	Bug 59976: EUP | FR 53489 - Damage Recording Extra Details - Repair Date			
============================================================================*/
vars
	pxyTI 		: CM_TrackedItem;
	di 			: CM_DamageInstance;
	theReturn 	: Integer;
	damageInstance : CM_DamageInstance;
	pxyCount,
	realCount	: Integer;
begin
	if self.isParentFormUpdate then
		self.myParentForm.CM_ContainerEnqForm.doShowDamageEntriesForCargoEnq(self.myProxyMasterItem.CM_TrackedItem);
		pxyTI := self.myProxyMasterItem.CM_TrackedItem;
		
		if pxyTI.amIDamaged = false then  // 17/07/23 navcs2 Bug 59045
			pxyTI.setDamaged(false);
			pxyTI.setDamagedDT(false);		//27.07.2022 navsrk20 TFS 53862 // 
		//Start 08.08.2022 navak20 TFS 53862
		else
			pxyTI.setDamaged(true);
			pxyTI.setDamagedDT(true);
		endif;	
		//End 08.08.2022 navak20 TFS 53862
	else
		pxyTI := self.myProxyMasterItem.CM_TrackedItem;
		
		// 04/08/2023 navcs2 ChangeRequest 59565 Start
		if pxyTI.amIDamaged = false then  
			pxyTI.setDamaged(false);
			pxyTI.setDamagedDT(false);		
		else
			pxyTI.setDamaged(true);
			pxyTI.setDamagedDT(true);
		endif;
		// 04/08/2023 navcs2 ChangeRequest 59565 End
		
		foreach di in self.allProxyDamageInstances do
			di.setMySubject(pxyTI);
		endforeach;
		
		// 01/08/2023	navcs2	ChangeRequest 59569 Changes Start
		foreach di in self.myProxyMasterItem.CM_TrackedItem.allDamageInstances do
			if di.status = DamageStatusRepaired then
				pxyCount += 1;
			endif;
		endforeach;
	
		foreach di in self.myParentForm.CM_ContainerEnqForm.myCurrentObject.CM_TrackedItem.allDamageInstances do
			if di.status = DamageStatusRepaired then
				realCount += 1;
			endif;
		endforeach;
	
		if pxyCount &gt; realCount then
			self.newRepair := true;
		endif;
		// 01/08/2023	navcs2	ChangeRequest 59569 Changes end
		
		while true do
			app.myTrxUA.trxUpdateTrackedItem(pxyTI, null, TI_UPDMODE_NORMAL, null, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				//global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
	endif;
	
epilog
	if self.mode = self.Mode_Update then
		if pxyTI &lt;&gt; null then	//30.08.2023 navma1 #59976
			delete pxyTI;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveTrackedItemGeneric" id="9a1d6849-3f5d-4624-892b-9d8155cd5393">
        <updating/>
        <source>doSaveTrackedItemGeneric() updating;

/*

Purpose: To update the damage on a tracked item i a generic way. We assume the form we are coming from is not in edit mode and we kill the proxy
//cwnrd1 par 29415 23.5.2012			

Parameters:			

Return Value:		


Date		Who		Reason
23 May 2012	cnwrd1	Initial creation

*/

vars
	pxyTI 		: CM_TrackedItem;
	di 			: CM_DamageInstance;
	theReturn 	: Integer;
begin

	pxyTI := self.myProxyMasterItem.CM_TrackedItem;
	
	foreach di in self.allProxyDamageInstances do
		di.setMySubject(pxyTI);
	endforeach;
	
	while true do
		app.myTrxUA.trxUpdateTrackedItem(pxyTI, null, TI_UPDMODE_NORMAL, null, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog
	delete self.myProxyMasterItem;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveWagon" id="a8b6f4a8-87a0-4104-af59-4f87636d67ac">
        <updating/>
        <source>doSaveWagon() updating;
// ---------------------------------------------------------------------------
// Created:     28 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyWagon : CM_Wagon;
	theReturn : Integer;
	di : CM_DamageInstance;
	wagonUpdateCtrl : CMIF_WagonUpdateController;	//03 Nov 2009	NDL	Par 21519
	objectArray : ObjectArray;
begin
	pxyWagon := app.createUpdateProxy(self.myRealMasterItem).CM_Wagon;
	
	foreach di in self.allProxyDamageInstances do
		di.setMySubject(pxyWagon);
	endforeach;
	
	//21 Oct 2009	NDL	Par 21457 - Handle deletion of damage on wagon.
	create objectArray transient;
	foreach di in pxyWagon.allDamageInstanceByPos do
		if not self.allProxyDamageInstances.includes(di) then
			//pxyWagon.allDamageInstanceByPos.removeIfPresent(di);
			delete di;  //cnwjo3 par 21463
			objectArray.add(di);
		endif;
	endforeach;
	
	//03 Nov 2009	NDL	Par 21519
	create wagonUpdateCtrl transient;
	wagonUpdateCtrl.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 50837
	self.setCmifFromWagonPxy(pxyWagon, wagonUpdateCtrl);
	
	while true do
		app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport);	//03 Nov 2009	NDL	Par 21519
		//app.myTrxUA.trxUpdateTrainWagon(pxyWagon, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;


epilog
	self.allProxyDamageInstances.purge;
	delete pxyWagon;
	delete wagonUpdateCtrl;
	if not objectArray.isEmpty then
		objectArray.purge();
	endif;
	delete objectArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveWagonMaster" id="29f12e19-53f8-4a4d-ba94-5caff1a06d77">
        <updating/>
        <source>doSaveWagonMaster() updating;
// ---------------------------------------------------------------------------
// Created:     28 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyWagon : CM_WagonMaster;
	theReturn : Integer;
	di : CM_DamageInstance;
	damage : CM_DamageInstance;
	objectArray : CM_ObjectArray;
begin
	pxyWagon := app.createUpdateProxy(self.myRealMasterItem).CM_WagonMaster;
	pxyWagon.setPropogateChanges(false);	//21 Oct 2009	NDL Par 20857
	
	foreach di in self.allProxyDamageInstances do
		di.setMySubject(pxyWagon);
	endforeach;
	
	//21 Oct 2009	NDL	Par 21457 - Handle deletion of damage on wagon master.
	create objectArray transient;
	foreach damage in pxyWagon.allDamageInstancesByPos do
		if not self.allProxyDamageInstances.includes(damage) then
			//pxyWagon.allDamageInstancesByPos.removeIfPresent(damage);
			delete damage;  //cnwjo3 par 21463
			objectArray.add(damage);
		endif;
	endforeach;
	
	while true do
		app.myTrxUA.trxUpdateWagonMaster(pxyWagon, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else  
			theReturn := app.showErrorWarningDialog(app.getErrorString(Wagon), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;


epilog
	self.allProxyDamageInstances.purge;
	if not objectArray.isEmpty then
		objectArray.purge();
	endif;
	delete objectArray;
	delete pxyWagon;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowPhotos" id="f0655f39-5785-4616-9ee8-b5181f52f6e7">
        <source>doShowPhotos();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Dec 2024 navlc30 JIRA 33478 Match functionality in the thin client for Damage Recording Improvement
08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
*/

vars
	photos : ObjectArray;
	menuAction : CMUI_MenuAction;	
begin

	if self.myRealMasterItem = null or (not self.myRealMasterItem.isKindOf(CM_TrackedItem)) then
		return;
	endif;
	create menuAction transient;
	menuAction.setMyForm(self);
	self.myAssistant.showPhotosForm(self.myRealMasterItem.CM_TrackedItem, null, null, null, photos, menuAction);		//08.08.2025 navhl20 #35650	
	
epilog
	delete menuAction;
end;</source>
    </JadeMethod>
    <JadeMethod name="enableDisableRepairField" id="74b20c6b-01f3-434c-8797-a068e86022fd">
        <source>enableDisableRepairField( _ifRepair : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jul 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
11 Aug 2023	navkc1	Bug 59686: EUP | Damage Repair Date
30 Aug 2023	navlc30 Bug 59976: EUP | FR 53489 - Damage Recording Extra Details - Repair Date
*/

vars
	dateTime : TimeStamp;
begin
	if _ifRepair then
		self.lblRepairReason.enabled     := true;
		self.lblRepairDateTime.enabled   := true;
		self.lblRepairedRemarks.enabled  := true;
		self.cmbRepairedReason.enabled   := true;
		self.repairedDate.enabled 		 := true;
		self.repairedTime.enabled 		 := true;
		self.txtRepairedRemarks.enabled  := true;
		
		//self.repairedDate.setDate(date); //11/08/2023	navkc1	Bug 59686		//30.8.2023 navlc30 #59976
		//self.repairedTime.setTime(time); //11/08/2023	navkc1	Bug 59686		//30.8.2023 navlc30 #59976
		dateTime := self.systemToLocalTime(app.actualTimeServer);				//30.8.2023 navlc30 #59976
		self.repairedDate.setDate(dateTime.date());								//30.8.2023 navlc30 #59976
		self.repairedTime.setTime(dateTime.time());								//30.8.2023 navlc30 #59976
		
		if self.mode = Mode_View then
			self.txtRepairedRemarks.enabled := false;
			self.cmbRepairedReason.enabled  := false;
			self.repairedDate.enabled       := false;
			self.repairedTime.enabled       := false;
		endif;
	else
		self.lblRepairReason.enabled     := false;
		self.lblRepairDateTime.enabled   := false;
		self.lblRepairedRemarks.enabled  := false;
		self.cmbRepairedReason.enabled   := false;
		self.repairedDate.enabled 		 := false;
		self.repairedTime.enabled 		 := false;
		self.txtRepairedRemarks.enabled  := false;
		self.cmbRepairedReason.listIndex := -1;		
		self.repairedDate.text 			 := null;				
		self.repairedTime.text 			 := null;				
		self.txtRepairedRemarks.text 	 := null;		
	endif;
epilog

end;</source>
        <Parameter name="_ifRepair" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getItemForDisplay" id="4dc4c989-599f-48f6-b832-fd1e9758e9cf">
        <source>getItemForDisplay() : CM_Object;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		21 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 21/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars

begin
	if self.myProxyMasterItem &lt;&gt; null then
		return self.myProxyMasterItem;
	else
		return self.myRealMasterItem;
	endif;
epilog
end;</source>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="hasInfoEntered" id="968fe0e0-4915-4800-b90e-c72c486b2bc7">
        <source>hasInfoEntered() : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		13 August 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 13/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
// 12 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
// 13 Nov 2022	navak20 Bug 55274: MTN - Damage Date/Time not showing current date/time as defaultr
//----------------------------------------------------------------------
vars
	str 						: String;
	damageDT 					: TimeStamp;	// 13.11.2022 navak20 TFS 55274
	damageDetailsOptional 		: Boolean;
	myTerminal 					: CM_Terminal;
begin

	myTerminal := self.myTerminal;
	damageDetailsOptional := myTerminal.getConfig(DamageDetailsOptional).Boolean;
	
	if self.cmbDamage.listObject = null then 
		str := app.getErrorString(DamageCode);
	endif;
	
	if self.cmbPosition.listObject = null then
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp;  app.getErrorString(DamagePosition);//'Damage Position';
	endif;

	// 12.07.2022 navak20 TFS 53862
	if not myTerminal.getConfig(DamageSeverityOptional).Boolean then
		if self.cmbSeverity.listIndex = -1 and self.getMyTerminal.allDamageSeverities.isNotEmpty then
			if str &lt;&gt; null then
				str := str &amp; ', ';
			endif;
			str := str &amp; app.getErrorString(Severity);	//'Severity';
		endif; 
	endif;
	
	//quantity won't be visible for bulk cargo
	if self.txtQuantity.visible and self.txtQuantity.text.Integer &lt;= null then //PAR20902 cnwsh3 
		if str &lt;&gt; null then
			str := str &amp; ', ';
		endif;
		str := str &amp; app.getErrorString(CM_Quantity);
	endif;
	
	// 12.07.2022 navak20 TFS 53862
	if not damageDetailsOptional then
		if self.cmbResponsible.listIndex = -1 and self.getMyTerminal.allDamageParties.isNotEmpty then
			if str &lt;&gt; null then
				str := str &amp; ',';
			endif;
			str := str &amp; app.getErrorString(Responsible_party);
		endif;
		if self.cmbLocation.listIndex = -1 and self.getMyTerminal.allDamagePlaces.isNotEmpty then
			if str &lt;&gt; null then
				str := str &amp; ',';
			endif;
			str := str &amp; app.getErrorString(Location);
		endif;
		if self.cmbDamageReason.listIndex = -1 and self.getMyTerminal.allDamageReasons.isNotEmpty then
			if str &lt;&gt; null then
				str := str &amp; ',';
			endif;
			str := str &amp; app.getErrorString(Damage_reason);
		endif;
	endif;
	
	//Start 13.11.2022 navak20 TFS 55274
	damageDT.setDate(self.damageDate.getDate());
	damageDT.setTime(self.damageTime.getTime());
	if damageDT = null then
		str := str &amp; app.getErrorString(Damage_date_time);
	elseif damageDT &gt; self.systemToLocalTime(app.actualTimeServer) then
		str := str &amp; app.getErrorString(Damage_date_time_future);
	elseif damageDT &lt; self.systemToLocalTime(app.actualTimeServer).subtractYears(10) then
		str := str &amp; app.getErrorString(Damage_date_time_past);
	endif;
	//End 13.11.2022 navak20 TFS 55274
	
	return str;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initCombos" id="dfd1d521-d4b3-4a84-b622-ad4eed631e4a">
        <source>initCombos();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 28 April 2009
//
// Implemented version: 7.7.3
// CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
// 06 July 2022 navak20 TFS 53862 EUP - WMS - Damage Recording Extra Details
//----------------------------------------------------------------------
vars
	object : Object;
	interface : IF_DamageDetails;
	defaultSeverity : CM_DamageSeverity;
begin
	object := self.getItemForDisplay();
	if object &lt;&gt; null then
		interface:=object.IF_DamageDetails;
	else
		//epr par 31845 24/10/13
		interface:=self.myDamageInterface;
	endif;	
	
	self.myAssistant.comboBoxDamageCodes(self.cmbDamage, interface);
	self.myAssistant.comboBoxDamagePositons(self.cmbPosition, interface);
	self.myAssistant.comboBoxDamageSeverity( self.cmbSeverity);
	self.myAssistant.comboBoxDamageParty(self.cmbResponsible);			// July 6, 202 navak20 TFS 53862
	self.myAssistant.comboBoxDamagePlace(self.cmbLocation);				// July 6, 202 navak20 TFS 53862
	self.myAssistant.comboBoxDamageReason(self.cmbDamageReason);		// July 6, 202 navak20 TFS 53862
	self.myAssistant.comboBoxRepairedReason(self.cmbRepairedReason);	// July 6, 202 navak20 TFS 53862
	self.myAssistant.comboBoxDamageStatus(self.cmbStatus);				// July 6, 202 navak20 TFS 53862
	self.comboBoxDamageSize();											// July 6, 202 navak20 TFS 53862
	self.initForTesting();

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="initDamageTable" id="d43368d9-8c78-4305-8bed-5048cd7335fa">
        <source>initDamageTable();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 28 April 2009
//
// Implemented version: 7.7.3
// 
// CCMS SFW1066  - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	tbl : CM_DataTable;
	row : EntTableRow;
	entDef : EntTableDef;
	
begin
	tbl := self.tblDamage;
	tbl.selectionType := CM_BaseTable.SelectionType_Row;
	tbl.myDataClass := CM_DamageInstance;
	tbl.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_DamageCodesDataTable));
	
	tbl.userInputEnabled := (self.mode = Mode_Add) or (self.mode = Mode_Update);
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="initForTesting" id="c9edba50-2ba0-4004-ac3e-f010b5cc3d3a">
        <source>initForTesting();
/*
Purpose:			

Date		Who		Reason
28 June 2023	navab1
