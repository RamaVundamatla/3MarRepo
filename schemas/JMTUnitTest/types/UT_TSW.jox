    <JadeMethod name="zGetEdiStatus" id="59c06894-3032-4871-b753-019b4f27c44b">
        <source>zGetEdiStatus(_ediStatus : Integer) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2023	navpw1	Initial creation TFS: 61364 (61375)

*/

vars
	ediControllerStatus : CM_EDIControllerAgent;
	
begin
	create ediControllerStatus transient;
	return ediControllerStatus.displayStatus(_ediStatus);
	
epilog
	delete ediControllerStatus;
	
end;</source>
