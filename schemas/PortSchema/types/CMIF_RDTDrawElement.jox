    <JadeMethod name="drawWellEnd" id="97221631-ceee-44e5-99f5-d16e8fb370fc">
        <source>drawWellEnd( _frame : Frame input; _x1, _y1, _x2, _y2 : Real; _scaleFactor : Real; _isLandscape: Boolean; _flipH: Boolean; _flipV: Boolean; _drawMode : Integer; _wellId : String ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2014	cnwndl1	Initial creation

*/

vars

	x1, y1,
	x2, y2			: Real;
	xOffset : Real;
	yOffset : Real;
	wagonHeightPixels : Real;
	points : RealArray;
	
begin

	_frame.drawFontBold := true;
	
	if _drawMode = CMIF_RDTDrawElement.MODE_FACE then
	
		wagonHeightPixels := self.getSizeInPixels(2, _scaleFactor);
		
		yOffset := _y2 - _y1;
		xOffset := _x2 - _x1;
		x1 := _x1;
		x2 := _x2;
		y1 := _y1;
		y2 := _y2;

		//draw separation between wells on frames
		_frame.drawWidth := 2;
		if _flipH then
			_frame.drawLine( x1, y1, x1, y1 + wagonHeightPixels, Black );
			_frame.drawTextAt( _wellId, x1 + 10,  y1, Black );
			x1 := _x1 - xOffset;
			x2 := _x2 - xOffset;
		else
			_frame.drawLine( x2, y1, x2, y1 + wagonHeightPixels, Black );
			_frame.drawTextAt( _wellId, x2 - 18,  y1, Black );
		endif;
		
		// draw pre end of well wheels
		self.drawWheels( x1, y1, x2, y2, _frame, _scaleFactor, 0 );

		
	elseif _drawMode = CMIF_RDTDrawElement.MODE_TOPDOWN then
	
	
		_frame.drawFillColor := Black;
		
		wagonHeightPixels := self.getSizeInPixels(2, _scaleFactor) / 2;  //thickness of the blue border...
			
		yOffset := _y2 - _y1;
		xOffset := _x2 - _x1;
		
		x1 := _x1;
		x2 := _x2;
		y1 := _y1 + wagonHeightPixels;
		y2 := _y2 - wagonHeightPixels;

		//draw separation between wells on frames
		create points transient;
		_frame.drawWidth := 2;
		
		if _flipH then
			x1 := _x1 - xOffset;
			x2 := _x2 - xOffset;
		endif;
		
		
		if _isLandscape then
			if _flipH then
				_frame.drawTextAt( _wellId, x2 + 10, _y2, Black );
			else
				_frame.drawTextAt( _wellId, x2 - 18, _y2, Black );
			endif;
		endif;
		
		if _isLandscape then
			// triangle below cargo
			points.add( x2 );  points.add( y2 );
			points.add( x2 - ( wagonHeightPixels / 2 ) );  points.add( y2 + wagonHeightPixels );
			points.add( x2 + ( wagonHeightPixels / 2 ) );  points.add( y2 + wagonHeightPixels );
			
			_frame.drawFilledPolygon( points, Black );
			
			// triangle above cargo
			points.clear();
			
			points.add( x2 );  points.add( y1 );
			points.add( x2 - ( wagonHeightPixels / 2 ) );  points.add( y1 - wagonHeightPixels );
			points.add( x2 + ( wagonHeightPixels / 2 ) );  points.add( y1 - wagonHeightPixels );
			
			_frame.drawFilledPolygon( points, Black );
		endif;
		
		_frame.drawFillColor := Gray;
		
	endif;
		
epilog

	delete points;

end;
</source>
        <access>protected</access>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandscape" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
        <Parameter name="_drawMode" type="Integer"/>
        <Parameter name="_wellId" type="String"/>
    </JadeMethod>
    <JadeMethod name="drawWellStart" id="aafb825d-ac0d-49f0-b097-c72da23c7020">
        <source>drawWellStart( _frame : Frame input; _x1, _y1, _x2, _y2 : Real; _scaleFactor : Real; _isLandscape: Boolean; _flipH: Boolean; _flipV: Boolean; _drawMode : Integer; _wellId : String ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2014	cnwndl1	Initial creation

*/

vars

	x1, y1,
	x2, y2			: Real;
	xOffset : Real;
	yOffset : Real;
	wagonHeightPixels : Real;
	points : RealArray;
	wagonWidth : Real;
	
begin

	_frame.drawFontBold := true;

	if _drawMode = CMIF_RDTDrawElement.MODE_FACE then
	
		wagonHeightPixels := self.getSizeInPixels(2, _scaleFactor);
		x1 := _x1;
		x2 := _x2;
		xOffset := _x2 - _x1;

		//draw separation between wells on frames
		_frame.drawWidth := 2;
		if _flipH then
			_frame.drawLine( x2, _y1, x2, _y1 + wagonHeightPixels, Black );	
			
			// Draw next well first set of wheels
			self.drawWheels( x2, _y1, x2 + xOffset, _y2, _frame, _scaleFactor, 0 );
			_frame.drawTextAt( _wellId, x2 - 18,  _y1, Black );
			
		else
			_frame.drawLine( x1, _y1, x1, _y1 + wagonHeightPixels, Black );
			
			// Draw next well first set of wheels
			self.drawWheels( x1, _y1, x2, _y2, _frame, _scaleFactor, 0 );
			_frame.drawTextAt( _wellId, x1 + 10,  _y1, Black );
			
		endif;
		
	elseif _drawMode = CMIF_RDTDrawElement.MODE_TOPDOWN then
		
		_frame.drawFillColor := Black;
		wagonHeightPixels := self.getSizeInPixels(2, _scaleFactor) / 2;  //thickness of the blue border...	
		yOffset := _y2 - _y1;
		xOffset := _x2 - _x1;
		
		x1 := _x1;
		x2 := _x2;
		y1 := _y1 + wagonHeightPixels;
		y2 := _y2 - wagonHeightPixels;
		
		if _flipH then
			x1 := _x1 + xOffset;
			x2 := _x2 + xOffset;
		endif;
		
		if _isLandscape then
			if _flipH then
				_frame.drawTextAt( _wellId, x1 - 18, _y2, Black );
			else
				_frame.drawTextAt( _wellId, x1 + 10, _y2, Black );
			endif;
		endif;
		
		//draw separation between wells on frames
		create points transient;
		_frame.drawWidth := 2;
		
		
		if _isLandscape then
			// triangle below cargo at well end
			points.add( x1 );  points.add( y2 );
			points.add( x1 - ( wagonHeightPixels / 2 ) );  points.add( y2 + wagonHeightPixels );
			points.add( x1 + ( wagonHeightPixels / 2 ) );  points.add( y2 + wagonHeightPixels );

			_frame.drawFilledPolygon( points, Black );
			
			// triangle above cargo at well end
			points.clear();
			
			points.add( x1 );  points.add( y1 );
			points.add( x1 - ( wagonHeightPixels / 2 ) );  points.add( y1 - wagonHeightPixels );
			points.add( x1 + ( wagonHeightPixels / 2 ) );  points.add( y1 - wagonHeightPixels );
			
			_frame.drawFilledPolygon( points, Black );
		
		else
		
			wagonWidth := x2 - x1;
			
			if _flipV then
				y2 := y2 + wagonHeightPixels;
			else
				y2 := y1 - wagonHeightPixels;
			endif;
			
			if _flipH then
				
				// triangle right of well end
				points.add( x1 - wagonWidth );  points.add( y2 );
				points.add( x1 - wagonWidth - ( wagonHeightPixels / 2 ) );  points.add( y2 - ( wagonHeightPixels / 2 ) );
				points.add( x1 - wagonWidth - ( wagonHeightPixels / 2 ) );  points.add( y2 + ( wagonHeightPixels / 2 ) );
				
				_frame.drawFilledPolygon( points, Black );
				
				// triangle left of well end
				points.clear();
				points.add( x1 );  points.add( y2 );
				points.add( x1 + ( wagonHeightPixels / 2 ) );  points.add( y2 - ( wagonHeightPixels / 2 ) );
				points.add( x1 + ( wagonHeightPixels / 2 ) );  points.add( y2 + ( wagonHeightPixels / 2 ) );
				
				_frame.drawFilledPolygon( points, Black );
			
			else
				// triangle right of well end
				points.add( x2 );  points.add(y2);
				points.add( x2 + ( wagonHeightPixels / 2 ) );  points.add( y2 - ( wagonHeightPixels / 2 ) );
				points.add( x2 + ( wagonHeightPixels / 2 ) );  points.add( y2 + ( wagonHeightPixels / 2 ) );
				
				_frame.drawFilledPolygon( points, Black );
				
				// triangle left of well end
				points.clear();
				points.add( x1 );  points.add( y2 );
				points.add( x1 - ( wagonHeightPixels / 2 ) );  points.add( y2 - ( wagonHeightPixels / 2 ) );
				points.add( x1 - ( wagonHeightPixels / 2 ) );  points.add( y2 + ( wagonHeightPixels / 2 ) );
				
				_frame.drawFilledPolygon( points, Black );
			
			endif;
			
			
		endif;
		
		_frame.drawFillColor := Gray;
		
	endif;
		
epilog

	delete points;

end;
</source>
