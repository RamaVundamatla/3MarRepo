    <JadeMethod name="trxUpdateUserLogonAttempts" id="6cdacdc0-8234-40b1-8ebf-72e367cd63be">
        <updating/>
        <source>trxUpdateUserLogonAttempts(user : CM_User input; expectedEdition : Integer; numAttempts : Integer;
			_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if expectedEdition &lt; 1 then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ExpectedEditionInvalid, expectedEdition.String, method.name, null, null);
		return;
	endif;

	if user = null then
		app.setContinueCMExceptions(false);
	//	app.raiseCMException1(REQUIRED_FIELD, "user", null, null);
		app.raiseCMException(Input_required_field_Usr, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	beginTransaction;
	
	// Lock will be released at commit/abort transaction	
	exclusiveLock(user);
	
	if _passport.noErrors then
		if user.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "user", null, null);
			return;
		endif;
	endif;

	if _passport.noErrors then
		// Perform the operation
		user.updateNumberLogonAttempts(numAttempts);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="user" type="CM_User" usage="input"/>
        <Parameter name="expectedEdition" type="Integer"/>
        <Parameter name="numAttempts" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
