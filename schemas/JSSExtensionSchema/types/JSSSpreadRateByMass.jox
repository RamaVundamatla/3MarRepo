    <JadeMethod name="convertBaseToTarget" id="9ecc44ed-bb4c-4d46-9d23-4cfa8ddb149c">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.GRAMS_PER_SQUARE_CENTIMETRE then
		convertedMeasure	:=	pMeasure / 10;

	elseif pUnitTo = self.GRAMS_PER_SQUARE_METRE then
		convertedMeasure	:=	pMeasure * 1000;
		
	elseif pUnitTo = self.INCHES_OF_RAINFALL then
		convertedMeasure	:=	pMeasure / 2.54;
		
	elseif pUnitTo = self.KILOGRAMS_PER_HECTARE then
		convertedMeasure	:=	pMeasure * 10000;
		
	elseif pUnitTo = self.KILOGRAMS_PER_SQUARE_CM then
		convertedMeasure	:=	pMeasure / 10000;
		
	elseif pUnitTo = self.KILOGRAMS_PER_SQUARE_METRE then
		convertedMeasure	:=	pMeasure;
		
	elseif pUnitTo = self.MILLIGRAMS_PER_SQUARE_METRE then
		convertedMeasure	:=	pMeasure * 1000;
		
	elseif pUnitTo = self.MILLIMETRES_OF_RAINFALL then
		convertedMeasure	:=	pMeasure;
		
	elseif pUnitTo = self.OUNCES_PER_SQUARE_FOOT then
		convertedMeasure	:=	pMeasure / 0.305152;
		
	elseif pUnitTo = self.OUNCES_PER_SQUARE_INCH then
		convertedMeasure	:=	pMeasure / 43.942;
		
	elseif pUnitTo = self.OUNCES_PER_SQUARE_YARD then
		convertedMeasure	:=	pMeasure * 49.494;
		
	elseif pUnitTo = self.POUNDS_PER_ACRE then
		convertedMeasure	:=	pMeasure * 8921.791;
		
	elseif pUnitTo = self.POUNDS_PER_SQUARE_FOOT then
		convertedMeasure	:=	pMeasure / 4.882428;
		
	elseif pUnitTo = self.POUNDS_PER_SQUARE_INCH then
		convertedMeasure	:=	pMeasure / 703.07;
		
	elseif pUnitTo = self.POUNDS_PER_SQUARE_YARD then
		convertedMeasure	:=	pMeasure / 0.542492;
		
	elseif pUnitTo = self.TONNES_PER_HECTARE then
		convertedMeasure	:=	pMeasure * 10;
		
	elseif pUnitTo = self.TONS_UK_PER_ACRE then
		convertedMeasure	:=	pMeasure * 3.982942;
		
	elseif pUnitTo = self.TONS_US_PER_ACRE then
		convertedMeasure	:=	pMeasure * 4.460896;
		
	else
		JSSException.raise_(JSS_X_03004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of Spread Rate (by mass) to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="65031619-bae1-467d-8db0-f5b160fc8031">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.GRAMS_PER_SQUARE_CENTIMETRE then
		convertedMeasure	:=	self.measure * 10;

	elseif pUnitFrom = self.GRAMS_PER_SQUARE_METRE then
		convertedMeasure	:=	self.measure / 1000;
		
	elseif pUnitFrom = self.INCHES_OF_RAINFALL then
		convertedMeasure	:=	self.measure * 2.54;
		
	elseif pUnitFrom = self.KILOGRAMS_PER_HECTARE then
		convertedMeasure	:=	self.measure / 10000;
		
	elseif pUnitFrom = self.KILOGRAMS_PER_SQUARE_CM then
		convertedMeasure	:=	self.measure * 10000;
		
	elseif pUnitFrom = self.KILOGRAMS_PER_SQUARE_METRE then
		convertedMeasure	:=	self.measure;
		
	elseif pUnitFrom = self.MILLIGRAMS_PER_SQUARE_METRE then
		convertedMeasure	:=	self.measure / 1000;
		
	elseif pUnitFrom = self.MILLIMETRES_OF_RAINFALL then
		convertedMeasure	:=	self.measure;
		
	elseif pUnitFrom = self.OUNCES_PER_SQUARE_FOOT then
		convertedMeasure	:=	self.measure * 0.305152;
		
	elseif pUnitFrom = self.OUNCES_PER_SQUARE_INCH then
		convertedMeasure	:=	self.measure * 43.942;
		
	elseif pUnitFrom = self.OUNCES_PER_SQUARE_YARD then
		convertedMeasure	:=	self.measure / 49.494;
		
	elseif pUnitFrom = self.POUNDS_PER_ACRE then
		convertedMeasure	:=	self.measure / 8921.791;
		
	elseif pUnitFrom = self.POUNDS_PER_SQUARE_FOOT then
		convertedMeasure	:=	self.measure * 4.882428;
		
	elseif pUnitFrom = self.POUNDS_PER_SQUARE_INCH then
		convertedMeasure	:=	self.measure * 703.07;
		
	elseif pUnitFrom = self.POUNDS_PER_SQUARE_YARD then
		convertedMeasure	:=	self.measure * 0.542492;
		
	elseif pUnitFrom = self.TONNES_PER_HECTARE then
		convertedMeasure	:=	self.measure / 10;
		
	elseif pUnitFrom = self.TONS_UK_PER_ACRE then
		convertedMeasure	:=	self.measure / 3.982942;
		
	elseif pUnitFrom = self.TONS_US_PER_ACRE then
		convertedMeasure	:=	self.measure / 4.460896;
		
	else
		JSSException.raise_(JSS_X_03003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of Spread Rate (by mass) to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
</Class>
