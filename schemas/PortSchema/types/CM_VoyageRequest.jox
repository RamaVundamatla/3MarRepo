    <JadeMethod name="getFirstAllocation" id="de7b4fac-99b1-4a46-9a65-b158e091bb1d">
        <source>getFirstAllocation() : CM_VoyageAllocation;
/*
Purpose:			
Date		Who		Reason
27 June 2011	cnwab1	Initial creation
*/

vars
	allocation : CM_VoyageAllocation;
begin

	allocation := self.allAllocations.first.CM_VoyageAllocation;
	if allocation &lt;&gt; null then
		return allocation;
	endif;

