    <JadeMethod name="cnEcGetDuplicate" id="b71ad588-b5d1-40b8-86b0-5d2737be7081">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2014	cnwndl1	Initial creation

*/

vars

	oidTable : CnEcOidTable;
	id : String;
	rtHandHeld : CM_RadioTelemetryDevice;
	rtOid : String;
	xmlObj : CnEcXmlStructureInstance;
	xmlObj2 : CnEcXmlStructureInstance;
	currentOidValue : String;
	obj : Object;
	rtObj : CM_RadioTelemetry;

begin

	id := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "id" ).String;

	if id &lt;&gt; null then
		xmlObj	:=	pInput.findStructure("myRadioTelemetry");
		if xmlObj &lt;&gt; null then
			xmlObj2	:=	xmlObj.findStructure("OID");
			if xmlObj2 &lt;&gt; null then
				rtOid := xmlObj2.tagData;
				if rtOid &lt;&gt; null then
					//grubby, grubby, but should be OK if Hubble being used correctly.
					if not CnEcOidTable.instances.isEmpty then
						oidTable := CnEcOidTable.lastInstance;
					endif;
					if oidTable &lt;&gt; null then
						obj := oidTable.getObject(rtOid);
					endif;
					if obj &lt;&gt; null and obj.isKindOf(CM_RadioTelemetry) then
						rtObj := obj.CM_RadioTelemetry; 
					endif;
				endif;
			endif;
		endif;
		
		if rtObj &lt;&gt; null then
			rtHandHeld := rtObj.allRTDevices.getAtKey(id);
		endif;
	
	endif;
	
epilog

	return rtHandHeld;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
