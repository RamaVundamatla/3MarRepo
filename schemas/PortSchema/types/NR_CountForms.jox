        <source>runAsSeperateProcess(): Boolean;
// ---------------------------------------------------------------------------
// Created:     27 May 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendToNextProcess" id="9a4008ab-35c3-4351-a021-7071086576ae">
        <source>sendToNextProcess() : Boolean;
// ---------------------------------------------------------------------------
// Created:     28 May 2006 by cnwrs2
//
// Purpose:     Returns true if has sent to another process
// ---------------------------------------------------------------------------
vars

begin

	self.allProcesses.rebuild;
	
	if self.allProcesses.isEmpty then
		return false;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAllProcesses" id="24ad38ba-de3e-47cc-8943-8d26d6df7b5f">
        <source>setAllProcesses();
// ---------------------------------------------------------------------------
// Created:     27 May 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
02 Apr 2008	cnwkpd1	PAR #16421 - Rework to remove extended share locking on JADE 
					system objects

*/

vars
//	tmpNode			: Node;
	tmpProcess		: Process;
	invalidProcess	: Boolean;
	
begin
	self.allProcesses.clear;
	
	on Exception do app.handleDeletedObject(exception, tmpProcess, invalidProcess);	// PAR #16421
	
	foreach tmpProcess in Process.instances do
		if tmpProcess &lt;&gt; process and tmpProcess.persistentApp.name = JMTerminal then
			self.allProcesses.add(tmpProcess);
		endif;
	endforeach;
	
/*	PAR #16421 - old code replaced	

	foreach tmpNode in system.nodes discreteLock do
		foreach tmpProcess in tmpNode.processes discreteLock do
			if tmpProcess &lt;&gt; self and
			   tmpProcess.persistentApp.name = 'JMTerminal' then
				self.allProcesses.add(tmpProcess);
			endif;
		endforeach;
	endforeach;

*/

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="1c29bee3-218b-49ea-9c6a-598302db3e48">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     05 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if eventType = NR_NodeRequest_CntTransients then
		self.countForms();
		return;
	endif;
	
	inheritMethod(eventType, theObject, eventTag, userInfo);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="writeServerLog" id="a8b1f1ec-ad84-4e9c-99c8-46db8933579d">
        <executionLocation>server</executionLocation>
        <source>writeServerLog(_fileName, _msg : String) serverExecution;
// ---------------------------------------------------------------------------
// Created:     27 May 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	f	: File;
	
begin

	create f transient;
	f.fileName := _fileName;
	
epilog
	delete f;

end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
</Class>
