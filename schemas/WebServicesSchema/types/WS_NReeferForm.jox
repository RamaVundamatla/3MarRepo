<Class name="WS_NReeferForm" id="33df19c3-7263-427d-903f-07c733b7c78b">
    <superclass name="WS_NFormObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <ImplicitInverseRef name="content" id="ae6b7a2e-1291-4839-9b50-03f0ece25a06">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
    </ImplicitInverseRef>
    <JadeMethod name="buildFormDefinition" id="18c12baa-4381-4c96-8aad-c9615908f58f">
        <updating/>
        <source>buildFormDefinition() : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/10/2020	jlgdap1		Initial creation TFS 49227 Navis API - nReefer API
//
vars
	entDef : EntTableDef;
	row : EntTableRow;
	fieldArray, addedArray : WS_NFieldDefinitionArray;
	field : WS_NFieldDefinition;
	heading : String;

begin
	entDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_ReeferAPI);
	if entDef = null then
		return false;
	endif;
	
	// form response is an array of arrays, each sub-array being the fields that are grouped
	// in a single container in the reefer app. An Ent Table is used to define the fields, and 
	// "Group" rows are used to split the rows into groups for app containers
	create fieldArray transient;
	foreach row in entDef.allEntTableRows discreteLock do
		if row.isGroupRow then
			// do we have anything in the fieldArray? If so, add it to our content, and clear
			if not fieldArray.isEmpty then
				create addedArray transient;
				fieldArray.copy(addedArray);
				self.content.add(addedArray);
				fieldArray.clear;
			endif;
			continue;
		endif;
		// we don't want to send ufvGkey in the form field message otherwise it appears in the app
		// so don't give it a heading, and filter out anything without a heading
		heading := row.getHeadingUnaltered;
		if row.getHeadingUnaltered() = null then
			continue;
		endif;
		
		field := self.createField(row);
		if field &lt;&gt; null then
			fieldArray.add(field);
		endif;
	endforeach;
	// last one
	if not fieldArray.isEmpty then
		create addedArray transient;
		fieldArray.copy(addedArray);
		self.content.add(addedArray);
		fieldArray.clear;
	endif;
	
	return true;
	
epilog
	delete fieldArray;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createField" id="85f7bdd6-c191-44b0-8805-2e7dbc45a672">
        <updating/>
        <source>createField(_entRow : EntTableRow) : WS_NFieldDefinition updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/10/2020	jlgdap1		Initial creation TFS 49227 MTN Navis API - nReefer API
//
vars
	fieldDef : WS_NFieldDefinition;

begin
	create fieldDef transient;
	if fieldDef.setField(_entRow) then
		return fieldDef;
	else
		delete fieldDef;
		return null;
	endif;
epilog

end;</source>
        <Parameter name="_entRow" type="EntTableRow"/>
        <ReturnType type="WS_NFieldDefinition"/>
    </JadeMethod>
</Class>
