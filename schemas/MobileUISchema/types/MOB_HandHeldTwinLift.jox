    <JadeMethod name="doOk" id="3ce30f26-5cfe-4e09-844d-b52dad39e2c1">
        <updating/>
        <source>doOk() protected, updating;
//03 June 2008	cnwdw1	
// Move the twin tracked items to the ship
vars
	trackedItem : CM_TrackedItem;
	slotController : CM_SlotController;
	trackedItems : CM_TIArray;
	slotControllers : CM_LCArray;
begin
	create trackedItems transient;
	create slotControllers transient;
	// Move to forward slot
	trackedItems.add(self.getSessionAgent().myForwardTI);
	slotControllers.add(self.getSessionAgent().myForwardSlotController);
	// Move to aft slot
	trackedItems.add(self.getSessionAgent().myAftTI);
	slotControllers.add(self.getSessionAgent().myAftSlotController);
	while true do
		self.getDataAgent().moveToShip(trackedItems, self.getSessionAgent.myJob, slotControllers);
		if self.completedOK() then
			break;
		endif;
	endwhile;

	if self.isJobComplete() then
		//self.gotoForm(MOB_HandHeldSelectVoyageForm, true);
		self.gotoForm(MOB_HandHeldSelectVoyageForm,false);	//24 Nov 2010	NDL Par 1972
	else
		self.doBack();
	endif;

epilog
	delete trackedItems;
	delete slotControllers;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSwitch" id="a354d3ec-4673-460f-a253-a05b87b62bab">
        <updating/>
        <source>doSwitch() protected, updating;
//03 June 2008	cnwdw1	
// Swap the aft and forward containers
vars
	trackedItem : CM_TrackedItem;
begin
	trackedItem := self.getSessionAgent().myForwardTI;
	self.getSessionAgent().myForwardTI := self.getSessionAgent().myAftTI;
	self.getSessionAgent().myAftTI := trackedItem;
	self.refreshForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getHelpDescr" id="de960a72-717f-4ebd-aaa6-6715a238bf4f">
        <source>getHelpDescr(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2010	cnwndl1	Initial creation	Par 25074

*/

constants
	Bullet = 149;
vars
	
begin

	return	Bullet.Character &amp; " " &amp; app.getErrorString(Switch_between_day_night) &amp; CrLf; 

			
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleF2Key" id="9877ecd0-c05b-475a-a95d-9a2ce03f567d">
        <updating/>
        <source>handleF2Key() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwndl1	Initial creation	Par 25074

*/

vars

	vehicleConfig : CM_RTVehicleConfig;
	form : MOB_HandHeldForm;

begin

	vehicleConfig := self.myMobileGenericAgent.myTerminal.getRTVehicleConfigForObject(null);

	if self.myMobileGenericAgent.myScreenConfig = vehicleConfig.myDayScreenConfig then
		//changing from day to night
		self.myMobileGenericAgent.setMyScreenConfig( vehicleConfig.myNightScreenConfig );
		
	else
		//changing from night to day or setting up from null
		self.myMobileGenericAgent.setMyScreenConfig( vehicleConfig.myDayScreenConfig );
		
	endif;
	
	form := self;
	self.myHandHeldCheckerAgent.doApplyConfigColours( form );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="refreshForm" id="85429acd-f232-426b-aea6-6bc594f0dc06">
        <updating/>
        <source>refreshForm() updating;
vars
	job : CM_VoyageJob;
begin
	job := self.getSessionAgent().myJob;
	self.txtJob.caption := "";
	if job &lt;&gt; null then
		self.txtJob.caption := "Job " &amp; job.id;
	endif;
	
	// Set the bay id and deck
	self.txtBay.caption := "Bay " &amp; self.getSessionAgent().myBay.id;
	if self.getSessionAgent.deck = DeckOnDeck then
		self.txtBay.caption := self.txtBay.caption &amp; " OD";
	else
		self.txtBay.caption := self.txtBay.caption &amp; " UD";
	endif;	
	
	self.lblForwardTI.caption := self.getSessionAgent().myForwardTI.id;
	self.lblAftTI.caption := self.getSessionAgent().myAftTI.id;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="685b6a38-9e03-4620-b0dc-11119cb0a92e">
        <updating/>
        <source>setupForm() updating, protected;
vars

	form : MOB_HandHeldForm;
	
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	inheritMethod();
	self.refreshForm();
	
	form := self;
	self.myHandHeldCheckerAgent.doApplyConfigColours( form );	//22 Nov 2010	NDL Par 25074
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="95834f0b-590c-41a5-8b72-a9fa54b76525">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013149, locale);
	btnBack.translateCaption(Xlat_0013150, locale);
	btnOK.translateCaption(Xlat_0013151, locale);
	btnSwitch.translateCaption(Xlat_0013152, locale);
	lblAft.translateCaption(Xlat_0013153, locale);
	lblAftTI.translateCaption(Xlat_0013154, locale);
	lblForward.translateCaption(Xlat_0013155, locale);
	lblForwardTI.translateCaption(Xlat_0013156, locale);
	txtBay.translateCaption(Xlat_0013157, locale);
	txtJob.translateCaption(Xlat_0013158, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
