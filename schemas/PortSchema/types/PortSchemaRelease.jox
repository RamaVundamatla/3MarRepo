		aStopTable.shortHeading := "FOREST";
//		aStop.canIYardMove := true;
//		aStop.canIDeliveryRequest := true;
//		aStop.canIReleaseRequest := true;
		aStopTable.myRoot := theRoot;
	endif;	
	// ##########################

	if theRoot.allStopsTable[TI_Stop_Safety] = null then
		create aStopTable;
		aStopTable.id := TI_Stop_Safety;
		// Give all the different types to all the stops
		//theCargoTypes.copy(aStopTable.allCargoTypesNew);	//25.10.2022	navhl20	TFS 53862
		aStopTable.code := "S";
//		aStop.defaultImportStop := false;
		aStopTable.heading := "Safety";
		aStopTable.shortHeading := "Safety";
//		aStop.canIYardMove := true;
//		aStop.canIReleaseRequest := true;
//		aStop.canIDeliveryRequest := true;
		aStopTable.myRoot := theRoot;
	endif;
	
			
	// ##########################

	if theRoot.allStopsTable[TI_Stop_Terminal] = null then
		create aStopTable;
		aStopTable.id := TI_Stop_Terminal;
		// Give all the different types to all the stops
		//theCargoTypes.copy(aStopTable.allCargoTypesNew);	//25.10.2022	navhl20	TFS 53862
		aStopTable.code := "T";
//		aStop.defaultImportStop := false;
		aStopTable.heading := "Terminal";
		aStopTable.shortHeading := "Term";
//		aStop.canIYardMove := true;
//		aStop.canIDeliveryRequest := true;
		aStopTable.myRoot := theRoot;
//		aStop.canIReleaseRequest := true;
