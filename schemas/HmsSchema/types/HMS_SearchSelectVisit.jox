    <JadeMethod name="setDateDefaults" id="20b3f8e1-c10e-4c81-bf34-4274b924165f">
        <updating/>
        <source>setDateDefaults() updating, protected;

// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	now:		TimeStamp;
	nowLocal:	TimeStamp;
	firstDT:	TimeStamp;
	firstDTLocal:TimeStamp;
	lastDT:		TimeStamp;
	lastDTLocal:		TimeStamp;
	//voyage:		CM_Voyage;
	movement:	HMS_VoyageMovement;
	harbour:	HMS_Harbour;
begin
 	// This method sets default dates for the selection criteria
 	// Voyages Arrived Before...  - Set to Now 
 	// Voyages Arrived After...   - Set to Now 
 	// Voyages Arrived Between... - Set to first arrivedDT and last arrivedDT

	now := app.actualTimeServer;					// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	nowLocal := self.systemToLocalTime(now);		// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
   	// Voyages Arrived Before...  - Set to Now 
 	self.txtDateVoyBefore.setDate(nowLocal.date());
	self.txtTimeVoyBefore.setTime(nowLocal.time());

	// Voyages Arrived After...   - Set to Now 
	self.txtDateVoyAfter.setDate(nowLocal.date());
	self.txtTimeVoyAfter.setTime(nowLocal.time());

	/*// Voyages Arrived Between... - Set to first arrived DT and last arrivedDT
	voyage	:= self.myTerminal.allVoyagesByArrivalDTCode.first;
	if voyage &lt;&gt; null then
		firstDT	:=	voyage.arrivedDT;
	endif;

	voyage	:= self.myTerminal.allVoyagesByArrivalDTCode.last; //app.thisTerminal.CM_HMS_Terminal.voyagesByArrivedDT.last;
	if voyage &lt;&gt; null then
		lastDT	:=	voyage.arrivedDT;
	endif;*/
	
	harbour := self.myTerminal.myHarbour;
	
	/*movement := harbour.allVoyageMovements.first;
	if movement &lt;&gt; null then
		firstDT := movement.occursOnDT;
	endif;*/
	
	//Set to start of financial year
	firstDT.setDate(('31/03/'&amp;now.date.year.String).Date);
	if firstDT &gt; now then
		firstDT := firstDT.cnEcAddYears(-1);
	endif;
	
	if harbour &lt;&gt; null then
		movement := harbour.allVoyageMovements.last.HMS_VoyageMovement;
	endif;
	
	if movement &lt;&gt; null then
		lastDT := movement.occursOnDTNEW;
	endif;	
	
	if (not firstDT.isValid()) then
		if self.myViewController &lt;&gt; null then
			firstDT := self.myViewController.viewStartDT;
			lastDT := self.myViewController.viewFinishDT;
		endif;
	endif;

	firstDTLocal := self.systemToLocalTime(firstDT);	// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	lastDTLocal := self.systemToLocalTime(lastDT);		// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.txtDateBtwA.setDate(firstDTLocal.date());
	self.txtTimeBtwA.setTime(firstDTLocal.time());
	self.txtDateBtwB.setDate(lastDTLocal.date());
	self.txtTimeBtwB.setTime(lastDTLocal.time());

	// Default to optBetween
	optArrvBetween.value:=true;


end;</source>
        <access>protected</access>
    </JadeMethod>
