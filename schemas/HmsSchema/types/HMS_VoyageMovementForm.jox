    <JadeMethod name="displayHMSResource" id="7361f2a6-2c77-4034-9914-7967140dd8f6">
        <source>displayHMSResource(_allResources : HMS_ResourcesByCodeDict) protected;
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	idx : Integer;
	resource : HMS_Resource;
begin

	if (not self.shtWharfServices.visible) then
		return;	
	endif;
	
	if _allResources = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _allResources passed to method');
		return;
	endif;
	
	foreach resource in _allResources discreteLock
		where resource.isNotAvailableForEntry = false do // CCMS 1350
		idx := self.lstWharfServices.addItem(resource.description);
		lstWharfServices.itemObject[idx] := resource;
		lstWharfServices.itemLevel[idx] := ResourceLevel;
		lstWharfServices.itemPicture[idx] := resource.myResourceType.iconUpState;
	endforeach;
	
	if idx &gt; 0 then
		self.lstWharfServices.itemExpanded[ResourceLevel] := true;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_allResources" type="HMS_ResourcesByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="displayHMSResources" id="b13c0247-6ed2-47bb-9f3f-1205a1dad7ba">
        <source>displayHMSResources(_berth : HMS_Berth) protected;
//--------------------------------------------------
// Created:	06 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	wharf : HMS_Wharf;
	idx : Integer;
begin
	
	if (not self.shtWharfServices.visible) then
		return;
	endif;
	
	self.lstWharfServices.clear;
	
	if _berth &lt;&gt; null then
		wharf := _berth.myWharf;
	elseif self.mode = self.Mode_View then
		if self.myCurrentMovement = null then
			return;
		endif;	
		wharf := self.myCurrentMovement.getMyBerth.myWharf;	
	elseif self.cmbToBerth.listIndex &gt; 0 then
		wharf := self.cmbToBerth.listObject.HMS_Berth.myWharf;
	endif;
	
	if wharf = null then
		self.lstWharfServices.addItem(app.getErrorString(HMCannot_Display_Wharf_Service));	
		return;	
	endif;

	idx := self.lstWharfServices.addItem(wharf.description);
	lstWharfServices.itemObject[idx] := wharf;
	lstWharfServices.itemPicture[idx] := self.picWharf.picture;			
	lstWharfServices.itemLevel[idx] := 1;		
	
	self.displayHMSResource(wharf.allResources);
		
	if lstWharfServices.listCount &gt; 0 then
		lstWharfServices.itemExpanded[1] := true;		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="displayMovement" id="ae9ccb90-2217-4185-8ca1-2b7d7a8ed19a">
        <updating/>
        <source>displayMovement() updating, protected;

/*

Date		Who		Reason
29 Mar 2008	cnwkpd1	PAR #16118 - Standardise display of from berth when no previous movement is found
					If theer is no previous movement, then display the default sea harbour region details.
					
03/07/2014  cnwma1	CCMS SFW1328  HMS Not Available For Entry  
23/01/2019	jlgdap1	TFS 42987 Harbour resources various fixes
30 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
21 Sep 2022 navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
04 Oct 2022 navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
22 Mar 2023	navdap1	TFS 56593 EUP - Show Bollard+Meters in all instances
10/07/2024	navcs2		Bug 64769: MSL- IMT- Unable to manage the movements in Harbor management
*/

vars
  	movePrev:			HMS_VoyageMovement;
  	defaultTideClass:	HMS_TidalClass;  	// Modified by Russell 29/03/99
	harbour:			HMS_Harbour;
	seaHarbourRegion:	HMS_HarbourRegion;	// PAR #16118
	seaHRArrivalBerth:	HMS_Berth;
	tug              :	HMS_Tug;			// cnwma1  3/7/2014   CCMS SFW 1328
	row				 :	Integer;			// cnwma1  3/7/2014   CCMS SFW 1328
begin
	
	if self.myCurrentMovement = null then
		return;
	endif;

	harbour := self.myCurrentMovement.myHarbour;	

	self.tbxRemarks.text := self.myCurrentMovement.remarks;			
	
	txtVesselName.text := self.myCurrentMovement.getDisplayStringForAttribute(ETRow_VesselName, true);
 	tbxMoveType.text := self.myCurrentMovement.moveType;
 	tbxLineCrewReqd.text := self.myCurrentMovement.numLineCrewRequired.asStringJMT();
	
	//PAR16109 cnwsh3 Control was configured to only 1dp instead of 2 dp
	tbxDraftFwd.text := self.myCurrentMovement.draftFwd.asStringJMT();	//4.1.1 Draft enhancements
	tbxDraftAft.text := self.myCurrentMovement.draftAft.asStringJMT();

	// Set pilot exempt state
	//30 Apr 2012	NDL	Par 29496
	if self.mode = self.Mode_Add then
		ckbxPilotExempt.value := self.myCurrentMovement.myHMSVoyageData.isPilotExempt;
	else
		ckbxPilotExempt.value := self.myCurrentMovement.pilotExempt;
	endif;
	ckbxPilotExempt.click(ckbxPilotExempt);

	ckbxChargeMove.value := (not self.myCurrentMovement.chargeForMove);
	tbxLineCrewReqd.text := self.myCurrentMovement.numLineCrewRequired.asStringJMT();
	tbxShipsMaster.text := self.myCurrentMovement.shipsMaster;

	movePrev := self.myCurrentMovement.getVoyageMovementPrevious();

 	if movePrev = null then
 		// Arrival from sea
		tbxBerthFrom.text := null;
		seaHarbourRegion := app.myRoot.getSeaHarbourRegion();			// PAR #16118
// 		if harbour.defaultDepartBerth &lt;&gt; null then
//	 		tbxBerthFrom.text := harbour.defaultDepartBerth.description;
	 	tbxBerthFrom.text := null;	 	
		if seaHarbourRegion &lt;&gt; null then
			seaHRArrivalBerth := seaHarbourRegion.getArrivalBerth();
			if seaHRArrivalBerth &lt;&gt; null then
				tbxBerthFrom.text := seaHRArrivalBerth.getDisplayString();		// PAR #16118
			endif;
	 	endif;
		
 		tbxAftClearFrom.text := app.getErrorString(NotApplicable);
 		tbxForeClearFrom.text := app.getErrorString(NotApplicable);
 		tbxBowMarkFrom.text := app.getErrorString(NotApplicable);
 		tbxSternMarkFrom.text := app.getErrorString(NotApplicable);
 		tbxOrientFrom.text := app.getErrorString(NotApplicable);
	else
		// Load berth details for previous movement
		// If berth.ofWharf is logical, then set marks and clearances to N/A
		if movePrev.isLogicalBerth() then
			tbxAftClearFrom.text := app.getErrorString(NotApplicable);
 			tbxForeClearFrom.text := app.getErrorString(NotApplicable);
 			tbxBowMarkFrom.text := app.getErrorString(NotApplicable);
 			tbxSternMarkFrom.text := app.getErrorString(NotApplicable);
 			tbxOrientFrom.text := app.getErrorString(NotApplicable);
 		else
 			if movePrev.aftClearanceTo=ClearanceUnbounded then
 	 			tbxAftClearFrom.text := app.getErrorString(Unlimited);
 	 		else 
 	 			tbxAftClearFrom.text := movePrev.aftClearanceTo.asStringJMT();
 			endif;

 			if movePrev.foreClearanceTo=ClearanceUnbounded then
 	 			tbxForeClearFrom.text := app.getErrorString(Unlimited);
 	 		else 
 				tbxForeClearFrom.text := movePrev.foreClearanceTo.asStringJMT();
 			endif;


 			tbxBowMarkFrom.text := movePrev.bowMarkTo.asStringJMT();
 			tbxSternMarkFrom.text := movePrev.sternMarkTo.asStringJMT();
 			if movePrev.sideTo=OrientPortSideTo then
 				tbxOrientFrom.text := app.getErrorString(PortSideTo);
 			else
 				tbxOrientFrom.text := app.getErrorString(StarboardSideTo);
 			endif;	
   		endif;


 	endif;
    if self.myCurrentMovement.getMyBerth &lt;&gt; null then
		if (not self.myCurrentMovement.getMyBerth.isVisibleOnView) then			    
  		   	// Departure to sea (or other logical berth)
  		   	cbxOrientTo.listIndex  :=  cbxOrientTo.addItem(app.getErrorString(NotApplicable));
  		   	cbxOrientTo.itemText[cbxOrientTo.listIndex]  :=  app.getErrorString(NotApplicable);
  		   	cbxOrientTo.enabled := false;
 			
 			tbxAftClearTo.text := app.getErrorString(NotApplicable);
 			tbxForeClearTo.text := app.getErrorString(NotApplicable);
 			txtBowMarkTo.text := app.getErrorString(NotApplicable);
 			txtSternMarkTo.text := app.getErrorString(NotApplicable);
 			txtBridgeMark.text := app.getErrorString(NotApplicable); 			
 		else

			if	self.myCurrentMovement.sideTo = OrientPortSideTo then 
				cbxOrientTo.listIndex := OrientPortSideTo;
			else
				cbxOrientTo.listIndex := OrientStarboardSideTo;
		 	endif;			
			lastValidBowMark := self.myCurrentMovement.bowMarkTo;
			lastValidSternMark := self.myCurrentMovement.sternMarkTo;

	 		txtBowMarkTo.text := lastValidBowMark.asStringJMT();
	 		txtSternMarkTo.text := lastValidSternMark.asStringJMT();
 			txtBridgeMark.text := self.myCurrentMovement.getBridgeMark();	
			
			// START 21 Sep 2022	navsj20	TFS 54739
			self.cmbBowMarkBollard.clear;
			self.cmbBridgeMarkBollard.clear;
			self.cmbSternMarkBollard.clear;
			if self.myCurrentMovement.getMyBerth &lt;&gt; null then
				self.cmbToBerth.listObject:=myCurrentMovement.getMyBerth;
				populateBollardResources(self.cmbToBerth.listObject.HMS_Berth);	//04 Oct 2022	navsj20	TFS 54739
			endif;

			self.cmbBowMarkBollard.listIndex := self.cmbBowMarkBollard.findObject(self.myCurrentMovement.myBowBollard);
			self.cmbBridgeMarkBollard.listIndex := self.cmbBridgeMarkBollard.findObject(self.myCurrentMovement.myBridgeBollard);
			self.cmbSternMarkBollard.listIndex := self.cmbSternMarkBollard.findObject(self.myCurrentMovement.mySternBollard);
			if self.mode = self.Mode_Add then
				txtBowMarkMeter.text:=null;
				txtBridgeMarkMeter.text:=null;
				txtSternMarkMeter.text:=null;
			else
				self.txtBowMarkMeter.text := self.stringOrNull(self.myCurrentMovement.bowToBollard.Integer);			// TFS 56593 		// 10/07/2024	navcs2		Bug 64769
				self.txtBridgeMarkMeter.text := self.stringOrNull(self.myCurrentMovement.bridgeToBollard.Integer);		// TFS 56593		// 10/07/2024	navcs2		Bug 64769
				self.txtSternMarkMeter.text := self.stringOrNull(self.myCurrentMovement.sternToBollard.Integer);		// TFS 56593		// 10/07/2024	navcs2		Bug 64769
			endif;
			//21 Sep 2022	navsj20	TFS 54739
			
	    	lastValidForeClearance := self.myCurrentMovement.foreClearanceTo;
			lastValidAftClearance := self.myCurrentMovement.aftClearanceTo;
			lastValidBerth := self.myCurrentMovement.getMyBerth;
			lastValidOrientation := self.myCurrentMovement.sideTo;
						
			originalBerth := lastValidBerth;
	 		if lastValidAftClearance=ClearanceUnbounded then
	 			tbxAftClearTo.text := app.getErrorString(Unlimited);
	 		else 
	 			tbxAftClearTo.text := lastValidAftClearance.asStringJMT();
	 		endif;
	 		if lastValidForeClearance=ClearanceUnbounded then
	 			tbxForeClearTo.text := app.getErrorString(Unlimited);
	 		else 
	 			tbxForeClearTo.text := lastValidForeClearance.asStringJMT();
	 		endif;

		endif;
	endif;

 	// Load "Default Tidal Class" for this ship
    // Modified by Russell 29/03/99
    // ---------------------------------------------------------------------------
	if self.myCurrentMovement.moveType=HMSMovementTypeDeparture then
 		// Departure movement
 		defaultTideClass := self.myCurrentMovement.myHMSVoyageData.myTidalClassDept;
 	else
  		// Arrival or shift movement 
  		defaultTideClass := self.myCurrentMovement.myHMSVoyageData.myTidalClass;
  	endif;
  	if defaultTideClass&lt;&gt;null then
  		tbxDefaultTidal.text := defaultTideClass.description;
  	else
  		tbxDefaultTidal.text := "";
  	endif;
  	// --------------------------------------------------------------------

 	// Set "Movement Tidal Class" 
	
	self.cmbTidalClass.listIndex := self.cmbTidalClass.findObject(self.myCurrentMovement.myTidalClass); // cnwma1  4/7/2014   CCMS SFW 1328
	if self.cmbTidalClass.listIndex = -1 and self.myCurrentMovement.myTidalClass &lt;&gt; null then			  // cnwma1  3/7/2014   CCMS SFW 1328
		self.cmbTidalClass.addItemObject(self.myCurrentMovement.myTidalClass.description, self.myCurrentMovement.myTidalClass);
		self.cmbTidalClass.listIndex := self.cmbTidalClass.findObject(self.myCurrentMovement.myTidalClass);
	endif;

	self.setDefaultRelOrderTimes();

	// Load specific relative times for movement services
    if self.myCurrentMovement.relativeOrderTimeLines&gt;-1 then
    	tbxLineRelative.text := "+" &amp; self.myCurrentMovement.relativeOrderTimeLines.asStringJMT();
    else
    	tbxLineRelative.text := self.myCurrentMovement.relativeOrderTimeLines.asStringJMT();
	endif;
	if self.myCurrentMovement.relativeOrderTimePlaunch&gt;-1 then
		tbxLaunchRelative.text := "+" &amp; self.myCurrentMovement.relativeOrderTimePlaunch.asStringJMT();
	else
		tbxLaunchRelative.text := self.myCurrentMovement.relativeOrderTimePlaunch.asStringJMT();
	endif;
	if self.myCurrentMovement.relativeOrderTimeTugs&gt;-1 then 
		tbxTugRelative.text := "+" &amp; self.myCurrentMovement.relativeOrderTimeTugs.asStringJMT();
	else
		tbxTugRelative.text := self.myCurrentMovement.relativeOrderTimeTugs.asStringJMT();
	endif; 

	self.setDefaultActOrderTimes();

	// Modified by Russell 07/04/99
	// -------------------------------------------------------------
	self.setPLaunchReqdStatus();
	// -------------------------------------------------------------

    // Set list and combobox items
    if self.myCurrentMovement.locationPilotLaunch&gt;0 then
    	cbxLaunchPosn.listIndex := self.myCurrentMovement.locationPilotLaunch;
		cbxLaunchPosn.text := cbxLaunchPosn.itemText[cbxLaunchPosn.listIndex];
	endif;
	if self.myCurrentMovement.locationTug&gt;0 then
    	cbxTugPosn.listIndex := self.myCurrentMovement.locationTug;
		cbxTugPosn.text := cbxTugPosn.itemText[cbxTugPosn.listIndex];
	endif;
	
	if self.myCurrentMovement = null then
		self.lstTugs.setSelected(null);
	else
		self.lstTugs.setSelected(null); //21 Jan 2019	NDL	TFS 42997 - Need to clear anything that is already selected.
		//self.lstTugs.setSelected(self.myCurrentMovement.allTugsUsed);										// cnwma1  3/7/2014   CCMS SFW 1328
		foreach tug in self.myCurrentMovement.allTugsUsed do												// cnwma1  3/7/2014   CCMS SFW 1328
			if self.lstTugs.findObject(tug, row) then
				self.lstTugs.setRowSelect(row, true);
			else
				self.lstTugs.accessRow(self.lstTugs.addItem(Tab &amp; tug.description &amp; ' (' &amp; tug.code &amp; ')')).itemObject := tug;
				self.lstTugs.setRowSelect(self.lstTugs.accessedRow.row, true);
			endif;
		endforeach;
	endif;	

	// Load Pilot/Master
	//30 Oct 2018	NDL	TFS 41662
	/*row := null;						// TFS 42987 // ----&gt; TFS 44438
	//self.lstPilots.setSelected(null);
	foreach movementPilotDetails in self.myCurrentMovement.allMovementPilotDetails do // --&gt; TFS 44438						
		if self.lstPilots.findObject(movementPilotDetails.myPilot, row) then
			self.lstPilots.setRowSelect(row, true);
		else
			self.lstPilots.accessRow(self.lstPilots.addItem(Tab &amp; self.myAssistant.displayEntryHMSPilot(movementPilotDetails.myPilot))).itemObject := movementPilotDetails.myPilot;
			self.lstPilots.setRowSelect(self.lstPilots.accessedRow.row, true);
		endif;
	endforeach;	// &lt;-- TFS 44438	
	if self.myCurrentMovement &lt;&gt; null then // --&gt; TFS 44438
		if self.myCurrentMovement.allPilots.isEmpty then
			pilot := self.myCurrentMovement.getUnConvertedMyPilotRef;
			if pilot &lt;&gt; null then
				if self.lstPilots.findObject(pilot, row) then
					self.lstPilots.setRowSelect(row, true);
				else
					self.lstPilots.accessRow( self.lstPilots.addItem( Tab &amp; self.myAssistant.displayEntryHMSPilot(pilot) ) ).itemObject := pilot;
					self.lstPilots.setRowSelect(self.lstPilots.accessedRow.row, true);
				endif;
			endif;
		else
			foreach pilot in self.myCurrentMovement.allPilots do											
				if self.lstPilots.findObject(pilot, row) then
					self.lstPilots.setRowSelect(row, true);
				else
					self.lstPilots.accessRow( self.lstPilots.addItem( Tab &amp; self.myAssistant.displayEntryHMSPilot(pilot) ) ).itemObject := pilot;
					self.lstPilots.setRowSelect(self.lstTugs.accessedRow.row, true);
				endif;
			endforeach;
		endif;
	endif;*/ // &lt;---- TFS 44438
	
	
//	self.cmbPilot.listIndex := self.cmbPilot.findObject(self.myCurrentMovement.myPilot);						// cnwma1  4/7/2014   CCMS SFW 1328
//	if self.cmbPilot.listIndex = -1 and self.myCurrentMovement.myPilot &lt;&gt; null then								// cnwma1  3/7/2014   CCMS SFW 1328
//		self.cmbPilot.addItemObject(self.myCurrentMovement.myPilot.description, self.myCurrentMovement.myPilot);
//		self.cmbPilot.listIndex := self.cmbPilot.findObject(self.myCurrentMovement.myPilot);
//	endif;
	
	self.cmbMaster.listIndex := self.cmbMaster.findObject(self.myCurrentMovement.myMaster);
	self.cmbMaster.click(cmbMaster);
	
	// Load Pilot Launch
	/*self.cmbPilotLaunch.listIndex := self.cmbPilotLaunch.findObject(self.myCurrentMovement.myPilotLaunch);	// cnwma1  4/7/2014   CCMS SFW 1328 // ----&gt; TFS 44438
	if self.cmbPilotLaunch.listIndex = -1 and self.myCurrentMovement.myPilotLaunch &lt;&gt; null then					// cnwma1  3/7/2014   CCMS SFW 1328
		self.cmbPilotLaunch.addItemObject(self.myCurrentMovement.myPilotLaunch.description,self.myCurrentMovement.myPilotLaunch);
		self.cmbPilotLaunch.listIndex := self.cmbPilotLaunch.findObject(self.myCurrentMovement.myPilotLaunch);
	endif;
	if not self.myCurrentMovement.allMovementPilotDetails.isEmpty then // --&gt; TFS 44438
		self.cmbPilotLaunch.listIndex := self.cmbPilotLaunch.findObject(self.myCurrentMovement.allMovementPilotDetails.first.myPilotLaunch);
	endif;
	if self.cmbPilotLaunch.listIndex = -1 and not self.myCurrentMovement.allMovementPilotDetails.isEmpty
		and self.myCurrentMovement.allMovementPilotDetails.first.myPilotLaunch &lt;&gt; null then
		self.cmbPilotLaunch.addItemObject(self.myCurrentMovement.allMovementPilotDetails.first.myPilotLaunch.description,self.myCurrentMovement.allMovementPilotDetails.first.myPilotLaunch);
		self.cmbPilotLaunch.listIndex := self.cmbPilotLaunch.findObject(self.myCurrentMovement.allMovementPilotDetails.first.myPilotLaunch);
	endif;*/ // &lt;---- TFS 44438

	// Load Line Company
	self.cmbLineCompany.listIndex := self.cmbLineCompany.findObject(self.myCurrentMovement.myLineCompany);	// cnwma1  4/7/2014   CCMS SFW 1328
	if self.cmbLineCompany.listIndex = -1 and self.myCurrentMovement.myLineCompany &lt;&gt; null then					// cnwma1  3/7/2014   CCMS SFW 1328
		self.cmbLineCompany.addItemObject(self.myCurrentMovement.myLineCompany.description,self.myCurrentMovement.myLineCompany);
		self.cmbLineCompany.listIndex := self.cmbLineCompany.findObject(self.myCurrentMovement.myLineCompany);
	endif;
	// Load berth position details for the "From Berth"
	if movePrev&lt;&gt;null then
		if movePrev.getMyBerth&lt;&gt;null then
			tbxBerthFrom.text := movePrev.getMyBerth.getDisplayString();		// PAR #16118
		else
			tbxBerthFrom.text := null;
		endif;
	endif;

	// Load "To Berth"
	self.cmbToBerth.listIndex := self.cmbToBerth.findObject(self.myCurrentMovement.getMyBerth);

	// Load Tidal Window Details
	self.calcClosestTidalWindow();

	// Set "Shipping Line"
	self.cmbShippingLine.setObject(self.myCurrentMovement.myShippingLine);

	// Set "Agent"
	self.cmbShippingAgent.setObject(self.myCurrentMovement.myShippingAgent);	

	self.optAgent.value := self.myCurrentMovement.isAgentDefault;

	self.loadContactsList();

	self.txtVisitNumber.text := self.myCurrentMovement.myHarbour.getVesselVisitCountStr(self.myCurrentMovement.myHMSVoyageData.vesselCode, self.myCurrentMovement.occursOnDTNEW);

	if self.myCurrentMovement.moveStatusNEW = MovementStatus_Planned then
 		tbxMoveStatus.text := app.getErrorString(Planned);
 	elseif self.myCurrentMovement.moveStatusNEW=MovementStatus_ConfirmedPlan then
 		tbxMoveStatus.text := app.getErrorString(PlanConfirmed);
 	elseif self.myCurrentMovement.moveStatusNEW=MovementStatus_Actual then
 		tbxMoveStatus.text := app.getErrorString(Actual);
 	else
 		tbxMoveStatus.text := "";
 	endif;

	self.tbxRemarks.text := self.myCurrentMovement.remarks;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayMovementDetails" id="0f1bdafd-3e75-4004-ae0e-d3f691b314fc">
        <updating/>
        <source>displayMovementDetails() updating, protected;
//-----------------------------------------
// Created: July 2005 By: cnwgd1
//-----------------------------------------
/*

Date		Who		Reason
12 Oct 2009	cnwkpd1	PAR #20995 - Disable all updates for archived movements (including adding new 
					movements)

*/

vars
	dateTime,
	now 	  : TimeStamp;
	tmpMovement : HMS_VoyageMovement;
begin
	
	tmpMovement := self.myCurrentMovement;
	self.btnResourcesUsed.enabled := tmpMovement &lt;&gt; null;
	
	if tmpMovement = null then

		// clear data
		self.clearData();				
		self.setCaption(self.Caption);
		
		if (not self.isFirstActivateComplete) then
			self.cmbMovements.setFocus();
		endif;

	else

		self.setCaption(self.cmbMovements.text &amp; ' ' &amp; self.Caption);	// 26/5/2016	cnwmp6	TFS 488 - Multi timezone changes
		
		// PAR #20995 - Disable all updates for archived movements
		if self.viewOnly or tmpMovement.archived then
			self.btnNew.enabled := false;
			self.btnEdit.enabled := false;
			self.btnDelete.enabled := false;
		else
			self.btnNew.enabled := true;
			self.btnEdit.enabled := true;
			self.btnDelete.enabled := true;
		endif;
		
/*		if self.myCurrentMovement.archived then
			self.btnEdit.enabled := false;
		else // Lorcan 12052 If the previous selection was archived and this one is not the button stayed disabled
			self.btnEdit.enabled := true;
		endif;		
*/	
		dateTime := self.systemToLocalTime(tmpMovement.occursOnDTNEW);	// 25/5/16 cnwmp6 TFS 488 - Multi timezone support
		if dateTime.isValid then
			self.txtMoveOnDate.setDate(dateTime.date());
			self.txtMoveOnTime.setTime(dateTime.time());
		else
			self.txtMoveOnDate.text := null;
			self.txtMoveOnTime.text := null;
		endif;
		self.displayMovement();			
		
	endif;

	self.displayResources();
			
	self.setNavigatorHeading(self.caption);
		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayMvmntPilotDetails" id="c6e9ddcf-ada7-4716-b3e3-76a2039ad9a7">
        <updating/>
        <source>displayMvmntPilotDetails() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	movementPilotDetails : HMS_MovementPilotDetails;
begin
	self.tblPilotLaunch.rows := self.tblPilotLaunch.fixedRows;		
	if self.myCurrentMovement = null then
		return;
	endif;
	foreach movementPilotDetails in self.myCurrentMovement.allMovementPilotDetails do
		self.addMvmntPilotDetailsToTable(movementPilotDetails);		
	endforeach;	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayResourceUsed" id="2586a390-9e19-46f3-8ea5-220cde183cbc">
        <updating/>
        <source>displayResourceUsed()updating, protected;
//--------------------------------------------------
// Created:	16 February 2005 By: cnwgd1
//--------------------------------------------------
// 03 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars
	resourceUsed : HMS_ResourceUsed;	
begin

	//purge all cloned control and reset control new index
	//self.allClonedControls.purge(); // TFS 44438
	//newIndex := 0; // TFS 44438

	self.tblResUsed.rows := self.tblResUsed.fixedRows;		

	if self.myCurrentMovement = null then
		return;
	endif;

	foreach resourceUsed in self.myCurrentMovement.allResourceUsed do

		self.addResourceUsedToTable(resourceUsed);
		
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayResources" id="562969f1-4877-41ef-8b4b-6d028dd022ed">
        <updating/>
        <source>displayResources()updating, protected;
//--------------------------------------------------
// Created:	05 April 2004 By: cnwgd1
//--------------------------------------------------
// 02 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars

begin	
	self.displayHMSResources(null);
	self.setSelectedResources();
	self.allClonedControls.purge(); // TFS 44438
	self.newIndex := 0; // TFS 44438	
	self.displayResourceUsed();
	self.displayMvmntPilotDetails(); // TFS 44438	
end;</source>
        <access>protected</access>
    </JadeMethod>
