	truck					: String;
	termID					: String;
	
begin

	
	app.initialize();
	
	create dsl transient;
	dsl.setActiveProfileMDHONLY();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	termID := "Enter Terminal Code";
	read termID;
	
	terminal := app.myRoot.allTerminals[termID];
