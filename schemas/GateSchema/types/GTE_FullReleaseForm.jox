//----------------------------------------------------------------
//	Created:	10 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
begin
	if table.row = table.getRowByName(ETRow_GeneratePinNo) then
		if table.getValueByName(ETRow_GeneratePinNo).Boolean then
			table.showRowByName(ETRow_EmailOptions, false);
		else
			table.hideRowByName(ETRow_EmailOptions, false);
		endif;
	endif;
end;</source>
