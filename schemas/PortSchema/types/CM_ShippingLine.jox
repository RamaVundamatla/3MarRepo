    <JadeMethod name="getAllDischargePorts" id="3eb74457-1cb2-4f9b-bf37-3abbc6dd7067">
        <source>getAllDischargePorts(_set : CM_PortSet input);
/*2
------------------------------------------------------------------------
Created:			16 January 2003 by cnwdwq1
Purpose:			Gets all ports from this shipping line's shipPortGroups
Parameters:		As above. Special comment:
Returns:			As above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	spg : CM_ShipPortGroup;
	sp : CM_ShipPort;
begin
	if _set = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "_set", null, null);
		return;
	endif;
	_set.clear;
	foreach spg in self.shipPortGroups do
		foreach sp in spg.shipPorts do
			if _set.includes(sp.port) then
				continue;
			endif;
			_set.add(sp.port);
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_set" type="CM_PortSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllOperators" id="15f6742e-5790-4031-a09c-3512d6ab68d0">
        <source>getAllOperators(_operDict : CM_OperatorByCodeDict input);
//--------------------------------------------------
// Created:	12 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	portGrp : CM_ShipPortGroup;
begin
	if _operDict = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _operDict passed ot method');
		return;	
	endif;
	
	foreach portGrp in self.shipPortGroups do
		portGrp.getAllOperators(_operDict);	
	endforeach;
	
end;</source>
        <Parameter name="_operDict" type="CM_OperatorByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="756c2203-b993-4916-83b0-489a6c05c439">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     20 April 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txt		: String;
	tmpStr	: String;
	email	: CM_EmailAddress2;
	shipGrp : CM_ShipPortGroup;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
	foreach email in self.allContacts do
		if tmpStr = null then
			tmpStr := email.name;
		else
			tmpStr := tmpStr &amp; ', ' &amp; email.name;
		endif;
	endforeach;
	txt := txt &amp; 'Contacts Selected' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	tmpStr := null;
	foreach shipGrp in self.shipPortGroups do
		if tmpStr = null then
			tmpStr := shipGrp.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; shipGrp.code;
		endif;
	endforeach;
	txt := txt &amp; 'Port Groups' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
