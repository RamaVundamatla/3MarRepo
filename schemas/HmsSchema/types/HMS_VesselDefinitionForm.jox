    <JadeMethod name="cbxTidalClassArrv_change" id="8e057e9c-1d03-47ce-9e60-e435f9c01133">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cbxTidalClassArrv_change(combobox: ComboBox input) updating;

vars

begin
	// Covert all tidal class enteries to upper case
	cbxTidalClassArrv.text:=cbxTidalClassArrv.text.String.toUpper;

	// Don't accept any tidal class that is not already defined
	if cbxTidalClassArrv.listCount&gt;0 then
		if cbxTidalClassArrv.findString(1,cbxTidalClassArrv.text.String)=-1 then
			// Set text to first tidal class;
			cbxTidalClassArrv.text:=cbxTidalClassArrv.itemText[1];
		endif;
		loadTidalClassTbl;
	endif;



end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
