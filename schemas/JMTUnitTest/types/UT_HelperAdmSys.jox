    </JadeMethod>
    <JadeMethod name="xCreateToDoTaskDesc" id="9f47d511-cb3c-44ff-baef-da38127cc66e">
        <source>xCreateToDoTaskDesc(_testName   : String;
					_code		: String;
					_cargoType	: String) :CM_ToDoTaskDesc;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2021		navma1	Initial creation
02 November 2022		navds20 ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
*/

vars
	term 			   			: CM_Terminal;
	selectedCargoTypes			: ObjectArray;
	selectedResourceTypes 		: CM_ObjectSet;
	toDoDesc 					: CM_ToDoTaskDesc;
	proxy 						: CM_ToDoTaskDesc;
	completionTransactionType,
	creationTransactionType		: CM_TransactionType;
	
begin
	
	xDeleteToDoTaskDesc(_code);
	
	term := self.getTerminal;
	
	create selectedCargoTypes transient;
	selectedCargoTypes.add(app.myRoot.getCargoTypeFromAbbrev(_cargoType));
	
	create selectedResourceTypes transient;
	
	completionTransactionType := null;
	if self.opts.includesKey(UT_OPTS_CompleteTransType) then
		completionTransactionType := app.myRoot.allTransactionTypes[self.opts.int(UT_OPTS_CompleteTransType)];
	endif;
	
	creationTransactionType := null;
	if self.opts.includesKey(UT_OPTS_CreateTransType) then
		creationTransactionType := app.myRoot.allTransactionTypes[self.opts.int(UT_OPTS_CreateTransType)];
	endif;
	
	create proxy transient;
	proxy.setProxy(	_code,			
					_code,			
					0,							
					_code,		
					0,							
					completionTransactionType,						
					creationTransactionType,						
					selectedCargoTypes,			
					selectedResourceTypes,						
					false,						
					null,						
					null,						
					term.allSubTerminals,
					TODO_TYPE_GROUP_TI,	//02/11/2022 navds20 TFS #56635[54261]	
					null,	//02/11/2022 navds20 TFS #56635[54261]
					null,	//02/11/2022 navds20 TFS #56635[54261]
					false
					);
	
	app.myTrxCA.trxCreateToDoTaskDesc(proxy, toDoDesc, app.myPassport);
	
	self.assertTrueMsg(toDoDesc &lt;&gt; null ,'Test : ' 						      		  &amp;   _testName   &amp; CrLf &amp; 
										'Error : Failed to create ToDo Task Desc : '  &amp;   _code 	  &amp; CrLf &amp; 
										'Trx Errors: '						 		  &amp;    app.myPassport.getErrorsAsString  );
										  
	return toDoDesc;
epilog
	delete selectedResourceTypes;
	delete selectedCargoTypes;
	delete proxy;
end;</source>
        <Parameter name="_testName" type="String"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_cargoType" type="String"/>
        <ReturnType type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="xCreateVessel" id="5ef556d5-646b-40d9-b463-6a74691f08c0">
        <source>xCreateVessel(_vslType : String;
		      _hasHms  : Boolean):CM_Vessel;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2022		navma1	Initial creation

*/
vars
	vessel					: CM_Vessel;
	pxyVessel				: CM_Vessel;
	operator			    : CM_Operator;
	conflictManager			: CMIF_HMS_ConflictsManager;
	errors					: String;
	tidalClassArrival		: HMS_TidalClass;			
	tidalClassDept			: HMS_TidalClass;
	pxyHMSVesselData		: HMS_VesselData;
	hms_VesselDataHarbour	: HMS_VesselDataHarbour;
	shippingLine			: CM_ShippingLine;
	shipAgent				: CM_ShippingAgent;
	terminal				: CM_Terminal;
begin
		
	if self.doDeleteFirst then
		self.xDeleteVessel();
	endif;
	
	create pxyVessel transient;
	
	pxyVessel.setProxyForVessel(null,
								self.code,
								'UT'&amp;self.code,
								self.opts.str( ETRow_CallSign ),
								"",
								"",	
								"",
								self.opts.str( ETRow_LloydsNumber ),
								1,
								0,
								0,
								VESSEL_TYPE_LOLO,
								2000,
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								true,
								false,
								self.myOperator,
								null,
								false);
	
	if _hasHms then
		
		
	create pxyHMSVesselData transient;
	pxyVessel.setHMSVesselData(pxyHMSVesselData);
	
	create hms_VesselDataHarbour transient;	// NOTE: the delete is handled by the delete on the pxyVessel
	
	terminal		    := app.myRoot.allTerminals['UT'];
	tidalClassArrival	:= app.myRoot.allTidalClasses[ 'E' ];
	tidalClassDept		:= app.myRoot.allTidalClasses[ 'C' ];
	shippingLine        := app.myRoot.allShippingLines['UTSL'];
	shipAgent	        := app.myRoot.allShippingAgentsByCode['UTSA'];
	
	hms_VesselDataHarbour.setProxy(	null,
									false,
									false,
									null,
									null,
									null,
									null,
									null,
									null,
									null,
									terminal.myHarbour,
									null,
									shipAgent,
									null,
									null,
									tidalClassArrival,
									tidalClassDept );
	pxyHMSVesselData.allVesselDataForHarbour.add( hms_VesselDataHarbour );
	
	pxyHMSVesselData.setProxy(	app.myRoot,
								false,
								false,
								false,
								false,
								false,
								false,
								false,
								false,
								"",
								"",
								"",
								0,
								0,
								0,
								100,
								20000,
								20000,
								19000,
								0,
								0,
								0,
								0,
								0,
								shippingLine,
								app.myRoot.allVesselTypes["G"] );
	endif;
	
	app.myTrxCA.trxCreateVessel(pxyVessel, vessel, conflictManager, app.myPassport);
	
	if app.myPassport.hasErrors then
		errors := app.myPassport.getErrorsAsString;
		self.assertTrueMsg(false ,'Test : ' 						      		  &amp;   self.testname   &amp; CrLf &amp; 
								  'Error : Failed to Add Vessel : ' 			  &amp;   self.code 	  &amp; CrLf &amp; 
								  'Trx Errors: '						 		  &amp;    errors  );
	endif;
	
	if _vslType = 'HOLD' then
		// Create Holds
		self.xCreateVesselHolds();
		
		self.assertTrueMsg(vessel.myGeneralCargoVesselStructure &lt;&gt; null ,
				'Test : ' 						      		  &amp;   self.testname   &amp; CrLf &amp; 
				'Error : Failed to Add Vessel : ' 			  &amp;   self.code 	  &amp; CrLf &amp; 
				'Trx Errors: '						 		  &amp;    app.myPassport.getErrorsAsString  );
	elseif _vslType = 'LOLO' then
		
	elseif _vslType = 'RORO' then
		
	endif;
	
	return vessel;
	
epilog
	delete pxyVessel;
	
end;</source>
        <Parameter name="_vslType" type="String"/>
        <Parameter name="_hasHms" type="Boolean"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="xCreateVesselHolds" id="ecb6440c-8e66-4ffe-83e7-6982907b599f">
        <source>xCreateVesselHolds();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2022		navma1	Initial creation

*/

vars
	vessel 			  : CM_Vessel;
	vesselName 		  : String;
	gcHoldLocnDefn 	  : CM_GCHoldLocationDefn;
	gcVesselStructure : CM_GeneralCargoVesselStructure;
	i, 
	j, 
	holds, 
	decks			 : Integer;
	loadState 		 : Boolean;
	root			 : CM_Root;
begin
	root	:= self.getRoot();
	vessel	:= root.allVessels[ self.code.toUpper ];
	
	assertNotNull(vessel);
	
	
	gcVesselStructure := vessel.myGeneralCargoVesselStructure;
	if gcVesselStructure = null then
		self.addGCStructureDefn(vessel);
		gcVesselStructure := vessel.myGeneralCargoVesselStructure;
	endif;
	
	holds := 4;
	decks := 3;
	
	foreach i in 1 to holds do
		foreach j in 1 to decks do
			self.addGCHoldDefn(gcVesselStructure,	
				i,		//_holdNum: Integer;
				j,		//_placeNum: Integer;
				false,	//_isOnDck : Boolean;			
				null, 	// _maxWeight : Integer;		
				null,	// _maxVolume: Decimal;		
				0,		// _maxHeight: Decimal;	
				1,		// _onShipCrane: Integer;		
				"Hold" &amp; i.String &amp; " Deck" &amp; j.String
				);
		endforeach;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="xDeleteCargoType" id="a62adbfa-0d51-4020-9db5-1b5b3534f78e">
        <source>xDeleteCargoType(_checkReleaseRequest ,
				 _checkOffsite,
				 _checkOnSite,
				 _checkPrenote,
				 _checkTba,
				 _checkVoyage			: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2021		navma1	Initial creation

*/

vars
	cargoType		: CM_CargoType;
	terminal		: CM_Terminal;
	voyage			: CM_Voyage;
	cargoTypeId		: Integer;
	bulkRelease	    : CM_BulkRelease;
	obj				: Object;
	mergeIter		: MergeIterator;
	tiSet			: CM_TISet;
	iter			: Iterator;
	ti              : CM_TrackedItem;
	product			: CM_Product;
	tilcType 		: CM_TILCType;
begin
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( self.code );
	terminal  := app.myRoot.allTerminals['UT'];
	
	if cargoType = null then
		assertNull(cargoType);
		return;
	endif;
	
	self.assertEqualMsg(cargoType.allTerminals.size , 1, "Cargo Type Should be only Used in UT");

	beginTransaction;
	cargoType.setPropertyValue(CM_CargoType::hasNoNonInversedUsages.name, true);
	commitTransaction;
	
	cargoTypeId := cargoType.id;
	
	if _checkReleaseRequest then
		foreach bulkRelease in terminal.allBulkReleasesByCodeDate do
			foreach obj in bulkRelease.allReserveDetails do
				if obj.isKindOf(CM_ReserveSelection) and obj.CM_ReserveSelection.myCargoType = cargoType then
					self.deleteReleaseRequest(bulkRelease.code);
					break;
				endif;
			endforeach;		
		endforeach;
	endif;
	
	create tiSet transient;
	create mergeIter transient;
	
	if _checkPrenote then
		mergeIter.addCollection(terminal.allNotifiedTIsByCargoTypeId);
	endif;
	
	if _checkOnSite then
		mergeIter.addCollection(terminal.allOnsiteTIsByCargoTypeId);
	endif;
	
	if _checkTba then
		mergeIter.addCollection(terminal.allTbaTIsByCargoTypeId);
	endif;
	
	mergeIter.addCollection(terminal.allRRPTIsByCargoTypeId);
	
	mergeIter.startKeyGeq(cargoTypeId, null);
	
	while mergeIter.next(ti) do
		if ti.cargoType &lt;&gt; cargoTypeId then
			break;
		endif;

		tiSet.addNoDuplicates(ti,false);
	endwhile;
	

	if _checkOffsite then
		iter := terminal.allOffsiteTIsByCargoTypeId.createIterator();
		terminal.allOffsiteTIsByCargoTypeId.startKeyGeq(cargoTypeId, null, null, iter);
		while iter.next(ti) do 
			if ti.cargoType &lt;&gt; cargoTypeId then
				break;
			endif;
			tiSet.addNoDuplicates(ti,false);
		endwhile;
		delete iter;
	endif;
	
	if _checkVoyage then
		foreach voyage in terminal.allVoyagesByCode do
			iter := voyage.allOnshipTIsByCargoTypeId.createIterator;
			voyage.allOnshipTIsByCargoTypeId.startKeyGeq(cargoTypeId, null, iter);
			while iter.next(ti) do
				if ti.cargoType &lt;&gt; cargoTypeId then
					break;
				endif;
				
				tiSet.addNoDuplicates(ti,false);
			endwhile;
			delete iter;
		endforeach;
		
	endif;
	
	
	self.deleteTrackedItem(tiSet, true);
	
	foreach product in cargoType.allProducts do
		self.deleteProduct(product, product.myOperator, cargoType);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	
	
	foreach tilcType in cargoType.allTILCTypes do
		self.deleteTrailerType(tilcType);
	endforeach;
	
	self.ignoreTrxWarnings(true);
	app.myTrxDA.trxDeleteCargoType(cargoType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete mergeIter;
	delete tiSet;
	delete iter;

end;</source>
        <Parameter name="_checkReleaseRequest" type="Boolean"/>
        <Parameter name="_checkOffsite" type="Boolean"/>
        <Parameter name="_checkOnSite" type="Boolean"/>
        <Parameter name="_checkPrenote" type="Boolean"/>
        <Parameter name="_checkTba" type="Boolean"/>
        <Parameter name="_checkVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xDeleteCustomsAction" id="9aea9136-a916-4a07-9699-5820195abed5">
        <source>xDeleteCustomsAction(_customsActionName, _actionKeyField : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2023	navpw1	Initial creation TFS: 61364 (61375)

*/

vars
	realCustomsAction : CM_EDIAction;
	
begin
	realCustomsAction := app.myRoot.allEDIActions[_customsActionName];
	if realCustomsAction &lt;&gt; null then
		self.deleteEDIAction(_customsActionName, null, _actionKeyField);
		self.assertIsDeleted(realCustomsAction);
	endif;
	
end;</source>
        <Parameter name="_customsActionName" type="String"/>
        <Parameter name="_actionKeyField" type="String"/>
    </JadeMethod>
    <JadeMethod name="xDeleteHarbourResource" id="003b900d-0805-4ae7-b32c-bf67a84c8672">
        <source>xDeleteHarbourResource(_code    : String; 
				       _harbour : HMS_Harbour);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2022		navma1	Initial creation

*/

vars
	resource		: HMS_Resource;
begin
	
	resource := _harbour.allResources[_code];
	
	if resource &lt;&gt; null then
		
		self.xDeleteResourceType(resource.myResourceType);				
		
		app.myTrxDA.trxDeleteHMSResource(resource, app.myPassport);
		
		self.assertNoTrxErrorsOrWarnings();
		
		beginTransaction;
			delete resource;
		commitTransaction;
	endif;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="xDeleteInvoiceCalcType" id="f38dfce0-2569-42b7-ba0b-efa25f73d6b0">
        <source>xDeleteInvoiceCalcType(_code : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2022		navma1	Initial creation

*/

vars
	calcType : CM_CalculationType;
begin
	
	foreach calcType in app.myRoot.allCalculationTypesByCode reversed do
		if calcType.code = _code then
			app.myTrxDA.trxDeleteCalculationType(calcType, app.myPassport);
		endif;
	endforeach;
end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="xDeleteResourceType" id="de08da3c-9e08-4337-b997-38e50e55f5df">
        <source>xDeleteResourceType(_resourceType : Any);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2022		navma1	Initial creation

*/

vars
	resourceType			: HMS_Object;
	resource				: HMS_Resource;
	deleteResources 		: Boolean;
begin

	if _resourceType.isKindOf(String) then
		resourceType := app.myRoot.allResourceTypes[_resourceType.String];
	else	
		resourceType := _resourceType.HMS_Object;
	endif;
	
	if resourceType &lt;&gt; null then
	
		if self.opts.includesKey("deleteResources") then
			deleteResources := self.opts.bool("deleteResources");
		endif;
		
		beginTransaction;
		if deleteResources then	
			resourceType.HMS_ResourceType.allResources.purge();
		else
			foreach resource in resourceType.HMS_ResourceType.allResources do
				resource.setPropertyValue("myResourceType", null);
			endforeach;
		endif;
		commitTransaction;
		
		app.myTrxDA.trxDeleteHMSObject(resourceType, app.myPassport);
		
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
epilog

end;</source>
        <Parameter name="_resourceType" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xDeleteResourceTypeGroup" id="12b6ade3-9bd7-4c49-b08c-3ded51722016">
        <source>xDeleteResourceTypeGroup(_resourceTypeGroupCode : String);
