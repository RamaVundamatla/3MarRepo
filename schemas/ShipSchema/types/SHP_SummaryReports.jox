    <JadeMethod name="doResize" id="6019c7e3-536c-4133-9239-31aee79044cf">
        <source>doResize();
// ---------------------------------------------------------------------------
// Created:     29 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
constants
	Gap = 5;
vars

begin
	self.tblEnt.left := Gap;
	self.tblEnt.width := self.width - (Gap * 4);

end;</source>
