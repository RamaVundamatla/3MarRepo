*/

vars

begin
	return self.myWORequestType;

epilog

end;</source>
        <ReturnType type="CM_WorkOrderRequestByType"/>
    </JadeMethod>
    <JadeMethod name="isComplete" id="141b2a1c-def7-4210-85bf-b48b3de7514b">
        <methodInvocation>mapping</methodInvocation>
        <source>isComplete(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// Date			Who		Reason
// 28 Sep 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
// 07 Nov 2023 	navhl20 ChangeRequest 58756:[60740] EUP | VAS Mobile App - [53813.010] VAS Mobile App
// ---------------------------------------------------------------------------
vars
	//toDoTask	: CM_ToDoTask;
begin

	/*
	//07.11.2023 navhl20 #58756[60740]
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	_value := true;
	
	foreach	toDoTask in self.allToDoTasks do
		if toDoTask.status = STATUS_TODO then
			_value := false;
			break;
		endif;
	endforeach;*/
	inheritMethod(set, _value);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
