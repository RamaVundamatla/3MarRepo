// Purpose:		### PAR 10765 ### 
// 				Renamed 1 April 2008 By Graeme Black cnwgb1 PAR 16407
// ---------------------------------------------------------------------------

vars
	aCT : CM_CalculationType;
begin

	// ### PAR 10765 ### //
	aCT := self.getCalcType();
