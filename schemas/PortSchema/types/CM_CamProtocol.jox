    <JadeMethod name="getMyCamControllerAgent" id="2860aa1d-7432-4dfe-97dc-d8691e2f28a9">
        <source>getMyCamControllerAgent() : CM_CamControllerAgent;
//
// 29 Jun 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
//
vars
	object : CM_CamControllerAgent;
	edition : Integer;
	invalidObj : Boolean;
begin
	object := self.myCamControllerAgent;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception, object, invalidObj);
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;
epilog

end;</source>
        <ReturnType type="CM_CamControllerAgent"/>
    </JadeMethod>
    <JadeMethod name="getName" id="54f3cd02-2479-4bc6-a173-a98039da2c3e">
        <source>getName() : String;

vars
	returnStr		: String;
	
begin
	returnStr	:=	inheritMethod() &amp; Tab &amp;
					code.padBlanks( 30 ) &amp; Tab &amp;
//					description.padBlanks( 30 ) &amp; Tab &amp;
//					useTiOperator.cnEcGetYesNo &amp; Tab &amp;
//					useVoyageOperator.cnEcGetYesNo &amp; Tab &amp;
//					specialField14.cnEcGetYesNo &amp; Tab &amp;
//					specialField15.cnEcGetYesNo &amp; Tab &amp;
					creationTime.shortCurrentLocaleFormat;
	
	return returnStr;
	
epilog
	
