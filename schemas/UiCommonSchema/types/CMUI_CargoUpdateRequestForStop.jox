    <JadeMethod name="doSaveToDo" id="08f2e0ed-b5f7-48de-a7f4-f355f811bc73">
        <source>doSaveToDo(_cargoId: String; _addresses: CM_StringArray; _cmifEventReq: CMIF_EventRequestController input; _currentRequestPxy: CM_EventRequestStops) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	pxyRequestStops : CM_EventRequestStops;
	numberPxyToDo,
	i : Integer;
	toDoTask : CM_ToDoTaskDesc;
	isAdd, isRemove : Boolean;
	toDoRemarks : String;
	
begin

	numberPxyToDo := 0;
	
	while i &lt; self.tblToDo.rows do
	
		i := i+1;
		
		isAdd := self.tblToDo.accessCell(i,self.addClearCol).text = self.addText;
		isRemove := self.tblToDo.accessCell(i,self.addClearCol).text = self.clearText;
		
		if not isAdd and not isRemove then
			continue;
		else
			toDoTask := self.tblToDo.accessRow(i).itemObject.CM_ToDoTaskDesc;
			toDoRemarks := self.tblToDo.accessCell(i,toDoRemarksCol).text;
		endif;
		
		numberPxyToDo := numberPxyToDo + 1;
		
	endwhile;
	
	if numberPxyToDo = 0 then
		app.raiseCMException(Must_selec_clear_your_selec_to, ETRow_Stops, null);
		return;
	elseif numberPxyToDo &gt; 1 then
		app.raiseCMException(Only_selec_task_stops_updat_re, ETRow_Stops, null);
		return;
	endif;
	
	if _currentRequestPxy &lt;&gt; null then
		pxyRequestStops := _currentRequestPxy;
	else
		create pxyRequestStops as CM_EventRequestForStop transient;
	endif;
	
	pxyRequestStops.setProxyRequestStops(	EventRequestTypeToDo,
											_addresses,
											null,
											null,
											null,
											null,
											null,
											null,
											EventRequestPending,
											isRemove,
											self.chkNotify.value,												
											null,
											false,
											null,
											null,
											null,
											pxyRequestStops.isEDI,
											toDoTask,
											null,
											null,
											null,	//_custAgent : CM_CustomsAgent 
											toDoRemarks,	//_toDoRemarks		: String
											null,	//_tiBOL	
											null,	//_clearCustAgent		
											null,   
											null,   
											null); 
											
	if pxyRequestStops.CM_EventRequestForStop.myStopTableTemplate = null then
		pxyRequestStops.CM_EventRequestForStop.setMyStopTemplate( self.myProxyStopTableTemplate );
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_addresses" type="CM_StringArray"/>
        <Parameter name="_cmifEventReq" type="CMIF_EventRequestController" usage="input"/>
        <Parameter name="_currentRequestPxy" type="CM_EventRequestStops"/>
    </JadeMethod>
    <JadeMethod name="doSaveWeightCertified" id="c870e7c9-3ba2-4722-9ea9-dc87e0fd426f">
        <source>doSaveWeightCertified(_cargoId: String; _addresses: CM_StringArray; _cmifEventReq: CMIF_EventRequestController input; _currentRequestPxy: CM_EventRequestStops) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	pxyRequestStops : CM_EventRequestStops;
	
begin

	if _currentRequestPxy &lt;&gt; null then
		pxyRequestStops := _currentRequestPxy;
	else
		create pxyRequestStops as CM_EventRequestForStop transient;
	endif;
	
	pxyRequestStops.setProxyRequestStops(	EventRequestTypeWeight,
											_addresses,
											null,
											null,
											null,
											null,
											null,
											null,
											EventRequestPending,
											false,
											self.chkNotify.value,												
											null,
											false,
											null,
											null,
											null,
											pxyRequestStops.isEDI,
											null,
											null,
											self.txtRemarks.text.trimBlanks,
											null,	//_custAgent : CM_CustomsAgent 
											null,	//_toDoRemarks		: String
											null,	//_tiBOL	
											null,	//_clearCustAgent		
											null,   
											null,   
											null); 
											
	pxyRequestStops.setProxyWeightCertified(	self.tblWeight.getConvertedValue(),								// TFS #1699
												self.chkIsCertified.value,										// TFS #1699
												self.txtAuthName.text.trimBlanks.toUpper,				//Bug 38876				
												self.txtCertName.text.trimBlanks.toUpper	);
											
	if pxyRequestStops.CM_EventRequestForStop.myStopTableTemplate = null then
		pxyRequestStops.CM_EventRequestForStop.setMyStopTemplate( self.myProxyStopTableTemplate );
	endif;

epilog

end;</source>
