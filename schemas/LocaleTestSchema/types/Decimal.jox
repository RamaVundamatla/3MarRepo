	endif;
	
	return sTemp;
	*/
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asStringWeightJMT" id="f6a063c4-2e20-473b-b512-32a74b0f3cfc">
