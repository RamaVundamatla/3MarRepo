        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="unconfirmWagonOutwards" id="1c3e6f4e-74d5-491e-827b-b88c534f8564">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="wagonCode" id="fbb61af9-0290-406e-9167-d064fdc273f8">
        <length>21</length>
        <embedded/>
        <type name="String"/>
        <text>cnwsh3 02/07/2008 PAR17395
Was length 30 but now length 20 to maintain consistency with the actual CM_Wagon.id field.

EDI Wagons (CM_EDIPrenoteTI and CM_EDIBookingTI) have wagonNumber attributes of 30 which,
at the time of an EDI load is ok.  We use the verifyEDITIs to check there won't be a problem
and the user can make a manual change at that point to reduce the field length.</text>
    </PrimAttribute>
    <PrimAttribute name="wagonPosition" id="5b80575d-5a5e-48c4-901a-1aa5cbd82972">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="actionForCreate" id="aaed816d-4021-421e-a9c5-b610f97aec9a">
        <updating/>
        <source>actionForCreate(_realWagon : CM_Wagon output; _passport : CM_Passport input; _auditAgent : CM_CreateTransactionAuditAgent input)updating;
//--------------------------------------------------------------
//Created: 05 March 2003 By: cnwgd1
// 29 Oct 2024  navma1  	MTN-33231 MTN - Enable Deferred Updates For Train and Wagon Events 
//--------------------------------------------------------------
vars
	terminal					: CM_Terminal;
	wagonPos					: CMIF_TIWagonPosition;
	previousController,
	wagonController 			: CM_WagonController;
	realTI,
	cloneTI,
	ti							: CM_TrackedItem;
	wagonLength,
	loc, 
	pos							: Integer;
	wellDef 					: CM_WagonWellDefinition;
	well 						: CM_WellcarWellVisit;
	wagonMoveController 		: CMIF_WagonMoveController;	//25 Feb 2021	NDL	TFS 50837
	isInterTermTransferEnabled  : Boolean;
	lenInUnits					: Integer;

begin
	if self.mode &lt;&gt; Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Invalid_mode) &amp; ' (' &amp; self.mode.String &amp; ')');
		return;
	endif;
	
	//26 Feb 2021	NDL:	TFS 50837
	if self.effectiveTimeStamp.isValid then
		create wagonMoveController transient;
		wagonMoveController.setEffectiveTimeStampOverride( self.effectiveTimeStamp );
	endif;
	
	create _realWagon as self.myProxyWagon.class persistent;
	_realWagon.setForCreate(wagonMoveController, self.myProxyWagon);
	
	if _passport.noErrors then //+ cnwmd1, CCMS 1067, Par 19710
		_auditAgent.audCreateGeneric(_realWagon);
	endif;
	
	if self.myRailLine &lt;&gt; null then
		self.myRailLine.addWagon( wagonMoveController, _realWagon, self.wagonPosition, insertWagon);
		// get rid of null references on the end the wagon array
		self.myRailLine.tidyWagons();
	endif;
	
	// Create Controllers for each wagon...
	
	if _realWagon.isWellcarVisit then	//10 Dec 2014	NDL	Par 35346
		foreach wellDef in _realWagon.myWagonClass.allWagonWellDefArray do
			well := _realWagon.CM_WellcarVisit.createWellFromDef( wellDef );
		endforeach;
		
	else
		lenInUnits := _realWagon.myWagonClass.getLenInUnits;		//29.10.2024 navma1 #MTN-33231
		
		foreach loc in 1 to lenInUnits do							//29.10.2024 navma1 #MTN-33231
			create wagonController as _realWagon.getLocationContClassToCreate persistent;
			wagonController.setForCreate(_realWagon.id &amp; _realWagon.myWagonClass.locationIds[loc].trimBlanks,
										true,
										_realWagon,
										previousController);
			
			previousController := wagonController;
		endforeach;
		
	endif;

	if _passport.hasErrors then
		return;
	endif;

	terminal 				   := _passport.myTerminal;
	wagonLength 			   := _realWagon.myWagonClass.lenInUnits;
	isInterTermTransferEnabled := app.isInterTerminalTransferEnabled();   //29.10.2024 navma1 #MTN-33231
	
	foreach wagonPos in self.allWagonPositions do
		pos := wagonPos.position;
		
		// this position indicate the index of the controller
		if pos &lt; 1 then 
			continue;
		endif;
		
		if pos &gt; wagonLength then
			continue;
		endif;
		
		foreach ti in wagonPos.allTrackedItems do	//14 Oct 2014	NDL	Par 35040
		
			if ti &lt;&gt; null and ti.isTransient then
				// DVB Added inter terminal tranfering functionality. 30/07/04
				// DVB changed to use new flags 05/04/05
				if isInterTermTransferEnabled then						//29.10.2024 navma1 #MTN-33231	
					realTI := terminal.lookupTrackedItem(ti.id, ti.cargoType, TI_STATE_TRANSFER, null, true);
				endif;
				
				if realTI &lt;&gt; null then
					cloneTI := realTI.getCloneForInterTerminalMove2(terminal, false);
					realTI := cloneTI;
				else
					realTI := terminal.allNotifiedTIsByCargoTypeId[ti.cargoType, ti.id];
					
				endif;
				
				if realTI = null then
					realTI := terminal.createTrackedItem(ti, _passport);
				else
					realTI.setForRailHandHeld(ti);
				endif;
				
				ti     := realTI;
				realTI := null;
			endif;
			
			wagonController := _realWagon.allLocationsControllersArray[pos];
			wagonController.setController(ti, wagonPos.hasTwistLocks,
										  wagonPos.twistLocksAreUp,
										  wagonPos.available, _passport);
									  
		endforeach;
		
	endforeach;
	
	if self.confirmWagonInwards and not _realWagon.confirmed then	//26 Aug 2020	NDL	TFS 49950
		_realWagon.confirmWagonInwards(wagonMoveController, self.doAutoPlan, _passport);
	elseif self.unconfirmWagonInwards and _realWagon.confirmed then	//26 Aug 2020	NDL	TFS 49950
		_realWagon.unconfirmWagonInwards(_passport);
	endif;
	
	if self.confirmWagonOutwards and not _realWagon.confirmedOutwards then		//26 Aug 2020	NDL	TFS 49950
		_realWagon.confirmWagonOutwards( wagonMoveController, _passport);
	elseif self.unconfirmWagonOutwards and _realWagon.confirmedOutwards then	//26 Aug 2020	NDL	TFS 49950
		_realWagon.unconfirmWagonOutwards(_passport);
	endif;
epilog

	delete wagonMoveController;
end;</source>
        <Parameter name="_realWagon" type="CM_Wagon" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_auditAgent" type="CM_CreateTransactionAuditAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionForPrenote" id="f21a3246-7fff-423e-9c64-34406c346256">
        <updating/>
        <source>actionForPrenote(_passport : CM_Passport input; _slotNumber : String)updating;
//--------------------------------------------------------------
//Created: 05 June 2003 By: cnwgd1
//02 Oct 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
//--------------------------------------------------------------
vars	
	wagonClassId : String;
	wagonClass   : CM_WagonClass;
	theWagon     : CM_Wagon;
	ti           : CM_TrackedItem;
begin

	if self.allTrackedItems.isEmpty then
		app.raiseCMException1(ERR_NO_OBJECT,app.getErrorString(NO_Cargo_found), null, null); 
		return;
	endif;
	
	// wagonCode can be null as sometimes the wagon is not known
	if self.wagonCode &lt;&gt; null then		

		if self.myTrain = null then
			theWagon := _passport.myTerminal.getCurrentWagonByID(self.wagonCode);
		else
			theWagon := self.myTrain.allWagonsByIdInward[self.wagonCode];	
		endif;
		
		if theWagon = null then	
			// Wagon does not exist, create it.	
			self.mode := Mode_Add;
			//create self.myProxyWagon transient;
			
			if self.myWagonClass = null then	//12 May 2014	NDL	Par 33615
				wagonClassId := app.myRoot.getWagonClassViaHookCode(_passport.myTerminal,self.wagonCode,null); //20 Jul 2009 NDL CCMS 1067
				wagonClass 		:= app.myRoot.allWagonClasses[wagonClassId];
			else
				wagonClass := self.myWagonClass;	//12 May 2014	NDL	Par 33615
				wagonClassId := self.myWagonClass.code;	//12 May 2014	NDL	Par 33615
			endif;
			create self.myProxyWagon as app.getWagonVisitClassToCreate( wagonClass, _passport.myTerminal,self.wagonCode, null ) transient;	//15 Mar 2013	NDL	Par 31278
			self.myProxyWagon.setProxy(_passport.myTerminal, self.wagonCode, wagonClass, self.myTrain, self.myTrain, null, null, null, null, null,null,null);//02.10.2020 cnwma1 TFS #50112 
			self.actionForCreate(theWagon, _passport, app.myUtilityCA.myCreateAuditAgent); //+ cnwmd1, CCMS 1067, Par 19919
		endif;
	endif;		
	
	if _passport.hasErrors then
		return;
	endif;
	
	foreach ti in self.allTrackedItems do
		ti.setWagonForPrenote(self.wagonCode, wagonClass, theWagon, _passport, _slotNumber);
	endforeach;
		
epilog
	delete self.myProxyWagon;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_slotNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="actionForUpdate" id="986bf042-a4cf-469b-88ce-327a8c5835f4">
        <updating/>
        <source>actionForUpdate(_passport : CM_Passport input; _auditAgent : CM_UpdateTransactionAuditAgent input)updating;
//--------------------------------------------------------------
//Created: 05 March 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  ------------------------------------
// 21/08/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 29 Oct 2024  navma1  	MTN-33231 MTN - Enable Deferred Updates For Train and Wagon Events 
//--------------------------------------------------------------
vars
	realWagon					: CM_Wagon;
	wagonPos					: CMIF_TIWagonPosition;
	wagonLength,
	expectedEdition				: Integer;
	terminal					: CM_Terminal;
	tiToRemove					: CM_TISet;
	wagonController				: CM_WagonController;
	realTI,
	cloneTI,
	ti							: CM_TrackedItem;
	railJob						: CM_RailJob;
	wagonMoveController 		: CMIF_WagonMoveController;	//26 Feb 2021	NDL	TFS 50837
	isInterTermTransferEnabled  : Boolean;

begin
	if self.mode &lt;&gt; Mode_Update then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Invalid_mode) &amp; ' (' &amp; self.mode.String &amp; ')');
		return;
	endif;
	
	//26 Feb 2021	NDL:	TFS 50837
	if self.effectiveTimeStamp.isValid then
		create wagonMoveController transient;
		wagonMoveController.setEffectiveTimeStampOverride( self.effectiveTimeStamp );
	endif;

	// ### TFS 62857 (62858) 18Mar2024 NAVPW1
	if wagonMoveController &lt;&gt; null and self.retrospectiveDT &lt;&gt; null and self.retrospectiveDT.isValid then
		wagonMoveController.retrospectiveDT := self.retrospectiveDT;
	endif;
	// ### TFS 62857 (62858) 18Mar2024 NAVPW1
	
	self.myProxyWagon.pxyGetRealObjectAndEdition(realWagon, expectedEdition);
	
	if realWagon = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Wagon.name, null, null);
		return;
	endif;
	
	//12 Nov 2014	NDL	Par 35164
	app.myValUA.valWagon(self.myProxyWagon);	
	if _passport.hasErrors then
		return;
	endif;
	
	//30 Sep 2009	NDL	Par 20744
	if realWagon.allLocationsControllersArray.isEmpty then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(No_Location_Controllers) &amp; ' (' &amp; realWagon.id &amp; ')');
		return;
	endif;

	exclusiveLock(realWagon);

	if _passport.noErrors and self.expectedEditionWagon &lt;&gt; realWagon.edition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Wagon), null, null);
		return;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	if _passport.noErrors then //+ cnwmd1, CCMS 1067, Par 19919
		_auditAgent.audUpdateGeneric(realWagon, true);
	endif;

	realWagon.setForUpdate(wagonMoveController, self.myProxyWagon);
	
	if _passport.hasErrors then
		return;
	endif;

	wagonLength := realWagon.myWagonClass.getLenInUnits;
	
	create tiToRemove transient;
	foreach wagonController in realWagon.allLocationsControllersArray do	//04 Dec 2014	NDL	Par 35345
		foreach ti in wagonController.allTrackedItems do
			if not tiToRemove.includes(ti) then
				tiToRemove.add(ti);
			endif;
		endforeach;
	endforeach;	

	terminal := _passport.myTerminal;
	
	// Par 10619 Determine which containers need removing before
	// trying to put new container in its place.
	
	foreach wagonPos in self.allWagonPositions do
		// this position indicates the index of the controller	
		if wagonPos.position &lt; 1 then
			continue;
		endif;
		if wagonPos.position &gt; wagonLength then			
			continue;
		endif;
	//	ti := wagonPos.myTrackedItem;
		foreach ti in wagonPos.allTrackedItems do	//14 Oct 2014	NDL	Par 35040
			//if it is transient check that there is a real because tiToRemove includes persistent
			if ti &lt;&gt; null and ti.isTransient then
				ti:=ti.pxyGetRealObject();
			endif;
			if tiToRemove.includes(ti) then
				tiToRemove.remove(ti);
			endif;
		endforeach;
		
	endforeach;
	
	foreach ti in tiToRemove do
		ti.moveToLocation(null, null, null, null, REAL_MODE, true, true, false, false, false,false,null,null,null, null,null,_passport);	// TFS 2651
	endforeach;
	
	isInterTermTransferEnabled := app.isInterTerminalTransferEnabled();   //29.10.2024 navma1 #MTN-33231
	
	foreach wagonPos in self.allWagonPositions do
		// this position indicates the index of the controller	
		if wagonPos.position &lt; 1 then
			continue;
		endif;
		if wagonPos.position &gt; wagonLength then			
			continue;
		endif;

		foreach ti in wagonPos.allTrackedItems do	//14 Oct 2014	NDL	Par 35040
		
			if ti &lt;&gt; null and ti.isTransient then
				// DVB Added inter terminal tranfering functionality. 30/07/04
				// DVB changed to use new flags 05/04/05
				if isInterTermTransferEnabled then						//29.10.2024 navma1 #MTN-33231								
					realTI := terminal.lookupTrackedItem(ti.id, ti.cargoType, TI_STATE_TRANSFER, null, true);
				endif;
				
				if realTI &lt;&gt; null then
					cloneTI := realTI.getCloneForInterTerminalMove2(terminal, false);
					realTI := cloneTI;
				elseif ti.pxyIsProxy then//th2 added 7/06/2007 - from Gdansk HH the ti is a proxy
					realTI := ti.pxyGetRealObject();
				else
					realTI := terminal.allNotifiedTIsByCargoTypeId[ti.cargoType, ti.id];
					//realTI := terminal.allNotifiedTIsByCargoTypeId.getNextItem(tiSet, ti.cargoType, ti.id);
					//12 Sep 2013	NDL	Par 32479 - multi pre-note break bulk on train
					if ti.canMergeBreakBulk then
						realTI := null;
					endif;
				endif;
				if realTI = null then
					realTI := terminal.createTrackedItem(ti, _passport);
				else
					realTI.setForRailHandHeld(ti);
					
				endif;
				ti := realTI;
				realTI := null;
			endif;
		
			wagonController := realWagon.allLocationsControllersArray[wagonPos.position];
			wagonController.setController(ti, wagonController.hasTwistlocks,
										  wagonController.twistlocksAreUp,
										  wagonController.isAvailable, _passport);
									  
		endforeach;

	endforeach;

	if _passport.hasErrors then
		return;
	endif;		
		

	if self.myRailLine &lt;&gt; null then // PAR 19710
		app.myUtilityUA.utlUpdateWagonPosition( wagonMoveController, self.myRailLine, realWagon, self.wagonPosition, _passport);
	endif;
	
	if self.confirmWagonInwards then
		if (not realWagon.confirmed) then
			realWagon.confirmWagonInwards(wagonMoveController, self.doAutoPlan, _passport);
			
		else//th2 31/05/2007 for PAR14154 - may be confirmed already, but because no containers were
			//previously on the wagon, no recieval job got created, so create one now if it doesn't already
			//exist. Also see further on were any new cargo items get queued if the user has selected to autoplan the cargo
			railJob := realWagon.getReceiveJob();
			if railJob = null then //and (not self.allTrackedItems.isEmpty) 
				realWagon.confirmWagonInwards(null, self.doAutoPlan, _passport);
			/*	railJob := realWagon.createRailReceiveJob(_passport);
				if not app.myPassport.checkValidation then
					return;
				endif;*/
			else
			
			endif;
		endif;
		
	elseif self.unconfirmWagonInwards then
		if realWagon.confirmed then
			realWagon.unconfirmWagonInwards(_passport);
		endif;
	endif;
	
	if railJob = null and realWagon.confirmed then //+ cnwmd1 Par 25324 - adding cargo after wagon is confirmed
		railJob := realWagon.getReceiveJob();
	endif;
	
	////th2 31/05/2007 for PAR14154 - autoplan any that aren't queued already if the user has selected 'do autoplan'
	if railJob &lt;&gt; null then
		foreach wagonController in realWagon.allLocationsControllersArray do	//04 Dec 2014	NDL	Par 35345
			foreach ti in wagonController.allTrackedItems do
				//PAR 14531 - autoplan even when already confirmed
				if self.doAutoPlan and ti.myPrimaryQueuedLocation = null then
					ti.autoPlan(QUEUE_MODE, railJob, null, null, _passport);
				endif;
				if (not railJob.allReceiveTrackedItems.includes(ti)) then
					//epr par 34466 7/7/14 new quantity/weight param
					railJob.addJobRequest(ti, true, null,null, _passport);
				endif;
				//a rail job already exists but cargo was added need to  only confirm trackedItems that are not in the wagons 
				// allTIsReceived collection
				//if not realWagon.allTIsReceived.includes(ti) and self.confirmWagonInwards then 	//- cnwmd1, Par 25324
				if not realWagon.allTIsReceived.includes(ti) then 									//+ cnwmd1 Par 25324 to get to this point the wagon will be confirmed in
					ti.confirmWagon( wagonMoveController, TI_STATE_NORMAL, _passport);
					ti.matchTBA();
					realWagon.arrivalProcessForTI( wagonMoveController, ti);
				endif;
			endforeach;
		endforeach;
	endif;
	
	if self.confirmWagonOutwards and (not realWagon.confirmedOutwards) then
		realWagon.confirmWagonOutwards( wagonMoveController, _passport);
	elseif self.unconfirmWagonOutwards and realWagon.confirmedOutwards then
		realWagon.unconfirmWagonOutwards(_passport);
	endif;
	
	if _passport.noErrors then //+ cnwmd1, CCMS 1067, Par 19919
		_auditAgent.audUpdateGeneric(realWagon, false);
	endif;
epilog
	//delete tiSet;
	if tiToRemove &lt;&gt; null then	// 30 Jul 2009	NDL
		tiToRemove.clear();
	endif;
	delete tiToRemove;
	delete wagonMoveController;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_auditAgent" type="CM_UpdateTransactionAuditAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addTiToWagonAtPosition" id="f9e7fb6d-9110-4cb9-a7b2-a8b7f80babc0">
        <updating/>
        <source>addTiToWagonAtPosition(_ti : CM_TrackedItem io; _position : Integer; _wagon : CM_Wagon input) updating;

/*

Purpose:			
	//Add the new cargo item and wagonPositions
Parameters:			

Return Value:		


Date			Who		Reason
19 August 2009	cnwndl1	Initial creation
21 August 2009	consw1	PAR 19913 - SFW1067 Rail Simplifications
*/

vars

	idx, pos,
	unitsRequired : Integer;
	tiWagonPos	: CMIF_TIWagonPosition;		
	wagonClass : CM_WagonClass;
	wellDef : CM_WagonWellDefinition;
	wellPos : Integer;
	
begin

	if _wagon = null then
		return;
	endif;

	if _position = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Position), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Position), null, null); // cnwdb2	PAR 35364
		return;
	endif;

	if _ti = null then
	//	app.raiseCMException1(REQUIRED_FIELD,  app.getErrorString(CargoItem_Name), null, null);
		app.raiseCMException1(Input_required_field_Required,  app.getErrorString(CargoItem_Name), null, null); // cnwdb2	PAR 35364
		return;
	endif;	
	
	if _wagon.isWellcarVisit then	//12 Dec 2014	NDL	Par 35346
		unitsRequired  := _wagon.CM_WellcarVisit.getLengthInUnitsForWagon(_ti).Integer;
	elseif _wagon.isFlatcar then	//25 Mar 2013	NDL	Par 31278
		unitsRequired := _ti.getLengthInUnitsForWagon().Integer; // PAR 18015
	elseif _wagon.isBoxcar then	//25 Mar 2013	NDL	Par 31278
		unitsRequired := 1;
	endif;
	pos := _position;
	
	//validate cargo does not run over the end of the wagon
	//and validate position is not already taken
	wagonClass := _wagon.myWagonClass;
	if wagonClass &lt;&gt; null then
		if wagonClass.isFlatcar then	//25 Mar 2013	NDL	Par 31278
			//N.B. (pos + unitsRequired -1) because the first position itself is used
			if (pos + unitsRequired -1) &gt; wagonClass.getLenInUnits then
				app.raiseCMException(Wagon_Cargo_Overhang, null, null);
				return;
			endif;
			
			
		
		elseif wagonClass.isWellcar then
			wellDef := wagonClass.getWellAtPosition(_position, wellPos);
			if wellDef = null or wellPos = 0 then
				//position not found
				app.raiseCMException1(Cannot_over, _ti.id, null, _ti);
				return;
			endif;
			if (wellPos + unitsRequired -1) &gt; wellDef.lenInUnits then
				// would be astride the articulation point 
				app.raiseCMException1(Cannot_over, _ti.id, null, _ti);
				return;
			endif;
		endif;
		
		if wagonClass.isBoxcar then	//03 Aug 2015	NDL	- Found in during testing	Test 01-381
			//wasn't allowing multiple cargo items in a boxcar from thin client pre-note add from wagon maint.
		else
			foreach tiWagonPos in self.allWagonPositions do
				if tiWagonPos.position = pos then
					if ( tiWagonPos.allTrackedItems.size + 1 ) &gt; wagonClass.maxNumInStack then
						app.raiseCMException1(Wagon_invalid_cargo_position,pos.String, null, null);
						return;
					endif;
				endif;
			endforeach;
		endif;
	
	endif;
	
	foreach idx in 1 to unitsRequired  do
	
		create tiWagonPos transient;
		self.allWagonPositions.add(tiWagonPos);
		
		if pos = _position then
			// only set the ti on the first controller as the move code
			// finds the secondary location to move ti to
			// else we just set the twist locks for the secondary controllers
		//	tiWagonPos.myTrackedItem := _ti;
			if _ti &lt;&gt; null then	//14 Oct 2014	NDL	Par 35040
				tiWagonPos.allTrackedItems.addExclusive(_ti);
			endif;
		endif;
		
		// set the id on all controllers thi s TI covers
	//	tiWagonPos.trackedItemId := _ti.id;
		tiWagonPos.myRailLine := _wagon.myRailLine;

		// this relates to the order of the containers from left to right
		tiWagonPos.position := pos;
		// if there is a container then it must have twistlocks
		tiWagonPos.available := true;
		tiWagonPos.hasTwistLocks := true;
		// container locked
		tiWagonPos.twistLocksAreUp := (idx = 1 or idx = unitsRequired);
		pos := pos + 1; 
	endforeach;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_position" type="Integer"/>
        <Parameter name="_wagon" type="CM_Wagon" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addTrackedItem" id="555ad5b6-ded6-41fd-9860-e2b33c834547">
        <source>addTrackedItem(_cargoType : CM_CargoBOLType; _isoType, _tiId : String) : CM_TrackedItem protected;
// -------------------------------------------
// Created 22 October 2003 by cnwdvb1
// -------------------------------------------
vars
	proxyTI,
	ti,
	cloneTI			: CM_TrackedItem;
	tiId,
	proxyTIID		: String;
	loadState		: Boolean;
	class			: Class;
	terminal		: CM_Terminal;
begin

	terminal := app.getMyTerminalDO_NOT_USE();
	tiId 		:= _tiId.toUpper.trimBlanks();

	if _cargoType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(CM_Cargo_Type), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(CM_Cargo_Type), null, null); // cnwdb2	PAR 35364
		return null;
	endif;
		
	if tiId = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Cargo_ID), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Cargo_ID), null, null); // cnwdb2	PAR 35364
		return null;
	endif;	

	foreach ti in self.allTrackedItems do
		if ti.id = tiId then
			app.raiseCMException3(ERR_TI_ONSITE, _cargoType.description, tiId, terminal.code, null, null);		
			return null;
		endif;
	endforeach;
	ti := null;		
	app.cmsBeginLoad(loadState);

	// DVB 30/07/04 Add inter terminal transfer code.
	ti := terminal.lookupTrackedItem(tiId, _cargoType.id, TI_STATE_TRANSFER, null, true);
	if ti &lt;&gt; null then
		cloneTI := ti.getCloneForInterTerminalMove2(terminal, true);
		proxyTI := cloneTI;
	else
		// Is it a prenote ti that already exists.
		ti := terminal.allNotifiedTIsByCargoTypeId[_cargoType.id, tiId];
	endif;
	
	// We don't want ti to be already on site.
	if terminal.allOnsiteTIsByCargoTypeId[_cargoType.id, tiId] &lt;&gt; null then
		app.raiseCMException1(ERR_TI_ONSITE, tiId, null, null);
		app.raiseCMException1(ERR_ADDING_TI, tiId, null, null);
		return null;
	endif;
	
	// What type of ti are we thinking of creating.
	if _cargoType.isKindOf(CM_CargoType) then
		class := _cargoType.CM_CargoType.myClassToCreate;
	else
		class := _cargoType.class;
	endif;
				
	// Create new ti.
	if ti = null then									
		create proxyTI as class transient;
		proxyTI.setPxyFromDefaultTI(terminal, _cargoType.id, tiId, null, null); 
//	PAR 16031	
//		self.checkISOType(proxyTI, _cargoType.id,_isoType);
		proxyTI.changeISOType(_isoType, null,  app.myPassport); 		// this changes the length of the TI not just its ISO string	
	else
		// Just get the pre note proxy.
		// Could be inter terminal clone from above.
		if proxyTI = null then
		// Get proxy of this ti.
		// Par 10426
		//	proxyTi := ti.pxyCreateUpdateProxy();	
			proxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
		endif;
		self.checkISOType(proxyTI, _cargoType.id,_isoType);
	endif;
		
	self.allTrackedItems.add(proxyTI);
	return proxyTI;
	
epilog
	app.cmsEndLoad(loadState);
end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_tiId" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="autoSetEffectiveTimeStamp" id="d91b9c4c-7d65-4e1f-9c00-fce8d0a1a233">
        <updating/>
        <source>autoSetEffectiveTimeStamp() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 February 2021	navndl1	Initial creation	TFS 50837

*/

constants
	RailOpsFormName : String = "YRD_RailOperationsForm";
vars

	activeForm : Form;
	railOpsForm : Form;
	ts : TimeStamp;
	
begin

	if self.effectiveTimeStamp.isValid then
		//don't clobber what has already been set.
		return;
	endif;

	if app.applicationType = app.ApplicationType_GUI then
		activeForm := app.activeForm();
		if activeForm &lt;&gt; null then
			if activeForm.name = RailOpsFormName then
				railOpsForm := activeForm;
			else
				railOpsForm := activeForm.getMyParentNamed( RailOpsFormName );
			endif;
		endif;
	endif;
	
	if railOpsForm &lt;&gt; null then
		railOpsForm.sendMsgWithIOParams("getRetrospectiveTS",ts);
		self.setEffectiveTimeStampOverride( ts );
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildWagonPositionForTI" id="dce843e0-2982-4fd3-b298-5e2c3ae677fe">
        <updating/>
        <source>buildWagonPositionForTI(_ti : CM_TrackedItem; _position : Integer; _railLine : CM_RailLine) updating;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  ---------------
// 21/08/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
//-----------------------------------------
vars
	is40		: Boolean;
	idx, pos,
	unitsRequired : Integer;
	tiWagonPos	: CMIF_TIWagonPosition;		
	tmpArray	: CMIF_TIWagonPositionArray;
begin

	// create CMIF_TIWagonPositions, one for each wagon controller
	// this works out from the bottom row of container what controllers belong to what positions
	// it uses a Point which allows 2 integers to be grouped together in an array
	// the first number (x) is the starting position inthe controller array and the second number (y) is how many controllers, which is basically the length in units
	// use the position on the screen to pin point the controllers that this container is on
	// this allows us to use the position and height on the screen to stack the containers

	if _position = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Position), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Position), null, null); // cnwdb2	PAR 35364
		return;
	endif;

	if _ti = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(CargoItem_Name), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(CargoItem_Name), null, null); // cnwdb2	PAR 35364
		return;
	endif;	
	
	
	unitsRequired := _ti.getLengthInUnits().Integer;
	if _ti.isAttributeTrue(TI_Attrib_IsThirty) then
	unitsRequired := 3;
	endif;
	pos := _position;

	// if its a forty footer then add to the bottom of stack	
	is40 := (_ti.sizeAttributes.bitAnd(ISO_LEN_40) &gt; 0 or _ti.sizeAttributes.bitAnd(ISO_LEN_45) &gt; 0);
	
	foreach idx in 1 to unitsRequired  do
		create tiWagonPos transient;
		if is40 then
			self.allWagonPositions.insert(idx,tiWagonPos);		
		else
			self.allWagonPositions.add(tiWagonPos);
		endif;
		
		if pos = _position then
			// only set the ti on the first controller as the move code
			// finds the secondary location to move ti to
			// else we just set the twist locks for the secondary controllers
			//tiWagonPos.myTrackedItem := _ti;
			if _ti &lt;&gt; null then	//14 Oct 2014	NDL	Par 35040
				tiWagonPos.allTrackedItems.addExclusive(_ti);
			endif;
		endif;
		
		// set the id on all controllers
//		tiWagonPos.trackedItemId := _ti.id;
		tiWagonPos.myRailLine := _railLine;

		// this relates to the order of the containers from left to right
		tiWagonPos.position := pos;
		// if there is a container then it must have twistlocks
		tiWagonPos.available := true;
		tiWagonPos.hasTwistLocks := true;
		// container locked
		tiWagonPos.twistLocksAreUp := (idx = 1 or idx = unitsRequired);
		pos := pos + 1; 
	endforeach;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_position" type="Integer"/>
        <Parameter name="_railLine" type="CM_RailLine"/>
    </JadeMethod>
    <JadeMethod name="canAddAnotherContainer" id="81710968-4255-4a5c-a6f1-2a8f4551e638">
        <source>canAddAnotherContainer(_wagon : CM_Wagon; _wagonNumber : String; _ti : CM_TrackedItem) : Integer protected;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	wagonClassUnits,
	unitsUsed 			: Integer;
	ti					: CM_TrackedItem;
	newPos,
	maxHeight,
	level				: Integer;
	iter				: Iterator;
	isOverLimit			: Boolean;

begin

	wagonClassUnits := self.myWagonClass.getLenInUnits;
	maxHeight		:= self.myWagonClass.maxNumInStack;
	level			:= 1;

	// Where can we put this sucker.	
	iter := self.allTrackedItems.createIterator();
	// Go for as many high or until we find a spot.
	while level &lt;= maxHeight do
		isOverLimit := false;
		while iter.next(ti) do
			if ti = _ti then
				// This is our ti. Where are we up to.
				newPos := unitsUsed;
			endif;
			// Get how many 10 foot units are covered.
			unitsUsed := unitsUsed + ti.getLengthInUnits().Integer;
			// Have we exceeded the space at this level.
			if wagonClassUnits &lt; unitsUsed then
				// We want iterator to continue but one level up.
				// Reset unitsUsed for next level.
				unitsUsed := 0;
				// We want to try current ti again.
				iter.back(ti);
				isOverLimit := true;
				break;
			endif;
		endwhile;
		// Increment the level.
		level := level + 1;
		// Have we got this far without exceeding space.
		if not isOverLimit then
			break;
		endif;
	endwhile;
	
	if (wagonClassUnits &lt; unitsUsed) or isOverLimit then
		return 0;
	endif;
	
	return newPos + 1;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_wagonNumber" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="checkISOType" id="3b26a111-403c-4e08-b670-33a546b520ce">
        <source>checkISOType(_ti : CM_TrackedItem; _cargoType : Integer; _isoType : String) protected;
// -------------------------------------------
// Created 06 April 2004 by cnwdvb1
// -------------------------------------------
vars

	container	: CM_Container;
	theIso		: CM_ISOType;

begin

	// Par 8032 DVB 06/04/04
	if not _ti.isTransient then
		app.raiseCMException1(NotAProxyObject,	app.getErrorString(Cargo) &amp; class.name &amp; ' ' &amp; method.name, null, null);
		return;
	endif;
	if _ti.isKindOf(CM_Container) then
		container := _ti.CM_Container;
		if container.isoType &lt;&gt; _isoType then
			if container.myCargoType.id &lt;&gt; _cargoType then
				app.raiseCMException2(CargoTypeDoesNotMatchIsoType,_cargoType.String, _isoType, null, null);
				return;
			endif;
			container.zSetPxyISOType(_isoType);
		endif;
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_isoType" type="String"/>
    </JadeMethod>
    <JadeMethod name="doAddCargoItem" id="a92f3731-506a-4d5a-b1ca-70bf0f879c19">
        <updating/>
        <source>doAddCargoItem(	_wagon 					: CM_Wagon;
				_wagonId,
				_tiId					: String;
				_cargoType				: CM_CargoBOLType;
				_isoType				: String;
				_railLine				: CM_RailLine) updating;

vars
	pos				: Integer;
	posStr			: String;
	ti				: CM_TrackedItem;
	theController	: CM_WagonController;
	proxyTi			: CM_TrackedItem;

begin

	// If we have a wagon can we find the specified ti on it.
	if _wagon &lt;&gt; null then
		ti := _wagon.findTi(_tiId);
	endif;

	if ti = null then
		// We don't have a ti so we want to create one.
		ti := self.addTrackedItem(_cargoType, _isoType, _tiId);
		// Will it fit on the wagon.
		pos := self.canAddAnotherContainer(_wagon, _wagonId, ti); 
	else
		// We have a ti. Where is it on the wagon.
		theController := ti.getPrimaryLocation(REAL_MODE).CM_WagonController;
		if theController.myWagon = _wagon  then
			pos := _wagon.allLocationsControllersArray.indexOf(theController);										 	
		endif;
		
		// Get proxy of this ti.
		// Par 10426
		//	proxyTi := ti.pxyCreateUpdateProxy();	
		proxyTi := app.createUpdateProxy(ti).CM_TrackedItem;

//	PAR 16031	
//		self.checkISOType(proxyTi, _cargoType.id, _isoType);
		proxyTi.changeISOType(_isoType, null,  app.myPassport); 		// this changes the length of the TI not just its ISO string	
		self.allTrackedItems.add(proxyTi);
		ti := proxyTi;
	endif;
	
	// We don't have a position so stop.
	if pos = 0 then
		app.raiseCMException1(ERR_TOO_MUCH_ON_WAGON, '',null, null);
		return;
	endif;

	// Everything is fine so create cmif position objects for trx.	
	if app.myPassport.noErrors() then
		self.buildWagonPositionForTI(ti, pos, _railLine);
	endif;			
end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_wagonId" type="String"/>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_railLine" type="CM_RailLine"/>
    </JadeMethod>
    <JadeMethod name="hasWagonPositionForPos" id="c3fe1c8a-18c9-47c1-a97b-bab3d01c6111">
        <source>hasWagonPositionForPos( _pos : Integer ):Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwndl1	Initial creation

*/

vars
	wagonPosition : CMIF_TIWagonPosition;
begin
	foreach wagonPosition in self.allWagonPositions do
		if wagonPosition.position = _pos then
			return true;
			break;
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pos" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateFromExistingWagonAddTi" id="a96fe0a1-177e-4719-8175-656af81c5240">
        <updating/>
        <source>populateFromExistingWagonAddTi( _realWagon : CM_Wagon;
								_selectedTi : CM_TrackedItem;
								_selectedPosition : Integer
								) updating;

/*

Purpose:			
		Setup the controller with the specific details related to the wagon.
		If a selected ti and position have been supplied, set up the new wagon position too
Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwndl1	Initial creation CCMS 1094

*/

vars

	currentTIs : CM_TIArray;
	currentTI : CM_TrackedItem;
	locationCtrller : CM_WagonController;
	tiWagonPos : CMIF_TIWagonPosition;
	selectedTi : CM_TrackedItem;
	wagon : CM_Wagon;
	
begin

	if _realWagon = null then
		return;
	endif;
	
	create currentTIs transient;
	_realWagon.getAllTrackedItems(true, currentTIs, false);//Add all current TI's (so they are not removed) Have to use inward and unconfirmed to ensure 
															// we get all....
	currentTIs.copy(self.allTrackedItems);
	
	//** Add existing items to wagonPositions
	foreach currentTI in currentTIs do
		if self.mode = self.Mode_Update then
			if _selectedTi &lt;&gt; null and _selectedTi = currentTI then
				continue;
			endif;
		endif;
		
		locationCtrller := _realWagon.getLocationControllerForTI(currentTI).CM_WagonController;
		if locationCtrller = null then
			continue;
		endif;
		create tiWagonPos transient;
		//tiWagonPos.myTrackedItem := currentTI;
		tiWagonPos.allTrackedItems.addExclusive( currentTI );
		
//		tiWagonPos.trackedItemId := currentTI.id;
		tiWagonPos.myRailLine := self.myRailLine;

		// this relates to the order of the containers from left to right
		tiWagonPos.position := _realWagon.allLocationsControllersArray.indexOf(locationCtrller);
		tiWagonPos.available := locationCtrller.isAvailable;
		tiWagonPos.hasTwistLocks := locationCtrller.hasTwistlocks;
		tiWagonPos.twistLocksAreUp := locationCtrller.twistlocksAreUp;
		self.allWagonPositions.add(tiWagonPos);
		
	endforeach;
	
	if _selectedTi &lt;&gt; null and _selectedPosition &gt; 0 then
		selectedTi := _selectedTi;
		wagon := _realWagon;
		self.addTiToWagonAtPosition(selectedTi, _selectedPosition, wagon);
		self.allTrackedItems.add(selectedTi);
	endif;
	
	self.setEmptyWagonPositionsByWagon(_realWagon);
	
epilog

	delete currentTIs;
	
end;</source>
        <Parameter name="_realWagon" type="CM_Wagon"/>
        <Parameter name="_selectedTi" type="CM_TrackedItem"/>
        <Parameter name="_selectedPosition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeTrackedItem" id="ff5091a1-8a94-4089-9f1d-bd92e30b1fd7">
        <updating/>
        <source>removeTrackedItem( _ti : CM_TrackedItem; _realWagon : CM_Wagon ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwndl1	Initial creation

*/

vars
	tiWagonPos : CMIF_TIWagonPosition;
	pos : Integer;
begin

	if _ti = null then
		return;
	endif;
	
	foreach pos in 1 to self.allWagonPositions.size reversed do
	
		tiWagonPos := self.allWagonPositions[pos];
	//	if tiWagonPos.myTrackedItem &lt;&gt; _ti then
	//		continue;
	//	endif;
		//14 Oct 2014	NDL	Par 35040
		if not tiWagonPos.allTrackedItems.includes( _ti ) then
			continue;
		endif;
		
		//14 Oct 2014	NDL	Par 35040
		if tiWagonPos.allTrackedItems.size &gt; 1 then 
			tiWagonPos.allTrackedItems.remove( _ti );
		else
			self.allWagonPositions.remove(tiWagonPos);
			delete tiWagonPos;
		endif;
		
		if self.allTrackedItems.includes(_ti) then
			self.allTrackedItems.remove(_ti);
		endif;
	endforeach;
	
	self.setEmptyWagonPositionsByWagon(_realWagon);
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_realWagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="setBasicDetails" id="6f8dcb3e-5361-4413-b344-643035b848ba">
        <updating/>
        <source>setBasicDetails(	_mode : Integer;
					_rake : CM_RailLine;
					_train : CM_Train;
					_wagonPosition : Integer;
					_trainMode : Boolean
					) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwndl1	Initial creation

*/

vars

	form : Form;

begin

	self.mode := _mode;
	self.myRailLine	:= _rake;
	self.wagonPosition := _wagonPosition;
	self.myTrain := _train;
	self.isTrainMode := _trainMode;
	
	self.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 50837
	
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_rake" type="CM_RailLine"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wagonPosition" type="Integer"/>
        <Parameter name="_trainMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setEffectiveTimeStampOverride" id="f82802d7-f71b-46c5-ac26-877cc3301f6c">
        <updating/>
        <source>setEffectiveTimeStampOverride(newTS : TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2021	navndl1	Initial creation	TFS 50837

*/

vars

begin

	self.effectiveTimeStamp := newTS;

epilog

end;</source>
        <Parameter name="newTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setEmptyWagonPositions" id="96acc0d1-b441-4728-bd32-6106f77d70c3">
        <updating/>
        <source>setEmptyWagonPositions(_railLine : CM_RailLine) updating;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------
vars
	wagonLength,
	pos : Integer;
	found : Boolean;
	wagonPos : CMIF_TIWagonPosition;
begin
	if self.myWagonClass = null then
		return;
	endif;
	
	wagonLength := self.myWagonClass.getLenInUnits;
	
	foreach pos in 1 to wagonLength do
		found := false;
		foreach wagonPos in self.allWagonPositions do
			if wagonPos.position = pos then
				found := true;
				break;
			endif;
		endforeach;
		
		if found then
			continue;
		endif;
		
		create wagonPos transient;
		self.allWagonPositions.add(wagonPos);
		wagonPos.myRailLine := _railLine;
		wagonPos.position := pos;
		wagonPos.available := true;
		wagonPos.hasTwistLocks := true;
		wagonPos.twistLocksAreUp := false;
	endforeach;
end;</source>
        <Parameter name="_railLine" type="CM_RailLine"/>
    </JadeMethod>
    <JadeMethod name="setEmptyWagonPositionsByWagon" id="9f8dc3c9-14f9-4810-b363-5a973d99dcc1">
        <updating/>
        <source>setEmptyWagonPositionsByWagon( _wagon : CM_Wagon) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2009	cnwndl1	Initial creation

*/

vars

	wagonLength,
	pos : Integer;
	wagonPosition : CMIF_TIWagonPosition;
	wagonClass : CM_WagonClass;
	
begin
	if _wagon = null then
		return;
	endif;

	wagonClass := _wagon.myWagonClass;
	if wagonClass = null then
		return;
	endif;
	
	wagonLength := wagonClass.getLenInUnits;

	foreach pos in 1 to wagonLength do
	
		if hasWagonPositionForPos(pos) then
			continue;
		endif;
		
		create wagonPosition transient;
		self.allWagonPositions.add(wagonPosition);
		wagonPosition.myRailLine := _wagon.myRailLine;
		wagonPosition.position := pos;
		wagonPosition.available := _wagon.allLocationsControllersArray[pos].isAvailable;
		wagonPosition.hasTwistLocks := _wagon.allLocationsControllersArray[pos].hasTwistlocks; 
		wagonPosition.twistLocksAreUp := _wagon.allLocationsControllersArray[pos].twistlocksAreUp;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="validate" id="0a45b7be-b737-497b-89d6-67e00b9b02fa">
        <source>validate(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 05 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	ti : CM_TrackedItem;
	updController	: CMIF_TIUpdateController;	
	realWagon, otherWagon : CM_Wagon;
	term : CM_Terminal;
	tmpTrain : CM_Train;
begin
	/* //+ cnwmd1, CCMS 1067, Par 19913 - Moved to CM_Wagon::validateMe
	if self.myTrain = null then
		app.raiseCMException2(ERROR_NO_TRAIN,self.myProxyWagon.id, null, null,self);
		return;
	endif;*/

	
	if self.myProxyWagon = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Proxy) &amp; " " &amp; app.getErrorString(Wagon_null) );
		return;
	endif;	

	if not self.isTrainMode then // PAR 19710
		if self.myRailLine = null then
			app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Railway_line_null));
			return;
		endif;
		
		
		if self.myRailLine.myRailArea.myTerminal &lt;&gt; self.myProxyWagon.myTerminal then
			app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Wagon_terminal_not_rail) );
			return;
		endif;
		
		if self.wagonPosition &gt; self.myRailLine.maximumWagons then
			app.raiseCMException2(ERR_KEY_NOT_FOUND, self.wagonPosition.String, app.getErrorString1(Rail_line_positi_rail_area, self.myRailLine.id ), null, null);
		endif;
	endif;
	
	if self.mode = Mode_Update then
		self.myProxyWagon.raiseExceptionIfNotProxy(method);
		self.myProxyWagon.validateForUpdate;
	endif;
	
	if self.mode = Mode_Add then
	
		/* //- cnwmd1, CCMS 1067, Par 19913 - moved to CM_Wagon::validateForCreate
		// PAR 19710
		if self.myTrain.allWagonsByIdInward[self.myProxyWagon.id] &lt;&gt; null then
			app.raiseCMException2(Wagon_with_alread_exists_train, self.myProxyWagon.id, self.myTrain.code, null, null);
		endif;
		*/
		
		self.myProxyWagon.validateForCreate;
		
		if self.myRailLine &lt;&gt; null then
			otherWagon := self.myRailLine.allWagonsById[self.myProxyWagon.id];
			if otherWagon &lt;&gt; null then
				app.raiseCMException2(Wagon_with_code_alrea_exist_ra,self.myProxyWagon.id, self.myRailLine.getFullId(),  null, null);
				return;
	
			endif;
		endif;
		
		// PAR 26429
		if self.confirmWagonInwards and self.myRailLine = null then
			app.raiseCMException1(Cannot_Confirm_In_No_Rake_Spec, myProxyWagon.id, null, null);
			
		endif;
 	endif;

	realWagon := myProxyWagon.pxyGetRealObject;

	if realWagon &lt;&gt; null then
	
		// PAR 21182
		if realWagon.myTerminalDeparted &lt;&gt; null then // DEPARTED
			if self.myRailLine &lt;&gt; null then // trying to confirm onto the rake!
				app.raiseCMException2(Wagon_depart_cannot_confir_rak, realWagon.id, self.myRailLine.getDisplayDetails(false), null, null);
			endif;
		endif;
		// PAR 21182
		tmpTrain := myProxyWagon.myTrainInwards;
		if  tmpTrain &lt;&gt; null then
			otherWagon := tmpTrain.allWagonsByIdInward[realWagon.id];
			if otherWagon &lt;&gt; null and otherWagon &lt;&gt; realWagon then
				app.raiseCMException2(INWARD_WAG_ALREADY_EXISTS, realWagon.id,tmpTrain.code, null, null);
			endif;
		endif;
		// PAR 21182
		if myProxyWagon.myTrainOutwards &lt;&gt; tmpTrain then
			tmpTrain := myProxyWagon.myTrainOutwards;
			if  tmpTrain &lt;&gt; null then
				otherWagon :=  tmpTrain.allWagonsByIdOutward[realWagon.id];
				if otherWagon &lt;&gt; null and otherWagon &lt;&gt; realWagon then
					app.raiseCMException2(OUTWARD_WAG_ALREADY_EXISTS, realWagon.id,tmpTrain.code, null, null);
				endif;
			endif;
		endif;
	
	
		if self.confirmWagonInwards and self.myRailLine = null then
			app.raiseCMException1(Cannot_Confirm_In_No_Rake_Spec, realWagon.id, null, realWagon);
			
		endif;
		if not self.isTrainMode then // PAR 19710
			if realWagon.myRailLine &lt;&gt; null then
				if realWagon.myRailLine &lt;&gt; self.myRailLine then
					app.raiseCMWarning3(WARN_WAGON_RAILLINE, self.myProxyWagon.id, realWagon.myRailLine.id,
							self.myRailLine.id, null, null, realWagon);
				endif;
				
				
			else // PAR 19710
				// Trying to confirm without a rail line!
				if self.myProxyWagon.confirmed &lt;&gt; realWagon.confirmed then 
					app.raiseCMException1(Canno_confi_they_have_been_ass, realWagon.id, null, null);
				endif;
			endif;
		endif;
	endif;
	
	if self.confirmWagonInwards then
		if realWagon = null or (realWagon &lt;&gt; null and not realWagon.confirmed) then
			app.raiseCMWarning1(CONFIRM_WAGON_CONFIRM, self.myProxyWagon.id, ETRow_ConfirmInward, null, realWagon);
		endif;
	elseif self.unconfirmWagonInwards and realWagon &lt;&gt; null and realWagon.confirmed then
		app.raiseCMWarning(Unconfirm_warning, ETRow_ConfirmInward, null, realWagon);
		
	endif;
	
	updController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	term := _passport.myTerminal;
	
	foreach ti in self.allTrackedItems do
		/*
		//th2 - they may be unconfirming the wagon - at any rate if the TIs are already onsite this 
		//will be caught in the move code IF they are even going to be moved
		if (not self.ignoreTIsAlreadyOnsite) then
			if term.allOnsiteTIsByCargoTypeId[ti.cargoType, ti.id.trimBlanks] &lt;&gt; null then
				app.raiseCMException1(ERR_TI_ONSITE, ti.id, null, null);
			endif;
		endif;
		*/
		
		//+cnwml2 PAR26452
		if ti.checkNotRecvdForInwardsWagon(realWagon) and self.confirmWagonInwards then		// 07/12/2010 cnwmh5 #26452
			app.raiseCMException1(ERR_Cargo_Received, ti.id, null, null);
		endif;
	
		ti.validateTrackedItem(updController, _passport);
	endforeach;	
	
epilog
	delete updController;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
