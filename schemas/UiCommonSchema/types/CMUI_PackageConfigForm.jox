    <JadeMethod name="getDisplayForFileType" id="b7962b8f-741e-46d6-9729-c9dfbf1f8cae">
        <source>getDisplayForFileType(_value :Integer):String protected;
/*
Date		Who		Reason
27/03/2012	cnwcs5	Initial creation - CCMS POL 2144 / Par 29312 - Extract Baplie by Operator
20/05/2016	cnwdap1	TFS #1881 BAPLIE/EDI VGM Updates
*/
vars

begin
	if _value = EDIFileType_Baplie15 then
		return CMUI_EDIDBExtract.EDI_FORMAT_BAPLIE_15;
	elseif _value = EDIFileType_Baplie20 then
		return CMUI_EDIDBExtract.EDI_FORMAT_BAPLIE_20;
	elseif _value = EDIFileType_Baplie22 then						// TFS #1881
		return CMUI_EDIDBExtract.EDI_FORMAT_BAPLIE_22;				// TFS #1881
	elseif _value = EDIFileType_VSLStow then
		return CMUI_EDIDBExtract.EDI_FORMAT_STOW_ADVICE;
	elseif _value = EDIFileType_BayFile then
		return CMUI_EDIDBExtract.EDI_FORMAT_MASTER_PLAN;
	elseif _value = EDIFileType_Anf then
		return CMUI_EDIDBExtract.EDI_FORMAT_ANF;
	elseif _value = EDIFileType_XML_TOLL_PREADVICE then
		return CMUI_EDIDBExtract.EDI_FORMAT_XML_TOLLNZ;
	elseif _value = EDIFileType_CSVWWL then
		return CMUI_EDIDBExtract.EDI_FORMAT_CSV_WWL;
	elseif _value = EDIFileType_XML_Celina then
		return CMUI_EDIDBExtract.EDI_FORMAT_XML_CELINA;
	elseif _value = EDIFileType_WWLCar then
		return CMUI_EDIDBExtract.EDI_FORMAT_WWL;
	elseif _value = EDIFileType_Coprar then 
		return CMUI_EDIDBExtract.EDI_FORMAT_COPRAR;
	elseif _value = EDIFileType_Movins then 
		return CMUI_EDIDBExtract.EDI_FORMAT_MOVINS;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayForPackageType" id="af032ae2-8452-425b-b6fe-534b4892cf29">
