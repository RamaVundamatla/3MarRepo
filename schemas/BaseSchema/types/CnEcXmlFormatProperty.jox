    <JadeMethod name="handleXMLException" id="5b04b28d-b4d1-4277-ac0b-5afa8a0cae7a">
        <source>handleXMLException(pException : CnEcBaseXmlException; pErrorMsg : String io) : Integer;

begin
	pErrorMsg := pException.errorItem;
	return Ex_Resume_Next;
end;</source>
        <Parameter name="pException" type="CnEcBaseXmlException"/>
        <Parameter name="pErrorMsg" type="String" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="07318c2d-705b-48e7-ab75-2b47170d1cd4">
        <updating/>
        <source>initializeMe(pName:String; pTagName : String; pIsShowTagData : Boolean; pFormatClass : CnEcXmlFormatClass) updating;

begin
	self.propertyName 	:= pName;
	self.tagName		:= pTagName;

	self.isShowTagData	:= pIsShowTagData;

	self.myFormatClass	:= pFormatClass;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pTagName" type="String"/>
        <Parameter name="pIsShowTagData" type="Boolean"/>
        <Parameter name="pFormatClass" type="CnEcXmlFormatClass"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="ac190c86-d24d-46a9-90ec-99921c40060d">
        <updating/>
        <source>updateMe(pTagName : String; pIsShowTagData : Boolean) updating;

begin
	if self.tagName	&lt;&gt; pTagName then
		self.tagName	:= pTagName;
	endif;
	
	if self.isShowTagData &lt;&gt; pIsShowTagData then
		self.isShowTagData	:= pIsShowTagData;
	endif;

end;</source>
        <Parameter name="pTagName" type="String"/>
        <Parameter name="pIsShowTagData" type="Boolean"/>
    </JadeMethod>
