    <JadeMethod name="getBoardFeetAmount" id="d7fea779-e372-4818-a041-baca0799f7c7">
        <source>getBoardFeetAmount(): Decimal;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 22 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	heightInch 	: Decimal[23,4];
	lengthFeet 	: Decimal[23,4];
	widthInch 	: Decimal[23,4];
	boardFeet	: Decimal[23,4];
begin
	heightInch 	:= self.height / 2.54;
	widthInch 	:= self.width / 2.54;
	lengthFeet 	:= self.length / 30.48;
	
	boardFeet := (heightInch * widthInch * lengthFeet) / 12;
	
	if self.quantity &gt; 0 then
		boardFeet := boardFeet * self.quantity;
	endif;
	
	if self.totalQuantity &gt; 0 then
		boardFeet := boardFeet * self.totalQuantity;
	endif;
	
	return boardFeet;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getBulkBreakBulkOverSupply" id="b0581eaa-cb81-4147-95a6-e65b59ab2c31">
        <source>getBulkBreakBulkOverSupply(_qty: Integer output; _weight: Decimal output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2017	jlgndl1	Initial creation	TFS 5701

*/

vars

	trans : CM_TITransaction;
	qty : Integer;
	weight : Decimal [16,3];
	total : Integer;

begin
	
	
	foreach trans in self.allTransactions reversed where trans.type = TRANS_TYPE_BREAKBULK_OVERAGE  do
		if trans &lt;&gt; null then
			if trans.CM_BBDiscrepancy.quantityChange &gt; 0 then
				qty := trans.CM_BBDiscrepancy.quantityChange;
				weight := trans.CM_BBDiscrepancy.weightChange;
				_qty := _qty + qty;
				_weight := _weight + weight;
			endif;
		endif;
	endforeach;
	
	return _qty &gt; 0 or _weight &gt; 0;

epilog

end;</source>
        <Parameter name="_qty" type="Integer" usage="output"/>
        <Parameter name="_weight" type="Decimal" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBulkBreakBulkUnderSupply" id="d4fa1a1f-a672-4dfe-9ca0-88bca1fa05a3">
        <source>getBulkBreakBulkUnderSupply(_qty: Integer output; _weight: Decimal output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2017	jlgndl1	Initial creation	TFS 5701

*/

vars

	trans : CM_TITransaction;
	qty : Integer;
	weight : Decimal [16,3];
	total : Integer;

begin
	
	
	foreach trans in self.allTransactions reversed where trans.type = TRANS_TYPE_BREAKBULK_OVERAGE  do
		if trans &lt;&gt; null then
			if trans.CM_BBDiscrepancy.quantityChange &lt; 0 then
				qty := trans.CM_BBDiscrepancy.quantityChange * -1;
				weight := trans.CM_BBDiscrepancy.weightChange * -1;
				_qty := _qty + qty;
				_weight := _weight + weight;
			endif;
		endif;
	endforeach;
	
	return _qty &gt; 0 or _weight &gt; 0;

epilog

end;</source>
        <Parameter name="_qty" type="Integer" usage="output"/>
        <Parameter name="_weight" type="Decimal" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getChargeQuantity" id="bf123d10-15a3-42fa-ac2e-b5cdadb10f04">
        <source>getChargeQuantity() : Real;
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 07/09/2015	cnwdap1		PAR #36751 Only charge for the actual quantity moved
vars
	mergeSplit : CM_TITransaction;					// PAR #36751

begin
	if self.getAndUseMergeSplitQVW(mergeSplit) then													// PAR #36751
		if mergeSplit.isKindOf(CM_Merge) then														// PAR #36751
			return mergeSplit.CM_Merge.totalQuantity.max(mergeSplit.CM_Merge.totalQuantity * -1);	// PAR #36751
		elseif mergeSplit.isKindOf(CM_Split) then													// PAR #36751
			return mergeSplit.CM_Split.totalQuantity.max(mergeSplit.CM_Split.totalQuantity * -1);	// PAR #36751
		endif;																						// PAR #36751
	endif;																							// PAR #36751

	return self.totalQuantity;				// PAR #36751

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDaysOnsiteForPeriod" id="f9271aaa-f9ad-4c0c-8ed3-5b577549a82e">
        <source>getDaysOnsiteForPeriod(_startDate,
							_endDate : Date) :Integer;
// ---------------------------------------------------------------------------
// Created:     12 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	chargableDays,
	daysOnsiteForPeriod,
	daysOnSite			: Integer;
	theReleaseDate,
	today,
	chargeEndDate,
	chargeStartDate,
	freePeriodEnded		: Date;
	trans				: CM_TITransaction;
begin
	today := app.actualTimeServer.date;
	
	if _startDate &gt; _endDate then
		return null;
	endif;
	//take 1 away from the freePeriodEnded because this should reflect that the TI has been onsite for
	//one day on the day it arrives.
	freePeriodEnded := (self.receivedDT.date + self.getFreeStorageDays) - 1;
	//only calculate the storage charge for the dates passed in, not the entire time onsite
	if freePeriodEnded &lt;= _startDate then
		chargeStartDate := _startDate;
	else
		chargeStartDate := freePeriodEnded;
	endif;  
	
	if chargeStartDate &gt;= _endDate then
		return null;
	endif; 
	//don't exceed the present when getting the chargeEndDate, and allow for the fact
	//that the TI may have been loaded out within the query date range, and MAY still need a charge
	
	theReleaseDate := self.getBOLReleaseDate;
	if theReleaseDate &lt;&gt; null then
		if theReleaseDate &lt; chargeStartDate then
			return null;
		elseif theReleaseDate &lt; _endDate then //the TI has been loaded out within the date range
			chargeEndDate := theReleaseDate;
		else
			chargeEndDate := _endDate;
		endif;
	else
		//check a few basic things that would halt storage charging 
		if self.myParent &lt;&gt; null then
			//use pack date as end date
			trans := self.getLastTransOfType(TRANS_TYPE_PACK);
			if trans &lt;&gt; null and trans.dateTime.isValid then
				theReleaseDate := trans.dateTime.date;
				if theReleaseDate &lt; chargeStartDate then
					return null;
				elseif theReleaseDate &lt; _endDate then //the TI has been loaded out within the date range
					chargeEndDate := theReleaseDate;
				else
					chargeEndDate := _endDate;
				endif;	
			else
				return null; //parent is being charged
			endif;
		elseif self.site &lt;&gt; TI_SITE_ONSITE then
			//use releaseDT as end date
			theReleaseDate := self.releasedDT.date;
			if (not theReleaseDate.isValid)
			or theReleaseDate &lt; chargeStartDate then
				return null;	
			elseif theReleaseDate &lt; _endDate then //the TI has been loaded out within the date range
				chargeEndDate := theReleaseDate;
			else
				chargeEndDate := _endDate;
			endif;
		else //the TI has not been loaded out
			if _endDate &gt;= today then
				chargeEndDate := today;
			else
				chargeEndDate := _endDate;
			endif;
		endif;
	endif;		
	
	//add 1 to the chargable days because this should reflect that the TI has been onsite for
	//one day on the day it arrives.
	chargableDays := (chargeEndDate - chargeStartDate) + 1;
	
	return chargableDays;

end;</source>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDiameter" id="2be029a0-193e-4bee-b4a8-739168d110a6">
