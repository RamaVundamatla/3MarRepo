    <JadeMethod name="doShowOptions" id="feb2ce31-384f-47a3-b3b1-3d8c32f74da9">
        <final/>
        <updating/>
        <source>doShowOptions() subschemaHidden, final, protected, updating;
/*
------------------------------------------------------------------------
Created:			14 April 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	aForm : CMUI_SysPerfOptions;
	spa : CMUI_SysPerformAgent;
begin
	spa := self.mySysPerformAgent;
	
	create aForm transient;
	
	self.myOptions := aForm;
	
	aForm.chkAvgAbort.value := spa.showAvgAbort;
	aForm.chkAvgBgnNotes.value := spa.showAvgBegnNote;
	aForm.chkAvgCommit.value := spa.showAvgCommit;
	aForm.chkAvgCreates.value := spa.showAvgCreates;
	aForm.chkAvgDeletes.value := spa.showAvgDeletes;
	aForm.chkAvgDlvNotes.value := spa.showAvgDlvNotes;
	aForm.chkAvgEndNotes.value := spa.showAvgEndNotes;
	aForm.chkAvgGetLocks.value := spa.showAvgGetLocks;
	aForm.chkAvgGets.value := spa.showAvgGets;
	aForm.chkAvgLocks.value := spa.showAvgLocks;
	aForm.chkAvgServerExec.value := spa.showAvgServerExec;
	aForm.chkAvgUnlocks.value := spa.showAvgUnlocks;
	aForm.chkAvgUpdates.value := spa.showAvgUpdates;
	aForm.chkNumAvailFat.value := spa.showChkNumAvailFat;
	aForm.chkNumAvailThin.value := spa.showChkNumAvailThin;
	aForm.chkNumThin.value := spa.showChkThin;
	aForm.chkNumProcesses.value := spa.showChkNumProcesses;
	aForm.chkNumProcLic.value := spa.showChkNumProcLic;
	aForm.mskNumToGet.text := spa.numToRetrieve.String;
	if aForm.showModal() = IDOK then
		self.getProcessesDisplay();
	endif;
	
epilog
	delete aForm;
end;</source>
        <access>protected</access>
        <subAccess>hidden</subAccess>
    </JadeMethod>
