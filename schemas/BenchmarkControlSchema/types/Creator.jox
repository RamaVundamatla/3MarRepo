    <JadeMethod name="copyFile" id="b75e6e7a-4569-44e3-86db-dc21d3f18006">
        <updating/>
        <source>copyFile(f,g:File input; upfs:Boolean; s:String) updating;

begin
//	if upfs = true then return; endif;  // avoid copying to m24
	g.fileName:=s;
	g.usePresentationFileSystem:=upfs;
	while not f.endOfFile do
		g.writeBinary(f.readBinary(10000));
	endwhile;
	f.close;
	g.lastModifiedTime:=f.lastModifiedTime;
	g.close;
	//app.logMessage("file created: "&amp;g.fileName);
end;</source>
        <Parameter name="f" type="File" usage="input"/>
        <Parameter name="g" type="File" usage="input"/>
        <Parameter name="upfs" type="Boolean"/>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="966e17dd-b398-4d64-814b-342afb308e95">
        <updating/>
        <source>create() updating;

begin
	computerName:=app.computerName.toLower;
	userCode:=process.getUserCode;
	instanceId:=getInstanceIdForObject(process).Integer;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmd" id="966e6dff-a6c4-49ef-8731-a0d82a6e3bf7">
        <updating/>
        <source>doCmd(cmd,cmdLog:String) updating;

vars
	result:String;
	i,j,retCode:Integer;
begin
	node.createExternalProcess(null,'cmd /c c:\cardinal\bin\datetime'&amp;cmdLog,null,null,true,true,retCode);
	node.createExternalProcess(null,'cmd /c echo '&amp;cmd&amp;cmdLog,null,null,true,true,retCode);
	node.createExternalProcess(null,'cmd /c '&amp;cmd&amp;cmdLog,null,null,true,true,retCode);
	result:=cmd&amp;" retCode="&amp;retCode.String&amp;" "&amp;process.userCode&amp;"@"&amp;process.userInfo;
	node.createExternalProcess(null,'cmd /c c:\cardinal\bin\datetime'&amp;cmdLog,null,null,true,true,retCode);
	app.logMessage(result);
	global.causeEvent(Bmk_Result, true, result);
end;</source>
        <Parameter name="cmd" type="String"/>
        <Parameter name="cmdLog" type="String"/>
    </JadeMethod>
