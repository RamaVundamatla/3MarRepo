    <JadeMethod name="findEDIDataType" id="3ec1aa6b-8ddb-466a-b3b1-8a435ce3e042">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType: Integer io; _fileTypeCode: Integer io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2023	navsp1	Initial creation TFS ChangeRequest 58054: EUP - Manifest Send EDI Endpoint

*/

vars

begin
	_ediDataClass	:= CM_EDIDataTransManifest;
	_dataType		:= EDIDataType_TransportManifest;
	_fileTypeCode	:= self.type;

epilog

end;</source>
