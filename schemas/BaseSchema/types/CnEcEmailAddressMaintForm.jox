    <JadeMethod name="addAddress" id="d9119944-cf6a-4e00-a4a5-53822b302da4">
        <source>addAddress() protected;

vars
	agentObj	: CnEcEmailAgent;
	baseDataObj	: CnEcEmailBaseData;
	addressObj	: CnEcEmailAddress;
	addressName	: String;
	errorMsg	: String;
	
begin
	agentObj	:=	self.aMyEmailSendForm.aMyTA;
	baseDataObj	:=	self.aMyEmailSendForm.aMyEmailBaseData;
	addressName := txtLastName.text &amp; ", " &amp; txtGivenName.text; 
	
	errorMsg	:=	agentObj.trxCnEcEmailAddressCreate(	baseDataObj,	//pCnEcEmailBaseDataParent : CnEcEmailBaseData io;
														txtEmailAddress.text,	//pEmailAddress:String;
														baseDataObj,	//pMyBaseData:CnEcEmailBaseData;
														addressName,	//pName:String;
														addressObj	//pCnEcEmailAddressNew : CnEcEmailAddress output
														);

	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg,"Error",MsgBox_OK_Only);
	else
		txtEmailAddress.text := "";
		txtGivenName.text := "";
		txtLastName.text := "";
		self.setButtons();
	endif;
	
	// clear the fields and ..
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnAdd_click" id="41299d5c-b50b-4ad5-b40e-401e9141e2b2">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdd_click(jadeMask: JadeMask input) updating;

