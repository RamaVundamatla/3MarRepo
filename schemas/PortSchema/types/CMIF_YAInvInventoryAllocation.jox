    <JadeMethod name="isLocnMoveDir_Match" id="2e3c115e-7e84-4c73-a5c8-b9780cb46fc9">
        <source>isLocnMoveDir_Match(_yaData: CM_YADataPattern): Boolean;
/*
Purpose:			

Date		Who		Reason
03JUN2021	NAVAB1	TFS 51219
*/

vars
//	movedir	 : Integer;
	movedirstr : String;
	position : Integer;
begin
	if _yaData.pattern = null then
		return true;
	endif;
	
//	movedir := self.myLocationEvent.getMoveDirection();
//	movedirstr := app.locnMoveDirEnumToString(movedir).toUpper;
// ### TFS 51686	movedirstr := self.myLocationEvent.directionMode;	//13 Jul 2021	NDL	TFS 51528
	movedirstr := self.myLocationEvent.directionMode.toUpper();	 // ### TFS 51686 05AUG2021 NAVAB1
	
	position := _yaData.pattern.pos(movedirstr,1);
	
	return position &gt; 0;
epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataPattern"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOperator_Match" id="7e59035b-3f0d-4095-b29c-f52c21747b92">
        <source>isOperator_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:			

Date		Who		Reason
24MAY2021	NAVAB1	TFS 51219
*/

vars
	op : CM_Operator;
begin

	if self.myLocationEvent.operatorCode = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	
	op := app.myRoot.allOperators[self.myLocationEvent.operatorCode];
	
	if op = null then
		return false;
	endif;
	return _yaData.matches(op);


end;</source>
