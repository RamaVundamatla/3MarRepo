    <JadeMethod name="testRecompareAll" id="e07ec42c-5dfc-45ea-8ecd-7dc548ae7768">
        <source>testRecompareAll();

vars
	isInvalid		: Boolean;					// cnwrl1 09/08/2010 PAR 24337
	iEdition		: Integer;					// cnwrl1 09/08/2010 PAR 24337
	ti				: CM_TrackedItem;
	redisplayEDITIs	: CM_EDITISet;
	ignoreFields	: StringArray;
	
begin
	// cnwrl1 09/08/2010 PAR 24337 - start of coding
	if self.myLLCAgent.myEDILoadList = null then
		return;
	endif;
	// Can happen via the doPrint method (why is it being called from there?)
	on Exception do app.handleDeletedObject( exception, self.myLLCAgent.myEDILoadList, isInvalid );
	// Check availability by doing a de-reference
	iEdition	:= self.myLLCAgent.myEDILoadList.edition();
	if isInvalid then
		self.myLLCAgent.validateAgentReferences( self.myLLCAgent.myEDILoadList );
		return;
	endif;
	// cnwrl1 09/08/2010 PAR 24337 - end of coding
	
	create redisplayEDITIs;
	create ignoreFields transient;
	self.getIgnoreFields(ignoreFields);
	foreach ti in self.myLLCAgent.allTIsOnTerminal do
		self.myLLCAgent.reCompareItem(ti, self.myCurrentVoyage, ignoreFields, redisplayEDITIs, app.myPassport); //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
	endforeach;
	
epilog
	delete redisplayEDITIs;
	delete ignoreFields;
end;
</source>
    </JadeMethod>
