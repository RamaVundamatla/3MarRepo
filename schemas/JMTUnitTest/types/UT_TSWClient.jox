<Class name="UT_TSWClient" id="8b5a320a-1f9d-4f85-9bf1-8049eed72318">
    <superclass name="UT_EDI"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="tTSWClientCheck" id="6c83d9f3-3510-42d3-9c5a-96d974d11751">
        <source>tTSWClientCheck();
/*	cnwdap1

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jul 2016	cnwkpd1	TFS 1832 - TSW Web Client
21 Nov 2018 jlgmd1	TFS42090 - Check for a null result

*/

vars
	tswClient		: CMIF_TSWHelper;
	xml				: JadeXMLDocument;
	result			: String;
	element			: JadeXMLElement;
	reqStatus		: JadeXMLElement;
	partner			: JadeXMLElement;
	message			: JadeXMLElement;
	messageStr		: String;
	pos 			: Integer;
	
begin
	create tswClient transient;
	
	// Test with JADE as submitter - should return 51364340D as partner code
	self.logMessage('Sending request for submitter "JADE"');
	result := tswClient.getNextPendingNotification("JADE");
	self.logMessage('Result received - ' &amp; result);
	
	self.assertNotNullMsg(result, "No response received from TSW. Result ");
	
	pos := result.pos("&lt;ReqStatus&gt;", 1);
	if pos &lt;&gt; null then
		if result[pos+11:9] = "NOT FOUND" then
			//no more messages
			return;
		else
			pos := result.pos("&lt;?xml", 1);
			if pos &lt;&gt; null then
				result := result[pos:result.length-28];
			endif;
		endif;
	endif;
	
	create xml transient;
	xml.parseString(result);
	
	element := xml.getElementByTagNameNS("*", "ResponseDetail");
	self.assertNotNullMsg(element, "ResponseDetail XML element");
	reqStatus := element.getElementByTagNameNS("*", "ReqStatus");
	self.assertNotNullMsg(reqStatus, "ReqStatus XML element");
	if reqStatus.text = "NOT FOUND" then
		//no more messages to process
	else
		partner := element.getElementByTagNameNS("*", "Partner");
		self.assertNotNullMsg(partner, "Partner XML element");
		self.assertEqual(partner.text(), "51364340D");
		message := element.getElementByTagNameNS("*", "Message");
		self.assertNotNullMsg(message, "Message XML element");
		messageStr := message.writeToString;
		self.logMessage("Message obtained from parsing xml response - " &amp; messageStr);
	endif;
	
epilog
	delete tswClient;
	delete xml;	
end;
</source>
    </JadeMethod>
</Class>
