    <JadeMethod name="getAllYAIdentifiers" id="db645384-4bbd-4f0e-8970-4ebe0fb12a80">
        <source>getAllYAIdentifiers(_yaIdentifiers: StringArray input) : Boolean;

/*

Purpose:		This method returns a list of all the identifiers for this criteria type that may be used for data entry.

Parameters:			

Return Value:		


Date			Who		Reason
27 August 2008	consw1	Initial creation

*/

vars

begin
	_yaIdentifiers.clear;
	_yaIdentifiers.add("20");
	_yaIdentifiers.add("30");
	_yaIdentifiers.add("40");
	_yaIdentifiers.add("45");
	_yaIdentifiers.add("53");

	return true;
	
epilog

end;</source>
        <Parameter name="_yaIdentifiers" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
