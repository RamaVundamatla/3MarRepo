*/

vars

begin
	return self.systemToLocalTime(self.arrivedDT);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="056e697b-85a8-422c-8e4c-9cb4b2127334">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     05 March 2007 by cnwrs2
// 22/02/2017	cnwma1 TFs #3468:POL - Update Audit details for Voyage Cut Off Dates
// 09/11/2022   navmv20 Bug 55318: LNX - Estimated Arrival/Departure and Actual Arrival/Departure dates are mismatched in audit
// Purpose:     
// ---------------------------------------------------------------------------
vars
	rtnStr,
	tmpStr		: String;
	tmpOperator	: CM_Operator;
	cuttOff : CM_ReceivalCutoffVoyage;
begin
	rtnStr := inheritMethod();

	
	
	/*

	foreach tmpOperator in self.allOperatorsCargoReceiveOnHold do
		if tmpStr = null then
		else
		endif;
	endforeach;
	*/
	
	//30 Apr 2012	NDL	Par 2012
	if self.myHMSVoyageData &lt;&gt; null then
		tmpStr := self.myHMSVoyageData.isPilotExempt.String;
		rtnStr := rtnStr &amp; 'myHMSVoyageData : isPilotExempt' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null ;
	
	// ### TFS CR 65830 TASK 65833 19SEP2024 NAVAB1
	if self.myVoyageProgress &lt;&gt; null then
		tmpStr := self.myVoyageProgress.pauseProgress.String;
		rtnStr := rtnStr &amp; 'Voyage Progress PAUSE' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;

	tmpStr := null ;

	if self.allReceivalCutoffs.size &gt; 0  then   //22/02/2017 cnwma1 TFS #3468
		foreach cuttOff in self.allReceivalCutoffs do
			if cuttOff &lt;&gt; null then
				tmpStr := tmpStr &amp; "Code:"&amp;cuttOff.code &amp;" "&amp;"Earliest Receival:"&amp;"  "&amp;cuttOff.earliestDateTime.asStringJMT 
						 &amp;"  "&amp;"Cut-off:" &amp; cuttOff.cutoffDateTime.asStringJMT 
						 &amp;"  "&amp;"Earliest Receival PN:" &amp; cuttOff.earliestDateTimePN.asStringJMT() //04/03/2025	navkc1 JIRA Story MTN-34227
						 &amp;"  "&amp;"Cut-off-PN:" &amp; cuttOff.cutoffDateTimePN.asStringJMT() //04/03/2025	navkc1 JIRA Story MTN-34227
						 &amp;CrLf;
			endif;
		endforeach;
		tmpStr :=tmpStr.trimLeft;
		rtnStr := rtnStr &amp; 'Voyage Cut-offs' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	// START - 09/11/2022 navmv20 TFS 55318
	tmpStr := null;
	if self.arrivedDT &lt;&gt; null then
		tmpStr := self.systemToLocalTime(self.arrivedDT).String;
		rtnStr := rtnStr &amp; 'Arrived DT' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.departedDT &lt;&gt; null then
		tmpStr := self.systemToLocalTime(self.departedDT).String;
		rtnStr := rtnStr &amp; 'Departed DT' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.estimatedArrivalDT &lt;&gt; null then
		tmpStr := self.systemToLocalTime(self.estimatedArrivalDT).String;
		rtnStr := rtnStr &amp; 'Estimated Arrival DT' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.estimatedDepartureDT &lt;&gt; null then
		tmpStr := self.systemToLocalTime(self.estimatedDepartureDT).String;
		rtnStr := rtnStr &amp; 'Estimated Departure DT' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	// END - 09/11/2022 navmv20 TFS 55318
	return rtnStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBOL" id="d8482fc7-ef5b-46de-985c-2a4ce3484463">
        <source>getBOL(_bolNumber: String): CM_BOLIn;
//29 December 2010	cnwdw1	
// PAT 26671
begin
	return self.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralBillOfLading, BOL_STATUS_NORMAL, _bolNumber, null);
end;</source>
        <Parameter name="_bolNumber" type="String"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="getBOLInsFromNumber" id="8ee2f3da-674d-40ed-943a-77378653c936">
        <source>getBOLInsFromNumber(_bolInSet 	: CM_BOLSet input;
					_bolType 	: Integer;
					_bolNumber 	: String;
					_forwards	: Boolean;
					_dateTime	: TimeStamp);
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 21 August 2008
//
// Implemented version:
// 14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  
//----------------------------------------------------------------------
vars
	bolIn				: CM_BOLIn;
	iter				: Iterator;
	bolDict				: CM_BOLInByTypeStatusNumDTDict;
	typeKey,
	statusKey			: Integer;
	tsKey				: TimeStamp;
	bolNumKey			: String;
	// Use this only for now...... BOLType_GeneralBillOfLading
	
begin
	if _bolInSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'BOLOut set passed in is null');
		return;
	endif;
	
	bolDict := self.allBOLInByTypeStatusNumDT;
	iter := bolDict.createIterator;
	bolDict.startKeyGeq(_bolType, BOL_STATUS_NORMAL, _bolNumber, _dateTime, iter);
	if not _forwards then
		while iter.back(bolIn) do
			iter.getCurrentKeys(typeKey,statusKey,bolNumKey,tsKey); //MTN-35226
			
			//no need to check timeSamp key because we're looping backwards
			if typeKey &lt;&gt; _bolType then 
				break;
			endif;
			
			if not bolNumKey.startsWith(_bolNumber) then
				break;
			endif;
		
			_bolInSet.add(bolIn);
		endwhile;
		
	else
		while iter.next(bolIn) do
			iter.getCurrentKeys(typeKey,statusKey,bolNumKey,tsKey); //MTN-35226
			
			if typeKey &lt;&gt; _bolType then
				break;
			endif;
			
			if  not bolNumKey.startsWith(_bolNumber) then 
				break;
			endif;
			
			_bolInSet.add(bolIn);
		endwhile;
	endif;
		
epilog
	delete iter;
end;</source>
        <Parameter name="_bolInSet" type="CM_BOLSet" usage="input"/>
        <Parameter name="_bolType" type="Integer"/>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_forwards" type="Boolean"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getBOLOutsFromNumber" id="4d664e44-570d-4cf7-9cc8-1e8bd5f205d8">
        <source>getBOLOutsFromNumber(_bolOutSet : CM_BOLSet input;
					_bolType 	: Integer;
					_bolNumber 	: String;
					_forwards	: Boolean;
					_dateTime	: TimeStamp);
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 21 August 2008
//
// Implemented version:
//  14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  
//----------------------------------------------------------------------
vars
	bolOut				: CM_BOLOut;
	iter				: Iterator;
	bolDict				: CM_BOLInByTypeStatusNumDTDict;
	typeKey,
	statusKey			: Integer;
	tsKey				: TimeStamp;
	bolNumKey			: String;
	// Use this only for now...... BOLType_GeneralBillOfLading
	
begin
	if _bolOutSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'BOLOut set passed in is null');
		return;
	endif;
	
	bolDict := self.allBOLInByTypeStatusNumDT;
	iter := bolDict.createIterator;
	bolDict.startKeyGeq(_bolType, BOL_STATUS_NORMAL, _bolNumber, _dateTime, iter);
	if not _forwards then
		while iter.back(bolOut) do
			iter.getCurrentKeys(typeKey,statusKey,bolNumKey,tsKey); //MTN-35226
			
			//no need to check timeSamp key because we're looping backwards
			if typeKey &lt;&gt; _bolType then 
				break;
			endif;
			
			if not bolNumKey.startsWith(_bolNumber) then
				break;
			endif;
		
			_bolOutSet.add(bolOut);
		endwhile;
		
	else
		while iter.next(bolOut) do
			iter.getCurrentKeys(typeKey,statusKey,bolNumKey,tsKey); //MTN-35226
			
			if typeKey &lt;&gt; _bolType then
				break;
			endif;
			
			if  not bolNumKey.startsWith(_bolNumber) then 
				break;
			endif;
			
			_bolOutSet.add(bolOut);
		endwhile;
	endif;
		
epilog
	delete iter;
end;</source>
        <Parameter name="_bolOutSet" type="CM_BOLSet" usage="input"/>
        <Parameter name="_bolType" type="Integer"/>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_forwards" type="Boolean"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getBargeTowDepartureDate" id="18066c57-9974-4be5-b983-6ea82faeb526">
        <source>getBargeTowDepartureDate():TimeStamp;
/*

Purpose:	

getBargeTowDepartureDate() should return:
if isBarge = TRUE
	NULL if any voyages with that Voyage Group Code do not have a departure date
	otherwise the Latest Voyage Departure Date for a Voyage with a matching Voyage Group Code.
If isBarge = FALSE
	NULL		

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2021	navndl1	Initial creation	TFS 51196

*/

vars

	iter : Iterator;
	startObject : CM_Voyage;
	voyage : CM_Voyage;
	latestDate : TimeStamp;

begin

	if self.isBarge and self.voyageGroupCode &lt;&gt; null then
		iter := self.myTerminal.allVoyagesByVoyageGroupCode.createIterator;
		startObject := self.myTerminal.allVoyagesByVoyageGroupCode.getAtKeyGeq( self.voyageGroupCode );
		if startObject = null or startObject.voyageGroupCode &lt;&gt; self.voyageGroupCode then
			return self.departedDT;
		endif;
		latestDate := null;
		iter.startAtObject( startObject );
		while iter.next( voyage ) do
			if voyage.voyageGroupCode &lt;&gt; self.voyageGroupCode then
				break;
			endif;
			if not voyage.departedDT.isValid then
				return null;
			endif;
			if not latestDate.isValid then
				latestDate := voyage.departedDT;
			elseif voyage.departedDT &gt; latestDate then
				latestDate := voyage.departedDT;
			endif;
		endwhile;
		return latestDate;
		
	else
		return null;
		
	endif;

epilog

	delete iter;

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getBerthCode" id="427f94bd-4c59-4dcc-8e7d-d9c63490bb97">
        <source>getBerthCode() : String;
// CCMS C3 1124 33320 expose berth code for reports in views not using/needing HMS_Berth
vars
	berthCode	: String;
	berth		: HMS_Berth;
begin
	berth := self.getMyBerth();
	if berth &lt;&gt; null then
		berthCode := berth.code;
	endif;
	
	return berthCode;
end;
</source>
