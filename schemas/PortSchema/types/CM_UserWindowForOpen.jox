<Class name="CM_UserWindowForOpen" id="e08340ff-32d2-4851-85e6-97dfe5a530e5">
    <superclass name="CM_UserWindow"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Has an instance for each window class.  When a user opens a
window this holds the info stored from its last close time
to reset to how the user wants it to appear (does not
apply to windows being opened on app startup).</text>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="myUserForOpen" id="54701403-eea6-4a20-ad99-750a56d6ca17">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_User"/>
        <access>readonly</access>
        <Inverse name="CM_User::allUserWindowsForOpen"/>
    </ExplicitInverseRef>
    <JadeMethod name="setForCreate" id="c9de0e06-353a-4b04-949b-57c85d9b0e0e">
        <updating/>
        <source>setForCreate(_pxy: CM_UserWindow; _user: CM_User) updating;
// ---------------------------------------------------------------------------
// Created:     01 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.setForUpdate(_pxy);
	
	self.myUserForOpen := _user;

end;</source>
        <Parameter name="_pxy" type="CM_UserWindow"/>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="30004877-f674-46ae-b5bb-23573d02492c">
        <updating/>
        <source>setProxy(pUser: CM_User; pWindowName: String; pXMLInfo: String; pTop: Real; pLeft: Real; pWidth: Real; pHeight: Real; pState: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     01 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.setProxySuperclass(pUser, pWindowName, pXMLInfo, pTop, pLeft, pWidth, pHeight, pState);
	self.myUserForOpen := pUser;

end;</source>
        <Parameter name="pUser" type="CM_User"/>
        <Parameter name="pWindowName" type="String"/>
        <Parameter name="pXMLInfo" type="String"/>
        <Parameter name="pTop" type="Real"/>
        <Parameter name="pLeft" type="Real"/>
        <Parameter name="pWidth" type="Real"/>
        <Parameter name="pHeight" type="Real"/>
        <Parameter name="pState" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setUserFor724" id="ba47866f-ddab-4128-9c53-70e013626280">
        <updating/>
        <source>setUserFor724(_user : CM_User) updating;
// ---------------------------------------------------------------------------
// Created:     01 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myUserForOpen := _user;
end;</source>
        <Parameter name="_user" type="CM_User"/>
    </JadeMethod>
</Class>
