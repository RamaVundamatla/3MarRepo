    <JadeMethod name="setForCreate" id="3adf0a2a-50e1-40b5-8127-1b73426ac927">
        <updating/>
        <source>setForCreate(_proxy : CM_CamTaskHistory; _camProtocol :CM_CamProtocol; _passport : CM_Passport) updating;
//
//25 May 2012	cnwrs1		Par 26914 - make cams restart after lock error
//
vars

begin
	self.setForUpdate(_proxy);
	self.camProtocol := _camProtocol;
end;
</source>
        <Parameter name="_proxy" type="CM_CamTaskHistory"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5a3ef508-a806-41ea-9d52-e6ffb96dbfd7">
        <updating/>
        <source>setForUpdate(_proxy :CM_CamTaskHistory) updating;
//
// 25 May 2012	cnwrs1	Par 26914 - make cams restart after lock error
// 17 Jul 2012	cnwcs5	par 29601 - log excluded transactions
//28 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//30 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 21/08/2012	cnwcs5	par 30176 - conversion for 29601
// 21/08/2012	cnwcs5	par 30176 - conversion for above
//15 jun 2016	cnwrs1	Par 35544 - Change Cams task hisoty to use JadeBytes  
vars

begin
	self.runDateTime	:= _proxy.runDateTime;
	self.startDateTime	:= _proxy.startDateTime;
	self.endDateTime	:= _proxy.endDateTime;
	
	self.logExcludedTransactions := _proxy.logExcludedTransactions;  // par 30176 Aug 2012
	
	self.seqNumber		:= _proxy.seqNumber;
	self.camProtocol	:= _proxy.camProtocol;
	self.dailySeqNumber	:= _proxy.dailySeqNumber;
	self.fileName		:= _proxy.fileName;
	self.computerName	:= _proxy.computerName;
	self.status			:= _proxy.status;
	self.errorMessage	:= _proxy.errorMessage;
	
	self.myFileDataStorageHeader 	:= _proxy.myFileDataStorageHeader;
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;_proxy.fileData.size.String&amp;' '&amp;self.fileData.size.String;
//	self.fileData.clear();
//	_proxy.fileData.copy(self.fileData);	//28 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
	self.clearRawData;
	_proxy.rawData.copy(self.rawData);
end;
</source>
        <Parameter name="_proxy" type="CM_CamTaskHistory"/>
    </JadeMethod>
