    <JadeMethod name="getFutureMoveTypeString" id="3238b2ce-aebb-41a7-b734-b4c1c96a59e9">
        <source>getFutureMoveTypeString(fmType : Integer) : String;
/*
 ------------------------------------------------------------------------
Created:			04 November 2002 by cnwdwq1
Purpose:			Returns the string for the type of CM_FutureMove being used.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
begin
	if fmType = TI_FutureMovePlanned then
		return app.getErrorString(TIFutureMovePlanned);
	elseif fmType = TI_FutureMoveDLRDischarge then
		return app.getErrorString(TIFutureMoveDLRDischarge);
	elseif fmType = TI_FutureMoveDLRLoad then
		return app.getErrorString(TIFutureMoveDLRLoad);
	elseif fmType = TI_FutureMoveQueued then
		return app.getErrorString(Queued_Move);
	elseif fmType = TI_FutureMoveSOB then
		return app.getErrorString(TIFutureMoveSOB);
	elseif fmType = TI_FutureMoveOverstow then
		return app.getErrorString(TIFutureMoveOverstow);
	elseif fmType = TI_FutureMoveEDI then
		return app.getErrorString(EDI);
	else
		return app.getErrorString(TIFutureMoveUnknown);
	endif;
		
end;</source>
        <Parameter name="fmType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHMSTxnClassForType" id="cede7d11-ac8d-440b-91bd-02d7577994ba">
        <source>getHMSTxnClassForType(pType : Integer) : Class;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
begin
	if pType = TRANS_TYPE_AddVoyageDelay then
		return HMS_VoyageDelayAdd;
	elseif pType = TRANS_TYPE_EditVoyageDelay then
		return HMS_VoyageDelayEdit;
	elseif pType = TRANS_TYPE_DeleteVoyageDelay then
		return HMS_VoyageDelayDelete;
	elseif pType = TRANS_TYPE_HMSVoyageAdd then
		return HMS_VoyageAdd;
	elseif pType = TRANS_TYPE_HMSVoyageEdit then
		return HMS_VoyageEdit;
	elseif pType = TRANS_TYPE_HMSVoyageArchive then
		return HMS_VoyageArchived;
	elseif pType = TRANS_TYPE_HMSVoyageDeleted then
		return HMS_VoyageDeleted;
	elseif pType = TRANS_TYPE_ConfirmActualMove then
		return HMS_ConfirmActualMove;
	elseif pType = TRANS_TYPE_ConfirmPlanMove then
		return HMS_ConfirmPlanMove;
	elseif pType = TRANS_TYPE_AddMovement then
		return HMS_MovementAdd;
	elseif pType = TRANS_TYPE_EditMovement then
		return HMS_MovementEdit;
	elseif pType = TRANS_TYPE_ArchiveMovement then
		return HMS_MovementArchived;
	elseif pType = TRANS_TYPE_EditMovementTime then
		return HMS_MovementTimeEdit;
	elseif pType = TRANS_TYPE_ResourceBooked then
		return HMS_ResourceBooked;
	elseif pType = TRANS_TYPE_ResourceCancelled then
		return HMS_ResourceCancelled;
	elseif pType = Trans_Type_ResourceCharged then
		return HMS_VTMISTransaction;
	elseif pType = TRANS_TYPE_EditMarineTimings then
		return HMS_MarineServicesTimingsEdit;
	endif;
	if app.isDevelopmentSystem() then
		app.raiseCMException1(ERR_INVALID_TRANSTYPE, pType.String, 'type', null);  //par25665 cnwrs1 7 sept 2010
	endif;
	return null;
end;</source>
        <Parameter name="pType" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
