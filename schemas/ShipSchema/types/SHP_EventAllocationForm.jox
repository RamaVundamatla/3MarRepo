    <JadeMethod name="populateForm" id="38192a76-5c4b-4ffd-bfd6-d1da66885e15">
        <source>populateForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2017	cnwns1	Initial creation

*/

vars
	eventTypes: ObjectArray;
	firstEventType : CM_EventType;
	eventType : CM_EventType;
	iter : Iterator;
	myOwnerType : Integer;

begin
	self.mulColumns.userInputEnabled 			:= true;
	self.mulColumns.formDisplayEntryMethodName  	:= SHP_EventAllocationForm::getEventName.name;
	self.mulColumns.multiSelect					:= ListBox.MultiSelect_Extended;
	self.mulColumns.myAvailableListBox.sorted 	:= true;		
	self.mulColumns.mySelectedListBox.sorted 	:= true;
	self.mulColumns.setTabIndex();
	self.mulColumns.myBaseForm := self;
	
	create	eventTypes transient;
		
	iter := app.myRoot.allEventTypesByCategory.createIterator;
	firstEventType := app.myRoot.allEventTypesByCategory.getAtKeyGeq(CM_EventType.VOYAGE_EVENT,null);

	if firstEventType &lt;&gt; null then
		iter.startAtObject(firstEventType);
		while iter.next( eventType ) do
			if eventType.category &lt;&gt; CM_EventType.VOYAGE_EVENT then
				break;
			endif;
			eventTypes.add(eventType);
		endwhile;
	endif;	
	
	self.mulColumns.setAvailable(eventTypes, true); 

	myOwnerType := self.getOwnerType;
	
	if myOwnerType = Voyage then
		self.mulColumns.setSelected(self.myVoyage.allAllocatedEvents);
		frmVessel.visible := false;
	elseif myOwnerType = Vessel then
		self.mulColumns.setSelected(self.myVessel.allAllocatedEvents);
		frmVoyage.visible := false;	
	endif;

	self.mulColumns.setFocus();
epilog
	delete eventTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFromGroupCopy" id="6ba2c21b-b323-4580-bb13-037f2f4827c2">
        <source>setFromGroupCopy(_group : CM_EventTypeGroup input);
/*
Purpose:			
Date		Who		Reason
02 February 2017	cnwab1	Initial creation
*/

vars
	events : CM_EventTypeSet;
	event : CM_EventType;
	idx : Integer;
begin
	create events transient;
	self.mulColumns.getSelected(events);
	
	foreach event in _group.allEventTypes discreteLock do
		if event.category &lt;&gt; CM_EventType.VOYAGE_EVENT then
			continue;
		endif;
		
		if not events.includes(event) then
			events.add(event);
		endif;
	
	endforeach;
	
	self.mulColumns.setSelected(events);

epilog
	delete events;
end;</source>
        <Parameter name="_group" type="CM_EventTypeGroup" usage="input"/>
    </JadeMethod>
