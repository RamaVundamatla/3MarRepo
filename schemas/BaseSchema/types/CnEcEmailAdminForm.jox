    <JadeMethod name="baseData" id="83095d53-fbf9-4437-b04c-fa1e7e68b7aa">
        <source>baseData() protected;

vars
	formObj	: CnEcEmailBaseDataForm;
	
begin
	create formObj;
	formObj.aIsAdminMode		:=	true;
	formObj.lblNotes.caption	:=	"The values shown here will be those used as the default values for ";
	formObj.lblNotes.caption	:=	formObj.lblNotes.caption &amp; "all 'NEW' Base Data Objects." &amp; CrLf;
	formObj.lblNotes.caption	:=	formObj.lblNotes.caption &amp; "Press 'Update' to save the changes.." &amp; CrLf;
	formObj.showModal();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnBaseData_click" id="c2281a99-2a76-4ca8-a57f-708f81fceb92">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBaseData_click(btn: Button input) updating;

begin
	self.baseData();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClose_click" id="92a2269f-615b-4fc3-b04d-ebf8967a82fd">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;

begin
	unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="968d5877-35ed-48ce-999d-c001f4b33c5e">
        <updating/>
        <source>doFormLoad() updating, protected;

vars
	agentObj		: CnEcEmailAgent;
	emailRootObj	: CnEcEmailRoot;
	emailRootNewObj	: CnEcEmailRoot;
	errorMsg		: String;
	
begin
	self.allowClose	:=	false;
	self.centreWindow();

	create agentObj transient;
	self.aMyTA	:=	agentObj;
	
	emailRootObj	:=	CnEcEmailRoot.firstInstance;
	
	if not app.isValidObject(emailRootObj) or emailRootObj = null then
		errorMsg := self.aMyTA.trxCnEcEmailRootCreate(emailRootNewObj);
		
		if errorMsg &lt;&gt; null then
			app.msgBox(errorMsg,"Error",MsgBox_OK_Only);
		else
			emailRootObj	:=	emailRootNewObj;
			errorMsg		:=	self.aMyTA.trxCnEcEmailBaseDataDefault(emailRootObj);
			
			if errorMsg &lt;&gt; null then
				app.msgBox(errorMsg,"Error",MsgBox_OK_Only);
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="736a89cf-96f4-4357-8bcf-dce1666ec5e1">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	inheritMethod();
	self.doFormLoad();
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="38aac7f2-fed8-4ff7-aef1-09df54da0c68">
