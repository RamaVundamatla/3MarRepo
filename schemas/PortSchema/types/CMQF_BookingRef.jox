    <JadeMethod name="addBookingRefToColl" id="5928ebec-5d14-4c68-862c-86981cf4a86f">
        <updating/>
        <source>addBookingRefToColl(_collection : Collection input; _bookingRef	: CM_BookingRef)updating;

vars

begin
	_collection.add(_bookingRef);
	
//	self.totalExpectedQuantity := self.totalExpectedQuantity + _bookingRef.quantity;
//	self.totalExpectedWeight := self.totalExpectedWeight + _bookingRef.weight;
// dh 29/2/2008 ccms 1618 replaced these to allow for individual book ref items
	self.totalExpectedQuantity := self.totalExpectedQuantity + _bookingRef.getTotalQuantity;
	self.totalExpectedWeight := self.totalExpectedWeight + _bookingRef.getTotalWeight;
end;
</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="filterBkingRefByOperatorRefVoy" id="753f7452-d0f8-48f4-9bd3-bbcdfb5a5004">
        <updating/>
        <source>filterBkingRefByOperatorRefVoy(_dict : CM_BookingRefsByTermOperRefVoy; 
						_iter : Iterator input; 
						_collection : Collection input;
						 _passport: CM_Passport) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
//12 Aug 2013	cnwrs1	Par 32048 the collection is now by terminal
// 14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  
*/
vars
	bookingRef		: CM_BookingRef;
	terminalKey : CM_Terminal;
	operatorCodeKey,
	bookingRefKey	: String;
	voyageKey		: CM_Voyage;
	breakOut		: Boolean;
begin
	
	while _iter.next(bookingRef) do
		_iter.getCurrentKeys(terminalKey, operatorCodeKey, bookingRefKey, voyageKey); //MTN-35226
		if self.myOperator &lt;&gt; null and self.myOperator.code &lt;&gt; operatorCodeKey then
			break;
		endif;
		
		if self.bookingRef &lt;&gt; null and self.bookingRef &lt;&gt; bookingRefKey then
			continue;
		endif;
		
		if self.includesObject(bookingRef, _passport, breakOut) and
		   (not _collection.includes(bookingRef)) then
	//		_collection.add(bookingRef);					// dh - 28/11/2007 par 15407
			addBookingRefToColl(_collection, bookingRef);	// dh + 28/11/2007 par 15407
		endif;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_dict" type="CM_BookingRefsByTermOperRefVoy"/>
        <Parameter name="_iter" type="Iterator" usage="input"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterBookingRefByOperatorRef" id="a7a79565-e738-407f-9557-dac3eaf7d71e">
        <updating/>
        <source>filterBookingRefByOperatorRef(_dict : CM_BookingRefsByOperatorRef; 
						_iter : Iterator input; 
						_collection : Collection input;
						 _passport: CM_Passport) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
----------   ----------  --------------------------------------------------
*/
vars
	bookingRef		: CM_BookingRef;
	operatorCodeKey,
	bookingRefKey	: String;
	breakOut		: Boolean;
begin
	
	while _iter.next(bookingRef) do
		_iter.getCurrentKeys(operatorCodeKey, bookingRefKey); //MTN-35226
		if self.myOperator &lt;&gt; null and self.myOperator.code &lt;&gt; operatorCodeKey then
			break;
		endif;
		
		if self.bookingRef &lt;&gt; null and self.bookingRef &lt;&gt; bookingRefKey then
			continue;
		endif;
		
		if self.includesObject(bookingRef, _passport, breakOut) and
		   (not _collection.includes(bookingRef)) then
	//		_collection.add(bookingRef);					// dh - 28/11/2007 par 15407
			addBookingRefToColl(_collection, bookingRef);	// dh + 28/11/2007 par 15407
		endif;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_dict" type="CM_BookingRefsByOperatorRef"/>
        <Parameter name="_iter" type="Iterator" usage="input"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterBookingRefByRef" id="bc36f3ee-f237-4b22-b6d2-a5cf7633cab2">
        <updating/>
        <source>filterBookingRefByRef(_dict : CM_BookingRefsByRef; 
						_iter : Iterator input; 
						_collection : Collection input;
						_passport: CM_Passport)updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
----------   ----------  --------------------------------------------------
*/
vars
	bookingRef		: CM_BookingRef;
	bookingRefKey	: String;
	breakOut		: Boolean;
begin

	while _iter.next(bookingRef) do
		_iter.getCurrentKeys(bookingRefKey); //MTN-35226
		
		if self.bookingRef &lt;&gt; null and self.bookingRef &lt;&gt; bookingRefKey then
			break;
		endif;
		
		if self.includesObject(bookingRef, _passport, breakOut) then
			if (not _collection.includes(bookingRef)) then
		//		_collection.add(bookingRef);					// dh - 28/11/2007 par 15407
				addBookingRefToColl(_collection, bookingRef);	// dh + 28/11/2007 par 15407
			endif;
		endif;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_dict" type="CM_BookingRefsByRef"/>
        <Parameter name="_iter" type="Iterator" usage="input"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterBookingRefByRefDups" id="757bb60a-fa48-4df8-a2c7-f09e2a1d5157">
        <updating/>
        <source>filterBookingRefByRefDups(_dict : CM_BookingRefsByRefDups; 
							_iter : Iterator input; 
							_collection : Collection input;
							_passport: CM_Passport) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
 14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
----------   ----------  --------------------------------------------------
*/
vars
	bookingRef		: CM_BookingRef;
	bookingRefKey	: String;
	breakOut		: Boolean;
begin

	while _iter.next(bookingRef) do
		_iter.getCurrentKeys(bookingRefKey); //MTN-35226
		
		if self.bookingRef &lt;&gt; null and self.bookingRef &lt;&gt; bookingRefKey then
			break;
		endif;
		
		if self.includesObject(bookingRef, _passport, breakOut) and
		   (not _collection.includes(bookingRef)) then
	//		_collection.add(bookingRef);					// dh - 28/11/2007 par 15407
			addBookingRefToColl(_collection, bookingRef);	// dh + 28/11/2007 par 15407
		endif;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_dict" type="CM_BookingRefsByRefDups"/>
        <Parameter name="_iter" type="Iterator" usage="input"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterForConsign" id="d396f4cd-b615-4105-863e-457ee05b9fd7">
        <updating/>
        <source>filterForConsign(_collection : Collection input; _passport: CM_Passport) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
//12 Aug 2013	cnwrs1	Par 32048 the collection is now by terminal
//17 Feb 2015	cnwkpd1	PAR #35704 - Changes to prevent extended locking

*/
vars
	consign			: CM_ConsigneeConsignor;
	iter			: Iterator;
	terminal		: CM_Terminal;
begin
	if self.consignee &lt;&gt; null then
		consign := app.myRoot.allConsigneeConsignors[self.consignee];
	else
		consign := app.myRoot.allConsigneeConsignors[self.consignor];	
	endif;

	if consign = null then
		return;
	endif;
	foreach terminal in self.allTerminals discreteLock do
		delete iter;												// 27/02/2015 cnwmh5 - transient leak
		if self.myOperator &lt;&gt; null then
			iter := consign.allBookingRefsByOperatorRef.createIterator();
			consign.allBookingRefsByOperatorRef.startKeyGeq(terminal, self.myOperator.code, self.bookingRef, null,iter); // adm 150908 Par 17936
			self.filterBkingRefByOperatorRefVoy(consign.allBookingRefsByOperatorRef, iter, _collection, _passport);
		else
			iter := consign.allBookingRefsByRef.createIterator();
			consign.allBookingRefsByRef.startKeyGeq(self.bookingRef, iter);
			self.filterBookingRefByRefDups(consign.allBookingRefsByRef, iter, _collection, _passport);
		endif;
	endforeach;
epilog
	delete iter;	
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterForTerminal" id="2dde74b8-7776-4248-a97c-6365b6757682">
        <updating/>
        <source>filterForTerminal(_collection : Collection input; _passport: CM_Passport) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
17 Feb 2015	cnwkpd1	PAR #35704 - Changes to prevent extended locking

*/
vars

	terminal		: CM_Terminal;
	iter			: Iterator;
begin
	foreach terminal in self.allTerminals discreteLock do
		delete iter;
		iter := terminal.allBookingRefsByRef.createIterator();
		terminal.allBookingRefsByRef.startKeyGeq(self.bookingRef, iter);
		self.filterBookingRefByRefDups(terminal.allBookingRefsByRef, iter, _collection, _passport);
	endforeach;

epilog
	delete iter;	
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterForVoyage" id="ae08f104-4f3d-469f-bc3e-ce8e79a1c5d9">
        <updating/>
        <source>filterForVoyage(_collection : Collection input; _passport: CM_Passport) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	iter			: Iterator;
begin
	iter := self.getMyVoyage.allBookingRefs.createIterator;
	if self.myOperator &lt;&gt; null then
		self.getMyVoyage.allBookingRefs.startKeyGeq(self.myOperator.code, self.bookingRef, iter);
	endif;
	
	self.filterBookingRefByOperatorRef(self.getMyVoyage.allBookingRefs, iter, _collection, _passport);
	
epilog
	delete iter;	
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="096c8cfd-5fc5-4e9c-8313-f0f3ab29dba0">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
//12 Aug 2013	cnwrs1	Par 32048 the collection is now by terminal
*/
vars

begin
	self.totalExpectedQuantity := null;
	self.totalExpectedWeight := null;
	
	if self.getMyVoyage &lt;&gt; null then
		self.filterForVoyage(_collection, _passport);
	elseif self.consignee &lt;&gt; null or 
	   self.consignor &lt;&gt; null then
		self.filterForConsign(_collection, _passport);
	//elseif self.myOperator &lt;&gt; null then
	//	self.filterForOperator(_collection, _passport);
	// 05 Dec 2013	NDL	Par 33123 - Put back again.
	else
		self.filterForTerminal(_collection, _passport);
	endif;
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d99fd863-b28a-4ef4-8a4e-620653330bf6">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars
	runDate : Date;
	oid     : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
/*
	runDate := app.actualTimeServer().date;

	// Arrival
	if _attrName = ETRow_ArrivalsDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.voyageArrivalDateFromTplType, self.voyageArrivalDateFromTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.voyageArrivalDateFromTplType, self.voyageArrivalDateFromTplFactor);
		endif;
	endif;
	
	if _attrName = ETRow_ArrivalsDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.voyageArrivalDateToTplType, self.voyageArrivalDateToTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.voyageArrivalDateToTplType, self.voyageArrivalDateToTplFactor);
		endif;
	endif;


	return inheritMethod(_attrName, _getCalculatedDate);
*/
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyCommodity" id="29073f24-8c99-4ca7-b0a7-6b8063a1c32d">
        <source>getMyCommodity():CM_Commodity;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	commodity : CM_Commodity;
	edition : Integer;
	invalidObj : Boolean;

begin

	commodity := self.myCommodity;

	if commodity = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, commodity, invalidObj );
	edition := commodity.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return commodity;

epilog

end;</source>
        <ReturnType type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyage" id="328a9a40-5d0f-4501-a51f-6b567c64e550">
        <source>getMyVoyage():CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	voyage : CM_Voyage;
	edition : Integer;
	invalidObj : Boolean;

begin

	voyage := self.myVoyage;

	if voyage = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, voyage, invalidObj );
	edition := voyage.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return voyage;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="23c59b17-a388-4ad8-b8ba-1d8a76441dd5">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid : String output): String;
/* ---------------------------------------------------------------------------
Created:	29 July 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars
	runDate : Date;
	
begin

	runDate := app.actualTimeServer().Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support

	// Arrival
	if _attrName = ETRow_ArrivalsDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.voyageArrivalDateFromTplType, self.voyageArrivalDateFromTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.voyageArrivalDateFromTplType, self.voyageArrivalDateFromTplFactor);
		endif;
	endif;
	
	if _attrName = ETRow_ArrivalsDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.voyageArrivalDateToTplType, self.voyageArrivalDateToTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.voyageArrivalDateToTplType, self.voyageArrivalDateToTplFactor);
		endif;
	endif;
	if _attrName = ETRow_BookingStatus then
		return app.getBookingRefStatusString(self.status);//PAR25404 cnwsh3 29/09/2010
	endif;

	return inheritMethod(_attrName, _getCalculatedDate, _oid);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="c352aa5e-d1e1-49a7-b5e4-1f69b534d69b">
        <updating/>
        <source>includesObject(_bookingRef: CM_BookingRef; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason

23 July 2008	cnwdz2	 Par16765 - check if myCommodity is null before accessing its code property.	
----------   ----------  --------------------------------------------------
*/
vars
	ti			: CM_BreakBulkGeneric;
	commodCode  : String;
	terminal	: CM_Terminal;
	bookMatch 	: Boolean;
	reason		: String; //05/04/2024	navkc1 Bug 63509
begin
	//+cnwml2 PAR23244
	bookMatch := false;
	foreach terminal in self.allTerminals do
		if _bookingRef.myTerminal = terminal then
			bookMatch := true;
			break;
		endif;
	endforeach;
	
	if not bookMatch then
		return false;
	endif;
	
	if self.getMyCommodity &lt;&gt; null then
		commodCode := self.getMyCommodity.code;
	endif;
	
	//at this point the booking reference number has been checked through iterator key in filter methods so no need to check again
	if (self.myOperator &lt;&gt; null and self.myOperator &lt;&gt; _bookingRef.myOperator) or
	   (_bookingRef.getMatchingItem(getMyCargoType, commodCode, null, null, null, null, null, null, null, reason) = null) or  // Par16765 cnwdz2 // ### TFS 56707 (56712) 05Apr2023 NAVPW1
	   (self.getMyVoyage &lt;&gt; null and self.getMyVoyage &lt;&gt; _bookingRef.myVoyage) or
	   (self.consignee &lt;&gt; null and self.consignee &lt;&gt; _bookingRef.consigneeCode) or
	   (self.consignor &lt;&gt; null and self.consignor &lt;&gt; _bookingRef.consignorCode) or
	   (self.status &lt;&gt; -1 and self.status &lt;&gt; _bookingRef.status) or //PAR25404 - CCMS1063 
	    not self.matchVoyageArrivalDate( _bookingRef )	//Par 17601. July 2008
	then
		return false;
	endif;
	//dh 28/11/2007 - par 15407 - moved these out to addBookingRefToColl method where object is being added and not just checked.	
	//self.totalExpectedQuantity := self.totalExpectedQuantity + _bookingRef.quantity;
	//self.totalExpectedWeight := self.totalExpectedWeight + _bookingRef.weight;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="matchVoyageArrivalDate" id="d2adb96c-1156-4232-b604-a697011bb640">
        <source>matchVoyageArrivalDate( _bookingRef: CM_BookingRef ) : Boolean protected;
/* ---------------------------------------------------------------------------
Created:	29 July 2008	by cnwvu1

Purpose:	Par 17601
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.getMyVoyage &lt;&gt; null then
		return true;	// the filter voyage has preference. Filter arrival date From/To are ignored
	endif;

	if self.voyageArrivalDateFrom = null and self.voyageArrivalDateTo = null then
		return true;	//  Filter arrival date From/To = null and are ignored
	endif;
	
	//when self.myVoyage = null and filter arrival date From/To are not null
	
	if _bookingRef.myVoyage = null then
		return false;
		
	else 	//when _bookingRef.voyage &lt;&gt; null, we have to compare arrival date From / To
		
		if not _bookingRef.myVoyage.arrivedDT.isValid() then
			return false;	//when _bookinRef.voyage arrival date = null, don't include the booking reference
		endif;
		
		//copmaring arrival date From
		if self.voyageArrivalDateFrom.isValid() then
			if _bookingRef.myVoyage.arrivedDT.date &lt; self.voyageArrivalDateFrom then
				return false;
			endif;
		endif;
		
		//copmaring arrival date To
		if self.voyageArrivalDateTo.isValid() then
			if _bookingRef.myVoyage.arrivedDT.date &gt; self.voyageArrivalDateTo then
				return false;
			endif;
		endif;
		
	endif;
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_bookingRef" type="CM_BookingRef"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDatesForTemplateRun" id="65a1df7d-cdaa-4390-965c-337e739b03ab">
        <updating/>
        <source>setDatesForTemplateRun(_runDate: Date) updating;
/* ---------------------------------------------------------------------------
Created:	29 July 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	inheritMethod(_runDate);

	self.voyageArrivalDateFrom	:= self.setDateFromTemplate( self.voyageArrivalDateFromTplType,	self.voyageArrivalDateFromTplFactor, _runDate );
	self.voyageArrivalDateTo	:= self.setDateFromTemplate( self.voyageArrivalDateToTplType,	self.voyageArrivalDateToTplFactor,   _runDate );

end;</source>
        <Parameter name="_runDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="8f88a103-bc9b-448b-ada7-8eda235822c4">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;
/* ---------------------------------------------------------------------------
Created:	29 July 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	eventData : CM_EventDataVoyage;
begin
	inheritMethod(_obj, _runDate, _allEventData);
	
	self.voyageArrivalDateFrom	:= self.setDateFromTemplate( self.voyageArrivalDateFromTplType,	self.voyageArrivalDateFromTplFactor, _runDate );
	self.voyageArrivalDateTo	:= self.setDateFromTemplate( self.voyageArrivalDateToTplType,	self.voyageArrivalDateToTplFactor,   _runDate );
	
	//epr par 34813 10/9/14
	eventData := _allEventData[EventDataVoyage].CM_EventDataVoyage;
	if eventData &lt;&gt; null and eventData.myVoyage &lt;&gt; null then
		self.setMyVoyage( eventData.myVoyage );
	endif;
end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
