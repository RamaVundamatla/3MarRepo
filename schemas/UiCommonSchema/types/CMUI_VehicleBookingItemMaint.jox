        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optBtnRR_click(optionbutton: OptionButton input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 May 2023		navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
02 June 2023	navpw1	TFS: 58256 - Added volume controls
02 Nov 2023		navlc30 Bug 61055: EUP - VBS Changes - Multiple Items option is available on the Edit mode
23 Apr 2024 	navlc30 ChangeRequest 63581: FR - 53429 - VBS - Adding entire release with line items
*/

begin
	self.cmbReleaseReq.visible 		:= true;
	self.cmbBooking.visible			:= false;
	self.lblReleaseReq.visible 		:= true;
	self.lblBooking.visible			:= false;
	self.lblCargoId.visible			:= false;
	self.txtCargo.visible			:= false;
	self.btnFindCargo.visible		:= false;
	self.cmbReserveDetail.visible 	:= true;
	self.lblReserveDetails.visible	:= true;
	self.cmbBookingItem.visible 	:= false;
	self.lblBookingItem.visible		:= false;
	self.cmbCargo.visible 			:= false;
	self.lblCargo.visible			:= false;
	self.lblQuantity.visible 		:= false;
	self.txtQuantity.visible 		:= false;
	self.lblWeight.visible 			:= false;
	self.tblWeight.visible 			:= false;
	self.lblVolume.visible 			:= false;	// ### TFS 58256 02Jun2023 NAVPW1
	self.tblVolume.visible 			:= false;	// ### TFS 58256 02Jun2023 NAVPW1
	self.chkMultipleItems.visible 			:= false;		//02.11.2023 navlc30 #61055
	self.btnFindCargoMultiple.visible		:= false;		//02.11.2023 navlc30 #61055
	self.chkAddAllItems.visible		  		:= false;		//23.04.2024 navlc30 #63581
	self.initTableItems(ETDef_ResDetails);
	self.populateSourceCombo();
	self.alignTable();
	
end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateCombos" id="f8eccef4-178a-489d-939c-773a1b998ae4">
        <updating/>
        <source>populateCombos() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022		navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
03 May 2023 	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
*/

vars
	terminal : CM_Terminal;
	vbTimeSlot : CM_VehicleBookingTimeSlotItem;		// 23.12.2022 navak20 TFS 55979
begin
	vbTimeSlot := self.myPxyVehicleBookTimeSlotItem;	// 23.12.2022 navak20 TFS 55979
	// Populate the direction combo box
	/*
	//03.5.2023 navhl20 #57402[57471]
	self.cmbDirection.clear;
	self.cmbDirection.addItemWithData("", self.DIRECTION_BLANK);
	self.cmbDirection.addItemWithData(app.getErrorString(VBS_direction_pickup), DIRECTION_PICKUP);
	self.cmbDirection.addItemWithData(app.getErrorString(VBS_direction_delivery), DIRECTION_DELIVERY);*/
	
	//if self.myPxyVehicleBookTimeSlotItem &lt;&gt; null then		// 23.12.2022 navak20 TFS 55979
	if vbTimeSlot &lt;&gt; null then		// 23.12.2022 navak20 TFS 55979
		//self.cmbDirection.setIndexForItemData(self.myPxyVehicleBookTimeSlotItem.direction);	// 23.12.2022 navak20 TFS 55979
		//self.cmbDirection.setIndexForItemData(vbTimeSlot.direction);							//03.5.2023 navhl20 #57402[57471]
		if vbTimeSlot.direction = DIRECTION_PICKUP then											//03.5.2023 navhl20 #57402[57471]
			self.optBtnPickUp.value 	:= true;
			self.optBtnBooking.visible 	:= false;
			self.optBtnRR.visible 		:= true;
			self.optBtnDelivery.value 	:= false;
		elseif vbTimeSlot.direction = DIRECTION_DELIVERY then	
			self.optBtnDelivery.value 	:= true;
			self.optBtnBooking.visible 	:= true;
			self.optBtnRR.visible 		:= false;
			self.optBtnPickUp.value 	:= false;
		endif;
	else																						//03.5.2023 navhl20 #57402[57471]
		self.optBtnPickUp.value 		:= true;
		self.optBtnRR.value 			:= true;
		self.optBtnRR.visible 			:= true;
		self.optBtnDelivery.visible		:= false;
		self.optBtnDelivery.value 		:= false;
	endif;
	
	// Populate the Source Type Combo
	self.populateSourceTypeCombo();
	
	// Populate the Source Combo
	self.populateSourceCombo();

	// populate the Details Combo
	self.populateDetailsCombo();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCombosForNew" id="c19fa186-695c-4416-934f-bb9857b1751a">
        <source>populateCombosForNew();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 July 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
03 May 2023 	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
*/

vars

begin
	/*
	//03.5.2023 navhl20 #57402[57471]
	self.cmbDirection.addItemWithData(app.getErrorString(VBS_direction_pickup), DIRECTION_PICKUP);
	self.cmbDirection.addItemWithData(app.getErrorString(VBS_direction_delivery), DIRECTION_DELIVERY);
	self.cmbDirection.addItemWithData("", self.DIRECTION_BLANK);
	
	if self.cmbDirection.getCurrentItemData = DIRECTION_PICKUP then
		self.cmbSourceType.addItemWithData("Cargo", self.SOURCE_CARGO);
		self.cmbSourceType.addItemWithData("Release Request", self.SOURCE_RELEASE);
		self.cmbSourceType.addItemWithData("", self.SOURCE_EMPTY);
	elseif self.cmbDirection.getCurrentItemData = DIRECTION_DELIVERY then
