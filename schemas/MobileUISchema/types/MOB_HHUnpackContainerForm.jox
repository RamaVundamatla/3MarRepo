    <JadeMethod name="clickInYardItem" id="df664ebc-e8ac-4e3e-9fe5-811521186521">
        <updating/>
        <source>clickInYardItem( obj : Object ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	ti : CM_TrackedItem;
	success : Boolean;
	hideMoveConfirmation: Boolean;
begin

	if CM_TrackedItem.hasInstance( obj ) then
		ti := obj.CM_TrackedItem;
	endif;

	
	//epr par 34472 3/7/14 
	hideMoveConfirmation := app.myPassport.myTerminal.getConfig(HhMoveConfirmation).Boolean;	//15 Dec 2015	NDL	Par 37288
	success := self.myMobileGenericAgent.doPackCargo(self.myUnpackContainer,	
														ti, hideMoveConfirmation
														);
	if success then
		self.goBackToFirst( MOB_HHUnpackContainerForm );
		return;
	endif;
			

epilog

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doChangeID" id="b83bcab9-a904-4788-9498-d5366a00223e">
        <source>doChangeID(	_ti : CM_TrackedItem;
			_newCargoId : String
			) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2014	cnwndl1	Initial creation	Par 33859
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars

	tiSet : CM_TISet;
	existingTi : CM_TrackedItem;
	msg : String;
	pxyTi : CM_TrackedItem;
	load : Boolean;
	theReturn : Integer;

begin

	if not self.allowChangeID then
		return true;
	endif;
	
	create tiSet transient;
	self.myTerminal.lookupAllOnsiteTrackedItems( _ti.myCargoType.id, _newCargoId, tiSet, false, null );
	
	if not tiSet.isEmpty then
		if not _ti.myCargoType.allowDuplicates then
			msg := app.getErrorString1(Cargo_already_used,_newCargoId);
			self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, true);
			return false;
		endif;
	endif;
	
	app.cmsBeginLoad(load);
	pxyTi := _ti.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	
	pxyTi.zSetPxyAlternativeId( _ti.id );
	pxyTi.zSetPxyId( _newCargoId );
	
	//warn them
	msg := app.getErrorString2( Sure_want_change, _ti.id, _newCargoId );
	// from 34405 change Error to Warning as more appropriate
	if self.msgBox( msg, app.getErrorString(Warning), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
		return false;
	endif;
	
	while true do
	
		app.myTrxUA.trxUpdateTrackedItem(pxyTi,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Cargo_item_update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
			else
				break;
			endif;
		endif;
		
	endwhile;
	
	return false;

epilog

	delete tiSet;
	delete pxyTi;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_newCargoId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doClickUnPackButton" id="10933e92-ffbf-4d4b-9afb-7d9fd7b1dc03">
        <updating/>
        <source>doClickUnPackButton( btn: Button input ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation

*/

vars

	_ti : CM_TrackedItem;
	newCargoId : String;
	
/*	hasActions : Boolean;
	resDetailSet : CM_ReserveDetailSet;
	bookingItemSet : CM_BookingRefItemSet;
	opt1Str : String;
	opt2Str : String;
	opt3Str : String;
	opt4Str : String;
	returnValue : Integer;
	doActions : Boolean;
	doUnpack : Boolean;
	doChecks : Boolean; */

begin

	_ti := btn.userObject.CM_TrackedItem;
	if _ti = null then
		//need to create one....
		self.gotoForm( MOB_HHUnpackNewCargo, false );
		return;
		
	endif;
	
	//08 Apr 2014	NDL	Par 33859
	if self.allowChangeID then
		newCargoId := self.txtCargoId.text.trimBlanks;
		if newCargoId &lt;&gt; null and newCargoId = self.lblCargoId.caption.trimBlanks.toUpper then
			newCargoId := null;
		endif;
		if newCargoId &lt;&gt; null and newCargoId &lt;&gt; _ti.id then
			if not self.doChangeID(_ti,newCargoId) then
				return;
			endif;
		endif; 
	endif;
	
	//09 Dec 2016	NDL	TFS 3113 / 2001 
/*	create resDetailSet transient;
	create bookingItemSet transient;
	if _ti.hasDocumentActions( resDetailSet, bookingItemSet ) then
		hasActions := true;
	endif;
	
	
	if not hasActions then */
	
		self.myMobileGenericAgent.setMyNextTiToAction(_ti);
		//if self.myTerminal.allCargoChecks[CARGO_CHECK_CONTEXT_UNPACK].allCargoCheckItems.size = 0 then
		if self.myTerminal.hasNoCargoCheckItemsFor(CARGO_CHECK_CONTEXT_UNPACK) then	//31 May 2012	NDL Par 29038
			self.gotoForm( MOB_HHUnpackCargoToForm, false );
			return;
			
		else
			//requires checks first
			self.myMobileGenericAgent.setMyDeliveryRequest(null);
			self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.UnpackCargo);
			self.gotoForm(MOB_HHGateCheckCargo, false);
			return;
			
		endif;
	
/*	else
		//09 Dec 2016	NDL	TFS 3113 / 2001 - lets implement a 100 different ways to skin the cat for Steinweg
		//01 Mar 2017	NDL	TFS 3157 - So Tomek has changed his mind yet again, bgack it all out and put it back to teh way it was.
		doActions := false;
		doUnpack := false;
		doChecks := false;
	
		opt1Str := app.getErrorString( Unpack );
		opt2Str := app.getErrorString( Perform_document_actions );
		opt3Str := app.getErrorString( Perform_cargo_checks );
		opt4Str := app.getErrorString(None_above_cancel);
		if self.myTerminal.hasNoCargoCheckItemsFor(CARGO_CHECK_CONTEXT_UNPACK) then
			returnValue := self.optBox(opt1Str, opt2Str, opt3Str, opt4Str, 3, app.getErrorString(Select_option) );
			if returnValue = 1 then
				doUnpack := true;
			elseif returnValue = 2 then
				doActions := true;
			elseif returnValue = 3 then
				doChecks := true;
			else
				//bail
				return;
			endif;
		else
			returnValue := self.optBox(opt1Str, opt2Str, opt4Str, null, 2, app.getErrorString(Select_option) );
			if returnValue = 1 then
				doUnpack := true;
			elseif returnValue = 2 then
				doActions := true;
			else
				//bail
				return;
			endif;
		endif;
		
		if doActions then
			self.myMobileGenericAgent.setAllReserveDetails( resDetailSet );
			self.myMobileGenericAgent.setAllBookingRefItems( bookingItemSet );
			self.myMobileGenericAgent.setStringField1( self.fldCargo.topSheet.name );
			self.myMobileGenericAgent.setMyNextTiToAction( _ti );
			self.gotoForm( MOB_HHDocumentActions, false );
			
		elseif doUnpack then
			self.myMobileGenericAgent.setMyNextTiToAction(_ti);
			self.gotoForm( MOB_HHUnpackCargoToForm, false );
			return;
			
		elseif doChecks then
			self.myMobileGenericAgent.setMyNextTiToAction(_ti);
			self.myMobileGenericAgent.setMyDeliveryRequest(null);
			self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.UnpackCargo);
			self.gotoForm(MOB_HHGateCheckCargo, false);
			return;
			
		endif;
		
	endif; */
	
epilog

//	delete resDetailSet;
//	delete bookingItemSet;
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFindCargoButton" id="3eb8015f-3399-49fd-a7cf-69ea040c370a">
        <updating/>
        <source>doFindCargoButton() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars
	
	str : String;
	ti : CM_TrackedItem;
	theTI : CM_TrackedItem;
	buttonNumber : Integer;
	menuButton : MOB_Button;
	value : Real;

begin

	str := self.txtCargoId.text.trimBlanks.toUpper;
	if str = null then
		return;
	endif;
	
	if str = self.lblCargoId.caption.trimBlanks.toUpper then
		return;
	endif;
	
	foreach ti in self.myUnpackContainer.allChildren do
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnToUnpackTemp.getControl(buttonNumber);
		if ti.id = str then	
			theTI := ti;
			break;
		endif;
		if menuButton &lt;&gt; null then
			value := value + menuButton.height;
		endif;
	endforeach;
	
	if theTI &lt;&gt; null then
		self.scrToUnPack.value := value.Integer;
		self.setMenuScrollStart( self.scrToUnPack, self.btnToUnpackTemp, self.frmToUnPack, self.myUnpackContainer.allChildren.size + 1 );
		menuButton.setFocus();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="e6979cf5-b30e-48ec-bd19-c9db799c4970">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	folderHeight : Real;
	stdHeight : Real;
	
	size : Integer;
	menuButton : MOB_Button;
	index: Integer;
	buttonWidth: Real;
	buttonHeight : Integer;
	buttonTop : Integer;
	
	vTop : Real;
	vLeft : Real;
	vHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;
	folderHeight := self.clientHeight - self.getCMDHeight() - self.resizedMargin;
	
	self.fldCargo.move(	self.resizedMargin,
						self.resizedMargin,
						self.clientWidth - self.resizedMargin,
						folderHeight
						);
						
	self.frmUnpacked.move(	0,
							0,
							self.shtUnpacked.width - self.resizedMargin,
							self.shtUnpacked.height - self.resizedMargin
							);
								
	self.txtCargoId.move(	0,
							1,
							self.shtToUnPack.width - self.resizedMargin,
							stdHeight
							);
	if _initialSetup then
		self.txtCargoId.text := lblCargoId.caption.toUpper;
	endif;
							
	vTop := self.txtCargoId.height + self.resizedMargin;
	self.frmToUnPack.move(	0,
							vTop,
							self.shtToUnPack.width - self.resizedMargin,
							self.shtToUnPack.height - vTop - self.resizedMargin
							);
							
	size := self.myUnpackContainer.allChildren.size + 1;
	if size &gt; 0 then
		buttonHeight := self.getScrollingButtonHeight();
		self.btnToUnpackTemp.height := buttonHeight;
		buttonWidth := self.getButtonWidthSetScrollBar( size, self.frmToUnPack, self.btnToUnpackTemp.height, self.scrToUnPack );
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to size do
			menuButton := self.btnToUnpackTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnToUnpackTemp.fontSize;	//07 Apr 2015	NDL	Par 35990
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
		
	endif;
	
	size := self.myMobileGenericAgent.allUnpackedTis.size;
	if size &gt; 0 then
		buttonHeight := self.getScrollingButtonHeight();
		self.btnInYardTemp.height := buttonHeight;
		buttonWidth := self.getButtonWidthSetScrollBar( size, self.frmUnpacked, self.btnInYardTemp.height, self.scrUnPacked );
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to size do
			menuButton := self.btnInYardTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnInYardTemp.fontSize;	//07 Apr 2015	NDL	Par 35990
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
		
	endif;
							
	inheritMethod(_initialSetup);
	
	//29 Sep 2016	NDL	TFS 2654 / 2001
	self.btnDocActions.visible := false;
	if not self.docActsToDisplay.isEmpty then
		vHeight := self.btnOne.height;
		self.frmToUnPack.height := self.frmToUnPack.height - self.resizedMargin - vHeight;
		self.frmUnpacked.height := self.frmUnpacked.height - self.resizedMargin - vHeight;
		vTop := self.frmToUnPack.top + self.frmToUnPack.height + self.resizedMargin;
		vLeft := 0;//self.resizedMargin;
		self.btnDocActions.parent := self.shtToUnPack;
		self.btnDocActions.visible := true;
		self.btnDocActions.move(	vLeft,
									vTop,
									self.btnOne.width,
									vHeight );
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUnpackComplete" id="529b1434-92b9-4f72-942f-cbd690abbc4b">
        <updating/>
        <source>doUnpackComplete():Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06/07/2011	cnwndl1	Initial creation	Par 26476
26/06/2012	cnwdap1	PAR #29735 New parameter for CM_TrackedItem:;setBookingRefAndItem
*/

vars
	pxyTI			: CM_TrackedItem;
	result			: Integer;
	checksSubCargo	: CM_TrackedItem;
	clearProxy 		: Boolean;
begin

	
	//08 Mar 2017	NDL	TFS 3635
	if self.myMobileGenericAgent.isWaitingOnRequiredChecks(CONT_CHECK_CONTEXT_UNPACK, self.myUnpackContainer, checksSubCargo) &lt;&gt; null then 
		self.myMobileGenericAgent.setMyNextTiToAction(self.myUnpackContainer);
		self.myMobileGenericAgent.setChecksState(CONT_CHECK_CONTEXT_UNPACK);
		self.myMobileGenericAgent.setDisplayIdOnCheckForm(true);
		self.gotoForm( MOB_HHGateCheckCargo, false );	
		return false;
	endif;
	clearProxy:=true;
	app.myMobileAgent.setMyProxy( self.myUnpackContainer );
	pxyTI := app.myMobileAgent.getMyProxyObject().CM_TrackedItem;
	
	while true do
		app.myTrxUA.trxUpdateTIUnpackComplete(pxyTI, app.myPassport, null);
		if app.myPassport.trxCompletedOK() then
			return true;
			
		else
			result := app.showErrorWarningDialog(app.getErrorString(PackUnpack),
												app.myPassport,
												ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			return false;
		endif;
	endwhile;
	
	return false;
	
	
epilog
	//epr TFS 23/8/17 5532
	if clearProxy then
		app.myMobileAgent.setMyProxy( null );
	endif;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fldCargo_querySheetChg" id="066ef96e-ead7-4fc3-806a-9ae892199587">
        <controlMethod name="Folder::querySheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldCargo_querySheetChg(folder: Folder; newSheet: Sheet):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2016	cnwndl1	Initial creation	TFS 2654 / 2001

*/

vars

begin

	if newSheet = self.shtToUnPack then
		self.btnDocActions.parent := self.shtToUnPack;	
	elseif newSheet = self.shtUnpacked then
		self.btnDocActions.parent := self.shtUnpacked;
	endif;
	
	self.btnDocActions.visible := not self.docActsToDisplay.isEmpty;
	
	return true;

epilog

end;</source>
        <Parameter name="folder" type="Folder"/>
        <Parameter name="newSheet" type="Sheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPennButtonCaption" id="1eec06dc-cef0-4f38-8357-79fd1dd311af">
        <source>getPennButtonCaption( _ti : CM_TrackedItem ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2014	cnwndl1	Initial creation	Par 33859

*/

vars

	line1 : String;
	consigneeStr : String;
	line2 : String;

begin

	line1 := _ti.cargoTypeDescr &amp; " - " &amp; _ti.id;
	if _ti.myConsignee &lt;&gt; null then
		consigneeStr := " - " &amp; _ti.myConsignee.description;
	endif;
	line2 := _ti.getDefaultTotalWeightDisplay &amp; consigneeStr;
	
	return line1 &amp; CrLf &amp; line2;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="bc77da5e-ef7c-4aad-923b-b92903f39e9f">
