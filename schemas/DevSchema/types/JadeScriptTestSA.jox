<Class name="JadeScriptTestSA" id="e96e0465-cdbd-4a1e-8cb0-c840cddeda21">
    <superclass name="JadeScript"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <JadeMethod name="displayClassName" id="0e3f69cb-6bd1-4037-b628-c254afeb334a">
        <source>displayClassName();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2025	navsaa30	Initial creation

*/

constants
	Separator	: String = "::";
vars
	property		: Property;
	klass			: Class;
	klassName		: String;
begin
	klass := CM_TrackedItem.class;
	klassName := klass.name;
	foreach property in klass.cnGetProperties() do
		write klassName &amp; Separator &amp; property.name;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getClassMethodsList" id="11a777d3-4247-4a36-8e22-d1ab77de2cb2">
        <source>getClassMethodsList();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2025	naviv1	Initial creation

*/
constants
Separator	: String = "::";
vars
	mtd				: Method;
	klass			: Class;
	klassName		: String;
begin
	klass := CM_Commodity.class;
	klassName := klass.name;
	foreach mtd in klass.cnGetMethods() do
		write klassName &amp; Separator &amp; mtd.name;
	endforeach;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="getClassMethodsList2" id="150dd837-5e6b-4e65-b69a-52a481ce8d1e">
