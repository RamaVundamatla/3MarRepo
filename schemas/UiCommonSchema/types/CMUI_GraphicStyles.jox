    <JadeMethod name="doDrawFillFrame" id="3a0aa9b4-b8eb-426f-811c-42b550350fed">
        <source>doDrawFillFrame(_frm : CMUI_Frame input; _style : Integer; _colour : Integer);
/*
Date		    Who			Reason
06 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	_frm.clearGraphics();
	
	_frm.autoRedraw := true;
		
	_frm.backColor := self.frmToolbar.backColor;
	_frm.bevelColor := _frm.backColor;
	_frm.drawFillStyle := _style;	
	_frm.drawFillColor := _colour;
	_frm.drawFilledRectangle(0, 0, _frm.width, _frm.height, self.frmToolbar.backColor);
	
epilog

end;</source>
        <Parameter name="_frm" type="CMUI_Frame" usage="input"/>
        <Parameter name="_style" type="Integer"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDrawFills" id="8fa39b86-c3ef-492f-a15d-d572d9eac91e">
        <source>doDrawFills(_colour : Integer);
/*
Date		    Who			Reason
07 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	self.doDrawFillFrame(self.frmFillStyle1, Frame.DrawFillStyle_Cross, _colour);
	self.doDrawFillFrame(self.frmFillStyle2, Frame.DrawFillStyle_DiagonalCross, _colour);
	self.doDrawFillFrame(self.frmFillStyle3, Frame.DrawFillStyle_DownDiagonal, _colour);
	self.doDrawFillFrame(self.frmFillStyle4, Frame.DrawFillStyle_HorzLine, _colour);
	self.doDrawFillFrame(self.frmFillStyle5, Frame.DrawFillStyle_Solid, _colour);
	self.doDrawFillFrame(self.frmFillStyle6, Frame.DrawFillStyle_UpDiagonal, _colour);
	self.doDrawFillFrame(self.frmFillStyle7, Frame.DrawFillStyle_VertLine, _colour);
	self.doDrawFillFrame(self.frmFillStyle8, Frame.DrawFillStyle_Transparent, _colour);
epilog

end;</source>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDrawFrameDemos" id="3bfd6a89-d0a9-4a03-85d1-c61963387e8d">
        <source>doDrawFrameDemos(_width,_lineColour,_fillColour : Integer);
/*
Date		    Who			Reason
05 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	
begin
	
	self.doDrawLines(_width,_lineColour);		
	self.doDrawFills(_fillColour);
	
epilog

end;</source>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_lineColour" type="Integer"/>
        <Parameter name="_fillColour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDrawLineFrame" id="2770e860-0120-407d-a11c-ab7f81300d27">
        <source>doDrawLineFrame(_frm : CMUI_Frame input; _style : Integer; _width : Integer;_colour : Integer);
/*
Date		    Who			Reason
06 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	_frm.clearGraphics();
	_frm.autoRedraw := true;
	
	_frm.drawStyle := _style;
	_frm.drawWidth := _width;
	_frm.drawFillColor := _colour;
	_frm.drawLine(0, _frm.height/3, _frm.width, _frm.height/3, _colour);
epilog

end;</source>
        <Parameter name="_frm" type="CMUI_Frame" usage="input"/>
        <Parameter name="_style" type="Integer"/>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDrawLines" id="96632fe5-3702-4c92-8002-a94276885f1e">
        <source>doDrawLines(_width : Integer; _colour : Integer);
/*
Date		    Who			Reason
07 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	self.doDrawLineFrame(self.frmLineStyle1,Frame.DrawStyle_Dash,_width,_colour);
	self.doDrawLineFrame(self.frmLineStyle2,Frame.DrawStyle_DashDot,_width,_colour);
	self.doDrawLineFrame(self.frmLineStyle3,Frame.DrawStyle_DashDotDot,_width,_colour);
	self.doDrawLineFrame(self.frmLineStyle4,Frame.DrawStyle_Dot,_width,_colour);
	self.doDrawLineFrame(self.frmLineStyle5,Frame.DrawStyle_Solid,_width,_colour);	
	self.doDrawLineFrame(self.frmLineStyle6,Frame.DrawStyle_Transparent,_width,_colour);	
epilog

end;</source>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doIgnoreSkin" id="8fef57d5-cb76-4026-97f2-b662b4b371dd">
        <source>doIgnoreSkin();
// ---------------------------------------------------------------------------
// Created:     23 May 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.btnFillColour1.ignoreSkin := true;
	self.btnFillColour2.ignoreSkin := true;
	self.btnFillColour3.ignoreSkin := true;
	self.btnFillColour4.ignoreSkin := true;
	self.btnFillColour5.ignoreSkin := true;
	self.btnFillColour6.ignoreSkin := true;
	self.btnFillColour7.ignoreSkin := true;
	self.btnFillColour8.ignoreSkin := true;
	self.btnFillColour9.ignoreSkin := true;
	self.btnFillColour10.ignoreSkin := true;
	self.btnFillColour11.ignoreSkin := true;
	self.btnFillColour12.ignoreSkin := true;

	
	self.btnLineColour1.ignoreSkin := true;
	self.btnLineColour2.ignoreSkin := true;
	self.btnLineColour3.ignoreSkin := true;
	self.btnLineColour4.ignoreSkin := true;
	self.btnLineColour5.ignoreSkin := true;
	self.btnLineColour6.ignoreSkin := true;
	self.btnLineColour7.ignoreSkin := true;
	self.btnLineColour8.ignoreSkin := true;
	self.btnLineColour9.ignoreSkin := true;
	self.btnLineColour10.ignoreSkin := true;
	self.btnLineColour11.ignoreSkin := true;
	self.btnLineColour12.ignoreSkin := true;

	self.btnLineWidth1.ignoreSkin := true;
	self.btnLineWidth2.ignoreSkin := true;
	self.btnLineWidth3.ignoreSkin := true;
	self.btnLineWidth4.ignoreSkin := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadSelectedControls" id="0b9fcd87-78a8-4764-ba4b-fcbf9619924e">
        <source>doLoadSelectedControls();
/*
Date		    Who			Reason
08 April 2011	cnwas3	  Initial creation: CCMS 1031
When form initiates, it preselects the current fill and line styles, based on the proxy settings
*/

vars
	lineStyle,fillStyle, lineColour, fillColour, lineDrawWidth  : Integer;
	cntrl : Control;
	grpBox : CMUI_GroupBox;
	frm : CMUI_Frame;
begin
	if self.myCurrentDeckItemLayout = null then
		return;
	endif;

	fillStyle := self.myCurrentDeckItemLayout.drawFillStyle;	
	lineStyle := self.myCurrentDeckItemLayout.drawLineStyle;
	lineColour := self.myCurrentDeckItemLayout.drawLineColour;	
	fillColour := self.myCurrentDeckItemLayout.drawFillColour;
	lineDrawWidth := self.myCurrentDeckItemLayout.drawWidth;
	
	foreach cntrl in self.allControlsByName do
		if (cntrl.isKindOf(CMUI_Frame)) then
			if cntrl.parent.isKindOf(CMUI_GroupBox) then
				grpBox := cntrl.parent.CMUI_GroupBox;
				frm := cntrl.CMUI_Frame;
				if grpBox = self.grpFillStyle then
					if frm.drawFillStyle = fillStyle then
						self.doSelectFrame(frm);							
					endif;
				elseif frm.drawStyle = lineStyle	then
					self.doSelectFrame(frm);
				endif;
			endif;
		elseif (cntrl.isKindOf(CMUI_Button)) then
			if cntrl.parent.isKindOf(CMUI_ToolbarFrame) then
				if cntrl.parent.CMUI_ToolbarFrame = self.frmColourButtons then
					if cntrl.CMUI_Button.backColor = fillColour then
						cntrl.CMUI_Button.value := true;
					endif;
				elseif cntrl.parent.CMUI_ToolbarFrame = self.frmLineColour then
					if cntrl.CMUI_Button.backColor = lineColour then
						cntrl.CMUI_Button.value := true;
					endif;
				elseif cntrl.parent.CMUI_ToolbarFrame = self.frmLineWidth then
					if cntrl.CMUI_Button.drawWidth = lineDrawWidth then
						cntrl.CMUI_Button.value := true;
					endif;
				endif;
			endif;
		
		endif;
		
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectFrame" id="2e38772c-250f-42d8-84db-6ecad2aa7e8b">
        <source>doSelectFrame(_frm : Frame input);
/*
Date		    Who			Reason
07 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	frmGroup : CMUI_GroupBox;
	frm : CMUI_Frame;
	cntrl : Control;
begin
		
	_frm.bevelInner := 1;
	_frm.bevelInnerWidth := 3;
	frmGroup := _frm.parent.CMUI_GroupBox;
	
	if frmGroup = self.grpFillStyle then 
		self.myCurrentDeckItemLayout.setDrawFillStyle(_frm.drawFillStyle);
	else
		self.myCurrentDeckItemLayout.setProxyLineStyle(_frm.drawStyle);
	endif;
	
	foreach cntrl in self.allControlsByName where cntrl &lt;&gt; _frm and cntrl.parent = frmGroup do
		self.doUnselectFrame(cntrl.CMUI_Frame);
	endforeach;
epilog

end;</source>
        <Parameter name="_frm" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSetupToolbarFrames" id="05d8d744-6264-4dfe-8493-e9f7e070763e">
        <updating/>
        <source>doSetupToolbarFrames() updating;
/*
Date		    Who			Reason
07 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	
begin
// TFS 50421	self.frmColourButtons.width := self.grpFillStyle.width - self.btnColoursFill.width + 1;
	self.frmColourButtons.borderStyle := 0;
	
	self.btnFillColour1.left := 1;
	self.btnFillColour1.backColor := White;
	self.btnFillColour2.left := self.btnFillColour1.left + self.btnFillColour1.width + 1;
	self.btnFillColour2.backColor := Black;
	self.btnFillColour3.left := self.btnFillColour2.left + self.btnFillColour2.width + 1;
	self.btnFillColour3.backColor := Grey;
	self.btnFillColour4.left := self.btnFillColour3.left + self.btnFillColour3.width + 1;
	self.btnFillColour4.backColor := LightGray;
	self.btnFillColour5.left := self.btnFillColour4.left + self.btnFillColour4.width + 1;
	self.btnFillColour5.backColor := SkyBlue;
	self.btnFillColour6.left := self.btnFillColour5.left + self.btnFillColour5.width + 1;
	self.btnFillColour6.backColor := DarkBlue;
	self.btnFillColour7.left := self.btnFillColour6.left + self.btnFillColour6.width + 1;
	self.btnFillColour7.backColor := Green;
	self.btnFillColour8.left := self.btnFillColour7.left + self.btnFillColour7.width + 1;
	self.btnFillColour8.backColor := LightGreen;
	self.btnFillColour9.left := self.btnFillColour8.left + self.btnFillColour8.width + 1;
	self.btnFillColour9.backColor := Brown;
	self.btnFillColour10.left := self.btnFillColour9.left + self.btnFillColour9.width + 1;
	self.btnFillColour10.backColor := Mauve;
	self.btnFillColour11.left := self.btnFillColour10.left + self.btnFillColour10.width + 1;
	self.btnFillColour11.backColor := Red;
	self.btnFillColour12.left := self.btnFillColour11.left + self.btnFillColour11.width + 1;
	self.btnFillColour12.backColor := Yellow;	
	
	
	self.btnLineColour1.left := 1;
	self.btnLineColour1.backColor := White;
	self.btnLineColour2.left := self.btnLineColour1.left + self.btnLineColour1.width + 1;
	self.btnLineColour2.backColor := Black;
	self.btnLineColour3.left := self.btnLineColour2.left + self.btnLineColour2.width + 1;
	self.btnLineColour3.backColor := Gray;
	self.btnLineColour4.left := self.btnLineColour3.left + self.btnLineColour3.width + 1;
	self.btnLineColour4.backColor := LightGray;
	self.btnLineColour5.left := self.btnLineColour4.left + self.btnFillColour4.width + 1;
	self.btnLineColour5.backColor := SkyBlue;
	self.btnLineColour6.left := self.btnLineColour5.left + self.btnLineColour5.width + 1;
	self.btnLineColour6.backColor := DarkBlue;
	self.btnLineColour7.left := self.btnLineColour6.left + self.btnLineColour6.width + 1;
	self.btnLineColour7.backColor := Green;
	self.btnLineColour8.left := self.btnLineColour7.left + self.btnLineColour7.width + 1;
	self.btnLineColour8.backColor := LightGreen;
	self.btnLineColour9.left := self.btnLineColour8.left + self.btnLineColour8.width + 1;
	self.btnLineColour9.backColor := Brown;
	self.btnLineColour10.left := self.btnLineColour9.left + self.btnLineColour9.width + 1;
	self.btnLineColour10.backColor := Mauve;
	self.btnLineColour11.left := self.btnLineColour10.left + self.btnLineColour10.width + 1;
	self.btnLineColour11.backColor := Red;
	self.btnLineColour12.left := self.btnLineColour11.left + self.btnLineColour11.width + 1;
	self.btnLineColour12.backColor := Yellow;	
	
	self.frmLineColour.width := self.btnLineColour12.left + self.btnLineColour12.width + 4;
	self.frmLineColour.borderStyle := 0;
	
//	self.frmLineWidth.width := self.grpLineStyle.width - self.btnColoursLines.width - self.frmLineColour.width - 1;
	self.frmLineWidth.borderStyle := 0;
	
	self.lblLineWidth.alignment := 1;
	self.lblLineWidth.autoSize := true;
	self.lblLineWidth.top := 5;
	
	self.lblLineWidth.left := 9;
	self.btnLineWidth1.left := self.lblLineWidth.left + self.lblLineWidth.width + 5; self.btnLineWidth1.drawWidth := 1;
	self.btnLineWidth2.left := self.btnLineWidth1.left + self.btnLineWidth1.width + 5; self.btnLineWidth2.drawWidth := 2;
	self.btnLineWidth3.left := self.btnLineWidth2.left + self.btnLineWidth2.width + 5; self.btnLineWidth3.drawWidth := 3;
	self.btnLineWidth4.left := self.btnLineWidth3.left + self.btnLineWidth3.width + 5; self.btnLineWidth4.drawWidth := 4;
	
	
epilog

end;</source>
    </JadeMethod>
