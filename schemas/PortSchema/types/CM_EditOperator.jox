    <JadeMethod name="docketCorrection" id="778e11ab-f8d1-4191-a717-5e34261c80aa">
        <updating/>
        <source>docketCorrection( _bol : CM_BOLIn ) updating;
// --------------------------------------------------------------------------------------------------------
// Created:     13 Feb 2008 by cnwvu1
//
// Purpose:     ccms1089. Docket Correction.
// 				a) clones the transaction and puts the clone into the array self.previousVersions
// 				b) corrects myOperator and myProductFrom field for the transaction
// --------------------------------------------------------------------------------------------------------

vars
	
begin

	inheritMethod( _bol );
	
end;
</source>
        <Parameter name="_bol" type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="docketCorrectionForSupplier" id="001b75c8-46e5-4fb0-b03c-e532f3cf3f16">
        <updating/>
        <source>docketCorrectionForSupplier( _bol : CM_BOLIn; _operatorCorrection, _productCorrection : Boolean ) updating;
// --------------------------------------------------------------------------------------------------------
// Created:     13 Feb 2008 by cnwvu1
//
// Purpose:     ccms1089. Docket Correction.
// 				a) clones the transaction and puts the clone into the array self.previousVersions
// 				b) corrects myOperator (if requires) and myProductFrom fields for the transaction
// --------------------------------------------------------------------------------------------------------

vars

begin

	if _bol.myOperator = null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Docket Corrections. The Operator is null for the CM_EditOperator transaction correction' );
		return;
	endif;

	if not _operatorCorrection and not _productCorrection then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Should be at least one correction for the Docket Correction' );
	endif;
	
	if _productCorrection then
		self.docketCorrection( _bol );
	else
		self.savePreviousVersion();
	endif;
	
	if _operatorCorrection then
		// editing transaction's info fieldsValues : BString
		self.correctValueFrom_forClass( _bol, CM_TrackedItem::myOperator );
		self.correctFieldsValues_primitive( CM_TrackedItem::operatorCode, _bol.myOperator.code, null );
		self.myOperatorFrom := _bol.myOperator;
	endif;
	
end;
</source>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_operatorCorrection" type="Boolean"/>
        <Parameter name="_productCorrection" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCCEventProperties" id="bcaf26b8-7338-489e-8b9f-4f0c764faaf3">
        <source>getCCEventProperties(ccEvent: CMIF_CCEvent) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 45963

*/

vars

	operatorBefore : String;
	operatorAfter : String;
	
begin

	if self.myOperatorFrom &lt;&gt; null then
		operatorBefore := self.myOperatorFrom.description;
		if operatorBefore = null then
			operatorBefore := self.myOperatorFrom.code;
		endif;
	endif;
	if self.myOperatorTo &lt;&gt; null then
		operatorAfter := self.myOperatorTo.description;
		if operatorAfter = null then
			operatorAfter := self.myOperatorTo.code;
		endif;
	endif;

	inheritMethod(ccEvent);
	
	ccEvent.addText( "operatorBefore", operatorBefore );
	ccEvent.addText( "operatorAfter", operatorAfter) ;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="ccEvent" type="CMIF_CCEvent"/>
    </JadeMethod>
    <JadeMethod name="getCCEventType" id="a38bf7ec-9f95-4c53-8364-5b5ba9a45181">
        <source>getCCEventType(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation		TFS 45963

*/

vars

begin
	return CC_EventType_OperChange;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="09f5198b-351c-40f4-bd35-ddee8b7ea633">
        <source>getDisplayString(): String;
//--------------------------------------------------------------
//Created: 27 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	detail : String;
begin
	if self.myOperatorFrom &lt;&gt; null then
		detail := 'From ' &amp; self.myOperatorFrom.description;
	endif;	
	if self.myOperatorTo &lt;&gt; null then
		detail := detail &amp; ' to ' &amp; self.myOperatorTo.description;
	endif;
	
	return detail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="979dea7f-ff75-49d6-b1d1-f28ed3b29ae2">
        <source>getEnquiryRow(): String;
//--------------------------------------------------------------
//Created: 27 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	detail : String;
begin
	detail := inheritMethod();
	if self.myOperatorFrom &lt;&gt; null and app.isValidObject(self.myOperatorFrom) then//changed by cnwyl1 for par15317
		detail := detail &amp; 'From ' &amp; self.myOperatorFrom.description;
	endif;	
	if self.myOperatorTo &lt;&gt; null and app.isValidObject(self.myOperatorTo) then//changed by cnwyl1 for par15317
		detail := detail &amp; ' to ' &amp; self.myOperatorTo.description;
	endif;
	
	detail := detail &amp; ' Reason : ' &amp; self.reasonCode;

	return detail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperatorToCode" id="a94aedfd-0ab2-4359-9512-bbabf6a3a6bd">
        <source>getOperatorToCode(): String;
// ---------------------------------------------------------------------------
// Created:     24 November 2003	cnwth2
//
// Purpose:     USED IN REPORTS - DON'T DELETE
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.myOperatorTo.code;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TIUpdateController" id="a7f4f7a8-cc15-4d45-9ee3-5a42ceeb6429">
        <updating/>
        <source>setFromCMIF_TIUpdateController(_tiUpdateCntrlr: CMIF_TIUpdateController; _passport : CM_Passport) updating;
//--------------------------------------------------------------
//Created: 02 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_tiUpdateCntrlr, _passport);
	self.myOperatorFrom := _tiUpdateCntrlr.myOperatorFrom;
	self.myOperatorTo 	:= _tiUpdateCntrlr.myOperatorTo;

end;</source>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateCMIF_TIUpdateCntrlr" id="3bce9d64-6926-446a-8191-4fdae27a9709">
        <source>validateCMIF_TIUpdateCntrlr(_tiUpdateCntrlr: CMIF_TIUpdateController; _passport : CM_Passport input): Boolean;
//--------------------------------------------------------------
//Created: 02 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if (not inheritMethod(_tiUpdateCntrlr, _passport)) then
		return false;
	endif;
	
	if _tiUpdateCntrlr.myOperatorFrom = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null myOperatorFrom. Contact Developer.');
	endif;
	if _tiUpdateCntrlr.myOperatorTo = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null myOperatorTo. Contact Developer.');
	endif;	

epilog
	return _passport.noErrors();

end;</source>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
