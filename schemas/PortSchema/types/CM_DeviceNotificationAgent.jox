    <JadeMethod name="sendNotification" id="58b2d956-8638-4bb3-bd84-c62700cfdd9b">
        <source>sendNotification(user : CM_User; _message : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2013	cnwmc5	Initial creation

*/

vars
	
begin
	if user.notificationPlatform &lt;&gt; null and user.notificationToken &lt;&gt; null then
		if user.notificationPlatform.toLower() = "android" then
			sendToAndroidUser(user.notificationToken, _message);
		elseif user.notificationPlatform.toLower() = "ios" then
			sendToiOSUser(user.notificationToken, _message);
		endif;
	endif;
epilog
	
end;</source>
        <Parameter name="user" type="CM_User"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="sendNotificationToAll" id="2041e979-4c7d-49fd-b99c-9a6983045a39">
        <source>sendNotificationToAll(_message, _topic : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2013	cnwmc5	Initial creation

*/

vars
	user 				: CM_User;
	allTokensAndroid	: HugeStringArray;
	allTokensiOS		: HugeStringArray;
begin
	create allTokensAndroid transient;
	create allTokensiOS transient;
	
	foreach user in app.myRoot.allUsers do
		if user.notificationPlatform &lt;&gt; null and user.notificationToken &lt;&gt; null then
			if user.notificationPlatform.toLower() = "android" then
				allTokensAndroid.add(user.notificationToken);
			elseif user.notificationPlatform.toLower() = "ios" then
				allTokensiOS.add(user.notificationToken);
			endif;
		endif;
	endforeach;
	
	if allTokensAndroid.size &gt; 0 then
		sendToAndroidAll(allTokensAndroid, _message, _topic);
	endif;
	
	if allTokensiOS.size &gt; 0 then
		sendToiOSAll(allTokensiOS, _message);
	endif;
epilog
	delete allTokensAndroid;
	delete allTokensiOS;
end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_topic" type="String"/>
    </JadeMethod>
    <JadeMethod name="sendRequestToAndroidGCM" id="1760907c-0008-4645-86f9-67e57ecbdf1c">
        <source>sendRequestToAndroidGCM( _message : String ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2013	cnwmc5	Initial creation

*/

vars
	i 			: Integer;
	response 	: Boolean;
	isOpen 		: Boolean;
begin
	http.url := ANDROID_SERVERURL;
	http.setContentType("application/json", i);
	
	app.writeLog("Push Notifications: About to open connection to server: " &amp; http.url &amp; " Proxy host: " 
					&amp; http.proxyHostname &amp; " Proxy user: " &amp; http.proxyUser, LogINFO);
	isOpen := http.open(true);	
	
	if isOpen then
		app.writeLog("Push Notifications: Connection open. About to send request to " &amp; http.url &amp; " containing the message: " &amp; _message, LogINFO);
		response := http.sendRequest("POST", "Authorization:key=" &amp; ANDROID_AUTHKEY, _message);
		
		if response then 
			app.writeLog("Push Notifications: The message was sent successfully. Respone headers: " &amp; http.responseHeaders
							&amp; " Response body: " &amp; http.responseBody.String, LogINFO);
		else
			app.writeLog("Push Notifications: The message did NOT send.. Response headers: " &amp; http.responseHeaders, LogINFO);
		endif;
	else
		app.writeLog("Push Notifications: The connection to " &amp; http.url &amp; " was not successful", LogINFO);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="sendToAndroidAll" id="b4d8544e-d6d9-4142-8207-0419374cddd1">
        <source>sendToAndroidAll(_allTokens : HugeStringArray; _message, _topic : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2013	cnwmc5	Initial creation

*/

vars
	msg				: String;
	date			: Date;
	allTokensAsStr	: String;
	token			: String;
begin
	allTokensAsStr := '[';
	foreach token in _allTokens do
		allTokensAsStr := allTokensAsStr &amp; '"' &amp; token &amp; '",';
	endforeach;
	allTokensAsStr := allTokensAsStr[1:allTokensAsStr.length-1];
	allTokensAsStr := allTokensAsStr &amp; ']';

	msg := 	'{ "collapse_key": "' &amp; _topic &amp; '", "data": {"message": "' &amp; _message &amp; '" }, "registration_ids": ' &amp; allTokensAsStr &amp; '}';
	
	sendRequestToAndroidGCM(msg);
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_allTokens" type="HugeStringArray"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_topic" type="String"/>
    </JadeMethod>
    <JadeMethod name="sendToAndroidUser" id="7c562987-c413-435e-a083-ecb65eb26c5c">
        <source>sendToAndroidUser(_token, _message : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2013	cnwmc5	Initial creation

*/

vars
	msg				: String;
	i				: Integer;
	date			: Date;
	response 		: Boolean;
begin
	msg := 'data.message=' &amp; _message &amp; '&amp;registration_id=' &amp; _token;
	
	self.sendRequestToAndroidGCM(msg);
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_token" type="String"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
