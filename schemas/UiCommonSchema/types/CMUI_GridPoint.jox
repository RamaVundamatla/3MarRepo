    <JadeMethod name="setForCreateTI" id="28f70943-10b9-4f9d-9d9c-f8f1c757615e">
        <updating/>
        <source>setForCreateTI(_theTI : CM_TrackedItem;_theMode : Integer; _controller : CMIF_DrawingAttrController input) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		Get every single piece of info that we need to display the TI and store it in a CMUI_GridAttribute
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	aGridAttributes : CMUI_GridAttributes;

begin
	create aGridAttributes transient;

	if _theMode = REAL_MODE then
		self.allTrackedItemAttributes.add(aGridAttributes);
	elseif _theMode = QUEUE_MODE then
		self.allQueuedTrackedItemAttributes.add(aGridAttributes);
	elseif _theMode = PLANNING_MODE then
		self.allPlanTrackedItemAttributes.add(aGridAttributes);
	endif;
	_theTI.getAllDrawingAttributes(aGridAttributes, _controller);

	if aGridAttributes.width &lt; 1 then
		aGridAttributes.width := 1;
	endif;

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theMode" type="Integer"/>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateTIXML" id="28bd3751-efab-452e-a0c7-78711aa72524">
        <updating/>
        <source>setForCreateTIXML(_theXMLString : String;_theMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1 - currently only used by yard. Ship has its own version
//
// Purpose:		Get every single piece of info that we need to display the TI and store it in a CMUI_GridAttribute
//				NOTE each piece of XML is a TI
// ---------------------------------------------------------------------------

vars
	aGridAttributes : CMUI_GridAttributes;
	theSArray,theCArray : StringArray;
	theIArray : IntegerArray;
	theTI,theDummyTI : CM_TrackedItem;
	isPrimary : Boolean;
	theXMLTag : String;
	pos, index : Integer;
	theOArray : ObjectArray;
begin
	
	theDummyTI := self.myGridArea.myDummyTI;
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("TO");
	if theXMLTag &lt;&gt; null then
		theTI := theXMLTag.asOid.CM_TrackedItem;
	endif;
	
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("PRIM");
	if theXMLTag &lt;&gt; null then
		isPrimary := theXMLTag.Integer.Boolean;
		
//		if theTI.getPrimaryLocation(_theMode) = self.myLocationsController then
		if isPrimary then		
			if _theMode = REAL_MODE then
				self.allTrackedItems.add(theTI);
			elseif _theMode = PLANNING_MODE then
				self.allPlannedTrackedItems.add(theTI);
			elseif _theMode = QUEUE_MODE then
				self.allQueuedTrackedItems.add(theTI);
			endif;
		else
			if _theMode = REAL_MODE then
				self.allTrackedItems.add(theDummyTI);
			elseif _theMode = PLANNING_MODE then
				self.allPlannedTrackedItems.add(theDummyTI);
			elseif _theMode = QUEUE_MODE then
				self.allQueuedTrackedItems.add(theDummyTI);
			endif;
		endif;
	endif;
	
	create aGridAttributes transient;
	if _theMode = REAL_MODE then
		self.allTrackedItemAttributes.add(aGridAttributes);
	elseif _theMode = QUEUE_MODE then
		self.allQueuedTrackedItemAttributes.add(aGridAttributes);
	elseif _theMode = PLANNING_MODE then
		self.allPlanTrackedItemAttributes.add(aGridAttributes);
	endif;
	create theCArray transient;
	create theSArray transient;
	create theIArray transient;
	create theOArray transient;
	
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("id");
	if theXMLTag &lt;&gt; null then
		aGridAttributes.id := theXMLTag;
	endif;
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("wt");
	if theXMLTag &lt;&gt; null then
		aGridAttributes.weight := (theXMLTag.Integer / 1000).rounded;
	endif;
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("ht");
	if theXMLTag &lt;&gt; null then
		aGridAttributes.height := theXMLTag.Integer;
	endif;
	theXMLTag := _theXMLString.cnEcGetTagValueOfName("wd");
	if theXMLTag &lt;&gt; null then
		aGridAttributes.width := theXMLTag.Integer;
		if aGridAttributes.width &lt; 1 then
			aGridAttributes.width := 1;
		endif;
		aGridAttributes.width := (aGridAttributes.width / 2).Integer;

	endif;
	// ### COLOURS
	pos := 1;
	while (pos &lt;&gt; 0) do
		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("cc",pos);
		if pos = 0 then
			break;
		endif;
		index :=  _theXMLString.cnEcGetNextTagValueOfName("ci",pos).Integer;
		if theXMLTag &lt;&gt; null then
			theIArray.atPut(index,theXMLTag.Integer);
		endif;
	endwhile;
	// ### ICONS
	pos := 1;
	while (pos &lt;&gt; 0) do
		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("at",pos);
		if theXMLTag &lt;&gt; null then
			theSArray.add(theXMLTag);
		endif;
	endwhile;
	// ## CODES
	pos := 1;
	while (pos &lt;&gt; 0) do
		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("cd",pos);
		if pos = 0 then
			break;
		endif;
		index :=  _theXMLString.cnEcGetNextTagValueOfName("ci",pos).Integer;
		if theXMLTag &lt;&gt; null then
			theCArray.atPut(index,theXMLTag);
		endif;
	endwhile;
/*
	// ## OBJECTS
	pos := 1;
	while (pos &lt;&gt; 0) do
		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("cd",pos);
		if pos = 0 then
			break;
		endif;
		index :=  _theXMLString.cnEcGetNextTagValueOfName("ci",pos).Integer;
		if theXMLTag &lt;&gt; null then
			theOArray.atPut(index,anObject);
			if _controller.myTerminal &lt;&gt; null and anObject &lt;&gt; null then
				self.beginNotification(anObject, _controller.myTerminal.getTerminalEvent(EVENT_CODE_COLOUR_CHANGE), Response_Continuous, null);
			endif;

		endif;
	endwhile;
*/
	theIArray.copy(aGridAttributes.allDisplayColors);
	theSArray.copy(aGridAttributes.allDisplayIcons);
	theCArray.copy(aGridAttributes.allDisplayCodes);
	theOArray.copy(aGridAttributes.allDisplayObjects);


epilog
	delete theCArray;
	delete theSArray;
	delete theIArray;
	delete theOArray;
end;</source>
        <Parameter name="_theXMLString" type="String"/>
        <Parameter name="_theMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreateTI_Array" id="36f1bd57-b74a-4ed8-b9dc-3e185f6e8b0d">
        <updating/>
        <source>setForCreateTI_Array(_array : StringArray; _theMode : Integer; 
			_controller : CMIF_DrawingAttrController input; 
			_tmpArray : StringArray input) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1 - currently only used by yard. Ship has its own version
//
// Purpose:		Get every single piece of info that we need to display the TI and store it in a CMUI_GridAttribute
//				NOTE each piece of XML is a TI
// ---------------------------------------------------------------------------
vars
	aGridAttributes : CMUI_GridAttributes;
	tmpIcons,
	tmpCodes		: StringArray;
	tmpColours 		: IntegerArray;
	theTI,
	theDummyTI 		: CM_TrackedItem;
	isPrimary		: Boolean;
	tmpStr			: String;
	tmpColorCodeChangeEvent,
	i,
	idx				: Integer;
	anObject 	: Object;
	tmpDisplayObjects	: ObjectArray;
	tmpDisplayColors	: IntegerArray;

begin
	
	theDummyTI := self.myGridArea.myDummyTI;

	theTI := _array[3].asOid.CM_TrackedItem;

	isPrimary := _array[2].Integer.Boolean;
		
	if isPrimary then		
		if _theMode = REAL_MODE then
			self.allTrackedItems.add(theTI);
		elseif _theMode = PLANNING_MODE then
			self.allPlannedTrackedItems.add(theTI);
		elseif _theMode = QUEUE_MODE then
			self.allQueuedTrackedItems.add(theTI);
		endif;
	else
		// theDummyTI is used for the back end of a 40
		if _theMode = REAL_MODE then
			self.allTrackedItems.add(theDummyTI);
		elseif _theMode = PLANNING_MODE then
			self.allPlannedTrackedItems.add(theDummyTI);
		elseif _theMode = QUEUE_MODE then
			self.allQueuedTrackedItems.add(theDummyTI);
		endif;
	endif;
	
	create aGridAttributes transient;
	if _theMode = REAL_MODE then
		self.allTrackedItemAttributes.add(aGridAttributes);
	elseif _theMode = QUEUE_MODE then
		self.allQueuedTrackedItemAttributes.add(aGridAttributes);
	elseif _theMode = PLANNING_MODE then
		self.allPlanTrackedItemAttributes.add(aGridAttributes);
	endif;

	aGridAttributes.id		:= _array[4];
	aGridAttributes.height	:= _array[5].Integer;
	aGridAttributes.width	:= _array[6].Integer;
	if aGridAttributes.width &lt; 1 then
		aGridAttributes.width := 1;
	endif;
	aGridAttributes.width := (aGridAttributes.width / 2).Integer;

	aGridAttributes.weight := (_array[7].Integer / 1000).rounded;

	// Now handle the codes/colour details

	tmpColours	:= aGridAttributes.allDisplayColors;

//	tmpCodes.atPut(TI_ColourMode_Max, null);
//	tmpColours.atPut(TI_ColourMode_Max, -1);

	// #### CODES
	tmpStr := _array[8];
	tmpStr.getTokensForDelimiter(GridData_SubDelimiter, aGridAttributes.allDisplayCodes);
	
	// #### COLOUR
	tmpStr := _array[9];
	_tmpArray.clear;
	tmpStr.getTokensForDelimiter(GridData_SubDelimiter, _tmpArray);
	
	tmpDisplayColors := aGridAttributes.allDisplayColors;
	tmpDisplayObjects := aGridAttributes.allDisplayObjects;
	
	idx := 0;
	foreach tmpStr in _tmpArray do
		if tmpStr.Integer = NullColour then
			tmpDisplayColors.add(White);
		else
			tmpDisplayColors.add(tmpStr.Integer);
		endif;
	endforeach;

	// #### OBJECTS
	tmpStr := _array[10];
	_tmpArray.clear;
	tmpStr.getTokensForDelimiter(GridData_SubDelimiter, _tmpArray);
	
	if _controller.myTerminal &lt;&gt; null then
		tmpColorCodeChangeEvent := EVENT_CODE_COLOUR_CHANGE;
	endif;
	
	idx := 0;
	foreach tmpStr in _tmpArray do
		anObject := null;
		if tmpStr &lt;&gt; null then
			anObject := tmpStr.asOid;
			if anObject &lt;&gt; null then
				self.beginNotification(anObject, tmpColorCodeChangeEvent, Response_Continuous, null);
			endif;
		endif;
		tmpDisplayObjects.add(anObject);
	endforeach;
	
	// #### ICONS
	tmpStr := _array[11];
	tmpStr.getTokensForDelimiter(GridData_SubDelimiter, aGridAttributes.allDisplayIcons);

end;</source>
        <Parameter name="_array" type="StringArray"/>
        <Parameter name="_theMode" type="Integer"/>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
        <Parameter name="_tmpArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8343cdd6-d648-4bf2-9a08-0d5bf2e2fc35">
        <updating/>
        <source>setForUpdate(_controller : CMIF_DrawingAttrController input)updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.allPlanTrackedItemAttributes.purge;
	self.allQueuedTrackedItemAttributes.purge;
	self.allTrackedItemAttributes.purge;
	self.allTrackedItems.clear;
	self.allPlannedTrackedItems.clear;
	self.allQueuedTrackedItems.clear;
//	self.myGridArea.mySDF.myParentForm.sendMsgWithParams("doNoteForObject", self); // this will update the macro info table

end;</source>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateAssociatedPoint" id="eeb58390-ff2d-443b-9edb-a84bfeb55d72">
        <source>setForUpdateAssociatedPoint(_controller : CMIF_DrawingAttrController input);
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	lGridPoint : CMUI_GridPoint;
	gridArea : CMUI_GridArea;
	gridFrame : CMUI_GridAreaFrame;
	lCol , lRow : Integer;
	yardFlippedDropOnRight : Boolean;
begin
	gridArea := self.myGridArea;
	gridFrame := gridArea.myGridAreaFrame;
	
	lRow := self.row;

	lCol := self.column + 1;
	lGridPoint := gridArea.allGridPoints[lRow,lCol];
	if lGridPoint &lt;&gt; null then
		lGridPoint.setForUpdate(_controller); // update all the attributes for this point - mainly TI properties
		lGridPoint.drawBetweenPoints(gridFrame); // clear the 2 pixel gap between points
		lGridPoint.drawSelf(gridFrame);
	endif;
	lCol := self.column - 1;
	lGridPoint := gridArea.allGridPoints[lRow,lCol];
	if lGridPoint &lt;&gt; null then
		lGridPoint.setForUpdate(_controller); // update all the attributes for this point - mainly TI properties
		lGridPoint.drawBetweenPoints(gridFrame); // clear the 2 pixel gap between points
		lGridPoint.drawSelf(gridFrame);
	endif;

end;</source>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setSelectedDrawingAttributes" id="de9a6c19-1f02-4119-b49d-d271876e1068">
