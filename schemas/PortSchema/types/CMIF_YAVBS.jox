    <JadeMethod name="getMatchingCargoTypes" id="6cf68157-76d3-4528-944b-e7625bbb0997">
        <source>getMatchingCargoTypes(_checkObject	: Object;
					    _objSet     	: ObjectSet io	);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023 navma1  ChangeRequest 54049: EUP - VBS MTN - [9] - Linking Multiple Slots to Vehicle visit
03 Aug 2023	navma1	Bug 59263: Error 1090 when validating VBS Slots Criteria
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
*/

vars
	cmgte			: CMGTE_Entity;
	vbsSlotItem		: CM_VehicleBookingTimeSlotItem;
	cargoTypeId		: Integer;
	cargoType		: CM_CargoBOLType;
begin
	
	if _checkObject.isKindOf(CMGTE_Entity) then
		cmgte 		:= _checkObject.CMGTE_Entity;
	elseif _checkObject.isKindOf(CM_VehicleBookingTimeSlotItem) then
		vbsSlotItem := _checkObject.CM_VehicleBookingTimeSlotItem;
	elseif _checkObject.isKindOf(CM_BookingRefItem) then
		cargoType 	:= _checkObject.CM_BookingRefItem.myCargoType;
	elseif _checkObject.isKindOf(CM_ReserveDetail) then
		cargoType 	:= _checkObject.CM_ReserveDetail.getMyCargoType();
	elseif _checkObject.isKindOf(CM_TrackedItem) then
		cargoType	:= _checkObject.CM_TrackedItem.myCargoType;
	endif;
	
	if cmgte &lt;&gt; null then
		if cmgte.isKindOf(CMGTE_Receival) then
			cargoTypeId := cmgte.CMGTE_Receival.cargoType;
		elseif cmgte.isKindOf(CMGTE_Release) then
			cargoTypeId := cmgte.CMGTE_Release.cargoType;
		endif;
		
		cargoType := app.myRoot.allCargoTypesById[cargoTypeId];

	elseif vbsSlotItem &lt;&gt; null then
		if vbsSlotItem.myTrackedItem &lt;&gt; null then
			cargoType := vbsSlotItem.myTrackedItem.myCargoType;
		elseif vbsSlotItem.myBookingItem &lt;&gt; null then
			cargoType := vbsSlotItem.myBookingItem.myCargoType;
		elseif vbsSlotItem.myReserveDetails &lt;&gt; null and vbsSlotItem.myReserveDetails.isKindOf(CM_ReserveSelection) then
			cargoType := vbsSlotItem.myReserveDetails.CM_ReserveSelection.myCargoType;
		endif;
	endif;
	
	if cargoType &lt;&gt; null then
		_objSet.addNoDuplicates(cargoType, false);
	endif;
epilog

end;
</source>
        <Parameter name="_checkObject" type="Object"/>
        <Parameter name="_objSet" type="ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMatchingCarrier" id="40a7bf52-bbb5-4fcd-831b-8e667ddf2c7d">
        <source>getMatchingCarrier(_checkObject		: Object;
				   _objSet     		: ObjectSet io	);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023 navma1  ChangeRequest 54049: EUP - VBS MTN - [9] - Linking Multiple Slots to Vehicle visit
03 Aug 2023	navma1	Bug 59263: Error 1090 when validating VBS Slots Criteria

*/

vars
	cmgte			: CMGTE_Entity;
	vbsSlotItem		: CM_VehicleBookingTimeSlotItem;
	carrier			: CM_Carrier;
begin
	
	if _checkObject.isKindOf(CM_VehicleBookingTimeSlot) then
		carrier := _checkObject.CM_VehicleBookingTimeSlot.myCarrier;	//03.08.2023 navma1 #59263
	elseif _checkObject.isKindOf(CMGTE_Entity) then
		cmgte := _checkObject.CMGTE_Entity;
	elseif _checkObject.isKindOf(CM_VehicleBookingTimeSlotItem) then
		vbsSlotItem := _checkObject.CM_VehicleBookingTimeSlotItem;
	endif;
	
	if cmgte &lt;&gt; null and cmgte.myVehicleVisitRecord &lt;&gt; null then
		carrier := cmgte.myVehicleVisitRecord.getCarrier;
	elseif vbsSlotItem &lt;&gt; null then
		if vbsSlotItem.myVehicleBookingSlot &lt;&gt; null  then
			carrier := vbsSlotItem.myVehicleBookingSlot.myCarrier;
		endif;
	endif;
	
	if carrier &lt;&gt; null then
		_objSet.addNoDuplicates(carrier,false);
	endif;
epilog

end;</source>
        <Parameter name="_checkObject" type="Object"/>
        <Parameter name="_objSet" type="ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMatchingCommodities" id="74c4ae9a-e38b-49cc-bdba-f383c5123b45">
        <source>getMatchingCommodities(_checkObject	: Object;
					   _objSet     	: ObjectSet io	);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023 navma1  ChangeRequest 54049: EUP - VBS MTN - [9] - Linking Multiple Slots to Vehicle visit
03 Aug 2023	navma1	Bug 59263: Error 1090 when validating VBS Slots Criteria
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
21 Aug 2023 navma1	Defect 59927: MTN - 1090 exception when updating the VBS slots using EDI
*/

vars
	cmgte			: CMGTE_Entity;
	vbsSlotItem		: CM_VehicleBookingTimeSlotItem;
	commodityCode	: String;
	commodity		: CM_Commodity;
begin
	
	if _checkObject.isKindOf(CMGTE_Entity) then
		cmgte       := _checkObject.CMGTE_Entity;
	elseif _checkObject.isKindOf(CM_VehicleBookingTimeSlotItem) then
		vbsSlotItem := _checkObject.CM_VehicleBookingTimeSlotItem;
	elseif _checkObject.isKindOf(CM_BookingRefItem) then
		commodity   := _checkObject.CM_BookingRefItem.getMyCommodity();
	elseif _checkObject.isKindOf(CM_ReserveSelection) then															//21.08.2023 navma1 #59927
		_checkObject.CM_ReserveSelection.getMatchingCriteriaObjects(_objSet,YACriteriaType_Commodity);				//21.08.2023 navma1 #59927
	elseif _checkObject.isKindOf(CM_TrackedItem) then
		commodity   := _checkObject.CM_TrackedItem.getCommodityObject();
	endif;
	
	if cmgte &lt;&gt; null then
		if cmgte.isKindOf(CMGTE_Receival) then
			commodityCode := cmgte.CMGTE_Receival.commodity;
		elseif cmgte.isKindOf(CMGTE_Release) then
			commodityCode := cmgte.CMGTE_Release.commodity;
		endif;
		
		commodity := app.myRoot.allCommodities[commodityCode];
		
	elseif vbsSlotItem &lt;&gt; null then
		if vbsSlotItem.myTrackedItem &lt;&gt; null then
			commodity := vbsSlotItem.myTrackedItem.getCommodityObject;
		elseif vbsSlotItem.myBookingItem &lt;&gt; null then
			commodity := vbsSlotItem.myBookingItem.getMyCommodity;
		elseif vbsSlotItem.myReserveDetails &lt;&gt; null and vbsSlotItem.myReserveDetails.isKindOf(CM_ReserveSelection) then
			vbsSlotItem.myReserveDetails.CM_ReserveSelection.getMatchingCriteriaObjects(_objSet,YACriteriaType_Commodity);
		endif;
	endif;

	if commodity &lt;&gt; null then
		_objSet.addNoDuplicates(commodity, false);
	endif;
epilog

end;
</source>
        <Parameter name="_checkObject" type="Object"/>
        <Parameter name="_objSet" type="ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMatchingOperators" id="2919ed37-61c2-4252-83fc-34963509e7b3">
        <source>getMatchingOperators(_checkObject	: Object;
					 _objSet     	: ObjectSet io	);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023 navma1  ChangeRequest 54049: EUP - VBS MTN - [9] - Linking Multiple Slots to Vehicle visit
03 Aug 2023	navma1	Bug 59263: Error 1090 when validating VBS Slots Criteria
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
*/

vars
	cmgte			: CMGTE_Entity;
	vbsSlotItem		: CM_VehicleBookingTimeSlotItem;
	operator		: CM_Operator;
begin
	
	if _checkObject.isKindOf(CMGTE_Entity) then
		cmgte	    := _checkObject.CMGTE_Entity;
	elseif _checkObject.isKindOf(CM_VehicleBookingTimeSlotItem) then
		vbsSlotItem := _checkObject.CM_VehicleBookingTimeSlotItem;
	
	elseif _checkObject.isKindOf(CM_BookingRef) then
		operator    := _checkObject.CM_BookingRef.myOperator;
	elseif _checkObject.isKindOf(CM_BookingRefItem) then
		operator    := _checkObject.CM_BookingRefItem.myBookingReference.myOperator;
	elseif _checkObject.isKindOf(CM_BulkRelease) then
		operator    := _checkObject.CM_BulkRelease.myOperator;
	elseif _checkObject.isKindOf(CM_ReserveDetail) then
		operator    := _checkObject.CM_ReserveDetail.myReserveHeader.myOperator;
	elseif _checkObject.isKindOf(CM_TrackedItem) then
		operator    := _checkObject.CM_TrackedItem.myOperator;
	endif;
	
	if cmgte &lt;&gt; null then
		operator := app.myRoot.allOperators[cmgte.operatorCode];
	elseif vbsSlotItem &lt;&gt; null then
		
		if vbsSlotItem.myTrackedItem &lt;&gt; null then
			operator := vbsSlotItem.myTrackedItem.myOperator;
			
		elseif vbsSlotItem.myBookingItem &lt;&gt; null then
			operator := vbsSlotItem.myBookingItem.myBookingReference.myOperator;
		elseif vbsSlotItem.myReserveDetails &lt;&gt; null then
			operator := vbsSlotItem.myReserveDetails.myReserveHeader.myOperator;
		elseif vbsSlotItem.myBooking &lt;&gt; null then
			operator :=vbsSlotItem.myBooking.myOperator;
		elseif vbsSlotItem.myBulkRelease &lt;&gt; null then
			operator := vbsSlotItem.myBulkRelease.myOperator;
		endif;
	endif;
	
	if operator &lt;&gt; null then
		_objSet.addNoDuplicates(operator, false);
	endif;
epilog

end;</source>
        <Parameter name="_checkObject" type="Object"/>
        <Parameter name="_objSet" type="ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMatchingProducts" id="71392e2f-9116-4544-b7c4-afd56f9bfb25">
        <source>getMatchingProducts(_checkObject	: Object;
					 _objSet     	: ObjectSet io	);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2023 navma1  ChangeRequest 54049: EUP - VBS MTN - [9] - Linking Multiple Slots to Vehicle visit
03 Aug 2023	navma1	Bug 59263: Error 1090 when validating VBS Slots Criteria
11 Aug 2023	navma1	Bug 59793: FR | EUP 53429 - EDI upload - Criteria validation, VBS ID, Verification stage, External Ref number duplication.
*/

vars
	cmgte			: CMGTE_Entity;
	vbsSlotItem		: CM_VehicleBookingTimeSlotItem;
	product			: CM_Product;
begin
	
	if _checkObject.isKindOf(CMGTE_Entity) then
		cmgte       := _checkObject.CMGTE_Entity;
	elseif _checkObject.isKindOf(CM_VehicleBookingTimeSlotItem) then
		vbsSlotItem := _checkObject.CM_VehicleBookingTimeSlotItem;
	
	elseif _checkObject.isKindOf(CM_BookingRefItem) then
		product     := _checkObject.CM_BookingRefItem.myProduct;
	elseif _checkObject.isKindOf(CM_ReserveDetail) then
		product     := _checkObject.CM_ReserveDetail.getMyProduct();
	elseif _checkObject.isKindOf(CM_TrackedItem) then
		product     := _checkObject.CM_TrackedItem.myProduct;
	endif;
	
	if cmgte &lt;&gt; null and cmgte.myProduct &lt;&gt; null then
		product := cmgte.myProduct;
	elseif vbsSlotItem &lt;&gt; null then
		if vbsSlotItem.myTrackedItem &lt;&gt; null then
			product := vbsSlotItem.myTrackedItem.myProduct;
		elseif vbsSlotItem.myBookingItem &lt;&gt; null then
			product := vbsSlotItem.myBookingItem.myProduct;
		elseif vbsSlotItem.myReserveDetails &lt;&gt; null and vbsSlotItem.myReserveDetails.isKindOf(CM_ReserveSelection) then
			product := vbsSlotItem.myReserveDetails.CM_ReserveSelection.myProduct;
		endif;
	endif;
	
	if product &lt;&gt; null then
		_objSet.addNoDuplicates(product, false);
	endif;
	
epilog

end;</source>
        <Parameter name="_checkObject" type="Object"/>
        <Parameter name="_objSet" type="ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isCargoType_Match" id="576dae8c-878d-4978-9322-f5732f6ed4ca">
        <source>isCargoType_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Aug 2023	navma1	Bug 59263: Error 1090 when validating VBS Slots Criteria
*/

vars

begin
	if _yaData.isEmpty() then
		return true;
	endif;
	
	// Do we have a match?
	return _yaData.matches(self.myCargoType);
epilog
	
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCarrier_Match" id="15d40a57-b295-48b7-836a-e5fe68b75446">
        <source>isCarrier_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Aug 2023	navma1	Bug 59263: Error 1090 when validating VBS Slots Criteria

*/
vars

begin

	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;

	// Do we have a match?
	return _yaData.matches(self.myCarrier);

end;</source>
