    <JadeMethod name="addAlertId" id="74201542-41e4-4aef-ba08-767c63e06968">
        <updating/>
        <source>addAlertId(str : String) updating;

vars

begin
	if self.generateLog = false then
		return;
	endif;
	if app.alertManager = null then
		app.initialize;	
	endif;
	if self.alertManager = null then
		self.alertManager := app.alertManager;
	endif;
	self.alertManager.logAlert.setAlertId(str);
end;</source>
        <Parameter name="str" type="String"/>
    </JadeMethod>
    <JadeMethod name="addLogEntry" id="2ea26635-a8ad-4aae-8640-00c15596dcdb">
        <source>addLogEntry(str : String; logType : Integer; messageNumber : Integer);
//Simple method to add a log entry to this object.
//I have changed the implimentation  from a CM_Strings to one of a 
//system alert, to gain some level of permanence. Some methods call the
//autoplan internally, I cannot get ccess to the object extrernally.
//This is a good compromise. The automoveplan creates an info alert object
//and populates it with the details of how it did what it did.

//Changes
//30/11/2009, cnwmd1, Par 20524 - New param 'messageNumber' added.  Message number is now included with each log entry output so that the source of errors/warnings are more easily identified.
vars
	ti : CM_TrackedItem;
	logStr : String;
begin
	//+ cnwmd1, Par 20524
	logStr := str;
	ti := self.myTrackedItem;
	if ti &lt;&gt; null then
		logStr := logStr &amp; " " &amp; ti.getLogId();
	endif;

	
	if self.isAutoPlanMove then
		
		if self.generateLog = false then
			return;
		endif;
		logStr := logStr &amp; " " &amp; app.getErrorString1(Message_number, messageNumber.String);
		if self.alertManager &lt;&gt; null then
			self.alertManager.addLogAlert(logStr);
		endif;
		app.writeLog(logStr, LogINFO);
	else
		if logType = IsError then
			app.setContinueCMExceptions(false);
			//app.raiseCMException1(Move_FullReplacementText, logStr, null, null);
			self.raiseAutoPlanException( messageNumber, logStr, null, null);	// 12 Sep 2012	NDL	Par 30346
		elseif logType = IsWarning then
			//app.raiseCMWarning1(Move_FullReplacementText, logStr, null, null,self.myTrackedItem);
			self.raiseAutoPlanWarning( messageNumber, logStr, null, null, self.myTrackedItem);	// 12 Sep 2012	NDL	Par 30346
		elseif logType = IsForLogging then
			if self.generateLog = false then
				return;
			endif;
			logStr := logStr &amp; " " &amp; app.getErrorString1(Message_number, messageNumber.String);
			if self.alertManager &lt;&gt; null then
				self.alertManager.addLogAlert(logStr);
			endif;
			//app.writeLog(logStr, LogAlways); //- cnwmd1 &amp; cnwrs2, Par 20524.  Logging no longer required.  
		endif;
	endif;
end;</source>
        <Parameter name="str" type="String"/>
        <Parameter name="logType" type="Integer"/>
        <Parameter name="messageNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addVerboseLogEntry" id="f134c85d-31b2-4306-9663-b5dd94fce21d">
        <updating/>
        <source>addVerboseLogEntry(str : String; logType : Integer; messageNumber : Integer) updating;
//Adds a longer detailed entry to the log.

//Changes
//1/12/2009, cnwmd1, Par 20524 - New param 'messageNumber' added.  Message number is now included with each log entry output so that the source of errors/warnings are more easily identified.
vars

begin
	if self.isAutoPlanMove then
		if app.verboseLogging = false then
			return;
		endif;
		//self.addLogEntry(str, logType, Move_FullReplacementText);
		self.addLogEntry(str, logType, messageNumber);// 12 Sep 2012	NDL	Par 30346
	else
		if logType = IsForLogging then
			if app.verboseLogging = false then
				return;
			endif;
			//self.addLogEntry(str, logType, Move_FullReplacementText);
			self.addLogEntry(str, logType, messageNumber);// 12 Sep 2012	NDL	Par 30346
		elseif logType = IsError then			
			app.setContinueCMExceptions(false);
			//app.raiseCMException1(Move_FullReplacementText, str, null, null);
			self.raiseAutoPlanException( messageNumber, str, null, null);	// 12 Sep 2012	NDL	Par 30346
		elseif logType = IsWarning then
			//app.raiseCMWarning1(Move_FullReplacementText, str, null, null,self.myTrackedItem);
			self.raiseAutoPlanWarning( messageNumber, str, null, null, self.myTrackedItem);	// 12 Sep 2012	NDL	Par 30346
		endif;
	endif;
end;</source>
        <Parameter name="str" type="String"/>
        <Parameter name="logType" type="Integer"/>
        <Parameter name="messageNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="134a9e99-d89c-4311-acf3-dd23efe48b81">
        <updating/>
        <source>create() updating;
/*
 ------------------------------------------------------------------------
Created:			29 October 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	//---------------------
	//Set this by default. Its checked when the determine whether we are doing
	//some of the tests. As the cmif_moveController is now its superclass and it can
	//create one of these via a cloneSelf, the constructor is NOT called an this
	//property is FALSE.
	//---------------------
	self.isAutoPlanMove := true;
	//---------------------
	//Setup other stuff as well
	//---------------------
	self.setAlertManager();
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="04ce7d8f-92c3-4f00-93ee-28314377d66c">
        <updating/>
        <source>delete() updating;
//Destructor.
vars

begin
	if self.myTrackedItem = null then
		return;
	endif;

	if not global.isValidObject(self.myTrackedItem) then
		return;		//could have been deleted already
	endif;

	if self.myTrackedItem.isTransient then
		//Cleanup the transient object we created. This must be a
		//ISO Request.
		delete self.myTrackedItem;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getController" id="c6cb4bec-f360-48d5-b497-b2148d81f9df">
        <source>getController()	: CM_LocationsController;
// 29/04/2013	cnwcs5	par 30475 - removed isISoRequest
vars

begin
	return self.targetLocation;
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getLastLogEntry" id="a77b7ded-658d-42a2-acef-9c75e6de87d3">
        <source>getLastLogEntry() : String;
/*
 ------------------------------------------------------------------------
Created:			16 October 2001 by cnwdwq1
Purpose:			Returns the last log entry from the alertManager.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	if app.alertManager = null then
		return null;	
	endif;
	if self.alertManager = null then
		return null;
	endif;
	return self.alertManager.getLastLogEntry;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLogType" id="2db01060-5f88-49e7-a123-d925342745ab">
        <source>getLogType() : Integer;
/*

Date		Who		Reason
12 August 2013	cnwer1	Initial creation PAR 31492

*/

vars

begin
	if self.moveMode = REAL_MODE  or self.isAutoPlanMove then
		return IsError;
	else
		return IsWarning;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRequestID" id="cfd6e2b8-ae01-451c-9d39-7448546003ed">
        <source>getRequestID() : String;
//--------------------------------------------------
// Created:	23 June 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myWorkListEntry &lt;&gt; null then
		return self.myWorkListEntry.getTreeDescription();
	endif;
	if self.request &lt;&gt; null then
		if self.request.myJob &lt;&gt; null then
			return self.request.myJob.getTreeDescription();
		endif;
	endif;
	if self.myTrackedItem &lt;&gt; null then
		return self.myTrackedItem.id;
	endif;
	return '';	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isTestToBeDone" id="e519cd18-aaba-4c9b-b879-e87ab9d7fc40">
        <source>isTestToBeDone(testType : Integer; lc : CM_LocationsController) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			29 October 2001 by cnwdwq1
Purpose:			Wraps the messages generated for NOT testing something into 1
							place. This alos gives me the ability to ignore this if we are doing an
							autoplan and use the same testing routines for normal mode moves.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	isSet : Boolean;
	//tStr : String;
	msgNum : Integer;
begin

	if (not self.isAutoPlanMove) then
		//------------------------
		//If we are doing a REAL move (i.e. not an autoplan) then
		//simply return.
		//------------------------
		return true;
	endif;
	
	// These settings are depreciated and are now mostly handled by yard allocations.
	
	// typicaly we want to skip these tests
	// unless the test is for power in which case we will always want to do the test.
	
	
	if testType = TI_Test_Power then
		return true;	
	else
		return false;
	endif;
	
end;</source>
        <Parameter name="testType" type="Integer"/>
        <Parameter name="lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="raiseAutoPlanException" id="77affb96-8550-4ea8-b509-3c931883f601">
        <source>raiseAutoPlanException( errNo : Integer; errString : String; 
				  pAttrNameString : String; pGuiObject : Object ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2012	cnwndl1	Initial creation	Par	30346 

*/

vars

	exObj	: CM_Exception;

begin

	create exObj transient;

	exObj.set(errNo, errString, false, pAttrNameString, pGuiObject, null);

	raise exObj;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="errNo" type="Integer"/>
        <Parameter name="errString" type="String"/>
        <Parameter name="pAttrNameString" type="String"/>
        <Parameter name="pGuiObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="raiseAutoPlanWarning" id="516432da-2783-485c-9a59-86927ac36800">
        <source>raiseAutoPlanWarning(errNo : Integer; errStr : String; 
				  pAttrNameString : String; pGuiObject : Object; _subject : CM_Object) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2012	cnwndl1	Initial creation	Par 30346

*/

vars

	exObj	: CM_Exception;

begin
	if app.isConverting then
		return;
	endif;

	create exObj transient;
	exObj.set(errNo, errStr, true, pAttrNameString, pGuiObject, _subject);
	
	raise exObj;

end;</source>
        <access>protected</access>
        <Parameter name="errNo" type="Integer"/>
        <Parameter name="errStr" type="String"/>
        <Parameter name="pAttrNameString" type="String"/>
        <Parameter name="pGuiObject" type="Object"/>
        <Parameter name="_subject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setAlertManager" id="2232aed6-823f-4989-9e56-4029c13f97d0">
        <updating/>
        <source>setAlertManager() updating;

begin
	if app.alertManager = null then
		app.initialize;	
	endif;
	if self.alertManager = null then
		self.alertManager := app.alertManager;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setOriginatingController" id="b64f6c6e-5a9b-4c77-bd21-1aa440a5286d">
        <updating/>
        <source>setOriginatingController(obj : CM_LocationsController  constant) updating;
//Method called by all methods to update the appropriate object.
//If we are processing a non-ISO request, then we update the
// 29/04/2013	cnwcs5	par 30475 - removed isISoRequest
vars

begin
	sourceLocation := obj;
end;</source>
        <Parameter name="obj" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="updateController" id="e7f5080c-7c04-41e6-8046-5a992e4b58dd">
        <updating/>
        <source>updateController(obj : CM_LocationsController  constant) updating;
//Method called by all methods to update the appropriate object.
//If we are processing a non-ISO request, then we update the
// 29/04/2013	cnwcs5	par 30475 - removed isISoRequest
vars

begin
	self.targetLocation := obj;
	if obj = null then	//30 Oct 2017	NDL	TFS 7470 - Not valid to set myToPrimaryLocation to null during the location testing.
		return;
	endif;
	self.myToPrimaryLocation := obj;
end;</source>
        <Parameter name="obj" type="CM_LocationsController"/>
    </JadeMethod>
</Class>
