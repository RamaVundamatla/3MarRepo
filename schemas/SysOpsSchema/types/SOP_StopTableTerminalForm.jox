    <JadeMethod name="populateTblUpdRequests" id="29619a70-a3d4-49dc-a5c7-afcbb4da6d10">
        <source>populateTblUpdRequests();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	headerStr : String;
	eventReqForStop : CM_EventRequest;
	lineStr : String;
	rowIndex : Integer;

begin

	self.tblUpdRequests.clear();
	self.tblUpdRequests.rows := 1;
	self.tblUpdRequests.fixedRows := 1;
	self.tblUpdRequests.columns := 2;
	
	headerStr := 	app.getErrorString(Update_type) &amp; Tab
				&amp;	app.getErrorString(Update_details);
				
	self.tblUpdRequests.setCellText( 1, 1, headerStr );
	
	if myProxyStopTableTemplate &lt;&gt; null then
		foreach eventReqForStop in myProxyStopTableTemplate.allEventRequests do
			lineStr := eventReqForStop.typeString &amp; Tab
					&amp;	eventReqForStop.CM_EventRequestForStop.getUpdateDetails;
			rowIndex := self.tblUpdRequests.addItem( lineStr );
			self.tblUpdRequests.accessRow( rowIndex ).itemObject := eventReqForStop;
			
		endforeach; 
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="c3066845-601b-4480-b1a5-fc4120b95fae">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2012	cnwndl1	Initial creation

*/

vars

begin

	//06 Nov 2012	NDL	Par 29859
	if self.unsavedChanges then
		if app.msgBox(	app.getErrorString(UnsavedChangesWillBeLost) &amp; CrLf &amp; app.getErrorString(Want_close_anyway),
						app.getErrorString(Want_close_anyway),
						MsgBox_Yes_No) = MsgBox_Return_No then
			cancel := 1;
			return;
		else
			//we are bailing, back out the changes.
			if self.myProxyStopTableTemplate &lt;&gt; null then
				self.myProxyStopTableTemplate.resetEventRequestsFromDB();
			endif;
		endif;
	endif;
	

epilog

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="2639fab3-3648-462c-86b0-4d3e3e89689d">
        <source>setControlsForView()protected;
// ---------------------------------------------------------------------------
// Created:     05 June 2009 by concms1
// Purpose:     Par 19830 - allow for view mode
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin	
	lstStopPrevent.readOnly		:= true;
	
	lstStopProcess.readOnly		:= true;
	lstStopSet.readOnly			:= true;
	
	chkChildIgnore.readOnly		:= true;
	chkChildOnly.readOnly		:= true;
	chkCoastalIgnore.readOnly	:= true;
	chkCoastalOnly.readOnly		:= true;
	chkTranshipIgnr.visible	:= false;
	chkTranshipOnly.visible	:= false;
	chkFullsOnly.readOnly		:= true;
	chkMTsOnly.readOnly			:= true;
	
	mulHoldVoyages.readOnly		:= true;
	
	btnSaveBase.enabled			:= false;
	
	//01 May 2019	NDL	TFS 43918
	btnURAdd.enabled 			:= false;
	btnURUpdate.enabled 		:= false;
	btnURDelete.enabled 		:= false;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSelectedStopTableTplAreas" id="a74c84d4-762f-4da8-838b-6d22179e8228">
        <source>setSelectedStopTableTplAreas() protected;
//ccms1824 cnwrs1 may 2009
vars
	stopArea	:	Integer;
	strObj		:	CM_String;
	setAreas : IntegerArray;
	processAreas : IntegerArray;
	checkAreas : IntegerArray;
begin
	self.allSetSetStopAreas.clear;
	self.allSetPreventStopAreas.clear;
	self.allSetProcessStopAreas.clear;
	create setAreas transient;
	create processAreas transient;
	create checkAreas transient;
	self.myProxyStopTable.getAllSetAreas(self.myProxyStopTableTemplate.myTerminal, setAreas);
	self.myProxyStopTable.getAllProcessAreas(self.myProxyStopTableTemplate.myTerminal, processAreas);
	self.myProxyStopTable.getAllCheckAreas(self.myProxyStopTableTemplate.myTerminal, checkAreas);
	
	foreach stopArea in setAreas do
		//cnwmc5 - 14 April 2014 - CCMS 2352
		if self.allAvailableSetStopAreas.size() &gt;= stopArea then
			strObj := self.allAvailableSetStopAreas[stopArea].CM_String;
			if strObj &lt;&gt; null then
				self.allSetSetStopAreas.add(strObj);
			endif;
		endif;
	endforeach;
	
	foreach stopArea in checkAreas do
		strObj := self.allAvailablePreventStopAreas[stopArea].CM_String;
		if strObj &lt;&gt; null then
			self.allSetPreventStopAreas.add(strObj);
		endif;
	endforeach;
	
	//cnwmc5 - 14 April 2014 - CCMS 2352
	if self.myProxyStopTableTemplate &lt;&gt; null 
	and self.myProxyStopTableTemplate.isBOLOnly then
		return;
	endif;
	
	foreach stopArea in processAreas do
		strObj := self.allAvailableProcessStopAreas[stopArea].CM_String;
		if strObj &lt;&gt; null then
			self.allSetProcessStopAreas.add(strObj);
		endif;
	endforeach;
epilog
	strObj := null;
	delete setAreas;
	delete processAreas;
	delete checkAreas;
end;
</source>
        <access>protected</access>
    </JadeMethod>
