        <source>setProxyFromObject(_object: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2023		navma1	Initial creation

*/

vars

begin
	inheritMethod(_object);
	self.id 			:= _object.CM_WorkOrder.id;
