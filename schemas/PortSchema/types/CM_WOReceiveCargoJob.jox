<Class name="CM_WOReceiveCargoJob" id="6200f2cc-6455-4547-9888-ee1e329649a3">
    <superclass name="CM_WorkOrderJob"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="allVoyageJobs" id="e5224c75-d145-4e76-aea2-3964ae1eb0ae">
        <transientToPersistentAllowed/>
        <type name="CM_JobArray"/>
        <access>readonly</access>
        <Inverse name="CM_VoyageWorkPointJob::myWorkOrderReceiveJob"/>
    </ExplicitInverseRef>
    <JadeMethod name="areWLEsAllDone" id="4b964ffd-b5b7-4b38-b34f-7d8fb8a4f0d0">
        <source>areWLEsAllDone(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
*/

vars
	
begin
	if self.allVoyageJobs.isNotEmpty then
		if self.allCompletedWLEsByDate.size &lt;&gt; self.workListEntries.size then
			return false;
		endif;
		
		return true;
	else
		return inheritMethod();
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeIncludedOnWOO" id="f2445255-4103-4896-9b04-364cce1020f0">
        <source>canBeIncludedOnWOO(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jul 2023	navma1	ChangeRequest 56738: EUP | Stop Including Work Order Jobs in Work order operation screen
18 Jan 2024 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
*/

vars
	transport : Integer;
begin
	
	if self.myWODtl &lt;&gt; null then
		transport  := self.myWODtl.getTransport();
	endif;
	
	if transport = TI_TRANSMODE_SHIP then
		if self.status &lt;&gt; JOB_COMPLETE then		//18.01.2024 navhl20 #62066
			return true	;
		else
			return false;
		endif;
	endif;
	
	return app.isSpecial = true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllVoyJobs" id="e544460c-405f-4d22-9c46-517fdea0128f">
        <source>getAllVoyJobs(): CM_JobArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes

*/

vars

begin
	return self.allVoyageJobs;
epilog

end;</source>
        <ReturnType type="CM_JobArray"/>
    </JadeMethod>
    <JadeMethod name="getType" id="fa865510-3f76-47c1-9684-7759d081619a">
        <source>getType():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2023	navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS

*/

vars
	wod 	 : CM_WorkOrderTIDtl;
	transStr : String;
begin
	wod := self.myWODtl;
	
	if wod &lt;&gt; null then
		transStr := app.transportModeENumToString(wod.CM_WodReceive.transport);
		return 'Unload' &amp; Space &amp; transStr;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isJobMatchingMode" id="724c130b-813f-4d1a-a07f-0b05917c590f">
        <source>isJobMatchingMode(_mode: Integer): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Jun 2023	navhl20	ChangeRequest 58765: EUP - Delivery Dispatch – Allocation List - Rail
03 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	wod 		: CM_WorkOrderTIDtl;
	tranport	: Integer;
begin
	
	wod := self.myWODtl;
	
	if wod &lt;&gt; null then
		
		tranport := wod.CM_WodReceive.transport;
		
		if tranport      = TI_TRANSMODE_ROAD then
			return _mode = 1;				//YRD_WorkOrderOperation.Mode_ROAD
		elseif tranport  = TI_TRANSMODE_RAIL then
			return _mode = 2;				//YRD_WorkOrderOperation.Mode_RAIL
		elseif tranport  = TI_TRANSMODE_SHIP then			//03.10.2023 navhl20 #60033
			return _mode = 3;				//YRD_WorkOrderOperation.Mode_SHIP
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="14356a4b-12f9-4db5-87d9-8144a1643472">
        <updating/>
        <source>setForCreateInternal(_receiveCargoJobParam : CMIF_WorkOrderJobParams;_terminal : CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jul 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
*/



vars
	req : CM_WOReceiveCargoRequest;
begin
	inheritMethod(_receiveCargoJobParam, _terminal);

	//---------------
	//Build a Request
	//---------------
	create req;	
	req.setForCreateInternal(self, _receiveCargoJobParam);
	//---------------
	//Build the WLEs' from the request.
	//---------------
	self.createWLEs();
end;</source>
        <Parameter name="_receiveCargoJobParam" type="CMIF_WorkOrderJobParams"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
