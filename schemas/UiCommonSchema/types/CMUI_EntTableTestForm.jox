    <JadeMethod name="lstToDo_hasGotFocus" id="be8dc528-3c91-4e4e-a7d4-6e1c63f9dac1">
        <controlMethod name="CMUI_FieldFrame::hasGotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstToDo_hasGotFocus(_fieldFrame: CMUI_FieldFrame input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2009	cnwdap1	Initial creation

*/

vars

begin
	// make list box bigger, and place it over the textbox
	self.lstToDoTasks.move(self.txtToDoTasks.getFormLeft, self.txtToDoTasks.getFormTop, self.txtToDoTasks.width, 100);
	self.lstToDoTasks.visible := true;
	self.lstToDoTasks.parent := self;
	self.txtToDoTasks.visible := false;
	self.lstToDoTasks.setFocus;
epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstToDo_hasLostFocus" id="847ac7af-7a11-4879-a9c0-44a5e52a92c7">
        <controlMethod name="CMUI_FieldFrame::hasLostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstToDo_hasLostFocus(_fieldFrame: CMUI_FieldFrame input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2009	cnwdap1	Initial creation

*/

vars
	str 	: String;

begin
	// get codes from list box, display in text box and disappear the list box
	str := self.lstToDoTasks.getSelectedString(CM_ToDoTaskDesc::shortDescription.name);
	if str.length &gt; 30 then
		self.txtToDoTasks.text := str[1:29]&amp; '...';
	else
		self.txtToDoTasks.text := str;
	endif;
	self.txtToDoTasks.visible := true;
	self.lstToDoTasks.visible := false;
	self.lstToDoTasks.parent := _fieldFrame;
epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="356d2cf9-44cd-4727-b503-a0d602ce2215">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2009	cnwdap1	Initial creation
*/
vars

begin
	inheritMethod();

	self.handleMenusForModalDisplay();
	self.centreOverParent(20);	

	self.cmbDischargePort.myAssistant := self.myAssistant;
	self.myAssistant.comboBoxSubTerminal(self.cmbSubTerminal.getEmbeddedControl.ComboBox, null, self.myTerminal);	
	self.doBuildCoolingTypes(self.cmbCoolingType.getEmbeddedControl.ComboBox);
	self.doBuildVoltageTypes(self.cmbVoltageType.getEmbeddedControl.ComboBox);
	
	self.cmbSpecialLift.retainPaintedHeight := true;
	self.initFieldsForEntDefName(ETDef_ContainerFull, true);
//	self.setupFormFull;

	self.txtCargoID.setMyCaption("Container ID");
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f0f495fa-336f-4a01-9a8e-d0b535a3fddf">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 August 2017 10:00:14.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017357, locale);
	btnAttachments.translateCaption(Xlat_0011885, locale);
	btnIsOverDim.translateCaption(Xlat_0011886, locale);
	chkCleaned.translateCaption(Xlat_0011887, locale);
	chkCurtainsIn.translateCaption(Xlat_0011888, locale);
