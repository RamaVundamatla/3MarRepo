    <JadeMethod name="setStorageConfigAndDetails" id="664e1163-7b78-4520-9466-54fea99c50b4">
        <source>setStorageConfigAndDetails(_updController : CnEcReleaseController);
/*

Purpose:			
		This script will be used to populate new attributes added 
			CM_StorageConfig::railReceivalType
			CM_StorageConfig::roadReceivalType
			CM_StorageConfig::unpackReceivalType
			
			CM_StorageDetail::shipReceivalType
			CM_StorageDetail::railReceivalType
			CM_StorageDetail::roadReceivalType
			CM_StorageDetail::unpackReceivalType
			
Parameters:			

Return Value:		

Date		Who		Reason
08/06/2023	navkc1	CR 58003 Task 58004: JADE - Storage Config - Upgrade Scripts

*/

vars
	storageConfig		: CM_StorageConfig;
	storageDetail		: CM_StorageDetail;
	objArray			: ObjectArray;
	allStorageDetails	: CM_StorageDetailSet;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; "Populating CM_StorageConfig and CM_StorageDetail", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Populating CM_StorageConfig and CM_StorageDetail") ;	
	endif;
	
	create objArray transient;
	CM_StorageConfig.allInstances(objArray, 0, true);
	
	beginTransaction;
	
	foreach storageConfig in objArray as CM_StorageConfig do
		
		storageConfig.setPropertyValue(CM_StorageConfig::railReceivalType.name, Storage_RailActualReceival);
		storageConfig.setPropertyValue(CM_StorageConfig::roadReceivalType.name, Storage_RoadActualReceival);
		storageConfig.setPropertyValue(CM_StorageConfig::unpackReceivalType.name, Storage_UnpackActualUnpack);
		
		foreach storageDetail in storageConfig.allStorageDetails do
			storageDetail.setPropertyValue(CM_StorageDetail::shipReceivalType.name, storageConfig.shipReceivalType);
			storageDetail.setPropertyValue(CM_StorageDetail::railReceivalType.name, Storage_RailActualReceival);
			storageDetail.setPropertyValue(CM_StorageDetail::roadReceivalType.name, Storage_RoadActualReceival);
			storageDetail.setPropertyValue(CM_StorageDetail::unpackReceivalType.name, Storage_UnpackActualUnpack);
		endforeach;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Completed populating CM_StorageConfig and CM_StorageDetail", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Completed populating CM_StorageConfig and CM_StorageDetail") ;
	endif;
	// Defect 58828: MTN - Upgrade Script missing addScriptRun
	self.addScriptRun(method.name);
	
epilog
	delete objArray;
	delete allStorageDetails;
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setTermSecurityEventTypes" id="53854b05-d02a-448b-a5ed-6c98b2a8b090">
        <source>setTermSecurityEventTypes(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2020	jlgndl1	Initial creation	TFS 48784

*/

vars

	role : CM_SecurityRoleTerminal;
	rootRole : CM_SecurityRoleTerminalRoot;
	eventType : CM_EventType;
	coll : CM_EventTypeByTypeDict;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Add all Event Types to every Terminal Security Role", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Add all Event Types to every Terminal Security Role") ;	
	endif;
	
	create coll transient;
	foreach eventType in app.myRoot.allEventTypesByType do
		if eventType.canIncludeInSecurityRole then
			coll.add( eventType );
		endif;
	endforeach;
	
	beginTransaction;
	foreach role in CM_SecurityRoleTerminal.instances do
		role.setEventTypes( coll );
	endforeach;
	foreach rootRole in CM_SecurityRoleTerminalRoot.instances do
		rootRole.setEventTypes( coll );
	endforeach;
	commitTransaction;
	
	
	app.writeLog(method.qualifiedName &amp; " Add all Event Types to every Terminal Security Role Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Add all Event Types to every Terminal Security Role Completed") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete coll;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="specificPostStandard" id="14626760-3a5b-486a-b6af-66bd725666d3">
        <updating/>
        <source>specificPostStandard(pControllerObj: CnEcReleaseController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#	Description
============================================================================
14 Feb 2020	jlgmd1			Initial creation
02 Oct 2020 cnwma1 			ChangeRequest 50112: ASPA - GCI Stevedores
