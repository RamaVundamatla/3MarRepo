    <JadeMethod name="tLanderDischargeVoyageJob" id="ced69f14-b5e9-41e4-95a9-a4b92784215b">
        <source>tLanderDischargeVoyageJob();
// cnwer1
// Test validation of target for lander moves from a LOLO/RORO location
// cnwdw1

constants
	VoyageName = 'UTMDHVOY4';
	ShipName = 'UTMDHVES4';
	TestOperator = 'MSK';
	CraneTransferAreaId	= "UTC1T6";
	IMV1 = "UTIM";
vars
	cta							: CM_CraneTransferArea;
	bs							: CM_BlockStack;
	vessel 						: CM_Vessel;
	voyage 						: CM_Voyage;
	queue						: CM_VoyageQueue;
	rampQueue					: CM_VoyageCraneQueue;
	cargo1, cargo2, cargo3, cargo4,
	cargo5						: CM_TrackedItem;
	crane						: CM_Machine;
	imv							: CM_Machine;
	job 						: CM_VoyageJob;
	wle 						: CM_WorkListEntry;
	slotsFrom					: CM_SlotControllerArray;
	tmpLoadCC					: CMIF_LoadColorCode;
	theSlot 					: CM_LocationsController;
	ctaLane: CM_LocationsController;
	strs 						: StringArray;
	tas							: StringArray;
	idx							: Integer;
	pxyTask						: CM_RTQueueTask;
	agent : CMIF_MobileGenericAgent;
	result: Boolean;
begin

	self.disableAllYA(true);
	bs:= self.addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	self.addYACatchAll("UTMYA", bs);
	
	self.deleteMachine("UTMC");
	cta := self.addCraneTransferArea(CraneTransferAreaId);

	create tas transient;
	tas.add(cta.id);
	tas.add(bs.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	crane := self.addCrane("UTMC", null, tas, null);
	
	self.addMachineRule (cta, bs, RTMoveMethod_7);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	vessel := self.addVesselLOLOholdsRORO(ShipName, self.getOperator(TestOperator));
	voyage	:= self.addVoyageWithConRORO(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													null, 10, false, true);
	queue := self.addVoyageQueue(voyage);
	rampQueue := self.addVoyageCraneQueue(voyage, queue, crane);
	
	create strs transient;
	deleteContainer("UTMDHJ00001");
	strs.clear;
	strs.add("010682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo1 := self.addContainerAtLocnDisch("UTMDHJ00001", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);

	deleteContainer("UTMDHJ00003");
	strs.clear;
	strs.add("010684");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo3 := self.addContainerAtLocnDisch("UTMDHJ00003", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);

	deleteContainer("UTMDHJ00004");
	strs.clear;
	strs.add("010686");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo4 := self.addContainerAtLocnDisch("UTMDHJ00004", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);

	deleteContainer("UTMDHJ00005");
	strs.clear;
	strs.add("010482");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo5 := self.addContainerAtLocnDisch("UTMDHJ00005", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);


	
	
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageName, "01", DeckOnDeck, 1, 1, 3, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	job := self.addVoyageJob(voyage, crane.code, slotsFrom, true);
	assertTrue(job &lt;&gt; null);
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
	imv := self.addIMV(IMV1, 93, tas, rampQueue.id);
	self.machineAssignToQueue(imv, rampQueue);

	// Check that Lander can discharge to yard
	create agent transient;
	agent.setMyTerminal(self.getTerminal());
	agent.setMyVoyage(voyage);
	agent.setDoNotShowMsgBox(true);
	
	
	on CM_Exception do app.validationExHandler(exception,app.myPassport);
	//epr TFS 3760 lander functions refactored to use CMIF_MobileGenericAgent
	//now just need to call agent.doLanderDischarge
	
	result :=agent.doLanderDischarge(cargo1,bs.getLocationsController,null,null);	
	self.assertTrueMsg(result, "Lander discharge failed for UTMDHJ00001");
	assertEqual(cargo1.myPrimaryActualLocation, bs.getLocationsController);
	
	
	// Check that Lander can put cargo to IMV
	result :=agent.doLanderDischarge(cargo3, imv.getMyVehicleMachineController,null,null);
	self.assertTrueMsg(result, "Lander discharge failed for UTMDHJ00003");
	assertEqual(cargo3.myPrimaryActualLocation, imv.myMachineController);

	// Check that Lander can put cargo to CTA
	ctaLane := cta.getFirstAvailableDischLane;
	result :=agent.doLanderDischarge(cargo4, ctaLane,null,null);
	assertEqual(cargo4.myPrimaryActualLocation, ctaLane);
	
	deleteContainer("UTMDHJ00002");
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo2 := self.addContainerAtLocnDisch("UTMDHJ00002", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);

	// Check that the Lander cannot discharge cargo that is not in a voyage job
	self.moveQueued(cargo2, bs.getLocationsController);
	assertNotNull(cargo2.getPrimaryLocation(QUEUE_MODE));
	assertEqual(cargo2.getPrimaryLocation(QUEUE_MODE).myTerminalArea, bs);
		
	result :=agent.doLanderDischarge(cargo2, bs.getLocationsController,null,null);

	self.assertFalse(result);
	self.assertTrxError(Not_found_worklis_entry); //should get error no wle found 

	self.doQueueUnplannedUnworkedCargo(cargo5,job,wle);
	self.assertNotNull(wle);
	result:= agent.doLanderDischargeToGround(cargo5,ctaLane,GroundInTransit,null,null);
	//should move to cta lane and leave if queued to
	self.assertTrue(result);
	self.assertEqual(cargo5.myPrimaryActualLocation,ctaLane);
	self.assertNotNull(wle);
	self.assertNotNull(cargo5.myPrimaryQueuedLocation);

epilog
	self.disableAllYA(false);
	delete slotsFrom;
	delete strs;
	delete tas;
	delete pxyTask;
	delete agent;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tLanderNonWorked" id="133b01a6-77bf-48d9-af4d-309ac871b55d">
        <source>tLanderNonWorked();
// cnwer1
//24 November 2011	cnwdw1	
// This tests the working of a discharge using NonPlannedNonWorked voyage and the Lander app. This is
// the process used by MSL to discharge cargo from RORO decks
constants
	VoyageName = 'UTVOYRORO';
	ShipName = 'UTRORO';
	TestOperator = 'MSK';
	CraneTransferAreaId	= "UTC1T1";
	IMV1 = "UTI1";
vars
	cta: CM_CraneTransferArea;
	bs: CM_BlockStack;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	queue: CM_VoyageQueue;
	rampQueue: CM_VoyageCraneQueue;
	cargo1: CM_TrackedItem;
	tas: StringArray;
	crane: CM_Machine;
	imv: CM_Machine;
	wle : CM_WorkListEntry;
	forkLift: CM_Machine;
	success: Boolean;
	agent : CMIF_MobileGenericAgent;

begin

	self.disableAllYA(true);
	bs:= self.addBlockStack("UBS1", 100, null);
	self.addYACatchAll("UTYA", bs);
	
	self.deleteMachine("UTRP");
	cta := self.addCraneTransferArea(CraneTransferAreaId);

	create tas transient;
	tas.add(cta.id);
	tas.add(bs.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	crane := self.addCrane("UTRP", null, tas, null);
	
	self.addMachineRule (cta, bs, RTMoveMethod_7);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	vessel := self.addVesselLOLOholdsRORO(ShipName, self.getOperator(TestOperator));
	voyage	:= self.addVoyageWithConRORO(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													null, 10, false, true);
	queue := self.addVoyageQueue(voyage);
	rampQueue := self.addVoyageCraneQueue(voyage, queue, crane);
	
	cargo1 := self.addContainerAtLocnDisch("UT1001", "2200", "MT", TI_IMEX_STATUS_IMPORT, voyage.myShipBlockStack, app.myRoot.allPorts["NZPOE"], voyage);

	imv := self.addIMV(IMV1, 93, tas, rampQueue.id);
	self.machineAssignToQueue(imv, rampQueue);
	forkLift := self.addForkLift("UTFL", 94, tas, rampQueue.id);
	
	create agent transient;
	agent.setMyTerminal(self.getTerminal());
	agent.setMyVoyage(voyage);
	agent.setDoNotShowMsgBox(true);
	on CM_Exception do app.validationExHandler(exception,app.myPassport);
	//epr TFS 3760 lander functions refactored to use CMIF_MobileGenericAgent
	//now just need to call agent.doLanderDischarge
	success :=agent.doLanderDischarge(cargo1,imv.myMachineController,null,null);
	assertTrue(success);
	self.assertNoTrxErrors();
	assertEqual(cargo1.myPrimaryActualLocation, imv.myMachineController);
	
	self.checkTIForTxnOfType(cargo1, TRANS_TYPE_REC_SHIP);				// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(cargo1, TRANS_TYPE_WHARFAGE);				// 15/08/2012 cnwmh5
	
	wle:=cargo1.allWorklistEntries.first;
	self.assertNotNull(wle);
	
	// Forklift sets down into yard
	self.machineLogon(forkLift);
	
	self.machineAcceptTask(forkLift, wle.allRTQueueEntries.last.allTasks.first);
	self.machinePickup(forkLift);
	self.machineSetdown(forkLift, cargo1, bs.id);
	self.machineLogOff(forkLift);
	
	// Make sure temp voyage job is deleted
	assertEqual(voyage.allVoyageJobs.size, 0);
	
epilog
	self.disableAllYA(false);
	delete tas;
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tMTReleaseAssignedCargoTBA" id="d8d9b9e2-6ad8-4a11-a22f-d20b643b1404">
        <source>tMTReleaseAssignedCargoTBA();
// cnwma1
//cnwrd1
/*
Purpose:			Simulate Mulaha MT ship release process.

Parameters:			

Return Value:		

Date		Who		Reason
16/12/2013	cnwrd1	Initial creation
19/09/2017	jlgdap1	TFS 6851 SSL New parameter for trxCreateEDIDataFromBayPan
// 10 Sep 2019	cnwrs1	TFS 46030
// 08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/
vars
	voyage1: CM_Voyage;
	voyage2: CM_Voyage;
	vessel: CM_Vessel; 
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
	voyageJob : CM_VoyageJob;
	releaseRequest: CM_BulkRelease;
	dischargePort: CM_Port;
	ti1, ti2, ti3: CM_TrackedItem;
	bs1, bs2: CM_BlockStack;
	straddle: CM_Machine;
	targetArea, sourceArea: CM_TerminalArea;
	tas: StringArray;
	queue: CM_RadioTelemetryQueue;
	queueEntry: CM_RTQueueEntry;
	queuetask: CM_RTQueueTask;
	craneName: String;
	crane: CM_Crane;
	//agent: CM_MobileAgent;
	agent : CMIF_MobileGenericAgent;
	wle: CM_WorkListEntry;
	bay: CM_BayDefn;
	oldShowRelConfig : Boolean;
	file							: File;
	extractFileName					: String;
	type							: Integer;
	planStr							: String;
	ediDataBayPlan					: CM_EDIDataBayPlan;
	ediControllerAgent				: CM_EDIControllerAgent;
	ediDataParams					: CMIF_EDIDataDetails;
	ediFileType 					: CM_EDIFileType;
	operator						: CM_Operator;
	ediData							: CM_EDIData;
	ediFile							: CM_EDIFile;
	tareWeight						: Decimal[10,4];
	ediTI							: CM_EDIReleaseRequestTI;
	tiEDI							: CM_EDIBayPlanTI;
	obj								: Object;
	isDoClearanceCheck : Boolean;
begin
	self.setTerminalConfig(AllowRTSwithoutVGM, true);	// NAVAB1 28FEB2024 FIXING UTS for CUT
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	dischargePort := app.myRoot.allPorts["NZAKL"];
	craneName := self.getProfileSetting(UT_Profile.P_CRANE).asString;

	bs1 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
//	bs2 := addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString&amp;"X", 100, null);


	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyYA);  // yard allocations only
	self.setTerminalConfig(ShowRelReqOnShipLoadList, true); // create TBA containers
	

	// createVoyage
	deleteVoyage("UTMTREL");
	deleteVessel("UTMTREL");
	vessel := addVesselCellular("UTMTREL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	foreach bay in vessel.myCellularVesselStructure.allBaysByLabel do//04Sep2012	cnwrs1	Par30321	if the trx is to be retried then setup the effective date again
		beginTransaction;
		bay.setPropertyValue(CM_BayDefn::maxPileWeight20IB.name, 2000);
		bay.setPropertyValue(CM_BayDefn::maxPileWeight20OB.name, 2000);
		commitTransaction;
	endforeach;	
	voyage1 := addVoyageWithContainerStructur("UTMTREL", "UTMTREL", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	// Create some mt cargo
	self.deleteContainer("TEST0000002");  // Shouldn't get this cargo is not in bs1
	ti2 := self.addContainerAtLocnDisch("TEST0000002", "UT20", "MT", TI_IMEX_STATUS_EXPORT, bs1.myLocationsController, dischargePort, voyage1);
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	self.deleteStops(ti2);
	self.setCargoReadyToShip(ti2);
	
	self.deleteContainer("TEST0000001");  // This is the one we should get as it is in bs1
	ti1 := self.addContainerAtLocnDisch("TEST0000001", "UT20", "MT", TI_IMEX_STATUS_EXPORT, bs1.myLocationsController, dischargePort, voyage1);
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	self.deleteStops(ti1);
	self.setCargoReadyToShip(ti1);

	// create Release
	deleteReleaseRequest("UTMTREL");
	self.opts.purge;
	self.opts.addAssoc("Number", 2);
	self.opts.addAssoc("ISOGroup", "UT20");
	self.opts.addAssoc("Voyage", voyage1);
	self.opts.addAssoc("DischargePort", dischargePort);
	self.opts.addAssoc("TerminalArea", bs1);   // Make sure only get cargo from bs1
	releaseRequest := addReleaseByTypeRequestOpts("UTMTREL", BR_TYPE_SHIP, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	assertEqual(releaseRequest.allReserveDetails.size, 1);

	crane := self.getCrane(craneName);
	assertNotNull(crane);
	self.addMachineRule(bs1, crane.transferArea, RTMoveMethod_23);   // Straddle only

	// colourCodeLoad
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType := true;
	tmpLoadCC.myDischargePort := dischargePort;
	tmpLoadCC.myBulkReleaseReserveDetail := releaseRequest.allReserveDetails.last;

	self.getJobSlotControllers("UTMTREL","01",DeckOnDeck,1,1,2,slots);
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Empty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_AssignRelease);
		
	voyageJob:=self.addVoyageJob(voyage1,craneName,slots, false);
		assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job was null");
		assertTrue(slots.first.mySlotRequestLoad.getAttrEmpty);

	
	// setup the controller agent
	create ediControllerAgent transient;
	ediControllerAgent.setTerminal( self.getTerminal );														//17/11/2015 cnwmk3 PAR 36146
	
	// extract the file out to check that the details have been extracted correctly
		type := 11;
		planStr := "BAPLIE 95B  SMDG 2.0";
			
	// get the extract file name details
		delete file;
		create file transient;
		file.fileName := "c:\temp\BayPlanExtract.txt"; 
		//file.fileName := app.getTempDir() &amp; "BayPlanExtract.txt"; 
		if file.isAvailable then
			file.purge();
		endif;
		extractFileName := file.fileName;
	
		// extract out the file
		delete ediDataParams;
		create ediDataParams transient;
		operator := app.myRoot.allOperators["UTOP"];
		self.assertNotNull(operator);
		ediFileType :=  app.myRoot.allEDIFileTypes[type, planStr];
		self.assertNotNull(ediFileType);
		app.myTrxCA.trxCreateEDIDataFromBayPan(ediDataBayPlan, self.getTerminal().myEdiConfig, voyage1, PROPOSED_BAYPLANS, extractFileName, 
			//operator.code, operator, operator,  ediFileType, app.myPassport, null, null, null);				// TFS 6851
			operator.code, operator, operator,  ediFileType, app.myPassport, null, null, null, false);			// TFS 6851
		self.assertNoTrxErrorsOrWarnings();
		ediDataParams.operator := voyage1.myOperator;
		ediFile := ediDataBayPlan.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediDataBayPlan.number, ediDataParams);
	
	
	ediData := ediFile.ediData;
	self.assertNotNullMsg (ediData, 'No edi data for release requests');
	
	tareWeight := app.myRoot.allISOTypeGroups["UT20"].maxTareWeight;
	
	foreach obj in ediData.allEDITrackedItems do
		tiEDI := obj.CM_EDIBayPlanTI;
		self.assertEqual(tareWeight, tiEDI.weight.Decimal);
		self.assertNull(tiEDI.isoType);
	endforeach;
	
		
	self.releaseAssignCargo(releaseRequest,null, ti1);
	self.releaseAssignCargo(releaseRequest,null, ti2);
	assertEqual(releaseRequest.allTrackedItemsAssigned.size, 2);	
	
	self.loadAllJobsToOps(voyage1, true);
	
	self.deleteStops(ti1);
	self.deleteStops(ti2);

	self.moveAllCargoOnVoyage(voyage1, QUEUE_MODE);
		assertNotNull(voyage1.allVoyageJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.targetLocation);
		assertTrue(voyage1.allVoyageJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.targetLocation.isKindOf(CM_SlotController));
	
	queueEntry := voyage1.allVoyageJobs.first.workListEntries.first.allRTQueueEntries.first;
	wle := queueEntry.myWorkListEntry;
	queuetask := queueEntry.allTasks.first;
	queue := queueEntry.myQueue;
	targetArea := queueEntry.allTasks.first.targetLocation.myTerminalArea;
	sourceArea := queueEntry.allTasks.first.sourceLocation.myTerminalArea;
	
	assertEqual(sourceArea, bs1);
	
	// workJob to CTA
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(bs1.id);
	self.addStraddle("UTS1", 91, tas, queue.id);
	
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	
	app.isRTApp:=true;  
	self.machineLogon(straddle);
	self.machineAcceptSpecifiedTask(straddle, queueEntry);
	self.ignoreTrxWarnings(true);
	self.machineDirector(straddle, ti1);
	self.ignoreTrxWarnings(true);
	// Use Lander to move to ship
	create agent transient;
	agent.setDoNotShowMsgBox(true);
	agent.moveTI( ti1, null, slots.first, wle, true, 0, 0, null );
	
	self.machineLogOff(straddle);

	assertTrueMsg(wle.isCompleteForJob, "Wle is not complete for job");
	
	assertEqualMsg(ti1.myPrimaryActualLocation, slots.first, "Tracked Item Location Expected: '" &amp; slots.first.CM_SlotController.getFullId() &amp; "' | Actual: '" &amp; ti1.myPrimaryActualLocation.getFullId() &amp; "'");
	assertEqualMsg(ti1.getImExStatus, TI_IMEX_STATUS_EXPORT, "Tracked Item Imex Status Expected: '" &amp; app.imexStatusEnumToString(TI_IMEX_STATUS_EXPORT) &amp; "' | Actual: '" &amp; app.imexStatusEnumToString(ti1.getImExStatus()) &amp; "'");
	assertEqual(ti1.myVoyage, voyage1);
	self.checkTIForTxnOfType(ti1, TRANS_TYPE_REL_SHIP);				// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(ti1, TRANS_TYPE_WHARFAGE);				// 15/08/2012 cnwmh5
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	app.isRTApp:=false;  
	delete slots;
	delete tmpLoadCC;
	delete tas;
	delete agent;
	delete ediControllerAgent;
	delete ediDataParams;
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="tMTReleaseMultiMachine" id="3280e2f4-b01c-49b4-be89-acaa307a0093">
        <source>tMTReleaseMultiMachine();
// cnwer1
//25 August 2010	cnwdw1	
// Work a Ship MT Release from start to finish
// 10 Sep 2019	cnwrs1	TFS 46030
//
vars
	voyage1: CM_Voyage;
	voyage2: CM_Voyage;
	vessel: CM_Vessel; 
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
	voyageJob : CM_VoyageJob;
	releaseRequest: CM_BulkRelease;
	dischargePort: CM_Port;
	ti1, ti2, ti3: CM_TrackedItem;
	fk1: CM_ForkLiftStack;
	forklift, imv: CM_Machine;
	targetArea, sourceArea: CM_TerminalArea;
	sourceLocation, targetLocation: CM_LocationsController;
	tas: StringArray;
	queue: CM_RadioTelemetryQueue;
	queueEntry: CM_RTQueueEntry;
	queuetask: CM_RTQueueTask;
	craneName: String;
	crane: CM_Crane;
	autoPlanMTReleaseStrategy : Integer;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	dischargePort := app.myRoot.allPorts["NZAKL"];
	craneName := self.getProfileSetting(UT_Profile.P_CRANE).asString;
	
	self.deleteTerminalArea("UT_FK");
	fk1 := self.addForkLiftStack("UT_FK", 5, 5, 5);

	self.setTerminalConfig(AutoPlanMTReleaseStrategy, AutoPlanMTRelStrategyTerminal);

	// createVoyage
	deleteVoyage("UTMTREL");
	deleteVessel("UTMTREL");
	vessel := addVesselCellular("UTMTREL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage1 := addVoyageWithContainerStructur("UTMTREL", "UTMTREL", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	self.deleteContainer("TEST0000001");  // This is the one we should get as it is in bs1
	ti1 := self.addContainerAtLocnDisch("TEST0000001", "UT20", "MT", TI_IMEX_STATUS_EXPORT, fk1.allLocationsControllers.first, dischargePort, voyage1);
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	self.deleteStops(ti1);
	self.setCargoReadyToShip(ti1);
	
	assertEqual(ti1.myPrimaryActualLocation, fk1.allLocationsControllers.first);

	// create Release
	deleteReleaseRequest("UTMTREL");
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", "UT20");
	self.opts.addAssoc("Voyage", voyage1);
	self.opts.addAssoc("DischargePort", dischargePort);
	self.opts.addAssoc("TerminalArea", fk1);   // Make sure only get cargo from bs1
	releaseRequest := addReleaseByTypeRequestOpts("UTMTREL", BR_TYPE_SHIP, TI_CargoType_Container);
	assertNotNull(releaseRequest);

	// Create machine rule Forklift-&gt;IMV between Forklift stack and Crane Transfer Area
	crane := self.getCrane(craneName);
	assertNotNull(crane);
	self.addMachineRule(fk1, crane.transferArea, RTMoveMethod_1);
	// colourCodeLoad
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType := true;
	tmpLoadCC.myDischargePort := dischargePort;
	tmpLoadCC.myBulkReleaseReserveDetail := releaseRequest.allReserveDetails.first;

	self.getJobSlotControllers("UTMTREL","01",DeckOnDeck,1,1,1,slots);
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Empty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_AssignRelease);
		
	voyageJob:=self.addVoyageJob(voyage1,craneName,slots, false);
	assertTrue(voyageJob &lt;&gt; null);
		assertTrue(slots.first.mySlotRequestLoad.getAttrEmpty);

	self.loadAllJobsToOps(voyage1, true);
	
	self.moveAllCargoOnVoyage(voyage1, QUEUE_MODE);
		assertNotNull(voyage1.allVoyageJobs.first.workListEntries.first.allRTQueueEntries.last.allTasks.first.targetLocationId);
	
	queueEntry := voyage1.allVoyageJobs.first.workListEntries.first.allRTQueueEntries.first;
	queuetask := queueEntry.allTasks.first;
	queue := queueEntry.myQueue;
	assertNotNull(queue);
	targetLocation := voyage1.allVoyageJobs.first.workListEntries.first.allRTQueueEntries.last.allTasks.first.targetLocation;
	assertNotNull(targetLocation);
	assertTrue(targetLocation.isKindOf(CM_SlotController));
	sourceLocation := queueEntry.allTasks.first.sourceLocation;
	assertTrue(sourceLocation.isGridLocation);
	sourceArea := sourceLocation.myTerminalArea;
	
	assertEqual(sourceArea, fk1);
	
	// workJob to CTA using Fork Lift
	self.deleteMachine("UTF1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(fk1.id);
	self.addForkLift("UTF1", 91, tas, queue.id);
	forklift := self.getMachine("UTF1");
	assertNotNull(forklift);
	delete tas;
	
	// Add imv
	self.deleteMachine("UTI1");
	self.deleteRTDevice("92");
	create tas transient;
	tas.add(crane.transferArea.id);
	self.addIMV("UTI1", 92, tas, queue.id);
	imv := self.getMachine("UTI1");
	assertNotNull(imv);
	
	app.isRTApp:=true;  
	self.machineLogon(imv);
	self.machineLogon(forklift);
	self.machineAcceptSpecifiedTask(forklift, queueEntry);
	self.machineDirector(forklift, ti1);
	assertEqual(queueEntry.allTasks.first.sourceLocation, sourceLocation);
	assertEqual(queueEntry.allTasks.size, 3);
	assertEqual(queueEntry.allTasks.last.ti, ti1);
	self.machineSetdownTask(forklift, queueEntry.allTasks.last, "UTI1");

	assertFalse(ti1.isOnShip);
	
	// lander app load to ship
	self.landerLoad(ti1, slots.first);
	assertTrue(ti1.isOnShip);
	self.machineLogOff(forklift);
	self.machineLogOff(imv);
	
	// check for valid ship txns
	self.checkTIForTxnOfType(ti1, TRANS_TYPE_REL_SHIP);				// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(ti1, TRANS_TYPE_WHARFAGE);				// 15/08/2012 cnwmh5
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	app.isRTApp:=false;  
	
	delete slots;
	delete tmpLoadCC;
	delete tas;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Emmet_Fails&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;Fails&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
