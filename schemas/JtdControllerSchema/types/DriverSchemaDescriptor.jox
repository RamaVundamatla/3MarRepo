    <JadeMethod name="updateForCreate" id="20ff5ab0-c564-454c-ac5e-872f1977a161">
        <updating/>
        <source>updateForCreate(scm : Schema; mth : Method) updating;

begin
	self.mySchema := scm;
	
	if scm = null then
		self.schemaName := null;
	else
		self.schemaName := scm.name;
	endif;

	self.myProfileTextMethod := mth;
end;</source>
        <Parameter name="scm" type="Schema"/>
        <Parameter name="mth" type="Method"/>
    </JadeMethod>
</Class>
