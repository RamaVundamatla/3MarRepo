        <updating/>
        <source>trxUpdateTIToDoTaskAddBulk(_toDoTaskDesc : CM_ToDoTaskDesc;
						_tiSet 			: CM_TISet input;
						_passport 		: CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	Adds todo tasks to multiple containers. Where tasks are already present or completed or
			cannot be added, a series of warnings regarding those TIs will be displayed

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	// DVB change trx to use defered updates. 05/04/05
	_passport.useTITransactionDeferUpdate	:= true;
	_passport.useTIDictDeferUpdate			:= true;
	
	if _passport.myStateChangeController &lt;&gt; null then
		_passport.myStateChangeController.initForObjects(_tiSet);  //jlier1 TFS 61676 14/12/23
	endif;
	
	beginTransaction;
	app.myUtilityUA.utlUpdateTIToDoTaskAddBulk(_toDoTaskDesc, _tiSet, _passport);
	
	_passport.doDeferredUpdates();
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
