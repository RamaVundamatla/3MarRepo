    <JadeMethod name="getExtraInfo" id="3cf9cef2-5c8f-4983-8738-171cd19c3fc3">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 January 2023	navcs2	ChangeRequest 56833:[56834] EUP - VAS Train Work Order

*/

vars
	block   	: CM_DataContainerBlock;
	addStr  	: String;	
	wagon		: CM_Wagon;
begin
	
	inheritMethod(_dataContainer);

	addStr := self.allWagons.listString(Comma,CM_Wagon::id.name);
	
	if addStr &lt;&gt; null then
		wagon	:= self.allWagons.first;
		block 	:= _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Wagon), DC_Label, 1, wagon);
		block.addNewItem(addStr, DC_Data, 1, wagon);
	endif;	
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyDebtor" id="7cd66eb0-76f8-4c4f-92c1-06755a3a31f3">
        <source>getMyDebtor() : CM_Debtor;
/*
Purpose:			

Date		Who		Reason
23JUN2023	NAVAB1	 BUG 58790
*/

vars
	debtor : CM_Debtor;
	wagon : CM_Wagon;
begin
	 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
	if self.myDebtor &lt;&gt; null then
		return self.myDebtor;
	endif;

	wagon := self.allWagons.first;
	if wagon = null then
		wagon := self.allWagonsCompleted.first;
	endif;
	
	if wagon &lt;&gt; null then
		if wagon.myCarrier &lt;&gt; null then
			debtor := wagon.myCarrier.myDebtor;
		endif;
	endif;
	
	if debtor = null then
		debtor :=  self.myParent.getMyDebtor();  // ### TFS BUG 58790 23JUN2023 NAVAB1
	endif;
	
	return debtor;
epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
