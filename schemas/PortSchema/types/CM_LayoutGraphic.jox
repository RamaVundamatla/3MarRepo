    <JadeMethod name="setProxy" id="8188669c-f494-4d12-abd1-23cfef106646">
        <updating/>
        <source>setProxy(pWidth, pHeight : Integer; pTA : CM_TerminalArea; pColour, pTop, pLeft : Integer; pOrientation : Real; 
							_pointsPolygon : PointArray input;_label : String;_terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin
	self.raiseExceptionIfNotTransient(method);

	self.width := pWidth;
	self.height := pHeight;
	self.drawLineColour := pColour;
	self.top := pTop;
	self.left := pLeft;
	self.orientation := pOrientation;
	self.label := _label;
	self.myTerminal := _terminal;
	
	self.setPointsPolygon(_pointsPolygon);
	
end;</source>
        <Parameter name="pWidth" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pTA" type="CM_TerminalArea"/>
        <Parameter name="pColour" type="Integer"/>
        <Parameter name="pTop" type="Integer"/>
        <Parameter name="pLeft" type="Integer"/>
        <Parameter name="pOrientation" type="Real"/>
        <Parameter name="_pointsPolygon" type="PointArray" usage="input"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
