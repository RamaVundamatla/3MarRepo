    <JadeMethod name="isTransitStatus_Match" id="5e7298c2-e086-4a5d-9b47-526cac2666db">
        <source>isTransitStatus_Match(_yaData: CM_YADataInteger): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Apr 2017	cnwma1 TFS #3890:STWO - Add 'in transit' to Cargo allocations

*/

vars
	yaData : CM_YAData;
	yaDataInteger : CM_YADataInteger;
	int : Integer;

begin
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_TransitStatus );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataInteger) then
		yaDataInteger := yaData.CM_YADataInteger;
		if yaDataInteger &lt;&gt; null then
			if not yaDataInteger.allValues.isEmpty then
				int := yaDataInteger.allValues.first;
				return _yaData.allValues.includes(int);
			endif;
		endif;
	endif;
		
	return true;

epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataInteger"/>
        <ReturnType type="Boolean"/>
