    <JadeMethod name="cnEcGetDuplicate" id="dfa2d3c0-9b73-40f9-baac-51abba0a593d">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	make : String;
	vMake : CM_VehicleMake;

begin

	make := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "make" ).String; 
	
	if make &lt;&gt; null then
		vMake := app.myDutyDocRoot.allVehicleMakes.getAtKey( make );
	endif;

epilog

	return vMake;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
