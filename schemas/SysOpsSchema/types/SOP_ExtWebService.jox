    <JadeMethod name="setupForm" id="46ad8e5d-1c40-4856-a807-5afa60c6d975">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2018	jlgmp6	Initial creation	TFS42015

*/

vars

begin
	inheritMethod();

	frmToolbar.alignContainer := Frame.AlignContainer_Top;
	toolbarStyle := ToolbarStyle_ShowNoHide;	
	showToolbar := true;

	if self.myAssistant = null then
		create self.myAssistant transient;
	endif;

	self.cmbCargoChainFunction.addItem(CreateManualInvLineStr);

    self.getTerminalsForUser();
	self.cmbTerminal.listCollection(self.allTerminalsForThisUser, false, 0);

	self.tblEventMappings.rows := self.tblEventMappings.fixedRows;
	self.tblEventMappings.columns := 3;
	self.tblEventMappings.fixedRows := 1;
	self.tblEventMappings.fixedColumns := 0;
	self.tblEventMappings.accessCell(1, 1).text := app.getErrorString(Event_name);
	self.tblEventMappings.accessCell(1, 2).text := app.getErrorString(Cargo_chain_function);
	self.tblEventMappings.accessCell(1, 3).text := app.getErrorString(ParametersHeading);

	self.populateTable();
	
	self.mode := Mode_View;
	self.setControls();

	if self.tblEventMappings.rows = self.tblEventMappings.fixedRows then
		self.btnEdit.enabled := false;
	else
		self.tblEventMappings.row := self.tblEventMappings.fixedRows + 1;
		self.populateControls();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblEventMappings_click" id="770c28a7-72c6-407f-a7be-b8b1fbea3f65">
