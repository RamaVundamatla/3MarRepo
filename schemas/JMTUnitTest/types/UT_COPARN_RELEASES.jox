    <JadeMethod name="doCoparn_UpdateChecks" id="5b0ba489-cd4a-4184-beb5-d128dd7958cb">
        <source>doCoparn_UpdateChecks(_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode :String; _operator :CM_Operator; _rules :CM_EDIPartyCoparnRules input) protected;
/*
Date		Who		Reason
30/04/2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
03/09/2012	cnwcs5	par 30097 - configure rules for updates/deletes
*/
constants
	BLOCKSTACK 	= 'BS_COPARN';
	YA 			= 'YA_COPARN';
vars
	ya		:CM_YardAllocation;
	array 	:CM_LCArray;
	bs		:CM_BlockStack;
begin
	self.disableAllYA(true);
	self.deleteYA(YA);
	self.deleteTerminalArea (BLOCKSTACK);
	
	bs := self.addBlockStack (BLOCKSTACK, null, null);
	
	create array transient;
	array.add (bs.allLocationsControllers.first);
	
	ya := self.addYA1(YA, YACriteriaType_OperatorItem, _operator.code, array);

	self.doCoparn_UpdateChecksBlocked (_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode);
	self.doCoparn_UpdateChecksRoad (_sender, _voyageCode, _vesselName,  _consignorCode, _consigneeCode, _operator, bs, _rules);
	self.doCoparn_UpdateChecksRail (_sender, _voyageCode, _vesselName,  _consignorCode, _consigneeCode, _operator, bs, _rules);
epilog
	delete array;
	self.disableAllYA(false);
end;</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
