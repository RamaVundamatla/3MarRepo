	endif;
	
	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateToDoTemplate(pProxyToDoTemplate, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
