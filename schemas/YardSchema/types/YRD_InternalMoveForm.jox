    <JadeMethod name="doBuildComboTarget" id="c1856255-a810-477a-b2ae-dcf09cab134e">
        <updating/>
        <source>doBuildComboTarget() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason 
13 August 2009	cnwrd1	Initial creation
20 June 2022 navmv20 Bug 53816 : Mismatch between the dropdown list (source area vs target area) of the delivery request form
08 Sep 2022	jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
*/
// 

vars

	aTerminalArea, aBlockStack : CM_TerminalArea;
	idx : Integer;
	theFilter		: CMQF_TerminalAreas;
	theQryReport	: CM_QryReport;
	aGridArea		: CM_GridArea; // 22 June 2022 navvt20 Bug 53816
	aGridObject 	: CM_GridObject; // 22 June 2022 navvt20 Bug 53816
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	self.cmbTargetArea.clear;
	theQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepTerminalArea);
	
	create theFilter transient;
	theFilter.allTerminals.add(self.myTerminal);
	
	theFilter.terminalAreaTypes.add(TA_TYPE_CRANE_TRANS);
	theFilter.terminalAreaTypes.add(TA_TYPE_DEPOT_LCL);
	theFilter.terminalAreaTypes.add(TA_TYPE_BLOCK_STACK);
	theFilter.terminalAreaTypes.add(TA_TYPE_SUBBLOCK_STACK);	
	theFilter.terminalAreaTypes.add(TA_TYPE_WASH_AREA);			
	theFilter.terminalAreaTypes.add(TA_TYPE_PTI);				
	theFilter.terminalAreaTypes.add(TA_TYPE_REPAIR);				
	theFilter.terminalAreaTypes.add(TA_TYPE_RECTRANS);				
	theFilter.terminalAreaTypes.add(TA_TYPE_RELTRANS);				
	theFilter.terminalAreaTypes.add(TA_TYPE_DAIRY);			
	theFilter.terminalAreaTypes.add(TA_TYPE_FORK_LIFT_STACK);									
	theFilter.terminalAreaTypes.add(TA_TYPE_STRADDLE_STACK);				
	theFilter.terminalAreaTypes.add(TA_TYPE_RTG);						
	theFilter.terminalAreaTypes.add(TA_TYPE_RMG);	 
	theFilter.terminalAreaTypes.add(TA_TYPE_RAIL_TRANS);	 
	theFilter.terminalAreaTypes.add(TA_TYPE_IRREGULAR_BLOCK_AREA);	
	theFilter.terminalAreaTypes.add(TA_TYPE_RORO_LANE_AREA);	
	theFilter.terminalAreaTypes.add(TA_TYPE_MAFI);	
	
	
	// Does not handle straddle stacks, only single controller areas
	// Straddles are handled by a string entry into the cmb edit text field (e.g. C 2601).
	theQryReport.doFilter(theFilter, app.myPassport);
	
	//idx := self.cmbTargetArea.addItem('');
	//self.cmbTargetArea.itemObject[idx] := null;
	self.cmbTargetArea.addItemObject('',null);
	
	foreach aTerminalArea in theFilter.allQryTerminalAreas do
		//idx := self.cmbTargetArea.addItem(aTerminalArea.id);
		//self.cmbTargetArea.itemObject[idx] := aTerminalArea;
		//self.cmbTargetArea.addItemObject(aTerminalArea.id,aTerminalArea);
		
		//22 June 2022 navvt20 Bug 53816 START
		
		self.cmbTargetArea.addItemObject( aTerminalArea.id &amp; " " &amp; aTerminalArea.getMenuDetails(false,REAL_MODE) , aTerminalArea); 
		if aTerminalArea.isGridArea then
				aGridArea := aTerminalArea.CM_GridArea;
				//OMG hideous hack for bays/rows
				if aGridArea.areLocationIdsColThenRow then
				// forklift/gbs
				//look at columns/bays
					foreach aGridObject in aGridArea.allGridColumns do
						self.cmbTargetArea.addItemObject(aTerminalArea.id &amp; " " &amp; aGridObject.getFullLabel() , aGridObject);		
					endforeach;
				else
				//straddle etc lool at bays/rows
					foreach aGridObject in aGridArea.allGridRows do
						self.cmbTargetArea.addItemObject( aTerminalArea.id &amp; " " &amp; aGridObject.getFullLabel() , aGridObject);		
					endforeach;			
				endif;
			endif;
			// 22 June 2022 navvt20 Bug 53816 END
	endforeach;
	
		//endif;
	

epilog
	delete theFilter;
	self.mousePointer := Window.MousePointer_Default;

end;

</source>
    </JadeMethod>
