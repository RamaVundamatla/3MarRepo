    <JadeMethod name="addToolbarControls" id="d7d247a3-371f-4b53-afb9-372e062ee9d2">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Date		    Who			Reason
24 March 2011	cnwas3	  Initial creation

*/

vars
	deckToolbar, layerToolbar, dimToolbar : CMUI_Toolbar;
begin
	
	deckToolbar := self.frmToolbar;
	layerToolbar := self.toolbarLayItems;
	dimToolbar := self.toolbarItemDim;
	
	inheritMethod();	
	
	deckToolbar.addButton(self.btnNewDeckLayer, CMUI_Toolbar.Control_Alignment_Left);	
//	deckToolbar.addButton(self.btnSaveDeckLayer, CMUI_Toolbar.Control_Alignment_Left);	
	deckToolbar.addButton(self.btnCopyDeckLayer, CMUI_Toolbar.Control_Alignment_Left);
	deckToolbar.addButton(self.btnDltDeckLayer, CMUI_Toolbar.Control_Alignment_Left);		
	deckToolbar.positionToolbarControls();		
	
	layerToolbar.addButton(self.btnNewLayerItem, CMUI_Toolbar.Control_Alignment_Left);	
	layerToolbar.addButton(self.btnFillLayers, CMUI_Toolbar.Control_Alignment_Left);
//	layerToolbar.addButton(self.btnSaveLayerItem, CMUI_Toolbar.Control_Alignment_Left);
	layerToolbar.addButton(self.btnCopyLayerItem, CMUI_Toolbar.Control_Alignment_Left);
	layerToolbar.addButton(self.btnDltLayerItem, CMUI_Toolbar.Control_Alignment_Left);
	layerToolbar.positionToolbarControls();	
	
	dimToolbar.addButton(self.btnNewItemDim,CMUI_Toolbar.Control_Alignment_Left);
//	dimToolbar.addButton(self.btnSaveItemDim,CMUI_Toolbar.Control_Alignment_Left);
//	dimToolbar.addButton(self.btnCopyItemDim,CMUI_Toolbar.Control_Alignment_Left);
	dimToolbar.addButton(self.btnDltItemDim,CMUI_Toolbar.Control_Alignment_Left);
	dimToolbar.positionToolbarControls();	
	
	//self.setFrames(-2147483633);
	//self.setFrames(self.backColor);
	//self.setFrames(15132390);
	self.setFrames(self.backColor);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
