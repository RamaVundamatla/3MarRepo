    <JadeMethod name="getDisplayStringForAttribute" id="b90f3238-f73d-4bef-8969-98020206bd4c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	moveAmount 	: String;
	moveDetail,
	lDetail : String;
	theTI,
	otherTI		: CM_TrackedItem;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			//Split off  (10 Widgets) at location %3 from this cargo item new quantity %3.  Split to cargo at location %4 new quantity 45.
			
			//Split off cargo (10 Widgets) at location %3 from this cargo at location %4 new quantity 
			
			theTI := self.myTrackedItem;
			otherTI := self.getOtherTrackedItem();
			if otherTI = null then
				lDetail :="[DELETED] ";
			endif;
			lDetail := lDetail &amp; "Split off ";

			if self.action = self.ACTION_PARENT then	
				if theTI &lt;&gt; null then
					moveAmount:= self.getMoveAmount;
					//lDetail := lDetail  &amp; otherTI.id;
					if moveAmount &lt;&gt; null then
						moveDetail :=  moveAmount &amp;  " " &amp;  theTI.getProductOrISODescr;
						if self.locationId &lt;&gt; null then
							moveDetail := moveDetail &amp; " at location " &amp; self.locationId;
						endif;
					
						lDetail := lDetail &amp; " " &amp; moveDetail;
						
						lDetail := lDetail &amp; " (" &amp; self.getOldAmount &amp; ")"; //epr par 31705 19/6/13 now showing before quantity
					endif;
				endif;
				
				if self.myChildSplit &lt;&gt; null then
					if self.myChildSplit.oldQuantity &lt;&gt; 0 or self.myChildSplit.oldVolume &lt;&gt; 0 or self.myChildSplit.oldWeight &lt;&gt; 0 then
						lDetail := lDetail &amp; ". Merged into cargo " &amp; self.myChildSplit.myTrackedItem.id;
					else
						lDetail := lDetail &amp; ". Created new cargo " &amp; self.myChildSplit.myTrackedItem.id;
					endif;
					lDetail := lDetail &amp; " at location " &amp; self.myChildSplit.locationId.asStringJMT &amp; ".";
				endif;
			
			elseif self.action = self.ACTION_CHILD then
				if otherTI &lt;&gt; null then		
					moveDetail :=  self.getNewAmount &amp;  " " &amp;  otherTI.getProductOrISODescr ;
					if self.myParentSplit &lt;&gt; null and self.myParentSplit.locationId &lt;&gt; null then
						moveDetail := moveDetail &amp; " from " &amp; otherTI.id &amp; " at location " &amp; self.myParentSplit.locationId;
					endif;
					lDetail := lDetail &amp; " " &amp; moveDetail;
					
					if self.myParentSplit &lt;&gt; null  then
						lDetail := lDetail &amp; " (" &amp; self.myParentSplit.getOldAmount &amp; ")"; //epr par 31705 19/6/13 now showing before quantity
					endif;
				endif;
				
				
				if self.oldQuantity &lt;&gt; 0 or self.oldVolume&lt;&gt; 0 or self.oldWeight &lt;&gt; 0 then
					lDetail := lDetail &amp; ". Merged into cargo " &amp; self.myTrackedItem.id;
				else
					lDetail := lDetail &amp; ". Created this cargo " &amp; self.myTrackedItem.id;
				endif;
				lDetail := lDetail &amp; " at location " &amp; self.locationId.asStringJMT &amp; ".";
				
			endif;
			
			return lDetail;
			
		endif;

	elseif _attrName = ETRow_SplitFromId then
		theTI := self.myTrackedItem;
		otherTI := self.getOtherTrackedItem();
		if self.action = self.ACTION_PARENT then
			if otherTI &lt;&gt; null then
				lDetail := otherTI.id;
			endif;
		elseif self.action = self.ACTION_CHILD then
			if theTI &lt;&gt; null then
				lDetail := theTI.id;
			endif;
		endif;
		return lDetail;
		
	elseif _attrName = ETRow_SplitFromQuantity then
		theTI := self.myTrackedItem;
		if otherTI &lt;&gt; null then
			lDetail := theTI.quantity.asStringJMT();
		endif;
		return lDetail;
	
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationStr" id="5fd1312d-b7f9-48c4-89a4-f0c44ff9058c">
