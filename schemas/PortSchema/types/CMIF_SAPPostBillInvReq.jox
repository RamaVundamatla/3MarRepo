        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleSAPResponse" id="558233b2-272b-4b56-9767-137ae9602c5f">
        <source>handleSAPResponse(	_response: CMIF_SAPWSResponse;
					_cashReceipt: CM_CashReceipt input;
					_invoice: CM_Invoice input;
					_invoiceLines: CM_InvoiceLineSet input;
					_activityHistory: CM_ActivityHistoryExtInterface input
					): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2019	jlgndl1	Initial creation	TFS 46758

*/

vars

begin

	if  _response = null or _response.status = "E" or _response.status = " "  or _response.status = null  then
		
	elseif _response.status = "X" then
		if _invoice &lt;&gt; null then
			self.updateInvoice( _invoice );
		endif;
		
	endif;

	//Now do the updating of the activity history and create alerts / emails if required
	return inheritMethod(_response, _cashReceipt, _invoice, _invoiceLines, _activityHistory);

epilog

end;</source>
        <Parameter name="_response" type="CMIF_SAPWSResponse"/>
        <Parameter name="_cashReceipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_invoiceLines" type="CM_InvoiceLineSet" usage="input"/>
        <Parameter name="_activityHistory" type="CM_ActivityHistoryExtInterface" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateInvoice" id="bd538959-8746-46e8-8b3e-bebfd51a6d8c">
        <source>updateInvoice( _invoice : CM_Invoice input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2019	jlgndl1	Initial creation	tFS 46758
7/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt

*/

vars

	msg : String;
	wasLockError : Boolean;
	lockCount : Integer;

begin

	app.myPassport.setupForDeadlockReplay(-100, 2000);

	while true do
			
		app.myTrxUA.trxSapWSDL17Success( _invoice, app.myPassport );
			
		wasLockError := ( app.myPassport.allErrors.includesErrorCode( 1027 ) and app.myPassport.allErrors.size = 1 );
		if wasLockError then
			lockCount := lockCount + 1;
		endif;
		
		if app.myPassport.hadDeadlock = false  and not wasLockError then
			if app.myPassport.silentDeadlockRetryCount &gt; 0 or lockCount &gt; 0 then
				msg := method.qualifiedName &amp; " got past lock while processing " &amp; self.getWSDLType &amp; " response.";
				app.writeLog(msg ,LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
			endif;
			break;
		endif;
		
		if app.myPassport.hadDeadlock then
			msg := method.qualifiedName &amp; " deadlock (" &amp; app.myPassport.silentDeadlockRetryCount.String &amp; ") encountered while processing " &amp; self.getWSDLType &amp; " response.";
			app.writeLog(msg ,LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
			
			if app.myPassport.silentDeadlockRetryCount &gt; app.myPassport.silentDeadlockLimit then
				break;
			endif;
		elseif wasLockError then
			msg := method.qualifiedName &amp; " lock (" &amp; lockCount.String &amp; ") encountered while processing " &amp; self.getWSDLType &amp; " response.";
			app.writeLog(msg ,LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
			
			if lockCount &gt; app.myPassport.silentDeadlockLimit then
				break;
			endif;
		endif;

		app.myPassport.hadDeadlock := false;
		wasLockError := false;
		
		process.sleep (app.myPassport.silentDeadlockSleepTime);

	endwhile;

epilog
	app.myPassport.resetSilentDeadlockHandler;	//7/3/25 navsaa30 #14818
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
</Class>
