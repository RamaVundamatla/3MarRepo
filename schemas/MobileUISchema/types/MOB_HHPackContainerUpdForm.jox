    <JadeMethod name="doResizeControls" id="66c8bdc6-e55f-4f4f-9b33-e6a4ddac1c3e">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	folderHeight : Real;
	
	bookingRefItem : CM_BookingRefItem;
	resDetail : CM_ReserveDetail;
	resDetailSet : CM_ReserveDetailSet;
	bookingItemSet : CM_BookingRefItemSet;
	docActions : CM_DocumentActions;

begin

	self.setResizeableMarginAndFontSize();
	
	create resDetailSet transient;
	create bookingItemSet transient;
	if self.myPackContainer &lt;&gt; null then
		if self.myPackContainer.hasDocumentActions( resDetailSet, bookingItemSet ) then
			if not bookingItemSet.isEmpty then
				bookingRefItem := bookingItemSet.first;
				if bookingRefItem &lt;&gt; null then
					docActions := bookingRefItem.myBookingRefItemActions;
				endif;
			elseif not resDetailSet.isEmpty then
				resDetail := resDetailSet.first;
				if resDetail &lt;&gt; null then
					docActions := resDetail.myReserveDetailActions;
				endif;
			endif;
		endif;
	endif;
	
	
	
	folderHeight := self.clientHeight - (self.resizedMargin * 3) - self.getCMDButtonsHeight;
	
	if docActions &lt;&gt; null then
		self.btnDocActions.visible := true;
		self.btnDocActions.height := self.btnOne.height;
		folderHeight := folderHeight - self.btnDocActions.height - self.resizedMargin;
	else
		self.btnDocActions.visible := false;
	endif;

	self.tblCargo.move(	self.resizedMargin,
						self.resizedMargin,
						self.clientWidth - self.resizedMargin - self.resizedMargin,
						folderHeight
						);
	
	if self.btnDocActions.visible then
		self.btnDocActions.move(	self.resizedMargin,
									self.tblCargo.top + self.tblCargo.height + self.resizedMargin,
									self.btnOne.width,
									self.btnOne.height
									);
	endif;
	
	inheritMethod(_initialSetup);
	
	self.tblCargo.resize;	//27 Jun 2017	NDL	TFS 4647

epilog

	delete resDetailSet;
	delete bookingItemSet;

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDataFromObject" id="3d02f5ef-098a-435e-b0a1-e8e0318c48f5">
        <source>getDataFromObject(entTableRow: EntTableRow; errMsg: String output): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	dataValue : String;

begin

	if entTableRow.name = ETRow_BookingReference
	or entTableRow.name = ETRow_VoyageCode
	or entTableRow.name = ETRow_DischargePort
	or entTableRow.name = ETRow_DestinationPort
	then
	
		if self.myMobileGenericAgent.myPackExportBookingRef &lt;&gt; null then
			self.tblCargo.accessRow( self.tblCargo.getRow(entTableRow.name)).enabled := false;	// Fields populated from the Export Bookings can not be changed.
			dataValue := self.myMobileGenericAgent.myPackExportBookingRef.getDisplayStringForAttribute(entTableRow.name,false);
		else
			dataValue := self.myPackContainer.getDisplayStringForAttribute(entTableRow.name,false);
		endif;
	
	elseif entTableRow.name = ETRow_ImexStatus then
		if self.myMobileGenericAgent.myPackExportBookingRef &lt;&gt; null then
			self.tblCargo.accessRow( self.tblCargo.getRow(entTableRow.name)).enabled := false;	// Fields populated from the Export Bookings can not be changed.
			dataValue := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT].description;
		else
			dataValue := self.myPackContainer.getDisplayStringForAttribute(entTableRow.name,false);
		endif;
	
	elseif entTableRow.name = ETRow_BookingReferenceItem then
		if self.myMobileGenericAgent.myPackExportBookingItem &lt;&gt; null then
			self.tblCargo.accessRow( self.tblCargo.getRow(entTableRow.name)).enabled := false;	// Fields populated from the Export Bookings can not be changed.
			dataValue := self.myMobileGenericAgent.myPackExportBookingItem.getDisplayString;
		else
			dataValue := self.myPackContainer.getDisplayStringForAttribute(entTableRow.name,false);
		endif;
	elseif entTableRow.name = ETRow_Commodity then
		//epr par 36611 10/8/15
		if not self.myPackContainer.isEmpty then
			dataValue := self.myPackContainer.getDisplayStringForAttribute(entTableRow.name,false);
		endif;
	
		
	else
		dataValue := self.myPackContainer.getDisplayStringForAttribute(entTableRow.name,false);
	endif;

	if entTableRow.name = ETRow_CarriageTempC then
		if dataValue.length &gt; 0 then
			if dataValue[1] = '+' then
				dataValue := dataValue[2:end];
			endif;
		endif;
	endif;
	
	return dataValue;

epilog

end;</source>
        <Parameter name="entTableRow" type="EntTableRow"/>
        <Parameter name="errMsg" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStringValueFromTable" id="93e1c0d9-ddc0-43e8-8cbe-2146f30826a2">
        <source>getStringValueFromTable( _attrName : String ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2015	cnwndl1	Initial creation	Par 36703

*/

vars
	row : Integer;
	aCellControl : Control;
	strValue : String;
begin
	row := self.tblCargo.getRow( _attrName );
	if row &gt; 0 then
	
		if self.tblCargo.accessRow( row ).visible &lt;&gt; false then 
	
			aCellControl := self.tblCargo.accessCell( row, 2 ).cellControl;
			if aCellControl &lt;&gt; null and aCellControl.isKindOf(CMUI_MeasurementTable) then
				return aCellControl.CMUI_MeasurementTable.getConvertedValue().String;
			endif;
			
			strValue := self.tblCargo.getCellText(row,2).String.trimBlanks;
			
			//16 Aug 2016	NDL	TFS 2540
			if strValue = null then
				if _attrName = ETRow_CarriageTempC
				or _attrName = ETRow_CarriageTempF
				or _attrName = ETRow_PackTempC
				or _attrName = ETRow_PackTempF
				then
					strValue := NULL_TEMPERATURE.String;
				endif;
			endif;
			
			return strValue;
		
		endif;
		
	endif;
	
	if _attrName = ETRow_CarriageTempC
	or _attrName = ETRow_CarriageTempF
	or _attrName = ETRow_PackTempC
	or _attrName = ETRow_PackTempF
	then
		return NULL_TEMPERATURE.String;
	endif;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="8ccb4f18-c72e-480b-8d44-2f665f4d6247">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation

*/

vars

begin

	if not self.validateSelections() then
		return;
	endif;
	
	if not self.updatePackContainer() then
		return;
	endif;
	
	if self.getSessionAgent.peekAtPreviousForm = MOB_HHPackRequestSTW then	//16 Apr 2018	NDL	TFS 38083
		self.gotoForm( MOB_HHPackContainerFormSTW, false );
	else
		self.gotoForm( MOB_HHPackContainerForm, false );
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
