    <JadeMethod name="picture" id="2f05a9ac-c857-46b6-99ce-65c9432e631d">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>picture(set: Boolean; value: Binary io) mapping, updating;

vars

begin
	inheritMethod(set, value);
	if set then
		picture := value;
		if picture = null then
			visible := false;
		else
			visible := true;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Binary" usage="io"/>
    </JadeMethod>
