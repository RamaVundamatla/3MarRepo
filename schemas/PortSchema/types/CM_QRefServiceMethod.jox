    <JadeMethod name="create" id="44a44727-3f53-4cac-ad84-b02501e0612d">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	oper : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);

epilog

end;</source>
    </JadeMethod>
