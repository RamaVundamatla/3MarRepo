    <JadeMethod name="getLastModifiedTimeStamp" id="559db656-3bee-432a-98a9-d0eb3638f0f3">
        <source>getLastModifiedTimeStamp() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2021	navpw1	Initial creation TFS: 52202

*/

begin
	if self.patchVersion &lt;&gt; null then
		return '"' &amp; self.modifiedBy &amp; '" "' &amp; self.modifiedVersion &amp; '" ' &amp; self.patchVersion &amp; " " &amp; self.getTimeStamp() &amp; ";";
	else
		return '"' &amp; self.modifiedBy &amp; '" "' &amp; self.modifiedVersion &amp; '" ' &amp; self.getTimeStamp() &amp; ";";
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
