    <JadeMethod name="validateMe" id="3e45dee1-8151-45ef-b6ee-d0d9ae58276a">
        <source>validateMe();
/*

Purpose:			Validates whether an Invoice Note passes validation to be created

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
03 February 2022	navpw1	Initial creation TFS: 52752

*/

begin
	if self.myInvoice = null then
		app.raiseCMException(Input_required_field_invoice, null, null);
	endif;

	if self.note = null then
		app.raiseCMException1(REQUIRED_FIELD, "Notes", null, null);
	endif;
	
end;</source>
    </JadeMethod>
</Class>
