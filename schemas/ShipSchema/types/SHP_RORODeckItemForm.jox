    <JadeMethod name="cmbType_click" id="e21492d5-c25f-42e2-8dc9-89dcaf4596da">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbType_click(combobox: ComboBox input) updating;
/*
Date		    Who			Reason
17 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	if (self.chkIsMovable.visible and (combobox.text = app.getErrorString(DeckItem_General_Items) or combobox.text = app.getErrorString(DeckItem_Machinery))) or	//switch to machinery/general items view
		(not self.chkIsMovable.visible and (combobox.text = app.getErrorString(DeckItem_Internal_Ramp) or combobox.text = app.getErrorString(DeckItem_Lift))) then  //switch to ramp/lift view		
		self.setupTextBoxes(true,not self.chkIsMovable.visible);
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
