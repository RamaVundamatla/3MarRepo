    <JadeMethod name="canDo" id="d233ea26-1ad5-4865-8112-dfed2e131383">
        <source>canDo(_permValue: Integer; _rptId : String): Boolean;
// ---------------------------------------------------------------------------
// Created:     02 December 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _rptId &lt;&gt; null then
		return self.myUserTerminal.canDoReport(_rptId);
	endif;
	
	return self.myUserTerminal.canDo(_permValue);
	

end;</source>
        <Parameter name="_permValue" type="Integer"/>
        <Parameter name="_rptId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
