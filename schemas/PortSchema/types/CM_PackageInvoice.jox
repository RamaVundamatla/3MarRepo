    <JadeMethod name="erase" id="61079709-c7be-4bb9-9f07-093cb252b953">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*

Purpose:			Delete invoice packages, and its associates 

Parameters:			

Return Value:		Nothing

Date			Who		Reason
25 January 2019	jlgzm1	TFS42936 Unable to edit or delete invoice packages

*/

vars
	autoTask		: CM_AutoTask;
	autoSchedule 	: CM_AutoSchedule;
begin
	
	if not self.allTasks.isEmpty() then
		//Should only have one task. One is automatically created on invoice package creation
		//and unable to make new tasks for invoice packages manually
		autoTask := self.allTasks.first();
		if not autoTask.allAutoSchedules.isEmpty() then
			//first delete our automatically generated autoSchedule
			autoSchedule := autoTask.allAutoSchedules.first();
			delete autoSchedule;
		endif;
		//now delete the task
		delete autoTask;
	endif;
	//now delete the package
	inheritMethod(_eraseLevel);
	
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEmailBody" id="0e0a632c-bb69-4a69-af55-e97edcd50ba7">
        <source>getEmailBody(_invoice : CM_Invoice) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2025	navah1	Initial creation
27 May 2025	navah1	Bug 34605: LINX - Invoice Package Reports - Email Fields
*/

vars 
	entTableRow: EntTableRow;
	entTableDef: EntTableDef;
	entTableName,
	heading,
	str: String;
	strObj: CM_String;
	strDict: CM_StringDict;
	strObjStr: CM_StringWithString; 
	index: Integer;
begin
	entTableName := self.myEmailTemplate.entTableName;
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(entTableName);
	if entTableDef = null then
		return str;
	endif;
	create strDict transient;
	foreach entTableRow in entTableDef.allEntTableRows do
		heading := entTableRow.getHeading(null, null, app.myCurrentLocale);
		if self.myEmailTemplate.allIncludedFields.includes(heading) then
			index := self.myEmailTemplate.allIncludedFields.indexOf(heading);
			create strObjStr transient;
			strObjStr.set(index.String.padLeadingZeros(2), heading &amp; ": " &amp;  _invoice.getDisplayStringForAttribute(entTableRow.name, false));
			strDict.add(strObjStr);	
		endif;
	endforeach;
	foreach strObj in strDict do
		str := str &amp; strObj.CM_StringWithString.strString &amp; CrLf;
	endforeach;
	
	str := str &amp; CrLf;
	return str &amp; CrLf;
	
epilog
	delete strObjStr;
	if strDict &lt;&gt; null then
		strDict.purge();
	endif;
	delete strDict;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEmailSubject" id="a5f878fc-b8fd-40e3-8350-5cb9ade5686b">
        <source>getEmailSubject(_invoice: CM_Invoice; _subject: String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Oct 2025	navah1	Initial creation
17 Oct 2025	navah1  Story 36249: LINX | Configurable Invoice Email Subject Placeholder Support
*/

vars   
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	subject,
	vesselName,
	voyageCode,
	voyageCodeExternal : String;
begin
	subject := _subject; 
	voyage := _invoice.myVoyage; 
	
	if voyage &lt;&gt; null then
		voyageCodeExternal := voyage.voyageCodeExternal;
		voyageCode := voyage.code;
		vessel := voyage.getMyVessel();
	endif;
	
	if vessel &lt;&gt; null then
		vesselName := vessel.name;
	endif;
	
	// Replace placeholders  
	subject := subject.replace("@INV", _invoice.getExternalInvoiceNumber()); // Placeholder for InvoiceNumber
	subject := subject.replace("@STA", _invoice.getStatusDescription(_invoice.status)); // Placeholder for InvoiceStatus
	subject := subject.replace("@VOE", voyageCodeExternal); // Placeholder for VoyageExternalCode
	subject := subject.replace("@VOY", voyageCode); // Placeholder for VoyageCode
	subject := subject.replace("@VES", vesselName); // Placeholder for VesselName
	subject := subject.replace("@TER", _invoice.myTerminal.code); // Placeholder for TerminalCode
	subject := subject.replace("@DEBTCODE", _invoice.debtor.code); // Placeholder for DebtorCode
	 
	return subject;
epilog
	

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_subject" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
