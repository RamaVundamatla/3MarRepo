    <JadeMethod name="isFatalThinClientError" id="b24c1977-0d38-46f8-b910-bc79fad74363">
        <source>isFatalThinClientError(exObj : Exception) : Boolean;
// ---------------------------------------------------------------------------
// Created:     17 February 2004 by cnwrs2
//
// Purpose:     Method here rather than on Exception as JSS exception  do not have this method
// ---------------------------------------------------------------------------
vars

begin
	if exObj = null then
		return false;
	endif;
	return ((exObj.errorCode &gt;= 14140) and (exObj.errorCode &lt;= 14149));
end;</source>
