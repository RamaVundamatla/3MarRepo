    <JadeMethod name="hasNonReviewedAlerts" id="b3c13707-ce52-4732-a9fe-8acbd00eebe6">
        <source>hasNonReviewedAlerts(_onlyFromHandHelds : Boolean) : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	alert : CM_SystemAlert;
	object : Object;
	alerts : Collection;
	iter : Iterator;
begin
	alerts:=self.getAlerts();
	if alerts = null then
		return false;
	endif;
	iter:= alerts.createIterator;
	while iter.next(object) do
		if not object.isKindOf(CM_SystemAlert) then
			continue;
		endif;
		alert:=object.CM_SystemAlert;
		if alert.mySystemAlertType = null then
			continue;
		endif;
		if alert.reviewed then
			continue;
		endif;
		if _onlyFromHandHelds then
			if alert.mySystemAlertType &lt;&gt; app.myRoot.allSystemAlertTypes[EVENT_AT_RTGAlert] and
				alert.mySystemAlertType &lt;&gt; app.myRoot.allSystemAlertTypes[EVENT_AT_HandHeldAlert]  then
				continue;
			endif;
		endif;
		return true;	
	endwhile;
	
	return false;
epilog
	delete iter;
end;</source>
        <Parameter name="_onlyFromHandHelds" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
