<GUIClass name="CMUI_VoyageAdminSummary" id="acfc6625-74d6-4555-9096-eb2b7e61aa62">
    <superclass name="CMUI_VoyageWeightSummary"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="addTotalsRow" id="6e77a7d9-dd35-4ab1-a3f3-5f0faef048d6">
        <source>addTotalsRow() protected;
// -------------------------------------------
// Created 04 October 2004 by cnwdvb1
// -------------------------------------------
vars

	tbl		: Table;
	row,
	startRow,
	numRows,
	cols,
	totalCol,
	col,
	startCol,
	countTotal,
	grandTotal,
	totalRow	 : Integer;

begin


	tbl 		:= self.tblReport;
	numRows 	:= tbl.rows;
	totalRow 	:= numRows + 1;
	startRow	:= tbl.fixedRows + 1;
	cols		:= tbl.columns;
	totalCol	:= cols + 1;
	tbl.columns := totalCol;
	tbl.accessColumn(totalCol).fontBold := true;
//	tbl.accessedColumn.width := 100;
	tbl.setCellText(tbl.fixedRows, totalCol, 'Total');
	startCol	:= tbl.fixedColumns + 1;

	foreach row in startRow to numRows do
		foreach col in startCol to cols do
			countTotal := countTotal + tbl.accessCell(row, col).text.Integer;
		endforeach;
		tbl.setCellText(row, totalCol, countTotal.String);
		grandTotal := grandTotal + countTotal;
		countTotal := 0;
	endforeach;

	tbl.rows := totalRow;
	tbl.accessRow(totalRow).fontBold := true;
	tbl.setCellText(totalRow, tbl.fixedColumns, 'Total');
	foreach col in startCol to cols do
		foreach row in startRow to numRows do
			countTotal := countTotal + tbl.accessCell(row, col).text.Integer;
		endforeach;
		tbl.setCellText(totalRow, col, countTotal.String);
		countTotal := 0;
	endforeach;
	tbl.setCellText(totalRow, totalCol, grandTotal.String);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTable" id="4e800faf-4e77-456f-af6f-ab79fb5d089f">
        <source>populateTable() protected;
// -------------------------------------------
// Created 04 October 2004 by cnwdvb1
// -------------------------------------------
vars

	tbl 				: Table;
	fixedColumns,
	totalColumns,
	maxCols,
	currentCol,
	currentRow			: Integer;
	summaryDict			: CMIF_VoyageSummaryByValueDict;
	voySummary			: CMIF_VoyageSummary;
	iter				: Iterator;
	colHeading,
	rowHeading			: String;
	headingsArray		: StringArray;

begin
	
	summaryDict := self.myJRWVoyageSummary.allVoyageSummaryObjects;

	maxCols := 1;
	tbl := self.tblReport;
	tbl.autoSize := Table.AutoSize_None;
	tbl.columns := maxCols;
	tbl.addItem('');
	tbl.accessColumn(1).fontBold := true;
	tbl.accessedColumn.alignment := Table.Alignment_Left_Middle;
	tbl.accessRow(1).fontBold := true;
	tbl.fixedColumns := 1;
	tbl.fixedRows := 1;
	iter := summaryDict.createIterator();
	rowHeading := 'xxx';
	create headingsArray transient;
	while iter.next(voySummary) do
		if not headingsArray.includes(voySummary.keyValue2) then
			headingsArray.add(voySummary.keyValue2);
		endif;
	endwhile;
	headingsArray.cnEcSort(false);
	fixedColumns := tbl.fixedColumns;
	tbl.columns := headingsArray.size + fixedColumns;
	totalColumns := tbl.columns;
	currentCol := fixedColumns;
	foreach colHeading in headingsArray do
		currentCol := currentCol + 1;
//		tbl.accessColumn(currentCol).width := 100;
		tbl.accessCell(tbl.fixedRows, currentCol).text := colHeading;
	endforeach;
//	tbl.accessColumn(1).width := 30;

	iter.reset();
	while iter.next(voySummary) do
		if rowHeading &lt;&gt; voySummary.keyValue1 then
			currentCol := fixedColumns;
			rowHeading := voySummary.keyValue1;
			currentRow := tbl.addItem(rowHeading);
		endif;
		currentCol := headingsArray.indexOf(voySummary.keyValue2) + fixedColumns;
		if currentCol &gt; fixedColumns and currentCol &lt;= totalColumns then
			tbl.setCellText(currentRow, currentCol, voySummary.numGeneral.String); 
		endif;
	endwhile;

	

epilog
	delete headingsArray;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTableOld" id="4992a927-69f0-4546-b7c6-c7c2e0b63140">
        <source>populateTableOld() protected;
// -------------------------------------------
// Created 04 October 2004 by cnwdvb1
// -------------------------------------------
vars

	tbl 				: Table;
	maxCols,
	currentCol,
	currentRow			: Integer;
	summaryDict			: CMIF_VoyageSummaryByValueDict;
	voySummary			: CMIF_VoyageSummary;
	iter				: Iterator;
	rowHeading			: String;

begin
	
	summaryDict := self.myJRWVoyageSummary.allVoyageSummaryObjects;

	maxCols := 1;
	tbl := self.tblReport;
	tbl.columns := maxCols;
	tbl.addItem('');
	tbl.accessColumn(1).fontBold := true;
	tbl.accessedColumn.alignment := Table.Alignment_Left_Middle;
	tbl.accessRow(1).fontBold := true;
	tbl.fixedColumns := 1;
	tbl.fixedRows := 1;
	iter := summaryDict.createIterator();
	rowHeading := 'xxx';
	while iter.next(voySummary) do
		if rowHeading &lt;&gt; voySummary.keyValue1 then
			currentCol := tbl.fixedColumns;
			rowHeading := voySummary.keyValue1;
			currentRow := tbl.addItem(rowHeading);
		endif;
		currentCol := currentCol + 1;
		if maxCols &lt; currentCol then
			maxCols := currentCol;
			tbl.columns := maxCols;
			tbl.accessCell(tbl.fixedRows, maxCols).text := voySummary.keyValue2;
		endif;
		tbl.setCellText(currentRow, currentCol, voySummary.numGeneral.String); 
	endwhile;

epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setNoDataDisplay" id="471073e2-9871-4518-94b2-ccce2464d62f">
        <source>setNoDataDisplay();
// -------------------------------------------
// Created 04 October 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.lblNoData.caption := 'No Data To Display For Voyage Administration Summary';


end;</source>
    </JadeMethod>
    <JadeMethod name="setupHeader" id="5d2857aa-a196-40e5-8b6a-fcee19c38bfb">
        <source>setupHeader() protected;
// ---------------------------------------------------------------------------
// Created:     20 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	Gap = 5;
vars

begin
	self.frmHeader.height := 145;
	self.lblPage.top := self.lblPrinted.top;
	self.lblHeading3_1.top := self.lblPrinted.top;
	self.lblHeading3_1.left := self.lblHeading3_1.left - Gap;
	
	self.lblTerminalName.visible := false;
	self.lblReportId.visible := false;
	self.lblPrinted.top := self.picPortLogo.top + self.picPortLogo.height + Gap;
	self.lblPrinted.left := self.lblPrinted.left - 10;
	self.lblPrintedDtl.top := self.lblPrinted.top;
	self.lblPrintedDtl.left := self.lblPrintedDtl.left - 10;
	self.lblPrintTime.top := self.lblPrinted.top;
	self.lblPrintTime.left := self.lblPrintTime.left - 15;
	
	self.picJadeLogo.picture := app.getPicLogoProduct;
	self.picPortLogo.picture := app.getPicLogoPort;
	self.picJadeLogo.visible := true;
	self.picPortLogo.visible := true;
	self.picJadeLogo.zOrder(1);
	self.picPortLogo.zOrder(1);
	
	self.lblHeading1.caption := self.myJRWVoyageSummary.myVoyage.code &amp; ' - ' &amp; 
						self.myJRWVoyageSummary.myVoyage.vesselName.trimBlanks &amp; ' - Summary';
						
	self.lblHeading1.alignment := self.lblHeading2.Alignment_Center_Middle;
	self.lblHeading1.top := 10;
	self.lblHeading1.height := 20;
	self.lblHeading1.fontSize := 12;
	self.lblHeading1.fontBold := true;
	
//	self.lblHeading2.caption := 'Ordered by ' &amp; self.myJRWVoyageSummary.orderedByHeading1;
	
	self.lblHeading2.alignment := self.lblHeading2.Alignment_Center_Middle;
	self.lblHeading2.top := 40;
	self.lblHeading2.height := 20;
	self.lblHeading2.fontSize := 12;
	self.lblHeading2.fontBold := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
