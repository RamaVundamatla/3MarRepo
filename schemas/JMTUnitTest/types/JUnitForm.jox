        <updating/>
        <source>lbxTests_click(listbox: ListBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
19 December 2011	cnwmh5	Initial creation

*/

vars

begin

	if listbox.text = "UT_UnitTest" or listbox.text = "UT_DSL" then
		if btnSaveCateg.caption = "Save Category" then
			btnSaveCateg.caption := "Delete Category";
		endif;
	else
		if btnSaveCateg.caption &lt;&gt; "Save Category" then
			btnSaveCateg.caption := "Save Category";
		endif;
	endif;

	self.recalcCurrentRunTotals();
	self.showTotals();
	///self.lblCurrentMethod.caption := null;
	
epilog

end;</source>
