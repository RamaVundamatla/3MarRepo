    <JadeMethod name="handleProduct" id="27d7f052-d0a8-4cbc-bfd9-30570dab7751">
        <source>handleProduct(	_productCode:String;
				_product:CM_Product;
				_viewModeCode: String;
				_code:String output;
				_color:Integer output;
				_object:Object output) protected;
// --------------------------------------------------------------------------------
// Created:		01 December 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iterObj		: Iterator;
	trimCode	: String;
	theCode		: String;
	codeKey		: String;
	theColor	: Integer;
	colorKey	: Integer;
	theObject	: Object;
	
begin
	trimCode	:=	_productCode.trimBlanks();

	if trimCode = null or (_viewModeCode &lt;&gt; null and _viewModeCode &lt;&gt; trimCode) then
		_code 	:=	null;
		_color	:=	NullColour;
		return;
	endif;

	iterObj	:=	self.myIterUsedProduct;
	self.allUsedProducts.startKeyGeq(trimCode, iterObj);
	self.allUsedProducts.getIteratorKeys(codeKey, iterObj);
	
	theCode		:=	null;
	theColor	:=	NullColour;
	
	if codeKey = trimCode then
		// found the right one
		theCode		:=	trimCode;
		theColor	:=	_product.colour;
		iterObj.next(theObject);
	else
		if _product &lt;&gt; null then
			self.allUsedProducts.add(_product);
			self.beginNotification(_product, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			theCode		:=	trimCode;
			theColor	:=	_product.colour;
			theObject	:=	_product;
		endif;
	endif;

	_code	:=	theCode;
	_color	:=	theColor;
	_object	:=	theObject;
end;</source>
        <access>protected</access>
        <Parameter name="_productCode" type="String"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_viewModeCode" type="String"/>
        <Parameter name="_code" type="String" usage="output"/>
        <Parameter name="_color" type="Integer" usage="output"/>
        <Parameter name="_object" type="Object" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleProduct2" id="daf94648-6eb5-4b6a-af48-823fb577e155">
        <source>handleProduct2(_code:String; _product:CM_Product; _viewModeCode:String; _codesStr, _colourStr, _objStr : String io);
// --------------------------------------------------------------------------------
// Created:		01 December 2005 by cnwdad1
