    <JadeMethod name="doMnuTaskAmendICLocation" id="8ec49138-e078-49b9-907a-8ad8a8c973d2">
        <source>doMnuTaskAmendICLocation() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2011	cnwer1	Initial creation

*/

vars
	selectLocationForm		: CMUI_LocationSelector;
	twinTaskId	: String;
	lTask,
	twinTask,
	task				: CM_RTQueueTask;
	location,
	twinLocation,
	newTwinLocation,
	newLocation	: CM_LocationsController;
	machine 	: CM_Machine;
	twinTI		: CM_TrackedItem;
	allFilterTAs : CM_TerminalAreaSet;
	wle 		: CM_WorkListEntry;
	sourceICArea ,
	targetICArea : CM_TerminalArea;
begin

	if not checkCurrentObjects() then
		return;
	endif;
	
	create allFilterTAs transient;
	wle := self.myCurrentEntry.myWorkListEntry;
	
	if self.myCurrentTask.taskType &lt;&gt; TASK_MOVE  and  self.myCurrentTask.taskType &lt;&gt; TASK_DIRECTOR then
		if self.myCurrentTask.taskType = TASK_PICKUP then
			lTask:=self.myCurrentTask.myEntry.findTaskOfType(TASK_SETDOWN,NULL_INTEGER);
		elseif self.myCurrentTask.taskType = TASK_SETDOWN then
			lTask:=self.myCurrentTask;
		endif;
		
		if lTask.myEntry.myNextRelatedEntry &lt;&gt; null then
			if  lTask.targetLocation.isKindOf(CM_GantryICAreaLaneController) then
				return;
			endif;
			if lTask.machineTypeGroup = MACHINETYPEGRP_SOURCEIC  then
				if wle.getOriginalTaskSourceLoc &lt;&gt; null then
					sourceICArea :=wle.getOriginalTaskSourceLoc.myTerminalArea;
				endif;
				if sourceICArea &lt;&gt; null  then
					sourceICArea.allAssociatedInterchangeAreas.copyNoDupsNoTransaction(allFilterTAs);
				endif;
			elseif lTask.machineTypeGroup = MACHINETYPEGRP_TARGETIC then
				// going to ic area then  if amending this task should only let them change to a new ic area / ic grid location
				if wle.getFinalTaskTargetLoc  &lt;&gt; null  then
					targetICArea :=wle.getFinalTaskTargetLoc.myTerminalArea;
				endif;
				if targetICArea &lt;&gt; null  then
					targetICArea.allAssociatedInterchangeAreas.copyNoDupsNoTransaction(allFilterTAs);
				endif;
			endif;
		endif;
	endif;
	
	if targetICArea = null and sourceICArea = null then
		return;
	endif;
	

	location := 	lTask.ultimateTargetLocation; // cnwgb1 28 May 2008 PAR 16709
	
	
	machine:= lTask.machine;
	if machine &lt;&gt; null and lTask.taskType = TASK_SETDOWN and not machine.isMultiLift then // epr CCMS 1391 warehouse vmt 20/8/14
		foreach task in machine.allCurrentQueueTasks do
			if task &lt;&gt; lTask then
				twinTask:=task;
				break;
			endif;
		endforeach;
	endif;
	
	if twinTask &lt;&gt; null then
		twinLocation:=twinTask.ultimateTargetLocation;
		twinTaskId:=twinTask.getTaskId;
		twinTI:=twinTask.ti;
	endif;
		

	create selectLocationForm;
	selectLocationForm.centreWindow;
	selectLocationForm.myTerminal:=self.myTerminal;
	selectLocationForm.initForm(location,twinLocation,lTask.getTaskId,twinTaskId ,lTask.ti,twinTI,true,
								(lTask.taskType = TASK_DIRECTOR),allFilterTAs,null);		// 23099 extra director status param

	selectLocationForm.showModal;
	
	if selectLocationForm.modalResult &lt;&gt; IDCANCEL then
		newLocation:=selectLocationForm.txtLoc.userObject.CM_LocationsController;
		newTwinLocation:=selectLocationForm.txtTwinLoc.userObject.CM_LocationsController;
		if location = newLocation then
			return;
		endif;
		
		//epr par 27083 18/2/2011
		if not checkCurrentObjects() then
			return;
		endif;
		
		while true do
			app.myTrxUA.trxUpdateRTTaskICLocation(newLocation, lTask,newTwinLocation,twinTask,app.myPassport);
			if self.doTransactionLoopCompleted(app.getErrorString(Change_target_location)) then
				break;
			endif;
		endwhile; 
	endif;
epilog
	delete selectLocationForm;
	delete allFilterTAs;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuTaskAmendSourceLocation" id="a0f0e432-aa3e-4db8-92a5-91b76700c941">
        <source>doMnuTaskAmendSourceLocation() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 January 2011	cnwer1	Initial creation

*/

vars
	lTask : CM_RTQueueTask;
	location,newLocation : CM_LocationsController;
	selectLocationForm		: CMUI_LocationSelector;
	allTasks : ObjectArray;
	iter 	: Iterator;
	obj 	: Object;
	ti 		: CM_TrackedItem;
	taskId  : String;
	invalidTask : Boolean;
begin
	if not checkCurrentObjects() then
		return;
	endif;
	lTask:= self.myCurrentTask;
	
	if 	lTask.taskType = TASK_DIRECTOR  then
		location := 	lTask.sourceLocation;
	else
		return; 
	endif;
	
	create allTasks transient;
	self.tblQEntries.allSelectedObjects.copy(allTasks);
	
	if allTasks.size = 1 then
		taskId :=lTask.getTaskId;
		ti :=lTask.ti;
	endif;
	
	create selectLocationForm;
	selectLocationForm.centreWindow;
	selectLocationForm.myTerminal:=self.myTerminal;
	selectLocationForm.initForm(location,null,taskId,null ,ti,null,false,
								true,null,null);		// 23099 extra director status param
	if allTasks.size &gt; 1 then
		selectLocationForm.caption:="Bulk Amend Source";
	endif;
	selectLocationForm.showModal;
	
	if selectLocationForm.modalResult = IDCANCEL then
		return;
	endif;
	

	newLocation:=selectLocationForm.txtLoc.userObject.CM_LocationsController;
	
	//01 Mar 2011	NDL	Par 27112
	if newLocation = null then
		app.msgBox(app.getErrorString(No_Source_location_found), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//epr 36202 28/5/15 
	on Exception do app.handleDeletedObject(exception,lTask,invalidTask);
	iter:=allTasks.createIterator;
	while iter.next(obj) do
		lTask:=obj.CM_RTQueueTask;
		if 	lTask.taskType &lt;&gt; TASK_DIRECTOR then
			continue;
		endif;
		if lTask.sourceLocation = newLocation then
			continue;
		endif;

		while true do
			app.myTrxUA.trxUpdateRTTaskDirectoLocation(newLocation, lTask, true, app.myPassport);
			if self.doTransactionLoopCompleted(app.getErrorString(Change_director_location)) then
				break;
			endif;
		endwhile; 
	endwhile;	
	
epilog
	delete selectLocationForm;
	delete allTasks;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuTaskAmendTargetLocation" id="6d21f4f9-1f2e-4e79-a4ae-7ee78ebd32e6">
        <source>doMnuTaskAmendTargetLocation() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Feb 2009	cnwer1	Initial creation
31 Jan 2011 cnwer1	 PAR 26495 
*/

vars

	selectLocationForm		: CMUI_LocationSelector;
	taskId,
	twinTaskId				: String;
	lTask,
	twinTask,
	task					: CM_RTQueueTask;
	location,
	twinLocation,
	newTwinLocation,
	newLocation				: CM_LocationsController;
	machine 				: CM_Machine;
	ti,
	twinTI					: CM_TrackedItem;
	wle,twinWLE 			: CM_WorkListEntry;
	newMoveMethodRule 		: CM_RTMoveMethodRule;
	isDirector 				: Boolean;
	allTasks 				: ObjectArray;
	iter 					: Iterator;
	obj 					: Object;
	invalidTask 			: Boolean;
	rtQueueEntry 			: CM_RTQueueEntry;
begin

	
	
	//epr par 32440 12/3/15 added ability to bulk amend target location
	create allTasks transient;
	self.tblQEntries.allSelectedObjects.copy(allTasks);
	
	if allTasks.size() = 1 then
		if not checkCurrentObjects() then
			return;
		endif;
		lTask:= self.myCurrentTask;
		rtQueueEntry:=self.myCurrentEntry;
		//epr par  26495 - alwasy amending the final target location
		wle := rtQueueEntry.myWorkListEntry;
		location:=wle.getFinalTaskTargetLoc;
		
		machine:= self.myCurrentTask.machine;
		if machine &lt;&gt; null and not machine.isMultiLift then // epr CCMS 1391 warehouse vmt 20/8/14
			foreach task in machine.allCurrentQueueTasks do
				if task &lt;&gt; lTask then
					twinTask:=task;
					break;
				endif;
			endforeach;
		endif;
		
		if twinTask &lt;&gt; null then		
			//epr par 26495 - likewise always the twins final location
			twinWLE:=twinTask.myEntry.myWorkListEntry;
			twinLocation:=twinWLE.getFinalTaskTargetLoc;
			twinTaskId:=twinTask.getTaskId;
			twinTI:=twinTask.ti;
		endif;
		taskId:=lTask.getTaskId;
		isDirector:=lTask.taskType = TASK_DIRECTOR;
		ti:=lTask.ti;
	endif;	
	
	create selectLocationForm;
	selectLocationForm.centreWindow;
	selectLocationForm.myTerminal:=self.myTerminal;
	selectLocationForm.initForm(location,twinLocation,taskId,twinTaskId ,ti,twinTI,true,
								isDirector,null,rtQueueEntry);		// 23099 extra director status param

	selectLocationForm.showModal;
	if selectLocationForm.modalResult = IDCANCEL then
		return;
	endif;
	

	newLocation:=selectLocationForm.txtLoc.userObject.CM_LocationsController;
	if allTasks.size() = 1 then
		newTwinLocation:=selectLocationForm.txtTwinLoc.userObject.CM_LocationsController;
		newMoveMethodRule:=selectLocationForm.getMoveMethodRule();
	endif;
	
	//01 Mar 2011	NDL	Par 27112
	if newLocation = null then
		app.msgBox(app.getErrorString(No_Target_location_found), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception,lTask,invalidTask);
	iter:=allTasks.createIterator;
	while iter.next(obj) do
		lTask:=obj.CM_RTQueueTask;
		wle := lTask.myEntry.myWorkListEntry;
		if invalidTask then
			invalidTask:=false;
			continue;
		endif;
		location:=wle.getFinalTaskTargetLoc;
	
		if location = newLocation then
			continue;
		endif;		
	/*
	
	// Voyage WLE return to yard code
	
	If we are a voyage job heading to a slot/cta and the user selects to amend target location to a yard location we are sending the cargo back to the yard
	
	we should:
	Warn the user we are going to take a ship job container and put it back in th yard, and we are going to unplan it also.
	
	Move the current RTentry onto a new YARD job queued as it would be to whatever yard location from its current location (machine, ICA, CTA etc).
	Tidy up/remove any queue entry against the voyage WLE
	Unplan the container from the ship 
	
	if it is a ship release (i.e. was a director task) then we return it to a director task/unasign the actual cargo item
	
	*/
		//cnwrd1 par 29286 
		if lTask.ti &lt;&gt; null and  (location &lt;&gt; null and ( location.isVoyageController or location.isCraneLaneController)) 
			or ( location = null and lTask.myEntry.status = ENTRY_COMPLETE and lTask.myEntry.myJob.isVoyageTypeJob() and lTask.myEntry.myJob.jobType = JOB_TYPE_LOAD )then // TFS 4859
			//we were going to a ship
			if app.msgBox(app.getErrorString1(This_voyag_load_task_cargo_cha,lTask.ti.id ),null, MsgBox_OK_Cancel) = MsgBox_Return_OK then
				while true do
					app.myTrxUA.trxUpdateVoyageRTReturnToYard(newLocation, lTask,newTwinLocation,twinTask,newMoveMethodRule,app.myPassport);
					if self.doTransactionLoopCompleted(app.getErrorString(Change_target_location)) then
						break;
					endif;
				endwhile; 							
			endif;
		else
			while true do
				app.myTrxUA.trxUpdateRTTaskTargetLocation(newLocation, lTask,newTwinLocation,twinTask,newMoveMethodRule,app.myPassport);
				if self.doTransactionLoopCompleted(app.getErrorString(Change_target_location)) then
					break;
				endif;
			endwhile; 
		endif;
	endwhile;
epilog
	delete allTasks;
	delete selectLocationForm;
	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuTaskDeleteEntry" id="4cff562a-86c3-43a5-8376-9eb7efa599ad">
        <updating/>
        <source>doMnuTaskDeleteEntry(_entry : CM_RTQueueEntry io) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/12/2014   cnwdb2 PAR  35364
// ---------------------------------------------------------------------------

vars
	lReturn 	: Integer;
	lResult 	: Boolean;
	objArray,	
	objArray2	: ObjectArray;
	theTask		: CM_RTQueueTask;
	obj			: Object;
begin
	
	self.clearErrorWarnings();
	
//	lReturn := app.msgBox(app.getErrorString2(CONF_DELETE,"Queued Entry(s)", null), "Confirm Unqueue",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	lReturn := app.msgBox(app.getErrorString(Sure_want_delete35364i), app.getErrorString(Confirm_unqueue),MsgBox_Yes_No + MsgBox_Question_Mark_Icon); //cnwdb2 PAR 35364
 
	if lReturn = MsgBox_Return_Yes then
		create objArray transient;
		create objArray2 transient;
		self.tblQEntries.allSelectedObjects.copy(objArray);
		foreach obj in objArray do
			theTask := obj.CM_RTQueueTask;
			if not global.isValidObject(theTask) then
				continue;
			endif;
			if not objArray2.includes(theTask.myEntry) then
				objArray2.add(theTask.myEntry);
			endif;
		endforeach;
		foreach obj in objArray2 do	
			self.deleteQueueEntry(obj.CM_RTQueueEntry);
		endforeach;
		
	endif;
epilog	
	delete objArray;
	delete objArray2;
end;</source>
        <Parameter name="_entry" type="CM_RTQueueEntry" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doMnuTaskEditRequest" id="e3bbb8d2-fe6d-4d34-9559-ac8fec40f326">
