<Class name="TST_TestRecorderAgent" id="7a5203ab-2cef-48c2-b6dc-0cc771c2c04d">
    <superclass name="CM_Agent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="testObjects"/>
    <JadeMethod name="getTestDetails" id="e7e084db-b5d1-40e7-a351-d0a7e6986534">
        <source>getTestDetails(_trxName : String; _baseClass : Class; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     17 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	recForm	: TST_RecorderEntryForm;
	savePointer	: Integer;
begin

	savePointer := app.mousePointer;

	create recForm transient;

	if recForm.init(_trxName, _baseClass, _passport) then
		app.mousePointer := Window.MousePointer_Default;
		recForm.showModal();
	endif;

epilog
	delete recForm;
	app.mousePointer := savePointer;

end;</source>
        <Parameter name="_trxName" type="String"/>
        <Parameter name="_baseClass" type="Class"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="recCreateInOut" id="31d37512-d784-4063-80db-d223b4ff5332">
        <source>recCreateInOut(pIntFaceCommon : CMIF_InOutCommon input; pIntFaceArray : CMIF_TIObjectArray; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     17 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tstObj	: TST_trxCreateInOut;
begin

	if _passport.testCode = null or
	   _passport.myTestClassToCreate = null then
		write class.name &amp; '::' &amp; method.name &amp; '  testCode or myTestClassToCreate is null so no test created';
		return;
	endif;

	create tstObj as _passport.myTestClassToCreate persistent;
	tstObj.init(pIntFaceCommon, pIntFaceArray, _passport);

end;</source>
        <Parameter name="pIntFaceCommon" type="CMIF_InOutCommon" usage="input"/>
        <Parameter name="pIntFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
