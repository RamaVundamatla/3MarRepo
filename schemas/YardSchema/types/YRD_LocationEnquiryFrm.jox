    <JadeMethod name="setFilterValues" id="1c392483-447c-4fad-a9ed-e9967a38d8fa">
        <updating/>
        <source>setFilterValues() updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 Sep 2009	cnwkpd1		PAR #20663 - Correct problem when opening Yard Area from Terminal Area
//							enquiry
// ---------------------------------------------------------------------------
vars

begin
	if not self.amInitialisingWithObject then
		inheritMethod();
	else
		self.filterIMEXStatus := NULL_INTEGER;			// PAR #20663
	endif;
	
	// Ensure we only ever search for on-site
	self.filterState := TI_STATE_NORMAL;
	self.btnMoveIt.enabled := true;

	self.allowMultiSelectDelete := false;	
	
	if self.filterTerminalArea &lt;&gt; null and self.filterTerminalArea.type = TA_TYPE_DELETE then
	//	self.filterState := TI_STATE_DELETED;
		self.allowMultiSelectDelete := true;
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnMoveIt.enabled:= false;
		self.allowMultiSelectDelete := false;	
	
		
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setFormHeading" id="072bc22c-586b-42fd-83ab-f49b5ebd3b33">
        <updating/>
        <source>setFormHeading() updating;
//--------------------------------------------------------------
//Created: 06 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	str : String;
begin
	
	str := self.getCaptionPrefix();
/*	PAR 7651 AKB2004FEB - they could not see their block stack IDs when minimised
	if self.filterYardLocation &lt;&gt; null then
		self.setCaption(str &amp; ' ' &amp; self.filterYardLocation.ident);
	elseif self.filterTerminalArea &lt;&gt; null then
		self.setCaption(str &amp; ' ' &amp; self.filterTerminalArea.id);
	elseif self.filterVoyage &lt;&gt; null then
		self.setCaption(str &amp; ' ' &amp; self.filterVoyage.description.trimBlanks);
	else
*/
	if self.filterYardLocation &lt;&gt; null then
		if CM_BoxcarWagonController.hasInstance( self.filterYardLocation ) then	//21 Mar 2013	NDL	Par 31278
			self.setCaption(self.filterYardLocation.CM_BoxcarWagonController.myWagon.id &amp; " " &amp; app.getErrorString(Cargo_Enquiry));
		elseif CM_IrregularBlockController.hasInstance( self.filterYardLocation ) then	// PAR 32308
			self.setCaption(self.filterYardLocation.getFullId() &amp; " " &amp; app.getErrorString(Cargo_Enquiry));
		else
			self.setCaption(self.filterYardLocation.ident &amp; " " &amp; str);
		endif;
	elseif self.filterTerminalArea &lt;&gt; null then
		self.setCaption(self.filterTerminalArea.id &amp; " " &amp; str);
	elseif self.filterVoyage &lt;&gt; null then
		self.setCaption(self.filterVoyage.description.trimBlanks &amp; " " &amp; str);
	else
		self.setCaption(str);		
	endif;

	
	if self.filterTerminalArea = null then
		self.txtHeader.text := self.staMain.caption;
		self.txtHeader.backColor:= White;
	else	
		self.txtHeader.text := self.staMain.caption &amp; '; ' &amp; self.filterTerminalArea.getTextHeader();
		//epr ccms 1440 17/7/06
		if self.filterTerminalArea.isKindOf(CM_BlockStack) and self.filterTerminalArea.CM_BlockStack.isOverlapped then
			//cnwmc5 - PAR 31051
			if not app.isUsingSkin then
				self.txtHeader.backColor:= Yellow;
			else
				self.txtHeader.backColor:= White;
			endif;
		// ccms 1573	14/August/2007
		elseif not self.filterTerminalArea.allRestrictionsLabour.isEmpty() then
			self.txtHeader.backColor:= LightRed; 
		else
			//cnwmc5 - PAR 31051
			if not app.isUsingSkin then
				self.txtHeader.backColor := self.colorControlBack;	//Par14787
			else
				self.txtHeader.backColor:= White;
			endif;
		endif;
		if self.filterYardLocation &lt;&gt; null and self.filterYardLocation.isKindOf(CM_IrregularBlockController) then
			if self.filterYardLocation.status = LC_Status_Closed then 
				self.txtHeader.text := self.txtHeader.text &amp; CrLf &amp; self.filterYardLocation.getStatusDescription();
				self.txtHeader.backColor:= LightRed; 
			endif;
		endif;
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyDataClassForCargoType" id="dda03f3b-3457-475e-8481-93d6063f522c">
        <updating/>
        <source>setMyDataClassForCargoType(_typeId: Integer) updating;
//-----------------------------------------
//Created: March 2003 By: cnwgd1
//-----------------------------------------
vars

	theType	: CM_CargoBOLType;

begin

//	theType := app.myRoot.getCargoBOLTypeForId(_typeId);

//	self.tblData.setTerminologyRelevant(theType, self.myTerminal);
//	Set null for cargo type terminology. currently Terminoogy is working this way NOT on default cargo type. 
	self.tblData.setTerminologyRelevant(null, self.myTerminal);
	
	if theType &lt;&gt; null then
		if theType.isKindOf(CM_CargoType) then
			self.myDataClass := currentSchema.getClass(theType.CM_CargoType.classNameToCreate);
		endif;
	endif;
	
	if self.myDataClass = null or self.cmbFiltTiType.listObject = null then
		self.myDataClass := CM_TrackedItem;
	endif;

end;</source>
        <Parameter name="_typeId" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setNotifications" id="1df96f5f-e83e-404c-9831-f0bddb80eb74">
        <source>setNotifications();
//--------------------------------------------------
// Created:	29 August 2007  cnwvu1
//--------------------------------------------------
vars

begin

	self.endNotificationForSubscriber(self.tblData);
	if self.filterTerminalArea &lt;&gt; null then
		self.tblData.beginNotification(self.filterTerminalArea, self.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA), Response_Continuous, null);
		self.tblData.beginNotification(self.filterTerminalArea, self.myTerminal.getTerminalEvent(EVENT_TI_MOVE_FROM_LOCATION), Response_Continuous, null);
		self.tblData.beginNotification(self.filterTerminalArea, self.myTerminal.getTerminalEvent(EVENT_TI_MOVE_TO_LOCATION), Response_Continuous, null);
	endif;

end;
</source>
    </JadeMethod>
