    <JadeMethod name="selectContainer" id="6d4b8606-fbd6-4861-9166-d80400516236">
        <updating/>
        <source>selectContainer(pContainer : GTE_ContainerFrame) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	if self.mySelectedContainer &lt;&gt; null then
		self.mySelectedContainer.deSelect();
	endif;

	self.mySelectedContainer := pContainer;
	self.mySelectedContainer.select();
	
	// set selected container to be dragged
	self.myDraggedContainer := pContainer;
	
end;</source>
        <Parameter name="pContainer" type="GTE_ContainerFrame"/>
    </JadeMethod>
    <JadeMethod name="setContainer" id="15a9bbbc-6b18-47b7-9b30-b61f4dd8f4bd">
        <updating/>
        <source>setContainer(pIdx : Integer; pId : String; pLength : Integer; pDoors : Boolean; pSheet : GTE_Sheet) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm	: GTE_ContainerFrame;
	found	: Boolean;
	max,
	idx		: Integer;

begin
	if pIdx = 0 then
		// find a free one
		max := self.allContainerFrames.size;
		foreach idx in 1 to max do
			contFrm := self.allContainerFrames[idx];
			if contFrm.mySheet = null then
				found := true;
				break;
			endif;
		endforeach;

		if found then
			if self.addToFront then
				if idx &lt;&gt; 1 then
					// move found one to first position
					self.allContainerFrames.remove(contFrm);
					self.allContainerFrames.insert(1, contFrm);
				endif;
			else
				if idx &lt;&gt; max then
					// move found one to end
					self.allContainerFrames.remove(contFrm);
					self.allContainerFrames.add(contFrm);		// this will add at the end
				endif;
			endif;
		else
			// create a new container frame
			contFrm := createContainerFrame();
			if self.addToFront then
				self.allContainerFrames.insert(1, contFrm);
			else
				self.allContainerFrames.add(contFrm);
			endif;
		endif;
	else
		contFrm := self.allContainerFrames[pIdx].GTE_ContainerFrame;
	endif;
	
	contFrm.setDetails(pId, pLength, pDoors, pSheet);

// Always select the new container (RJS - 23/4/01)
//	if self.mySelectedContainer = null then
	if self.mySelectedContainer &lt;&gt; null then
		self.mySelectedContainer.deSelect();
	endif;
		self.mySelectedContainer := contFrm;
		self.mySelectedContainer.select();
//	endif;
	
	if (not found) then
		// a container must have been added
		contFrm.top := self.myTruckCabPicture.top;
		self.setLengths();
	endif;
	self.displayContainers();

end;</source>
        <Parameter name="pIdx" type="Integer"/>
        <Parameter name="pId" type="String"/>
        <Parameter name="pLength" type="Integer"/>
        <Parameter name="pDoors" type="Boolean"/>
        <Parameter name="pSheet" type="GTE_Sheet"/>
    </JadeMethod>
    <JadeMethod name="setDoorsVisible" id="f14566f1-5336-401f-8007-b544d0a07120">
        <source>setDoorsVisible(pValue : Boolean);
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm	: GTE_ContainerFrame;
	
begin

	foreach contFrm in self.allContainerFrames do
		if pValue then
			contFrm.showDoorsDirBtn();
		else
			contFrm.hideDoorsDirBtn();
		endif;
	endforeach;
	
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLengths" id="9f2a4967-acee-4029-9d19-b9ea98030804">
        <updating/>
        <source>setLengths() updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	numSlots,
	stdLength	: Integer;

begin

	// numSlots is visible * factor
	numSlots := self.numVisibleContainers;

	if numSlots &lt; StdNumContainers then
		numSlots := StdNumContainers;
	endif;

	// calculate the lenth of the currently displayed truckbed
	stdLength := (self.myTruckBedLeftPic.width + self.myTruckBedMiddlePic.width + self.myTruckBedRightPic.width).Integer;

	// Divide by number of containers to display
	stdLength := (stdLength / numSlots).Integer;

/*	
	if numSlots &gt; StdNumContainers then
		// as more than 4 containers set lengths to be minimum
		self.length10 := stdLength;
		self.length20 := stdLength;
		self.length40 := stdLength;
	else
*/
		self.length10 := stdLength;
		self.length20 := stdLength * 2;
		self.length40 := stdLength * 4;
//	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
