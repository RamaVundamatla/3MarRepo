    <JadeMethod name="doMnuSendToReportInvoice" id="58192e83-fd54-4f32-a8d0-c959d6d728bd">
        <updating/>
        <source>doMnuSendToReportInvoice(_selectedOnly : Boolean) updating;
//----------------------------------------------------------------------
// Created by 	cnwjre1
// Date 		Sept 2010 CCMS 1155 par 23583 Invoice rate reporting
vars
	objArray : ObjectArray;
begin
	inheritMethod(_selectedOnly);
	
	// Report writer throws exceptions when in transaction state.
	// Added flag to app to ignore any transaction calls that are not in 
	// the trx layer (Eg, CM_Charge.evaluateRate).
	app.isReportWriter := true;
	
	create objArray transient;
	
	self.getRatesForReport(objArray, _selectedOnly);
	
	self.doSendToReport(objArray);
epilog
	if objArray &lt;&gt; null then
		objArray.purge;		// contains transients created for reporting
	endif;
	delete objArray;
	app.isReportWriter := false;
end;</source>
        <Parameter name="_selectedOnly" type="Boolean"/>
    </JadeMethod>
