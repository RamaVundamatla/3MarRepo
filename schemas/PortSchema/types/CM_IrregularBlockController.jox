    <JadeMethod name="numTIs" id="b4182c87-a58b-4be9-9eed-942d911a43f5">
        <methodInvocation>mapping</methodInvocation>
        <source>numTIs(set: Boolean; _value: Integer io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2013	cnwndl1	Initial creation

*/

vars

	tot : Integer;
	lc : CM_YardController;

begin

	inheritMethod(set, _value);
	
	if not set and self.isRack then
		foreach lc in self.allSubLocations do
			tot := tot + lc.numTIs;
		endforeach;
		_value := tot;
	endif;

epilog

