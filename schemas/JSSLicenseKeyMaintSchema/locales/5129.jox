    <TranslatableString name="PRODUCT_CODE_BLANK" id="c3edf130-b1b4-458d-aa20-9bf000734e9b">
        <source>PRODUCT_CODE_BLANK = "The Product Code cannot be blank"</source>
    </TranslatableString>
    <TranslatableString name="PRODUCT_COMPONENT_EXISTS" id="88f53087-f7f1-4014-901b-2e074edc90eb">
        <source>PRODUCT_COMPONENT_EXISTS(pID) = "A Product Component already exists with the requested ID: " &amp; pID</source>
