    <JadeMethod name="getCaseDescr" id="ff644bf9-9720-4bc2-8f8d-c824b00629aa">
        <source>getCaseDescr(_value : Integer) : String protected;
// ---------------------------------------------------------------------------
// Created:     05 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _value = TextBox.Case_Lower then
		return TextBox.Case_Lower.String &amp; ' - All Lower';
	elseif _value = TextBox.Case_Upper then
		return TextBox.Case_Upper.String &amp; ' - All Upper';
	elseif _value = TextBox.Case_UpperFirst then
		return TextBox.Case_UpperFirst.String &amp; ' - First Upper';
	elseif _value = TextBox.Case_LowerFirst then
		return TextBox.Case_LowerFirst.String &amp; ' - First Lower';
	else
		return TextBox.Case_None.String &amp; ' - None';
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="1aeb0b91-fc6e-4e24-9a26-cb0a7ee2e873">
        <updating/>
        <source>init(pAttrName : String; pInputType : Integer; pEntTableCellControl : EntTableCellControl; pEntTableRow : EntTableRow io) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.attributeName	:= pAttrName;
	self.inputType		:= pInputType;
	self.myEntTableCellControl := pEntTableCellControl;
	self.myEntTableRow	   := pEntTableRow;

	self.myEntTableRow.getInputTypeDetails(self.inputTypeDescr, self.myInputTypeClass);
	
	if self.myInputTypeClass = null then
		app.msgBox('Unhandled input type (' &amp; self.inputTypeDescr &amp; ')', 'Error', MsgBox_OK_Only);
		return false;
	endif;

	return true;
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pInputType" type="Integer"/>
        <Parameter name="pEntTableCellControl" type="EntTableCellControl"/>
        <Parameter name="pEntTableRow" type="EntTableRow" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initPropertiesTable" id="59839a10-cbbc-406f-8c10-b24d0272944c">
        <updating/>
        <source>initPropertiesTable() updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	tblProperties.clearAttributes();

	if self.inputType = Table.InputType_CheckBox then
	elseif self.inputType = Table.InputType_TextBox then
		self.initTextBoxProperties();
	elseif self.inputType = Table.InputType_ComboBox then
	elseif self.inputType = Table.InputType_TextNumeric then
		self.initTextNumericProperties();
	elseif self.inputType = Table.InputType_SignedNumeric then
		self.initSignedNumericProperties();
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initSignedNumericProperties" id="25ada421-76b0-40c2-95bf-e315e413aa7d">
        <updating/>
        <source>initSignedNumericProperties() updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tbl		: CM_EntryTable;
	tmpRow	: Integer;
	
begin
	tbl := tblProperties;
	
	tmpRow := tbl.addAttribute('decimals', 'decimals', Table.InputType_TextNumeric, 0, true);
	tmpRow := tbl.addAttribute('maxLength', 'maxLength', Table.InputType_TextNumeric, 0, true);	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTextBoxProperties" id="7d2a3332-6dff-448d-ba27-7a0315cd97c7">
        <updating/>
        <source>initTextBoxProperties() updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tbl		: CM_EntryTable;
	tmpRow	: Integer;
	
begin

	tbl := tblProperties;
	
	tmpRow := tbl.addAttribute('case', 'Case', Table.InputType_ComboBox, 0, true);
	tbl.setComboValues(tmpRow, getCaseDescr(TextBox.Case_None) &amp; Tab &amp;
							   getCaseDescr(TextBox.Case_Lower) &amp; Tab &amp;
							   getCaseDescr(TextBox.Case_Upper) &amp; Tab &amp;
							   getCaseDescr(TextBox.Case_UpperFirst) &amp; Tab &amp;
							   getCaseDescr(TextBox.Case_LowerFirst));

	tmpRow := tbl.addAttribute('maxLength', 'Max Length', Table.InputType_TextNumeric, 0, true);	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTextNumericProperties" id="5b387b95-8558-4c1c-9c78-69973b91062a">
        <updating/>
        <source>initTextNumericProperties() updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tbl		: CM_EntryTable;
	tmpRow	: Integer;
	
begin

	tbl := tblProperties;
	
	tmpRow := tbl.addAttribute('decimals', 'decimals', Table.InputType_TextNumeric, 0, true);
	tmpRow := tbl.addAttribute('maxLength', 'maxLength', Table.InputType_TextNumeric, 0, true);	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="53595a35-78de-4f5c-b8a7-2f5326c0aaa8">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str	: String;
	
begin
	self.frmToolbarBtns.left := 7000;
	self.handleMenusForModalDisplay();
	
	self.modalResult := MsgBox_Return_Cancel;
	
	if self.viewOnly then
		btnOK.visible := false;
		tblProperties.userInputEnabled := false;
	endif;
	if self.myTerminal &lt;&gt; null then
		self.caption := self.myTerminal.code &amp; " " &amp; self.attributeName &amp; ' properties';
	endif;
	self.setInputTypeCaption();	
	self.initPropertiesTable();
	self.setDefaults();

end;</source>
    </JadeMethod>
    <JadeMethod name="saveData" id="33d3861c-3129-4e48-8466-05423c600171">
        <updating/>
        <source>saveData() updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpRow,
	tmpCase	: Integer;
	
begin

	if self.myEntTableCellControl &lt;&gt; null then
		delete self.myEntTableCellControl;
	endif;
	
	create self.myEntTableCellControl as self.myInputTypeClass transient;
	tblProperties.setObjectFromTable(self.myEntTableCellControl, null, false);
	
	tmpRow := tblProperties.getRow('case');
	if tmpRow &gt; 0 then
		// definition has a "case" row
		tmpCase := tblProperties.getValue(tmpRow).Integer;
		self.myEntTableCellControl.setPropertyValue('case', tmpCase);
	endif;
	
	self.myEntTableCellControl.myEntTableRow := self.myEntTableRow;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaults" id="65dd6383-bd8e-4fb2-9ec6-e04528046ae9">
        <source>setDefaults() protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tbl	: CM_EntryTable;
	
begin

	if self.myEntTableCellControl = null then
		return;
	endif;

	tbl := tblProperties;
	
	if self.myEntTableCellControl.isKindOf(EntTableTextBox) then
		tbl.setValueByName('case', getCaseDescr(self.myEntTableCellControl.EntTableTextBox.case));
		tbl.setValueByName('maxLength', self.myEntTableCellControl.EntTableTextBox.maxLength);

	elseif self.myEntTableCellControl.isKindOf(EntTableTextNumeric) then
		tbl.setValueByName('decimals', self.myEntTableCellControl.EntTableTextNumeric.decimals);
		tbl.setValueByName('maxLength', self.myEntTableCellControl.EntTableTextNumeric.maxLength);

	elseif self.myEntTableCellControl.isKindOf(EntTableSignedNumeric) then
		tbl.setValueByName('decimals', self.myEntTableCellControl.EntTableSignedNumeric.decimals);
		tbl.setValueByName('maxLength', self.myEntTableCellControl.EntTableSignedNumeric.maxLength);
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setInputTypeCaption" id="d6e6dfc1-fe2f-41fd-95eb-9f9a3385d787">
        <updating/>
        <source>setInputTypeCaption() updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str	: String;
	
begin

	if self.inputType = Table.InputType_None then
		str := 'None';
	elseif self.inputType = Table.InputType_CheckBox then
		str := 'CheckBox';
	elseif self.inputType = Table.InputType_TextBox then
		str := 'TextBox';
	elseif self.inputType = Table.InputType_ComboBox then
		str := 'ComboBox';
	elseif self.inputType = Table.InputType_TextNumeric then
		str := 'TextNumeric';
	elseif self.inputType = Table.InputType_SignedNumeric then
		str := 'SignedNumeric';
	else
		str := 'Unknown';
	endif;
	
	lblInputType.caption := 'InputType ' &amp; str;

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
