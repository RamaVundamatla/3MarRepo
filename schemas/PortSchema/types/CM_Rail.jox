        <source>isInUse(): Boolean;
//--------------------------------------------------
// Created:	05 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	railLine : CM_RailLine;
	object : Object;
begin
	foreach railLine in self.allRailLines do
		if (not railLine.allWagonsById.isEmpty) then
