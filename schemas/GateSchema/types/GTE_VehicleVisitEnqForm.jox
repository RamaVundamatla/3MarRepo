    <JadeMethod name="updateTableColumnFilters" id="818b2d26-8918-4b81-8274-aae1b440f111">
        <updating/>
        <source>updateTableColumnFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2013	cnwndl1	Initial creation	Par 32587

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;

	self.allColumnFilters.replaceAllFiltersForTable( _table, _allFilterColumns );


epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict"/>
    </JadeMethod>
    <JadeMethod name="zDoEdit" id="a2fb8e3b-5878-41fd-acc2-fe042a8a6158">
        <updating/>
        <source>zDoEdit() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	vvr : CM_VehicleVisitRecord;
	form : GTE_VehicleVisitMaintForm;
	msg : String;

begin

	if not self.tblData.allSelectedObjects.isEmpty then
		vvr := self.tblData.allSelectedObjects.first.CM_VehicleVisitRecord;
	endif;
	
	if vvr = null then
		app.msgBox( app.getErrorString(CMUI_Nothing_Selected), app.getErrorString(Error), MsgBox_Stop_Icon  + MsgBox_OK_Only);
		return;
	endif;
	
	if not self.myTerminal.roadProcessIsASPA then
		msg := app.getErrorString2( Road_opera_form_not_suppo_term, self.myTerminal.getMyRoadProcess.code, self.caption );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_Stop_Icon  + MsgBox_OK_Only);
		return;
	endif;

	form := app.loadForm( GTE_VehicleVisitMaintForm, CMUI_Assistant, false, false, true, self.myTerminal, null).GTE_VehicleVisitMaintForm;
	
	app.mousePointer := MousePointer_Default;

	if form &lt;&gt; null then
		form.setVehicleVisitRecord( vvr );
		form.setParentForm( self );
		form.centreOverParent( 30 );
		form.show();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
