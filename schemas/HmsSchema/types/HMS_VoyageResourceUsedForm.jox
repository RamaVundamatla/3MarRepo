begin
	create hmsResourceUsedProforma transient;
	
	hmsResourceUsedProforma.dummyUpLaunch(_move);
	
	self.dummyUpAddToList(hmsResourceUsedProforma, _move);
	
/*
	if _move.myPilotLaunch = null then
		return;
	endif;
	
	theVoyage := _move.myHMSVoyageData.myVoyage;
	aHarbour := _move.myHarbour;

