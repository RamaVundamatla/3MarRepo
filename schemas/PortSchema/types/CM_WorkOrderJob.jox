    <JadeMethod name="addTI" id="c8b0b571-6fcc-4fc6-92c6-8f169544f7a6">
        <updating/>
        <source>addTI(_ti: CM_TrackedItem input; _request: CM_Request) updating;
/*
Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
*/
vars

begin
	exclusiveLock(self);

	if (_ti = null or _request = null) then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_TI_LINK_PARAM, null, null);
		return;	
	endif;

	sharedLock(_request);
	exclusiveLock(_ti);

	self.updateTICollections(_ti, _request);	

	self.updateObjectEdition(self);	
	
	app.myEventManager.createSingleObjInfoNoteEvt(self, app.myPassport.myTerminal.getTerminalEvent(YardJob_Update_Event), self);

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_request" type="CM_Request"/>
    </JadeMethod>
    <JadeMethod name="addToJobSheet" id="fb97acde-9858-428c-9aaf-b10639675608">
        <updating/>
        <source>addToJobSheet()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 Jul 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
27 Sep 2023	navma1  ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
*/

vars

	woJobSheet		: CM_WorkOrderJobSheet;
	wod				: CM_WorkOrderDtl;
	term		    : CM_Terminal;
begin
	
	term := self.myTerminal;
	
	//jobSheet.addJob(self, 0);							//27.09.2023 navma1 #59638
	
	/*
	//02.06.2023 navma1 #58296
	Link to Work Order Job Sheet;
	*/
	woJobSheet := term.myWOJobSheet;
	if woJobSheet = null then	
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Work order Job Sheet. Contact Developer.');
	endif;
	
	self.setMyWorkOrderJobSheet(woJobSheet);
	
	wod := self.myWODtl;
	if wod &lt;&gt; null then
		woJobSheet.allWorkOrderDetails.addNoDuplicates(wod,false);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="canCompleteToDoJob" id="8ece762b-732b-4eba-8749-89a6256b6cdc">
        <source>canCompleteToDoJob(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Mar 2024	navma1	Bug 62770: EUP - 1090 exception when clicking on the Instructions button on the Complete To Do Tasks form
*/

vars
	wodtl : CM_WorkOrderDtl;
begin
	
	wodtl := self.myWODtl;
	
	if wodtl &lt;&gt; null and wodtl.isWorkOrderTIDtl then
		
		return wodtl.CM_WorkOrderTIDtl.allSelectedTIs.isNotEmpty;
		
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeStatus" id="3f590617-0e4c-498a-8952-7fd5a9f48dbb">
        <updating/>
        <source>changeStatus(_newStatus: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/07/2022  navcs2 ChangeRequest 53932: MTN - Jobs Changes
*/

vars
	oldStatus : Integer;
begin

	exclusiveLock(self);

	oldStatus := self.status;

	if oldStatus = _newStatus then //No change
	  	return;
	endif;


	self.status := _newStatus;
	
	if self.status = JOB_COMPLETE then		
		self.causeTerminalEvent(self.Event_Mode_Update);
	endif;									
end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="153fa337-bea2-4e71-83c0-663fad5f67eb">
        <updating/>
        <source>createWLEs() updating;
/*
Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
*/

vars
	tmpRequest 	: CM_Request;
begin

	exclusiveLock(self);

	foreach tmpRequest in self.allRequests do
		sharedLock(tmpRequest);
		tmpRequest.createWLEs();
	endforeach;
	
	self.updateStatus();	
	self.updateObjectEdition(self);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="1243a708-a0a8-4abd-b495-71b9e442ecc7">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
*/

vars
	wle				: CM_WorkListEntry;
	req 			: CM_Request;
	invalid 		: Boolean;
	
begin
	if self.status = JOB_UNACTIONED or self.status = JOB_COMPLETE  or self.allEntries.size = 0 then
		//Carry on.
	else
		//-----------------
		//Attempt a status update, to ensure we are REALLY not up to date
		//-----------------
		self.updateStatus();
	endif;
	exclusiveLock(self);
	
	foreach req in self.allRequests do
		req.processDeleteForWO();
	endforeach;
	
	//-----------------
	//Nuke the WLE's
	//-----------------
	
	on Exception do app.handleDeletedObject(exception, wle, invalid);
	
	while workListEntries.size &gt; 0 do : outerLoop
		wle := workListEntries.first;
		exclusiveLock(wle);
		//---------------
		//Tell WLE to deref from the TI
		//---------------
		wle.eraseFromTI();
		//workListEntries.remove(wle);
		//---------------
		//Tell WLE to deref from the Queue
		//---------------
		while wle.allRTQueueEntries.isEmpty = false do
			wle.allRTQueueEntries.last.deleteEntry( false, null);			
			if app.myPassport &lt;&gt; null then 
				if app.myPassport.hasErrors then 
					break outerLoop; 
				endif;
			endif;
		endwhile;
		
//		if global.isValidObject(wle) then
		invalid := false;
		wle.causeEvent(self.getMyTerminal.getTerminalEvent(WLE_Delete_Event), false, wle);
		if not invalid then
			delete wle;
		endif;
	endwhile;
	
	on Exception do null;
	
	if app.myPassport &lt;&gt; null then 
		if app.myPassport.hasErrors then 
			return;
		endif;
	endif;

	req := self.allRequests.first;
	if req &lt;&gt; null then
		delete req;
	endif;

	self.allTrackedItems.clear;
	//------------
	//Remove ourselves from SwapJobSheet on terminal
	//------------
	inheritMethod(_eraseLevel);
	
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEs" id="554bc0d1-24ed-4d31-a6d5-a8b9308a7f21">
        <source>getAllWLEs(_wleArray: CM_WLEArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
10 July 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
06 Mar 2025 	navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars

	wle :  CM_WorkListEntry;
begin

	if self.workListEntries.isEmpty then
		return;
	endif;

	foreach wle in self.workListEntries discreteLock do	//06.03.2025 navma1 #MTN-34179
		_wleArray.add(wle);			
	endforeach;


epilog

end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCargoSubType" id="675524e8-928d-40cf-9079-3fa458965126">
        <source>getCargoSubType(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Nov 2023 navhl20 ChangeRequest 61514: EUP | Ship Operations in DD - [54176.040] - [Release] Allocation List
18 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
10 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
20 May 2024 navhl20 Bug 64191: EUP - Lock and Freeze issue
*/

vars
	ti				: CM_TrackedItem;
	invalidObject	: Boolean;
	objset			: CM_ObjectSet;
	isShipGrp		: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidObject);
	
	create objset transient;
	if self.allTrackedItems.isNotEmpty() then						//18.12.2023 navhl20 #58400[61617]
		isShipGrp := self.isInGrpCriteria(WOJG_CargoSubTypeInt);	//20.05.2024 navhl20 #64191
		
		if isShipGrp then
			ti := self.allTrackedItems.first;
			return ti.getCargoSubTypeDescr();
		else
			foreach ti in self.allTrackedItems do
				
				invalidObject := false;
				ti.edition;
				
				if invalidObject then
					continue;
				endif;
				objset.tryAddIfNotNull(ti.myProduct);
			endforeach;
		
			if objset.isNotEmpty then
				return objset.listString(Comma,CM_Product::description.name);
			endif;
		endif;
	else
		return inheritMethod();
	endif;
epilog
	delete objset;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCommodity" id="6be8b5b0-9f8c-4c3a-82a2-d024aef441b9">
        <source>getCommodity(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Nov 2023 navhl20 ChangeRequest 61514: EUP | Ship Operations in DD - [54176.040] - [Release] Allocation List
10 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
20 May 2024 navhl20 Bug 64191: EUP - Lock and Freeze issue
*/

vars
	ti				: CM_TrackedItem;
	invalidObject	: Boolean;
	objset			: ObjectSet;
	isShipGrp		: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidObject);
	
	create objset transient;
	if self.allTrackedItems.isNotEmpty() then
		isShipGrp := self.isInGrpCriteria(WOJG_CommodityInt);
		
		if isShipGrp then
			ti := self.allTrackedItems.first;
			return ti.commodity;
		else
			foreach ti in self.allTrackedItems  do
				invalidObject := false;
				ti.edition;
				
				if invalidObject then
					continue;
				endif;
				
				objset.tryAddIfNotNull(ti.getCommodityObject);
			endforeach;
			
			if objset.isNotEmpty then
				return objset.listString(Comma,CM_Commodity::code.name);
			endif;
		endif;
	else
		return inheritMethod();
	endif;
epilog
	delete objset;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDischargePort" id="88ad4457-4e3a-4338-8bcc-d5ad2767a514">
        <source>getDischargePort():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Nov 2023 navhl20 ChangeRequest 61514: EUP | Ship Operations in DD - [54176.040] - [Release] Allocation List
10 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
20 May 2024 navhl20 Bug 64191: EUP - Lock and Freeze issue
*/

vars
	ti				: CM_TrackedItem;
	invalidObject	: Boolean;
	objset			: CM_ObjectSet;
	isShipGrp		: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidObject);
	
	create objset transient;
	if self.allTrackedItems.isNotEmpty() then
		isShipGrp := self.isInGrpCriteria(WOJG_DischargePortInt);	//20.05.2024 navhl20 #64191
		
		if isShipGrp then
			ti := self.allTrackedItems.first;
			return ti.dischargePort;
		else
			foreach ti in self.allTrackedItems  do
				invalidObject := false;
				ti.edition;
				
				if invalidObject then
					continue;
				endif;
				
				objset.tryAddIfNotNull(ti.getDischargePortObject());
			endforeach;
		
			if objset.isNotEmpty then
				return objset.listString(Comma,CM_Port::code.name);
			endif;
		endif;
	else
		return inheritMethod();
	endif;
epilog
	delete objset;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="004d3f2d-6d00-4a79-9a7c-4bbd89272f2a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 	ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
22 Jun 2023 navhl20 ChangeRequest 57758: EUP - Delivery Dispatch – Un Allocated Rail
21 Sep 2023 navhl20 Bug 60615: MTN - Release by type work order job is not appearing on the Delivery dispatch screen
*/

vars
	job : CM_Job;
begin
	if _attrName = ETRow_RegNumber then
		job := self.getRegNumber();						//21.9.2023 navhl20 #60615
		if job &lt;&gt; null then								//21.9.2023 navhl20 #60615
			return job.getDisplayStringForAttribute(_attrName,_short);
		endif;
	elseif _attrName = ETRow_Type then
		return self.getType();
	elseif _attrName = ETRow_Train then					//22.6.2023 navhl20 #57758
		return self.getTrainNumber();
	elseif _attrName = ETRow_Wagon then					//22.6.2023 navhl20 #57758
		if self.getWagon() &lt;&gt; null then
			return self.getWagon().id;
		endif;
		return null;
	else
		
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstLinkedWle" id="60ff2bba-833c-46eb-a3ba-81c7cff91554">
        <source>getFirstLinkedWle(): CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Oct 2024 navhl20 Bug 33146: EUP | Release cargo workorder completing early when split across multiple Vehicle Bookings

*/

vars
	wle		: CM_WorkListEntry;
begin
	foreach wle in self.workListEntries discreteLock where wle.status &lt;&gt; WLE_COMPLETED do
		if wle.CM_WOWLE.myOperationalWLE &lt;&gt; null then
			return wle;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getFirstTrackedItem" id="84e42cb1-22fb-41f6-b344-afede515e62c">
        <source>getFirstTrackedItem(): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
*/

vars
	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;
begin
	
	ti := self.allTrackedItems.first;
	
	if ti &lt;&gt; null then
		return ti;
	endif;
	
	wle := self.allCompletedWLEsByDate.first;
	if wle &lt;&gt; null then
		ti := wle.myTrackedItem;
	endif;
	
	return ti;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getGateEntry" id="bf3a6d06-eca9-4ad1-973a-14e6cb2149fc">
        <source>getGateEntry(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2023 navhl20 Bug 60615: MTN - Release by type work order job is not appearing on the Delivery dispatch screen

*/

vars
	wle	: CM_WorkListEntry;
	job : CM_Job;
begin
	if self.workListEntries.first.isKindOf(CM_WOWLE) then
		wle := self.workListEntries.first.CM_WOWLE.myOperationalWLE;
		if wle &lt;&gt; null and wle.isKindOf(CM_YardWLE) then
			job := wle.job;
		endif;
	endif;
	
	if not job.isKindOf(CM_RoadJob) then
		return null;
	endif;
	
	if job &lt;&gt; null then
		return job.CM_RoadJob.getGateEntry();
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHolds" id="a0000659-35ec-4264-834f-830d8e20fa08">
        <source>getHolds():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Nov 2023 navhl20 ChangeRequest 61514: EUP | Ship Operations in DD - [54176.040] - [Release] Allocation List
10 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle				: CM_WorkListEntry;
	str,
	hold			: String;
	invalidObject	: Boolean;
	voyage			: CM_Voyage;
	wleArr			: CM_WLEArray;
begin
	on Exception do app.handleDeletedObject(exception, wle, invalidObject);
	
	if self.workListEntries.isNotEmpty then
		voyage := self.getMyVoyage();
		
		create wleArr transient;
		self.workListEntries.copy(wleArr);		//06.03.2025 navma1 #MTN-34179
		
		foreach wle in wleArr discreteLock do	//06.03.2025 navma1 #MTN-34179
			invalidObject := false;
			wle.edition;
			
			if invalidObject then
				continue;
			endif;
			
			hold := wle.locationSource;
			
			if hold &lt;&gt; null and hold.cnContains(voyage.code) then
				if str = null then
					str := str &amp; hold;
				elseif not str.cnContains(hold) then
					str := str &amp; Comma &amp; hold;
				endif;
			endif;
		endforeach;
		return str;
	else
		return inheritMethod();
	endif;
epilog
	delete wleArr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIMEXStatus" id="04e38dce-1d62-4329-ab37-3b1e54ab5f14">
        <source>getIMEXStatus(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Nov 2023 navhl20 ChangeRequest 61514: EUP | Ship Operations in DD - [54176.040] - [Release] Allocation List
10 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
20 May 2024 navhl20 Bug 64191: EUP - Lock and Freeze issue
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	ti				: CM_TrackedItem;
	invalidObject	: Boolean;
	objSet			: ObjectSet;
	wod             : CM_WorkOrderDtl;
	transport		: Integer;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidObject);
	
	if self.allTrackedItems.isNotEmpty then
		wod := self.getMyWorkOrderDtl();
		
		if wod &lt;&gt; null and wod.isKindOf(CM_WorkOrderTIDtl) then				//20.05.2024 navhl20 #64191
			transport := wod.CM_WorkOrderTIDtl.getTransport();
		endif;
		
		if transport = TI_TRANSMODE_SHIP then								//20.05.2024 navhl20 #64191
			ti := self.allTrackedItems.first;
			return ti.getImExStatusStringDesc(true);
		else
			create objSet  transient;
			
			foreach ti in self.allTrackedItems discreteLock  do				//06.03.2025 navma1 #MTN-34179
				invalidObject := false;
				ti.edition;
				
				if invalidObject then
					continue;
				endif;

				objSet.tryAddIfNotNull(ti.getImExStatusObject);
			endforeach;
			
			if objSet.isNotEmpty then
				return objSet.listString(Comma,CM_IMEXStatus::abbreviation.name);
			endif;
		endif;
	else
		return inheritMethod();
	endif;
epilog
	delete objSet;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobClassNiceString" id="5836be28-0520-433f-bb4b-9c8ba880dc5c">
        <source>getJobClassNiceString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/03/2024	navkc1 CR 62694 Task 62900: Jade - Work Order Job Name

*/

vars

begin
	return self.getJobTypeDescription();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobTypeDescription" id="b1174140-05fb-4db2-8c70-c13f0262e2d6">
        <source>getJobTypeDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate

*/

vars

begin
	if self.myWODtl &lt;&gt; null then
			return self.myWODtl.getTypeDescription;
	else if self.myWorkOrderDtlToDo &lt;&gt; null	 then
			return self.myWorkOrderDtlToDo.getTypeDescription;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="93439cf8-41b6-4744-a164-ee7c19739517">
