<Class name="CM_ReportInvoiceTotal" id="42ecfcba-566e-426b-8c00-55044473c782">
    <superclass name="CM_Transient"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>CCMS CPL 2120 used in XML extract via report</text>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myInvoice" id="b6c6ead1-07f4-4263-bc07-7c094ef9d118">
        <embedded/>
        <type name="CM_Invoice"/>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myJRWInvoice" id="e5c6ab7d-1b11-4aea-8409-7e083c322d56">
        <kind>child</kind>
        <embedded/>
        <type name="CM_JRWInvoice"/>
        <Inverse name="CM_JRWInvoice::myReportInvoiceTotal"/>
    </ExplicitInverseRef>
    <PrimAttribute name="netAmount" id="5e6a2a37-ddd0-495b-a0e1-1fdfab025573">
        <precision>18</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="quantity" id="576cabc2-4482-4b1d-af26-2899f0d48853">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="taxAmount" id="6a033095-25a8-472b-a5a2-4073ee0eda39">
        <precision>18</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="totalAmount" id="7a21a1b1-3cbf-4184-b068-e6695df3dff7">
        <precision>18</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <JadeMethod name="getXMLInvoiceSummary" id="9161ad86-9927-4322-ae2d-4d5dc34554c1">
        <source>getXMLInvoiceSummary() : String;
// 28218 CCMS 2120 Oct 2011 electronic invoicing, method used in report writer
vars
	result	: String;
begin
	result := '&lt;invoicesummary&gt;' &amp; CrLf &amp;
			  '&lt;invoiceqty&gt;' &amp; self.quantity.String &amp; '&lt;/invoiceqty&gt;' &amp; CrLf &amp;
			  '&lt;invoicecost&gt;' &amp; CrLf &amp;
			  '&lt;currency&gt;NZD&lt;/currency&gt;' &amp; CrLf &amp;
			  '&lt;netamount&gt;' &amp; self.netAmount.String &amp; '&lt;/netamount&gt;' &amp; CrLf &amp;
			  '&lt;gst&gt;' &amp; self.taxAmount.String &amp; '&lt;/gst&gt;' &amp; CrLf &amp;
			  '&lt;totalamount&gt;' &amp; self.totalAmount.String &amp; '&lt;/totalamount&gt;' &amp; CrLf &amp;
			  '&lt;/invoicecost&gt;' &amp; CrLf &amp;
			  '&lt;/invoicesummary&gt;';
	result.encodeUTF8();
	return result;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
