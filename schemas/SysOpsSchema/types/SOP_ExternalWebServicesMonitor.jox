    <JadeMethod name="populateTableCams" id="3735ba9f-ad1e-4c3d-83ee-5bf1a205e09d">
        <updating/>
        <source>populateTableCams() updating,protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/12/2022	navdap1		Initial creation TFS 55159 MTN Export CAMS to JSON API Endpoint
// 03/4/2023	jlier1 		TFS 56856 - refactored to call one method to search - just set up the filtered attributes here
// 04/09/2023	navcs2		Bug 60234: EUP | FR EDI - External Webservice Monitor CAMS Search
// 26/05/2024	navcs2		ChangeRequest 59188: EUP | API Search - External Webservice Monitor
// 14/08/2024	navcs2		Bug 65590: EUP - EWS Monitor - Free text search not working

vars
	fromTime, toTime : Time;
	allEWSActivities : CM_EWSActivityByDateTime;
	eWSActivity		 : CM_ExternalWebServiceActivity;
	terminals : CM_TerminalByCodeDict;
	protocol	: CM_CamProtocol;						// 26/05/2024	navcs2		ChangeRequest 59188
begin
	if self.mskTimeFrom.getTime().isValid then
		fromTime := self.mskTimeFrom.getTime();
	else
		fromTime.setTime(0,0,0,0);
	endif;
	
	if self.mskTimeTo.getTime().isValid then
		toTime := self.mskTimeTo.getTime();
	else
		toTime.setTime(23,59,59,999);
	endif;	
	
	if self.mskDateFrom.getDate().isValid then
		self.filterDateFrom.setDate(self.mskDateFrom.getDate());
		self.filterDateFrom.setTime(fromTime);
	endif;
	if self.mskDateTo.getDate().isValid then
		self.filterDateTo.setDate(self.mskDateTo.getDate());
		self.filterDateTo.setTime(toTime);
	endif;
	
	create terminals transient;
	self.getTerminals(terminals);

	/*
	26/05/2024	navcs2		ChangeRequest 59188
	if self.cmbResponseCams.listIndex &gt; 1 then
		self.filterResponseCode:=self.cmbResponseCams.listData;
	endif;
	*/
	self.filterText := self.txtSearchBox.text;	// 14/08/2024	navcs2	Bug 65590
	self.getResponses(); 	// 26/05/2024	navcs2		ChangeRequest 59188
	self.getStatus(); 		// 26/05/2024	navcs2		ChangeRequest 59188
	
	//if self.cmbProtocolCams.listObject &lt;&gt; null and self.cmbProtocolCams.listObject.isKindOf(CM_CamProtocol) then 		// 04/09/2023 navcs2 Bug 60234			//26/05/2024	navcs2		ChangeRequest 59188
		//self.filterProtocol := self.cmbProtocolCams.listObject.CM_CamProtocol;										// 04/09/2023 navcs2 Bug 60234			//26/05/2024	navcs2		ChangeRequest 59188
	//endif;																											// 04/09/2023 navcs2 Bug 60234			//26/05/2024	navcs2		ChangeRequest 59188
	
	self.getProtocols();																	//26/05/2024	navcs2		ChangeRequest 59188
	
	create allEWSActivities transient;														//26/05/2024	navcs2		ChangeRequest 59188
	
	if not self.filterProtocol.isEmpty then													//26/05/2024	navcs2		ChangeRequest 59188
		foreach protocol in self.filterProtocol do											//26/05/2024	navcs2		ChangeRequest 59188
			foreach eWSActivity in protocol.allEWSCamsActivities do							//26/05/2024	navcs2		ChangeRequest 59188
				allEWSActivities.add(eWSActivity);											//26/05/2024	navcs2		ChangeRequest 59188
			endforeach;																		//26/05/2024	navcs2		ChangeRequest 59188
		endforeach;																			//26/05/2024	navcs2		ChangeRequest 59188
	else
		allEWSActivities := app.myRoot.allEWSActivities;
	endif;
	
	self.filterInterfaceName:=CM_EWSActivityCams@interface;
	self.filterClass:= CM_EWSActivityCams;

	self.populateTable(terminals,allEWSActivities);
	
epilog
	delete terminals;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTableEDBIC" id="b99b1f47-cdfa-467d-94b3-bf6b7087312d">
        <updating/>
        <source>populateTableEDBIC() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Nov 2022	navpw1	Initial creation TFS: 55215
03/4/2023	jlier1 	TFS 56856 - refactored to call one method to search - just set up the filtered attributes here
12/04/2023	navdap1	TFS 57362 CUX Changes to Outgoing Message Formats
26/05/2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
14/08/2024	navcs2	Bug 65590: EUP - EWS Monitor - Free text search not working

*/

vars
	fromTime, toTime : Time;
	terminals : CM_TerminalByCodeDict;
	interface : CM_ExternalWebServiceDef;			// 26/05/2024	navcs2		ChangeRequest 59188
begin
	if self.mskTimeFrom.getTime().isValid then
		fromTime := self.mskTimeFrom.getTime();
	else
		fromTime.setTime(0,0,0,0);
	endif;
	
	if self.mskTimeTo.getTime().isValid then
		toTime := self.mskTimeTo.getTime();
	else
		toTime.setTime(23,59,59,999);
	endif;	

	if self.mskDateFrom.getDate().isValid then
		self.filterDateFrom.setDate(self.mskDateFrom.getDate());
		self.filterDateFrom.setTime(fromTime);
	endif;
	if self.mskDateTo.getDate().isValid then
		self.filterDateTo.setDate(self.mskDateTo.getDate());
		self.filterDateTo.setTime(toTime);
	endif;
	
	if self.cmbType.listIndex &gt; 1 then				// 26/05/2024	navcs2		ChangeRequest 59188
		self.filterType := self.cmbType.text;		// 26/05/2024	navcs2		ChangeRequest 59188
	endif;

	create terminals transient;
	self.getTerminals(terminals);	//27 May 2024	navcs2	ChangeRequest 59188
	self.getStatus();				//27 May 2024	navcs2	ChangeRequest 59188
	self.getResponses();			//27 May 2024	navcs2	ChangeRequest 59188	
	self.filterText := self.txtSearchBox.text;	// 14/08/2024	navcs2	Bug 65590
	
	self.filterClass:= CM_EWSActivityEdBic;
	self.filterInterfaceName := ExternalWebServiceEDBIC;
	// TFS 57362 temp change until this form gets changed to use the actual definition name to search for
	interface := app.myRoot.getFirstActiveExtWebService(CM_CuxportServiceDef);
	if interface &lt;&gt; null then
		self.filterInterfaceName := interface.name;
	endif;
	// TFS 57362 end
	
	self.populateTable(terminals,app.myRoot.allEWSActivities);
	
epilog
	delete terminals;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTableFinanceOne" id="22a624ae-f886-4346-b5a2-735f4f6a5f34">
        <updating/>
        <source>populateTableFinanceOne() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2023	jlier1	Initial creation 56856
27 May 2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
14/08/2024	navcs2	Bug 65590: EUP - EWS Monitor - Free text search not working

*/

vars

	fromTime, toTime : Time;
	allEWSActivities : CM_EWSActivityByDateTime;
	terminals : CM_TerminalByCodeDict;
begin

	if self.mskTimeFrom.getTime().isValid then
		fromTime := self.mskTimeFrom.getTime();
	else
		fromTime.setTime(0,0,0,0);
	endif;
	
	if self.mskTimeTo.getTime().isValid then
		toTime := self.mskTimeTo.getTime();
	else
		toTime.setTime(23,59,59,999);
	endif;	
	
	if self.mskDateFrom.getDate().isValid then
		self.filterDateFrom.setDate(self.mskDateFrom.getDate());
		self.filterDateFrom.setTime(fromTime);
	endif;
	if self.mskDateTo.getDate().isValid then
		self.filterDateTo.setDate(self.mskDateTo.getDate());
		self.filterDateTo.setTime(toTime);
	endif;
	
	// the dictionaries holding external web service activities are keyed by terminal first
	// so we need to know what terminals we're processing for
	
	create terminals transient;
	self.getTerminals(terminals);	//27 May 2024	navcs2	ChangeRequest 59188
	self.getStatus();				//27 May 2024	navcs2	ChangeRequest 59188
	self.getResponses();			//27 May 2024	navcs2	ChangeRequest 59188
	self.filterText := self.txtSearchBox.text;	
	
	if filterInvoice &lt;&gt; null and self.txtInvoiceFO.text &lt;&gt; filterInvoice.sequenceNum.String then
		self.filterInvoice:=null;
	endif;
	
	if filterInvoice &lt;&gt; null then
		allEWSActivities := filterInvoice.allEWSFinanceOneActivities;
	else
		allEWSActivities := app.myRoot.allEWSActivities;
	endif;
	self.filterClass:= CM_EWSActivityFinanceOne;
	self.filterInterfaceName:=ExternalWebServiceFinanceOne;
	self.populateTable(terminals,allEWSActivities);
	
epilog
	delete terminals;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateTableGenericAPIScan" id="72fdc209-36df-4c02-92cc-0b72f9412508">
        <updating/>
        <source>populateTableGenericAPIScan()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
31 March 2022	navgm20	Initial creation 	tfs 52777
30 Aug 2022 	navma1	Bug 54684: MTN - Issues with External Monitor Screen if there are more than 32,000 record
03/4/2023	jlier1 		TFS 56856 - refactored to call one method to search - just set up the filtered attributes here
26/05/2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
14/08/2024	navcs2	Bug 65590: EUP - EWS Monitor - Free text search not working

*/

vars
	fromTime, toTime : Time;
	terminals : CM_TerminalByCodeDict;	
begin
	

	if self.mskTimeFrom.getTime().isValid then
		fromTime := self.mskTimeFrom.getTime();
	else
		fromTime.setTime(0,0,0,0);
	endif;
	if self.mskTimeTo.getTime().isValid then
		toTime := self.mskTimeTo.getTime();
	else
		toTime.setTime(23,59,59,999);
	endif;	

	if self.mskDateFrom.getDate().isValid then
		self.filterDateFrom.setDate(self.mskDateFrom.getDate());
		self.filterDateFrom.setTime(fromTime);
	endif;
	if self.mskDateTo.getDate().isValid then
		self.filterDateTo.setDate(self.mskDateTo.getDate());
		self.filterDateTo.setTime(toTime);
	endif;
	
	if self.cmbAction.listIndex &gt; 1 then
		self.filterAction := self.cmbAction.text[1:1];
	endif;
	
	if self.cmbType.listIndex &gt; 1 then
		self.filterType := self.cmbType.text;
	endif;
	
	create terminals transient;
	self.getTerminals(terminals);	//27 May 2024	navcs2	ChangeRequest 59188
	self.getStatus();				//27 May 2024	navcs2	ChangeRequest 59188
	self.getResponses();			//27 May 2024	navcs2	ChangeRequest 59188		
	self.filterText := self.txtSearchBox.text;	// 14/08/2024	navcs2	Bug 65590
	
	self.filterInterfaceName:=CM_EWSActivityGenericScan.InterfaceName;
	self.filterClass:= CM_EWSActivityGenericScan;
	
	self.populateTable(terminals,app.myRoot.allEWSActivities);
epilog
	delete terminals;
end;</source>
    </JadeMethod>
