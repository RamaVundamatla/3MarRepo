    <JadeMethod name="isThereRoomForTI" id="8435a0de-b0ba-4db3-b303-7cf35485549f">
        <source>isThereRoomForTI(_overHangLC : CM_LocationsController; _control: CMIF_MoveController input; _ti : CM_TrackedItem) : String;
// ---------------------------------------------------------------------------
// Created:     18 December 2008 by cnwab1
//
//					PAR 18682 - CCMS SFW 1055
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	primaryPortion : Integer;
	overHangFree, offset : Integer;
	tiLen : Integer;
	wholeLC : Integer;
	lcLen : Integer;
	nextGC : CM_GridController;
	tmpLen : String;
begin
	lcLen := self.myTerminalArea.locationLength.Integer;
	
	if self.offsetFlexi = lcLen then
		primaryPortion := lcLen.Integer;
	else
		offset := self.offsetFlexi;
		if offset = 0 then
			offset := self.getStrictOffsetForTI(_ti);
		endif;
		
//		primaryPortion := (lcLen -  self.offsetFlexi).Integer;
		primaryPortion := (lcLen -  offset).Integer;
	endif;
	
	if _overHangLC.allTrackedItems.isEmpty() then 
		overHangFree := lcLen;
	else
		overHangFree := _overHangLC.offsetFlexi;
	endif;
	tiLen := _ti.getActualLength().Integer;
	
	nextGC := self;
	while true do
		nextGC := nextGC.myNextController;
		if nextGC = null or nextGC = _overHangLC then
			break;
		endif;
		
		wholeLC := (wholeLC + lcLen).Integer;
	endwhile;
	
	if tiLen &gt; (primaryPortion + overHangFree + wholeLC) then
	
		if _overHangLC.allTrackedItems.includes(_ti) then
			return null;
		endif;
//		return "There is cargo in the way.";
		tmpLen := _ti.getActualLength().String;
		return app.getErrorString3(ERR_NO_MOVE_ODD, _ti.id, tmpLen, tmpLen); // PAR 18647
	
	endif;

	if not _overHangLC.CM_GridController.amIAvailable or _overHangLC.CM_GridController.mySubBlockStack &lt;&gt; null then
		tmpLen := _ti.getActualLength().String;
		return app.getErrorString3(ERR_NO_MOVE_ODD, _ti.id, tmpLen, tmpLen); 
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_overHangLC" type="CM_LocationsController"/>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isTopPositionCargo" id="20a02e15-fbc4-4bc5-aac2-b10ccb7712ca">
        <source>isTopPositionCargo(_ti: CM_TrackedItem; _height : Integer): Boolean;
// -------------------------------------------
// Created 22 August 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if _height &lt;= 0 then
		if self.allTrackedItems.last = _ti then
			return true;
		else
			return false;
		endif;
	endif;

	if self.allTrackedItems.size &gt;= _height and self.allTrackedItems.at(_height) = _ti then
		return true;
	endif;

	return false;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTopTI" id="70addb32-4ebc-4405-8c39-6769782fe6eb">
        <source>isTopTI(ti: CM_TrackedItem; mode: Integer): Boolean;
/*
 ------------------------------------------------------------------------
Created:			04 December 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	array : CM_TIArray;
begin
	create array transient;
	self.getTIs(array, mode, true); // PAR 27749
	if not array.includes(ti) then
		return false;
	endif;
	return (array.last = ti);
epilog
	delete array;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTrackedItemOverStowed" id="f93bd9a9-973d-4b96-92f3-782fc76adcd8">
        <source>isTrackedItemOverStowed(_ti : CM_TrackedItem): Boolean;
// -------------------------------------------
// Created 22 August 2005 by cnwdvb1
// -------------------------------------------
vars

	dischargePort	: String;
	voy				: CM_Voyage;
	ti				: CM_TrackedItem;

begin

	if self.allTrackedItems.last = _ti then
		return false;
	endif;
	
	voy 			:= _ti.myVoyage;
	dischargePort	:= _ti.dischargePort;
	
	foreach ti in self.allTrackedItems reversed, discreteLock do 
		if ti.myVoyage &lt;&gt; voy then
			return true;
		elseif ti.dischargePort &lt;&gt; dischargePort then
			return true;
		elseif ti = _ti then
			return false;
		endif;
	endforeach;

	return false;


end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTrackedItemOverStowing" id="857f3593-a672-4f0b-9b1c-01f38f48e5c4">
        <source>isTrackedItemOverStowing(_ti: CM_TrackedItem): Boolean;
// -------------------------------------------
// Created 22 August 2005 by cnwdvb1
// -------------------------------------------
vars

	voy				: CM_Voyage;
	ti				: CM_TrackedItem;

begin

	if self.allTrackedItems.first = _ti then
		return false;
	endif;
	
	voy 			:= _ti.myVoyage;
	
	foreach ti in self.allTrackedItems discreteLock do 
		if ti.myVoyage &lt;&gt; voy then
			return true;
		elseif ti = _ti then
			return false;
		endif;
	endforeach;

	return false;


end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWithinSeparationLimits" id="65266770-71e3-4336-bfdb-241432188427">
        <source>isWithinSeparationLimits(pSourceLocn	:	CM_LocationsController)	:	Boolean;
//Tests that this lC is not within parent::numRowsMachineSep rows.
//If it IS, it returns TRUE, else it returns FALSE.
//By here, we have confirmed that souceLocn IS in the same straddle stack
//as we are. Now, see our parent for the separation rules, and do our bit.
vars
	numRows	:	Integer;
	myRow	:	Integer;
	itsRow	:	Integer;
begin
	numRows := self.myGridArea.numberOfRowsMachineSep;	
	if numRows = 0 then
		//----------------
		//No separation rule, everything goes. Crash alley!
		//----------------
		return false;
	endif;
  	myRow := self.row;
//  	itsRow := pSourceLocn.CM_StackController.ordinalRow; // AKB2005JAN need to delete ordinalrow
  	itsRow := pSourceLocn.CM_StackController.row;

	if myRow = itsRow then
		//--------------
		//In same row!!!
		//--------------
		return true;
	endif;
	if myRow &gt; itsRow then
		if (itsRow + numRows) &gt;= myRow then
			return true;
		endif;
	else
	 	if (itsRow - numRows) &lt;= myRow then
			return true;
		endif;
	endif;
 	return false;
end;</source>
        <Parameter name="pSourceLocn" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myTerminalArea" id="6643209a-ef0d-40e8-a00a-e480f359b13f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myTerminalArea(set: Boolean; _value: CM_TerminalArea io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(set, _value);

	if (not set) then
		// Jade will return value of attribute
		return;
	endif;
	
	if _value = null or
	   not _value.isKindOf(CM_GridArea) then 
		self.myGridArea := null;
		return;
	endif;
	//----------------------
	//Set the parent reference at the same time the myTerminalArea ref is being set.
	//We do this to get an inverse to a dict on the CM_GridArea class.
	//----------------------
	self.myGridArea := _value.CM_GridArea;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_TerminalArea" usage="io"/>
    </JadeMethod>
    <JadeMethod name="overstowingDifferentDischPort" id="b71087c9-9227-45bf-beea-9da2145b2c0d">
        <source>overstowingDifferentDischPort(_ti : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpTI, theTI : CM_TrackedItem;
	idx, endIdx : Integer;
begin
	if self.allTrackedItems.isEmpty then
		return false;
	endif;
	if self.allTrackedItems.size = 1 then
		return false;
	endif;
	
	theTI := _ti;
	
	endIdx := self.allTrackedItems.indexOf(theTI);
	
	if endIdx = 1 then
		return false;
	endif;
	endIdx := endIdx - 1;
	
	if endIdx &lt; 1 then
		return false;
	endif;
	
	foreach idx in 1 to endIdx do
		tmpTI := self.allTrackedItems[idx];
		if tmpTI.dischargePort &lt;&gt; theTI.dischargePort then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="overstowingDifferentVoyage" id="f461947d-8f3c-46ee-88ea-f00007203fb3">
        <source>overstowingDifferentVoyage(_ti : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpTI, theTI : CM_TrackedItem;
	idx, endIdx : Integer;
begin
	if self.allTrackedItems.isEmpty then
		return false;
	endif;
	if self.allTrackedItems.size = 1 then
		return false;
	endif;
	
	theTI := _ti;
	
	endIdx := self.allTrackedItems.indexOf(theTI);
	
	if endIdx = 1 then
		return false;
	endif;
	endIdx := endIdx - 1;
	
	if endIdx &lt; 1 then
		return false;
	endif;
	
	foreach idx in 1 to endIdx do
		tmpTI := self.allTrackedItems[idx];
		if tmpTI.myVoyage &lt;&gt; theTI.myVoyage then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queryConnectTower" id="b1e8233c-f611-44aa-a1a6-2420f208cac1">
        <source>queryConnectTower(theParams : CMIF_ConnectParams input ;ti : CM_TrackedItem;  connectMode	:	Integer);

constants
	MSGBOX_TITLE = "Target Location Query";
vars
	term	:	CM_Terminal;
	msgStr	:	String;
	towerHeight	: Integer;
	tower : CM_TrackedItem;
	tc					: CM_TowerController;
	isPrevious 	: Boolean;
	ph 					: CM_Container;
	locnId	:	String;
	nextLC	:	CM_StackController;
begin

	term := app.getMyTerminalDO_NOT_USE;
	if ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "TI Ref in QueryConnectTower", null, null);
		return;
	endif;	

	if ti.isKindOf(CM_Container) then
		ph := ti.CM_Container;
	else
		return;
	endif;
	
	if not ph.requiresTemperature then
		//Does not need temperature settings
		return;
	endif;

	if ti.typeAttributes.bitAnd(ISO_INTEGRAL) &lt;&gt; 0 then
		//Integrals dont need tower.
		return;
	endif;

	locnId	:= self.getFullId;
	if self.getMyNextController(CM_TowerController).CM_TowerController &lt;&gt; null then
		tc := getMyNextController(CM_TowerController).CM_TowerController;
	elseif self.getMyPreviousController(CM_TowerController) &lt;&gt; null then
		tc := getMyPreviousController(CM_TowerController).CM_TowerController;
		isPrevious := true;
	else
		//--------------
		//NO TOWER CONTROLLERS in this Straddle Stack!
		//--------------
		if connectMode = QUERY_CONNECT then
			//ERROR!
			if theParams.radioTelemetryUser then
				term.createStringAlert(SEVERE_WARNING, app.getErrorString2(ERR_NO_ADJACENT_TOWER, ti.id.trimRight, locnId), null );		
			endif;
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_NO_ADJACENT_TOWER, ti.id.trimRight, locnId, null, null);
			return;
		endif;
		if theParams.radioTelemetryIgnoreWarnings then
			return;	//If no tower, then no sense in checking for anything else!
		endif;
		if theParams.radioTelemetryUser then
			//Radio telemetry user. Create an alert, and raise an execption
			term.createStringAlert(SEVERE_WARNING, app.getErrorString(ERR_MOVE_RT_ERR), app.getErrorString2(WARN_NO_ADJACENT_TOWER, ti.id.trimRight, locnId) );
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_MOVE_RT_ERR, null, null);
			return;
		endif;
		app.raiseCMException2(WARN_NO_ADJACENT_TOWER, ti.id, locnId ,null, null);
		theParams.radioTelemetryGaveWarning := true;
	endif;

	if connectMode = QUERY_PLANNED_MOVE then
		//Do not check the tower actual state for planned moves
		return;
	endif;	

	if connectMode = QUERY_CONNECT then
		//NFS 3814: We are looking for the height of a tracked
		//item ALREADY in the stack
		towerHeight := self.allTrackedItems.indexOf(ti);
	else
		//Add 1 to towerheight, we are looking for a tower at height
		//we want to stack to. If numTI's is 0, then we want to check
		//at height 1
		if self.numTIs &lt; 0 then	//Funnily enough, some LC's have -1 as numTI's!!!
			towerHeight := 1;
		else
			towerHeight := self.numTIs + 1;
		endif;
	endif;
	//-------------
	//Get Tower @ height
	//-------------
  	tc.getTIAtHeight(tower, towerHeight, REAL_MODE);
	if tower = null then
		//NO TOWER at this height

		if connectMode = QUERY_CONNECT then
			if theParams.radioTelemetryUser then
				term.createStringAlert(SEVERE_WARNING, app.getErrorString2(ERR_NO_ADJACENT_TOWER, ti.id.trimRight, locnId), null );		
			endif;
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_NO_ADJACENT_TOWER, ti.id.trimRight, locnId, null, null);
			return;
		endif;

		if theParams.radioTelemetryIgnoreWarnings then
			return;	//If no power, then no sense in checking for power damaged!
		endif;
		if theParams.radioTelemetryUser then
			//Radio telemetry user. Create an alert, and raise an execption
			term.createStringAlert(SEVERE_WARNING, app.getErrorString(ERR_MOVE_RT_ERR), app.getErrorString2(WARN_NO_ADJACENT_TOWER, tc.getID(), locnId) );
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_MOVE_RT_ERR, null, null);
			return;
		endif;

		app.raiseCMException2(WARN_NO_ADJACENT_TOWER, ti.id.trimRight, locnId , null, null);
		theParams.radioTelemetryGaveWarning := true;
	endif; 
	//--------------
	//Check location on other side of tower is Available (new 31 March 1999 DWQ)
	//--------------
	if connectMode &lt;&gt; QUERY_CONNECT then		//NF 3814 AA 25/9/01: Not relevant for connections (?)
	
 		if isPrevious then
			nextLC := self.getMyPreviousController(CM_StackController).CM_StackController;
 		else
			nextLC := self.getMyNextController(CM_StackController).CM_StackController;
 		endif;
 		if nextLC &lt;&gt; null then
 			if not nextLC.isAvailable(towerHeight, null) then // PAR 17886
				app.setContinueCMExceptions(false);
				app.raiseCMException1(ERR_AREA_FULL, ti.id.trimRight, null, null);
				return;
			endif;
 		endif;
 	endif;
	//Tell the tower to check itself 
	tower.CM_Tower.queryConnectPortHole(theParams,ti, isPrevious, connectMode);
end;</source>
        <Parameter name="theParams" type="CMIF_ConnectParams" usage="input"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="connectMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="requiresOverHangingBackend" id="99886d7c-d841-4f22-8b5f-4e341c654650">
        <source>requiresOverHangingBackend(_theTI : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:     29 December 2008 by cnwab1
//
//					PAR 18682 CCMS SFW 1055
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpLC : CM_LocationsController;
begin
	if self.myTerminalArea &lt;&gt; null then // cnwcp2 - 9/2/2009 - null pointer check - came across when creating tests for HandHeld
		if self.myTerminalArea.isRightAligned() then
			tmpLC := _theTI.myOSBackEndLocation; 
			if tmpLC = null then
				tmpLC := self;
			endif;
			
			if _theTI.isTwenty and tmpLC.offsetFlexi &gt; 0 then
				return true;
			elseif _theTI.isAttributeTrue(TI_Attrib_IsThirty) then
				return true;
			elseif _theTI.isAttributeTrue(TI_Attrib_IsForty) and tmpLC.offsetFlexi &gt; 0 then
				return true;
			elseif _theTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
				return true;
			elseif _theTI.isAttributeTrue(TI_Attrib_IsFiftyThree) then
				return true;
			endif;
		
		else	
			if _theTI.isTwenty and self.offsetFlexi &gt; 0 then
				return true;
			elseif _theTI.isAttributeTrue(TI_Attrib_IsThirty) then
				return true;
			elseif _theTI.isAttributeTrue(TI_Attrib_IsForty) and self.offsetFlexi &gt; 0 then
				return true;
			elseif _theTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
				return true;
			elseif _theTI.isAttributeTrue(TI_Attrib_IsFiftyThree) then
				return true;
			endif;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
