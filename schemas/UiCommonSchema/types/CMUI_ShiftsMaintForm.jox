    <JadeMethod name="doDelShift" id="aa294a98-8b72-4480-b0a3-f3c7bb892497">
        <updating/>
        <source>doDelShift() updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	12/03/2010	cnwjo3		par 22841
// ---------------------------------------------------------------------------

vars
	idx, theReturn : Integer;
	shiftEntity : CM_ShiftEntity;
	seNotTransient : Boolean;
	invalid : Boolean;
begin
	shiftEntity := self.myCurrentShift;
	
	if shiftEntity = null then
		return;  //if no shift is selected from the table do NOTHING
	endif;
	
	on Exception do app.handleDeletedObject(exception,shiftEntity,invalid);
	
	seNotTransient := not shiftEntity.isTransient();
	
	if invalid then
		return;  //if nothing from the table is selected and/or the current shift is invalid (deleted) do nothing
	endif;
	
	if self.optStandard.value or (self.optByDate.value and seNotTransient ) then
		while true do
			app.myTrxDA.trxDeleteShift(self.myCurrentShift, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog('Worker Shift Deletion', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			break;
		endwhile;
	else
		if self.myCurrentShift.isTransient() then
			self.myProxyShift := self.myCurrentShift;
			self.mode := self.MODE_DELETE;
			self.myProxyShift.setProxy(null,null,null,self.myProxyShift.code,self.myProxyShift.description, self.myTerminal, true);
			self.saveShift();

		else
		endif;
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doEditShift" id="9f1465bf-4dd6-4472-90aa-dd538db9718d">
        <updating/>
        <source>doEditShift() updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/08/2008	concms1		par17766 set zOrder when display shift frame
// ---------------------------------------------------------------------------

vars

begin
	if self.myCurrentShift &lt;&gt; null then
		self.setFormMode(MODE_EDIT);
		if self.optStandard.value then
			self.setAddDialog();
			self.myProxyShift := self.createProxiesForEdit();
			self.frmAddDialog.visible := true;
			self.frmAddDialog.zOrder (1);	// par 17766 cms 21/08/2008
			self.timeStartTime.setFocus();
		else
			self.setAddDialogDay();
			self.myProxyShift := self.myCurrentShift;
			self.frmAddDialogDay.visible := true;
			self.mskDateStart.setFocus();
		endif;
	else
		app.msgBox("Please select a worker shift.", "Error",0);
		return;
	endif;
	
end;
</source>
    </JadeMethod>
