vars
	ta				: CM_TerminalArea;
begin
	app.mousePointer := Busy;
	ta := combobox.listObject.CM_TerminalArea;
	if ta &lt;&gt; null then
		self.myAssistant.comboBoxLocationControllers(self.cmbLocation, ta.allLocationsControllers, false);
	endif;
	
epilog
	app.mousePointer := Idle;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
