    <JadeMethod name="trxUpdateTerminalArea" id="b5d72b6a-4e05-4eb3-a0fe-113ec99d9d23">
        <updating/>
        <source>trxUpdateTerminalArea(_proxyTAMaster : CM_TerminalAreaMaster input; _passport : CM_Passport input) updating;
//trxUpdateTerminalArea(_proxyTA : CM_TerminalArea input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// ---------------------------------------------------------------------------
vars
	realTAMaster : CM_TerminalAreaMaster;
	realTA, proxyTA       : CM_TerminalArea;
	expectedEdition  : Integer;
	pxyDeckingOptions : CM_YADeckingOptionsTA;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	
	
	if _proxyTAMaster = null then
		app.raiseCMException1(ERR_NO_OBJECT, "Terminal Area", null, null);
	endif;

	_proxyTAMaster.raiseExceptionIfNotProxy(method);
	_proxyTAMaster.pxyGetRealObjectAndEdition(realTAMaster, expectedEdition);
	
	beginTransaction;

	app.myUtilityUA.utlUpdateTerminalArea(_proxyTAMaster, _passport);
	if _passport.hasErrors then
		return;
	endif;
	
	if (realTAMaster &lt;&gt; null and realTAMaster.isKindOf(CM_TerminalArea)) then
		realTA:=realTAMaster.CM_TerminalArea;
		proxyTA:=_proxyTAMaster.CM_TerminalArea;
	
	endif;
	
		//epr par 1/7/10 24724
	if proxyTA &lt;&gt; null then
		pxyDeckingOptions:=proxyTA.myYADeckingOptions;
	endif;
	
	if realTA &lt;&gt; null  and pxyDeckingOptions &lt;&gt; null then
		//all the location cells have been lost - need to rebuild these for the area
		//clear out anything invalid picked up from the original gridobjects
		// PAR 34890	if proxyTA.isKindOf(CM_GridArea) then	// 25/02/2010 cnwar2 #21209
		//if not proxyTA.isBlockStack() and not proxyTA.isBulkArea() then // PAR 34890								// TFS 49453
		if not proxyTA.isBlockStack()
		and not proxyTA.isBulkArea()
		and not proxyTA.isGeneralCargoAllocArea 		// TFS 49453
		and not proxyTA.isIrregularBlockArea	//18 Feb 2021	NDL	TFS 50824
		then
			pxyDeckingOptions.allYALocationCellsIn.purge;
			pxyDeckingOptions.allYALocationCellsOut.purge;
		endif;
				
		app.myUtilityCA.utlCreateDeckOptionsApplyRules(realTA, pxyDeckingOptions, DeckingLevel_TA, _passport);
		
		if _passport.hasErrors then
			return;
		endif;
		
		realTA.setGridObjectsForDecking(_passport);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	
		
epilog
		//epr par 24724 1/7/10 make sure the proxy TA is the same as when it arrived in this method - i.e. if we have warnings and get back here need the proxyTA to have a reference to pxyDeckingOptions
	if pxyDeckingOptions &lt;&gt; null then
		pxyDeckingOptions.setProxy(pxyDeckingOptions.showHeightsForCustom, pxyDeckingOptions.useReverseOfIn, proxyTA);
	endif;

	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyTAMaster" type="CM_TerminalAreaMaster" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTerminalAreaFlag" id="a36f3dcb-956c-4d67-a2c1-9285c41cf571">
        <updating/>
        <source>trxUpdateTerminalAreaFlag(_realTerminalArea : CM_TerminalArea input;
							_isSuitableForLoadFrom,
							_isSuitableForLoadInto : Boolean;
							_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     15 March 2004	cnwth2
//
// Purpose:     Simply updates a single boolean flag (can by either, but not both of the passed in flags)
//			
//			 
// ----------   ----------  --------------------------------------------------
vars
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	app.myUtilityUA.utlUpdateTerminalAreaFlag(_realTerminalArea, 
												_isSuitableForLoadFrom, 
												_isSuitableForLoadInto,
												_passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_realTerminalArea" type="CM_TerminalArea" usage="input"/>
        <Parameter name="_isSuitableForLoadFrom" type="Boolean"/>
        <Parameter name="_isSuitableForLoadInto" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTerminalAreaGCAlloc" id="53ddcfe7-5c5e-4e4a-b631-f97993946abc">
        <updating/>
        <source>trxUpdateTerminalAreaGCAlloc(_proxyTA : CM_GeneralCargoAllocRowArea input; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/12/2020	jlgdap1		Initial creation TFS 50110 ASPA General Cargo Allocation Row - Label
//
vars
	realTA : CM_GeneralCargoAllocRowArea;
	expectedEdition : Integer;
	pxyDeckingOptions : CM_YADeckingOptionsTA;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	if _proxyTA = null then
		app.raiseCMException1(ERR_NO_OBJECT, "Terminal Area", null, null);
	endif;

	_proxyTA.raiseExceptionIfNotProxy(method);
	_proxyTA.pxyGetRealObjectAndEdition(realTA, expectedEdition);
	
	beginTransaction;

	app.myUtilityUA.utlUpdateTerminalAreaGCAlloc(_proxyTA, _passport);
	if _passport.hasErrors then
		return;
	endif;
	
	pxyDeckingOptions := _proxyTA.myYADeckingOptions;
	
	if realTA &lt;&gt; null and pxyDeckingOptions &lt;&gt; null then
		//all the location cells have been lost - need to rebuild these for the area
		app.myUtilityCA.utlCreateDeckOptionsApplyRules(realTA, pxyDeckingOptions, DeckingLevel_TA, _passport);
		
		if _passport.hasErrors then
			return;
		endif;
		
		realTA.setGridObjectsForDecking(_passport);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
epilog
	// make sure the proxy TA is the same as when it arrived in this method - i.e. if we have warnings and get back here need the proxyTA to have a reference to pxyDeckingOptions
	if pxyDeckingOptions &lt;&gt; null then
		pxyDeckingOptions.setProxy(pxyDeckingOptions.showHeightsForCustom, pxyDeckingOptions.useReverseOfIn, _proxyTA);
	endif;

	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyTA" type="CM_GeneralCargoAllocRowArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTerminalAreaICAreas" id="e9cf5815-60b5-47ed-8b52-c9bea8fc6d25">
        <updating/>
        <source>trxUpdateTerminalAreaICAreas(_ta :CM_TerminalArea; _coll :CM_InterchangeAreaArray; _passport :CM_Passport input)updating;
// ---------------------------------------------------------------------------
// Created:     26 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	app.myUtilityUA.utlUpdateTerminalAreaICAreas(_ta, _coll, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_coll" type="CM_InterchangeAreaArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTerminalAreaInUse" id="65fb0f1a-5aad-43e9-a1e9-bd00f975b4b9">
        <updating/>
        <source>trxUpdateTerminalAreaInUse(_controller : CMIF_TerminalArea input; _deckingToLevel: Integer; _passport : CM_Passport input) updating;
//trxUpdateTerminalAreaInUse(_proxyTA : CM_TerminalArea input; _deckingToLevel: Integer; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
//
// 	When		Who			What
//	15/10/2009	cnwdap1		PAR #21350 'bigger' check was being done after utlUpdateTerminalAreaInUse,
//							which had already set the rows and columns to the new values
// ---------------------------------------------------------------------------
vars
	realTA	: CM_TerminalArea;
	proxyTA : CM_TerminalArea;
	expectedEdition : Integer;
	bigger : Boolean;
	pxyDeckingOptions : CM_YADeckingOptionsTA;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	proxyTA := _controller.myPxyTerminalArea;
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if proxyTA = null then
		app.raiseCMException1(ERR_NO_OBJECT, "Terminal Area", null, null);
		return;
	endif;
	
	proxyTA.raiseExceptionIfNotProxy(method);
	proxyTA.pxyGetRealObjectAndEdition(realTA, expectedEdition);
	
	bigger := realTA.hasGridAreaIncreased(proxyTA);  // PAR 17379

	
	beginTransaction;
	app.myUtilityUA.utlUpdateTerminalAreaInUse(proxyTA, _passport);
	
	if _passport.hasErrors then // PAR 17379
		return;
	endif;
	
	//epr par 1/7/10 24724
	if proxyTA &lt;&gt; null then
		pxyDeckingOptions:=proxyTA.myYADeckingOptions;
	endif;
	
	if (realTA &lt;&gt; null and realTA.isKindOf(CM_TerminalArea)) and pxyDeckingOptions &lt;&gt; null then // PAR 18994
		if bigger then // PAR 17379
			//all the location cells have been lost - need to rebuild these for the area
			//clear out anything invalid picked up from the original gridobjects
			pxyDeckingOptions.allYALocationCellsIn.purge; // PAR 17379
			pxyDeckingOptions.allYALocationCellsOut.purge; // PAR 17379
					
			app.myUtilityCA.utlCreateDeckOptionsApplyRules(realTA, pxyDeckingOptions, DeckingLevel_TA, _passport); // PAR 17379
			
			if _passport.hasErrors then // PAR 17379
				return; // PAR 17379
			endif;
			
			realTA.setGridObjectsForDecking(_passport); // PAR 17379
		else
			app.myUtilityUA.utlUpdateDeckOptionsApplyRules(pxyDeckingOptions, _deckingToLevel, _passport);
		endif;
	endif;
epilog
	
	//epr par 24724 1/7/10 make sure the proxy TA is the same as when it arrived in this method - i.e. if we have warnings and get back here need the proxyTA to have a reference to pxyDeckingOptions
	if pxyDeckingOptions &lt;&gt; null then
		pxyDeckingOptions.setProxy(pxyDeckingOptions.showHeightsForCustom, pxyDeckingOptions.useReverseOfIn, proxyTA);
	endif;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_controller" type="CMIF_TerminalArea" usage="input"/>
        <Parameter name="_deckingToLevel" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateTerminalAreaStorageGp" id="30823267-4c2d-405d-8ebd-81f5692796d8">
        <updating/>
        <source>trxUpdateTerminalAreaStorageGp(_proxyTerminalAreaStorageGroup : CM_TerminalAreaStorageGroup input; _passport : CM_Passport input) updating;
