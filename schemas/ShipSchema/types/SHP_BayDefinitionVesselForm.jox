    <JadeMethod name="unloadForm" id="4ed7e415-4ff0-4b8a-b626-e0620099ca52">
        <updating/>
        <source>unloadForm() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.myProxyCellularVessel &lt;&gt; null then
		if global.isValidObject(self.myProxyCellularVessel) then
			if self.myProxyCellularVessel.isTransient then
				delete self.myProxyCellularVessel;
			endif;
		endif;
	endif;
	if self.myCurrentCellularVessel &lt;&gt; null then
		if global.isValidObject(self.myCurrentCellularVessel) then
			if self.myCurrentCellularVessel.isTransient then
				delete self.myCurrentCellularVessel;
			endif;
		endif;
	endif;
	if self.myCurrentBay &lt;&gt; null then
		if global.isValidObject(self.myCurrentBay) then
			if self.myCurrentBay.isTransient then
				delete self.myCurrentBay;
			endif;
		endif;
	endif;
	
	return inheritMethod();	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="9c115987-1ba9-490b-8e06-1a73ae7c66c4">
        <updating/>
        <source>updateProgress(_cmifMonitor : CMIF_Monitor input) updating;
//--------------------------------------------------
// Created:	02 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_cmifMonitor);
	//self.pbProgressBar.doWindowEvents(0);	// don't do this! we just need to repaint it, not pass off to windows to do events
	
	// TFS 49052 navmd1 MACS3 Vessel Library API
	self.pbProgressBar.refreshNow();
	self.lblModalInfo.refreshNow();
	self.lblModalMessage.refreshNow();
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateBayLabelsWizard" id="02648bdf-1f00-4a2c-9d11-0923ebbac739">
        <source>validateBayLabelsWizard(_bayList : String; _len1ok : Boolean) : Boolean ;
// ---------------------------------------------------------------------------
// Created:     June 2008 ANDREW BISHOP
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// // PAR 17912
// ---------------------------------------------------------------------------

vars

	aLabel : String;
	theLabels, tmpLabels : StringArray;
	idx, hyphen,comma  : Integer;
begin
	aLabel := _bayList.String;
	
	if aLabel.pos("|", 1) &gt; 0 then
		return false;
	endif;
	
	
	aLabel.replaceChar(",","|");
	aLabel.replaceChar(" ","|");
	create theLabels transient;
	create tmpLabels transient;
	
	aLabel.getTokensForDelimiter("|", theLabels);
	
//	theLabels.inspectModal;
	idx := 0;
	
	foreach aLabel in theLabels do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		
		if aLabel.trimBlanks.length &gt; 2 then
			return false;
		endif;
		if not aLabel.trimBlanks.isInteger then
			return false;
		endif;
		if not _len1ok and aLabel.trimBlanks.length = 1 then
			return false;
		endif;
		if tmpLabels.includes(aLabel.trimBlanks) then
			app.msgBox("Duplicate Bay IDs Are Not Allowed!" &amp; Cr  &amp; "Bay ID " &amp; aLabel &amp; " Is Duplicated." &amp; Cr &amp; 
							"Please re-edit the bay IDs.",
							"Bay ID Duplication",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			self.txtWBayOrder.setFocus(); // PAR 18147
			return true; // PAR 18147
		else
			tmpLabels.add(aLabel.trimBlanks);
		endif;
	endforeach;

	return true;
epilog
	delete theLabels;
	delete tmpLabels;
end;</source>
        <Parameter name="_bayList" type="String"/>
        <Parameter name="_len1ok" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTierCellLabels" id="2e3b0425-c192-4bef-a9d7-229b3e737a3a">
        <updating/>
        <source>validateTierCellLabels(_theHeading : String; _theValue : Any) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aLabel : String;
	theLabels : StringArray;
	idx : Integer;
begin
	aLabel := _theValue.String;
	aLabel.replaceString(" ","|");
	theLabels := aLabel.getTokens;
	idx := 0;
	
	foreach aLabel in theLabels do
		if aLabel.trimBlanks = null then
			continue;
		endif;
		
		if aLabel.trimBlanks.length &gt; 2 then
		//	app.msgBox("The " &amp; _theHeading  &amp; " Label '" &amp; aLabel &amp; "' Is Too Long." 
		//		&amp; Cr &amp; "Labels Cannot Be Longer Than 2 Characters.",_theHeading &amp; " Label Error", MsgBox_OK_Only);
			return false;
		endif;
		if not aLabel.trimBlanks.isInteger then
		//	app.msgBox("The " &amp; _theHeading  &amp; " Label '" &amp; aLabel &amp; "' Must Be A Number." 
		//		&amp; Cr &amp; "Labels Cannot Be Alpha Numeric or Longer Than 2 Characters.",_theHeading &amp; " Label Error", MsgBox_OK_Only);
			return false;
		endif;
		if aLabel.trimBlanks.length = 1 then
		//	app.msgBox("The " &amp; _theHeading  &amp; " Label '" &amp; aLabel &amp; "' Is Too Short "
		//		&amp; Cr &amp; "Labels Should Be 2 Characters Long, Zero Filled.",_theHeading &amp; " Label Error", MsgBox_OK_Only);
			return false;
		endif;
	endforeach;

	return true;
epilog
	delete theLabels;
end;</source>
        <Parameter name="_theHeading" type="String"/>
        <Parameter name="_theValue" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateWizardData" id="a126608e-1203-4a20-b7ba-0d5e9be59f31">
        <source>validateWizardData() : TextBox;
// ---------------------------------------------------------------------------
// Created:     June 2008 ANDREW BISHOP
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// // PAR 17912
// ---------------------------------------------------------------------------

vars

begin
	// set defaults if user just clicks SAVE
	if self.txtWBayOrder.text.pos("-",1) &gt; 0 then
		self.txtWBayOrder.lostFocus(self.txtWBayOrder);
	endif;
	if self.txtWOnDeckCells.text.pos("-",1) &gt; 0 then
		self.txtWOnDeckCells.lostFocus(self.txtWOnDeckCells);
	endif;
	if self.txtWOnDeckTier.text.pos("-",1) &gt; 0 then
		self.txtWOnDeckTier.lostFocus(self.txtWOnDeckTier);
	endif;
	if self.txtWUnderDeckCel.text.pos("-",1) &gt; 0 then
		self.txtWUnderDeckCel.lostFocus(self.txtWUnderDeckCel);
	endif;
	if self.txtWUnderDeckTr.text.pos("-",1) &gt; 0 then
		self.txtWUnderDeckTr.lostFocus(self.txtWUnderDeckTr);
	endif;

	// validate the values
	if not self.doValidateCellTierLabels(self.txtWOnDeckCells.text, "On Deck Cell", null) then
		return self.txtWOnDeckCells;
	endif;
	if not self.doValidateCellTierLabels(self.txtWOnDeckTier.text, "On Deck Tier", null) then
		return self.txtWOnDeckTier;
	endif;
	if not self.doValidateCellTierLabels(self.txtWUnderDeckCel.text, "Under Deck Cell", null) then
		return self.txtWUnderDeckCel;
	endif;
	if not self.doValidateCellTierLabels(self.txtWUnderDeckTr.text, "Under Deck Tier", null) then
		return self.txtWUnderDeckTr;
	endif;
	
	// PAR 18147
	if not self.doValidateTierLabels(self.txtWUnderDeckTr.text, false) then
		return self.txtWUnderDeckTr;
	endif;
	if not self.doValidateTierLabels(self.txtWOnDeckTier.text, true) then
		return self.txtWOnDeckTier;
	endif;
	
	if not self.validateBayLabelsWizard(self.txtWBayOrder.text,false) then
		app.msgBox("Physical Bay Order can only have zero filled numbered" &amp; Cr &amp; "bay IDs with space and comma separators." &amp;  // PAR 18147
						Cr &amp; "Bay IDs must be 2 characters in length.", "Physical Bay Order Problem", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.txtWBayOrder.setFocus();
		return self.txtWBayOrder;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="TextBox"/>
    </JadeMethod>
</GUIClass>
