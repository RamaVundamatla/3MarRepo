<Class name="CMIF_EDIBayPlan" id="394134f1-15f7-4e1a-92bd-ff1518d9fd41">
    <superclass name="CMIF_EDI"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <ImplicitInverseRef name="myEDIData" id="00bda5cb-28f3-4a24-a557-f5feaee8a7b5">
        <embedded/>
        <type name="CM_EDIData"/>
    </ImplicitInverseRef>
    <PrimAttribute name="voyageCode" id="749d048c-9a34-44d5-9da8-314366bceaca">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="processEDITIs" id="172b7168-2156-4797-8c13-2abd661bd8db">
        <updating/>
        <source>processEDITIs() updating;
//
// 08 Mar 2018	jlgrs1	TFS 37484 - QNS Allow DB Loading of Bay Plan files
//
vars
	terminal : CM_Terminal;
	voyage : CM_Voyage;
begin
	terminal := self.getMyTerminal();
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	
	voyage := terminal.lookupVoyage(self.voyageCode, null, false);
	if voyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, self.voyageCode, null, null);
		return;
	endif;
// PAR 33644	if voyage.isNonPlannedVoyage and voyage.myShipBlockStack = null then
	if not voyage.structureIncludesLOLO and voyage.myShipBlockStack = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Non-planned voyage without a ship block stack controller.');
		return;
	endif;
	if self.myEDIData.allEDITrackedItems.isEmpty then
		app.writeLog(class.name &amp; " " &amp; method.name &amp;  " no TI's found to load", LogINFO);
		return;
	endif;
	app.myTrxCA.trxCreateEDIBayPlanPartial(self.myEDIData, app.myPassport); 	// par 30064 Sep 2012	//ccms 1845
	if app.myPassport.noErrors then
		
		//epr par 37287 19/2/16 cargo notification requests were done on cargo create this caused problems for milaha
		// now its done on the baplie load and for milaha does the process stops edi automatically
/*		if self.myEDIData.status = CM_EDIFile.EDI_STATUS_DBLOADED and app.myRoot.isClientMilaha then
			app.myTrxUA.trxProcessStopsEDIOnShip(voyage, app.myPassport);
			app.myPassport.moveErrorsToSet(errorSet);
		endif;*/
		if voyage &lt;&gt; null then
			voyage.causeEvent(terminal.getTerminalEvent(Voyage_NewEDI_Event), true, null);
		endif;
	endif;
epilog
end;</source>
    </JadeMethod>
</Class>
