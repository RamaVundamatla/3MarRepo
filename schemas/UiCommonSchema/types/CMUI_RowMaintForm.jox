    <JadeMethod name="setVisibility" id="d693fb8b-6128-4353-99ea-7f059a4bb612">
        <source>setVisibility(_new : Boolean) protected;

vars

	view 	: String;

begin

	self.shtTblInput1.visible := false;
	if self.myCurrentRowController &lt;&gt; null or _new then
		self.shtTblInput1.visible := true;
		self.tblInput1.adjustHeight(1000);
		self.tblInput1.optimiseHeadingColumn();
		self.tblInput1.cnEcResizeContents();
	endif;
	if  self.mode &lt;&gt; self.Mode_Add and self.mode &lt;&gt; self.Mode_Update then
		doEnableControls(false);
	endif;
	self.tblInput1.setFocus;
end;</source>
        <access>protected</access>
        <Parameter name="_new" type="Boolean"/>
    </JadeMethod>
