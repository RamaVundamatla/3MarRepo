    <JadeMethod name="doSystemNotification" id="759ae850-a7f3-4dcb-94e5-395d49a587a0">
        <updating/>
        <source>doSystemNotification(_event: Integer; _xlation :CM_Xlation; _eventTag: Integer) updating;
/*
Date		Who		Reason
11 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	table			:CM_DataTable;
	row				:Integer;
	isSelected,
	gotException	:Boolean;	
begin
	on Exception do app.handleDeletedObject (exception, _xlation, gotException);
	
	table := self.tblData;

	if _event = Object_Delete_Event or _event = Object_Update_Event then
			
		table.findObjectInRow(_xlation, row);
	
		if row &lt;= table.fixedRows then
			// if an outward xlation has inwards xlation(s) then it wont have its own row in the table
			// if the outward translation were deleted or updated then any associated inward translations would have 
			// cause an update notification event
			return;
		endif;
		
		isSelected := (row = table.row);
		
		if _event = Object_Delete_Event then
			table.removeItem(row); 
			
			self.doNotableRemove (_xlation);
		else
			table.setCellText (row, 1, _xlation.getAttributeStringForDefArray(table.allTblDataEntRows));
		endif;
		
		if isSelected then					
			table.row := table.fixedRows;
			
			table.clearAllSelected;			
			
			self.doTblDataRowColChange (table);	
			
			self.showNumberOfItems (table);	
		else
			self.doTblDataRowColChange (table);	
		endif;
		
		
	elseif _event = Object_Create_Event then	
		if _xlation.isKindOf (CM_Xlation_Out) then
			// need to handle differently - if this is the first outward xlation and there
			// are inward xlations for the same system code then the inwards will have caused an update notification event.
			return;
		endif;
		if not self.includeObject (_xlation) then
			return;
		endif;
		
		if gotException then
			return;
		endif;
		
		self.doQueryAddItem (table, _xlation, null);
		
		if table.allSelectedObjects.size = 0 then
			self.showNumberOfItems (table);		
		else									
			self.showSelectedCount(table.allSelectedObjects.size, table.rows-table.fixedRows);
		endif;									
	endif;
epilog

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_xlation" type="CM_Xlation"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDBClick" id="c9cf95f2-9ff6-4456-966f-5fe35c485f53">
