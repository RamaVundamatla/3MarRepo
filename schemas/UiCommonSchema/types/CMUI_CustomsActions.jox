    <JadeMethod name="doSearch" id="75e7756c-4866-47a2-9eea-2e0c00724373">
        <updating/>
        <source>doSearch() updating;
// ---------------------------------------------------------------------------
// Created:	29 September 2008 By Graeme Black cnwgb1
// 19/07/2016 cnwma1 TFS2341 PAR37816 JMT - Error on doing Customs Actions Search
// ---------------------------------------------------------------------------
vars
	ediFileTypeClass : CM_EDIFileType;
	obj : Object;
begin
	if self.cmbFileType.listIndex &gt; -1 then    //19/07/2016 cnwma1  TFS2341 PAR37816
		obj := self.cmbFileType.itemObject[self.cmbFileType.listIndex];
	endif;
	if obj &lt;&gt; null then
		ediFileTypeClass := obj.CM_EDIFileType;
	endif;
	if ediFileTypeClass &lt;&gt; null then
		self.ediFileType := ediFileTypeClass.type;
	endif;
	self.showTable();

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateTable" id="9db58d8d-b4e7-4be1-8a05-d9d6d078c278">
        <updating/>
        <source>doUpdateTable(_actionObject: CM_EDIAction; _eventTag : Integer) updating;
// ---------------------------------------------------------------------------
// Created:	18 September 2008 By Graeme Black cnwgb1
// Purpose:	
// ---------------------------------------------------------------------------
vars
	anAction : CM_EDIAction;
	aRow : Integer;
begin
	if _eventTag = Object_Delete_Event then
		self.showTable();
	elseif _actionObject.myEDIFileType.type = self.ediFileType then
		if _eventTag = Object_Update_Event then
			if self.tblActions.findObjectInRow( _actionObject, aRow ) then
				self.tblActions.updateItemObject(_actionObject, null , null, app.myPassport); // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
			endif;
		elseif _eventTag = Object_Create_Event then
				self.tblActions.row := self.tblActions.addItemObject(_actionObject, _actionObject.getAttributeStringForDefArray(self.tblActions.allTblDataEntRows)); // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
			self.setTableColors(0);
		endif;
	endif;
epilog
end;</source>
        <Parameter name="_actionObject" type="CM_EDIAction"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="cef0e837-21e7-4302-af7b-203e74a17d05">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:	30 September 2008 By Graeme Black cnwgb1
// Purpose:	
// ---------------------------------------------------------------------------
vars
	rtnStr : String;
	myString : String; 
begin
	rtnStr :=  inheritMethod();
	myString := "&lt;EDI_FileType&gt;"	&amp; self.ediFileType.asStringJMT() &amp; "&lt;/EDI_FileType&gt;" ;
	return rtnStr &amp; myString;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleSystemNotification" id="195274b7-be8b-4054-b9e6-565d97508573">
        <updating/>
        <source>handleSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		20 November 2009
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// 20/11/2009   cnwsh3		Moved from CMUI_CustomsAction::sysNotify
//----------------------------------------------------------------------
//04/12/2019 JLGNS1 Bug 47819: PEN - Minor issues found during testing of 46721
vars
	theRow : Integer;
	str : String;
	backColour : Integer;
	table : CM_DataTable;
begin
	if CM_EDIAction.hasInstance(theObject) then
		table := self.tblActions;
		if eventType = Object_Delete_Event then
			table.findObjectInRow(theObject, theRow);
			if table.removeDeletedObject(theObject) then
				if table.rows &gt; table.fixedRows then
					if (theRow - 1) &gt; table.fixedRows then
						theRow := theRow - 1;
					endif;
					table.selectRow(theRow, false);
				endif;
			endif;
		elseif eventType = Object_Create_Event then
		
			//27 Sep 2018	NDL	TFS 41141
			if self.ediFileType = null
			or theObject.CM_EDIAction.myEDIFileType.type &lt;&gt; self.ediFileType
			then
				return;
			endif;
			
			str := theObject.CM_EDIAction.getAttributeStringForDefArray(table.allTblDataEntRows);
			theRow := table.addItemObject(theObject, str);
			if theRow mod 2 = 0 then
				backColour := self.colorRow1;
			else
				backColour := self.colorRow2;
			endif;
			table.accessedRow.backColor := backColour;
		elseif eventType = Object_Update_Event then
			 
			table.updateItemObject(theObject,self.colorRow1,self.colorRow2,app.myPassport);//Bug 47819
			
		endif;
		
	endif;
	//self.doUpdateTable( theObject.CM_EDIAction, eventTag );
epilog
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
