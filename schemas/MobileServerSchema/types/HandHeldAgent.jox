    <JadeMethod name="listBoxRailLine" id="78e67385-9720-426d-9119-e84b634ffae8">
        <source>listBoxRailLine(_lstBox: ListBox input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	
	taIter 		: Iterator;
	railLine 	: CM_RailLine;
	taDict		: CM_TAByTypeIdDict;
	taIdKey		: String;
	taTypeKey	: Integer;
	ta			: CM_TerminalArea;
begin
	if _lstBox = null then
		return;
	endif;
	taDict := self.myTerminal.allTerminalAreasByTypeId;
	taIter := taDict.createIterator;
	taDict.startKeyGeq(TA_TYPE_RAILWAY_TRACK, null, taIter);
	
	while taIter.next(ta) do
		taDict.getIteratorKeys(taTypeKey, taIdKey, taIter);
		if taTypeKey &lt;&gt; TA_TYPE_RAILWAY_TRACK then
			break;
		endif;
		
		foreach railLine in ta.CM_Rail.allRailLinesByIndex do
			_lstBox.itemObject[_lstBox.addItem(ta.id &amp; ' ' &amp; railLine.id)] := railLine;
		endforeach;
		
	endwhile;
	
	
epilog
	delete taIter;
end;</source>
        <Parameter name="_lstBox" type="ListBox" usage="input"/>
    </JadeMethod>
