    <JadeMethod name="getTableTaskType" id="1a527f27-36be-48d9-bc1d-242348314e95">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::getTableTaskType"/>
        </interfaceImplements>
        <source>getTableTaskType(_table : Table input) : Integer;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwer1	Initial creation

*/

vars

begin
	if _table = self.tblTasks then
		return TASK_UNACTIONED;
	elseif _table = self.tblGetNext then
		if app.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.GETNEXT_TASK then
			return NULL_INTEGER;
		elseif app.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.ACCEPT_TASK then
			return TASK_OFFERED;
		else
			return TASK_WORKING;
		endif;
	elseif _table = self.tblMoveInfo then
		return TASK_WORKING;
	endif;

epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
