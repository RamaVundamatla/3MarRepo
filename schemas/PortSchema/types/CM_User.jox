    <JadeMethod name="setPassword" id="5c59cfd6-bdbd-42ab-bf29-1bbcb8015241">
        <updating/>
        <source>setPassword(_value : String; _checkRecentlyUsedPasswords : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:			06 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------	----------		--------------------------------------------------
// 18 Sep 2019	jlgdi1			Added JMTSupportUser to skip password validation
// 21 Sep 2020  cnwma1 			ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data
// 04 Feb 2025	navah1			Story 14660: MTN - New option to disable users from changing their own passwords
// ---------------------------------------------------------------------------
vars
	passwordBin, b  : Binary;
	newPword,msg	: String;
begin
	
	if self.isInternalSystemUser() then  //21.09.2020 cnwma1 TFS #49758
		return;
	endif;
	
	if not self.canChangePassword() then 	//04.02.2025 navah1 #14660
		app.raiseCMException1(PasswordChangeProhibited, self.code, null, null);
		return;
	endif;
	
	newPword := _value;//.toUpper();
	self.validatePassword(newPword);
	if (not self.isPasswordStrong(newPword)) then
		app.setContinueCMExceptions(false);
		
		app.raiseCMException1(Your_passwor_must_follows, app.myRoot.getPasswordDescription(), null, null);
		return;	
	endif;
	
	passwordBin	:=	app.encryptPassword(self.code, newPword, self.isNewEncryptionImplemented);
	
//	if self.isRecentlyUsedPassword(newPword) then
	if _checkRecentlyUsedPasswords and self.isRecentlyUsedPassword(newPword) then	// PAR12487	27/09/2006	cnwvu1
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_PASSWORD_UNCHANGED, null, null);
		return;		
	endif;
	
	// This method should be used only to update persistents
	self.raiseExceptionIfTransient(method);
	// Lock self before comparing values to ensure we have the latest edition.
	// We assume that we're called within a transaction, so the lock will be
	// released at commit/abort transaction.
	exclusiveLock(self);
	
	if self.currentPassword &lt;&gt; passwordBin then
		
		// Password has changed, so record the timestamp
		self.datePassword	:=	app.actualTimeServer();
		
		// Add the current password to the history list
		if self.recentPasswords.size &gt;= app.myRoot.getConfig(NumberOfPrevPasswords).Integer
		and self.recentPasswords.size &gt; 0
		then
			// The history list is full, so get rid of the oldest one
			self.recentPasswords.removeAt(self.recentPasswords.size);
		endif;
		
		if self.recentPasswords.isEmpty() then
			self.recentPasswords.add(self.currentPassword);
		else
			// Insert the current password at the front of the list
			self.recentPasswords.insert(1, self.currentPassword);
		endif;
		
//		app.myAA.auditUpdate(self, "currentPassword", self.currentPassword);
		app.myAA.auditUpdate(self, CM_User::datePassword.name, self.datePassword); //cnwrs1 aug 2006 should be showing encryted password
		self.currentPassword	:=	passwordBin;
		
		self.isUseStrongPassword := true;
	endif;
	
	// Assume that if a new user and user is self then this is the user 
	// logging in for first time and changing and not from user-maintenance
	// where password is being set.
	if self.status = NewUser and app.getMyUser() = self then
		self.updateStatus(EnabledNormalUser); 		
	endif;
end;</source>
        <Parameter name="_value" type="String"/>
        <Parameter name="_checkRecentlyUsedPasswords" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPreventPasswordChange" id="7c5698b7-d948-4866-92d2-32b9ee8b03c5">
