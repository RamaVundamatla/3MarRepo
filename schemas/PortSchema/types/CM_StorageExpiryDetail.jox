    <JadeMethod name="setStorageExpDetail" id="14188271-c25b-4ccc-b5cb-d28b168da5bb">
        <updating/>
        <source>setStorageExpDetail(_actionDate 	: Date; 
					_ti 			: CM_TrackedItem;
					_storageDetail  : CM_StorageDetail) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
23 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	freeStDays 		: Integer;
	operator  		: CM_Operator;
	oprCode   		: String;
	transaction 	: CM_TITransaction;
	totalQty 		: Integer;
	totalWt,
	totalVol 		: Decimal[14,4];
	storageDetail   : CM_StorageDetail;
	freeDaysType,
	chargedDaysType : Integer;
	dateTime, 
	lastFree 		: TimeStamp;
begin
	self.setTrackedItem(_ti);
	
	if _actionDate &lt;&gt; null then
		dateTime := _actionDate.asTimeStamp;
	endif;
	
	if _storageDetail = null then										//23.05.2024 navma1 #64224
		storageDetail := _ti.getMatchingFreeStorageDetail( null );
	else
		storageDetail := _storageDetail;
	endif;
	
	if storageDetail &lt;&gt; null and _ti.isOnSite() then
		freeDaysType    := storageDetail.freeDaysType;
		chargedDaysType := storageDetail.chargedDaysType;
		freeStDays 		:= storageDetail.freeStorageDays;
	else
		freeDaysType    := self.freeDaysType;
		chargedDaysType := self.chargedDaysType;
		freeStDays 		:= self.freeStorageDays;
		// ### TFS BUG 64221 21MAY2024 NAVAB1 storageDetail := self.myStorageDetail;
	endif;
	
	operator := _ti.getReceiveOperator();
	if operator &lt;&gt; null then
		oprCode := operator.code;
	endif;
	transaction := _ti.allTransactions.findFirstReceivalTrans();
	if transaction &lt;&gt; null then
		totalQty := transaction.totalQuantity;
		totalWt  := transaction.totalWeight;
		totalVol := transaction.totalVolume;
		if dateTime = null then
			dateTime := transaction.dateTime;
		endif;
	endif;
	
	self.setFreeDaysType(freeDaysType);
	self.setFreeStorageDays(freeStDays);
	
	lastFree := _ti.deriveFreeStorageDateTime(); // ### TFS BUG 60548 09OCT2023 NAVAB1 getLastFreeStorageDateTime();
	self.setProxy(self.additionalStorageDays,
				  dateTime,
				  self.freeDays,
				  freeDaysType,
				  null,
				  freeStDays,
				  self.freeStorageDaysRemaining,
				  lastFree,
				  self.futureStorageAnniversary,
				  self.incoTermsCode, 
				  self.myOwnershipChange, 
				  storageDetail,
				  _ti, 
				  oprCode,
				  self.operatorForBillingCode, 
				  self.storageChangeReason,// ### TFS BUG 60548 09OCT2023 NAVAB1
				  totalQty, 
				  totalVol, 
				  totalWt, 
				  chargedDaysType);
epilog

end;</source>
        <Parameter name="_actionDate" type="Date"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_storageDetail" type="CM_StorageDetail"/>
    </JadeMethod>
