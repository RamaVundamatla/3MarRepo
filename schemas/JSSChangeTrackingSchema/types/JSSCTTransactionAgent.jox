    <JadeMethod name="transientHandler" id="3770a574-713a-4a4a-9716-ddd1aff6d72e">
        <source>transientHandler(pTheException:Exception):Integer protected;
/*
		This method is not intended to show how to do exception handling.
		It is included only to complete the general strategy.
*/
begin
	/*
		a simple way of showing any exceptions that occur in this transaction agent approach demo
							NOT TO BE USED IN A REAL APPLICATION
	*/
	self.dumpCallStack(self.class.name);
	if pTheException.currentMethodDesc = null then
write self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp; pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " occurred.";
	else
write self.class.getName() &amp; "::" &amp; method.name &amp; " " &amp; pTheException.errorCode.String &amp; " - " &amp; pTheException.text &amp; " occurred in " &amp; pTheException.currentMethodDesc.method.name;
	endif;
	// Abort the transaction (does nothing if not in transaction state).
	abortTransientTransaction;

	// Abort the operation.
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateProcessDisplay" id="ff2182f8-0ef5-42d6-a07b-cba80c10a04e">
        <source>trxUpdateProcessDisplay(pUserInfo: String; pAdminInfo: String);
/*
*/
begin
   	beginTransaction;
   	process.userInfo := pUserInfo;
   	process.adminInfo := pAdminInfo;
   	commitTransaction;
end;</source>
        <Parameter name="pUserInfo" type="String"/>
        <Parameter name="pAdminInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="tryLockingObject" id="f3c3e60a-9f64-4251-a690-e837f0f551f6">
        <source>tryLockingObject(pObject: Object): Boolean protected;
/*
	Try to get a lock on the Object, or return false after trying 1000 times
*/
/*

Date		Who		Reason
22 May 2009	cnwkpd1	CCMS SFW 1007 - Rework to just queue on the lock for 100 seconds

*/

vars
//	count: Integer;
begin
	return self.tryLock(pObject, Exclusive_Lock, Transaction_Duration, 100 * 1000);
	
/*	
	while not self.tryLock(pObject, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate)	do
		count := count + 1;
		if count &gt; 1000 then
			return (false);
		endif;
		process.sleep(100);	//	let it rest for 100 milliseconds
	endwhile;
	return (true);
*/
end;</source>
        <access>protected</access>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateEntity" id="1ab9ef8d-812f-427a-b859-eed2aeb792d9">
        <updating/>
        <source>updateEntity(): Boolean updating;
/*
*/
begin
	on Exception do self.xHandler(exception);
	on DeadlockException do self.xHandlerDeadlock(exception);
	on LockException do self.xHandlerLock(exception);

	if self.doValidate(self.JSSM_TRX_UPDATE) then
		if self.lockEntity() then
			beginTransaction;

			if self.doUpdate() then
				commitTransaction;
			else
				abortTransaction;
				return false;
			endif;
		endif;
	else
		return false;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
