    <JadeMethod name="xGetWLEs" id="45933936-d434-4620-944c-d734739cb493">
        <source>xGetWLEs(_voyage : CM_Voyage; _job : CM_VoyageJob; _wleSet : CM_WLESet io; _mode : Integer);

/*

Purpose:		Get the wles

Date			Who		Reason
21/03/2014		cnwmh5	Initial creation

*/

vars

	jobSheet						: CM_JobSheet;
	job								: CM_Job;
	wle								: CM_WorkListEntry;
	ti								: CM_TrackedItem;

begin

	foreach jobSheet in _voyage.allJobSheets discreteLock do
		foreach job in jobSheet.allJobsByOrder discreteLock do
			if _job &lt;&gt; null and job &lt;&gt; _job then
				continue;
			endif;
		//	if job.jobType = JOB_TYPE_DISCHARGE then
				if self.opts.includesKey("LoadedToOperations") and not job.CM_VoyageJob.isLoadedToOperations then
					continue;
				endif;
				foreach wle in job.workListEntries discreteLock do
					if wle.status = WLE_COMPLETED then
						continue;
					endif;
					if _mode = NO_MODE then
						if wle.isQueued() or wle.myFutureMove &lt;&gt; null then
							continue;
						endif;
					elseif (_mode = PLANNING_MODE or _mode = QUEUE_MODE) and wle.myFutureMove = null then
						continue;					
					endif;
					ti := wle.myTrackedItem;
					if ti = null then
						continue;
					endif;
					
					if not _wleSet.includes(wle) then
						_wleSet.add(wle);
					endif;
				endforeach;
			//elseif job.jobType = JOB_TYPE_LOAD then
			//endif;
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_wleSet" type="CM_WLESet" usage="io"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xGetWLEsToAutoPlan" id="677fd7e0-cd80-4812-b693-0d81be8b38e5">
        <source>xGetWLEsToAutoPlan(_voyage : CM_Voyage; _job : CM_VoyageJob; _wleSet : CM_WLESet io);

/*

Purpose:		Get the wles for ti's to autoplan

Date			Who		Reason
21/03/2014		cnwmh5	Initial creation

*/

vars

	jobSheet						: CM_JobSheet;
	job								: CM_Job;
	wle								: CM_WorkListEntry;
	ti								: CM_TrackedItem;

begin

	foreach jobSheet in _voyage.allJobSheets discreteLock do
		foreach job in jobSheet.allJobsByOrder discreteLock do
			if _job &lt;&gt; null and job &lt;&gt; _job then
				continue;
			endif;
			if job.jobType = JOB_TYPE_DISCHARGE then
				if self.opts.includesKey("LoadedToOperations") and not job.CM_VoyageJob.isLoadedToOperations then
					continue;
				endif;
				foreach wle in job.workListEntries discreteLock do
					if wle.status = WLE_COMPLETED or  wle.isQueued() or wle.myFutureMove &lt;&gt; null then
						continue;
					endif;
					ti := wle.myTrackedItem;
					if ti = null then
						continue;
					endif;
					
					if not _wleSet.includes(wle) then
						_wleSet.add(wle);
					endif;
				endforeach;
			endif;
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_job" type="CM_VoyageJob"/>
        <Parameter name="_wleSet" type="CM_WLESet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xImportWagonClass" id="97abb624-b2af-445a-8f8c-f9d7ddb146f6">
        <executionLocation>server</executionLocation>
        <source>xImportWagonClass() serverExecution;

/*

Purpose:		Import Wagon(s) Class from file

Date			Who		Reason
15/04/2014		cnwmh5	Initial creation

*/

vars

	file						: File;
	wagonClass					: CM_WagonClass;
	

begin

	// delete wagon class
	wagonClass := app.myRoot.allWagonClasses["UTMH1"];
	self.assertNotNull(wagonClass);
	self.deleteWagonClassAndWagons(wagonClass);
	wagonClass := app.myRoot.allWagonClasses["UTMH2"];
	self.assertNotNull(wagonClass);
	self.deleteWagonClassAndWagons(wagonClass);

	// write the details to a file
	create file transient;
	file.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := app.cnGetServerMiscPath() &amp; "\UTWagonClassImport.csv";
	file.usePresentationFileSystem := false;
	if file.isAvailable() then
		file.purge;
	endif;
	
	file.writeLine('Code,Doors accessible,Accepts generator,Maximum cargo weight lbs,Maximum number in stack,Length in 10 Foot units,Location IDs,' &amp; 
		'Not Available For Entry,Deck height m,Maximum cargo height m,Tare weight lbs,Carrier,Internal Height m,Intenal Length m,Internal Width m,' &amp; 
		'Overall Height m,Overall Length m,Overall Width m,Wagon Type');				// header line
	file.writeLine('UTMH1,1,0,165347,1,1,1,0,,,14330,,3.89,18.3,2.7,4,19,2.9,2');   			// Boxcar
	file.writeLine('UTMH2,1,1,94799,1,6,"01 02 03 04 05 06",1,0.01,0.01,2,ACE,,,,,,,1');	// Flatcar
	file.close();
	
	// import the file
	file.kind := File.Kind_Unknown_Text;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	file.mode := File.Mode_Input;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	app.myTrxCA.trxImportWagonClassFromFile(file, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	wagonClass := app.myRoot.allWagonClasses["UTMH1"];
	self.assertNotNull(wagonClass);
	self.assertEqual(wagonClass.wagonType, 2);
	self.assertEqual(wagonClass.doorsAccessible, false);
	self.assertEqual(wagonClass.acceptsGenerator, false);
	
	wagonClass := app.myRoot.allWagonClasses["UTMH2"];
	self.assertNotNull(wagonClass);
	self.assertEqual(wagonClass.wagonType, 1);
	self.assertEqual(wagonClass.doorsAccessible, true);
	self.assertEqual(wagonClass.acceptsGenerator, true);
	
epilog

	delete file;

end;</source>
    </JadeMethod>
    <JadeMethod name="xLoadStuffBackToVoyage" id="401dc568-a007-451d-a534-6e0b61e3d1bd">
        <source>xLoadStuffBackToVoyage(_voyage : CM_Voyage);

/*

Purpose:		Load Stuff back to the voyage and do machine stuff

Date			Who		Reason
25/03/2014		cnwmh5	Initial creation

*/

vars

	voyageJob 					: CM_VoyageJob;
	tmpLoadCC					: CMIF_LoadColorCode;
	forklift					: CM_Machine;
	queueEntry					: CM_RTQueueEntry;
	queueTask					: CM_RTQueueTask;
	mediator 					: CM_RadioTelemetryMediator;
	ti							: CM_TrackedItem;
	wle							: CM_WorkListEntry;
	pxyMachine					: CM_Machine;
	stowageController 			: CMIF_StowageConfirmController;
	newTITxn 					: CM_TITransaction;	
	newQueue 					: CM_RadioTelemetryQueue;
	blockStack					: CM_BlockStack;
	moveController				: CMIF_MoveController;

	slots 						: CM_SlotControllerArray;
	lcs							: CM_LCArray;
	theTIs						: CM_TIArray;
	avGrades					: IntegerArray;
	wleSet						: CM_WLESet;
	wleArray					: CM_WLEArray;
	queueTasks					: CM_RTQueueTaskArray;	
	
	tiId						: String;
	index 						: Integer;
	
begin
	
	
	
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType := true;
	tmpLoadCC.myDischargePort := app.myRoot.allPorts["NZAKL"];
	
	create slots transient;
	create lcs transient;
	create theTIs transient;
	create wleSet transient;
	
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "21", DeckUnderDeck, 2, 1, 7, slots);
	self.markSlotsAsLoadCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRN1", slots, false);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.planTIsLOLO(null, slots, _voyage, true);
	self.xGetWLEs(_voyage, voyageJob, wleSet, QUEUE_MODE);
	
	self.opts.purge();
	self.opts.addAssoc("ISOGroup", "UT20");
	self.opts.addAssoc("Voyage", _voyage);
	self.opts.addAssoc("DischargePort", "NZNSN");
	self.opts.addAssoc('Number', 7);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "21", DeckUnderDeck, 3, 1, 7, slots);
	self.markSlotsAsLoadCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRN1", slots, false);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.planTIsLOLO(null, slots, _voyage, true);
	self.xGetWLEs(_voyage, voyageJob, wleSet, QUEUE_MODE);
	
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "21", DeckUnderDeck, 4, 1, 7, slots);
	self.markSlotsAsLoadCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRN1", slots, false);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.planTIsLOLO(null, slots, _voyage, true);
	self.xGetWLEs(_voyage, voyageJob, wleSet, QUEUE_MODE);
	
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "21", DeckUnderDeck, 5, 1, 7, slots);
	self.markSlotsAsLoadCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRN1", slots, false);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.planTIsLOLO(null, slots, _voyage, true);
	self.xGetWLEs(_voyage, voyageJob, wleSet, QUEUE_MODE);
	
	self.opts.purge();
	self.opts.addAssoc("ISOGroup", "UT20");
	self.opts.addAssoc("Voyage", _voyage);
	self.opts.addAssoc("DischargePort", "NZLYT");
	self.opts.addAssoc('Number', 7);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "21", DeckUnderDeck, 6, 1, 7, slots);
	self.markSlotsAsLoadCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRMH", slots, false);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.planTIsLOLO(null, slots, _voyage, true);
	self.xGetWLEs(_voyage, voyageJob, wleSet, QUEUE_MODE);
	
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "21", DeckUnderDeck, 7, 1, 7, slots);
	self.markSlotsAsLoadCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRMH", slots, false);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.planTIsLOLO(null, slots, _voyage, true);
	self.xGetWLEs(_voyage, voyageJob, wleSet, QUEUE_MODE);
	
	self.opts.purge();
	self.opts.addAssoc("ISOGroup", "UT20");
	self.opts.addAssoc("Voyage", _voyage);
	self.opts.addAssoc("DischargePort", "NZCHC");
	self.opts.addAssoc('Number', 7);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "21", DeckUnderDeck, 1, 1, 7, slots);
	self.markSlotsAsLoadCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRMH", slots, false);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.planTIsLOLO(null, slots, _voyage, true);
	self.xGetWLEs(_voyage, voyageJob, wleSet, QUEUE_MODE);
	
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "21", DeckUnderDeck, 8, 1, 7, slots);
	self.markSlotsAsLoadCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRMH", slots, false);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	self.planTIsLOLO(null, slots, _voyage, true);
	self.xGetWLEs(_voyage, voyageJob, wleSet, QUEUE_MODE);
	
	self.loadAllJobsToOps(_voyage, true);
	
	app.isRTApp := true;  
	forklift := self.getMachine("UTTU");
	self.machineLogon(forklift);
	
	// queue all wles
	foreach wle in wleSet do
		self.queueWLE(wle);
	endforeach;	
	
	create queueTasks transient;
	
	
	create wleArray transient;
	wleSet.copy(wleArray);
	
	queueEntry := wleArray[1].allRTQueueEntries.first;
	self.assertNotNull(queueEntry);
	voyageJob := queueEntry.myJob.CM_VoyageJob;
	self.assertNotNull(voyageJob);
	ti := queueEntry.myWorkListEntry.myTrackedItem;
	queueTask := queueEntry.allTasks.first;
	self.assertNotNull(queueTask);	
	
	self.machineAcceptSpecifiedTask(forklift, queueEntry);
	
	self.expectedTrxErrors.clear();
	self.expectedTrxErrors.add(WARN_JOB_LOADED);
	self.expectedTrxErrors.add(WARN_TI_SEQUENCED);
	
	create mediator transient;
	mediator.machine := forklift;
	mediator.task := forklift.currentQueueTask;
	mediator.setActiveTerminal(self.getTerminal());
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxRT.trxPickupWithTask(mediator, null, true, null, 0, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
		
	mediator.myCurrentTi := ti;
	app.myTrxRT.trxMoveTI(queueTask.myEntry.myWorkListEntry.getTargetLocation().getID(), null, mediator, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti.isOnShip(), true);
	self.assertEqual(_voyage.allOnshipTIsByIdCargoType.size, 1);
	
	create stowageController transient;
	stowageController.type := TRANS_TYPE_STOWAGE_CONFIRM;
	stowageController.dateTime := app.cnGetServerTime;
	stowageController.noCharge := true;
	stowageController.userId  := app.myPassport.userCode;
	stowageController.confirmedLocation := ti.myPrimaryActualLocation.getID() &amp; "1";
	stowageController.myVoyageJob := voyageJob;
	stowageController.isForVoyage := true; // ### TFS CR 56806 TASK 56807 01MAR2023 NAVAB1
	stowageController.myTerminal := self.getTerminal();
	stowageController.myTrackedItem := ti;
	app.myPassport.warningsAcknowledged := true;  
	app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateStowageConfirmation(stowageController, newTITxn, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(newTITxn.isKindOf(CM_StowageConfirmation), true);
		
	// trxPickUp / Reject
	
	queueEntry := wleArray[2].allRTQueueEntries.first;
	self.assertNotNull(queueEntry);
	ti := queueEntry.myWorkListEntry.myTrackedItem;
	queueTask := queueEntry.allTasks.first;
	self.assertNotNull(queueTask);	
	
	mediator.machine := forklift;
	mediator.task := null;
	mediator.myCurrentTi := ti;
	mediator.setActiveTerminal(self.getTerminal());
	
	
	
	self.machineAcceptSpecifiedTask(forklift, queueEntry);
	
	mediator.machine := forklift;
	mediator.task := forklift.currentQueueTask;
	mediator.myCurrentTi := ti;
	mediator.setActiveTerminal(self.getTerminal());

	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxRT.trxRejectTask(mediator, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(_voyage.allOnshipTIsByIdCargoType.size, 1);
	self.assertEqual(forklift.rejectedRTQueueTasks.size, 1);
	
	queueTasks.clear();
	queueTasks.add(queueTask);
	app.myTrxUA.trxUpdateMachineRejectedRTTsks(forklift, queueTasks, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(forklift.rejectedRTQueueTasks.size, 0);
	
	
	// trxPickUp / trxSetdown
	
	queueEntry := wleArray[3].allRTQueueEntries.first;
	self.assertNotNull(queueEntry);
	ti := queueEntry.myWorkListEntry.myTrackedItem;
	queueTask := queueEntry.allTasks.first;
	self.assertNotNull(queueTask);	
		
	self.machineAcceptSpecifiedTask(forklift, queueEntry);
	
	mediator.machine := forklift;
	mediator.task := forklift.currentQueueTask;
	mediator.myCurrentTi := ti;
	mediator.setActiveTerminal(self.getTerminal());
	app.myTrxRT.trxUpdateGradeForTI(13, mediator, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti.CM_Container.availabilityGrade, 13);
	

	
	
	// trxAccept
	
	queueEntry := wleArray[4].allRTQueueEntries.first;
	self.assertNotNull(queueEntry);
	ti := queueEntry.myWorkListEntry.myTrackedItem;
	queueTask := queueEntry.allTasks.first;
	self.assertNotNull(queueTask);	
		
	mediator.machine := forklift;
	mediator.task := forklift.currentQueueTask;
	mediator.myCurrentTi := ti;
	mediator.setActiveTerminal(self.getTerminal());
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxRT.trxAcceptTask(mediator, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxRT.trxSetMediatorState(mediator, RadioTelemetryAgent.AcceptedTask, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(mediator.state, RadioTelemetryAgent.AcceptedTask);
	
	queueTasks.clear();
	queueTasks.add(queueTask);	
	app.myTrxRT.trxChangeAllTasksStatus(queueTasks, forklift, TASK_USER_HELD, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(queueTask.status, TASK_USER_HELD);
	
	app.myTrxRT.trxChangeAllTasksStatus(queueTasks, forklift, TASK_UNACTIONED, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(queueTask.status, TASK_UNACTIONED);
	
	
	ti := wleArray[8].allRTQueueEntries.first.myWorkListEntry.myTrackedItem;
	mediator.myCurrentTi := null;
	app.myTrxRT.trxEnqTrackedItem(ti.id, mediator, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(mediator.myCurrentTi, ti);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Err_TrackedItemsNotFound);
	mediator.myCurrentTi := null;
	app.myTrxRT.trxEnqTrackedItem("SHIPZ112231", mediator, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(self.expectedTrxErrorFound, true);
	self.assertEqual(mediator.myCurrentTi, null);
	
	
	mediator.myOnHoldTask := queueTask;
	mediator.isOnHold := true;
	app.myTrxRT.trxManipulateOnHold(false, mediator, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(mediator.isOnHold, false);
	self.assertEqual(mediator.myOnHoldTask, null);

	app.myPassport.setWarningsIgnored(false);
	app.myPassport.setWarningsAcknowledged(false);
	
	pxyMachine := app.createUpdateProxy(forklift).CM_Machine;
	app.myTrxUA.trxUpdateRTResetMediator(pxyMachine, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(forklift.loggedOn, false);
	
	
	queueEntry := wleArray[10].allRTQueueEntries.first;
	self.assertNotNull(queueEntry);
	
	newQueue := self.getQueue("MASTER");
	self.moveRTTask(queueEntry, newQueue);
	self.assertEqual(queueEntry.myQueue.id, "Master Queue");
	
	self.machineLogOff(forklift);
	
	// plan stuff to the ship
	blockStack := self.getTerminalArea("UTMHBSH").CM_BlockStack;
	self.assertNotNull(blockStack);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "07", DeckUnderDeck, 3, 1, 7, slots);
	self.markSlotsAsLoadCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageJob := self.addVoyageJob(_voyage, "CRN1", slots, false);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(voyageJob);
	app.myTrxUA.trxUpdateSlotControllerUnplan(PLANNING_MODE, slots.first, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(slots.first.allPlannedFutureMoves.size, 0);
	
	blockStack := self.getTerminalArea("UTMHBSH").CM_BlockStack;
	self.assertNotNull(blockStack);
	
	// trxMoveTrackedItemsAssignToJob
	
	lcs.clear();
	theTIs.clear();
	slots.copy(lcs);
	
	tiId := "UTYARDMH";
	self.opts.purge();
	self.opts.addAssoc("Voyage", _voyage);
	foreach index in 1 to lcs.size step 1 do
		ti := self.addContainerAtLocation(tiId &amp; index.String.padLeadingZeros(3), _voyage.myOperator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, 
			blockStack.getMyLocationsController());
		self.assertNotNull(ti);
		theTIs.add(ti);
		self.updateTI(ti);
		self.deleteStops(ti);
	endforeach;
	
	create moveController transient;
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isForcedMove := true;
	lcs.copy(moveController.allToLocations);
	moveController.setMyTrackedItem(theTIs.first);
	moveController.mySlotRequest := lcs.first.getRequest(true).CM_SlotRequest;
	moveController.moveTrackedItemsSource(self.getTerminal(), theTIs);
	
	foreach ti in theTIs do
		self.assertNotNull(ti.myPrimaryPlannedLocation);
	endforeach;
	
epilog

	app.isRTApp := false;

	delete mediator;
	
	delete avGrades;
	delete tmpLoadCC;
	delete slots;
	delete lcs;
	delete theTIs;
	delete wleSet;
	delete wleArray;
	delete queueTasks;
	delete pxyMachine;
	delete stowageController;
	delete moveController;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xRORODeckOrdinal" id="aabad874-d18d-472e-9e5f-58cd9ae1e5a0">
        <source>xRORODeckOrdinal(_voyage : CM_Voyage);

/*

Purpose:		trxUpdateRORODecksOrdinal

Date			Who		Reason
24/03/2014		cnwmh5	Initial creation

*/

vars

	deck						: CM_DeckVoyage;
	obj							: Object;
	pxyDeck						: CM_DeckVoyage;
	
	pxyDecks					: CM_DeckVoyageByOrdDict;
	
	deckOrder					: String;
	ordinal1					: Integer;
	ordinal2					: Integer;
	loadState					: Boolean;

begin

	create pxyDecks transient;
	app.cmsBeginLoad(loadState);
	foreach deck in _voyage.myROROStructure.allDecks do	
		pxyDeck := deck.pxyCreateUpdateProxy();
		pxyDeck.setOrdinal(deck.ordinal);
		pxyDecks.add(pxyDeck);
	endforeach;
	app.cmsEndLoad(loadState);
	
	ordinal1 := pxyDecks.first.ordinal;
	ordinal2 := pxyDecks.last.ordinal;
	pxyDecks.moveElement(ordinal2, ordinal1, deck, true);
	
	app.myTrxUA.trxUpdateRORODecksOrdinal(pxyDecks, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	
	foreach deck in _voyage.myROROStructure.allDecks do
		deckOrder := deckOrder.trimBlanks() &amp; deck.description;
	endforeach;
	
	self.assertEqual(deckOrder, "LOWER HOLDMAIN DECKGARAGE DECKTWEEN DECKUPPER DECK");
	
epilog

	app.cmsEndLoad(loadState);
	
	if pxyDecks &lt;&gt; null and not pxyDecks.isEmpty() then
		foreach obj in pxyDecks do	
			delete obj;
		endforeach;
	endif;

	delete pxyDecks;

end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xRailConfigSetup" id="c23bf5ab-1f93-4971-a376-c4574d13725b">
        <source>xRailConfigSetup(_opCriteria : CM_YACriteriaTypeArray io; _yaRailConfig : CM_YARailConfig output);

/*

Purpose:		Setup the Colour coding details for rail

Date			Who		Reason
15/04/2014		cnwmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	yaConfig				: CM_YAConfig;
	ct 						: CM_YACriteriaType;
	pxyRailConfig			: CM_YARailConfig;
	
	opCriteria				: CM_YACriteriaTypeArray;
	
begin

	terminal := self.getTerminal();
	
	yaConfig := terminal.myYAConfig;
	self.assertNotNull(yaConfig);
	
	_yaRailConfig := yaConfig.allYARailConfigs.first.CM_YARailConfig;
	self.assertNotNull(_yaRailConfig);
	
	_yaRailConfig.allOpCriteria.copy(_opCriteria);
	
	create opCriteria transient;
	ct := CM_YATypeCargoType.firstInstance;
	opCriteria.add(ct);
	ct := CM_YATypeDischargePort.firstInstance;
	opCriteria.add(ct);
	ct := CM_YATypeISO.firstInstance;
	opCriteria.add(ct);
	ct := CM_YATypeCommodity.firstInstance;
	opCriteria.add(ct);
	self.assertEqual(opCriteria.size, 4);
	
	self.opts.purge();
	self.opts.addAssoc("OpCriteria", opCriteria);	
	self.updateYARailConfig(_yaRailConfig);
	
epilog

	delete opCriteria;

end;</source>
        <Parameter name="_opCriteria" type="CM_YACriteriaTypeArray" usage="io"/>
        <Parameter name="_yaRailConfig" type="CM_YARailConfig" usage="output"/>
    </JadeMethod>
    <JadeMethod name="xReceiveFromShip" id="a900a9ab-1ffe-402c-a58f-fbe9ed4f9240">
        <source>xReceiveFromShip(_voyage : CM_Voyage);

/*

Purpose:		

Date			Who		Reason
02/04/2014		cnwmh5	Initial creation

*/

vars

	blockStack					: CM_BlockStack;
	tmpLoadCC					: CMIF_LoadColorCode;
	ti							: CM_TrackedItem;
	voyageJob					: CM_VoyageJob;
	voyageJob1					: CM_VoyageJob;
	voyageWLE					: CM_VoyageWLE;
	obj							: Object;
	slot						: CM_SlotController;
	
	slots						: CM_SlotControllerArray;
	slotsToFill					: StringArray;
	tiSet						: CM_TISet;
	wleSet						: CM_WLESet;
	
begin

	blockStack := self.getTerminalArea("UTMHBSH").CM_BlockStack;
	self.assertNotNull(blockStack);
	
	create slots transient;
	create slotsToFill transient;
	create wleSet transient;
	create tiSet transient;
		
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "NZAKA");
	self.addVoyageCargoLOLO(_voyage, "050202", 7, slotsToFill);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "05", DeckUnderDeck, 4, 1, 7, slots);
	foreach slot in slots do
		slot.allTrackedItemsById.copy(tiSet);
	endforeach;
	///self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	//voyageJob := self.addVoyageJob(_voyage, "CRN1", slots, true);
	///self.assertNoTrxErrorsOrWarnings();
	///self.assertNotNull(voyageJob);
	///self.xGetWLEs(_voyage, voyageJob, wleSet, NO_MODE);
	
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "NZNSN");
	self.addVoyageCargoLOLO(_voyage, "050102", 7, slotsToFill);
	slots.clear();
	self.getJobSlotControllers(_voyage.code, "05", DeckUnderDeck, 5, 1, 7, slots);
	foreach slot in slots do
		slot.allTrackedItemsById.copy(tiSet);
	endforeach;
	///self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	///voyageJob1 := self.addVoyageJob(_voyage, "CRN1", slots, true);
	///self.assertNoTrxErrorsOrWarnings();
	///self.assertNotNull(voyageJob1);
	//self.xGetWLEs(_voyage, voyageJob1, wleSet, NO_MODE);
	
	
	foreach ti in tiSet do
		//voyageWLE := obj.CM_VoyageWLE;
		//ti := voyageWLE.myTrackedItem;
		self.deleteStops(ti);
		self.assertEqualMsg(ti.getAllStops().size, 0, ti.id &amp; ' has stops');
		//tiSet.add(ti);
	endforeach;
	
	
	self.loadAllJobsToOps(_voyage, true);
	self.assertNoTrxErrorsOrWarnings();
	
	// receive the items from the ship
	app.myTrxUA.trxReceiveFromShip(tiSet, blockStack.myLocationsController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete slots;
	delete slotsToFill;
	delete tiSet;
	delete wleSet;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xReleaseRequests" id="3a1fea41-59ec-4c12-b9be-d2ad5b32ef9f">
        <source>xReleaseRequests(_voyage : CM_Voyage);

/*

Purpose:		

Date			Who		Reason
02/04/2014		cnwmh5	Initial creation

*/

vars

	blockStack				: CM_BlockStack;
	releaseRequest			: CM_BulkRelease;
	ti						: CM_TrackedItem;
	obj						: Object;
	tmpLoadCC				: CMIF_LoadColorCode;
	voyageJob				: CM_VoyageJob;
	slot					: CM_SlotController;
	
	tis						: ObjectSet;
	slots 					: CM_SlotControllerArray;
	tiSet					: CM_TISet;
	
	count					: Integer;

begin

	blockStack := self.getTerminalArea("UTMHBSH").CM_BlockStack;
	self.assertNotNull(blockStack);

	self.opts.purge();
	self.opts.addAssoc("Number", 10);
	self.opts.addAssoc("Voyage", _voyage);
	releaseRequest := self.addReleaseByTypeRequest("UTMHSHIP01", BR_TYPE_SHIP, TI_CargoType_Container, "2200");
	self.assertNotNull(releaseRequest);
	
	create tis transient;
	blockStack.getAllLocationsTrackedItems(tis);
	
	self.opts.purge();
	self.opts.addAssoc('IMEXStatus', TI_IMEX_STATUS_EXPORT);
	count := 1;
	foreach obj in tis do
		ti := obj.CM_TrackedItem;
		if ti.isPlanned(PLANNING_MODE) or ti.isPlanned(QUEUE_MODE) or ti.isQueued() then
			self.unqueueTI(ti);
		endif;
		self.setCargoReadyToShip(ti);
		self.updateTI(ti);
		self.releaseAssignCargo(releaseRequest, null, ti);
		self.assertEqual(ti.bulkReleaseAssignedCode, releaseRequest.code);
		count := count + 1;
		if count &gt; 10 then
			break;
		endif;
	endforeach;
	
	// get the slots to colour code and add release to
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType := true;
	tmpLoadCC.myDischargePort := app.myRoot.allPorts["NZAKL"];
	tmpLoadCC.myBulkReleaseReserveDetail := releaseRequest.allReserveDetails.first;
	
	self.getJobSlotControllers(_voyage.code, "29", DeckOnDeck, 1, 1, 10, slots);
	self.markSlotsAsLoadJob(slots, tmpLoadCC);
	self.markSlotsAsLoadCC(slots, tmpLoadCC,CM_SlotRequest.Attribute_Empty);
	self.markSlotsAsLoadCC(slots, tmpLoadCC,CM_SlotRequest.Attribute_AssignRelease);
	
	voyageJob := self.addVoyageJob(_voyage, "CRN1", slots, false);
	self.assertNotNull(voyageJob);
	
	foreach slot in slots do	
		self.assertNotNull(slot.mySlotRequestLoad);
	endforeach;

	self.loadAllJobsToOps(_voyage, true);
	
	create tiSet transient;
	tis.copy(tiSet);
	app.myTrxUA.trxUpdateUnassignRelease(tiSet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach obj in tiSet do
		ti := obj.CM_TrackedItem;
		self.assertEqual(ti.bulkReleaseAssignedCode, null);
	endforeach;
	
epilog

	delete slots;
	delete tis;
	delete tmpLoadCC;
	delete tiSet;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="xSwapWagonCargoPositions" id="468c3c85-bd1e-446a-b7be-812ba4c07661">
        <source>xSwapWagonCargoPositions(_train : CM_Train);

/*

Purpose:		trxSwapWagonCargoPositions

Date			Who		Reason
16/04/2014		cnwmh5	Initial creation

*/

vars

	wagon						: CM_Wagon;
	locnController				: CM_WagonController;
	ti							: CM_TrackedItem;
	transClass					: Object;
	
	selectedCargo				: CM_TIArray;
	locationStrArray			: StringArray;
	
	index						: Integer;
	
	control : CMIF_WagonMoveController;
	newLocationsArray : ObjectArray;
	iter : Iterator;

begin
		
//	create transClass as rootSchema.getSchema("YardSchema").getClass("YRD_Assistant") transient;	
		
	create selectedCargo transient;
	create locationStrArray transient;
	
	wagon := _train.allWagonsByIdInward["UTMH04"];
	self.assertNotNull(wagon);
	
	index := 0;
	foreach locnController in wagon.allLocationsControllersArray do
		foreach ti in locnController.allTrackedItems do
			if not selectedCargo.includes(ti) then
				index := index + 1;
				if index &gt; 2 then 
					break;
				endif;
				selectedCargo.add(ti);
				locationStrArray.add(ti.getPrimaryLocationId(REAL_MODE));
			endif;
		endforeach;
		if index &gt; 2 then
			break;
		endif;
	endforeach;
	
//	transClass.sendMsgWithIOParams("doCargoPositionSwap", selectedCargo);
	
	create newLocationsArray transient;
	iter := selectedCargo.createIterator;
	while iter.back( ti ) do
		newLocationsArray.add( ti.myPrimaryActualLocation );
	endwhile;
	app.myTrxUA.trxSwapWagonCargoPositions( control, selectedCargo, newLocationsArray, app.myPassport);
	
	self.assertEqual(selectedCargo.first.getPrimaryLocationId(REAL_MODE), locationStrArray.last);
	self.assertEqual(selectedCargo.last.getPrimaryLocationId(REAL_MODE), locationStrArray.first);
	
epilog

	delete locationStrArray;
	delete selectedCargo;
	delete transClass;
	delete newLocationsArray;
	delete iter;
	
end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="xTestRunImportTasksOnShip" id="cf751ae7-7056-40fc-8557-afd9b89e8c06">
        <source>xTestRunImportTasksOnShip(_voyage : CM_Voyage io);

/*

Purpose:		Test Run Import Tasks On Ship

Date			Who		Reason
13/03/014		cnwmh5	Initial creation

*/

vars

	ti							: CM_TrackedItem;
	obj							: Object;

	slotsToFill					: StringArray;
	portsArray					: StringArray;
	
	firstTime					: Boolean;

begin

	create slotsToFill transient;
	
	firstTime := true;
	create portsArray transient;
	portsArray.add("NZAKA");
	portsArray.add("NZAKL");
	portsArray.add("NZCHC");
	

	// create some cargo on the LOLO voyage to run import tasks against
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_IMPORT);
	self.addVoyageCargoLOLO(_voyage, "170802", 7, slotsToFill);
	
	beginTransaction;
	foreach ti in _voyage.allOnshipTIsByIdCargoType do
		if ti.isImport then
			foreach obj in ti.allTransactions do
				if obj.isKindOf(CM_StopAdd) then
					obj.CM_StopAdd.setForDelete(null);
				elseif obj.isKindOf(CM_StopCleared) then
					obj.CM_StopCleared.setForDelete(null);
				endif;
			endforeach;	
			if firstTime then
				commitTransaction;
				app.myTrxUA.trxUpdateDischargePorts(ti, portsArray, app.myPassport);
				self.assertNoTrxErrorsOrWarnings();
				firstTime := false;
				beginTransaction;
			endif;
		endif;
	endforeach;
	commitTransaction;
	
	// now check to see that not stops and all stops add txn are deleted
	firstTime := true;
	foreach ti in _voyage.allOnshipTIsByIdCargoType do
		self.assertEqualMsg(ti.getAllStops().size, 0, ti.id &amp; ' has stops');
		foreach obj in ti.allTransactions do
			if obj.isKindOf(CM_StopAdd) then
				self.assertEqual(obj.CM_StopAdd.deleted, true);
			elseif obj.isKindOf(CM_StopCleared) then
				self.assertEqual(obj.CM_StopCleared.deleted, true);
			endif;
		endforeach;
		if firstTime then
			self.assertNotEqualMsg(ti.allDischargePorts.size, 0, ti.id &amp; " allDischargePorts is empty");
			firstTime := false;
		endif;
	endforeach;
	
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.addVoyageCargoLOLO(_voyage, "170702", 7, slotsToFill);

	app.myTrxUA.trxRunImportTasksOnShip(_voyage, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// now test to see that stops have been applied
	foreach ti in _voyage.allOnshipTIsByIdCargoType do
		if ti.isImport then
			self.assertNotEqualMsg(ti.getAllStops().size, 0, ti.id &amp; " should have stops but it doesn't");
		else	
			self.assertEqualMsg(ti.getAllStops().size, 0, ti.id &amp; " shouldn't have stops but it does");
		endif;
	endforeach;
	
epilog

	delete slotsToFill;
	delete portsArray;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="xUpdateRailSettings" id="e14894e9-036c-467f-82fc-764508d51194">
        <source>xUpdateRailSettings();

/*

Purpose:		Update the rail settings - terminal set config

Date			Who		Reason
14/04/2014		cnwmh5	Initial creation

*/

vars

	railSettings				: CMIF_RailSettings;
	terminal					: CM_Terminal;
	
	railAutoSwitch				: Boolean;

begin

	terminal := self.getTerminal();
	railAutoSwitch := terminal.getConfig(RailAutoSwitch).Boolean;

	create railSettings transient;
	railSettings.myTerminal := terminal;
	railSettings.trainAutoNumber :=  terminal.getConfig(TrainAutoNumber).Boolean;
	railSettings.trainAutoNumberPrefix := terminal.getConfig(TrainAutoNumberPrefix).String;
	railSettings.railPostDepartVisHrs := terminal.getConfig(RailPostDepartVisHrs).Integer;	
	railSettings.trainManifestReportIn := terminal.getConfig(TrainManifestReportIn).String;
	railSettings.trainManifestReportOut :=  terminal.getConfig(TrainManifestReportOut).String;
	railSettings.useOutwardRailConfirm :=  terminal.getConfig(UseOutwardRailConfirm).Boolean;
	railSettings.noTLMovesToWagons :=  terminal.getConfig(RailNoTwinLiftMoves).Boolean;
	railSettings.defRailCarrier := terminal.getConfig(DefRailCarrier).String;
	railSettings.defRailOpsArea := terminal.getConfig(DefRailOpsArea).String;
	railSettings.defWagonClass := terminal.getConfig(DefWagonClass).String;
	railSettings.customsEDIonTrain := terminal.getConfig(CustomsEDIonTrain).Boolean;
	railSettings.hHAlwaysCargoFullID :=terminal.getConfig(RailHHAlwaysCargoFullID).Boolean;
	railSettings.hHCargoMustPrenote := terminal.getConfig(RailHHCargoMustPrenote).Boolean;
	railSettings.hHWarnPrenoteHazDiffer := terminal.getConfig(RailHHWarnPrenoteHazDiffer).Boolean;
	railSettings.hHAlwaysWagonFullID := terminal.getConfig(RailHHAlwaysWagonFullID).Boolean;
	railSettings.hHWagonUseReversedID := terminal.getConfig(RailHHWagonUseReversedID).Boolean;
	railSettings.showRelReqOnRailLoadList := terminal.getConfig(ShowRelReqOnRailLoadList).Boolean;
	railSettings.railDisallowOutwardQueue := terminal.getConfig(RailDisallowOutwardQueue).Boolean;
	railSettings.railTrackClearErr := terminal.getConfig(RailTrackClearErr).Boolean;
	railSettings.railAutoSwitch := not railAutoSwitch;
	
	app.myTrxUA.trxUpdateRailSettings(railSettings, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(terminal.getConfig(RailAutoSwitch).Boolean,  not railAutoSwitch);

epilog

	delete railSettings;

end;</source>
    </JadeMethod>
    <JadeMethod name="xUpdateWagonDeparture" id="b5c5fded-fd84-45dd-baac-2c7a1ebb7752">
        <source>xUpdateWagonDeparture(_train : CM_Train);

/*

Purpose:		Update wagon departure

Date			Who		Reason
22/04/2014		cnwmh5	Initial creation

*/

vars

	wagonSet				: CM_WagonSet;

begin

	create wagonSet transient;

	wagonSet.add(_train.allWagonsByOrderOutward.last);
	
	app.myTrxUA.trxUpdateWagonDeparture(wagonSet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(_train.allWagonsByIdOutward.last.myTerminalDeparted);
	
epilog

	delete wagonSet;

end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="xUpdateWagonFromCMIF" id="d58071e0-d7c3-4094-9b2b-76c89accb511">
        <source>xUpdateWagonFromCMIF(_train	: CM_Train);

/*

Purpose:		Update the wagon details from the CMIF

Date			Who		Reason
10/04/2014		cnwmh5	Initial creation

*/
constants

	WagonId						: String = "UTMH07";
	ContainerId					: String = "UTMHTR00001";
	BlockStackId				: String = "UTTR1";
	
vars

	wagon						: CM_Wagon;
	wagonUpdateCtrl 			: CMIF_WagonUpdateController;
	ti							: CM_TrackedItem;
	bs							: CM_BlockStack;
	pxyWagon					: CM_Wagon;
	wagonClass 					: CM_WagonClass;
	
	selectedPosition			: Integer;
	loadState					: Boolean;
	remarks						: String;
	wagonPos					: Integer;
	
begin

	
	wagon := _train.allWagonsByIdInward[WagonId];
	self.assertNotNull(wagon);

	create wagonUpdateCtrl transient;	
	
	selectedPosition := 1;
	
	bs := self.addBlockStack(BlockStackId, 20, null);
	self.assertNotNull(bs);
	
	ti := self.getTrackedItem(ContainerId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	ti := self.addContainerAtLocation(ContainerId, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", "GENL", 
		TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	self.assertNotNull(ti);
	self.deleteStops(ti);
	
	app.cmsBeginLoad(loadState);
	pxyWagon := app.createUpdateProxy(wagon).CM_Wagon;
	app.cmsEndLoad(loadState);
	
	remarks := wagon.remarks;
	if self.opts.includesKey("WagonRemarks") then
		remarks := self.opts.str("WagonRemarks");
	endif;
	
	pxyWagon.setProxy(self.getTerminal(), 
		wagon.id, 
		wagon.myWagonClass, 
		wagon.myTrainInwards, 
		wagon.myTrainOutwards,
		remarks, 
		0, 
		0, 
		0, 
		wagon.myCarrier,
		wagon.myStevedoreReceive,       //02.10.2020 cnwma1 TFS #50112
		wagon.myStevedoreRelease);      //02.10.2020 cnwma1 TFS #50112
		
	wagonUpdateCtrl.setBasicDetails( CMIF_WagonUpdateController.Mode_Update,
		wagon.myRailLine,
		_train,
		wagonPos, 
		true);
		
	//wagonUpdateCtrl.populateFromExistingWagonAddTi(wagon, ti, selectedPosition);
	wagonUpdateCtrl.expectedEditionWagon := wagon.edition;
	wagonUpdateCtrl.myProxyWagon := pxyWagon;
	
	app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(wagon.remarks, remarks);
	
epilog

	app.cmsEndLoad(loadState);
	
	delete pxyWagon;

	delete wagonUpdateCtrl;

end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="xUpdateWagonInTransit" id="9f980268-505c-48f3-bb39-257957f3a623">
        <source>xUpdateWagonInTransit(_train : CM_Train);

/*

Purpose:		Update Wagon in Transit

Date			Who		Reason
16/04/2014		cnwmh5	Initial creation

*/

vars

	wagon							: CM_Wagon;
	ti								: CM_TrackedItem;
	locnController					: CM_WagonController;

	wagonSet 						: CM_WagonSet;

begin

	wagon := _train.allWagonsByIdInward["UTMH06"].CM_Wagon;
	self.assertNotNull(wagon);
	
	create wagonSet transient;
	wagonSet.add(wagon);
	
	self.opts.purge();
	self.opts.addAssoc('IMEXStatus', TI_IMEX_STATUS_REMAINONBOARD);
	foreach locnController in wagon.allLocationsControllersArray do
		foreach ti in locnController.allTrackedItems do 
			self.updateTI(ti);
		endforeach;
	endforeach;
	
	app.myTrxUA.trxUpdateWagonInTransit(wagonSet, TI_IMEX_STATUS_REMAINONBOARD, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	self.assertEqual(wagon.isInTransit(), true);

epilog

	delete wagonSet;

end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="xUpdateWagonRailAlloc" id="e0577e7e-c81a-4918-9c91-ad4a6b6e2ae0">
        <source>xUpdateWagonRailAlloc(_train : CM_Train);

/*

Purpose:		Update wagon(s) Allocation

Date			Who		Reason
15/04/2014		cnwmh5	Initial creation

*/

vars

	pxyYAObj						: CM_RailAllocation;
	criteria						: CM_YACriteria;
	port							: CM_Port;
	criteriaType					: CM_YACriteriaType;
	wagon							: CM_Wagon;
	locnController					: CM_WagonController;
	
	iter							: Iterator;
	
	wagons							: CM_WagonByIdDict;
	objSet							: CM_ObjectSet;
	
	index							: Integer;

begin

	create pxyYAObj transient;

	create wagons transient;
		
	wagon := _train.allWagonsByIdInward["UTMH08"];
	self.assertNotNull(wagon);
	wagons.add(wagon);
	wagon := _train.allWagonsByIdInward["UTMH10"];
	self.assertNotNull(wagon);
	wagons.add(wagon);
	
	create criteria transient;
	create objSet transient;
	port := app.myRoot.allPorts["NZAKL"];
	self.assertNotNull(port);
	objSet.add(port);

	criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_DischargePort];
	self.assertNotNull(criteriaType);
	
	criteria.setProxy(criteriaType, objSet, null);
	criteria.setYardAllocation(pxyYAObj);
	
	pxyYAObj.setProxy(wagons.first.id,
		app.getErrorString(Rail_colour_coding),
		null,
		YAFillOption_InOrder,
		YAFillOption_InOrder,
		YAExpiryType_Never,
		null,
		16711680,
		null,
		YAOverlap_Never,
		YANoLocation_Continue,
		null,
		0,
		false,
		false,
		null,
		null,
		true,
		self.getTerminal());	

	app.myTrxUA.trxUpdateWagonRailAlloc(wagons, pxyYAObj, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach wagon in wagons do
		foreach locnController in wagon.allLocationsControllersArray do
			self.assertNotNull(locnController.myRailAllocation);
		endforeach;
	endforeach;	
	
	// delete the colour coding from the last 3 wagons in the array
	//trxDeleteRailAllocsForWagons
	objSet.clear();
	index := 0;
	foreach wagon in wagons do
		index := index + 1;
		if index &gt;= 3 then
			objSet.add(wagon);
		endif;
	endforeach;
	
	app.myTrxDA.trxDeleteRailAllocsForWagons(objSet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//foreach wagon in _train.allWagonsByIdInward where wagon.id &lt;&gt; "UTMH08" and wagon.id &lt;&gt; "UTMH10" do
	foreach wagon in _train.allWagonsByIdInward do
		foreach locnController in wagon.allLocationsControllersArray do
			if objSet.includes(wagon) and not wagons.includes(wagon) then
				self.assertNull(locnController.myRailAllocation);
			endif;
		endforeach;	
	endforeach;
	
	// as the delete removes all the colour coding from all wagons need to recolour code required wagons
	objSet.clear();
	index := 0;
	foreach wagon in wagons do
		index := index + 1;
		if index &lt; 3 then
			objSet.add(wagon);
		endif;
	endforeach;
	wagons.clear();
	objSet.copy(wagons);	
	
	app.myTrxUA.trxUpdateWagonRailAlloc(wagons, pxyYAObj, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach wagon in wagons do
		foreach locnController in wagon.allLocationsControllersArray do
			if wagons.includes(wagon) then
				self.assertNotNull(locnController.myRailAllocation);
			endif;
		endforeach;	
	endforeach;
	
epilog

	delete criteria;
	delete objSet;
	delete pxyYAObj;
	delete wagons;
	delete iter;

end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="xUpdateWagonRakePositionSwap" id="16b94d18-a49b-4c73-950d-b3de58eaec8c">
        <source>xUpdateWagonRakePositionSwap(_train : CM_Train);

/*

Purpose:		Wagon rake position swap

Date			Who		Reason
22/04/2014		cnwmh5	Initial creation

*/

vars

	wagon1						: CM_Wagon;
	wagon2						: CM_Wagon;
	
	wagon1OldPos				: Integer;
	wagon2OldPos				: Integer;
	
begin

	wagon1 := _train.allWagonsByIdInward['UTMH02'];
	self.assertNotNull(wagon1);
	wagon1OldPos := wagon1.myRailLine.CM_RailLine.allWagons.indexOf(wagon1);
	wagon2 := _train.allWagonsByIdInward['UTMH08'];
	self.assertNotNull(wagon2);
	wagon2OldPos := wagon2.myRailLine.CM_RailLine.allWagons.indexOf(wagon2);
	
	app.myTrxUA.trxUpdateWagonRakePositionSwap(wagon1, wagon2, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	self.assertEqual(wagon1.myRailLine.CM_RailLine.allWagons.indexOf(wagon1), wagon2OldPos);
	self.assertEqual(wagon2.myRailLine.CM_RailLine.allWagons.indexOf(wagon2), wagon1OldPos);
	
epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="xUpdateWagonTrackedItem" id="a167e858-f82d-47a8-8231-c7ed6e8c7d35">
        <source>xUpdateWagonTrackedItem(_train : CM_Train);

/*

Purpose:		trxUpdateWagonTrackedItem

Date			Who		Reason
16/04/2014		cnwmh5	Initial creation
02 Oct 2020    cnwma1   ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	ti						: CM_TrackedItem;
	pxyWagon				: CM_Wagon;
	wagon					: CM_Wagon;
	bs						: CM_BlockStack;
	moveControl				: CMIF_WagonMoveController;
	tiArray					: CM_TIArray;
	wagonArray				: CM_WagonArray;
	loadState				: Boolean;
begin

	// get the block stack
	bs := self.getTerminalArea("UTMHRAIL1").CM_BlockStack;
	if bs = null then
		bs := self.addBlockStack("UTMHRAIL1", 50, null);
	endif;
	self.assertNotNull(bs);

	// create the ti
	self.opts.purge();
	self.opts.addAssoc("DischargePort", "NZAKL");
	ti := self.addContainerAtLocation("UTMHQWE0001", app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString],
		"2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController);
	self.assertNotNull(ti);
	self.updateTI(ti);
	self.deleteStops(ti);
	
	create tiArray transient;
	tiArray.add(ti);

	wagon := _train.allWagonsByIdInward.last;
	self.assertNotNull(wagon);
	
	create wagonArray transient;
	create moveControl transient;
	wagonArray.add(wagon);
	
	app.myTrxUA.trxUpdateWagonConfirm(wagonArray, true, moveControl, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	app.cmsBeginLoad(loadState);
	pxyWagon := wagon.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	pxyWagon.setProxy(wagon.myTerminal, wagon.id, wagon.myWagonClass, wagon.myTrainInwards, wagon.myTrainOutwards, 
		wagon.remarks, wagon.maxCargoHeight, wagon.maxCargoWeight, wagon.tareWeight, wagon.myCarrier,wagon.myStevedoreReceive,wagon.myStevedoreRelease); //02.10.2020 cnwma1 TFS #50112
	
	app.myTrxUA.trxUpdateWagonTrackedItem(pxyWagon, tiArray, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	app.cmsEndLoad(loadState);

	delete pxyWagon;
	delete tiArray;
	delete wagonArray;
	delete moveControl;

end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="xWagonJobs" id="8844aeb1-bcc5-4d15-8a90-d87c18c21c00">
        <updating/>
        <source>xWagonJobs(_train : CM_Train) updating;

/*

Purpose:		Train job trx's

Date			Who		Reason
22/04/2014		cnwmh5	Initial creation

*/

vars

	wagon							: CM_Wagon;
	blockStack						: CM_BlockStack;
	moveController					: CMIF_MoveController;
	params 							: CMIF_AutoplanParams;
	ya								: CM_YardAllocation;
	ti								: CM_TrackedItem;
	
	locations 						: CM_LCArray;
	wagons 							: CM_WagonArray;
	tis 							: CM_TIArray;
	wlesToUnassign 					: CM_WLEArray;
	
begin

	self.disableAllYA(true);
		
	blockStack := self.getTerminalArea("UTMHRAIL1").CM_BlockStack;
	if blockStack = null then
		blockStack := self.addBlockStack("UTMHRAIL1", 50, null);
		self.assertNotNull(blockStack);
	endif;
	
	create locations transient;
	locations.add(blockStack.allLocationsControllers.first);
	self.deleteYA("UTMHRAIL1");
	ya := self.addYA1WithFill("UTMHRAIL1", YACriteriaType_ISO, "2213", locations, YAFillOption_InOrder, YAFillOption_FIFO,false);
	self.assertNotNull(ya);

	create tis transient;
	wagon := _train.allWagonsByIdInward["UTMH02"];
	self.assertNotNull(wagon);
	wagon.getAllTrackedItems(true, tis, false);
	self.assertNotEqual(tis.size, 0);
	
	wagon := _train.allWagonsByIdInward["UTMH04"];
	self.assertNotNull(wagon);
	wagon.getAllTrackedItems(true, tis, false);
	
	wagon := _train.allWagonsByIdInward["UTMH06"];
	self.assertNotNull(wagon);
	wagon.getAllTrackedItems(true, tis, false);
		
	create params transient;
	params.moveMode := QUEUE_MODE;
	params.myTerminalArea := blockStack;
	params.myJob := null;
	params.showWarningWhenNoPlan := true;
	tis.copy(params.allTrackedItems);
	app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach ti in tis do
		self.assertNotNull(ti.myPrimaryQueuedLocation);
	endforeach;
	
	// trxUnAssignWleFromWagon
	create wlesToUnassign transient;
	wagon := _train.allWagonsByIdInward["UTMH06"];
	self.assertNotNull(wagon);
	wagon.allRailJobs.first.workListEntries.copy(wlesToUnassign);	
	app.myTrxUA.trxUnAssignWleFromWagon(wlesToUnassign, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	self.disableAllYA(false);

	delete wagons;
	delete tis;
	delete moveController;
	delete params;
	delete locations;
	delete wlesToUnassign;
	
end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
</Class>
