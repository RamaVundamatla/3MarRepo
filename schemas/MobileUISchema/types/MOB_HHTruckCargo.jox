    <JadeMethod name="setComboValues" id="cb1bb5de-4426-4bad-b666-e78d30617199">
        <source>setComboValues() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	isoType : CM_ISOType;
	port : CM_Port;
	commodity : CM_Commodity;
	operator : CM_Operator;
	voyage : CM_Voyage;
	cargoType : CM_CargoType;
	product : CM_Product;
	existingString : String;
	index : Integer;
	consign	: CM_ConsigneeConsignor;//cnwas3 par 23700
	imex : CM_IMEXStatus;
	dimType : String;
	make : CM_VehicleMake;
	model : CM_VehicleModel;
	vehType : CM_VehicleType;
	tilcType : CM_TILCType;
	beforeVoyage : CM_Voyage;
begin
	
	//epr tfs 1939 4/5/16
	if self.lockedDown then
		return;
	endif;
	//select items in combos used in tables
	if tblCargo.getRow(ETRow_IsoType) &gt; 0 then
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_IsoType),2);
		if myTrackedItem &lt;&gt; null and myTrackedItem.isContainer then
			isoType := myTrackedItem.CM_Container.getISOTypeObject;
		endif;
		if isoType &lt;&gt; null then
			self.cmbISOType.listIndex := self.cmbISOType.findObject(isoType);
		elseif existingString &lt;&gt; null then
			index := self.cmbISOType.findStringExact(1,existingString);
			if index &gt; 0 then
				isoType := cmbISOType.itemObject[index].CM_ISOType;
			endif;
			if isoType = null then
				isoType := app.myRoot.allISOTypes.getAtKey(existingString);
			endif;
			if isoType &lt;&gt; null then
				self.cmbISOType.listIndex := self.cmbISOType.findObject(isoType);
			else
				self.cmbISOType.listIndex := -1;
			endif;
		else
			self.cmbISOType.listIndex := -1;
		endif;
		self.tblCargo.setValueByControlName(self.cmbISOType.name, self.cmbISOType.text);
	endif;
	
	if tblCargo.getRow(ETRow_CargoType) &gt; 0 then
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_CargoType),2);
		if self.myTrackedItem &lt;&gt; null then
			cargoType := myTrackedItem.myCargoType;
		endif;
		if cargoType &lt;&gt; null then
			self.cmbType.listIndex := self.cmbType.findObject(cargoType);
		elseif existingString &lt;&gt; null then
			index := self.cmbType.findStringExact(1,existingString);
			if index &gt; 0 then
				cargoType := cmbType.itemObject[index].CM_CargoType;
			endif;
			if cargoType = null then
				cargoType := app.myRoot.allCargoTypesById.getAtKey(existingString.Integer);
			endif;
			if cargoType &lt;&gt; null then
				self.cmbType.listIndex := self.cmbType.findObject(cargoType);		
			else
				self.cmbType.listIndex := -1;
			endif;
		else
			self.cmbType.listIndex := -1;
		endif;
		self.tblCargo.setValueByControlName(self.cmbType.name, self.cmbType.text);
		self.populateSubCargo( cargoType ); //10 Sep 2013	NDL	Par 32172
		self.populateCmbDimType( cargoType );  //10 Sep 2013	NDL	Par 32172
	endif;
	
	if tblCargo.getRow(ETRow_SubCargoType) &gt; 0 then
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_SubCargoType),2);
		if myTrackedItem &lt;&gt; null then
			product := myTrackedItem.myProduct;
		endif;
		if product &lt;&gt; null then
			self.cmbSubCargo.listIndex := self.cmbSubCargo.findObject(product);
		elseif existingString &lt;&gt; null then
			index := self.cmbSubCargo.findStringExact(1,existingString);
			if index &gt; 0 then
				product := cmbSubCargo.itemObject[index].CM_Product;
			endif;
			if product &lt;&gt; null then
				self.cmbSubCargo.listIndex := self.cmbSubCargo.findObject(product);
			
			else
				self.cmbSubCargo.listIndex := -1;
			endif;
		else
			self.cmbSubCargo.listIndex := -1;
		endif;
		self.tblCargo.setValueByControlName(self.cmbSubCargo.name, self.cmbSubCargo.text);
	endif; 
	
	if tblCargo.getRow(ETRow_VoyageCode) &gt; 0 then
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_VoyageCode),2);
		beforeVoyage:=self.cmbVoyage.listObject.CM_Voyage;
		if myTrackedItem &lt;&gt; null then
			voyage := myTrackedItem.myVoyage;
		endif;
		if voyage &lt;&gt; null then
			self.cmbVoyage.listIndex := self.cmbVoyage.findObject(voyage);
		elseif existingString &lt;&gt; null then
			index := self.cmbVoyage.findStringExact(1,existingString);
			if index &gt; 0 then
				voyage := cmbVoyage.itemObject[index].CM_Voyage;
			else	//05 Mar 2014	NDL	Par 33596
				voyage := self.myMobileGenericAgent.getVoyageFromCode( existingString );
			endif;
			if voyage &lt;&gt; null then
				self.cmbVoyage.listIndex := self.cmbVoyage.findObject(voyage);
			else
				self.cmbVoyage.listIndex := -1;
			endif;
		else
			self.cmbVoyage.listIndex := -1;
		endif;
		
		self.tblCargo.setValueByControlName(self.cmbVoyage.name, self.cmbVoyage.text);
		if beforeVoyage &lt;&gt; self.cmbVoyage.listObject then
			self.populateVoyageDependantCombos();
		endif;
	endif;
	
	if tblCargo.getRow(ETRow_VoyageOperator) &gt; 0 then
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_VoyageOperator),2);
		if myTrackedItem &lt;&gt; null then
			operator := myTrackedItem.myOperator;
		endif;
		if operator &lt;&gt; null then
			self.cmbOperator.listIndex := self.cmbOperator.findObject(operator);
		elseif existingString &lt;&gt; null then
			index := self.cmbOperator.findStringExact(1,existingString);
			if index &gt; 0 then
				operator := cmbOperator.itemObject[index].CM_Operator;
			endif;
			if operator = null then
				operator := app.myRoot.allOperators.getAtKey(existingString);
			endif;
			if operator &lt;&gt; null then
				self.cmbOperator.listIndex := self.cmbOperator.findObject(operator);
			else
				self.cmbOperator.listIndex := -1;
			endif;
		else
			self.cmbOperator.listIndex := -1;
		endif;
		
		self.tblCargo.setValueByControlName(self.cmbOperator.name, self.cmbOperator.text);
	endif;
	
	if tblCargo.getRow(ETRow_DestinationPort) &gt; 0 then
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_DestinationPort),2);
		port := null;
		if myTrackedItem &lt;&gt; null then
			port := myTrackedItem.cargoIF_GetObjectForETRow(ETRow_DestinationPort).CM_Port;
		endif;
		if port &lt;&gt; null then
			self.cmbDestination.listIndex := self.cmbDestination.findObject(port);
		elseif existingString &lt;&gt; null then
			index := self.cmbDestination.findStringExact(1,existingString);
			if index &gt; 0 then
				port := cmbDestination.itemObject[index].CM_Port;
			endif;
			if port = null then
				port := app.myRoot.allPorts.getAtKey(existingString);
			endif;
			if port &lt;&gt; null then
				self.cmbDestination.listIndex := self.cmbDestination.findObject(port);
			else
				self.cmbDestination.listIndex := -1;
			endif;
		else
			self.cmbDestination.listIndex := -1;
		endif;

		self.tblCargo.setValueByControlName(self.cmbDestination.name, self.cmbDestination.text);
	endif; 
	
	if tblCargo.getRow(ETRow_DischargePort) &gt; 0 then
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_DischargePort),2);
		port := null;
		if myTrackedItem &lt;&gt; null then
			port := myTrackedItem.cargoIF_GetObjectForETRow(ETRow_DischargePort).CM_Port;
		endif;
		if port &lt;&gt; null then
			self.cmbDischarge.listIndex := self.cmbDischarge.findObject(port);	
		elseif existingString &lt;&gt; null then
			index := self.cmbDischarge.findStringExact(1,existingString);
			if index &gt; 0 then
				port := cmbDischarge.itemObject[index].CM_Port;
			endif;
			if port = null then
				port := app.myRoot.allPorts.getAtKey(existingString);
			endif;
			if port &lt;&gt; null then
				self.cmbDischarge.listIndex := self.cmbDischarge.findObject(port);
			else
				self.cmbDischarge.listIndex := -1;
			endif;
		else
			self.cmbDischarge.listIndex := -1;
		endif;

		self.tblCargo.setValueByControlName(self.cmbDischarge.name, self.cmbDischarge.text);
	endif; 

	if tblCargo.getRow(ETRow_Commodity) &gt; 0 then
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_Commodity),2);
		if existingString &lt;&gt; null then
			commodity := app.myRoot.allCommodities[existingString];
		endif;
		if myTrackedItem &lt;&gt; null then
			commodity := myTrackedItem.getCommodityObject;
		endif;
		if commodity &lt;&gt; null then
			self.cmbCommodity.listIndex := self.cmbCommodity.findObject(commodity);
		elseif existingString &lt;&gt; null then
			index := self.cmbCommodity.findStringExact(1,existingString);
			if index &gt; 0 then
				commodity := cmbCommodity.itemObject[index].CM_Commodity;
			endif;
			if commodity = null then
				commodity := app.myRoot.allCommodities.getAtKey(existingString);
			endif;
			if commodity &lt;&gt; null then
				self.cmbCommodity.listIndex := self.cmbCommodity.findObject(commodity);
			else
				self.cmbCommodity.listIndex := -1;
			endif;
		else
			self.cmbCommodity.listIndex := -1;
		endif;		
		self.tblCargo.setValueByControlName(self.cmbCommodity.name, self.cmbCommodity.text);
	endif;
	
	if tblCargo.getRow(ETRow_FreightForwarder) &gt; 0 then		//cnwas3 par 23700 begin
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_FreightForwarder),2);
		consign := null;
		if myTrackedItem &lt;&gt; null then
			consign := myTrackedItem.cargoIF_GetObjectForETRow(ETRow_FreightForwarder).CM_ConsigneeConsignor;
		endif;
		if consign &lt;&gt; null then
			self.cmbFreightFwdr.listIndex := self.cmbFreightFwdr.findObject(consign);	
		elseif existingString &lt;&gt; null then
			index := self.cmbFreightFwdr.findStringExact(1,existingString);
			if index &gt; 0 then
				consign := cmbFreightFwdr.itemObject[index].CM_ConsigneeConsignor;
			endif;
			if consign = null then
				consign := app.myRoot.allConsigneeConsignors.getAtKey(existingString);
			endif;
			if consign &lt;&gt; null then
				self.cmbFreightFwdr.listIndex := self.cmbFreightFwdr.findObject(consign);
			else
				self.cmbFreightFwdr.listIndex := -1;
			endif;
		else
			self.cmbFreightFwdr.listIndex := -1;
		endif;

		self.tblCargo.setValueByControlName(self.cmbFreightFwdr.name, self.cmbFreightFwdr.text);
	endif; 													//cnwas3 par 23700 end
	
	if tblCargo.getRow(ETRow_Consignee) &gt; 0 then		// 36376
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_Consignee),2);
		consign := null;
		if myTrackedItem &lt;&gt; null then
			consign := myTrackedItem.cargoIF_GetObjectForETRow(ETRow_Consignee).CM_ConsigneeConsignor;
		endif;
		if consign &lt;&gt; null then
			self.cmbFreightFwdr.listIndex := self.cmbFreightFwdr.findObject(consign);	
		elseif existingString &lt;&gt; null then
			index := self.cmbConsignee.findStringExact(1,existingString);
			if index &gt; 0 then
				consign := cmbConsignee.itemObject[index].CM_ConsigneeConsignor;
			endif;
			if consign = null then
				consign := app.myRoot.allConsigneeConsignors.getAtKey(existingString);
			endif;
			if consign &lt;&gt; null then
				self.cmbConsignee.listIndex := self.cmbConsignee.findObject(consign);
			else
				self.cmbConsignee.listIndex := -1;
			endif;
		else
			self.cmbConsignee.listIndex := -1;
		endif;

		self.tblCargo.setValueByControlName(self.cmbConsignee.name, self.cmbConsignee.text);
	endif; 												

	//27 Sep 2010	NDL	Par 25744
	if tblCargo.getRow(ETRow_BookingReference) &gt; 0 then
		populateCmbBRItem();
	endif;
	
	//+cnwml2 PAR25745
	if tblCargo.getRow(ETRow_ImexStatus) &gt; 0 then
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_ImexStatus),2);
		imex := null;
		if myTrackedItem &lt;&gt; null then
			imex := myTrackedItem.cargoIF_GetObjectForETRow(ETRow_ImexStatus).CM_IMEXStatus;
		endif;
		if imex &lt;&gt; null then
			self.cmbImexStatus.listIndex := self.cmbImexStatus.findObject(imex);
		elseif existingString &lt;&gt; null then
			index := self.cmbImexStatus.findStringExact(1,existingString);
			if index &gt; 0 then
				imex := self.cmbImexStatus.itemObject[index].CM_IMEXStatus;
			endif;
			
			if imex = null then
				imex := app.myRoot.allImexStatuses.getAtKey(TI_IMEX_STATUS_EXPORT);			//default to export
			endif;
			self.cmbImexStatus.listIndex := self.cmbImexStatus.findObject(imex);

		else
			imex := app.myRoot.allImexStatuses.getAtKey(TI_IMEX_STATUS_EXPORT);			//default to export
			self.cmbImexStatus.listIndex := self.cmbImexStatus.findObject(imex);
		endif;

		self.tblCargo.setValueByControlName(self.cmbImexStatus.name, self.cmbImexStatus.text);
	endif; 
	
	//06 Sep 2013	NDL	Par 32413
	if tblCargo.isRowVisible(ETRow_DimType)  then
		self.cmbDimType.visible := true;
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_DimType),2);
		dimType := null;
		index := 0;
		if myTrackedItem &lt;&gt; null and self.myTrackedItem.isKindOf(CM_BreakBulkGeneric) then
			dimType := myTrackedItem.CM_BreakBulkGeneric.type;
		endif;
		if dimType &lt;&gt; null then
			index := self.cmbDimType.findStringExact(1,dimType);	
		elseif existingString &lt;&gt; null then
			index := self.cmbDimType.findStringExact(1,existingString);
		endif;
		if index &gt; 0 then
			self.cmbDimType.listIndex := index;
		else
			self.cmbDimType.listIndex := -1;
		endif;

		self.tblCargo.setValueByControlName(self.cmbDimType.name, self.cmbDimType.text);
	else
		self.cmbDimType.visible := false;
	endif; 
	
	//23 Sep 2013	NDL	Par 32215
	if tblCargo.isRowVisible(ETRow_Make)  then
		self.cmbVehicleMake.visible := true;
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_Make),2);
		make := null;
		index := 0;
		if myTrackedItem &lt;&gt; null and self.myTrackedItem.isKindOf(CM_Car) then
			make := myTrackedItem.CM_Car.getVehicleMake();
		endif;
		if make &lt;&gt; null then
			index := self.cmbVehicleMake.findObject(make);	
		elseif existingString &lt;&gt; null then
			index := self.cmbVehicleMake.findStringExact(1,existingString);
		endif;
		if index &gt; 0 then
			self.cmbVehicleMake.listIndex := index;
		else
			self.cmbVehicleMake.listIndex := -1;
		endif;

		self.tblCargo.setValueByControlName(self.cmbVehicleMake.name, self.cmbVehicleMake.text);
	else
		self.cmbVehicleMake.visible := false;
	endif; 
	
	if tblCargo.isRowVisible(ETRow_Model)then
		self.cmbVehicleModel.visible := true;
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_Model),2);
		model := null;
		index := 0;
		if myTrackedItem &lt;&gt; null and self.myTrackedItem.isKindOf(CM_Car) then
			model := myTrackedItem.CM_Car.getVehicleModel();
		endif;
		if model &lt;&gt; null then
			index := self.cmbVehicleModel.findObject(model);	
		elseif existingString &lt;&gt; null then
			index := self.cmbVehicleModel.findStringExact(1,existingString);
		endif;
		if index &gt; 0 then
			self.cmbVehicleModel.listIndex := index;
		else
			self.cmbVehicleModel.listIndex := -1;
		endif;

		self.tblCargo.setValueByControlName(self.cmbVehicleModel.name, self.cmbVehicleModel.text);
	else
		self.cmbVehicleModel.visible := false;
	endif; 
	
	if tblCargo.isRowVisible(ETRow_VehicleType) then
		self.cmbVehicleType.visible := true;
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_VehicleType),2);
		vehType := null;
		index := 0;
		if myTrackedItem &lt;&gt; null and self.myTrackedItem.isKindOf(CM_Car) then
			vehType := myTrackedItem.CM_Car.getVehicleType;
		endif;
		if vehType &lt;&gt; null then
			index := self.cmbVehicleType.findObject(vehType);	
		elseif existingString &lt;&gt; null then
			index := self.cmbVehicleType.findStringExact(1,existingString);
		endif;
		if index &gt; 0 then
			self.cmbVehicleType.listIndex := index;
		else
			self.cmbVehicleType.listIndex := -1;
		endif;

		self.tblCargo.setValueByControlName(self.cmbVehicleType.name, self.cmbVehicleType.text);
	else
		self.cmbVehicleType.visible := false;
	endif; 
	
	//24 Sep 2013	NDL	Par 32556
	if tblCargo.isRowVisible(ETRow_TrailerType)  then
		self.cmbTrailerType.visible := true;
		existingString := null;
		existingString := tblCargo.getCellText(tblCargo.getRow(ETRow_TrailerType),2);
		tilcType := null;
		index := 0;
		if myTrackedItem &lt;&gt; null and self.myTrackedItem.isKindOf(CM_TILC) then
			tilcType := myTrackedItem.CM_TILC.myTILCType;
		endif;
		if tilcType &lt;&gt; null then
			index := self.cmbTrailerType.findObject(tilcType);	
		elseif existingString &lt;&gt; null then
			index := self.cmbTrailerType.findStringExact(1,existingString);
		endif;
		if index &gt; 0 then
			self.cmbTrailerType.listIndex := index;
		else
			self.cmbTrailerType.listIndex := -1;
		endif;

		self.tblCargo.setValueByControlName(self.cmbTrailerType.name, self.cmbTrailerType.text);
	else
		self.cmbTrailerType.visible := false;
	endif; 
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEntTable" id="ab3323a6-1d02-4bec-b1f3-b1115186e736">
        <updating/>
        <source>setEntTable( entTableString : String ) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	entTableRow : EntTableRow;
	rowIndex : Integer;
	
begin
	
	self.myEntTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[entTableString];
	if self.myEntTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; entTableString &amp; ') not found');
		return;
	endif;
	
	self.myEntTableView := self.myEntTableDef.allEntTableViews[ETView_HandHeld];
	if self.myEntTableView = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'View (' &amp; ETView_HandHeld &amp; ') within (' &amp; entTableString &amp; ') not found');
		return;
	endif;
	
	self.tblCargo.setEntTableFromView(self.myEntTableDef, self.myEntTableView, null, null);
	
	self.tblCargo.columnWidth[1] := (self.tblCargo.width / 3).Integer;
								
	self.loadTblCargo();
	
	//05 Mar 2014 	NDL	Par 33596 - Quick and Dirty until we change all forms to use "Total Quantity" and "Number of IDs"
	rowIndex := self.tblCargo.getRowByName(ETRow_NumItems);
	if self.tblCargo.getRowByName(ETRow_NumItems)  &gt; 0 then
		if rowIndex &gt; 0 then
			self.tblCargo.setCellText(rowIndex,1,app.getErrorString(CM_Total_Quantity));
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="entTableString" type="String"/>
    </JadeMethod>
    <JadeMethod name="setErrorPostionFor" id="a81cbdfa-6480-4c48-82bc-d1966ac24e78">
        <source>setErrorPostionFor( _attrName : String ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	row : Integer;
	
begin

	row := tblCargo.getRow(_attrName);
	
	if row &gt; 0 then
		self.tblCargo.topRow := row;
		self.tblCargo.row := row;
		self.tblCargo.column := 2;
		self.tblCargo.setFocus();
		self.tblCargo.leftColumn := 1;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setInitialCursorPosition" id="a812c4ce-5b2e-4101-b63b-35532442258e">
        <source>setInitialCursorPosition() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	cursorRow : Integer;
	locRow : Integer;
	cargoType : CM_CargoType;
	tableCell : JadeTableCell;
	bookingNumber : String;
	config : Integer;
	rowIndex : Integer;
	
begin

	cursorRow := tblCargo.getRow(ETRow_CargoId);
	
	if self.formAction = UnloadingUnknownTi then
	
		//27 Sep 2010	NDL	Par 25744
		config :=  self.myTerminal.getConfig(BookingRefRequired).Integer;
		bookingNumber := getStringValueFromTable( ETRow_BookingReference );
		if bookingNumber = null and config = BookingRequired_Strict then
			if tblCargo.getRow(ETRow_BookingReference) &gt; 0 then
				cursorRow := tblCargo.getRow(ETRow_BookingReference);
			endif;
			
		else
		
			cargoType := self.cmbType.listObject.CM_CargoType;
			if cargoType = null and tblCargo.getRow(ETRow_CargoType) &gt; 0 then
				// need to capture the cargo type first.
				cursorRow := tblCargo.getRow(ETRow_CargoType);	
			endif;
		
		endif;
		self.tblCargo.row := cursorRow;
		
	elseif cursorRow &gt; 0 and self.tblCargo.getCellText(cursorRow,2).trimBlanks = null then
		// if there is no cargo id entered, set the focus in this cell in 
		//readiness to scan / enter the id.
		self.tblCargo.row := cursorRow;
		
	else
		// we should be entering the location
		locRow := tblCargo.getRow(ETRow_Location);
		if locRow &gt; 0 then
			self.tblCargo.row := locRow;
		else
			self.tblCargo.row := cursorRow;
		endif;
		
	endif;
	
	//02 Sep 2013	NDL	Par 32368
	if self.lockedDown then
		if not self.tblCargo.accessCell(self.tblCargo.row,2).enabled then
			// have chosen a row that we can't enter into, find the first one we can enter into.
			foreach rowIndex in self.tblCargo.fixedRows + 1 to self.tblCargo.rows do
				if self.tblCargo.accessCell(rowIndex,2).enabled then
					if self.tblCargo.accessRow(rowIndex).visible then
						self.tblCargo.row := rowIndex;
						break;
					endif;
				endif;
			endforeach;
		endif;
	endif;
	
	self.tblCargo.columnWidth[1] := (self.tblCargo.width / 3).Integer;
	self.tblCargo.columnWidth[2] := ( ( self.tblCargo.width / 3) * 2 ).Integer;

	// position scroll bar so that the left column is visible.
	self.tblCargo.leftColumn := 1;	
	self.tblCargo.column := 2;
	tableCell := self.tblCargo.accessCell(cursorRow,2);
	
	//24 Mar 2010 	NDL	Par 23316
	if tableCell.cellControl &lt;&gt; null and tableCell.cellControl.isKindOf(TextBox) then
		tableCell.cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
	endif;
	
	self.tblCargo.setFocus();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bf60ce40-79a8-41b0-8a98-9754d6965add">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	entTableString :String;
	
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	self.setupCmdButtons( 3, app.getErrorString(SAVE_THAT_LADY_YO), app.getErrorString(Checks), app.getErrorString(Back), null, null );

	self.setBaseData();
		
	inheritMethod();
	
	//epr tfs 1939 5/5/16 changes for perfomance populate comobos once when for loads
	self.populateCombos();
	
	resetEntTableIfRequired(null);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblCargo_click" id="c2fc5a83-90ce-44f8-af3f-d5f5e74f00e7">
        <controlMethod name="CM_MobEntryTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargo_click(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

begin

	if table.column = 2 then	//02 Sep 2013	NDL	Par 32368
		self.checkIfLockedDown();
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
