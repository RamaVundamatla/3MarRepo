    <JadeMethod name="isSnapShotDataMatch" id="37751d11-87d1-47f2-bd7b-b9f98194b714">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 28/04/2015	cnwdap1		Initial creation PAR #36094 CCM SSFW 1413 TFS 313 Cold Store Enhancements
//
vars

begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	if _criteria.myYAData.CM_YADataString.value.Decimal = _propertyValue.Decimal or
	   _criteria.myYAData.CM_YADataString.value = null then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
