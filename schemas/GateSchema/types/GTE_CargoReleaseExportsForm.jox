    <JadeMethod name="showThumbnailData" id="d8e243ca-acd3-4f25-bca5-843b9a368f71">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
//-----------------------------------------
// Created: February 2004 By: cnwgd1
//-----------------------------------------
vars
	ti				: CM_TrackedItem;
	str,
	dataStr			: String;
	headings,
	data			: HugeStringArray;
	dataSize,
	i				: Integer;
			
begin

	ti := obj.CM_TrackedItem;

	self.setNavigatorHeading(ti.cargoTypeDescr &amp; ' (' &amp; ti.id &amp; ')');
	tblThumb.rows := 0;
		
	create headings transient;
	create data transient;
	ti.showThumbnailData(headings, data, false,false, false); //cnwrd1 10.11.08 CCMS JMT 1743/1764 
	dataSize := data.size;
	foreach str in headings do
		i := i + 1;
		if i &gt; dataSize then
			break;
		endif;
		dataStr := data[i];
		if not self.includeThumbnailEmptyRow(dataStr,null,str) then
			continue;
		endif;
		
		tblThumb.addItem(str &amp; Tab &amp; data[i]);
	endforeach;

	self.btnSelectAllTV.enabled:= true;
	
epilog
	delete headings;
	delete data;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="da11a873-3ca1-42dc-9e82-2e20aa48c45b">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpTI	: CM_TrackedItem;

begin

// do NOT do an inherit method here

	tmpTI := theObject.CM_TrackedItem;
	
	if eventType = Object_Delete_Event then
		self.zTblDataSysNotifyDelete(Object_Delete_Event, tmpTI, eventTag);

	elseif eventType = Object_Update_Event then
		self.zTblDataSysNotifyUpdate(eventType, theObject, eventTag);

	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="221d0497-be56-4492-bb3b-f5cb5f0139bb">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: CM_TrackedItem);
//--------------------------------------------------
// Created:	16 February 2004 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------
// 02/06/2016	cnwdap1		TFS #1949 VGM Process Requirements - Allocations
vars
	drwAtt		: CM_DrawingAttribute;
	theCell		: JadeTableCell;
	cellText	: String;
begin
	inheritMethod(_idxRow, _obj);
	
	if self.columnCEDO &gt; 0 then
		cellText := tblData.accessCell(_idxRow, self.columnCEDO).text;
		//if the cell has not been updated from the note yet do it
		if _obj &lt;&gt; null and _obj.getCustExpEntryNoMinusSlash() &lt;&gt; null then
			cellText := _obj.getCustExpEntryNoMinusSlash();
			tblData.accessCell(_idxRow, self.columnCEDO).text := cellText;
		endif;
		if cellText = null 
		or cellText = NA_Coastal then
			if _obj &lt;&gt; null and _obj.isCoastalOutbound then
				tblData.accessCell(_idxRow, self.columnCEDO).foreColor := self.ColorGreyDark;
			else
				tblData.accessCell(_idxRow, self.columnCEDO).backColor := Red;
			endif;
		else
			tblData.accessCell(_idxRow, self.columnCEDO).backColor := tblData.backColor;
		endif;
	endif;

	if self.columnHeld &gt; 0 and self.columnHeld &lt;= self.tblData.columns then
		theCell := tblData.accessCell(_idxRow, self.columnHeld);
		if theCell.text &lt;&gt; null then
			drwAtt := app.myRoot.allDrawingAttributes[PicTICustomHold];
			if drwAtt &lt;&gt; null then
				theCell.foreColor := drwAtt.colour;
				theCell.text := drwAtt.fontCharacter.Character;	
				theCell.fontName := drwAtt.fontName;
			endif;								
		endif;
	endif;
	
	if _obj.isHazardous then
		self.tblData.accessRow(_idxRow).foreColor := Red; // AKB2004NOV
	endif;	
	
	if self.columnHasVGM &gt; 0 and self.columnHasVGM &lt;= self.tblData.columns then						// TFS #1949
		cellText := tblData.accessCell(_idxRow, self.columnHasVGM).text;							// TFS #1949
		//if the cell has not been updated from the note yet do it									// TFS #1949
		if _obj &lt;&gt; null and _obj.hasVGMDetails() and not _obj.isEmpty then							// TFS #1949
			cellText := _obj.hasVGMDetails.getYes;													// TFS #1949
			tblData.accessCell(_idxRow, self.columnHasVGM).text := cellText;						// TFS #1949
		endif;																						// TFS #1949
		if cellText = null then																		// TFS #1949
			if _obj &lt;&gt; null and not _obj.hasVGMDetails and not _obj.isEmpty then					// TFS #1949
				tblData.accessCell(_idxRow, self.columnHasVGM).backColor := Red;					// TFS #1949
			else																					// TFS #1949
				tblData.accessCell(_idxRow, self.columnHasVGM).backColor := self.tblData.backColor;	// TFS #1949
			endif;																					// TFS #1949
		else																						// TFS #1949
			tblData.accessCell(_idxRow, self.columnHasVGM).backColor := tblData.backColor;			// TFS #1949
		endif;																						// TFS #1949
	endif;																							// TFS #1949
end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b62fa761-bda6-49ac-a70b-176cbc801ece">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005434, locale);
	mnuCargo.translateCaption(Xlat_0005435, locale);
	mnuTransactions.translateCaption(Xlat_0005436, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="22f82eeb-ae98-48a5-abfb-42cf128e09d9">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	termEvent	: Integer;
	tmpTI		: CM_TrackedItem;

begin

	if self.myTerminal &lt;&gt; null then
		termEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	endif;

	if termEvent = TIEvent_Terminal_Release then
		// treat as a delete because it has been removed from the collection for on-site items
		tmpTI := theObject.CM_TrackedItem;
		self.zTblDataSysNotifyDelete(Object_Delete_Event, tmpTI, eventTag);
		
	elseif termEvent = TIEvent_Terminal_Receival or termEvent = TIEvent_PreNote_Add then
		tmpTI := theObject.CM_TrackedItem;
		if tmpTI.isExport then
			// treat as a create
			self.zTblDataSysNotifyCreate(Object_Create_Event, tmpTI, eventTag);
		endif;
	endif;

	inheritMethod(eventType, theObject, eventTag, userInfo);

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
