    <JadeMethod name="renameFile" id="b9396526-0af6-40b1-9302-f4b9cd8cb3fe">
        <updating/>
        <source>renameFile(pOldFileName:String; pNewFileName:String; pNodeOptions:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		09 July 2002 by cnwdad2
//
// Purpose:		Renames the requested file to the specified new name.
//
// Parameters:	pOldFileName - The original name of the file.
//				pNewFileName - The new name of the file.
//				pNodeOptions - Specifies the source JADE nodes.
//
// Returns:		True if the operation succeeded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sourceNode	: Integer;
	
begin
	on Exception do self.xHandler(exception);
	
	self.doFileErrorSet(0, null);
	
	if self.interpretSourceNodeOptions(pNodeOptions, sourceNode) then
	
		if sourceNode = JSSFMFileManagerService.NODE_SOURCE_CLIENT then
			return self.renameDiskFileClient(pOldFileName, pNewFileName);
			
		elseif sourceNode = JSSFMFileManagerService.NODE_SOURCE_APPSERVER then
			return self.renameDiskFileAppServer(pOldFileName, pNewFileName);
			
		elseif sourceNode = JSSFMFileManagerService.NODE_SOURCE_DBSERVER then
			return self.renameDiskFileDbServer(pOldFileName, pNewFileName);
			
		endif;
		
	endif;
epilog
	on Exception do null;
	
	self.doFileErrorCheck();
end;</source>
        <Parameter name="pOldFileName" type="String"/>
        <Parameter name="pNewFileName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFileChunkSize" id="d43dafab-0652-4daa-bb8f-f0f377ded138">
        <updating/>
        <source>setFileChunkSize(pChunkSize:Decimal) updating;
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad2
//
// Purpose:		Updates the receiver's fileChunkSize property.
//
// Parameters:	pChunkSize - The new chunk size value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	chunkSize	: Decimal[23];
	
begin
	if pChunkSize = 0 then
		chunkSize	:=	self.COPY_CHUNK_SIZE;		// Default value.
	else
		chunkSize	:=	pChunkSize;
	endif;
	
	if self.fileChunkSize &lt;&gt; chunkSize then
		self.fileChunkSize	:=	chunkSize;
	endif;
end;</source>
        <Parameter name="pChunkSize" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setServiceManager" id="622d4ab4-48d8-4ed7-8413-d8ea24b38261">
