<Class name="CMIF_1StopRoadExitRequest" id="5c86da4b-23c9-4bf3-bb09-f954ab6d3b31">
    <superclass name="CMIF_Object"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myVehicleVisit" id="e0b500ed-1b89-4345-8a6f-dc8cffa69a62">
        <embedded/>
        <type name="CM_VehicleVisitRecord"/>
    </ImplicitInverseRef>
    <JadeMethod name="getActivityDescription" id="f27d50ec-e978-497d-9074-997d3ef5c558">
        <source>getActivityDescription() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/01/2022	navdap1		Initial creation TFS 52268 AAT 1-Stop VBS Integration
//
vars

begin
	return "Visit Number: " &amp; self.myVehicleVisit.visitNumber &amp; CrLf &amp;
			"Number of bookings: " &amp; self.myVehicleVisit.all1StopExtVehicleBookings.size.String &amp; CrLf &amp;
			"Number of released items: " &amp; self.myVehicleVisit.allReleasedTrackedItems.size.String &amp; CrLf &amp;
			"Number of received items: " &amp; self.myVehicleVisit.allReceivedTrackedItems.size.String;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
