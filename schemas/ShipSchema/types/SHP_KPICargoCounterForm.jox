    <JadeMethod name="keyDown" id="8c51b6fc-ef35-4c98-92e7-1a4732aa30d5">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*

Date		    Who			Reason
12 October 2010	cnwas3	  Initial creation

*/

vars

begin
	if keyCode = CMUI_Key_F3 then		
		self.doShowParametersForm();	
	elseif keyCode = J_key_P then
		self.doPrintTblData();	
	elseif keyCode = J_key_C and shift.isAltKeyPressed  then
		self.unloadForm();		
	else
		inheritMethod(keyCode, shift);
	endif;
		
epilog

end;</source>
