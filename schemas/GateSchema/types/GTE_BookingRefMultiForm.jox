    <JadeMethod name="handleExtraTableTabbing" id="e464f637-3ca3-4481-a3a7-e5f28281c61e">
        <source>handleExtraTableTabbing(_keyCode: Integer io; _shift: Integer):Boolean;
/*
	Created on 28 March 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if self.tblExtra.parent = self.frm_BRItem then
		if self.tblExtra.isOnBottomEntryRow 
		and _shift = 0 then
			self.tabNext;
//			btnOkItem.setFocus;
			return false;
		elseif self.tblExtra.isOnTopEntryRow 
		and _shift = 1 then
			self.tabPrior;
//			btnCancelItem.setFocus;
			return false;
		endif;		
	else		
		return inheritMethod(_keyCode, _shift);
	endif;
end;</source>
        <Parameter name="_keyCode" type="Integer" usage="io"/>
        <Parameter name="_shift" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
