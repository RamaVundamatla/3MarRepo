	//self.exportObjects(CM_PortGroup, dirName, true, true, 0);
	//self.exportObjects(CM_Country, dirName, true, true, 0);
	//self.exportObjects(CM_ShipPort, dirName, true, true, 0);
	//self.exportObjects(CM_ShipPortGroup, dirName, true, true, 0);
	
	// Export config
	// Need to handle specifically at some point
	//self.exportObjects(CM_Root, dirName, true, false, 0);
	//self.exportObjects(CM_Terminal, dirName, true, false, 0);
	//self.exportObjects(CM_YAConfig, dirName, true, true, 0);	
	self.exportObjects(CMIF_ConfigTerminal, dirName, true, false, 0);

	result := true;
epilog
	if result then
		write "Fin Successfully.";
	else
		write "Fin failure.";
	endif;
	delete fileFolder;
end;</source>
    </JadeMethod>
    <JadeMethod name="flLoadEDIBayPlan" id="7a8c40fc-fbf6-444d-972a-bbca3a06d7b5">
        <source>flLoadEDIBayPlan();
//
// Florida GreenWSI demo Aug 2006
//
vars
	csvFileObj : CnEcCsvFile;
	fileDefObj : CnEcFileDefinition;
	recordObj : CnEcFileRecord;
	fieldObj : CnEcFileField;
	startTime : Integer;
	productCode : String;
	bolCode, lastBolCode : String;
	count : Integer;
	voyageCode, idCode, operatorCode, farmCode, label, hatch, deck : String;
	boxes : Integer;
	packDate : Date;
	operator : CM_Operator;
	agent : DEV_LoadAgent;
	result : Boolean;
	theUser : CM_User;
begin
	app.initialize();
	app.isConverting := true; // ignore warnings
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
//	theUser := CM_Terminal.firstInstance.users["SUPERUSER"];
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.warningsAcknowledged	:= true;
	on Exception do null global;
	app.setPassBackExceptions(false, false);
	startTime := app.clock();
	app.mousePointer :=	Busy;
	create csvFileObj;
	csvFileObj.headerFieldNo :=	1;
	csvFileObj.headerIdentifier	:=	"H";
	create fileDefObj transient;

	fileDefObj.set(FL_CSV_NAME, FL_CSV_DIR&amp;'\'&amp;FL_CSV_NAME, FL_CSV_DIR);
	csvFileObj.cnEcLoadCsvFile(fileDefObj, true, 10);

	if (csvFileObj.isCancelled) then
		write "The file load was cancelled.";
		return;
	endif;

	write "CSV File read in " &amp; ((app.clock - startTime) / 1000).String &amp; " seconds.";

	create agent transient;
	foreach recordObj in fileDefObj.allRecords do
		lastBolCode := bolCode;
		productCode := null;
		foreach fieldObj in recordObj.allFields do
//			write recordObj.recordNo.String &amp; ": " &amp; fieldObj.fieldNo.String &amp; "=" &amp; fieldObj.fieldValue;
			if fieldObj.fieldNo = 1 then
				voyageCode := fieldObj.fieldValue;
			elseif fieldObj.fieldNo = 3 then
				idCode := fieldObj.fieldValue;
			elseif fieldObj.fieldNo = 4 then
				operatorCode := fieldObj.fieldValue;
			elseif fieldObj.fieldNo = 5 then
				productCode := fieldObj.fieldValue;
			elseif fieldObj.fieldNo = 6 then
				label := fieldObj.fieldValue;
			elseif fieldObj.fieldNo = 7 then
				productCode := productCode&amp;'-'&amp;fieldObj.fieldValue;
			elseif fieldObj.fieldNo = 8 then
				productCode := productCode&amp;'-'&amp;fieldObj.fieldValue;
			elseif fieldObj.fieldNo = 9 then
				farmCode := fieldObj.fieldValue;
			elseif fieldObj.fieldNo = 11 then
				boxes := fieldObj.fieldValue.Integer;
			elseif fieldObj.fieldNo = 12 then
				packDate := fieldObj.fieldValue.Date;
			elseif fieldObj.fieldNo = 14 then
				hatch := fieldObj.fieldValue;
			elseif fieldObj.fieldNo = 3 then
				if fieldObj.fieldValue.toUpper().trimBlanks() = 'A' or
				   fieldObj.fieldValue.toUpper().trimBlanks() = 'B' then
					deck := "Over";
				else
					deck := "Under";
				endif;
			endif;
		endforeach;
		bolCode := productCode&amp;label&amp;farmCode&amp;packDate.String;
		if bolCode &lt;&gt; lastBolCode then
			// new bol
		endif;
//		write recordObj.recordNo.String &amp; ": " &amp; recordObj.getDelimitedRecord("|");
	endforeach;
epilog
	delete csvFileObj;
	delete fileDefObj;		// This will also delete the collections of Records and Fields.
	app.mousePointer := Idle;
	delete agent;	
	write "All done in " &amp; startTime.cnEcClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="flLoadOperators" id="600de716-030c-4f91-aca4-e2f74b094d76">
        <source>flLoadOperators();
//
// Florida GreenWSI demo Aug 2006
vars
	csvFileObj : CnEcCsvFile;
	fileDefObj : CnEcFileDefinition;
	recordObj : CnEcFileRecord;
	fieldObj : CnEcFileField;
	startTime : Integer;
	operatorCode, operatorDesc : String;
	strArray : StringArray;
	count : Integer;
	operator : CM_Operator;
	agent : DEV_LoadAgent;
	result : Boolean;
	theUser : CM_User;
	allCodeGroups:CM_CodeGroupsByTypeDict;
begin
	app.initialize();
	app.isConverting := true; // ignore warnings
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
//	theUser := CM_Terminal.firstInstance.users["SUPERUSER"];
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.warningsAcknowledged	:= true;
	on Exception do null global;
	app.setPassBackExceptions(false, false);
	startTime := app.clock();
	app.mousePointer :=	Busy;
	create csvFileObj;
	csvFileObj.headerFieldNo :=	1;
	csvFileObj.headerIdentifier	:=	"H";
	create fileDefObj transient;
	fileDefObj.set(FL_CSV_NAME, FL_CSV_DIR&amp;'\'&amp;FL_CSV_NAME, FL_CSV_DIR);
	csvFileObj.cnEcLoadCsvFile(fileDefObj, true, 10);
	if (csvFileObj.isCancelled) then
		write "The file load was cancelled.";
		return;
	endif;
	write "CSV File read in " &amp; ((app.clock - startTime) / 1000).String &amp; " seconds.";

	create agent transient;
	create strArray transient;
	foreach recordObj in fileDefObj.allRecords do
		operatorCode := null;
		foreach fieldObj in recordObj.allFields do
//			write recordObj.recordNo.String &amp; ": " &amp; fieldObj.fieldNo.String &amp; "=" &amp; fieldObj.fieldValue;
			if fieldObj.fieldNo = 4 then
				operatorCode := fieldObj.fieldValue;
			endif;
		endforeach;
		if not strArray.includes(operatorCode) then
			strArray.add(operatorCode);
			create operator transient;
			create allCodeGroups transient;
			operator.setProxy(operatorCode, operatorCode, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, allCodeGroups,false, false, false,
							null, null, //cnwrd1 4.11.08 CCMS JMT 1743/1764  // adm 210708 CCMS 1738
								0, //cnwjo3 CCMS 1892, par 23587
								false,	// 14/03/2011 cnwcs5 par 26909 
								false	// 20/10/2011 cnwdap1 PAR #28524 CCMS POL 2096
								);
			
			result := agent.sendMsgWithParams("loadOperator", operator).Boolean;
		endif;
		// Alternatively, we could simply get a string of all fields delimited by a
		// specified character.  In this case, a "|" is used as the delimiter.

//		write recordObj.recordNo.String &amp; ": " &amp; recordObj.getDelimitedRecord("|");
	endforeach;
//	foreach productCode in strArray do
//		write productCode;
//	endforeach;
epilog
	delete csvFileObj;
	delete fileDefObj;		// This will also delete the collections of Records and Fields.
	app.mousePointer := Idle;
	delete strArray;
	delete agent;	
	write "All done in " &amp; startTime.cnEcClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="flLoadProducts" id="0e5fd22f-57f0-4ec1-9974-9fac38b1b8af">
        <source>flLoadProducts();
//
// Florida GreenWSI demo Aug 2006
//
vars
	csvFileObj : CnEcCsvFile;
	fileDefObj : CnEcFileDefinition;
	recordObj : CnEcFileRecord;
	fieldObj : CnEcFileField;
	startTime : Integer;
	productCode, productDesc, operatorCode : String;
	strArray : StringArray;
	count : Integer;
	theUser : CM_User;
	product : CM_Product;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	handlingType : CM_HandlingType;
	result : Boolean;
	agent : DEV_LoadAgent;
	handlingSubType : CM_HandlingSubType;	//31 Mar 2017	NDL	TFS 3414
begin
	app.initialize();
	app.isConverting := true; // ignore warnings
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
//	theUser := CM_Terminal.firstInstance.users["SUPERUSER"];
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.warningsAcknowledged	:= true;
	on Exception do null global;
	app.setPassBackExceptions(false, false);
	startTime := app.clock();
	app.mousePointer :=	Busy;
	create csvFileObj;
	csvFileObj.headerFieldNo :=	1;
	csvFileObj.headerIdentifier	:=	"H";
	create fileDefObj transient;

	fileDefObj.set(FL_CSV_NAME, FL_CSV_DIR&amp;'\'&amp;FL_CSV_NAME, FL_CSV_DIR);
	csvFileObj.cnEcLoadCsvFile(fileDefObj, true, 10);

	if (csvFileObj.isCancelled) then
		write "The file load was cancelled.";
		return;
	endif;

	write "CSV File read in " &amp; ((app.clock - startTime) / 1000).String &amp; " seconds.";
	create agent transient;
	create strArray transient;
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk];
	handlingType := app.myRoot.allHandlingTypes[TI_HandlingType_Pallets];
	foreach recordObj in fileDefObj.allRecords do
		productCode := null;
		foreach fieldObj in recordObj.allFields do
//			write recordObj.recordNo.String &amp; ": " &amp; fieldObj.fieldNo.String &amp; "=" &amp; fieldObj.fieldValue;
			if fieldObj.fieldNo = 4 then
				operatorCode := fieldObj.fieldValue;
				operator := app.myRoot.allOperators[operatorCode];
			elseif fieldObj.fieldNo = 5 then
				productCode := fieldObj.fieldValue;
				if fieldObj.fieldValue = "SQ" then
					productDesc := "SQUASH";
				elseif fieldObj.fieldValue = "HDW" then
					productDesc := "Honeydew";
				elseif fieldObj.fieldValue = "WM" then
					productDesc := "Watermelon";
				elseif fieldObj.fieldValue = "CAN" then
					productDesc := "Cantelope";
				else
					write fieldObj.fieldValue&amp;" was not found";
				endif;
			elseif fieldObj.fieldNo = 7 then
				productCode := productCode&amp;'-'&amp;fieldObj.fieldValue;
				if fieldObj.fieldValue.cnEcSubstringCount('J') &lt;&gt; 0 then
					productDesc := productDesc&amp;' '&amp;"Jumbo";
				elseif fieldObj.fieldValue.cnEcSubstringCount('XL') &lt;&gt; 0 then
					productDesc := productDesc&amp;' '&amp;"ExtraLarge";
				elseif fieldObj.fieldValue.cnEcSubstringCount('L') &lt;&gt; 0 then
					productDesc := productDesc&amp;' '&amp;"Large";
				elseif fieldObj.fieldValue.cnEcSubstringCount('M') &lt;&gt; 0 then
					productDesc := productDesc&amp;' '&amp;"Medium";
				elseif fieldObj.fieldValue.cnEcSubstringCount('S') &lt;&gt; 0 then
					productDesc := productDesc&amp;' '&amp;"Small";
				else
//					write fieldObj.fieldValue&amp;" was not found";
				endif;
				count := fieldObj.fieldValue.Integer;
				if count &lt;&gt; 0 then
					productDesc := productDesc&amp;' '&amp;count.String&amp;" per box";
				endif;
			elseif fieldObj.fieldNo = 8 then
				productCode := productCode&amp;'-'&amp;fieldObj.fieldValue;
				if fieldObj.fieldValue = "F" then
					productDesc := productDesc&amp;' '&amp;"First Grade";
				elseif fieldObj.fieldValue = "S" then
					productDesc := productDesc&amp;' '&amp;"Second Grade";
				elseif fieldObj.fieldValue = "T" then
					productDesc := productDesc&amp;' '&amp;"Third Rate";
				else
					write fieldObj.fieldValue&amp;" was not found";
				endif;
			endif;
		endforeach;
		if not strArray.includes(productCode) then
			strArray.add(productCode);
			write productCode&amp;' '&amp;productDesc;
			create product transient;
//			create allCodeGroups transient;
			product.setProxy(cargoType, operator, null, null, handlingType, handlingSubType, 0, productCode, productDesc, 0, false, false, false, false,false,false,false);
			result := agent.sendMsgWithParams("loadProduct", product).Boolean;
		endif;
		// Alternatively, we could simply get a string of all fields delimited by a
		// specified character.  In this case, a "|" is used as the delimiter.

//		write recordObj.recordNo.String &amp; ": " &amp; recordObj.getDelimitedRecord("|");
	endforeach;
//	foreach productCode in strArray do
//		write productCode;
//	endforeach;
epilog
	delete csvFileObj;
	delete fileDefObj;		// This will also delete the collections of Records and Fields.
	app.mousePointer := Idle;
	delete strArray;
	delete agent;	
	write "All done in " &amp; startTime.cnEcClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="foo" id="342c8c90-1ae6-4c7e-b308-00d4fa08bdec">
