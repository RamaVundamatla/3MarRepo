        <source>isChildRow(_row: Integer): Boolean updating;
//20 January 2009	cnwdw1	
// The child rows in the table can be either YABlocks or YABlockGroups
/*

Date		Who		Reason
28 Jun 2010	cnwkpd1	PAR #24605 - Performance enhancement for Satellite View - change to call accessRow only once

