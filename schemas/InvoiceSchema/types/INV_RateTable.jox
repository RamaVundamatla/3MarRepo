    <JadeMethod name="addToolbarControls" id="f9f4bc5d-703f-44dd-a7eb-600fa38b444f">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	frm				: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;

	inheritMethod();
	//changed by cnwyl1 for PAR 11590
	//was...
	/*frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addFrame(self.frmTBDate,CMUI_Toolbar.Control_Alignment_Left);*/
	
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnServiceGroup,CMUI_Toolbar.Control_Alignment_Left);		// cnwjre1 July 2010 24019 option for services by group
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExtractCSV,CMUI_Toolbar.Control_Alignment_Left);	//epr 19/6/2006 ccms 1440
	frm.addButton(self.btnLoadCSV,CMUI_Toolbar.Control_Alignment_Left);		//epr 19/6/2006 ccms 1789.
	frm.addFrame(self.frmTBDate,CMUI_Toolbar.Control_Alignment_Left);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="3f28ccc6-8812-4042-8be5-ce37c82323fd">
        <source>addToolbarControlsQuery() protected;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	queryToolbar			: CMUI_Toolbar;
begin

	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnQueryToday, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	queryToolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnExtractCSV_click" id="4f926e10-8103-4d3b-8e77-fcd5586b1a4f">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExtractCSV_click(btn: Button input) updating;

vars

begin
	self.doExtractCSVFile();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnLoadCSV_click" id="8194d00a-687d-40e0-9dd5-061f78a5441a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnLoadCSV_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		11 December 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doLoadCSVFile();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnQueryToday_click" id="d1657e3e-b0e2-4622-9ffa-59c63c11899e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnQueryToday_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 27 Mar 2018	jlgdap1	TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
vars
	aDate : Date;
begin
	aDate:= self.systemToLocalTime(app.actualTimeServer).date();// 25 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.txtDateDebtor.setDate(aDate);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnRefresh_click" id="4f3cfe42-b18f-438f-ae90-f2aa63133fe4">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRefresh_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.internalQuery := true;
	self.doQuery();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnServiceGroup_click" id="a3de860d-9424-4ca6-952e-bf09259f6e35">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnServiceGroup_click(btn: Button input) updating;
// 24019 add option to show services by group
vars

begin
	if self.servicesByGroup then
		self.servicesByGroup := false;
		btn.bubbleHelp := "Services by Name";
	else
		self.servicesByGroup := true;
		btn.bubbleHelp := "Services by Group";
	endif;
	
	// cause the query multi-select group box to refresh the services list boxes with/without the group name
	self.msgbServices.refreshOwnListboxes();
	self.internalQuery := true;
	self.doQuery();
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbBank_click" id="2b0cf79b-573e-4472-8b37-7fcd25c9364b">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBank_click(combobox: ComboBox input) updating;

vars
	bank	: CM_Bank;
begin
	bank := self.cmbBank.listObject.CM_Bank;			// 35872
	if bank &lt;&gt; null and bank &lt;&gt; self.myCurrentBank then
		self.myCurrentBank := bank;
		self.setServicesAvailable();
	endif;

end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbTrades_click" id="91a4adbe-1e8e-4c78-afe4-20725f7ad67b">
