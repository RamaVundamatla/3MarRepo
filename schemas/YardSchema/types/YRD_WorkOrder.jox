    <JadeMethod name="getWorkPointDaysToComplete" id="3e4f25f5-dd62-4997-984c-2fe2c941b8ce">
        <source>getWorkPointDaysToComplete(_workPoint	  : CM_WorkPoint;
							_holdJob 	  : CM_VoyageHoldJob;
							_newTrsfrType : CM_VoyageJobTransferType;
							_gangs 		  : Integer;
							_newAmount    : String;
							_newRate 	  : String output) : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
25 April 2022	navhl20 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	cargoType   : CM_CargoType;
	ti 	        : CM_TrackedItem;
	wpCraneRate : CM_WorkPointCargoRates;
	totalHrs 	: Decimal[16,2];
	hrsPerDay 	: Decimal[4,2];
	elapsedDays : Decimal[6,2];
	newAmount   : Decimal[16,2];
	unit 		: String;
	posUnit		: Integer;
	measureType : CM_MeasurementType;
	wle			: CM_WorkListEntry;
begin
	
	if _workPoint = null  or _holdJob = null then
		return null ;
	endif;
	
	wle       := _holdJob.workListEntries.first;
	
	if wle = null then
		return null ;
	endif;
	
	cargoType := wle.getCargoType();
	
	if cargoType = null then
		return null;
	endif;
	
	wpCraneRate:=_workPoint.getDefinedTargetRate(_holdJob,_newTrsfrType,ti);
	
	if wpCraneRate = null then
		return null;
	endif;
	
	newAmount	:=_newAmount.asDecimalJMT;
	
	if cargoType.isBulkByWeight then
		measureType:=cargoType.myWeightMeasurementType;	
	elseif cargoType.isBulkByVolume then
		measureType:=cargoType.myVolumeMeasurementType;
	endif;
	
	
	if measureType &lt;&gt; null then
		unit 	:= measureType.shortName;
		posUnit :=_newAmount.pos(unit,1);
		
		if posUnit &gt; 0 then
			newAmount	:= _newAmount[1:posUnit].trimBlanks.asDecimalJMT;
		endif;
		
		newAmount	:= newAmount * measureType.conversionRate;
	endif;
	
	if cargoType.isBulkByVolume then
		totalHrs := ( newAmount / wpCraneRate.targetRatePHVolume ).Decimal.roundedTo(2);
	elseif cargoType.isBulkByWeight then
		totalHrs := (newAmount / wpCraneRate.targetRatePHWeight ).Decimal.roundedTo(2);
	else
		totalHrs := ( _newAmount.Integer / wpCraneRate.targetRatePHQuantity ).Decimal.roundedTo(2);
	endif;
	
	_newRate := wpCraneRate.getTargetRateStr();
	
	if totalHrs &lt;= 0 then
		return 0.0;
	endif;
	
	if _gangs &gt; 1 then
		totalHrs := totalHrs / _gangs;
	endif;

	if wpCraneRate.dailyHoursWorkable &gt; 0 and totalHrs &gt; wpCraneRate.dailyHoursWorkable then
		hrsPerDay := wpCraneRate.dailyHoursWorkable;
	else
		hrsPerDay := 24.0;
	endif;
	
	elapsedDays := ( totalHrs / hrsPerDay ).Decimal.roundedTo(2);
	
	return elapsedDays;
epilog

end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <Parameter name="_holdJob" type="CM_VoyageHoldJob"/>
        <Parameter name="_newTrsfrType" type="CM_VoyageJobTransferType"/>
        <Parameter name="_gangs" type="Integer"/>
        <Parameter name="_newAmount" type="String"/>
        <Parameter name="_newRate" type="String" usage="output"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
