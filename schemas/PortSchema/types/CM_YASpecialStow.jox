    <JadeMethod name="isSnapShotDataMatch" id="849a677f-f396-4ab7-9739-8cffffd27b3c">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;

vars
	obj		: Object;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	foreach obj in _criteria.myYAData.CM_YADataObjects.allObjects do
		if obj.CM_SpecialStow.code = _propertyValue then
			return true;
		endif;
	endforeach;
	
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="1343c652-b516-44da-8a38-471ae7c97eda">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023	navmk20	Task 57998: JADE - Storage Config - YA Criteria Storage Matching

*/

vars
	specialStow			: CM_SpecialStow;
	yaData				: CM_YAData;
	myTrackedItem		: CM_TrackedItem;
begin 

	if _tiTrx &lt;&gt; null then 
		myTrackedItem := _tiTrx.myTrackedItem;
		if myTrackedItem &lt;&gt; null then
			specialStow	:= myTrackedItem.getSpecialStow();
		endif;
	elseif _ti &lt;&gt; null then
		specialStow	:= _ti.getSpecialStow();
	endif;
	
	yaData := _criteria.myYAData;
	
	if yaData.CM_YADataObjects.matchesStorage(specialStow) then
		return true;
	endif;
	
	if yaData.isKindOf(CM_YADataPattern) and
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageAllocationCT" id="6b6a1236-2775-4dec-a8c6-6bb37e87f1b7">
