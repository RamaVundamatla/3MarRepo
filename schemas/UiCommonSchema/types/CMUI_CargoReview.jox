    <JadeMethod name="checkProgress" id="6f93858d-5619-4bba-a7f9-1fc27a3de563">
        <source>checkProgress(partsDone, partsInJob : Integer; lastUpdated : Decimal io) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2022	jlier1	Initial creation 53515

*/

vars

begin
	if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
		self.modalDialogUpdateInfo(app.getErrorString2(Displaying_items, partsDone.String, partsInJob.String));
		self.pbProgressBar.partsDone := partsDone;
		self.btnModalDefault.doWindowEvents(0);
		self.frmModalDialog.refreshNow();
		if self.modalDialogReturnValue = CMIF_Monitor.MonitorReturnValue_Cancel then
			return false;
		endif;
		lastUpdated := app.relativeMachineTime;														// PAR #35843
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="partsDone" type="Integer"/>
        <Parameter name="partsInJob" type="Integer"/>
        <Parameter name="lastUpdated" type="Decimal" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="chkAll_click" id="f9e8d128-6f69-4c56-ba52-6f0fafa407bc">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkAll_click(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2022	jlier1	Initial creation

*/

vars

begin
	if checkbox.value then
		self.tblArgument.selectAll;
		self.chkAll.caption := Space &amp; app.getErrorString(None);
	else
		self.tblArgument.clearSelected;
		self.chkAll.caption := Space &amp; app.getErrorString(CM_LIT_ALL);
	endif;
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
