    <JadeMethod name="isRotatable" id="7992220e-fd4c-4c2f-8064-60797b6b5abf">
        <source>isRotatable() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE

*/

vars

begin
	
	return self.typeAttributes.bitAnd(ISO_ROTATABLE) &lt;&gt; null;
	
