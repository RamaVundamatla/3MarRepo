    <JadeMethod name="outputHeader_TDT" id="028faad6-33fd-4a9b-a2e8-2c433db7c3a1">
        <updating/>
        <source>outputHeader_TDT(_camTaskHistory :CM_CamTaskHistory input; _protocol :CM_CamProtocol; _camVoyage :CM_CamVoyage; _count :Integer io; _coll :HugeStringArray input) : String updating, protected;
/*
Purpose:		Output TDT+20 segment for voyage			

Date		Who		Reason
17 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
19 Dec 2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	voyage	:CM_Voyage;
	strLine : String;
begin
	voyage	:= _camVoyage.voyageOid;
	
	if voyage &lt;&gt; null and not voyage.isNullVoyage then
		if _protocol.camGroup.useCallSign then
			strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeTDT20Segment (_protocol, _camVoyage.getSanitisedVoyageCode(), '1', 
														null, null, null, null, null, null, voyage.callSign.trimRight, '103', null, voyage.vesselName.trimRight.toUpper), _coll);
		else
			strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeTDT20Segment (_protocol, _camVoyage.getSanitisedVoyageCode(), '1', 
														null, null, null, null, null, null, voyage.lloydsNumber, '146', null, voyage.vesselName.trimRight.toUpper), _coll);
		endif;
	else
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeTDT20Segment (_protocol, _camVoyage.getSanitisedVoyageCode(), '1', 
													null, null, null, null, null, null, null, null, null, null), _coll);
	endif;
	_count := _count + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camVoyage" type="CM_CamVoyage"/>
        <Parameter name="_count" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNB" id="6fa679fc-322f-44df-874c-dcd623d64514">
        <updating/>
        <source>outputHeader_UNB(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _seqNumber :Integer; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
04/02/2013	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
vars
	msg :String;
begin
	if _protocol.camGroup.code.trimBlanks = "COL" and _protocol.terminal.getConfig(PortDestCode).String = "POE" then
		msg := self.makeUNBSegment (_protocol, "UNOA", 2, 'POTOTAGO', 'ZZ', _protocol.camGroup.recipient.trimBlanks, "ZZ", _seqNumber, null, true, _camTaskHistory.runDateTime);
		
	else
		msg := self.makeUNBSegment (_protocol, "UNOA", 2, self.getSenderCode_UNB (_protocol), "ZZ", _protocol.camGroup.recipient.trimBlanks, "ZZ", _seqNumber, null, false, _camTaskHistory.runDateTime);
	endif;

	return self.outputFileMessage(_camTaskHistory, msg, _coll);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
