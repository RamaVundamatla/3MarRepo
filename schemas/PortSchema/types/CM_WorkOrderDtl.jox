/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	str		: String;
	wagon	: CM_Wagon;
	wagons	: CM_WagonSet;
begin
	create wagons transient;
	
	self.getWagons(wagons);
	
	foreach wagon in wagons do
		if wagon.id = null then
			continue;
		endif;
		
		/* //16/01/2025	navkc1 JIRA Bug MTN-33804
		if str = null then
			str := wagon.id;
		else
			if str.pos(wagon.id, 1) &gt; null then
				continue;
			else
				str &amp;= Comma &amp; wagon.id;
			endif;
		endif;
		*/
		
		str.addStringToList(wagon.id, Comma); //16/01/2025	navkc1 JIRA Bug MTN-33804
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
