        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDLR_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		22 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	xLeft 	: Real;
	yTop	: Real;
begin
	
	xLeft := x;
	yTop := y;
	self.doContextMenuBuild();
	self.mnuLLUnplan.visible := false;
	self.mnuLLReadyToShip.visible := true;			// 27/9/19 MAP TFS 45590
	self.mnuLLLocateGridArea.visible := false;
	self.mnuContextShowOverstow.visible := false;	// PAR 21532 CCMS SFW 1025
	self.mnuContextMoveOverstow.visible := false;	// PAR 21532 CCMS SFW 1025

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   
	self.doTblDLRContextMenu(table,conwin,mouse,x,y);
	self.mnuContextTable.visible := true;
	self.mnuContextHide.visible := true;

	self.popupMenu(mnuContextTable, xLeft.Integer, yTop.Integer);

	return false;


end;</source>
