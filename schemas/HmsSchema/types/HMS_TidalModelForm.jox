    <JadeMethod name="displaySummary" id="33be5d1b-6b94-4d33-9af6-a22200b21088">
        <source>displaySummary(x:Real;table:Table input);

vars
 	ts:	TimeStamp;
begin
	if (x + table.left) &gt; self.xLow and (x + table.left) &lt;= self.xHigh then
		picSlider.left := x + table.left;
		
		if self.depthArray.size &gt;= x then
			lblSummaryDepth.caption := (self.chartDatum + self.depthArray[x.Integer].roundedTo(2)).String &amp; " (m)";
		endif;
		
		if self.flowRateArray.size &gt;= x then
			lblSummaryFlow.caption  := (self.flowRateArray[x.Integer].roundedTo(3)).String &amp; " (kt)"; //par19665 cnwrs1 May 2009
		endif;
		
		// Modified by Russell 19/10/99
		// -------------------------------------------------------------------------
		if self.timeArray.size &gt;= x then
			ts	:=	self.timeArray[x.Integer];
			lblTimeAtPosnVal.caption  := ts.date.shortFormatJMT() &amp; "; " &amp; ts.Time.userFormat($CM_HMS_Time24Hour);
		endif;
		// -------------------------------------------------------------------------
	endif;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
