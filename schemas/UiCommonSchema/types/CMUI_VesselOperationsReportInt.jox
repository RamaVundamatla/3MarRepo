    <JadeMethod name="addRowToDelayTable" id="0129cb62-44b2-4f6a-b9fd-7e19c8b19b89">
        <source>addRowToDelayTable(_table :Table input; _text :String; _dataArray :DecimalArray;_decimals :Integer):Integer protected;
/*
	Purpose:		Adds a row to the table		
	Parameters:		_table			- table being displayed
					_text			- text to display in columns 1-3
					_dataArray		- delay data for each crane (in hours)
					_decimals		- number of decimal places to display
	Return Value:		

Date			Who		Reason
24 July 2008	concms1	Initial creation
*/
constants
	TOTAL_COLUMN		= 10;
	VALUES_START_COLUMN	= 4;
vars
	row, int,
	size, col		:Integer;
	value, total	:Decimal [23, 8];
	str				:String;
begin
	row := _table.addItem (_text);
	
	// allow merge of first three columns
	_table.accessCell (row, 1).mergeCells	:= Table.MergeCells_Merge;	
	_table.accessedCell.alignment			:= Table.Alignment_Right;
	_table.accessedCell.fontBold			:= false;
	_table.accessCell (row, 3).mergeCells	:= Table.MergeCells_NotAvailable;
	
	
	// crane values
	size := _dataArray.size;
	
	foreach int in 1 to size do
		value := _dataArray[int].Decimal;
		total := total + value;
		
		if value = null then
			str := null;
		else
			str := value.asHoursMinutes;
		endif;
		
		col := VALUES_START_COLUMN + int - 1;	// column to put data
		
		_table.setCellText (row, col, str);
	endforeach;
	
	// totals
	if total = null then
		str := null;
	else
		str := total.asHoursMinutes;
	endif;
	
	_table.setCellText (row, TOTAL_COLUMN, str);
	
	return row;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_dataArray" type="DecimalArray"/>
        <Parameter name="_decimals" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addRowToHoursTable" id="d792740f-d4e1-4f2f-b2f0-f57f9e903c65">
        <source>addRowToHoursTable(_table :Table input; _text :String; _index :Integer; _dataArray :ObjectArray; _total :Decimal; _asHHMM :Boolean; _decimals :Integer):Integer protected;
/*
	Purpose:		Adds a row to the table		
	Parameters:		_table			- table being displayed
					_text			- text to display in columns 1-3
					_index			- position in array to get figures
					_dataArray		- contains array of data for each crane
					_totalsArray 	- contains the totals
					_decimals		- number of decimal places to display (ignored of _asHHMM is true)
					_asHHMM			- indicates whether to show the value as hours/minutes
	Return Value:		

Date			Who		Reason
24 July 2008	concms1	Initial creation
*/
constants
	TOTAL_COLUMN		= 10;
	VALUES_START_COLUMN	= 4;
vars
	row, int,
	size, col		:Integer;
	value, total	:Decimal [23, 8];
	str				:String;
begin
	row := _table.addItem (_text);
	
	// crane values
	size := _dataArray.size;
	
	foreach int in 1 to size do
		value := _dataArray[int].DecimalArray[_index];
		
		if value = null then
			str := null;
		elseif _asHHMM then
			str := value.asHoursMinutes;
		elseif _decimals = 0 then
			str := value.Integer.String;
		else
			str := value.roundedTo(_decimals).String;
		endif;
		
		col := VALUES_START_COLUMN + int -1;	// column to put data
		
		_table.setCellText (row, col, str);
	endforeach;
	
	// totals
	if _total = null then
		str := null;
	elseif _asHHMM then
		str := _total.asHoursMinutes;
	elseif _decimals = 0 then
		str := _total.Integer.String;
	else
		str := _total.roundedTo(_decimals).String;
	endif;
	
	_table.setCellText (row, TOTAL_COLUMN, str);
	
	return row;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_dataArray" type="ObjectArray"/>
        <Parameter name="_total" type="Decimal"/>
        <Parameter name="_asHHMM" type="Boolean"/>
        <Parameter name="_decimals" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addRowToMovesTable" id="8c504aae-26f5-4dfd-8c32-5aec36040e51">
        <source>addRowToMovesTable(_table :Table input; _text :String; _index :Integer; _dataArray :ObjectArray; _totalsArray :DecimalArray; _decimals :Integer):Integer protected;
/*
	Purpose:		Adds a row to the table		
	Parameters:		_table			- table being displayed
					_text			- text to display in columns 1-3
					_index			- position in array to get figures
					_dataArray		- contains array of data for each crane
					_totalsArray 	- contains the totals
					_decimals		- number of decimal places to display
	Return Value:		

Date			Who		Reason
24 July 2008	concms1	Initial creation
*/
constants
	TOTAL_COLUMN		= 10;
	VALUES_START_COLUMN	= 4;
vars
	row, int,
	size, col		:Integer;
	value, total	:Decimal [23, 8];
	str				:String;
begin
	row := _table.addItem (_text);
	
	// crane values
	size := _dataArray.size;
	
	foreach int in 1 to size do
		value := _dataArray[int].DecimalArray[_index];
		total := total + value;
		
		if value = null then
			str := null;
		elseif _decimals = 0 then
			str := value.Integer.String;
		else
			str := value.roundedTo(_decimals).String;
		endif;
		
		col := VALUES_START_COLUMN + int -1;	// column to put data
		
		_table.setCellText (row, col, str);
	endforeach;
	
	// totals
	if _totalsArray &lt;&gt; null then
		value := _totalsArray[_index];
	else
		// value is sum of array entries
		value := total;
	endif;
	
	if value = null then
		str := null;
	elseif _decimals = 0 then
		str := value.Integer.String;
	else
		str := value.roundedTo(_decimals).String;
	endif;
	
	_table.setCellText (row, TOTAL_COLUMN, str);
	
	return row;
epilog

end;</source>
