    <JadeMethod name="setPxyFromObject" id="ee99356b-f01f-46d6-8403-b4817e7e3537">
        <updating/>
        <source>setPxyFromObject(invoice : CM_Invoice) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 January 2026	navhn30	Initial creation

*/

vars
	toDTRate, fromDTRate : CM_CurrencyRate;

begin

	self.bankCode := invoice.bank.code;
	self.billOfLadingNumber := invoice.myBOL.number;
	self.bookingReference := invoice.myBookingRef.description;
	self.cargoGroupName := invoice.myCargoGroup.id;
	self.chargeTime := invoice.invoiceDate;
	self.contractDesc := invoice.contractIds;
	if invoice.myInvoiceNote &lt;&gt; null then
		self.creditNoteReasonCode := invoice.myInvoiceNote.note;
		self.invoiceNote := invoice.myInvoiceNote.note;
	endif;	
	self.externalInvoiceNumber := invoice.externalNumber;
	self.externalTaxNumber := invoice.externalTaxNumber;
	
	if invoice.myCurrencyType &lt;&gt; null then
		self.invoiceCurrency := invoice.myCurrencyType.code;
		
		fromDTRate := invoice.myCurrencyType.getRate(invoice.fromDT);
		if fromDTRate &lt;&gt; null then		
			self.fxRateInvEndDTMonthStart := fromDTRate.rate;
		endif;
		
		toDTRate := invoice.myCurrencyType.getRate(invoice.fromDT);
		if toDTRate &lt;&gt; null then
			self.fxRateInvEndDTMonthEnd := toDTRate.rate;
		endif;
	endif;
	
	self.invoiceNarration := invoice.narration;
	if invoice.myInvoiceProcess &lt;&gt; null then
		self.invoiceProcess := invoice.myInvoiceProcess.description;
	endif;	
	self.invoiceType := invoice.getCategory();
	self.invoiceTypeDesc := invoice.invoiceType.description;
	self.isManual := invoice.isManual;	
	self.isZeroRatedTax := invoice.isZeroRatedTax;
	if invoice.myLocale &lt;&gt; null then
		self.locale := invoice.myLocale.localeId;
	endif;
	self.paymentTermsCode := invoice.termsOfTrade;
	if invoice.myReleaseRequest &lt;&gt; null then
		self.releaseRequestID := invoice.myReleaseRequest.code;
	endif;
	self.sequenceNumber := invoice.sequenceNum;
	self.terminalCode := invoice.myTerminal.code;
	self.paymentTermsCode := invoice.termsOfTrade;
	
	if invoice.invoiceType &lt;&gt; null then
		if invoice.invoiceType.accrualType = 1 then 
			self.accuralType := "Accrue For Financial Period";
		else 
			self.accuralType := 'Until Closed';
		endif;
		
		if invoice.invoiceType.myInvTermsOfTrade &lt;&gt; null then
			self.termsOfTrade := invoice.invoiceType.myInvTermsOfTrade.description;
		endif;
	endif;
	
	if invoice.myWorkOrder &lt;&gt; null then
		self.workOrderNumber := invoice.myWorkOrder.id;
	endif;
	
	self.voyageID := invoice.voyageCode;
	self.totalTaxAmount := invoice.getTaxValueForInvoice();
	if invoice.invoiceLines &lt;&gt; null then
		self.totalNumberInvoiceLinesWhole := invoice.invoiceLines.size();	
	endif;
	self.totalInvoiceAmountWhole := invoice.totalAmount;


	
	
	





	
epilog

end;</source>
        <Parameter name="invoice" type="CM_Invoice"/>
    </JadeMethod>
</Class>
