    <JadeMethod name="getAuditTextForProperty" id="07a01b44-c20b-45aa-8622-bdb1dd4360e3">
        <source>getAuditTextForProperty(_property: Property): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwndl1	Initial creation	Par 27731
26 Jun 2025 navbs1	Story 35185: MTN - Refactor Required to Stop Using getDisplayStringForAttribute() for Known Attributes 

*/

vars

	propName : String;
	
begin

	propName := _property.name;

	if propName = CM_MTThreshold::myMTGrade.name then
		return self.formatAuditText(propName, self.getDisplayStringForAttribute(ETRow_MyMTGrade, false));
	
	else	
		return inheritMethod(_property);
		
	endif;

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="8a43fdb9-38cd-4d7e-b9ab-a39c3ab381bc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2011	cnwndl1	Initial creation

*/

vars

begin

	if _attrName = ETRow_MyMTGrade then
		if self.myMTGrade &lt;&gt; null then
			return self.myMTGrade.description;
		else
			return app.getErrorString(AnyString);
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
