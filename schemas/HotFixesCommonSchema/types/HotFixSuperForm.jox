end;
</source>
    </JadeMethod>
    <JadeMethod name="startHotFixSuper" id="24aec8b0-88d9-4789-b294-7fd2b3373316">
        <updating/>
        <source>startHotFixSuper() updating;
// Vytenis 11/2006
vars
	rtH			: RootHotFixes;
	rtHSuper	: RootHotFixSuper;
	dirHtFxSuper: FileFolder;		// folder of Hotfixes
	allDirs		: FileNodeArray;	// list of Hotfixes
	dirN		: FileNode;			// a directory of one Hotfix
	fInst		: File;
	pErrTxt		: String;
	rangeFrom, 
	rangeTo 	: Integer;

begin
	app.writeLogMessage('');
	app.writeLogMessage('');
	app.writeLogMessage(' _________________ Creating Super Hotfix _________________');

	rtH := app.myRootHotFix;
	if not rtH.initRootHotFixes( self.txtDirSetup.text, self.txtReleaseNo.text ) then
		return;
	endif;
	
	if rtH.myRootHotFixSuper = null then
		beginTransaction;
		create rtHSuper;
		rtHSuper.setForCreate( rtH, 0,0 );
		commitTransaction;
	endif;
	rtHSuper := app.myRootHotFix.myRootHotFixSuper;
	
	create dirHtFxSuper	transient;
	create allDirs		transient;
	create fInst transient;

	// getting list of all Hotfixes
	if not self.getDirsOfHotFixes( rtH.getDirHotFixes(), dirHtFxSuper, allDirs ) then
		return;
	endif;

	if allDirs.size = 0 then
		app.writeLogMessage('There are no Hotfix directories...');
		return;
	endif;
	//	We can make a super hotfix from one hotfix, though hotfix and superhotfix are equal in this case
	//if allDirs.size = 1 then
	//	app.writeLogMessage('There is only one Hotfix directory - ' &amp; allDirs[1].fileName;
	//	return;
	//endif;

	// check for range From and To and sets range integer values
	if not self.prepareRangeForSuperHotfix( self.txt_from.text.Integer, self.txt_to.text.Integer, rangeFrom, rangeTo ) then
		return;
	endif;
	beginTransaction;
	rtHSuper.setRange( rangeFrom, rangeTo );
	commitTransaction;

	// creating superHotfix directories
	if not rtH.createDirsForHotFix( 3, self.getNameDirHotFixSuper( allDirs ), self.getDirHotFixesSuper(), '', false, false ) then
 		return;
	endif;

	app.writeLogMessage('');
	app.writeLogMessage(' Processing Hotfixes:');
	foreach dirN in allDirs do
		if self.isHotfixInRangeOfSuperHotfix( dirN.fileName, rangeFrom, rangeTo ) then
			if not self.executeHotFix( dirN.fileName, allDirs ) then
				app.writeLogMessage('');
				app.writeLogMessage(' Creating failed...');
				return;
			endif;
		endif;
	endforeach;

	//setting singleuser if required
	self.setSingleUser(allDirs);	//Par18697. Dec 2008
	
	// copy JMTInstall.txt to JadeMaster
	fInst.fileName := self.getDirHotFixSuperClient(allDirs) &amp; rtH.FILE_JMT_INSTALL_NAME;
	if rtH.ZJade_Local_Mode_For_File_Copy then
		if not fInst.cnCopyFile( self.getDirHotFixSuperJadeMaster(allDirs) &amp; rtH.FILE_JMT_INSTALL_NAME, true, pErrTxt) then
			app.writeLogMessage('');
			app.writeLogMessage(pErrTxt);
			app.writeLogMessage(fInst.fileName.String &amp; ' not copied...');
			return;
		endif;
	else
		if not rtH.copyFile( fInst.fileName, self.getDirHotFixSuperJadeMaster(allDirs), true) then
			app.writeLogMessage('');
			app.writeLogMessage(fInst.fileName.String &amp; ' not copied...');
			return;
		endif;
	endif;
	
	if self.copyWeb(allDirs, rangeFrom, rangeTo) then		//cnwmc5 - 10 April 2014
		app.writeLogMessage('');
		app.writeLogMessage('Web files copied...');
	else
		app.writeLogMessage('');
		app.writeLogMessage('Web files not copied...');
	endif;
	
	//cnwmc5 - 10 April 2014
	app.writeLogMessage('');
	self.removeBinWebNotUsed(allDirs);
	
	app.writeLogMessage('');
	app.writeLogMessage(' Ok.');

	self.unloadForm();
	delete self;
	
epilog
	delete dirHtFxSuper;
	delete allDirs;
	delete fInst;
	
end;
</source>
    </JadeMethod>
</GUIClass>
