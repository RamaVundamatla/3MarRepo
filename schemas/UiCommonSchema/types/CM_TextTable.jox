    <JadeMethod name="mouseDown" id="35f0c847-7baa-4d0d-954b-8c09c07361db">
        <controlMethod name="CM_BaseTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	inheritMethod(table, button, shift, x, y);
	if table.CM_BaseTable.multiSelect &lt;&gt; MultiSelect_None and shift.bitAnd(2) &lt;&gt; 0 then
		self.controlKeyDown := true;
	else
		self.controlKeyDown := false;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="rowColumnChg" id="ab2df22a-0cec-4165-964e-49b7977a9d2d">
        <updating/>
        <source>rowColumnChg(table: Table input) updating;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	theRow		: JadeTableRow;
	theObject	: Object;
begin
	inheritMethod(table);

	if self.selectionType = self.SelectionType_Row then
		self.selectTheCurrentRow(table);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectRow" id="5016ea59-e2cf-4de1-befc-350b4958c98b">
        <updating/>
        <source>selectRow(_idx : Integer; _makeTopRow : Boolean) : Boolean updating;
/*
	Created on 12 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	theObj	: Object;
	theRow	: JadeTableRow;		
begin

	if _idx &lt;= self.fixedRows or _idx &gt; self.rows then
		return false;
	endif;

	theRow := self.accessRow(_idx);
	theRow.selected := true;
	if _makeTopRow then
		self.topRow := _idx;
	endif;
	theObj := theRow.itemObject;
	self.row := _idx;
	if theObj &lt;&gt; null then
		if (not self.allSelectedObjects.includes(theObj)) then
			self.allSelectedObjects.add(theObj);
		endif;
	endif;
	
	return true;
end;</source>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_makeTopRow" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectTheCurrentRow" id="d74267d1-59b0-41f4-a95a-97e73d554422">
        <source>selectTheCurrentRow(table: Table input);
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	theRow		: JadeTableRow;
	theObject	: Object;

begin
	theRow := table.accessRow(table.row);
	if self.controlKeyDown then
		if theRow.selected then
			theRow.selected := false;
		else
			theRow.selected := true;
		endif; 
	else
		table.clearAllSelected();
		theRow.selected := true;
	endif;
	
	// always add object from selected row into the allSelectedObjects set
	// so that the row will remain selected even if the user scrolls up/down
	theObject := theRow.itemObject;
	if theObject &lt;&gt; null then
		if theRow.selected then
			table.CM_BaseTable.allSelectedObjects.add(theObject);
		else
			table.CM_BaseTable.allSelectedObjects.remove(theObject);
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDisplayFromOrganiser" id="3eb78e67-59c7-4832-9a7d-da120207f255">
        <updating/>
        <source>setDisplayFromOrganiser(_entTblRowArray : EntTableRowArray)updating;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	if (not _entTblRowArray.isEmpty) then
		self.allDisplayEntTableRows.clear;
		_entTblRowArray.copy(self.allDisplayEntTableRows);
	endif;
end;</source>
        <Parameter name="_entTblRowArray" type="EntTableRowArray"/>
    </JadeMethod>
    <JadeMethod name="setMargins" id="ed5a6e24-0ea7-4133-876e-15d844564f4b">
        <updating/>
        <source>setMargins() updating;
/*
	Created on 19 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	i,
	numSheets	: Integer;
	tmpSheet	: JadeTableSheet;
begin
	numSheets := self.sheets;
	foreach i in 1 to numSheets do
		tmpSheet := self.accessSheet(i);
		tmpSheet.marginLeft := 2;
		tmpSheet.marginRight := 2;
		tmpSheet.marginTop := 2;
		tmpSheet.marginBottom := 2;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setRowsFromXMLString" id="f47db79e-5d85-4899-ad85-76181a590947">
        <source>setRowsFromXMLString(_xmlString : String):Boolean;
/*
	Created on 19 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	entRow			: EntTableRow;
	xmlDef,
	defName,
	tmpColHeading	: String;
	pos				: Integer;
	rowArray		: EntTableRowArray;
begin
	if _xmlString = null then
		return false;
	endif;

	create rowArray transient;
	self.allDisplayEntTableRows.copy(rowArray);
	self.allDisplayEntTableRows.clear;

	pos := 1;		
	xmlDef := _xmlString.cnEcGetNextTagValueOfName(XMLTag_EntTblDef &amp; self.myEntTableDef.name, pos);
	if xmlDef = null then
		// no xml for def, defaults will be used
		return false;
	endif;

	pos := 1;
	while (pos &gt; 0) do
		tmpColHeading := xmlDef.cnEcGetNextTagValueOfName(XMLTag_Column, pos);
		if tmpColHeading &lt;&gt; null then
			foreach entRow in rowArray do
				if entRow.name = tmpColHeading then
					self.allDisplayEntTableRows.add(entRow);
					break;
				endif;
			endforeach;
		endif;
	endwhile;
	return true;
epilog
	delete rowArray;
end;</source>
        <Parameter name="_xmlString" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableTextDisplayFields" id="a4719d0b-f113-4ad6-a084-75df94736062">
        <updating/>
        <source>setTableTextDisplayFields(_etDef : EntTableDef; _xmlString : String)updating;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	myEntTableDef := _etDef;
	if allDisplayEntTableRows.size = 0 then
		myEntTableDef.allEntTableRows.copy(allDisplayEntTableRows);
	endif;
	if _xmlString &lt;&gt; null then	
		setRowsFromXMLString(_xmlString);
	endif;
end;</source>
        <Parameter name="_etDef" type="EntTableDef"/>
        <Parameter name="_xmlString" type="String"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiserFrm" id="df782f39-5f8b-4288-8cbe-579ab117292b">
        <updating/>
        <source>showColumnOrganiserFrm(_terminal : CM_Terminal)updating;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	colOrgFrm : CMUI_ColumnOrganiserForm;
begin
	if self.myEntTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null self.myEntTableDef');
		return;
	endif;

	create colOrgFrm transient;
	colOrgFrm.setMyTerminal(_terminal);
	colOrgFrm.setMyTextTable(self);
//	allDisplayEntTableRows.copy(colOrgFrm.allTblDataEntRows);
	colOrgFrm.centreWindow;
	colOrgFrm.showModal;

	if colOrgFrm.modalResult = IDOK then
		self.form.CM_BaseForm.setTextDataFromOrganiser(self);
	endif;

epilog
	delete colOrgFrm;
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="c87a1365-1335-4287-870d-08c2dfd54b5a">
        <controlMethod name="CM_BaseTable::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	self.setMargins();
	self.autoSize 		:= Table.AutoSize_Row;

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
