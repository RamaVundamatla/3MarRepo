        <Parameter name="_gridPoint" type="SOP_GridPoint"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateStateOfRowColumn" id="4025fd5c-c7e2-413b-957c-66d0130bef46">
        <source>validateStateOfRowColumn(_gridObject : CM_GridObject) : Integer protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		_gridObject can be a CM_GridRow or CM_GridColumn
//
