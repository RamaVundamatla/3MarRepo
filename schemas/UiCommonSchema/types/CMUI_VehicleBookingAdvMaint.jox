    <JadeMethod name="translateForm" id="9c249a01-dde8-4d3c-af34-ec68f90a40d7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 September 2024 11:40:00.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025524, locale);
	btnCancel.translateCaption(Xlat_0025525, locale);
	btnSave.translateCaption(Xlat_0025526, locale);
	btnSlotAdd.translateCaption(Xlat_0025527, locale);
	btnSlotDelete.translateCaption(Xlat_0025528, locale);
	btnSlotEdit.translateCaption(Xlat_0025529, locale);
	chkKiosk.translateCaption(Xlat_0025512, locale);
	chkPreGateIn.translateCaption(Xlat_0025513, locale);
	chkPreGateOut.translateCaption(Xlat_0025514, locale);
	idLabel.translateCaption(Xlat_0025530, locale);
	lblCarrier.translateCaption(Xlat_0025515, locale);
	lblCopySlots.translateCaption(Xlat_0025996, locale);
	lblDriver.translateCaption(Xlat_0025516, locale);
	lblEndDT.translateCaption(Xlat_0025517, locale);
	lblExternalReference.translateCaption(Xlat_0025518, locale);
	lblRemarks.translateCaption(Xlat_0025519, locale);
	lblStartDT.translateCaption(Xlat_0025520, locale);
	lblSubCarrier.translateCaption(Xlat_0025521, locale);
	lblTILCType.translateCaption(Xlat_0026974, locale);
	lblVbsSlotType.translateCaption(Xlat_0025522, locale);
	lblVehicle.translateCaption(Xlat_0025523, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0025531, locale);
	mnuVbsTimeSlot.translateCaption(Xlat_0025532, locale);
	vbsSlotHeader.translateCaption(Xlat_0025533, locale);
	vbsSlotItems.translateCaption(Xlat_0025534, locale);
end;</source>
    </JadeMethod>
