    <JadeMethod name="asStringForWebInterface" id="d60c1bdf-b45a-4847-886a-212cb9e94a25">
        <source>asStringForWebInterface():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2012	cnwndl1	Initial creation	Par 30622

				The RIA may be running on a server that uses a different LOCALE than
				the client.  Convert to known format at both ends.

*/

vars

	str : String;

begin
	
	// The RIA is currently hard coded in the JavaScript side to use "dd/MM/yyyy", so that's what
	// we will output regardless of the server locale.
	
	if self.isValid() and self.year &gt; 1600 then
		str := self.format("dd/MM/yyyy");
	else
		str := null;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
