    <JadeMethod name="adhocTask" id="9e51343a-93b6-4fe1-9d94-1087888fac1b">
        <updating/>
        <source>adhocTask(_camProtocol: CM_CamProtocol; _startDateTime: TimeStamp; _endDateTime, _runDateTime: TimeStamp; _logExcludedTransactions, _logIncludedTransactions :Boolean) updating;
// -----------------------------------------------------------------------------
// Created:		20 May 2003  by Jason Chapman  (cnwjc2)
// -----------------------------------------------------------------------------
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------------
11/08/2010	cnwdad1		PAR #25172 - Pass CAM Protocol name to "logMessage" when raising an alert.
17/07/2012	cnwcs5		par 29601 - log excluded transactions
//28 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//20 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
// 26 Jun 2013	cnwrs1	par 31047 Cam Exception Handling testing
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
-------------------------------------------------------------------------------- */
vars
	log : File;
	camTaskHistory : CM_CamTaskHistory;
	camObject : CM_Object;
begin

	if not self.tryLock(_camProtocol, Exclusive_Lock, Session_Duration, LockTimeout_Server_Defined) then
		app.writeLog("Action : " &amp; method.name &amp; ".  " &amp; app.getErrorString(MSG_CAMS_ProtocolBusy), LogINFO);
		return;
	endif;
			
	self.isAdhoc 					:= true; 
	self.logExcludedTransactions	:= _logExcludedTransactions;	// par 29601 July 2012
	self.logIncludedTransactions := _logIncludedTransactions;
	
	if not self.setCurrentProtocol(_camProtocol) then	//20 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
		self.logMessage("CAMS failed to initialise for " &amp; self.myTerminal.name, null, true, true, false);
		return;
	endif;

	self.initAgent();

	self.logMessage(app.getErrorString(MSG_CAMS_AdhocStarted) &amp; " ", _camProtocol.code, false, false, true);
	
	if _logExcludedTransactions then
		self.logMessage('Logging Excluded Transactions is ON', null, false, false, true);
	else
		self.logMessage('Logging Excluded Transactions is OFF', null, false, false, true);
	endif;
	
	if self.armExceptionHandler then
		on NormalException do self.myCurrentCamProtocol.protocolExceptionHandler(exception);
	endif;

	//-----------------------------
	// Initialise task
	//-----------------------------
	self.startTask(_runDateTime, _startDateTime, _endDateTime);
	
	//-----------------------------
	// Do the task
	//-----------------------------
	self.extractAction();
	//-----------------------------
	// Send the file
	//-----------------------------
	self.sendAction();
	
	//-----------------------------
	// Finish-up task
	//-----------------------------
	self.endTask();
	
	//set the protocol back to hold for adhoc runs
	app.myTrxUA.trxUpdateCamObjectStatus(self.myCurrentCamProtocol, CAM_HOLDSTATUS, app.myPassport);
	
	if not app.myPassport.trxCompletedOK() then
		self.logMessage(app.getErrorString(ERR_CAMS_Process)&amp;' '&amp;self.getCurrentProtocolCode(), " failed to update CAM protocol status to HOLD during adhoc run.", true, true, false);	//par 26290 cnwrs1 11 Nov 2010
		app.myPassport.clearErrorsWarnings();
	endif;
	
	camTaskHistory 	:= self.myCurrentCamProtocol.taskHistoryByProtocolSeq[self.myCurrentCamProtocol, self.processSeqNumber];		//required?  copied from v6
	camObject 		:= camTaskHistory;	//19 June 2012	cnwrs1		Par 29821 - CAMS single transaction per file
	if camObject &lt;&gt; null then
		app.myTrxUA.trxUpdateCamObjectStatus(camObject, self.status, app.myPassport);
	endif;
	if not app.myPassport.trxCompletedOK() then
		self.logMessage(app.getErrorString(ERR_CAMS_Process)&amp;' '&amp;self.getCurrentProtocolCode(), " failed to end the CAM task.", false, true, false);	// PAR #28709
		app.myPassport.clearErrorsWarnings();
	endif;
	
	self.writeLog(app.getErrorString(MSG_CAMS_AdhocComplete));
epilog
	// otherwise the session unlock will not work
	if process.isInExceptionState then
		app.cmsAbortTransaction;
	endif;

	if _camProtocol &lt;&gt; null and self.isLockedByMe(_camProtocol) then
		self.unlock(_camProtocol);
	endif;
	
	log := self.protocolLog;
	if log &lt;&gt; null and log.isOpen() then
		log.close();
		delete log;
		self.protocolLog := null;
	endif;
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_endDateTime" type="TimeStamp"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_logExcludedTransactions" type="Boolean"/>
        <Parameter name="_logIncludedTransactions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="controllerXhandler" id="7ee76c93-e5fc-4148-b239-61a99d4a7ef8">
        <source>controllerXhandler(_exObj: Exception): Integer;
//----------------------------------------------------------------
//	Created:	27 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------------
11/08/2010	cnwdad1		PAR #25172 - Pass CAM Protocol name to "logMessage" when raising an alert.
//14 Nov 2012	cnwrs1 	par 30728 - dont write to log if it is not setup
//10 Jun 2013	cnwrs1	Par 31047 - add Enviroment Terminal and Protocol to Cams Alerts
--------------------------------------------------------------------------------
*/
vars
	errStr	: String;
begin
   	abortTransaction;
	errStr := app.getErrorString(Error) &amp; " (" &amp; _exObj.errorCode.String&amp;').';
	if self.protocolLog &lt;&gt; null then
		self.logMessage(errStr&amp;' '&amp;self.getErrorDesc(), _exObj.extendedErrorText, true, true, true);
	else
		app.writeLog(errStr&amp;' '&amp;self.getErrorDesc(), LogINFO);	//14 Nov 2012 cnwrs1 par 30728
	endif;
	//Our exceptions
	if _exObj.isKindOf(CM_Exception) then
		return Ex_Resume_Next;
	endif;
	return Ex_Pass_Back;
end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
