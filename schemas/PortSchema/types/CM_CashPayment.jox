    <JadeMethod name="getCargoDetails" id="171a04ee-3b38-465d-ae30-bc26a60dcc13">
        <source>getCargoDetails() : String;
// for reporting
vars
	trackedItem	: CM_TrackedItem;
	details		: String;
	cargoDesc	: String;
begin
	if self.myTrackedItem &lt;&gt; null then
		trackedItem := self.myTrackedItem;
		details := trackedItem.id;
		if trackedItem.myOperator &lt;&gt; null then
			cargoDesc := trackedItem.myOperator.code;
		endif;
		if trackedItem.isoTypeDesc &lt;&gt; null then
			if cargoDesc = null then
				cargoDesc := trackedItem.isoTypeDesc;
			else
				cargoDesc := cargoDesc &amp; " " &amp; trackedItem.isoTypeDesc;
			endif;
		endif;
		if trackedItem.cargoType = 1 then
			if trackedItem.commodity &lt;&gt; null then
				if cargoDesc = null then
					cargoDesc := trackedItem.commodity;
				else
					cargoDesc := cargoDesc &amp; " " &amp; trackedItem.commodity;
				endif;
			endif;
		else
			if cargoDesc = null then
				cargoDesc := trackedItem.cargoTypeDescr;
			else
				cargoDesc := cargoDesc &amp; " " &amp; trackedItem.cargoTypeDescr;
			endif;
		endif;
		details := details &amp; " " &amp; cargoDesc;
	endif;
	
	return details;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
