    <JadeMethod name="canUserAccessSelf" id="ddf8aa9f-10bb-474f-9fc9-291f650dffd6">
        <source>canUserAccessSelf(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2018	jlger1	Initial creation 38518

*/

vars
	consign,
	consginor : CM_ConsigneeConsignor;
	operator : CM_Operator;
	carrier  : CM_Carrier; 
	custAgent : CM_CustomsAgent;
	failedDAC: CM_DataAccessController;
begin
	
	
	operator := app.myRoot.allOperators[self.operatorCode];
	if operator &lt;&gt; null then
		if not operator.canUserAccessSelf(app.myPassport.myUser,failedDAC,app.myPassport) then
			return false;
		endif;
		
	endif;
	consign := app.myRoot.allConsigneeConsignors[self.consigneeCode];
	if consign &lt;&gt; null then
		if not consign.canUserAccessSelf(app.myPassport.myUser,failedDAC,app.myPassport) then
			return false;
		endif;
		
	endif;
	consginor := app.myRoot.allConsigneeConsignors[self.consignorCode];
	if consginor &lt;&gt; null then
		if not consginor.canUserAccessSelf(app.myPassport.myUser,failedDAC,app.myPassport) then
			return false;
		endif;
		
	endif;
	
	carrier := app.myRoot.allCarriers[self.carrier];
	if carrier &lt;&gt; null then
		if not carrier.canUserAccessSelf(app.myPassport.myUser,failedDAC,app.myPassport) then
			return false;
		endif;
		
	endif;
	custAgent := app.myRoot.allCustomsAgents[self.customsAgentCode.toUpper];
	if custAgent &lt;&gt; null then
		if not custAgent.canUserAccessSelf(app.myPassport.myUser,failedDAC,app.myPassport) then
			return false;
		endif;
		
	endif;
	return true;
	
	

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkEDIVoyageCutoff" id="12afc99f-509a-4f0a-8650-7c76f829fbf5">
        <source>checkEDIVoyageCutoff(_ediTIObj : Object) protected;
/*
Date		Who		Reason
07 March 2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	ediData	:CM_EDIData;
    ediTI : CM_EDITrackedItem;
begin
	if _ediTIObj = null then
		return;
	endif;
    
    if _ediTIObj.isKindOf(CM_EDITrackedItem) then
        ediTI := _ediTIObj.CM_EDITrackedItem;
    endif;
	
    if ediTI = null then
		// prenote not being created via EDI
        return;
    endif;
	
	ediData := ediTI.myEDIData;
	
	if ediData = null then
		return;
	endif;
	
	ediData.checkEDICutoff (self.voyageCode, self.operatorCode, ediTI);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediTIObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="checkNsetCommodityFrmDefault" id="00de1117-75c4-4b1b-b7c3-a1f419e21c5d">
        <updating/>
        <source>checkNsetCommodityFrmDefault() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 12 June 2019
TFS#		: 44416
Function	: This method will check if the current commodity field is null
			  if it is null and Cargo Sub Type exist use the the Cargo Sub Type
			  Commodity Defaults as the Commodity. If this is null then use the 
			  Cargo Type Default Commodity.
			  If Cargo Sub Type is null then use Cargo Type Default Commodity.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	cargoType : CM_CargoType;
begin	
	if self.cargoType &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[self.cargoType];
	endif;
	
	if self.commodity = null or self.commodity = "TBA" then		
		if self.myProduct &lt;&gt; null then
			self.commodity := self.myProduct.defaultCommodityCode;
		endif;		
		if (self.commodity = null or self.commodity = "TBA") and cargoType &lt;&gt; null then
			self.commodity := cargoType.defaultCommodityCode;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="checkNsetMeasurementFrmDefault" id="c574e8b8-3785-4af1-b474-a691c6907dbf">
        <updating/>
        <source>checkNsetMeasurementFrmDefault() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 12 June 2019
TFS#		: 44416
Function	: This method will check if the current measurement(/s) field are null
			  if null and Cargo Sub Type exist use the the Cargo Sub Type
			  Measurement Defaults value. If this is null then use the 
			  Cargo Type Measurement Default value.
			  If Cargo Sub Type is null then use Cargo Type Measurement Default value.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin	
	if self.height = null then		
		self.setHeightFromCargoTypeDef();
	endif;
	
	if self.weight = null then		
		self.setWeightFromCargoTypeDef();
	endif;
	
	if self.length = null then		
		self.setLengthFromCargoTypeDef();
	endif;
	
	if self.width = null then		
		self.setWidthFromCargoTypeDef();
	endif;
	
	if self.volume = null then		
		self.setVolumeFromCargoTypeDef();
	endif;
	
	if self.density = null then
		self.setDensityFromCargoTypeDef();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d2af9516-468e-4172-833a-67533ef6d274">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10 August 2015	cnwdap1		Initial creation PAR #
//
vars
	tiHazard : CM_TIHazard;

begin
	if _attrName = ETRow_HazardCode then
		tiHazard := self.allTIHazards.first.CM_TIHazard;
		if tiHazard = null then	
			return null;
		endif;
		return tiHazard.getUndgCodesAsString(true);	//25 Sep 2019	NDL	TFS 46633 - Leave as truncated version, but use new method
	elseif _attrName = ETRow_Limited then
		tiHazard := self.allTIHazards.first.CM_TIHazard;
		if tiHazard = null then
			return null;
		endif;
		return tiHazard.limitedQuantity.cnEcGetYesNo;
	elseif _attrName = ETRow_Selection then
		tiHazard := self.allTIHazards.first.CM_TIHazard;
		if tiHazard = null then
			return null;
		endif;
		return tiHazard.getSelectionString;
	elseif _attrName = ETRow_HazardDescription then
		tiHazard := self.allTIHazards.first.CM_TIHazard;
		if tiHazard = null then
			return null;
		endif;
		return tiHazard.description;
	elseif _attrName = ETRow_Weight then
		return app.convertMeasurementForDisplay(app.getDefaultMeasurementForType(Type_Weight).shortName, self.weightTotal);
	elseif _attrName = ETRow_Quantity then
		return self.quantity.String;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrainOfPreNoteWagon" id="29cb2e78-52a9-476c-935a-c99290e566d7">
        <source>getTrainOfPreNoteWagon():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	theTerminal : CM_Terminal;
	theWagon : CM_Wagon;
	theTrain : CM_Train;
	
begin

	if wagon = null or app.myPassport = null or app.myPassport.myTerminal = null then
		return null;
	else
		theTerminal := app.myPassport.myTerminal;
	endif;
	
	theWagon := theTerminal.getCurrentWagonByID(wagon);
	
	if theWagon = null then
		return null;
	endif;
	
	theTrain := theWagon.myTrainInwards;
		
	if theTrain = null then
		theTrain := theTerminal.getNullTrain();
	endif;
	
	return theTrain.getCodeDateString;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasCSIStop" id="6d173566-bc6d-4540-b9ac-707d7d28bf5f">
        <source>hasCSIStop() : Boolean;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 27 October 2006
//
//----------------------------------------------------------------------
//Temporary until stops become more generic for emails.  Add a new feature linking pin emails to stops, todo tasks and hazards
//to allow for user defined stops.
vars
	stopTable : CM_StopsTable;
	int : Integer;
	
begin
	
	foreach int in self.allStops discreteLock do
		stopTable := app.myRoot.allStopsTable[int];
		if stopTable.heading = 'Customs Scan Inspection' then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOneStopPrenote" id="cfb75ad7-4708-4048-8961-6692789905ab">
        <source>isOneStopPrenote():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2018	jlgndl1	Initial creation	TFS 36932

*/

vars

begin

	if self.myUserObject &lt;&gt; null and self.myUserObject.isKindOf( CM_EDIPrenoteTI ) then
		return self.myUserObject.CM_EDIPrenoteTI.isOneStopPrenote();
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
