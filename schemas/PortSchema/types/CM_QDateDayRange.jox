    <JadeMethod name="getSearchValue" id="752fa2d7-ff31-4efb-bd72-6d031941a4ca">
        <source>getSearchValue(): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06 September 2019	jlgdap1		Initial creation TFS 
//
vars
	str			: String;
begin
	str := self.fromNumDays.String &amp; ' and ' &amp; self.toNumDays.String;
	return str;

epilog

end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueRange" id="68e66f55-9ec5-4dd9-b014-5a964655a01b">
        <source>getSearchValueRange(_prop : CM_QueryProperty): Any;
/*

Purpose:	called needs to delete transient collection		

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	jlier1	Initial creation 53515

*/

vars
	dayRange : IntegerArray;
begin

	create dayRange transient;
	dayRange.add(fromNumDays);
	dayRange.add(toNumDays);
	
	return dayRange;

epilog

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="Any"/>
    </JadeMethod>
