    <JadeMethod name="setUser" id="d5b9065b-ed1d-4f16-b1f7-d8912f67ce46">
        <source>setUser() : CM_User;

// cnwdvb1 06 June 2003 

vars
	
	user 		: CM_User;
	
begin

	if self.myUser = null then
		user := self.myProcessingController.myUser;
	else
		user := self.myUser;	
	endif;
	
	if user = null then
		app.raiseCMException1(BackgroundErrorGeneral, 'User has not been specified', null, null);
	endif;
	
	app.myPassport.setMyUser(user);
	return user;

end;</source>
        <ReturnType type="CM_User"/>
    </JadeMethod>
