    <JadeMethod name="handleOK" id="3dee6523-ae2d-4596-b3a7-bb7e87fc08aa">
        <updating/>
        <source>handleOK() updating, protected;

vars
	tbl : Table;
	obj : Object;
	row	: Integer ;
	totalCount	: Integer ;
	index		: Integer ;
	reductionAmount	: Integer ;
begin
	tbl := self.tblSelectdProfil;
	
	self.allSelectedProfileCounts.clear ;
	self.allSelectedProfileNames.clear ;
	
	foreach row in tbl.fixedRows + 1 to tbl.rows do
		obj := tbl.accessRow( row ).itemObject;
		
		if obj &lt;&gt; null and obj.isKindOf(JtdDriverProfile) then
			allSelectedProfileNames.add( obj.JtdDriverProfile.jtdName );
			allSelectedProfileCounts.add( tbl.accessCell( row, 2).text.Integer );
		endif;
		
	endforeach;

	foreach index in 1 to allSelectedProfileCounts.size do
		totalCount := totalCount + allSelectedProfileCounts[ index ];
	endforeach;

	if totalCount &gt; totalDriverCount then
		reductionAmount := totalCount - totalDriverCount ;
		app.msgBox( 
				"Your requested driver make-up totals " &amp; totalCount.String &amp; " drivers but there are only " &amp; totalDriverCount.String &amp; " drivers active currently" &amp; CrLf &amp; CrLf &amp;
				"Please reduce your requested driver make-up by " &amp; reductionAmount.String &amp; " drivers",
				"Too many drivers requested",
				MsgBox_OK_Only + MsgBox_Stop_Icon
				);
		return;
	endif;

	self.modalResult := 0;
	self.unloadForm;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="f350bf6d-6e96-4653-af7e-eabb43638da8">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

begin
	if keyCode = 116 then // F5
		self.loadTheLot;
		keyCode := 0;
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="badfc921-a3b5-4cd0-bff1-7e750725e52b">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	self.width := 785;
	self.height := 460;
	self.loadTheLot;
	self.centreWindow;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadMethodProfilesTable" id="920e8b96-8f1d-418d-9d97-bfbed133f43e">
        <source>loadMethodProfilesTable(dp : JtdDriverProfile) protected;

vars
	mp : JtdMethodProfile;
	tbl : Table;
	
begin
	tbl := self.tblMthProfiles;
	
	tbl.rows := tbl.fixedRows;
	
	if dp = null then
		return;
	endif;

	if dp.jtdAllPrologProfiles.size &gt; 0 then
		tbl.addItem("Prolog");
		tbl.accessCell(tbl.rows, 1).fontBold := true;
		
		foreach mp in dp.jtdAllPrologProfiles do
			tbl.addItem(mp.jtdClassName &amp; "::" &amp; mp.jtdMethodName &amp;
				Tab &amp; mp.jtdNumCalls.String &amp; Tab &amp; mp.jtdThinkSecs.String);
		endforeach;
	endif;

	if dp.jtdAllMethodProfiles.size &gt; 0 then
		if dp.jtdAllPrologProfiles.size &gt; 0 or dp.jtdAllEpilogProfiles.size &gt; 0 then
			tbl.addItem("Main");
			tbl.accessCell(tbl.rows, 1).fontBold := true;
		endif;
		
		foreach mp in dp.jtdAllMethodProfiles do
			tbl.addItem(mp.jtdClassName &amp; "::" &amp; mp.jtdMethodName &amp;
				Tab &amp; mp.jtdNumCalls.String &amp; Tab &amp; mp.jtdThinkSecs.String);
		endforeach;
	endif;

	if dp.jtdAllEpilogProfiles.size &gt; 0 then
		tbl.addItem("Epilog");
		tbl.accessCell(tbl.rows, 1).fontBold := true;
		
		foreach mp in dp.jtdAllEpilogProfiles do
			tbl.addItem(mp.jtdClassName &amp; "::" &amp; mp.jtdMethodName &amp;
				Tab &amp; mp.jtdNumCalls.String &amp; Tab &amp; mp.jtdThinkSecs.String);
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="dp" type="JtdDriverProfile"/>
    </JadeMethod>
    <JadeMethod name="loadTheLot" id="aa4e8f70-859c-440d-a1ae-67c42b5993e9">
        <updating/>
        <source>loadTheLot() updating, protected;

vars
	dsdDict : DriverSchemaDescriptorNameDict;
	dpDict : JtdDriverProfileNameDict;
	dsd : DriverSchemaDescriptor;
	dp : JtdDriverProfile;
	s, ds : String;
	profileTable	: Table;
	methodsTable	: Table;
	n : Integer;
	row	:	Integer ;	
	pd	: ProcessDescriptor;
	nd	: NodeDescriptor;
	profileName	: String ;
	count	: Integer ;
	totalCount : Integer ;
begin
	self.allDriverProfiles.purge;
	
	profileTable	:= self.tblSelectdProfil ;
	methodsTable	:= self.tblMthProfiles;
	
	profileTable.rows		:= profileTable.fixedRows;
	profileTable.columns	:= 2 ;
	profileTable.accessColumn(1).widthPercent	:= 80 ;
	profileTable.accessColumn(2).widthPercent	:= 20 ;
	profileTable.accessedColumn.alignment	:= Table.Alignment_Center_Middle ;
	profileTable.accessedColumn.inputType	:= Table.InputType_TextNumeric ;
	profileTable.accessCell(1, 1).text := "Profile" &amp; Tab &amp; "No. of " &amp; CrLf &amp; "Drivers";
	
	methodsTable.rows := methodsTable.fixedRows;
	methodsTable.accessCell(1, 1).text := "Method" &amp; Tab &amp; "Calls" &amp; Tab &amp; "Delay";
	methodsTable.accessColumn(2).alignment := Table.Alignment_Center;
	methodsTable.accessColumn(3).alignment := Table.Alignment_Center;

	methodsTable.accessColumn(1).widthPercent	:= 70 ;
	methodsTable.accessColumn(2).widthPercent	:= 15 ;
	methodsTable.accessColumn(3).widthPercent	:= 15 ;

	create dsdDict transient;
	create dpDict transient;

	// get descriptors for all driver schemas in schema name order
	rootSchema.getAllDriverSubschemaDescs(dsdDict);

	foreach dsd in dsdDict do
		dpDict.clear;
		app.createDriverProfilesFromMethod(dsd.myProfileTextMethod, dpDict, true);

		if dpDict.size &lt; 1 then
			continue;
		endif;

		dpDict.copy(self.allDriverProfiles);
		row	:= profileTable.addItem(dsd.schemaName);
		profileTable.accessRow( row ).foreColor	:= Blue ;

		foreach dp in dpDict do
			if dp.jtdDefaultThinkSecs &gt; 0 then
				ds := ", Delay " &amp; dp.jtdDefaultThinkSecs.String;
			else
				ds := null;
			endif;
			s := "  " &amp; dp.jtdName &amp; " [" &amp; dp.jtdGetTotalMethods.String &amp; ", ";
			if dp.jtdRandomSelection then
				s := s &amp; "Random" &amp; ds &amp; ']';
			else
				s := s &amp; "In Sequence" &amp; ds &amp; ']';
			endif;

			count := 0 ;

			foreach nd in app.mySession.allNodeDescriptorsByName do
				foreach pd in nd.allProcessDescriptors do
					if pd.profileName = dp.jtdName then
						count := count + 1;
					endif;
				endforeach;
			endforeach;	

			row := profileTable.addItem( s &amp; Tab &amp; count.String );
			
			totalCount := totalCount + count ;
			
			profileTable.accessRow( row ).itemObject := dp;
		endforeach;
	endforeach;

	self.totalDriverCount	:= totalCount ;

epilog
	if dsdDict &lt;&gt; null then
		dsdDict.purge;
		delete dsdDict;
	endif;

	// the contents of dpDict is copied to self.allDriverProfiles,
	// which is purged at the start of the method and also when the
	// form is unloaded
	delete dpDict;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblSelectdProfil_click" id="b478fe65-0514-4fab-b18e-c70f5e877a7b">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSelectdProfil_click(table: Table input) updating;

vars
	obj : Object;

begin
	if table.row &lt;= table.fixedRows or table.row &gt; table.rows then
		// belts and braces
		self.tblMthProfiles.rows := self.tblMthProfiles.fixedRows;
		return;
	endif;
	
	obj := table.accessRow( table.row ).itemObject;
	
	if obj = null or (not obj.isKindOf(JtdDriverProfile)) then
		self.tblMthProfiles.rows := self.tblMthProfiles.fixedRows;
		return;
	endif;

	self.loadMethodProfilesTable(obj.JtdDriverProfile);	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unload" id="6c076e82-47eb-4765-b135-b6757a0097d7">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

begin
	self.allDriverProfiles.purge;
end;</source>
    </JadeMethod>
