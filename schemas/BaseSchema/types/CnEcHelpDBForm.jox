    <JadeMethod name="closeForm" id="0e0873eb-4e9e-410b-b3c6-38520d5372ec">
        <updating/>
        <source>closeForm() updating;

vars
	msg_return	: Integer;

begin
	msg_return := self.discardChangesPrompt();

	if msg_return = MsgBox_Return_Yes then
		delete aAllNewForms;
		delete aAllChangedForms;
		
		if self.aFontName &lt;&gt; app.fontName then
			app.fontName := self.aFontName;
		endif;
		
		if self.aFontSize &lt;&gt; app.fontSize then
			app.fontSize := self.aFontSize;
		endif;
		
		unloadForm();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="createCnEcHelp" id="1082565a-8057-4889-a4e1-d4c420d51a74">
        <source>createCnEcHelp(myCnEcHelp : CnEcHelp io);

begin
	if myCnEcHelp = null then
		beginTransaction;
		create myCnEcHelp;
		myCnEcHelp.update( currentSchema.name, null, currentSchema, false, false );
		commitTransaction;
	endif;
end;</source>
        <Parameter name="myCnEcHelp" type="CnEcHelp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createHelpForm" id="1a5068da-7846-43f4-9f57-44b70f9af911">
        <source>createHelpForm( object : Object );

vars
	error	: String;
	cnHelp	: CnEcHelpFormDetail;

begin
	cnHelp := aMyHelp.getHelpForm(object.Form);
	
	if cnHelp = null then
		beginTransaction;
		error := aMyHelp.createHelpForm(cnHelp, object.Form);
		
		if error.length &gt; 0 then
			app.msgBox( error, "Error Creating Help Form", MsgBox_OK_Only );
			abortTransaction;
		else
			commitTransaction;
		endif;
	endif;
end;</source>
        <Parameter name="object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="discardChangesPrompt" id="3d0e03cd-e30a-40a4-8009-29f98fc373ff">
        <source>discardChangesPrompt() : Integer;

begin
	if btnSaveChanges.enabled then
		return app.msgBox(	"You have not saved your changes. Do you wish to discard your changes?",
							"Unsaved Changes",
							MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second);
	endif;

	return MsgBox_Return_Yes;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayFormForChange" id="405ec6f6-bc5a-4ebe-ab43-fa759ba873c3">
        <source>displayFormForChange();

vars
	cnEcHelpFormDetail	: CnEcHelpFormDetail;
	theForm				: Form;
	listPointer			: Integer;
	
begin
	sheetMaintenance.enabled	:= false;
	sheetOptions.enabled		:= false;
	sheetProjects.enabled		:= false;
	btnClose.enabled			:= false;
	sheetDetails.visible		:= true;
	btnGetForms.enabled			:= false;
	btnExtractForm.enabled		:= false;
	btnUpdateForm.enabled		:= false;
	txtDescription.setFocus();

	listPointer := lstForms_change.listIndex;
	
	if listPointer &gt; 0 then
		lstForms_change.listIndex := CNEC_NULL_INDEX;
		lstForms_change.listIndex := listPointer;
		lstForms_change.itemSelected[listPointer] := true;
		theForm := lstForms_change.itemObject[listPointer].Form;
//		write("changed: " &amp; lbChangedForms.listObject.Form.name);
	else
		listPointer := lstForms_included.listIndex;
		lstForms_included.listIndex := CNEC_NULL_INDEX;
		lstForms_included.listIndex := listPointer;
		lstForms_included.itemSelected[listPointer] := true;
		theForm := lstForms_included.itemObject[listPointer].Form;
//		write("included: " &amp; lbIncluded.listObject.Form.name);
	endif;

	cnEcHelpFormDetail	:= aMyHelp.getHelpForm(theForm);
	txtFormName.text	:= theForm.name;

	txtDescription.text := cnEcHelpFormDetail.description;

	if cnEcHelpFormDetail.helpTopic = "" then
		txtHelpKeyword.text := theForm.name;
	else
		txtHelpKeyword.text := cnEcHelpFormDetail.helpTopic;
	endif;

	txtContextID.text		:= cnEcHelpFormDetail.helpContextID.String;
	txtDateModified.text	:= aMyHelp.getFormTimeStamp(theForm).String;
	txtHelpFile.text		:= cnEcHelpFormDetail.helpFile;
	btnStore_Update.enabled	:= true;

	// for now...

	lstStored_list.listIndex := CNEC_NULL_INDEX;
	txtTime.text := "";
end;</source>
    </JadeMethod>
    <JadeMethod name="excludeNewForms" id="1a768582-7f57-47bb-8fb7-03e104b58cbf">
        <source>excludeNewForms(processAllForms : Boolean);

vars
	object	: Object;
	myIndex	: Integer;
	changes	: Boolean;
begin
	foreach myIndex in 1 to lstForms_new.listCount do
		if processAllForms or lstForms_new.itemSelected[myIndex] then
			object := lstForms_new.itemObject[myIndex];
			
			if object &lt;&gt; null then
				changes := true;
				aAllNewForms.remove(object);
				aAllExcludedForms.add(object);
			endif;
		endif;
	endforeach;

	if changes then
		self.populateHelpLists();
		btnSaveChanges.enabled := true;
		btnGetForms.enabled := false;
	endif;
	
	self.setButtons(null);
end;</source>
        <Parameter name="processAllForms" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="folder_sheetChg" id="b2e4a388-8dde-4013-b10e-edd08c73b716">
