    <JadeMethod name="view_BuildEntireForeground" id="0662ecf2-5792-4e85-b307-583a8fa02e43">
        <updating/>
        <source>view_BuildEntireForeground() updating;
//--------------------------------------------------------------
//Created: 28 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	inheritMethod();
	
	if (not global.isValidObject(self.myCurrentWorkingMovement)) then
		self.setMySelectedMovement(null);
	endif;

	self.myGraphicalView.buildEntireForeground(self.myCurrentWorkingMovement, false);
		
end;</source>
    </JadeMethod>
    <JadeMethod name="view_BuildForegroundForXViews" id="cb4a4c15-a004-4668-bf0f-05246677af3a">
