<Class name="CMIF_MobileGateChecker" id="4c8934a9-262e-46e8-9631-dd1be69104ba">
    <superclass name="CMIF_MobileGenericAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="gate"/>
    <JadeMethod name="checkFindAndAssignTrailer" id="8156f7df-1c54-4c27-8c56-409ab4b30374">
        <source>checkFindAndAssignTrailer(_truckReg : String):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2016	cnwma1	Initial creation TFS 1488:JMT Mobile Apps - RecRel - Gate Checker

*/
vars
	truck : CM_Vehicle;
	currentLocation : CM_LocationsController;
	gateLocation	: CM_GateAreaLaneController;
	errorMess : String;
	job : CM_Job;
	trailerId : String;
	trailerObj : CM_TrackedItem;

begin

	truck := self.findTruck( errorMess,_truckReg, true );
	errorMess := null;
	gateLocation := self.myGateAreaLaneController;
	if truck &lt;&gt; null and gateLocation &lt;&gt; null  then	
		currentLocation	:= truck.myPrimaryActualLocation;
		if currentLocation &lt;&gt; null
		and currentLocation.isYardLocation
		and not gateLocation.isInsideYard()
		then
			// moving out of yard into outward gate lane. The job must be complete or have everything done
			// except identifying the real trailer if it was using a realease trailer by type..
			job :=  truck.allRoadJobs.first;
			if job &lt;&gt; null and job.status &lt;&gt; JOB_COMPLETE then
				if not truck.myUnknownChassis.allTrackedItems.isEmpty then
					//make the trailer id text box visible so we can catch the data.
					errorMess := "Must enter the trailer id first";
					app.raiseCMException(Error_Display,errorMess,null); //22/02/2017 cnwma1 TFS #2761
					return false;
				endif;
			endif;
			
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_truckReg" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doGateCheckerCompleteOutward" id="8c4bbb59-5263-4801-b337-7f78cfc70e3c">
        <source>doGateCheckerCompleteOutward():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2016	cnwma1	Initial creation TFS 1488 JMT Mobile Apps - RecRel - Gate Checker
16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit

*/

vars
	truck : CM_Vehicle;
	theRoadJob : CM_RoadJob;
	invalidJob : Boolean;
	errorMess : String;
	userResponse : Integer;
	visit : CM_VehicleVisitRecord;
	
	controller : CM_LaneController;
	thePrinter : CM_PrinterDef;
	printers : StringArray;
	printReceipt : Boolean;
begin
	truck := self.myTruck;
	on Exception do app.handleDeletedObject(exception, theRoadJob, invalidJob);
	theRoadJob := truck.allRoadJobs.first.CM_RoadJob;
	
	// Look thru all of its road jobs set and check if any of them still have any devices in their working devices IDs collection.
	if theRoadJob &lt;&gt; null and theRoadJob.status &lt;&gt; JOB_COMPLETE then
		if theRoadJob.allWorkingDeviceIDs.cnEcIsNotEmpty() then
			app.raiseCMException(XLAT_RoadExit_Warning1,null, null);
			return false;
		endif;
	endif;
	
	if not invalidJob and theRoadJob &lt;&gt; null then
		if theRoadJob.status &lt;&gt; JOB_COMPLETE then
			if theRoadJob.autoComplete then
				app.raiseCMException(XLAT_Road_Exit_Error1,null,null);
				return false;
			else
				app.raiseCMException(XLAT_Road_Exit_Error2,null,null);
				return false;	
			endif;
		endif;	
	endif;
	
	if not invalidJob and theRoadJob &lt;&gt; null then
		visit := theRoadJob.CM_RoadJob.myVehicleVisit;
	endif;
	
	if not invalidJob and theRoadJob &lt;&gt; null then
		// if the vehicle is going out a gate that has a p-check location then 
		if not self.doProcessRoadExit_CheckLocn (truck, false) then
			return false;
		endif;
		if theRoadJob.isTurnAroundJob and truck &lt;&gt; null then
			// if turnaround defferred update of deleted TIs transactions crashes
			app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
		else	
			//app.myTrxDA.trxRoadExit(theRoadJob, app.myPassport);			//16.02.2024 navnk30 #62414
			app.myTrxDA.trxRoadExit(theRoadJob, null, app.myPassport);		//16.02.2024 navnk30 #62414
		endif;
		
	elseif not invalidJob and truck &lt;&gt; null then
		// if the vehicle is going out a gate that has a p-check location then 
		if not self.doProcessRoadExit_CheckLocn (truck, false) then
			return false;
		endif;
		
		app.myTrxDA.trxVehicleRoadExit(truck, app.myPassport);
	endif;
	
	if (not app.myPassport.trxCompletedOK) then
		//errorMess := app.myPassport.getAllErrorsWarningsAsString;             //22/02/2017 cnwma1 TFS #2761
		//app.raiseCMException(Err_Unexpected_Program_Error,errorMess,null);   //22/02/2017 cnwma1 TFS #2761
		return false;
	else
		//08 Mar 2010 NDL	Par 22680
		printReceipt := self.myTerminal.getConfig(GateReceiptRequired).Boolean;		
		if visit &lt;&gt; null and printReceipt then
			controller := self.myGateAreaLaneController;
			if controller &lt;&gt; null then
				thePrinter := controller.getPrinter();
			endif;
			
			if thePrinter = null then
				errorMess := app.getErrorString1(Need_Server_Printer, controller.getFullId);
				app.raiseCMException(Printing_error,errorMess,null);
			else
				create printers transient;
				self.getServerPrinters( printers );
				if not printers.includes( thePrinter.physicalPrinterName.trimBlanks ) then
					errorMess := app.getErrorString2(Unknown_Server_Printer, thePrinter.physicalPrinterName.trimBlanks, controller.getFullId);
					app.raiseCMException(Unknown_Server_Printer,errorMess,null);
						
				else
					visit.printRoadReceipt(	null, null, thePrinter.physicalPrinterName );	
					return true;
				endif;
			
			endif;
			
		endif;
		
		return true;
		
	endif;
	
epilog

	delete printers;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessRoadExit_CheckLocn" id="35279916-f175-41fa-9ebd-dcd2c61f39bf">
        <source>doProcessRoadExit_CheckLocn(_vehicle: CM_Vehicle; _skipGateCheck: Boolean): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2016	cnwma1	Initial creation TFS 1488 JMT Mobile Apps - RecRel - Gate Checker

*/

vars
	obj		:Object;
	job		:CM_RoadJob;
	gate	:CM_Gate;
	lc		:CM_YardController;
begin
	// we really only expect there to be one job for the vehicle and it should be complete
	foreach obj in _vehicle.allRoadJobs do
		job := obj.CM_RoadJob;
		
		if job.status &lt;&gt; JOB_COMPLETE then
			app.raiseCMException(XLAT_Road_Exit_Error2,null,null);
			return false;
		endif;
		
		if not _skipGateCheck then	//04 Mar 2016	NDL	TFS 1593
			gate := job.getExitGate;
		endif;
		
		if gate &lt;&gt; null and gate.hasPGateAreas_OUT then
			lc := _vehicle.myPrimaryActualLocation;
			
			if not lc.isGateAreaLocation then
				// cannot road exit from yard
				app.raiseCMException(XLAT_Road_Exit_Error3,null,null);
				return false;
			endif;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_skipGateCheck" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findTruck" id="8cddec97-d9b7-474d-8f22-c56e8833a354">
        <source>findTruck( errMsg : String output; _truckReg :String ;_ignoreValidation : Boolean ) : CM_Vehicle;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Feb 2015 cnwma1   TFS 1488 JMT Mobile Apps - RecRel -  Gate Checker
*/
vars

	truckString : String;
	term : CM_Terminal;
	truck : CM_Vehicle;
	state : String;	
begin
	
	truckString := _truckReg;
	if truckString.trimBlanks = null  then
		app.raiseCMException1(Enter_truck,null, null, null);
		truck := null;
	else
		// identify the truck from the value entered.
		term := self.myTerminal;
		truck := term.vehicles[truckString.toUpper, state];
		if truck = null then
			
			if state &lt;&gt; null then
				app.raiseCMException2(Err_Unknown_Truck_Rego_State,truckString, state,null, null);
			else
				app.raiseCMException1(ERR_Truck_Unknown,truckString, null, null);
			endif;
		endif;
		
	endif;
	
	if truck &lt;&gt; null and not _ignoreValidation then	//15 Jukly 2014	NDL	Par 34562
		self.isValidTruckForLane(truck, errMsg);
	endif;
	return truck;
	
epilog

end;</source>
        <Parameter name="errMsg" type="String" usage="output"/>
        <Parameter name="_truckReg" type="String"/>
        <Parameter name="_ignoreValidation" type="Boolean"/>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="isValidTruckForLane" id="901c31e1-efa6-462b-88a1-91a5891ffc87">
        <source>isValidTruckForLane(truck : CM_Vehicle io; errMsg : String output);
/*
Purpose:			
Parameters:			
Return Value:		

Date			Who			Reason
25 Feb 2015 	cnwma1   	TFS 1488 JMT Mobile Apps - RecRel -  Gate Checker
25 Jul 2016 	cnwma1   	TFS 2273 JMT - Mobile Apps - Gate Checker Issues
30 Aug 2024		jlizm1		TFS 65856 MTN - Gate Checker Not validating when there is a truck in the lane
12 Sep 2024 	navma1		Bug 66073: SNO - Code :83948. When trying to change Vehicle registration
*/
vars
	truckString 		: String;
	inward 				: Boolean;
	job 				: CM_RoadJob;
	outwardLane 		: Boolean;
	inYard 				: Boolean;
	inYardInterChange 	: Boolean;
	glc 				: CM_GateAreaLaneController;
	lc					: CM_LocationsController;
begin
	
	if truck = null then
		return;
	endif;
	
	lc := truck.myPrimaryActualLocation;

	if lc = null and truck.allRoadJobs.isEmpty then
		app.raiseCMException1(Truck_no_jobs,null, null, null);
		truck := null;
		return;
	endif;
	
	glc := self.myGateAreaLaneController;
	if glc &lt;&gt; null then
		if glc.hasVehicles then
			if not glc.allVehicleMachines.includes(truck) then
				app.raiseCMException1(Lane_In_Use, glc.getNiceName, null, null);
				return;
			endif;
		endif;
	endif;
	
	inward := self.inward;
	if inward then
		inYard := false;
		outwardLane := false;
		if lc &lt;&gt; null then
			inYard := lc.CM_YardController.isInsideYard;
			if lc.isKindOf(CM_GateAreaLaneController) then
				outwardLane := lc.CM_GateAreaLaneController.laneDirection = CM_GateAreaLaneController.Is_Out_Lane;
			endif;
		endif;
		if lc &lt;&gt; null and inYard then
			if ( lc.isKindOf(CM_GateAreaLaneController) and
				lc.CM_GateAreaLaneController.laneDirection = CM_GateAreaLaneController.Is_In_Lane ) then 
				// this means we have selected a truck that is already in a lane, i.e. we have already started
				// to confirm it, but got interupted for some reason.  This is OK.
			else
				// problem here this truck is already in the yard, but an inward lane has been selected.
				truckString := truck.regNumber;
				app.raiseCMException2(Truck_In_Yard,truckString, self.myGateAreaLaneController.getNiceName,null, null);  // cnwma1 TFS 2273 26/07/2016
				truck := null;
				return;
			endif;
			
		else
			if outwardLane then
				// truck is already in an outward lane...
				truckString := truck.regNumber;
				app.raiseCMException1(Truck_outward_no_move_inward,null, null, null);
				truck := null;
				return;
			else
				// This truck is outside the yard i.e. Pre-Gate, ( heading for an inward lane )
			endif;
		endif;
		
	else
		outwardLane := false;
		inYard 		:= false;
		if lc &lt;&gt; null then
			if lc.isKindOf(CM_GateAreaLaneController) then
				outwardLane   := lc.CM_GateAreaLaneController.laneDirection = CM_GateAreaLaneController.Is_Out_Lane;
			endif;
			inYard 			  := lc.CM_YardController.isInsideYard;
			inYardInterChange := lc.CM_YardController.isYardInterchangeAreaLocation;
		endif;
		
		if lc = null or ( not inYard and not inYardInterChange and not outwardLane ) then
			// problem here this truck is already outside the yard or in an inward lane.
			truckString := truck.regNumber;
			app.raiseCMException1(Truck_Outside_Yard,truckString, self.myGateAreaLaneController.getNiceName, null);
			truck := null;
			return;
			
		else
			// This truck is in the yard (heading for an outward lane...) 
			job := truck.allRoadJobs.first.CM_RoadJob;
			if job &lt;&gt; null and job.status &lt;&gt; JOB_COMPLETE then
				app.raiseCMException1(ERR_JOB_NOT_COMPLETE,job.jobId,null, null);
				truck := null;
				return;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="truck" type="CM_Vehicle" usage="io"/>
        <Parameter name="errMsg" type="String" usage="output"/>
    </JadeMethod>
</Class>
