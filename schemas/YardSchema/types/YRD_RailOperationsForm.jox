    <JadeMethod name="doMnuWagonDelete" id="ccacfe24-2bda-4bb6-80ec-10a8c2b0fff0">
        <updating/>
        <source>doMnuWagonDelete(menuItem : MenuItem) updating, protected;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lWagon : CM_Wagon;
	rtnValue : Boolean;
	lWagonID : String;
	lResult : Integer;
	theWagonArea : YRD_WagonArea;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	if not menuItem.userObject.isKindOf(CM_Wagon) then
		return;
	endif;
	lWagon := menuItem.userObject.CM_Wagon;
	
	//lResult := app.msgBox("Are you sure that you want to delete wagon " &amp; lWagon.id &amp; "?", "Confirm Delete",MsgBox_Yes_No + MsgBox_Question_Mark_Icon); //- cnwmd1, CCMS 1067, Par 19710
	lResult := app.msgBox(app.getErrorString1(Sure_that_want_delete_wagon, lWagon.id), app.getErrorString(Confirm_Delete),MsgBox_Yes_No + MsgBox_Question_Mark_Icon); //+ cnwmd1, CCMS 1067, Par 19710
	if lResult = MsgBox_Return_Yes	then
		theWagonArea := self.getWagonAreaFromWagonObject(lWagon);

		//lWagonID := lWagon.id &amp; " deleted from " &amp; lWagon.myRailLine.getIdString; //- cnwmd1, CCMS 1067, Par 19710
		lWagonID := app.getErrorString2(Item_Deleted_From, lWagon.id, lWagon.myRailLine.getIdString);//+ cnwmd1, CCMS 1067, Par 19710
		
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteWagon(lWagon, false, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				self.doRefresh();
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Wagon_delete), app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;

	endif;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
