    <JadeMethod name="createContract" id="f34c8636-56d5-480f-b197-d944339ec7a3">
        <updating/>
        <source>createContract()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jan 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint
02 Mar 2023 navtnr20 Bug 56906: EUP - Minor UX issues when adding contract/contract information
17 Apr 2024 navrv30 Bug 63667: POB - Unable to Create Contract in Correct Business Unit
*/
vars
	pxyCon, realCon 		: CM_InvoiceContract;
	terminal				: CM_Terminal;
	bank 					: CM_Bank;
	debtor 					: CM_Debtor;
	desc,contractID			: String;
	scheduleTSstart 		: TimeStamp;
	scheduleTSend 			: TimeStamp;
	primarycheck,
	activeCheck				: Boolean;
	theReturn : Integer;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	if self.cmbDebtor.listIndex &lt;&gt; -1 then
		debtor := self.cmbDebtor.itemObject[self.cmbDebtor.listIndex].CM_Debtor;
	endif;
	if self.txtContractID &lt;&gt; null then
		contractID := self.txtContractID.text;
	endif;
	if self.txtDescription &lt;&gt; null then
		desc := self.txtDescription.text;
	endif;
	terminal := app.myPassport.myTerminal;
	//17 Apr 2024 navrv30 Bug 63667	
	bank := self.myCurrentBank;

	scheduleTSstart.setDate(self.mskContractFromStart.text.asDateJMT());
	scheduleTSstart.setTime(self.mskContractFromStartTime.text.asTimeJMT());
	scheduleTSend.setDate(self.mskContractFromEnd.text.asDateJMT());
	scheduleTSend.setTime(self.mskContractFromEndTime.text.asTimeJMT());
	primarycheck := self.chkPrimary.value;
	activeCheck :=  self.chkActive.value;
	create pxyCon transient;
	pxyCon.setProxy(activeCheck,contractID,  self.localToSystemTime(scheduleTSstart),  self.localToSystemTime(scheduleTSend), primarycheck, bank, terminal, debtor,desc); // ### BUG 58796 26JUN2023 NAVAB1 'localToSystemTime'
	
	while true do
		app.myTrxCA.trxCreateInvContract(pxyCon, realCon, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox(app.getErrorString(Invoice_contrac_create_success), app.getErrorString(Message),MsgBox_OK_Only);//navtnr20 02-03-2023 56906
			self.myInvoiceContract := realCon;
			if self.myInvoiceContract &lt;&gt; null  then
				self.btnAdd.enabled := true;
				self.btnRemove.enabled := true;
				self.btnUpdate.enabled := true;
				self.btnCopy.enabled := true;
				self.btnAttachments.enabled := true;
			endif;
			self.updateMode := true;
			self.handleContractDetails();
			
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_contract_create), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;

epilog
	self.mousePointer := Window.MousePointer_Default;
	delete pxyCon;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnAuditClick" id="edb51187-7e24-4ecd-b717-841f2346c417">
        <source>doBtnAuditClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2023	navrv30 Bug 58391: EUP - Audits for Invoice Copy

*/

vars
	contract : CM_InvoiceContractDetails;
begin
	contract := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceContractDetails;
	if contract = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	app.viewAuditFormModal(contract, self.myAssistant.class, self.myTerminal);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCopyClick" id="17de1c9a-ff74-4c01-9580-b918d8355b23">
        <updating/>
        <source>doBtnCopyClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023	navkc1	Initial creation CR #55652 Task 56286: UI - Contract Detail Copy TRX
*/

vars
	contract				: CM_InvoiceContract;
	
	pxyContractDetails,
	newContractDetails,
	contractDetails			: CM_InvoiceContractDetails;
	
	theReturn 				: Integer;
begin
	
	contractDetails := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceContractDetails;
	if contractDetails = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning), MsgBox_OK_Only);
		return;
	endif;
	
	contract := contractDetails.myInvoiceContract;
	
	if app.msgBox(app.getErrorString1(Clone_Cont_Details, contractDetails.auditId()), app.getErrorString(Information), MsgBox_Yes_No) = MsgBox_Return_Yes then
		pxyContractDetails := contractDetails.cloneForCopy(true, false, null, true); // ### BUG 56908 21MAR2023 NAVAB1
		pxyContractDetails.setMyInvoiceContract(contract);
		
		while true do
			app.myTrxCA.trxCopyInvoiceContractDetails(pxyContractDetails, newContractDetails, app.myPassport);
			
			if app.myPassport.trxCompletedOK() then
				self.clearErrorWarnings();
				app.msgBox(app.getErrorString(Invoic_contra_detail_create_su), app.getErrorString(Message),MsgBox_OK_Only);
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_contrac_details_create), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
			endif;
			break;
		endwhile;
	endif;	
epilog
	if pxyContractDetails &lt;&gt; null then
		pxyContractDetails.deleteClonedProxy();
	endif;
	delete pxyContractDetails;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUpdateClick" id="9a371558-2e47-4918-a8b9-73b8a1fbbda4">
        <updating/>
        <source>doBtnUpdateClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
15 March 2023	navmk20		Bug 57096: MTN - Minor UX issue when using contract maintenance
16 October 2023	navmv20	Bug 60893: FR - 54089 - Invoice Contract screens - Modal mode
*/

vars
	form : INV_ContractRateMaint;
	bank :CM_Bank;
	contract : CM_InvoiceContractDetails;
begin
	contract := self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceContractDetails;
	if contract = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	if contract &lt;&gt; null then
		//16/10/2023	navmv20	Bug 60893 - start
		form := self.myContractRateMaint;
		if form &lt;&gt; null then
			form.unloadForm();
		endif;
		form := app.loadForm(INV_ContractRateMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractRateMaint;
		self.myContractRateMaint := form;
		form.myParentForm := self;
		/*if form  = null then
			form := app.loadForm(INV_ContractRateMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractRateMaint;
			self.myContractRateMaint := form;
			form.myParentForm := self;
		else
			return;
		endif;*/
		//form := app.loadForm(INV_ContractRateMaint, INV_Assistant, false, false,false, self.myTerminal,null).INV_ContractRateMaint;
		//16/10/2023	navmv20	Bug 60893 - end
		
		if form &lt;&gt; null then
			//form.updateMode := true;	//31/01/2023	navkc1 Bug 61578
			form.mode := INV_ContractRateMaint.MODE_UPDATE; //31/01/2023	navkc1 Bug 61578
			form.setInvContract(self.myInvoiceContract);
			form.setMyCurrentBank(self.myCurrentBank);
			form.setInvContractDetail(contract);
			form.centreWindow();
			//form.showModal; //16/10/2023	navmv20	Bug 60893
			form.show; //16/10/2023	navmv20	Bug 60893
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleNotification" id="0548b369-25e1-48dd-841a-fc4dbc1a15cc">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Feb 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint

*/

vars
	dataLine	: String;
	invContract : CM_InvoiceContractDetails;
	event : Integer;
	idx : Integer;
	theDataLine : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if userInfo.isKindOf(CM_InvoiceContractDetails) then
		invContract := userInfo.CM_InvoiceContractDetails;
	elseif theObject.isKindOf(CM_InvoiceContractDetails) then
		invContract := theObject.CM_InvoiceContractDetails;
	endif;
	
	if event = Event_InvContractDtlCreate then
		if invContract &lt;&gt; null then			
			self.tblDisplayRow();
		endif;
	elseif event = Event_InvContractDtlUpdate then
		if invContract &lt;&gt; null then
			self.tblData.findObjectInRow(invContract,idx);
			if idx &gt; self.tblData.fixedRows then
				theDataLine := invContract.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessCell(idx, 1).text := theDataLine;
			endif;
		endif;
	elseif event = Event_InvContractDtlDelete then
		self.tblData.removeItemObject(invContract);
		self.doNotableClear();
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doLoadDebtor" id="2f973cb2-2030-4624-8bee-51e40d57bfc0">
        <source>doLoadDebtor();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jan 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint
22 November 2023 navmv20 Bug 60579: MTN - Debtor missing from list of available debtors in Invoice Contracts Enquiry
*/

vars
	theCMB : CMUI_ComboBox;
	debtor : CM_Debtor;
	index : Integer;
	debtorTerminal : CM_DebtorTerminal; //22/09/2023 navmv20 Bug 60579
begin
	theCMB := self.cmbDebtor;
	theCMB.clear;
	//22/09/2023 navmv20 Bug 60579 - start
	foreach debtorTerminal in self.myTerminal.allDebtorTerminals discreteLock do
		debtor := debtorTerminal.myDebtor;
	//foreach debtor in app.myRoot.myRootCompany.debtors do
	//22/09/2023 navmv20 Bug 60579 - end
		index := theCMB.addItem(debtor.name);
		theCMB.itemObject[index] := debtor;
	endforeach;
	theCMB.lostFocus(theCMB);
end;</source>
    </JadeMethod>
