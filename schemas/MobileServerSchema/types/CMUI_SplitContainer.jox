    <JadeMethod name="setLeftControl" id="e03e8027-1a9f-479d-a10f-fc18e4f15608">
        <updating/>
        <source>setLeftControl(_control : Control input) updating;
// ---------------------------------------------------------------------------
// Created:     28 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.myLeftControl := _control;
	if _control &lt;&gt; null then
		_control.parent := self;
	endif;

end;</source>
