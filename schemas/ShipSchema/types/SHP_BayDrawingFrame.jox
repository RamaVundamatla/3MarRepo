    <JadeMethod name="drawBayHeading" id="2155b5f6-e87d-4b20-bb1d-cc577abab53b">
        <updating/>
        <source>drawBayHeading(_bay : CM_Bay; _theX, _theY : Integer; _onDeck : Boolean; _bayDrawingController : SHP_BayDrawingController) updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	offSet, rowOffset : Real;
	numSlotsOD, numSlotsUD,theMiddleX,theSpace : Integer;
	theString : String;
	aColumn : CMUI_GridColumn; 
	theRowHeight,
	theColWidth,theScaleFactor : Real;
	firstPoint, lastPoint : CMUI_GridPoint;
	halfGraphicWidth,
	yOffset2, 
	theX		: Integer;
	iAmPrinting : Boolean;
	theFrame : SHP_BayDrawingFrame;
begin

	iAmPrinting := _bayDrawingController.amPrinting;
	
	if iAmPrinting and _onDeck then
		return;
	endif;
	
	theScaleFactor := _bayDrawingController.scaleFactor;
	theFrame := self;
		
	yOffset2 := HeadingGraphicHeight;

	halfGraphicWidth := (HeadingGraphicWidth / 2).Integer;

	theString := _bay.id; 
	
	// ### BAY ID
	if iAmPrinting then
		theX := _theX;
		theFrame.drawFillStyle := Frame.DrawFillStyle_Transparent;
		theFrame.drawEllipse1(theX - 10 , _theY, theX + 10, _theY + yOffset2, Black);
		theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
		theFrame.drawTextAt(theString, theX, _theY + 3,Black);
		
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
		
		return;
	endif;
	
	theX := _theX - halfGraphicWidth;

	// ### BAY ID
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	theFrame.drawFillColor := Blue; 
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	theFrame.drawEllipse1(theX, _theY, theX + HeadingGraphicWidth, _theY + HeadingGraphicHeight, Blue);
	theFrame.drawTextAt(theString, theX + HeadingGraphicTextXOffset, _theY + HeadingGraphicTextYOffset, White);

	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;

	if _bayDrawingController.showHoldID then
		theString := _bay.myHold.ordinalHold.String.padLeadingZeros(2);
		if theString.trimBlanks &lt;&gt; null then
			theX := theX - 3 - HeadingGraphicWidth;
			theFrame.drawFillColor := Green;
			theFrame.drawFilledRectangle(theX, _theY, theX + HeadingGraphicWidth, _theY + HeadingGraphicHeight,Green);
			theFrame.drawTextAt(theString, theX + HeadingGraphicTextXOffset, _theY + HeadingGraphicTextYOffset, White);
		endif;
	endif;

	// ##### 40 ID
	if _onDeck  then
		theString := _bay.getFortyFootBayID.trimBlanks;

		theX := _theX + halfGraphicWidth + 3;

		theFrame.drawFillColor := Mauve;
		theFrame.drawEllipse1(theX, _theY, theX + HeadingGraphicWidth, _theY + HeadingGraphicHeight, Mauve);
		theFrame.drawTextAt(theString, theX + HeadingGraphicTextXOffset, _theY + HeadingGraphicTextYOffset, White);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_theX" type="Integer"/>
        <Parameter name="_theY" type="Integer"/>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_bayDrawingController" type="SHP_BayDrawingController"/>
    </JadeMethod>
    <JadeMethod name="drawCell" id="4845af1a-79a2-4508-bb25-99ceeff68537">
        <updating/>
        <source>drawCell(_cell : CM_CellDefn; _startX, _startY : Integer; 
		_gridDict : CMUI_GridObjectByX1Y1X2Y2Dict input;
		_bayDrawingController : SHP_BayDrawingController input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	slotDefn	: CM_SlotDefn;
	slot	: CM_SlotController;
	tiersNot, tmpDisplayMode	: Integer;
	yOffset : Integer;
	tmpRowHeight,
	x, y	: Integer;
	bottomTI : CM_TrackedItem;
	numSlotsAvailable,
	maxPileWeight,
	pileWeight,
	weight20s,
	weightOthers : Integer;
	bottomSlotDefn : CM_SlotDefnVoyage;
	bottomRequest,
	bottomDischRequest,
	bottomLoadRequest : CM_SlotRequest;
	lengthX,
	heightY : Integer;	
	height,
	heightAvailable : Real;
	usedHeight, 
	availHeight,
	maxHeight : Integer;

begin

	x := _startX;
	y := _startY;
	
	tmpDisplayMode	:= _bayDrawingController.displayMode;
	tmpRowHeight	:= _bayDrawingController.rowHeight;
	// PAR 26760
	if tmpDisplayMode &lt;&gt; ShpDisplayMode_Defn 
	and _cell.myBayUD &lt;&gt; null then
		tiersNot := _cell.myBayUD.getNumTiersTotallyUnavailable(false);
	endif;
	
	// split up here to try and improve speed
	if tmpDisplayMode = ShpDisplayMode_Defn then
		foreach slotDefn in _cell.allSlotDefinitions reversed do
		
			y := _startY - (tmpRowHeight * slotDefn.ordinalTier );
			slot := slotDefn.CM_SlotDefnVoyage.mySlotController;
			self.drawSlot(slotDefn, slot, x, y, _gridDict, _bayDrawingController);
			if  _bayDrawingController.hasWeights then 
				
				slot.getPileWeightHeight(tmpDisplayMode,bottomTI,weight20s,weightOthers,height);
				
				if bottomSlotDefn = null  then
					bottomSlotDefn:=slotDefn.CM_SlotDefnVoyage;
				endif;	
			
				if bottomLoadRequest = null and 
					slot.mySlotRequestLoad &lt;&gt; null then
					bottomLoadRequest:= slot.mySlotRequestLoad;
				endif;
				if bottomDischRequest = null and 
					slot.mySlotRequestDischarge &lt;&gt; null then
					bottomDischRequest:= slot.mySlotRequestDischarge;
				endif;				
											
			endif;		
		endforeach;
	else

		foreach slotDefn in _cell.allSlotDefinitions where (not slotDefn.unavailable) do
			y := _startY - (tmpRowHeight * (slotDefn.ordinalTier - tiersNot)); // PAR 26760
			numSlotsAvailable := numSlotsAvailable  + 1;	
			slot := slotDefn.CM_SlotDefnVoyage.mySlotController;
			self.drawSlot(slotDefn, slot, x, y, _gridDict, _bayDrawingController);
			if  _bayDrawingController.hasWeights then 				
				slot.getPileWeightHeight(tmpDisplayMode,bottomTI,weight20s,weightOthers,height);
					
				if bottomSlotDefn = null  then
					bottomSlotDefn:=slotDefn.CM_SlotDefnVoyage;
				endif;	
			
				if bottomLoadRequest = null and 
					slot.mySlotRequestLoad &lt;&gt; null then
					bottomLoadRequest:= slot.mySlotRequestLoad;
				endif;
				if bottomDischRequest = null and 
					slot.mySlotRequestDischarge &lt;&gt; null then
					bottomDischRequest:= slot.mySlotRequestDischarge;
				endif;					
						
			endif;			
		endforeach;
	
	endif;
	
	//epr TFS 3284 3/2/17 more effecient to work this stuff out as we are iterating the cells and slots the first time
	
	if self.myBayDrawingController.showHeights then
		heightAvailable:=numSlotsAvailable * HEIGHT_FULL_NORMAL;
		usedHeight := (height * 0.3048).roundedTo(0).Integer;
		maxHeight := (heightAvailable * 0.3048).roundedTo(0).Integer;
		availHeight := maxHeight  - usedHeight;
	endif;
	
	
	if _bayDrawingController.hasWeights  then 
		pileWeight:=_cell.getTotalPileWeights(weight20s,weightOthers);
		//epr TFS 3284 1/2/17
		maxPileWeight:= _cell.getMaxPileWeightForBottomTI(bottomTI,bottomRequest,bottomSlotDefn);
		
		lengthX:=x + _bayDrawingController.xAxisLabelOffset;
		if _cell.onDeck then
			heightY := 15;																				// PAR #36269
			if self.myBayDrawingController.showHeights then 																		// PAR #36269
				heightY := heightY + 30;																// PAR #36269
			endif;																						// PAR #36269
			if self.myBayDrawingController.showWeights then 																		// PAR #36269
				heightY := heightY + 30;																// PAR #36269
			endif;		
			heightY:= _bayDrawingController.yHatchPos -heightY;
		else
			heightY := _bayDrawingController.yUnderDeckEndPos  +2;
			if self.myBayDrawingController.showHeights and self.myBayDrawingController.showWeights then														// PAR #36269
				heightY := heightY + 15;		// allow for extra line for weight				// PAR #36269
			endif;
		endif;
		_bayDrawingController.drawCellPileWeight(self,self.myBay, pileWeight, (pileWeight &gt; maxPileWeight),lengthX, heightY);
		if self.myBayDrawingController.showWeights then 
			_bayDrawingController.drawCellPileWeight(self,self.myBay, (maxPileWeight - pileWeight), (pileWeight &gt; maxPileWeight), lengthX, heightY + 15);// PAR #36269
			_bayDrawingController.drawCellPileWeight(self,self.myBay, maxPileWeight, (pileWeight &gt; maxPileWeight), lengthX, heightY + 30);			// PAR #36269
		endif;
		if self.myBayDrawingController.showHeights then 
			if self.myBayDrawingController.showWeights then																													// PAR #36269
				yOffset:= 45;																													// PAR #36269
			else																																// PAR #36269
				yOffset:= 15;																													// PAR #36269
			endif;	
			_bayDrawingController.drawCellPileWeight(self, self.myBay, usedHeight, (usedHeight &gt; maxHeight), lengthX, heightY + yOffset);			// PAR #36269
			_bayDrawingController.drawCellPileWeight(self, self.myBay, availHeight, (usedHeight &gt; maxHeight), lengthX, heightY +yOffset + 15);		// PAR #36269
			_bayDrawingController.drawCellPileWeight(self, self.myBay, maxHeight, (usedHeight &gt; maxHeight), lengthX, heightY + yOffset + 30);		// PAR #36269
		endif;
	endif;
	

end;</source>
        <access>protected</access>
        <Parameter name="_cell" type="CM_CellDefn"/>
        <Parameter name="_startX" type="Integer"/>
        <Parameter name="_startY" type="Integer"/>
        <Parameter name="_gridDict" type="CMUI_GridObjectByX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="_bayDrawingController" type="SHP_BayDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawCells" id="1b0cd990-c099-4b86-8316-60d69f704fd9">
        <updating/>
        <source>drawCells(_cells : CM_CellDefnByOrdinalDict; _x1, _y1 : Integer; 
		_gridDict : CMUI_GridObjectByX1Y1X2Y2Dict input;
		_bayDrawingController : SHP_BayDrawingController input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpCell		: CM_CellDefn;
	tmpWeight,
	theColWidth,
	cellX		: Integer;

begin

	if _cells = null then
		return;
	endif;

	theColWidth := _bayDrawingController.columnWidth;

	foreach tmpCell in _cells do
		cellX := _x1 + tmpCell.getDrawingPosX(theColWidth);
		self.drawCell(tmpCell, cellX, _y1, _gridDict, _bayDrawingController);
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_cells" type="CM_CellDefnByOrdinalDict"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_gridDict" type="CMUI_GridObjectByX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="_bayDrawingController" type="SHP_BayDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawHatchLid" id="317452bf-689b-41df-98bf-b21648f1e004">
        <updating/>
        <source>drawHatchLid(_bay : CM_Bay; _hatchLid : CM_HatchLid; _bayDrawingController : SHP_BayDrawingController; _fromRedraw : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 21/05/2015	cnwdap1		PAR #36269 Visual Display of Stack Weight Info
// 12/08/2015	cnwdap1		PAR #36731 Correct drawing of hatch lid
vars
	theX1, theX2, theY1, theY2 : Integer;
	aRow : CMUI_GridRow;
	theColWidth	: Integer;
	tmpSlot : CM_SlotDefn;
	tmpSController : CM_SlotController;
	minX, minY : Real;
	x1y1, x2y2 : Point;
begin

	theColWidth := _bayDrawingController.columnWidth;
	
	theX1 := self.leftSideMargin + _hatchLid.getDrawingPosStartX(_bay, theColWidth); 
	theX2 := self.leftSideMargin + _hatchLid.getDrawingPosEndX(_bay, theColWidth); 

	
	
	// PAR 26760 theY1 := _bayDrawingController.yHatchPos;
	
	// PAR #36731 not necessary any more
	//showHeights := self.getMyTerminalFromForm.getConfig(ShowHeightsLOLOPlanning).Boolean;	// PAR #36269
	//showWeights := self.getMyTerminalFromForm.getConfig(ShowWeightsLOLOPlanning).Boolean;	// PAR #36269
	//heightY := 15;																			// PAR #36269
	//if showHeights then																		// PAR #36269
	//	heightY := heightY + 50;															// PAR #36269
	//endif;																					// PAR #36269
	//if showWeights then																		// PAR #36269
	//	heightY := heightY + 35;															// PAR #36269
	//endif;																					// PAR #36269
	//if showWeights and showHeights then
	//	heightY := heightY - 5;
	//endif;
	//if self.myBayDrawingController.scaleFactor = self.myBayDrawingController.ScaleFactor_1 then 				// PAR #36269
	//	heightY := 5;																							// PAR #36269
	//elseif self.myBayDrawingController.printOutputStyle = self.myBayDrawingController.PrintOutput_Small then	// PAR #36269
	//	heightY := 15;																							// PAR #36269
	//elseif self.myBayDrawingController.printOutputStyle = self.myBayDrawingController.PrintOutput_Medium then	// PAR #36269
	//	heightY := 25;																							// PAR #36269
	//endif;																										// PAR #36269

	// PAR 26760 draw lids after bottom of OD based on what we have actually drawn
	tmpSlot := _bay.getFirstLastTierSlot(true, true, true, true, true);
	if tmpSlot &lt;&gt; null then
		tmpSController := tmpSlot.CM_SlotDefnVoyage.mySlotController;
		self.allObjectsOnDeck.getMinXY(minX, minY);
		if self.allObjectsOnDeck.findObjectInDictGetXY(tmpSController,x1y1, x2y2) then
			minY := x1y1.y;
		endif;
		theY1 := (minY + self.myBayDrawingController.rowHeight + 15).Integer;
	endif;
	
	
	
	if _bayDrawingController.amPrinting then
		if _bayDrawingController.printOutputStyle &lt;&gt; _bayDrawingController.PrintOutput_Large then // no weights drawn
			theY1 := theY1 - 10;
		endif;
		theY2 := theY1 + _bayDrawingController.HatchLidHeight_Print;
	else
		theY2 := theY1 + _bayDrawingController.HatchLidHeight_Screen;
	endif;

	if _bayDrawingController.allSelectedObjects.includes(_hatchLid) then
//		self.myForm.sendMsgWithParams("doBuildComboTableBays", _hatchLid.allBays);
		self.drawFillColor := Yellow;
	else
		self.drawFillColor := White;
	endif;
	
	theY1 := _bayDrawingController.yUnderDeckPos - 10;						// PAR #36731
	if self.myBayDrawingController.printOutputStyle = self.myBayDrawingController.PrintOutput_Medium then	// PAR #36731
		theY1 := _bayDrawingController.yUnderDeckPos - 15;					// PAR #36731
	endif;																	// PAR #36731
	if self.myBayDrawingController.amPrinting then							// PAR #36731
		theY2 := theY1 + 5;													// PAR #36731
	else																	// PAR #36731
		theY2 := theY1 + 10;												// PAR #36731
	endif;																	// PAR #36731
	self.drawFilledRectangle(theX1, theY1, theX2, theY2,Black);
	
	if (not _fromRedraw) then
		self.allHatches.putAtKey(theX1, theY1, theX2, theY2, _hatchLid);
	endif;

	if _hatchLid.endsMidCell then
		self.drawFillColor := Red;
		self.drawFilledRectangle(theX2 - 5, theY1, theX2, theY2, Red);
	endif;
	if _hatchLid.startsMidCell then
		self.drawFillColor := Red;
		self.drawFilledRectangle(theX1, theY1, theX1 + 5, theY2, Red);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_hatchLid" type="CM_HatchLid"/>
        <Parameter name="_bayDrawingController" type="SHP_BayDrawingController"/>
        <Parameter name="_fromRedraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawObjectAt" id="ce911fd4-4375-49af-a862-b29be7f8869f">
        <updating/>
        <source>drawObjectAt(_obj: Object; _x1, _y1, _x2, _y2 : Integer; _drawingController : SHP_BayDrawingController input) updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _obj = null then
		return;
	endif;

	if CM_SlotController.hasInstance(_obj) then
		_drawingController.setFromSlotDefn(_obj.CM_SlotController.mySlotDefnVoyage, _x1, _y1, _x2, _y2);
		_drawingController.drawCurrentObject(self);
	
	elseif CM_SlotDefn.hasInstance(_obj) then
		_drawingController.setFromSlotDefn(_obj.CM_SlotDefn, _x1, _y1, _x2, _y2);
		_drawingController.drawCurrentObject(self);

	elseif CM_HatchLid.hasInstance(_obj) then
		self.drawHatchLid(self.myBay, _obj.CM_HatchLid, _drawingController, true);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled object ' &amp; _obj.String);
	endif;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_drawingController" type="SHP_BayDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawOnDeck" id="97f95f78-d55c-4c87-8e22-21cd52e3a3d7">
        <updating/>
        <source>drawOnDeck(_bay : CM_Bay; _bayDrawingController : SHP_BayDrawingController input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 21/05/2015	cnwdap1		PAR #36269 TFS 331 Visual Display of Stack Weight Info
// 07/02/2017	cnwer1		TFS 3284 performance improvements calculating pile weights
// 16/03/2018 	JLGNS1		Bug 37525: SNO - (re Ticket 36886): Header in bay plan printing

vars
	offSet, 
	rightLabelPos,
	leftLabelPos	: Real;
	minX, minY, maxX, maxY, theRowHeight	: Real;
	theColWidth 	: Integer;
	theY, 
	theX,
	theSpaceX	: Integer;
	theLabel	: String;
	theFrame : SHP_BayDrawingFrame;
	tmpCell	: CM_CellDefn;
	tmpTier	: CM_TierDefn;
	tmpSlot : CM_SlotDefn;
	tmpSController : CM_SlotController;
	theSideMargin,
	theOnDeckOffset,
	weightYPos	: Integer;
	drawLabels,
	drawWeights		: Boolean;
	tmpObjDict		: CMUI_GridObjectByX1Y1X2Y2Dict;	
	form : Form;
	mode : Integer;
	x1y1, x2y2 : Point;
	cellLabelY : Integer;
	heightY : Integer;								// PAR #36269
	yOffset : Integer;								// PAR #36269
	unavailableCells : ObjectSet;
	iAmPrinting: Boolean;
	printOutputStyle,
	numSlotsOD,
	numSlotsUD,
	tmpY,
	tmpWidth: Integer;
	saveFontSize: Real;
	theString: String;
	yTrailerOffset : Integer;	//Bug 37525

begin

	theFrame := self;
	
	theX := (_bayDrawingController.bayWidth / 2).Integer;
	self.drawBayHeading(_bay, theX, 0, true, _bayDrawingController);

	iAmPrinting 	:= _bayDrawingController.amPrinting;
	printOutputStyle := _bayDrawingController.printOutputStyle;
	theRowHeight 	:= _bayDrawingController.rowHeight;
	theColWidth	 	:= _bayDrawingController.columnWidth;
	theSpaceX 		:= _bayDrawingController.xAxisLabelOffset;
	theOnDeckOffset	:= self.getOnDeckOffset(_bay, _bayDrawingController);		//cnwmc5 - 25 Oct 2013 - PAR 32847
	tmpObjDict		:= self.allObjectsOnDeck;
//	maxWeight 		:= (_bay.maxPileWeight20OB / 1000).rounded;
	drawWeights 	:= _bayDrawingController.hasWeights;
	drawLabels		:= _bayDrawingController.hasLabels;
	weightYPos		:= _bayDrawingController.yHatchPos - 15;
	theSideMargin	:= self.leftSideMargin;

	// 03 Sep 2010	NDL	Par 25215
	form := self.form;
	
	if form &lt;&gt; null and form.isKindOf(SHP_VoyageAreaForm2) then
		//25 Jan 2011	NDL Par 26641
		if form.SHP_VoyageAreaForm2.displayMode = ShpDisplayMode_Actual then	
			mode := ShpDisplayMode_Actual;
		else
			//proposed or colour code load or colour code discharge
			mode := ShpDisplayMode_Proposed;
		endif;
	else
		mode := ShpDisplayMode_Actual;	// default value.
	endif;

	create unavailableCells transient;
	// draw the slots by cell (COLUMN) and then the column labels seperately
	foreach tmpCell in _bay.allCellsOnDeckByOrdinal do
		// PAR 26760 
		if _bayDrawingController.displayMode &lt;&gt; ShpDisplayMode_Defn 
		and tmpCell.isTotallyUnavailable() then
			//epr TFS 3284 1/2/17
			unavailableCells.add(tmpCell);
			continue;
		endif;

		theX := theSideMargin + tmpCell.getDrawingPosX(theColWidth);
		
		self.drawCell(tmpCell, theX, theOnDeckOffset, tmpObjDict, _bayDrawingController);

	endforeach;

	 // PAR 26760 draw label seperately
	// ### CELL LABELS
	if drawLabels then
		// CELL OFFSETS
		tmpSlot := _bay.getFirstLastTierSlot(true, false, true, true, true);
		if tmpSlot &lt;&gt; null then
			tmpSController := tmpSlot.CM_SlotDefnVoyage.mySlotController;
			theFrame.allObjectsOnDeck.getMinXY(minX, minY);
			
			//04 Nov 2011	NDL	Par 28607 / 28632
			if _bayDrawingController.displayMode = ShpDisplayMode_Defn then
				cellLabelY := (minY - 15).Integer;
			endif;
			
			if theFrame.allObjectsOnDeck.findObjectInDictGetXY(tmpSController,x1y1, x2y2) then
				minY := x1y1.y;
			endif;
			theY := (minY - 15).Integer;
			foreach tmpCell in _bay.allCellsOnDeckByOrdinal  do
				if unavailableCells.includes(tmpCell) then
					continue;
				endif;
					
				theLabel := tmpCell.id;
		
				theX := theSideMargin + tmpCell.getDrawingPosX(theColWidth);
				offSet := theX + theSpaceX;
		
				if _bayDrawingController.displayMode = ShpDisplayMode_Defn then	//04 Nov 2011	NDL	Par 28607 / 28632
					theFrame.drawTextAt(theLabel, offSet, cellLabelY, Black);
				else
					theFrame.drawTextAt(theLabel, offSet, theY, Black);
				endif;
			endforeach;
		endif;
	endif;
	 // PAR 26760 draw label seperately
	// ### WEIGHT LABELS	
	
	heightY := 15;																				// PAR #36269
	if self.myBayDrawingController.showHeights then 																		// PAR #36269
		heightY := heightY + 30;																// PAR #36269
	endif;																						// PAR #36269
	if self.myBayDrawingController.showWeights then 																		// PAR #36269
		heightY := heightY + 30;																// PAR #36269
	endif;																						// PAR #36269
	if drawWeights then
		weightYPos := _bayDrawingController.yHatchPos - heightY;								// PAR #36269
		
		/*foreach tmpCell in _bay.allCellsOnDeckByOrdinal  do
			if unavailableCells.includes(tmpCell) then
				continue;
			endif;
					
			theX := theSideMargin + tmpCell.getDrawingPosX(theColWidth);
			offSet := theX + theSpaceX;
			// 03 sep 2010	NDL	Par 25215 - tmpWeight value above not always right.
			tmpCell.getPileWeight(	weight20,	//_weight20s : Integer output;
							weightOthers,	//_weightOthers : Integer output;
							tmpWeight,	//_displayWeight : Integer output;
							maxWeight,	//_maxPileWeight : Integer output;
							mode,	//_mode : Integer;
							comment	//_makeUpComment : String output
							);
		
			_bayDrawingController.drawCellPileWeight(self, _bay, tmpWeight, (tmpWeight &gt; maxWeight), offSet, weightYPos);
			
			if self.myBayDrawingController.showWeights then																														// PAR #36269
				_bayDrawingController.drawCellPileWeight(self, _bay, (maxWeight - tmpWeight), (tmpWeight &gt; maxWeight), offSet, weightYPos + 15);	// PAR #36269
				_bayDrawingController.drawCellPileWeight(self, _bay, maxWeight, (tmpWeight &gt; maxWeight), offSet, weightYPos + 30);					// PAR #36269
			endif;																																	// PAR #36269
			tmpWeight := 0;
			
			if self.myBayDrawingController.showHeights then																														// PAR #36269
				if self.myBayDrawingController.showWeights then																													// PAR #36269
					yOffset := 45;																													// PAR #36269
				else																																// PAR #36269
					yOffset := 15;																													// PAR #36269
				endif;																																// PAR #36269
				tmpCell.getPileHeights(mode,usedHeight, availHeight, maxHeight);																			// PAR #36269
				_bayDrawingController.drawCellPileWeight(self, _bay, usedHeight, (usedHeight &gt; maxHeight), offSet, weightYPos + yOffset);			// PAR #36269
				_bayDrawingController.drawCellPileWeight(self, _bay, availHeight, (usedHeight &gt; maxHeight), offSet, weightYPos + yOffset + 15);		// PAR #36269
				_bayDrawingController.drawCellPileWeight(self, _bay, maxHeight, (usedHeight &gt; maxHeight), offSet, weightYPos + yOffset + 30);		// PAR #36269
			endif;																																	// PAR #36269
		endforeach;*/
		
		yOffset := null;															// PAR #36269
		if self.myBayDrawingController.showWeights then															// PAR #36269
			theFrame.drawTextAt("Wgt", minX - 20, weightYPos, Black);				// PAR #36269
			theFrame.drawTextAt("Rem", minX - 20, weightYPos + 15, Black);			// PAR #36269
			theFrame.drawTextAt("Max", minX - 20, weightYPos + 30, Black);			// PAR #36269
			yOffset := 45;															// PAR #36269
		else																		// PAR #36269
			yOffset := 15;															// PAR #36269
		endif;																		// PAR #36269
		if self.myBayDrawingController.showHeights then															// PAR #36269
			theFrame.drawTextAt("Hgt", minX - 20, weightYPos + yOffset, Black);		// PAR #36269
			theFrame.drawTextAt("Rem", minX - 20, weightYPos + yOffset+ 15, Black);	// PAR #36269
			theFrame.drawTextAt("Max", minX - 20, weightYPos + yOffset+ 30, Black);	// PAR #36269
		endif;																		// PAR #36269
	endif;
	
	if self.myBayDrawingController.showHeights and self.myBayDrawingController.showWeights then
		theFrame.drawLine(minX-theColWidth, weightYPos + 45, offSet+theColWidth, weightYPos + 45, Black);
	endif;
	

	// ### TIER LABELS
	if drawLabels then
		//offSet := theOnDeckOffset - theRowHeight + _bayDrawingController.yAxisLabelOffset;	//cnwmc5 - 29 Oct 2013 - PAR 32879
		//offSet := minY + (theRowHeight * 0.3);												//cnwmc5 - 29 Oct 2013 - PAR 32879
		leftLabelPos := minX - 20; // PAR 26760
		theFrame.allObjectsOnDeck.getMaxXY(maxX, maxY);// PAR 26760
		rightLabelPos := maxX + 5;// PAR 26760
		
		foreach tmpTier in _bay.allTiersOnDeck reversed do
						
			//03 Nov 2011	NDL	Par 28632
			if tmpTier.isTotallyUnavailable() then
				continue;
			endif;
			
			//cnwmc5 - 29 Oct 2013 - PAR 32879
			if theFrame.allObjectsOnDeck.findObjectInDictGetXY(tmpTier.getFirstVisibleSlotController(),x1y1, x2y2) then
				offSet := x1y1.y + 3;		//Position plus offset to center.
			endif;
			
			theLabel := tmpTier.id;
			theFrame.drawTextAt(theLabel, leftLabelPos, offSet, Black);
			
			if drawWeights then
				_bayDrawingController.drawTierPileWeight(self, _bay, DeckOnDeck, tmpTier.ordinal, rightLabelPos, offSet);
			endif;
			//offSet := offSet + theRowHeight;		//cnwmc5 - 29 Oct 2013 - PAR 32879
		endforeach;
				
		//04 Nov 2011	NDL	Par 28607 / 28632
		if _bayDrawingController.displayMode = ShpDisplayMode_Defn then
			//offSet := maxY - (theRowHeight * 0.7);			//cnwmc5 - 29 Oct 2013 - PAR 32879
			foreach tmpTier in _bay.allTiersOnDeck do
				if not tmpTier.isTotallyUnavailable() then
					//offSet := offSet - theRowHeight;			//cnwmc5 - 29 Oct 2013 - PAR 32879
					continue;
				endif;
				
				//cnwmc5 - 29 Oct 2013 - PAR 32879
				if theFrame.allObjectsOnDeck.findObjectInDictGetXY(tmpTier.getFirstSlotController(),x1y1, x2y2) then
					offSet := x1y1.y + 3;		//Position plus offset to center.
				endif;
				
				theLabel := tmpTier.id;
				theFrame.drawTextAt(theLabel, leftLabelPos, offSet, Black);
				//offSet := offSet - theRowHeight;				//cnwmc5 - 29 Oct 2013 - PAR 32879
			endforeach;
		endif;
		
	endif;

	// #########################
	// print the bay trailer
	// - the bay ID and the hold id, the number of slots OD / UD and total
	 
	if self.myBayDrawingController.printSeparateODUD and not (iAmPrinting and printOutputStyle = _bayDrawingController.PrintOutput_Small) then
		self.myBay.getNumberOfSlotsAvailable(numSlotsOD, numSlotsUD);
		
		theX := (_bayDrawingController.bayWidth / 2).Integer;
		yTrailerOffset := 15;								//Bug 37525
		if self.myBayDrawingController.showWeights then		//Bug 37525	
			yTrailerOffset := yTrailerOffset + 35;			//Bug 37525	
		endif;												//Bug 37525	
		if self.myBayDrawingController.showHeights then		//Bug 37525	
			yTrailerOffset := yTrailerOffset + 45;			//Bug 37525	
		endif;												//Bug 37525	
		theY := weightYPos + yTrailerOffset;				//Bug 37525
		
		if iAmPrinting then
			saveFontSize	:= self.drawFontSize;
			theFrame.drawFontSize := 7;
			theString := numSlotsOD.asStringJMT;
			theFrame.drawTextAt(theString,theX + 15,theY,Black);
			theFrame.drawLine(theX + 15,theY+ 11,theX + 25,theY+ 11, Black);
			theString := numSlotsUD.asStringJMT;
			theFrame.drawTextAt(theString,theX + 15,theY+ 10,Black);
			theString := (numSlotsUD + numSlotsOD).String ;
			theFrame.drawTextAt(theString,theX + 30,theY+ 5,Black);
			
			theFrame.drawFontSize := saveFontSize;
		else
			theString := numSlotsOD.String ;
			theFrame.drawTextAt(theString, theX + 5, theY, Black);
			theFrame.drawLine(theX + 5, theY + 15, theX + 20 , theY + 15, Black);

			theString := (numSlotsUD + numSlotsOD).String ;
			theFrame.drawTextAt(theString, theX + 25, theY + 7,Black);
			
			theString := numSlotsUD.asStringJMT;
			theFrame.drawTextAt(theString, theX + 5, theY + 20,Black);
		endif;

		if (not iAmPrinting) then
			tmpY := self.clientHeight - 4;
			tmpWidth  := self.clientWidth;
			theFrame.drawLine(11, tmpY, tmpWidth - 11, tmpY, 12566463);
		endif;

		self.drawBayHeading(_bay, theX - (HeadingGraphicWidth / 2).Integer, theY, false, _bayDrawingController);
	endif;

epilog
	delete unavailableCells;
end;</source>
        <access>protected</access>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_bayDrawingController" type="SHP_BayDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="6bf6ecc6-221b-4bc6-a445-a8909f6308c4">
        <updating/>
        <source>drawSelf(_bayDrawingController : SHP_BayDrawingController input; _ondeck : Boolean; _underDeck : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
25 Jun 2010	cnwkpd1	PAR #21914 - Speed up Bay View drawing as per JBL recommendations

*/

vars
	tmpHatchLid	: CM_HatchLid;

begin
	self.beginBatchDrawing();			// PAR #21914

	self.allHatches.clear;
	self.allObjectsOnDeck.clear;
	self.allObjectsUnderDeck.clear;

	//epr TFS 3284 3/2/17
	_bayDrawingController.initConfigs(self.myBay.getMyTerminal);
	
	_bayDrawingController.setLabelFont(self);

	if _ondeck then
		self.drawOnDeck(self.myBay, _bayDrawingController);
	endif;
	
	if not self.myBayDrawingController.printSeparateODUD then		// 6/12/17 MAP TFS7494
		foreach tmpHatchLid in self.myBay.allHatchLids do
			self.drawHatchLid(self.myBay, tmpHatchLid, _bayDrawingController, false);
		endforeach;
	endif;

	if _underDeck then
		self.drawUnderDeck(self.myBay, _bayDrawingController);
	endif;
	_bayDrawingController.setDefaultFont(self);

epilog
	self.endBatchDrawing(); 			// PAR #21914
	
end;</source>
        <Parameter name="_bayDrawingController" type="SHP_BayDrawingController" usage="input"/>
        <Parameter name="_ondeck" type="Boolean"/>
        <Parameter name="_underDeck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSlot" id="70e97678-34cf-4572-a4ae-7156a2c96b44">
        <updating/>
        <source>drawSlot(_slotDefn : CM_SlotDefn; _slot : CM_SlotController; x1, y1 : Integer; 
		_gridDict : CMUI_GridObjectByX1Y1X2Y2Dict input;
		_bayDrawingController : SHP_BayDrawingController input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	splitWeight,
	x2,
	y2				: Integer;
	tmpTI	: CM_TrackedItem;

begin

	if _slot = null then
		app.raiseCMException1(MethodWithNullParam, '_slot', null, null);
		return;
	endif;

	x2 := x1 + _bayDrawingController.columnWidth;
	y2 := y1 + _bayDrawingController.rowHeight; 
	
	_bayDrawingController.setFromSlotDefn(_slotDefn, x1, y1, x2, y2);

	_bayDrawingController.setDefaultFont(self);
	_bayDrawingController.drawCurrentObject(self);
	
	// now set the font back for labels
	_bayDrawingController.setLabelFont(self);

	_gridDict.putAtKey(x1, y1, x2, y2, _slot);

	
end;</source>
        <access>protected</access>
        <Parameter name="_slotDefn" type="CM_SlotDefn"/>
        <Parameter name="_slot" type="CM_SlotController"/>
        <Parameter name="x1" type="Integer"/>
        <Parameter name="y1" type="Integer"/>
        <Parameter name="_gridDict" type="CMUI_GridObjectByX1Y1X2Y2Dict" usage="input"/>
        <Parameter name="_bayDrawingController" type="SHP_BayDrawingController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawTextScaled" id="e3eaa4f2-aa2e-4c99-ab2a-cefc92b466b8">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>drawTextScaled(_text: String; _x1: Real; _y1: Real; _color: Integer) clientExecution, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2012	cnwndl1	Initial creation	Par 29316

*/

vars

	startFontSize : Real;
	scaleFactor : Real;
	maxDimension : Real;
	numActiveRows : Integer;
	charWidth : Real;
	charHeight : Real;
	left : Real;

begin

	numActiveRows := self.myBayDrawingController.getNumAttributeRows();
	
	if numActiveRows = 1 then
	
		self.drawTextAt( _text, _x1 -2, _y1, _color);
	
	else
	
		scaleFactor := self.myBayDrawingController.scaleFactor;
		maxDimension := (( scaleFactor * 10 ) / numActiveRows ); // num pixels high and wide of the available area to draw in
	
		if self.drawFontName.pos("dings", 1) &gt; 0 then
		
			startFontSize := self.drawFontSize; // save off the current fontsize

			//charHeight := self.drawTextHeight(_text); // height of the char at this font size		//cnwmc5 - PAR 30989
			charHeight := self.drawTextWidth(_text);		//cnwmc5 - PAR 30989	
			
			while charHeight &gt; maxDimension do
				if self.drawFontSize &lt; 7 then		//cnwmc5 - PAR 30989
					break;
				endif;
				self.drawFontSize := self.drawFontSize - 1; // make the font smaller
				charHeight := self.drawTextHeight(_text);
			endwhile;
			
			charWidth := self.drawTextWidth(_text);// width of the char at this font size
			while charWidth &gt; maxDimension do
				if self.drawFontSize &lt; 7 then		//cnwmc5 - PAR 30989
					break;
				endif;
				self.drawFontSize := self.drawFontSize - 1; // make the font smaller
				charWidth := self.drawTextWidth(_text);
			endwhile;
		
		else
			charWidth := self.drawTextHeight(_text);// width of the char at this font size	//cnwmc5 - PAR 30989
		
		endif;
		
		// There is a 2 pixel left hand margin in _x1 that we can use if the char is near the width limit. 
		if charWidth +1 &gt; maxDimension then
			left := _x1 - 1;
		elseif charWidth +2 &gt; maxDimension then
			left := _x1 - 2;
		else
			left := _x1;
		endif;
		
		self.drawTextAt( _text, left, _y1, _color);
	
		// set font size back agaion
		if startFontSize &gt; 0 then
			self.drawFontSize := startFontSize;
		endif;
	
	endif;
	

epilog

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_color" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawUnderDeck" id="23db3f49-959c-449d-9d8c-d52ab704cb26">
        <updating/>
        <source>drawUnderDeck(_bay : CM_Bay; _bayDrawingController : SHP_BayDrawingController input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 21/05/2015	cnwdap1		PAR #36269 TFS 331 Visual Display of Strack Weight Info
// 07/02/2017	cnwer1		TFS 3284 performance improvements calculating pile weights
vars
	offSet, 
	rightLabelPos,
	leftLabelPos	: Real;
	theX, theY,
	numSlotsOD, numSlotsUD,
	theSpaceX	: Integer;
	theString : String;
	theColWidth	: Integer;
	theRowHeight,
	minX, minY, maxX, maxY : Real;
	theLabel : String;
	theFrame : SHP_BayDrawingFrame;
	iAmPrinting : Boolean;
	saveFontSize	: Real;
	printOutputStyle	: Integer;
	tmpCell	: CM_CellDefn;
	tmpTier	: CM_TierDefn;
	tmpSlot : CM_SlotDefn;
	tmpSController : CM_SlotController;
	theUnderDeckPos,
	theSideMargin,
	tmpWidth,
	weightYPos,
	maxWeight,
	tmpY	: Integer;
	hasLabels,
	drawWeights	: Boolean;
	tmpObjDict		: CMUI_GridObjectByX1Y1X2Y2Dict;
	form : Form;
	mode : Integer;
	x1y1, x2y2 : Point;
	cellLabelY : Integer;
	showHeights,									// PAR #36269
	showWeights : Boolean;							// PAR #36269
	yOffset : Integer;								// PAR #36269
	unavailableCells : ObjectSet;
begin

	theFrame := self;
	iAmPrinting 	:= _bayDrawingController.amPrinting;
	printOutputStyle := _bayDrawingController.printOutputStyle;
	theRowHeight 	:= _bayDrawingController.rowHeight;
	theColWidth	 	:= _bayDrawingController.columnWidth;
	theSpaceX 		:= _bayDrawingController.xAxisLabelOffset;
	drawWeights 	:= _bayDrawingController.hasWeights;
	tmpObjDict		:= self.allObjectsUnderDeck;
	hasLabels		:= _bayDrawingController.hasLabels;
	theUnderDeckPos	:= self.getUnderDeckOffSet(_bayDrawingController) + 15;
	maxWeight 		:= (_bay.maxPileWeightUD / 1000).rounded;
	weightYPos		:= _bayDrawingController.yUnderDeckEndPos + 2;
	theSideMargin	:= self.leftSideMargin;

	//25 Jan 2011	NDL Par 26641
	form := self.form;
	if form &lt;&gt; null and form.isKindOf(SHP_VoyageAreaForm2) then
		if form.SHP_VoyageAreaForm2.displayMode = ShpDisplayMode_Actual then	
			mode := ShpDisplayMode_Actual;
		else
			//proposed or colour code load or colour code discharge
			mode := ShpDisplayMode_Proposed;
		endif;
	else
		mode := ShpDisplayMode_Actual;	// default value.
	endif;

	create unavailableCells transient;
	foreach tmpCell in _bay.allCellsUnderDeckByOrdinal do
		// PAR 26760
		if _bayDrawingController.displayMode &lt;&gt; ShpDisplayMode_Defn 
		and tmpCell.isTotallyUnavailable() then
			unavailableCells.add(tmpCell);
			continue;
		endif;
		theX := theSideMargin + tmpCell.getDrawingPosX(theColWidth);

		self.drawCell(tmpCell, theX, theUnderDeckPos, tmpObjDict, _bayDrawingController);
	
	endforeach;


	 // PAR 26760 draw label seperately
	// ### CELL LABELS
	if hasLabels then
		tmpSlot := _bay.getFirstLastTierSlot(false, false, true, true, true);
		if tmpSlot &lt;&gt; null then
			tmpSController := tmpSlot.CM_SlotDefnVoyage.mySlotController;
			theFrame.allObjectsUnderDeck.getMinXY(minX, minY);
			
			//04 Nov 2011	NDL	Par 28607 / 28632
			if _bayDrawingController.displayMode = ShpDisplayMode_Defn then	
				cellLabelY := (minY - 15).Integer;
			endif;
			
			if theFrame.allObjectsUnderDeck.findObjectInDictGetXY(tmpSController,x1y1, x2y2) then
				minY := x1y1.y;
			endif;
			theY := (minY - 15).Integer;
			foreach tmpCell in _bay.allCellsUnderDeckByOrdinal do
				if unavailableCells.includes(tmpCell) then
					continue;
				endif;
						
				theLabel := tmpCell.id;
		
				theX := theSideMargin + tmpCell.getDrawingPosX(theColWidth);
				offSet := theX + theSpaceX;
		
				if _bayDrawingController.displayMode = ShpDisplayMode_Defn then	//04 Nov 2011	NDL	Par 28607 / 28632
					theFrame.drawTextAt(theLabel, offSet, cellLabelY, Black);
				else
					theFrame.drawTextAt(theLabel, offSet, theY, Black);
				endif;
			endforeach;
		endif;
	endif;
	 // PAR 26760 draw weight seperately
	// ### WEIGHT LABELS
	showHeights := self.myBayDrawingController.showHeights;		// PAR #36269
	showWeights := self.myBayDrawingController.showWeights;		// PAR #36269
	//epr par  37165 27/11/15
	if _bayDrawingController.amPrinting and _bayDrawingController.printOutputStyle &lt;&gt; _bayDrawingController.PrintOutput_Large then
		showHeights:=false;
		showWeights:=false;	
	endif;
	
	if drawWeights then
		weightYPos := _bayDrawingController.yUnderDeckEndPos  +2;
		if showHeights and showWeights then														// PAR #36269
			weightYPos := weightYPos + 15;		// allow for extra line for weight				// PAR #36269
		endif;	
		/*
		// PAR #36269
		foreach tmpCell in _bay.allCellsUnderDeckByOrdinal  do
			if unavailableCells.includes(tmpCell) then
					continue;
				endif;
			// PAR 26760 
			
			theX := theSideMargin + tmpCell.getDrawingPosX(theColWidth);
			offSet := theX + theSpaceX;
			// 03 sep 2010	NDL	Par 25215 - tmpWeight value above not always right.
			tmpCell.getPileWeight(	weight20,	//_weight20s : Integer output;
							weightOthers,	//_weightOthers : Integer output;
							tmpWeight,	//_displayWeight : Integer output;
							maxWeight,	//_maxPileWeight : Integer output;
							mode,	//_mode : Integer;
							comment	//_makeUpComment : String output
							);
			_bayDrawingController.drawCellPileWeight(self, _bay, tmpWeight, (tmpWeight &gt; maxWeight), offSet, weightYPos);
			if showWeights then																												// PAR #36269
				_bayDrawingController.drawCellPileWeight(self, _bay, (maxWeight - tmpWeight), (tmpWeight &gt; maxWeight), offSet, weightYPos + 15);// PAR #36269
				_bayDrawingController.drawCellPileWeight(self, _bay, maxWeight, (tmpWeight &gt; maxWeight), offSet, weightYPos + 30);			// PAR #36269
			endif;																															// PAR #36269
			tmpWeight := 0;
			
			if showHeights then																														// PAR #36269
				if showWeights then																													// PAR #36269
					yOffset := 45;																													// PAR #36269
				else																																// PAR #36269
					yOffset := 15;																													// PAR #36269
				endif;																																// PAR #36269
				tmpCell.getPileHeights(mode,usedHeight, availHeight, maxHeight);																			// PAR #36269
				_bayDrawingController.drawCellPileWeight(self, _bay, usedHeight, (usedHeight &gt; maxHeight), offSet, weightYPos + yOffset);			// PAR #36269
				_bayDrawingController.drawCellPileWeight(self, _bay, availHeight, (usedHeight &gt; maxHeight), offSet, weightYPos + yOffset + 15);		// PAR #36269
				_bayDrawingController.drawCellPileWeight(self, _bay, maxHeight, (usedHeight &gt; maxHeight), offSet, weightYPos + yOffset + 30);		// PAR #36269
			endif;																																	// PAR #36269
		endforeach;
		endif;
		*/
		yOffset := null;															// PAR #36269
		if showWeights then															// PAR #36269
			theFrame.drawTextAt("Wgt", minX - 20, weightYPos, Black);				// PAR #36269
			theFrame.drawTextAt("Rem", minX - 20, weightYPos + 15, Black);			// PAR #36269
			theFrame.drawTextAt("Max", minX - 20, weightYPos + 30, Black);			// PAR #36269
			yOffset := 45;															// PAR #36269
		else																		// PAR #36269
			yOffset := 15;															// PAR #36269
		endif;																		// PAR #36269
		if showHeights then															// PAR #36269
			theFrame.drawTextAt("Hgt", minX - 20, weightYPos + yOffset, Black);		// PAR #36269
			theFrame.drawTextAt("Rem", minX - 20, weightYPos + yOffset+ 15, Black);	// PAR #36269
			theFrame.drawTextAt("Max", minX - 20, weightYPos + yOffset+ 30, Black);	// PAR #36269
		endif;																		// PAR #36269
		
	endif;
	
	if showHeights and showWeights then
		theFrame.drawLine(minX-theColWidth, weightYPos + 45, offSet+theColWidth, weightYPos + 45, Black);
	endif;
	
	// ### TIER LABELS
	if hasLabels then

		//offSet := _bayDrawingController.yUnderDeckPos + _bayDrawingController.yAxisLabelOffset;		//cnwmc5 - 29 Oct 2013 - PAR 32879
		//offSet := minY + (theRowHeight * 0.3);														//cnwmc5 - 29 Oct 2013 - PAR 32879
		leftLabelPos := minX - 20; // PAR 26760
		theFrame.allObjectsUnderDeck.getMaxXY(maxX, maxY);// PAR 26760
		rightLabelPos := maxX + 5;// PAR 26760
		
		foreach tmpTier in _bay.allTiersUnderDeck reversed do
			// PAR 26760
			/*if _bayDrawingController.displayMode &lt;&gt; ShpDisplayMode_Defn 
			and tmpTier.isTotallyUnavailable() then
				continue;
			endif;*/
			
			//03 Nov 2011	NDL	Par 28632
			if tmpTier.isTotallyUnavailable() then
				continue;
			endif;
			
			//cnwmc5 - 29 Oct 2013 - PAR 32879
			if theFrame.allObjectsUnderDeck.findObjectInDictGetXY(tmpTier.getFirstVisibleSlotController(),x1y1, x2y2) then
				offSet := x1y1.y + 3;		//Position plus offset to center.
			endif;
			
			theLabel := tmpTier.id;
			theFrame.drawTextAt(theLabel, leftLabelPos, offSet, Black);
			
			if drawWeights then
				_bayDrawingController.drawTierPileWeight(self, _bay, DeckUnderDeck, tmpTier.ordinal, rightLabelPos, offSet);
			endif;
			//offSet := offSet + theRowHeight;		//cnwmc5 - 29 Oct 2013 - PAR 32879
		endforeach;
		
		//04 Nov 2011	NDL	Par 28607 / 28632
		if _bayDrawingController.displayMode = ShpDisplayMode_Defn then
			//offSet := maxY - (theRowHeight * 0.7);			//cnwmc5 - 29 Oct 2013 - PAR 32879
			foreach tmpTier in _bay.allTiersUnderDeck do
				if not tmpTier.isTotallyUnavailable() then
					//offSet := offSet - theRowHeight;			//cnwmc5 - 29 Oct 2013 - PAR 32879
					continue;
				endif;
				
				//cnwmc5 - 29 Oct 2013 - PAR 32879
				if theFrame.allObjectsUnderDeck.findObjectInDictGetXY(tmpTier.getFirstSlotController(),x1y1, x2y2) then
					offSet := x1y1.y + 3;		//Position plus offset to center.
				endif;
				theLabel := tmpTier.id;
				theFrame.drawTextAt(theLabel, leftLabelPos, offSet, Black);
				//offSet := offSet - theRowHeight;				//cnwmc5 - 29 Oct 2013 - PAR 32879
			endforeach;
		endif;
		
		offSet := 15;
	else
		offSet := 5;
	endif;	

	if self.myJobSeqSheet &lt;&gt; null then // do not print this on the sequence sheet
		return;
	endif;
	
	// #########################
	// print the bay trailer
	// - the bay ID and the hold id, the number of slots OD / UD and total
	 
	theX := (_bayDrawingController.bayWidth / 2).Integer;
	yOffset := offSet.Integer;														// PAR #36269
	if showWeights then																// PAR #36269
		yOffset := yOffset + 35;													// PAR #36269
	endif;																			// PAR #36269
	if showHeights then																// PAR #36269
		yOffset := yOffset + 45;													// PAR #36269
	endif;																			// PAR #36269
	if showWeights and showHeights then												// PAR #36269
		yOffset := yOffset + 15;													// PAR #36269
	endif;																			// PAR #36269
	//theY := (_bayDrawingController.yUnderDeckEndPos + offSet).Integer;			// PAR #36269
	theY := (_bayDrawingController.yUnderDeckEndPos + yOffset).Integer;				// PAR #36269
		
	if not (iAmPrinting and printOutputStyle = _bayDrawingController.PrintOutput_Small) then
		self.myBay.getNumberOfSlotsAvailable(numSlotsOD, numSlotsUD);
		
		if iAmPrinting then
			saveFontSize	:= self.drawFontSize;
			theFrame.drawFontSize := 7;
			theString := numSlotsOD.asStringJMT;
			theFrame.drawTextAt(theString,theX + 15,theY,Black);
			theFrame.drawLine(theX + 15,theY+ 11,theX + 25,theY+ 11, Black);
			theString := numSlotsUD.asStringJMT;
			theFrame.drawTextAt(theString,theX + 15,theY+ 10,Black);
			theString := (numSlotsUD + numSlotsOD).String ;
			theFrame.drawTextAt(theString,theX + 30,theY+ 5,Black);
			
			theFrame.drawFontSize := saveFontSize;
		else
			theString := numSlotsOD.String ;
			theFrame.drawTextAt(theString, theX + 5, theY, Black);
			theFrame.drawLine(theX + 5, theY + 15, theX + 20 , theY + 15, Black);

			theString := (numSlotsUD + numSlotsOD).String ;
			theFrame.drawTextAt(theString, theX + 25, theY + 7,Black);
			
			theString := numSlotsUD.asStringJMT;
			theFrame.drawTextAt(theString, theX + 5, theY + 20,Black);
		endif;

		if (not iAmPrinting) then
			tmpY := self.clientHeight - 4;
			tmpWidth  := self.clientWidth;
			theFrame.drawLine(11, tmpY, tmpWidth - 11, tmpY, 12566463);
		endif;
	endif;

	self.drawBayHeading(_bay, theX - (HeadingGraphicWidth / 2).Integer, theY, false, _bayDrawingController);
epilog
	delete unavailableCells;
end;</source>
        <access>protected</access>
        <Parameter name="_bay" type="CM_Bay"/>
        <Parameter name="_bayDrawingController" type="SHP_BayDrawingController" usage="input"/>
    </JadeMethod>
