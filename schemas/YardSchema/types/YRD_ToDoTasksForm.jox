    <JadeMethod name="doNotableClear" id="57b7ff3e-4801-4d61-8968-4e89876aebc4">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		/*if anObject.isKindOf(____OBJECT TYPE____) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(____EVENT_NAME_____));
			removedNotification := removedNotification + 1;
		endif;*/
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="d5e8b6ef-79d9-4900-adc4-c6022d5a6e83">
        <source>doPrint();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	gtpRateTable:        CM_GenericTablePrint;
	now:                 TimeStamp;
	hdrStr				: String;
	tmpJadeReport  : JadeReport;
begin
	
	app.mousePointer := MP_HOURGLASS;
//	app.printer.printPreview := true;
	app.printer.suppressDialog := true;
	now := self.systemToLocalTime(app.actualTimeServer());	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support

	create gtpRateTable;
	app.printer.setMargins(Print_Landscape,0,0,10,10);


	// setup header information

	// set header
	gtpRateTable.frHeader.width := app.printer.pageWidth;
	hdrStr := self.caption &amp; " (";
	if self.viewOption = self.VIEW_OPTION_TODO then
		hdrStr := hdrStr &amp; "To Be Done)";
	else
		hdrStr := hdrStr &amp; "Completed)";
	endif;

	gtpRateTable.setHeaders(hdrStr, null);
	create tmpJadeReport transient;
	tmpJadeReport.description := "ToDo Tasks";
	app.printer.setReport(tmpJadeReport);

	app.printer.setHeader(gtpRateTable.frHeader);

	// set footer
	gtpRateTable.frFooter.width := app.printer.pageWidth;
	gtpRateTable.lblTheUser.caption := app.getMyUserCode;
	gtpRateTable.lblTheDatePrinted.caption := now.String;
	app.printer.setFooter(gtpRateTable.frFooter);

	gtpRateTable.printTable(tblData, true, null);


epilog
	app.printer.close;
	app.printPreview(tmpJadeReport, true);
	delete gtpRateTable;
	app.mousePointer := MP_DEFAULT;


end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="3d550086-f2bd-4fbb-a1d7-639a98648afa">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tuckAwayRow,
	numRows 				: Integer;
	theFilter				: CMQF_TerminalTIs;
	theQryReport			: CM_QryReport;
	tbl					: CM_DataTable;
	ls						: Boolean;	
	cmifMonitor				: CMIF_Monitor;
begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	app.cmsBeginLoad(ls);
	self.btnAddComplete.enabled := false;
	self.btnRemoveTasks.enabled := false;


	self.numItemsShown		:= 0;
	self.numItemsSearched	:= 0;
	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
	self.modalDialogShow(null,'Return Data','Cancel',null,'Searching for data',null);
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		create cmifMonitor transient;
	endif;
	
	cmifMonitor.myParent := self;
	
	self.tblInfo.rows := self.tblInfo.fixedRows;
	self.tblData.rows := self.tblData.fixedRows;

	tbl := self.tblData;
	tuckAwayRow := tbl.row;
	theQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepTerminalTIs);

	theFilter := self.myTIQueryFilter;
	theFilter.reset();
	theFilter.allTerminals.add(self.myTerminal);
	
	self.lstTermArea.allSelectedObjects.copy(theFilter.allQryTerminalAreas);
	self.lstVoyage.allSelectedObjects.copy(theFilter.allVoyages);
	self.lstOperator.allSelectedObjects.copy(theFilter.allOperators);
	self.lstTasks.allSelectedObjects.copy(theFilter.allTasks);
	theFilter.doOnshipForVoyages := self.chkIncludeOnship.value;		
	theFilter.toDoOption := self.cmbToDoOpt.text;
	theFilter.completedOption := self.cmbCompleteOpt.text;

	self.lstCargoType.allSelectedObjects.copy(theFilter.allCargoTypes);
	theQryReport.doFilter(theFilter, app.myPassport);

	if (theFilter.allQryTrackedItems.isEmpty) then
		app.msgBox('No items were found to match the selected criteria', 'Nothing found', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	

	self.displayTIs(theFilter.allQryTrackedItems);

	self.tblData.sortColumn[1] := 1;
	
	numRows := tbl.rows;
	
	if tuckAwayRow &lt; 0 or tuckAwayRow &gt; numRows then
		tuckAwayRow := 1;
	endif;

	tbl.row := tuckAwayRow;
	tbl.accessRow(tuckAwayRow).selected := true;
	tbl.topRow := tuckAwayRow;
	self.doTblDataRowColChange(tbl);
	
	self.frmQuery.visible := false;
	self.btnAddComplete.enabled := true;
	self.btnRemoveTasks.enabled := true;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled:= false;
		self.btnAddComplete.enabled:= false;
		self.btnRemoveTasks.enabled:= false;
		self.btnEdit.enabled:= false;
		self.btnCancel.enabled:= false;
	endif;
	
epilog
	self.frmModalDialog.visible := false;
	app.myPassport.setMyCMIFMonitor(null);
	delete cmifMonitor;
	app.cmsEndLoad(ls);	
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
