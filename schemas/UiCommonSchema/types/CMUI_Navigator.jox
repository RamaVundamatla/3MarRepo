    <JadeMethod name="menuResetFromJMTDefault" id="4f3e3805-a7eb-407b-b283-693de8bd3050">
        <updating/>
        <source>menuResetFromJMTDefault()updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	user		: CM_User;
	ut			: CM_UserTerminal;
	fromEntity	: CM_MenuEntity;
	terminal	: CM_Terminal;
	menuRoot	: CM_MenuRoot;
begin
	if (not self.checkOpenWindows) then
		return;
	endif;
	
	if not app.msgBox('Are you sure you wish to reset your menu to the JMT default?','Are you sure?', MsgBox_OK_Cancel) = MB_OK then
		return;
	endif;
	
	fromEntity := self.lstTest.listObject.CM_MenuEntity;
	
	if not (fromEntity.isKindOf(CM_MenuUserItem) or fromEntity.isKindOf(CM_MenuRoot))  then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Move called for non-menuUserItem');
	endif;
	
	user := app.getMyUser;
	terminal := fromEntity.getMyTerminal;

	if terminal = null then
		menuRoot := fromEntity.getMyMenuRoot;
		if CM_MenuRootForUser.hasInstance(menuRoot) then //we are dealing with the user's system item menu root
			beginTransaction;
			user.resetSysEntMenuFromJMTDefault(true);
			app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
								null,	//_terminal : CM_Terminal;
								null,	//_objectForExtraDetail : Object;
								"System Menu for " &amp; user.code &amp; ", set from JMT Default",	//_description : String;
								true,	//_insideTransaction : Boolean;
								false	//_temp: Boolean
								);
			self.lstTest.displayTree(true, null);
			commitTransaction;
		endif;
		return;
	endif;
	
	ut := user.getUserTerminal(terminal);
	
	if ut = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'User Terminal object could not be found');
		return;
	endif;
	
	beginTransaction;
	ut.resetNavMenuFromJMTDefault(true);
	app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
								null,	//_terminal : CM_Terminal;
								null,	//_objectForExtraDetail : Object;
								"Terminal Menu for " &amp; terminal.code &amp; "/" &amp; user.code &amp; ", set from JMT Default",	//_description : String;
								true,	//_insideTransaction : Boolean;
								false	//_temp: Boolean
								);
	commitTransaction;
	
	self.lstTest.displayTree(true, null);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="menuResetFromSystemDefault" id="d6758f41-e6d7-4617-9443-40489d9f4af0">
        <updating/>
        <source>menuResetFromSystemDefault() updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	user		: CM_User;
	ut			: CM_UserTerminal;
	fromEntity	: CM_MenuEntity;
	terminal	: CM_Terminal;
	menuRoot	: CM_MenuRoot;
	debugObj	: Object;

begin
	if (not self.checkOpenWindows()) then
		return;
	endif;
	
	if not app.msgBox('Are you sure you wish to reset your menu to the system default?','Are you sure?', MsgBox_OK_Cancel) = MB_OK then
		return;
	endif;
	
	fromEntity := self.lstTest.listObject.CM_MenuEntity;
	
	if not (fromEntity.isKindOf(CM_MenuUserItem) or fromEntity.isKindOf(CM_MenuRoot))  then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Move called for non-menuUserItem');
		return;
	endif;
	
	user := app.getMyUser;
	terminal := fromEntity.getMyTerminal;
	
	if terminal = null then
		menuRoot := fromEntity.getMyMenuRoot;
		if menuRoot.isKindOf(CM_MenuRootForUser) then //we are dealing with the user's system item menu root
			beginTransaction;
			user.resetSysEntMenuFromSysDefault(true);
			app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
										null,	//_terminal : CM_Terminal;
										null,	//_objectForExtraDetail : Object;
										"System Menu for " &amp; user.code &amp; ", set from System Default",	//_description : String;
										true,	//_insideTransaction : Boolean;
										false	//_temp: Boolean
										);
			commitTransaction;	
		endif;
		self.lstTest.displayTree(true, null);	
		return;
	endif;
	
	ut := user.getUserTerminal(terminal);
	
	if ut = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'User Terminal object could not be found');
		return;
	endif;
	
	beginTransaction;
	ut.resetNavMenuFromSysDefault(false);
	app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
								null,	//_terminal : CM_Terminal;
								null,	//_objectForExtraDetail : Object;
								"Terminal Menu for " &amp; terminal.code &amp; "/" &amp; user.code &amp; ", set from System Default",	//_description : String;
								true,	//_insideTransaction : Boolean;
								false	//_temp: Boolean
								);
	commitTransaction;
	
	self.lstTest.displayTree(true, null);	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="mnuDockTopLeft2_click" id="bcb673be-dac5-41d1-80ed-7483f8b5f1e0">
