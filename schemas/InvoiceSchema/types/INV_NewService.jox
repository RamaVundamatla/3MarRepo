    <JadeMethod name="displayService" id="287da6f8-316f-45e3-bd85-bc5564c925dd">
        <source>displayService(_theObject : CM_ServiceType) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navkc1	Initial creation - ChangeRequest 54569

*/

vars

begin
	if _theObject = null then
		return null;
	else
		return _theObject.CM_ServiceType.code;
	endif;
epilog

end;</source>
        <Parameter name="_theObject" type="CM_ServiceType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBuildCmbGL" id="d35482cb-871f-4886-ae66-0d4f45d3e3c2">
        <source>doBuildCmbGL();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// 22/08/2022	navkc1	ChangeRequest 54569: Use the same new form for Edit mode
// ---------------------------------------------------------------------------

vars
	gl : CM_GLCode;
begin
	self.cmbGL.clear;
	self.cmbGL.addItem("(none)");
	self.cmbGL.itemObject[self.cmbGL.newIndex] := null;
	foreach gl in self.myCurrentBank.glCodes where not gl.isNotAvailableForEntry do
		self.cmbGL.addItem(gl.code &amp; " - " &amp; gl.remarks);
		self.cmbGL.itemObject[self.cmbGL.newIndex] := gl;
	endforeach;
	self.cmbGL.listIndex := 1;
	
	// 22/08/2022	navkc1	#54569 --&gt;
	if self.mode = self.UpdateMode_Update and self.myCurrentServiceObject &lt;&gt; null and self.myCurrentServiceObject.genLCode &lt;&gt; null then
		// Populate GL code
		self.cmbGL.listObject := self.myCurrentServiceObject.genLCode;
	endif;
	// 22/08/2022	navkc1	#54569 &lt;--

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildCmbRateType" id="2043b83f-c892-444d-b3fb-66318ed7d20f">
        <source>doBuildCmbRateType();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// 22/08/2022	navkc1	ChangeRequest 54569: Use the same new form for Edit mode
// ----------	--------	--------------------------------------------------

vars
	serviceObject	: CM_Service;
begin
	self.cmbRateTypes.clear;

	self.cmbRateTypes.addItem(app.getErrorString(Default_rate));
	self.cmbRateTypes.itemData[self.cmbRateTypes.newIndex] := CM_Service.DEFAULT_RATE_TABLE; //0

	if self.myTerminal.getConfig(ShipLinePortGroupsForInv).Boolean then
		self.cmbRateTypes.addItem(app.getErrorString(Shipping_line_rate));
		self.cmbRateTypes.itemData[self.cmbRateTypes.newIndex] := CM_Service.TRADE_RATE_TABLE; //1
	endif;
	
	self.cmbRateTypes.addItem(app.getErrorString(Vessel_rate));
	self.cmbRateTypes.itemData [self.cmbRateTypes.newIndex] := CM_Service.VESSEL_RATE_TABLE; //2
	
	self.cmbRateTypes.addItem(app.getErrorString(VesselType_rate));									
	self.cmbRateTypes.itemData [self.cmbRateTypes.newIndex] := CM_Service.VESSELTYPE_RATE_TABLE; //3
	
	self.cmbRateTypes.addItem(app.getErrorString(Berth_rate));									
	self.cmbRateTypes.itemData [self.cmbRateTypes.newIndex] := CM_Service.BERTH_RATE_TABLE; //4
	
	self.cmbRateTypes.addItem(app.getErrorString(VisitType_rate));									
	self.cmbRateTypes.itemData [self.cmbRateTypes.newIndex] := CM_Service.VISITTYPE_RATE_TABLE;	//5
	
	self.cmbRateTypes.listIndex := 1;
	
	serviceObject := self.myCurrentServiceObject; //14/01/2025	navkc1 JIRA Bug MTN-33802
	
	// 22/08/2022	navkc1	#54569 --&gt;
	if self.mode = self.UpdateMode_Update and serviceObject &lt;&gt; null and serviceObject.defaultRateTable &gt; 0 then
		// Populate the Rate
		//self.cmbRateTypes.listIndex := self.myCurrentServiceObject.defaultRateTable + 1;
		self.cmbRateTypes.listIndex := self.cmbRateTypes.findItemData(serviceObject.defaultRateTable); //14/01/2025	navkc1 JIRA Bug MTN-33802
	endif;
	// 22/08/2022	navkc1	#54569 &lt;--
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildCmbTax" id="1201af27-4a31-4c99-a8ff-583725683ab5">
        <source>doBuildCmbTax();
// ---------------------------------------------------------------------------
// Created:		May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// 22/08/2022	navkc1	ChangeRequest 54569: Use the same new form for Edit mode
// ---------------------------------------------------------------------------

vars
	tax : CM_TaxCode;
begin
	self.cmbTaxCode.clear;
	self.cmbTaxCode.addItem("(none)");
	self.cmbTaxCode.itemObject[self.cmbTaxCode.newIndex] := null;
	foreach tax in self.myCurrentBank.allTaxCodes 
		where tax.notAvailableForEntry = false do
		self.cmbTaxCode.addItem(tax.getDisplayDetails(false));
		self.cmbTaxCode.itemObject[self.cmbTaxCode.newIndex] := tax;
	endforeach;
	self.cmbTaxCode.listIndex := 1;

	// 22/08/2022	navkc1	#54569 --&gt;
	if self.mode = self.UpdateMode_Update and self.myCurrentServiceObject &lt;&gt; null and self.myCurrentServiceObject.myTaxCode &lt;&gt; null then
		// Populate Tax code
		self.cmbTaxCode.listObject := self.myCurrentServiceObject.myTaxCode;
	endif;
	// 22/08/2022	navkc1	#54569 &lt;--
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMsgService" id="52ae3f8a-a945-4b03-b3aa-be1b708a6622">
        <source>doBuildMsgService();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navkc1	Initial creation - ChangeRequest 54569

*/

vars
	allServiceTypes		: CM_ServiceTypeSet;
	serviceType			: CM_ServiceType;
	
	theService			: CM_Service;
	theBank				: CM_Bank;
begin
	// Set current service object referece
	theService 	:= self.myCurrentServiceObject;
	// Set current bank object referece
	theBank		:= self.myCurrentBank;
	
	create allServiceTypes transient;
	
	// Build Available object
	if theBank &lt;&gt; null then
		foreach serviceType in theBank.allServiceTypes do
			allServiceTypes.add(serviceType);
		endforeach;
		
		if allServiceTypes.size() &gt; 0 then
			self.msgServices.setAvailable(allServiceTypes, false);
		endif;
	endif;
	
	// Set Selected object
	if theService &lt;&gt; null then
		self.msgServices.setSelected(theService.allServiceTypes);
	endif;
	
epilog
	delete allServiceTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCalcTypesBuild" id="5652181a-38cf-416c-a18d-1e228a697701">
        <source>doCmbCalcTypesBuild();
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 11/09/2017	cnwma1  TFS #6897 JMT - Calculation Type Label Refactor
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// 22/08/2022	navkc1	ChangeRequest 54569: Use the same new form for Edit mode
// ---------------------------------------------------------------------------

vars
	tmpDesc : String;
	aCT, defaultCT : CM_CalculationType;
	haveVTMIS : Boolean;
	haveCARGO : Boolean;
begin
	haveVTMIS := app.myRoot.canDo(Mod_Harbour); 
	haveCARGO := app.myRoot.canDo(Mod_CargoHandling); // CONTAINER LICENSE
	
	self.cmbCalcTypes.clear;
	self.cmbCalcTypes.sorted := true;

	foreach aCT in app.myRoot.allCalculationTypesByCode discreteLock  where not aCT.isNotAvailableForEntry do
		if (aCT.isCargoCalcType and not haveCARGO) then
			continue;
		elseif (aCT.isVoyageCalcType and not haveVTMIS) then
			continue;
		endif;

		/* // ### TFS BUG 59913 31AUG2023 NAVAB1  
		tmpDesc := "";
		if aCT.isVoyageCalcType then 
			tmpDesc := "HMS - ";
		elseif aCT.isCargoCalcType then 
			tmpDesc := "Cargo - ";
		elseif aCT.isInventoryType then  // ### TFS 51219 28MAY2021 NAVAB1
			tmpDesc := "Inventory - "; // ### TFS 51219 28MAY2021 NAVAB1
		elseif aCT.isEventCalcType then
			tmpDesc := "Event - ";
		elseif aCT.isWorkOrderType and not aCT.isStandardWorkOrder() then
			tmpDesc := "Work Order - ";
		endif;
	*/
		tmpDesc := aCT.getComboDescription(); // ### TFS BUG 59913 31AUG2023 NAVAB1  description;               
		
		self.cmbCalcTypes.addItemObject(tmpDesc,aCT);
	
		if aCT.code = "CCT00" then
			defaultCT := aCT;
		endif;
	endforeach;

	if self.mode = self.UpdateMode_Update and self.myCurrentServiceObject &lt;&gt; null and self.myCurrentServiceObject.myCalculationType &lt;&gt; null then	// 22/08/2022	navkc1	#54569
		self.cmbCalcTypes.listObject := self.myCurrentServiceObject.myCalculationType; 		// 22/08/2022	navkc1	#54569
		self.doCmbChargesBuild(null); 								// 22/08/2022	navkc1	#54569 - don't need this in edit mode since it's disabled and hidden
	elseif defaultCT &lt;&gt; null then
		self.cmbCalcTypes.listObject := defaultCT;
		self.doCmbChargesBuild(defaultCT);
	else
		self.doCmbChargesBuild(null);
	
	endif;
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbChargesBuild" id="2e8c78fc-223f-4acb-bdeb-db22fe920320">
        <source>doCmbChargesBuild(_type : CM_CalculationType);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
// Modified:    April 2008 By Graeme Black cnwgb1 for CCMS Cp 1047		
//26.07.2018	cnwma1	Bug 39781: Getting a 1090 on opening Invoice Line Types
// ---------------------------------------------------------------------------

vars
	default : CM_DebtorType;
	dt : CM_DebtorType;		//31 Oct 2019	NDL	TFS 47100
begin
	
	self.cmbCharges.clear;
	self.cmbCharges.sorted := true;

	if _type = null 
	or _type.isCargoCalcType then // CARGO
		self.myAssistant.comboBoxDebtorType(self.cmbCharges, false, false);
	elseif _type.isVoyageCalcType then // HMS
		self.cmbCharges.addItem(app.myRoot.allDebtorTypes[CM_DebtorType.DT_SHIP_OPERATOR].description);
		self.cmbCharges.itemObject[1] := app.myRoot.allDebtorTypes[CM_DebtorType.DT_SHIP_OPERATOR];
		self.cmbCharges.listIndex := 1;
	elseif _type.isEventCalcType then // EVENTS
		self.cmbCharges.addItem(app.myRoot.allDebtorTypes[CM_DebtorType.DT_EVENT_TYPE].description);
		self.cmbCharges.itemObject[1] := app.myRoot.allDebtorTypes[CM_DebtorType.DT_EVENT_TYPE];
		self.cmbCharges.listIndex := 1;
		
	 // ### TFS 51219 28MAY2021 NAVAB1
	elseif _type.isInventoryType then // INVENTORY
	
		dt := app.myRoot.allDebtorTypes[CM_DebtorType.DT_CARGO_OPERATOR];
		self.cmbCharges.addItemObject(dt.description, dt);
		dt := app.myRoot.allDebtorTypes[CM_DebtorType.DT_CARRIER];
		self.cmbCharges.addItemObject(dt.description, dt);
		dt := app.myRoot.allDebtorTypes[CM_DebtorType.DT_CONSIGNEE];
		self.cmbCharges.addItemObject(dt.description, dt);
		dt := app.myRoot.allDebtorTypes[CM_DebtorType.DT_CONSIGNOR];
		self.cmbCharges.addItemObject(dt.description, dt);
		dt := app.myRoot.allDebtorTypes[CM_DebtorType.DT_SHIP_OPERATOR];
		self.cmbCharges.addItemObject(dt.description, dt);
		
		self.cmbCharges.listIndex := 1;
	elseif _type.isWorkOrderType then // Voyage WORK ORDERS
		self.cmbCharges.addItem(app.myRoot.allDebtorTypes[CM_DebtorType.DT_SHIP_OPERATOR].description);
		self.cmbCharges.itemObject[1] := app.myRoot.allDebtorTypes[CM_DebtorType.DT_SHIP_OPERATOR];
		self.cmbCharges.listIndex := 1;
	elseif _type.isBolCalcType then	//31 Oct 2019	NDL	TFS 47100
		self.myAssistant.comboBoxDebtorType(self.cmbCharges, false, true);	//29 Oct 2019	NDL	TFS 47100
	endif;
end;</source>
        <Parameter name="_type" type="CM_CalculationType"/>
    </JadeMethod>
    <JadeMethod name="doCmbInvTypeInvBuild" id="fcccfbe8-a0ca-4e73-b3bf-e265d0af3918">
        <source>doCmbInvTypeInvBuild();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	invoiceType : CM_InvoiceDesc;
begin
	self.cmbInvTypeInv.clear;

	foreach invoiceType in self.myCurrentBank.invoiceTypes where not invoiceType.isNotAvailableForEntry do
		self.cmbInvTypeInv.addItem(invoiceType.description);
		self.cmbInvTypeInv.itemObject[self.cmbInvTypeInv.newIndex] := invoiceType;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbUomBuild" id="929049cc-5188-4cc4-ac37-105bb3cb9635">
        <source>doCmbUomBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who			Reason
02 Feburary 2023	navvt20		TFS CR 56132 Task 56134: UI - Invoice Line Type - UOM

*/

vars
	invUOM : CM_InvoiceUnitOfMeasure;
begin
	self.cmbUOM.clear;
	
	self.cmbUOM.addItem("");
	foreach invUOM in app.myRoot.allInvoiceUnitOfMeasure  do
		self.cmbUOM.addItem(invUOM.description);
		self.cmbUOM.itemObject[self.cmbUOM.newIndex] := invUOM;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveDefaultRate" id="8544b891-e61d-44e5-8625-59a68d8327e8">
        <updating/>
        <source>doSaveDefaultRate(_service : CM_Service): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2019	jlgab1	Initial creation

*/

vars
	debtorRate : CM_DebtorRate;
	tradeRate : CM_LineGroupDebtorRate;
	berthRate : CM_BerthRate;
	vesselRate : CM_VesselRate;
	vesselTypeRate: CM_VesselTypeRate;
	visitTypeRate : CM_VisitTypeRate;
	rateEntry : CM_RateEntry;
	now : TimeStamp;
	pxyRE, realRE : CM_RateEntry;
	ls : Boolean;
	theReturn : Integer;
begin
	if self.chkAutoSetThisDefaultRate.value = false then
		return true;
	endif;
	
	
	if _service = null then
		return true;
	endif;
	
	// the new service will have a default rate of zero, lets find it and change it.
	if self.cmbRateTypes.itemData[self.cmbRateTypes.listIndex] = CM_Service.DEFAULT_RATE_TABLE then
		debtorRate := _service.debtorNodeRates.first;
		rateEntry := debtorRate.rateEntries.first;
		// The rate will have been auto created when the service was created.
		// Create an update proxy to set our rate.
		
		now := app.actualTimeServer().addDays(-1);
		
		app.cmsBeginLoad(ls);
		pxyRE := app.createUpdateProxy(rateEntry).CM_RateEntry;
		app.cmsEndLoad(ls);
		
		pxyRE.setProxy(null, 
									self.txtRate.text.Decimal, 
									rateEntry.rate,
									rateEntry.userId,
									now, 
									rateEntry.expiryTimestamp,
									rateEntry.ignoreThisEntry,
									rateEntry.adjustmentToBase,
									rateEntry.percentageOfBase,
									null);
									
	
		while true do
			app.myTrxUA.trxUpdateRateEntry(pxyRE, app.myPassport);
	
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				break;
			else
				theReturn := app.showErrorWarningDialog("Rate Entry", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return false;
			endif;
			break;
		endwhile;
	endif;
epilog
	delete pxyRE;
end;</source>
        <Parameter name="_service" type="CM_Service"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveLineType" id="f98882c9-759a-4792-99a1-244b196e04d4">
        <updating/>
        <source>doSaveLineType(_service : CM_Service): Boolean updating;
/*
Purpose:	TFS 44275		
Date				Who			Reason
MAY 2019		JLGAB1 initial creation
31/01/2023		navvt20	TFS CR 56132 Task 56134: UI - Invoice Line Type - UOM
*/


vars
	pxyInvoiceLineDesc, newInvoiceLineType		: CM_InvoiceLineDesc;
	table				: CM_EntryTable;
	theReturn : Integer;
	theServices : CM_ServiceByNameDict;
	chgNum : Integer;

begin
	if self.chkAutoLine.value = false then
		return true;
	endif;
	
	if _service = null then
		return true;
	endif;
	
	create pxyInvoiceLineDesc transient;
	pxyInvoiceLineDesc.bank := self.myCurrentBank;

	create theServices transient;
	theServices.add(_service);
	if self.cmbCharges.listIndex &gt; 0 then
		chgNum := self.cmbCharges.itemData[self.cmbCharges.listIndex];
	endif;
	
	pxyInvoiceLineDesc.setProxy(false,
								false,
								chgNum,
								self.cmbCharges.listObject.CM_DebtorType, 
								_service.myCalculationType,
								self.cmbInvTypeInv.listObject.CM_InvoiceDesc,
								_service.name,
								0,
								"",
								"",
								theServices,
								false,
								0,	
								"",
								"",
								false, 
								false,
								null,
								self.cmbUOM.listObject.CM_InvoiceUnitOfMeasure	// 31 Jan 2023 navvt20 TFS 56134
								);
								

	while true do
 
		app.myTrxCA.trxCreateInvoiceLineDesc(pxyInvoiceLineDesc, newInvoiceLineType, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			//global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Type", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
	return true;

epilog
	delete pxyInvoiceLineDesc;
	delete theServices;
end;</source>
        <Parameter name="_service" type="CM_Service"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveService" id="db664eb6-3cbb-4448-86b2-d6ddb8dd2493">
        <updating/>
        <source>doSaveService() updating, protected;
// save code for save and save/next

// 22/08/2022	navkc1	ChangeRequest 54569: Use the same new form for Edit mode

vars
	ls : Boolean;
	theReturn : Integer;
	realService, pxyService : CM_ServiceObject;
begin
	
	if self.mode = self.UpdateMode_New then
		create pxyService as CM_Service transient;
	elseif self.mode = self.UpdateMode_Update then // 22/08/2022	navkc1	#54569
		beginLoad; 
		pxyService := app.createUpdateProxy(self.myCurrentServiceObject).CM_ServiceObject;	// 22/08/2022	navkc1	#54569
		endLoad;
	endif;
	
	self.doSetProxyFromTable(pxyService);
	
	while true do
		if self.mode = self.UpdateMode_New then
			app.myTrxCA.trxCreateServiceObject(pxyService,realService,app.myPassport);
		elseif self.mode = self.UpdateMode_Update then							// 22/08/2022	navkc1	#54569
			app.myTrxUA.trxUpdateServiceObject(pxyService, app.myPassport);		// 22/08/2022	navkc1	#54569
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Service Schedule", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	if self.mode = self.UpdateMode_New then // 22/08/2022	navkc1	#54569 - Do this only when creating new service
		self.doSaveLineType(realService.CM_Service);
		self.doSaveDefaultRate(realService.CM_Service);
	endif;
	
epilog
	delete pxyService;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetProxyFromTable" id="dd129546-9b01-4530-a763-4a80e831f50d">
        <updating/>
        <source>doSetProxyFromTable(_pxy : CM_ServiceObject input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// 23/8/22	navkc1 	ChangeRequest #54569 - Add Service Types
// ---------------------------------------------------------------------------

vars
	notAvailable	: Boolean;

	rateType : Integer;
	rootSG, tmpSG : CM_ServiceGroup;
	serviceTypes : CM_ServiceTypeSet;
begin
	rootSG := self.myCurrentBank.getRootServiceGroup();
	if self.myCurrentServiceGroup = null then
		self.myCurrentServiceGroup := rootSG;
	endif;
	
	rateType := self.cmbRateTypes.itemData[self.cmbRateTypes.listIndex];
	tmpSG := self.myCurrentServiceGroup;
	notAvailable := false;
	
	create serviceTypes transient;
	
	self.msgServices.getSelected(serviceTypes);
	
	_pxy.setProxy(self.txtName.text,
					self.myCurrentBank,
					self.txtRemarks.text,
					self.cmbGL.listObject.CM_GLCode,
					tmpSG,
					rateType,
					self.cmbCalcTypes.listObject.CM_CalculationType,
					self.cmbTaxCode.listObject.CM_TaxCode,
					notAvailable,
					self.txtExtRef1.text,
					self.txtExtRef2.text,
					serviceTypes); // 23/08/22	navkc1	#54569

epilog
	delete serviceTypes;
end;</source>
        <Parameter name="_pxy" type="CM_ServiceObject" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doValidateInvoiceLine" id="51160056-98a1-4834-92c8-d97109a9da71">
        <source>doValidateInvoiceLine() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2021	navlw1	Initial creation TFS# 51998

*/

vars

begin
	if self.chkAutoLine.value = true and self.cmbInvTypeInv.listObject = null then
		app.raiseCMException(Invoi_line_type_must_have_invo,null,null);
		return false;
	else 
		return true;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initMsgService" id="5a2cec1e-08b8-4cf5-998d-fa09f5312cd4">
        <source>initMsgService();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2022	navkc1	Initial creation

*/

vars
	theGroupBox		: CMUI_MultiSelectGroupBox;
begin

	theGroupBox									:= self.msgServices;
	theGroupBox.caption 						:= null;
	theGroupBox.lockBottom 						:= false;
	theGroupBox.lockRight						:= false;
	theGroupBox.stretchHeight 					:= true;
	theGroupBox.stretchWidth 					:= true;
	theGroupBox.multiSelect 					:= ListBox.MultiSelect_Extended;
	theGroupBox.formDisplayEntryMethodName 		:= "displayService";
	theGroupBox.availableHeading 				:= app.getErrorString(Available_services);
	theGroupBox.selectedHeading 				:= app.getErrorString(Selected_services);
	theGroupBox.myBaseForm						:= self;
	theGroupBox.mySelectedListBox.sorted 		:= false;
	theGroupBox.readOnly 						:= false;
	
	theGroupBox.cnEcResizeContents();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cd3374f8-d13d-4082-945f-972a14a6aa2d">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2019	jlgab1	Initial creation
22 Aug	2022	navkc1	ChangeRequest 54569: Use the same new form for Edit mode / Add Service Types to screen
02 Feb  2023	navvt20	TFS CR 56132 Task 56134: UI - Invoice Line Type - UOM

*/

vars
	rate : Decimal    [23,6];
	dpl : Integer;
begin
	inheritMethod();

	self.doBuildCmbGL();
	self.doBuildCmbRateType();
	self.doBuildCmbTax();
	self.doCmbCalcTypesBuild();
	self.doCmbInvTypeInvBuild();
	self.initMsgService();		// 22/08/2022	navkc1	#54569 -Add service type to screen
	self.doBuildMsgService();	// 22/08/2022	navkc1	#54569	Add service type to screen
	self.doCmbUomBuild();		// 02/02/2023 	navvt20 TFS 56134

	dpl := self.getRateEntryDecimalPlaces(); // ### TFS 51219 25MAY2021 NAVAB1
	self.txtRate.text := rate.asStringJMTWithPrecision(dpl, false);
	self.txtRate.decimals := dpl; // ### TFS 51219 25MAY2021 NAVAB1
	
	// 22/08/2022	navkc1	#54569 --&gt; Populate fields in Edit mode
	if self.mode = self.UpdateMode_Update and self.myCurrentServiceObject &lt;&gt; null then
		self.caption := "Editing Service " &amp; self.myCurrentServiceObject.name;
		self.setCaption(self.caption);
		self.txtName.text 		:= self.myCurrentServiceObject.name;
		self.txtExtRef1.text 	:= self.myCurrentServiceObject.externalReference1;
		self.txtExtRef2.text 	:= self.myCurrentServiceObject.externalReference2;
		self.txtRemarks.text 	:= self.myCurrentServiceObject.remarks;
		self.chkNAFE.value 		:= self.myCurrentServiceObject.isNotAvailableForEntry;
		
	endif;
	// 22/08/2022	navkc1	#54569 &lt;--
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9941b361-e187-4b0c-a113-6c7e183dfe1a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 09 February 2023 08:56:27.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023618, locale);
	btnClose.translateCaption(Xlat_0023619, locale);
	btnNext.translateCaption(Xlat_0023620, locale);
	btnSave.translateCaption(Xlat_0023621, locale);
	chkAutoLine.translateCaption(Xlat_0023622, locale);
	chkAutoSetThisDefaultRate.translateCaption(Xlat_0023623, locale);
	chkNAFE.translateCaption(Xlat_0024271, locale);
	grpInvoiceLine.translateCaption(Xlat_0023624, locale);
	lblCalcType.translateCaption(Xlat_0023625, locale);
	lblCharges.translateCaption(Xlat_0023626, locale);
	lblDefaultRate.translateCaption(Xlat_0023627, locale);
	lblExtRef1.translateCaption(Xlat_0024638, locale);
	lblExtRef2.translateCaption(Xlat_0024639, locale);
	lblGLCode.translateCaption(Xlat_0023628, locale);
	lblInvoiceType.translateCaption(Xlat_0023629, locale);
	lblName.translateCaption(Xlat_0023630, locale);
	lblRateType.translateCaption(Xlat_0023631, locale);
	lblRemarks.translateCaption(Xlat_0023632, locale);
	lblTaxCode.translateCaption(Xlat_0023633, locale);
	lblUnitOfMeasure.translateCaption(Xlat_0025428, locale);
	shtDetail.translateCaption(Xlat_0025020, locale);
	shtService.translateCaption(Xlat_0025021, locale);
end;</source>
    </JadeMethod>
