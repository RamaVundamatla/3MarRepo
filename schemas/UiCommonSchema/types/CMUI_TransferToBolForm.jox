    <JadeMethod name="doOK" id="a2c31029-1c54-43ee-96c9-1c328f909a9e">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Apr 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

begin

	if not self.transferCargo() then
