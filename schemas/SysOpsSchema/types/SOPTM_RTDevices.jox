    <JadeMethod name="setupThumbnailDetails" id="13bfefb1-4f8a-431c-a829-cabe47ad6f4e">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;
	row		: Integer;

begin

  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_RadioTelemetryDataTbl);
	
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Type, false);
	//theForm.zAddSortColumn(ETRow_Id, false);
	 
	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_RadioTelemetryDataTblRvs);
	theForm.shtTblInput1.visible := true;
	
	self.myForm.myAssistant.comboBoxRTDeviceType(self.myForm.cmbDeviceType);
	self.myForm.myAssistant.comboBoxMachineId(self.myForm.cmbMachine, null);
	self.myForm.myAssistant.comboBoxCameraType(self.myForm.cmbCameraType);	//08 Dec 2010	NDL	Par 23831
	self.myForm.myAssistant.comboBoxPrinterDefs(self.myForm.cmbPrinters, false, null);	// TFS 978 label printer
	
	theForm.cmbPassword.clear();
	theForm.cmbPassword.addItem(true.getYesNo);
	theForm.cmbPassword.addItem(false.getYesNo);

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="ff34f50a-c705-4f13-bd2f-79b788e6469f">
        <updating/>
        <source>showThumbnail(_rtDevice : CM_RadioTelemetryDevice) updating;
// 17/08/2016 cnwrh7	TFS	2501
vars

	theForm : SOP_TableMaintForm;
	printerName	: String;
	idx : Integer;
begin

  
	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Type2, _rtDevice.type);
	theForm.tblInput1.setValueByName(ETRow_Id2,	_rtDevice.id);
	theForm.tblInput1.setValueByName(ETRow_Model, _rtDevice.model);
	theForm.tblInput1.setValueByName(ETRow_ComputerName, _rtDevice.computerName);
	theForm.tblInput1.setValueByName(ETRow_MessageId,	_rtDevice.lastMessageId);
	self.changeViews(_rtDevice.type);
	self.myForm.tblInput1.showRowByName(ETRow_MessageId, false);
	self.myForm.tblInput1.adjustHeight(800);
	if _rtDevice.type = RTDevice_Vehicle and _rtDevice.CM_RTDeviceVehicleMount.myMachine &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_Machine, theForm.myAssistant.displayEntryMachine(_rtDevice.CM_RTDeviceVehicleMount.myMachine));
		
		idx := theForm.cmbMachine.findObject(_rtDevice.CM_RTDeviceVehicleMount.myMachine); // AKB2007JULY - DCT EXCEPTION
		theForm.cmbMachine.listIndex := idx; // AKB2007JULY - DCT EXCEPTION
		
	elseif _rtDevice.type = RTDevice_HandHeld then	//08 Dec 2010	NDL	Par 23831
		theForm.tblInput1.setValueByName( ETRow_CameraType, app.cameraTypeEnumToString(_rtDevice.cameraType) );		
		idx := theForm.cmbCameraType.findStringExact( 1, app.cameraTypeEnumToString(_rtDevice.cameraType) );
		theForm.cmbCameraType.listIndex := idx;
		// TFS 978 hand-held label printer
		if _rtDevice.myLabelPrinter &lt;&gt; null then
			printerName := _rtDevice.myLabelPrinter.description;
		endif;
		theForm.tblInput1.setValueByName( ETRow_Printer, printerName);		
		idx := theForm.cmbPrinters.findStringExact( 1, printerName );
		if idx &gt; 0 then
			theForm.cmbPrinters.listIndex := idx;
		endif;
	endif;

	theForm.tblInput1.setValueByName(ETRow_PasswordRequired,	_rtDevice.isPasswordCompulsory.getYesNo);
	theForm.tblInput1.setValueByName(ETRow_UseSerialConnection,_rtDevice.useSerialConnection);
	theForm.tblInput1.setValueByName(ETRow_UseTCPConnection,_rtDevice.useLocalTCPConnection);			// +17/08/2016 cnwrh7	TFS	2501
	theForm.btnSerialConn.enabled:=_rtDevice.useSerialConnection;
	theForm.btnTCPConn.enabled := _rtDevice.useLocalTCPConnection;			//+ 17/08/2016 cnwrh7	TFS	2501
	

end;</source>
        <Parameter name="_rtDevice" type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
</Class>
