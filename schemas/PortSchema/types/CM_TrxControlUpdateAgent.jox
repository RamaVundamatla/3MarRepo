//Purpose: Sets scale job to complete and creates the unscaled logs
//--------------------------------------------------------------
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateToDoRequestStatus(_request, _newStatus, _passport);

	if _passport.noErrors then
		app.myUtilityCA.utlCreateUnscaledLogs(_bol, _passport);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_request" type="CM_Request" usage="io"/>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_bol" type="CM_BOL" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateLogScalingHdr" id="3cac7e17-8693-4d53-8266-cb1136ec97f9">
        <updating/>
        <source>trxUpdateLogScalingHdr(_proxyLogScalingHdr : CM_LogScalingHdr; _passport : CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		27 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	realLogScalingHdr	: CM_LogScalingHdr;
	expectedEdition		: Integer;
	terminal			: CM_Terminal;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	_proxyLogScalingHdr.raiseExceptionIfNotProxy(method);
	_proxyLogScalingHdr.pxyGetRealObjectAndEdition(realLogScalingHdr, expectedEdition);
	
	if realLogScalingHdr = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LogType.name, null, null);
		return;
	endif;
	
	// use a session lock here so does not get unlocked by endLoad after validation
	lock(realLogScalingHdr, Exclusive_Lock, Session_Duration, LockTimeout_Server_Defined);

	if _passport.noErrors and realLogScalingHdr.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Log Scaling Header', null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);

	if realLogScalingHdr.bolNumber = _proxyLogScalingHdr.bolNumber then
		_proxyLogScalingHdr.validateForUpdate();
	else
		_proxyLogScalingHdr.validateForCreate();
	endif;
	
	endLoad;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	beginTransaction;
	terminal := _passport.myTerminal;
	if _passport.noErrors then
		realLogScalingHdr.setForUpdate(_proxyLogScalingHdr);
	endif;

	if _passport.noErrors then
		terminal.causeEvent(terminal.getTerminalEvent(BOLRecon_Update_Event), false, realLogScalingHdr);	
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
	if realLogScalingHdr &lt;&gt; null then
		unlock(realLogScalingHdr);
	endif;
end;</source>
        <Parameter name="_proxyLogScalingHdr" type="CM_LogScalingHdr"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
