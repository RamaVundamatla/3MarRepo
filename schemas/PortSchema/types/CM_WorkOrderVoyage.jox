    <JadeMethod name="getDisplayStringForAttribute" id="6f9f4f5b-ca16-4fbb-80dd-8c5dc5e874ee">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2018	jlger1	Initial creation

*/

vars

begin
	if _attrName = ETRow_Voyage then
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.code;
		endif;
		return self.voyageCodeExternal;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="687cbb2d-2cdc-402d-a9e1-1dccbf55a8d7">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:		TFS 39718	

Parameters:			

Return Value:		

Date		Who		Reason
11 Jul 2018	jlgab1	Initial creation
30 Nov 2021 navma1	Bug 52482: SAL - Web Portal - Cargo Work Orders
*/

vars
	block   : CM_DataContainerBlock;
	wod 	: CM_WorkOrderDtl;
	addStr	: String;	
	ti 	    : CM_TrackedItem;
	tis 	: CM_TISet;
begin
	inheritMethod(_dataContainer);

	
	if self.myVoyage &lt;&gt; null then
		if self.myVoyage.code &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(VoyageCode), DC_Label, 1, null); 
			block.addNewItem(self.myVoyage.code, DC_Data, 1, self.myVoyage);					 // 30.11.2021 navma1 #52482
		endif;
		if self.myVoyage.voyageCodeExternal &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Voyage External Code", DC_Label, 1, null);
			block.addNewItem(self.myVoyage.voyageCodeExternal, DC_Data, 1, self.myVoyage);      // 30.11.2021 navma1 #52482
		endif;
	endif;
	
	if not self.allWoDtls.isEmpty then	//22 Oct 2019	NDL	TFS 47125
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Total_days), DC_Label, 1, null);
		block.addNewItem(self.allWoDtls.first.CM_WorkOrderVoyageDtl.getCurrentLengthOfTime().asStringJMT(), DC_Data, 1, null);
	else
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Total_days), DC_Label, 1, null);
		block.addNewItem(self.lengthOfTime.asStringJMT(), DC_Data, 1, null);
		
	endif;
	
	// TFS 39507
	foreach ti in self.allTIs do
		if addStr= "" then
			addStr := ti.id;
		else
			addStr := addStr &amp; ", " &amp; ti.id;
		endif;
	endforeach;
	
	if addStr &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Cargo), DC_Label, 1, ti); // TFS 39349 added TI
		block.addNewItem(addStr, DC_Data, 1, ti); // TFS 39349 added TI
	endif;	
	
	

	foreach wod in self.allWoDtls	discreteLock do
		wod.getExtraInfo(_dataContainer);
	endforeach;
	
epilog
	delete tis;


end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getInvFromDateTime" id="52278daf-342f-493d-9c05-1c98f4deb51e">
