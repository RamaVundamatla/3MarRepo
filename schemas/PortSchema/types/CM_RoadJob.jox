    <JadeMethod name="isJobTypeMatching" id="41bb0ef3-6887-4af0-91f6-cc83012b543e">
        <source>isJobTypeMatching(_jobType : Integer):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2023	navhl20	Defect 58906: MTN - The Allocated and Unallocated list is not refreshing correctly using the filter criteria
31 May 2024 navlc30 Defect 64408: EUP - Receive Cargo Job Type is generated for Release work orders
*/

vars

begin
	//if self.isRelease then					//31.05.2024 navlc30 #64408
	if self.isRoadReleaseJob then				//31.05.2024 navlc30 #64408
		return _jobType = WO_TASK_RELEASE;
	else
		return _jobType = WO_TASK_RECEIVE;
	endif;
epilog

end;</source>
        <Parameter name="_jobType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOnlyDevice" id="75ceefae-393d-4ce4-b4f2-8a51e8b23d1a">
        <source>isOnlyDevice(_dev : String):Boolean;
/*
	Created on 08 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	return self.allWorkingDeviceIDs.size() = 1 and self.allWorkingDeviceIDs.first() = _dev; 
end;</source>
        <Parameter name="_dev" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOpsViewData" id="e549d915-8d9b-4738-b7ef-a867edf2de4f">
        <source>isOpsViewData(): Boolean;
/*
Purpose:			

Date		Who		Reason
26 August 2021	navab1	TFS 51853
*/

vars
	isopsview : Boolean;
begin

	isopsview := inheritMethod();
	
	if isopsview then
		return true;
	endif;
	
	// if the last WLE has been deleted then look at the VVR to see if the TIs are for OpsView
	if self.myVehicleVisit &lt;&gt; null then // ### TFS 51853 01DEC2021 NAVAB1
		return self.myVehicleVisit.isOpsViewData(); // ### TFS 51853 01DEC2021 NAVAB1
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRelease" id="261f73fa-50f9-4083-b0ec-506ed1f201a2">
        <source>isRelease() : Boolean;
//Returns true if any of the requests are releases
//06 Mar 2025 navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
vars
	request : CM_Request;
begin
	
	foreach request in self.allRequests discreteLock do									//06.03.2025 navma1 #MTN-34179
		if request.isYardRequest and not request.CM_YardRequest.isReceipt then			//06.03.2025 navma1 #MTN-34179
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isReleaseByType" id="43d5f7b1-dd6d-4516-84f3-fe0211bcedb8">
        <source>isReleaseByType() : Boolean;
//Returns true if any of the requests are releases by type
//06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// PAR 18699 
vars
	request : CM_Request;
begin
	foreach request in self.allRequests discreteLock do		//06.03.2025 navma1 #MTN-34179
		if request.isYardRequest then
			if request.myOriginatingBulkRelease &lt;&gt; null and request.myOriginatingBulkRelease.releaseByType then
				return true;
			// par 23023 delivery requests not being queued
			elseif request.isDeliveryRequest then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRemainOnBoardTrailer" id="f8849b76-c1a8-4071-be7f-39efa160dadb">
        <source>isRemainOnBoardTrailer(_ti : CM_TrackedItem) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Aug 2024	navma1	Bug 65855: EUP - Total Count on the Cargo Scanning app is showing the wrong value when we gate in the truck with trailer

*/

vars
	vvr 	: CM_VehicleVisitRecord;
	inTi,
	outTi 	: CM_TrackedItem;
begin
	
	vvr := self.myVehicleVisit;
	
	if vvr = null then 
		return false;
	endif;
	
	if vvr.myInCMGTE_Chassis = null then
		return false;
	endif;
	
	if vvr.myOutCMGTE_Chassis = null then
		return false;
	endif;
	
	inTi 	:= vvr.myInCMGTE_Chassis.myTrackedItem;
	outTi 	:= vvr.myOutCMGTE_Chassis.CMGTE_Release.myTrackedItem;
	
	if (inTi &lt;&gt; null and outTi &lt;&gt; null) and (_ti = inTi and _ti = outTi) then
		return true;
	endif;
	

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
