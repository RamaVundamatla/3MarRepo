    </JadeMethod>
    <JadeMethod name="doEditCargo" id="b8fbf249-5ac0-42db-878a-b697519eda0d">
        <source>doEditCargo(_ti: CM_TrackedItem; _editCurrentObject: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who			Reason
06 May 2022			navsrk20	Initial creation TFS 53388
08 November 2022	navmd1		TFS 55379 Refactor VoyageOpsCG Form

*/

vars
	tiSet 		: CM_TISet;
	objArr		: CM_ObjectArray;
begin
	create tiSet transient;
	// ### TFS 58922 04JUL2023 NAVAB1self.getCurrentlySelectedTIs(tiSet);
	self.getAllSelectedTIs("", tiSet, false, self.myCurrentContextTbl);// ### TFS 58922 04JUL2023 NAVAB1

	// This is a bit dumb and can probably be done better
	create objArr transient;
	tiSet.copy(objArr);
	
	self.myAssistant.showCargoEnquiryForTIs(tiSet.first, objArr, self.myMasterMenuAction, _editCurrentObject);
epilog
	delete objArr;
	delete tiSet;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_editCurrentObject" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuMoveItClick" id="461002b6-cd49-4458-9180-731d6c9f5e6c">
        <updating/>
        <source>doMnuMoveItClick(_tiArray: ObjectArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
05 May 2022			navsj20	Initial creation TFS 53388
08 November 2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form

*/
vars
	tiArray			: CM_TIArray;
	obj,item		: Object;
	ti				: CM_TrackedItem;
begin
	if _tiArray = null or _tiArray.isEmpty then 
		return;
	endif;
	
	create tiArray transient;
	
	// To avoid duplicates, go trhough CGs first
	foreach ti in _tiArray as CM_TrackedItem where ti.isCargoGroupItem do
		ti.CM_CargoGroup.allAssignedTrackedItems.copy(tiArray);
	endforeach;
	
	// And then add any individual items
	foreach ti in _tiArray as CM_TrackedItem where not ti.isCargoGroupItem do
		tiArray.tryAdd(ti);
	endforeach;
	
	if tiArray.size &lt; 2 then
		self.myAssistant.showMoveItForm(tiArray, self.getMoveMode);
	else
		self.myAssistant.showMoveItForm(tiArray, AUTO_PLAN_MODE);
	endif;
	
epilog
	delete tiArray;
end;</source>
        <Parameter name="_tiArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="855a22c4-b111-404c-b5aa-8ab4d80dad20">
        <updating/>
        <source>doNotableClear() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
05 December 2022	navmd1	TFS 55379 - Fix cargo group line not being removed when cargo group detail is deleted

*/

vars
	ti		: CM_TrackedItem;
begin
	on Exception do self.handle1066(exception, null, self);
	foreach ti in self.allDisplayedTIs where ti.isCargoGroupItem do
		self.endNotification(ti, Object_Update_Event);
	endforeach;

	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNoteHandlingObject" id="e5b04503-e821-42db-8827-a5e075259885">
        <updating/>
        <source>doNoteHandlingObject(_notificationRecord: CMIF_NotificationRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/07/2025	navkc1 	JIRA MTN 35478 MTN | Voyage Operations - Notification Framework
14 Jan 2026 navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/

vars
	cargoGroup		: CM_CargoGroup;
	ti 				: CM_TrackedItem;
	userInfo		: Any;
	event,
	eventTag,
	eventType		: Integer;
	noteObj			: Object;
	invalid			: Boolean;
	term			: CM_Terminal;
begin
	noteObj 	:= _notificationRecord.myObject;
	eventType 	:= _notificationRecord.eventType;
	eventTag 	:= _notificationRecord.eventTag;
	userInfo 	:= _notificationRecord.myUserInfo;
	
	if noteObj = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception,ti,invalid);

	if self.myCurrentVoyage = null then
		return;
	endif;
	
	term := self.myTerminal;
	
	if term &lt;&gt; null then
		event := term.getEventFromTerminalEvent(eventType);
	endif;
	
	if event = EVENT_VOYAGE_CARGOGROUP_DETAIL then
		if userInfo &lt;&gt; null and userInfo.isKindOf(CM_Voyage) then
			self.loadCurrentVoyage();
		endif;
	elseif event = EVENT_CARGOGROUP_UPDATE then
		if not self.isInCargoGrouping or userInfo = null then
			return;
		endif;
		cargoGroup:= userInfo.CM_CargoGroup;
		if self.allDisplayedTIs.includes(cargoGroup) then
			self.updateCargoGroup(cargoGroup);
		else
			self.addNewCargoGroup(cargoGroup);
		endif;
	elseif event = EVENT_CARGOGROUP_DELETE then
		if userInfo &lt;&gt; null then
			self.handleDeletedTI(userInfo.CM_TrackedItem);
		endif;
	else
		if noteObj.isKindOf(CM_CargoGroup) then
			self.handleNotifications(eventType, noteObj.CM_CargoGroup, eventTag, null);
		else
			self.myCargoGroup := null;
			
			if noteObj.isKindOf(CM_TrackedItem) then
				ti := noteObj.CM_TrackedItem;
				
				if ti.isChild() then
					self.doNoteForCurrentViewTI(ti, false, false, true);
					return;
				endif;
			endif;
			
			inheritMethod(_notificationRecord);
		endif;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_notificationRecord" type="CMIF_NotificationRecord"/>
    </JadeMethod>
    <JadeMethod name="doPostFilterTableProcessing" id="62196579-5867-4f11-8a60-022d2361abc9">
