    <JadeMethod name="setMyStopsTable" id="18e1f3b9-abb7-482c-a0d0-da65a86ea492">
        <updating/>
        <source>setMyStopsTable( _value : CM_StopsTable ) updating;

/*
Date				Who		Reason
21 January 2010		cnwrl1	Initial creation as part of PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
*/
	
vars
	
begin
	if myStopsTable &lt;&gt; _value then
		myStopsTable	:= _value;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="694df6dd-2e32-4dfa-9dbd-69855754bb86">
        <updating/>
        <source>setMyTrackedItem(_theTI : CM_TrackedItem input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 20 Oct 2022	navsj20		ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
vars
	aOK 			: Boolean;
	tmpStopTable	: CM_StopsTable;
	theTI	, realTI		: CM_TrackedItem; //cnwrd1 par 20532 15.9.09
begin
	if app.isUnitTestGarbageCollect then
		return false;
	endif;

	if _theTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'theTI', null, null);
		return false;
	endif;

	tmpStopTable := self.myStopsTable;
	if tmpStopTable = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'self.myStopsTable', null, null);
		return false;
	endif;
	
	if not _theTI.pxyIsProxy() then	// ### TFS 55481 23Nov2022 NAVPW1
		//if (not tmpStopTable.isValidForCargoType(_theTI.cargoType)) then	//20.10.2022	navsj20	TFS 53862
		if (not tmpStopTable.isValidForStopCriteria(_theTI)) then	//20.10.2022	navsj20	TFS 53862
			//app.raiseCMException3(StopNotValidForCargoType, tmpStopTable.heading, _theTI.cargoTypeDescr, _theTI.id, null, null);	//20.10.2022	navsj20	TFS 53862
			app.raiseCMException2(StopNotValidForTrackedItem, tmpStopTable.heading, _theTI.id, null, null);		//20.10.2022	navsj20	TFS 53862
			return false;
		endif;
	endif;							// ### TFS 55481 23Nov2022 NAVPW1
	
	//cnwrd1 par 20532 15.9.09 start 
	theTI := _theTI;
	realTI := _theTI.pxyGetRealObject().CM_TrackedItem; // ### TFS CR 60424 TASK 60549 24OCT2023 NAVAB1
	
	// ### TFS CR 60424 TASK 60549 24OCT2023 NAVAB1
	if self.myStopsTable.requiresInfoForCustoms() 
	and realTI &lt;&gt; null
	and realTI.allCustomDocDetails.isNotEmpty() then
		if (not theTI.getAllStops().includesKey(self.id)) then	
			self.myTrackedItem := theTI;
			aOK := true;
		else
			aOK := false; // TI already has this stop - don't bother with a warning/error
		endif;
	
	else
	//	if (not theTI.getAllStops().includesKey(self.id)) then	// cnwrl1 14/12/2009 PAR 21889 - what it was
		if not theTI.isStopSet( self.id ) then
			self.myTrackedItem := theTI;
			aOK := true;
		else
		//cnwrd1 par 20532 15.9.09 end
		
			// TI already has this stop - don't bother with a warning/error
		endif;
	endif;
	
	return aOK;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyCustDocApplied" id="f8412add-3bf4-4599-9945-f9778fe15808">
        <updating/>
        <source>setProxyCustDocApplied(_custDocDetail : CM_CustomDocumentDetail) updating;
/*
Purpose:			

Date		Who		Reason
01 September 2023	navab1	CR 59942 TASK 59943 
*/

vars
	custDoc : CM_CustomDocument;
begin
	if _custDocDetail&lt;&gt; null then
		custDoc := _custDocDetail.getCustomDocumentHeader();
		if custDoc &lt;&gt; null then
			self.custDocCode := custDoc.code;
			self.custDocSequence := custDoc.sequence.String;
			if  custDoc.myCustomLicense &lt;&gt; null then
				self.custDocLicense := custDoc.myCustomLicense.code;
			endif;
			self.custDocType := custDoc.myCustomDocumentType.code &amp; " " &amp; CM_CustomDocumentType@getDirectStrFromInt(custDoc.direction);
		endif;
	endif;
	
	self.myCustomDocumentDetlAppliedBy := _custDocDetail;
epilog

end;</source>
        <Parameter name="_custDocDetail" type="CM_CustomDocumentDetail"/>
    </JadeMethod>
