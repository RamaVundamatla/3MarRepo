        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediAgent" type="CM_EDIControllerAgent"/>
        <Parameter name="_ediDataType" type="Integer"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="io"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <Parameter name="_assist" type="CMIF_EDIUserDefinedAssist" usage="io"/>
