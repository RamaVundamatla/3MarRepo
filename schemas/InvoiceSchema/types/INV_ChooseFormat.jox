    <JadeMethod name="dumpContractsCSV" id="239658bb-dc66-46ae-add1-f409aaf57ced">
        <updating/>
        <source>dumpContractsCSV(_file : File input; _passport : CM_Passport input) : Integer updating;
/*
Purpose:			

Date		Who		Reason
16 January 2023	navmv20	TFS 55650 Task 55701: Jade - Contracts XML Extract TRX
24 October 2024 navrv30 MTN 14674 FR | 54089 - EUP - Invoice Contracts - CSV extract based on the search criteria [NEW SCOPE]
*/

vars
	agent : CMIF_InvoiceContract;
	noOfContracts : Integer;
	
begin
	
	if app.msgBox(app.getErrorString1(There_items_dumped,self.allInvoiceContracts.size.String),app.getErrorString(Confirmation),MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
		global.beep;
		return 0;
	endif;

	create agent transient;
	app.mousePointer := MP_HOURGLASS;
	
	self.allInvoiceContracts.copy(agent.allInvoiceContracts);
	//24 October 2024 navrv30 MTN
	self.allInvContractDetails.copy(agent.allInvContractDetails);
	self.allInvContractRates.copy(agent.allInvContractRates);
	
	if self.myParent.fldMain.topSheet = self.myParent.shtContract then
		noOfContracts := agent.extractInvoiceContractsCSV(_file,_passport);
	elseif self.myParent.fldMain.topSheet = self.myParent.shtDetails then
		noOfContracts := agent.extractInvoiceDetailsCSV(_file,_passport);
	else
		noOfContracts := agent.extractInvoiceRatesCSV(_file,_passport);
	endif;
	return noOfContracts;
	
epilog
	delete agent;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="dumpContractsXML" id="e0f98db9-0a3e-4ef6-b65a-1740ab70bc9c">
        <updating/>
        <source>dumpContractsXML(_file : File input) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2023	navmv20	TFS 55650 Task 55701: Jade - Contracts XML Extract TRX

*/

vars
 agent 		     : CMIF_InvoiceContract;
 noOfContracts   : Integer;
 
begin
	if app.msgBox(app.getErrorString1(There_items_dumped,self.allInvoiceContracts.size.String),app.getErrorString(Confirmation),MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
		global.beep;
		return 0;
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	create agent transient;
	
	noOfContracts := agent.extractInvoiceContractsXML(_file,null,self.allInvoiceContracts);
	return noOfContracts;
epilog
	delete agent;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fileSilentExceptionHandler" id="8eddabff-37ff-46dd-916d-c62e3da41534">
        <source>fileSilentExceptionHandler(_exObj: Exception; _hadFileException : Boolean io): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2023	navmv20	TFS 55650 Task 55701: Jade - Contracts XML Extract TRX

*/

vars
	returnVal		: Integer;
begin
	returnVal := Ex_Pass_Back;
	if _exObj.errorCode &gt; 5000 and _exObj.errorCode &lt;= 5099 then
		_hadFileException:=true;
		if _exObj.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

	return returnVal;
epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_hadFileException" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExportFileName" id="e3f2f302-9165-47c8-8217-ab3d9b4106bb">
        <source>getExportFileName(_startDT :TimeStamp; _extension : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2023	navmv20	TFS 55650 Task 55701: Jade - Contracts XML Extract TRX

*/

vars
	
begin
	return app.getErrorString(Invcontractextract) &amp; _startDT.date.userFormat($CM_YearFormat) &amp; _extension ;
epilog

end;</source>
