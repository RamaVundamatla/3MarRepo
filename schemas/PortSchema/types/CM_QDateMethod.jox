    <JadeMethod name="getValueForObject" id="b6f5c2f0-4494-41ce-b42b-489758abe583">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2009	cnwar2	Initial creation

*/

vars
	
begin
	return _obj.sendMsg(self.propertyName).Date;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setTextValues" id="0dcb817a-0f41-4c9a-98de-8aba7b9fdc78">
        <source>setTextValues(_txt: TextBox input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2009	cnwar2	Initial creation

*/

vars

begin
	if _txt = null or (self.getControlTypeForOperator(_operator) &lt;&gt; QueryControl_TextBox) then
		return;
	endif;
	
	_txt.text := _operator.getSearchValue.String ;

	
epilog

end;</source>
        <Parameter name="_txt" type="TextBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="65f34839-248e-4ceb-bed5-4e8a77b82059">
        <source>translateToDisplayValue(_value: Any): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 January 2009	cnwar2	Initial creation

*/

vars

begin
	
	if _value.isKindOf(Date) then	//  cnwrd1 14.7.2008 par #17511 	
		return _value.Date.asStringJMT() ; //  cnwrd1 14.7.2008 par #17511     	
	else
		return _value.Date.asStringJMT()  &amp;' '&amp; _value.Time.asStringJMT();	// Par 17266, removed seconds for query's result. 03 July 2008, cnwvu1 
	endif;
                                                                                                                                              


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="1a9eca2e-6c23-46ae-b955-38e296209f92">
        <source>translateToSearchValueForWeb(_value: Any; _sending: Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/01/2020	jlgdap1		Initial creation TFS 47456 SNO Web portal report issue 2 - ensure dates go out to web portal as dd/mm/yyyy
//
vars

begin
	if _sending then
		if _value.Date.isValid then
			return _value.Date.format('dd/MM/yyy');
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
