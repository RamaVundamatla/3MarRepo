    <JadeMethod name="getMatchingPackages" id="89c8f7af-bcca-45f0-b588-3ead156e9da2">
        <source>getMatchingPackages( _packages : CM_PackageSet input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2019	jlgndl1	Initial creation	TFS 45181
09/01/2022 	navcs2	Bug 56085: MTN - Vehicle Visit Record Package Matching Logging
*/

vars

	ti : CM_TrackedItem;
	package: CM_Package;
	blurb: String;
	reason: String;

begin
	
	// 09/01/2022 navcs2 Bug 56085 Start
	foreach ti in self.allReceivedTrackedItems discreteLock do		// 12/4/18 MAP TFS37340
		foreach package in self.myTerminal.allPackagesVVR discreteLock,reversed do
			blurb := method.qualifiedName() &amp; " Considering package " &amp; package.code &amp; " (priority " &amp; package.CM_PackageVVR.priority.String &amp; ") for received tracked item " &amp; ti.id &amp; " of vehicle visit " &amp; self.visitNumber;
			if package.CM_PackageVVR.myVVRCriteria = null or package.CM_PackageVVR.myVVRCriteria.matchesReason(ti, reason, null) then
				app.writeLog(blurb &amp; ", MATCH", LogINFO);
				if not _packages.includes(package) then
					_packages.add(package);
				endif;
				break;
			else
				app.writeLog(blurb &amp; ", no match (" &amp; reason &amp; ")", LogINFO);
			endif;
		endforeach;
	endforeach;
	
	foreach ti in self.allReleasedTrackedItems discreteLock do
		foreach package in self.myTerminal.allPackagesVVR discreteLock, reversed do
			blurb := method.qualifiedName() &amp; " Considering package " &amp; package.code &amp; " (priority " &amp; package.CM_PackageVVR.priority.String &amp; ") for released tracked item " &amp; ti.id &amp; " of vehicle visit " &amp; self.visitNumber;
			if package.CM_PackageVVR.myVVRCriteria = null or package.CM_PackageVVR.myVVRCriteria.matchesReason(ti, reason, null) then
				app.writeLog(blurb &amp; ", MATCH", LogINFO);
				if not _packages.includes(package) then
					_packages.add(package);
				endif;
				break;
			else
				app.writeLog(blurb &amp; ", no match (" &amp; reason &amp; ")", LogINFO);
			endif;
		endforeach;
	endforeach;
	// 09/01/2022 navcs2 Bug 56085 End
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_packages" type="CM_PackageSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMoveTotalForTIDisplay" id="6b559052-d690-4a2b-ae91-4fcdfde7acfc">
        <source>getMoveTotalForTIDisplay(_ti : CM_TrackedItem input) : String;
/* Changes

Date		Name	TFS#	Description
============================================================================
28/04/2016	cnwer1			Initial creation PAR
============================================================================*/
vars
	total : Decimal[14,4];
	unit : String;
	vvrd : CM_VehicleVisitRecordDetail;
	
begin
	if _ti = null then
		return null;
	endif;
	
	foreach vvrd in self.allVehicleVisitRecordDetails do
		if vvrd.recordType = VisitRecord_CargoRemoved then
			total := total + vvrd.getExtraInfo_MoveTotalTI(_ti);		
		elseif vvrd.recordType = VisitRecord_CargoPlaced then		//01 Dec 2015	NDL	Par 36987
			total := total - vvrd.getExtraInfo_MoveTotalTI(_ti);
		endif;
	endforeach;
	
	if total = 0 then	//04 Sep 2018	NDL	TFS 39769
		return null;
	endif;
	
	if _ti.isBulkByVolume then
		unit := _ti.myCargoType.myVolumeMeasurementType.shortName;	
		return total.asStringJMT &amp;  Space &amp; unit;
	elseif _ti.isBulkByWeight then
		unit := _ti.myCargoType.myWeightMeasurementType.shortName;	
		return total.asStringJMT &amp;  Space &amp; unit;
		
	else
		return total.Integer.asStringJMT;
	endif;
	
	return null;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveTotalForTIID" id="78d5cae9-f10c-439c-bf42-d4bffe5a1fb9">
        <source>getMoveTotalForTIID(_tiID : String) : Decimal;
/*

Date		Who		Reason
10 October 2013	cnwer1	Initial creation PAR 32717

*/

vars

	total : Decimal[14,4];
	vvrd	:CM_VehicleVisitRecordDetail;
begin
	total	:= 0;
	
	foreach vvrd in self.allVehicleVisitRecordDetails do
		if vvrd.recordType = VisitRecord_CargoRemoved then
			total:=total + vvrd.getExtraInfo_MoveTotalTIID(_tiID);
		elseif vvrd.recordType = VisitRecord_CargoPlaced then	//01 Dec 2015	NDL	Par 36987
			total:=total - vvrd.getExtraInfo_MoveTotalTIID(_tiID);
		endif;
	endforeach;
	
	return total;
epilog

end;</source>
        <Parameter name="_tiID" type="String"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getMoveTotalForTIIDDisplay" id="09011915-0afb-4e93-b5c4-dadf5977b71c">
        <source>getMoveTotalForTIIDDisplay(_ti : CM_TrackedItem) : String;
/*

Date		Who		Reason
27 April 2016	cnwer1	Initial creation TFS 1842

*/

vars
	total : Decimal[14,4];
	unit  : String;
begin
	if _ti = null then
		return null;
	endif;
	
	total:=self.getMoveTotalForTIID(_ti.id);
	if _ti.isBulkByVolume then
		unit := _ti.myCargoType.myVolumeMeasurementType.shortName;	
		return total.asStringJMT &amp;  Space &amp; unit;
	elseif _ti.isBulkByWeight then
		unit := _ti.myCargoType.myWeightMeasurementType.shortName;	
		return total.asStringJMT &amp;  Space &amp; unit;
		
	else
		return total.Integer.asStringJMT;
	endif;
	
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
