    <JadeMethod name="doRefresh" id="fd301a6d-fd61-4f7d-93fd-28b1b4605463">
        <updating/>
        <source>doRefresh() protected, updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	
	// PAR 23408 22/04/2010. When a prenote is cahnged by another user and tempSheet is of this prenote (btnRefresh is enabled)
	// we should refresh GTE_Sheet. i.e. prenpte's sheet which is active. Otherwise, just refresh WeighBridgeData as before.
	if self.btnRefresh.enabled then
	
		self.doRefreshWhenPrenoteChanged();
	   
	else
		// do refresh as it was before
		self.doLoadLogDocketData();
		
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRefreshWhenPrenoteChanged" id="7d0924ee-7070-4286-9d91-7736181aa8a0">
        <updating/>
        <source>doRefreshWhenPrenoteChanged() updating, protected;
/* ---------------------------------------------------------------------------
Created:	22 April 2010	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	theTI		: CM_TrackedItem;
	sheetRefresh: GTE_Sheet;
	tableObj	: CM_EntryTable;
	
begin

	if self.myGTESheetRequiresRefresh = null then	// there is no sheet to refresh
		return;
	endif;

	sheetRefresh	:= self.myGTESheetRequiresRefresh;
	
	if self.fldInOut.topSheet &lt;&gt; sheetRefresh then
		return;	// something wrong, they have to be equal, when there is btnRefresh enabled
	endif;

	// refreshing actual sheet from a prenote
	theTI := sheetRefresh.myMenuAction.myObject.CM_TrackedItem;
	
	sheetRefresh.myTblMain.clearValues();
	sheetRefresh.myTblExtra.clearValues();
	
	self.setIsFromPrenote(theTI, sheetRefresh);
	//self.setValuesFromReceivalTI(obj.CM_TrackedItem, newSheet);
	self.setDefaultsFromObject(sheetRefresh, theTI);
	self.loadBookingRefItems(theTI.myBookingRef, theTI.myBookingRefItem);
	
	sheetRefresh.tiEdition := theTI.edition;

	sheetRefresh.setContainerSizeFromISOType();
	self.resizeSheet(sheetRefresh);

	tableObj := sheetRefresh.myTblMain;
	if sheetRefresh.myMenuAction.code = NavObj_GTE_In and
	   sheetRefresh.getCargoBOLTypeId = BOLType_Log then
		tableObj.goToRowByName(ETRow_PercentScaled);
		tableObj.setFocus();		
	elseif tblCommon.getValueByName(ETRow_RegNumber) = null then
		tblCommon.goToRowByName(ETRow_RegNumber);
		tblCommon.setFocus();
	else
		tableObj.moveFirst();
		tableObj.setFocus();		
	endif;
	
	// set controls - btnRefresh shoud be disabled after refreshing
	self.myGTESheetRequiresRefresh := null;
	self.setBtnRefresh();
	self.topSheet.backColor := self.fldInOut.sheetBackColorSelected;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
