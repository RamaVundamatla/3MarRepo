    <JadeMethod name="readReorg" id="594a14f3-5865-4deb-ac1b-8514d38d6260">
        <source>readReorg();

constants
	Space : Character = " ";
vars
	file : File;
	reorg : CM_ReorgClass;
	newReorg : CM_ReorgClass;
	str : String;
	line : String;
	strArray : StringArray;
	found : Boolean;
	cls : Class;
begin
	create file transient;
	file.mode := File.Mode_Input;
	file.kind := File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := "d:\testdb\logs_782\classestoreorg.txt";
	create strArray transient;
	while (not file.endOfFile()) do
		strArray.clear;
		line := file.readLine().trimBlanks;
		if line = null then
			continue;
		endif;
		line.getTokensForDelimiter(Space, strArray);
		write strArray[1];
		found := false;
		foreach reorg in CM_ReorgClass.instances do
			cls := currentSchema.getClass(reorg.name);
			if reorg.name = strArray[1] then
				found := true;
				break;
			endif;
		endforeach;
		if found then
			if not reorg.in782  then
				beginTransaction;
				reorg.in782 := true;
				commitTransaction;
			endif;
		else
			beginTransaction;
			create newReorg;
			newReorg.name := strArray[1];
			newReorg.in782 := true;
			commitTransaction;
		endif;
	endwhile;
	file.close;
epilog
	delete file;
	delete strArray;
end;
</source>
    </JadeMethod>
    <JadeMethod name="readReorgList" id="1c96e17b-b1ba-43e2-9f18-7caae674092b">
        <source>readReorgList();

vars
	reorg1 : CM_ReorgClass;
	reorg2 : CM_ReorgClass;
	strArray : StringArray;
	cls : Class;
	superClassed : Boolean;
	str : String;
	str1 : String;
	str2 : String;
begin
	create strArray transient;
	foreach reorg1 in CM_ReorgClass.instances do
		str1 := reorg1.name;
		if reorg1.in773 and reorg1.in781 and reorg1.in782 then
			cls := currentSchema.getClass(reorg1.name);
			str := cls.getSuperclass.name;
			superClassed := false;
			foreach reorg2 in CM_ReorgClass.instances do
				if reorg2.in773 and reorg2.in781 and reorg2.in782 then
					str2 := reorg2.name;
					if reorg2 = reorg1 then
						continue;
					endif;
					if reorg2.name = str then
						superClassed := true;
						break;
					endif;
				endif;
			endforeach;
			if not superClassed then
				strArray.add(cls.name);
			endif;
		endif;
	endforeach;
	foreach str in strArray do
		write str;
	endforeach;
epilog
	delete strArray;
end;
</source>
    </JadeMethod>
