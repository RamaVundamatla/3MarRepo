	self.myListForm := _myListForm;
	self.myParentForm := _myParentForm;	
	self.mode := _mode; // ### TFS BUG 56908 15MAR2023 NAVAB1
epilog

end;</source>
        <Parameter name="_contextObj" type="CM_InvoiceContractDetails"/>
        <Parameter name="_myObjectMatchCriteria" type="CM_InvoiceContractCriteria" usage="io"/>
        <Parameter name="_myListForm" type="CMUI_ObjectCriteriaListForm"/>
