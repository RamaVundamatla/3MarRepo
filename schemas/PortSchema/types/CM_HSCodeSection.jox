    <JadeMethod name="shouldAuditProperty" id="5887b6aa-4fac-485d-ad04-bfdfc3dafb82">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if 	propName = CM_HSCodeSection::allHSCodeChapters.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="0f96eeb6-047e-4037-8ed6-08ab73ea7f49">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	inheritMethod();
	
	self.validateForUpdate();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="55b4a3bb-dfa0-4bc2-a69f-e98568005e05">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	realHS,
	exisitngHS : CM_HSCodeSection;
	
begin
	inheritMethod();
	
	if self.id = null then
		app.raiseCMException(Input_required_field_Id, null, null);
		return;
	endif;
	
	if self.id.length &lt;&gt; 2 then
		app.raiseCMException2(Field_length_characters_long, self.id &amp; ": " &amp; app.getErrorString(Id), "2", null, null);
	endif;
	
	realHS := self.pxyGetRealObject();
	exisitngHS := app.myRoot.allHSSections[self.id];
	
	if exisitngHS &lt;&gt; null and (realHS = null or exisitngHS &lt;&gt; realHS) then
		app.raiseCMException3(ERR_DuplicateItemWith, app.getErrorString(Section), app.getErrorString(Id), self.id, null, null);
		return;
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
