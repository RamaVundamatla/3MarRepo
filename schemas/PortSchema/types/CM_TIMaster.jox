    <JadeMethod name="intHeightMetres" id="ed68f667-eb4a-4f70-836e-5b22ccf87448">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>intHeightMetres(set: Boolean; _value: Integer io) mapping, updating;
// --------------------------------------------------------------------------------
// Created:		19 February 2009 by cnwdad1
//
// Purpose:		When setting: Sets the non-virtual External Height of the reciever
//				(which is stored in centimetres) by converting from the specified value.
//
//				When retrieving: Returns the External Width of the receiver in metres,
//				by converting from the non virtual External Width which is stored
//				in centimetres.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if set then
		self.intHeight	:=	(_value / 100);
	else
		_value			:=	(self.intHeight * 100).rounded();
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
