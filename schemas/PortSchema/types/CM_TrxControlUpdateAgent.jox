    <JadeMethod name="trxSetupCamTaskHistory" id="0c978ecd-5120-4ce4-80ec-0b3d0cb4c5eb">
        <updating/>
        <source>trxSetupCamTaskHistory(_camProtocol : CM_CamProtocol input; _camAgent : CM_CamControllerAgent input; _camFile : CM_CamFile input; _runDateTime : TimeStamp; _camTaskHistory : CM_CamTaskHistory io;
		   _unhSeqNumber : Integer io; _seqNumber : Integer; _terminal : CM_Terminal; _allTransactions : CM_MemberKeyDictionary; _contextObj : Object; _transactions : CM_TITransactionSet) updating;
//----------------------------------------------------------------
//	Created:	April 2008 cnwrs1
//----------------------------------------------------------------
// 18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 30 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 04 Dec 2012	cnwcs5	CCMS SFW 1294/par 30855
// 09 Jan 2020	jlgdap1	TFS 48016 SNO Deletion CODECO - new _transactions parameter
// 25 Sep 2023	navdap1	TFS 60365 EUP | FR 53853 - Goods Receipt Message Grouping
//							Changed _contextObj from CM_Object to Object
vars
	passport	:CM_Passport;
begin
	passport := app.myPassport;
	
	self.initialiseActivityWithPassport(passport, method);
	
	passport.useTIDictDeferUpdate			:= true;
	passport.useTITransactionDeferUpdate 	:= true;
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, passport);
	on LockException do agtPassportLockExHandler(exception, passport);
	
	beginTransaction;
	
	//app.myUtilityUA.utlSetupCamTaskHistory(_camProtocol, _camAgent, _camFile, _camAgent.runDateTime, _unhSeqNumber, _seqNumber, _terminal, _allTransactions, _contextObj);				// TFS 48016
	app.myUtilityUA.utlSetupCamTaskHistory(_camProtocol, _camAgent, _camFile, _camAgent.runDateTime, _unhSeqNumber, _seqNumber, _terminal, _allTransactions, _contextObj, _transactions);	// TFS 48016
	
	if passport.noErrors then
		passport.doDeferredUpdates();	
	endif;
epilog
	self.finaliseActivityWithPassport(passport);
end;
</source>
