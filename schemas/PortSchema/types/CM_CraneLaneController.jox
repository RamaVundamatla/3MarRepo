    <JadeMethod name="getDisplayStringForAttribute" id="78519482-9276-4548-a37e-3b2733238ad6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2013	cnwer1	Initial creation HAT 2189

*/

vars
	realSelf : CM_CraneLaneController;
begin
	if _attrName = ETRow_Lane then
		return self.getLaneId;
	elseif _attrName = ETRow_IsLoad then
		return self.myTerminalArea.CM_CraneTransferArea.loadLanes.includes(self).getYesNo;
	elseif _attrName = ETRow_IsDischarge then
		return self.myTerminalArea.CM_CraneTransferArea.dischargeLanes.includes(self).getYesNo;
	elseif _attrName = ETRow_HasCage then
		return (self.numOfTwinLiftCages &gt; 0).getYesNo;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLaneId" id="74d552a4-d894-43d4-b816-3a57f1b3c6e1">
        <source>getLaneId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2013	cnwer1	Initial creation HAT 2189

*/

vars
	area : CM_CraneTransferArea;
begin
	//epr TFS 3418 data dump got 1090
	if self.myTerminalArea = null then
		return null;
	endif;
	
	area := self.myTerminalArea.CM_CraneTransferArea;
	if area.lanes = null then
		return null;
	endif;
	return area.lanes.indexOf(self).String;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
