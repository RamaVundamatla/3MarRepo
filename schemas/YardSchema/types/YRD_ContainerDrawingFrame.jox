    <JadeMethod name="getPointsForObject" id="a23a3059-9cba-46a7-b114-f63fc5dae81f">
        <source>getPointsForObject(_obj: Object; _x1: Integer output; _y1: Integer output; _x2: Integer output; _y2: Integer output): Boolean;
/* ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 10/03/2011 	cnwmh5		PAR #27142 - Change where handleDeleteObject is armed
10 Mar 2017 cnwer1 		removed references to trailer drawing controler
*/
vars
	iter	: Iterator;
	tmpObj	: Object;	
	found : Boolean;
	invalidObject : Boolean;
	anLC : CM_LocationsController;
	theTI, doppleganger : CM_TrackedItem;
	theDrawController : YRD_ContainerDrawingController;
	tmpRDrawingController	: YRD_RoRoLaneDrawingController;
	anFM : CM_FutureMove;
	theName : String;
	cell : CM_YALocationCell;
begin

	if _obj = null then
		return false;
	endif;

	on Exception do app.handleDeletedObject(exception,_obj,invalidObject);
	
	theName:=_obj.getName;
	if invalidObject then
		return false;
	endif;
	
	theDrawController := self.myDockBar.myDrawingController;
	
	if theDrawController = null then
	
		tmpRDrawingController  := self.myDockBar.myRoRoLaneDrawingController;					// cnwjk3 ccms 1018 4/12/09
												// cnwjk3 ccms 1018 4/12/09
		if tmpRDrawingController = null then					// cnwjk3 ccms 1018 4/12/09
			return false;
		endif;
			
		tmpRDrawingController.allDrawnObjects.getPointsForObject(_obj,_x1, _y1, _x2, _y2);	// cnwjk3 ccms 1018 4/12/09	
		
		return true;
	endif;
		
	if _obj.isKindOf(CM_LocationsController) then
		anLC := _obj.CM_LocationsController;
	elseif _obj.isKindOf(CM_TrackedItem) then
		theTI := _obj.CM_TrackedItem;
		//doppleganger := theTI.myTranshipImport;							// PAR #23645 CCMS 1116
		if theDrawController.displayMode = DISPLAY_MODE_ACTUAL then
			anLC := theTI.myPrimaryActualLocation;
		elseif theDrawController.displayMode = DISPLAY_MODE_PLAN then
			anLC := theTI.myPrimaryPlannedLocation;
			//if anLC = null and theTI.isTranshipExport() then				// PAR #23645 CCMS 1116
			//	anLC := theTI.myTranshipImport.myPrimaryPlannedLocation;	// PAR #23645 CCMS 1116
			//endif;														// PAR #23645 CCMS 1116
		elseif theDrawController.displayMode = DISPLAY_MODE_QUEUE then
			anLC := theTI.myPrimaryQueuedLocation;
		endif;
	elseif _obj.isKindOf(CM_FutureMove) then // PAR 19600
		anFM := _obj.CM_FutureMove;
		anLC := anFM.getPrimaryLocation();
	elseif _obj.isKindOf(CM_YALocationCell) then // 24 Aug 2011	NDL	PAR 28035
		cell := _obj.CM_YALocationCell;
		found := theDrawController.getPointsForCellLocation( cell, _x1, _y1, _x2, _y2 );
		return found;
	else
		return false;
	endif;
	
	if anLC = null then
		return false;
	endif;
	iter := theDrawController.myGridObjectsIterator;
	iter.reset;
	iter.startAtObject(_obj);
	while iter.next(tmpObj) do
		if tmpObj = _obj then
			found := true;
			theDrawController.allGridObjects.getIteratorKeys(_x1, _y1, _x2, _y2, iter);

			break;
		else
			break;
		endif;
	endwhile;
	return found;
epilog
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Integer" usage="output"/>
        <Parameter name="_y1" type="Integer" usage="output"/>
        <Parameter name="_x2" type="Integer" usage="output"/>
        <Parameter name="_y2" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPointsForSubBlockStack" id="225fadaa-df7c-466c-b46c-d42752048e8c">
        <source>getPointsForSubBlockStack(_obj: Object; _x1: Integer output; _y1: Integer output; _x2: Integer output; _y2: Integer output): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 March 2009	cnwjk3	SFW 1030 

*/

vars	
	theDrawController : YRD_ContainerDrawingController;
	p1, p2 : Point;
begin

	if _obj = null 
	or (not global.isValidObject(_obj)) then
		return false;
	endif;

	theDrawController := self.myDockBar.myDrawingController;
	
	if theDrawController = null then
		return false;
	endif;

	if not _obj.isKindOf(CM_SubBlockStack) then
		return false;
	endif;

	
	if theDrawController.allGridObjects.findObjectInDictGetXYExtremes(_obj,  p1, p2) then
		_x1 := p1.x;
		_y1 := p1.y;
		_x2 := p2.x;
		_y2 := p2.y;
		return true;
	else
		return false;
	endif;
epilog
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Integer" usage="output"/>
        <Parameter name="_y1" type="Integer" usage="output"/>
        <Parameter name="_x2" type="Integer" usage="output"/>
        <Parameter name="_y2" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
