    <JadeMethod name="cmbMachineType_lostFocus" id="e426956e-0427-4644-8c08-227e35b10ba9">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbMachineType_lostFocus(combobox: ComboBox input) updating;

//5/09/2019 	JLGNS1	Bug 46173: PNL - Vehicle App Driver Initiated Move of overstowed container

vars
	machineType : CM_MachineType;
begin

	if combobox.parent.isKindOf(CM_EntryTable) then
		combobox.parent.CM_EntryTable.setValueByControlName(combobox.name, combobox.text);
		if combobox.listObject = null then
			return;
		endif;
		machineType:=combobox.listObject.CM_MachineType;
		self.myCurrentTableItem.SOPTM_Machine.showHideRowsForMachineType(machineType.type);
		
		if machineType &lt;&gt; null then																//Bug 46173
			self.myAssistant.comboBoxMchLiftType(self.cmbMchLiftType, machineType.type, null);	//Bug 46173
		endif;																					//Bug 46173
		
		self.resize;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
