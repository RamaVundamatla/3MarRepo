    <JadeMethod name="completeWLE" id="570d8e02-bb8f-4af2-8eae-f0f9531f303c">
        <updating/>
        <source>completeWLE(_ti : CM_TrackedItem)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
19 Dec 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
04 Jan 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
17 May 2024 navhl20 Bug 64191: EUP - Lock and Freeze issue
29 May 2024 navhl20 Bug 64345: EUP - Retrospective Partial Discharge not wokring.
09 Dec 2024	navhl20 Bug MTN-33643: EUP - Partial move by weight is not working in Work Order Operation screen - Receive
*/

vars
	req 	: CM_Request;
	wleVoy	: CM_VoyageWLE;
	wle		: CM_WorkListEntry;
	wleWO	: CM_WOWLE;
	job		: CM_Job;
begin
	req := self.allRequests.first;
	if req &lt;&gt; null and _ti &lt;&gt; null then
		create wleVoy;
		wleVoy.setForCreate(self, req);
		//29.05.2024 navhl20 #64345 System notification already updating about newly created job.
		//wleVoy.causeEvent(wleVoy.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, wleVoy);		//29.05.2024 navhl20 #64345
		if self.myWorkOrderReceiveJob &lt;&gt; null then
			job := self.myWorkOrderReceiveJob;
		else
			job := self.myWorkOrderReleaseJob; 
		endif;
		if job &lt;&gt; null and job.allCompletedWLEsByDate.isNotEmpty() then		//04.01.2023 navhl20 #61092[61621]
			wleWO := job.allCompletedWLEsByDate.last.CM_WOWLE;
		endif;
		wleVoy.setMyTrackedItem(_ti);
		wleVoy.setQuantity(wleWO.quantity);
		wleVoy.setWeight(wleWO.weight);										//09.12.2024 navhl20 #33643
		wleVoy.setLocations(wleWO.locationSource,_ti.locationId);
		wleVoy.setStatus(WLE_COMPLETED);
		self.status := JOB_PART_COMPLETE;
		if app.isWebApp then												//17.05.2024 navhl20 #64191
			self.plannedLocation := null;		//26/08/2024	navkc1 CR 63588 Task 63589
			self.plannedLocations := null;		//26/08/2024	navkc1 CR 63588 Task 63589
			self.plannedTerminalAreas := null;	//26/08/2024	navkc1 CR 63588 Task 63589
		endif;
		
		//27/05/2025	navkc1 JIRA MTN 34904 - Fire a WLE create event
		app.myEventManager.createSingleObjInfoNoteEvt(wleVoy, self.getMyTerminal.getTerminalEvent(WLE_Create_Event), wleVoy);
		
	else
		if self.myWorkOrderReceiveJob &lt;&gt; null then
			job := self.myWorkOrderReceiveJob;
		else
			job := self.myWorkOrderReleaseJob; 
		endif;
		if job.status = JOB_COMPLETE then
			self.status := JOB_COMPLETE;
			self.causeTerminalEvent(self.Event_Mode_Update);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
