/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/11/2011	cnwdap1	Initial creation PAR #27814 Set myTAView reference when TA view selected
*/
vars

begin
	if listbox.itemObject[listbox.listIndex] &lt;&gt; null then
		self.myTAView := listbox.itemObject[listbox.listIndex].CM_TerminalAreaView;
	endif;
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
