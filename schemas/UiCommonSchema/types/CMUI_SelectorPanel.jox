    <JadeMethod name="sendToReport" id="066f8a67-ebe1-442f-bf45-4226eda6e398">
        <source>sendToReport( _objArray : ObjectArray input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars
	jrwReportName	: String;
	selectedOnly,
	printPreview 	: Boolean;
	outputType		: Integer;
	filePath		: String;
begin

	if _objArray.isEmpty then
		return;
	endif;
	
	if app.getReportToSendItems(CM_TrackedItemView, null, selectedOnly, jrwReportName, printPreview, outputType, filePath) then
		app.sendItemsToReport(CM_JRWTrackedItems, _objArray, jrwReportName, printPreview, outputType, filePath);
	endif;
	
epilog
	
end;</source>
