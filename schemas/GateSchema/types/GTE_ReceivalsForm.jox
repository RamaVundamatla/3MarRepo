    <JadeMethod name="cmbBookingRefItemClick" id="53378e1d-3e2b-424f-96fd-d9295bcfd521">
        <updating/>
        <source>cmbBookingRefItemClick(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// 30/11/2009	cnwmh5		PAR 21492 - add setting of sub type details
// ---------------------------------------------------------------------------
vars
	tmpBookingRefItem	: CM_BookingRefItem;
begin
	app.mousePointer := MousePointer_HourGlass;
	
	tmpBookingRefItem := combobox.listObject.CM_BookingRefItem;
	if tmpBookingRefItem &lt;&gt; null then	
		self.setDefaultsFromObject(tmpBookingRefItem);	
		self.myAssistant.GTE_Assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_MyBookingRefItem, tmpBookingRefItem.getShortDisplay);
		self.setSysSubTypeDetails(tmpBookingRefItem);		// 30/11/2009 cnwmh5 #21492
	endif;
	
	self.sptMain.cnEcResizeContents();	// 26/11/2008 cnwar2 #17617
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
