end;</source>
        <Parameter name="pUser" type="CM_User"/>
        <Parameter name="pUserWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateUser_CargoType" id="ecbc17dc-7ca2-48dd-b775-9a262e387228">
        <source>utlUpdateUser_CargoType(_proxyUserCargoType : CM_UserConfigCargoType; _passport : CM_Passport input);
// 09 August 2011	cnwjre1	CCMS 1776 Cargo Enquiry User Definable Layout
// called for new and update, distinguished by a getRealObject finding something or not
vars
	realUserCargoType	: CM_UserConfigCargoType;
	expectedEdition	: Integer;

begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	_proxyUserCargoType.pxyGetRealObjectAndEdition(realUserCargoType, expectedEdition);

	if realUserCargoType= null then
		// this may be because the default option has been set for an existing instance
		// 34529 check unconditionally - may have set default and then made changes before saving
		realUserCargoType := _proxyUserCargoType.myUser.allUserCargoTypes[_proxyUserCargoType.myUser, _proxyUserCargoType.myCargoBOLType];
		if realUserCargoType &lt;&gt; null then
			expectedEdition := realUserCargoType.edition;
		endif;
	endif;
	if realUserCargoType= null then
		// this is actually new
		// from 34529 checking, if default there is nothing to do
		if _proxyUserCargoType.isDefault then
			return;
		endif;
		create realUserCargoType as _proxyUserCargoType.class persistent;
		expectedEdition := realUserCargoType.edition;
	endif;

	app.myValUA.valUser_CargoType(_proxyUserCargoType);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realUserCargoType);

	if _passport.noErrors and realUserCargoType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "userCargoType", null, null);
		return;
	endif;

	if _passport.noErrors then
		// if _proxyUser.isDefault is set, this is implemented by having no userCargoType instance for this
		//  user/cargo type combination, so delete the current object, otherwise update it
		if _proxyUserCargoType.isDefault then
			realUserCargoType.erase(NORMAL_ERASE);
		else
			realUserCargoType.setForUpdate(_proxyUserCargoType);
		endif;
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(UserConfigCargo_Update_Event), false, realUserCargoType);
	endif;

end;
</source>
        <Parameter name="_proxyUserCargoType" type="CM_UserConfigCargoType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVBSForRoadManifest" id="e558062e-cb68-490e-aeb4-be77d7dbcd7c">
        <updating/>
        <source>utlUpdateVBSForRoadManifest(	_manifest : CM_EDIDataTransManifest;
								_strArray : StringArray;
								_vbsType : CM_VehicleBookingTimeSlotType;
								_prevVBSExtReference : String;
								_passport : CM_Passport input	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01/09/2023	navdap1		Initial creation TFS 60186 EUP | FR 53824 - Road Manifest VBS Booking
// 24/11/2023	navcs2		ChangeRequest 60874: MTN | Jade Upgrade - Unit Test Review (Fixing transient leaks for postManifest unit tests)
// 08/08/2024	navcs2		ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
// 05/06/2025	navdap1		MTN-12349 EUP - Transport Manifest load after locking does not add all cargo to work order
//
vars
	externalRef : String;
	terminal : CM_Terminal;
	vbsTerminal : CM_VehicleBookingTerminal;
	ediTI : CM_EDITrackedItem;
	ediPrenote : CM_EDIPrenoteTI;
	ediPrenotes : CM_EDITIArray;
	ti : CM_TrackedItem;
	vbsTS, pxyVbsTs, prevVbsTS : CM_VehicleBookingTimeSlot;
	match, invalid : Boolean;
	carrier : CM_Carrier;
	vbsItems : CM_VehicleBookingTSItemSet;
	vbsItem : CM_VehicleBookingTimeSlotItem;
	vbsItemTrans : CM_VehicleBookingTimeSlotItem;		// MTN-12349
	tiSet : CM_TISet;
	vbsStartTS : TimeStamp;
begin
	self.initialiseActivity();
	
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	
	terminal := _passport.myTerminal;
	vbsTerminal := terminal.myVehicleBookingTerminal;
	
	// If an external reference is passed in, look for a VB Slot to match
	externalRef := _manifest.transportReferenceCustomer;
	create ediPrenotes transient;
	foreach ediTI in _manifest.myGateDocument.allEDITrackedItems where ediTI.isEDIPrenote do
		ediPrenotes.add(ediTI);
	endforeach;
	ediPrenote := ediPrenotes.first.CM_EDIPrenoteTI;
	if externalRef &lt;&gt; null then
		vbsTS := vbsTerminal.allVBTimeslotsByExtRef[externalRef];
	endif;
	if _prevVBSExtReference &lt;&gt; null then
		prevVbsTS := vbsTerminal.allVBTimeslotsByExtRef[_prevVBSExtReference];
	endif;
	carrier := app.myRoot.allCarriers[ediPrenote.carrierCode];
	
	// If we find a slot, does it match (slot type, carrier, cargo type, cargo subtype, commodity, operator)
	match := true;
	if vbsTS = null then
		match := false;
	else
		if _vbsType &lt;&gt; null and vbsTS.myVBTimeSlotType &lt;&gt; _vbsType then
			match := false;
		elseif carrier &lt;&gt; null and vbsTS.myCarrier &lt;&gt; carrier then
			match := false;
		endif;
		foreach vbsItem in vbsTS.allVehicleBookingItems do
			ti := vbsItem.myTrackedItem;
			if ti = null then
				continue;
			endif;
			ti.edition;
			if invalid then
				vbsItem.setMyTrackedItem(null);
				ti := null;
			endif;
			
			if ti &lt;&gt; null then
				if ti.cargoType &lt;&gt; ediPrenote.cargoType then
					match := false;
				elseif ti.productCode &lt;&gt; null and ediPrenote.product &lt;&gt; null and ti.productCode &lt;&gt; ediPrenote.product then
					match := false;
				elseif ti.commodity &lt;&gt; ediPrenote.commodity and ediPrenote.commodity &lt;&gt; null then
					match := false;
				elseif ti.operatorCode &lt;&gt; ediPrenote.operatorCode then
					match := false;
				endif;
			endif;
			
			if not match then
				break;
			endif;
		endforeach;
	endif;
	
	// If the external reference has changed, unbook the previous slot
	if prevVbsTS &lt;&gt; null then
		pxyVbsTs := app.createUpdateProxy(prevVbsTS).CM_VehicleBookingTimeSlot;
		foreach vbsItem in pxyVbsTs.allVehicleBookingItems do
			if not app.isValidObject(vbsItem.myTrackedItem) then
				vbsItem.setMyTrackedItem(null);
			endif;
		endforeach;
		
		pxyVbsTs.setProxy(	prevVbsTS.bookingTSstart,		// scheduleTSstart
							prevVbsTS.bookingTSend, 		// scheduleTSend
							vbsTerminal, 					// _myVBTerminal
							carrier, 						// _myCarrier		//20.Nov.2023 navsp1 TFS 61039
							null, 							// _mySubCarrier
							null, 							// _myDriver
							null, 							// _myVehicle
							prevVbsTS.remarks,				// _remarks
							prevVbsTS.includesDelivery,		// _includesDelivery
							prevVbsTS.includesPickUp,		// _includesPickup
							null,							// _bookedTiIDs
							null,							// _myVehicleVisitRecord,
							prevVbsTS.myVBTimeSlotType,		// _myVBTimeslotType
							prevVbsTS.id,					// _id
							null,							// _allBookingRefs
							null,							// _allBulkReleases
							null,							// _allVBSTimeSlotItems
							prevVbsTS.preGateInCheck,		// _preGateInCheck
							prevVbsTS.preGateOutCheck,		// _preGateOutCheck
							prevVbsTS.kioskCheck,			// _kioskCheck
							null,							// _externalReference
							null);							// _myTILCType			08 Aug 2024 navcs2	ChangeRequest 63928

							
		app.myUtilityUA.utlUpdateVehicleBookingAdv(pxyVbsTs, null, null, null, _passport);
		delete pxyVbsTs;
	endif;
	
	// If we found a slot, and the slot doesn't match, "unbook" it
	// - clear external reference, carrier, subcarrier, driver, vehicle
	// - clear cargo items from the slot
	if not match and vbsTS &lt;&gt; null then
		pxyVbsTs := app.createUpdateProxy(vbsTS).CM_VehicleBookingTimeSlot;
		pxyVbsTs.setProxy(	vbsTS.bookingTSstart,			// scheduleTSstart
							vbsTS.bookingTSend, 			// scheduleTSend
							vbsTerminal, 					// _myVBTerminal
							carrier, 						// _myCarrier		//20.Nov.2023 navsp1 TFS 61039
							null, 							// _mySubCarrier
							null, 							// _myDriver
							null, 							// _myVehicle
							vbsTS.remarks,					// _remarks
							vbsTS.includesDelivery,			// _includesDelivery
							vbsTS.includesPickUp,			// _includesPickup
							null,						// _bookedTiIDs
							null,							// _myVehicleVisitRecord,
							vbsTS.myVBTimeSlotType,			// _myVBTimeslotType
							vbsTS.id,						// _id
							null,							// _allBookingRefs
							null,							// _allBulkReleases
							null,							// _allVBSTimeSlotItems
							vbsTS.preGateInCheck,			// _preGateInCheck
							vbsTS.preGateOutCheck,			// _preGateOutCheck
							vbsTS.kioskCheck,				// _kioskCheck
							null,							// _externalReference
							null);							// _myTILCType			08 Aug 2024 navcs2	ChangeRequest 63928

							
		app.myUtilityUA.utlUpdateVehicleBookingAdv(pxyVbsTs, null, null, null, _passport);
		delete pxyVbsTs;
		vbsTS := null;
	endif;
	
	// If the slot matched, update it. If it didn't match, create a slot
	if (match and vbsTS &lt;&gt; null) or vbsTS = null then
		if vbsTS &lt;&gt; null then
			pxyVbsTs := app.createUpdateProxy(vbsTS).CM_VehicleBookingTimeSlot;
		else
			create pxyVbsTs transient;
		endif;
		
		// Get the items to attach
		create vbsItems transient;
		create tiSet transient;
		foreach ediTI in ediPrenotes do
			ti := terminal.findPrenoteCargo(ediTI.id.toUpper, ediTI.cargoType, null, ediTI.getCargoGroupId());				//navra1 - TFS 60776 - 10th Oct 2023
			if ti &lt;&gt; null then
				tiSet.addNoDuplicates(ti, false);//18.Oct.2023 navsp1 TFS 60913
				create vbsItemTrans transient;					// MTN-12349
				vbsItemTrans.setProxy(DIRECTION_DELIVERY, null, null, null, null, ti, pxyVbsTs, ti.quantity, null, CM_VehicleBookingTimeSlotItem.SOURCE_CARGO, ti.totalWeight, ti.totalVolume,	// MTN-12349
									null); // ### TFS 61525 (61527) 11Jul2024 NAVPW1
				vbsItems.add(vbsItemTrans);						// MTN-12349
			endif;
		endforeach;
		
		vbsStartTS.setDate(_manifest.estimatedDateTimeOfArrival.date);			//20.Sep.2023 navsp1 TFS 60454
		vbsStartTS.setTime(_vbsType.startTime);									//20.Sep.2023 navsp1 TFS 60454
		
		pxyVbsTs.setProxy(	vbsStartTS,
							vbsStartTS.addMinutes(_vbsType.duration),
							vbsTerminal,
							carrier,
							null,
							null,
							null,
							_manifest.vehicleBookingSlotRemarks,
							true,
							false,
							_strArray,
							null,
							_vbsType,
							vbsTerminal.generateNextVBSTimeslotId(),
							null,
							null,
							vbsItems,
							_vbsType.preGateInCheck,
							_vbsType.preGateOutCheck,
							_vbsType.kioskCheck,
							externalRef	,
							null);						// 08 Aug 2024 navcs2	ChangeRequest 63928	
							
	endif;
	
	if vbsTS = null then
		app.myUtilityCA.utlCreateVehicleBookingAdv(pxyVbsTs, vbsTS, vbsItems, false, _passport);
	else
		app.myUtilityUA.utlUpdateVehicleBookingAdv(pxyVbsTs, _strArray, null, tiSet, _passport);
	endif;
	
epilog
	delete vbsItemTrans;					// 24/11/2023	navcs2		ChangeRequest 60874		// MTN-12349
	delete pxyVbsTs;
	delete tiSet;
	if not vbsItems.isEmpty then			// 24/11/2023	navcs2		ChangeRequest 60874
		vbsItems.purge();					// 24/11/2023	navcs2		ChangeRequest 60874
	endif;									// 24/11/2023	navcs2		ChangeRequest 60874
	delete vbsItems;
	delete ediPrenotes;
	
	on Exception do null;
end;</source>
        <Parameter name="_manifest" type="CM_EDIDataTransManifest"/>
        <Parameter name="_strArray" type="StringArray"/>
        <Parameter name="_vbsType" type="CM_VehicleBookingTimeSlotType"/>
        <Parameter name="_prevVBSExtReference" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVBSTimeSlotItem" id="a2ec7168-267c-4a38-b895-cf9054edaeca">
        <updating/>
        <source>utlUpdateVBSTimeSlotItem(_pxyVBSItem : CM_VehicleBookingTimeSlotItem input; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26/08/2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
23 Aug 2023 navhl20 Defect 59936: MTN - Displaying only the first tracked item on the Audit Enquiry for the Vehicle Booking Time Slot
22/03/2024	navcs2	ChangeRequest 61199: EUP | FR | 54329 | VBS - Release Line validation

*/

vars
	realVbsTimeSlotItem : CM_VehicleBookingTimeSlotItem;
	expectedEdition : Integer;
	
begin
	self.initialiseActivity();

	_pxyVBSItem.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyVBSItem.validateForCreate();		// 22/03/2024	navcs2	ChangeRequest 61199
	
	_pxyVBSItem.pxyGetRealObjectAndEdition(realVbsTimeSlotItem, expectedEdition);
	
	if realVbsTimeSlotItem = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WorkOrderDtl.name, null, null);
		return;
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	
	app.setContinueCMExceptions(false);

	self.exclusiveLock(realVbsTimeSlotItem);

	if _passport.noErrors and realVbsTimeSlotItem.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Vehicle Booking Time Slot Item', null, null);
		return;
	endif;

	realVbsTimeSlotItem.setForUpdate(_pxyVBSItem, realVbsTimeSlotItem.myVehicleBookingSlot);
epilog
	

end;</source>
        <Parameter name="_pxyVBSItem" type="CM_VehicleBookingTimeSlotItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVBSlotType" id="10862f54-3d89-4222-9b13-98daaf025476">
        <updating/>
        <source>utlUpdateVBSlotType(_pxyVBSSlot : CM_VehicleBookingTimeSlotType input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2022	navhl20 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars
	realVbsTimeSlotType : CM_VehicleBookingTimeSlotType;
	expectedEdition : Integer;
	
begin
	self.initialiseActivity();

	_pxyVBSSlot.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyVBSSlot.pxyGetRealObjectAndEdition(realVbsTimeSlotType, expectedEdition);
	
	if realVbsTimeSlotType = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VehicleBookingTimeSlotType.name, null, null);
		return;
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realVbsTimeSlotType);

	if _passport.noErrors and realVbsTimeSlotType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Vehicle Booking Time Slot Type', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVbsTimeSlotType, true);
	endif;

	realVbsTimeSlotType.setForUpdate(_pxyVBSSlot);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVbsTimeSlotType, false);
	endif;
epilog

end;</source>
        <Parameter name="_pxyVBSSlot" type="CM_VehicleBookingTimeSlotType" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVVDepartedTransport" id="16f3f7b1-d23f-46bb-baf5-9d3c4b87059d">
        <source>utlUpdateVVDepartedTransport(_pxyVVR : CM_VehicleVisitRecord; _addedCargo : CMGTE_EntitySet; _location : CM_LocationsController; _moveControllers : CMIF_Array;  _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
15 May 2024		navhn30	Bug 63871: EUP | FR - 59098 - Departed Transport Correction - Driver Details Not Required
*/

vars
	realVVR : CM_VehicleVisitRecord;
begin
	self.initialiseActivity();
	
	// do validation
	self.raiseExceptionIfNull(_pxyVVR, _pxyVVR.jobNumber);

	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	realVVR := self.getRealObjectAndEditionCheck(_pxyVVR, _pxyVVR.jobNumber, _passport).CM_VehicleVisitRecord;
//	realVVR.checkCreateVehicleAndDriver(_pxyVVR.regNumber, _pxyVVR.driversName, _pxyVVR.getMyCarrier, _pxyVVR);
	
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realVVR, true);
	endif;

	if _passport.noErrors then
		// do updates
		realVVR.updateAddRemoveCargo(_pxyVVR, _addedCargo, _location, _moveControllers, _passport);
	endif;

	realVVR.checkCreateVehicleAndDriver(_pxyVVR.regNumber, _pxyVVR.driverCode, _pxyVVR.getMyCarrier, _pxyVVR);	// 15.05.24		navhn30		TFS #63871		20/09/2025	navcs2	MTN-35846

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realVVR, false);
	endif;

epilog

end;</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="_addedCargo" type="CMGTE_EntitySet"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_moveControllers" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVVRCancel" id="fca8e243-566b-4a65-882d-877b5f9b7f0e">
        <updating/>
        <source>utlUpdateVVRCancel(_vvr : CM_VehicleVisitRecord input; _reason :String; _passport: CM_Passport input) updating;
/*
Date		Who		Reason
14 Sep 2009	cnwjk3	SFW1035
21/09/2009	cnwcs5	Renamed to reflect functionality - create cancell VVRD
22/09/2009	cnwcs5	Create VVRD directly rather than using proxy
18 Jun 2013	cnwcs5	par 31670 - new _context parameter for createVehicleVisitDetail method
31 dec 2013 cnwdap1	PAR #32849 CCMS PEN 2321 Security Gate
*/

vars
	
begin
	// create the VVRD for the cancellation
	_vvr.createVisitRecordDetail (VisitRecord_Cancel, _reason, null);		// par 31670
	
	// change status of job to cancelled
	_vvr.changeStatus(CM_VehicleVisitRecord.Status_Cancelled);
	_vvr.setTimeOutCancelled( app.serverTimestampAtTrxStart );	//cnwrd1 par 25064 21.7.2010
	
	_vvr.createVisitRecordDetail(VisitRecord_Complete_OutGate, null, null);	// par 31670, PAR 27472
	
	if _vvr.myTerminal.getConfig(SiteHasSecurityGate).Boolean then						// PAR #32849
		_vvr.createVisitRecordDetail(VisitRecord_DepartSecurityGate, null, null);		// PAR #32849
	endif;																				// PAR #32849
	
	if _vvr.vehicle &lt;&gt; null then
		_vvr.vehicle.setMyPrimaryActualLocation(null,false);			// move offsite
	endif;
	
	_vvr.disAssocGateEntVbsti();	// ### JIRA: MTN-14770 29Oct2024 NAVPW1
	
	_vvr.causeEvent(_vvr.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), false, _vvr);
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVVRCancelWithJob" id="919f1d91-43bd-4350-8da0-07b36ae74bf0">
        <updating/>
        <source>utlUpdateVVRCancelWithJob(_vvr : CM_VehicleVisitRecord input; _reason :String; _passport: CM_Passport input) updating;
/*
Date		Who		Reason
27 Feb 2012	cnwrd1	Initial creation
18 Jun 2013	cnwcs5	par 31670 - new _context parameter for createVehicleVisitDetail method
05 Oct 2015 cnwma1  PAR #36948 Unloading-reloading cargo using Truck Loader results in offsite item on dock receipt				
26 Sep 2016 cnwma1  TFS #2741:UE 4 in app WebServicesSchema::JMTWebService of CIGPJMT					   
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
03 Oct 2023 navnk30	Bug 60531: MTN - Deleting Road Work list entry delete work order wles
25 Nov 2024	jlizm1	MTN 33235 Delete current entry reverting already exported cargo
*/

vars
	job			: CM_RoadJob;	// 23/02/2010 cnwcs5
	jobDeleted	: Boolean;		// 23/02/2010 cnwcs5
	
	// cnwmc5 - 26 Jan 2015 - PAR 35536
	wle			: CM_WorkListEntry;
	wleArray	: CM_WLEArray;
	jobEdition : Integer;
	generator : CM_Generator;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	on Exception do app.handleDeletedObject (exception, job, jobDeleted);  //26/09/2016 cnwma1 TFS #2741
	job := _vvr.myRoadJob;
	
	jobEdition := job.edition;  //26/09/2016 cnwma1 TFS #2741
	if not jobDeleted then
		app.myValDA.valRoadJobCancel(job);
	endif;
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;
	
	// cnwmc5 - 26 Jan 2015 - PAR 35536
	if not jobDeleted then                    //26/09/2016 cnwma1 TFS #2741
		create wleArray transient;
		job.getAllWLEs(wleArray);
		foreach wle in wleArray do
			
			if wle.isKindOf(CM_YardWLE) then									//03.10.2023 navnk30 #60531
				wle.setMyWorkOrderWLE(null);
			endif;
			
			if _vvr.allReleasedTrackedItems.includes(wle.myTrackedItem) then   // 05/10/2015 cnwma1 PAR #36948 
				_vvr.allReleasedTrackedItems.remove(wle.myTrackedItem);
				
				//27.02.2018 cnwma1 ChangeRequest #36813
				generator := wle.myTrackedItem.getGenerator;
				if generator &lt;&gt; null then
					if _vvr.allReleasedTrackedItems.includes(generator) then
						_vvr.allReleasedTrackedItems.remove(generator);
					endif;
				endif;
				//27.02.2018 cnwma1 ChangeRequest #36813
			endif;
			job.removeWLE(wle, _reason);
		endforeach;
		//job.erase(NORMAL_ERASE);
	endif;
	if _passport.hasErrors then
		return;
	endif;
	
	// create the VVRD for the cancellation
	_vvr.createVisitRecordDetail (VisitRecord_Cancel, _reason, null);	// par 31670
	// change status of job to cancelled
	_vvr.changeStatus(CM_VehicleVisitRecord.Status_Cancelled);
	_vvr.setTimeOutCancelled( app.serverTimestampAtTrxStart );			//cnwrd1 par 25064 21.7.2010
	
	_vvr.createVisitRecordDetail(VisitRecord_Complete_OutGate, null, null);	// par 31670 PAR 27472
	
	if _vvr.vehicle &lt;&gt; null then
		_vvr.vehicle.setMyPrimaryActualLocation(null,false);			// move offsite
	endif;
	
	_vvr.causeEvent(_vvr.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), false, _vvr);

epilog
	delete wleArray;
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVVRInspection" id="d708c780-f4d3-4021-bc2e-86d106cbb04e">
        <updating/>
        <source>utlUpdateVVRInspection(_vvr : CM_VehicleVisitRecord input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2022	navsp1	Initial creation - ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
14/02/2024	navcs2	Bug 62454: FR | 53667 - Inspection App - Resend Message discrepancy (Changed Signature)

*/

vars

begin
	/* 30.Oct.2023 navsp1 TFS 60964 - Manual sending of the Gate In/ Gate Out inspection message does not need to update the inspections status and time.
	if _forcedInspectionIn then
		_vvr.updateGateCheckDetails(true,_vvr.InspectionPending,null);
	endif;
	if _forcedInspectionOut then
		_vvr.updateGateCheckDetails(false,_vvr.InspectionPending,null);
	endif;*/
	CMIF_TrxActionInspection@createAction(_vvr,_passport);		// 14/02/2024	navcs2	Bug 62454
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVVRRoadExit" id="16893c5e-83c7-440e-9a94-f3a782332233">
        <source>utlUpdateVVRRoadExit( vvr : CM_VehicleVisitRecord; _passport : CM_Passport input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2020	jlgndl1	Initial creation	TFS 49189 - refactored into separate method
31/05/2022		jlier1		TFS 53650 - refactored schedule packages now called from vvr.departureProcess
09Dec2022	navsp1 TFS - ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
*/

vars

	ti : CM_TrackedItem;

begin

	if vvr &lt;&gt; null then
		//09Dec2022 navsp1 TFS 55580
		//Validation to prevent road exit if pregate OUT check is required and not done.
		if vvr.gateOutCheckStatus = vvr.InspectionPending then
			app.raiseCMException2(Vehicle_cannot_road_exit, vvr.vehicle.regNumber, vvr.InspectionPending, null, vvr.vehicle);
			return;
			
		//28.Mar.2023 navsp1 TFS 57268
		elseif vvr.gateOutCheckStatus = vvr.InspectionFailed then
			app.raiseCMException2(Vehicle_cannot_road_exit, vvr.vehicle.regNumber, vvr.InspectionFailed, null, vvr.vehicle);
			return;
		endif;
		
		//11 Jan 2013	NDL	Par 30921 - Testing
		//Cargo can be added on the fly.  This will not have an associated job so check for these
		//and add to the released cargo of the vehicle visit record if required.
		vvr.doExitForNoJobCargoLoads();	
	endif;
	
	if _passport.noErrors then
		// rebuild these as in some cases the TI is deleted
		// above which can result in invalid objects in the
		// deferred dicts
		_passport.rebuildDeferredDicts();
		_passport.doDeferredUpdates();
	endif;

	if vvr &lt;&gt; null then
		// CCMS 1280 Cash Invoicing epr 10/8/12 have to convert pro forma to real cash payments
		if  vvr.myTerminal.isCashOnlyEnabled() then //04/09/2017 cnwma1 TFS #6670
			if _passport.noErrors then
				foreach ti in vvr.allReleasedTrackedItems discreteLock do
					app.myUtilityUA.utlUpdateCashPaymentFromTI(ti,vvr,_passport);
					if _passport.hasErrors() then
						return;
					endif;
				endforeach;
			endif;
		endif;
	endif; 

epilog

end;</source>
        <Parameter name="vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateVVRSubCarrier" id="da11229d-e824-4665-bb0e-653dffad0df5">
        <updating/>
        <source>utlUpdateVVRSubCarrier(_pxyVvr : CM_VehicleVisitRecord; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2022	navhl20	ChangeRequest 53430: EUP - Sub Carrier registration in MTN

*/

vars
	expectedEdition		: Integer;
	realVvr : CM_VehicleVisitRecord;
begin
	self.initialiseActivity();
	
	_pxyVvr.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyVvr.pxyGetRealObjectAndEdition(realVvr, expectedEdition);
	
	if realVvr = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_VehicleVisitRecord.name, null, null);
		return;
	endif;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	exclusiveLock(realVvr);

	if _passport.noErrors and realVvr.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Vehicle Visit Record', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVvr, true);
	endif;

	if _passport.noErrors then
			realVvr.setSubCarrierCode(_pxyVvr.subCarrierCode);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realVvr, false);
	endif;
	
epilog

end;</source>
