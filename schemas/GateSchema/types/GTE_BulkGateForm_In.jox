    <JadeMethod name="setDefaultGate" id="b0f67a1a-85d3-40b8-b320-c798fae7afbd">
        <source>setDefaultGate() protected;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2016	cnwns1	Initial creation

*/

vars
	gate : CM_Gate;
	
begin
	
	if not self.myBulkGateAgent.gateAndLaneSet then
		self.getXMLSettingsForSetup();									
	endif;
	
	gate := self.myBulkGateAgent.myGate;
	
	if gate = null then	 
		gate := self.myTerminal.getDefaultGate_IN;	
	endif;
		
	if gate &lt;&gt; null and self.cmbGate.findObject(gate) &lt;&gt; -1 then	
		self.doChangeGate(gate);									
	else															
		self.cmbGate.setIndex(1);									
		self.doChangeGate(self.cmbGate.listObject.CM_Gate);			
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDirectionLabel" id="beb56acb-468a-4631-aab3-72fa234f6cd3">
        <source>setDirectionLabel(_cargoDirection : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2016	cnwns1	Initial creation

*/
constants
	 InIcon = "i";
	 OutIcon = "h";
vars
	lDirection : Integer;
begin
	lDirection := _cargoDirection;
	
	if lDirection = Inward then
		lblDirectionIcon.caption := InIcon;
		lblDirection.caption := app.getErrorString(ReceivalStr);
	elseif	lDirection = Outward then
		lblDirectionIcon.caption := OutIcon;
		lblDirection.caption := app.getErrorString(Release);
	else
		lblDirectionIcon.caption := Empty_String;
		lblDirection.caption 	:= Empty_String;
	endif;
epilog

end;</source>
        <Parameter name="_cargoDirection" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDriverDetails" id="f92e098e-d4fd-4fff-92ae-6d9b542a8d8f">
        <source>setDriverDetails(_driver : CM_DriverDetails) protected;
/*

Date		Who		Reason
// Created:     09 December 2016 by cnwns1

*/

vars

begin
	if _driver = null then
		return;
	endif;
	
	if self.cmbDriver.visible then
		self.cmbDriver.setIndexFromObject(_driver);
	else
		self.txtDriverName.text:=_driver.name;
		self.txtDriverCode.text:=_driver.code;
	endif;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_driver" type="CM_DriverDetails"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVVR" id="c9771e9c-ac74-4d5a-b582-7b0f84eaab79">
        <updating/>
        <source>setMyCurrentVVR(_vvr : CM_VehicleVisitRecord) updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 December 2016 by cnwns1

//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 08/06/2022 		navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN
// ---------------------------------------------------------------------------
vars
	carr,subCarr		: CM_Carrier;
	gate		: CM_Gate;
	gateArea	: CM_GateArea;
	laneCont	: CM_GateAreaLaneController;
	termArr		: CM_TerminalArea;			
	detail		: CM_VehicleVisitRecordDetail;
	invalid 	: Boolean;
	load 		: Boolean;
	objSet		: CM_ObjectSet;
	laneIndex 	: Integer;
	weighbridge : CM_WeighBridgeObj;
begin

	self.myBulkGateAgent.myRealVVR := _vvr;
	
	if _vvr = null then
		self.clearForm();
		return;
	endif;
	
	create objSet transient;
	
	
	if self.myBulkGateAgent.myPxyGTEEntity &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,self.myBulkGateAgent.myPxyGTEEntity,invalid);
		delete self.myBulkGateAgent.myPxyGTEEntity;
		self.myBulkGateAgent.myPxyGTEEntity := null;
	endif;
	
	if not self.myBulkGateAgent.myRealVVR.allGateEntities.isEmpty then
		app.cmsBeginLoad(load);
		self.myBulkGateAgent.myPxyGTEEntity := self.myBulkGateAgent.myRealVVR.allGateEntities.first.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
	endif;
			
	if _vvr.myGateIn = null then
		detail := _vvr.getSecurityGateArrivedDetail;				
		if detail &lt;&gt; null then										
		else														
			self.clearForm();
			self.myBulkGateAgent.myRealVVR := _vvr;
			return;
		endif;														
	endif;
	
	self.beginNotification(_vvr, self.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), Response_Continuous, 0);
	self.beginNotification(_vvr, self.myTerminal.getTerminalEvent(EVENT_VEH_VISIT_TRANSACTION), Response_Continuous, 0);

	self.txtVisitNumber.text := _vvr.visitNumber;
	app.writeLog(method.qualifiedName &amp; " Showing details for VVR " &amp; _vvr.visitNumber, LogINFO);		
		
	if _vvr.vehicle &lt;&gt; null and not _vvr.vehicle.isUnknownVehicle then 		
		if self.txtRegno.visible then
			self.txtRegno.text := _vvr.regNumber;
		else
			self.cmbRegNo.setIndexFromObject(_vvr.getVehicle);
		endif;
		self.onRegChanged();
		
		carr := _vvr.getMyCarrier();
		
		if carr &lt;&gt; null and self.cmbCarrier.findObject(carr) = -1 then 
			self.cmbCarrier.addItemObject(carr.description, carr);
		endif;
		self.cmbCarrier.listObject := carr;
		
		//08/06/2022 navhl20 TFS 53430
		if isSubCarrierEnabled then
			subCarr := _vvr.getMySubCarrier();
			
			if subCarr &lt;&gt; null and self.cmbSubCarrier.findObject(subCarr) = -1 then 
				self.cmbSubCarrier.addItemObject(subCarr.description, subCarr);
			endif;
			self.cmbSubCarrier.listObject := subCarr;
		endif;
		//08/06/2022 navhl20 TFS 53430
	endif;													
	
	if _vvr.myDriverDetails &lt;&gt; null then
		self.setDriverDetails(_vvr.myDriverDetails);
	else
		if self.txtDriverCode.visible then
			self.txtDriverCode.text:=_vvr.driverCode;
			self.txtDriverName.text:=_vvr.driversName;
		endif;
	endif;
	
	termArr := self.myTerminal.allTerminalAreas[_vvr.transferAreaId];
	if termArr &lt;&gt; null and self.cmbInterchange.findObject(termArr) &gt; 0 then		
		self.cmbInterchange.listObject := termArr;
	endif;
	
	weighbridge := _vvr.getBulkWeighbridge();
	
	if weighbridge &lt;&gt; null then
		laneCont := weighbridge.myGateLane;
		gate :=	laneCont.getGate;
	else
		laneCont := _vvr.getBulkGateAreaLaneContrIn;	//TFS 5560 jlgns1 28/7/17
		gate := _vvr.myGateIn;
	endif;
	
	self.doChangeGate(gate);										
	
	
	self.myBulkGateAgent.setGateAreaLaneController(laneCont);
		
	if cmbGateLanes.visible then
		laneIndex :=	self.cmbGateLanes.findObject(self.myBulkGateAgent.myGateAreaLaneController);
		self.cmbGateLanes.listIndex := laneIndex;				
	endif;
	
	
//	if objSet.first() &lt;&gt; null then		
//		gateArea := objSet.first().CM_GateArea;
//		if gateArea.laneCount &gt; 0 then								
//			self.cmbGateLanes.listObject := laneCont;				
//		endif;														
//	endif;															
		
	// vehicle and carrier details																				
	if (_vvr.vehicle &lt;&gt; null and _vvr.vehicle.isUnknownVehicle) or _vvr.carrierCode = NULL_CARRIER_CODE then	
		self.detailsChangedVehicle := true;																		
	endif;																										
	
	delete objSet;
	
epilog
	app.cmsEndLoad(load);
end;</source>
        <access>protected</access>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setProxyVVR" id="ac24399a-242a-4474-9745-157a0a8383bf">
        <source>setProxyVVR(_pxyVVR : CM_VehicleVisitRecord input);
// ---------------------------------------------------------------------------
// Created:     09 December 2016 by cnwns1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 13/05/2022 		navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN
// ---------------------------------------------------------------------------

vars	
	ta				: CM_TerminalArea;				
	interchangeArea,								
	state,
	carrier,
	subCarrier,				//08/06/2022 navhl20 TFS 53430 
	regNumber,
	driverCode,
	driverName		: String;
	showTrouble		: Boolean;
	ownerTrailerID	: String;
	gate			: CM_Gate;						
//	aGate			: CM_GateArea;					
	lane			: CM_GateAreaLaneController;	
	bat				: CM_RFIDTag;	
	objSet			: CM_ObjectSet;
//	obj 			: Object;
//	useComboLane 	: Boolean;
begin

	showTrouble := false;
	
	create objSet transient;
	
	ta := self.cmbInterchange.listObject.CM_TerminalArea;	
	if ta &lt;&gt; null then										
		interchangeArea := ta.id;							
	endif;													
		
	// ### Set Proxy
	if self.cmbCarrier.listObject &lt;&gt; null then
		carrier := self.cmbCarrier.listObject.CM_Carrier.code;
	endif;
	
	//Start 08/06/2022 navhl20 TFS 53430
	if self.cmbSubCarrier.listObject &lt;&gt; null then
		subCarrier := self.cmbSubCarrier.listObject.CM_Carrier.code;
	endif;
	//End 08/06/2022 navhl20 TFS 53430
	
	if self.txtRegno.visible then
		regNumber := self.txtRegno.text.trimBlanks();
	else
		regNumber:= self.cmbRegNo.text.trimBlanks();
	endif;
	state := self.txtState.text.trimBlanks();
	
	_pxyVVR.setAutoComplete(false);
	_pxyVVR.setTimeIn(null, null);
	
	//  if the a-gate does not have lanes then we don't show them in the lane combo and we 
	//	use the default inward lane for the gate area
//	gate := self.cmbGate.listObject.CM_Gate;						
	gate := self.myBulkGateAgent.myGate;						
	
//	if gate &lt;&gt; null then		
//		gate.getPGateAreas_IN(objSet);
//		foreach obj in objSet do
//			if obj.CM_GateArea.laneCount &gt; 0 then
//				useComboLane := true;
//			endif;
//		endforeach;
//	endif;															
						
	//			process.isNDS;		
						
lane := self.myBulkGateAgent.myGateAreaLaneController;	
					
//	if useComboLane then
//		lane := self.cmbGateLanes.listObject.CM_GateAreaLaneController;	
//	else
//		if objSet.first &lt;&gt; null then
//			lane := objSet.first.CM_GateArea.getDefaultLane_IN;
//		endif;
//	endif;															
	
	
	
	if self.cmbDriver.visible then
		if self.cmbDriver.listObject &lt;&gt;  null then	
			driverCode := self.cmbDriver.listObject.CM_DriverDetails.code;
			driverName:= self.cmbDriver.listObject.CM_DriverDetails.name;
		endif;
	else
		driverCode:=self.txtDriverCode.text;
		driverName:=self.txtDriverName.text;
	endif;

	//_pxyVVR.setProxyFlexiGate(driverCode, driverName, carrier, regNumber, state, interchangeArea,self.myTerminal, gate, lane, ownerTrailerID);			//13/05/2022 navhl20 TFS 53430 
	_pxyVVR.setProxyFlexiGate(driverCode, driverName, carrier, subCarrier, regNumber, state, interchangeArea,self.myTerminal, gate, lane, ownerTrailerID);			//13/05/2022 navhl20 TFS 53430 
	
	_pxyVVR.setIsUpdatable(false);
	
	if not self.myTerminal.getConfig(GateInAutoVisitNo).Boolean then
		
		// a bat number, don't update the visit number											
		app.writeLog(method.qualifiedName &amp; " Looking for a bat number of '" &amp; self.txtVisitNumber.text &amp; "'", LogINFO);	
		bat := self.myTerminal.allRFIDTagsByCode[self.txtVisitNumber.text];						
		if self.myTerminal.getConfig(SiteHasSecurityGate).Boolean and bat &lt;&gt; null then			
			app.writeLog(method.qualifiedName &amp; " Found a bat  '" &amp; self.txtVisitNumber.text &amp; "'", LogINFO);				
			app.writeLog(method.qualifiedName &amp; " Leaving '" &amp; _pxyVVR.visitNumber &amp; "' on the proxy vvr", LogINFO);		
		else																					
			app.writeLog(method.qualifiedName &amp; " Didnt find a bat for '" &amp; self.txtVisitNumber.text &amp; "', setting vvr", LogINFO);	
			_pxyVVR.setVisitNumber(self.txtVisitNumber.text);
		endif;																					
	else
		app.writeLog(method.qualifiedName &amp; " self.myTerminal.getConfig(GateInAutoVisitNo) is true", LogINFO);			
	endif;
	
	
epilog
	
	delete objSet;
end;</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTxtPinToNullOrVbsId" id="6bbe1f81-f2c7-482c-879f-623809f57f94">
