    <JadeMethod name="getHighestCargoHeightDisplay" id="3b8790e1-5888-42ab-9a0b-396587dbae64">
        <source>getHighestCargoHeightDisplay() :String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2022	TFS 54700 jlier1	Initial creation 

*/

vars
	highestCargoHeight : Decimal [23,4];
	measureType : CM_MeasurementType;
begin

	measureType := app.getDefaultMeasurementForType(Type_Height);

	if self.height &lt;&gt; null then
		highestCargoHeight:= self.height;
	endif;
	
	if highestCargoHeight = null then
		highestCargoHeight :=self.myTILCType.height;
	endif;
	
	if measureType = null then
		return highestCargoHeight.asStringJMT;
	endif;
	
	
	return app.convertMeasurementForDisplay(measureType.shortName, highestCargoHeight) &amp; Space &amp; measureType.shortName;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
