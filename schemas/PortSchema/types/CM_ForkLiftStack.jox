    <JadeMethod name="isAccessRestricted" id="4322020f-4628-4a43-9e0b-0e6ba8f83c1c">
        <source>isAccessRestricted(_ignoreQueued : Boolean; 
						pLocation : CM_GridController; 
						_ti : CM_TrackedItem;
						_machine : CM_Machine) : Integer;
// ---------------------------------------------------------------------------
// Created:		September 2001 By Andrew Bishop cnwab1
//
// Purpose:		wrok out where our ordinal location is. then decide whether there are containers in front or our location or behind restricting our access
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 7 May 2018	jlger1		TFS 37584 reach stacker overstow changes
vars
	
	overstowController : CMIF_OverstowController;
begin

	if not self.useSideAccessRules then
		return TA_ACCESS_FRONT_BACK;
	endif;
	// in Fork Lift Stack overstow moves a lack of suitable locations results in the TI being moved to the swap stack
	// If the source or target location being passed in is not a stackcontroller then it has full access
	if (not pLocation.isKindOf(CM_StackController)) then
		return TA_ACCESS_FRONT_BACK;
	endif;
	
	//epr TFS 37584 7/5/18
	create overstowController transient;
	if pLocation &lt;&gt; null then
		overstowController.setGridLocation(pLocation);
		overstowController.setMachine(_machine);
	else
		overstowController.setParams(null,_ti,false,null,_machine);
	endif;
	overstowController.getAllOverstows();
	if overstowController.isSideOverstowed then
		return TA_ACCESS_NO;
		
	else
		if overstowController.accessDirection = CM_YABlock.SideAccess_Front then
			return TA_ACCESS_FRONT;
		else
			return TA_ACCESS_BACK;
		endif;
		
	endif;
	return TA_ACCESS_NO;
	
epilog
	delete overstowController;
end;</source>
        <Parameter name="_ignoreQueued" type="Boolean"/>
        <Parameter name="pLocation" type="CM_GridController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isForkliftStack" id="bea5f18b-eac9-4ecb-8753-c0918bccc48d">
