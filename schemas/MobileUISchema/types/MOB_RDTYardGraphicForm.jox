    <JadeMethod name="btnGo_click" id="4c6e2ba6-e3a4-4c66-a37e-0794b7112ee7">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnGo_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2010	cnwjk3	Initial creation

*/

vars
	lc	: CM_LocationsController;
	height	: Integer;
	terminal : CM_Terminal;
begin
	
	terminal := self.getTerminal();
	terminal.findLocationFromString(self.txtLocation.text.trimBlanks(), true, lc, height);
	if lc = null then
		return;
	endif;
	
	/*
	if lc.myTerminalArea.isKindOf(CM_StraddleStack) then
		self.setDisplayForStraddle();
	elseif lc.myTerminalArea.isKindOf(CM_Rail) then
		self.setDisplayForRail();
	else
		self.setDisplayForRTG();
	endif;
	*/
	self.myDrawingController.gotoLocationByString(self.txtLocation.text, self.myDrawingController.drawMode, false);
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnLandscape_click" id="11e59f98-f8eb-41ec-8ac9-f86efde9425e">
