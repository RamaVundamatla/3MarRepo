    <JadeMethod name="vehicleBookingCarrier" id="d356534c-4fff-4a40-bc29-9c53135c7040">
        <source>vehicleBookingCarrier():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 October 2014	cnwndl1	Initial creation	Par 35008

*/

vars

	vbts : CM_VehicleBookingTimeSlot;

begin

	if self.myJRWVBDetailsObj &lt;&gt; null then
		vbts := self.myJRWVBDetailsObj.myVehicleBookingTimeSlot;
		if vbts &lt;&gt; null and vbts.myCarrier &lt;&gt; null then
			return vbts.myCarrier.description;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="vehicleBookingTimeslotDate" id="4f9fb03b-5e5a-4e21-b66f-7b4f70dfdba3">
