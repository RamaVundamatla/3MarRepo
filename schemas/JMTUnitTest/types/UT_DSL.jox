    <JadeMethod name="deleteEDIInwardXlation" id="7a8da574-cb75-4f99-ba80-e3cacddbdbcd">
        <source>deleteEDIInwardXlation(_foreignCode : String; _xlationType : Integer; _operator : CM_Operator; _cargoType : CM_CargoBOLType);

// 02/04/2013	cnwcs5	CCMS POL 2097 / par 31259
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
vars
	xlationTable 		: CM_XlationTable;
	xlation 			: CM_Xlation;
	operatorTerminal 	: CM_OperatorTerminal;
	allDeleteXlations	: CM_XlationSet;
begin
	if _xlationType = XLATION_TYPE_VOYAGETERMINAL and _operator &lt;&gt; null then
		operatorTerminal := _operator.allOperatorTerminals[self.getTerminal()];
		
		if operatorTerminal &lt;&gt; null then
			xlationTable := operatorTerminal.allXlationTables[_xlationType, null];
		endif;
	elseif _operator &lt;&gt; null then
		xlationTable := _operator.allXlationTables[_xlationType, _cargoType];
	else
		xlationTable := self.getRoot().allXlationTables[_xlationType, null, null, null];
	endif;
	
	if xlationTable = null then
		return;
	endif;
	
	//changed because if the xlation table only had 1 translation would delete the table when deleting the xlation 
	// and this would cause error 4
	create allDeleteXlations transient;
	xlationTable.allInwardTranslations.copy(allDeleteXlations);
	
	foreach xlation in allDeleteXlations where xlation.foreignCode = _foreignCode do
		app.myTrxDA.trxDeleteXlation(xlation, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
epilog
	delete allDeleteXlations;
end;
</source>
        <Parameter name="_foreignCode" type="String"/>
        <Parameter name="_xlationType" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="deleteEDIInwardXlationSCode" id="d9b217c3-60d6-4254-b536-6fa23974649b">
        <source>deleteEDIInwardXlationSCode(_systemCode : String; _xlationType : Integer; _operator : CM_Operator; _cargoType : CM_CargoBOLType);

// 02/04/2013	cnwcs5	CCMS POL 2097 / par 31259
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
vars
	xlationTable 		: CM_XlationTable;
	xlation 			: CM_Xlation;
	operatorTerminal 	: CM_OperatorTerminal;
	allDeleteXlations	: CM_XlationSet;
begin
	if _xlationType = XLATION_TYPE_VOYAGETERMINAL then
		operatorTerminal := _operator.allOperatorTerminals[self.getTerminal()];
		
		if operatorTerminal &lt;&gt; null then
			xlationTable := operatorTerminal.allXlationTables[_xlationType, null];
		endif;
	elseif _operator &lt;&gt; null then
		xlationTable := _operator.allXlationTables[_xlationType, _cargoType];
	else
		xlationTable := self.getRoot().allXlationTables[_xlationType, null, null, null];
	endif;
	
	if xlationTable = null then
		return;
	endif;
	
	//changed because if the xlation table only had 1 translation would delete the table when deleting the xlation 
	// and this would cause error 4
	create allDeleteXlations transient;
	xlationTable.allInwardTranslations.copy(allDeleteXlations);
	
	foreach xlation in allDeleteXlations where xlation.systemCode = _systemCode do
		app.myTrxDA.trxDeleteXlation(xlation, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
epilog
	delete allDeleteXlations;
end;
</source>
        <Parameter name="_systemCode" type="String"/>
        <Parameter name="_xlationType" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="deleteEDIOutwardXlation" id="a0404a9b-98e1-4c3d-aeea-eaf612c4ef81">
        <source>deleteEDIOutwardXlation(_systemCode : String; _xlationType : Integer; _operator : CM_Operator; _cargoType : CM_CargoBOLType);

// 02/04/2013	cnwcs5	CCMS POL 2097 / par 31259
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
vars
	xlationTable 		: CM_XlationTable;
	xlation 			: CM_Xlation;
	operatorTerminal 	: CM_OperatorTerminal;
begin
	if _xlationType = XLATION_TYPE_VOYAGETERMINAL and _operator &lt;&gt; null then
		operatorTerminal := _operator.allOperatorTerminals[self.getTerminal()];
	endif;
	
	if operatorTerminal &lt;&gt; null then
		xlationTable := operatorTerminal.allXlationTables[_xlationType, null];
	elseif _operator &lt;&gt; null then
		xlationTable := _operator.allXlationTables[_xlationType, _cargoType];
	else
		xlationTable := self.getRoot().allXlationTables[_xlationType, null, null, null];
	endif;
	
	if xlationTable = null then
		return;
	endif;
	
	foreach xlation in xlationTable.allOutwardTranslations where xlation.systemCode = _systemCode do
		app.myTrxDA.trxDeleteXlation(xlation, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
epilog
end;
</source>
        <Parameter name="_systemCode" type="String"/>
        <Parameter name="_xlationType" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="deleteEDIOutwardXlationFCode" id="6591fd89-ba51-46d0-86b8-d8a535d1af73">
        <source>deleteEDIOutwardXlationFCode(_foreignCode : String; _xlationType : Integer; _operator : CM_Operator; _cargoType : CM_CargoBOLType);

// 02/04/2013	cnwcs5	CCMS POL 2097 / par 31259
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
vars
	xlationTable 		: CM_XlationTable;
	xlation 			: CM_Xlation;
	operatorTerminal 	: CM_OperatorTerminal;
begin
	if _xlationType = XLATION_TYPE_VOYAGETERMINAL then
		operatorTerminal := _operator.allOperatorTerminals[self.getTerminal()];
	endif;
	
	if operatorTerminal &lt;&gt; null then
		xlationTable := operatorTerminal.allXlationTables[_xlationType, null];
	elseif _operator &lt;&gt; null then
		xlationTable := _operator.allXlationTables[_xlationType, _cargoType];
	else
		xlationTable := self.getRoot().allXlationTables[_xlationType, null, null, null];
	endif;
	
	if xlationTable = null then
		return;
	endif;
	
	foreach xlation in xlationTable.allOutwardTranslations where xlation.foreignCode = _foreignCode do
		app.myTrxDA.trxDeleteXlation(xlation, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
epilog
end;
</source>
        <Parameter name="_foreignCode" type="String"/>
        <Parameter name="_xlationType" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
