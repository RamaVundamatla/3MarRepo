    <JadeMethod name="createSummaryObj" id="9b648026-60b4-4def-aedc-7bc6fcfe1dfd">
        <source>createSummaryObj (_ti: CM_Container; _summaryObjects: CMIF_ExportStiffByISODischLoad input);
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sumObj		: CMIF_ExportStiffSum;
	isNew		: Boolean;
begin
	sumObj := _summaryObjects[_ti.isoType, _ti.dischargePort, _ti.loadPort]; 
	
	if sumObj = null then
		create sumObj transient;
		sumObj.setForCreateFromFilter(self);
		isNew := true;
	endif;
	
	sumObj.setFromTI(_ti, isNew);
	
	if isNew then
		_summaryObjects.add(sumObj);	
	endif;

end;</source>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_summaryObjects" type="CMIF_ExportStiffByISODischLoad" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="5e174ced-5fc5-4691-a606-8310727196bd">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

begin

	self.allStiffRepDetail.purge();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="01156f60-a3c9-41e1-be69-71306203f5fe">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;

/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	ti					: CM_TrackedItem;
	terminal			: CM_Terminal;
	breakOut			: Boolean;
	
	iterTI				: Iterator;
	cargoTypeKey		: Integer;
	idKey				: String;
	includedTIs			: CM_TIByIdDict;
	statusesOfInterest	: IntegerArray;
	typesOfInterest		: IntegerArray;
	status,brType		: Integer;
	tmpColl				: CMIF_ExportStiffByISODischLoad;
begin
	
	tmpColl := _collection.CMIF_ExportStiffByISODischLoad;
	
	create includedTIs transient;
	
	foreach terminal in self.allTerminals do
		delete iterTI;
		iterTI := terminal.allOnsiteTIsByCargoTypeId.createIterator();
		
		terminal.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_Container, null, iterTI);
		
		while iterTI.next(ti) do
			
			if ti.cargoType &lt;&gt; TI_CargoType_Container then
				break;
			endif;
			
		//	if self.checkStatusIncludesObject(ti, _passport, breakOut) then
				if not includedTIs.includes(ti) and self.includesObject(ti,_passport, breakOut) then
					includedTIs.add(ti);
				endif;
		//	endif;
		endwhile;
		
		
	endforeach;
	//we've got this stuff now what do we do?
	foreach ti in includedTIs discreteLock do
		self.createSummaryObj(ti.CM_Container, tmpColl);
	endforeach;
	

epilog
	delete includedTIs;
	delete iterTI;		// PAR #26678
		
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="6e42eb13-2156-46ad-9df9-cb658e226e59">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _ti.myVoyage = self.getMyVoyage and inheritMethod(_ti, _passport, _breakOut) then
		return true;
	endif;
	return false;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
