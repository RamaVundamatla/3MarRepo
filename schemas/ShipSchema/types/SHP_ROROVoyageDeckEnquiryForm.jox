    <JadeMethod name="setCaption" id="d3a45cd1-1d3e-4548-b736-3508849dbaae">
        <updating/>
        <source>setCaption(_caption: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	//should differentiate between vessel and voyage 
	self.caption:=app.getErrorString(Roro_voyage_deck_enquiry) &amp; " - " &amp; self.myROROVoyageStructure.myVoyage.code; 


epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="4867534f-3ad2-4ffe-a257-a89238553923">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	inheritMethod();

	self.mnuExportDeckXML.visible:=false;
	self.mnuExportXMLVessel.visible:=false;
	self.mnuImportXML.visible:=false;
	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnDeckSorting.enabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="startNotes" id="2ad025db-2a1c-44a2-a6cc-4cdfa05280bd">
        <source>startNotes() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.beginNotification(self.myROROVoyageStructure,EVENT_VESSEL_DECK_CREATE,Response_Continuous,null);
	self.beginNotification(self.myROROVoyageStructure,EVENT_VESSEL_DECK_UPDATE,Response_Continuous,null);
	self.beginNotification(self.myROROVoyageStructure,EVENT_VESSEL_DECK_DELETE,Response_Continuous,null);
	self.beginNotification(self.myROROVoyageStructure, EVENT_LOCATION_REFRESH, Response_Continuous, null);	// 28687
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e430ec2f-cc15-465b-a9ad-fa46f18b2c39">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 15:46:02.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022921, locale);
	btnDeckSorting.translateBubbleHelp(Xlat_0018575, locale);
	btnDeckSorting.translateCaption(Xlat_0018576, locale);
end;</source>
    </JadeMethod>
</GUIClass>
