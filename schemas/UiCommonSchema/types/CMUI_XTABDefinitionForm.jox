    <JadeMethod name="create" id="2a9b33a2-5727-49a0-ae33-52ad58010924">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
