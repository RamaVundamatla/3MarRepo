    <JadeMethod name="doStartMachines" id="72fb4ea3-26aa-41d9-adcd-7043cc15d41d">
        <source>doStartMachines() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 September 2010	cnwkpd1	PAR #24294 - CCMS MES 1080 - ITS Driver Initiated Move 

*/

vars
	machines		: StringArray;
	table			: Table;
	formTop,
	formLeft,
	selectCol,
	idCol,
	row,
	column			: Integer;
	machine			: String;
	simForm			: ITSMachineSimulatorForm;
	
begin
	table := self.tblMachines;
	
	foreach column in 1 to table.columns do
		if table.getCellText(1, column) = self.Machine_Column_ID then
			idCol := column;
		elseif table.getCellText(1, column) = self.Machine_Column_Select then
			selectCol := column;
			break;
		endif;
	endforeach;
			
	create machines transient;
	
	foreach row in 2 to table.rows do
		if table.getCellText(row, selectCol) = "1" then
			machines.add(table.getCellText(row, idCol));
		endif;
	endforeach;
	
	if app.msgBox("Start " &amp; machines.size.String &amp; " machines?", "Action", MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	// Now start up all the forms
	foreach machine in machines do
		create simForm;
		simForm.show();
		
		simForm.left := formLeft;
		simForm.top := formTop;
		
		formLeft := formLeft + 20;
		formTop := formTop + 20;
		
		simForm.txtMachine.text := machine;
		simForm.txtUser.text := self.txtUser.text;
		simForm.txtPassword.text := self.txtPassword.text;
		simForm.txtACKDelay.text := "0";
		
		app.doWindowEvents(100);
	endforeach;

	// Now fire them all into action
	global.causeEvent(ITSServerControl.START_MACHINE, true, null);
	
	
epilog
	delete machines;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getValueForMachineColumn" id="6950f2ae-a602-4a9f-91e8-5b763e2ca56d">
        <source>getValueForMachineColumn(_machine : Object;
						 _columnName : String) : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 September 2010	cnwkpd1	PAR #24294 - CCMS MES 1080 - ITS Driver Initiated Move 

*/

vars
	rtDevice		: Object;
	
begin
	if _machine = null then
		return null;
	endif;
	
	if _columnName = self.Machine_Column_ID then
		return _machine.getPropertyValue("id").String;
	elseif _columnName = self.Machine_Column_Type then
		return _machine.getPropertyValue("machineType").String;
	elseif _columnName = self.Machine_Column_Description then
		return _machine.getPropertyValue("description").String;
	elseif _columnName = self.Machine_Column_RT_Device_ID then
		rtDevice := _machine.getPropertyValue("myRTDevice").Object;
		if rtDevice = null then
			return null;
		else
			return rtDevice.getPropertyValue("id").String;
		endif;
	endif;
			
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_machine" type="Object"/>
        <Parameter name="_columnName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseMachinesTable" id="dd6a1261-48c1-411b-adfa-44222e2145ee">
        <source>initialiseMachinesTable() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 September 2010	cnwkpd1	PAR #24294 - CCMS MES 1080 - ITS Driver Initiated Move 

*/
vars
	columnArray		: StringArray;
	columnName		: String;
	table			: Table;
	
begin
	table := self.tblMachines;
	
	table.rows := 0;
	table.columns := 0;
	
	table.rows := 1;
	table.fixedRows := 1;
	
	table.selectMode := Table.SelectMode_WholeRows;
	
	create columnArray transient;
	columnArray.add(self.Machine_Column_ID);
	columnArray.add(self.Machine_Column_Type);
	columnArray.add(self.Machine_Column_Description);
	columnArray.add(self.Machine_Column_RT_Device_ID);
	columnArray.add(self.Machine_Column_Select);
	
	foreach columnName in columnArray do
		table.columns := table.columns + 1;
		table.setCellText(1, table.columns, columnName);
	endforeach;
	

epilog
	delete columnArray;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="2a1231ec-fe03-4b4c-9bb0-4cfc82d747ec">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 Sep 2010	cnwkpd1	CCMS MES 1080 - Multi machine initiation

*/

vars

begin
	self.myControl := ITSServerControl.firstInstance;
	
	if self.myControl = null then
		app.msgBox("ITS Server Application is not yet running, will terminate", "Error", MsgBox_OK_Only);
		terminate;
	endif;
	
	if self.tryLock(self.myControl, Reserve_Lock, Transaction_Duration, LockTimeout_Immediate) then
		self.unlock(self.myControl);
		app.msgBox("ITS Server Application is not yet running, will terminate", "Error", MsgBox_OK_Only);
		terminate;
	endif;
	
	self.txtHostname.text := self.myControl.remoteAddress;
	self.txtPort.text := self.myControl.remotePort.String;
	self.txtTimeout.text := self.myControl.timeout.String;
	self.chkUsePresent.value := self.myControl.usePresentationTCP;
	
	self.setDefaults();
		
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadMachinesTable" id="2c4f13eb-f4e8-4897-9b3f-793ad1fa3ced">
        <source>loadMachinesTable() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 September 2010	cnwkpd1	PAR #24294 - CCMS MES 1080 - ITS Driver Initiated Move 

*/

vars
	terminal		: Object;		// CM_Terminal
	machine			: Object;		// CM_Machine
	iter			: Iterator;
	columnName,
	value			: String;
	row,
	column			: Integer;
	table			: Table;
	rtDeviceIsNum	: Boolean;
	
begin
	table := self.tblMachines;
	table.rows := table.fixedRows;
		
	terminal := self.cmbTerminal.listObject;
	if terminal = null then
		return;
	endif;
	
	iter := terminal.getPropertyValue("machines").Collection.createIterator();
	
	while iter.next(machine) do
	
		row := table.addItem(null);
		
		rtDeviceIsNum := false;
		
		foreach column in 1 to table.columns do
			columnName := table.getCellText(1, column);
			
			if columnName &lt;&gt; self.Machine_Column_Select then
				value := self.getValueForMachineColumn(machine, columnName);
				if value &lt;&gt; null and columnName = self.Machine_Column_RT_Device_ID then
					rtDeviceIsNum := value.isInteger;
				endif;
				
				table.setCellText(row, column, value);
			
			else
				table.accessCell(row, column).inputType := Table.InputType_CheckBox;
				if rtDeviceIsNum then
					table.setCellText(row, column, "1");
				endif;
				
			endif;
		endforeach;
		
	endwhile;
	
	
epilog
	delete iter;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTerminalCombo" id="b4d862ac-ef0e-40eb-bf96-9540b22be5cc">
        <source>loadTerminalCombo() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 September 2010	cnwkpd1	PAR #24294 - CCMS MES 1080 - ITS Driver Initiated Move 

*/

vars
	portSchema 		: Schema;
	rootCls			: Class;
	root			: Object;			// CM_Root
		
begin
	portSchema := rootSchema.getSchema("PortSchema");
	if portSchema = null then
		return;
	endif;
	
	rootCls := portSchema.getClass("CM_Root");
	if rootCls = null then
		return;
	endif;
	
	root := rootCls.firstInstance();
	if root = null then
		return;
	endif;

	self.cmbTerminal.clear();
	self.cmbTerminal.listCollection(root.getPropertyValue("allTerminals").Collection, false, 0);
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDefaults" id="a04aad98-bf80-4966-aa28-f21f45f81aa8">
        <source>setDefaults() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 Sep 2010	cnwkpd1	PAR #24294 - CCMS MES 1080 - ITS Driver Initiated Move 

*/

vars

begin
	self.txtUser.text := app.userName.toUpper;
	self.txtPassword.text := app.userName.toUpper;
	
	self.loadTerminalCombo;
	
	self.initialiseMachinesTable();
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
