    <JadeMethod name="validateRange" id="f13e3a34-792e-4a8c-b3f9-b06dc84f3b05">
        <source>validateRange(pFrom:Any; pTo:Any):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pFrom.jssIsGreaterThan(pTo) then
		JSSException.raise_(JSS_X_03010, "Invalid range: [" &amp; pFrom.String &amp; "] is greater than [" &amp; pTo.String &amp; "].");
		return false;
	else
		return true;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pFrom" type="Any"/>
        <Parameter name="pTo" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
