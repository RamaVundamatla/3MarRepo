<CollClass name="StringArray">
    <JadeMethod name="jssDoSort" id="ad40a58a-21a6-444c-81c9-0bdd90762526">
        <lockReceiver/>
        <updating/>
        <source>jssDoSort(pTheSorter: JSSSorter) updating, protected, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayPointer	: Integer;
	stringValue		: String;
	theSortKey		: Object;
	anyValue		: Any;

begin
	foreach stringValue in self do
		pTheSorter.addValue(stringValue);
	endforeach;
	
	self.purge();
	
	foreach theSortKey in pTheSorter.mySortColl do
		self.add(theSortKey.JSSSortKey.getValue().String);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheSorter" type="JSSSorter"/>
    </JadeMethod>
    <JadeMethod name="jssParseTokens" id="cc7000d6-4385-484e-8086-af2905b201e6">
        <lockReceiver/>
        <updating/>
        <source>jssParseTokens(pString:String) updating;
	// Add each token in the input string to the receiver.
vars
	characterPos	: Integer;
	stringLength	: Integer;
	
begin
	characterPos	:=	1;
	stringLength	:=	pString.length();
	
	foreach characterPos in 1 to stringLength do
		self.add(pString.getNextToken(characterPos));
	endforeach;
end;</source>
        <Parameter name="pString" type="String"/>
    </JadeMethod>
</CollClass>
