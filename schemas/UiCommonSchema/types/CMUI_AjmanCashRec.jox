        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDataFieldsFromObject" id="283ae558-8b54-46f7-bbf4-0f1584d565b6">
        <updating/>
        <source>setDataFieldsFromObject(_obj: CM_Object; _lineUp: Boolean; _showLabelArea: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2012	cnwndl1	Initial creation	Par 30689

*/

vars

	cashReceipt : CM_CashReceipt;

begin

	if _showLabelArea then
		//app.printer.print( self.testFrame );
		self.printLabelFieldAreaBoundary();	//21 July 2014	NDL Par 34611
	endif;
		
	if _lineUp then
		self.populateLineUp();
		return;
			
	elseif _obj &lt;&gt; null then
	
		self.myPopulatingObject := _obj;	//31 Jan 2014	NDL	Par 33181
	
		if _obj.isKindOf( CM_CashReceipt ) then
		
			cashReceipt := _obj.CM_CashReceipt.getDDPrimaryCashReceipt;//31 Jan 2014	NDL	Par 33181 - want to use teh one that is populated with all the data
			self.myPopulatingObject := cashReceipt;
			self.setFromCashReceipt( cashReceipt );
			
		elseif _obj.isKindOf( CM_CashPayment ) then
			self.setFromCashPayment( _obj.CM_CashPayment );
		else
			self.populateLineUp();
		endif;
	
		return;
		
	endif;
	
	inheritMethod( _obj, _lineUp, _showLabelArea );

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_lineUp" type="Boolean"/>
        <Parameter name="_showLabelArea" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromCashPayment" id="edf6420a-1345-4c01-89f5-d25e2c93f8db">
        <updating/>
        <source>setFromCashPayment( _payment : CM_CashPayment ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2012	cnwndl1	Initial creation	Par 30689

*/

vars

	drTerm : CM_DebtorTerminal;
	dr : CM_Debtor;
//	invoice : CM_Invoice;

begin

	drTerm := _payment.getDebtorTerminal;
	if drTerm &lt;&gt; null then
		dr := drTerm.myDebtor;
		self.myDebtor := dr;
	endif;

	self.lblA.caption := null;
	self.lblB.caption := _payment.dateTime.Date.asStringJMT;
	self.lblC.caption := "";	//multi-line label populated directly in "doProcessLabelContents"
	
	if dr &lt;&gt; null then
		self.lblD.caption := dr.postingNumber.String;
	endif;
	
	self.lblE.caption := null;	
	self.lblF.caption := _payment.getTypeString(drTerm);
	self.lblG.caption := _payment.cashValue.asCurrencyJMT;	
	self.lblH.caption := _payment.cashValue.asCurrencyJMTWords;	
	self.lblI.caption := _payment.cashValue.asCurrencyJMT;
	
	self.lblJ.caption := null;	
	self.lblK.caption := null;	
	self.lblL.caption := null;	
	self.lblM.caption := null;	
	self.lblN.caption := null;
	
	if _payment.myUser &lt;&gt; null then
		self.lblO.caption := _payment.myUser.code;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_payment" type="CM_CashPayment"/>
    </JadeMethod>
    <JadeMethod name="setFromCashReceipt" id="25b20c91-e6d6-49ec-81e0-6ebeb9ad1e01">
        <updating/>
        <source>setFromCashReceipt( _receipt : CM_CashReceipt ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2012	cnwndl1	Initial creation	Par 30689

*/

vars

	drTerm : CM_DebtorTerminal;
	dr : CM_Debtor;
	otherReceipt : CM_CashReceipt;
	totalAmount : Decimal [16,4];
	cashTotalAmount : Decimal [16,4];
	chequeTotalAmount : Decimal [16,4];
	
begin

	drTerm := _receipt.getDebtorTerminal;
	if drTerm &lt;&gt; null then
		dr := drTerm.myDebtor;
	endif;
	
	self.pageNo := 1;	//28 Jan 2014	NDL	Par 33181

	self.lblA.caption := _receipt.sequenceNum.String;
	self.lblB.caption := _receipt.dateTime.Date.asStringJMT;
	self.lblC.caption := "";	//multi-line label populated directly in "doProcessLabelContents"
	
	if dr &lt;&gt; null then
		self.lblD.caption := dr.decfinName.String;
	endif;
	
	self.myDebtor := dr;
	
	self.lblE.caption := null;
	
//	self.lblF.caption := _receipt.getTypeString(drTerm);
//	self.lblG.caption := _receipt.cashValue.asCurrencyJMT;
	//28 Jan 2014	NDL	Par 33181
	// gets the values to be used in the details portion of the receipt
	_receipt.getDDParticularsForAjmanRep( self.labelFStringArray, self.labelGStringArray );
	self.labelFStringArray.copy( self.preProcFArray );
	self.labelGStringArray.copy( self.preProcGArray );
	
	//03 Feb 2014	NDL	Par 33181
	_receipt.getDDOtherReceipts( self.otherReceipts ); // There can be mulitple CM_CashReceipts associated with a single payment
													// I.e. a cheque and some cash
	
	totalAmount := _receipt.cashValue;
	foreach otherReceipt in otherReceipts do
		totalAmount := totalAmount + otherReceipt.cashValue;
	endforeach;
	
	
	
	if _receipt.myPaymentMethod &lt;&gt; null and _receipt.myPaymentMethod.isCheque then
		chequeTotalAmount := _receipt.cashValue; 
		self.lblJ.caption := _receipt.chequeNumber;
		self.lblK.caption := _receipt.cashValue.asCurrencyJMT;
		if _receipt.chequeDate.isValid then
			self.lblL.caption := _receipt.chequeDate.asStringJMT;
		endif;
		self.lblM.caption := _receipt.chequeBank;
		self.lblN.caption := _receipt.chequeBranch;
	else
		cashTotalAmount := _receipt.cashValue;
		self.lblJ.caption := null;
		self.lblK.caption := null;
		self.lblL.caption := null;
		self.lblM.caption := null;
		self.lblN.caption := null;
	endif;
	
	foreach otherReceipt in otherReceipts do
		if otherReceipt.myPaymentMethod &lt;&gt; null and otherReceipt.myPaymentMethod.isCheque then
			if chequeTotalAmount &gt; 0 then
				self.lblJ.caption := self.lblJ.caption &amp; CrLf;
				self.lblK.caption := self.lblK.caption &amp; CrLf;
				self.lblL.caption := self.lblL.caption &amp; CrLf;
				self.lblM.caption := self.lblM.caption &amp; CrLf;
				self.lblN.caption := self.lblN.caption &amp; CrLf;
			endif;
			chequeTotalAmount := chequeTotalAmount + otherReceipt.cashValue;
			self.lblJ.caption := self.lblJ.caption &amp; otherReceipt.chequeNumber;
			self.lblK.caption := self.lblK.caption &amp; otherReceipt.cashValue.asCurrencyJMT;
			if otherReceipt.chequeDate.isValid then
				self.lblL.caption := self.lblL.caption &amp; otherReceipt.chequeDate.asStringJMT;
			endif;
			self.lblM.caption := self.lblM.caption &amp; otherReceipt.chequeBank;
			self.lblN.caption := self.lblN.caption &amp; otherReceipt.chequeBranch;
		else
			cashTotalAmount := cashTotalAmount + otherReceipt.cashValue;
		endif;
	endforeach;
	
	self.lblH.caption := "By Cash:  " &amp; cashTotalAmount.asCurrencyJMT &amp; "   " 
						&amp; "By Cheque:  " &amp; chequeTotalAmount.asCurrencyJMT &amp; CrLf
						&amp; totalAmount.asCurrencyJMTWords;
	self.lblI.caption := CrLf &amp; totalAmount.asCurrencyJMT;
	
	if _receipt.myUser &lt;&gt; null then
		self.lblO.caption := _receipt.myUser.code;
	endif;
	
	self.setParticularsAndAmountsDetail( true );
	if not self.labelFStringArray.isEmpty then 
		self.createNextPage();
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_receipt" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="setParticularsAndAmountsDetail" id="e49c00f2-8ca7-4765-8253-9bad9376f992">
        <source>setParticularsAndAmountsDetail( _preProcessing : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2014	cnwndl1	Initial creation	Par 33181

*/

vars

	top : Integer;
	startTop : Integer;
	amountTop : Integer;
	lineHeight : Integer;
	tempDescs : CM_StringDict;
	tempAmounts : CM_StringDict;
	desc : String;
	amount : String;
	descStrArray : HugeStringArray;
	amountStrArray : StringArray;
	printAttrib : Integer;
	

begin

	if self.myPopulatingObject = null or not self.myPopulatingObject.isKindOf( CM_CashReceipt ) then
		//we populate 'f' &amp; 'g' by normal means if no Cash Receipt
		return;
	endif;
	
	create tempDescs transient;
	create tempAmounts transient;
	top := ( self.lblF.top + 1 ).Integer;
	startTop :=  self.lblF.top.Integer;
	amountTop := ( self.lblG.top + 1 ).Integer;
	lineHeight := self.lblF.getTextHeight( "X" );
	
	//set the array of strings that we are using
	if _preProcessing then
		descStrArray := self.labelFStringArray;
		amountStrArray := self.labelGStringArray;
	else
		descStrArray := self.preProcFArray;
		amountStrArray := self.preProcGArray;
	endif;
	
	if not descStrArray.isEmpty then
		while true do
			printAttrib := 0;
			desc := descStrArray[1];
			if not amountStrArray.isEmpty then
				amount := amountStrArray[1];
			endif;
			if amount.trimBlanks = null then
				printAttrib := self.BOLD_Attribute;
				amount := " ";
			endif;
			if ( top + lineHeight ) &lt;= ( startTop + self.lblF.height ) then
				self.createTempSubLabelText( self.lblF, desc, top, tempDescs, printAttrib );
				self.createTempSubLabelText( self.lblG, amount, amountTop, tempAmounts, 0 );
				descStrArray.removeAt(1);	// remove the processed value from the array
				if not amountStrArray.isEmpty then
					amountStrArray.removeAt(1);
				endif;
				if descStrArray.isEmpty then
					break; // none left
				endif;
			else
				break; // will result in a new page later, becaus emore to print
			endif;
		endwhile;
	endif;
	
	if not tempDescs.isEmpty then
		self.addMultiplePrintLines( tempDescs );
	endif;
	if not tempAmounts.isEmpty then
		self.addMultiplePrintLines( tempAmounts );
	endif;
			
epilog

	if tempDescs &lt;&gt; null then
		if not tempDescs.isEmpty then
			tempDescs.purge();
		endif;
		delete tempDescs;
	endif;
	if tempAmounts &lt;&gt; null then
		if not tempAmounts.isEmpty then
			tempAmounts.purge();
		endif;
		delete tempAmounts;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_preProcessing" type="Boolean"/>
    </JadeMethod>
</GUIClass>
