    <PrimAttribute name="isCodeGroupNOTRequired" id="f6d950a4-512f-4aab-b005-49508321277a">
        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
        <text>
This is set to "true" in the "create" method of sub-classes that
do not require "myCodeGroup" to be set.  It is then used in the validation.
The default is "false" - that is "myCodeGroup" is required to be set.</text>
    </PrimAttribute>
    <ExplicitInverseRef name="myCodeGroup" id="9f5a0bc5-693e-4d9d-81ce-764c83face0a">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_CodeGroup"/>
        <access>readonly</access>
        <text>
Note that this will be NULL for some sub-classes as they
are sub-codes of another code</text>
        <Inverse name="CM_CodeGroup::allCodes"/>
    </ExplicitInverseRef>
