    <JadeMethod name="doSave" id="7230ad11-61e6-45a7-b0b2-884f2735423d">
        <updating/>
        <source>doSave(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
16 June 2011	cnwndl1	Initial creation	Par 27731
*/

vars

	theForm : SOP_TableMaintForm;
	isActive : Boolean;
	lastNotified : TimeStamp;
	maxLevel : Integer;
	minLevel : Integer;
	iSOTypeGroup : CM_ISOTypeGroup;
	mTGrade : CM_MTGrade;
	operator : CM_Operator;
	priority : Integer;
	reNotifyMins : Integer;
	pxyThreshold : CM_MTThreshold;
	
begin
	
	theForm := self.myForm; 
	
	isActive := theForm.tblInput1.getValueByName(ETRow_IsActive).Boolean;
	lastNotified := theForm.tblInput1.getValueByName(ETRow_LastNotified).TimeStamp;
	maxLevel := theForm.tblInput1.getValueByName(ETRow_MaxLevel).Integer;
	minLevel := theForm.tblInput1.getValueByName(ETRow_MinLevel).Integer;
	iSOTypeGroup := theForm.cmbISOTypeGroup.listObject.CM_ISOTypeGroup;
	mTGrade := theForm.cmbGrade.listObject.CM_MTGrade;
	operator := theForm.cmbOperator.listObject.CM_Operator;
	priority := theForm.tblInput1.getValueByName(ETRow_Priority).Integer;
	reNotifyMins := theForm.tblInput1.getValueByName(ETRow_ReNotifyMins).Integer;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_MTThreshold transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	pxyThreshold := theForm.myProxyObject.CM_MTThreshold;
	pxyThreshold.setProxy(	isActive,	//_isActive : Boolean;
							maxLevel,	//_maxThresholdLevel : Integer;
							minLevel,	//_minThresholdLevel : Integer;
							iSOTypeGroup,	//_myISOTypeGroup : CM_ISOTypeGroup;
							operator,	//_myOperator : CM_Operator;
							priority,	//_processingPriority : Integer;
							reNotifyMins,	//_reNotificationMinutes : Integer;
							self.myForm.myTerminal	//_myTerminal : CM_Terminal
							);
	pxyThreshold.setMyMTGrade(mTGrade);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateThreshold(pxyThreshold, theForm.myCurrentObject, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateThreshold(pxyThreshold, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
