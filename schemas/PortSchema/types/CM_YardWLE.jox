    <JadeMethod name="setTIsForAutoComplete" id="a9e3e06b-5a8b-4a45-81f1-318a73e13bf0">
        <source>setTIsForAutoComplete();
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars

begin
	inheritMethod();

	if self.myTrackedItem = null
	and self.myBOL &lt;&gt; null	 
	and self.getRelatedWLE() = null then
		self.myBOL.setTIsForAutoComplete();
	endif;

end;</source>
