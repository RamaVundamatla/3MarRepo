/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
21 March 2017		cnwndl1	Initial creation	TFS 3813
13 October 2022		jlizm1	TFS 54118 Assigning Releases to Wagons

*/

vars

begin

	//represents a release with no known quantity.
	if self.myRequest &lt;&gt; null then
		return self.myRequest.isAnyAmount;
	endif;
	
	return false;

epilog

end;</source>
