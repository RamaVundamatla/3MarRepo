<CollClass name="CM_WLEArray" id="31378e2c-3b2a-4fc7-b2ec-5d6a6d6a4b36">
    <memberType name="CM_WorkListEntry"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="operatn"/>
    <JadeMethod name="addAndSortSingleSequences" id="f619d298-0305-40b9-8d3f-79e0126f6960">
        <lockReceiver/>
        <updating/>
        <source>addAndSortSingleSequences(_isStarboard : Boolean; _wles : CM_WLEArray) updating;
// -------------------------------------------
// Created 02 September 2005 by cnwdvb1
// -------------------------------------------
/*
09 October 2023		jlizm1	Initial creation TFS 59730 Kiosk Load Sequence
*/
vars

	dyna	: DynaDictionary;
	
begin

	create dyna transient;
	dyna.setMembership(CM_VoyageWLE);
	if _isStarboard then
		dyna.addMemberKey(CM_VoyageWLE::seqNumCustomStarboard.name, false, false);
		dyna.addMemberKey(CM_VoyageWLE::seqNumWorkOrder.name, false, false);
	else
		dyna.addMemberKey(CM_VoyageWLE::seqNumCustomPort.name, false, false);
		dyna.addMemberKey(CM_VoyageWLE::seqNumWorkOrder.name, false, false);
	endif;
	
	// Par 12711 Let dupes through so no crash if custom stuff up.
	dyna.endKeys(true);	
	
	_wles.copy(dyna);
	
	dyna.copy(self);
epilog	
	delete dyna;

end;</source>
        <Parameter name="_isStarboard" type="Boolean"/>
        <Parameter name="_wles" type="CM_WLEArray"/>
    </JadeMethod>
    <JadeMethod name="addAndSortTwinSequences" id="f4e93a01-d876-4ce0-a4a5-f7c2fbc99254">
        <lockReceiver/>
        <updating/>
        <source>addAndSortTwinSequences(_isStarboard : Boolean; _wles : CM_WLEArray) updating;
// -------------------------------------------
// Created 02 September 2005 by cnwdvb1
// -------------------------------------------
/*
09 October 2023		jlizm1	Initial creation TFS 59730 Kiosk Load Sequence
*/
vars

	dyna	: DynaDictionary;
	
begin

	create dyna transient;
	dyna.setMembership(CM_VoyageWLE);
	if _isStarboard then
		dyna.addMemberKey(CM_VoyageWLE::numSeqStarboardTwinCustom.name, false, false);
		dyna.addMemberKey(CM_VoyageWLE::seqNumWorkOrder.name, false, false);
	else
		dyna.addMemberKey(CM_VoyageWLE::numSeqPortTwinCustom.name, false, false);
		dyna.addMemberKey(CM_VoyageWLE::seqNumWorkOrder.name, false, false);
	endif;
	// Par 12711 Let dupes through so no crash if custom stuff up.
	dyna.endKeys(true);		
	
	_wles.copy(dyna);
	
	dyna.copy(self);
epilog	
	delete dyna;

end;</source>
        <Parameter name="_isStarboard" type="Boolean"/>
        <Parameter name="_wles" type="CM_WLEArray"/>
    </JadeMethod>
    <JadeMethod name="getFirstUnactionedWLE" id="91578fad-2566-4810-9b35-9ef4631839bf">
        <source>getFirstUnactionedWLE() : CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 October 2023			jlizm1	Initial creation TFS 59730 Kiosk Load Sequence

*/

vars
	wle : CM_WorkListEntry;
	
begin
	foreach wle in self do
		if wle.status = WLE_UNACTIONED then
			return wle;
		endif;
	endforeach;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="includesWLEfor" id="70d3d9fd-3cf1-4e24-a2eb-41c7b3184989">
        <source>includesWLEfor( _ti : CM_TrackedItem ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2018	jlgndl1	Initial creation	TFS 41240

*/

vars

	wle: CM_WorkListEntry;

begin

	foreach wle in self do
		if wle.myTrackedItem = _ti then
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
