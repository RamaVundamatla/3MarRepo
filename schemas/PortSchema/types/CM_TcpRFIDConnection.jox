    <JadeMethod name="writeJBUSCommand" id="71f38168-c5af-4141-87a5-7bf38e485c1e">
        <source>writeJBUSCommand(_slave,_command,_parameter : String);
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 May 2007	cnwer1	Initial creation - PAR#xxxx
///////////////////////////////////////////////////////
//NOT SUPPORTED IN UNICODE SYSTEM
// 11/3/16  cnwns1 PAR 36286 unicode version
//////////////////////////////////////////////////////

*/
vars
	slave,
	function,
	command,
	parameter, 
	crc16String,crc16,
	jbus: String;
	callbackMethod : String;

begin
	slave:=_slave;//#01.Character;
	
	command:=_command;//#0.Character &amp; #42.Character;
		

	if command = JBUS_READ_TAG.String then
		callbackMethod:=CM_TcpRFIDConnection::writeGetTagCB.name;
		function:=#03.Character;

	elseif command = JBUS_GET_STATUS.String then
		callbackMethod:=CM_TcpRFIDConnection::writeReaderStatusCB.name;
		function:=#03.Character;
	elseif command =  JBUS_READ_PREVIOUS_TAG.String then
		function:=#03.Character;
		callbackMethod:=CM_TcpRFIDConnection::writeGetPreviousTagCB.name;
	elseif command =  JBUS_RESET_READER.String then
		function:=#05.Character;
		callbackMethod:=CM_TcpRFIDConnection::writeResetReaderCB.name;
	elseif command = JBUS_GET_CURRENT_RECORD_LENGTH.String then
		function:=#03.Character;
		callbackMethod:=CM_TcpRFIDConnection::writeGetCurrentRecordLengthCB.name;
	elseif  command = JBUS_GET_CURRENT_RECORD.String then
		function:=#03.Character;
		callbackMethod:=CM_TcpRFIDConnection::writeGetCurrentRecordCB.name;
	elseif command = JBUS_BUZZ.String then
		function:=#05.Character;
	elseif command = GET_STATUS_MEMORY.String then
		function:=#03.Character;
		callbackMethod:=CM_TcpRFIDConnection::writeGetStatusMemoryCB.name;
	elseif command = JBUS_RESET_RECORD.String then
		function:=#05.Character;
		callbackMethod:=CM_TcpRFIDConnection::writeResetRecordCB.name;
	elseif command = JBUS_GET_NUM.String then
		function:=#03.Character;
		callbackMethod:=CM_TcpRFIDConnection::writeGetNumCB.name;
	elseif command = JBUS_CLEAR_LOG.String then
		function:=#10.Character;
		callbackMethod:=CM_TcpRFIDConnection::writeClearLogCB.name;
	elseif command = JBUS_GET_PREVIOUS_RECORD.String then
		function :=#03.Character;
		callbackMethod:=CM_TcpRFIDConnection::writeGetPrevRecordCB.name;
	elseif command = JBUS_GET_LOG_STATUS.String then
		function:=#03.Character;
		callbackMethod:=CM_TcpRFIDConnection::writeGetLogStatusCB.name;
	elseif command = JBUS_GET_MAX_RECORD.String then
		function:=#03.Character;
		callbackMethod:=CM_TcpRFIDConnection::writeGetMaxRecordLengthCB.name;
	endif;
	
	parameter:=_parameter;//#0.Character &amp; _parameter;//"14".String.cnEcHexValue.Character;
	
	jbus:= slave &amp; function &amp; command &amp; parameter;
	crc16String:= app.crc16(jbus);
	app.writeLog(method.name &amp; ":: crc16String = " &amp; crc16String.String,LogDEBUG);
	crc16:=crc16String[1:2].cnEcHexValue.Character &amp; crc16String[3:2].cnEcHexValue.Character;
	jbus:=jbus &amp; crc16;
	app.writeLog(jbus.Binary.String,LogDEBUG);
	self.writeBinaryAsynch(jbus.Binary,self,callbackMethod);


end;
</source>
        <Parameter name="_slave" type="String"/>
        <Parameter name="_command" type="String"/>
        <Parameter name="_parameter" type="String"/>
    </JadeMethod>
    <JadeMethod name="writeReaderStatusCB" id="f1d360e7-69c6-46b8-b542-7ece283e028b">
