    <JadeMethod name="doRejectTask" id="683ccff3-bc9c-4d51-a5de-91c0bde29bed">
        <source>doRejectTask();
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	objSet 		: CM_RTQueueTaskArray;
begin

	app.mousePointer	:=	Busy;
	create objSet transient;
	self.getSelectedTableObjects(objSet);
	if objSet.isEmpty then
		return;
	endif;
	self.clearErrors;
	app.myVehicleMountedIMVGuiAgent.doCancelTasks(objSet,self.allErrorMsgs);
	if self.checkErrors() then
		return;
	endif;
	self.setupDefaultButtons();
epilog
	app.mousePointer	:=	Idle;
	delete objSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTableItemSelect" id="1f97dd0a-f421-46ff-afaa-817d865a292f">
        <source>doTableItemSelect(_obj : Object input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 November 2006	cnwer1	Initial creation 

*/
vars
	hasCurrentTask : Boolean;
begin
	if _obj = null or not  _obj.isKindOf(CM_RTQueueEntry) then
		return;
	endif;

	hasCurrentTask:=app.myVehicleMountedIMVGuiAgent.hasCurrentTask(_obj.CM_RTQueueEntry);
	
	btnComplete.enabled:=hasCurrentTask;


epilog

end;</source>
        <Parameter name="_obj" type="Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSelectedTableObjects" id="8e54dcd7-55fa-4e83-8f1f-653ff71f9e89">
        <source>getSelectedTableObjects(_selectedObjects: CM_RTQueueTaskArray io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 October 2009	cnwer1	Initial creation PAR 20701

*/

vars
	theAcceptedRow : Integer;
	obj : Object;
begin
	theAcceptedRow:=0;
	//epr par 17955 26/9/08
	//nothing to check
	if self.tblJobs.rows =  self.tblJobs.fixedRows then 
		return;
	endif;
	theAcceptedRow:=self.tblJobs.row;
	/* it has been changed so that an IMV can only ever have 2 tasks at any one time
		they could be single or twin moves
		
	*/
	//if it is the fixed row then nothing is selected 
	if theAcceptedRow = self.tblJobs.fixedRows then
		//automatically select the first row 
		theAcceptedRow:=self.tblJobs.fixedRows+1;
	endif;
	
	obj := self.tblJobs.accessRow(theAcceptedRow).itemObject;
	
	if obj = null then
		app.msgBox("You must select an item in the list","Job",MsgBox_Exclamation_Mark_Icon);
	else
		
		app.myVehicleMountedIMVGuiAgent.getSelectedTasks(obj.CM_RTQueueEntry, _selectedObjects);
	
	endif;

epilog

end;</source>
        <Parameter name="_selectedObjects" type="MobileHandHeldThin::CM_RTQueueTaskArray" usage="io"/>
    </JadeMethod>
