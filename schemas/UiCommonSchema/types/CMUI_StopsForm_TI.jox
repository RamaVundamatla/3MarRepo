<GUIClass name="CMUI_StopsForm_TI" id="9c96a3fc-f2fd-4a33-895f-e47b0b4ec163">
    <superclass name="CMUI_StopsForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allTrackedItems" id="d72a9592-01e8-47b6-85bc-aef9089a6348">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
