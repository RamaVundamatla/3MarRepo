    <JadeMethod name="getGapDrawWidth" id="274e0912-da4c-4d0e-ba7e-8c40c986389f">
        <source>getGapDrawWidth(_lc : CM_GridColumn) : Real;
// ---------------------------------------------------------------------------
// Created:		27 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	ColWidth		: Integer = 24;

vars

	theColWidth : Real;
	gapWidth : Integer;
begin

	theColWidth	 := ColWidth * self.scaleFactor;

	gapWidth := _lc.getGapWidth();
	theColWidth := ((theColWidth / 7) * gapWidth).Integer;
	return theColWidth;
end;</source>
