    <JadeMethod name="doBrowseForFolder" id="eccc88ee-044e-4ffb-8479-39f6e0b97171">
        <source>doBrowseForFolder(_folderTextBox : TextBox input;
				  _onServer : Boolean);
/*

Purpose:			Browse for a folder, either on the server or client

Parameters:			_onServer set to true if a server folder is required

Return Value:		Selected folder, or null if none selected

Date		Who		Reason
18 Nov 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms

*/

vars
	ff				: FileFolder;
	newFolder		: String;
	
begin
	create ff transient;
	if _onServer then
		newFolder := ff.browseForServerFolder("Choose a server folder", _folderTextBox.text);
	else
		newFolder := ff.browseForFolder("Choose a folder", _folderTextBox.text);
	endif;

	if newFolder &lt;&gt; null then
		_folderTextBox.text := newFolder;
	endif;
	
epilog
	delete ff;
	
end;</source>
        <Parameter name="_folderTextBox" type="TextBox" usage="input"/>
        <Parameter name="_onServer" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeIsMonthlyRelease" id="f2e88bc2-00a2-4445-b5d2-33983e1d3aaf">
        <updating/>
        <source>doChangeIsMonthlyRelease() updating;
/*

Date		Who		Reason
26 May 2015	cnwer1	Initial creation TFS - 336 Monthly Releases

*/

vars

begin
	if self.chkMonthly.value then
		self.chkExtractAll.value := false;
	else
		if self.fullReleaseTargetDir &lt;&gt; null then
			self.txtTargetDir.text:=self.fullReleaseTargetDir;
			self.fullReleaseTargetDir:=null;
			self.txtTargetMonthly.text:=null;
			self.myReleaseExtractAgent.versionString:= app.myRoot.getVersionString();
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeMonthlyReleaseNum" id="7c05d81c-1062-471f-a6c1-dc9c2e272b04">
        <updating/>
        <source>doChangeMonthlyReleaseNum() updating;
/*

Date		Who		Reason
27 May 2015	cnwer1	Initial creation TFS 336 - Monthly Releases

*/

vars

begin
	if not self.chkMonthly.value then
		return;
	endif;

	if self.fullReleaseTargetDir = null then
		self.fullReleaseTargetDir:=self.txtTargetDir.text;
	endif;
	
	self.myReleaseExtractAgent.monthlyVersion:=self.txtTargetMonthly.text;
	
	self.txtTargetDir.text:=self.fullReleaseTargetDir &amp; "\Monthly\" &amp; self.myReleaseExtractAgent.versionString &amp; self.myReleaseExtractAgent.monthlyVersion;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doStartExtract" id="4eaadbb7-4053-445b-a856-c6dc377dbdaf">
        <source>doStartExtract();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Nov 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms
22 Aug 2013	cnwkpd1	CCMS SFW 1347 - JADE 7 Deployment
15 May 2019 jlgmd1	TFS 39667 - JMT - API Documentation

*/

vars

begin
	self.myReleaseExtractAgent.baseReleaseDirectory := self.txtBaseDir.text;
	self.myReleaseExtractAgent.targetReleaseDirectory := self.txtTargetDir.text;
	self.myReleaseExtractAgent.tempServerDirectory := self.txtTempDir.text;
	self.myReleaseExtractAgent.resultEmailAddress := self.txtEmail.text;
	self.myReleaseExtractAgent.baseJARIDirectory := self.txtBaseJARIDir.text;
	
	self.myReleaseExtractAgent.extractAllSchemas := self.chkExtractAll.value;
	self.myReleaseExtractAgent.extractEncryptedSchemas := self.chkExtractEnc.value;
	self.myReleaseExtractAgent.extractJRWFiles := self.chkExtractJRW.value;
	self.myReleaseExtractAgent.createJMTInstallFile := self.chkCreateInstall.value;
	self.myReleaseExtractAgent.createJARIRelease := self.chkCreateJARI.value;
	self.myReleaseExtractAgent.isMonthlyExtract:= self.chkMonthly.value; //epr TFS 336 - Monthly Releases 27/5/15
	self.myReleaseExtractAgent.extractWSDLChanges := self.chkCmpWsdlChanges.value;	// TFS 39667
	
	self.myReleaseExtractAgent.doReleaseExtract();
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="b7b8316d-5102-45b3-af87-e16dc3238950">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Nov 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms

*/

vars

begin
	self.setupForm();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="eb8dd008-99cd-4b15-9bf3-6bf6a4fc9c26">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Nov 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms
22 Aug 2013	cnwkpd1	CCMS SFW 1347 - JADE 7 Deployment
15 May 2019 jlgmd1	TFS 39667 - JMT - API Documentation

*/

vars

begin
	delete self.myReleaseExtractAgent;
	create self.myReleaseExtractAgent transient;
	
	self.myReleaseExtractAgent.setDefaultsForFullRelease();
	
	self.txtBaseDir.text := self.myReleaseExtractAgent.baseReleaseDirectory;
	self.txtTargetDir.text := self.myReleaseExtractAgent.targetReleaseDirectory;
	self.txtTempDir.text := self.myReleaseExtractAgent.tempServerDirectory;
	self.txtEmail.text := self.myReleaseExtractAgent.resultEmailAddress;
	self.txtBaseJARIDir.text := self.myReleaseExtractAgent.baseJARIDirectory;
	
	self.chkExtractAll.value := self.myReleaseExtractAgent.extractAllSchemas;
	self.chkExtractEnc.value := self.myReleaseExtractAgent.extractEncryptedSchemas;
	self.chkExtractJRW.value := self.myReleaseExtractAgent.extractJRWFiles;
	self.chkCreateInstall.value := self.myReleaseExtractAgent.createJMTInstallFile;
	self.chkCreateJARI.value := self.myReleaseExtractAgent.createJARIRelease;
	self.chkCmpWsdlChanges.value := self.myReleaseExtractAgent.extractWSDLChanges;
	
epilog

end;</source>
    </JadeMethod>
