//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theString : String;
begin

	_theTable.setValue(_theIndex, theString);

end;</source>
        <Parameter name="_theTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="_theProperty" type="String"/>
        <Parameter name="_theIndex" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="a53822fd-1265-4b62-b796-31f125be181d">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theXML : String;
	theGridArea : CMUI_GridArea;
begin
	return null;
	
	// do not use this. See initWithObject

	theXML := inheritMethod();

	theXML := theXML &amp; "&lt;" &amp; XML_FH &amp; "&gt;" &amp; self.xmlFlipH.Integer.String &amp; "&lt;/" &amp; XML_FH &amp; "&gt;";
	theXML := theXML &amp; "&lt;" &amp; XML_FV &amp; "&gt;" &amp; self.xmlFlipV.Integer.String &amp; "&lt;/" &amp; XML_FV &amp; "&gt;";
	return theXML;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="f3970bcb-7700-4133-9b27-8313b3962e4b">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	flipH, flipV, bigFont,hideL,hideT,hideM : Boolean;
	zoomScale : Real;
begin
	// par 11163 rs jan 2006
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
	endif;
	
	// do not use this. See initWithObject
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
 	
	// #### FLIP HORIZONTAL
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_FH);
 	flipH := false;
 	if theXMLValue &lt;&gt; null then
 		flipH := theXMLValue.Integer.Boolean;
 	endif;
 	
 	// #### FLIP VERTICAL
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_FV);
 	flipV := false;
 	if theXMLValue &lt;&gt; null then
 		flipV := theXMLValue.Integer.Boolean;
 	endif;


	self.xmlFlipH := flipH;
	self.xmlFlipV := flipV;
end;</source>
    </JadeMethod>
