    <JadeMethod name="trxSplitBreakBulkToNewID" id="3870a3d9-8e0a-4fa5-ae47-53fad7784928">
        <updating/>
        <source>trxSplitBreakBulkToNewID(  _sourceTi : CM_Cargo io;
							_newTiIds : StringArray; 
							_quantity : Integer; 
							_weight : Decimal;
							_operator : CM_Operator;
							_includeStops ,
							_includeToDo,
							_includeDamage,
							_includeHaz : Boolean;
							_passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk
01 Apr 2014	NDl	CCMS 1366

*/

vars

	tiId : String;
	newTi : CM_Cargo;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	app.myValUA.valBreakBulkSplitManual( _sourceTi, _newTiIds, _quantity, _weight, _passport );
	
	if _passport.hasErrors then
		return;
	endif;

	beginTransaction;
	
	foreach tiId in _newTiIds do

		if _passport.hasErrors then
			break;
		endif;
		
		app.myUtilityUA.utlSplitBreakBulkToNewID( _sourceTi, tiId, newTi, _quantity, _weight, _operator,_includeStops ,
							_includeToDo,
							_includeDamage,
							_includeHaz, null, _passport );
	
	endforeach;

epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_sourceTi" type="CM_Cargo" usage="io"/>
        <Parameter name="_newTiIds" type="StringArray"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_includeStops" type="Boolean"/>
        <Parameter name="_includeToDo" type="Boolean"/>
        <Parameter name="_includeDamage" type="Boolean"/>
        <Parameter name="_includeHaz" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSplitBreakBulkToNewIDAndLoc" id="9919f6c9-4e74-4da7-a758-48562717b9af">
        <updating/>
        <source>trxSplitBreakBulkToNewIDAndLoc(  _sourceTi : CM_Cargo io;
								_newTiId : String;
								_quantity : Integer;
								_weightOrVolume : Decimal;
								_newLocation : CM_LocationsController;
								_wle : CM_WorkListEntry input;
								_passport : CM_Passport input
								) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk
01 Apr 2014	NDl	CCMS 1366

*/

vars

	newTi : CM_Cargo;
	moveController	: CMIF_MoveController;
	rtQueEntry : CM_RTQueueEntry;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	beginTransaction;
	
	// create a new bulk or break bulk cargo item that matches the parent one, and populate with the 'quantity'/'weight' portion of the parents items.
	app.myUtilityUA.utlSplitBreakBulkToNewID( _sourceTi, _newTiId, newTi, _quantity, _weightOrVolume, _sourceTi.myOperator,true,true,true,true, null, _passport );
	
	if _passport.hasErrors then
		return;
	endif;
	

	//now move the new cargo item to its new position;
	create moveController transient;
	moveController.setMyTrackedItem( newTi);
	moveController.setMyToPrimaryLocation(_newLocation);
	moveController.setMoveMode(REAL_MODE);
	moveController.setQuantity(newTi.totalQuantity);
	moveController.setWeight(newTi.totalWeight);
	
	if _wle &lt;&gt; null then
		moveController.setMyWorkListEntry(_wle);
		if not _wle.allRTQueueEntries.isEmpty then
			rtQueEntry := _wle.allRTQueueEntries.last;
		endif;
		if rtQueEntry &lt;&gt; null then
			moveController.isRTMultiMove := true;
			moveController.myRTQueueEntry := rtQueEntry;
			moveController.isRTPickupTask := false;
			moveController.setJobForMove(_wle.job);
			moveController.isRadioTelemetryMove := true;
		endif;
	endif;
	
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	_passport.doDeferredUpdates();	
		
epilog

	delete moveController;							// 19/05/2015 cnwmh5 - Tranisent Leak

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_sourceTi" type="CM_Cargo" usage="io"/>
        <Parameter name="_newTiId" type="String"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weightOrVolume" type="Decimal"/>
        <Parameter name="_newLocation" type="CM_LocationsController"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSplitBreakBulkToNewIDs" id="e724dddc-9693-4589-81b0-13a260dd646a">
        <updating/>
        <source>trxSplitBreakBulkToNewIDs(	_sourceTi : CM_Cargo io;
							_newBaseId :String;
							_createManyCargo : Boolean;
							_suffix : String;
							_quantity : Integer;
							_weight : Decimal;
							_newOperator : CM_Operator;
							_includeStops ,
							_includeToDo,
							_includeDamage,
							_includeHaz : Boolean;
							_passport : CM_Passport input) updating;
/*

Date		Who		Reason
30 June 2016	cnwer1	Initial creation TFS 1500

*/

vars
	suffixLength : Integer;
	firstSuffix : Integer;
	lastSuffix : Integer;
	newTiIds : StringArray;
	tiId : String;
	newTi : CM_Cargo;
	terminal : CM_Terminal;
	suffixInt : Integer;
	quantity : Integer;
begin
	
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

		
	app.setContinueCMExceptions(false);
	
	self.raiseExceptionIfNull(_sourceTi,app.getErrorString(Cargo));
	
	//epr TFS 7524 24/10/17
	if _newBaseId = null then
		app.raiseCMException(Input_required_field_Id,null,null);
	endif;
	
	terminal:=_sourceTi.getMyTerminal();
	quantity:=_quantity;
	create newTiIds transient;
	if _sourceTi.myCargoType.isBulkByQuantity and _createManyCargo  then
			
		firstSuffix :=_suffix.Integer;
		lastSuffix := ((firstSuffix + _quantity) - 1);
		suffixLength := _suffix.length;
		quantity:=1;
		
		if lastSuffix.String.length &gt; suffixLength then
			suffixLength := lastSuffix.String.length;
		endif;
		
		foreach suffixInt in firstSuffix to lastSuffix do
			tiId := _newBaseId &amp; suffixInt.padLeadingWith('0',suffixLength);
			if not newTiIds.includes(tiId) and tiId &lt;&gt; null then
				
				newTiIds.add( tiId );
			endif;
		endforeach;
		
	else
		//creating 1 new cargo item
		if _newBaseId &lt;&gt; null then
			newTiIds.add(_newBaseId);
		endif;
	endif;

	
	app.myValUA.valBreakBulkSplitManual( _sourceTi, newTiIds, quantity, _weight, _passport );
	
	
	beginTransaction;
	
	foreach tiId in newTiIds do

		if _passport.hasErrors then
			break;
		endif;
		
		app.myUtilityUA.utlSplitBreakBulkToNewID( _sourceTi, tiId, newTi, quantity, _weight, _newOperator,_includeStops ,
							_includeToDo,
							_includeDamage,
							_includeHaz, null, _passport );
	
	endforeach;

epilog
	delete newTiIds;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_sourceTi" type="CM_Cargo" usage="io"/>
        <Parameter name="_newBaseId" type="String"/>
        <Parameter name="_createManyCargo" type="Boolean"/>
        <Parameter name="_suffix" type="String"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_newOperator" type="CM_Operator"/>
        <Parameter name="_includeStops" type="Boolean"/>
        <Parameter name="_includeToDo" type="Boolean"/>
        <Parameter name="_includeDamage" type="Boolean"/>
        <Parameter name="_includeHaz" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSplitWLEforRailAssign" id="75d1c4ef-dc98-4649-bb5a-31abda02e9e0">
        <updating/>
        <source>trxSplitWLEforRailAssign(	_originalWle : CM_WorkListEntry input;
							_splitWt : Decimal;
							_splitQty : Integer;
							_newWle : CM_WorkListEntry output;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2020	jlgndl1	Initial creation	TFS 50164

*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

		
	app.setContinueCMExceptions(false);
	
	beginTransaction;
		
	app.myUtilityUA.utlSplitWLEforRailAssign( _originalWle, _splitWt, _splitQty, _newWle, _passport );
	

epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_originalWle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_splitWt" type="Decimal"/>
        <Parameter name="_splitQty" type="Integer"/>
        <Parameter name="_newWle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxStageCargoForRelease" id="0f11627c-c9ec-46c9-bccd-a60cecc0b9ba">
        <updating/>
        <source>trxStageCargoForRelease(	_moveControl : CMIF_MoveController input;
							_reserveDetail : CM_ReserveDetail input;
							_unStage : Boolean;
							_passport : CM_Passport input
							) updating;
/*

Purpose:			STWR ONLY version			

Parameters:			

Return Value:		

Date		Who		Reason
13 Oct 2015	cnwndl1	Initial creation	Par 37033
20 Sep 2021 jlier1	TFS 51626
25 July 2022	jlier1 	TFS 53363
*/

vars

	ti : CM_TrackedItem;
	target : CM_LocationsController;
	tiSet : CM_TISet;
	br : CM_BulkRelease;
	wle,railWLE : CM_WorkListEntry;
	tbaTI : CM_TrackedItem;
	cmif : CMIF_MoveController;
	targetLocation : CM_LocationsController;
	yardWle : CM_YardWLE;
	skipAttributes : IntegerArray;	
	reason : String;
	moveTrx : CM_Move;
	assigningRel : Boolean;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	ti := _moveControl.myTrackedItem; // 10 Aug 2021	NDL	Moved up, found in daily unit tests
	
	//epr TFS 51626 29/7/21 - moving exceptions from the form to the trx layer
	if  not _unStage then
		if _reserveDetail &lt;&gt; null and _reserveDetail.isKindOf(CM_ReserveSelection) then
			//11 Jan 2017	NDL	TFS 3189/2876
			if _reserveDetail.myReserveHeader.isShipType then
				//testing against the reserve selection needs to ignore Voyage, Discharge Port and IMEX,
				//because these are unconditionally reset when assigned to the ship release during staging
				create skipAttributes transient;
				skipAttributes.add( YACriteriaType_Voyage );
				skipAttributes.add( YACriteriaType_DischargePort );
				skipAttributes.add( YACriteriaType_ImexStatus );
			endif;
			if not ti.testAgainstReserveSelection( _reserveDetail.CM_ReserveSelection, reason, false, skipAttributes ) then
				app.raiseCMException2(Warn_Request_Line_Match, reason, ti.id,null,null);
				return;
			endif;
		endif;
	endif;
	
	
	_passport.useTITransactionDeferUpdate := true;	// 05 Jul 2017	NDL	TFS 5238	
	_passport.useTIDictDeferUpdate := true;			// 05 Jul 2017	NDL	TFS 5238
	
	beginTransaction;
	
//	ti := _moveControl.myTrackedItem;	//moved up.
	target := _moveControl.myToPrimaryLocation;	
	
	//queued move, or instant move
	if ti.myPrimaryActualLocation &lt;&gt; target then
		app.myUtilityUA.utlUpdateMoveTrackedItem(_moveControl, _passport);
	endif;
		
	if app.myPassport.hasErrors then
		_passport.clearDeferUpdatesCollections();	// 05 Jul 2017	NDL	TFS 5238
		return;
	endif;
	
	ti := _moveControl.myTrackedItem;	// in case it has been split off
	moveTrx:=_moveControl.allMoveTransactions.first.CM_Move;
	
	if _unStage then
		create tiSet transient;
		tiSet.add( ti );
		
		if _reserveDetail &lt;&gt; null then
			foreach wle in ti.allWorklistEntries discreteLock do
				if wle.myRequest = null then
					continue;
				endif;
				if wle.status &lt;&gt; WLE_COMPLETED then
					continue;
				endif;
				if wle.job = null or not wle.job.isKindOf(CM_RailJob) then
					continue;
				endif;
				if wle.myRequest.myReserveDetail = _reserveDetail then
					railWLE:=wle;
					break;
				endif;
			endforeach;
		endif;
		
		if railWLE &lt;&gt; null then
			if app.myPassport.noErrors then
				if railWLE &lt;&gt; null then
					create cmif transient;
					cmif.setMyWorkListEntry(railWLE);
					cmif.setMyTrackedItem(railWLE.myTrackedItem);
					cmif.setMoveMode(PLANNING_MODE);
					railWLE.rebuildStatus();
					app.myUtilityUA.utlUpdateWLEUnassignTI(cmif, _passport);

				endif;
			endif;
		else
			app.myUtilityUA.utlUpdateUnassignRelease( tiSet, _passport);
		endif;
		
		
	else
		br := _reserveDetail.myReserveHeader;
		if moveTrx &lt;&gt; null and br &lt;&gt; null and not br.allTrackedItemsAssigned.includes(ti) then
			//assigning from the machine
			assigningRel:=true;
		endif;
	
		app.myUtilityUA.utlAddToReserveDetail(_reserveDetail, ti, _passport);
		
		// 05 Jul 2017	NDL	TFS 5238
		if app.myPassport.hasErrors then
			_passport.clearDeferUpdatesCollections();	
			return;
		endif;
		
		if assigningRel then
			//flag that the machine assigned to release in this trx - and not the user in JMT
			moveTrx.setExtraData(TrnsExtraDataAssignedRel,_reserveDetail.getOidAsString);
		endif;
		
		
		//10 Jan 2016	NDL	TFS 3189/2876
		
		if br &lt;&gt; null then
			if br.isShipType then
				//set the voyage and discharge port on assigned cargo item to the values on the release request and set the imex to export
				ti.setShipRelAssignedValues( _reserveDetail, _passport );
			
			elseif br.isRailType then
				//11 Jan 2017	NDL	TFS 3192/2877
				// see if we can find a WLE that is assigned to a Wagon for our release, that this ti matches AND
				// that has not yet got a TI associated with it (or has a 'tba' assigned to it) and do the needfull,
				// i.e. magically associate the newly 'staged/assigned' rail release cargo, with the 'director' tasks
				// that might have already been created and assigned to wagons for this reserve detail.
				
				wle := br.getRailWleToAssignTiTo( _reserveDetail, ti );
				if wle &lt;&gt; null then
				
					targetLocation := wle.getTargetLocation;
					if targetLocation = null then
						// it will be if its only assigned and not queued
						if wle.isKindOf(CM_YardWLE) then
							yardWle := wle.CM_YardWLE;
						endif;
						if yardWle &lt;&gt; null and not yardWle.allLocationControllers.isEmpty then
							targetLocation := yardWle.allLocationControllers.first;
						endif;
					endif;
					
					if targetLocation &lt;&gt; null then
					
						tbaTI := wle.myTrackedItem; //get a reference to this sucker, so we can delete the tba if it has one
						wle.setMyTrackedItem( ti );
						
						create cmif transient;
						cmif.setMyWorkListEntry(wle);
						cmif.setMyTrackedItem(ti);
						cmif.setMyToPrimaryLocation(targetLocation);
						if wle.allRTQueueEntries.isEmpty then
							cmif.setMoveMode(PLANNING_MODE);
						else
							cmif.setMoveMode(QUEUE_MODE);
						endif;
						app.myUtilityUA.utlUpdateWLEAssignTI(cmif, _passport);
						
						if tbaTI &lt;&gt; null then
							tbaTI.erase(NORMAL_ERASE);
						endif;
					
					endif;
					
				endif;
			
			endif;
			
		endif;
		
	endif;
	
	_passport.doDeferredUpdates();	// 05 Jul 2017	NDL	TFS 5238
	
epilog
	delete skipAttributes;
	delete tiSet;
	delete cmif;
	self.finaliseActivityWithPassport(_passport);
	
end;
</source>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="input"/>
        <Parameter name="_unStage" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxStageMultiCargoForRelease" id="33688fb0-1c85-4e80-b3fc-7467b6f60962">
        <updating/>
        <source>trxStageMultiCargoForRelease(	_tis : CM_TISet;
																_reserveDetail : CM_ReserveDetail input;
																_targetLocation : CM_LocationsController;
																_passport : CM_Passport input
															 ) updating;
/*

Purpose:			STWR ONLY version			

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2018	jlgrh7		Initial creation	TFS38573  STWR - "Stage all" function in staging app takes a long time processing items

*/

vars
	skipAttributes						: IntegerArray;	
	ti : CM_TrackedItem;
	reason 										: String;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	//epr TFS 51626 29/7/21 - moving exceptions from the form to the trx layer
	if  _reserveDetail &lt;&gt; null and _reserveDetail.isKindOf(CM_ReserveSelection) then
		//11 Jan 2017	NDL	TFS 3189/2876
			if _reserveDetail.myReserveHeader.isShipType then
				//testing against the reserve selection needs to ignore Voyage, Discharge Port and IMEX,
				//because these are unconditionally reset when assigned to the ship release during staging
				create skipAttributes transient;
				skipAttributes.add( YACriteriaType_Voyage );
				skipAttributes.add( YACriteriaType_DischargePort );
				skipAttributes.add( YACriteriaType_ImexStatus );
			endif;
		
		foreach ti in _tis discreteLock do
			if not ti.testAgainstReserveSelection( _reserveDetail.CM_ReserveSelection, reason, false, skipAttributes ) then
				 app.raiseCMException2(Warn_Request_Line_Match, reason, ti.id,null,null);
				 return;
			endif;
		endforeach;	
					
	endif;
	
	
	_passport.useTITransactionDeferUpdate := true;	// 05 Jul 2017	NDL	TFS 5238	
	_passport.useTIDictDeferUpdate := true;			// 05 Jul 2017	NDL	TFS 5238
	
	beginTransaction;
	app.myUtilityUA.utlStageMultiCargoForRelease(_tis,
																									_reserveDetail,
																									_targetLocation,
																									_passport ) ;
				
	if app.myPassport.hasErrors then
		_passport.clearDeferUpdatesCollections();	// 05 Jul 2017	NDL	TFS 5238
	else
		_passport.doDeferredUpdates();	// 05 Jul 2017	NDL	TFS 5238
	endif;

epilog
	delete skipAttributes;
	self.finaliseActivityWithPassport(_passport);
	
end;
</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="input"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSwapMachineTandemTaskState" id="c806b222-a376-46d0-99bf-2cb6daafe414">
        <updating/>
        <source>trxSwapMachineTandemTaskState(_machine : CM_Machine input;_rtTask, _secondTask : CM_RTQueueTask input;_passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2019		jlgns1	Initial creation
16/10/2019	JLGNS1	TFS47394: JMT - Tandem Lift moves - Order of selecting and set down items using Vehicle App
09/01/2020	jlgka1	TFS 48161: Web Apps - Swap slider in tandem mode not functioning.
*/

vars
	tasks : CM_RTQueueTaskArray;	
begin
	// Always initialize the activity first.
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers.
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	self.raiseExceptionIfNull(_machine,app.getErrorString(Machine));
	self.raiseExceptionIfNull(_rtTask,"Queue Task");	
	self.raiseExceptionIfNull(_secondTask,"Tandem Task");	


	beginTransaction;
	
	app.myUtilityUA.utlSwapMachineTandemTasks(_machine ,_rtTask, _secondTask ,_passport);
	
	if _rtTask.myEntry.myJob.isRelease 
	and _rtTask.myEntry.myJob.isRoadJob 
	and _secondTask.myEntry.myJob.isRelease 
	and _secondTask.myEntry.myJob.isRoadJob  then	
		app.myUtilityUA.utlSwapTruckTasks(_rtTask.myEntry.myWorkListEntry,_secondTask.myEntry.myWorkListEntry,_passport);
	else		
		app.myUtilityUA.utlSwapTandemTasksTargetLoc(_rtTask, _secondTask);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	create tasks transient;
	
	_machine.allCurrentQueueTasks.copy(tasks);
	
	app.myUtilityUA.utlMachineSetTaskStates(_machine,tasks,_passport);
	
	
epilog
	
	delete tasks;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_secondTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
