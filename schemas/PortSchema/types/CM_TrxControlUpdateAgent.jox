    <JadeMethod name="trxUpdateSourceLocation" id="02ba2afe-4105-4568-8f0d-87af2ce457f6">
        <updating/>
        <source>trxUpdateSourceLocation(pProxySource:CM_SourceLocation; _applyFscToChildren: Boolean; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 11 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	realSource	: CM_SourceLocation;
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateSourceLocation(pProxySource, realSource, _passport);

	if _passport.hasErrors() then
		return;
	endif;
	
	if not _applyFscToChildren then
		return;
	endif;

	if not realSource.isSourceLocation() then	// Here can be Loading Contractor or Logging Contractor. See MCUI_CodesMaintTree form
		return;
	endif;
	
	// applying FSC value for all children - stands
	app.myUtilityUA.utlUpdateSourceLocationFSC(realSource, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pProxySource" type="CM_SourceLocation"/>
        <Parameter name="_applyFscToChildren" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
