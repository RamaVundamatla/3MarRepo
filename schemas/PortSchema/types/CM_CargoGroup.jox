    <JadeMethod name="totalQuantity" id="bb082597-d9da-4799-9225-f31ef727f294">
        <methodInvocation>mapping</methodInvocation>
        <source>totalQuantity(set: Boolean; _value: Integer io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2015	cnwndl1	Initial creation	Par 36338
19 Nov 2025 navhl20 Bug MTN-36492: TPA - Overall System Slowness
*/

vars
	iter 			: Iterator;
	ti 				: CM_TrackedItem;
	runningTotal 	: Integer; 
	detail 			: CM_CargoGroupDetail;
begin

	if set then
		_value := NULL_QUANTITY;
	else
		if app.myPassport.isInEdiVerifyMode or app.myPassport.isInEdiDBLoadMode then		//19.11.2025 navhl20 #36492
			return;
		endif;
		
		// ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1
		foreach detail in self.allCargoGroupDetails discreteLock do
			if detail.myVoyage &lt;&gt; null then
				runningTotal := runningTotal + detail.totalQuantity.max(1);
			endif;
		endforeach;
		_value := runningTotal;
		if runningTotal &gt; 0 then
			return;
		endif;

		iter := self.allAssignedTrackedItems.createIterator;
		while iter.next( ti ) do
			runningTotal := runningTotal + ti.totalQuantity.max(1);
		endwhile;
		_value := runningTotal;
	endif;
	

epilog

	delete iter;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="totalVolume" id="d4cd0548-41d8-4043-8c39-61ab60115c2b">
        <methodInvocation>mapping</methodInvocation>
        <source>totalVolume(set: Boolean; _value: Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2015	cnwndl1	Initial creation	Par 36338
19 Nov 2025 navhl20 Bug MTN-36492: TPA - Overall System Slowness
*/

vars
	iter 			: Iterator;
	ti 				: CM_TrackedItem;
	runningTotal 	: Decimal[16,4]; 
	detail 			: CM_CargoGroupDetail;
begin

	if set then
		_value := NULL_VOLUME;
	else
		
		if app.myPassport.isInEdiVerifyMode or app.myPassport.isInEdiDBLoadMode then			//19.11.2025 navhl20 #36492
			return;
		endif;
		
		// ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1
		foreach detail in self.allCargoGroupDetails discreteLock do
			if detail.myVoyage &lt;&gt; null then
				runningTotal := runningTotal + detail.totalVolume; // ### TFS BUG 62187 14FEB2024 NAVAB1 .max(1);
			endif;
		endforeach;
		_value := runningTotal;
		if runningTotal &gt; 0 then
			return;
		endif;

		iter := self.allAssignedTrackedItems.createIterator;
		while iter.next( ti ) do
			runningTotal := runningTotal + ti.totalVolume;
		endwhile;
		_value := runningTotal;
	endif;
	

epilog

	delete iter;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="totalWeight" id="abacfbc8-8555-4780-8d12-cbe708557a2a">
        <methodInvocation>mapping</methodInvocation>
        <source>totalWeight(set: Boolean; _value: Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2015	cnwndl1	Initial creation	Par 36338
19 Nov 2025 navhl20 Bug MTN-36492: TPA - Overall System Slowness
*/

vars
	iter 			: Iterator;
	ti 				: CM_TrackedItem;
	runningTotal 	: Decimal[16,4]; 
	detail 			: CM_CargoGroupDetail;
begin

	if set then
		_value := NULL_WEIGHT;
	else
		
		if app.myPassport.isInEdiVerifyMode or app.myPassport.isInEdiDBLoadMode then		//19.11.2025 navhl20 #36492
			return;
		endif;
		
		// ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1
		foreach detail in self.allCargoGroupDetails discreteLock do
			if detail.myVoyage &lt;&gt; null then
				runningTotal := runningTotal + detail.totalWeight;
			endif;
		endforeach;
		_value := runningTotal;
		if runningTotal &gt; 0 then
			return;
		endif;
		
		iter := self.allAssignedTrackedItems.createIterator;
		while iter.next( ti ) do
			runningTotal := runningTotal + ti.totalWeight;
		endwhile;
		_value := runningTotal;
	endif;
	

epilog

	delete iter;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateCollections" id="37da3631-6a44-4db7-b1fd-e8620dde3526">
        <updating/>
        <source>updateCollections() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod();
	
	self.nullAllVoyageRefs();
	self.nullAllOperatorTerminalRefs();
	
	self.myNotifiedTerminal := null;
	self.myNotifiedVoyage := null;
	self.myTbaTerminal := null;
	self.myRRPTerminal := null;	//13 Mar 2020	NDL	TFS 47004
	self.myOnsiteTerminal := null;
	self.myOffsiteTerminal := null;
	
	if self.state = TI_STATE_DELETED then
		self.myCargoGroupTerminal := null;
		self.myDeletedTerminal := self.myTerminal;
	elseif ( self.myTerminal &lt;&gt; null and self.myCargoGroupTerminal &lt;&gt; self.myTerminal ) then
		self.myCargoGroupTerminal := self.myTerminal;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="upgradeFromNCG" id="c4e1526c-80c9-4695-8f04-0614462bcb70">
        <updating/>
        <source>upgradeFromNCG( _ncg : CM_NotifiedCargoGroup ): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	cargoId : String;
	returnValue : Boolean;
	iter : Iterator;
	obj : Object;

begin

	self.defaultLocation := _ncg.defaultLocation;
	self.remarks := _ncg.remarks;
	
	self.allPreAssignedCargoIds.clear();
	self.allPreAssignedCargoIdsDict.purge();
	
	if not _ncg.allPreAssignedCargoIdsDict.isEmpty then
		iter := _ncg.allPreAssignedCargoIdsDict.createIterator;
		while iter.next( obj ) do
			cargoId := iter.getCurrentKey( 1 ).String;
			if cargoId &lt;&gt; null then
				self.allPreAssignedCargoIds.add( cargoId );
				self.allPreAssignedCargoIdsDict.putAtKey(cargoId, self); // the object doesn't matter, just want a keyed dict.
			endif;
		endwhile;
		delete iter;
	endif;
	
	self.setMyCargoGroupAssignment( _ncg.myCargoGroupAssignment );
	
	returnValue := true;

epilog

	return returnValue;

end;</source>
        <Parameter name="_ncg" type="CM_NotifiedCargoGroup"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="0fbc1fec-66d4-4768-a02f-51d87bec6585">
        <source>validateDelete(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2015	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod(_passport);
	
	if self.hasOnsiteAssignedCargo
	or self.hasPrenotifiedAssignedCargo	//15 Feb 2016	NDL	Par 37544
	then
		app.raiseCMException(Cargo_group_not_delet_while_as, null, null);
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForAssignMove" id="5a5c99c4-34ad-4e00-9d7e-bea8891f84d9">
        <source>validateForAssignMove(	_cga : CM_CargoGroupAssignment input;
						_selectedCargo : CM_TrackedItem input;
						_nextCargoGroup : CM_CargoGroup output;
						_newLocation :CM_LocationsController output; 
						_onlyCompleteGroup : Boolean output;
						_completeGroup : Boolean output;
						_clearCargoGroup : Boolean output;
						_clearLocation : Boolean output) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2021	jlier1	Initial creation 51683
 
*/

vars
	location :CM_LocationsController;
	isPreAssigned : Boolean;
	isSelectable,
	isLastSelectableTI : Boolean;
	strArray : StringArray;
	cgNewTotalWeight : Decimal [16,4];	
begin
	_onlyCompleteGroup:=false;
	_completeGroup:=false;
	_clearCargoGroup:=false;
	_clearLocation:=false;
	if _cga = null then
		app.raiseCMException(Input_requir_cargo_group_assig,null,null);
		return null;
	endif;
	
	isPreAssigned := self.isPreAssigned;
	isSelectable := self.isSelectable;
	location:=_newLocation;
	create strArray transient;
	if isPreAssigned then
		if self.getPreAssignedToScan( strArray ) = 1
		and _selectedCargo.id = strArray.first
		then
			_completeGroup:=true;
			return app.getErrorString2(Last_cargo_item, _selectedCargo.id, self.id);
		endif;
		
	elseif isSelectable then
		if _cga.getNotYetScanned( strArray, false ) = 1
		and _selectedCargo.id = strArray.first
		then
		
			isLastSelectableTI := true;
			_completeGroup:=true;
			return app.getErrorString3(Last_avail_item_been_scann_com, _cga.id, self.id, _cga.id);
		endif;		
	endif;
	
	if isSelectable and not isLastSelectableTI then
			cgNewTotalWeight := self.totalWeight + _selectedCargo.totalWeight;
			if cgNewTotalWeight &gt; self.maxWeight and self.maxWeight &lt;&gt; null then
				//current cargo group would exceed max weight, auto complete it and auto select the next available in order
				_nextCargoGroup := _cga.getNextCargoGroup( self, _selectedCargo );
				//if don't get exceptions and newCargoGroup is different 
				//change the cargo group on the form
				if _nextCargoGroup = null then
					//if  exceptions are returned need to  call cargo group complete
					_onlyCompleteGroup:=true;
					_clearCargoGroup:=true;
					return app.getErrorString1(Weigh_would_excee_cargo_group_,self.id);
					
				else
					_newLocation := _nextCargoGroup.getLastOnsiteLocation;
				
					if _newLocation &lt;&gt; null then	
						_completeGroup:=true;
						if _newLocation &lt;&gt; location then
							//change waring to  Excee_max_weigh_chg_Loc											
							return app.getErrorString4( Excee_max_weigh_chg_Loc, self.id,_selectedCargo.id, _nextCargoGroup.id, _newLocation.getFullId);
						else
							return app.getErrorString3( Have_excee_maxim_weigh_been_co, self.id, _selectedCargo.id, _nextCargoGroup.id);
						endif;
					else				
						_onlyCompleteGroup:=true;
						_clearLocation:=true;
						//call cargo group complete					
						return app.getErrorString3(Excee_max_weigh_needs_Loc,self.id,_selectedCargo.id, _nextCargoGroup.id );
					endif;
				endif;
			endif;
	endif;
	
	_completeGroup:=false;
	
epilog
	delete strArray;
end;</source>
        <Parameter name="_cga" type="CM_CargoGroupAssignment" usage="input"/>
        <Parameter name="_selectedCargo" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_nextCargoGroup" type="CM_CargoGroup" usage="output"/>
        <Parameter name="_newLocation" type="CM_LocationsController" usage="output"/>
        <Parameter name="_onlyCompleteGroup" type="Boolean" usage="output"/>
        <Parameter name="_completeGroup" type="Boolean" usage="output"/>
        <Parameter name="_clearCargoGroup" type="Boolean" usage="output"/>
        <Parameter name="_clearLocation" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForAssignment" id="8942b7e5-b2ab-4519-b6e7-d0b19cf0d753">
        <source>validateForAssignment( _passport : CM_Passport );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2018	jlgndl1	Initial creation	TFS 39186
12 Nov 2019	NDl	TFS 47298
*/

vars

begin

	if self.getMyCargoGroupAssignment.myTerminal = null then
		app.raiseCMException( Select_Terminal, self.id, null );
		return;
	endif;

	if self.myCargoType = null then
		app.raiseCMException1( Requires_cargo_type, self.id, null, null );
		return;
	elseif not self.myCargoType.isCargoGroup then
		app.raiseCMException2( Cargo_type_selec_not_defin_car, self.myCargoType.description, self.id, null, null );
		return;
	endif;
	
	if id = null then
		app.raiseCMException( ERR_INVALID_TI_ID, null, null );
		return;
	endif;
	
	if self.myOperator = null then
		app.raiseCMException( Please_select_operator, null, null );
		return;
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateForComplete" id="f0d9543b-1fcd-4ecf-87e2-e7b1b1c1e1eb">
        <source>validateForComplete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/08/2015	cnwndl1	Initial creation	Par 36608
20/02/2018	jlgdap1	TFS 37096 Suppress maximum weight warning when a cargo group that's part of a preassigned notified group is completed
*/

vars

	measureType : CM_MeasurementType;

begin
	
	if self.totalWeight &gt; self.maxWeight then
	//	if _notifiedGroup = null or (_notifiedGroup &lt;&gt; null and _notifiedGroup.allPreAssignedCargoIdsDict.isEmpty) then		// TFS 37096
		if not self.isPreAssigned then	//02 Oct 2018	NDL	TFS 39186
			if self.maxWeight = 0 then
				app.raiseCMWarning2(Total_weight_exceed_maximu_wei, self.getDefaultMeasureTotalWeight(), "0", null, null, null); 
			else
				app.raiseCMWarning2(Total_weight_exceed_maximu_wei, self.getDefaultMeasureTotalWeight(), self.getMeasureMaxWeightUnit, null, null, null); 
			endif;
		endif;																												// TFS 37096
	endif;

	if self.totalWeight &lt; self.minWeight then
		if self.totalWeight = 0 then
			app.raiseCMWarning2(Total_weigh_less_than_minim_we, "0", self.getMeasureMinWeightUnit, null, null, null);
		else
			app.raiseCMWarning2(Total_weigh_less_than_minim_we, self.getDefaultMeasureTotalWeight(), self.getMeasureMinWeightUnit, null, null, null);
		endif;
	endif;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateId" id="6c5190c1-7129-4809-90e9-cccdbbe92067">
        <source>validateId(pControl: CMIF_TIUpdateController) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation	Par 36338
28/06/2022 navds20 TFS 53760 MTN - DuplicateItem not Translatable
*/

vars

	existingCG : CM_CargoGroup;
	realCG : CM_CargoGroup;
	tmpId : String;

begin

	inheritMethod(pControl);
	
	tmpId := self.id.toUpper.trimBlanks;
	
	existingCG := self.myTerminal.getCargoGroupItem( tmpId );										//14.Nov.2023 navsp1 TFS 61127
	//existingCG := self.myTerminal.getCargoGroupItemForOperator( tmpId, self.operatorCode, null);	//14.Nov.2023 navsp1 TFS 61127
	
	if self.isTransient then
		realCG := self.pxyGetRealObject();
	else
		realCG := self;
	endif;
	
	if existingCG &lt;&gt; null and existingCG.id &lt;&gt; tmpId then
		existingCG := null;
	endif;
	
	if existingCG &lt;&gt; null and existingCG &lt;&gt; realCG then
		//app.raiseCMException2(DuplicateItem, tmpId, app.getErrorString(Cargo_group), null, null);  //28/06/2022 navds20 TFS 53760
		app.raiseCMException1(Already_exists_cargo_group, tmpId, null, null); //28/06/2022 navds20 TFS 53760
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateOperator" id="a40ee233-3535-4f4a-83e1-01058c658c1b">
        <updating/>
        <source>validateOperator(pControl: CMIF_TIUpdateController; _passport: CM_Passport input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/03/2024	navkc1 Defect 63095: EUP - COO - Approve - Cargo Group and operator not working correctly
25/06/2024	navmd1	TFS 64797 Allow updating the operator when no cargo is associated to the group
24/06/2025	jlizm1	MTN 34778 Add terminal as key for operator cargo group collection

*/

vars
	operator 	: CM_Operator;
	realCG		: CM_CargoGroup;
	hasTIs		: Boolean;
	exisitingCG	: CM_CargoGroup;
	
begin
	inheritMethod(pControl, _passport);
	
	operator := self.myOperator;
	if operator = null then
		// this will have raised errors in inherit method
		return;
	endif;

	if self.isTransient() then
		realCG := self.pxyGetRealObject();
	endif;
	
	exisitingCG := operator.allCargoGroupsByTerminal.getAtKey(self.myTerminal, self.id);
	if exisitingCG &lt;&gt; null then
		if realCG = null or exisitingCG &lt;&gt; realCG then
			app.raiseCMException2(Already_exists_cg_operator, self.id, operator.code, null, null);
		endif;
	endif;
	
	if realCG = null then
		return;
	endif;
	
	hasTIs := realCG.allAssignedTrackedItems.size &gt; 0;
	
	if not realCG.allOperators.includes(operator) and hasTIs then
		if app.isCargoGroupEnabled then
			app.raiseCMException2(Cargo_assoc_with_cargo_group_m, operator.code, realCG.getAllOperatorsCode(), ETRow_Operator, null);
		endif;
	endif;
	
	if operator &lt;&gt; realCG.myOperator then
		CMIF_TrxActionCargoGroupUpdOp@createAction(null, realCG, app.myPassport);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateWeight" id="a56bfb60-7eef-419b-b2c8-b7b58e1a59b1">
        <updating/>
        <source>validateWeight(pControl: CMIF_TIUpdateController; _passport: CM_Passport input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin

	self.validateWeightIncluding(null);
	
	//don't do any of the inherited stuff...
