    <JadeMethod name="addToolbarControls" id="c1c0174f-298f-46dc-bec7-c358583a6771">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:     09 September 2010 by cnwcs5
// Purpose:     Hide toolbar buttons that were added in the superclass method
//				which we don't want.
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	toolbar			: CMUI_Toolbar;
begin
	inheritMethod();

	toolbar := self.frmToolbar;
		
	self.btnShowLoadFile.visible	:= false;
	self.btnDeleteTV.visible 		:= false;
	self.btnExtractNew.visible		:= false;
	self.btnUserTypes.visible		:= false;
	self.btnDeleteEDITi.visible		:= false;
	
	toolbar.positionToolbarControls();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
