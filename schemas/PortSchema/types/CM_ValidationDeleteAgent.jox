    <JadeMethod name="aValSample" id="d2a46b96-dc57-415d-bcc3-8d5d8033347c">
        <source>aValSample(_obj : CM_TrxTestObject io; _controller : CM_TrxTestController);
// ---------------------------------------------------------------------------
// Created:     03 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNull(_obj, 'Test Object');

	if not self.exclusiveLockObjectToDelete(_obj) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;

	_obj.validateForDelete(_controller);

end;</source>
        <Parameter name="_obj" type="CM_TrxTestObject" usage="io"/>
        <Parameter name="_controller" type="CM_TrxTestController"/>
    </JadeMethod>
    <JadeMethod name="raiseExceptionIfNull" id="d4371bb9-1258-49d0-aad9-d7a918b3d2f9">
        <source>raiseExceptionIfNull(pObject: Object; pErrStr: String) protected;
// ---------------------------------------------------------------------------
// Created:     20 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pObject = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_DEL_NULLOBJECT, pErrStr, null, null);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pErrStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="valArchivedVoyage" id="b73b983a-0218-408e-aa16-474966d0f6ef">
        <source>valArchivedVoyage(_voyage : CM_Voyage);
// -------------------------------------------
// Created 24 August 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if not _voyage.archived then
		app.raiseCMException1(CannotPurgeVoyage, 'Voyage ' &amp; _voyage.code &amp; ' Is Not Archived', null, null);
		return;
	endif;

	_voyage.validateForGarbageCollection();


end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
