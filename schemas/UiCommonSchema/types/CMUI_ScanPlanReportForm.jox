    <JadeMethod name="printProfileSummaryReport" id="85201d32-56bb-4341-93a1-369668064f4d">
        <source>printProfileSummaryReport() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2020	jlgndl1	Initial creation - essentially copied from SHP_VoyageAreaForm2 but using the locally selected bays to derive the holds.

*/

vars
	filter				: CMQF_VoyageSummary;
	qryReport			: CM_QryReport;
	jrwManager			: JadeReportWriterManager;
	jrwReport			: JadeReportWriterReport;
	jadeReport			: JadeReport;
	orderedByOption,
	actualProposedOption,
	loadDischargeOption,
	jrwFileName			: String;
	selectedBays : CM_BayVoyageByIdDict;
	bay : CM_BayVoyage;
begin
	//get the qryReport definition object, create the filter object and tell it to do its thing
	if self.optSlotLoad.value then	//self.displayMode = ShpDisplayMode_ColCodeLoad then
		qryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepVoyColourCodeByLoad);
		orderedByOption := CMQF_VoyageSummary.ORDERED_BY_LOADPORT;
		actualProposedOption := CMQF_VoyageSummary.MODE_OPT_PROPOSED;
		loadDischargeOption := CMQF_VoyageSummary.MODE_OPT_LOAD;
	elseif self.optSlotDisc.value then	//if self.displayMode = ShpDisplayMode_ColCodeDisch then
		qryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepVoyColourCodeByDischarge);
		orderedByOption := CMQF_VoyageSummary.ORDERED_BY_DISCHARGEPORT;
		actualProposedOption := CMQF_VoyageSummary.MODE_OPT_PROPOSED;
		loadDischargeOption := CMQF_VoyageSummary.MODE_OPT_DISCHARGE;
	else
		qryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepVoyageProfile);
		orderedByOption := CMQF_VoyageSummary.ORDERED_BY_DISCHARGEPORT;
		actualProposedOption := CMQF_VoyageSummary.MODE_OPT_ACTUAL;
	endif;

	if qryReport = null then
		app.msgBox('The system failed to retreive the profile report from the database.', 'Could not find report', MsgBox_Exclamation_Mark_Icon);		
		return true;
	endif;
	
	filter := qryReport.createFilter().CMQF_VoyageSummary;
	filter.initialize();
	filter.actualProposedOption := actualProposedOption;
	filter.loadDischargeOption := loadDischargeOption;
	
	create selectedBays transient;
	self.mulBays.getSelected( selectedBays );
	foreach bay in selectedBays where bay.myHold &lt;&gt; null do
		filter.allHolds.addNoDuplicates( bay.myHold, false );
	endforeach;

	filter.allHolds.removeInvalidObjects();	
	filter.orderKey1 := orderedByOption;
	
	filter.setMyVoyage( self.mySelectedVoyage );
	qryReport.doFilter(filter, app.myPassport);
	
	jrwManager := app.createReportWriterManager();
	
	jrwFileName := qryReport.jrwReportName.first;
	jrwReport := jrwManager.getReport(jrwFileName);
	
	app.printer.printPreview := false;
	create jadeReport transient;
	jadeReport.description := jrwReport.name;
	app.printer.setReport(jadeReport);
	jrwReport.run();
	if self.chkPreview.value then
		app.printPreview(jadeReport, true);
	else
		app.printer.printReport( jadeReport );
	endif;

	abortTransaction;		// to clear any locks held by the report writer
	
epilog

	return true;
	
	delete jrwManager;
	delete jrwReport;
	delete filter;
	delete selectedBays;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectVoyage" id="b79d86b1-8546-4702-9422-0008437d0ea4">
        <updating/>
        <source>selectVoyage()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	index : Integer;

begin

	self.mulBays.setSelected( null );
	self.mulBays.setAvailable( null, true );

	index := self.cmbVoyage.listIndex;
	if index &gt; 0 then
		self.mySelectedVoyage := self.cmbVoyage.itemObject[index].CM_Voyage;
		self.mulBays.setupControl( self.mulBays.caption, self.mySelectedVoyage.myCellularVoyageStructure.allBayVoyagesById, CMUI_ScanPlanReportForm::displayBay.name);
	else
		self.mySelectedVoyage := null;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromCaller" id="8173fe87-b3fc-4004-94d2-baee9e287a96">
        <updating/>
        <source>setFromCaller(	_caller : CM_BaseForm;
				_voyage : CM_Voyage;
				_selectedBays : CM_BayVoyageByIdDict;
				_displayMode : Integer;
				_colourMode : Integer
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

begin

	self.setParentForm( _caller );

	if _voyage &lt;&gt; null then
		self.mySelectedVoyage := _voyage;
		
		if _selectedBays &lt;&gt; null and not _selectedBays.isEmpty then
			_selectedBays.copy( self.preSelectedBays );
		endif;
		
		self.preDisplayMode := _displayMode;
		self.preColourMode := _colourMode;
	
	endif;
	
	

epilog

end;</source>
        <Parameter name="_caller" type="CM_BaseForm"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_selectedBays" type="CM_BayVoyageByIdDict"/>
        <Parameter name="_displayMode" type="Integer"/>
        <Parameter name="_colourMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d0318c1d-b833-4458-9f78-6c40df0db78d">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

begin

	create self.myScanPlanAgent transient;

	self.mulBays.setupControl( self.mulBays.caption, null, CMUI_ScanPlanReportForm::displayBay.name);
	self.mulBays.setSelected( null ); 
	self.mulBays.multiSelect := ListBox.MultiSelect_Simple;
	self.mulBays.myAvailableListBox.sorted := true;
	
	inheritMethod();
	
	if self.mySelectedVoyage &lt;&gt; null then
		self.cmbVoyage.setObject( self.mySelectedVoyage );	
	endif;
	
	self.selectVoyage();
	
	self.handleMenusForModalDisplay();
	if self.myParentForm &lt;&gt; null then
		self.centreOverParent( 0 );
	endif;
	
	self.btnOk.caption := app.getErrorString( INV_Print );
	if self.myTerminal.getConfig(ShipShowISOType).Boolean then
		self.optColISO.caption := app.getErrorString( CM_ISO_Type );
	else
		self.optColISO.caption := app.getErrorString( Mode_Group );
	endif;
	
	if self.mySelectedVoyage &lt;&gt; null then
		self.mulBays.setSelected( self.preSelectedBays );
		
		if self.preDisplayMode = ShpDisplayMode_ColCodeLoad then
			self.optSlotLoad.value := true;
		elseif self.preDisplayMode = ShpDisplayMode_ColCodeDisch then
			self.optSlotDisc.value := true;
		elseif self.preDisplayMode = ShpDisplayMode_Actual then
			self.optSlotAct.value := true;
		elseif self.preDisplayMode = ShpDisplayMode_Proposed then
			self.optSlotProp.value := true;
		else
			//Do nothing it will default to what it had last tine
		endif;
		
		
		if self.preColourMode = VIEW_COMMODITY then
			self.optColComm.value := true;
		elseif self.preColourMode = VIEW_DISPORT then
			self.optColDPort.value := true;
		elseif self.preColourMode = VIEW_ISOGROUP then
			self.optColISO.value := true;
		elseif self.preColourMode = VIEW_LOADPORT then
			self.optColLPort.value := true;
		elseif self.preColourMode = VIEW_OPERATOR then
			self.optColOp.value := true;
		else
			//Do nothing it will default to what it had last tine
		endif;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c7b24337-1c30-434a-87db-2572daa3cc5f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 30 September 2020 14:27:37.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024045, locale);
	chkCargoList.translateCaption(Xlat_0024046, locale);
	chkPreview.translateCaption(Xlat_0024047, locale);
	chkProfileSumm.translateCaption(Xlat_0024048, locale);
	grpBaysPerPage.translateCaption(Xlat_0024049, locale);
	grpLegend.translateCaption(Xlat_0024050, locale);
	grpPaperSize.translateCaption(Xlat_0024051, locale);
	grpROB.translateCaption(Xlat_0024052, locale);
	grpSlotColour.translateCaption(Xlat_0024053, locale);
	grpSlotContent.translateCaption(Xlat_0024054, locale);
	lblBays.translateCaption(Xlat_0024055, locale);
	lblVoyage.translateCaption(Xlat_0024056, locale);
	optA3.translateCaption(Xlat_0024057, locale);
	optA4.translateCaption(Xlat_0024058, locale);
	optColComm.translateCaption(Xlat_0024059, locale);
	optColDPort.translateCaption(Xlat_0024060, locale);
	optColISO.translateCaption(Xlat_0024061, locale);
	optColLPort.translateCaption(Xlat_0024062, locale);
	optColNone.translateCaption(Xlat_0024063, locale);
	optColOp.translateCaption(Xlat_0024064, locale);
	optOneBay.translateCaption(Xlat_0024065, locale);
	optOnePage.translateCaption(Xlat_0024066, locale);
	optPageAll.translateCaption(Xlat_0024067, locale);
	optROBGrey.translateCaption(Xlat_0024068, locale);
	optROBWhite.translateCaption(Xlat_0024069, locale);
	optSixBay.translateCaption(Xlat_0024070, locale);
	optSlotAct.translateCaption(Xlat_0024071, locale);
	optSlotDandL.translateCaption(Xlat_0024072, locale);
	optSlotDisc.translateCaption(Xlat_0024073, locale);
	optSlotLoad.translateCaption(Xlat_0024074, locale);
	optSlotProp.translateCaption(Xlat_0024075, locale);
	optThreeBay.translateCaption(Xlat_0024076, locale);
	optTwelveBay.translateCaption(Xlat_0024077, locale);
	optTwoBay.translateCaption(Xlat_0024078, locale);
end;</source>
