    <JadeMethod name="getSpecialDataForDef" id="2ae0bfe9-48df-4395-bf04-98bb03abee8b">
        <source>getSpecialDataForDef(_theTable : Table; _theProperty : String; _theIndex : Integer; _theObject : Object);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theString : String;
begin

	if _theProperty = "vesselClonedFrom" then
		theString := self.clonedFromVessel;
	endif;
	if _theProperty = "typeOfVessel" then
		theString := app.vesselAccessTypeEnumToStr(self.vesselType);
	endif;

	// Note that this assumes that this is a CM_EntryTable which is not
	// available in this schema
	_theTable.sendMsgWithParams("setValue", _theIndex, theString);

end;</source>
        <Parameter name="_theTable" type="Table"/>
