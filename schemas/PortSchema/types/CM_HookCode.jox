    <JadeMethod name="cloneMySelf" id="6d9174ae-bbe9-44d0-a756-6b45f352a7a7">
        <updating/>
        <source>cloneMySelf( _isTransient : Boolean):SelfType updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2008	cnwrd1	Initial creation

*/

vars
	newHookCode	:	SelfType;
	hookHist, newHookHist 	: CM_HookCodeHistory;
begin
	newHookCode := self.cloneSelf(_isTransient);
	/*
	foreach hookHist in self.allHookCodeHistory do
		newHookHist := hookHist.cloneSelf(_isTransient);		
		//newHookHist.myHookCode := newHookCode;
		setForProxy(_jadeCode, _userCode	: String; _hookCode	: CM_HookCode) updating;
	endforeach;
*/
	return newHookCode;
epilog

end;</source>
        <Parameter name="_isTransient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="createProxyHookLinkForParent" id="517f381d-962e-47ab-977f-f44e795307e0">
        <source>createProxyHookLinkForParent(_hookType : Integer; _parent : CM_Object);
// ---------------------------------------------------------------------------
// Created:     16 January 2008 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpHookLink	: CM_HookLink;
	
begin
	self.raiseExceptionIfNotTransient(method);
	
	tmpHookLink := self.allHookLinks.first;
	
	if tmpHookLink = null then
		// need to add one
		create tmpHookLink transient;
		tmpHookLink.setForProxy(_hookType, _parent, self);
	endif;

end;</source>
        <Parameter name="_hookType" type="Integer"/>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="exportMyCollectionsXML" id="9cf2a3fa-0e24-470a-85bb-511ca902008f">
        <source>exportMyCollectionsXML(_file: File; _objArray: ObjectArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 April 2009	cnwrd1	Initial creation
// 3.4.09 cnwrd1 par 19188
*/

vars
	hookHistory 	:  CM_HookCodeHistory;
	hookLink 		: CM_HookLink;
begin
	
	_file.writeLine('&lt;'&amp;CM_HookCode::allHookCodeHistory.name&amp;'&gt;');
	foreach hookHistory in self.allHookCodeHistory do
		hookHistory.exportMeXML(_file, _objArray, false, false);
	endforeach;
	_file.writeLine('&lt;/'&amp;CM_HookCode::allHookCodeHistory.name&amp;'&gt;');
	
	_file.writeLine('&lt;'&amp;CM_HookCode::allHookLinks.name&amp;'&gt;');
	foreach hookLink in self.allHookLinks do
		hookLink.exportMeXML(_file, _objArray, false, false);
	endforeach;
	_file.writeLine('&lt;/'&amp;CM_HookCode::allHookLinks.name&amp;'&gt;');
	
epilog

end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
