<Class name="CM_CustomStopClear" id="98d02775-91d5-4545-9097-43a8e07d66d0">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="customsEntryNumber" id="2697f7ac-be58-4ab5-8420-a462f385435a">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="extraInfo" id="d9eb6cc4-11af-43d3-836d-f71bc167e4ea">
        <length>36</length>
