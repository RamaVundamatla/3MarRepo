    <JadeMethod name="doTblDataDBClick" id="8666d5c0-2b0a-411b-afa9-040417bcb0ff">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;

vars

begin
	inheritMethod(table);
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	if table.column &lt;= table.fixedColumns then
		return;
	endif;
	
	if table.row &gt; table.fixedRows then
		if self.btnEditItem.enabled then
			self.doEdit();
		endif;
	endif;

end;
</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRowColChange" id="c6029e8d-c818-447b-983a-1063dafe2616">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;

vars
	theObject 	: Object;
	ct			: TimeStamp;
	invalid		: Boolean;
	invLineDesc	: String;
	ild			: CM_InvoiceLineDesc;
				mapping : CM_TranMapInvoiceLineMapping;
begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;

	theObject := table.accessRow(table.row).itemObject;
	if theObject &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, theObject, invalid);
		ct := theObject.creationTime;
	endif;
	
	if invalid then
		return;
	endif;
	
	if theObject.isKindOf(CM_QuantityRangeMap) then
		self.myQuantityRangeMap := theObject.CM_QuantityRangeMap;
		invLineDesc := table.accessCell(table.row, table.columns).text;
		// TFS 40620 foreach ild in self.myQuantityRangeMap.allInvoiceLineMaps do
		foreach mapping in self.myQuantityRangeMap.allTMInvoiceLineMappings do // TFS 40620
			ild := mapping.myTMInvoiceLineDesc; // TFS 40620
			if ild.narration = invLineDesc then
				self.myInvoiceLineDesc := ild;
				break;
			endif;
		endforeach;
		self.myInvoiceAllocation := self.myQuantityRangeMap.myQuantityMap.myInvoiceAllocation;
	endif;
	
	if self.myInvoiceAllocation &lt;&gt; null then
		self.btnDelete.enabled := not self.myInvoiceAllocation.default;
	endif;

	inheritMethod(table);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExtraExtraInfo" id="ca810c3a-da25-4bc9-9efc-44a50ec2a5a0">
        <source>getExtraExtraInfo(_dataContainer : CM_DataContainer; _object : CM_Object);
//
vars
	invalidObject	: Boolean;
	mapping	: String;
	block	: CM_DataContainerBlock;
	yac		: CM_YACriteria;
begin
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Criteria), DC_MoreInfo, 1, null);
	
	foreach yac in self.myInvoiceAllocation.allCriteria do
		block := _dataContainer.addNewBlock;
		block.addNewItem(yac.myYACriteriaType.description, DC_Label, 1, yac);
		block.addNewItem(yac.getRawDescription(), DC_Data, 1, yac);
	endforeach;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Mapping), DC_MoreInfo, 1, null);
	
	on Exception do app.handleDeletedObject(exception, self.myQuantityRangeMap.myQuantityMap.mySnapShotQuantityType, invalidObject);
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Snap_shot_quantity_attr), DC_Label, 1, null);
	block.addNewItem(self.myQuantityRangeMap.myQuantityMap.mySnapShotQuantityType.heading, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Invoice_quantity_start), DC_Label, 1, null);
	block.addNewItem(self.myQuantityRangeMap.rangeStart.String, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Invoice_quantity_end), DC_Label, 1, self);
	block.addNewItem(self.myQuantityRangeMap.rangeEnd.String, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Charge_zero_quantity), DC_Label, 1, self);
	block.addNewItem(app.getYesBlank(self.myQuantityRangeMap.myQuantityMap.chargeZero), DC_Data, 1, null);
	
	if self.myQuantityRangeMap.myQuantityMap.mappingType = CM_QuantityMap.MapType_Single then
		mapping := app.getErrorString(Single);
	else
		mapping := app.getErrorString(Escalating);
	endif;
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Quantity_mapping_type), DC_Label, 1, self);
	block.addNewItem(mapping, DC_Data, 1, null);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Invoice_line), DC_Label, 1, self);
	block.addNewItem(self.myInvoiceLineDesc.narration, DC_Data, 1, null);

end;
</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="67b321c2-f328-4d26-b9ad-b23f1d7ad532">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

vars
	theXML : String;
	hideMacro : Boolean;
begin
	hideMacro :=  (self.mnuContextHide.caption = self.MNU_MACRO_SHOW);
	
	theXML := inheritMethod();
	theXML := theXML &amp; global.formatAsXML("HM", hideMacro.Integer.String);
	return theXML;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="b2f32b69-9c4c-4841-89a6-7e5bcf697918">
        <source>getXMLSettingsForSetup();
// initFromUserWindow-style code but called from setupForm
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	hideM : Boolean;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	theXML := userWindow.xmlInfo;
 	theXMLValue := theXML.cnEcGetTagValueOfName("HM");
 	hideM := false;
 	if theXMLValue &lt;&gt; null then
 		hideM := theXMLValue.Integer.Boolean;
 	endif;
 	
 	if hideM then
 		self.splMain.hideRightControl(true);
 		self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
 	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="86cac1ed-2a80-438a-a637-11a4db8eeb63">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;

vars

begin
	inheritMethod();
	// show macro stuff here from populateTable from setupForm as this is called after resize and so the macro table shows with the current form size
	self.doTblDataRowColChange(self.tblData);

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTable" id="7edc78d2-dd6f-49c1-8bb4-3c3331b7037a">
        <updating/>
        <source>populateTable() updating;

vars
	attr,
	savedRow,
	row,
	col		: Integer;
	str,
	qtyType,
	range	: String;
	allGroupProps : CM_QueryPropertyArray;
	ild			: CM_InvoiceLineDesc;
	queryProp	: CM_QueryProperty;
	qm			: CM_QuantityMap;
	qrm			: CM_QuantityRangeMap;
	ya			: CM_YardAllocation;
	yac			: CM_YACriteria;
	invAlloc	: CM_InvoiceAllocation;
	obj			: Object;
	selected,
 	selectedSorted	: ObjectArray;
	sa			: CnStringArray;		// membership size 260
	mapping : CM_TranMapInvoiceLineMapping;
begin

	create allGroupProps transient;
	self.mySnapShotBroker.mySnapShotDefinition.getGroupingProperties( allGroupProps );
	create selected transient;
	foreach queryProp in allGroupProps where queryProp.allocationAttribute &lt;&gt; 0 do
		if self.mySnapShotBroker.allYACriteriaTypes.includes(queryProp.allocationAttribute) then
			selected.add(queryProp);
		endif;
	endforeach;
	create selectedSorted transient;
	foreach attr in self.mySnapShotBroker.allYACriteriaTypes do
		foreach obj in selected do
			queryProp := obj.CM_QueryProperty;
			if queryProp.allocationAttribute = attr then
				selectedSorted.add(obj);
				break;
			endif;
		endforeach;
	endforeach;

	create sa transient;
	if self.tblData.rows &gt; 1 then
		savedRow := self.tblData.row;
	endif;
	row := 1;
	col := 1;
	self.tblData.fixedRows := 1;
	self.tblData.columns := selectedSorted.size + 3;		// properties plus attribute, range and invoice line
	self.tblData.rows := self.mySnapShotBroker.getChildrenSize() + 1;	// each item plus fixed header
	self.tblData.selectMode := CM_EntryTable.SelectMode_CurrentRow;

	foreach obj in selectedSorted do
		queryProp := obj.CM_QueryProperty;
		self.tblData.row := row;
		self.tblData.column := col;
		self.tblData.text := queryProp.niceName;
		col := col + 1;
	endforeach;
	self.tblData.column := col;
	self.tblData.text := "Range";
	col := col + 1;
	self.tblData.column := col;
	self.tblData.text := "Attribute";
	col := col + 1;
	self.tblData.column := col;
	self.tblData.text := "Invoice Line";
	
	// clear the 'my' references to handle an empty table
	self.myInvoiceLineDesc := null;
	self.myQuantityRangeMap := null;
	self.myInvoiceAllocation := null;
	
	row := row + 1;
	foreach ya in self.mySnapShotBroker.allInvoiceAllocationsByPriory do
		invAlloc := ya.CM_InvoiceAllocation;
		col := 1;
		sa.clear;
		foreach yac in invAlloc.allCriteria do
			sa.add(yac.getRawDescription);
		endforeach;
		qm := invAlloc.myQuantityMap;
		qtyType := qm.mySnapShotQuantityType.heading;
		foreach qrm in qm.allQuantityRanges do
			self.myQuantityRangeMap := qrm;
			self.myInvoiceAllocation := self.myQuantityRangeMap.myQuantityMap.myInvoiceAllocation;
			range := qrm.rangeStart.Integer.String &amp; " - " &amp; qrm.rangeEnd.Integer.String;
			self.tblData.row := row;
			// TFS 40620 foreach ild in qrm.allInvoiceLinesUsed do
			foreach mapping in qrm.allTMInvoiceLineMappings do // TFS 40620
				ild := mapping.myTMInvoiceLineDesc; // TFS 40620
			
			
			
				self.myInvoiceLineDesc := ild;
				col := 1;
				foreach str in sa do
					self.tblData.column := col;
					self.tblData.text := str;
					col := col + 1;
				endforeach;
				self.tblData.column := col;
				self.tblData.text := range;
				col := col + 1;
				self.tblData.column := col;
				self.tblData.text := qtyType;
				col := col + 1;
				self.tblData.column := col;
				self.tblData.text := ild.narration;
				self.tblData.accessRow(row).itemObject := qrm;
				self.myQuantityRangeMap := qrm;
				self.myInvoiceLineDesc := ild;
				row := row + 1;
			endforeach;
		endforeach;
	endforeach;
	// restore the current row
	if savedRow &gt; 0 and savedRow &lt;= self.tblData.rows then
		self.tblData.row := savedRow;
	else
		self.tblData.row := 2;	// first data row
	endif;
	self.doTblDataRowColChange(self.tblData);		// show macro stuff
	
epilog
	delete allGroupProps;
	delete selected;
	delete selectedSorted;
	delete sa;
end;



</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="72c70ac7-7efc-401d-a34b-58d4629001d5">
        <updating/>
        <source>setupForm() updating;

vars

begin
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.useTableInfo := true; 
	// the only context menu is Show/Hide macro info
	self.mnuSendReportMain.visible := false;
	self.mnuContextColourLegend.visible := false;
	self.mnuColumnOrganiser.visible := false;
	self.useTableInfo := true;
	self.mnuInvUpdate.visible := true;
	self.mnuInvNew.visible := true;

	inheritMethod();
	self.getXMLSettingsForSetup();
	self.createMyAssistant(INV_Assistant);
	
	self.caption := app.getErrorString1(Invoice_mappings_for, "'" &amp; self.mySnapShotBroker.mySnapShotDefinition.name &amp; "'");
	self.populateTable();
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE), Response_Continuous, null);
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d0ccb652-e4c8-43b2-b674-2bc6ccdd78e4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 08 February 2019 08:19:09.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
