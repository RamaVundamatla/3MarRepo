    <JadeMethod name="getBOL" id="db260176-4930-42b6-a20d-92cdd4904d08">
        <source>getBOL(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwndl1	Initial creation	Par 35008

*/

vars

	returnStr : String;

begin
	
	if self.myReserveSelection &lt;&gt; null then
		if self.myReserveSelection.myBOLIn &lt;&gt; null then
			returnStr := self.myReserveSelection.myBOLIn.number;
		endif;
	endif;
	
	return returnStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoType" id="23037e6e-7b4f-407e-9614-20554ff07c19">
        <source>getCargoType(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2014	cnwndl1	Initial creation	Par 35008

*/

vars

	ct : CM_CargoType;
	returnStr : String;

begin
	
	if self.myReserveSelection &lt;&gt; null then
		ct := self.myReserveSelection.getCargoType;
	endif;
	if ct = null then
		if self.myBookingItem &lt;&gt; null then
			ct := self.myBookingItem.myCargoType;
		endif;
	endif;
	
	if ct &lt;&gt; null then
		returnStr := ct.description;
	endif;
	
	return returnStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
