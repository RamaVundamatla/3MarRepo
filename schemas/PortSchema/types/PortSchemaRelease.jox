    <JadeMethod name="createQryReportFilterObjects" id="4c65af28-56d5-4a99-8fae-6f947819504e">
        <source>createQryReportFilterObjects(_controller: CnEcReleaseController) protected;
// ---------------------------------------------------------------------------
// Created:     07 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cnt						: Integer;
	objArray				: CM_ObjectArray;
	qryReport				: CM_QryReport;
	obj						: Object;
	filterObject			: CMQF_FilterReports;
	tmpClass				: Class;
begin
	create objArray transient;
	CM_QryReport.allInstances(objArray, null, true);
	
	beginTransaction;
	foreach obj in objArray do
		qryReport := obj.CM_QryReport;
		if (not global.isValidObject(qryReport.myFilterObject)) then
			qryReport.setMyFilterObject(null);
		endif;
		
		if qryReport.myFilterObject &lt;&gt; null then
			if (qryReport.myFilterObject.class.name.toUpper &lt;&gt; qryReport.filterClassName.toUpper) then
				//someone has changed the filter class of the report, delete it and continue with re-build
				//obvious any defaults setup will be lost
				delete qryReport.myFilterObject;
			else
				continue;
			endif;
		endif;
		
		if qryReport.filterClassName = null then
			// this is valid
			continue;
		endif;
		
		tmpClass := currentSchema.getClass(qryReport.filterClassName);
		if tmpClass = null then
			_controller.logEntry('Class not found for (' &amp; qryReport.filterClassName &amp; ') ' &amp; qryReport.String);
			continue;
		endif;
		
		create filterObject as tmpClass persistent;		
		//filterObject.isDefaultHolder := true;
		qryReport.setPropertyValue('myFilterObject', filterObject);
		
		cnt := cnt + 1;
		if cnt mod 100 = 0 then
			commitTransaction;
			beginTransaction;
		endif;
	endforeach;
	commitTransaction;
	
	_controller.logEntry('Create default filter objects for ' &amp; cnt.String &amp; ' reports');
epilog
	delete objArray;
end;</source>
        <access>protected</access>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
