    <JadeMethod name="doVerify" id="3365d4d0-d7b4-4b41-87ce-4f0bd9f75791">
        <source>doVerify() protected;
/*
Date		Who		Reason
27 March 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	xlationTable 	: CM_XlationTable;
	warningColl 	: HugeStringArray;
begin
	app.mousePointer := MP_HOURGLASS;
	
	create warningColl transient;
	
	foreach xlationTable in app.myRoot.allXlationTables do
		xlationTable.verify(warningColl);
	endforeach;
	
	//app.setMyTerminal(CM_Terminal.firstInstance);
	
	app.mousePointer := MP_DEFAULT;
	
	app.showErrorWarningDialogArray("EDI Translation errors", null, warningColl, ErrWarnMode_CanAckWarnings);
epilog
	app.mousePointer := MP_DEFAULT;
	
	//app.setMyTerminal(null);
	
	delete warningColl;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getExtraExtraInfo" id="3fd74677-ef40-479d-b745-41cc641cb509">
        <source>getExtraExtraInfo(_dataContainer: CM_DataContainer; _xlation :CM_Xlation);
/*
Date		Who		Reason
12 March 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
//16 Apr 2015	cnwrs1	Par 36065 Check cargotype and subtype
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
vars
	etDef		: EntTableDef; 
	etRow		: EntTableRow;
	block		: CM_DataContainerBlock;
	terminal	: CM_Terminal;
	locale		: CM_Locale;
	xlation		: CM_Xlation;
	count		: Integer;
begin

	etDef 		:= app.myController.getEntTableDef (ETDef_EDIXlations);
	terminal	:= self.myTerminal;
	locale		:= app.myCurrentLocale;
	
	etRow := etDef.getEntTableRow (ETRow_Operator);
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_xlation.getDisplayStringForAttribute (ETRow_Operator, false), DC_Data, 1, null);
	
	etRow := etDef.getEntTableRow (ETRow_Terminal);
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_xlation.getDisplayStringForAttribute (ETRow_Terminal, false), DC_Data, 1, null);
	
	etRow := etDef.getEntTableRow (ETRow_Type);
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_xlation.getDisplayStringForAttribute (ETRow_Type, true), DC_Data, 3, null);
	
	if _xlation.isKindOf (CM_Xlation_In) then
		etRow := etDef.getEntTableRow (ETRow_ForeignIn);
		block := _dataContainer.addNewBlock;
		
		block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
		block.addNewItem (_xlation.getDisplayStringForAttribute (ETRow_ForeignIn, false), DC_Data, 1, null);
		
		etRow := etDef.getEntTableRow (ETRow_Criteria);
		block := _dataContainer.addNewBlock;
		
		block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
		block.addNewItem (_xlation.getDisplayStringForAttribute (ETRow_Criteria, false), DC_Data, 1, null);
	endif;
	
	etRow := etDef.getEntTableRow (ETRow_SystemCode);
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_xlation.getDisplayStringForAttribute (ETRow_SystemCode, false), DC_Data, 1, null);	
	
	etRow := etDef.getEntTableRow (ETRow_SystemDesc);
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_xlation.getDisplayStringForAttribute (ETRow_SystemDesc, false), DC_Data, 1, null);	
	
	etRow := etDef.getEntTableRow (ETRow_ForeignOut);
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_xlation.getDisplayStringForAttribute (ETRow_ForeignOut, false), DC_Data, 3, null);	
	
	if _xlation.isKindOf (CM_Xlation_Out) then
		return;
	endif;
	
	// blank row
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (null, DC_Data, 4, null);
	
	// other system code usages	
	foreach xlation in _xlation.myXlationTable.allInwardTranslations do
		if xlation = _xlation or xlation.systemCode &lt;&gt; _xlation.systemCode then
			continue;
		endif;
		
		if count = 0 then
			block.addNewItem (app.getErrorString1 (System_Code_Xlations, _xlation.getSystemCodeDisplay), DC_Label, 2, null);
		else
			block.addNewItem (null, DC_Label, 2, null);
		endif;
		
		if xlation.CM_Xlation_In.canHaveCriteria then
			block.addNewItem (xlation.CM_Xlation_In.getCriteriaDisplay (false), DC_Data, 2, xlation);
		else
			block.addNewItem (xlation.foreignCode, DC_Data, 2, xlation);
		endif;
		
		count := count + 1;
	endforeach;

epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <Parameter name="_xlation" type="CM_Xlation"/>
    </JadeMethod>
    <JadeMethod name="getTopFor_splMain" id="9443a542-db37-42df-a8b6-9c1335a0e33d">
        <source>getTopFor_splMain(): Real protected;
/*
Date		Who		Reason
11 March 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	return self.topMargin + self.frmSearch.height;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="6a366760-a1f3-4586-aacb-68104852f597">
        <source>includeObject(_xlation :CM_Xlation):Boolean protected;
/*
Date		Who		Reason
12 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	filterOperator					: CM_Operator;
	filterType, xlationType		: Integer;
	xlationTable				: CM_XlationTable;
	terminal					: CM_Terminal;
begin
	filterType		:= self.cmbType.getCurrentItemData;
	xlationTable	:= _xlation.myXlationTable;
	xlationType		:= xlationTable.type;
	
	if filterType &gt; 0 then
		if xlationType &lt;&gt; filterType then
			return false;
		endif;
	else
		if filterType = CMUI_Assistant.ItemData_All_Operator and _xlation.myXlationTable.isSystemXlationTable then
			return false;
		elseif filterType = CMUI_Assistant.ItemData_All_System and not _xlation.myXlationTable.isSystemXlationTable then
			return false;
		endif;
	endif;
	
	filterOperator	:= self.cmbOperator.getCurrentItemObject.CM_Operator;
	
	if not _xlation.myXlationTable.isSystemXlationTable and
		not _xlation.myXlationTable.isTerminalXlationTable then
		if xlationTable.getMyOperator &lt;&gt; filterOperator then
			return false;
		endif;
	endif;
	
	terminal := self.cmbTerminal.getCurrentItemObject.CM_Terminal;
	
	if terminal &lt;&gt; null then 
		if xlationType = XLATION_TYPE_VOYAGETERMINAL and terminal &lt;&gt; xlationTable.getMyTerminal then
			return false;
		endif;
		if _xlation.myXlationTable.isTerminalXlationTable and terminal &lt;&gt; xlationTable.myTerminal then
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xlation" type="CM_Xlation"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTableData" id="e32fd6d9-e52a-4b50-9bf8-789f1e94b706">
        <updating/>
        <source>initTableData(_theEntDef: String) updating;
/*
Date		Who		Reason
11 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259 
*/
vars
	table	:CM_DataTable;
begin 
	inheritMethod(_theEntDef);
	
	table := self.tblData;
	
	table.multiSelect			:= CM_DataTable.MultiSelect_Simple;
	table.scrollBars			:= CM_DataTable.ScrollBars_Both;
	table.optimiseRowHeight		:= true;
epilog

end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="b06cc6e7-3b6d-4143-9fa4-5313bacf4df0">
        <updating/>
        <source>setCorrectComboStyle() updating;
/*
Purpose:	During the change to 22.0.24 some combo boxes had their STYLE set to zero, this is a patchable way to fix that.				

Date		Who		Reason
11 June 2024	navab1	BUG 64462
*/

vars

begin
	inheritMethod();

	self.cmbTerminal.style := 2;
	self.cmbType.style := 2;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7f6b2804-9e77-4117-99e0-c787e7d76706">
        <updating/>
        <source>setupForm() updating;
/*
Date		Who		Reason
11 Mar 2013	cnwcs5	Initial creation - CCMS POL 2097/par 31259
*/
vars
	assistant	:CMUI_Assistant;
	type		:Integer;
	operator	:CM_Operator;
begin
	self.staStatusBar.visible	:= true;
	self.usesQueryFrame 		:= false;
	self.useTableInfo			:= true;
	self.toolbarStyle 			:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar 			:= true;
	self.useTableSorting 		:= true;
	
	inheritMethod();

	self.btnNew.enabled					:= true;
	self.mnuContextColourLegend.visible	:= false;
	
	self.initTableData (ETDef_EDIXlations);
	
	assistant 	:= self.myAssistant;
	type		:= self.initialTranslationType;
	operator	:= self.myInitialOperator;
	
	assistant.comboBoxEDIXlationTypes (self.cmbType, true, true, type);
	
	self.cmbTerminal.style := ComboBox.Style_DropDownComboList;
	
	assistant.comboBoxTerminalAll (self.cmbTerminal, null);
	
	self.cmbOperator.setObject (operator);
	
	self.setNavigatorHeading (self.caption);
	
	self.frmSearch.top 		:= self.frmToolbar.height;
	self.frmSearch.width	:= self.clientWidth;
	self.frmSearch.left		:= 0;
	
	if type = null then
		self.cmbType.setFocus;
	else
		if operator = null then
			self.cmbOperator.setFocus;
		else
			self.doQuery;
		endif;
	endif;
	
	self.doCmbTypeClick (self.cmbType);
	
	self.beginClassNotification(CM_Xlation_In, false, Object_Create_Event, Response_Continuous, 0);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2411dc87-3bb8-4fac-9290-dd928708ad05">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 03 February 2023 08:37:14.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018742, locale);
	btnCopy.translateCaption(Xlat_0018743, locale);
	btnImportCSV.translateCaption(Xlat_0025416, locale);
	btnNew.translateCaption(Xlat_0018744, locale);
//	btnRefresh.translateCaption(Xlat_0018745, locale);
	btnVoyageBulkTranslation.translateCaption(Xlat_0024641, locale);
	lblCargoType.translateCaption(Xlat_0025417, locale);
	lblOperator.translateCaption(Xlat_0018747, locale);
	lblSystemCode.translateCaption(Xlat_0025418, locale);
	lblTerminal.translateCaption(Xlat_0018748, locale);
	lblType.translateCaption(Xlat_0018749, locale);
end;</source>
    </JadeMethod>
</GUIClass>
