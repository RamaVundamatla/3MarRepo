    <JadeMethod name="doProcess" id="d5a36caf-27d7-4cc1-af91-aa31a3c5f3a0">
        <source>doProcess();
/*
Purpose:			

Date		Who		Reason
16 July 2021	navab1	TFS 51515
*/

vars
	iter : Iterator;
		eventTrx : CM_EventTransaction;
	locAct : CMEVT_LocationActivity;
	keyTimeStamp : TimeStamp;
	keyType : Integer;
	breakOut : Boolean;
begin
	iter :=	self.myTerminal.allEventsByTypeDateTime.createIterator();
	
	
	if self.allTerminalAreas.isNotEmpty() then
		self.myTerminal.allEventsByTypeDateTime.startKeyGeq( EVT_LocationBalance, earliestDT, iter);
	
		while iter.next( eventTrx ) do
			iter.getCurrentKeys( keyType, keyTimeStamp );
			if keyType &lt;&gt; EVT_LocationBalance then
				break;
			endif;
			
			locAct := eventTrx.CMEVT_LocationActivity;
					
			if self.myCargoType &lt;&gt; null and self.myCargoType &lt;&gt; locAct.getCargoType() then
				continue;
			endif;
					
			if self.myOperator &lt;&gt; null and self.myOperator &lt;&gt; locAct.getOperator() then
				continue;
			endif;
			
			if locAct.mySourceTA &lt;&gt; null then
				if not self.allTerminalAreas.includes(locAct.mySourceTA) then
					if locAct.myTargetTA &lt;&gt; null then
						if not self.allTerminalAreas.includes(locAct.myTargetTA) then
							continue;
						endif;
					else	
						continue;
					endif;
				endif;
			else
				if locAct.myTargetTA &lt;&gt; null then
					if not self.allTerminalAreas.includes(locAct.myTargetTA) then
						continue;
					endif;
				else
					continue; // no TAs at all
				endif;
			endif;
			
			locAct.setNeedsRecalculation(true);
		endwhile;
	endif;

	
	if self.allPreviousTTerminalAreas.isNotEmpty() then
		self.myTerminal.allEventsByTypeDateTime.startKeyGeq( EVT_LocationBalance, previousTS, iter);
	
		while iter.next( eventTrx ) do
			iter.getCurrentKeys( keyType, keyTimeStamp );
			if keyType &lt;&gt; EVT_LocationBalance then
				break;
			endif;
			
			locAct := eventTrx.CMEVT_LocationActivity;
					
			if self.myCargoType &lt;&gt; null and self.myCargoType &lt;&gt; locAct.getCargoType() then
				continue;
			endif;
					
			if self.myOperator &lt;&gt; null and self.myOperator &lt;&gt; locAct.getOperator() then
				continue;
			endif;
			
			if locAct.mySourceTA &lt;&gt; null then
				if not self.allPreviousTTerminalAreas.includes(locAct.mySourceTA) then
					if locAct.myTargetTA &lt;&gt; null then
						if not self.allPreviousTTerminalAreas.includes(locAct.myTargetTA) then
							continue;
						endif;
					else	
						continue;
					endif;
				endif;
			else
				if locAct.myTargetTA &lt;&gt; null then
					if not self.allPreviousTTerminalAreas.includes(locAct.myTargetTA) then
						continue;
					endif;
				else
					continue; // no TAs at all
				endif;
			endif;
			
			locAct.setNeedsRecalculation(true);
		endwhile;	
	endif;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="initialiseFromProxy" id="a16896db-a475-4e17-bf6d-3bd782f82ccc">
        <updating/>
        <source>initialiseFromProxy(_proxyLA, _realLA : CMEVT_LocationActivity) updating;
/*
Purpose:			

Date		Who		Reason
16 July 2021	navab1	TFS 51515
*/

vars

	term : CM_Terminal;
	cargotype : CM_CargoType;
	operator : CM_Operator;
	pxyTS, realTS : TimeStamp;
begin

	
	// SOURCE
	// The setting of the proxy only changes the LC, if the LC is for a TA the TA is still what is on the real
	if _proxyLA.mySourceLocation &lt;&gt; null
	and _proxyLA.mySourceLocation.myTerminalArea &lt;&gt; null then
		self.allTerminalAreas.addNoDuplicates(_proxyLA.mySourceLocation.myTerminalArea, false);
		
		if _realLA.mySourceLocation &lt;&gt; null
		and _realLA.mySourceLocation.myTerminalArea &lt;&gt; null then
			if _proxyLA.mySourceLocation.myTerminalArea &lt;&gt; _realLA.mySourceLocation.myTerminalArea then
				self.allPreviousTTerminalAreas.addNoDuplicates(_realLA.mySourceLocation.myTerminalArea, false);
			endif;
		endif;
	else
		if _proxyLA.mySourceTA &lt;&gt; null then
			self.allTerminalAreas.addNoDuplicates(_proxyLA.mySourceTA, false);
			
			if _realLA.mySourceTA &lt;&gt; null then
				if _proxyLA.mySourceTA &lt;&gt; _realLA.mySourceTA then
					self.allPreviousTTerminalAreas.addNoDuplicates(_realLA.mySourceTA, false);
				endif;
			endif;
		endif;
	endif;
	
	// TARGET
	if _proxyLA.myTargetLocation &lt;&gt; null
	and _proxyLA.myTargetLocation.myTerminalArea &lt;&gt; null then
		self.allTerminalAreas.addNoDuplicates(_proxyLA.myTargetLocation.myTerminalArea, false);
		
		if _realLA.myTargetLocation &lt;&gt; null
		and _realLA.myTargetLocation.myTerminalArea &lt;&gt; null then
			if _proxyLA.myTargetLocation.myTerminalArea &lt;&gt; _realLA.myTargetLocation.myTerminalArea then
				self.allPreviousTTerminalAreas.addNoDuplicates(_realLA.myTargetLocation.myTerminalArea, false);
			endif;
		endif;
	else
		if _proxyLA.myTargetTA &lt;&gt; null then
			self.allTerminalAreas.addNoDuplicates(_proxyLA.myTargetTA, false);
			
			if _realLA.myTargetTA &lt;&gt; null then
				if _proxyLA.myTargetTA &lt;&gt; _realLA.myTargetTA then
					self.allPreviousTTerminalAreas.addNoDuplicates(_realLA.myTargetTA, false);
				endif;
			endif;
			
		endif;
	endif;

	if self.allPreviousTTerminalAreas.isEmpty() then
		earliestDT := _realLA.dateTime;
		if _proxyLA.dateTime.Date &lt;&gt; _realLA.dateTime.Date then
			earliestDT := _proxyLA.dateTime.cnEcMin(_realLA.dateTime);
		endif;
	
	// If changing TAs then need to set 'recalc' on the 'new' TA from the 'new' date and the 'old' TA from the 'old' date
	else
		earliestDT := _proxyLA.dateTime;
		previousTS := _realLA.dateTime;

	endif;

	
	self.myTerminal := _realLA.myTerminal;
	self.myCargoType := _realLA.getCargoType();
	self.myOperator := _realLA.getOperator();
	

epilog

end;</source>
        <Parameter name="_proxyLA" type="CMEVT_LocationActivity"/>
        <Parameter name="_realLA" type="CMEVT_LocationActivity"/>
    </JadeMethod>
</Class>
