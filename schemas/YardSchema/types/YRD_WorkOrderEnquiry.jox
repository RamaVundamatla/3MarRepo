    <JadeMethod name="initSearch" id="d260955a-85cb-4023-aaa0-9e451baea6ee">
        <updating/>
        <source>initSearch() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14/12/2009	cnwrd1	Initial creation
26/06/2018	jlgdap1	TFS 39440 PEL1 Work Order Enquiry Parameters
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
11 Oct 2021 jlier1	removed inaportnet status ref
25 Apr 2022 navma1  ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
20/12/2022  navcs2 	ChangeRequest 54698:[54264] EUP - [Framework] - Enable VAS Work Order in Work Order Enquiry Screen
21/12/2022 	navcs2  ChangeRequest 56006: EUP - New VAS Workorder Subscription 
*/

vars	
	status     : CM_Association;
	count      : Integer;
	userWindow : CM_UserWindow;				// TFS 39440
	userData   : String;					// TFS 39440
	mulStatus  : CMUI_MultiSelectGroupBox;
begin

	mulStatus	:= self.mltWOStatus;
	
	mulStatus.userInputEnabled 				:= true;
	mulStatus.formDisplayEntryMethodName 	:= YRD_WorkOrderEnquiry::displaySchStatus.name;
	mulStatus.multiSelect					:= ListBox.MultiSelect_Extended;
	mulStatus.myAvailableListBox.sorted 	:= false;		
	mulStatus.mySelectedListBox.sorted 		:= false;
	mulStatus.setTabIndex();
	mulStatus.myBaseForm 					:= self;
	
	
	self.allTaskStatus.clear();

	/**
		21/12/2022 navcs2 ChangeRequest 56006 changes start
	**/
	if self.hasVasSubscription then
		self.frmQuery.width  := 735;					// TFS 39440 // 
		self.frmQuery.height := 400;					//29.09.2021 navma1 #51925
		self.tblToDoWO.visible := true;
		self.chkToDoWO.visible := true;
	else
		self.frmQuery.width  := 500;
		self.frmQuery.height := 400;
		self.tblToDoWO.visible := false;
		self.chkToDoWO.visible := false;
		self.doSelectUnselectWOTypes(false, self.tblToDoWO);
	endif;
	/**
		21/12/2022 navcs2 ChangeRequest 56006 changes end
	**/
	
	self.frmQuery.centreWindow();					//25.04.2022 navma1 #52351
	
	count := 1;
	while count &lt; WO_STATUS_MAX + 1 do		
		create status transient;
		status.setValue(count);
		self.allTaskStatus.insert( count, status);
		
		if self.allSelectedStatus.includes(count) then
			self.allSelectedStatusObj.add( status ); 
		endif;
		
		count := count + 1;		
	endwhile;

	mulStatus.setAvailable(self.allTaskStatus, true); 
	mulStatus.setSelected(self.allSelectedStatusObj); 
	self.cmbOrganisation.setFocus();
	
	self.initWorkOrderTypes();									// TFS 39440
	self.initTransportMode();									//26/11/2024	navkc1 JIRA Story MTN-19092
	if app.getMyUser &lt;&gt; null then								// TFS 39440
		userWindow := self.myUserWindow;						// TFS 39440
		if userWindow = null then								// TFS 39440
			userWindow := app.getUserWindow(self.name, false);	// TFS 39440
		endif;													// TFS 39440
		if userWindow &lt;&gt; null then								// TFS 39440
			userData := userWindow.xmlInfo.cnEcGetTagValueOfName(self.SearchWOCargoTypes.String);	// TFS 39440
			if userData = null then								// TFS 39440
				userWindow := null;								// TFS 39440
			endif;												// TFS 39440
		endif;													// TFS 39440
	endif;														// TFS 39440
	if userWindow = null then									// TFS 39440
		self.chkCargoWO.value := true;							// TFS 39440
		self.chkCargoWO_click(self.chkCargoWO);					// TFS 39440
		self.chkVoyageWO.value := true;							// TFS 39440
		self.chkVoyageWO_click(self.chkVoyageWO);				// TFS 39440
	endif;														// TFS 39440

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblData" id="0703fd74-1b3b-45de-9e56-edd6ef9435c5">
        <updating/>
        <source>initTblData() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwmd1	Initial creation

*/

vars
	entDef	: EntTableDef;
	index	: Integer;
	xmlStr	: String;
begin

	if self.isEnqType_WorkOrder() then
		entDef	:= app.myController.getEntTableDef(ETDef_WorkOrder);
		//self.tblData.setMyDataClass(CM_WorkOrder);
		xmlStr := self.enquiryTypeDef_WorkOrder;
	elseif self.isEnqType_Task() then
		entDef	:= app.myController.getEntTableDef(ETDef_WorkOrderTask);
		//self.tblData.setMyDataClass(CM_WorkOrder);
		xmlStr := self.enquiryTypeDef_Task;
	endif;
	
	//self.tblData.setMyDataClass(CM_WorkOrder); //not sure if req'd
	
	if xmlStr &lt;&gt; null then
		self.tblData.setTblDataEntRowsFromXML(entDef, xmlStr);	
	else	
		self.tblData.setTblDataEntRowsFromDef(entDef);
	endif;
	
	self.tblData.userInputEnabled := false;
	self.tblData.selectMode := Table.SelectMode_CurrentRow;
	self.tblData.selectionType := CM_DataTable.SelectionType_Row;
	self.tblData.multiSelect := self.tblData.MultiSelect_None;
	self.tblData.stretchWidth := true;
	self.tblData.stretchHeight := false;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initTransportMode" id="801de073-f21b-4cf7-ab81-15524b2e3f60">
        <source>initTransportMode();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/
vars
	table : CMUI_ListTable;
begin

	table := self.tblTransportMode;
	
	if table.row &lt; 1 then
		table.clear;
		table.rows 				    := 0;
		table.columns 				:= 3;
		table.accessColumn(3).visible := false;
		
		table.addItem(Tab &amp; TI_TRANSMODE_ROAD_STR &amp; Tab &amp; TI_TRANSMODE_ROAD.String);
		table.addItem(Tab &amp; TI_TRANSMODE_RAIL_STR &amp; Tab &amp; TI_TRANSMODE_RAIL.String);
		table.addItem(Tab &amp; TI_TRANSMODE_SHIP_STR &amp; Tab &amp; TI_TRANSMODE_SHIP.String);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initWorkOrderTypes" id="6d04a85d-035b-4292-93bd-4835dfe51e37">
        <source>initWorkOrderTypes() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/06/2018	jlgdap1		Initial creation TFS 39440 PEL1 Work Order Enquiry Parameters
// 29/09/2021   navma1 		ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
// 2/12/2022 	navcs2 		54698:[54264] EUP - [Framework] - Enable VAS Work Order in Work Order Enquiry Screen
vars
	workOrderDetailType : CM_WorkOrderDetailType;
begin
	if self.tblCargoWO.rows &lt; 1 then
		self.tblCargoWO.clear;
		self.tblCargoWO.rows 				    := 0;
		self.tblCargoWO.columns 				:= 3;
		self.tblCargoWO.accessColumn(3).visible := false;
		self.tblCargoWO.sortColumn[1] 			:= 2;	
		
		foreach workOrderDetailType in app.myRoot.allWorkOrderTaskTypes discreteLock do
			
			if workOrderDetailType.type &lt;&gt; WorkOrderMode_Cargo then
				continue;
			endif;
			
			self.tblCargoWO.addItem(Tab &amp; workOrderDetailType.description &amp; Tab &amp; workOrderDetailType.id.String);
			
		endforeach;
		
		self.tblVoyageWO.clear;
		self.tblVoyageWO.rows    				 := 0;
		self.tblVoyageWO.columns 				 := 3;
		self.tblVoyageWO.accessColumn(3).visible := false;
		self.tblVoyageWO.sortColumn[1]           := 2;
		
		foreach workOrderDetailType in app.myRoot.allWorkOrderTaskTypes discreteLock do									
			
			if workOrderDetailType.type &lt;&gt; WorkOrderMode_Voyage then
				continue;
			endif;
			
			self.tblVoyageWO.addItem(Tab &amp; workOrderDetailType.description &amp; Tab &amp; workOrderDetailType.id.String);
			
		endforeach;
		
		
		/**
		* 2/12/2022 navcs2 ChangeRequest #54698:[54264]
		* Changes Start
		**/
		self.tblToDoWO.clear;
		self.tblToDoWO.rows    				   := 0;
		self.tblToDoWO.columns 				   := 3;
		self.tblToDoWO.accessColumn(3).visible := false;
		self.tblToDoWO.sortColumn[1]           := 2;
		
		foreach workOrderDetailType in app.myRoot.allWorkOrderTaskTypes discreteLock do
			
			if workOrderDetailType.type &lt;&gt; WorkOrderMode_ToDo then
				continue;
			endif;
			
			self.tblToDoWO.addItem(Tab &amp; workOrderDetailType.description &amp; Tab &amp; workOrderDetailType.id.String);
			
		endforeach;
		/**
		* 2/12/2022 navcs2 ChangeRequest #54698:[54264]
		* Changes End
		**/
		
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
