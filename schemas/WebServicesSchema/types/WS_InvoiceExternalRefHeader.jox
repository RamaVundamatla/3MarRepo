<Class name="WS_InvoiceExternalRefHeader" id="e3d92844-de0e-456a-bb43-9e838988a897">
    <superclass name="WS_RestProxyObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="externalFinancialID" id="eeaeee96-fef5-4648-9b84-5602ac79af47">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="externalNumber" id="86735409-c21b-446d-ad62-c89007a53c7a">
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="externalReferences" id="2ac745e1-52fd-41d3-a4b3-ad740e5b2df0">
        <memberTypeInverse/>
        <type name="WS_InvoiceExternalRefDict"/>
    </ImplicitInverseRef>
    <PrimAttribute name="externalTaxNumber" id="5556f423-0df1-42d7-b13e-8e4d2823131b">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="numberOfLines" id="a7ff4a14-9a4f-4876-a44f-dfe337e43bc1">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="total" id="52ec5131-790a-4494-8343-304859806236">
        <precision>23</precision>
        <scaleFactor>6</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <JadeMethod name="delete" id="567af7cd-83c5-4480-871f-9e407eb7ab16">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/01/2026	navkc1 JIRA MTN 36571 - ROS - 2 - External Reference updates in API

*/

vars

begin
	self.externalReferences.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateFromCMIFHeader" id="2717addd-9fa8-45eb-a515-1312395d61ed">
        <updating/>
        <source>populateFromCMIFHeader(_cmifHeader : CMIF_InvoiceExternalRefHeader) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/01/2026	navkc1 JIRA MTN 36571 - ROS - 2 - External Reference updates in API

*/

vars
	cmifSummary		: CMIF_InvoiceExternalRefSummary;
	extRef			: WS_InvoiceExternalReferences;
begin
	self.externalFinancialID 	:= _cmifHeader.externalFinancialID;
	self.externalNumber 		:= _cmifHeader.externalNumber;
	self.externalTaxNumber 		:= _cmifHeader.externalTaxNumber;
	self.numberOfLines			:= _cmifHeader.numberOfLines;
	self.total 					:= _cmifHeader.total;
	
	foreach cmifSummary in _cmifHeader.allSummaries do
		create extRef transient;
		
		extRef.contractID 		:= cmifSummary.contractID;
		extRef.invoiceLineType 	:= cmifSummary.invoiceLineType;
		extRef.numberOfLines 	:= cmifSummary.numberOfLines;
		extRef.cargoType 		:= cmifSummary.cargoType;
		extRef.cargoSubType 	:= cmifSummary.cargoSubType;
		extRef.commodity 		:= cmifSummary.cargoSubType;
		extRef.rate 			:= cmifSummary.rate;
		extRef.total 			:= cmifSummary.total;
		extRef.externalRef1 	:= cmifSummary.externalRef1;
		extRef.externalRef2 	:= cmifSummary.externalRef2;
		extRef.externalRef3 	:= cmifSummary.externalRef3;
		extRef.externalRef4 	:= cmifSummary.externalRef4;
		
		self.externalReferences.add(extRef);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_cmifHeader" type="CMIF_InvoiceExternalRefHeader"/>
    </JadeMethod>
    <JadeMethod name="updateToCMIFHeader" id="1d4c9fe8-8e02-4f57-86dd-0f59e967c340">
        <source>updateToCMIFHeader(_cmifHeader : CMIF_InvoiceExternalRefHeader io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/01/2026	navkc1 JIRA MTN 36571 - ROS - 2 - External Reference updates in API

*/

constants
	NULLVALUE = "&lt;NULL&gt;";

vars
	lineType,
	contractID,
	updateValue 	: String;
	rate			: Decimal[23,6];
	extRef			: WS_InvoiceExternalReferences;
	cmifSummary		: CMIF_InvoiceExternalRefSummary;
begin

	// If request is "&lt;NULL&gt;", we clear the value
	// If request is "", then we ignore it
	// Else, update
	
	// External Financial ID
	updateValue := self.externalFinancialID;
	if updateValue &lt;&gt; null then
		if updateValue =  NULLVALUE then
			_cmifHeader.externalFinancialID := null;
		else
			_cmifHeader.externalFinancialID := updateValue;
		endif;
	endif;
	
	// External Number
	updateValue := self.externalNumber;
	if updateValue &lt;&gt; null then
		if updateValue =  NULLVALUE then
			_cmifHeader.externalNumber := null;
		else
			_cmifHeader.externalNumber := updateValue;
		endif;
	endif;
	
	// External Tax Number
	updateValue := self.externalTaxNumber;
	if updateValue &lt;&gt; null then
		if updateValue =  NULLVALUE then
			_cmifHeader.externalTaxNumber := null;
		else
			_cmifHeader.externalTaxNumber := updateValue;
		endif;
	endif;
	
	foreach cmifSummary in _cmifHeader.allSummaries do
		lineType 	:= cmifSummary.invoiceLineType;
		rate		:= cmifSummary.rate;
		contractID 	:= cmifSummary.contractID;
		
		extRef := self.externalReferences.getAtKey(contractID, lineType, rate);
		
		if extRef = null then
			delete cmifSummary;
			continue;
		endif;
		
		// External Ref 1
		updateValue := extRef.externalRef1;
		if updateValue &lt;&gt; null then
			cmifSummary.externalRef1Update := true;
			if updateValue = NULLVALUE then
				cmifSummary.externalRef1 := null;
			else
				cmifSummary.externalRef1 := updateValue;
			endif;
		endif;
		
		// External Ref 2
		updateValue := extRef.externalRef2;
		if updateValue &lt;&gt; null then
			cmifSummary.externalRef2Update := true;
			if updateValue = NULLVALUE then
				cmifSummary.externalRef2 := null;
			else
				cmifSummary.externalRef2 := updateValue;
			endif;
		endif;
		
		// External Ref 3
		updateValue := extRef.externalRef3;
		if updateValue &lt;&gt; null then
			cmifSummary.externalRef3Update := true;
			if updateValue = NULLVALUE then
				cmifSummary.externalRef3 := null;
			else
				cmifSummary.externalRef3 := updateValue;
			endif;
		endif;
		
		// External Ref 4
		updateValue := extRef.externalRef4;
		if updateValue &lt;&gt; null then
			cmifSummary.externalRef4Update := true;
			if updateValue = NULLVALUE then
				cmifSummary.externalRef4 := null;
			else
				cmifSummary.externalRef4 := updateValue;
			endif;
		endif;
		
	endforeach;
	
	_cmifHeader.allSummaries.rebuild();
epilog
	
end;</source>
        <Parameter name="_cmifHeader" type="CMIF_InvoiceExternalRefHeader" usage="io"/>
    </JadeMethod>
</Class>
