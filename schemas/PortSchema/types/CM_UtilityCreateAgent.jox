// ---------------------------------------------------------------------------
// Created:	02 October 2008 By Graeme Black cnwgb1
// Purpose:	
// 31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCustomsStatusMessage(_proxyMessage);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _realMessage persistent;
	_realMessage.setForCreate(_proxyMessage);
	
	if _passport.noErrors() then
		//self.myCreateAuditAgent.audCreateGeneric(_realMessage);			//31.03.2025 navma1 #MTN-34387
		_realMessage.myBOL.causeEvent(_realMessage.myTerminal.getTerminalEvent(EVENT_EDICUSTOMSMESSAGE), false, _realMessage);
	endif;
	
epilog
end;</source>
