    <JadeMethod name="addOnlyDecksColumn" id="9c4ceb74-53b4-4c62-83b0-812611a04290">
        <source>addOnlyDecksColumn();
/*
Date		    Who			Reason
20 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

constants
	TheBackColor1 = 16768991;
	TheBackColor2 = 14680031;
vars
	idx 		: Integer;
	tbl			: CM_DataTable;
begin
	tbl := self.tblData;
	tbl.fixed3D := false;
	tbl.rows := 0;
	tbl.alignment := Table.Alignment_Center_Top;
	
	idx := tbl.addItem("Decks");
	idx := tbl.addItem("Disch Import");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;
	idx := tbl.addItem("Disch SOB");
	tbl.accessRow(idx).backColor := TheBackColor2;
	tbl.accessCell(idx,1).backColor := TheBackColor2;
	idx := tbl.addItem("Disch DLR");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;
	idx := tbl.addItem("");
	tbl.accessRow(idx).backColor := TheBackColor2;
	tbl.accessCell(idx,1).backColor := TheBackColor2;
	tbl.accessedRow.visible := false;
	idx := tbl.addItem("");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;
	tbl.accessedRow.visible := false;
	idx := tbl.addItem("");
	tbl.accessRow(idx).backColor := TheBackColor2;
	tbl.accessCell(idx,1).backColor := TheBackColor2;
	tbl.accessedRow.visible := false;
	idx := tbl.addItem("Discharge Total");
	tbl.accessRow(idx).backColor := Black;
	tbl.accessRow(idx).foreColor := White;
	tbl.accessCell(idx,1).backColor := Black;
	tbl.accessCell(idx,1).foreColor := White;
	idx := tbl.addItem("Load");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;
	idx := tbl.addItem("Load DLR");
	tbl.accessRow(idx).backColor := TheBackColor2;
	tbl.accessCell(idx,1).backColor := TheBackColor2;
	idx := tbl.addItem("");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;
	tbl.accessedRow.visible := false;
	idx := tbl.addItem("");
	tbl.accessRow(idx).backColor := TheBackColor2;
	tbl.accessCell(idx,1).backColor := TheBackColor2;
	tbl.accessedRow.visible := false;
	idx := tbl.addItem("Load Total");
	tbl.accessRow(idx).backColor := Black;
	tbl.accessRow(idx).foreColor := White;
	tbl.accessCell(idx,1).backColor := Black;
	tbl.accessCell(idx,1).foreColor := White;
	idx := tbl.addItem("");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;
	tbl.accessedRow.visible := false;
	idx := tbl.addItem("Deck Totals");
	tbl.accessRow(idx).backColor := TheBackColor2;
	tbl.accessCell(idx,1).backColor := TheBackColor2;
	idx := tbl.addItem("Forward to Aft");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;
	idx := tbl.addItem("Aft to Forward");
	tbl.accessRow(idx).backColor := TheBackColor2;
	tbl.accessCell(idx,1).backColor := TheBackColor2;
	idx := tbl.addItem("Remarks");
	tbl.accessRow(idx).backColor := TheBackColor1;
	tbl.accessCell(idx,1).backColor := TheBackColor1;

	tbl.fixedRows := 1;
	tbl.accessRow(1).backColor := self.colorHeadingColumn;
	tbl.fixedColumns := 1;
	tbl.accessColumn(1).alignment := Table.Alignment_Left_Top;

end;</source>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="06d2257b-9bde-4190-b410-1f5a5a08be1d">
