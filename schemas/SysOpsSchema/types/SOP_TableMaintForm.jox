    <JadeMethod name="setupForDataAccessController" id="3dfb566d-7014-4502-b7cb-96fac3c2e73c">
        <updating/>
        <source>setupForDataAccessController(pCaption, pMethodName : String; pClass : Class) updating;
// ---------------------------------------------------------------------------
// Created:     05 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myDataClass := CM_DataAccessController;
	self.setTblDataEntRows(ETDef_DataAccessTbl);

	self.myDataAccessClass := pClass;
	
	// setup the controls for the thumbnail display
	
	mulSelect1.availableHeading := self.getDataAccessMulti() &amp; ' available';
	mulSelect1.formDisplayEntryMethodName := pMethodName;
	shtMultiSelect1.caption := pCaption;

	shtTblInput1.visible := false;
	shtMultiSelect1.visible := true;
	lblName.visible := true;
	txtName.visible := true;
	optAllow.visible := true;
	optDisallow.visible := true;
	mulSelect1.visible := true;
	
	mulSelect1.cnEcResizeContents();

end;</source>
        <Parameter name="pCaption" type="String"/>
        <Parameter name="pMethodName" type="String"/>
        <Parameter name="pClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3f9bdecf-647e-4b47-acbc-6b3aa975ce21">
        <updating/>
        <source>setupForm() updating;

// Created by cnwdvb1 on 28 November 2006

// cnwcs5 	ccms1061	
// 18/04/2024	navdap1	TFS 63717 "Table" combo box corrections
begin
	// TFS 63717 start
	if app.doNotFIlterCombos then
		self.cmbTable.style := ComboBox.Style_DropDownComboList;
	endif;
	// TFS 63717 start
	
	inheritMethod();
	self.txtTZShortID.visible:=false; //epr TFS 2495 8/8/16 
	self.portCmbOrderDescrFirst := self.myAssistant.getPortCmbOrderDescFirst;
	
	//25/06/2024	navkc1 CR 64823 Task 64824
	self.frmTableFilter.setCallbackMethod(SOP_TableMaintForm::doFilterTable.name);
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupJRWDesignComboAndSheets" id="e4c98d2d-3465-4698-864e-f0b311d0189d">
        <updating/>
        <source>setupJRWDesignComboAndSheets(_protocolDesc : CM_CamProtocolDesc; _camItem : SOPTM_CamProtocol input) updating;
/*
Date				Who		Reason
11 December 2009	cnwphb1	Initial creation
23/03/2011			cnwcs5	par 27231 - hide/show rows
18/05/2011			cnwcs5	CCMS SCT 2058 / par 27460 - user defined special charac	ters
01/07/2013			cnwcs5	par 31819 - do not allow "send files with no message" for user defined JRW files
// 15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
// 15 Aug 2014	cnwrs1	Par 34561 - Suzano Cams
// 17 Nov 2014  cnwgb1  Par 35255 - AST 2405 Event-based CAMS
//19 May 2015	cnwrs1	Par36271 - Chestnut Hill truck release XML 
//28 Jun 2016  cnwma1  TFS #2226 POL - Update to VERMAS structure from Ship Operators
*/
vars
	isUserDefined	:Boolean;			// cnwcs5 23/03/2011 par 27231
	table			:CM_EntryTable;		// cnwcs5 23/03/2011 par 27231
	tc : ClassColl;
    events : IntegerArray;
begin
	table := self.tblInput1;										// cnwcs5 par 31819 July 2013
	create tc transient;
	create events transient;
	if _protocolDesc &lt;&gt; null then
		//epr TFS 2395 20/7/16
		self.shtMultiSelect6.enabled:=_protocolDesc.useEditTriggers ;
		if _protocolDesc.useEditTriggers then
			if self.mode = self.Mode_View then
				self.mulSelect6.userInputEnabled	:= false;
				self.chkAnyTriggField.enabled		:= false;
			else
				self.mulSelect6.userInputEnabled	:= true;
				self.chkAnyTriggField.enabled		:= true;
			endif;		
		endif;
		
		if _protocolDesc.isUserDefinedReport then
			_camItem.loadJRWDesignNameComboBox(self.JRWView_Transaction);
			
			self.shtMultiSelect8.enabled			:= false;
			self.mulSelect7.userInputEnabled		:= false;
			self.shtMultiSelect2.enabled			:= true;						
			isUserDefined := true;
			
			table.hideRowByName(ETRow_SendMtFiles, false);				// cnwcs5 par 31819 July 2013
			
		elseif _protocolDesc.isUserDefinedEventReport then
			_camItem.loadJRWDesignNameComboBox(self.JRWView_Transaction);
			
			self.shtMultiSelect8.enabled			:= false;
			self.shtMultiSelect2.enabled			:= false;		
			
			if self.mode = self.Mode_View then
				self.mulSelect7.userInputEnabled	:= false;
			else
				self.mulSelect7.userInputEnabled	:= true;
			endif;
			
			isUserDefined := true;
			
			table.hideRowByName(ETRow_SendMtFiles, false);				// cnwcs5 par 31819 July 2013
		else
			_camItem.loadJRWDesignNameComboBox(self.JRWView_None);
			
			self.shtMultiSelect7.enabled			:= false;
			self.shtMultiSelect8.enabled			:= true;
			self.mulSelect7.userInputEnabled		:= false;
			self.shtMultiSelect2.enabled			:= true;
					
			table.showRowByName(ETRow_SendMtFiles, false);				// cnwcs5 par 31819 July 2013
		endif;
		
		table.hideRowByName(ETRow_SingleContainerPerUNB, false);	//10 Apr 2018	NDL	TFS 7556
		table.showRowByName (ETRow_IsSingleTransPerFile, false);	// cnwcs5 23/03/2011 par 27231
		if isUserDefined then 											// cnwcs5 23/03/2011 par 27231
			table.hideRowByName (ETRow_SpecialField11, false); 	//epr par 33034 10/1/14
			table.showRowByName(ETRow_SpecialField14, false);			// cnwcs5 par 31819 July 2013
			table.showRowByName(ETRow_SpecialField15, false);			// cnwcs5 par 31819 July 2013
		else	
			//table.hideRowByName (ETRow_IsSingleTransPerFile, false);	// cnwcs5 23/03/2011 par 27231
			table.showRowByName (ETRow_SpecialField11, false); 	//epr par 33034 10/1/14
			table.hideRowByName(ETRow_SpecialField14, false);			// cnwcs5 par 31819 July 2013
			table.hideRowByName(ETRow_SpecialField15, false);			// cnwcs5 par 31819 July 2013
		endif;															// cnwcs5 23/03/2011 par 27231
		
		if _protocolDesc.isCoarri or _protocolDesc.isCodeco or _protocolDesc.isX12 or _protocolDesc.isVermas  then  // 27/06/2016 cnwma1
			table.showRowByName (ETRow_DecimalCharacter, false);		// par 27460 cnwcs5
			table.showRowByName (ETRow_ElementSeperator, false);		// par 27460 cnwcs5
			table.showRowByName (ETRow_EscapeCharacter, false);			// par 27460 cnwcs5
			table.showRowByName (ETRow_SegmentTerminator, false);		// par 27460 cnwcs5
			table.showRowByName (ETRow_SubElementSeperator, false);		// par 27460 cnwcs5
		else
			table.hideRowByName (ETRow_DecimalCharacter, false);		// par 27460 cnwcs5
			table.hideRowByName (ETRow_ElementSeperator, false);		// par 27460 cnwcs5
			table.hideRowByName (ETRow_EscapeCharacter, false);			// par 27460 cnwcs5
			table.hideRowByName (ETRow_SegmentTerminator, false);		// par 27460 cnwcs5
			table.hideRowByName (ETRow_SubElementSeperator, false);		// par 27460 cnwcs5		
		endif;
		
		//epr 3/2/16 1090 when creating new cam protocl
		_protocolDesc.availableTransactions(tc);
		_protocolDesc.availableEvents(events);
		if not _protocolDesc.requiresCargoType then
			self.shtMultiSelect8.enabled := false;
		endif;
	else
		table.hideRowByName(ETRow_SendMtFiles, false);					// cnwcs5 par 31819 July 2013
		table.hideRowByName(ETRow_SpecialField14, false);				// cnwcs5 par 31819 July 2013
		table.hideRowByName(ETRow_SpecialField15, false);				// cnwcs5 par 31819 July 2013
		
	endif;
	

	
	if tc.size = 0 then
		self.shtMultiSelect2.enabled := false;
	endif;
	
    
    //Should the Events Tab be enabled PAR 35255 cnwgb1 17.11.2014
	
   
    if events.size = 0 then
        self.shtMultiSelect7.enabled := false;
    else
        self.shtMultiSelect7.enabled := true;
        self.mulSelect7.userInputEnabled := (self.mode &lt;&gt; self.Mode_View);
    endif;
epilog
	delete tc;
    delete events;
end;</source>
        <Parameter name="_protocolDesc" type="CM_CamProtocolDesc"/>
        <Parameter name="_camItem" type="SOPTM_CamProtocol" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupMTReportColumnCombo" id="e63f6b30-2180-49d7-93ed-b4da0007929b">
        <source>setupMTReportColumnCombo();
//----------------------------------------------------------------
//	Created:	02 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.cmbMTReportCol.clear;
	self.cmbMTReportCol.addItemAt(null, MTReportTaskColumn_Null);
	self.cmbMTReportCol.addItemAt(app.getErrorString(Wash), MTReportTaskColumn_Wash);
	self.cmbMTReportCol.addItemAt(app.getErrorString(Repair), MTReportTaskColumn_Repair);
	self.cmbMTReportCol.addItemAt(app.getErrorString(Pretrip), MTReportTaskColumn_Pretrip);
	self.cmbMTReportCol.addItemAt(app.getErrorString(PTI_Repair), MTReportTaskColumn_PTIRepair);
	self.cmbMTReportCol.addItemAt(app.getErrorString(Survey), MTReportTaskColumn_Survey);

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTableDetails" id="5172e34a-fa33-48b9-b3e2-620b2a0db2a9">
        <updating/>
        <source>setupTableDetails() updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
