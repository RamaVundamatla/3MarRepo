    <JadeMethod name="addCashOnlyDebtor" id="af35b24e-4f5c-48c8-9366-7311359b9d57">
        <source>addCashOnlyDebtor( _debtorName : String ) : CM_Debtor protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2012	cnwndl1	Initial creation

*/

vars

	debtorNodeController : CMIF_DebtorNode;
	debtorNode : CM_DebtorNode;
	proxyDebtor : CM_Debtor;
	debtorTermDetail : CMIF_DebtorTerminalDetail;
	term : CM_Terminal;
	root : CM_Root;
begin
	root := app.myRoot;
	
	create debtorNodeController transient;
	create proxyDebtor transient;
	
	self.setDebtorNodeController1( _debtorName, debtorNodeController, proxyDebtor );
	self.setInvLineTypes1( proxyDebtor );

	
	 // ### TFS 52237 02NOV2021 NAVAB1 add debtor terminal for all terminals
	foreach term in root.allTerminals do
		create debtorTermDetail transient;
		
		debtorTermDetail.setMyTerminal(term);
		debtorTermDetail.setPaymentType(PaymentType_PostPay);
		debtorTermDetail.setCashOnly(true);
		debtorNodeController.allDebtorTerminalDetails.add(debtorTermDetail);
	endforeach;

	app.myTrxCA.trxCreateDebtorNode( debtorNodeController, debtorNode, app.myPassport );
	
	self.assertTrueMsg(debtorNode &lt;&gt; null, "Cash only Debtor not created..." &amp; app.myPassport.getErrorsAsString);
	
	return debtorNode.CM_Debtor;

epilog
	debtorNodeController.allDebtorTerminalDetails.purge(); // ### TFS 52237 27OCT2021 NAVAB1

	delete proxyDebtor;
	delete debtorNodeController;

end;</source>
        <access>protected</access>
        <Parameter name="_debtorName" type="String"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="addOnsiteCargoForId" id="1303701a-94fe-4387-b5c3-60bfa955df57">
        <updating/>
        <source>addOnsiteCargoForId(_id : String; _createWash : Boolean; _daysBack : Integer) : CM_TrackedItem updating, protected;

/*

Purpose:		Add onsite container with the given id, in UT_BS1, with an optional Washed transaction so there is an existing charge
					also optionally back-date the transactions to get storage charges
Parameters:			

Return Value:		


Date		Who		Reason
22 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars
	baseDate,
	now		: Date;
	ti : CM_TrackedItem;
	type : CM_TerminalAreaType;
	blockStack : CM_BlockStack;
	washTxCont : CMIF_TITransactionController;

begin

	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack &lt;&gt; null, "Block Stack UT_BS1 not found...");

	ti := self.addContainerAtLocation( _id, self.myOperator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.allLocationsControllers.first);
	
	beginTransaction;
	ti.setPropertyValue( "totalWeight", "4000".Decimal );
	
	if _createWash then
		create washTxCont transient;
		washTxCont.type := TRANS_TYPE_WASH;
		washTxCont.noCharge := false;

		ti.createTransaction(washTxCont, app.myPassport);
	endif;
	commitTransaction;
	
	// set transaction dates back the given number of days
	if _daysBack &lt;&gt; 0 then
		baseDate := now - _daysBack;	// cargo create date
		self.setTransactionDate(ti, baseDate);
	endif;

	return ti;

epilog
	delete washTxCont;
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_createWash" type="Boolean"/>
        <Parameter name="_daysBack" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addUnitToProFormaAlloc" id="0127d0e9-cf3f-44ed-988e-743ff98a5cd6">
        <source>addUnitToProFormaAlloc( _alloc : CM_ProformaTransactionCriteria input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	ls : Boolean;
	tType : CM_TransactionType;
	unitType : Integer;
	unitValue : Decimal[16,4];
	proxy : CM_ProformaTransactionUnit;
	
	allPxys : CM_ProformaTransactionUnitDict;

begin

	create allPxys transient;

	app.cmsBeginLoad(ls);
	
	foreach tType in _alloc.allTransactionTypes do
	
		unitType := CM_ProformaTransactionCriteria.UnitType_UserUnit;
		unitValue := 1;
		
		create proxy transient;
		proxy.setProxy(	tType,	//_myTransactionType : CM_TransactionType;
						unitType,	//_unitType : Integer;
						unitValue,	//_unitValue : Decimal;
						_alloc	//_myProformaTransactionCriteria : CM_ProformaTransactionCriteria
						);
					
		allPxys.add( proxy );
					
	endforeach;
					
	app.cmsEndLoad(ls);
	
	app.myTrxUA.trxUpdateProformaCritUnits(_alloc, allPxys, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Error creating transaction units on pro forma allocations - " &amp; app.myPassport.getAllErrorsWarningsAsString);

epilog

	app.cmsEndLoad(ls);
	if allPxys &lt;&gt; null and not allPxys.isEmpty then
		allPxys.purge();
	endif;
	delete allPxys;

end;</source>
        <access>protected</access>
        <Parameter name="_alloc" type="CM_ProformaTransactionCriteria" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cashTestChildCargo" id="1f00d99b-8d25-4a14-994f-1fe171c165dd">
        <updating/>
        <source>cashTestChildCargo(_id : String; _drTerm1 : CM_DebtorTerminal; _truckOut : CM_Vehicle) updating, protected;

/*

Purpose:		Cash module testing, gate out a container with 2 children with storage due and with one full payment.

Parameters:			

Return Value:		


Date		Who		Reason
29/04/2014	cnwjre1	34800
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	
	drTerm1 : CM_DebtorTerminal;
	drTerm2 : CM_DebtorTerminal;
	
	cashReceipt : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	onsiteTi : CM_TrackedItem;
	packTIs, unpackTIs: CM_TIArray;
	wh: CM_IrregularBlockArea;
	cargo1, cargo2: CM_TrackedItem;
	trans	: CM_TITransaction;
	operator	: CM_Operator;

	endDate : Date;
	cashToPay,
	cashTotal,
	cargoEstimatedCashCharges : Decimal[23,6];// [16,4]; // TFS 47529
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	carrier : CM_Carrier;
	
	truckIn : CM_Vehicle;
	truckOut : CM_Vehicle;
	vvrIn : CM_VehicleVisitRecord;
	vvrOut : CM_VehicleVisitRecord;
	
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	allAgents		: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
begin
	msg := method.name;

	truckOut := _truckOut;
	//Now create onsite cargo that will be gated out by truck.
	cargoId := _id;
	onsiteTi := self.addOnsiteCargoForId(cargoId, true, 10);
	self.deleteContainer("MATCHILD001");
	self.deleteContainer("MATCHILD002");
	wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_WAREHOUSE).asString].CM_IrregularBlockArea;
	operator := self.getOperator("UTC1");
	cargo1 := self.addContainerAtLocation("MATCHILD001", operator, "2200", "GENL", 1, wh.allLocationsControllers.first);
	cargo2 := self.addContainerAtLocation("MATCHILD002", operator, "2200", "GENL", 1, wh.allLocationsControllers.first);
	self.assertLocationHasTI(wh.allLocationsControllers.first, cargo1);

	//first pack in 1 child container
	create packTIs transient;
	packTIs.add(cargo1);
	self.packContainer(onsiteTi.CM_Container, packTIs);
	self.packCompleteContainer(onsiteTi.CM_Container);
	self.assertEqualMsg(onsiteTi.numChildren, 1, "Container children incorrect");

	// pack the second child
	packTIs.clear();
	packTIs.add(cargo2);
	self.packContainer(onsiteTi.CM_Container, packTIs);
	self.packCompleteContainer(onsiteTi.CM_Container);
	self.assertEqualMsg(onsiteTi.numChildren, 2, "Container children incorrect");

	
	/*//unpack this container
	create unpackTIs transient;
	unpackTIs.add(cargo1);
	unpackTIs.add(cargo2);
	self.unpackContainer(onsiteTi, unpackTIs);
	self.unpackCompleteContainer(onsiteTi);
	self.assertEqualMsg(onsiteTi.numChildren, 0, "Container children incorrect");
	*/

	// is Storage, FCL, operator UTCH, null voyage, no stops, no agent assigned, 
	beginTransaction;
	onsiteTi.setMyVoyage(self.myVoyage, app.myPassport);
	foreach trans in onsiteTi.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	commitTransaction;

	self.assertTrueMsg(onsiteTi &lt;&gt; null, msg &amp; " On Site Cargo '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi);
	allTIs.add(cargo1);
	allTIs.add(cargo2);
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	agent := self.createProformaAgent(now, onsiteTi);
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;
	allAgents.add(agent);

	agent := self.createProformaAgent(now, cargo1);
	cashTotal := cashTotal + agent.cashPayments;
	cashToPay := cashToPay + agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;
	allAgents.add(agent);

	agent := self.createProformaAgent(now, cargo2);
	cashTotal := cashTotal + agent.cashPayments;
	cashToPay := cashToPay + agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;
	allAgents.add(agent);

	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;

	cashReceipt := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	// 
	
	self.assertTrueMsg(cashReceipt &lt;&gt; null, msg &amp; " Cash Receipt not created...");
	self.assertTrueMsg(cashReceipt.cashValue &gt; 0, msg &amp; " Cash Receipt value not set");

epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	delete unpackTIs;
	delete packTIs;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_truckOut" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="cashTestExtras" id="ff31e2d9-d230-417d-b40e-15db0f96eeb8">
        <updating/>
        <source>cashTestExtras(_id1 : String; _id2 : String; _drTerm1 : CM_DebtorTerminal; _type : Integer) updating, protected;

/*

Purpose:		Cash module testing

Parameters:			

Return Value:		


Date		Who		Reason
13/04/2015	cnwjre1	
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	invoiceEveryReceipt	: Boolean;
	
	cashReceipt1 : CM_CashReceipt;
	cashReceipt2 : CM_CashReceipt;
	cashReceipt3 : CM_CashReceipt;
	cashReceipt : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	profDetail	: CM_ProformaDetails;
	paymentMeth : CM_PaymentMethod;

	status	: Integer;
	isZeroRated : Boolean;
	termsOfTrade : CM_InvoiceTermsOfTrade;
	purchaseOrderNumber : String;
	narration : String;
	numRows		: Integer;
	invoicedString,
	estimatedString,
	extraTrxs	: String;
	invSchema	: Schema;
	invClass	: Class;
	invAssistant	: Object;
	cmif_header	: CMIF_CashReceiptHeader;
	cmif_detail	: CMIF_CashReceiptDetail;

	onsiteTi1,
	onsiteTi2	: CM_TrackedItem;
	trans	: CM_TITransaction;
	vvrOut	: CM_VehicleVisitRecord;
	carrier	: CM_Carrier;
	truckOut	: CM_Vehicle;

	nowDate,
	baseDate,
	endDate : Date;
	total,
	cashToPay,
	cashTotal,
	cargoEstimatedCashCharges : Decimal[23,6];// [16,4]; // TFS 47529
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	service			: CM_Service;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	obj				: Object;
	allAgents		: ObjectArray;
	agent,
	agent1,
	agent2	: CM_CashInvoiceProformaAgent;
	type : CM_TerminalAreaType;
	blockStack1,
	blockStack2	: CM_BlockStack;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
begin
	msg := method.name;
	if self.myTerminal.getConfig(CashInvoiceEveryReceipt).Boolean then
		invoiceEveryReceipt := true;
	endif;

	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");
	blockStack2 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS2").CM_BlockStack;
	self.assertTrueMsg(blockStack2 &lt;&gt; null, "Block Stack UT_BS2 not found...");
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	
	cargoId := _id1;
	onsiteTi1 := self.createContainerFromVoyage(self.myVoyage, cargoId, blockStack1, "22G1", operator, "GENL", "NZPOE", "NZPOE", 2200, 4500).CM_Container;
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, msg &amp; " On Site Cargo 1 '" &amp; cargoId &amp; "' not created...");
	cargoId := _id2;
	onsiteTi2 := self.createContainerFromVoyage(self.myVoyage, cargoId, blockStack1, "22G1", operator, "GENL", "NZPOE", "NZPOE", 2200, 4500).CM_Container;
	self.assertTrueMsg(onsiteTi2 &lt;&gt; null, msg &amp; " On Site Cargo 2 '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi1);
	allTIs.add(onsiteTi2);
	// back-date the transactions to get storage
	baseDate := nowDate - 20;
	self.setTransactionDate(onsiteTi1, baseDate);
	self.setTransactionDate(onsiteTi2, baseDate);
	// move the container to get some current charges - need 3 moves are the move from/to Nowhere are no longer charged after 36460
	self.move(onsiteTi1, blockStack2);
	self.move(onsiteTi2, blockStack2);
	self.move(onsiteTi1, blockStack1);
	self.move(onsiteTi2, blockStack1);
	self.move(onsiteTi1, blockStack2);
	self.move(onsiteTi2, blockStack2);
	
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	agent1 := self.createProformaAgent(now, onsiteTi1);
	allAgents.add(agent1);
	agent2 := self.createProformaAgent(now, onsiteTi2);
	allAgents.add(agent2);
	// agent invoice lines 3 times $20 for move all to UT_Cash1,
	//	3 pro forma lines  Rel road $20, Storage x5 $100 and Storage x15 $600
	//  total to pay 780
	
	cashTotal := agent1.cashPayments + agent2.cashPayments;
	cashToPay := agent1.invoicedCashCharges + agent1.estimatedCashCharges + agent2.invoicedCashCharges + agent2.estimatedCashCharges - cashTotal;		// should be 2 x 780

	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
	
// TFS 45953 not used anymore	agent1.setIncludeManual(true);
	agent1.createExtraProformaLines("Credit", -700.00);
// TFS 45953 not used anymore	agent2.setIncludeManual(true);
	agent2.createExtraProformaLines("Credit", -700.00);
	cashToPay := cashToPay - 1400;			// should be 160

	cashReceipt1 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, msg &amp; " Cash Receipt 1 for on site cargo not created...");

	count := 0;
	foreach cashPayment in cashReceipt1.allCashPayments do
		count := count + 1;
		if count &lt; 5 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		elseif count = 5 or count = 12 then
			self.assertEqualMsg(cashPayment.cashValue, 100.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		elseif count = 6 or count = 13 then
			self.assertEqualMsg(cashPayment.cashValue, 600.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		elseif count = 7 or count = 14 then
			self.assertEqualMsg(cashPayment.cashValue, -700.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		else
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		endif;
	endforeach;
	assertEqualMsg(count, 14, msg &amp; " Receipt 1 cash payments");
	
epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	delete invAssistant;
	if cmif_header &lt;&gt; null then
		cmif_header.allDetails.purge;
		delete cmif_header;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_id1" type="String"/>
        <Parameter name="_id2" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cashTestMultipleReceipts10" id="54e2c8f2-1088-4830-9391-81424cc8a735">
        <updating/>
        <source>cashTestMultipleReceipts10(_id1 : String; _id2 : String; _drTerm1 : CM_DebtorTerminal; _type : Integer) updating, protected;
/*
Purpose - 	Test split and then merge of invoice lines for cash debtor that have a calc type of to do resource quantiity

				Create cargo on ship (break bulk splittable) Splittable cargo quantity of 4, volume of 1012.8275 weight of 18143.68.
				transaction map has mapping for move from ship to yard and storage. 
				
				Discharge 1st item in 1 part will be 1 invoice line
				Then Split into 4 parts, different IDs using SPLIT TRX
				Should be 1 proportional invoice line on each TI
				
				Add a to do on all TIs
				Complete to do on all and enter resource quantity
				
				check that each has the appropriate invoice line.
				
				Then Merge into 1 part, using MERGE TRX
				Should be 4 invoice lines because there are 4 seperate transactions.

				Then Split TI into 4 parts, different IDs using SPLIT TRX
				
				Should be 5 invoice lines  TI, 1 for each to do and the discharge line
				
				Then Merge into 1 part, using MERGE TRX
				Should be 4 invoice lines because there are 4 seperate transactions.
	
				Who - NAVAB1
Date - 07AUG2025
ADO - JIRA 35638
*/

constants

vars
	cargoId		: String;
	msg			: String;
	idx : Integer;

	onsiteTi1,onsiteTi2,
	cashTI1	: CM_TrackedItem;

	
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;

	type : CM_TerminalAreaType;
	blockStack1,
	blockStack2	: CM_BlockStack;
	tempID : String;
	ct : CM_CargoType;
	port : CM_Port;
	invLine : CM_InvoiceLine;
	newTiIds: StringArray;
	allTisToMerge, allTIsForTODO : CM_TISet;
	todotaskDesc : CM_ToDoTaskDesc;
	todotask : CM_ToDoTask;
	resourceType : CM_ResourceType;
	proxyResourceTypeUsage : CM_ResourceTypeUsage;
	tiTrx : CM_TITransaction;
		resourceUsageProxys 	: CM_ResourceTypeUsageSet;

begin
	msg := method.name;
	
	//self.myTerminal.setConfig(InvoiceRoundLineTotal,2);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2);

	//self.assertTrueMsg(ct &lt;&gt; null, "Cargo Type 15104 - UTBY is null");
	if self.opts.includesKey("CargoType") then
		ct := self.opts.obj("CargoType").CM_CargoType;
	endif;
	self.assertNotNullMsg(ct, "Failed to get cargo Type");
	
	port := app.myRoot.allPorts["NZAKL"];
	self.assertTrueMsg(port &lt;&gt; null, "port is null");
	
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");
	blockStack2 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS2").CM_BlockStack;
	self.assertTrueMsg(blockStack2 &lt;&gt; null, "Block Stack UT_BS2 not found...");
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	
	self.deleteCargo(_id1 &amp; "-01", ct);
	self.deleteCargo(_id1 &amp; "-02", ct);
	self.deleteCargo(_id1 &amp; "-03", ct);
	cargoId := _id1;
	cashTI1 := self.createGCOnShipQWV(null,cargoId, ct,operator,  self.myVoyage,port , 18143.68, 13.000,4 );
	
	self.assertTrueMsg(cashTI1 &lt;&gt; null, "On Ship Cargo 1 '" &amp; cargoId &amp; "' not created...");
	self.assertTrueMsg(cashTI1.totalQuantity = 4,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong quantity SBE 4 is " &amp; cashTI1.totalQuantity.String);
	self.assertTrueMsg(cashTI1.totalVolume = 13,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong volume SBE 13 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight = 18143.68,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong weight SBE 18143.68 is " &amp; cashTI1.totalWeight.String);
	
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	beginTransaction;
	cashTI1.setPropertyValue("myCustomsAgent",customsAgent);
	commitTransaction;

	// ### MOVE all
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",4); // Move ALL
	self.move(cashTI1, blockStack1);

	onsiteTi1 := blockStack1.getTiById(_id1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 4, "OnsiteTi1 sbe 4");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 1, "OnsiteTi1 should have 1 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitDis", "OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 374.40, "OnsiteTi1 has wrong invoice line total - 2.1SA is " &amp; invLine.lineTotal.String);


	
	// ###### SPLIT
	cashTI1 := onsiteTi1;
	create newTiIds transient;
	newTiIds.add(_id1 &amp; "-01");
	newTiIds.add(_id1 &amp; "-02");
	newTiIds.add(_id1 &amp; "-03");
	app.myTrxUA.trxSplitBreakBulkToNewID(	onsiteTi1.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											1,	//_quantity : Integer;
											3.25,	// _weightOrVolume : Decimal;
											onsiteTi1.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON SPLIT 1 ");

	create allTisToMerge transient;
	create allTIsForTODO transient;
	
	tempID := _id1;
	onsiteTi1 := blockStack1.getTiById(tempID);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, tempID &amp; " OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1, tempID &amp; " OnsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi1.totalVolume = 3.25, tempID &amp; " OnsiteTi1 sbe 3.25 is " &amp; onsiteTi1.totalVolume.String);

	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), tempID &amp; " OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 1, tempID &amp; " OnsiteTi1 should have 2 invoice lines");
	
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitDis", "1.1 OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 93.60, "Merged OnsiteTi1 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(invLine.totalAmount = 93.60, "Merged OnsiteTi1 has wrong invoice total amount - 2.4DDA is " &amp; invLine.totalAmount.String);
	self.assertTrueMsg(invLine.totalRate = 28.8, "Merged OnsiteTi1 has wrong invoice total rate - 2.5DDA is " &amp; invLine.totalAmount.String);
	
	
	
	
	allTIsForTODO.add(onsiteTi1);
	
	tempID := _id1 &amp; "-01";
	onsiteTi1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(onsiteTi1);
	allTIsForTODO.add(onsiteTi1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, tempID &amp; " OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1, tempID &amp; " OnsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi1.totalVolume = 3.25, tempID &amp; " OnsiteTi1 sbe 3.25 is " &amp; onsiteTi1.totalVolume.String);

	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), tempID &amp; " OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 1, tempID &amp; " OnsiteTi1 should have 2 invoice lines");
	
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitDis", "1.1 OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 93.60, "Merged OnsiteTi1 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(invLine.totalAmount = 93.60, "Merged OnsiteTi1 has wrong invoice total amount - 2.4DDA is " &amp; invLine.totalAmount.String);
	self.assertTrueMsg(invLine.totalRate = 28.8, "Merged OnsiteTi1 has wrong invoice total rate - 2.5DDA is " &amp; invLine.totalAmount.String);
	
	tempID := _id1 &amp; "-02";
	onsiteTi1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(onsiteTi1);
	allTIsForTODO.add(onsiteTi1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, tempID &amp; " OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1, tempID &amp; " OnsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi1.totalVolume = 3.25, tempID &amp; " OnsiteTi1 sbe 3.25 is " &amp; onsiteTi1.totalVolume.String);

	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), tempID &amp; " OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 1, tempID &amp; " OnsiteTi1 should have 2 invoice lines");
	
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitDis", "1.1 OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 93.60, "Merged OnsiteTi1 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(invLine.totalAmount = 93.60, "Merged OnsiteTi1 has wrong invoice total amount - 2.4DDA is " &amp; invLine.totalAmount.String);
	self.assertTrueMsg(invLine.totalRate = 28.8, "Merged OnsiteTi1 has wrong invoice total rate - 2.5DDA is " &amp; invLine.totalAmount.String);
	
	tempID := _id1 &amp; "-03";
	onsiteTi1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(onsiteTi1);
	allTIsForTODO.add(onsiteTi1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, tempID &amp; " OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1, tempID &amp; " OnsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi1.totalVolume = 3.25, tempID &amp; " OnsiteTi1 sbe 3.25 is " &amp; onsiteTi1.totalVolume.String);

	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), tempID &amp; " OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 1, tempID &amp; " OnsiteTi1 should have 2 invoice lines");
	
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitDis", "1.1 OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 93.60, "Merged OnsiteTi1 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(invLine.totalAmount = 93.60, "Merged OnsiteTi1 has wrong invoice total amount - 2.4DDA is " &amp; invLine.totalAmount.String);
	self.assertTrueMsg(invLine.totalRate = 28.8, "Merged OnsiteTi1 has wrong invoice total rate - 2.5DDA is " &amp; invLine.totalAmount.String);
	
	// ###### ADD TO DO TASK
	todotaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["Palletised"];
	self.addToDoTask(todotaskDesc,allTIsForTODO);
	todotask := onsiteTi1.allToDoTasksToDo.first;
	self.assertTrueMsg(todotask &lt;&gt; null, todotaskDesc.description &amp; " not created on TI1");
	
	create resourceUsageProxys transient;
	foreach resourceType in todotaskDesc.allResourceTypes as CM_ResourceType do 
		create proxyResourceTypeUsage transient;
		proxyResourceTypeUsage.setProxy(	resourceType,					//_resourceType : CM_ResourceType;
											null,							//_transaction 	: CM_TITransaction;
											false,						    //_noCharge 	: Boolean;
											5.0,							//_quantity		: Decimal;
											resourceType.description,		//_remarks 		: String;
											CM_InvoiceLine.STATUS_NORMAL,	//_status 		: Integer;
											null, null,null,null,null);		
		resourceUsageProxys.add(proxyResourceTypeUsage);

	endforeach;
	
	self.completeToDoTask(todotaskDesc,allTIsForTODO , resourceUsageProxys);
	
	// check trans and resources
	foreach onsiteTi2 in allTIsForTODO do
		tiTrx := onsiteTi2.allTransactions.last;
		self.assertTrueMsg(tiTrx &lt;&gt; null, "Transaction not created for " &amp; onsiteTi2.id &amp; " todo issue");
		self.assertTrueMsg( tiTrx.myToDoTask.toDoTaskDesc = todotaskDesc, 		"FAIL Completion of To Do Task '" 			  &amp; todotaskDesc.description &amp; "' for " &amp; onsiteTi2.id &amp; " to create transaction." );
		self.assertTrueMsg( tiTrx.allResourceUsages.size = todotaskDesc.allResourceTypes.size, todotaskDesc.description &amp; " Resource Count not correct" );
	
		self.assertTrueMsg(tiTrx.allInvoiceLines.isNotEmpty(),  todotaskDesc.description &amp;  " did not charge for " &amp; onsiteTi2.id);
		invLine := tiTrx.allInvoiceLines.first;
		self.assertTrueMsg(invLine &lt;&gt; null,  todotaskDesc.description &amp;  " no invoice line " &amp; onsiteTi2.id);
		self.assertTrueMsg(invLine.invoiceLineDesc.narration = "UT_LneSplitRes", todotaskDesc.description &amp;  " wrong invoice line type for " &amp; onsiteTi2.id);
		self.assertTrueMsg(invLine.totalAmount = 144.00, "Merged OnsiteTi1 has wrong invoice total amount - 2.4SEA is " &amp; invLine.totalAmount.String);
	
	endforeach;
	
	// #### MERGE
	app.myTrxUA.trxMergeBreakBulk(cashTI1.CM_Cargo,	//_targetTi : CM_BreakBulkGeneric;
										allTisToMerge,	//_allItemsToBeMerged : CM_TISet;
										app.myPassport	//_passport : CM_Passport input
										);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON MERGE 1 ");

	onsiteTi1 := blockStack1.getTiById(_id1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "Merged OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 4, "Merged OnsiteTi1 sbe 4");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "Merged OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 5, "Merged OnsiteTi1 should have 5 invoice line");
	
	
	

	// ##### SPLIT AGAIN
	app.myTrxUA.trxSplitBreakBulkToNewID(	onsiteTi1.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											1,	//_quantity : Integer;
											3.25,	// _weightOrVolume : Decimal;
											onsiteTi1.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON SPLIT 2 ");

	allTIsForTODO.clear;
	allTIsForTODO.add(onsiteTi1);
	onsiteTi1.allSplitChildrenTis.copy(allTIsForTODO);
	
	foreach onsiteTi2 in allTIsForTODO do
		if onsiteTi2.isZombie then
			continue;
		endif;

		tempID := onsiteTi2.id;
		onsiteTi1 := blockStack1.getTiById(tempID);
		cashTI1 := onsiteTi1;
		self.assertTrueMsg(onsiteTi1 &lt;&gt; null, tempID &amp; " OnsiteTi1 is null");
		self.assertTrueMsg(onsiteTi1.totalQuantity = 1, tempID &amp; " OnsiteTi1 sbe 2");
		self.assertTrueMsg(onsiteTi1.totalVolume = 3.25, tempID &amp; " OnsiteTi1 sbe 3.25 is " &amp; onsiteTi1.totalVolume.String);

		self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), tempID &amp; " OnsiteTi1 should have invoice line");
		self.assertTrueMsg(onsiteTi1.invoiceLines.size = 5, tempID &amp; " OnsiteTi1 should have 5 invoice lines");
		
		idx := 1;
		foreach invLine in onsiteTi2.invoiceLines do
			if idx = 1 then
				self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitDis", tempID &amp; " 3.1 OnsiteTi1 has wrong invoice line type");
				self.assertTrueMsg(invLine.lineTotal = 93.6, tempID &amp; " Merged-2 OnsiteTi1 has wrong invoice line total - 2.222SA is " &amp; invLine.lineTotal.String);
			else
				self.assertTrueMsg(invLine &lt;&gt; null, tempID &amp; " Merged-2 OnsiteTi1 has no invoice line");
				self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitRes", tempID &amp; " 3.2 OnsiteTi1 has wrong invoice line type");
				self.assertTrueMsg(invLine.lineTotal = 36.00, tempID &amp; " Merged-2 OnsiteTi1 has wrong invoice line total - 2.222SB is " &amp; invLine.lineTotal.String);
			endif;

			idx += 1;
		endforeach;
		
	endforeach;
	

epilog
	if resourceUsageProxys &lt;&gt; null then
		resourceUsageProxys.purge();
		delete resourceUsageProxys;
	endif;

	if allTisToMerge&lt;&gt; null then
		beginTransaction;
		allTisToMerge.purge;
		commitTransaction;
	endif;
	delete allTisToMerge;

	delete newTiIds;
	if allTIsForTODO&lt;&gt; null then
		beginTransaction;
		allTIsForTODO.purge;
		commitTransaction;
	endif;
	delete allTIsForTODO;
end;</source>
        <access>protected</access>
        <Parameter name="_id1" type="String"/>
        <Parameter name="_id2" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cashTestMultipleReceipts2" id="1d9e9bc6-ff0f-4990-9331-9a2564fb1271">
        <updating/>
        <source>cashTestMultipleReceipts2(_id1 : String; _id2 : String; _drTerm1 : CM_DebtorTerminal; _type : Integer) updating, protected;
/*

Purpose:		Cash module testing, TFS 2073 invoice lines being added to posted invoices.
				This code sets cargo, transactions and receipts as per the document to reproduce this issue attached to the TFS.
Parameters:			

Return Value:		


Date		Who		Reason
22/06/2016	cnwjre1	TFS 2073 
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	invoiceEveryReceipt	: Boolean;
	
	cashReceipt1 : CM_CashReceipt;
	cashReceipt2 : CM_CashReceipt;
	cashPayment	: CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	status	: Integer;
	isZeroRated : Boolean;
	termsOfTrade : CM_InvoiceTermsOfTrade;
	purchaseOrderNumber : String;
	narration : String;
	invAssistant	: Object;

	onsiteTi1,
	onsiteTi2	: CM_TrackedItem;
	vvrOut	: CM_VehicleVisitRecord;
	carrier	: CM_Carrier;
	truckOut	: CM_Vehicle;

	nowDate,
	baseDate,
	endDate : Date;
	cashToPay,
	cashTotal	: Decimal[23,6];// [16,4]; // TFS 47529
	postedInvoice,
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	debtorType	: CM_DebtorType;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	obj				: Object;
	allAgents		: ObjectArray;
	agent,
	agent1,
	agent2	: CM_CashInvoiceProformaAgent;
	type : CM_TerminalAreaType;
	blockStack1,
	blockStack2	: CM_BlockStack;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
begin
	msg := method.name;
	if self.myTerminal.getConfig(CashInvoiceEveryReceipt).Boolean then
		invoiceEveryReceipt := true;
	endif;

	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");
	blockStack2 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS2").CM_BlockStack;
	self.assertTrueMsg(blockStack2 &lt;&gt; null, "Block Stack UT_BS2 not found...");
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	
	cargoId := _id1;
	onsiteTi1 := self.createContainerFromVoyage(self.myVoyage, cargoId, blockStack1, "22G1", operator, "GENL", "NZPOE", "NZPOE", 2200, 4500).CM_Container;
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, msg &amp; " On Site Cargo 1 '" &amp; cargoId &amp; "' not created...");
	cargoId := _id2;
	onsiteTi2 := self.createContainerFromVoyage(self.myVoyage, cargoId, blockStack1, "22G1", operator, "GENL", "NZPOE", "NZPOE", 2200, 4500).CM_Container;
	self.assertTrueMsg(onsiteTi2 &lt;&gt; null, msg &amp; " On Site Cargo 2 '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi1);
	allTIs.add(onsiteTi2);
	// back-date the transactions to get storage
	baseDate := nowDate - 20;
	self.setTransactionDate(onsiteTi1, baseDate);
	self.setTransactionDate(onsiteTi2, baseDate);
	
	// move the second container to get some current charges
	self.move(onsiteTi2, blockStack2);
	self.move(onsiteTi2, blockStack1);
	self.move(onsiteTi2, blockStack2);
	
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	agent1 := self.createProformaAgent(now, onsiteTi1);
	allAgents.add(agent1);
	agent2 := self.createProformaAgent(now, onsiteTi2);
	allAgents.add(agent2);
	// agent 1 no invoice lines
	//	3 pro forma lines  Rel road $20, Storage x5 $100 and Storage x15 $600
	//  total to pay 720
	// agent 2 invoice lines 3 times $20 for move all to debtor UT_Cash1,
	//	3 pro forma lines  Rel road $20, Storage x5 $100 and Storage x15 $600
	//  total to pay 780
	
	cashTotal := agent1.cashPayments;
	cashToPay := agent1.invoicedCashCharges + agent1.estimatedCashCharges - cashTotal;
	
	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
	
	// first receipt is for the pro forma only
	//  deselect the invoice lines
	cashToPay := 0;
	foreach obj in allAgents do
		agent := obj.CM_CashInvoiceProformaAgent;
		agent.allCurrentInvLines.clear(); // TFS 45953

// TFS 45953		foreach invLine in agent.allCurrentInvLines do
// TFS 45953			agent.setSelected(false, false, invLine);
// TFS 45953		endforeach;
		cashToPay := cashToPay + agent.getTotal();
	endforeach;
	///cashToPay := 1440;			// the pro forma charges only for both tis

	cashReceipt1 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, msg &amp; " Cash Receipt 1 for on site cargo not created...");

	// gate first container out
	// create carrier and truck
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	// Clear all the stops
	self.deleteStops(onsiteTi1);

	vvrOut := self.createVVR( truckOut, onsiteTi1 );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 
	
	// post the invoice from the first receipt
	if _type = 1 then
		cashInvoice := cashReceipt1.myCashInvoice;
		if cashInvoice.status = CM_Invoice.INVOICE_SUSPENSE then
			beginTransaction;
			cashInvoice.setPropertyValue("status", CM_Invoice.INVOICE_OPEN);
			commitTransaction;
		endif;
		status := CM_Invoice.INVOICE_PENDING;
		self.updateInvoiceStatus(cashInvoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, false);
		self.assertEqualMsg(cashInvoice.status, CM_Invoice.INVOICE_PENDING, "Invoice " &amp; count.String &amp; " Pending");

		status := CM_Invoice.INVOICE_POSTED;
		isZeroRated := true;
		purchaseOrderNumber := "ABC123";
		narration := "Unit test";
		self.updateInvoiceStatus(cashInvoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, false);
		self.assertEqualMsg(cashInvoice.status, CM_Invoice.INVOICE_POSTED, "Invoice " &amp; count.String &amp; " POSTED");
		postedInvoice := cashInvoice;
		// should be 3 payments and 6 lines
		count := 0;
		foreach cashPayment in postedInvoice.allCashPayments do
			count := count + 1;
		endforeach;
		self.assertEqualMsg(count, 6, "posted invoice cash payments");
		count := 0;
		foreach invLine in postedInvoice.invoiceLines do
			count := count + 1;
		endforeach;
		
		if invoiceEveryReceipt then // TFS 48127 JLGAB1
			self.assertEqualMsg(count, 3, "posted invoice lines"); // TFS 48127 JLGAB1
		else
			self.assertEqualMsg(count, 6, "posted invoice lines");
		endif;
	endif;
	// NOTE: receipt 1 POSTED invoice has 3 payments and 6 lines

	// second receipt is for the current invoice lines, second cargo item
	//  Create new agent
	delete agent1;
	delete agent2;
	allAgents.clear();
	agent1 := self.createProformaAgent(now, onsiteTi2);
	allAgents.add(agent1);
	cashToPay := 0;
	// clear the proforma invoice lines (should be paid anyway)
	foreach obj in allAgents do
		agent := obj.CM_CashInvoiceProformaAgent;
		agent.allProformaInvLines.purge(); // TFS 45953
// TFS 45953		foreach invLine in agent.allProformaInvLines do
// TFS 45953			agent.setSelected(true, false, invLine);
// TFS 45953		endforeach;
		cashToPay := cashToPay + agent.getTotal();
	endforeach;

	///cashToPay := 60;		// 3 * 20 for Move

	cashReceipt2 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	self.assertTrueMsg(cashReceipt2 &lt;&gt; null, msg &amp; " Cash Receipt 2 for on site cargo not created...");
	
	// gate second container out
	// create carrier and truck
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	// Clear all the stops
	self.deleteStops(onsiteTi2);

	vvrOut := self.createVVR( truckOut, onsiteTi2 );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 
	
	// NOTE: receipt 1 POSTED invoice NOW has 6 payments and 9 lines (was posted with 3 payments and 6 lines)
	//  the extra payments are actually correct as they are for the 3 posted but not yet paid for Moves
	//  the extra 3 lines are wrong as they are storage for the second TI and should go to the invoice of the second receipt.
	// NOTE: receipt 2 invoice has 3 payments and NO lines (it should have the 3 storage lines).
		// should be 3 payments and 6 lines
	// Posted invoice should be the same
	count := 0;
	foreach cashPayment in postedInvoice.allCashPayments do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 3, "posted invoice cash payments at end");
	count := 0;
	foreach invLine in postedInvoice.invoiceLines do
		count := count + 1;
	endforeach;

	if invoiceEveryReceipt then // TFS 48127 JLGAB1
		self.assertEqualMsg(count, 3, "posted invoice lines at end"); // TFS 48127 JLGAB1
	else
		self.assertEqualMsg(count, 6, "posted invoice lines at end");
	endif;
		
	// posted invoice should be different from receipt 1 cash invoice
	cashInvoice := cashReceipt1.myCashInvoice;
	self.assertNotEqualMsg(cashInvoice, postedInvoice, "receipt 1 cash invoice at end");
	// receipt 1 should have a new invoice with the lines and payments for release+storage of item 2
	count := 0;
	foreach cashPayment in cashInvoice.allCashPayments do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 3, "receipt 1 invoice cash payments at end");
	count := 0;
	foreach invLine in cashInvoice.invoiceLines do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 3, "receipt 1 invoice lines at end");
	
	// receipt 2 invoice should have the payments only for the Move charges of item 1
	cashInvoice := cashReceipt2.myCashInvoice;
	count := 0;
	foreach cashPayment in cashInvoice.allCashPayments do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 3, "receipt 2 invoice cash payments at end");
	count := 0;
	foreach invLine in cashInvoice.invoiceLines do
		count := count + 1;
	endforeach;
	if invoiceEveryReceipt then // TFS 48127 JLGAB1
		self.assertEqualMsg(count, 3, "receipt 2 invoice lines at end");
	else
		self.assertEqualMsg(count, 0, "receipt 2 invoice lines at end");
	endif;
epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	delete invAssistant;
end;</source>
        <access>protected</access>
        <Parameter name="_id1" type="String"/>
        <Parameter name="_id2" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cashTestMultipleReceipts2a" id="0d00de37-9b79-4dd4-bcc7-e7be36d333a1">
        <updating/>
        <source>cashTestMultipleReceipts2a(_id1 : String; _drTerm1 : CM_DebtorTerminal input; _type : Integer) updating, protected;
/*

Purpose:		Test par 37956, one receipt for charges and pro forma then another a few days later, change the debtor to be credit
				and release the cargo.  This tests the example given in the par.

Parameters:			

Return Value:		


Date		Who		Reason
22/06/2016	cnwjre1	TFS 2186

*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	expected	: Integer;
	count		: Integer;
	invoiceEveryReceipt	: Boolean;
	
	cashReceipt1 : CM_CashReceipt;
	cashReceipt2 : CM_CashReceipt;
	cashReceipt3	: CM_CashReceipt;
	cashPayment	: CM_CashPayment;
	profDetail	: CM_ProformaDetails;
	paymentMeth : CM_PaymentMethod;

	status	: Integer;
	isZeroRated : Boolean;
	termsOfTrade : CM_InvoiceTermsOfTrade;
	purchaseOrderNumber : String;
	narration : String;
	invAssistant	: Object;

	onsiteTi1	: CM_TrackedItem;
	vvrOut	: CM_VehicleVisitRecord;
	carrier	: CM_Carrier;
	truckOut	: CM_Vehicle;

	nowDate,
	baseDate,
	endDate : Date;
	profTotal,
	lineTotal,
	cashToPay,
	cashTotal	: Decimal [23,6];
	postedInvoice,
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	debtorType	: CM_DebtorType;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	obj				: Object;
	allAgents		: ObjectArray;
	agent,
	agent1,
	agent2	: CM_CashInvoiceProformaAgent;
	type : CM_TerminalAreaType;
	blockStack1,
	blockStack2	: CM_BlockStack;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
begin
	msg := method.name;
	self.setTerminalConfig(CashInvoiceEveryReceipt, true);
	invoiceEveryReceipt := true;

	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");
	blockStack2 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS2").CM_BlockStack;
	self.assertTrueMsg(blockStack2 &lt;&gt; null, "Block Stack UT_BS2 not found...");
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	
	cargoId := _id1;
	onsiteTi1 := self.createContainerFromVoyage(self.myVoyage, cargoId, blockStack1, "22G1", operator, "GENL", "NZPOE", "NZPOE", 2200, 4500).CM_Container;
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, msg &amp; " On Site Cargo 1 '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi1);
	// back-date the transactions to get storage
	baseDate := nowDate - 20;
	self.setTransactionDate(onsiteTi1, baseDate);
	
	// move the container to get some current charges
	self.move(onsiteTi1, blockStack2);
	self.move(onsiteTi1, blockStack1);
	self.move(onsiteTi1, blockStack2);
	
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	// first payment effective 4 days ago
	now.setDate(nowDate - 4);
	agent1 := self.createProformaAgent(now, onsiteTi1);
	allAgents.add(agent1);
	// agent 1 invoice lines 3 times $20 for move all to debtor UT_Cash1,
	//	3 pro forma lines  Rel road $20, Storage x5 $100 and Storage x11 $440
	//  total to pay 620
	
	cashToPay := agent1.getTotal();		// 620
	
	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
	
	// first receipt is for all charges

	cashReceipt1 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, msg &amp; " Cash Receipt 1 for on site cargo not created...");

	
	// second receipt is for an extra 4 days storage
	//  Create new agent
	delete agent1;
	allAgents.clear();
	now.setDate(nowDate);
	agent1 := self.createProformaAgent(now, onsiteTi1);
	allAgents.add(agent1);

	cashToPay := agent1.getTotal();		// 160 for the extra storage

	cashReceipt2 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	self.assertTrueMsg(cashReceipt2 &lt;&gt; null, msg &amp; " Cash Receipt 2 for on site cargo not created...");
	
	// check the receipts before releasing
	count := 0;
	cashTotal := 0;
	foreach cashPayment in cashReceipt1.allCashPayments do
		count := count + 1;
		cashTotal := cashTotal + cashPayment.cashValue;
	endforeach;
	self.assertEqualMsg(count, 6, "receipt 1 cash payments");
	self.assertEqualMsg(cashTotal, 620.Decimal, "Receipt 1 cash payment total");
	count := 0;
	lineTotal := 0;
	foreach invLine in cashReceipt1.allInvoiceLines do
		count := count + 1;
		lineTotal := lineTotal + invLine.lineTotal;
	endforeach;
	self.assertEqualMsg(count, 3, "receipt 1 invoice lines");
	self.assertEqualMsg(lineTotal, 60.Decimal, "Receipt 1 invoice line total");
	count := 0;
	profTotal := 0;
	foreach profDetail in cashReceipt1.allProformaDetails do
		count := count + 1;
		profTotal := profTotal + profDetail.lineTotal;
	endforeach;
	self.assertEqualMsg(count, 3, "receipt 1 pro forma details");
	self.assertEqualMsg(profTotal, 560.Decimal, "Receipt 1 proforma detail total");

	count := 0;
	cashTotal := 0;
	foreach cashPayment in cashReceipt2.allCashPayments do
		count := count + 1;
		cashTotal := cashTotal + cashPayment.cashValue;
	endforeach;
	self.assertEqualMsg(count, 1, "receipt 2 cash payments");
	self.assertEqualMsg(cashTotal, 160.Decimal, "Receipt 2 cash payment total");
	count := 0;
	lineTotal := 0;
	foreach invLine in cashReceipt2.allInvoiceLines do
		count := count + 1;
		lineTotal := lineTotal + invLine.lineTotal;
	endforeach;
// TFS 45953	self.assertEqualMsg(count, 3, "receipt 2 invoice lines");
// TFS 45953	self.assertEqualMsg(lineTotal, 60.Decimal, "Receipt 2 invoice line total");
	self.assertEqualMsg(count, 0, "receipt 2 invoice lines");// TFS 45953 there should be no invoice lines. the invoice lines are on the first cash receipt
	self.assertEqualMsg(lineTotal, 0.Decimal, "Receipt 2 invoice line total");// TFS 45953
	count := 0;
	profTotal := 0;
	foreach profDetail in cashReceipt2.allProformaDetails do
		count := count + 1;
		profTotal := profTotal + profDetail.lineTotal;
	endforeach;
// TFS 45953		self.assertEqualMsg(count, 3, "receipt 2 pro forma details");
// TFS 45953		self.assertEqualMsg(profTotal, 160.Decimal, "Receipt 2 proforma detail total");
	self.assertEqualMsg(count, 1, "receipt 2 pro forma details");// TFS 45953 there should only 1 proforma, it matches the single cash payment
	self.assertEqualMsg(profTotal, 160.Decimal, "Receipt 2 proforma detail total"); // TFS 45953	

	// make this debtor no longer cash-only
	beginTransaction;
	_drTerm1.setCashOnly(false);
	commitTransaction;

	
	// gate container out
	// create carrier and truck
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	// Clear all the stops
	self.deleteStops(onsiteTi1);

	vvrOut := self.createVVR( truckOut, onsiteTi1 );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 
	
	// receipt 1 invoice should have the original charges and all of the payments on it
	cashInvoice := cashReceipt1.myCashInvoice;
	count := 0;
	foreach cashPayment in cashInvoice.allCashPayments do
		count := count + 1;
	endforeach;
	//self.assertEqualMsg(count, 7, "receipt 1 invoice cash payments at end");
	count := 0;
	foreach invLine in cashInvoice.invoiceLines do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 3, "receipt 1 invoice lines at end " &amp; _type.String);
	
	// nothing on receipt 2 invoice
	cashInvoice := cashReceipt2.myCashInvoice;
	count := 0;
	foreach cashPayment in cashInvoice.allCashPayments do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 1, "receipt 2 invoice cash payments at end");
	count := 0;
	foreach invLine in cashInvoice.invoiceLines do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 0, "receipt 2 invoice lines at end");
	
	// the first 3 lines are the paid Move lines, the next 3 are the unpaid storage lines on a separate Yard invoice
	count := 0;
	foreach invLine in onsiteTi1.invoiceLines do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 6, "cargo invoice lines at end");

epilog
	beginTransaction;
	_drTerm1.setCashOnly(true);
	commitTransaction;

	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	delete invAssistant;
end;</source>
        <access>protected</access>
