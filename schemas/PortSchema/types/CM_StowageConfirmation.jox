    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="1688a9be-3a93-43fc-9628-16338ee7e6f1">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_StowageConfirmController; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
08 November 2011	cnwer1	Initial creation CCMS MES 1033
16 Febrary 2022		navlw1 	TFS# 52579 PCC RORO Scanning Integration added remarks
*/

vars

begin
	inheritMethod(_tiTransCntrl, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	self.confirmedLocation := _tiTransCntrl.confirmedLocation;
	self.plannedLocation:= _tiTransCntrl.plannedLocation;
	self.myVoyageJob := _tiTransCntrl.myVoyageJob;
	if self.myVoyageJob &lt;&gt; null then	//02 Mar 2016	NDL	TFS 1593
		self.jobId := self.myVoyageJob.jobId;
	endif;
	self.isLoad := _tiTransCntrl.isLoad;
	self.remarks := _tiTransCntrl.remarks; // 16 Feb 2022 navlw TFS# 52579
	
	self.isForVoyage := _tiTransCntrl.isForVoyage; // ### TFS CR 56806 TASK 56807 01MAR2023 NAVAB1
	
	if self.confirmedLocation = null then  // ### TFS CR 56806 TASK 56807 01MAR2023 NAVAB1
		if _tiTransCntrl.myConfirmationLocation &lt;&gt; null then
			self.confirmedLocation := _tiTransCntrl.myConfirmationLocation.getFullId(); // ### TFS CR 56806 TASK 56807 01MAR2023 NAVAB1
		endif;
	endif;
	
	if self.plannedLocation = null then  // ### TFS CR 56806 TASK 56807 01MAR2023 NAVAB1
		if _tiTransCntrl.myTargetLocation &lt;&gt; null then
			self.plannedLocation := _tiTransCntrl.myTargetLocation.getFullId(); // ### TFS CR 56806 TASK 56807 01MAR2023 NAVAB1
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_StowageConfirmController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
