    <DbClassMap file="jsscore_default"/>
    <JadeMethod name="errorItem" id="0b3f801c-989c-4abe-b6fb-89a37d3a66eb">
        <methodInvocation>mapping</methodInvocation>
        <source>errorItem(set: Boolean; _value: String io) mapping;
// --------------------------------------------------------------------------------
// Created:		13 February 2002 by cnwdad1
//
// Purpose:		To ensure that the length of the error item (i.e. the error message)
//				will not exceed the maximum allowable length.  If the message is too
//				long, the remainder will be truncated.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	maximumLength	: Integer;
	
begin
	if set then
		maximumLength	:=	self.getErrorItemLength(method.name);
		
		if _value.length &gt; maximumLength then
			_value	:=	_value[1:(maximumLength - 3)] &amp; "…";
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getErrorItemLength" id="d3195ea4-2f7d-4cd6-acc5-e8790333f5a7">
        <source>getErrorItemLength(pPropertyName:String):Integer protected;
// --------------------------------------------------------------------------------
// Created:		13 February 2002 by cnwdad1
//
// Purpose:		Returns the declared length (in character units) of the errorItem
//				string property.
//
// Parameters:	pPropertyName - The name of the property who's length is required.
//
// Returns:		The declared length of the property.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	propertyObj	: Property;
	
begin
	propertyObj	:=	self.class.rootType.getPropertyInHTree(pPropertyName);
	
	if propertyObj &lt;&gt; null
	and Attribute.hasInstance(propertyObj)
	and propertyObj.type = String
	then
		if app.isUnicode() then
			return (propertyObj.getLength() div 2) - 1;
		else
			return propertyObj.getLength() - 1;
		endif;
	endif;
	
	return 0;
end;</source>
        <access>protected</access>
        <Parameter name="pPropertyName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isJSSException" id="a14cae5b-7ca3-4ad2-9815-6f2a2c248614">
        <source>isJSSException(): Boolean;
// --------------------------------------------------------------------------------
// Created:		24 April 2003 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the exception is a JSS
//				exception.
//
// Parameters:	None
//
// Returns:		True if the exception object is a JSS exception, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</ExceptionClass>
