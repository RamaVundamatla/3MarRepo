    <JadeMethod name="getMarineServiceDtlForResource" id="f171e1fc-28ca-45b3-a593-97918e851d58">
        <source>getMarineServiceDtlForResource( _hmsResource : HMS_Resource) : CM_WodMarineServiceDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlger1	Initial creation

*/

vars
	allMarineServices : CM_WodMarineServiceDetailSet;
	marineService : CM_WodMarineServiceDetail;
begin
	
	allMarineServices:=self.getAllMarineServiceDetails;
	if allMarineServices = null or allMarineServices.first = null then
		return null;
	endif;
	foreach marineService in allMarineServices discreteLock do
		if marineService.myHMSResource = _hmsResource then
			return marineService;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <Parameter name="_hmsResource" type="HMS_Resource"/>
        <ReturnType type="CM_WodMarineServiceDetail"/>
    </JadeMethod>
