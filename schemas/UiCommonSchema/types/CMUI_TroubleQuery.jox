    <JadeMethod name="initTable" id="8e499665-dbb5-4813-91b0-a0c347440f75">
        <source>initTable();
// ---------------------------------------------------------------------------
// Created:     06 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	IGNORE = 5;  
vars
	row : Integer;
	table : CM_DataTable;
begin
	table := self.tblData;
	
	table.columns := 6;
	table.rows := 0;
	//table.addItem("Terminal" &amp; Tab &amp; "Name" &amp; Tab &amp; "Date" &amp; Tab &amp; "Transaction" &amp; Tab &amp; "Type" &amp; Tab &amp; "Stage"  );
	table.addItem("Transaction" &amp; Tab &amp; "Date" &amp; Tab &amp; "Time" &amp; Tab &amp; "Dwell" &amp; Tab &amp; "Truck" &amp; Tab &amp; "Stage"  );
	table.selectMode := Table.SelectMode_CurrentRow;
	table.fixedRows := 1;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTerminals" id="94616af0-d4d0-4b27-b639-ae0f659e23d6">
