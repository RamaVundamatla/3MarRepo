    <JadeMethod name="getObjects" id="c45095da-f2a1-45c2-9c8d-6fb9ac573818">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/08/2023	navkc1	CR 59603 Task 59604: UI - CustDocs More Stop Criteria

*/

vars
	docType		: CM_CustomDocumentType;
	terminal	: CM_Terminal;
	userTerm	: CM_UserTerminal;
	user		: CM_User;
begin

	user := app.getMyUser();
	
	foreach userTerm in user.allUserTerminals do
		terminal := userTerm.getMyTerminal();
		
		foreach docType in terminal.allCustomDocumentTypes do
			objects[docType.getYAIdentifier()] := docType;
		endforeach;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
