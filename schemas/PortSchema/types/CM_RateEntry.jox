    <CompAttribute name="allCostPerUnits" id="f9a7c156-a22e-486b-bb3f-80baaa177a83">
        <type name="DecimalArray"/>
        <text>

if calculationType = INV_CALC_TYPE_BUSINESS_HRS_QTY then
	this will have 2 entries. 1 for INCLUDED times and 1 for EXCLUDED times i.e. whether the timestamp is in the range or not.

elseif calculationType = INV_CALC_TYPE_DAYS_CONNECTED then
					or INV_CALC_TYPE_DAYS_ONSITE_AT
					or INV_CALC_TYPE_DAYS_SINCE_RECVL
					or INV_CALC_TYPE_QUANTITY
					or INV_CALC_TYPE_RESOURCE_QTY
					or INV_CALC_TYPE_REVENUE_TONS
					or INV_CALC_TYPE_TIMEBLCK_HRS
					or INV_CALC_TYPE_TIMEBLCK_HRS_UNT
					or INV_CALC_TYPE_TIME_PERIOD_HRS
					or INV_CALC_TYPE_TRANSQUANTITY
					or INV_CALC_TYPE_UNITY
					or INV_CALC_TYPE_VESSEL_TON
					or INV_CALC_TYPE_VOLUME
					or INV_CALC_TYPE_WEIGHT
					or INV_CALC_TYPE_WEIGHT_TON then
	this will have 1 entry the cost per unit

elseif calculationType = INV_CALC_TYPE_VESSEL_TON_RANGE then
	this will have 1 entry per range of integers
endif;</text>
    </CompAttribute>
