    <JadeMethod name="doFrameHLabelMouseUp" id="05ecf298-c446-49f8-a35e-2103234ee6ae">
        <updating/>
        <source>doFrameHLabelMouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
Purpose:			
Date		Who		Reason
28 April 2011	cnwab1	Initial creation
*/

vars
	tmpSect, proxySection : CM_VesselSectionVessel;
	posM : Decimal[12,2];
	theResult : Integer;
	code : String;
	tmpX : Real;
begin
	if self.mode = self.Mode_View then
		return;
	endif;
	if self.frmScrollable.myHLabels.left &lt; 50 then
		tmpX := ((self.frmScrollable.myHLabels.left - 50) * -1) + x;
	else
		tmpX :=  x;
	endif;
	
	if y &gt; 55 then
		tmpSect := self.getSectionFromPixelX(tmpX, posM).CM_VesselSectionVessel;
		if tmpSect &lt;&gt; null then
			self.doSectionDelete(tmpSect);
		else
			self.doSectionAdd(posM);
		endif;
	endif;
epilog
	delete proxySection;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
