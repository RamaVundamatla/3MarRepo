    <JadeMethod name="isBOL" id="28c9cd96-bc6e-4973-8aa3-6df1715eaa64">
        <source>isBOL() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 April 2014	cnwmc5	Initial creation	CCMS 2352

*/

vars

begin
	if self.allApplyAreas.includes(StopApplyBOL) then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBOLOnly" id="a5a8733a-3cb1-46e0-b82b-ad9680350b4c">
        <source>isBOLOnly() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 April 2014	cnwmc5	Initial creation	CCMS 2352

*/

vars

begin
	if self.allApplyAreas.includes(StopApplyBOL)
	and self.allApplyAreas.size() = 1 then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isNotSet" id="cdbdf2fe-d0d2-4d8d-b98a-ede38a422cf5">
        <source>isNotSet() : Boolean;
//ccms1824 cnwrs1 may 2009
// return true if all values are null
//
vars

begin
	if self.allApplyAreas.size = 0 and
	   self.allHoldVoyages.size = 0 and
	   self.allPreventAreas.size = 0 and
	   self.allProcessAreas.size = 0 and
	   self.allEventRequests.size = 0 and	//02 May 2019	NDL	TFS 43918
	   not isChildIgnore and
	   not isChildOnly and
	   not isChildIgnore and
	   not isCoastalIgnore and
	   not isCoastalOnly and
	   not isTranshipIgnore and
	   not isTranshipOnly and
	   not isFull and
	   not isMT then
		return true;
	endif;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="8268d478-5023-4f28-a87d-0f5f652db09d">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		Aug 2007 cnwrs1 CCMS 1017
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyStopTableTemplate	: CM_StopTableTemplate;
	completedOK		: Boolean;
	
begin
	proxyStopTableTemplate := inheritMethod();
	self.allHoldVoyages.copy(proxyStopTableTemplate.allHoldVoyages); //ccms1824 cnwrs1 may 2009	
	
	proxyStopTableTemplate.resetEventRequestsFromDB();	//02 May 2019	NDL	TFS 43918
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyStopTableTemplate;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyStopTableTemplate;
	endif;	
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="pxyUpdateRequestsDiffer" id="71292bff-bb96-420a-b74c-2a331a1b080b">
        <source>pxyUpdateRequestsDiffer( allPxyEventRequests : CM_EventRequestByStatus ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	realEventRequest : CM_EventRequest;
	pxyEventRequest : CM_EventRequest;

begin

	if self.allEventRequests.size &lt;&gt; allPxyEventRequests.size then
		return true;
	endif;
	
	foreach pxyEventRequest in allPxyEventRequests do
		realEventRequest := pxyEventRequest.pxyGetRealObject();
		if realEventRequest = null then
			// its a new one.
			return true;
		endif;
		if realEventRequest.CM_EventRequestForStop.differsFrom( pxyEventRequest.CM_EventRequestForStop ) then
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="allPxyEventRequests" type="CM_EventRequestByStatus"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetEventRequestsFromDB" id="0870adfe-7f54-41d9-9a13-6f35454ad6e5">
        <source>resetEventRequestsFromDB();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2019	jlgndl1	Initial creation	TFS 43918

*/

vars

	realStopTableTemplate : CM_StopTableTemplate;
	realEventRequest : CM_EventRequest;
	realEventRequestStops : CM_EventRequestForStop;	
	pxyEventRequestStops : CM_EventRequestForStop;
	load : Boolean;
	

begin

	if not self.isTransient then
		return;
	endif;
	
	if not self.allEventRequests.isEmpty then
		self.allEventRequests.purge;
	endif;
	
	realStopTableTemplate := self.pxyGetRealObject();
	if realStopTableTemplate &lt;&gt; null then
		app.cmsBeginLoad(load);
		foreach realEventRequest in realStopTableTemplate.allEventRequests do
			realEventRequestStops := realEventRequest.CM_EventRequestForStop;
			pxyEventRequestStops := realEventRequestStops.pxyCreateUpdateProxy();
			pxyEventRequestStops.setMyStopTemplate( self );
		endforeach;
		app.cmsEndLoad(load);
	endif;

epilog

	app.cmsEndLoad(load);

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6cde963a-e421-48af-9e90-d890e50d35a0">
        <updating/>
        <source>setForCreate(_proxyStopTableTemplate : CM_StopTableTemplate) updating;
// ---------------------------------------------------------------------------
// Created:		Aug 2007 cnwrs1 CCMS 1017
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.setForUpdate(_proxyStopTableTemplate);
	// make sure the new StopTabletemplate keys are set correctly.
	self.setKeys( _proxyStopTableTemplate.myTerminal, _proxyStopTableTemplate.myStopTable );
end;</source>
        <Parameter name="_proxyStopTableTemplate" type="CM_StopTableTemplate"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="23ce4331-4823-464c-ac6b-e1198a8d39cf">
        <updating/>
        <source>setForUpdate(_proxyStopTableTemplate : CM_StopTableTemplate) updating;
// ---------------------------------------------------------------------------
// Created:		Aug 2007 cnwrs1 CCMS 1017
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	pxyEventRequest : CM_EventRequest;
	pxyEventRequestStops : CM_EventRequestForStop;	
	realEventRequestStops : CM_EventRequestForStop;

begin


	_proxyStopTableTemplate.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.allPreventAreas.clear;
	_proxyStopTableTemplate.allPreventAreas.copy(self.allPreventAreas);
	self.allApplyAreas.clear;
	_proxyStopTableTemplate.allApplyAreas.copy(self.allApplyAreas);
	
	//epr TFS 1946 26/5/16
	if self.myStopTable &lt;&gt; null then
		if self.myStopTable.requiresInfoType = SOLAS then
			if not self.allApplyAreas.includes(StopApplySOLASVGM) then
				self.allApplyAreas.add(StopApplySOLASVGM);
			endif;
		else
			if self.allApplyAreas.includes(StopApplySOLASVGM) then
				self.allApplyAreas.remove(StopApplySOLASVGM);
			endif;
		endif;
		
	endif;
	
	self.allProcessAreas.clear;
	_proxyStopTableTemplate.allProcessAreas.copy(self.allProcessAreas);
	self.allHoldVoyages.clear; //ccms1824 cnwrs1 May 2009
	_proxyStopTableTemplate.allHoldVoyages.copy(self.allHoldVoyages);
//	self.myStopTable := _proxyStopTableTemplate.myStopTable;
//	self.myTerminal	:= _proxyStopTableTemplate.myTerminal;
	self.isCoastalOnly := _proxyStopTableTemplate.isCoastalOnly;
	self.isCoastalIgnore := _proxyStopTableTemplate.isCoastalIgnore;
	self.isChildOnly := _proxyStopTableTemplate.isChildOnly;
	self.isChildIgnore := _proxyStopTableTemplate.isChildIgnore;
	self.isTranshipOnly := _proxyStopTableTemplate.isTranshipOnly;
	self.isTranshipIgnore := _proxyStopTableTemplate.isTranshipIgnore;
	self.isMT := _proxyStopTableTemplate.isMT;
	self.isFull := _proxyStopTableTemplate.isFull;
	self.isExport := _proxyStopTableTemplate.isExport;
	self.isImport := _proxyStopTableTemplate.isImport;
	
	//02 May 2019	NDL	TFS 43918
	if not self.allEventRequests.isEmpty then
		self.allEventRequests.purge;
	endif;
	
	foreach pxyEventRequest in _proxyStopTableTemplate.allEventRequests do
		pxyEventRequestStops := pxyEventRequest.CM_EventRequestForStop;
		create realEventRequestStops persistent;
		realEventRequestStops.setForCreate( pxyEventRequestStops, app.myPassport );
		realEventRequestStops.setMyStopTemplate( self );
	endforeach;
	
end;</source>
        <Parameter name="_proxyStopTableTemplate" type="CM_StopTableTemplate"/>
    </JadeMethod>
    <JadeMethod name="setKeys" id="1e8ad061-af2d-4f7d-9f0d-7e1df25dc4a0">
        <updating/>
        <source>setKeys(_myTerminal : CM_Terminal; _myStopTable : CM_StopsTable) updating;

vars

begin
	self.myTerminal := _myTerminal;
	self.myStopTable := _myStopTable;

end;
</source>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
        <Parameter name="_myStopTable" type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="4e7bd155-50be-4754-9081-3bb04459b435">
        <updating/>
        <source>setProxy(_checkAreas, _setAreas, _processAreas : IntegerArray; _holdVoyages : CM_ObjectArray;
		 _isChildOnly, _isChildIgnore, _isCoastalOnly, _isCoastalIgnore, _isTranshipOnly, _isTranshipIgnore, _isMT, _isFull: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		Aug 2007 cnwrs1 CCMS 1017
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// ---------------------------------------------------------------------------
vars
	object : Object;
begin
	self.allPreventAreas.clear;
	_checkAreas.copy(self.allPreventAreas);
	self.allApplyAreas.clear;
	_setAreas.copy(self.allApplyAreas);
	self.allProcessAreas.clear;
	_processAreas.copy(self.allProcessAreas);
	self.allHoldVoyages.clear;
	if _holdVoyages &lt;&gt; null then
		foreach object in _holdVoyages do //ccms1824 cnwrs1 may 2009
			self.allHoldVoyages.add(object.CM_Voyage);
		endforeach;
	endif;
	
	//cnwmc5 - 14 April 2014 - CCMS 2352
	if self.isBOLOnly then
		self.isCoastalOnly := false;
		self.isCoastalIgnore := false;
		self.isChildOnly := false;
		self.isChildIgnore := false;
		self.isTranshipOnly := false;
		self.isTranshipIgnore := false;
		self.isMT := false;
		self.isFull := false;
	else
		self.isCoastalOnly := _isCoastalOnly;
		self.isCoastalIgnore := _isCoastalIgnore;
		self.isChildOnly := _isChildOnly;
		self.isChildIgnore := _isChildIgnore;
		self.isTranshipOnly := _isTranshipOnly;
		self.isTranshipIgnore := _isTranshipIgnore;
		self.isMT := _isMT;
		self.isFull := _isFull;
	endif;
end;</source>
        <Parameter name="_checkAreas" type="IntegerArray"/>
        <Parameter name="_setAreas" type="IntegerArray"/>
        <Parameter name="_processAreas" type="IntegerArray"/>
        <Parameter name="_holdVoyages" type="CM_ObjectArray"/>
        <Parameter name="_isChildOnly" type="Boolean"/>
        <Parameter name="_isChildIgnore" type="Boolean"/>
        <Parameter name="_isCoastalOnly" type="Boolean"/>
        <Parameter name="_isCoastalIgnore" type="Boolean"/>
        <Parameter name="_isTranshipOnly" type="Boolean"/>
        <Parameter name="_isTranshipIgnore" type="Boolean"/>
        <Parameter name="_isMT" type="Boolean"/>
        <Parameter name="_isFull" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="3f95322e-f46e-402b-8a6e-3f949ba2da1e">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars

begin
	if _property = null or
	   _property.name = CM_StopTableTemplate::myStopTable.name or
	   _property.name = CM_StopTableTemplate::appliesToBOLIn.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="864aec01-57e5-4e58-9d88-e9b9e7131301">
        <source>validateMe();
/*

Purpose:			
	ccms1824 cnwrs1 may 2009
Parameters:			

Return Value:		

Date		Who		Reason
27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
14 Aug 2023 navma1	Bug 59691: MTN - Stops Definition Validation for [Fulls,MTs]
*/

vars
	cargoType 		: CM_CargoBOLType;
	msgTypeStr  	: String;
	criteria 		: CM_YACriteria;	//20 Jul 2022	navsj20	TFS 53862
	stopTable		: CM_StopsTable;
	termCode		: String;
	stopCriteria	: CM_StopCriteria;
begin
	if isNotSet then //if the StopTableTemplate is null we dont need to validate it
		return;
	endif;

	stopTable := self.myStopTable;
	
	if stopTable &lt;&gt; null then
		stopCriteria := stopTable.myStopCriteria;
	endif;
	
	if self.myTerminal &lt;&gt; null then
		termCode := self.myTerminal.code;
	endif;
	
	if self.isChildOnly and self.isChildIgnore then
		app.raiseCMException1(Stop_Child_Only_Ignore, termCode, null, null);	
	endif;
	
	if self.isCoastalOnly and self.isCoastalIgnore then
		app.raiseCMException1(Stop_Coastal_Only_Ignore, termCode, null, null);	
	endif;
	
	if self.isTranshipOnly and self.isTranshipIgnore then
		app.raiseCMException1(Stop_Tranship_Only_Ignore, termCode, null, null);	
	endif;
	if not self.isMT and not self.isFull then														// cnwmc5 - 14 April 2014 - CCMS 2352
		if  not self.isBOLOnly and stopTable.isValidForCargoType(TI_CargoType_Container) then					
			app.raiseCMException1(Stop_Select_Full_MT, termCode, null, null);						// concms1 par 19830 june 2009
		endif;
	endif;
	
	if self.allProcessAreas.includes(StopProcessEDICustomExport) then
		if not stopTable.requiresInfo or 												
		   not stopTable.requiresInfoType = CEDO then
			app.raiseCMException1(Stop_CEDO_Error, termCode, null, null);			
		endif;
		
	elseif self.allProcessAreas.includes(StopProcessEDICustomImport) then
		if not stopTable.requiresInfo or												
		   not stopTable.requiresInfoType = CustomsEntryNumber then
			app.raiseCMException1(Stop_EDI_Error, termCode, null, null);				
		endif;
	endif;
	
	// cnwmc5 - 14 April 2014 - CCMS 2352
	cargoType := app.myRoot.getCargoBOLTypeForId(BOLType_GeneralBillOfLading);
	//if not self.myStopTable.allCargoTypesNew.includes(cargoType) and self.isBOLOnly then					//20 Jul 2022	navsj20	TFS 53862
	if stopCriteria &lt;&gt; null then 
		foreach criteria in stopCriteria.allCriteria where 
			criteria.myYACriteriaType.type = YACriteriaType_CargoType 
			and not criteria.myYAData.CM_YADataObjects.allObjects.includes(cargoType) and self.isBOLOnly do	//27 Jul 2022	navsj20	TFS 53862
				app.raiseCMException1(Stop_table_attributes_invalid, termCode, null, null);		
		endforeach;
	endif;
	
	// cnwmc5 - 14 April 2014 - CCMS 2352
	//if self.myStopTable.allCargoTypesNew.includes(cargoType) and self.myStopTable.allCargoTypesNew.size() = 1 and not self.isBOLOnly then				//20 Jul 2022	navsj20	TFS 53862
	if stopCriteria &lt;&gt; null then																				//20 Jul 2022	navsj20	TFS 53862
		foreach criteria in stopCriteria.allCriteria where 
			criteria.myYACriteriaType.type = YACriteriaType_CargoType do										//27 Jul 2022	navsj20	TFS 53862
			if criteria &lt;&gt; null and criteria.myYAData.isKindOf(CM_YADataObjects) then							//20 Jul 2022	navsj20	TFS 53862	
				if criteria.myYAData.CM_YADataObjects.allObjects.includes(cargoType) 							//20 Jul 2022	navsj20	TFS 53862
					and criteria.myYAData.CM_YADataObjects.allObjects.size() = 1 and not self.isBOLOnly then	//20 Jul 2022	navsj20	TFS 53862
					app.raiseCMException1(Stop_table_attributes_invalid, termCode, null, null);
				endif;
			endif;
		endforeach;			
	endif;
	
	//07 May 2019	NDL	TFS 43918
	if self.myTerminal &lt;&gt; null then
		if self.allEventRequests.includesGtrThanOne(EventRequestTypeRemarks) then
			msgTypeStr := app.getErrorString(Remarks);
			app.raiseCMWarning2( Your_curre_confi_inclu_more_th, msgTypeStr, termCode, null, null, null );
		endif;
		if self.allEventRequests.includesGtrThanOne(EventRequestTypeGrade) then
			msgTypeStr := app.getErrorString(Grade);
			app.raiseCMWarning2( Your_curre_confi_inclu_more_th, msgTypeStr, termCode, null, null, null );
		endif;
		if self.allEventRequests.includesGtrThanOne(EventRequestTypeWeight) then
			msgTypeStr := app.getErrorString(CM_Total_Weight);
			app.raiseCMWarning2( Your_curre_confi_inclu_more_th, msgTypeStr, termCode, null, null, null );
		endif;
	endif;
end;
</source>
    </JadeMethod>
</Class>
