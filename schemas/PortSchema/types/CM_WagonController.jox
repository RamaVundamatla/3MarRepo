    <JadeMethod name="getID" id="950ce239-17d4-4ecf-8a42-7ce6b27589fe">
        <source>getID(): String;

vars

begin

	if self.myTerminal.getConfig( RailDefaultWCIdFormat ).Integer = Rail_UPSP_Int then	//Par 35346 / CCMS 1408
		return self.getIdUPSPformat( null );
	
	else
		return self.id;
		
