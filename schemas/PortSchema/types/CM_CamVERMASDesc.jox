    <JadeMethod name="availableTransactions" id="72d8491d-0a29-4113-8794-d76dd2f8a8ff">
        <source>availableTransactions(_classColl: ClassColl input);
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//
//27 Jun 2016	TFS 2206 allow VEMAS On Full Export Receivals
vars

begin
	_classColl.add(CM_Weighed);
	_classColl.add(CM_Edit);
	_classColl.add(CM_ReceiveRail);
	_classColl.add(CM_ReceiveRailInterTerminal);
	_classColl.add(CM_ReceiveRoad);
	_classColl.add(CM_ReceiveRoadInterTerminal);
	_classColl.add(CM_ReceiveShip);
	_classColl.add(CM_SubTerminalReceiveDepot);		
	_classColl.add(CM_SubTermReceiveDepotIntern);
	_classColl.add(CM_SubTermReceiveDepotRail);
	_classColl.add(CM_SubTermReceiveDepotRoad);	
	_classColl.add(CM_SubTermReceiveDepotShip);			
	_classColl.add(CM_SubTerminalReceiveMarine);	
	_classColl.add(CM_SubTermReceiveMarineIntern);		
	_classColl.add(CM_SubTermReceiveMarineRail);	
	_classColl.add(CM_SubTermReceiveMarineRoad);	
	_classColl.add(CM_SubTermReceiveMarineShip);	
	_classColl.add(CM_SubTerminalReceiveWHouse);	
	_classColl.add(CM_SubTermReceiveWHouseIntern);	
	_classColl.add(CM_SubTermReceiveWHouseRail);	
	_classColl.add(CM_SubTermReceiveWHouseRoad);	
	_classColl.add(CM_SubTermReceiveWHouseShip);	
end;
</source>
