    <JadeMethod name="getGridLocation" id="5d12cdaa-24e2-470e-97ee-1be118f22a56">
        <source>getGridLocation(_lc : CM_LocationsController) : CMIF_RDTGridLocation;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars
	key : String;
	
begin
	if _lc = null then
		return null;
	endif;
	
	key := _lc.getOidAsString();
	return self.getObjectForKey(self.allGridLocationsByLCoid, key).CMIF_RDTGridLocation;
	
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="CMIF_RDTGridLocation"/>
    </JadeMethod>
    <JadeMethod name="getLengthOfTIInFt" id="40e2a3aa-b358-47da-b930-51a42d82d0f1">
        <source>getLengthOfTIInFt(_ti : CM_TrackedItem) : Real protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if _ti = null then 
		return 0;
	endif;
	if _ti.isKindOf(CM_Container) then
		//18 Dec 2014	NDL	Par 35346
		if _ti.myPrimaryActualLocation &lt;&gt; null and  _ti.myPrimaryActualLocation.isWellcarCont then
			return _ti.myPrimaryActualLocation.CM_WellcarWagonController.myWagon.getLengthInUnitsForWagon(_ti) * 10;
		else
			return _ti.getActualLength();
		endif;
	else
		// Assume 20 footer
		return 20;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getLengthOfTIInPixels" id="e173dd06-acb2-4480-be99-725767e9d70a">
        <source>getLengthOfTIInPixels(_ti : CM_TrackedItem; _scaleFactor : Real) : Real protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if _ti = null then 
		return 0;
	endif;
	if _ti.isKindOf(CM_Container) then
		return self.getSizeInPixels(_ti.getActualLength(), _scaleFactor);
	else
		// Assume 20 footer
		return self.getSizeInPixels(20, _scaleFactor);
	endif;
epilog

end;</source>
        <access>protected</access>
