    <JadeMethod name="setDisplayName" id="29faf10c-ac92-4554-bd2d-2954b8fee247">
        <updating/>
        <source>setDisplayName(_display : String) updating;
// ---------------------------------------------------------------------------
// Created:     09 October 2002 by cnwth2
