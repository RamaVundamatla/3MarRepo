    <JadeMethod name="getProduct" id="da751ffd-7715-400a-a8e9-f36ce7b9679c">
        <source>getProduct(_operator : String; _productStr : String) : CM_Product;
/*
----------   ----------  --------------------------------------------------
Created:	18 August 2006 By cnwth2

Purpose:	
/* Changes

Date		Name	TFS#		Description
============================================================================
04 Mar 2019	jlgrs1	TFS 41913 	STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
12 Jun 2019	jlgka1	TFS 44416 	PNL Loading Default Cargo Type Settings via EDI
28 Nov 2024 navma1	MTN-19124	STWO - Uploading an EDI file 'freezes' MTN.
============================================================================*/

vars
	product			: CM_Product;
	terminal		: CM_Terminal;
	cargoType		: CM_CargoType;
	operator		: CM_Operator;
	productStrUpper : String;
begin
	
	//jlgka1 TFS 44416 --&gt; move checking of null here so we don't need to proceed with the code anymore.
	if _productStr = null then
		return null;
	endif;
	//jlgka1 TFS 44416 --&gt;
	
	terminal := self.getMyTerminal();
	
	//jlgka1 TFS 44416 --&gt; Add the next two line to get cargo type and operator then
	// Comment out the for each to improved the perfomance as per Nelson's advise.
	// this affect the existing code but not related to my changes.
	cargoType := terminal.getCargoTypeFromDescription(self.cargoTypeDescr);
	operator  := app.myRoot.allOperators[_operator];
	
	if cargoType &lt;&gt; null then	
		
		productStrUpper := _productStr.toUpper;						//28.11.2024 navma1 #MTN-19124
		
		foreach product in cargoType.allProducts do	
			// jlgka1 TFS 44416 this also been comment out as per Nelson's advise to use the new dictionary
			// in searching for the Product code, so instead of checking the cargo type in the inside loop
			// we are doing it from the outer loop.
			
			if product.code.toUpper = productStrUpper then 		  //28.11.2024 navma1 #MTN-19124
				//jlgka1 TFS 44416 --&gt;
				if product.myOperator &lt;&gt; null and _operator &lt;&gt; null then
					if _operator = product.myOperator.code then
						return product;	
					endif;
				else					
					return product;
				endif;						
				//jlgka1 TFS 44416 &lt;--
			endif;
			
		endforeach;
	else
		product := app.myAlternateDict.getProductFromProdCode( terminal, operator, _productStr, true, true );
		return product;
	endif;	
end;</source>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_productStr" type="String"/>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="getPropertyFromColumnName" id="dcea0ce6-8fa1-49d5-b9a2-e757916c7c0a">
        <source>getPropertyFromColumnName(_columnName : String) : Property;
//
/// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
//
vars
	prop : Property;
begin
	if _columnName = ETRow_TranshipPortCodes  then 
		prop := self.class.getPropertyInHTree(CM_EDIPortTI::allTranshipPortCodes.name);
	elseif _columnName = ETRow_Remarks and self.isKindOf (CM_EDILayoutTI) then	// par 30426
		// remarks are stored in the description property
		prop := CM_EDILayoutTI::description;
	else
		prop := self.class.getPropertyInHTree(_columnName);
	endif;
	return prop;
end;
</source>
        <Parameter name="_columnName" type="String"/>
        <ReturnType type="Property"/>
    </JadeMethod>
