    <JadeMethod name="comboBoxLogOperation" id="490e9938-0303-49b2-a444-dca850bcc623">
        <source>comboBoxLogOperation(_combobox : ComboBox input);

// cnwdvb1 22 November 2002 

vars

	str	: String;

begin

	str := _combobox.text;
	_combobox.clear;
	_combobox.addItem('CF' &amp; Tab &amp; Tab &amp; 'Clear Fell');
	_combobox.addItem('RL' &amp; Tab &amp; Tab &amp; 'Road Line');
	_combobox.addItem('RLTHIN' &amp; Tab &amp; 'Road Line Thinning');
	_combobox.addItem('THIN' &amp; Tab &amp; Tab &amp; 'Thinning');
	_combobox.addItem('WT' &amp; Tab &amp; Tab &amp; 'Wind Throw');
	_combobox.text := str;

end;</source>
        <Parameter name="_combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxLogTreatment" id="3a53e18f-0902-4937-abd7-a365f5602350">
        <source>comboBoxLogTreatment(pCmb : ComboBox input; pTreatment : CM_LogTreatment; pCodeGroup: CM_LogTreatmentsByCodeDict; _includeUnavailableForEntry : Boolean);
//--------------------------------------------------------------
//Created: 12 March 2002 By: cnwgd1
//Changed CNWTH2 to consider CM_Code::notAvailableForEntry
//--------------------------------------------------------------
vars
	code				: CM_Code;	
begin

	pCmb.clear();
	
	if pCodeGroup = null or
	   pCodeGroup.isEmpty then
		return;
	endif;
	
	foreach code in pCodeGroup do
		if not _includeUnavailableForEntry and
		   code.notAvailableForEntry then
			continue;
		endif;
		
		pCmb.itemObject[pCmb.addItem(code.code &amp; Tab &amp; code.description)] := code;
	endforeach;
	
	if pTreatment &lt;&gt; null then
		pCmb.text := pTreatment.code &amp; Tab &amp; pTreatment.description;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pTreatment" type="CM_LogTreatment"/>
        <Parameter name="pCodeGroup" type="CM_LogTreatmentsByCodeDict"/>
        <Parameter name="_includeUnavailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxLogType" id="0b7bf3ef-e1ab-4232-bb8e-0c132b309795">
        <source>comboBoxLogType(pCmb : ComboBox; pType : CM_LogType;pCodeGroup : CM_LogTypeByCodeDict; _includeUnavailableForEntry : Boolean);
//--------------------------------------------------------------
//Created: 28 January 2002 By: cnwgd1
//Changed CNWTH2 to consider CM_Code::notAvailableForEntry
//--------------------------------------------------------------
vars
	tmpCombo		: ComboBox;
	code			: CM_Code;
begin
	tmpCombo := pCmb;	// done this way so the parameter does not have to be input
						// which allows sub-classed comboboxes to be passed through
	tmpCombo.clear();
	
	if pCodeGroup = null or
	   pCodeGroup.isEmpty then
		return;
	endif;
	   
	foreach code in pCodeGroup do
		if not _includeUnavailableForEntry and
		   code.notAvailableForEntry then
			continue;
		endif;
		
		pCmb.itemObject[pCmb.addItem(code.code &amp; Tab &amp; code.description)] := code;
	endforeach;
	
	if pType &lt;&gt; null then
		tmpCombo.text := pType.code &amp; Tab &amp; pType.description;
	else
		tmpCombo.text := null;		
	endif;
end;</source>
        <Parameter name="pCmb" type="ComboBox"/>
        <Parameter name="pType" type="CM_LogType"/>
        <Parameter name="pCodeGroup" type="CM_LogTypeByCodeDict"/>
        <Parameter name="_includeUnavailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxLoggingOrg" id="56c46d63-fdf4-4fa7-9365-69873d31f014">
        <source>comboBoxLoggingOrg(_cmb : ComboBox input; _loggingOrgCode : String);
//-----------------------------------------
// Created: February 2004 By: cnwgd1
//-----------------------------------------
vars
	tmpLoggingOrg	: CM_LoggingOrganisation;
	tmpDict		: CM_LoggingOrgByCodeDict;
	tmpCode,
	str			: String;
	found		: Boolean;
	index		: Integer;

begin
	_cmb.clear();
	_cmb.addItem(null);

	tmpDict := app.myRoot.allLoggingOrganisations;
	
	foreach tmpLoggingOrg in tmpDict do
		tmpCode := tmpLoggingOrg.code;
		if _loggingOrgCode &lt;&gt; null and (not found) then
			if tmpCode = _loggingOrgCode then
				found := true;
			elseif tmpCode &gt; _loggingOrgCode then
				// have come to entry which is 1 greater than code passed in
				found := true;
				_cmb.addItem(_loggingOrgCode);
			endif;
		endif;
		
		_cmb.addItem(tmpCode);
	endforeach;
	
	if _loggingOrgCode &lt;&gt; null then
		if (not found) then
			_cmb.addItem(_loggingOrgCode);
		endif;
		_cmb.text := _loggingOrgCode;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_loggingOrgCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxMTContainers" id="4b760df6-7c40-45f4-b3aa-81fee424d70b">
        <source>comboBoxMTContainers(_combo : ComboBox input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2009	cnwjk3	Initial creation
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/

vars
	ti				: CM_TrackedItem;
	dict			: CM_TIByCargoTypeIdDict;
	iter			: Iterator;
	idStr			: String;
	cargoType		: Integer;
	ls,
	maxCountExceeded: Boolean;
	count			: Integer;
	commodity		: CM_Commodity;
begin
	_combo.clear;
	dict := self.myTerminal.allOnsiteTIsByCargoTypeId;

	app.cmsBeginLoad(ls);
	iter := dict.createIterator;
	dict.startKeyGeq(TI_CargoType_Container, null, iter);
	while iter.next(ti) do
		iter.getCurrentKeys(cargoType, idStr);  //MTN-35226
		if cargoType &lt;&gt; TI_CargoType_Container then
			break;
		endif;
		commodity := ti.getCommodityObject();
		if commodity = null or not commodity.isEmpty then
			continue;
		endif;
		
		count := count + 1;
		if count &gt;= 29999 then
			//jade limit for a combo - this'll happen for 
			//logs every time - possibly other cargo types too
			maxCountExceeded := true;
			break;
		endif;		
		_combo.itemObject[_combo.addItem(idStr)] := ti;				
	endwhile;
	app.cmsEndLoad(ls);
	
	if maxCountExceeded then
		app.msgBox('There were more than 32,000 tracked items of selected type.' &amp; CrLf &amp;
					'Only the first 32,000 have been listed', ' Maximum entries exceeded', MsgBox_Exclamation_Mark_Icon);
	endif;
	
epilog
	delete iter;
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxMTGrade" id="8b5abd42-9e46-4c99-a998-901a624f2b46">
