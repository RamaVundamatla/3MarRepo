    <JadeMethod name="addSnapshotDataToTable" id="38c158cf-7f67-4efc-a8df-7f8659245d9b">
        <source>addSnapshotDataToTable( _resultObject : CM_Object );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwndl1	Initial creation

*/

vars
	theDataLine	: String;
	idx			: Integer;
begin

	theDataLine := _resultObject.getAttributeStringForDefArray(tblData.allTblDataEntRows);
	idx := self.tblData.addItem(theDataLine.trimBlanks);
	self.tblData.accessRow(idx).itemObject := _resultObject;
		
epilog

end;</source>
        <Parameter name="_resultObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="fa16930d-3d6a-4e7d-9588-e2678499ddaa">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

	frm : CMUI_Toolbar;
	queryToolbar : CMUI_Toolbar;
	
begin
	
	frm := self.frmToolbar;
	
	
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExportCSVQE, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addFrame(self.frmCmbDef, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnNewDef, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEditDef, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDeleteDef, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCreateData, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnNewData, CMUI_Toolbar.Control_Alignment_Left);
	
	inheritMethod();
	
	self.btnCancelBase.enabled := false;
	self.btnCancelBase.visible := false;
	
	
	queryToolbar := self.frmSSDef;
	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnDefault, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addFrame(self.frmSearchCrit, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.positionToolbarControls();
	queryToolbar.visible := true;

	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
