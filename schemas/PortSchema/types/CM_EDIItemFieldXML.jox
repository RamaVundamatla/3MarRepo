    <JadeMethod name="getAdditionalElements" id="b1cfda3f-ac86-4bbd-9d86-c755cccf8ca3">
        <source>getAdditionalElements(_xmlField: CM_EDIItemFieldXML; _element: JadeXMLElement; _elementArray: JadeXMLElementArray input);
//----------------------------------------------------------------
//	Created:	04 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ediField 		: Object;
	addXMLField		: CM_EDIItemFieldXML;
	otherElement	: JadeXMLElement;
begin

	foreach ediField in _xmlField.allFieldAdditionals do
		addXMLField := ediField.CM_EDIItemFieldXML;
		otherElement := _element.findElementForEDIField(addXMLField);

		if otherElement = null
		or otherElement.tagName &lt;&gt; addXMLField.tagName then
			continue;
		endif;
		_elementArray.add(otherElement);
	endforeach;
	
end;</source>
        <Parameter name="_xmlField" type="CM_EDIItemFieldXML"/>
        <Parameter name="_element" type="JadeXMLElement"/>
        <Parameter name="_elementArray" type="JadeXMLElementArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFieldFromElement" id="073d15b5-b1d7-4785-bb52-38018bfd678f">
        <source>getFieldFromElement(_element: JadeXMLElement; _converter: CMIF_EDIStringMethodHolder input): Any;
//----------------------------------------------------------------
//	Created:	04 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	value		: Any;
	subElement	: JadeXMLElement;
begin

	//initialise to empty string first
	value := "";



	if self.useSubField then
		subElement := _element.getElementByTagName(self.mySubField.tagName);
		if subElement = null then
			value := _element.textData.trimBlanks;
		else
			value := subElement.textData.trimBlanks;
		endif;
	elseif  self.systemName = CM_EDIPrenoteTI::imCodes.name 		or 
			self.systemName = CM_EDIBookingRefTI::imCodes.name  	then	// MES1008 Booking Ref can now have hazards too
		value := _element.writeToString(); //cnwrs1 nov 2006 was display
	else
		value := _element.textData.trimBlanks;
	endif;
	
	if self.stringFormatMethodName &lt;&gt; null then
		_converter.ediString := value.String;
		value := _converter.sendMsg(self.stringFormatMethodName);
	endif;	
	
	return value;

end;</source>
        <Parameter name="_element" type="JadeXMLElement"/>
        <Parameter name="_converter" type="CMIF_EDIStringMethodHolder" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getFieldFromElements" id="2c519196-8e12-4b5a-a502-d99e5aaa98da">
        <source>getFieldFromElements(_elements: JadeXMLElementArray; _converter: CMIF_EDIStringMethodHolder input): Any;
//----------------------------------------------------------------
//	Created:	04 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	xmlElement	: JadeXMLElement;
	value		: String;
begin

	foreach xmlElement in _elements do
		value := value &amp; self.getFieldFromElement(xmlElement, _converter).String;
	endforeach;

	return value;
	
end;</source>
        <Parameter name="_elements" type="JadeXMLElementArray"/>
        <Parameter name="_converter" type="CMIF_EDIStringMethodHolder" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getFieldKey" id="6589987b-556a-4607-abc2-fabd9cf613f8">
        <source>getFieldKey(): Any;
//----------------------------------------------------------------
//	Created:	10 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.useSubField
	and (not self.allAttributes.isEmpty) then
		return self.allAttributes.first.value &amp; " " &amp; self.mySubField.tagName;
	else
		return self.tagName;
	endif;

end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getFileFormatXML" id="efc1b9cd-ff64-4eb4-9316-4bba0004870c">
        <source>getFileFormatXML(_strXML: String io);
//----------------------------------------------------------------
//	Created:	08 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str	: String;
begin
	inheritMethod(_strXML);

	_strXML := _strXML &amp; "&lt;XMLDetail&gt;" &amp; CrLf;
	_strXML := _strXML &amp; "&lt;PathTags&gt;" &amp; CrLf;
	
	foreach str in self.allTagsInPath do
		_strXML := _strXML &amp; self.formatAsXML("PathTag", str);
	endforeach;
	
	_strXML := _strXML &amp; "&lt;/PathTags&gt;" &amp; CrLf;
	_strXML := _strXML &amp; "&lt;/XMLDetail&gt;" &amp; CrLf;


end;</source>
        <Parameter name="_strXML" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getMatchListDisplay" id="593ed7b4-6412-4970-8fe4-3fa0ae857872">
        <source>getMatchListDisplay(): String;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.allFieldAdditionals.isEmpty then
		if self.useSubField
		and (not self.allAttributes.isEmpty) then
			return self.allAttributes.first.value &amp; " " &amp; self.mySubField.tagName &amp; " &gt;&gt; " &amp; self.systemName &amp; "  {" &amp; self.stringFormatMethodName &amp; "}";
		else
			return self.name &amp; " &gt;&gt; " &amp; self.systemName &amp; "  {" &amp; self.stringFormatMethodName &amp; "}";
		endif;
	endif;
	
	return self.getOtherFieldsStr();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="nameSpace" id="dc7a007d-5ce1-4f81-82e1-e1f9253f5dc3">
        <methodInvocation>mapping</methodInvocation>
        <source>nameSpace(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	07 July 2005	by Jason Chapman  (cnwjc2)
//
//	Strictly specking this may not be the actual name space reported
//	by the JadeXMLElement this was created from
//----------------------------------------------------------------
vars
	ns		: String;
	pos		: Integer;
begin
	if set then
		return;
	else
		if self.allTagsInPath.size &gt;= 2 then
			ns := self.allTagsInPath[2];
			pos := ns.pos(" ", 1);
			if pos = 0 then
				_value := ns;
			else
				_value := ns[1:pos-1];
			endif;
		else
			_value := null;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="readTag" id="ba5f9351-999a-4550-8cee-b3039b97053c">
        <source>readTag(_fieldTag: String; _tagName: String output; _attributes: CM_FieldByNameDict input);
//----------------------------------------------------------------
//	Created:	04 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str			: String;
	pos			: Integer;
	position	: Integer;
	start		: Integer;
	name		: String;
	value		: String;
	attr		: CM_FieldAttribute;
begin
	str := _fieldTag;

	if str = null then
		return;
	endif;
	
	pos := _fieldTag.pos(" ", 1);
	
	if pos = 0 then
		_tagName := str;

		return;
	else
		_tagName := str[1:pos-1];
	endif;
	
	position := pos+1;

	
	while position &lt; str.length do
		name := null;
		value := null;
		
		pos := str.pos("=",position);
		if pos &lt;= position then
			return;
		endif;
		name := str[position:(pos-position)];
		
		position := pos;
		pos := str.pos('"',position);
		if pos &lt;= position then
			return;
		endif;
		position := pos;
		pos := str.pos('"',position+1);
		if pos &lt;= position then
			return;
		endif;
		start := position+1;
		value := str[start:(pos-start)];
		
		if name &lt;&gt; null
		and value &lt;&gt; null then
			create attr transient;
			attr.setForCreate(name, value, null);
			_attributes.add(attr);
		endif;
		
		position := pos + 1;
	endwhile;
end;</source>
        <Parameter name="_fieldTag" type="String"/>
        <Parameter name="_tagName" type="String" usage="output"/>
        <Parameter name="_attributes" type="CM_FieldByNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resetFieldsAdditional" id="f3150e68-2e44-474b-9bd5-d6e1ad40d7f1">
        <updating/>
        <source>resetFieldsAdditional() updating;
//----------------------------------------------------------------
//	Created:	03 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod();
	delete self.mySubField;


end;</source>
    </JadeMethod>
    <JadeMethod name="setElementXMLDetail" id="46cdead6-25f5-4631-b12b-8bffac4daf38">
        <source>setElementXMLDetail(_xmlElement: JadeXMLElement input);
//----------------------------------------------------------------
//	Created:	23 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpXMLElem	: JadeXMLElement;
	subElement	: JadeXMLElement;
	str			: String;
	attr		: CM_Field;
begin

	tmpXMLElem := _xmlElement.addElement("Attributes");
	
	foreach attr in self.allAttributes do
	
		subElement := tmpXMLElem.addElement("Attribute");
		
		tmpXMLElem := subElement.addElement("AttrName");
		tmpXMLElem.setText(attr.name);
		
		tmpXMLElem := subElement.addElement("AttrValue");
		tmpXMLElem.setText(attr.value);
		
	endforeach;	

	tmpXMLElem := _xmlElement.addElement("SubFieldName");
	if self.mySubField &lt;&gt; null then
		tmpXMLElem.setText(self.mySubField.name);
	endif;

	tmpXMLElem := _xmlElement.addElement("XMLDetail");
	tmpXMLElem := tmpXMLElem.addElement("PathTags");
	
	foreach str in self.allTagsInPath do
		subElement := tmpXMLElem.addElement("PathTag");
		subElement.setText(str);
	endforeach;


end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromXML" id="031aa1a3-4612-41fd-b73d-1ff604d6d2dd">
        <updating/>
        <source>setFromXML(_xmlElement: JadeXMLElement) updating;
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	xmlElement		: JadeXMLElement;
	elementArray	: JadeXMLElementArray;
	subField		: CM_EDIItemFieldXML;
	attribute		: CM_FieldAttribute;
	
begin

	inheritMethod(_xmlElement);

	create elementArray transient;

	_xmlElement.getAllElementsByTagName('PathTag', elementArray);

	foreach xmlElement in elementArray do
		self.allTagsInPath.add(xmlElement.textData);
	endforeach;
	
	//&lt;SubFieldName/&gt;
	xmlElement := _xmlElement.getElementByTagName('SubFieldName');
	if xmlElement &lt;&gt; null 
	and xmlElement.textData.trimBlanks &lt;&gt; null then
		create subField persistent;
		subField.setNonSystemAttributes(xmlElement.textData.trimBlanks, null, null);
		self.mySubField := subField;
	endif;

	//&lt;Attributes/&gt;
    elementArray.clear;
	_xmlElement.getAllElementsByTagName('Attribute', elementArray);

	foreach xmlElement in elementArray do
		create attribute persistent;
		attribute.setForCreate(xmlElement.getElementByTagName('AttrName').textData, xmlElement.getElementByTagName('AttrValue').textData, self);
	endforeach;
	
epilog
	delete elementArray;
end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="setMySubField" id="2012536d-0212-4eb3-8555-1e29b8b4efef">
        <updating/>
        <source>setMySubField(_subField: CM_EDIItemFieldXML) updating;
//----------------------------------------------------------------
//	Created:	04 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	self.mySubField := _subField;

end;</source>
        <Parameter name="_subField" type="CM_EDIItemFieldXML"/>
    </JadeMethod>
    <JadeMethod name="setNonSystemAttributes" id="e821ebc9-a4c5-45cd-a2f2-cc7654b212cf">
        <updating/>
        <source>setNonSystemAttributes(_name: String; _formatMethodName: String; _fieldObject: Any) updating;
//----------------------------------------------------------------
//	Created:	08 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_name, _formatMethodName, null);

	if JadeXMLElement.hasInstance(_fieldObject.Object) then
		self.setXMLDetails(_fieldObject.JadeXMLElement);
	endif;
	
	
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_formatMethodName" type="String"/>
        <Parameter name="_fieldObject" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setSubField" id="bbd8926b-cb15-41c9-88c6-f21b3657a805">
        <updating/>
        <source>setSubField(_xmlElem: JadeXMLElement): JadeXMLElement updating;
//----------------------------------------------------------------
//	Created:	03 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	fieldItem 	: CM_EDIItemFieldXML;
	xmlElem,
	parentElem	: JadeXMLElement;
begin

	if _xmlElem = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'XML element is null');
	endif;
	
	xmlElem := _xmlElem;
	
	if not JadeXMLElement.hasInstance(xmlElem.parentNode) then
		return xmlElem;
	endif;
	
	parentElem := xmlElem.parentNode.JadeXMLElement;
	
	if parentElem.attributes.isNotEmpty then
		//create the subField
		create fieldItem as CM_EDIItemFieldXML transient;
		fieldItem.setNonSystemAttributes(xmlElem.localName, null, xmlElem);
		self.mySubField := fieldItem;
	
		xmlElem := parentElem;
	endif;

	return xmlElem;
	
end;</source>
        <Parameter name="_xmlElem" type="JadeXMLElement"/>
        <ReturnType type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="setXMLDetails" id="d3956aaa-cc8f-4264-84b5-97d9dd77e9cf">
        <updating/>
        <source>setXMLDetails(_xmlElement: JadeXMLElement) updating, protected;
//----------------------------------------------------------------
//	Created:	08 October 2004	by Jason Chapman  (cnwjc2)
//
//	Used for setting transients
//----------------------------------------------------------------
vars
	attrib		: String;
	childElem,	
	xmlElem		: JadeXMLElement;
	xmlAttr		: JadeXMLAttribute;
	fieldAttr	: CM_FieldAttribute;
begin

	xmlElem := _xmlElement;
	
	self.myXMLElement := xmlElem;
	self.allTagsInPath.clear;
	self.allAttributes.purge;
	
	if not xmlElem.attributes.isEmpty then
		foreach xmlAttr in xmlElem.attributes do
			create fieldAttr transient;
			fieldAttr.setProxyFromXMLAttribute(xmlAttr, self);
		endforeach;
	endif;

	while xmlElem &lt;&gt; null do
		attrib := "";
		if not xmlElem.attributes.isEmpty then
			foreach xmlAttr in xmlElem.attributes do
				attrib := attrib &amp; " " &amp; xmlAttr.name &amp; '="' &amp; xmlAttr.value &amp; '"';
			endforeach;
		endif;
		self.allTagsInPath.add(xmlElem.tagName &amp; "" &amp; attrib);
		
//		self.allTagsInPath.add(xmlElem.tagName);
//		childElem := xmlElem;

		xmlElem := xmlElem.parentElement();
		
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="setXMLElement" id="baebff8b-cb5c-4f69-ac4c-fbb9d454d9dd">
