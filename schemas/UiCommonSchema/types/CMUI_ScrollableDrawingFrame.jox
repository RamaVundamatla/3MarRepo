    <JadeMethod name="getViewModeString" id="f4ac5338-4164-4bb7-a4a5-6715eec18995">
        <source>getViewModeString() : String;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 12/11/2012	cnwcs5	par 30519 - translations

