<Class name="CnEcTaskJanitor" id="5408322b-6a0b-468c-b78f-3fbcdea4df84">
    <superclass name="CnEcBackShedTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
