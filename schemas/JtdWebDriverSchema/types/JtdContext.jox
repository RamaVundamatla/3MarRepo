	if n &lt; 1 then
		return null;
	endif;
	
	startPos := s.pos(' ', n);
	
	if startPos &lt;= n then
		return null;
	endif;
	
	n := s.pos(';', startPos);
	
	if n &lt;= startPos then
		return null;
	endif;
	
	return s[startPos : n - startPos].trimBlanks;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdGetDefaultStatusDisplay" id="6239eff0-29b9-4eab-bc2b-fadfa64fd54e">
        <source>jtdGetDefaultStatusDisplay() : Boolean protected;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	n, startPos : Integer;
	s : String;
	
begin
	
	s := self.jtdMyProfileTextMethod.text.trimBlanks;
	
	if s = null then
		return true;
	endif;

	n := s.pos(JtdDriverProfile.JtdTagDefaultStatusDisplay, 1);
	
	if n &lt; 1 then
		return true;
	endif;
	
	startPos := s.pos(' ', n);
	
	if startPos &lt;= n then
		return true;
	endif;
	
	n := s.pos(';', startPos);
	
	if n &lt;= startPos then
		return true;
	endif;

	return s[startPos : n - startPos].trimBlanks.toLower = "on";
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdGetErrorString" id="55454cc3-5baa-401c-97a2-1ba6fe3b2a28">
        <source>jtdGetErrorString(errorCode : Integer) : String;

vars
	errMsg : JtdErrorMessage;
		
begin
	if errorCode &lt; self.jtdExceptionNumberBase then
		return "Non-driver error number: " &amp; errorCode.String;
	endif;
	errMsg := self.jtdAllErrorMessages[errorCode];
	if errMsg = null then
		return "Error " &amp; errorCode.String &amp; ": Unknown message";
	endif;
	return errMsg.jtdText;
end;</source>
        <Parameter name="errorCode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdGetEventNumbers" id="3b76d422-901d-4c27-ac1e-69ea437b5535">
        <updating/>
        <source>jtdGetEventNumbers() updating, protected;

vars
	constDict : MemberKeyDictionary;
	const : GlobalConstant;
	scm : Schema;
	cat : ConstantCategory;
	
begin
	// Get the controller schema
	scm := rootSchema.getSchema("JtdControllerSchema");
	if scm = null then
		self.jtdErrorMsg("Cannot find JtdControllerSchema.", true);
		return;
	endif;

	// Get the global constant category for the driver commands
	cat := scm.getCategory("TransactionDriverCommands");
	if cat = null then
		self.jtdErrorMsg("Cannot find TransactionDriverCommands global constant category.", true);
		return;
	endif;

	// Get the dictionary of global constants from the category
	constDict := cat.getPropertyValue("consts").MemberKeyDictionary;
	if constDict = null then
		self.jtdErrorMsg("Null TransactionDriverCommands constants dictionary.", true);
		return;
	endif;

	// CmdEventNumber ---------------------------------------------------------------------------
	
	const := constDict["CmdEventNumber"].GlobalConstant;
	
	if const = null then
		self.jtdErrorMsg("Cannot find CmdEventNumber global constant.", true);
		return;
	endif;

	self.jtdCommandEventNumber := const.valueAsInteger;
	
	if self.jtdCommandEventNumber &lt;= User_Base_Event then
		self.jtdErrorMsg("Invalid command notification event number: " &amp;
			self.jtdCommandEventNumber.String, true);
		return;
	endif;

	// CmdPingResponseEventNumber ---------------------------------------------------------------

	const := constDict["CmdPingResponseEventNumber"].GlobalConstant;
	
	if const = null then
		self.jtdErrorMsg("Cannot find CmdPingResponseEventNumber global constant.", true);
		return;
	endif;

	self.jtdPingResponseEventNumber := const.valueAsInteger;
	
	if self.jtdPingResponseEventNumber &lt;= User_Base_Event then
		self.jtdErrorMsg("Invalid ping response notification event number: " &amp;
			self.jtdPingResponseEventNumber.String, true);
		return;
	endif;

	// CmdTrxPingResponseEventNumber ------------------------------------------------------------

	const := constDict["CmdTrxPingResponseEventNumber"].GlobalConstant;
	
	if const = null then
		self.jtdErrorMsg("Cannot find CmdTrxPingResponseEventNumber global constant.", true);
		return;
	endif;

	self.jtdTrxPingResponseEventNumber := const.valueAsInteger;
	
	if self.jtdTrxPingResponseEventNumber &lt;= User_Base_Event then
		self.jtdErrorMsg("Invalid transaction ping response notification event number: " &amp;
			self.jtdTrxPingResponseEventNumber.String, true);
		return;
	endif;

	// CmdProfileMthResponseEventNo -------------------------------------------------------------

	const := constDict["CmdProfileMthResponseEventNo"].GlobalConstant;
	
	if const = null then
		self.jtdErrorMsg("Cannot find CmdProfileMthResponseEventNo global constant.", true);
		return;
	endif;

	self.jtdProfileMthResponseEventNo := const.valueAsInteger;
	
	if self.jtdProfileMthResponseEventNo &lt;= User_Base_Event then
		self.jtdErrorMsg("Invalid profile method response notification event number: " &amp;
			self.jtdProfileMthResponseEventNo.String, true);
		return;
	endif;

	// CmdDriverStopResponseEventNo -------------------------------------------------------------

	const := constDict["CmdDriverStopResponseEventNo"].GlobalConstant;
	
	if const = null then
		self.jtdErrorMsg("Cannot find CmdDriverStopResponseEventNo global constant.", true);
		return;
	endif;

	self.jtdStopResponseEventNo := const.valueAsInteger;
	
	if self.jtdStopResponseEventNo &lt;= User_Base_Event then
		self.jtdErrorMsg("Invalid driver stop response notification event number: " &amp;
			self.jtdStopResponseEventNo.String, true);
		return;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdGetGenerationSecs" id="9bf8dfa8-e878-44e0-b819-9134bac6025c">
        <source>jtdGetGenerationSecs() : Real;

vars
	r : Real;
	
begin
	r := (self.jtdGenEndClock - self.jtdGenStartClock) / 1000;
	
	if r &lt; 0 then
		return 0;
	endif;
	
	return r;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="jtdGetJadeCommandLine" id="1013a946-8732-4d9f-b24e-5ec9725dc355">
        <source>jtdGetJadeCommandLine() : String;

constants
	EndJadeCommandLine = "endJade";
	
vars
	n : Integer;
	s : String;
	
begin
	s := self.jtdGetCommandLine;
	
	n := s.pos(EndJadeCommandLine, 1);
	
	if n &lt; 1 then
		return s;
	endif;
	
	if n = 1 then
		return null;
	endif;

	return s[1 : n - 1];
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdGetMachineDetails" id="de534301-88d6-4596-a290-e5e7b7ec75b1">
        <source>jtdGetMachineDetails(localTotalMem, localAvailMem, thinTotalMem,
	thinAvailMem : Integer output; localCPU, thinCPU : String output);

vars
	errNo : Integer;
	
begin
	// arm an exception handler to guard against something going wrong in the
	// external function calls (eg: the entry points are not available)

	on Exception do self.jtdResumeNextExHandler(exception, errNo);
	
	self.jtdGetMemoryStatus(localTotalMem, localAvailMem, thinTotalMem, thinAvailMem);

	// if an exception occurs in jtdGetMemoryStatus, we'll resume to here

//	self.jtdGetCPUDetails(localCPU, thinCPU);

	// if an exception occurs in jtdGetCPUDetails, we'll resume to here and return
end;</source>
        <Parameter name="localTotalMem" type="Integer" usage="output"/>
        <Parameter name="localAvailMem" type="Integer" usage="output"/>
        <Parameter name="thinTotalMem" type="Integer" usage="output"/>
        <Parameter name="thinAvailMem" type="Integer" usage="output"/>
        <Parameter name="localCPU" type="String" usage="output"/>
        <Parameter name="thinCPU" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="jtdGetMemoryStatus" id="c7872da5-ca1c-4b47-9d93-45d7eeb3e988">
        <source>jtdGetMemoryStatus(localTotal, localAvail, thinTotal, thinAvail : Integer output) protected;

vars
	b : Binary;
	
begin
	localTotal := 0;
	localAvail := 0;

	thinTotal := 0;
	thinAvail := 0;

	// Get the memory status for the local machine. If we're running thin
	// client, this call will get the memory status for the app server.
	b[1 : 256] := 0.Binary;
	call jtdGetMemoryStatusLocalMachine(b);
	localTotal := b[9 : 4].Integer;
	localAvail := b[13 : 4].Integer;
	
	// If we're running thin client, get the memory status of the thin client
	// machine. Otherwise zero will be returned for the thin client numbers.
	if process.isUsingThinClient then
		b[1 : 256] := 0.Binary;
		call jtdGetMemoryStatusThinClient(b);
		thinTotal := b[9 : 4].Integer;
		thinAvail := b[13 : 4].Integer;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="localTotal" type="Integer" usage="output"/>
        <Parameter name="localAvail" type="Integer" usage="output"/>
        <Parameter name="thinTotal" type="Integer" usage="output"/>
        <Parameter name="thinAvail" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="jtdGetProfileNameAndMthCount" id="a77bf5ba-f591-414d-a318-630cd4114764">
        <source>jtdGetProfileNameAndMthCount(profileName : String output; mthCount : Integer output);

begin
	if self.jtdMyDriverProfile = null then
		profileName := "&lt;Null Profile&gt;";
		mthCount := 0;
	else
		profileName := self.jtdMyDriverProfile.jtdName;
		mthCount := self.jtdMyDriverProfile.jtdGetTotalMethods;
	endif;
end;</source>
        <Parameter name="profileName" type="String" usage="output"/>
        <Parameter name="mthCount" type="Integer" usage="output"/>
    </JadeMethod>
