    </JadeMethod>
    <JadeMethod name="populateCombo" id="9a068bf1-773d-46ac-913a-f61cd13f0d67">
        <source>populateCombo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 January 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	userTerm : CM_UserTerminal;
	term : CM_Terminal;
	index : Integer;

begin

	self.cmbTerminal.clear();
	foreach userTerm in app.getMyUser.allUserTerminals do
		term := userTerm.myTerminal;
		if self.myTerminal = term then
			index := self.cmbTerminal.addItem( " " &amp; term.name );
		else
			index := self.cmbTerminal.addItem( term.name );
		endif;
		self.cmbTerminal.itemObject[index] := term;
		if term.allYardAllocations.isEmpty then
			self.cmbTerminal.itemEnabled[index] := false;
		endif;
	endforeach;
	
	if self.cmbTerminal.listIndex &lt; 1 then
		self.cmbTerminal.listIndex := self.cmbTerminal.findObject( self.myTerminal );
	endif;
	
	if self.cmbTerminal.listCount = 1 then
		self.cmbTerminal.listIndex := 1;
		self.cmbTerminal.enabled := false;
	endif;
	
	self.cmbTerminal.click(cmbTerminal);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="refreshTable" id="6fd1881e-2645-44cd-8456-5ffc992a1401">
        <source>refreshTable( _theTable : CM_DataTable input; _removePlanned : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation

*/

vars

	rowIndex : Integer;
	obj : Object;
	ti : CM_TrackedItem;
	str : String;
	size : Integer;
	objsToRemove : ObjectArray;

begin

	create objsToRemove transient;

	foreach rowIndex in _theTable.fixedRows to _theTable.rows do
		obj := _theTable.accessRow(rowIndex).itemObject;
		if obj.isKindOf(CM_TrackedItem) then
			ti := obj.CM_TrackedItem;
			str := ti.getAttributeStringForDefArray(_theTable.allTblDataEntRows);
			if ti.myPrimaryPlannedLocation &lt;&gt; null then
				_theTable.accessRow( rowIndex ).backColor := Grey;
			else
				_theTable.accessRow( rowIndex ).backColor := White;
			endif;
		elseif obj.isKindOf(CM_TestAutoPlanResult) then
			str := obj.CM_TestAutoPlanResult.getAttributeStringForDefArray(_theTable.allTblDataEntRows);
			if _removePlanned then
				ti := obj.CM_TestAutoPlanResult.myTrackedItem;
				if ti &lt;&gt; null and ti.myPrimaryPlannedLocation &lt;&gt; null then
					objsToRemove.add( obj );
				endif;
			endif;
		else
			continue;
		endif;
		_theTable.setCellText( rowIndex, 1, str);
	endforeach;
	
	if not objsToRemove.isEmpty then
		foreach obj in objsToRemove do
			_theTable.removeItemObject(obj);
		endforeach;
	endif;
	
	size := _theTable.rows - _theTable.fixedRows;
	if _theTable = self.tblFailed then
		if size = 0 then
			self.shtFail.caption := app.getErrorString(Failed_test_plan);
		else
			self.shtFail.caption := "(x" &amp; size.String &amp; ") " &amp; app.getErrorString(Failed_test_plan);
		endif;
	elseif _theTable = self.tblSelectedCargo then
		if size = 0 then
			self.shtFail.caption := app.getErrorString(Selected_Cargo);
		else
			self.shtSelected.caption := "(x" &amp; size.String &amp; ") " &amp; app.getErrorString(Selected_Cargo);
		endif;
	elseif _theTable = self.tblWouldPlan then
		if size = 0 then
			self.shtFail.caption := app.getErrorString(Would_plan);
		else
			self.shtResults.caption := "(x" &amp; size.String &amp; ") " &amp; app.getErrorString(Would_plan);
		endif;
	endif;
	
epilog

	delete objsToRemove;

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_removePlanned" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeNotableTi" id="58a6ef0d-4a69-4d2d-acca-6e62ce62ea20">
        <source>removeNotableTi( ti : CM_TrackedItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation

*/

vars

begin

	if self.allNotableTis.includes( ti ) then
		self.allNotableTis.remove( ti );
		self.endNotification( ti, Any_System_Event );
	endif;


epilog

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
