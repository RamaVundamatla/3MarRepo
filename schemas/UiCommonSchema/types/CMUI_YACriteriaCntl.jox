// 28/05/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars
	startDate, endDate : CMUI_DateMask;

begin
	self.getDateRangeMasks(startDate, endDate);

