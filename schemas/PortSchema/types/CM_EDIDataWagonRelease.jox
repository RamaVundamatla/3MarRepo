    <JadeMethod name="verifyEDIDataTIs" id="98d237ba-5479-4c7d-91ca-64f217f4c73f">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2022	navra1	Initial creation - 54124
05 January  2023	navra1	Added validation for assigned amount - 54124

*/

vars
	partsDone			: Integer;
	partsInJob			: Integer;
	progressStr			: String;
	progressTS			: TimeStamp;
	ediTI 				: CM_EDITrackedItem;
	passport			: CM_Passport;
	terminal			: CM_Terminal;
	foundTrain			: CM_Train;
	localTI				: CM_EDIWagonReleaseTI;
	foundWagon				: CM_Wagon;	
	bulkReleaseSpecified 	: CM_BulkRelease;
	
	reservationDetIter	: Iterator;
	reserveDetail : CM_ReserveDetail;
	reservationFound : Boolean;	
	
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);	// get as many error messages in 1 go as possible		
	
	passport	:= _passport;
	partsInJob	:= self.allEDITrackedItems.size();
	partsDone	:= null;
	terminal	:= self.getMyTerminal();	
	
	if terminal = null then
		// should never happen but just in case!
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
		return passport.allErrorWarnings.size();
	endif;
	
	progressStr	:= app.getString(Verifying_Loaded_Details, partsInJob.display);
	progressTS	:= app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, passport);
	
	foreach ediTI in self.allEDITrackedItems do	
		
		localTI := ediTI.CM_EDIWagonReleaseTI;
		
		//check if the train really exists
		foundTrain	:= self.getRealTrain(terminal, localTI.trainCode);
		
		if foundTrain = null then
			app.raiseCMException2(	Train_DoesNotExist_ForTerminal,
									localTI.trainCode,
									terminal.code,
									ETRow_TrainCode,
									null);
			return passport.allErrorWarnings.size();
		endif;		
		
		// the wagon needs to be unique for the train itself
		// check if the wagon train really exists on the train
		foundWagon	:= self.getRealWagon(foundTrain, localTI.wagonNumber);
		
		
		if foundWagon = null then
			app.raiseCMException2(	Wagon_not_found_train,
										localTI.wagonNumber,
										localTI.trainCode,
										ETRow_WagonNumber,
										null);
			return passport.allErrorWarnings.size();
		endif;				
		
		//check if the release request exists and is a rail release				
		bulkReleaseSpecified := terminal.getBulkReleaseFromCode(localTI.releaseRequestNumber);
		if bulkReleaseSpecified = null or not bulkReleaseSpecified.isRailType then
			app.raiseCMException2(	Bulk_Release_Not_Found,			
										localTI.releaseRequestNumber,
										terminal.code,
										ETRow_BulkRelease,
										null);
			return passport.allErrorWarnings.size();
		endif;	
		
		//check all the reservations of the bulk release obtained to see if we have the requested line number in that
		reservationFound := false;	//assume its not found yet
		reservationDetIter := bulkReleaseSpecified.allReserveDetails.createIterator();
		if localTI.lineNumber &lt;&gt; null then	//only if there is a line number specified
			while reservationDetIter.next(reserveDetail) do				
				//The reserveDetail can only be of release by type
				if reserveDetail.CM_ReserveSelection.lineNumber = localTI.lineNumber then	//if you found the reservation that was needed, mark the boolean and exit the loop
					reservationFound := true;
					break;
				endif;
			endwhile;
		else	// you want to check if the line number exists only if there is a line number specified, otherwise we are going to be adding everything, so this check is not required
			reservationFound := true;
		endif;
		
		//if you didnt fine the reservation, you cannot process this line, so throw error
		if reservationFound &lt;&gt; true then
			app.raiseCMException2(	Reserv_not_found,													
										localTI.lineNumber.String,
										localTI.releaseRequestNumber,
										ETRow_BulkRelease,
										null);
			return passport.allErrorWarnings.size();
		endif;		
		
		//check if only one of a specific qty or any amount is specified
		if localTI.assignedQuantity &lt;&gt; null then //we have an assigned amount, so the any quantity should be false			
			if isAssignedAnyAmountTrue(localTI.assignedAnyAmount) &lt;&gt; false then
				app.raiseCMException2(	EDI_QTYSpecified_AnyAmountT,			
										localTI.releaseRequestNumber,
										terminal.code,
										ETRow_BulkRelease,
										null);
			endif;
			
			//navra1 - 5th Jan 2023 - TFS 55617
			//validate to see if you have as many qty as requested in the EDI, and if not error out		
			if self.validateEDIRequestedQty(foundWagon, localTI.assignedQuantity, bulkReleaseSpecified, localTI.lineNumber) = false then 
				app.raiseCMException2(	Reque_amoun_not_found_relea_re,			
										localTI.releaseRequestNumber,
										terminal.code,
										ETRow_BulkRelease,
										null);
			endif;
			//navra1 - 5th Jan 2023 - TFS 55617
			
		else	//we dont have an assigned amount, so the any quantity should be true
			if self.isAssignedAnyAmountTrue(localTI.assignedAnyAmount) &lt;&gt; true then
				app.raiseCMException2(	EDI_QTYNotSpecified_AnyAmountF,			
										localTI.releaseRequestNumber,
										terminal.code,
										ETRow_BulkRelease,
										null);
			endif;
		endif;		
		
		partsDone			:= partsDone + 1;
		
		//update progress
		self.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, passport);
		
	endforeach;		

	
	return passport.allErrorWarnings.size();
	
epilog
	delete reservationDetIter;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
