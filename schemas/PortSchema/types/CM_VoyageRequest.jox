    <JadeMethod name="isSpecialStow" id="3bcc6c28-8542-4489-8bd3-6b4242095d3a">
        <source>isSpecialStow() : Boolean;
// ---------------------------------------------------------------------------
// Created:		11 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------




// ANY CHANGES HERE MUST BE MIRRORED IN THE SAME METHOD ON CM_CONTAINER




vars
		commGrp : CM_CommodityGroup;

begin
	if self.getAttrOverDimensioned() then	//+ cnwmd1 Par 22101 - added to match CM_TrackedItem::isSpecialStow()
		return true;
	endif;
	if self.getAttrPowerRequired() then	// AKB2010NOV - UNIT TEST
		return true;
	endif;

	commGrp := self.getAttrCommodityGroup();
	if commGrp = null then
		return self.getAttrIsSpecialStow(); // AKB CCMS MSL 1028
	endif;
	
	return commGrp.isSpecialStow;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageAllocDirector" id="26bfcab1-a574-42a3-a123-54fc2c63a2fe">
        <source>isVoyageAllocDirector(): Boolean;

/*
//cnwrd1 ccms 1303 14.11.2012
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2012	cnwrd1	Initial creation

*/

vars
	aWle	: CM_WorkListEntry;
begin
	
	if not self.myJob.isAllowOutOfOrderLoading then //if we are note out of order we cant be voyage alloc loading
		return false;		
	endif;
	
	if self.getFirstAllocation() = null then
		return false;
	endif;
	
	
	foreach aWle in self.allWorkListEntries do
		if aWle &lt;&gt; null and aWle.myTrackedItem = null then
			return true; // we are out of order, have an allocation and dont have a tracked item
		endif;	
	endforeach;
	
	// we are out of order, have an allocation but dont have an unallocated wle 
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
