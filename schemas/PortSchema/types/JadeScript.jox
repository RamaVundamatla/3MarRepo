    <JadeMethod name="rel821_par32263" id="4f2dd61f-83ff-4b51-a330-ef8b64b43b84">
        <source>rel821_par32263();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/10/2013	cnwdap1		Initial creation PAR #32263 Update temperature reading date
//
constants
	SixHours			= 32400000.Decimal;
vars
	startDate, 
	stopDate		: TimeStamp;
	reeferProps		: CM_TIReeferProperties;
	tempReading		: CM_TempReading;
	iter			: Iterator;
	count,
	foundTrans 		: Integer;
	ti				: CM_TrackedItem;
	tiTrans			: CM_TITransaction;
	wrongTime		: TimeStamp;

begin
	app.initialize;
	app.writeLog("Starting JadeScript " &amp; method.qualifiedName, LogINFO);
	
	// if we're not licenced for refcon, or we're not Port Otago, just quit now
	if app.myRoot.client &lt;&gt; Client_PortOtago then
		app.writeLog("Client is not Port Otago - nothing to do", LogINFO);
		return;
	endif;
//	if not app.myRoot.canDo(PmRefCon) then
	if not app.myRoot.canDo(Mod_BaseSystem) then	//07 Oct 2019	NDL	TFS 46169
		app.writeLog("Client is not licenced for RefCon - nothing to do", LogINFO);
		return;
	endif;
	
	startDate.setDate("20/02/2013".Date);
	startDate.setTime("00:00".Time);
	stopDate.setDate("17/07/2013".Date);
	stopDate.setTime("23:59".Time);
	
	// read all reefer property objects to get to the temperature readings
	foreach reeferProps in CM_TIReeferProperties.instances discreteLock do
		iter := reeferProps.allTemperatureReadings.createIterator;
		reeferProps.allTemperatureReadings.startKeyGeq(startDate, iter);
		while iter.next(tempReading) do
			if tempReading.dateTime &gt; stopDate then
				break;
			endif;
			if not tempReading.isRefConReading then
				continue;
			endif;
			if not tempReading.myReeferProperties.myParent.isKindOf(CM_TrackedItem) then
				continue;
			endif;
			
			if tempReading.dateTime.cnEcDiff(tempReading.creationTime) &gt; SixHours then
				// do some updating
				count := count + 1;
				ti := tempReading.myReeferProperties.myParent.CM_TrackedItem;
				wrongTime := tempReading.dateTime;
				if count mod 50000 = 0 then
					app.writeLog("Sample: CM_TempReading " &amp; tempReading.getOidString &amp; " date changed from " &amp; wrongTime.asStringJMT &amp; " to " &amp; tempReading.creationTime.asStringJMT, LogINFO);
				endif;
				beginTransaction;
				// update the temperature reading
				tempReading.setPropertyValue(CM_TempReading::dateTime.name, tempReading.creationTime);
				// and the "Temperature Read" transaction
				tiTrans := ti.allTransactions[wrongTime, null];
				if tiTrans &lt;&gt; null and tiTrans.type = TRANS_TYPE_TEMP_READING then
					foundTrans := foundTrans + 1;
					if foundTrans mod 50000 = 0 then
						app.writeLog("Sample: CM_TITransaction " &amp; tiTrans.getOidString &amp; "date changed from " &amp; tiTrans.dateTime.asStringJMT &amp; " to " &amp; tempReading.creationTime.asStringJMT, LogINFO);
					endif;
					tiTrans.setPropertyValue(CM_TITransaction::dateTime.name, tempReading.creationTime);
				endif;
				// and the ti's edition, so data store gets updated
				ti.updateObjectEdition(ti);
				commitTransaction;
			endif;
		endwhile;
		delete iter;
	endforeach;
	app.writeLog("Number of temperature readings updated: " &amp; count.String &amp; ", number with Temperature Read transactions: " &amp; foundTrans.String, LogINFO);
	app.writeLog("Completed JadeScript " &amp; method.qualifiedName, LogINFO);
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="rel821_par32361" id="2ff988ad-3e89-45d2-a61d-4acc91fc0276">
        <source>rel821_par32361();
/*
Date		Who		Reason
29 Aug 2013	cnwcs5	par 32361
*/
vars

begin
	// make sure no instances of CM_Xlation are left behin so that 8.2.2 upgrade can
	// load class as abstract
	
	beginTransaction;
	CM_Xlation.instances.purge;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
