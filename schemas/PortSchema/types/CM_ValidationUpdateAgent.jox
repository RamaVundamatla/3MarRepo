    <JadeMethod name="valYACriteriaPriority" id="31673c7e-34ce-4442-a4c7-f6fc16c5963b">
        <source>valYACriteriaPriority(pCriteriaPriorityObj:CM_YACriteriaPriority; pProxyObj:CM_YACriteriaPriority);
// --------------------------------------------------------------------------------
// Created:		21 March 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNull(pProxyObj, 'Yard Allocation Criteria/Priority Proxy');
	self.raiseExceptionIfNull(pCriteriaPriorityObj, "Existing Yard Allocation Criteria/Priority");
	pProxyObj.raiseExceptionIfNotProxy(method);
	
	if pCriteriaPriorityObj.code = pProxyObj.code then
		pProxyObj.validateForUpdate();
	else
		pProxyObj.validateForCreate();
	endif;
end;</source>
        <Parameter name="pCriteriaPriorityObj" type="CM_YACriteriaPriority"/>
        <Parameter name="pProxyObj" type="CM_YACriteriaPriority"/>
    </JadeMethod>
