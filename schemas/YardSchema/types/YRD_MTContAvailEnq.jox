    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="9bbc4316-6090-483a-8cd9-944ce81697a3">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation	27731

*/

vars

	xmlStr	: String;
	str	: String;

begin

	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; self.tblData.getXmlStrForColumns(true);
	if self.myFiltOperator &lt;&gt; null then
		xmlStr := xmlStr &amp; global.formatAsXMLPrefix(YRD_MTContAvailEnq::myFiltOperator.name) &amp; myFiltOperator.getOidString &amp; global.formatAsXMLSuffix(YRD_MTContAvailEnq::myFiltOperator.name);
	endif;
	if self.myFiltIsoGroup &lt;&gt; null then
		xmlStr := xmlStr &amp; global.formatAsXMLPrefix(YRD_MTContAvailEnq::myFiltIsoGroup.name) &amp; myFiltIsoGroup.getOidString &amp; global.formatAsXMLSuffix(YRD_MTContAvailEnq::myFiltIsoGroup.name);
	endif;
	if self.myFiltGrade &lt;&gt; null then
		xmlStr := xmlStr &amp; global.formatAsXMLPrefix(YRD_MTContAvailEnq::myFiltGrade.name) &amp; myFiltGrade.getOidString &amp; global.formatAsXMLSuffix(YRD_MTContAvailEnq::myFiltGrade.name);
	endif;
	if self.myFiltReceivalDate.isValid then
		xmlStr := xmlStr &amp; global.formatAsXMLPrefix(YRD_MTContAvailEnq::myFiltReceivalDate.name) &amp; (myFiltReceivalDate - myFiltBaseDate).Integer.String &amp; global.formatAsXMLSuffix(YRD_MTContAvailEnq::myFiltReceivalDate.name);
	endif;
	if self.myFiltReleaseDate.isValid then
		xmlStr := xmlStr &amp; global.formatAsXMLPrefix(YRD_MTContAvailEnq::myFiltReleaseDate.name) &amp; (myFiltReleaseDate - myFiltBaseDate).Integer.String &amp; global.formatAsXMLSuffix(YRD_MTContAvailEnq::myFiltReleaseDate.name);
	endif;
	
	xmlStr := xmlStr &amp; global.formatAsXMLPrefix(YRD_MTContAvailEnq::mnuShowExtra.name) &amp; self.tblInfo.visible.Integer.String &amp; global.formatAsXMLSuffix(YRD_MTContAvailEnq::mnuShowExtra.name);

	xmlStr := xmlStr &amp; global.formatAsXMLPrefix(YRD_MTContAvailEnq::splRatioSaved.name) &amp; splRatioSaved.String &amp; global.formatAsXMLSuffix(YRD_MTContAvailEnq::splRatioSaved.name);

	return xmlStr;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="dc2c79e4-34f1-4f8e-9d37-d9112c522491">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation	Par 27731
//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	tmpStr : String;
	operator : CM_Operator;
	isoGroup : CM_ISOTypeGroup;
	grade : CM_MTGrade;
	tmpInt : Integer;
	tmpDate : Date;
	tmpBoolean : Boolean;
	today : Date;
	tmpTS : TimeStamp;
begin

	inheritMethod(_userWindow);
	//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	today := app.actualTimeServer.date();
	
	
	//set the default values for search fields
	self.doSetSearchDefaults();
	
	// now get any saved values the user may have
	tmpStr := null;
	tmpStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(YRD_MTContAvailEnq::myFiltOperator.name);
	if tmpStr &lt;&gt; null then
		operator := tmpStr.asOid.CM_Operator;
		self.cmbOperator.listIndex := self.cmbOperator.findObject( operator );
		if self.cmbOperator.listIndex &lt; 1 then
			self.cmbOperator.listIndex := 1;
		endif;
		self.myFiltOperator := self.cmbOperator.listObject.CM_Operator;
	endif;
	
	tmpStr := null;
	tmpStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(YRD_MTContAvailEnq::myFiltIsoGroup.name);
	if tmpStr &lt;&gt; null then
		isoGroup := tmpStr.asOid.CM_ISOTypeGroup;
		self.cmbISOGroup.listIndex := self.cmbISOGroup.findObject( isoGroup );
		if self.cmbISOGroup.listIndex &lt; 1 then
			self.cmbISOGroup.listIndex := 1;
		endif;
		self.myFiltIsoGroup := self.cmbISOGroup.listObject.CM_ISOTypeGroup;
	endif;
	
	tmpStr := null;
	tmpStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(YRD_MTContAvailEnq::myFiltGrade.name);
	if tmpStr &lt;&gt; null then
		grade := tmpStr.asOid.CM_MTGrade;
		self.cmbGrade.listIndex := self.cmbGrade.findObject( grade );
		if self.cmbGrade.listIndex &lt; 1 then
			self.cmbGrade.listIndex := 1;
		endif;
		self.myFiltGrade := self.cmbGrade.listObject.CM_MTGrade;
	endif;
	
	tmpStr := null;
	tmpStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(YRD_MTContAvailEnq::myFiltReceivalDate.name);
	if tmpStr &lt;&gt; null then
		tmpInt := tmpStr.Integer;
		self.myFiltBaseDate := today;
		self.myFiltReceivalDate := self.myFiltBaseDate + tmpInt;
		//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		tmpTS.cnEcSetDateAndTime(self.myFiltReceivalDate,TimeEndOfDay);
		self.txtReceivalDate.setDate(self.systemToLocalTime(tmpTS).date());
	endif;
	
	tmpStr := null;
	tmpStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(YRD_MTContAvailEnq::myFiltReleaseDate.name);
	if tmpStr &lt;&gt; null then
		tmpInt := tmpStr.Integer;
		self.myFiltBaseDate := today;
		self.myFiltReleaseDate := self.myFiltBaseDate + tmpInt;
		//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		tmpTS.cnEcSetDateAndTime(self.myFiltReleaseDate,TimeEndOfDay);
		self.txtReleaseDate.setDate(self.systemToLocalTime(tmpTS).date());
	endif;
			
	self.splRatioSaved := 75;// default, if nothing saved
	tmpStr := null;
	tmpStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(YRD_MTContAvailEnq::splRatioSaved.name);
	if tmpStr &lt;&gt; null then
		tmpInt := tmpStr.Integer;
		if tmpInt &gt; 0 and tmpInt &lt; 100 then
			self.splRatioSaved := tmpInt;
		endif;
	endif;

	tmpStr := null;
	tmpStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(YRD_MTContAvailEnq::mnuShowExtra.name);
	if tmpStr &lt;&gt; null then
		tmpBoolean := tmpStr.Integer = 1;
		self.doMnuShowExtra( tmpBoolean );
	endif;
		
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
