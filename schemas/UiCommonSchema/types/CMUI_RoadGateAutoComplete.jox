    <JadeMethod name="doDelete" id="377265f9-57d5-4f32-acf9-8c138d90e0c9">
        <updating/>
        <source>doDelete() updating;
/*

Changed On   	Changed By  Reason	
----------  	----------  --------------------------------------------------
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move

*/
vars
	result : Integer;
	msgStr : String;
	criteria : CM_Object;
	
begin

	criteria := self.tblData.accessRow(self.tblData.row).itemObject.CM_Object;

	if criteria &lt;&gt; null then
		msgStr := app.getErrorString2(ConfirmDelete, 'the selected', 'criteria');
	else
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;	
	endif;

	if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return;
	endif;	
	
	while true do
		app.myTrxDA.trxDeleteCMObject(criteria, app.myPassport ); //trxDeleteDelay(selectedObj.CM_Delay, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
	
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	

epilog
	//update the view since we are not listening to events
	self.refreshTableView();
end;
</source>
    </JadeMethod>
    <JadeMethod name="doEditItem" id="67597f64-8913-4b5e-8dbb-05eae58e38a9">
        <updating/>
        <source>doEditItem() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move

*/

vars
	criteria : CM_RoadGateAutoComplete;
	loadState : Boolean;
begin
	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;

	criteria := self.tblData.accessRow(self.tblData.row).itemObject.CM_RoadGateAutoComplete;
	if criteria = null then
		return;
	endif;
	
	self.setNavigatorHeading(criteria.name);
	
	app.cmsBeginLoad(loadState);
		self.myCurrentCriteria := criteria.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadState);
	self.isUpdate := true;
	self.doUpdateOrNew();
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNew" id="50f1f69e-ae44-4fe4-b7bb-41ddd4548e5c">
        <updating/>
        <source>doNew() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move

*/

vars
	criteriaNew : CM_RoadGateAutoComplete;
begin
	create criteriaNew transient;
	self.myCurrentCriteria := criteriaNew;
	isUpdate := false; // false means new
	self.doUpdateOrNew();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="5f04e91f-7ae8-45f3-9866-fe7eb34237fb">
        <updating/>
        <source>doQueryAddItem(_detail : CM_RoadGateAutoComplete) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move

*/

vars
	theDataLine : String;
	idx, colNumber : Integer;
begin
	theDataLine := _detail.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);

	idx := self.tblData.addItem(theDataLine);
	self.tblData.accessRow(idx).itemObject := _detail;
	
epilog

end;</source>
