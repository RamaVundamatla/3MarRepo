<Class name="CM_EWSTypeAgent" id="7303a5a6-0657-42e2-be17-809333f36129">
    <superclass name="CM_Agent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="allEWSEndpointTypeByType" id="31a9fae6-27f3-47c9-9d68-40d3cde7536b">
        <memberTypeInverse/>
        <type name="CM_EWSEndpointTypebyType"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allEWSEndpointTypesByName" id="125d5c11-92de-4522-8fd6-13afb6035894">
        <memberTypeInverse/>
        <type name="CM_EWSEndpointTypebyName"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allEWSTypesByName" id="b22af600-ad7a-4086-9002-809f11cf8281">
        <memberTypeInverse/>
        <type name="CM_ExtWebServiceTypeByName"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allEWSTypesByType" id="41998142-9d29-4f8e-bae5-4d46981cc517">
        <memberTypeInverse/>
        <type name="CM_ExtWebServiceTypeByType"/>
    </ImplicitInverseRef>
    <PrimAttribute name="useReal" id="e37f64e6-1337-4bca-98b2-53beb37eb4c0">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="delete" id="94c64025-6d61-4db0-ab10-6dd7b23dc11d">
        <updating/>
        <source>delete() updating;
// ### JIRA 33541 12DEC2024 NAVAB1
vars

begin
	if not self.useReal then 
		self.allEWSEndpointTypeByType.purge;
		self.allEWSTypesByType.purge;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="init" id="686681ca-3d5a-4a03-a47f-5ecba1c1862a">
        <updating/>
        <source>init() updating;
// ### JIRA 33541 12DEC2024 NAVAB1
vars
	tmpClassColl	: ClassColl;
	tmpClass		: Class;
	tmpEWSType		: CM_ExternalWebServiceType;
	tmpEndPointType		: CM_EWSEndpointType;
begin
	self.useReal := false;
	
	
	create tmpClassColl transient;
	CM_ExternalWebServiceType.allLocalSubclasses(tmpClassColl);
	
	foreach tmpClass in tmpClassColl do
		if tmpClass.abstract then
			continue;
		endif;
		
		create tmpEWSType as tmpClass transient;
		// the create method on CM_ExternalWebServiceType will set the name &amp; type attributes
		if tmpEWSType.name = null or
		   tmpEWSType.type &lt;= 0 then
			// this has not been set in the create so do not allow permissions for this
		   	delete tmpEWSType;
		   	continue;
		endif;
		self.allEWSTypesByType.add(tmpEWSType);
		self.allEWSTypesByName.add(tmpEWSType);
	endforeach;

	tmpClassColl.clear;
	CM_EWSEndpointType.allLocalSubclasses(tmpClassColl);
	
	foreach tmpClass in tmpClassColl do
		if tmpClass.abstract then
			continue;
		endif;
		create tmpEndPointType as tmpClass transient;
		// the create method on CM_EWSEndpointType will set the name &amp; type attributes
		if tmpEndPointType.name = null or
		   tmpEndPointType.type &lt;= 0 then
			// this has not been set in the create so do not allow permissions for this
		   	delete tmpEndPointType;
		   	continue;
		endif;
		self.allEWSEndpointTypeByType.add(tmpEndPointType);
		self.allEWSEndpointTypesByName.add(tmpEndPointType);
	endforeach;
epilog
	delete tmpClassColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="outputAsCSV" id="97e0898a-b1a6-46b8-8eb2-add15b041ab0">
        <source>outputAsCSV(_file : File);
// ### JIRA 33541 12DEC2024 NAVAB1
vars
	
begin

	_file.writeLine('EWS File');
	_file.writeLine(self.showLicenceDetailsEWS());

	
end;</source>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="showLicenceDetailsEWS" id="74131ce7-bee6-4756-b9a4-f5e57b0496fc">
        <source>showLicenceDetailsEWS() : String protected;
// ### JIRA 33541 12DEC2024 NAVAB1
vars
	canDo		: Boolean;
	ewsType	: CM_ExternalWebServiceType;
	endpointType	: CM_EWSEndpointType;
	tmpEWSDict		: CM_ExtWebServiceTypeByType;
	tmpEPDict	: CM_EWSEndpointTypebyType;
	str : String;
	root : CM_Root;
begin
	root := app.myRoot;

	if (not root.isLicensedForProductCode(ProductCode_EWS)) then
		str := app.getErrorString(LicenseDetailsNotYetEntered);
		return str;
	endif;

	//EWS

	tmpEWSDict := self.allEWSTypesByType;

	foreach ewsType in tmpEWSDict do

		canDo := root.canDoEDIFileType(ewsType.type);
		str := str &amp; ewsType.name &amp; Tab &amp; canDo.getYesNo()&amp; CrLf;
		
	endforeach;


	//EndPoints

	tmpEPDict := self.allEWSEndpointTypeByType;

	foreach endpointType in tmpEPDict do

		canDo := root.canDoEDIFileType(endpointType.type);
		str := str &amp; endpointType.name &amp; Tab &amp; canDo.getYesNo() &amp; CrLf;
		
	endforeach;
	return str;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
