<Class name="CM_Vessel">
    <JadeMethod name="exportAttrIgnorePDXML" id="e00c33cc-4610-434e-809a-79682518927f">
        <source>exportAttrIgnorePDXML(_attrName: String): Boolean;

vars

begin
	if _attrName = CM_Vessel::bitmap.name then
		return true;
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="c2a6fa75-7a3c-47c1-95ec-37259773d313">
        <updating/>
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object updating;

vars

begin
	if _name = CM_Vessel::myRootForVessel.name then
		if _theCode &lt;&gt; null then
			return app.myRoot;
		endif;
	elseif _name = CM_Vessel::myRootForVesselClass.name then
		if _theCode &lt;&gt; null then
			return app.myRoot;
		endif;
	elseif _name = CM_Vessel::myOperator.name then
		return app.myRoot.allOperators[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
