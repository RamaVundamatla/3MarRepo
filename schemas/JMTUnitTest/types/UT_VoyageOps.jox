    <JadeMethod name="uFloodNotifications" id="df695915-71b7-4dc6-bba0-d8b09b1917e1">
        <source>uFloodNotifications();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2021	navndl1	Initial creation	TFS 50796

*/

constants

	VesselCode : String = "SCANPLAN";  // existing vessel set up for scan plan testing with a variety of cell configurations
	Voyage1 : String = "SCP1";	 // existing voyage
	
vars

	voyage : CM_Voyage;
	minutesToRun : Decimal[4,1];
	elapsedInterval : TimeStampInterval;
	notesPerSecond : Integer;
	millisecondsPerNote : Integer;
	noteInterval : TimeStampInterval;
	totalNoteCount : Integer;
	includeOnSite : Boolean;
	includeOffSite : Boolean;
	includePreNote : Boolean;
	endTimeStamp : TimeStamp;
	now : TimeStamp;
	tiSet : CM_TISet;
	ti : CM_TrackedItem;
	iter : Iterator;
	count : Integer;
	voyageNotePerAllNoteCount : Integer;

begin

	minutesToRun := 1;  //Minutes to run
	notesPerSecond := 3; // How many notifications per second.
	voyageNotePerAllNoteCount := 10;
	
	includeOnSite := true;
	includeOffSite := true;
	includePreNote := true;

	
	millisecondsPerNote := ( 1000 / notesPerSecond ).Integer;
	noteInterval.set( 0, millisecondsPerNote );
	totalNoteCount := ( 60 * notesPerSecond * minutesToRun ).Integer;
	
	
	create tiSet transient;
	voyage := self.getVoyage( Voyage1 );
	
	voyage.allOnshipTIsByCargoTypeId.copy( tiSet );
	if includeOnSite then
		voyage.allOnsiteTIsByCargoTypeId.copy( tiSet );
	endif;
	if includeOffSite then
		voyage.allOffsiteTIsByCargoTypeId.copy( tiSet );
	endif;
	if includePreNote then
		voyage.allNotifiedTIsByCargoTypeId .copy( tiSet );
	endif;
	
	elapsedInterval.set( 0, ( minutesToRun * 60 * 1000 ).Integer );
	endTimeStamp := app.actualTimeAppServer + elapsedInterval;
	
	while true do
		iter := tiSet.createIterator;
		while iter.next( ti ) do
			count := count + 1;
			beginTransaction;
			if count &gt; voyageNotePerAllNoteCount then
				count := 1;
				ti.causeEvent( ti.myTerminal.getTerminalEvent(EVENT_TI_Voyage_Chg), false, voyage );
			else
				ti.updateObjectEdition(ti);
			endif;
			commitTransaction;
			process.sleep( millisecondsPerNote );
			now := app.actualTimeAppServer();
			if now &gt; endTimeStamp then
				break;
			endif;
		endwhile;
		delete iter;
		if now &gt; endTimeStamp then
			break;
		endif;
	endwhile;

epilog

	delete tiSet;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="uLoLoBasicMoves" id="7af79264-5af9-44bc-8cb2-214d1c13ae7b">
        <updating/>
        <source>uLoLoBasicMoves() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 September 2012	cnwrd1	Initial creation

*/


constants
	DischargeBox		= "UTDR0000002";
	TranshipBox			= "UTDR0000004";
	LoadBox				= "UTDR0000003";
	BlockStack1			= "UT_RDBS1";
	YardIC				= "UT_RD_IC";
	Ship				= "UTRDSHIP";
	ExpShip				= "UTRDSHIP2";
	Voyage1				= "UTRDVOYAGE";
	ExportVoyage		= "UTRDVOYEXP";
	CraneTransferAreaId	= "CTRD";
	CraneId				= "CRR1";

vars
	dischargeTi,
	loadTi,
	transhipTi,
	ti4				: CM_TrackedItem;
	bs				: CM_BlockStack;
	yardIC			: CM_InterchangeArea;
	wle				: CM_WorkListEntry;
	vessel,
	expVessel		: CM_Vessel;
	voyage,
	exportVoyage	: CM_Voyage;
	slots 			: CM_SlotControllerArray;
	voyageJob		: CM_VoyageJob;
	job				: CM_Job;
	request			: CM_Request;
	voyageQueue		: CM_VoyageQueue;
	craneQueue		: CM_VoyageCraneQueue;
	crane			: CM_Machine;
	operator		: CM_Operator;
	bayName			: String;
	loadPort,
	dischargePort	: CM_Port;
	jobs			: CM_JobArray;
	voyAlloc		: CM_VoyageAllocation;
	wles 			: CM_WLEArray;
	straddle		: CM_Machine;
	tas				: StringArray;
	cta				: CM_CraneTransferArea;
	transhipController		: CMIF_TranshipTIController;
begin
	
	create jobs transient;
	create wles transient;

	// delete everything first
	self.deleteContainer(DischargeBox);
	self.deleteContainer(LoadBox);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(YardIC);
	self.deleteVoyage(Voyage1);
	self.deleteVoyage(ExportVoyage);
	
	self.deleteVessel(Ship);
	self.deleteVessel(ExpShip);
	
	self.deleteTerminalArea(CraneTransferAreaId);
	
	
	// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStack1, 20, null);		
	
	
	// create the crane transfer area
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	//create vessel and voyage
	vessel := addVesselCellular(Ship, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	expVessel := addVesselCellular(ExpShip, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage := self.addVoyageWithContainerStructur(Voyage1, Ship, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);	
	exportVoyage := self.addVoyageWithContainerStructur(ExportVoyage, ExpShip, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	self.assertNotNull(vessel);
	self.assertNotNull(voyage);

	self.assertNotNull(expVessel);
	self.assertNotNull(exportVoyage);

	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	self.deleteMachine(CraneId);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;

	
	loadPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;

	//create discharge job
	bayName := '01';
	create slots transient;
	self.getJobSlotControllers(Voyage1, bayName, DeckOnDeck, 1, 1, 2, slots);
	assertEqual(slots.size, 2);
	dischargeTi := self.addContainerAtLocnDisch(DischargeBox , "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], loadPort, voyage);
	
	transhipTi := self.addContainerAtLocnDisch(TranshipBox , "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[2], loadPort, voyage);
	/*
	create transhipController transient;
	transhipController.myExportDestPort 	:= app.myRoot.allPorts['NZAKA'];
	transhipController.myExportDisPort 		:= app.myRoot.allPorts['NZAKL'];
	transhipController.myExportVoyage 		:= exportVoyage;
	transhipController.remarks 				:= "UT Tranship";
	transhipController.removeStops 			:= true;
	transhipController.allTrackedItems.add(transhipTi);	
	self.makeTrackedItemTranship(transhipController);
	*/
	
	// Color code and Create Discharge Jobs
	self.voyageDischargeColourCode(voyage);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, true);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job 1 not created");
	jobs.add(voyageJob);
	

	
	
	/*	controller	: CMIF_TranshipTIController;
	ti			: CM_TrackedItem;
begin
	create controller transient;
	controller.myExportDestPort 	:= app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort 		:= app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage 		:= _exportVoyage;
	controller.remarks 				:= "UT Tranship";
	controller.removeStops 			:= true;
	foreach ti in _voyage.allImportTIs do
		controller.allTrackedItems.add(ti);
	endforeach;
	
	self.makeTrackedItemTranship(controller);

	*/
	
	foreach wle in voyageJob.workListEntries do
		self.movePlannedWLE(wle.myTrackedItem, 	bs.myLocationsController, wle);
	endforeach;
	delete slots;
	

	voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code,"GEN2",null,1,false,false);
	bayName :='01';
	self.logMessageNow("Create Load Jobs for bay " &amp; bayName);
	create slots transient;
	self.getJobSlotControllers(voyage.code, bayName, DeckOnDeck, 1, 2, 1, slots);
	assertEqual(slots.size, 1);

	self.addLCsToLOLOAllocation(true, voyAlloc, slots, null);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, false);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");
	jobs.add(voyageJob);	
	loadTi := self.addContainerForExport(LoadBox, operator,
				"2200",	"GENL",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi, bs.getLocationsController);
	self.setCargoReadyToShip(loadTi);
	self.deleteStops(loadTi);
	self.movePlannedRequestToJob(loadTi, slots[1], slots[1].getRequest(true));
	delete slots;

	// ok have my load and discharge jobs now
	
	//load to ops
	self.loadAllJobsToOps(voyage, true);				
	
	self.addMachineRule( bs, crane.CM_Crane.transferArea, RTMoveMethod_23); //simple single straddle moves
	self.addMachineRule( crane.CM_Crane.transferArea, bs, RTMoveMethod_23); 
		
	voyageQueue := self.addVoyageQueue(voyage);
	craneQueue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);
	
	// Create Queues
	foreach job in jobs do
		foreach request in job.allRequests do
			foreach wle in request.allWorkListEntries do
				wles.add(wle);
				self.queueWLE(wle);
			endforeach;
		endforeach;
	endforeach;
	
	// workJob using straddle
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(bs.id); 
	tas.add(yardIC.id); 
	tas.add(crane.CM_Crane.transferArea.id); 
	self.addStraddle("UTS1", 91, tas, null);
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	if craneQueue &lt;&gt; null then
		beginTransaction;
		straddle.addToQueue(craneQueue, true, 0); //add straddle to crane queue
		commitTransaction;
	endif;
	delete tas;
	
	app.isRTApp:=true;  
	self.machineLogon(straddle);

	foreach wle in wles do
		self.machineAcceptTask(straddle, wle.allRTQueueEntries.first.allTasks.first);
		
		if wle.isReceipt and wle.job.isVoyageJob then 
			//crane := wle.job.CM_VoyageJob.getJobCrane();
			self.machineCraneActionPickup(straddle, dischargeTi, ti4);
			self.machinePickup(straddle);			
			self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, bs.id);	
		else
			self.machinePickup(straddle);
			self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, wle.allRTQueueEntries.first.allTasks.last.targetLocationId);
		endif;
		
	endforeach;	
	
	self.assertTrue( dischargeTi.myPrimaryActualLocation.isYardLocation);
	self.assertTrue( loadTi.myPrimaryActualLocation.isVoyageController);
	
	// check txns created correctly for the following
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_REC_SHIP);			// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_WHARFAGE);			// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(loadTi, TRANS_TYPE_REL_SHIP);				// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(loadTi, TRANS_TYPE_WHARFAGE);				// 15/08/2012 cnwmh5
	
epilog
	app.isRTApp:=false;  
	delete jobs;
	delete slots;
	delete wles;
	delete tas;						// 13/09/2012 cnwmc5
	delete transhipController;
end;</source>
    </JadeMethod>
    <JadeMethod name="uMoveAndUnqueuePerformace" id="2ac83541-de43-4fba-b3c9-716fbd4b052b">
        <source>uMoveAndUnqueuePerformace();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2021	navndl1	Initial creation	TFS 

*/

constants
	VoyageName = 'UTMDHVOY4';
	ShipName = 'UTMDHVES4';
	TestOperator = 'MSK';
	CraneTransferAreaId	= "UTC1T6";
	IMV1 = "UTIM";
vars
	cta							: CM_CraneTransferArea;
	bs							: CM_BlockStack;
	vessel 						: CM_Vessel;
	voyage 						: CM_Voyage;
	queue						: CM_VoyageQueue;
	rampQueue					: CM_VoyageCraneQueue;
	cargo1, cargo2, cargo3, cargo4,
	cargo5						: CM_TrackedItem;
	crane						: CM_Machine;
	imv							: CM_Machine;
	job 						: CM_VoyageJob;
	wle 						: CM_WorkListEntry;
	slotsFrom					: CM_SlotControllerArray;
	tmpLoadCC					: CMIF_LoadColorCode;
	theSlot 					: CM_LocationsController;
	ctaLane: CM_LocationsController;
	strs 						: StringArray;
	tas							: StringArray;
	idx							: Integer;
	pxyTask						: CM_RTQueueTask;
	agent : CMIF_MobileGenericAgent;
	result: Boolean;
	moveController		 : CMIF_MoveController;	
	futureMove 			 : CM_FutureMove;
	resultInt : Integer;
	myProfiler : JadeProfiler;
	
begin

	myProfiler := process.profiler;

	self.disableAllYA(true);
	bs:= self.addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 100, null);
	self.addYACatchAll("UTMYA", bs);
	
	self.deleteMachine("UTMC");
	cta := self.addCraneTransferArea(CraneTransferAreaId);

	create tas transient;
	tas.add(cta.id);
	tas.add(bs.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	crane := self.addCrane("UTMC", null, tas, null);
	
	self.addMachineRule (cta, bs, RTMoveMethod_7);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	vessel := self.addVesselLOLOholdsRORO(ShipName, self.getOperator(TestOperator));
	voyage	:= self.addVoyageWithConRORO(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													null, 10, false, true);
	queue := self.addVoyageQueue(voyage);
	rampQueue := self.addVoyageCraneQueue(voyage, queue, crane);
	
	create strs transient;
	deleteContainer("UTMDHJ00001");
	strs.clear;
	strs.add("010682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo1 := self.addContainerAtLocnDisch("UTMDHJ00001", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);

	deleteContainer("UTMDHJ00003");
	strs.clear;
	strs.add("010684");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo3 := self.addContainerAtLocnDisch("UTMDHJ00003", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);

	deleteContainer("UTMDHJ00004");
	strs.clear;
	strs.add("010686");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo4 := self.addContainerAtLocnDisch("UTMDHJ00004", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);

	deleteContainer("UTMDHJ00005");
	strs.clear;
	strs.add("010482");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo5 := self.addContainerAtLocnDisch("UTMDHJ00005", "2200", "MT", TI_IMEX_STATUS_IMPORT, theSlot, app.myRoot.allPorts["NZPOE"], voyage);

	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageName, "01", DeckOnDeck, 1, 1, 3, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	job := self.addVoyageJob(voyage, crane.code, slotsFrom, true);
	assertTrue(job &lt;&gt; null);
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
	imv := self.addIMV(IMV1, 93, tas, rampQueue.id);
	self.machineAssignToQueue(imv, rampQueue);

	// Check that Lander can discharge to yard
	create agent transient;
	agent.setMyTerminal(self.getTerminal());
	agent.setMyVoyage(voyage);
	agent.setDoNotShowMsgBox(true);
	
	
	on CM_Exception do app.validationExHandler(exception,app.myPassport);
	//epr TFS 3760 lander functions refactored to use CMIF_MobileGenericAgent
	//now just need to call agent.doLanderDischarge
	
	agent.doImportGetJobWLE(cargo1, job, wle, true, false, 0 ,0, bs.getLocationsController);
		
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();

	create moveController transient;
	moveController.setMyTrackedItem( cargo1);
	moveController.setMyToPrimaryLocation(bs.getLocationsController);
	moveController.setMoveMode(REAL_MODE);
	if wle &lt;&gt; null then
		moveController.setMyWorkListEntry(wle);
		moveController.setJobForMove(wle.job);
	endif;
	moveController.setTransferTypeFromJob( job, cargo1.myPrimaryActualLocation.getTransferType() );

	if myProfiler.isProfiling then
		myProfiler.reset;
		myProfiler.stop;
	endif;

	myProfiler.reportMethodSize := false;
	myProfiler.reportActualTime := true;
	myProfiler.reportCacheStatistics := false;
	myProfiler.reportLoadTime := false;
	myProfiler.reportTotalTime := true;
	myProfiler.reportStatistics := false;
	myProfiler.methodCount := 6000;
	
	myProfiler.start;
	
	app.myTrxUA.trxMoveTrackedItemAndUnQueue(moveController, futureMove, null, app.myPassport);
					
epilog

	if myProfiler &lt;&gt; null and myProfiler.isProfiling then
		myProfiler.stop;
		myProfiler.report;
	endif;

	self.disableAllYA(false);
	delete slotsFrom;
	delete strs;
	delete tas;
	delete pxyTask;
	delete agent;
	delete moveController;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uPAR28816" id="297f77c3-c4c5-48f9-a63e-1ade2f16f876">
        <source>uPAR28816();

/*

Purpose:		Use the Hand Held to discharge to ground DLR's

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2011	cnwmh5	Initial creation

*/
constants
	CONTAINER1ID		: String = "MDHZ9999994";
	CONTAINER2ID		: String = "MDHZ9999995";
	CONTAINER3ID		: String = "MDHZ9999996";
	BLOCKSTACK			: String = "UTMBS9";
	YARDALLOCATION 	 	: String = "UTMBS9";
	CRANENAME			: String = "CRN9";   //"UTC1";
	RTDEVICE			: Integer = 19;
	VOYAGENAME			: String = "UTMHHH9";
	VESSELNAME			: String = "UTMHHH9";
	ContainerBaseId		: String = "MDHZ99999";
vars

	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	tmpLoadCC			: CMIF_LoadColorCode;
	slotsTo				: CM_SlotControllerArray;
	slotsFrom			: CM_SlotControllerArray;
	operator			: CM_Operator;
	crane				: CM_Crane;
	voyageDischJob		: CM_VoyageJob;
	voyageLoadJob		: CM_VoyageJob;
	blockStack			: CM_BlockStack;
	locations			: CM_LCArray;
	dischargePort		: CM_Port;
	theSlot 			: CM_LocationsController;
	cargo,
	cargo1,
	cargo2, 
	cargo3 				: CM_TrackedItem;
	cta					: CM_CraneTransferArea;
	slot				: CM_SlotController;
	wle					: CM_WorkListEntry;
	trackedItem			: CM_TrackedItem;
	obj					: Object;
	
	strs 				: StringArray;
	tas					: StringArray;
	cargoArray			: ObjectArray;
		
	allObjectEditions	: CM_ObjectByOidEditionDict;	
	
	idx 				: Integer;
	index				: Integer;
	cargoId				: String;
	
begin

	operator := app.myRoot.allOperators["UTOP"];
	dischargePort := app.myRoot.allPorts["NZPOE"];
	
	// create the block stack
	self.deleteTerminalArea(BLOCKSTACK);
	blockStack := addBlockStack(BLOCKSTACK, 100, null);
	
	// create the crane transfer area
	self.deleteTerminalArea("UTC1T9");
	cta := self.addCraneTransferArea("UTC1T9");
	self.assertNotNull(cta);
	
	// create yard allocation;
	self.deleteYA(YARDALLOCATION);
	create locations transient;
	locations.add(blockStack.allLocationsControllers.first.CM_YardController);
	self.addYA1(YARDALLOCATION, YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, locations);
	
	// create Voyage
	deleteVoyage(VOYAGENAME);
	deleteVessel(VESSELNAME);
	vessel := addVesselCellular(VESSELNAME, operator);
	voyage := addVoyageWithContainerStructur(VOYAGENAME, VESSELNAME, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	/*
	// add the container(s)
	create strs transient;
	deleteContainer(CONTAINER1ID);
	strs.clear;
	strs.add("010682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo1 := self.addContainerAtLocnDisch(CONTAINER1ID, "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, dischargePort, voyage);
	deleteContainer(CONTAINER2ID);	
	strs.clear;
	strs.add("010684");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo2 := self.addContainerAtLocnDisch(CONTAINER2ID, "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, dischargePort, voyage);
	deleteContainer(CONTAINER3ID);
	strs.clear;
	strs.add("010686");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo3 := self.addContainerAtLocnDisch(CONTAINER3ID, "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, dischargePort, voyage);
	strs.clear;
	*/
	
	create cargoArray transient;
	create strs transient;
	index := 8;
	while index &gt; 0 do
		cargoId := ContainerBaseId &amp; index.String.padLeadingZeros(2);
		self.deleteContainer(cargoId);
		strs.clear();
		if index = 8 then
			strs.add("010682");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 7 then
			strs.add("010684");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 6 then
			strs.add("010686");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 5 then
			strs.add("010688");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 4 then
			strs.add("030682");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 3 then
			strs.add("030684");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 2 then
			strs.add("030686");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 1 then
			strs.add("030688");
			voyage.findLocation(strs, false, theSlot, idx);
		endif;
		cargo := self.addContainerAtLocnDisch(cargoId, "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, dischargePort, voyage);
		cargoArray.add(cargo);
		index := index - 1;
	endwhile;
		
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	self.deleteMachine(CRANENAME);
	crane := self.addCrane(CRANENAME, null, tas, null).CM_Crane;
	self.assertNotNull(crane);
		
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VOYAGENAME, "01", DeckOnDeck, 1, 1, 4, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	self.getJobSlotControllers(VOYAGENAME, "03", DeckOnDeck, 1, 1, 4, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	voyageDischJob := self.addVoyageJob(voyage, crane.id, slotsFrom, true);
	assertTrue(voyageDischJob &lt;&gt; null);
	
	// colour code the load slots
	create slotsTo transient;
	self.getJobSlotControllers(VOYAGENAME, "01", DeckOnDeck, 3, 1, 4, slotsTo);
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	self.getJobSlotControllers(VOYAGENAME, "03", DeckOnDeck, 3, 1, 4, slotsTo);
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	voyageLoadJob := self.addVoyageJob(voyage, crane.id, slotsTo, false);
	assertTrue(voyageLoadJob &lt;&gt; null);
	
	// link the slots
	create allObjectEditions transient;
	foreach slot in slotsFrom do
		allObjectEditions.add(slot);
	endforeach;
	foreach slot in slotsTo do
		allObjectEditions.add(slot);
	endforeach;
	app.myTrxUA.trxUpdateSlotReqLinkSOBDLR2(slotsFrom, slotsTo, allObjectEditions, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	// update the load jobs release ti's
	beginTransaction;
	voyageLoadJob.updateReleaseTI(cargo1);
	voyageLoadJob.updateReleaseTI(cargo2);
	voyageLoadJob.updateReleaseTI(cargo3);
	commitTransaction;
	*/
	
	beginTransaction;
	foreach obj in cargoArray do
		voyageLoadJob.updateReleaseTI(obj.CM_TrackedItem);
	endforeach;
	commitTransaction;
	
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);	
	
	/*
	// plan the items back to the ship
	self.planItemBackToShip(cargo1, slotsTo[3]);
	self.planItemBackToShip(cargo2, slotsTo[2]);
	self.planItemBackToShip(cargo3, slotsTo[1]);
		
	// use the hand held to move item(s) to the ground
	self.moveToGroundUsingHH(cargo1, voyageDischJob, crane);
	self.moveToGroundUsingHH(cargo2, voyageDischJob, crane);
	self.moveToGroundUsingHH(cargo3, voyageDischJob, crane);
	
	// check to see discharge status is completed
	foreach wle in voyageDischJob.workListEntries do
		self.assertEqual(WLE_COMPLETED, wle.status);
	endforeach;
	
	self.assertTrueMsg(cargo1.myPrimaryActualLocation.isKindOf(CM_CraneLaneController) and 
		cargo1.myPrimaryPlannedLocation.isKindOf(CM_SlotController), cargo1.id &amp; " current location isn't a Crane Area (" &amp; 
		cargo1.myPrimaryActualLocation.String &amp; ") and it isn't planned back to a slot (" &amp; cargo1.myPrimaryPlannedLocation.String &amp; ")");
	self.assertTrueMsg(cargo2.myPrimaryActualLocation.isKindOf(CM_CraneLaneController) and 
		cargo2.myPrimaryPlannedLocation.isKindOf(CM_SlotController), cargo2.id &amp; " current location isn't a Crane Area (" &amp; 
		cargo2.myPrimaryActualLocation.String &amp; ") and it isn't planned back to a slot (" &amp; cargo2.myPrimaryPlannedLocation.String &amp; ")");
	self.assertTrueMsg(cargo3.myPrimaryActualLocation.isKindOf(CM_CraneLaneController) and 
		cargo3.myPrimaryPlannedLocation.isKindOf(CM_SlotController), cargo3.id &amp; " current location isn't a Crane Area (" &amp; 
		cargo3.myPrimaryActualLocation.String &amp; ") and it isn't planned back to a slot (" &amp; cargo3.myPrimaryPlannedLocation.String &amp; ")");
	*/
	
epilog

	delete tmpLoadCC;
	delete slotsTo;
	delete slotsFrom;
	delete locations;
	delete strs;
	delete tas;
	delete allObjectEditions;
	delete cargoArray;
	
	if process.isInTransactionState then
		abortTransaction;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uPAR29093" id="eb613144-0362-41e4-98cc-f640a0f1231a">
        <updating/>
        <source>uPAR29093() updating;
/*
Purpose:			
Date		Who		Reason
14 February 2012	NAVAB1	Initial creation
*/

vars
	voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	q : CM_VoyageQueue;
	cq : CM_VoyageCraneQueue;
begin
	voyage := self.createVesselVoyage("UTBISHOP", "UTBISH9", null);

	self.createCargoOnSite();
	
	voyageJob := self.createVoyageLoadJobsVA(); // and Colour Coding
	self.planLoadItems("UTBISH9", "CRN1");
	self.loadAllJobsToOps(self.getVoyage("UTBISH9"), true);
	self.moveCargoForVoyageJob(voyageJob, QUEUE_MODE);

	q := self.getQueue("UTBISH9").CM_VoyageQueue;
	cq := q.allSubQueuesById["UTBISH9 CRN1"].CM_VoyageCraneQueue;
	
	beginTransaction;
	cq.setPropertyValue("loadMachinesMode", CM_VoyageCraneQueue.UseShipLanderApp);
	commitTransaction;

	self.addMachineAndQCargo(voyageJob);
epilog
	self.opts.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="uPar28685" id="40752cd3-56b0-4abc-a3c6-622f1eddcd21">
        <source>uPar28685();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
17 November 2011	cnwmh5	Initial creation

*/
constants

	StraddleStackId					: String = "UTMHSS1";
	ContainerId						: String = "UTMH10000";
	VoyageId						: String = "UTMHVOY7";
	VesselId						: String = "UTMHVES7";
	CraneTransferAreaId				: String = "UTMHCTA7";
	CraneId							: String = "UTC7";
	StraddleId						: String = "UTS7";
	IMVId							: String = "UTI7";
	StraddleDeviceId				: String = "148";
	IMVDeviceId						: String = "149";
	
vars

	straddleStack					: CM_StraddleStack;
	container						: CM_Container;
	operator						: CM_Operator;
	location						: CM_LocationsController;
	vessel							: CM_Vessel;
	voyage							: CM_Voyage;
	tmpLoadCC						: CMIF_LoadColorCode;
	voyageLoadJob					: CM_VoyageJob;
	cta								: CM_CraneTransferArea;
	crane							: CM_Machine;
	straddle						: CM_Machine;
	imv								: CM_Machine;
	
	locations						: CM_LCArray;
	slotsTo							: CM_SlotControllerArray;
	
	tas								: StringArray;
	
	index							: Integer;
	containerFullId					: String;
	
begin

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNull(operator);

	// create the straddle stack
	self.deleteTerminalArea(StraddleStackId);
	straddleStack := self.addStraddleStack(StraddleStackId, 3, 5, 1);
	self.assertNotNull(straddleStack);
	
	// get all locations controllers for the stack
	create locations transient;
	straddleStack.allGridControllersByRowColumn.copy(locations);

	// fill the straddle stack with containers
	self.opts.purge;
	self.opts.addAssoc("ReadyToShip", true);
	self.opts.addAssoc("CENum", "2345");
	index := 15;
	while index &gt; 0 do
		containerFullId := ContainerId &amp; index.String.padLeadingZeros(2);
		self.deleteContainer(containerFullId);
		location := locations[1];
		container := self.addContainerAtLocation(containerFullId, operator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, locations[1]);
		self.updateTI(container);
		locations.remove(location);
		self.deleteStops(container);
		index := index - 1;
	endwhile;
	
	// create the voyage
	deleteVoyage(VoyageId);
	deleteVessel(VesselId);
	vessel := addVesselCellular(VesselId, operator);
	self.assertNotNull(vessel);
	voyage := addVoyageWithContainerStructur(VoyageId, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voyage);
	
	// create the crane transfer area
	self.deleteTerminalArea(CraneTransferAreaId);
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", NORMAL_LIFT);
	self.deleteMachine(CraneId);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	
	// colour code load slots
	create slotsTo transient;
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 1, 1, 15, slotsTo);
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageLoadJob := self.addVoyageJob(voyage, crane.id, slotsTo, false);
	assertTrue(voyageLoadJob &lt;&gt; null);
	
	// plan the containers to the voyage
	locations.clear();
	straddleStack.allGridControllersByRowColumn.copy(locations);
	
	beginTransaction;
	index := 15;
	while index &gt; 0 do
		containerFullId := ContainerId &amp; index.String.padLeadingZeros(2);
		container := self.getTrackedItem(containerFullId).CM_Container;
		voyageLoadJob.updateReleaseTI(container);
		index := index - 1;
	endwhile;
	commitTransaction;
	
	index := 15;
	while index &gt; 0 do
		self.planItemBackToShip(locations[index].allTrackedItems[1], slotsTo[index]);
		index := index - 1;
	endwhile;
	
	// load jobs to job ops
	self.loadAllJobsToOps(voyage, true);
	
	// create machines so can work job
	tas.clear();
	tas.add(StraddleStackId);
	tas.add(CraneTransferAreaId);
	self.deleteMachine(StraddleId);
	self.deleteRTDevice(StraddleDeviceId);
	straddle := self.addStraddle(StraddleId, StraddleDeviceId.Integer, tas, null);
	self.assertNotNull(straddle);
	
	self.deleteMachine(IMVId);
	self.deleteRTDevice(IMVDeviceId);
	imv := self.addIMV(IMVId, IMVDeviceId.Integer, tas, null);
	self.assertNotNull(imv);
	
	// add machine rules
	self.deleteMachineRule(straddleStack, cta);
	self.addMachineRule(straddleStack, cta, RTMoveMethod_17);
	self.deleteMachineRule(cta, straddleStack);
	self.addMachineRule(cta, straddleStack, RTMoveMethod_9);
	
	
epilog

	delete locations;
	delete slotsTo;
	delete tas;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uScanPlanV3Test" id="f40ec72e-35c5-4291-9a3c-bc76b3451262">
        <source>uScanPlanV3Test();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 January 2021	jlgndl1	Initial creation	TFS 50539 - Thi sguy sets up teh data to test the scan plan report options

*/

constants

	VoyageCode1 : String = "UT_TATVOY";
	BSID : String = "BSSCAN";

vars

	voyage : CM_Voyage;
	bs : CM_BlockStack;
	ti : CM_TrackedItem;
	herePort : CM_Port;
	aklPort : CM_Port;
	isoType : String;
	isoTypeObj : CM_ISOType;
	commStr : String;
	comGrpCode : String;
	theSlot : CM_LocationsController;
	idx : Integer;
	strs : StringArray;
	bay : CM_BayVoyage;
	tiArray : CM_TIArray;
	tmpLoadCC : CMIF_LoadColorCode;
	dischargeSlots : CM_SlotControllerArray;
	loadSlots : CM_SlotControllerArray;
	voyageDischargeJob : CM_VoyageJob;
	voyageLoadJob : CM_VoyageJob;
	sobSlotsFrom : CM_SlotControllerArray;
	sobSlotsTo : CM_SlotControllerArray;
	dlrSlotsFrom : CM_SlotControllerArray;
	dlrSlotsTo : CM_SlotControllerArray;
	voyageSobDischJob : CM_VoyageJob;
	voyageSobLoadJob : CM_VoyageJob;
	allObjectEditions : CM_ObjectByOidEditionDict;
	voyageDlrDischJob : CM_VoyageJob;
	voyageDlrLoadJob : CM_VoyageJob;
	slotDefn : CM_SlotDefn;
	iter : Iterator;

begin

	//if rerunning will need to run the TAT script first.

	voyage := self.getVoyage( VoyageCode1 );
	aklPort := app.myRoot.allPorts["NZAKL"];
	herePort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	isoType := "4200";
	isoTypeObj := app.myRoot.allISOTypes.getAtKey( isoType );
	commStr := "GENL";
	comGrpCode := "GEN";
	
	//Delete pre-existing data
	bs := self.getTerminal.allTerminalAreas[ BSID ].CM_BlockStack;
	if bs &lt;&gt; null then
		create tiArray transient;
		bs.myLocationsController.allTrackedItems.copy( tiArray );
		foreach ti in tiArray do
			self.deleteTrackedItem(ti, false);
		endforeach;
		delete tiArray;
	endif;
	self.deleteTerminalArea( BSID );
	
	bay := voyage.myCellularVoyageStructure.allBayVoyagesById["05"];
	if bay &lt;&gt; null then
		create tiArray transient;
		bay.getAllTrackedItems( REAL_MODE, tiArray );
		foreach ti in tiArray do
			self.deleteTrackedItem(ti, false);
		endforeach;
		delete tiArray;
	endif;
	
	//reset bay 05 &amp; 07 on voyage to handle 40ft conts	(TAT vessel is set as 20's only)
	iter := bay.allSlotsByOrdinal.createIterator;
	while iter.next( slotDefn ) do
		beginTransaction;
		slotDefn.setAsFortyFoot(true);
		commitTransaction;
	endwhile;
	delete iter;
	bay := voyage.myCellularVoyageStructure.allBayVoyagesById["07"];
	iter := bay.allSlotsByOrdinal.createIterator;
	while iter.next( slotDefn ) do
		beginTransaction;
		slotDefn.setAsFortyFoot(true);
		commitTransaction;
	endwhile;
	delete iter;
	
	//Now add all the cargo and set up the test data
	
	create strs transient;
	create dischargeSlots transient;
	create loadSlots transient;
	create sobSlotsFrom transient;
	create sobSlotsTo transient;
	create dlrSlotsFrom transient;
	create dlrSlotsTo transient;
	
	//All in Bay 05
	//create discharge cargo
	strs.clear;
	strs.add("050688");
	voyage.findLocation(strs, false, theSlot, idx);
	dischargeSlots.add( theSlot.CM_SlotController );
	ti := self.addContainerAtLocnDisch("DISC1" &amp; strs[1], isoType, commStr, TI_IMEX_STATUS_IMPORT, theSlot, herePort, voyage);
	strs.clear;	
	
	strs.clear;
	strs.add("050686");
	voyage.findLocation(strs, false, theSlot, idx);
	dischargeSlots.add( theSlot.CM_SlotController );
	ti := self.addContainerAtLocnDisch("DISC1" &amp; strs[1], isoType, commStr, TI_IMEX_STATUS_IMPORT, theSlot, herePort, voyage);
	strs.clear;	
	
	strs.clear;
	strs.add("050684");
	voyage.findLocation(strs, false, theSlot, idx);
	dischargeSlots.add( theSlot.CM_SlotController );
	ti := self.addContainerAtLocnDisch("DISC1" &amp; strs[1], isoType, commStr, TI_IMEX_STATUS_IMPORT, theSlot, herePort, voyage);
	strs.clear;	
	
	strs.clear;
	strs.add("050682");
	voyage.findLocation(strs, false, theSlot, idx);
	dischargeSlots.add( theSlot.CM_SlotController );
	ti := self.addContainerAtLocnDisch("DISC1" &amp; strs[1], isoType, commStr, TI_IMEX_STATUS_IMPORT, theSlot, herePort, voyage);
	strs.clear;	
	
	strs.clear;
	strs.add("050288");
	voyage.findLocation(strs, false, theSlot, idx);
	dischargeSlots.add( theSlot.CM_SlotController );
	ti := self.addContainerAtLocnDisch("DISC2" &amp; strs[1], isoType, commStr, TI_IMEX_STATUS_IMPORT, theSlot, herePort, voyage);
	strs.clear;	
	
	strs.clear;
	strs.add("050286");
	voyage.findLocation(strs, false, theSlot, idx);
	dischargeSlots.add( theSlot.CM_SlotController );
	ti := self.addContainerAtLocnDisch("DISC2" &amp; strs[1], isoType, commStr, TI_IMEX_STATUS_IMPORT, theSlot, herePort, voyage);
	strs.clear;	
	
	strs.clear;
	strs.add("050284");
	voyage.findLocation(strs, false, theSlot, idx);
	dischargeSlots.add( theSlot.CM_SlotController );
	ti := self.addContainerAtLocnDisch("DISC2" &amp; strs[1], isoType, commStr, TI_IMEX_STATUS_IMPORT, theSlot, herePort, voyage);
	strs.clear;	
	
	strs.clear;
	strs.add("050282");
	voyage.findLocation(strs, false, theSlot, idx);
	dischargeSlots.add( theSlot.CM_SlotController );
	ti := self.addContainerAtLocnDisch("DISC2" &amp; strs[1], isoType, commStr, TI_IMEX_STATUS_IMPORT, theSlot, herePort, voyage);
		
	
	//create the Load cargo on-site
	
	bs := self.addBlockStack( BSID, 100, null );
	
	ti := self.addContainerAtLocnDisch("LOAD1050488", isoType, commStr, TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aklPort, voyage);
	strs.clear;
	strs.add(ti.id[6:end]);
	voyage.findLocation(strs, false, theSlot, idx);
	loadSlots.add( theSlot.CM_SlotController );
	
	ti := self.addContainerAtLocnDisch("LOAD1050486", isoType, commStr, TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aklPort, voyage);
	strs.clear;
	strs.add(ti.id[6:end]);
	voyage.findLocation(strs, false, theSlot, idx);
	loadSlots.add( theSlot.CM_SlotController );
	
	ti := self.addContainerAtLocnDisch("LOAD1050484", isoType, commStr, TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aklPort, voyage);
	strs.clear;
	strs.add(ti.id[6:end]);
	voyage.findLocation(strs, false, theSlot, idx);
	loadSlots.add( theSlot.CM_SlotController );
	
	ti := self.addContainerAtLocnDisch("LOAD1050482", isoType, commStr, TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aklPort, voyage);
	strs.clear;
	strs.add(ti.id[6:end]);
	voyage.findLocation(strs, false, theSlot, idx);
	loadSlots.add( theSlot.CM_SlotController );

	ti := self.addContainerAtLocnDisch("LOAD2050288", isoType, commStr, TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aklPort, voyage);
	strs.clear;
	strs.add(ti.id[6:end]);
	voyage.findLocation(strs, false, theSlot, idx);
	loadSlots.add( theSlot.CM_SlotController );
	
	ti := self.addContainerAtLocnDisch("LOAD2050286", isoType, commStr, TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aklPort, voyage);
	strs.clear;
	strs.add(ti.id[6:end]);
	voyage.findLocation(strs, false, theSlot, idx);
	loadSlots.add( theSlot.CM_SlotController );
	
	ti := self.addContainerAtLocnDisch("LOAD2050284", isoType, commStr, TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aklPort, voyage);
	strs.clear;
	strs.add(ti.id[6:end]);
	voyage.findLocation(strs, false, theSlot, idx);
	loadSlots.add( theSlot.CM_SlotController );
	
	ti := self.addContainerAtLocnDisch("LOAD2050282", isoType, commStr, TI_IMEX_STATUS_EXPORT, bs.myLocationsController, aklPort, voyage);
	strs.clear;
	strs.add(ti.id[6:end]);
	voyage.findLocation(strs, false, theSlot, idx);
	loadSlots.add( theSlot.CM_SlotController );
	
	//create Remain On Board Cargo
	strs.clear;
	strs.add("050388");
	voyage.findLocation(strs, false, theSlot, idx);
	ti := self.addContainerAtLocnDisch("ROBD1" &amp; strs[1], isoType, commStr, TI_IMEX_STATUS_REMAINONBOARD, theSlot, aklPort, voyage);
	dlrSlotsFrom.add(theSlot.CM_SlotController);
	strs.clear;
	strs.add("050304");  // DLR target 050304
	voyage.findLocation(strs, false, theSlot, idx);
	dlrSlotsTo.add(theSlot.CM_SlotController);	
	
	strs.clear;
	strs.add("050386");
	voyage.findLocation(strs, false, theSlot, idx);
	ti := self.addContainerAtLocnDisch("ROBS1" &amp; strs[1], isoType, commStr, TI_IMEX_STATUS_REMAINONBOARD, theSlot, aklPort, voyage);
	sobSlotsFrom.add(theSlot.CM_SlotController);
	strs.clear;
	strs.add("050302");  // SOB target 050302
	voyage.findLocation(strs, false, theSlot, idx);
	sobSlotsTo.add(theSlot.CM_SlotController);	
	
	strs.clear;
	strs.add("050384"); 
	voyage.findLocation(strs, false, theSlot, idx);
	ti := self.addContainerAtLocnDisch("ROBO2" &amp; strs[1], isoType, commStr, TI_IMEX_STATUS_REMAINONBOARD, theSlot, aklPort, voyage);
	
	
	strs.clear;	//this one stays where it is
	strs.add("050382");
	voyage.findLocation(strs, false, theSlot, idx);
	ti := self.addContainerAtLocnDisch("ROBO2" &amp; strs[1], isoType, commStr, TI_IMEX_STATUS_REMAINONBOARD, theSlot, aklPort, voyage);
	
	
	//create Discharge colour coding
	self.markSlotsAsDischargeCC( dischargeSlots, tmpLoadCC, CM_SlotRequest.Attribute_ColourCode );
	voyageDischargeJob := self.addVoyageJob(voyage, "CRN1", dischargeSlots, true);
	delete tmpLoadCC;
	
	
	//create Load colour coding
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType := true;
	tmpLoadCC.myDischargePort := aklPort;
	tmpLoadCC.myCommodityGroup := app.myRoot.allCommodityGroups[comGrpCode];
	tmpLoadCC.myISOType := isoTypeObj;
	if isoTypeObj.is40ftLong then
		tmpLoadCC.isForty := true;
	endif;
	self.markSlotsAsLoadJob( loadSlots, tmpLoadCC );
	self.markSlotsAsLoadCC( loadSlots, tmpLoadCC, CM_SlotRequest.Attribute_Forty );
	voyageLoadJob := self.addVoyageJob(voyage, "CRN1", loadSlots, false);
	
	//Plan the load containers
	foreach theSlot in loadSlots do
		ti := null;
		ti := voyage.allOnsiteTIsByIdCargoType.getAtKey( "LOAD105"&amp; theSlot.CM_SlotController.ident, TI_CargoType_Container );
		if ti = null then
			ti := voyage.allOnsiteTIsByIdCargoType.getAtKey( "LOAD205"&amp; theSlot.CM_SlotController.ident, TI_CargoType_Container );
		endif;
		beginTransaction;
		voyageLoadJob.updateReleaseTI( ti );
		commitTransaction;
		self.setCargoReadyToShip( ti );
		self.deleteStops( ti );
		self.planItemBackToShip( ti, theSlot.CM_SlotController);
	endforeach;
	
	//SOB jobs
	
	// colour code the SOB discharge slots
	self.markSlotsAsDischargeCC(sobSlotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsDischargeCC(sobSlotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	voyageSobDischJob := self.addVoyageJob(voyage, "CRN1", sobSlotsFrom, true);
	assertTrue(voyageSobDischJob &lt;&gt; null);
	
	// colour code the SOB load slots
	self.markSlotsAsLoadJob(sobSlotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(sobSlotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsLoadCC(sobSlotsTo, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	voyageSobLoadJob := self.addVoyageJob(voyage, "CRN1", sobSlotsTo, false);
	assertTrue(voyageSobLoadJob &lt;&gt; null);
	
	// link the SOB slots
	create allObjectEditions transient;
	foreach theSlot in sobSlotsFrom do
		allObjectEditions.add(theSlot);
	endforeach;
	foreach theSlot in sobSlotsTo do
		allObjectEditions.add(theSlot);
	endforeach;
	app.myTrxUA.trxUpdateSlotReqLinkSOBDLR2(sobSlotsFrom, sobSlotsTo, allObjectEditions, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete allObjectEditions;
	
	//Plan the SOB load side
	foreach theSlot in sobSlotsTo do
		ti := null;
		if theSlot.ident = "0302" then
			ti := voyage.allOnshipTIsByIdCargoType.getAtKey( "ROBS1050386", TI_CargoType_Container );
		else
			continue;
		endif;
		beginTransaction;
		voyageLoadJob.updateReleaseTI( ti );
		commitTransaction;
		self.setCargoReadyToShip( ti );
		self.deleteStops( ti );
		self.planItemBackToShip( ti, theSlot.CM_SlotController);
		self.editIMEXStatus(ti, TI_IMEX_STATUS_REMAINONBOARD,true);//The stuffing around above has changed this one from ROB, need to be ROB for the testing
	endforeach;
	
	//DLR Jobs
	
	// colour code the discharge DLR slots
	self.markSlotsAsDischargeCC(dlrSlotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsDischargeCC(dlrSlotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	voyageDlrDischJob := self.addVoyageJob(voyage, "CRN1", dlrSlotsFrom, true);
	assertTrue(voyageDlrDischJob &lt;&gt; null);
	
	// colour code the load DLR slots
	self.markSlotsAsLoadJob(dlrSlotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(dlrSlotsTo, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	voyageDlrLoadJob := self.addVoyageJob(voyage, "CRN1", dlrSlotsTo, false);
	assertTrue(voyageDlrLoadJob &lt;&gt; null);
	
	// link the DLR slots
	create allObjectEditions transient;
	foreach theSlot in dlrSlotsFrom do
		allObjectEditions.add(theSlot);
	endforeach;
	foreach theSlot in dlrSlotsTo do
		allObjectEditions.add(theSlot);
	endforeach;
	app.myTrxUA.trxUpdateSlotReqLinkSOBDLR2(dlrSlotsFrom, dlrSlotsTo, allObjectEditions, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete allObjectEditions;
	
	//Plan the DLR load side
	foreach theSlot in dlrSlotsTo do
		ti := null;
		if theSlot.ident = "0304" then
			ti := voyage.allOnshipTIsByIdCargoType.getAtKey( "ROBD1050388", TI_CargoType_Container );
		else
			continue;
		endif;
		beginTransaction;
		voyageLoadJob.updateReleaseTI( ti );
		commitTransaction;
		self.setCargoReadyToShip( ti );
		self.deleteStops( ti );
		self.planItemBackToShip( ti, theSlot.CM_SlotController);
		self.editIMEXStatus(ti, TI_IMEX_STATUS_REMAINONBOARD,true);	//The stuffing around above has changed this one from ROB, need to be ROB for the testing
	endforeach;
	
epilog

	delete strs;
	delete tiArray;
	delete dischargeSlots;
	delete tmpLoadCC;
	delete loadSlots;
	delete sobSlotsFrom;
	delete sobSlotsTo;
	delete dlrSlotsFrom;
	delete dlrSlotsTo;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="xCreateLOLOSOBContainers" id="d8455d7b-fac0-4850-9c1a-8ddcf682dfda">
        <source>xCreateLOLOSOBContainers(_voyage : CM_Voyage);

/*

Purpose:		Create the 20 and 40 foot containers for unit tests tLOLOSOBMoves	

Date			Who		Reason
04/03/2013		cnwmh5	Initial creation

*/
constants

	ContainerId					: String = "UTMDHDF00";
vars

	theSlot 					: CM_LocationsController;
	cargo 						: CM_TrackedItem;
	port 						: CM_Port;
	voyageDeck 					: CM_DeckVoyage;
	
	strs 						: StringArray;
	lcs 						: CM_LCArray;
	
	idx 						: Integer;
	locationStr					: String;
	cargoCount					: Integer;
	
begin

	// initialisations
	port := app.myRoot.allPorts[_voyage.myTerminal.getConfig(PortDestCode).String];
	cargoCount := 1;
	
	
	/*******************************************************************************
		For screen
	********************************************************************************/
	
	// 20 General
	create strs transient;
	strs.add("010688");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010686");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010684");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010488");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010486");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010484");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010288");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010286");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("010284");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U20G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
			
	
	// 40 General
	strs.clear();
	strs.add("021088");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U40G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("020888");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U40G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("021086");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U40G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("020886");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U40G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	strs.clear();
	strs.add("020884");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch(ContainerId &amp; cargoCount.padLeadingWith("0", 2), "U40G", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, port, _voyage);
	self.assertNotNull(cargo);
	cargoCount := cargoCount + 1;
	
epilog
	
	delete strs;
	
end;</source>
