epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPaymentCode" id="79a06abd-1e6c-4daa-bd71-1170271bfae7">
        <source>getPaymentCode(_invoice: CM_Invoice): String;
/*

Purpose:			
	
	The payment code for Pelindo1 is 12 characters long e.g. 991890001234

	The first 2 digits are always 99 - this is used to show that the code was generated in JMT
	The next 2 digits are the year the invoice was created e.g. 18
	The next digit is always 9 - this is used to show that the code was generated in JMT
	The last 7 digits are a  zero padded sequence number that resets at the beginning of each year 

	
Parameters:			

Return Value:		

Date			Who		Reason
13 June 2018	jlgndl1	Initial creation	TFS 39197
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
*/
vars

	ts   : TimeStamp;
	date : Date;
	paymentCode ,
	seqNum : String;
begin

	
	
	if _invoice = null then
		app.invLog(method.qualifiedName &amp; " No Invoice found.", LogTRACE.String);
		return null;
	endif;
	
	ts := _invoice.getRateDateFromStatus();
	if ts &lt;&gt; null and ts.date.isValid then
		date := ts.date;
	else
		date := _invoice.createdTime.Date;
	endif;
	
	if process.isInTransactionState then
		if self.myAutoPaymentIdGen = null then
			//first time up, create it.
			self.createMyAutoPaymentIdGen();
			if self.myAutoPaymentIdGen = null then
				return null;
			endif;
		endif;
		seqNum := self.myAutoPaymentIdGen.getNextIdForYear( date );
	else
		beginTransaction;
		if self.myAutoPaymentIdGen = null then
			//first time up, create it.
			self.createMyAutoPaymentIdGen();
			if self.myAutoPaymentIdGen = null then
				return null;
			endif;
		endif;
		seqNum := self.myAutoPaymentIdGen.getNextIdForYear( date );
		commitTransaction;
	endif; 
	
	paymentCode := "99"; 
	paymentCode := paymentCode &amp; date.format("yy");
	paymentCode := paymentCode &amp; "9";
	paymentCode := paymentCode &amp; seqNum;
	
	return paymentCode;
	
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPelindoInvTaxStatusStr" id="19388112-7b4e-4a10-bb60-0631fbee8526">
        <source>getPelindoInvTaxStatusStr( _invoice : CM_Invoice ):String;
/*

Purpose:			
	
	The first three digits indicate the tax status of the customer.

	I.	010 - The customer is charged tax in the invoice
	II.	020 - The customer is not charged tax in the invoice it is collected by other means
	III.	030 - Tax is calculated and dislayed on the invoice but is not included in the invoice total. The tax is collected by other means.
	IV.	070 - The customer is not charged tax
	The tax code 070 is used in 2 cases;
	1. The Terminal is in a tax free zone. There is no tax charged.
	2. The debtor has been issued an SKTD letter that has been presented to Pelindo1.

	V.	080 - The customer is not charged tax because the tax is waived
	The tax code 080 is used in 2 cases;
	1. The invoice is for fresh water. There is no tax charged.
	2. The debtor has been issued with a BUT letter that has been presented to Pelindo1 AND the flag of the vessel is from one of 26 specified companies.

	VI. There is a list of more than 100 customers who sometimes get charged tax and the 010 code is used and sometimes don't get charged tax and
	the 030 code is used.
	For these customers if the invoice total is less than 10 million Rupiah the 010 code is used. If the total of the invoice is more than 10 million Rupiah
	the 030 code is used and the tax is calculated and shown on the invoice but not included in the invoice total to be paid.
	One company, PT Pertamina (Persero) always gets the 030 code.

	VII. The third digit of the above codes is changed from a 0 to a 1 if the invoice is a replacement. This only occurs if the invoice being
	replaced is not from the current month. 
	Example:
	First Tax Invoice: 			010.009-17.00000001
	Replacement Tax Invoice: 	011.009-17.00000001

Parameters:			

Return Value:		

Date		Who		Reason
22/03/2018	jlgndl1	Initial creation
05/11/2018	cnwma1	Bug 41755: PEL1 - Invoice surcharges and Exemptions - External Tax Number
12/11/2018	jlgma1	Bug 41948: PEL1 - Fresh Water Invoice - Tax Number
23/11/2018	jlgdap1	TFS 41949 PEL1 Tax Number and Stamps based on SKTD and BUT Certificates on a Voyage
08/12/2018	jlgdap1	TFS 42455 PEL1 Tax code on Water Invoice
06/03/2023	navmk20	Task 56140: EUP Inv Config - Surcharge Logging
23 Oct 2024	navlw1 	JIRA-33107: Invoice Logging Use Levels
*/

vars
	surChgExempt   : CM_InvoiceTypeSurchargeExempt;
	extTax         : CM_InvoiceTypeExternalTax;
	dr 		       : CM_Debtor;
	term		   : CM_Terminal;
	len 		   : Integer;
	otherInvoice   : CM_Invoice;
	effectiveDT    : TimeStamp;
	conversionRate : CM_CurrencyRate;
	returnStr 	   : String;
	voyageData	   : HMS_VoyageData;			// TFS 41949
begin

	returnStr := "";
	
	if _invoice &lt;&gt; null then
	
		//28 May 2019	NDL	TFS 44651
		if _invoice.myOriginalAddFeesInvoice &lt;&gt; null then
			returnStr := "010";
		endif;
		
		// V.1
		//epr TFS 44550 refactored moved to invoice
		if _invoice.isWOWaterInvoice() then                  //12.11.2018 cnwma1 Bug #41948
			returnStr := "080";
		endif;
		
		//if _invoice.myVoyage &lt;&gt; null then						// TFS 41949	// TFS 42455
		if returnStr = null and _invoice.myVoyage &lt;&gt; null then	// TFS 41949	// TFS 42455
			voyageData := _invoice.myVoyage.myHMSVoyageData;	// TFS 41949
			if voyageData &lt;&gt; null then							// TFS 41949
				if voyageData.isZeroRatedTax then 				// TFS 41949
					if voyageData.isZeroRatedTaxCargo then		// TFS 41949
						returnStr := "080";						// TFS 41949
					else										// TFS 41949
						if not _invoice.isCargoInvoice then	// TFS 41949
							returnStr := "070";					// TFS 41949
						endif;									// TFS 41949
					endif;										// TFS 41949
				endif;											// TFS 41949
			endif;												// TFS 41949
		endif;													// TFS 41949
		
		if returnStr = "" then
			dr := _invoice.debtor;
			term := _invoice.myTerminal;
			
			// IV.1 - 070
			if term &lt;&gt; null then
				returnStr := term.getConfig(AdditionalInfo2).String;
			endif;
			
			if returnStr= "" then
				if  dr &lt;&gt; null then
		
					// VI   - 030
					// IV.2 - 070
					// V.2  - 080
					if _invoice.invoiceType &lt;&gt; null then
						surChgExempt := _invoice.invoiceType.mySurchargeAndExemptions;
						if surChgExempt &lt;&gt; null then
						    // extTax  := surChgExempt.getInvTypeExtTaxForInvTotal( dr, _invoice.getTotalAmount );
							//01 Nov 2018	NDL	TFS 41684
							if surChgExempt.myCurrencyType &lt;&gt; null then
								effectiveDT := _invoice.getRateDateForCurrencyCode();
								conversionRate := surChgExempt.myCurrencyType.getRate( effectiveDT );
							else
								conversionRate := null;
							endif;
							app.invLog("Get Invoice Type External Tax For Invoice Total for Debtor/ get Total Amount Converted ", LogINFO.String);	// 6.3.2023 navmk20 TFS 56140
							extTax  := surChgExempt.getInvTypeExtTaxForInvTotal( dr, _invoice.getTotalAmountConverted( conversionRate, null ) );
							
							if extTax &lt;&gt; null then
							//	if _invoice.myReversedPendingInvoice &lt;&gt; null     // invoice has been returned    //05.11.2018 cnwma1  #Bug 41755
							//	or _invoice.myPostedPendingInvoice  &lt;&gt; null then // invoice has been returned    //05.11.2018 cnwma1  #Bug 41755
									returnStr :=  extTax.externalTaxCode;
							//	endif;                                                                           //05.11.2018 cnwma1  #Bug 41755
							endif;
						endif;
					endif;
					
					// I - 010
					if returnStr = "" then
						if not dr.isZeroRatedTax then
							returnStr := "010";
						endif;
					endif;
					
					// II - 020
					if returnStr = "" then
						if dr.isZeroRatedTax then
							returnStr := "020";
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	// If its not configured or something is missing return the default value.
	
	if returnStr = null then
		returnStr := "010";
	endif;
	
	
	// VII
	otherInvoice := _invoice.myReversedPendingInvoice;
	if otherInvoice = null then
		otherInvoice := _invoice.myPostedPendingInvoice;
	endif;
	if  otherInvoice  &lt;&gt; null then // invoice has been returned for a different month
		
		if otherInvoice.getMonthForInvoice() &lt;&gt; _invoice.getMonthForInvoice() then
			// replace last "0" with "1"
			len := returnStr.length;
			if len &gt; 1 then
				if returnStr[len:end] = "0" then
					len := len - 1;
					if len &gt; 1 then
						returnStr := returnStr[1: len] &amp; "1";
					endif;
				endif;
			endif;
		endif;
		
	endif;
	
	return returnStr;
	
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPelindoRecTaxStatusStr" id="d410708f-da41-4d1e-81f8-0f202a0a8cd8">
        <source>getPelindoRecTaxStatusStr( _cashReceipt : CM_CashReceipt ):String;
/*

Purpose:			

	b.	The first three digits indicate the tax status of the customer.
		i.	010 - The customer is charged tax in the invoice
		ii.	020 - The customer is not charged tax in the invoice it is collected by other means
		iii.030 - Tax is calculated and dislayed on the invoice but is not included in the invoice total. The tax is collected by other means.
		iv.	070 - The customer is not charged tax
		v.	080 - The customer is not charged tax because the tax is waived
	
	There is a list of more than 100 customers who sometimes get charged tax and the 010 code is used and sometimes don't get charged tax and the 030 code is used.
	For these customers if the invoice total is less than 10 million Rupiah the 010 code is used. If the total of the invoice is more than 10 million Rupiah
	the 030 code is used and the tax is calculated and shown on the invoice but not included in the invoice total to be paid.
	One company, PT Pertamina (Persero) always gets the 030 code.
Parameters:			

Return Value:		

Date			Who		Reason
22 March 2018	jlgndl1	Initial creation
06 March 2023	navmk20	Task 56140: EUP Inv Config - Surcharge Logging
23 Oct 2024		navlw1 	JIRA-33107: Invoice Logging Use Levels
*/

vars

	dr : CM_Debtor;
	surChgExempt : CM_InvoiceTypeSurchargeExempt;
	extTax : CM_InvoiceTypeExternalTax;
	term: CM_Terminal;
	returnStr : String;
	cp : CM_CashPayment;
	invType : CM_InvoiceDesc;
begin



	if _cashReceipt &lt;&gt; null 
	and  _cashReceipt.myDebtorTerminal &lt;&gt; null then
		dr := _cashReceipt.myDebtorTerminal.myDebtor;
		
		cp := _cashReceipt.allCashPayments.first;
		
		if cp &lt;&gt; null then
			invType := cp.myProformaDetail.myInvoiceLineType.invoiceType ;
			
			if invType &lt;&gt; null and dr &lt;&gt; null then
				surChgExempt := invType.mySurchargeAndExemptions;
				if surChgExempt &lt;&gt; null then
					app.invLog("Get Invoice Type External Tax For Invoice Total for Debtor/ _cashReceipt.cashValue", LogINFO.String);	// 6.3.2023 navmk20 TFS 56140
					extTax  := surChgExempt.getInvTypeExtTaxForInvTotal( dr, _cashReceipt.cashValue );
					if extTax &lt;&gt; null then
						return extTax.externalTaxCode;
					endif;
				endif;
			endif;
		endif;
		term :=_cashReceipt.myTerminal;
	endif;
	
	// If its not configured or something is missing return the default value.
	if term &lt;&gt; null then
		returnStr := term.getConfig(AdditionalInfo2).String;
	endif;
	
	if returnStr = null then
		returnStr := "010";
	endif;
	
	return returnStr;
	
epilog

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPelindoSapTermCode" id="866dc60f-58aa-4bdc-8982-6f3a7bdd6712">
        <source>getPelindoSapTermCode(_terminal : CM_Terminal ):String;
/*

Purpose:			
	Pelindo1's requirement has been refined and they want to use the same 3 digit code [AdditionalInfo1] for all the Estimations, Tax Number and External Invoice Numbers. 
	
	d.	The second three digits indicates the terminal that generated the invoice. There is a table of the codes that need to be used for each
		terminal or terminal satellite. This is different from the code used to identify the terminal in MASTER TERMINAL. This table is included
		in Appendix B. It is not only limited to one number per terminal there are different numbers used for some satellite areas and different
		functional areas within some terminals.
	
Parameters:			

Return Value:		

Date		Who		Reason
22 March 2018	jlgndl1	Initial creation	TFS 37559
22 Nov   2018   cnwma1  ChangeRequest 42156: PEL1 - External Invoice Number - Additional field 1
*/

vars
	term : CM_Terminal;
	returnStr : String;
begin

	if _terminal &lt;&gt; null then
		term := _terminal;
	endif;
	
	if term &lt;&gt; null then
		returnStr := term.getConfig(AdditionalInfo1).String;
	endif;
	
	return returnStr;
	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTaxNumber" id="2d1fca71-99f2-46b6-8313-2b1e0105abd5">
        <source>getTaxNumber(_invoice: CM_Invoice;_taxDT : TimeStamp): String;
/*

Purpose:			
	
	The code is 16 digits long and follows the pattern AAA.BBB-CC.DDDDDDDD
	Example: 010.001-18.00000480

	As a Master Terminal Invoice Administrator, I want to be able to produce invoices with a number in a specific format so that I can comply
	with tax regulations.
	a.	The final invoice is numbered according to a specific format. 
	The code is 16 digits long and follows the pattern AAA.BBB-CC.DDDDDDDD
	Example: 010.001-18.00000480

	b.	The first three digits indicate the tax status of the customer.
		I.	010 - The customer is charged tax in the invoice
		II.	020 - The customer is not charged tax in the invoice it is collected by other means
		III.	030 - Tax is calculated and dislayed on the invoice but is not included in the invoice total. The tax is collected by other means.
		IV.	070 - The customer is not charged tax
			The tax code 070 is used in 2 cases;
			1. The Terminal is in a tax free zone. There is no tax charged.
			2. The debtor has been issued an SKTD letter that has been presented to Pelindo1.

		V.	080 - The customer is not charged tax because the tax is waived
			The tax code 080 is used in 2 cases;
			1. The invoice is for fresh water. There is no tax charged.
			2. The debtor has been issued with a BUT letter that has been presented to Pelindo1 AND the flag of the vessel is from one of 26 specified companies.

		VI. There is a list of more than 100 customers who sometimes get charged tax and the 010 code is used and sometimes don't get charged tax and  the 030 code is used.
			For these customers if the invoice total is less than 10 million Rupiah the 010 code is used. If the total of the invoice is more than 10 million Rupiah
			the 030 code is used and the tax is calculated and shown on the invoice but not included in the invoice total to be paid.
			One company, PT Pertamina (Persero) always gets the 030 code.
	c.	The third digit of the above codes is changed from a 0 to a 1 if the invoice is a replacement. This only occurs if the invoice being
		replaced is not from the current month. 
		Example:
		First Tax Invoice: 		010.009-17.00000001
		Replacement Tax Invoice: 	011.009-17.00000001
	d.	The second three digits indicates the terminal that generated the invoice. There is a table of the codes that need to be used for each
		terminal or terminal satellite. This is different from the code used to identify the terminal in MASTER TERMINAL. This table is included
		in Appendix B. It is not only limited to one number per terminal there are different numbers used for some satellite areas and different
		functional areas within some terminals.
	e.	The next two digits indicates the year the invoice is created.
	f.	The last eight digits is a sequential padded eight-digit number that must be unique to the terminal. For example, the next invoice generated
		after the one in the example above in the same terminal will have 00000481 as the last eight digits.
	g.	There are four different 'stamps' that must be included on the invoice if the 070 or 080 codes are used;
		i.	For port service of SKTD (Certificate of Notice of VAT)
			Tax Invoice 070 or not collected
			Stamp on invoice: "ADDED VALUE ADDED TAX RELATED PP 69 NOVEMBER 2015"
		ii.	For port service FTZ (Free Trade Zone)
			Tax invoice 070 or not collected
			Stamp on invoice: "VALUE ADDED TAX RETURNS IN WITH PP NUMBER 10 YEAR 2012"

		iii.For port services Tax Treaty
			Tax Invoice 080 or exempted
			Stamp on invoice: "VALUE ADDED TAX RETURNS UNDER THE PROVISION OF PP NUMBER 74 YEAR 2015"

		iv.	For port service and various water business
			Tax Invoice 080 or collected by yourself and collected tax collector
			Stamp on invoice: "VALUE ADDED TAX RETURNS IN WITH PP NUMBER 40 YEAR 2015"
			An example of an invoice with one of these stamps is included in Appendix A.

	The code is 16 digits long and follows the pattern AAA.BBB-CC.DDDDDDDD
	Example: 010.001-18.00000480
Parameters:			

Return Value:		

Date			Who		Reason
13 June 2018	jlgndl1	Initial creation	TFS 39197
01 Jan  2019    cnwma1	Bug 42754: PEL1 - Sequence and Format Tax Number for 2019
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
*/

constants
	Sep1 : String = ".";
	Sep2 : String = "-";	//29 Oct 2018	NDL	TFS 41617
	Sep3 : String = ".";
vars
	term 		   : CM_Terminal;
	ts 			   : TimeStamp;
	date 		   : Date;
	taxStatusValue : String;
	sapTermCode ,
	yearValue ,
	seqValue ,
	returnValue : String;
	autTaxNumberGen : CM_AutoTaxNumberGen;

begin

	if _invoice = null then
		return null;
	endif;
	term := _invoice.myTerminal;
	
	// AAA
	taxStatusValue := self.getPelindoInvTaxStatusStr( _invoice );
	
	// BBB
	sapTermCode:= self.getPelindoSapTermCode( term );
	
	if sapTermCode = null  then
		app.invLog(method.qualifiedName &amp; " Terminal 'Additional Info 1', needs to set up.", LogINFO.String);
		return null;
	endif;
	
	// CC
	/*//01.01.2019 cnwma1 Bug #42754
	ts := _invoice.getRateDateFromStatus();
	if ts &lt;&gt; null and ts.date.isValid then
		date := ts.date;
	else
		if _invoice.postedDT.isValid then
			date := _invoice.postedDT.Date;
		else
			if _invoice.toDT.isValid then
				date := _invoice.toDT.Date;
			else
				if _invoice.fromDT.isValid then
					date := _invoice.fromDT.Date;
				else
					date := _invoice.createdTime.Date;
				endif;
			endif;
		endif;
	endif;
	*/
	//01.01.2019 cnwma1 Bug #42754
	if _taxDT &lt;&gt; null and _taxDT.isValid then  
		date := _taxDT.Date;
	else
		date := app.actualTimeServer.Date;
	endif;
	
	yearValue := date.format("yy");
	
	// DDDDDDDD
	//Old way was system wide.
	/*	
	if process.isInTransactionState then
		if self.myAutoTaxNumberGen = null then
			self.createMyAutoTaxNumberGen();
		endif;
		seqValue := self.myAutoTaxNumberGen.getNextIdForYear( date );
	else
		beginTransaction;
		if self.myAutoTaxNumberGen = null then
			self.createMyAutoTaxNumberGen();
		endif;
		seqValue := self.myAutoTaxNumberGen.getNextIdForYear( date );
		commitTransaction;
	endif; 
	*/
	
	//18 Dec 2018	NDL	TFS 42614 - Now need to generate by terminal, NOT by system
	autTaxNumberGen := term.getMyAutoIdGenerator( CM_AutoTaxNumberGen ).CM_AutoTaxNumberGen;
	if autTaxNumberGen = null then
		//create new one if there isn't a terminal specific one.
		autTaxNumberGen := self.convertTaxGenToByTerminal( term, date );
	endif;
	if process.isInTransactionState then
		seqValue := autTaxNumberGen.getNextIdForYear( date );
	else
		beginTransaction;
		seqValue := autTaxNumberGen.getNextIdForYear( date );
		commitTransaction;
	endif; 
	
	returnValue := taxStatusValue &amp; Sep1 &amp; sapTermCode &amp; Sep2 &amp; yearValue &amp; Sep3 &amp; seqValue;

epilog

	return returnValue;

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_taxDT" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isInvoiceForWOWater" id="41cc0017-05a5-4bec-ae3b-026ca768c1bd">
        <source>isInvoiceForWOWater(_invoice: CM_Invoice):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2018	jlgma1	Bug 41948: PEL1 - Fresh Water Invoice - Tax Number
10 Dec      2018    cnwma1	Bug 42455: PEL1 - Tax code on Water Invoice
*/


vars

begin
