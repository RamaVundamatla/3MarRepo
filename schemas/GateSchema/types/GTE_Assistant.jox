    <JadeMethod name="cmbVoyageLostFocus" id="953796a0-9991-4269-85e8-f03fc88c8565">
        <source>cmbVoyageLostFocus(pVoyage : CM_Voyage; pTblMain, pTblExtra : CM_EntryTable io);
// ---------------------------------------------------------------------------
// Created:     02 May 2001 by cnwrs2
//
// Purpose:     Sets the companyCode from the voyage
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coyCode	: String;
	
begin

	if pVoyage = null then
		return;
	endif;
	
	if pVoyage.myDischargeCompany &lt;&gt; null then
		self.mainExtraSetValue(pTblMain, pTblExtra, ETRow_CompanyCode, pVoyage.myDischargeCompany.code);
	endif;

end;</source>
        <Parameter name="pVoyage" type="CM_Voyage"/>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="io"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDischarge" id="a2a7a5ce-6130-43aa-b2f0-c3d31a76f62f">
        <updating/>
        <source>comboBoxDischarge(pCmb: ComboBox input; pVoyage: CM_Voyage; pPort: CM_Port) updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pCmb, pVoyage, pPort);
	
	if pCmb.isKindOf(GTE_ComboBoxWithCurrentVoyage) then
		if pVoyage = null then
			pCmb.GTE_ComboBoxWithCurrentVoyage.currentVoyageCode := null;
		else
			pCmb.GTE_ComboBoxWithCurrentVoyage.currentVoyageCode := pVoyage.code.trimRight;
		endif;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pVoyage" type="CM_Voyage"/>
        <Parameter name="pPort" type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="doAddEditBookRequest" id="467e48e7-7d09-42b1-8023-92eb9094f562">
        <source>doAddEditBookRequest(_obj : Object);
/* ---------------------------------------------------------------------------
Created:	08 September 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	form : GTE_BookingRequestForm;

begin
	form := app.loadForm(GTE_BookingRequestForm,
							self.class,
							false,
							false,
							false,
							self.myTerminal, null).GTE_BookingRequestForm;
							
	if form = null then
		return;
	endif;

	if _obj = null then		//is a new booking			//-cnwml2 PAR20173 SFW CCMS 1091
		form.setMyTerminal(self.myTerminal);
		form.setMyBookingRefReq(_obj.CM_BookingRef);
		
		if _obj.CM_BookingRef = null then									//+cnwml2 PAR20164 SFW CCMS 1091
			form.chkNoEmptiesOut.value := false;								//+cnwml2 PAR20164 SFW CCMS 1091
		endif;																//+cnwml2 PAR20164 SFW CCMS 1091
	elseif _obj.isKindOf(CM_BookingRef) then
		form.setMyTerminal(self.myTerminal);
		form.setMyBookingRefReq(_obj.CM_BookingRef);
		
		if _obj.CM_BookingRef = null then									//+cnwml2 PAR20164 SFW CCMS 1091
			form.chkNoEmptiesOut.value := true;								//+cnwml2 PAR20164 SFW CCMS 1091
		endif;																//+cnwml2 PAR20164 SFW CCMS 1091
	elseif _obj.isKindOf(CM_BookingRefItem) then
		form.setMyTerminal(self.myTerminal);
		form.setMyBookingRefReq(_obj.CM_BookingRefItem.myBookingReference);
		
		if _obj.CM_BookingRefItem.myBookingReference = null then
			form.chkNoEmptiesOut.value := true;
		endif;
	endif;

	form.show;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doFlexiGateFormPINFocus" id="8538c12d-f3df-4f36-b539-ed0a888f27c2">
        <source>doFlexiGateFormPINFocus(_parentForm: CM_BaseForm);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2009	cnwdap1	Initial creation

*/

vars

begin
