<CollClass name="CM_FutureMoveArray" id="fdd16ed8-2238-4fd9-acc2-4c4da4ed07de">
    <memberType name="CM_FutureMove"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <JadeMethod name="auditIdDisplay" id="1acf99d4-c3a9-45cc-ad60-1138836292e1">
        <source>auditIdDisplay() : String;
// ---------------------------------------------------------------------------
// Created:     04 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	fm		: CM_FutureMove;
	rtnStr	: String;
begin

	foreach fm in self do
		if rtnStr = null then
			rtnStr := fm.auditId();
		else
			rtnStr := rtnStr &amp; '::' &amp; fm.auditId();
		endif;
	endforeach;

	return rtnStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="containsLC" id="7ad072a3-e9e5-4e6c-8c51-47f3b07427bf">
        <source>containsLC(_lc : CM_LocationsController) : Boolean;

vars
	fm		: CM_FutureMove;
begin
	foreach fm in self do
		if fm.getPrimaryLocation = _lc then
			return true;
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="containsTI" id="531e7f01-f5f8-4111-93ed-7ff591c2b973">
        <source>containsTI(_ti : CM_TrackedItem) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2010	cnwjk3	ccms 1018

*/

vars
	fm		: CM_FutureMove;
begin
	foreach fm in self do
		// All because CM_FutureMove doesn't contain myTrackedItem...
		if fm.isKindOf(CM_FutureMovePlanned) then
			if fm.CM_FutureMovePlanned.myTrackedItem = _ti then
				return true;
			endif;
		elseif fm.isKindOf(CM_FutureMoveQueued) then
			if fm.CM_FutureMoveQueued.myTrackedItem = _ti then
				return true;
			endif;
		endif;	
	endforeach;
	return false;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getFirstValidObject" id="f8e14539-acb3-442c-a640-170991f2b574">
        <source>getFirstValidObject():CM_FutureMove;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2014	cnwndl1	Initial creation	Par 35015

*/

vars

	lEdition : Integer;
	fm : CM_FutureMove;
	invalidObj : Boolean;
	iter : Iterator;

begin

	if self.isEmpty then
		return null;
	endif;

	on Exception do app.handleDeletedObject( exception, fm, invalidObj);
	iter := self.createIterator;
	while iter.next( fm ) do
		invalidObj := false;
		lEdition := fm.edition;
		if invalidObj then
			continue;
		endif;
		return fm;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_FutureMove"/>
    </JadeMethod>
    <JadeMethod name="getIndexOfLC" id="b78de03e-2f52-4a6e-a4c7-a7f9bb57a29d">
        <source>getIndexOfLC(_lc : CM_LocationsController) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2019	jlgns1	Initial creation
7/08/2019  	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
*/

vars
	fm	  : CM_FutureMove;
	count : Integer;
begin
	
	foreach fm in self do
		count := count + 1;
		if fm.getPrimaryLocation = _lc then
			return count;
		endif;
	endforeach;
	return null;

epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getIndexOfTI" id="d9a56bfa-88af-49dc-8131-12d41b21182b">
        <source>getIndexOfTI( _ti : CM_TrackedItem ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2014	cnwndl1	Initial creation

*/

vars
	fm		: CM_FutureMove;
	count : Integer;
begin
	foreach fm in self do
		// All because CM_FutureMove doesn't contain myTrackedItem...
		count := count + 1;
		if fm.isKindOf(CM_FutureMovePlanned) then
			if fm.CM_FutureMovePlanned.myTrackedItem = _ti then
				return count;
			endif;
		elseif fm.isKindOf(CM_FutureMoveQueued) then
			if fm.CM_FutureMoveQueued.myTrackedItem = _ti then
				return count;
			endif;
		endif;	
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasQueuedEntriesBeforeIndex" id="73ca0d56-3104-4463-81e5-d5d88ca69c68">
        <source>hasQueuedEntriesBeforeIndex(_currentQueue : CM_RadioTelemetryQueue;
								_currentIndex : Integer) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2009	cnwer1	Initial creation

*/

vars
	futureMove : CM_FutureMove;
	futureQueuedMove :CM_FutureMoveQueued;
	isQueuedOut : Boolean;
begin
	if _currentIndex = 0 then
		return false;
	endif;
	isQueuedOut:=false;
	foreach futureMove in self do
		isQueuedOut:=false;
		futureQueuedMove:=futureMove.CM_FutureMoveQueued;
		isQueuedOut:=isQueuedOut or futureQueuedMove.isQueueEntryAbove(_currentQueue,_currentIndex);
	endforeach;
	
	return  isQueuedOut;
epilog

end;</source>
        <Parameter name="_currentQueue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_currentIndex" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
