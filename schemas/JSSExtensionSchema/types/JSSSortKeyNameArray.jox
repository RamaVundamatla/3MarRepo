<CollClass name="JSSSortKeyNameArray" id="ac46c86d-f00c-41f2-9f42-d5e497afa015">
    <memberType name="JSSSortKeyName"/>
    <superclass name="ObjectArray"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
