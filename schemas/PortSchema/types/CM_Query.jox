    <DbClassMap file="query"/>
    <JadeMethod name="erase" id="43fb890a-18db-47f3-843f-478109f0a142">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//----------------------------------------------------------------
//	Created:	25 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	exclusiveLock(self);
	delete self;

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ba2d399b-04bf-411d-946d-b2f1e8797276">
        <source>getDisplayStringForAttribute(_attrName : String; _getCalculatedRunDate : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     07 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	tmpValue	: Any;
	tmpStr		: String;
	
begin
	tmpValue := self.getPropertyValue(_attrName);
	if tmpValue.isKindOf(String) then
		tmpStr := tmpValue.String;
	elseif tmpValue.isKindOf(Time) then
		if tmpValue.Time.isValid then
			tmpStr := tmpValue.Time.shortFormatJMT();
		endif;
	elseif tmpValue.isKindOf(Date) then
		if tmpValue.Date.isValid then
			tmpStr := tmpValue.Date.shortFormatJMT();
		endif;
	elseif tmpValue.isKindOf(TimeStamp) then
		if tmpValue.TimeStamp.isValid then
			tmpStr := tmpValue.Date.shortFormatJMT() &amp; ' ' &amp; tmpValue.Time.shortFormatJMT();
		endif;
	elseif tmpValue.isKindOf(Boolean) then
		tmpStr := app.getYesNo(tmpValue.Boolean);
	elseif tmpValue.isKindOf(CM_Object) then
		if tmpValue &lt;&gt; null then
			tmpStr := tmpValue.CM_Object.getDisplayDetails(false);
		endif;
	else
		tmpStr := tmpValue.String;
	endif;
	
	return tmpStr;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedRunDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="raiseExceptionIfNotTransient" id="422f8948-ee2f-4e4f-8f71-c7772e130e4f">
        <source>raiseExceptionIfNotTransient(callingMethod : Method);
// ---------------------------------------------------------------------------
// Created:     15 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	mthName : String;
	
begin

	if self.isTransient then
		return;
	endif;

	if callingMethod &lt;&gt; null then
		mthName := callingMethod.name;
	else
		mthName := "unknown method";
	endif;

	app.setContinueCMExceptions(false);
	app.raiseCMException2(MethodCalledForNonTransient, mthName, self.class.String, null, null);
	
end;</source>
        <Parameter name="callingMethod" type="Method"/>
    </JadeMethod>
</Class>
