    <JadeMethod name="setDisplayTotalColumn" id="2a27aa41-0fc6-4c0c-9454-2221a638a51c">
        <updating/>
        <source>setDisplayTotalColumn( _value : Boolean ) updating;
// ---------------------------------------------------------------------------
// Created:     20 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/01/2009	cnwrl1		Stop exception when not actually doing any updating (CCMS SFW 1047 - Totals Only Lists)
// ---------------------------------------------------------------------------
vars
	
begin
	if self.displayTotalColumn = _value then	// because this is being called on lost focus when not real updating is being done.
		return;
	endif;
	
	self.raiseExceptionIfNotTransient(method);
	
	self.displayTotalColumn := _value;
epilog
	
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
