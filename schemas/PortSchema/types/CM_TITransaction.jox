    <JadeMethod name="canUserAccessSelf" id="d11ee80b-e484-484b-9600-b13a94430c63">
        <source>canUserAccessSelf(_user: CM_User; _failedDAC  :CM_DataAccessController output; _passport: CM_Passport): Boolean;
//----------------------------------------------------------------
//	Created:	18 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpOperator	: CM_Operator;
	tmpCC		: CM_ConsigneeConsignor;
begin
	
	tmpOperator := self.getOperator();
	if tmpOperator &lt;&gt; null and
	   (not tmpOperator.canUserAccessSelf(_user, _failedDAC, _passport)) then
		return false;
	endif;
	
	tmpCC := self.getConsignee();
	if tmpCC &lt;&gt; null and
	   (not tmpCC.canUserAccessSelf(_user, _failedDAC, _passport)) then
		return false;
	endif;

	tmpCC := self.getConsignor();
	if tmpCC &lt;&gt; null and
	   (not tmpCC.canUserAccessSelf(_user, _failedDAC, _passport)) then
		return false;
	endif;

	return true;

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
