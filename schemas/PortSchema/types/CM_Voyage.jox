    <JadeMethod name="isPaidFor" id="96d21416-1465-4b5e-8664-5e9bbb576e50">
        <source>isPaidFor() : Boolean;
 // TFS 37454
vars
	result	: Boolean;
	proformaTotal,
	cashTotal,
	chargeTotal	: Decimal[16, 6];
	payment		: CM_CashPayment;
	invoiceLine	: CM_InvoiceLine;
	invoice : CM_Invoice;
begin

	foreach payment in self.allCashPayments do
		if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue; // TFS 7357
		endif; // TFS 7357
		// 35232 skip voided payments
		if payment.voided then
			continue;
		endif;
		cashTotal := cashTotal + payment.cashValue;
		/* // TFS 45953
		if payment.isProformaPayment then
			foreach proformaTotal in payment.proformaLineTotals do
				chargeTotal := chargeTotal + proformaTotal;
			endforeach;
		endif;
		*/
	endforeach;
	
	// 10/06/2014 add the cash-only debtor test
	foreach invoice in self.allInvoices where invoice.debtor.isCashOnlyDebtor(self.myTerminal) do
		foreach invoiceLine in invoice.invoiceLines do
			if invoiceLine.voided then
				continue;
			endif;
			chargeTotal := chargeTotal + invoiceLine.lineTotal;
		endforeach;
	endforeach;
	
	if cashTotal &lt;&gt; 0 or chargeTotal &lt;&gt; 0 then
		result := (cashTotal &gt;= chargeTotal);
	endif;
	return result;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRetrospective" id="5969aacf-6939-48d3-bdd4-02d484e83e6b">
        <source>isRetrospective():Boolean;
//--------------------------------------------------
// Created:	07 July 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
// PAR 33644	if (self.isNonPlannedVoyage or 
// PAR 33644	   self.isNonWorkedVoyage) and
// PAR 33644	   self.isNonPlannedOrNotCellularRORO then	// PAR 21745 CCMS MES 1031 - We treat RORO/Planned voyages as Planned
	if self.isHOLDSorSHIP() then
		if self.nonPlannedEffectiveDT.isValid then
			return true;
		endif;
	endif;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStatusDeparted" id="91c70768-fbf9-41be-a573-20fe628c8425">
