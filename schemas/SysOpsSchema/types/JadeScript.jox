<Class name="JadeScript">
    <JadeMethod name="db2Test" id="35b6f793-5872-4425-90e5-3abd0cff3a0e">
        <source>db2Test() : StringArray;
/*

Purpose:			
// get the group table rows from the Terminal table class
Parameters:			

Return Value:		

Date		Who		Reason
26 June 2014	cnwdb2	Initial creation

*/

vars


	item		: SOP_TableMaintItem;
	str : String ;  
	a : SOPTM_Terminal ; 
	subClasses	: ClassColl;
	subClass	: Class;
	entTableDef	: EntTableDef;
	int : Integer ; 
	entTabRow : EntTableRow ; 
	termArray : StringArray ; 
	rowCollection : String  ; 

begin
	create termArray transient ; 
	foreach entTableDef in app.myRoot.myEntTableDataRoot.allEntTableDefs do
		if entTableDef.myEntTableGroup.name = "ConfigGroup" then
			//if entTableDef.name = "ShipSettings" then
				foreach entTabRow in entTableDef.allEntTableRows do
					rowCollection :=  entTabRow.getHeading(null, null, null)  ; 
					//write " Entity name: " &amp; entTableDef.name &amp; " - " &amp; rowCollection  ; 
					//int := int + 1 ;
					termArray.add(rowCollection) ; 
					/*if rowCollection.cnContains("Max") then
						write rowCollection ; 
					endif ;*/ 
				endforeach  ;
			//endif  ;
		endif ; 
	endforeach  ;
//	write int.String  ; 
	
	return termArray  ;

	
epilog

//	delete termArray  ;

end;</source>
        <ReturnType type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="db2Test2" id="f09d5a37-261c-4fb2-a932-a929bbe5dbc9">
        <source>db2Test2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2014	cnwdb2	Initial creation

*/

vars
	stringArray : StringArray ; 
	idx : Integer  ; 
	numberedIndex :  IntegerArray ; 
	str : String ; 
	
	
	
begin
	create stringArray transient  ;
	create numberedIndex transient ; 
	
	
	str := "Id" ; 
	idx :=  stringArray.indexOf(str);	
		if idx &gt; 0 then
			numberedIndex[idx] := numberedIndex[idx] + 1;
		else
			stringArray.add(str);
			numberedIndex[stringArray.size] := 1;
		endif;
			
	str := "Id" ; 
	idx :=  stringArray.indexOf(str);	
		if idx &gt; 0 then
			numberedIndex[idx] := numberedIndex[idx] + 1;
		else
			stringArray.add(str);
			numberedIndex[stringArray.size] := 1;
		endif;
			
	str := "Id" ; 
	idx :=  stringArray.indexOf(str);	
		if idx &gt; 0 then
			numberedIndex[idx] := numberedIndex[idx] + 1;
		else
			stringArray.add(str);
			numberedIndex[stringArray.size] := 1;
		endif;
			
	foreach idx in 1 to stringArray.size do
		write stringArray[idx] &amp; " &gt;&gt;&gt; " &amp; numberedIndex[idx].String;
	endforeach;
	
	
			
epilog
	delete stringArray ; 
	delete numberedIndex ; 
end;</source>
    </JadeMethod>
