<Class name="System">
    <JadeMethod name="getDbServerCPUDetails" id="c3e496b5-33c2-4077-a92f-349377d82f3d">
        <executionLocation>server</executionLocation>
        <source>getDbServerCPUDetails() : String serverExecution;

constants
	HKEY_CLASSES_ROOT       : Integer = #80000000;
	HKEY_CURRENT_USER       : Integer = #80000001;
	HKEY_LOCAL_MACHINE      : Integer = #80000002;
	HKEY_USERS              : Integer = #80000003;
	HKEY_PERFORMANCE_DATA   : Integer = #80000004;
	HKEY_CURRENT_CONFIG     : Integer = #80000005;
	HKEY_DYN_DATA           : Integer = #80000006;
	PROCESSOR_INTEL_386     : Integer = 386;
	PROCESSOR_INTEL_486     : Integer = 486;
    PROCESSOR_INTEL_PENTIUM : Integer = 586;
    PROCESSOR_MIPS_R4000    : Integer = 4000;
    PROCESSOR_ALPHA_21064   : Integer = 21064;
 
vars
	sysInfo    : Binary;
	hKey       : Integer;
	subKey     : String[256];
	valueName  : String[256];
	data       : Binary[256]; 
	openKey    : Integer;
	result     : Integer; 
	openResult : Integer;
	length     : Integer;
	dwNumCPUs  : Integer;
	dwCPUType  : Integer;
	s          : String;
  
begin
	hKey := HKEY_LOCAL_MACHINE;
	subKey := "HARDWARE\DESCRIPTION\System\CentralProcessor\0";
	data := null;
	data[255 : 1] := 0.Binary;
	length := 255;
	valueName := "~MHz";
	sysInfo := null;
	sysInfo[32 : 1] := 0.Binary;
	
	if app.isUnicode then
		openResult := call winRegOpenKeyW(hKey, subKey, openKey);
		result := call winRegQueryValueExW(openKey, valueName, null, null, data, length);
	else
		openResult := call winRegOpenKeyA(hKey, subKey, openKey);
		result := call winRegQueryValueExA(openKey, valueName, null, null, data, length);
	endif;

	result := call winRegCloseKey(openKey);

	call winGetSystemInfo(sysInfo);
	
	dwNumCPUs := sysInfo[21 : 4].Integer;
	dwCPUType := sysInfo[25 : 4].Integer;

	if dwNumCPUs &gt; 1 then
		s := dwNumCPUs.String &amp; " x ";
	else
		s := null;
	endif;

	if dwCPUType = PROCESSOR_INTEL_386 then
		s := s &amp; "i386 ";
	elseif dwCPUType = PROCESSOR_INTEL_486 then
		s := s &amp; "i486 ";
	elseif dwCPUType = PROCESSOR_INTEL_PENTIUM then
		s := s &amp; "Pentium ";
	else
		s := s &amp; "Non-Intel ";
	endif;
	
	s := s &amp; data.Binary[1 : 4].Integer.String;
	
	return s;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDbServerNameAndTotalMemory" id="f76a3fc3-789f-4704-b9ab-b5606039764a">
        <executionLocation>server</executionLocation>
        <source>getDbServerNameAndTotalMemory(machineName : String output; totalMem : Integer output) serverExecution;

vars
	errNo, availMem : Integer; // availMem is not used
	s, errTxt : String;

begin
	totalMem := 0;

	s := app.computerNameAppServer;
	// to be consistent with computer names received via ping responses, we
	// replace any semi-colons with underscores (we assume that semi-colons
	// in computer names are unlikely)
	s.replaceChar(';', '_');
	machineName := s.trimBlanks;
	
	// arm an exception handler to guard against something going wrong in
	// getTotalAndAvailableMemory (eg: external functions are not available)
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);
	
	node.getTotalAndAvailableMemory(totalMem, availMem);

	// if an exception occurs in getTotalAndAvailableMemory, our handler armed
	// above will resume to here and we'll just return from this method
end;</source>
        <Parameter name="machineName" type="String" usage="output"/>
        <Parameter name="totalMem" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getFreeDiskAndMemory" id="e374aed9-7285-4d3a-a3a9-5cf7c1df40db">
        <source>getFreeDiskAndMemory(freeMem : Integer output; freeDisk : Decimal io;
	driveName : String output) protected;

// this method assumes it is executing on the db server node (ie: the
// caller must itself be a server method, or have been called from a
// server method)

vars
	path           : String;
	userFreeBytes  : Binary[8];
	totalBytes     : Binary[8];
	totalFreeBytes : Binary[8];
	avail          : Decimal[23];
	topHalf        : Integer;
	bottomHalf     : Integer;
	n              : Integer;
	b              : Binary;

begin
	b[1 : 256] := 0.Binary;
	
	call winGlobalMemoryStatus(b);

	freeMem := b[13 : 4].Integer;

	path := app.dbPath;
	if path = null then
		return;
	endif;
	
	n := path.pos(':', 1);
	if n &lt; 2 then
		return;
	endif;
	
	path := path[1 : n];
	driveName := path[1 : n - 1];
	
	if app.isUnicode then
		call winGetDiskFreeSpaceExW(path, userFreeBytes, totalBytes, totalFreeBytes);
	else
		call winGetDiskFreeSpaceExA(path, userFreeBytes, totalBytes, totalFreeBytes);
	endif;
		
	topHalf := totalFreeBytes[5 : 4].Integer;
	bottomHalf := totalFreeBytes[1 : 4].Integer;

	if bottomHalf &lt; 0 then
		avail := bottomHalf.bitAnd(#7FFFFFFF) + 2147483648;
	else
		avail := bottomHalf;
	endif;
	
	avail := avail + (topHalf * 4294967296);

	freeDisk := avail;
end;</source>
        <access>protected</access>
        <Parameter name="freeMem" type="Integer" usage="output"/>
        <Parameter name="freeDisk" type="Decimal" usage="io"/>
        <Parameter name="driveName" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getFreeDiskAndMemoryOnDbServer" id="1333902c-71ed-4883-8631-5a314d0aced9">
        <executionLocation>server</executionLocation>
        <source>getFreeDiskAndMemoryOnDbServer(freeMem : Integer output; freeDisk : Decimal io;
	driveName : String output) serverExecution;

vars
	errNo : Integer;
	errTxt : String;

begin
	freeMem := 0;
	freeDisk := 0;
	driveName := null;
	
	// arm an exception handler to guard against something going wrong in
	// getFreeDiskAndMemory (eg: the external functions are not available)
	on Exception do app.resumeNextExHandler(exception, errNo, errTxt);
	
	self.getFreeDiskAndMemory(freeMem, freeDisk, driveName);

	// if an exception occurs in getFreeDiskAndMemory, our handler armed
	// above will resume to here and we'll just return from this method
end;</source>
        <Parameter name="freeMem" type="Integer" usage="output"/>
        <Parameter name="freeDisk" type="Decimal" usage="io"/>
        <Parameter name="driveName" type="String" usage="output"/>
    </JadeMethod>
</Class>
