04 Aug 2023	navlw1	ChangeRequest 59284:[59660] EUP | FR - VAS Work Order Transactions - Fixing Duplicate Values 
*/

vars

begin
	
	if not self.hasCargoWorkOrderDetails  then
		return null;
	endif;
	
	return self.myWorkOrderDetail.CM_WorkOrderTIDtl.allSelectedTIs.listStringNoDuplicate(Comma,CM_TrackedItem::markNumber.name);
epilog

end;</source>
