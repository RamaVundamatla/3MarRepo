    <JadeMethod name="setupForm" id="83f910cb-6bfe-4b22-91ac-05c05be8b8bf">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwer1	Initial creation HAT 2189
31 July     2014    cnwma1 PAR 34408 Credit Customer current charges

*/

vars
	entTableDef : EntTableDef;
	extraEntTableDef : EntTableDef;
	extraRows : EntTableRowArray;
begin

	self.minimumHeight := 700;
	self.minimumWidth := 896;
	self.chkDataEntry.value := false;		// cnwma1 31/07/2014 PAR 34408
	inheritMethod();
	self.setPermissions;
	self.loadCombos();
	self.tblDutyDocItems.selectionType 	:= CM_BaseTable.SelectionType_Row;
	self.tblDutyDocItems.multiSelect 		:= CM_BaseTable.MultiSelect_Simple;
	entTableDef := app.myController.getEntTableDef(ETDef_DutyDocItem);

	if entTableDef &lt;&gt; null then
		self.tblDutyDocItems.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	self.loadDutyDoc(true);
	
	self.summarizeItems;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showCurrentCharges" id="a153ae19-f7be-4a08-a7b8-d44d2a009d21">
        <source>showCurrentCharges();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2013	cnwer1	Initial creation HAT 2189

*/

vars
	cashReceiptForm : CM_BaseForm; //INV_MultiCashReceiptForDutyDoc;
	subSys : CMUI_SubSystem;
	formCls,
	assistCls: Class;
begin
	
	subSys := app.myController.allSubSystems['InvoiceSchema'];
	
	if subSys &lt;&gt; null then
		subSys.getFormDetails('INV_MultiCashReceiptForDutyDoc', formCls, assistCls);
	endif;
	
	 cashReceiptForm:=app.loadForm(formCls, assistCls, false, false, false, self.myTerminal, null).CM_BaseForm;
	cashReceiptForm.setFormObject(self.myDutyDoc);
	cashReceiptForm.show;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="summarizeItems" id="ac88a678-3f6b-42eb-a30b-869cdae96a82">
        <source>summarizeItems();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2014	cnwdw1	Initial creation
*/
vars
	dutyDocItem: CM_DutyDocItem;
	count: Integer;
	sumValue, sumFreight, sumInsurance, sumNetValue, sumDuty: Decimal [16,4];
	freeDays: Integer;
begin
	
	if self.myDutyDoc &lt;&gt; null then
		foreach dutyDocItem in self.myDutyDoc.allDutyDocItems do
			count := count + 1;
			sumValue := sumValue + dutyDocItem.localValue;
			sumFreight := sumFreight + dutyDocItem.freight;
			sumInsurance := sumInsurance + dutyDocItem.insurance;
			sumNetValue := sumNetValue + dutyDocItem.getNetValue;
			sumDuty := sumDuty+ dutyDocItem.duty;
			
			freeDays := dutyDocItem.getMyTrackedItem.freeStorageDays;
			
		endforeach;
	endif;
	
	self.txtSumCount.caption := count.String;
	self.txtSumValue.caption := sumValue.asCurrencyJMT;
	self.txtSumFreight.caption := sumFreight.asCurrencyJMT;
	self.txtSumInsurance.caption := sumInsurance.asCurrencyJMT;
	self.txtSumNetValue.caption := sumNetValue.asCurrencyJMT;
	self.txtSumDuty.caption := sumDuty.asCurrencyJMT;
	
	self.txtFreeDays.caption := freeDays.String;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="7fdefeee-e4b4-4d7b-902d-945af3a55679">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2013	cnwer1	Initial creation

*/

vars
	msg : String;
begin
	if eventType =  Object_Delete_Event and theObject =  self.myDutyDoc then	
		msg := app.getErrorString1(Editi_been_delet_anoth_user_th,"Duty Document");		
		app.msgBox(msg, app.getErrorString(Warning),MsgBox_OK_Only);
		self.unloadForm();
	endif;

epilog

end;</source>
