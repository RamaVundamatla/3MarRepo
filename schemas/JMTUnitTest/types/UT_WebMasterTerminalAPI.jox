    <JadeMethod name="tPostUnpack" id="c6a4466d-26a3-4c40-bf50-8963fd11548a">
        <source>tPostUnpack();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2024	navsp1	Initial creation TFS ChangeRequest 65967: CUX | MasterTerminalAPI - Pack and Unpack APIs
08 October	 2024   navsp1  JIRA BUG 33031 CUX | Pack and Unpack APIs Issue
*/
constants
	CargoType		: String = "UTREBAR";
	ParentTI		: String = "UTTI6596700";
	ParentTI2		: String = "UTTI6596711";
	TrailerID		: String = "UTTILC65967";
	ChildCargo1		: String = "UTCH6596701";
	ChildCargo2		: String = "UTCH6596702";
	TerminalArea	: String = "UTBS8";
	Trailer_CT		: String = "TRCT01";
	TrailerType		: String = "UTTT65";
	
		IncomingJsonStringUnpackWrong = '{
    "parent": {
        "id": "'&amp; ParentTI &amp;'",
        "cargoTypeId": "CONT"
    },
     "cargo": [
            {
				"targetLocationId" : "'&amp;TerminalArea&amp;'",
				"id": "'&amp; ChildCargo2 &amp;'",
				"cargoTypeId": "'&amp; CargoType &amp;'",
				"quantity": 50,
				"volume" : {
							"amount" : "30000",
							"unit"   : "m3"
							},
				"weight" : {
							"amount" : "50000",
							"unit"	 : "kg"
							},
				"unpackTime" : "2024-08-04T07:30:00"
            }
        ],
    "complete": true
}';

	IncomingJsonStringUnpack = '{
    "parent": {
        "id": "'&amp; ParentTI &amp;'",
        "cargoTypeId": "CONT"
    },
     "cargo": [
            {
				"targetLocationId" : "'&amp;TerminalArea&amp;'",
				"id": "'&amp; ChildCargo1 &amp;'",
				"cargoTypeId": "'&amp; CargoType &amp;'",
				"quantity": 50,
				"volume" : {
							"amount" : "30000",
							"unit"   : "m3"
							},
				"weight" : {
							"amount" : "50000",
							"unit"	 : "kg"
							},
				"unpackTime" : "2024-08-04T07:30:00"
            }
        ],
    "complete": true
}';

	IncomingJsonStringUnpackFromTrailer = '{
    "parent": {
        "id": "'&amp; TrailerID &amp;'",
        "cargoTypeId": "'&amp;Trailer_CT&amp;'"
    },
     "cargo": [
            {
				"targetLocationId" : "'&amp;TerminalArea&amp;'",
				"id": "'&amp; ChildCargo1 &amp;'",
				"cargoTypeId": "'&amp; CargoType &amp;'",
				"quantity": 50,
				"volume" : {
							"amount" : "50000",
							"unit"   : "m3"
							},
				"weight" : {
							"amount" : "50000",
							"unit"	 : "kg"
							},
				"unpackTime" : "2024-08-04T07:30:00"
            }
        ],
    "complete": true
}';
PackTimeStamp = "01 August 2024, 10:25:58";
vars
	bs 					: CM_BlockStack;
	container,
	container2,
	cargo1,
	cargo2,
	packCargo1			: CM_TrackedItem;
	childCargoType,
	ctTrailer			: CM_CargoType;
	incomingJsonString,
 	loginJson,
	qParameters     	: String;
	expectFailure		: Boolean;
	trailer				: CM_TILC;
	tt					: CM_TILCType;
	packTS : TimeStamp;
begin
	
	//Clear data
	self.deleteContainer(ParentTI);
	self.deleteContainer(ParentTI2);
	self.deleteTerminalArea(TerminalArea);
	
	//Add terminal area
	bs:=self.addBlockStack(TerminalArea, 200, null);
	self.assertNotNull(bs);
	
	//Add container
	container := self.addContainer(ParentTI, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.assertTrueMsg(container &lt;&gt; null, "No TrackedItem: " &amp; ParentTI &amp; " Created");
	
	container2 := self.addContainer(ParentTI2, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.assertTrueMsg(container2 &lt;&gt; null, "No TrackedItem: " &amp; ParentTI2 &amp; " Created");
	
	childCargoType	:=	app.myRoot.getCargoTypeFromAbbrev(CargoType);
	
	self.deleteAllCargo(ChildCargo1, childCargoType);
	self.deleteAllCargo(ChildCargo2, childCargoType);
	
	packTS := PackTimeStamp.TimeStamp;
	
	//create a child cargo
	cargo1 := self.addCargoAtLocation(ChildCargo1, childCargoType, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs.myLocationsController);
	cargo2 := self.addCargoAtLocation(ChildCargo2, childCargoType, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs.myLocationsController);
	
	self.assertNotNull(cargo1);
	self.assertEqual(cargo1.myPrimaryActualLocation, bs.myLocationsController);
	
	//Set the values
	beginTransaction;
	cargo1.setTotalQuantity(50);
	self.assertEqual(cargo1.totalQuantity,50);
	cargo1.setMyTotalVolume(50000);
	cargo1.setTotalWeightWithoutTrans(50000);
	
	cargo2.setTotalQuantity(50);
	self.assertEqual(cargo2.totalQuantity,50);
	cargo2.setMyTotalVolume(50000);
	cargo2.setTotalWeightWithoutTrans(50000);
	commitTransaction;	
	
	//verify cargo
	self.assertEqual(cargo1.totalQuantity, 50);
	self.assertEqual(cargo1.totalVolume.Integer, 50000);
	self.assertEqual(cargo1.totalWeight.Integer, 50000);	
	
	self.assertEqual(cargo2.totalQuantity, 50);
	self.assertEqual(cargo2.totalVolume.Integer, 50000);
	self.assertEqual(cargo2.totalWeight.Integer, 50000);
	
	//Pack cargo to the container
	app.myTrxUA.trxUpdatePackCargo(container, cargo1, 50, 50000, false, null, null, false, packTS, app.myPassport);
	self.assertNoTrxErrors();
	self.assertEqual(container.isParent, true);
	self.assertEqual(container.allChildren.size, 1);	
	self.assertEqual(container.weightCargo.Integer, 50000.Integer);
	self.assertEqual(container.getMyCargoVolume().Integer, 50000.Integer);
	self.assertEqual(cargo1.isChild, true);
	self.assertEqual(cargo1.myParent.id, container.id);
	
	//Pack complete TRX	
	self.opts.purge();
	self.opts.addAssoc("RetroDT", packTS);
	self.packCompleteContainer(container.CM_Container);
	
	//API call to unpack an invalid child cargo																							//JIRA 33031
	incomingJsonString := IncomingJsonStringUnpackWrong;																				//JIRA 33031
	expectFailure := true;																												//JIRA 33031
	self.opts.purge();																													//JIRA 33031
	self.opts.addAssoc("ExpectedResponse", app.getErrorString1(Not_unpack_cargo_not_packed, ChildCargo2));								//JIRA 33031
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostUnPack.name, loginJson, qParameters, incomingJsonString, expectFailure);	//JIRA 33031
	
	//Pack cargo to a different container																								//JIRA 33031
	app.myTrxUA.trxUpdatePackCargo(container2, cargo2, 50, 50000, false, null, null, false, packTS, app.myPassport);					//JIRA 33031
	self.assertNoTrxErrors();																											//JIRA 33031
	self.assertEqual(container2.isParent, true);																						//JIRA 33031
	self.assertEqual(container2.allChildren.size, 1);																					//JIRA 33031
	self.assertEqual(container2.weightCargo.Integer, 50000.Integer);																	//JIRA 33031
	self.assertEqual(container2.getMyCargoVolume().Integer, 50000.Integer);																//JIRA 33031
	self.assertEqual(cargo2.isChild, true);																								//JIRA 33031
	self.assertEqual(cargo2.myParent.id, container2.id);																				//JIRA 33031
	
	//Pack complete TRX																													//JIRA 33031
	self.opts.purge();																													//JIRA 33031
	self.opts.addAssoc("RetroDT", packTS);																								//JIRA 33031
	self.packCompleteContainer(container2.CM_Container);																				//JIRA 33031
	
	//API call to unpack an invalid child cargo	/ invalid parent check																	//JIRA 33031
	incomingJsonString := IncomingJsonStringUnpackWrong;																				//JIRA 33031
	expectFailure := true;																												//JIRA 33031
	self.opts.purge();																													//JIRA 33031
	self.opts.addAssoc("ExpectedResponse", app.getErrorString2(Cargo_not_found_unpack, ChildCargo2, ParentTI));							//JIRA 33031
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostUnPack.name, loginJson, qParameters, incomingJsonString, expectFailure);	//JIRA 33031
	
	//API call to unpack cargo
	incomingJsonString := IncomingJsonStringUnpack;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostUnPack.name, loginJson, qParameters, incomingJsonString, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	//Verify after the API call
	self.assertEqual(cargo1.locationId, TerminalArea);
	self.assertEqual(cargo1.isChild, false);
	self.assertEqual(container.weightCargo.Integer, 0);
	self.assertEqual(container.getMyCargoVolume().Integer, 0);
	self.assertEqual(container.isUnpackingComplete(), true);	
	
	//Trailer Type
	self.opts.purge;
	self.opts.addAssoc("TrackAs",ProductType_Trailer);
	ctTrailer	:=	self.addCargoType(Trailer_CT, false);
	
	tt := self.addTrailerType(TrailerType, TrailerType, ctTrailer, 500, 1, 50, 30000, 13000, null, null, 500);
	
	trailer := self.addTrailerAtLocation(TrailerID, ctTrailer, tt, self.getOperator("PON"), bs.myLocationsController).CM_TILC;
	
	//Pack cargo to the trailer
	app.myTrxUA.trxUpdatePackCargo(trailer, cargo1, 50, 50000, false, null, null, false, packTS, app.myPassport);
	self.assertNoTrxErrors();
	self.assertEqual(trailer.isParent, true);
	self.assertEqual(trailer.allChildren.size, 1);	
	self.assertEqual(trailer.weightCargo.Integer, 50000.Integer);
	self.assertEqual(trailer.getMyCargoVolume().Integer, 50000.Integer);
	self.assertEqual(cargo1.isChild, true);
	self.assertEqual(cargo1.myParent.id, trailer.id);
	
	//API call to unpack cargo from trailer
	incomingJsonString := IncomingJsonStringUnpackFromTrailer;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostUnPack.name, loginJson, qParameters, incomingJsonString, expectFailure);
	self.assertNoTrxErrorsOrWarnings();
	
	//Verify after the API call
	self.assertEqual(cargo1.locationId, TerminalArea);
	self.assertEqual(cargo1.isChild, false);
	self.assertEqual(trailer.weightCargo.Integer, 0);
	self.assertEqual(trailer.getMyCargoVolume().Integer, 0);
	self.assertEqual(trailer.isUnpackingComplete(), true);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tPostVoyage" id="e83fa3b7-cfa2-4075-8e6f-2ae323e36266">
        <source>tPostVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 April 2023	navlw1	Initial creation CR 57560 CUX - MTN-EDBIC - Process Voyage - Unit Tests
28 Nov 2023		navlw1	Bug 57735: CUX - Only Mandatory fields are not accepting POST Request
19 Dec 2023		navlw1	Bug 60597: CUX | EDBIC - added tests for port rotation/tranship ports
12 Feb 2024		naviv1	CR 62354: CUX | FR 56696 - Ticket 62329 - Populate Trade from API and add Ports of Call -- Added 2 new test cases
04 Jul 2024 	navhn30  ChangeRequest 64828: CUX - Include Voyage Status in GET /voyage response
17 Jul 2024		navmd1	TFS 65226 Make sure we test timestamps that cross over Daylight savings boundries
22 Jul 2024		navdap1	TFS 65286 CUX | Include cargo structure flags in voyage API
08 Aug 2024		navhn30	Bug 65480: CUX | Issues on POST/PUT Voyage when includes Cargo structure flags
