    <JadeMethod name="getAutoMaskTIs" id="b3033a74-1fa1-42ca-9384-277cb0262f9a">
        <source>getAutoMaskTIs(_dict : Collection input; _mode : Integer; _dischargePort, _commodityGroup, _voyageCode : String);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	gridPoint,tmpP : CMUI_GridPoint;
	gridArea	: CMUI_GridArea;
	
begin
	foreach gridArea in self.allGridAreasByRowColumn do
		// in the draw of the gridpoint it checks whether _dict is empty before it uses it, so we must put something for automasking to work correctly
		// else if no matches then nothing draw white or things do not draw white until something does match.
		_dict.add(gridArea.myDummyTI);
		foreach gridPoint in gridArea.allGridPoints do
		
			gridPoint.getAutoMaskTIs(_dict,_mode, _dischargePort, _commodityGroup, _voyageCode);
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_dict" type="Collection" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_commodityGroup" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="getColumnWidth" id="e171846f-68d8-407b-bd88-7d9449942c4a">
        <source>getColumnWidth(_column : Integer) : Real;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	totalWidth, theWidth, aWidth : Real;
	idx : Integer;
	
begin
	if _column &lt; 1 then
		return 0;
	endif;
	
	if _column &lt;= self.allColumnEndPositions.size then
		theWidth := self.allColumnEndPositions[_column];
		
		if _column = 1 then
			return theWidth;
		else
			idx := _column - 1;
			totalWidth := self.allColumnEndPositions[idx];
			return	(theWidth - totalWidth);
		endif;
	endif;
	
	return 0;
end;</source>
        <Parameter name="_column" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getGridAreaForHLabel" id="64d9367c-fdbd-4b80-aaba-62280f0d9554">
