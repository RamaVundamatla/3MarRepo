    <JadeMethod name="returnFromDocAction" id="443aade5-642d-46f0-a764-939c834be957">
        <source>returnFromDocAction();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2016	cnwndl1	Initial creation	TFS 2654 / 2001

*/

vars
	sheetName : String;

begin
	
	sheetName := self.myMobileGenericAgent.stringField1;
	if sheetName = self.shtToUnPack.name then
		self.fldCargo.querySheetChg(self.fldCargo,self.shtToUnPack);
		self.fldCargo.topSheet := self.shtToUnPack;
	elseif sheetName = self.shtUnpacked.name then
		self.fldCargo.querySheetChg(self.fldCargo,self.shtUnpacked);
		self.fldCargo.topSheet := self.shtUnpacked;
	endif;

epilog

end;</source>
    </JadeMethod>
