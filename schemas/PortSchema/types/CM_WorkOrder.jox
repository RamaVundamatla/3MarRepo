    <JadeMethod name="canArchive" id="e96200ab-7a58-4571-8ede-abab73de838f">
        <source>canArchive():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Mar 2023 navma1 ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task

*/

vars

begin
	
	if self.archived then				// Already Archived
		return false;
	endif;
	
	if self.taskStatus = WO_STATUS_COMPLETE or self.taskStatus = WO_STATUS_CANCELLED then
		return true;
	endif;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeUnApprove" id="22d07176-7472-41c6-b1ec-37bb10feacb9">
        <source>canBeUnApprove():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2024 navhl20 ChangeRequest 63583: EUP | 54014 - Cargo Work Orders Enhancements - Remedial
21 May 2024 navbs1	Defect 64205: MTN - Work Order Enquiry - 1090 error occurring when trying to open context menu
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	wod		: CM_WorkOrderDtl;
	job		: CM_Job;
	jobSet	: CM_JobSet;
begin
	if not app.myPassport.isVASEnabled then
		return false;
	endif;
	
	foreach wod in self.allWoDtls discreteLock do		  //28.05.2024 navma1 #64224
		if wod.isKindOf(CM_WorkOrderTIDtl) then
			jobSet := wod.CM_WorkOrderTIDtl.allJobs;
		elseif wod.isKindOf(CM_WorkOrderToDoDtl) then
			jobSet := wod.CM_WorkOrderToDoDtl.allJobs;
		endif;
		
		if jobSet &lt;&gt; null and jobSet.isNotEmpty then		//21.05.2024 navbs1 #64205
			foreach job in jobSet do
				if job.status &lt;&gt; JOB_UNACTIONED then
					return false;
				endif;
			endforeach;
		else
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canCancel" id="e8b824ec-4f26-4413-a813-13ddba413f71">
        <source>canCancel() :Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 August 2018	jlger1	Initial creation

*/

vars

begin
	return not (self.taskStatus = WO_STATUS_COMPLETE
		or self.taskStatus = WO_STATUS_PARTCOMPLETE);
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canCancelSAPEstimate" id="d30c638f-c5b5-4fba-8222-257eb2994f1e">
        <source>canCancelSAPEstimate() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2019	jlger1	Initial creation TFS 43260

*/

vars
	cashRec : CM_CashReceipt;
	bgpSAPRequest  : BGP_Request;
begin
	if  not self.isWorkOrderForIMSR then
		return false;
	endif;
	
	if self.allCashReceipts.isEmpty then
		return false;
	endif;
	
	foreach cashRec in self.allCashReceipts discreteLock do
		if cashRec.paymentType &lt;&gt; PaymentType_AutoCollection then
			return false;
		endif;
		
		foreach bgpSAPRequest in cashRec.allSapRequests discreteLock do
			if bgpSAPRequest.BGP_SAPWSRequest.isSAPCancelEstimate then
				return false;
			endif;
		endforeach;
		
		if cashRec.paymentStatus  &lt;&gt; CM_CashReceipt.CREDIT_CHECK_APPROVED then
		   return false;
		endif;
	endforeach;
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
