    <JadeMethod name="transportModeStringToENum" id="c89b9a83-1a20-4b44-ab52-d6be898fd731">
        <source>transportModeStringToENum( _value : String ) : Integer;
// ------------------------------------------
// Created:     12 May 2006 by cnwvu1
//
//15.Apr.2024 navsp1 TFS Bug 62295: EUP | FR 54084 - CallOff Message - "Unknown" Type Release Request Not Created for Zimmer Case.
// ------------------------------------------

vars
	tmpVal	: String;

begin

	tmpVal := _value.toUpper;
	
	if tmpVal.String = TI_TRANSMODE_SHIP_STR.toUpper() then
		return TI_TRANSMODE_SHIP;
	elseif tmpVal.String = TI_TRANSMODE_ROAD_STR.toUpper() then
		return TI_TRANSMODE_ROAD;	
	elseif tmpVal.String = TI_TRANSMODE_RAIL_STR.toUpper() then
		return TI_TRANSMODE_RAIL;
	elseif tmpVal.String = TI_TRANSMODE_UNKNOWN_STR.toUpper() then	//TFS 62295
		return TI_TRANSMODE_UNKNOWN;								//TFS 62295
	else
		return null;
	endif;

end;</source>
        <Parameter name="_value" type="String"/>
