	faultResponse, 
	newFaultResponse : CM_FaultResponse;
	
begin
	self.initialiseActivity();
	
	foreach faultResponse in _allPxyFaultResponses do
		app.myUtilityCA.utlCreateFaultResponse(faultResponse, newFaultResponse, _terminal, _passport);
	endforeach;

	
epilog

end;</source>
