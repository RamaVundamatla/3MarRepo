    <JadeMethod name="setTblResourceText" id="1046bc8f-a103-464f-a8eb-47ac1d977379">
        <source>setTblResourceText(table: CM_DataTable input);
//--------------------------------------------------
// Created:	08 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
	cntrl : Control;
begin
	if self.lastValidRow &gt; table.fixedRows then
		if self.lastValidColumn = self.colResourceType then
			self.tblResources.accessRow(self.lastValidRow).height := 20;			
			cntrl := table.accessCell(self.lastValidRow, self.lastValidColumn).cellControl;
			str := cntrl.CMUI_ListTable.getSelectedFromDisplay();
		elseif self.lastValidColumn = self.colNumTugs then
			cntrl := table.accessCell(self.lastValidRow, self.lastValidColumn).cellControl;
			str := cntrl.TextBox.text;						
		elseif self.lastValidColumn = self.colMoveType then
			cntrl := table.accessCell(self.lastValidRow, self.lastValidColumn).cellControl;
			str := cntrl.ComboBox.text;									
		endif;
		if self.lastValidColumn &lt;&gt; table.column then
			table.accessCell(self.lastValidRow, self.lastValidColumn).text := str;
		else
			table.text := str;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="43d99d8f-443c-4933-acc4-531bbbf44f50">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	05 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;	
	
	self.viewModeOnly := (not app.myCurrentUserCan(self.myTerminal, PmHMSShipMaint));
	self.myHarbour := self.myTerminal.myHarbour;

	self.cmbVessel.isVesselComboByName := self.myTerminal.getConfig(VesselComboByName).Boolean;
	self.cmbShippingAgent.isDisplayByName := self.myTerminal.getConfig(ComboByNameAgent).Boolean;
	self.cmbShippingLine.isDisplayByName := self.myTerminal.getConfig(ComboByNameLine).Boolean;

	if app.myCurrentUserCan(self.myTerminal, Mod_Invoicing) then
		self.lbxResourceList.visible := false;
		self.tblResources.visible := true;

		self.tblResources.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_ResourceForMovement));
		self.tblResources.userInputEnabled := true;
		self.tblResources.accessColumn(self.tblResources.getColumnByRowName(ETRow_MyHarbourResource)).visible := false;	
		self.btnAddResource.visible := true;				
		self.btnDelResource.visible := true;
		self.colResourceType := self.tblResources.getColumnByRowName(ETRow_ResourceTypes);
		self.colNumTugs := self.tblResources.getColumnByRowName(ETRow_NumTugsForMovement);
		self.colMoveType := self.tblResources.getColumnByRowName(ETRow_MoveType);								
	endif;

end;</source>
    </JadeMethod>
