    <JadeMethod name="validateOnQtyWtOnSite" id="e5e0a85e-1867-46eb-8271-ed376cf29276">
        <source>validateOnQtyWtOnSite( _gteRelease : CMGTE_Release );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	ti : CM_TrackedItem;
	tiSet : CM_TISet;
	wt : Decimal[16,4];
	qty : Integer;
	
begin

	create tiSet transient;

	if not self.allTrackedItems.isEmpty then
		self.allTrackedItems.copy( tiSet );
		
	elseif self.myBOL &lt;&gt; null and not self.myBOL.allTrackedItems.isEmpty then
		self.myBOL.allTrackedItems.copy( tiSet );
		
	endif;
	
	foreach ti in tiSet do
		if ti.isOnSite then
		
			//29 Oct 2020	NDL	TFS 49189
			if _gteRelease &lt;&gt; null then
				if _gteRelease.myCargoType &lt;&gt; null and _gteRelease.myCargoType &lt;&gt; ti.myCargoType then
					continue;
				endif;
				if _gteRelease.myProduct &lt;&gt; null and _gteRelease.myProduct &lt;&gt; ti.myProduct then
					continue;
				endif;
				if _gteRelease.operatorCode &lt;&gt; null and _gteRelease.operatorCode &lt;&gt; ti.operatorCode then
					continue;
				endif;
				if _gteRelease.colour &lt;&gt; null and _gteRelease.colour &lt;&gt; ti.getColour then
					continue;
				endif;
				if _gteRelease.commodity &lt;&gt; null and _gteRelease.commodity &lt;&gt; ti.commodity then
					continue;
				endif;
				if _gteRelease.markNumber &lt;&gt; null and _gteRelease.markNumber &lt;&gt; ti.markNumber then
					continue;
				endif;
			endif;
		
			if ti.isBulkByVolume then
				wt := wt + ( ti.totalVolume * ti.getDensity);
			elseif ti.isBulkByWeight then
				wt := wt + ti.totalWeight;
			else
				qty := qty + ti.totalQuantity;
			endif;
		endif;
	endforeach;
	
	if _gteRelease &lt;&gt; null then
		if _gteRelease.myCargoType.isBulkByVolume or _gteRelease.myCargoType.isBulkByWeight then
			if wt &lt; _gteRelease.weight then
				app.raiseCMException(Insuff_quanti_site_this_releas,null,null);
			endif;
		else
			if qty &lt; _gteRelease.totalQuantity then
				app.raiseCMException(Insuff_quanti_site_this_releas,null,null);
			endif;
		endif;
	endif;
	
	
epilog

	delete tiSet;

end;</source>
        <Parameter name="_gteRelease" type="CMGTE_Release"/>
    </JadeMethod>
</Class>
