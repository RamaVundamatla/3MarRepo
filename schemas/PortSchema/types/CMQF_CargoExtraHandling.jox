<Class name="CMQF_CargoExtraHandling" id="43d12475-55ae-46e2-a808-729d938d5b68">
    <superclass name="CMQF_Discrepancy"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="998186f5-8f18-45c9-a669-674a97c92ab8">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 21 September 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
// 21/09/2011	cnwsh3		Initial creation - MES CCMS 1024 PAR28223 - Extra Cargo Handling report
//							Used for the Cargo Extra Hanlding system report.
//----------------------------------------------------------------------
vars
	startTS,
	endTS		: TimeStamp;
	txn			: CM_TITransaction;
	terminal 	: CM_Terminal;
	txnType		: Integer;
	voyage		: CM_Voyage;
	ti			: CM_TrackedItem;
	
begin
	self.initFields();
	//Set the time/date range.
	self.setDefaultStartEndDates(startTS, endTS);
	
	if self.getMyVoyage &lt;&gt; null then
		voyage := self.getMyVoyage;
		if not voyage.archived then
			foreach txnType in self.allTxnTypes do
				voyage.getTITxnsByTypeFromTIs(txnType, 
											  true,
											  true,
											  true,
											  true,
											  startTS, 
											  endTS, 
											  CMQF_FilterReports::checkStatusIncludesObject.name, 
											  self, 
											  _collection);
			endforeach;
			
		endif;
	else
		foreach terminal in self.allTerminals do : terminalLoop
			foreach txnType in self.allTxnTypes do
				terminal.getTITxnsForTypeAll(txnType, startTS, endTS, CMQF_FilterReports::checkStatusIncludesObject.name, self, _collection);
			endforeach;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="a5ed765d-47a8-4de8-bbcb-aeedb4f4b6ea">
        <updating/>
        <source>includesObject(_trx: CM_Edit; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 21 September 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	cargoType : CM_CargoType;
begin
	cargoType := _trx.myTrackedItem.myCargoType;
	
	//returnValue := inheritMethod(_trx, _passport, _breakOut);
	if self.getMyCargoType &lt;&gt; null and self.getMyCargoType &lt;&gt; cargoType then
		return false;
	endif;
	
	//cnwmc5 - 14/01/2013 - uncommented this code as it was causing the report to display incorrect data
	if _trx.yardAllocationMatch &lt;&gt; AllocationStatus_OutOf then
		return false;
	endif;
	
	return true;

epilog
end;</source>
        <access>protected</access>
        <Parameter name="_trx" type="CM_Edit"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFields" id="69a12eca-47b1-4ed2-af94-319acc6503bf">
        <updating/>
        <source>initFields() updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 21 September 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars

begin
	inheritMethod();
	
	self.allTxnTypes.add(TRANS_TYPE_EDIT);

epilog
end;</source>
    </JadeMethod>
</Class>
