    <JadeMethod name="setForShipPortGroups" id="c591a1ea-40da-4fb7-9e95-205bc7a4b1a8">
        <source>setForShipPortGroups(_oldCode: String);
//----------------------------------------------------------------
//	Created:	08 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	spg			: CM_ShipPortGroup;
	lgd			: CM_LineGroupDebtor;
	newLineCode,
	grpCode,
	debtorCode,
	lgdCode		: String;
begin
	
	//only call after making the update to code
	newLineCode := self.code;
	foreach spg in self.shipPortGroups do
		grpCode := spg.code;
		foreach lgd in spg.lineGroupDebtors do
			//code should be
			if lgd.debtor &lt;&gt; null then
				lgdCode	:=	newLineCode &amp; ' ' &amp; grpCode.trimBlanks &amp; ' ' &amp; lgd.debtor.name.trimBlanks;
			else
				lgdCode	:=	newLineCode &amp; ' ' &amp; grpCode.trimBlanks &amp; ' ';
			endif;
			if lgd.code &lt;&gt; lgdCode then
				lgd.setCode(lgdCode);	
			endif;
		endforeach;
	endforeach;

end;</source>
        <Parameter name="_oldCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1357de7b-5c71-4e6a-aec0-c49f36a66b2c">
        <updating/>
        <source>setForUpdate(_proxy :CM_ShippingLine) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/04/2013	cnwcs5		CCMS POL 2097 / par 31259
// 07 June 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 14 Aug 2023 	navhl20 ChangeRequest 56642: MTN - Invoicing Shipping Line / Debtor Link
// ---------------------------------------------------------------------------

vars
	oldCode, newCode	: String;
	
begin
	newCode := _proxy.code[1:4].trimBlanks;
	oldCode := self.code;
	
	if _proxy.myDebtor &lt;&gt; self.myDebtor then 									//14.8.2023 navhl20 #56642
		app.myRoot.causeEvent(EVENT_DEBTORNODE_UPDATE,false,self.myDebtor);
		app.myRoot.causeEvent(EVENT_DEBTORNODE_UPDATE,false,_proxy.myDebtor);
	endif; 
	self.myDebtor := _proxy.myDebtor;											//14.8.2023 navhl20 #56642	
	
	if oldCode &lt;&gt; newCode then
		// par 31259 - make sure xlations updated with new code
		self.updateXlations_Code (newCode, oldCode, self.allXlations);
		
		self.code := newCode;
	endif;
	
	//need to update the LGD's on ship port groups //PAR 11351 - do every time
	self.setForShipPortGroups(oldCode);
	
	self.description 			:= _proxy.description[1:40].trimBlanks;
	self.isNotAvailableForEntry := _proxy.isNotAvailableForEntry;
	self.colour := _proxy.colour;	// 07.06.2022 navtnr20 TFS 53204
	self.allContacts.clear();
	_proxy.allContacts.copy(self.allContacts);
	if self.myDebtor &lt;&gt; null then 												//14.8.2023 navhl20 #56642
		self.myDebtor.setShipLineGroupDebtor();
	endif; 

	self.setForVoyageOperators(); // PAR 9117
end;</source>
        <Parameter name="_proxy" type="CM_ShippingLine"/>
    </JadeMethod>
    <JadeMethod name="setForVoyageOperators" id="632748a8-38f6-42ab-af69-1bf10d6c69df">
        <source>setForVoyageOperators();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		PAR 9117
//
// ---------------------------------------------------------------------------
vars
	aVoyage : CM_Voyage;
begin
	foreach  aVoyage in self.allVoyages 
		where not aVoyage.archived do
		aVoyage.setForShippingLineOperators(self); // PAR 9117
	endforeach;
end;</source>
    </JadeMethod>
