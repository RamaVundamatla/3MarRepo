    <JadeMethod name="translateForm" id="b160bbf3-0c4e-4808-ac4b-6854ed8b40c9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 September 2018 08:25:55.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022995, locale);
	btnCancelChange.translateCaption(Xlat_0022996, locale);
	btnSaveChange.translateCaption(Xlat_0022997, locale);
	btnSelectAll.translateCaption(Xlat_0022998, locale);
	lblProperties.translateCaption(Xlat_0022999, locale);
	mnuColourLegends.translateCaption(Xlat_0023000, locale);
	mnuContext.translateCaption(Xlat_0023001, locale);
	mnuInspectObject.translateCaption(Xlat_0023002, locale);
end;</source>
    </JadeMethod>
</GUIClass>
