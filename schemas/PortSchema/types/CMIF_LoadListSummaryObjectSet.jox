<CollClass name="CMIF_LoadListSummaryObjectSet" id="486284fc-52c6-44de-85a4-07ab42438b29">
    <loadFactor>98</loadFactor>
    <memberType name="CMIF_LoadListSummaryObject"/>
    <superclass name="ObjectSet"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="query"/>
    <JadeMethod name="getCaptionDisplay" id="259cfb4a-0caa-432b-bb58-507e983af43d">
        <source>getCaptionDisplay():String;
// --------------------------------------------------------------------------------
// Created:		14 December 2005 by cnwdad1
//
// Purpose:		Returns a string that can be used to display a description which
//				summarizes the receiver's contents.
//
// Parameters:	None
//
// Returns:		A string containing a description of the receiver's contents.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	summaryObj		: CMIF_LoadListSummaryObject;
	allSummariesObj	: DynaDictionary;
	memberObj		: Object;
	displayValue	: String;
	lastImex		: String;
	lastPort		: String;
	lastIsoCode		: String;
	isNewGroup		: Boolean;
	
begin
	create allSummariesObj transient;
	allSummariesObj.setMembership(CMIF_LoadListSummaryObject);
	allSummariesObj.addMemberKey(CMIF_LoadListSummaryObject::imexStatusDescription.name, false, true);
	allSummariesObj.addMemberKey(CMIF_LoadListSummaryObject::dischargePort.name, false, true);
	allSummariesObj.addMemberKey(CMIF_LoadListSummaryObject::isoGroupingCode.name, false, true);
	allSummariesObj.endKeys(false);
	self.copy(allSummariesObj);
	
	lastImex	:=	null;
	lastPort	:=	null;
	lastIsoCode	:=	null;
	isNewGroup	:=	false;
	
	foreach memberObj in allSummariesObj do
		summaryObj	:=	memberObj.CMIF_LoadListSummaryObject;
		
		if lastImex &lt;&gt; summaryObj.imexStatusDescription
		or lastPort &lt;&gt; summaryObj.dischargePort
		then
			isNewGroup	:=	true;
			lastImex	:=	summaryObj.imexStatusDescription;
			lastPort	:=	summaryObj.dischargePort;
			
			if displayValue = null then
				displayValue	:=	lastImex &amp; "/" &amp; lastPort &amp; "/";
			else
				displayValue	:=	displayValue &amp; ":" &amp; lastImex &amp; "/" &amp; lastPort &amp; "/";
			endif;
		endif;
		
		if isNewGroup then
			displayValue	:=	displayValue &amp; summaryObj.isoGroupingCode;
		else
			displayValue	:=	displayValue &amp; "," &amp; summaryObj.isoGroupingCode;
		endif;
		
		if isNewGroup then
			isNewGroup	:=	false;
		endif;
	endforeach;
	
	return displayValue &amp; " - ";
epilog
	delete allSummariesObj;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
