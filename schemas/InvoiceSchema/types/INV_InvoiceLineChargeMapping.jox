	app.cmsBeginLoad(ls);

	mapTable.columns := 1;
	mapTable.column := 1;
	mapTable.row := 1;
	mapTable.fixedRows := 1;
	
	dict := app.myRoot.allStevedores;
	column := 1;
	pd.progress.partsInJob := dict.size;
	
	foreach steve in dict discreteLock do
		if steve.notAvailableForEntry then
			continue;
		endif;
		if not global.isValidObject(steve) then
			continue;
		endif;
		
		if self.myCurrentDebtorType.code  =  CM_DebtorType.DT_STEVEDORE_VOYAGE then //04.11.2020 cnwma1 TFS #50112
			if steve &lt;&gt; self.myCurrentParentObject.CM_Stevedore then
				continue;
			endif;
		endif;

		mapTable.columns := mapTable.columns + 1;
		column := mapTable.columns;
