    <JadeMethod name="setupForm" id="4ca66494-f6a5-4f44-96ff-1a9a856197bb">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/06/2009	consw1		PAR20125 - Wagon Enquiry does not show all selected wagons
// 23/08/2022 	navsj20		ChangeRequest 54281: EUP - Wagon Track Planning
// 25 Aug 2022 	navhl20 	ChangeRequest 54281: EUP - Wagon Track Planning
// 01 Aug 2023	jlizm1		TFS 59215 Wagon maintenance notifications
// ---------------------------------------------------------------------------

vars

begin
	self.usesQueryFrame := true;

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.useTableSorting := true;
	self.useTableInfo := true;
	self.staStatusBar.visible := true;	//23 Aug 2022	navsj20	TFS 54281
	inheritMethod();
	self.myAssistant.comboBoxTrain(self.cmbTrain, self.myCurrentTrain, true, false, false);

	self.setCaption(app.getErrorString(Wagon) &amp; " " &amp; app.getErrorString(Enquiry));
	self.setNavigatorHeading(self.caption);
	self.initTableData(ETDef_WagonList);	
//	self.tblData.accessColumn(1).width := 130;
	self.mnuContextColourLegend.visible := false;
	self.tblData.autoSize := 2;
	self.tblData.stretch := 1;
	self.tblInfo.rows := 0;
	self.buildComboAreas();
	
	//12/08/2010 cnwdz2 25396
	self.cmbOrigin.myAssistant 	:= self.myAssistant;
	self.cmbOrigin.isRail       := true;
	self.cmbOrigin.bubbleHelp   := app.getErrorString(BUBHELP_WAGONORGPORT);
	
	//11/08/2010 cnwdz2	25317
	self.cmbDestination.myAssistant 	:= self.myAssistant;
	self.cmbDestination.isRail			:= true;
	self.cmbDestination.bubbleHelp := app.getErrorString(BUBHELP_WAGONDESTPORT);

	if not self.allWagons.isEmpty() then
//		self.myCurrentTrain := self.allWagons.first.myTrainInwards;
//		self.cmbTrain.listObject := self.myCurrentTrain;
		self.doQuery();
		self.allWagons.clear();
		
		if self.confirmInMode then
			self.caption := app.getErrorString1(Confirm_train_WithParam, self.myCurrentTrain.code);
			self.showConfirmFrame();
		endif;
	endif;
	
	self.mnuContextSetTransit.caption := app.getErrorString(Set_All_cargo_in_transit);
	
	self.beginClassNotification(CM_Wagon,
								false,
								self.myTerminal.getTerminalEvent(Wagon_Create_Event),
								Response_Continuous,
								self.NOTE_EVENT_TAG_WAGON);
	
	self.beginClassNotification(CM_Train,
								false,
								Object_Delete_Event,
								Response_Continuous,
								self.NOTE_EVENT_TAG_TRAIN);
								
								
								
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNew.enabled:= false;
		self.btnDelete.enabled:= false;
		self.btnRemarks.enabled:= false;
	endif;
								
end;</source>
    </JadeMethod>
    <JadeMethod name="setupMoveModeCtrl" id="b0dbe791-507d-46b1-92a6-5d19e65b8a83">
        <updating/>
        <source>setupMoveModeCtrl() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/08/2022 navsj20	ChangeRequest 54281: EUP - Wagon Track Planning


*/

vars

	index : Integer;
	cntrl : Control;
	staLineMoveMode : CMUI_GridAreaStatusLine;
	top : Real;

begin
	foreach index in 1 to controlCount do
		cntrl := controls(index);
		if cntrl.isKindOf(CMUI_GridAreaStatusLine) then
			staLineMoveMode :=  cntrl.CMUI_GridAreaStatusLine;
			break;
		endif;
	endforeach;
	
	if staLineMoveMode = null then

		create staLineMoveMode transient;

		self.addControl(staLineMoveMode);
		staLineMoveMode.name := "frmStaMoveMode";
		
		staLineMoveMode.doBuildMenuMove();
		staLineMoveMode.sendMsg("createGraphics");
		
		staLineMoveMode.transparent := true;
		staLineMoveMode.myFrameMoveMode.transparent := false;
		staLineMoveMode.myFrameDisplayMode.transparent := true;
		staLineMoveMode.myFrameCaption.transparent := true;
		
		staLineMoveMode.alignContainer := 0;
		staLineMoveMode.myFrameMoveMode.alignContainer := 0;
		staLineMoveMode.myFrameDisplayMode.alignContainer := 0;
		staLineMoveMode.myFrameCaption.alignContainer := 0;
		
		staLineMoveMode.bevelInnerWidth := 0;
		staLineMoveMode.myFrameMoveMode.bevelInnerWidth := 0;
		staLineMoveMode.myFrameDisplayMode.bevelInnerWidth := 0;
		staLineMoveMode.myFrameCaption.bevelInnerWidth := 0;
		
		staLineMoveMode.bevelOuterWidth := 0;
		staLineMoveMode.myFrameMoveMode.bevelOuterWidth := 0;
		staLineMoveMode.myFrameDisplayMode.bevelOuterWidth := 0;
		staLineMoveMode.myFrameCaption.bevelOuterWidth := 0;
		
		staLineMoveMode.boundaryWidth := 0;
		staLineMoveMode.myFrameMoveMode.boundaryWidth := 0;
		staLineMoveMode.myFrameDisplayMode.boundaryWidth := 0;
		staLineMoveMode.myFrameCaption.boundaryWidth := 0;
				
		staLineMoveMode.myFrameMoveMode.enabled := true;
		staLineMoveMode.myFrameDisplayMode.enabled := false;
		staLineMoveMode.myFrameCaption.enabled := false;
		
		staLineMoveMode.myFrameMoveMode.visible := true;		
		staLineMoveMode.myFrameDisplayMode.visible := false;
		staLineMoveMode.myFrameCaption.visible := false;
		
		staLineMoveMode.myFrameMoveMode.height := 13;
		staLineMoveMode.myFrameDisplayMode.height := 10;
		staLineMoveMode.myFrameCaption.height := 10;
		staLineMoveMode.height := 13;
		
		staLineMoveMode.parent := self.staStatusBar;
		
		staLineMoveMode.myFrameMoveMode.top := 0;
		staLineMoveMode.myFrameMoveMode.left := staLineMoveMode.myFrameMoveMode.left - 15;		
	
	else
		staLineMoveMode.width := staStatusBar.width;
		staLineMoveMode.myFrameMoveMode.left := staLineMoveMode.width - 110;
			
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showCargo" id="81756c16-1c5b-4fc4-b06e-561a0c60df1e">
        <source>showCargo(_inward : Boolean);
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	wagon : CM_Wagon;
	obj : Object;
	objArray : CM_TIArray;
begin


	create objArray transient;
	
	foreach obj in self.tblData.allSelectedObjects discreteLock do
		wagon := obj.CM_Wagon;
		wagon.getAllTrackedItems(_inward, objArray, (wagon.myTerminalDeparted &lt;&gt; null));
	endforeach;
	
	if objArray.isEmpty() then
		app.msgBox(app.getErrorString(No_Cargo_For_Wagon), app.getErrorString(Cargo_Enquiry), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	else
		self.myAssistant.showCargoEnquiryForTIs(objArray[1].CM_TrackedItem, objArray, self.myMasterMenuAction, false);
	endif;

epilog
	delete objArray;
end;</source>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showConfirmFrame" id="da6aadf4-37d4-4c6f-a46a-2cb8eefe596c">
