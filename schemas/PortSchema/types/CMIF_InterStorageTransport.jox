    <JadeMethod name="action" id="4f894af6-5b0d-48dd-9b3e-eca976c1ccdc">
        <source>action(_passport : CM_Passport input);
//--------------------------------------------------
// Created:	27 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	ti : CM_TrackedItem;
	tiUpdateCntrl : CMIF_TIUpdateController;
begin

	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	
	foreach ti in self.allTrackedItems do
		exclusiveLock(ti);
		ti.performIST(self, tiUpdateCntrl, _passport);
	endforeach;

epilog
	delete tiUpdateCntrl;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="b8c1f5f3-3aff-49b6-95ab-766e76fa1850">
        <updating/>
        <source>create() updating;
//--------------------------------------------------
// Created:	27 January 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.businessUnitMustChange := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="validate" id="528236cd-f5a9-4572-b4eb-aaa69e7129ad">
        <source>validate(_passport : CM_Passport input);
//--------------------------------------------------
// Created:	27 January 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.imexStatus = TI_IMEX_STATUS_EXPORT then
		if self.myVoyage = null then
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_IST_CHANGE_NOVOYAGE, null, null);
		endif;
		//if app.myRoot.allPorts[self.dischargePort] = null then
		if app.myRoot.allPorts[self.dischargePort] = null then
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_IST_CHANGE_NOVOYAGE, null, null);
		endif;
	endif;

	if _passport.myTerminal.companies[self.companyCode] = null then
		app.setContinueCMExceptions(false);
	//	app.raiseCMException1(REQUIRED_FIELD, 'Business Unit', ETRow_CompanyCode, null);
		app.raiseCMException(Input_required_field_BusUnit, ETRow_CompanyCode, null); // cnwdb2	PAR 35364


	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
