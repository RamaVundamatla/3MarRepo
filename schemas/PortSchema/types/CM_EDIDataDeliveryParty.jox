    <JadeMethod name="getEDITIType" id="f0804efa-00f2-4b06-8496-e52038d55cd2">
        <source>getEDITIType(_ediDataType: Integer): Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2025	jlier1	Initial creation

*/

vars

begin
	if _ediDataType =  EDIDataType_DeliveryParty then	//17 Nov 2016	NDL	TFS 2843 / 2604
		return CM_EDIDeliveryPartyTI;
	elseif _ediDataType =  EDIDataType_Address then
		return CM_EDIAddressTI;
	else
		return CM_EDIDeliveryPartyTI;
	endif;


epilog

end;</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
