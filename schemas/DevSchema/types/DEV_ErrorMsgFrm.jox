    <JadeMethod name="textFound" id="2e86bae7-a354-42fc-82fd-9bdfdf5cde41">
        <source>textFound(_text : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:     17 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpText	: String;
	pos		: Integer;

begin

	if (not self.caseSensitive) then
		tmpText := _text.toUpper;
	else
		tmpText := _text;
	endif;

	if tmpText.pos(findTxt, 1) &gt; 0 then
	   	return true;
	endif;

	return false;

end;</source>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
