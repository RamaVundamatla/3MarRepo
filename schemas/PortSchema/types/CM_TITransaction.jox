    <JadeMethod name="getCalcTypeForTransaction" id="f997300c-f282-49e3-9ab3-595bad3322aa">
        <source>getCalcTypeForTransaction(): CM_CalculationType;
/*
Purpose:			
Date		Who		Reason
30 December 2014	cnwab1	Initial creation
*/

vars
	invLineDesc:  CM_InvoiceLineDesc;
	aSBController : CMIF_ServiceBroker;
	idx : Integer;
	aServ : CM_Service;
	bu : CM_Bank;
	
begin
	bu := self.getBusinessUnitObject();

	create aSBController transient;
	aSBController.myTransaction := self;
	
	bu.getInvoiceLineDescForXaction(aSBController);

	foreach invLineDesc in aSBController.allInvoiceLineTypes discreteLock do
		aServ := invLineDesc.services.first;
		if aServ &lt;&gt; null and aServ.myCalculationType &lt;&gt; null then
			return aServ.myCalculationType;
		endif;
	endforeach;
	return null;
	
epilog
	delete aSBController;
end;</source>
        <ReturnType type="CM_CalculationType"/>
    </JadeMethod>
