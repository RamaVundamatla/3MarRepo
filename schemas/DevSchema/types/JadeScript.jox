    <JadeMethod name="ndlDeleteTrucks" id="78bec536-0af7-4934-aac2-de8285132040">
        <source>ndlDeleteTrucks();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 September 2019	jlgndl1	Initial creation

*/

vars

	term : CM_Terminal;
	roadJob : CM_RoadJob;
	vehicle : CM_Vehicle;
	roadJobsToCleanup : CM_RoadJobSet;
	wle : CM_WorkListEntry;
	reason : String;
	result : Integer;
	wleArray : CM_WLEArray;
	gateLaneOut : CM_GateAreaLaneController;

begin

	term := CM_Root.firstInstance.allTerminals.getAtKey("T4");
	app.myPassport.setMyTerminal( term );

	create roadJobsToCleanup transient;
	create wleArray transient;
	
	foreach roadJob in CM_RoadJob.instances do
		if roadJob.myTerminal &lt;&gt; term then
			continue;
		endif;
		if roadJob.dwellTime &lt; 50000 then
			continue;
		endif;
		if roadJob.myVehicleVisit = null then
			continue;
		endif;
		if roadJob.myVehicleVisit.isBulkGateVVR then
			continue;
		endif;
		
		roadJobsToCleanup.addNoDuplicates( roadJob, false );
		
	endforeach;
	
	reason := "Clean up, too old.";
	
	foreach roadJob in roadJobsToCleanup do	
		foreach wle in roadJob.workListEntries where wle.status = WLE_UNACTIONED do
			wleArray.add( wle );	
		endforeach;	
	endforeach;
	
	foreach wle in wleArray do

		while true do
			app.myTrxDA.trxDeleteJobEntry(wle, reason, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog('Road WLE delete', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile; 
	
	endforeach; 
	
	roadJobsToCleanup.clear();
	
	foreach roadJob in CM_RoadJob.instances do
		if roadJob.myTerminal &lt;&gt; term then
			continue;
		endif;
		if roadJob.dwellTime &lt; 50000 then
			continue;
		endif;
		if roadJob.myVehicleVisit = null then
			continue;
		endif;
		if roadJob.myVehicleVisit.isBulkGateVVR then
			continue;
		endif;
		
		roadJobsToCleanup.addNoDuplicates( roadJob, false );
		
	endforeach;
	
	foreach roadJob in roadJobsToCleanup do	
		if roadJob.isCompleteForExit then
			while true do
				app.myTrxDA.trxVehicleRoadExit(roadJob.myVehicle, app.myPassport);
				if (not app.myPassport.trxCompletedOK) then
					result:=app.showErrorWarningDialog("Gate Out ", app.myPassport, ErrWarnMode_AddUpdate+ ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
						result = IDOK then
						app.myPassport.warningsAcknowledged     := true;
						continue;
					else
						break;
					endif;
				endif;
				break;
			endwhile;
		endif;
	endforeach;
		

	
epilog

	delete roadJobsToCleanup;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlDepartTrains" id="354639b1-c954-4ff8-929f-955f2cf5a390">
        <source>ndlDepartTrains();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2019	jlgndl1	Initial creation

*/

vars

	term : CM_Terminal;
	train : CM_Train;
	arrivedBefore : Date;
	trainsToDepart : CM_TrainSet;

begin

	create trainsToDepart transient;

	term := CM_Root.firstInstance.allTerminals.getAtKey("T4");
	app.myPassport.setMyTerminal( term );
	
	arrivedBefore := "01 Jan 2017".Date;
	
	foreach train in term.allTrainsOnTerminal do
		if train.isNullTrain then
			continue;
		endif;
		if not train.arrivalDT.Date.isValid then
			continue;
		endif;
		if train.arrivalDT.Date &gt;= arrivedBefore then
			continue;
		endif;
		trainsToDepart.addNoDuplicates( train, false );
	endforeach;
	
	trainsToDepart.inspectModal();

epilog

	delete trainsToDepart;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlFind6" id="9875a945-e8bd-47a9-8731-02e24d9cc3f1">
        <source>ndlFind6();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2016	cnwndl1	Initial creation

*/

vars

	schema : Schema;
	classOfObjBeingDeleted : Class;
	classColl : ClassColl;
	class : Class;
	iterClass : Iterator;
	
	propColl : PropertyNDict;
	iterProp : Iterator;
	prop : Property;
	ref : Reference;
	collClass : CollClass;
	
	propName : String;
	collTypeClass : Class;
	collClassColl : ClassColl;
	ignoreInversedRefs : Boolean;
	
	refStringArray : StringArray;
	refString : String;
	classString : String;
	propString : String;
	dotPos : Integer;
	
	objArray : ObjectArray;
	obj : Object;
	iterInst : Iterator;
	value : Any;
	count : Integer;
	
	resultsStrArray : String200Array;
	resultsStr : String;
	//cc : CnCntrl;

begin

	create refStringArray transient;
	create resultsStrArray transient;

	ignoreInversedRefs := false;

	schema := currentSchema;
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;
	classOfObjBeingDeleted := CM_Operator;
	
	classColl := schema.getAllClasses(false);
	create collClassColl transient;
	
	iterClass := classColl.createIterator;
	while iterClass.next( class ) do
		if not class.inheritsFrom( CM_Object ) then
			continue;
		endif;
		
		if class = CM_TrackedItem or class.inheritsFrom( CM_TrackedItem ) then
			continue;
		endif;
		
		propColl := class.getProperties();
		iterProp := propColl.createIterator;
		while iterProp.next ( prop ) do
		
			if prop.isKindOf(Reference) then
				continue;
			endif;
			
			propName := prop.name.toUpper;
			if propName = "OPERATOR"
			or propName = "OPERATORCODE"
			or propName = "OPER"
			then
	//			refStringArray.add( class.name &amp; "." &amp; prop.name );
			elseif propName.pos("PROPERT",1) &gt; 0 then
			elseif propName.pos("OPERATORTERMINAL",1) &gt; 0 then
			elseif propName.pos("CARGOOPERATION",1) &gt; 0 then
			elseif propName.pos("MYOPERTOR",1) &gt; 0 then
			elseif propName.pos("OPER",1) &gt; 0 then
				//resultsStr := class.name &amp; "." &amp; prop.name;
				refStringArray.add( class.name &amp; "." &amp; prop.name );
			endif;
			
		endwhile;
		delete iterProp;
		
	endwhile;
	delete iterClass;

	create objArray transient;
	foreach refString in refStringArray do
		
		dotPos := refString.pos(".",1);
		classString := refString[ 1 : dotPos - 1];
		propString := refString[ dotPos + 1 : end];
		class := schema.getClass( classString );
		
		objArray.clear();
		class.allInstances(objArray, 0, true);
		if objArray.isEmpty then
			resultsStrArray.add( refString &amp; " isEmpty" );
		else
			count := 0;
			prop := class.getProperty(propString);
			iterInst := objArray.createIterator;
			if prop.getType.inheritsFrom( Collection ) then
				while iterInst.next( obj ) do
					value := obj.getPropertyValue(propString);
					if value = null or value.Collection.isEmpty then
						continue;
					else
						count := count + 1;
					endif;
				endwhile;
			else
				while iterInst.next( obj ) do
					value := obj.getPropertyValue(propString);
					if value = null then
						continue;
					else
						count := count + 1;
					endif;
				endwhile;
			endif;
			if count = 0 then
				resultsStrArray.add( refString &amp; " isEmpty" );
			else
				resultsStrArray.add( refString &amp; " " &amp; count.String &amp; " uses found." );
			endif;
		endif;
		
	endforeach;
	
	
	foreach resultsStr in resultsStrArray do
		app.writeLog(resultsStr, LogINFO);
	endforeach;
	
epilog

	delete classColl;
	delete iterClass;
	delete iterProp;
	delete collClassColl;
	delete iterInst;
	delete resultsStrArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlFind7InvalidObjRef" id="48a287c9-bddf-40f9-9627-b3da217db191">
        <source>ndlFind7InvalidObjRef();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2016	cnwndl1	Initial creation

*/

vars


	class : Class;
	iterClass : Iterator;
	
	propColl : PropertyNDict;
	iterProp : Iterator;
	prop : Property;
	ref : Reference;
	
	
	propName : String;
	collTypeClass : Class;
	collClassColl : ClassColl;
	ignoreInversedRefs : Boolean;
	
	refString : String;
	
	obj : Object;
//	iterInst : Iterator;
	value : Any;
	count : Integer;
	
	resultsStrArray : String200Array;
	resultsStr : String;
	
	propClass : Type;
	
	objArray2 : ObjectArray;
	limitedClassColl : ClassColl;
	invalid : Boolean;
	anyObj : Object;
	iterObj : Iterator;
	collection : Collection;
	edition : Integer;
	collClass : CollClass;
	iterSubObj : Iterator;

begin

	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	
	app.writeLog("Find invalid Objects...", LogINFO);
	write "Find invalid Objects...  " &amp; app.actualTimeServer.String;

	create objArray2 transient;
	CM_Object.allInstances(objArray2, 0, true);
	app.writeLog(objArray2.size.String &amp;  " objects to check", LogINFO);
	write objArray2.size.String &amp;  " objects to check...  " &amp; app.actualTimeServer.String;
	
	create limitedClassColl transient;
	
	on Exception do app.handleDeletedObject(exception,obj,invalid);
	foreach obj in objArray2 do
		limitedClassColl.addExclusive(obj.class);
	endforeach;
	on Exception do null;
	
	app.writeLog(limitedClassColl.size.String &amp;  " classes to check", LogINFO);
	write limitedClassColl.size.String &amp;  " classes to check...  " &amp; app.actualTimeServer.String;

	ignoreInversedRefs := true;

	on Exception do app.handleDeletedObject(exception,anyObj,invalid);
	
	create resultsStrArray transient;

	iterClass := limitedClassColl.createIterator;
	while iterClass.next( class ) do
		if not class.inheritsFrom( CM_Object ) then
			continue;
		endif;
		
		propColl := class.getProperties();
		iterProp := propColl.createIterator;
		while iterProp.next ( prop ) do
			if not prop.isKindOf(Reference) then
				continue;
			endif;
			ref := prop.Reference;
			if ignoreInversedRefs then
				if ref.isKindOf(ExplicitInverseRef) then
					continue;
				endif;
			endif;
			
			propClass := prop.getType;
			if propClass &lt;&gt; null and  prop.getType.inheritsFrom( Collection ) then
				iterObj := class.instances.createIterator;
				while iterObj.next( obj ) do
					anyObj := obj.getPropertyValue(prop.name).Object;
					if anyObj = null then
						continue;
					endif;
					invalid := false;
					edition := anyObj.edition;
					if invalid then
						resultsStr := obj.String &amp; " check " &amp; prop.name &amp; " = " &amp; anyObj.String;
						resultsStrArray.add( resultsStr );
					endif;
					collClass :=  prop.getType.CollClass;
					propClass := collClass.getMemberType;
					if propClass &lt;&gt; null and propClass = CM_Object or propClass.inheritsFrom( CM_Object ) then
						collection := anyObj.Collection;
						if collection.isEmpty then
							continue;
						endif;
						iterSubObj := collection.createIterator;
						while iterSubObj.next( anyObj ) do
							if anyObj = null then
								resultsStr := obj.String &amp; " check " &amp; prop.name &amp; " = null member";
								resultsStrArray.add( resultsStr );
								continue;
							endif;
							invalid := false;
							edition := anyObj.edition;
							if invalid then
								resultsStr := obj.String &amp; " check " &amp; prop.name &amp; " = invalid member " &amp; anyObj.String;
								resultsStrArray.add( resultsStr );
							endif;
						endwhile;
						delete iterSubObj;
					endif;
					
				endwhile;
				delete iterObj;
				
			elseif propClass &lt;&gt; null and propClass = CM_Object or propClass.inheritsFrom( CM_Object ) then
				iterObj := class.instances.createIterator;
				while iterObj.next( obj ) do
					anyObj := obj.getPropertyValue(prop.name).Object;
					if anyObj = null then
						continue;
					endif;
					invalid := false;
					edition := anyObj.edition;
					if invalid then
						resultsStr := obj.String &amp; " check " &amp; prop.name &amp; " = " &amp; anyObj.String;
						resultsStrArray.add( resultsStr );
					endif;
				endwhile;
				delete iterObj;
			
			endif;
			
		endwhile;
		delete iterProp;
		
	endwhile;
	delete iterClass;
	
	
	foreach resultsStr in resultsStrArray do
		app.writeLog(resultsStr, LogINFO);
	endforeach;

	
	resultsStrArray.inspectModal();
	
epilog

	delete iterClass;
	delete iterProp;
	delete collClassColl;
	delete resultsStrArray;
	delete objArray2;
	delete limitedClassColl;
	delete iterSubObj;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlFindAllReferences" id="e2b60238-27ad-4360-b73a-fa94ecb9923b">
        <source>ndlFindAllReferences();
/*

Purpose:	Find persistent reference usage to CM_Operator...		

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2016	cnwndl1	Initial creation	TFS 1872

*/

vars

	schema : Schema;
	classOfObjBeingChecked : Class;
	classColl : ClassColl;
	class : Class;
	iterClass : Iterator;
	
	propColl : PropertyNDict;
	iterProp : Iterator;
	prop : Property;
	ref : Reference;
	collClass : CollClass;
	
	propName : String;
	collTypeClass : Class;
	collClassColl : ClassColl;
	ignoreInversedRefs : Boolean;
	
	refStringArray : StringArray;
	refString : String;
	classString : String;
	propString : String;
	dotPos : Integer;
	
	objArray : ObjectArray;
	obj : Object;
	iterInst : Iterator;
	value : Any;
	count : Integer;
	
	resultsStrArray : String200Array;
	resultsStr : String;
	

begin

	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	create refStringArray transient;
	create resultsStrArray transient;

	ignoreInversedRefs := false;

	schema := currentSchema;
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;
	classOfObjBeingChecked := CM_Terminal;
	
	classColl := schema.getAllClasses(false);
	create collClassColl transient;

	iterClass := classColl.createIterator;
	while iterClass.next( class ) do
		if not class.inheritsFrom( CM_Object ) then
			continue;
		endif;
		
		propColl := class.getProperties();
		iterProp := propColl.createIterator;
		while iterProp.next ( prop ) do
			if not prop.isKindOf(Reference) then
				continue;
			endif;
			ref := prop.Reference;
			if ignoreInversedRefs then
				if ref.isKindOf(ExplicitInverseRef) then
					continue;
				endif;
			endif;
			
			if prop.getType = classOfObjBeingChecked then
				refStringArray.add( class.name &amp; "." &amp; prop.name );
				
			elseif prop.getType.inheritsFrom( Collection ) then
				collClass :=  prop.getType.CollClass;
				if collClass.getMemberType = classOfObjBeingChecked then
					refStringArray.add( class.name &amp; "." &amp; prop.name );
					collClassColl.addExclusive( collClass );
				endif;
			
			endif;
			
		endwhile;
		delete iterProp;
		
	endwhile;
	delete iterClass;
	
	foreach collTypeClass in collClassColl do
		iterClass := classColl.createIterator;
		while iterClass.next( class ) do
			if not class.inheritsFrom( CM_Object ) then
				continue;
			endif;
			
			propColl := class.getProperties();
			iterProp := propColl.createIterator;
			while iterProp.next ( prop ) do
				if not prop.isKindOf(Reference) then
					continue;
				endif;
				ref := prop.Reference;
				if ignoreInversedRefs then
					if ref.isKindOf(ExplicitInverseRef) then
						continue;
					endif;
				endif;
				
				if prop.getType = collTypeClass then
					refStringArray.add( class.name &amp; "." &amp; prop.name );
				endif;
				
			endwhile;
			delete iterProp;
			
		endwhile;
		delete iterClass;
	endforeach;
/*	
	iterClass := classColl.createIterator;
	while iterClass.next( class ) do
		if not class.inheritsFrom( CM_Object ) then
			continue;
		endif;
		
		propColl := class.getProperties();
		iterProp := propColl.createIterator;
		while iterProp.next ( prop ) do
			propName := prop.name.toUpper;
			if propName = "OPERATOR"
			or propName = "OPERATORCODE"
			or propName = "OPER"
			then
				refStringArray.add( class.name &amp; "." &amp; prop.name );
			endif;
			
		endwhile;
		delete iterProp;
		
	endwhile;
	delete iterClass;
*/	
	create objArray transient;
	foreach refString in refStringArray do
		
		dotPos := refString.pos(".",1);
		classString := refString[ 1 : dotPos - 1];
		propString := refString[ dotPos + 1 : end];
		class := schema.getClass( classString );
		
		objArray.clear();
		class.allInstances(objArray, 0, true);
		if objArray.isEmpty then
			resultsStrArray.add( refString &amp; " isEmpty" );
		else
			count := 0;
			prop := class.getProperty(propString);
			iterInst := objArray.createIterator;
			if prop.getType.inheritsFrom( Collection ) then
				while iterInst.next( obj ) do
					value := obj.getPropertyValue(propString);
					if value = null or value.Collection.isEmpty then
						continue;
					else
						count := count + 1;
					endif;
				endwhile;
			else
				while iterInst.next( obj ) do
					value := obj.getPropertyValue(propString);
					if value = null then
						continue;
					else
						count := count + 1;
					endif;
				endwhile;
			endif;
			if count = 0 then
				resultsStrArray.add( refString &amp; " isEmpty" );
			else
				resultsStrArray.add( refString &amp; " " &amp; count.String &amp; " uses found." );
			endif;
		endif;
		
	endforeach;
	
	
	foreach resultsStr in resultsStrArray do
		app.writeLog(resultsStr, LogINFO);
	endforeach;
	
	
	resultsStrArray.inspectModal();
	
epilog

	delete classColl;
	delete iterClass;
	delete iterProp;
	delete collClassColl;
	delete iterInst;
	delete resultsStrArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlFindClassesWithMuchData" id="bd2fc0bc-f73b-4dc8-bc8b-c012e86ba13e">
        <source>ndlFindClassesWithMuchData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2016	cnwndl1	Initial creation

*/

vars

	schema : Schema;
	class : Class;
	collClassColl : ClassColl;
	obj : Object;
	count : Integer;
	objArray2 : ObjectArray;
	limitedClassColl : ClassColl;
	iterObj : Iterator;
	collClass : CollClass;
	classes : ClassNDict;
	size : Integer;
	
	cleanedUpClasses : ClassNDict;
	
	stateRef : CM_StateReference;
	parent : Object;
	invalid : Boolean;
	edition : Integer;
	
	excludedClasses : ClassNDict;

begin

	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	schema := currentSchema.getSchema("PortSchema");
	class := CM_Object;
	
	create cleanedUpClasses transient;
	cleanedUpClasses.add( CM_ActivityHistUnitTest );
	cleanedUpClasses.add( CM_ActivityHistoryGeneralSys );
	cleanedUpClasses.add( CM_ActivityHistoryGeneral );
	cleanedUpClasses.add( CM_SystemAlert );
	cleanedUpClasses.add( CMEVT_Login );
	cleanedUpClasses.add( CMEVT_Logout );
	cleanedUpClasses.add( CMEVT_OverriddenWarning );
	cleanedUpClasses.add( CM_MachineLogOnOffHistory );
	cleanedUpClasses.add( CM_MachineMoveHistory );
	cleanedUpClasses.add( CMEVT_TruckEvent );
	cleanedUpClasses.add( CM_BulkRelease );
	cleanedUpClasses.add( CM_EDISenderRecipFileTypeHist );
	
	create excludedClasses transient;
	excludedClasses.add( XLAT_FormCaption );
	excludedClasses.add( XLAT_Keyword );
	excludedClasses.add( XLAT_TextMessage );
	excludedClasses.add( XLAT_Translation );
	excludedClasses.add( CM_Log );
	excludedClasses.add( CM_CellDefn );
	excludedClasses.add( CM_Container );
	excludedClasses.add( CM_DeckItemLayout );
	excludedClasses.add( CM_Port );
	excludedClasses.add( CM_BreakBulkGeneric  );
	excludedClasses.add( CM_ROROLocnDefnVessel );
	excludedClasses.add( CM_ROROLocnDefnVoyage );
	excludedClasses.add( CM_RORORequestLayout );
	excludedClasses.add( CM_ROROSlotDefnVessel );
	excludedClasses.add( CM_ROROSlotDefnVoyage );
	excludedClasses.add( CM_ROROSlotRequest );
	excludedClasses.add( CM_SlotDefnVessel );
	excludedClasses.add( CM_SlotDefnVoyage );
	excludedClasses.add( CM_SlotRequest );
	excludedClasses.add( CM_TierDefn );
	excludedClasses.add( CM_VehicleVisitRecordDetail );
	
	create classes transient;
	class.getAllSubclassesAnywhere( classes );

	create limitedClassColl transient;
	foreach class in classes do
	
		if class.inheritsFrom( CM_TITransaction ) then
			continue;
		endif;
		if class.inheritsFrom( CM_LocationsController ) then
			continue;
		endif;
		
		if cleanedUpClasses.includes( class ) then
			continue;
		endif;
		
		if excludedClasses.includes( class ) then
			continue;
		endif;
		
		size := class.instances.size;
		if size &gt; 10000 then
			limitedClassColl.add( class );
			write class.name &amp; " - " &amp; size.String;
		endif;
	endforeach; 
	
/*	on Exception do app.handleDeletedObject( exception, parent, invalid );
	create objArray2 transient;
	foreach stateRef in CM_StateReference.instances do
		parent := stateRef.myParent;
		if stateRef.myParent &lt;&gt; null then
			edition := parent.edition;
			if invalid then
				objArray2.add( stateRef );
				invalid := false;
			endif;
		endif;
	endforeach; */
//	beginTransaction;
//	objArray2.purge;
//	commitTransaction; 
	
//	objArray2.inspectModal();
	
epilog

	delete collClassColl;
	delete objArray2;
	delete limitedClassColl;
	delete classes;
	delete cleanedUpClasses;
	delete excludedClasses;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlFindNonInversedRefs" id="028dd696-b4b3-4737-aa2c-815726d0dc0d">
        <source>ndlFindNonInversedRefs();
/*

Purpose:	Find persistent reference usage that might be left invalid by a delete...		

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2013	cnwndl1	Initial creation

*/

vars

	schema : Schema;
	classOfObjBeingDeleted : Class;
	classColl : ClassColl;
	class : Class;
	iterClass : Iterator;
	
	propColl : PropertyNDict;
	iterProp : Iterator;
	prop : Property;
	ref : Reference;
	collClass : CollClass;
	
	count : Integer;

begin

	schema := currentSchema;
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;
	classOfObjBeingDeleted := CM_Terminal;
	
	classColl := schema.getAllClasses(false);

	iterClass := classColl.createIterator;
	while iterClass.next( class ) do
		if not class.inheritsFrom( CM_Object ) then
			continue;
		endif;
		
		propColl := class.getProperties();
		iterProp := propColl.createIterator;
		while iterProp.next ( prop ) do
			if not prop.isKindOf(Reference) then
				continue;
			endif;
			ref := prop.Reference;
			if ref.isKindOf(ExplicitInverseRef) then
				continue;
			endif;
			
			if prop.getType = classOfObjBeingDeleted then
				write class.name &amp; "." &amp; prop.name;
				
			elseif prop.getType.inheritsFrom( Collection ) then
				collClass :=  prop.getType.CollClass;
				if collClass.getMemberType = classOfObjBeingDeleted then
					write class.name &amp; "." &amp; prop.name;
				endif;
			
			endif;
			
		endwhile;
		delete iterProp;
		
	endwhile;
	
	

epilog

	delete classColl;
	delete iterClass;
	delete iterProp;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlFindNonInversedRefs2" id="1ed4d578-ba7f-4d46-ac82-365659a8d7da">
        <source>ndlFindNonInversedRefs2();
/*

Purpose:	Find persistent reference usage that might be left invalid by a delete...		

Parameters:			

Return Value:		

Date		Who		Reason
16 January 2013	cnwndl1	Initial creation

*/

vars

//	schema : Schema;
//	classOfObjBeingDeleted : Class;
	classColl : ClassColl;
	class : Class;
	iterClass : Iterator;
	term : CM_Terminal;
	
//	propColl : PropertyNDict;
	iterInst : Iterator;
	object : Object;
//	prop : Property;
//	ref : Reference;
//	collClass : CollClass;
	
//	count : Integer;
	invalid : Boolean;
	edition : Integer;
	termSet : CM_TerminalSet;
	
	objectsToDelete : ObjectSet;
	
	ti : CM_TrackedItem;

begin

	app.isGarbageCollectionProcess := true;
	
	create classColl transient;
	


	

	classColl.add(CM_TIRequest); 
	
	
	
	create objectsToDelete transient;

	on Exception do app.handleDeletedObject( exception, ti, invalid );
	iterClass := classColl.createIterator;
	while iterClass.next( class ) do
		write class.name;
		iterInst := class.instances.createIterator;
		while iterInst.next( object ) do
			term := object.getPropertyValue('myTerminal').CM_Terminal;
			if term = null then
				continue;
			endif;
			
			edition := term.edition;
			if invalid then
				if term.String = "CM_Terminal/2351.35" then
					beginTransaction;
					object.setPropertyValue('myTerminal',null);
					objectsToDelete.add( object );
					write object;
					commitTransaction;
				endif;
				invalid := false;
				//write object;
			endif;
		endwhile;
		delete iterInst;
	endwhile;
	
	objectsToDelete.inspectModal();
	
	if app.msgBox("delete", "delete", MsgBox_Yes_No ) = MsgBox_Return_Yes then
		foreach object in objectsToDelete do
		beginTransaction;
		delete object;
		commitTransaction;
		endforeach;
	endif;

epilog

	app.isGarbageCollectionProcess := false;

	delete classColl;
	delete iterClass;
	delete iterInst;

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlFindPasswordUse" id="6d428d78-e49c-4d74-815a-2f1ab1b5c661">
        <source>ndlFindPasswordUse();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

	schema : Schema;
	classColl : ClassColl;
	class : Class;
	iterClass : Iterator;
	propColl : PropertyNDict;
	iterProp : Iterator;
	prop : Property;
	propName : String;

begin

	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	schema := currentSchema;
	while schema.name &lt;&gt; "PortSchema" do
		schema := schema.superschema;
	endwhile;
	
	classColl := schema.getAllClasses(false);
	
	iterClass := classColl.createIterator;
	while iterClass.next( class ) do
		if not class.inheritsFrom( CM_Object ) then
			continue;
		endif;
		
		propColl := class.getProperties();
		iterProp := propColl.createIterator;
		while iterProp.next ( prop ) do
			if prop.isKindOf(Reference) then
				continue;
			endif;
			if prop.type = String then
				propName := prop.name.toUpper;
				if propName.pos("PASSWORD",1) &gt; 0 then
					write class.name &amp; "." &amp; prop.name &amp; "  " &amp; prop.getLength.String;
				endif;
			endif;
		endwhile;
		delete iterProp;
		
	endwhile;
	delete iterClass;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="ndlx021" id="34dae85b-4284-4f10-8f75-fdfbf4be5d33">
        <source>ndlx021();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2012	cnwndl1	Initial creation 30682

*/

vars

	form1 : CMUI_AjmanCashRec;
	form2 : CMUI_AjmanEIR;
	form3 : CMUI_AjmanInvoice;
	defQryReport : CM_QryReport;
	form4 : CMUI_DotMatrixTestForm;
	
	
begin

	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");
	app.myPassport.setMyTerminal("2351.53".asOid.CM_Terminal);	// NDL Terminal
	
//	app.myRoot.loadJMTReportMenu();
//	return;
//	defQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepAutoDateReceiptNew);
//	write defQryReport.reportName;
	

