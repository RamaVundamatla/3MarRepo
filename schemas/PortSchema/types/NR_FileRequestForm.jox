    <JadeMethod name="refreshJRWINIButtons" id="3c0498ae-eea3-4a09-99d2-0e58a086d2e6">
        <source>refreshJRWINIButtons() protected;
/*
----------   ----------  --------------------------------------------------
Created:	05 December 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	iniFileName			: String;
	value				: String;
begin
	iniFileName 	:= app.getIniFileName();
	value			:= app.getProfileString(iniFileName, self.JRWINI_Section, self.JRWINI_PassBackException, null);
	
	if (not value.Boolean) then
		self.btnINIPassBackEx.caption := 'Set ' &amp; self.JRWINI_PassBackException &amp; ' On';		
	else
		self.btnINIPassBackEx.caption := 'Set ' &amp; self.JRWINI_PassBackException &amp; ' Off';
	endif;

	value			:= app.getProfileString(iniFileName, self.JRWINI_Section, self.JRWINI_QueryPrepTrace, null);
	if (not value.Boolean) then
		self.btnINIPrepTrace.caption := 'Set ' &amp; self.JRWINI_QueryPrepTrace;
	else
		self.btnINIPrepTrace.caption := 'Set ' &amp; self.JRWINI_QueryPrepTrace[1: self.JRWINI_QueryPrepTrace.length -2] &amp; 'Off';		
	endif;
	
	value			:= app.getProfileString(iniFileName, self.JRWINI_Section, self.JRWINI_QueryExecTrace, null);
	if (not value.Boolean) then
		self.btnINIExecTrace.caption := 'Set ' &amp; self.JRWINI_QueryExecTrace;
	else
		self.btnINIExecTrace.caption := 'Set ' &amp; self.JRWINI_QueryExecTrace[1: self.JRWINI_QueryExecTrace.length -2] &amp; 'Off';
	endif;
	
	value			:= app.getProfileString(iniFileName, self.JRWINI_Section, self.JRWINI_QueryStatisticsTrace, null);
	if (not value.Boolean) then
		self.btnINIStatTrace.caption := 'Set ' &amp; self.JRWINI_QueryStatisticsTrace;
	else
		self.btnINIStatTrace.caption := 'Set ' &amp; self.JRWINI_QueryStatisticsTrace[1: self.JRWINI_QueryStatisticsTrace.length -2] &amp; 'Off';
	endif;
	
	value			:= app.getProfileString(iniFileName, self.JRWINI_Section, self.JRWINI_QueryConcurrencyTrace, null);
	if (not value.Boolean) then
		self.btnINIConcurTrac.caption := 'Set ' &amp; self.JRWINI_QueryConcurrencyTrace;
	else
		self.btnINIConcurTrac.caption := 'Set ' &amp; self.JRWINI_QueryConcurrencyTrace[1: self.JRWINI_QueryConcurrencyTrace.length -2] &amp; 'Off';
	endif;
	
	value			:= app.getProfileString(iniFileName, self.JRWINI_Section, self.JRWINI_QueryDataFailureTrace, null);
	if (not value.Boolean) then
		self.btnINIDataFail.caption := 'Set ' &amp; self.JRWINI_QueryDataFailureTrace;
	else
		self.btnINIDataFail.caption := 'Set ' &amp; self.JRWINI_QueryDataFailureTrace[1: self.JRWINI_QueryDataFailureTrace.length -2] &amp; 'Off';
	endif;
	
	
	value			:= app.getProfileString(iniFileName, self.JRWINI_Section, self.JRWINI_QueryReadFailureOption, null);
	if (not value.Boolean) then
		self.btnINIReadFail.caption := 'Set ' &amp; self.JRWINI_QueryReadFailureOption[1: self.JRWINI_QueryReadFailureOption.length -3] &amp; 'On';
	else
		self.btnINIReadFail.caption := 'Set ' &amp; self.JRWINI_QueryReadFailureOption;
	endif;
	
	value			:= app.getProfileString(iniFileName, self.JRWINI_Section, self.JRWINI_LogQuery, null);
	if (not value.Boolean) then
		self.btnINILogQry.caption := 'Set ' &amp; self.JRWINI_LogQuery &amp; 'On';
	else
		self.btnINILogQry.caption := 'Set ' &amp; self.JRWINI_LogQuery &amp; 'Off';
	endif;

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resize" id="53a46ee8-46a7-478d-85cd-a6535b7c4fd3">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	// DVB changed 16/08/06. Uses Jade parent aspect stuff now.
	return;
	btnClose.top := self.clientHeight - staMain.height - 5 - btnClose.height;
	btnClose.left := self.clientWidth - 5 - btnClose.width;

//	btnSend.top := btnClose.top;
//	btnSend.left := btnClose.left - 5 - btnSend.width;

	btnCancelRequest.top := btnSend.top;
	btnCancelRequest.left := btnSend.left;
	
	fldMain.move(fldMain.left, fldMain.top,
				 btnClose.left + btnClose.width - fldMain.left,
				 btnClose.top - 5 - fldMain.top);

	tblLogEntries.width := shtOptions.clientWidth - 5 - tblLogEntries.left;			 
	tblLogEntries.height := shtOptions.clientHeight - 5 - tblLogEntries.top;			 

	splResults.width := shtResults.clientWidth - 5 - splResults.left;			 
	splResults.height := shtResults.clientHeight - 5 - splResults.top;		
	splResults.cnEcResizeContents();	 

end;</source>
    </JadeMethod>
    <JadeMethod name="saveActivityCapture" id="1d17de38-a7b9-4101-b1d6-e8174e93975b">
        <source>saveActivityCapture() protected;
/*
----------   ----------  --------------------------------------------------
Created:	12 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.myActivityCapture.enabled then
		app.msgBox("Changes will not be saved: Activity capture is currently enabled. You can't update its setting while it's listening.", 'Changes will not be saved: Already capturing', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);

		return;
	endif;
	self.myActivityCapture.setDetails(self.cmbActivityType.itemData[self.cmbActivityType.listIndex],
					self.chkLogProfile.value,
					self.chkLogDiag.value,
					self.chkLogSecurity.value,
					self.chkLogEntDef.value,
					self.chkLogConfig.value,
					self.optListenAll.value,
					self.txtMethodCount.text.Integer,
					self.txtMilliseconds.text.Integer,
					self.chkRemoteExec.value,
					self.chkActualTime.value,
					self.chkCacheStats.value,
					self.chkLoadTimes.value,
					self.chkMethodSize.value,
					self.chkStatistics.value,
					self.chkTotalTime.value);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectFileToGet" id="ec10d201-e859-402a-bc7f-8df46e5873cc">
        <source>selectFileToGet();
// ---------------------------------------------------------------------------
// Created:     07 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
	fileNode	: NR_FileNode;
	
begin

	idx := tblFilesList.row;
	if idx &lt;= tblFilesList.fixedRows then
		self.doFileListSort();
		return;
	endif;

	fileNode := tblFilesList.accessRow(idx).itemObject.NR_FileNode;
	
	if fileNode = null then
		return;
	endif;
	
	self.addFileNodeToTable(fileNode, tblFilesToGet);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="sendCountFormsRequest" id="66f1e21c-3b14-40c4-ac82-ee2eea4f2fc3">
        <updating/>
        <source>sendCountFormsRequest(_isForAllProcesses : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 May 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

begin

	if self.myNodeFormCountRequest &lt;&gt; null then
		if self.myNodeFormCountRequest.isBeingActioned then
			app.msgBox('A form count request is already being actioned.  You must wait until this is complete.', 'Error', MsgBox_OK_Only);
			return;
		endif;
	endif;

	beginTransaction;

	if self.myNodeFormCountRequest = null then
		create self.myNodeFormCountRequest persistent;
	endif;
	
	if _isForAllProcesses then
		self.myNodeFormCountRequest.setAllProcesses();
	endif;

	commitTransaction;

	self.beginNotification(self.myNodeFormCountRequest, self.myNodeFormCountRequest.NR_NodeRequestLogEntryEvent, Response_Continuous, 0);
	self.beginNotification(self.myNodeFormCountRequest, self.myNodeFormCountRequest.NR_NodeRequestCompleteEvent, Response_Continuous, 0);

	self.tblLogEntries.rows := self.tblLogEntries.fixedRows;
	
	if global.isValidObject(self.myProcess) then
		self.myProcess.causeEvent(self.myNodeFormCountRequest.NR_NodeRequestActionEvent, true, self.myNodeFormCountRequest);
		staMain.caption := 'Request sent to ' &amp;
			self.myNodeFormCountRequest.allProcesses.size.String &amp;
			' processes -&gt; ' &amp; self.myProcess.String;
	else
		app.msgBox('Process has been deleted.', 'Error', MsgBox_OK_Only);
	endif;
	
	self.btnCancelRequest.visible := true;
	self.btnSend.visible := false;

end;</source>
        <access>protected</access>
        <Parameter name="_isForAllProcesses" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendFileRequest" id="f73bd903-23c4-469a-b186-c3d2b348abd5">
        <updating/>
        <source>sendFileRequest() updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tsFrom,
	tsTo		: TimeStamp;
	tmpStr		: String;
	tmpDate		: Date;
	tmpTime		: Time;
	tmpFolders	: HugeStringArray;
	
begin

	staMain.caption := null;
	
	tmpStr := self.txtSearchDir.text;
	if tmpStr &lt;&gt; null then
		create tmpFolders transient;
		tmpFolders.add(tmpStr);
	endif;

	tsFrom	:= self.setTimeStampFromStr(txtDateFrom.text, txtTimeFrom.text);
	tsTo	:= self.setTimeStampFromStr(txtDateTo.text, txtTimeTo.text);
	
	self.initiateRequest(chkGetIniFile.value,
						 chkListFiles.value,
						 chkGetFiles.value,
						 chkGetVerInfo.value,
						 null, tmpFolders,
						 chkCardLogDir.value,
						 chkJadeLogDir.value,
						 chkJadeCrashDir.value,
						 self.chkDbaseDir.value,
						 self.chkTransientDir.value,
						 chkTempDir.value,
						 tsFrom, tsTo);


epilog
	delete tmpFolders;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sendTransientCheckRequest" id="3b81212f-44dd-4597-b4dd-ca5e9e7e86f7">
        <updating/>
        <source>sendTransientCheckRequest() updating, protected;
// ---------------------------------------------------------------------------
// Created:     07 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	tmpStr,
	schemaName	: String;
	maxNum		: Integer;
	tmpClasses	: StringArray;
begin

	schemaName := self.cmbSchema.text;
	if schemaName = null then
		app.msgBox('You must enter a schema name', 'Error', MsgBox_OK_Only);
		return;
	endif;
	
	if rootSchema.getSchema(schemaName) = null then
		app.msgBox('Schema name (' &amp; schemaName &amp; ') is not a valid schema', 'Error', MsgBox_OK_Only);
		return;
	endif;

	maxNum := self.txtMaxNum.text.Integer;
	if maxNum &lt; 100 then
		if app.msgBox('Max Num is &lt; 100.  Are You Sure?', '', MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;	
	endif;
	
	if self.lstCheck.listCount &gt; 0 then
		create tmpClasses transient;
		foreach tmpStr in self.lstCheck.itemText do
			if tmpStr &lt;&gt; null then
				tmpClasses.add(tmpStr);
			endif;
		endforeach;
	endif;
	
	if self.myCountTransientsRequest &lt;&gt; null then
		if self.myCountTransientsRequest.isBeingActioned then
			app.msgBox('A request is already being actioned.  You must wait until this is complete.', 'Error', MsgBox_OK_Only);
			return;
		endif;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;

	self.tblLogEntries.rows := self.tblLogEntries.fixedRows;
	self.tblLogEntries.addItem('Getting classes ....');
	
	beginTransaction;

	if self.myCountTransientsRequest = null then
		create self.myCountTransientsRequest persistent;
	else
		exclusiveLock(self.myCountTransientsRequest);
	endif;

	self.myCountTransientsRequest.sendRequest(schemaName, self.chkSubSchemas.value, maxNum, tmpClasses);

	commitTransaction;

	self.beginNotification(self.myCountTransientsRequest, NR_NodeFileRequest.NR_NodeRequestLogEntryEvent, Response_Continuous, 0);
	self.beginNotification(self.myCountTransientsRequest, NR_NodeFileRequest.NR_NodeRequestCompleteEvent, Response_Cancel, 0);

	self.tblLogEntries.rows := self.tblLogEntries.fixedRows;
	
	if self.myCountTransientsRequest.allLogEntries.size &gt; 0 then
		foreach tmpStr in self.myCountTransientsRequest.allLogEntries do
			self.tblLogEntries.addItem(tmpStr);
		endforeach;
	endif;
		
	if global.isValidObject(self.myProcess) then
		self.myProcess.causeEvent(NR_NodeFileRequest.NR_NodeRequestActionEvent, true, self.myCountTransientsRequest);
		staMain.caption := 'Request sent to process ' &amp; self.myProcess.String;
	else
		app.msgBox('Process has been deleted.', 'Error', MsgBox_OK_Only);
	endif;
	
	btnCancelRequest.visible := true;
	btnSend.visible := false;

epilog
	delete tmpClasses;
	app.mousePointer := MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setAllFilesToGet" id="c4467ad0-8e03-4e77-888f-c4874f33dadb">
        <updating/>
        <source>setAllFilesToGet(_tbl : Table input; _justCurrentRow : Boolean) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     07 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx,
	numRows		: Integer;
	fileNode	: NR_FileNode;

begin

	self.allFilesToGet.clear;

	if _justCurrentRow then
		idx := _tbl.row;
		if idx &gt; _tbl.fixedRows then
			fileNode := _tbl.accessRow(idx).itemObject.NR_FileNode;
			if fileNode &lt;&gt; null then
				self.allFilesToGet.add(fileNode.pathName);
			endif;
		endif; 
	else
		numRows := _tbl.rows;
		
		foreach idx in _tbl.fixedRows + 1 to numRows do
			fileNode := _tbl.accessRow(idx).itemObject.NR_FileNode;
			if fileNode &lt;&gt; null then
				self.allFilesToGet.add(fileNode.pathName);
			endif;
		endforeach;
	endif;
	
	if self.allFilesToGet.isEmpty then
		app.msgBox('No files selected to get.', 'Error', MsgBox_OK_Only);
		return false;
	endif;
	
	return true;

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_justCurrentRow" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setINIValue" id="2bb70fef-7f3e-42db-9f81-75b0f61bba71">
