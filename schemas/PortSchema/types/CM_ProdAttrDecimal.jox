    <JadeMethod name="divideValue" id="bfaa99e6-35ab-40cb-a320-88b5b6a589a7">
        <source>divideValue(_value: Decimal): Decimal;
// ---------------------------------------------------------------------------
// Created:     04 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	//check for division by zero - even though the multiplier should always be at least one
	if (self.multiplier &lt;&gt; 0) and (_value &lt;&gt; 0) then
		return _value / self.multiplier;
	else
		return _value;
	endif;

end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDefaultValueString" id="bb9a0335-ec3b-4e98-b281-9e4dbac8eeda">
        <source>getDefaultValueString(_attrName: String): String;
// ---------------------------------------------------------------------------
// Created:     17 October 2002		cnwth2	
//
// Purpose:     Returns the default string for the product attribute NOT subject to multiplier
//			 	self::getDisplayValueString return display value subject to multiplier - 
//				ie. for the Gate In/Out attachments screen
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 15/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	measureType : CM_MeasurementType;			// PAR #31155

begin
	measureType := self.myMeasurementType;													// PAR #31155
	if self.validationType = ValidationType_Value then
		if measureType &lt;&gt; null then															// PAR #31155
			return app.convertMeasurementForDisplay(measureType.shortName, self.value);		// PAR #31155
		else																				// PAR #31155
			return self.value.asStringMeasurementJMT();
		endif;																				// PAR #31155
	endif;
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b5456124-fa20-439c-85b1-ff198deac5e6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     09 October 2002 by cnwth2
//
// Purpose:     Return a value based on the validation type
//
// Changes		PAR 22189 Feb 2010. String chnaged by asStringJMT()
// ----------   ----------  --------------------------------------------------
// 15/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	defaultMeasure	: CM_MeasurementType;			// PAR #31155

begin
	if _attrName = ETRow_Multiplier then
		return self.multiplier.asStringJMT();
	
	elseif _attrName = ETRow_Range then
		if self.minValue &lt;&gt; null or self.maxValue &lt;&gt; null then
			return self.minValue.asStringJMT() &amp; ' : ' &amp; self.maxValue.asStringJMT();
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_Value then
		if self.myMeasurementType &lt;&gt; null then														// PAR #31155
			return app.convertMeasurementForDisplay(self.myMeasurementType.shortName, self.value);	// PAR #31155
		else
			//10 Sep 2013	NDL	Par 32172 -   PAR #31155
			if self.name = ETRow_MyLength then				
				defaultMeasure := app.getDefaultMeasurementForType(Type_Length);				
			elseif self.name = ETRow_MyWidth then				
				defaultMeasure := app.getDefaultMeasurementForType(Type_Width);					
			elseif self.name = ETRow_MyHeight then				
				defaultMeasure := app.getDefaultMeasurementForType(Type_Height);					
			elseif self.name = ETRow_MyWeight then													// PAR #31155
				defaultMeasure := app.getDefaultMeasurementForType(Type_Weight);					// PAR #31155
			elseif self.name = ETRow_MyVolume then													// PAR #31155
				defaultMeasure := app.getDefaultMeasurementForType(Type_Volume);					// PAR #31155
			endif;																					// PAR #31155
			if defaultMeasure &lt;&gt; null then															// PAR #31155
				return defaultMeasure.removeDecimalZeros(value.String);								// PAR #31155
			endif;																					// PAR #31155
			return self.value.asStringJMT();
		endif;																						// PAR #31155
	endif;
	
	return inheritMethod(_attrName, _short);	
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayValueString" id="76c28e15-1d1b-459d-bfaa-ef82831cfd0f">
        <source>getDisplayValueString(): String;
// ---------------------------------------------------------------------------
// Created:     24 October 2002		cnwth2	
//
// Purpose:     Returns display value subject to multiplier if any
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 15/03/2013	cnwdap1		PAR #31155 CCNS SFW 1321 Impeial Measurements
vars
	displayValue 	: Decimal[12,3]; //PAR18263 cnwsh3 16/3/2009
	result			: Decimal[23,10];	// PAR #31155
	//valueStr		: String;			// cnwmc5 - 9 Dec 2013 - PAR 33010
	
begin
	
	if self.myMeasurementType &lt;&gt; null then																// PAR #31155
		//valueStr := self.value.truncatedTo(self.myMeasurementType.getDecimalPrecision).String;			// PAR #31155	// cnwmc5 - 9 Dec 2013 - PAR 33010
		//result := app.convertMeasurementForStorage(self.myMeasurementType.shortName, valueStr.Decimal);	// PAR #31155
		return app.convertMeasurementForDisplay(self.myMeasurementType.shortName, self.value);				// PAR #31155	// cnwmc5 - 9 Dec 2013 - PAR 33010
	else																								// PAR #31155
		displayValue := (self.value * self.multiplier);
		
		if displayValue &gt; 0 then
			if displayValue mod 1 = 0 then
				return displayValue.Integer.asStringJMT;
			else
				return displayValue.asStringJMT;
			endif;
		endif;
	endif;																								// PAR #31155
	
	return null;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRangeDescr" id="c93a2ac1-c99f-4569-a86c-75dd89ed7157">
        <source>getRangeDescr(): String;
// ---------------------------------------------------------------------------
// Created:     12 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	minValue,
	maxValue			: Decimal[10,3];
	minStr,
	maxStr				: String;
begin
	minValue := (self.minValue * self.multiplier).roundedTo(3);
	if minValue mod 1 = 0 then
		minStr := minValue.Integer.String;
	else
		minStr := minValue.String;
	endif;
	
	maxValue := (self.maxValue * self.multiplier).roundedTo(3);
	if maxValue mod 1 = 0 then
		maxStr := maxValue.Integer.String;
	else
		maxStr := maxValue.String;
	endif;
	return minStr &amp; ' : ' &amp; maxStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
