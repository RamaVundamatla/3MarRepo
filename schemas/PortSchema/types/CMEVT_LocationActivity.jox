    <JadeMethod name="setRemarks" id="f66d53f4-15f8-4d39-99e6-5a7137569a08">
        <updating/>
        <source>setRemarks( _remarks : String )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2021	navndl1	Initial creation	TFS 51864 - new use for this field, should now be
												manually updateable for all.

*/

vars

begin

	self.remarks := _remarks;
	
	if not self.isTransient then
		//A temporary hack to create auditability for the devs use until the new auidt collection on 
		//CM_Object makes it into prod and the proper audits are added to this class.
		self.createTemporaryAuditObject();
	endif;

epilog

end;</source>
        <Parameter name="_remarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="setUpdateCapableAttributes" id="39a25a20-6613-4076-b55a-5f7b51a56d85">
        <updating/>
        <source>setUpdateCapableAttributes(	_dateTime : TimeStamp;
							_weight : Decimal;
							_quantity : Integer;
							_volume : Decimal;
							_mySourceObject : CM_Object;
							_myTargetObject : CM_Object;
							_remarks : String	//01 Sep 2021	NDL	TFS 51864
							) updating;
/*

Purpose:			

Parameters:			Use this method when updating.  These are the ONLY user updateable fields.

Return Value:		

Date		Who		Reason
12 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin

	if self.dateTime &lt;&gt; _dateTime then
		self.dateTime := _dateTime;
		self.setLocalDateTime( null, _dateTime, self.myTerminal );
		self.setHasBeenEdited( true );
	endif;
	
	if self.weight &lt;&gt; _weight then
		self.weight := _weight;
		self.setHasBeenEdited( true );
	endif;
	
	if self.quantity &lt;&gt; _quantity then
		self.quantity := _quantity;
		self.setHasBeenEdited( true );
	endif;
	
	if self.volume &lt;&gt; _volume then
		self.volume := _volume;
		self.setHasBeenEdited( true );
	endif;
	
	if _mySourceObject = null then
		self.setMySourceAttributes( null, false );
	elseif _mySourceObject.isKindOf( CM_LocationsController ) then
		self.setMySourceAttributes( _mySourceObject.CM_LocationsController, false );
	else
		self.setMySourceAttributesExt( _mySourceObject );
	endif;
	
	if _myTargetObject = null then
		self.setMyTargetAttributes( null, false );
	elseif _myTargetObject.isKindOf( CM_LocationsController ) then
		self.setMyTargetAttributes( _myTargetObject.CM_LocationsController, false );
	else
		self.setMyTargetAttributesExt( _myTargetObject );
	endif;
	
	self.remarks := _remarks;	//01 Sep 2021	NDL	TFS 51864
	
	self.setMovementDirection();	//13 Jul 2021	NDL	TFS 51528 - after source and target are set
	
	//A temporary hack to create auditability for the devs use until the new auidt collection on 
	//CM_Object makes it into prod and the proper audits are added to this class.
	self.createTemporaryAuditObject();
	
epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_mySourceObject" type="CM_Object"/>
        <Parameter name="_myTargetObject" type="CM_Object"/>
        <Parameter name="_remarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="33c0d5e8-cfe0-4d48-aa05-194cd4ec2aa2">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

	now : TimeStamp;
	maxDaysOld : Integer;

begin

	now := app.actualTimeServer();
	if self.dateTime &gt; now then
		app.raiseCMException( Date_not_future, null, null );
	else
		maxDaysOld := self.getMyTerminal.getLocationActivityMaxDays();
		if self.dateTime.date.cnEcAddDays( maxDaysOld ) &lt; now.date then
			app.raiseCMException1( Date_more_than_days, maxDaysOld.String, null, null );
		endif;
	endif;

	if self.mySourceTrain &lt;&gt; null then
		if not self.mySourceTrain.onSiteAt( self.dateTime ) then
			app.raiseCMWarning2( Train_not_onsite, self.mySourceTrain.getCodeDateString, self.dateTime.asStringJMT, "mySourceTrain", null, null );
		endif;
	endif;
	if self.myTargetTrain &lt;&gt; null then
		if not self.myTargetTrain.onSiteAt( self.dateTime ) then
			app.raiseCMWarning2( Train_not_onsite, self.myTargetTrain.getCodeDateString, self.dateTime.asStringJMT, "myTargetTrain", null, null );
		endif;
	endif;
	if self.mySourceVVR &lt;&gt; null then
		if not self.mySourceVVR.onSiteAt( self.dateTime ) then
			app.raiseCMWarning2( Vehicle_visit_not_onsite, self.mySourceVVR.idForLocationActivity, self.dateTime.asStringJMT, "mySourceVVR", null, null );
		endif;
	endif;
	if self.myTargetVVR &lt;&gt; null then
		if not self.myTargetVVR.onSiteAt( self.dateTime ) then
			app.raiseCMWarning2( Vehicle_visit_not_onsite, self.myTargetVVR.idForLocationActivity, self.dateTime.asStringJMT, "myTargetVVR", null, null );
		endif;
	endif;
	if self.mySourceVoyage &lt;&gt; null then
		if not self.mySourceVoyage.onSiteAt( self.dateTime ) then
			app.raiseCMWarning2( Voyage_not_onsite, self.mySourceVoyage.idForLocationActivity, self.dateTime.asStringJMT, "mySourceVoyage", null, null );
		endif;
	endif;
	if self.myTargetVoyage &lt;&gt; null then
		if not self.myTargetVoyage.onSiteAt( self.dateTime ) then
			app.raiseCMWarning2( Voyage_not_onsite, self.myTargetVoyage.idForLocationActivity, self.dateTime.asStringJMT, "myTargetVoyage", null, null );
		endif;
	endif;
	
epilog

end;</source>
