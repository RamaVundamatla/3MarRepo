    <JadeMethod name="doShowInfo" id="d174bdb0-4950-487b-88ff-3c206442fb38">
        <updating/>
        <source>doShowInfo() protected, updating;
/*
------------------------------------------------------------------------
Created:			02 June 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing

Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
	
*/

vars
	tmpTable : CM_DataTable;
	jli : JadeLicenceInfo;
	str : String;
	sta : StringArray;
begin
	app.mousePointer := MousePointer_HourGlass;
	staMain.caption := null;
	self.caption := app.getErrorString(RelView_Terminal_Licence);
	tmpTable := self.tblUpgrades;
	tmpTable.rows := 0;	//Clear
	tmpTable.clearSort;
	tmpTable.columns := 2;	//Clear
	staMain.caption := null;
	tmpTable.addItem('License/Information' &amp; Tab &amp; 'Value');
	tmpTable.fixedRows := 1;
	//Load the table
	create sta transient;
	create jli transient;
	jli.getLicenceInfo;
	
	str := 'Licensed to' &amp; Tab &amp; jli.licenceName;
	tmpTable.addItem(str);
	
	str := 'Total number of Processes Licensed' &amp; Tab &amp; jli.processLicences.String;
	tmpTable.addItem(str);
	
	str := 'Number of Development Licenses' &amp; Tab &amp; jli.developmentLicences.String;
	tmpTable.addItem(str);
	
	str := 'Number of HTML Sessions' &amp; Tab &amp; jli.nHtmlThinSessions.String;
	tmpTable.addItem(str);
	
	str := 'Number of JADE Development Sessions' &amp; Tab &amp; jli.nJadeDevProcesses.String;
	tmpTable.addItem(str);

	str := 'Number of JADE Thin Client Sessions (excl Dev)' &amp; Tab &amp; jli.nJadeThinNonJadeDevProcesses.String;
	tmpTable.addItem(str);

	str := 'Number of Available Process Licenses' &amp; Tab &amp; jli.nProcessesLeft.String;
	tmpTable.addItem(str);

	str := 'Number of Standard FAT Process Sessions' &amp; Tab &amp; jli.nNonJadeDevProcesses.String;
	tmpTable.addItem(str);

// rs1 mar 2006 not supported in Jade 6.1
//	str := 'Number of Secondary Databases that can connect' &amp; Tab &amp; jli.secondaryLicences.String;
//	tmpTable.addItem(str);
	//----------------------------
	//Display code below, however due to JADe's poxy implementation of the output I've decided to 
	//show my version instead.
	//----------------------------
	/*
	str := jli.display;
	str.asStringArrayByDelimiter(sta, CrLf);
	foreach str in sta do
		str := str.replaceString(':', Tab);
		tmpTable.addItem(str);
	endforeach;
	*/
	
	str := 'Total Containers created' &amp; Tab &amp; self.getInstanceIdForObject64(CM_Container.lastInstance).userNumberFormat($CNEC_NO_DECIMALS);
	tmpTable.addItem(str);

	str := 'Total Logs created' &amp; Tab &amp; self.getInstanceIdForObject64(CM_Log.lastInstance).userNumberFormat($CNEC_NO_DECIMALS);
	tmpTable.addItem(str);
	self.doHighlights();

epilog
	delete jli;
	delete sta;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadReleaseCombo" id="a603ef21-1ebc-4528-9b39-cb2672d758b0">
        <source>loadReleaseCombo() protected;
/*
------------------------------------------------------------------------
Created:			02 June 2004 by cnwdwq1
Purpose:			Loads the combo box with the releases loaded.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	startTimestamp : TimeStamp;
	allHistoryMasters : CnEcRelHistoryMasterByTimeDict;
	theHistoryMaster : CnEcReleaseHistoryMaster;
begin
	app.mousePointer := MousePointer_HourGlass;

	self.cmbLogs.clear();
	create allHistoryMasters transient;
	startTimestamp.cnEcSetDateAndTime('01/01/2000'.Date, '00:00'.Time);
	
	app.myBaseRoot.allReleaseHistoryMasters.searchForReleases(	startTimestamp, null, null, allHistoryMasters);
	
	if allHistoryMasters.isEmpty then
		return;
	endif;

	foreach theHistoryMaster in allHistoryMasters reversed do
		self.cmbLogs.addItemObject(theHistoryMaster.fullReleasePatchNumber, theHistoryMaster);
	endforeach;
epilog
	delete allHistoryMasters;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="85de56b3-49c1-4c0d-a96c-7c48150f0d25">
        <updating/>
        <source>setupForm() updating;
/*
------------------------------------------------------------------------
Created:			02 June 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars

begin
	app.mousePointer := MousePointer_HourGlass;
	self.setNavigatorHeading(self.caption); 
	if app.myBaseRoot = null then
		app.cnEcInitializeBaseSchema();
	endif;

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmToolbar.priorityRight := true;

	self.tableInit();
	self.loadReleaseCombo();
	if self.cmbLogs.listCount &gt; 0 then
		self.cmbLogs.listIndex :=1;
		self.btnUpgradeLogs.value := true;
		self.doCmbLogsClick();
	endif;
		
	self.doResize();

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="tableInit" id="5961c57c-6d6c-4c7b-bf37-db68c6cea99d">
        <source>tableInit() protected;
/*
------------------------------------------------------------------------
Created:			02 June 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	tmpTbl	: CM_DataTable;
begin

	tmpTbl := self.tblUpgrades;

	tmpTbl.selectionType := Table.SelectMode_FixedRow;
	tmpTbl.autoSize	:= Table.AutoSize_Column;
	
	tmpTbl.left := 0;
	tmpTbl.stretchWidth := true;
	tmpTbl.stretchHeight	:= true;
	tmpTbl.rows := 0;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tableRowLimitException" id="c5a344d6-4d90-4a3d-9005-886b8ee6abe5">
        <updating/>
        <source>tableRowLimitException(_exObj: Exception; _table: CM_BaseTable; _exOccurred: Boolean output): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2019	jlgns1	Initial creation
18 December 2019	jlgns1	Bug 48085: JMT - Row limit reached message box cannot be cleared on upgrade screen
*/

vars

begin
	if _exObj.errorCode = 14049 then
		app.msgBox(app.getErrorString1(MaxTablesRowsReached, JadeTableRowLimit.String)
					,app.getErrorString(TableRowLimitReached),MsgBox_OK_Only + MsgBox_Information_Icon);
		return Ex_Abort_Action;
	endif;
	return Ex_Pass_Back;
end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_table" type="CM_BaseTable"/>
        <Parameter name="_exOccurred" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblUpgrades_dblClick" id="d9f633c0-3a50-44a0-988d-c3a983470f18">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblUpgrades_dblClick(table: Table input) updating;
//--------------------------------------------------
// Created:	12 July 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.tblUpgrades.resortTableByColumn(table.column);
	self.doHighlights();

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="9c4f939e-3517-4b2d-83d9-58bfd60fb196">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008032, locale);
	btnShowInfo.translateBubbleHelp(Xlat_0000745, locale);
	btnShowInfo.translateCaption(Xlat_0000746, locale);
	btnUpgradeJMT.translateBubbleHelp(Xlat_0000743, locale);
	btnUpgradeJMT.translateCaption(Xlat_0000744, locale);
	btnUpgradeJMTSys.translateBubbleHelp(Xlat_0000741, locale);
	btnUpgradeJMTSys.translateCaption(Xlat_0000742, locale);
	btnUpgradeLogs.translateBubbleHelp(Xlat_0000748, locale);
	btnUpgradeLogs.translateCaption(Xlat_0000749, locale);
