/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2018	jlgndl1	Initial creation	TFS 37447

*/

vars

	obj : Object;
	schema : Schema;
	class : Class;
	assistant : Object;

begin

	obj := self.btnOOWConfirm.userObject;
	if obj.isKindOf(CM_WorkOrderVoyageDtl) then
		//all good
	else
		return;
	endif;

	schema := currentSchema.getSchema("ShipSchema");
	class := schema.getClass("SHP_Assistant");
	create assistant as class transient;
	assistant.setPropertyValue("myTerminal", self.myTerminal);
	assistant.sendMsgWithParams( "showOOWorkConfirmationForm", obj, self.myMasterMenuAction );

epilog

end;
</source>
