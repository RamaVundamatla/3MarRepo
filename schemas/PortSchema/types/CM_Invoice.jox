    <JadeMethod name="canMerge" id="aa01918e-2389-4a54-a150-6f99165bcde7">
        <source>canMerge() : Boolean;
/*
Purpose:			

Date		Who		Reason
08 January 2024	navab1	CR 58085 TASK 61342
*/

vars

begin

	if self.status = CM_Invoice.INVOICE_POSTED_PENDING 
	or self.status = CM_Invoice.INVOICE_POSTED_ERROR 
	or self.status = CM_Invoice.INVOICE_POSTED 
	or self.status = CM_Invoice.INVOICE_POSTED_REVERSE 
	or self.status = CM_Invoice.INVOICE_POSTED_CREDIT then
		return false;
	
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canOverrideRates" id="b1f7cb9e-6b00-484b-aace-941a5641ac1c">
        <source>canOverrideRates() : Boolean;
/*

Date		Who		Reason
25 September 2015	cnwer1	Initial creation PAR 36958
19 Nov       2018   cnwma1  Bug 42084: PEL1 - Invoice changes in Disputed status
*/

vars

begin
	//return self.isPending or self.isOpen;                  //19.11.2018 cnwma1  Bug #42084
	return self.isPending or self.isOpen or self.isDisputed; //19.11.2018 cnwma1  Bug # TFS 42084
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUpdate" id="31c7937d-56c3-4b71-96a0-4d9a00bed7e2">
        <source>canUpdate():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2018	cnwma1	ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction
05 Mar      2019    cnwma1	Bug 43664: PEL1 - Invoice restrictions (41945 failed)
*/

vars
	payType ,
	payStatus,
	currStatus	 : Integer;
	reqName   	 : String;
	extActHist   : CM_ActivityHistoryExtInterface;
	isReplaceInv : Boolean;
begin
	if self.allSAPActivity.isEmpty then
		return true;
	endif;
	
	payType 	:= self.paymentType;
	payStatus	:= self.paymentStatus;
	currStatus  := self.status;
	

	
	if payType = PaymentType_None then
		return true;
	endif;
	
	if self.myPostedPendingInvoice &lt;&gt; null then
		isReplaceInv := true;
	endif;

	if payType = PaymentType_AutoCollection then
		reqName := CM_SAPWSConsumerAgent::autocollPreInvoiceNewRequest_SI.name;
	elseif payType = PaymentType_PostPay then
		reqName :=  CM_SAPWSConsumerAgent::postBillInvoiceRequest_SI.name;
	endif;
	
	if reqName = null then
		return true;
	endif;
	
	extActHist := self.allSAPActivity.getAtKeyGeq(reqName,null);        //05.03.2019 cnwma1 #43664
	
	if extActHist = null or extActHist.requestName &lt;&gt; reqName then     //05.03.2019 cnwma1 #43664
		return true;
	endif;
	
	
	if extActHist &lt;&gt; null then
		if currStatus = CM_Invoice.INVOICE_PENDING then		
			if payType = PaymentType_AutoCollection then
				if isReplaceInv then
				
				else
					if payStatus = CM_Invoice.INVOICE_PAYMENT_PAID then
						return false;
					endif;
				endif;
		
			elseif payType = PaymentType_PostPay then
				
					if isReplaceInv then
						if   payStatus = CM_Invoice.INVOICE_PAYMENT_PAID then
							return true;
						elseif payStatus = CM_Invoice.INVOICE_PAYMENT_CANCEL then
							return true;
						elseif payStatus = CM_Invoice.INVOICE_PAYMENT_NOTPAID then
							return false;
						endif;
						
					else
						if payStatus = CM_Invoice.INVOICE_PAYMENT_NOTPAID then
							return false;
						endif;
					endif;
			endif;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserAccessSelf" id="7287268a-3324-4295-94ba-f8615c06706f">
        <source>canUserAccessSelf(_user: CM_User; _failedDAC  :CM_DataAccessController output; _passport: CM_Passport): Boolean;
// ---------------------------------------------------------------------------
// Created:		22 June 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.debtor &lt;&gt; null then
		return self.debtor.canUserAccessSelf(_user, _failedDAC, _passport);
	endif;
	return inheritMethod(_user, _failedDAC, _passport);

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkForMinimumCharge" id="1c3d96df-a8fc-4d1b-9519-43347592adbc">
        <source>checkForMinimumCharge();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/09/2015	cnwdap1		Initial creation PAR #36909 CCMS ADP 2537 Minimum Charge changes
// 08/11/2015	cnwdap1		PAR #37149 Allow duplicates in dyna dict (manual invoice lines can have same date/time)
// 06/01/2016	cnwdap1		PAR #37337 Cash Receipt invoices have already had minimum charges applied
// 20/1/2017	cnwer1		TFS 2903 changes so minimum charges can be set on invoice line type groups
//
vars
	invLine : CM_InvoiceLine;
	lastGroupType,
	lastType : CM_InvoiceLineDesc;
	linesByType : DynaDictionary;
	obj : Object;
	allMinumumChargeSets : ObjectArray;
	minimumChargeSet : ObjectArray;
begin
	// only check if invoice is closed
	if self.status &lt;&gt; self.INVOICE_PENDING then
		return;
	endif;
	// PAR #37337 And if I have a cash receipt, minimum payment has already 	// PAR #37337
	// been done as part of Cash processing										// PAR #37337
	if self.myCashReceipt &lt;&gt; null then											// PAR #37337
		return;																	// PAR #37337
	endif;																		// PAR #37337
	
	// sort all invoice lines by invoice line type
	create linesByType transient;
	linesByType.setMembership(CM_InvoiceLine);
	linesByType.addMemberKey(CM_InvoiceLine::invoiceLineDesc.name, false, true);
	linesByType.addMemberKey(CM_InvoiceLine::chargeTime.name, false, true);
	linesByType.endKeys(true);						// PAR #37149 changed from false
	
	self.invoiceLines.copy(linesByType);
	
	create allMinumumChargeSets transient;
	
	foreach obj in linesByType do
		invLine := obj.CM_InvoiceLine;
		//epr TFS 2903 19/1/17
		if invLine.invoiceLineDesc &lt;&gt; null and invLine.invoiceLineDesc.group &lt;&gt; null and invLine.invoiceLineDesc.group.myMinimumChargeInvoiceLineType &lt;&gt; null then
			if lastGroupType = null or lastGroupType &lt;&gt; invLine.invoiceLineDesc.group.myMinimumChargeInvoiceLineType then
				create minimumChargeSet transient;
				allMinumumChargeSets.add(minimumChargeSet);		
			endif;
			lastGroupType:=invLine.invoiceLineDesc.group.myMinimumChargeInvoiceLineType;
			minimumChargeSet.add(invLine);
		else
			if invLine.invoiceLineDesc.minimumChargeAmount = null or invLine.invoiceLineDesc.minimumChargeGroupBy &lt;&gt; lastType.GROUP_BY_INVOICE then
				continue;
			endif;
			
			if lastType = null or lastType &lt;&gt; invLine.invoiceLineDesc  then
				create minimumChargeSet transient;
				allMinumumChargeSets.add(minimumChargeSet);		
			endif;
			lastType:=invLine.invoiceLineDesc;
			minimumChargeSet.add(invLine);
		endif;
	endforeach;
	
		
	foreach obj in allMinumumChargeSets discreteLock do
		self.createMinimumChargesForGroup(obj.ObjectArray);
		
	endforeach;	
		
epilog
	if allMinumumChargeSets &lt;&gt; null then
		allMinumumChargeSets.purge;
	endif;
	delete allMinumumChargeSets;
	
	delete linesByType;
end;</source>
    </JadeMethod>
    <JadeMethod name="cloneForConsolidation" id="b8f2581b-44c4-4552-b67a-1cef29f74f8e">
        <source>cloneForConsolidation() : CM_Invoice;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2024	navrv30	Initial creation

*/
vars
	cloneInv : CM_Invoice;
	cmifStatus : CMIF_InvoiceStatus;
begin
	cloneInv := self.cloneSelf( true );  
//	cloneInv.setMyInvoiceProcess(self.getMyInvoiceProcess);
	create cmifStatus transient;	
	

	cmifStatus.newStatus 	:= INVOICE_PENDING;	

	cloneInv.exportedCount  := 0;
	cloneInv.invoiceType 	:= self.invoiceType;
	cloneInv.paymentType 	:= self.paymentType;
	cloneInv.paymentStatus  := self.paymentStatus;
	cloneInv.myBOL 			:= self.myBOL;
	cloneInv.myTrackedItem  := self.myTrackedItem;
	cloneInv.myVoyage		:= self.myVoyage;
	cloneInv.debtor 		:= self.debtor;
	cloneInv.externalNumber := null; // 07/02/2023	navkc1	#TFS CR 55305 TASK 55536
	cloneInv.bank			:= self.bank;
	cloneInv.setStatus( INVOICE_PENDING );	 // 01/02/2023	navkc1	TFS CR 55305 TASK 55537
	cloneInv.setPreviousStatus(self.previousStatus); // TFS 39618	
	
	/*finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass.setExternalOnCreate() then
		cloneInv.setExternalInvoiceNumber(finIOClass.setExternalInvoiceNumber(self));
	endif;
	
	foreach invLine in invoiceLines do
		cloneInvLine := invLine.cloneForReturn( cloneInv, false );
	endforeach;
	
	audit := cloneInv.doAuditInvStatusChanged(cmifStatus,0);
	if audit &lt;&gt; null then
		audit.setRemarksForReturn( self );
	endif;*/
	
	// ### JIRA 19932 21OCT2024 NAVAB1
	cloneInv.setMyInvoiceProcess(self.getMyInvoiceProcess);
	
	return cloneInv;
	
epilog
	delete cmifStatus;
end;</source>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="cloneForCopy" id="d0ba75e3-9bf1-475f-8a95-2283b1515e55">
        <source>cloneForCopy(): CM_Invoice;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Oct 2018 cnwma1 ChangeRequest 41703: PEL1 - Sap Integration - Post Billing Cancelled Invoice
28 Nov 2018 cnwma1 ChangeRequest 42118: PEL1 - Generate tax number and invoice date
01/02/2023	navkc1	TFS CR 55305 Task 55537 UI - Invoice List UI changes
*/

vars
	cloneInv : CM_Invoice;
	cmifStatus : CMIF_InvoiceStatus;
	invLine : CM_InvoiceLine;
	cloneInvLine : CM_InvoiceLine;
	finIOClass : CM_ExtFinanceIO;
	replacedTax : String;
	audit : CM_FinAuditInvStatusChanged;
begin
	cloneInv := self.cloneSelf( false );  
//	cloneInv.setMyInvoiceProcess(self.getMyInvoiceProcess); // TFS 39618 - reference not cloned	
	create cmifStatus transient;
	
	
	//cloneInv.setStatus( INVOICE_PENDING );	 // 01/02/2023	navkc1	TFS CR 55305 TASK 55537

	cmifStatus.newStatus 	:= INVOICE_PENDING;	

	cloneInv.exportedCount  := 0;
	cloneInv.sequenceNum 	:= self.bank.getSeqNum(SN_INVOICE);
	cloneInv.invoiceType 	:= self.invoiceType;
	cloneInv.paymentType 	:= self.paymentType;
	cloneInv.paymentStatus  := self.paymentStatus;
	cloneInv.myBOL 			:= self.myBOL;
	cloneInv.myTrackedItem  := self.myTrackedItem;
	cloneInv.myVoyage		:= self.myVoyage;
	cloneInv.debtor 		:= self.debtor;
	cloneInv.externalNumber := null; // 07/02/2023	navkc1	#TFS CR 55305 TASK 55536
	cloneInv.bank			:= self.bank;
	cloneInv.setStatus( INVOICE_PENDING );	 // 01/02/2023	navkc1	TFS CR 55305 TASK 55537
	cloneInv.setPreviousStatus(self.previousStatus); // TFS 39618	
	
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass.setExternalOnCreate() then
		cloneInv.setExternalInvoiceNumber(finIOClass.setExternalInvoiceNumber(self));
	endif;
	/* 28.11.2018 cnwma1 TFS #42118
	if self.externalTaxNumber &lt;&gt; null then
		if finIOClass.isKindOf(CM_Pelindo1Interface) then
			if self.status = CM_Invoice.INVOICE_POSTED then
				if self.postedDT.isValid then
					if self.postedDT.Date.cnEcGetFirstDayOfMonth &lt; app.actualTimeServer.date.cnEcGetFirstDayOfMonth then
						replacedTax := self.externalTaxNumber ;
						replacedTax[3:1] := "1";
						cloneInv.externalTaxNumber := replacedTax; 
					endif;
				endif;
			elseif self.status = CM_Invoice.INVOICE_PENDING then  //05.11.2018 cnwma1 TFS #41703
				if self.pendingDT.isValid then
					if self.pendingDT.Date.cnEcGetFirstDayOfMonth &lt; app.actualTimeServer.date.cnEcGetFirstDayOfMonth then
						replacedTax := self.externalTaxNumber ;
						replacedTax[3:1] := "1";
						cloneInv.externalTaxNumber := replacedTax; 
					endif;
				endif;
			endif;orginalTaxCode
		endif;
	endif;
	*/
	foreach invLine in invoiceLines do
		cloneInvLine := invLine.cloneForReturn( cloneInv, false );
	endforeach;
	
	audit := cloneInv.doAuditInvStatusChanged(cmifStatus,0);
	if audit &lt;&gt; null then
		audit.setRemarksForReturn( self );
	endif;
	
	// ### JIRA 19932 21OCT2024 NAVAB1
	cloneInv.setMyInvoiceProcess(self.getMyInvoiceProcess); // TFS 39618 - reference not cloned	
	
	return cloneInv;
	
epilog
	delete cmifStatus;
end;</source>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="cloneForReturn" id="fa7ddf2d-09a7-49e3-857c-42a4edd2d3c1">
        <source>cloneForReturn( _asCredit : Boolean ) : CM_Invoice;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2017	jlgndl1	Initial creation	TFS 6759
24 September 2018   cnwma1	Bug 40487: PEL1 - SAP Receive Document Cancellation
30 Se[tember 2019   cnwma1	Bug 46798: ASPA - AddressID Missing from Credit Memo
24 Sept		2024	jlier1  TFS 65963 CR 65949 NSW | Dynamic Integration Development
*/

vars

	cloneInv     : CM_Invoice;
	invLine      : CM_InvoiceLine;
	finIOClass   : CM_ExtFinanceIO;
	cloneInvLine : CM_InvoiceLine;
	now 		 : TimeStamp;
	cmifStatus   : CMIF_InvoiceStatus;
	audit        : CM_FinAuditInvStatusChanged;
	replacedTax  : String;

begin
	now := app.actualTimeAppServer; // TFS 43820 JLGAB1 

	cloneInv := self.cloneSelf( false );
//	cloneInv.setMyInvoiceProcess(self.getMyInvoiceProcess); // TFS 39618 - reference not cloned
	cloneInv.setPreviousStatus(self.previousStatus); // TFS 39618	

	/* removed, think it should be used but putting back to pre ticket being raised.
	// TFS 43820 JLGAB1 the dates will be cloned, lets null them all out and then they can be set as necessary
	cloneInv.prependDT := null; // TFS 43820 JLGAB1 
	cloneInv.pendingDT := null; // TFS 43820 JLGAB1 
	cloneInv.postedDT := null; // TFS 43820 JLGAB1 
	dateTime := app.serverTimestampAtTrxStart; // TFS 43820 JLGAB1
	if self.invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then // TFS 43820 JLGAB1
		cloneInv.fromDT := app.myRoot.myRootCompany.getPeriodEndDateInitialise(self.debtor, self.invoiceType, dateTime,false); // TFS 43820 JLGAB1
		cloneInv.toDT := app.myRoot.myRootCompany.getPeriodEndDateInitialise(self.debtor, self.invoiceType, dateTime,true);  // TFS 43820 JLGAB1
	else
		cloneInv.fromDT := dateTime; // TFS 43820 JLGAB1
		cloneInv.toDT := null;
	endif;
	*/
	
	create cmifStatus transient;
	/*// TFS 39618 PATCH 1 moved to bottom
	if _asCredit then
		//cloneInv.status := INVOICE_POSTED_CREDIT;
		cloneInv.setStatus( INVOICE_POSTED_CREDIT );	//13 Jun 2018	NDL	TFS 39197
		cmifStatus.newStatus := INVOICE_POSTED_CREDIT;
		now := app.actualTimeAppServer;
		cloneInv.postedDT := now;
	else
		//cloneInv.status := INVOICE_PENDING;
		cloneInv.setStatus( INVOICE_PENDING );	//13 Jun 2018	NDL	TFS 39197
		cmifStatus.newStatus := INVOICE_PENDING;
	endif;
	*/
	cloneInv.exportedCount := 0;
	cloneInv.sequenceNum      := self.bank.getSeqNum(SN_INVOICE);
	cloneInv.invoiceType      := self.invoiceType;
	cloneInv.paymentType      := self.paymentType; 			//10 Oct 2018	NDL	TFS 41281
	cloneInv.myBillingAddress := self.myBillingAddress;     //30.09.2019 cnwma1 #46798
	cloneInv.myBOL            := self.myBOL;
	cloneInv.myTrackedItem    := self.myTrackedItem;
	cloneInv.myVoyage         := self.myVoyage;
	cloneInv.debtor           := self.debtor;
	cloneInv.externalNumber	  := null; //can't have the same external number as the orginal this will cause an 1310 exception
	if self.myInvoiceProcess &lt;&gt; null and self.myInvoiceProcess.isInvoiceAPIProcess then
		cloneInv.externalFinancialId:=null;
	endif;
	
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass.setExternalOnCreate() then
		cloneInv.setExternalInvoiceNumber(finIOClass.setExternalInvoiceNumber(self));
	endif;
	
	//24.09.2018 cnwma1 Bug 40487
	/*
	c.	The third digit of the above codes is changed from a 0 to a 1 if the invoice is a replacement. This only occurs if the invoice being
	replaced is not from the current month. 
	*/
	if self.externalTaxNumber &lt;&gt; null then
		if finIOClass.isKindOf(CM_Pelindo1Interface) then
			if self.postedDT.Date.cnEcGetFirstDayOfMonth &lt; app.actualTimeServer.date.cnEcGetFirstDayOfMonth then
				replacedTax := self.externalTaxNumber ;
				replacedTax[3:1] := "1";
				// TFS 43820 JLGAB1 cloneInv.externalTaxNumber := replacedTax; 
				cloneInv.setTaxDetails(replacedTax,now); // TFS 43820 JLGAB1 
			endif;
		endif;
	endif;
	
	cloneInv.bank             := self.bank; //02/04/2025	navkc1 JIRA Bug MTN-34085
	//24.09.2018 cnwma1 Bug 40487
	// TFS 39618 PATCH 1
	if _asCredit then
		//cloneInv.status := INVOICE_POSTED_CREDIT;
		if self.myInvoiceProcess.isInvoiceAPIProcess then
			cloneInv.setStatus(INVOICE_POSTED_CREDIT_PENDING);
			cmifStatus.newStatus:=INVOICE_POSTED_CREDIT_PENDING;
		else
			cloneInv.setStatus( INVOICE_POSTED_CREDIT );	//13 Jun 2018	NDL	TFS 39197
			cmifStatus.newStatus := INVOICE_POSTED_CREDIT;
		endif;
		now := app.actualTimeAppServer;
		cloneInv.postedDT := now;
		//jlier1 18/9/24 TFS 65963 : CR 65949 NSW | Dynamic Integration Development
		if self.myInvoiceProcess.isInvoiceAPIProcess  and self.bank &lt;&gt; null and cloneInv.externalNumber = null   then
			cloneInv.externalNumber:=self.bank.generateNextCrdInvExtNumber();
		endif;
		
	else
		//cloneInv.status := INVOICE_PENDING;
		cloneInv.setStatus( INVOICE_PENDING );	//13 Jun 2018	NDL	TFS 39197
		cmifStatus.newStatus := INVOICE_PENDING;
	endif;
	//cloneInv.bank             := self.bank; //02/04/2025	navkc1 JIRA Bug MTN-34085
	
	//jlier1 JIRA#34066 20/2/25 -ignored voided invoice lines
	foreach invLine in invoiceLines where not invLine.voided do
		cloneInvLine := invLine.cloneForReturn( cloneInv, _asCredit );
	endforeach;
	
	audit := cloneInv.doAuditInvStatusChanged(cmifStatus,0);
	if audit &lt;&gt; null then
		audit.setRemarksForReturn( self );
	endif;

	
	// ### JIRA 19932 21OCT2024 NAVAB1
	cloneInv.setMyInvoiceProcess(self.getMyInvoiceProcess); // TFS 39618 - reference not cloned	

	return cloneInv;

epilog

	delete cmifStatus;

end;</source>
        <Parameter name="_asCredit" type="Boolean"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="coversTimeStamp" id="3d469c3e-b4e7-461b-ad06-55b7ee0f056c">
        <source>coversTimeStamp(datetime: TimeStamp): Boolean;
// if either of the time stamps are invalid then we say no
vars
	above:  Boolean;
	below:  Boolean;

begin
	if not self.fromDT.isValid then
		above := false;
	elseif self.fromDT &lt;= datetime then
		above := true;
	endif;

	if not self.toDT.isValid then
		below := false;
	elseif self.toDT &gt;= datetime then
		below := true;
	endif;

	return above and below;
end;</source>
        <Parameter name="datetime" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="coversTimeStampEvent" id="d34bd512-3095-4ac6-8f54-4c5d6158682a">
        <source>coversTimeStampEvent(_tran: CM_EventTransaction): Boolean;
// ---------------------------------------------------------------------------
// Created:		October By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	above:  Boolean;
	below:  Boolean;
	theToDate : TimeStamp;
	datetime: TimeStamp;
begin
	datetime := _tran.dateTime;
	
	if not fromDT.isValid then
		above := false;
	elseif fromDT &lt;= datetime then
		above := true;
	endif;

	if not toDT.isValid then
		below := false;
	elseif toDT &gt;= datetime then
		below := true;
	endif;


	return above and below;
end;</source>
        <Parameter name="_tran" type="CM_EventTransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="coversTimeStampTransaction" id="7b8d5a3d-e215-4849-9aff-355f26fc0b24">
        <source>coversTimeStampTransaction(_tran: CM_TITransaction): Boolean;
/* ---------------------------------------------------------------------------
Created:	July 2004 By Andrew Bishop cnwab1

Purpose:		

Changed On	By		TFS		Reason
----------	------	-----	-----------------------------------------------------
31 Jan 2020	jlgdi1	48447	Simplify the code. Remove adding 1 day (line 54) which causes an issue where an invoice incorrectly assigned/linked  
							an Invoice Line created by a transaction (Future Storage) that happens on the 1st day of the month.
							The concept on adding one day is affected by a code change raised on TFS 46956.
---------------------------------------------------------------------------
*/

vars
	transDateTime : TimeStamp;
	
begin	
	if (not self.fromDT.isValid()) or (not self.toDT.isValid()) then 
		return false;
	endif;
	
	transDateTime := _tran.dateTime;
	
	return (transDateTime &gt;= self.fromDT) and ((transDateTime &lt;= self.toDT));
	

	/*    Code Refactor 
	datetime := _tran.dateTime;
	
	if not fromDT.isValid then
		above := false;
	elseif fromDT &lt;= datetime then
		above := true;
	endif;

	if not toDT.isValid then
		below := false;
	elseif toDT &gt;= datetime then
		below := true;
	endif;

	// PAR 3271 AKB2002AUG from here
	// If the Auto Evaluate Storage Process is running then because it checks for the closing date and closes any invoices
	// that have expired, we need to jig the to date here so that the Storage transactions that we are creating are added to this still
	// open invoice. After creating all of the storage transactions we close the invoice
	
	// if below is false then we may be doing auto eval, so do further processing...
	if below = false then
		if _tran.isKindOf(CM_Storage) then
			if _tran.CM_Storage.isCreatedByBGP() then
				// we add 1 day to the ToDT on the invoice
				theToDate.setDate(toDT.date + 1);
				theToDate.setTime(toDT.time);
				if theToDate &gt;= datetime then
					below := true;
				endif;
			endif;
		endif;
	endif;

	return above and below;
	*/
	
end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="coversTimeStampVTMIS" id="c32a0074-348e-4d87-95e6-ee7148491a0d">
        <source>coversTimeStampVTMIS(_tran: HMS_VTMISTransaction): Boolean;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	above:  Boolean;
	below:  Boolean;
	theToDate : TimeStamp;
	datetime: TimeStamp;
begin
	datetime := _tran.transactionDT;
	
	if not fromDT.isValid then
		above := false;
	elseif fromDT &lt;= datetime then
		above := true;
	endif;

	if not toDT.isValid then
		below := false;
	elseif toDT &gt;= datetime then
		below := true;
	endif;


	return above and below;
end;</source>
        <Parameter name="_tran" type="HMS_VTMISTransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="coversTimeStampWO" id="724baa6a-a05c-415e-9e41-526f125baf7f">
        <source>coversTimeStampWO(_tran: CM_WOTransaction): Boolean;
/*
Purpose:		TFS 39237	
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/
vars
	above:  Boolean;
	below:  Boolean;
	theToDate : TimeStamp;
	datetime: TimeStamp;
begin
	datetime := _tran.dateTime;
	
	if not fromDT.isValid then
		above := false;
	elseif fromDT &lt;= datetime then
		above := true;
	endif;

	if not toDT.isValid then
		below := false;
	elseif toDT &gt;= datetime then
		below := true;
	endif;


	return above and below;
end;</source>
        <Parameter name="_tran" type="CM_WOTransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createFutureActor" id="428a14c3-ef13-41f9-ac4c-45b412277437">
        <source>createFutureActor(_invoice : CM_Invoice);
/*

Purpose: Create future actor when needed. 
		 The condition when to create future actor is on the method caller.

Dev Note : This method is created for code reusability.
           The code is originaly found in CM_invoice.setForUpdateStatus (line 166).
		   The TFS 47063 requires creation of Future Actor for Additional Fees (Surcharge) when 
		   a parent Invoice status changed from Open to PrePend and 
		   is configured to trigger creation of new invoice line corresponding to Surcharge Additional Fees.

Date		Who		TFS		Reason
18 Oct 2019	jlgdi1	47063	Initial creation
*/

constants
	ONE_DAY : Integer = 1;
	
vars
	futureActor : CM_InvoiceStatusAdvanceProcess;
	actionTimeStamp : TimeStamp;
	
begin
	create futureActor persistent;
	futureActor.setMyInvoice(_invoice);
	futureActor.setStatusDetails(CM_Invoice.INVOICE_PREPEND, CM_Invoice.INVOICE_PENDING);
	
	if self.paymentType = PaymentType_AutoCollection then
		actionTimeStamp := app.actualTimeServer.addDays(ONE_DAY);
	elseif self.paymentType = PaymentType_PostPay then  //02 Nov 2018	TFS 41769
		actionTimeStamp := app.actualTimeServer.addDays(ONE_DAY);
	endif;
	
	futureActor.setActionTimeStamp(actionTimeStamp);
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="createManLineForNonAssigned" id="ffdaba83-376d-489e-ae5a-2935fb2b7a47">
        <source>createManLineForNonAssigned( _pxyInvLine : CM_InvoiceLine input; _qty : Integer; _amount : Decimal ) : CM_InvoiceLine;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	newLine : CM_InvoiceLine;
	seqNum : Integer;
	charge : CM_Charge;
	qty : Integer;
	theController : CMIF_InvoiceLineManual; //29/09/2025	navkc1 JIRA 35917
begin

	qty := _qty;
	if qty = 0 then
		qty := 1;
	endif;
	/*//29/09/2025	navkc1 JIRA 35917 Change to use standard CMIF_InvoiceLineManual
	create newLine persistent;
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
	newLine.setForCreate(	seqNum,
							true,
							_pxyInvLine.remarks,
							_pxyInvLine.invoiceLineDesc,
							self,
							self.debtor,
							self.bank,
							qty,
							app.actualTimeServer()
							);
	
	newLine.setTrackedItem( _pxyInvLine.trackedItem );
	newLine.createCharges;
	
	foreach charge in newLine.charges do
		charge.evaluateRate();
		if _amount &gt; 0 then
			charge.total := _amount;
		endif;
		charge.setOverriden();
		if _amount &gt; 0 then
			charge.setRateForMinMax(_amount);
		else
			charge.setRateForMinMax(charge.total);
		endif;
	endforeach;
	newLine.setTotalAmount();  // ### JIRA 35502 21JUL2025 NAVAB1 if setting the total then set static value as well
	*/
	
	//29/09/2025	navkc1 JIRA 35917
	create theController transient;
	theController.remarks := _pxyInvLine.remarks;
	theController.myInvoice := self;
	theController.quantity := qty;
	theController.chargeTime := app.actualTimeServer();
	theController.isOverridden := true;
	theController.totalAmount := _amount;
	theController.myTrackedItem := _pxyInvLine.trackedItem;
	theController.rate := _amount;
	
	newLine := _pxyInvLine.invoiceLineDesc.createManualInvoiceLine(theController, _pxyInvLine.trackedItem, false);
	
	return newLine;

epilog
	delete theController; //29/09/2025	navkc1 JIRA 35917
end;</source>
        <Parameter name="_pxyInvLine" type="CM_InvoiceLine" usage="input"/>
        <Parameter name="_qty" type="Integer"/>
        <Parameter name="_amount" type="Decimal"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="createMinimumCharge" id="5bed2c12-6775-4b41-9efc-c6b16ba35590">
        <source>createMinimumCharge( 	_minimumChargeInvoiceLineType : CM_InvoiceLineDesc input;
						_debtor : CM_Debtor input;
						_newTotal : Decimal ) protected;
/*

Date			Who		Reason
19 January 2017	cnwer1	Initial creation TFS 2903
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	newLine : CM_InvoiceLine;
	seqNum : Integer;
	charge : CM_Charge;
	canLogExtra	: Boolean;	//26.02.2025 navah1	#34141
	theController : CMIF_InvoiceLineManual; //29/09/2025	navkc1 JIRA 35917
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	
	/*//29/09/2025	navkc1 JIRA 35917 Change to use standard CMIF_InvoiceLineManual
	create newLine persistent;
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
//	newLine.setForCreate(seqNum, false, null, _minimumChargeInvoiceLineType, self, _debtor, self.bank, 1, app.actualTimeServer());
	newLine.setForCreate(seqNum, true, null, _minimumChargeInvoiceLineType, self, _debtor, self.bank, 1, app.actualTimeServer());
	newLine.createCharges;
	foreach charge in newLine.charges do
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); // TFS 42084
		endif;
		charge.evaluateRate();
		charge.total := _newTotal;
// TFS 42084 charge.isTotalSetExplicitly := true; // should not have used isTotalSetExplicitly should have used overridden
		charge.setOverriden(); // TFS 42084
	//	charge.setRateForMinMax(charge.total);
		charge.setRateForMinMax( _newTotal );	//01 May 2019	NDL	TFS 44534
	endforeach;
	
	newLine.setTotalAmount();  // ### JIRA 35502 21JUL2025 NAVAB1 if setting the total then set static value as well	
	*/
	//29/09/2025	navkc1 JIRA 35917
	create theController transient;
	theController.myInvoice := self;
	theController.quantity := 1;
	theController.chargeTime := app.actualTimeServer();
	theController.isOverridden := true;
	theController.totalAmount := _newTotal;
	theController.rate := _newTotal;
	
	newLine := _minimumChargeInvoiceLineType.createManualInvoiceLine(theController, null, false);
	
epilog
	delete theController; //29/09/2025	navkc1 JIRA 35917
end;</source>
        <access>protected</access>
        <Parameter name="_minimumChargeInvoiceLineType" type="CM_InvoiceLineDesc" usage="input"/>
        <Parameter name="_debtor" type="CM_Debtor" usage="input"/>
        <Parameter name="_newTotal" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="createMinimumChargesForGroup" id="4abd62fb-f251-4efa-b3df-930dfd7f8ea1">
        <source>createMinimumChargesForGroup(allGroupedInvoiceLines : ObjectArray input)  protected;
/*

Date		Who		Reason
18 January 2017	cnwer1	Initial creation TFS 2903

*/

vars
	//minChargeAmount,minTotal : Decimal[16,6];
	invLine  : CM_InvoiceLine;
	obj : Object;
	invLineDesc : CM_InvoiceLineDesc;
	minChargeAmount,minTotal : Decimal[23,6];	//11 May 2018	NDL	TFS 38528
begin
	if allGroupedInvoiceLines = null or allGroupedInvoiceLines.isEmpty then
		return;
	endif;
	
	foreach obj in allGroupedInvoiceLines discreteLock do
		invLine :=obj.CM_InvoiceLine;
		minTotal:= minTotal + invLine.lineTotal;
	endforeach;
	
	if invLine = null then
		return;
	endif;
	invLineDesc:= invLine.invoiceLineDesc;
	if invLineDesc.group &lt;&gt; null and invLineDesc.group.myMinimumChargeInvoiceLineType &lt;&gt; null then
		minChargeAmount:=invLineDesc.group.minimumChargeAmount;
		invLineDesc:=invLineDesc.group.myMinimumChargeInvoiceLineType;
	else
		minChargeAmount:=invLineDesc.minimumChargeAmount;
		if invLineDesc.minimumChargeGroupBy &lt;&gt; CM_InvoiceLineDesc.GROUP_BY_INVOICE then
			return;
		endif;
		invLineDesc:=invLineDesc.minimumChargeInvoiceLineType;
	endif;
	
	if minTotal &lt; minChargeAmount then
		
		self.createMinimumCharge(invLineDesc,invLine.debtor,minChargeAmount - minTotal);
	
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="allGroupedInvoiceLines" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createMovementMinCharge" id="7bb49f69-ecb3-48dc-9596-8487cb5114e6">
        <source>createMovementMinCharge();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 March 2019	jlgndl1	Initial creation	TFS 43687
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars

	surChgExempt : CM_InvoiceTypeSurchargeExempt;
	effectiveDT : TimeStamp;
	conversionRate : CM_CurrencyRate;
	invLine : CM_InvoiceLine;
	invLineType : CM_InvoiceLineDesc;
	movement : HMS_VoyageMovement;
	grpMinChg : CM_InvTypeGroupingMinCharge;
	invLinesToProcess : CM_InvoiceLineSet;
	minGroupingsToProcess : CM_InvTypeGroupingMinChargeSet;
	desc : String;
	linesSubSet : CM_InvoiceLineBySeqNumDict;
	invSubSetTotal : Decimal [23,6];
	diff : Real;
	minChg : Real;
	rawDiff : Real;
	minChgInvLineType : CM_InvoiceLineDesc;
	remark : String;
	newLine : CM_InvoiceLine;
	seqNum : Integer;
	charge : CM_Charge;
	canLogExtra	: Boolean;	//26.02.2025 navah1	#34141
	theController : CMIF_InvoiceLineManual; //29/09/2025	navkc1 JIRA 35917
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog("Checking for Grouping Surcharges", LogINFO.String);
	endif;
	if self.myVoyage = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("No Voyage", LogINFO.String);
		endif;
		return;
	endif;
	
	if self.invoiceType &lt;&gt; null then
		surChgExempt := self.invoiceType.mySurchargeAndExemptions;
	endif;
	if surChgExempt = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("No Surcharges found", LogINFO.String);
		endif;
		return;
	endif;
	if surChgExempt.allInvTypeGroupingMinCharges.isEmpty then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("No " &amp; CM_Invoice.GrpMinCharge &amp; " found", LogINFO.String);
		endif;
		return;
	endif;
	if self.invoiceLines.isEmpty then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("No Invoice Lines found", LogINFO.String);
		endif;
		return;
	endif;
	
	//Get a collection of the groupings we actually need to process for this invoice, and the invoice lines they match.
	create invLinesToProcess transient;
	create minGroupingsToProcess transient;
	
	foreach invLine in self.invoiceLines do
		invLineType := invLine.invoiceLineDesc;
		movement := invLine.getMyMovementObject();
		grpMinChg := surChgExempt.allInvTypeGroupingMinCharges.getGroupingFor( invLineType, movement, null );
		if grpMinChg &lt;&gt; null then
			//we found a matching grouping for this line, add it to teh collection
			invLinesToProcess.addNoDuplicates( invLine, false );
			minGroupingsToProcess.addNoDuplicates( grpMinChg, false );
		endif;
	endforeach;
	
	if minGroupingsToProcess.isEmpty or invLinesToProcess.isEmpty then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("No Matching " &amp; CM_Invoice.GrpMinCharge &amp; " found", LogINFO.String);
		endif;
		return;
	endif;
	
	if surChgExempt.myCurrencyType &lt;&gt; null then
		effectiveDT := self.getRateDateForCurrencyCode();
		conversionRate := surChgExempt.myCurrencyType.getRate( effectiveDT );
	endif;
	
	//check that the lineType we would create is not also one that we should be checking for.
	//issue a warning if we do.
	foreach grpMinChg in minGroupingsToProcess do
		if minGroupingsToProcess.includesGrpForLineType( grpMinChg.getMinimumChargeInvLineType, desc ) then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog( grpMinChg.getMinimumChargeInvLineType.narration &amp; " will be created by '" &amp; grpMinChg.description &amp; "' which is included in Matching Grouping Min Charges " &amp; desc, LogINFO.String);
			endif;
		endif;
	endforeach;
	
	create linesSubSet transient; // To use to hold the sub set of lines per Grouping.
	
	foreach grpMinChg in minGroupingsToProcess do
	
		linesSubSet.clear();
		grpMinChg.getMatchingLines( invLinesToProcess, linesSubSet, null ); // gets the sub set of lines that are relevant for this particular grouping.
		
		invSubSetTotal := self.getTotalAmountConverted( conversionRate, linesSubSet );
		minChg := grpMinChg.minimumChargeAmount;
		minChgInvLineType := grpMinChg.getMinimumChargeInvLineType;
		
		if self.invoiceLines.includesInvLineType( minChgInvLineType ) then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog( grpMinChg.description &amp; " " &amp; CM_Invoice.GrpMinCharge &amp; " ignored, Invoice already includes an invoice line type of " &amp; minChgInvLineType.narration, LogINFO.String);
			endif;
		elseif invSubSetTotal &lt;= 0 then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog( grpMinChg.description &amp; " " &amp; CM_Invoice.GrpMinCharge &amp; " ignored, Invoice Grouping Total = " &amp; invSubSetTotal.String, LogINFO.String);
			endif;
		elseif minChg &gt; invSubSetTotal then
			app.invLog("Creating Invoice line to meet " &amp; grpMinChg.description &amp; " " &amp; CM_Invoice.GrpMinCharge &amp; " ", LogINFO.String);
			diff := minChg - invSubSetTotal;
			remark := "Invoice Grouping Total = " &amp; invSubSetTotal.String &amp; " " &amp; CM_Invoice.GrpMinCharge &amp; " = " &amp; minChg.String &amp; " Difference = " &amp; diff.String;
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(remark, LogINFO.String); 
			endif;
			if minChgInvLineType.currencyConversionNotRequired or conversionRate = null or conversionRate.rate = 0 then
				// all good, no conversion needed, generate the line as is
			else
				// convert diff to other currency
				rawDiff := diff;
				diff := conversionRate.convertBaseCurrencyToMe( rawDiff, 0 );	
				remark := remark &amp; " converted to " &amp; diff.String &amp; "( using " &amp; conversionRate.getDisplayDetails(false) &amp; ")"; 
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog(remark, LogINFO.String);
				endif;
			endif;
			
			/*//29/09/2025	navkc1 JIRA 35917 Change to use standard CMIF_InvoiceLineManual
			create newLine persistent;
			seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
			newLine.setForCreate(	seqNum,
									true,
									remark,
									minChgInvLineType,
									self,
									self.debtor,
									self.bank,
									1,
									app.actualTimeServer()
									);
			newLine.createCharges;
			foreach charge in newLine.charges do
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); 
				endif;
				charge.evaluateRate();
				charge.total := diff;
				charge.setOverriden();
				charge.setRateForMinMax(diff);
			endforeach;
			*/
			//29/09/2025	navkc1 JIRA 35917
			create theController transient;
			theController.remarks := remark;
			theController.myInvoice := self;
			theController.quantity := 1;
			theController.chargeTime := app.actualTimeServer();
			theController.isOverridden := true;
			theController.totalAmount := diff;
			theController.rate := diff;
			
			newLine := minChgInvLineType.createManualInvoiceLine(theController, null, false);
			
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("Invoice Minimum Charge already exceeded", LogINFO.String);
			endif;
		endif; 
		
		//remove the ones we just processed.
		foreach invLine in linesSubSet do
			invLinesToProcess.remove( invLine );
		endforeach;
		
		if invLinesToProcess.isEmpty then
			//nothing left to do here
			break;
		endif;
		
	endforeach;

epilog

	delete invLinesToProcess;
	delete minGroupingsToProcess;
	delete linesSubSet;
	delete theController; //29/09/2025	navkc1 JIRA 35917
end;</source>
    </JadeMethod>
    <JadeMethod name="createdBy" id="afa8422e-74d3-420b-b4d0-56722f841df4">
        <source>createdBy():CM_User;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2018	jlgndl1	Initial creation	TFS 40494

*/

vars

	user : CM_User;
	audit : CM_AuditObject;
	
begin

	audit := self.allAuditObjectsForClass.first();	//21 Jan 2021	NDL	TFS 50251
	if audit &lt;&gt; null then
		return audit.myUser;
	endif;

	return null;

epilog

end;</source>
        <ReturnType type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="delete" id="f1ca9315-da39-477c-84b4-2e7d6610ff23">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2018	jlgmp6	Initial creation	TFS37718

*/

vars
	
begin
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152
	
	//11 Feb 2019	NDL	TFS 43318
	app.myRoot.deleteFutureActor(self, CM_InvoiceStatusAdvanceProcess);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAuditInvStatusChanged" id="3b47a190-d1bf-46d7-ba85-16af4e048eb8">
        <updating/>
        <source>doAuditInvStatusChanged(_status : CMIF_InvoiceStatus;
						_oldStatus : Integer):CM_FinAuditInvStatusChanged updating, protected;
 //----------------------------------------------
//Created: 27 September 2001  By: cnwgd1
//----------------------------------------------
vars

	auditStatusChg	: CM_FinAuditInvStatusChanged;
	now				: TimeStamp;
	newStatus: Integer;
	
begin

	if _status = null then
		return null;
	endif;
	newStatus:=_status.newStatus;
	if newStatus = null then
		return null;
	endif;
	
	if newStatus = _oldStatus then
		return null;
	endif;
	
	//always audit the status change
	create auditStatusChg;
	auditStatusChg.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT); // PAR 15036 

	auditStatusChg.clearingRemarks := _status.voidReason;
	auditStatusChg.statusChangeReasonCode:=_status.voidReasonCode;
	
	
	auditStatusChg.previousStatus := _oldStatus;
	auditStatusChg.newStatus := newStatus;
	auditStatusChg.invoice := self;
	auditStatusChg.userId := app.getMyUserCode;
	auditStatusChg.dateTime := now;
	auditStatusChg.auditedFOs.clear;
	auditStatusChg.unauditedFOs.clear;
	//put the inv in audited FinObj since the auditing is handled at the invoice level.
	auditStatusChg.auditedFOs.add(self);
	auditStatusChg.setRemarks;
	
	return auditStatusChg;

end;</source>
        <access>protected</access>
        <Parameter name="_status" type="CMIF_InvoiceStatus"/>
        <Parameter name="_oldStatus" type="Integer"/>
        <ReturnType type="CM_FinAuditInvStatusChanged"/>
    </JadeMethod>
    <JadeMethod name="doCopyProcessing" id="74b92fbf-6c87-4555-8b5f-d7a50c8b8de0">
        <updating/>
        <source>doCopyProcessing(_pendingCMIF : CMIF_InvoiceStatus;
				_newReserveStatus : Integer;
				_pendingInv : CM_Invoice output;
				_passport : CM_Passport input
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Oct  2018    cnwma1 ChangeRequest 41703: PEL1 - Sap Integration - Post Billing Cancelled Invoice

*/

vars
	cmifStatus : CMIF_InvoiceStatus;
	oldStatus : Integer;
	invLine   : CM_InvoiceLine;
	dateTime : TimeStamp;
	finIOClass : CM_ExtFinanceIO;	////08 Apr 2019	NDL	TFS 44245
begin
	
	_pendingInv := self.cloneForCopy();
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	if _pendingCMIF.myTermsOfTrade &lt;&gt; null then
		_pendingInv.termsOfTradeCode := _pendingCMIF.myTermsOfTrade.code;
		_pendingInv.termsOfTrade	 := _pendingCMIF.myTermsOfTrade.description;
	endif;
	
	
	// TFS 43820 JLGAB1 the dates will be cloned, lets null them all out and then they can be set as necessary
	/*removed, think it should be used but putting back to pre ticket being raised. 
	_pendingInv.prependDT := null; // TFS 43820 JLGAB1 
	
	if _newReserveStatus = CM_Invoice.INVOICE_POSTED_REVERSE then // TFS 43820 JLGAB1 
		_pendingInv.pendingDT := null; // TFS 43820 JLGAB1 
		_pendingInv.postedDT := self.postedDT; // TFS 43820 JLGAB1 
	endif;
	if _newReserveStatus = CM_Invoice.INVOICE_PENDING_REVERSE then // TFS 43820 JLGAB1 
		_pendingInv.pendingDT := self.pendingDT; // TFS 43820 JLGAB1 
		_pendingInv.postedDT := null; // TFS 43820 JLGAB1 
	endif;
	
	if self.invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then // TFS 43820 JLGAB1
		_pendingInv.fromDT := app.myRoot.myRootCompany.getPeriodEndDateInitialise(self.debtor, self.invoiceType, dateTime,false); // TFS 43820 JLGAB1
		_pendingInv.toDT := app.myRoot.myRootCompany.getPeriodEndDateInitialise(self.debtor, self.invoiceType, dateTime,true);  // TFS 43820 JLGAB1
	else
		_pendingInv.fromDT := dateTime; // TFS 43820 JLGAB1
		_pendingInv.toDT := null;
	endif;
	*/
	_pendingInv.narration 			:= _pendingCMIF.narration;
	_pendingInv.isZeroRatedTax 		:= _pendingCMIF.isZeroRatedTax;
	_pendingInv.purchaseOrderNumber := _pendingCMIF.purchaseOrderNumber;
	_pendingInv.toDT 				:= _pendingCMIF.toDT;
	_pendingInv.debtorReference 	:= _pendingCMIF.debtorReference;
	_pendingInv.paymentStatus       := _pendingCMIF.paymentStatus;
	
	//08 Apr 2019	NDL	TFS 44245
	if _pendingCMIF.requiresNewPaymentCode then
		finIOClass := self.myTerminal.getConfig( FinancialIOClass ).CM_ExtFinanceIO;
		if finIOClass.isKindOf( CM_Pelindo1Interface ) then
			_pendingInv.paymentCode := finIOClass.getPaymentCode( _pendingInv );
		endif;
	endif;
	
	if app.myPassport.hasErrors then
		return;
	endif;

	create cmifStatus transient;
	cmifStatus.newStatus := _newReserveStatus;
	oldStatus := self.status;
	self.setPreviousStatus(oldStatus); // TFS 39618	
	self.setStatus( _newReserveStatus );
	
	self.doAuditInvStatusChanged(cmifStatus,oldStatus);
	
	foreach invLine in self.invoiceLines do
		invLine.changeStatus( CM_InvoiceLine.STATUS_VOIDED );
	endforeach;
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	self.myReversedPendingInvoice := _pendingInv;
	
epilog
	delete cmifStatus;
end;</source>
        <Parameter name="_pendingCMIF" type="CMIF_InvoiceStatus"/>
        <Parameter name="_newReserveStatus" type="Integer"/>
        <Parameter name="_pendingInv" type="CM_Invoice" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNotifyLinkedInvoicesCNotes" id="054ca049-1429-43c7-99b1-81e5500b1fb6">
        <source>doNotifyLinkedInvoicesCNotes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/10/2024	navkc1	JIRA 12538 MTN - (minor) Invoice doesn't refresh on Copy

*/

vars
	invoice : CM_Invoice;
	invoiceSet : CM_InvoiceSet;
begin
	create invoiceSet transient;
	
	// All other invoices collection
	self.allOtherInvoices.copy(invoiceSet);
	
	// Adding self
	invoiceSet.addNoDuplicates(self, false);
	
	// Add myOtherInvoice reference
	invoice := self.myOtherInvoice;
	if invoice &lt;&gt; null then
		invoiceSet.addNoDuplicates(invoice, false);
	endif;
	
	// Now do notification
	foreach invoice in invoiceSet do
		invoice.causeEvent(invoice.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, invoice);
	endforeach;
	
epilog
	delete invoiceSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doReturnProcessing" id="94659689-fc98-43ed-9467-0f13f0635115">
        <updating/>
        <source>doReturnProcessing( _creditCMIF : CMIF_InvoiceStatus;
					_creditInv : CM_Invoice output;
					_pendingInv : CM_Invoice output;
					_passport : CM_Passport input
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2017	jlgndl1	Initial creation	TFS 6759

*/

vars
	invLine : CM_InvoiceLine;
	cmifStatus : CMIF_InvoiceStatus;
	oldStatus ,newStatus : Integer;

begin

	_creditInv := self.cloneForReturn( true );
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	if _creditCMIF.myTermsOfTrade &lt;&gt; null then
		_creditInv.termsOfTradeCode := _creditCMIF.myTermsOfTrade.code;
		_creditInv.termsOfTrade := _creditCMIF.myTermsOfTrade.description;
	endif;
	
	_creditInv.narration := _creditCMIF.narration;
	_creditInv.isZeroRatedTax := _creditCMIF.isZeroRatedTax;
	_creditInv.purchaseOrderNumber := _creditCMIF.purchaseOrderNumber;
	_creditInv.toDT := _creditCMIF.toDT;
	_creditInv.debtorReference := _creditCMIF.debtorReference;
	
	if _creditCMIF.newPending then
		_pendingInv := self.cloneForReturn( false );
	endif;
	
	if app.myPassport.hasErrors then
		return;
	endif;

	create cmifStatus transient;
	newStatus := INVOICE_POSTED_REVERSE;
		

	cmifStatus.newStatus := newStatus;
	oldStatus := self.status;
	self.setPreviousStatus(oldStatus); // TFS 39618	
	//self.status := INVOICE_POSTED_REVERSE;
	self.setStatus( newStatus);	//13 Jun 2018	NDL	TFS 39197
	
	self.doAuditInvStatusChanged(cmifStatus,oldStatus);
	
	foreach invLine in self.invoiceLines do
		invLine.changeStatus( CM_InvoiceLine.STATUS_VOIDED );
	endforeach;
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	self.myReversedCreditInvoice := _creditInv;
	self.myReversedPendingInvoice := _pendingInv;

	// ### TFS CR 63369 TASK 63687 23APR2024 NAVAB1
	if _creditInv &lt;&gt; null then
		_creditInv.setTaxDetailsFromLines();
		_creditInv.setTotalAmountFromLines();
	endif;
	if _pendingInv &lt;&gt; null then
		_pendingInv.setTaxDetailsFromLines();
		_pendingInv.setTotalAmountFromLines();
	endif;
	/*
	if _creditCMIF.doExport and _creditInv &lt;&gt; null then
		finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		if finIOClass &lt;&gt; null then
			on Exception do app.handleDeletedObject( exception, finIOClass, invalid );
			edition := finIOClass.edition;
		endif;
		if finIOClass = null or invalid then
			create finIOClass as CM_DefaultFinanceIO transient;
			createdTransient := true;
		endif;
		finIOClass.export( _creditInv );
	endif;
	*/

epilog

/*	if createdTransient then
		delete finIOClass;
	endif; */
	delete cmifStatus;

end;</source>
        <Parameter name="_creditCMIF" type="CMIF_InvoiceStatus"/>
        <Parameter name="_creditInv" type="CM_Invoice" usage="output"/>
        <Parameter name="_pendingInv" type="CM_Invoice" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="emailNotify" id="d6e74fa1-4d34-4e38-a6e4-f0fcdc63f7e7">
        <source>emailNotify(_objectEmail: CM_ObjectEmail; _isDelete: Boolean; _object: CM_Object input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 December 2022    navmv20 Task 55514: Jade - Email Invoice Attachments Jade Code
25 January 2023		navvt20 TFS CR 56204 Task 56208: Jade - Invoice Status Email Attachments External Only
*/
vars
	fromAddress	: String;
	dataStorageHeaderSet   : CM_FileDataStorageHdrSet;
	blob : Binary;
	fileData : CM_FileData;
	fileDataDetail : CM_FileDataStorageDetail;
	blobFileName  : String;
	header : CM_FileDataStorageHeader;
	headerSet : CM_FileDataStorageHdrSet;
begin

	if _objectEmail = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'object email is null');
		return;
	endif;

	fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	
	if _objectEmail.CM_InvStatusDefaultEmail.attachFiles then
		create headerSet transient;
		//foreach fileData in self.allFiles do // 25 Jan 2024  navvt20 TFS 56208
		foreach fileData in self.allFiles where fileData.getInvoiceExternalOnly() do // 25 Jan 2024 navvt20 TFS 56208
			blob := fileData.getDataAsBinary();
			blobFileName:= fileData.fileName;
			
			if blob &lt;&gt; null  then
				header := app.convertBlobForRequest(blob, blobFileName, false, 0);
				if header &lt;&gt; null then
					headerSet.add(header);
				endif;
			endif;
		endforeach;
	endif;

	app.myUtilityCA.utlCreateEmailSendRequest(true,
												_objectEmail.name,
												_objectEmail.getToAddresses,
												fromAddress,
												_objectEmail.getCcAddresses,
												_objectEmail.getBccAddresses,
												self.getObjectEmailSubject(_objectEmail),
												self.getObjectEmailBody(_objectEmail),
												null,
												headerSet,
												null,
												null,
												EmailSource_Invoice,
												null,
												app.myPassport);

end;
</source>
        <Parameter name="_objectEmail" type="CM_ObjectEmail"/>
        <Parameter name="_isDelete" type="Boolean"/>
        <Parameter name="_object" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocIgnoreAttr" id="451e33eb-0594-4b74-9006-1cde86ff2640">
        <source>exportAsXMLDocIgnoreAttr(_property: Property input): Boolean;

vars

begin

	
	if _property = CM_Invoice::allCashPayments then
		return true;
	elseif _property = CM_Invoice::myBOL then
		return true;
	elseif _property = CM_Invoice::myTerminal then
		return false;
	elseif _property = CM_Invoice::myTrackedItem then
		return true;
	elseif _property = CM_Invoice::myVoyage then
		return false;
	elseif _property = CM_Invoice::myCashReceipt then
		return true;
	elseif _property = CM_Invoice::myTerminal then
		return true;
	endif;


	return inheritMethod(_property);
end;
</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="f72543b6-f954-48b8-bd37-9b657d57eb28">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;

vars

begin

	if _property = CM_Invoice::myTerminal then
		return ExportAsParent;
	elseif _property = CM_Invoice::myVoyage then
		return ExportAsParent;
	elseif _property = CM_Invoice::debtor then
		return ExportAsParent;
	elseif _property = CM_Invoice::invoiceType then
		return ExportAsParent;
	endif;
	
	return inheritMethod(_property);
end;
</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findCashReceipts" id="d4d5dddd-e12b-4526-aa47-653583b20b94">
        <source>findCashReceipts(_cashRecMatched : ObjectArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Jan 2019 cnwma1	Bug 42441: PEL1 - Missing Estimation ID WSDL 1.2 - Autocollection
02 Oct 2019 cnwma1	Bug 46853: PEL1 - (TOP URGENT) Pindah| Caught exception:
*/

vars
	cashRecsExcluded: ObjectArray;
	invLine			: CM_InvoiceLine;
	voyage      	: CM_Voyage;
	wo 			 	: CM_WorkOrder;
	cashRec      	: CM_CashReceipt;
	proforma     	: CM_ProformaDetails;
begin

	//27 May 2019	NDL	TFS 44651
	if self.myOriginalAddFeesInvoice &lt;&gt; null then
		//special code for split off tax invoices.
		self.findCashReceiptsForTax( _cashRecMatched );
		return;
	endif;
	
	if self.myVoyage = null then
		 return;
	endif;
	
	voyage := self.myVoyage;

	create cashRecsExcluded transient;
	
	foreach invLine   in self.invoiceLines discreteLock do  //Invoice Lines Loop
		
		if invLine.manual then
			continue;
		endif;
		
		foreach wo in voyage.allWorkOrders discreteLock do  			  // Work Order Loop //02.10.2019 cnwma1 #46853
			
			if wo.taskStatus = WO_STATUS_CANCELLED then  // 05.12.2018 cnwma1 42366
				continue;
			endif;
			
			foreach cashRec in wo.allCashReceipts discreteLock do    // Cash Receipt Loop  //02.10.2019 cnwma1 #46853
				
				if cashRec.getDebtor &lt;&gt; self.getDebtor then
					continue;
				endif;
				
				if cashRec.paymentType &lt;&gt; self.paymentType then
					continue;
				endif;
				
				/*
				First Iteration
				*/
				if not cashRecsExcluded.includes(cashRec) then
					foreach proforma in cashRec.allProformaDetails discreteLock do           //02.10.2019 cnwma1 #46853
					
						if proforma.transactionType = 0 then
							continue;
						endif;
						
						if proforma.myInvoiceLineType.invoiceType &lt;&gt;  self.invoiceType then   //08.12.2018 cnwma1 TFS #42441
							continue;
						endif;
						
						if proforma.myInvoiceLineType &lt;&gt; invLine.invoiceLineDesc then
							continue;
						endif;
							
						if proforma.quantity &lt;&gt; invLine.quantity then
							continue;
						endif;
						
						if proforma.lineTotal &lt;&gt; invLine.lineTotal then
							continue;
						endif;
						//return cashRec;
						_cashRecMatched.addExclusive(cashRec);
						cashRecsExcluded.addExclusive(cashRec);
					endforeach;
					
					/*
					21.11.2018 cnwma1 TFS #42129
					A second iteration of searching without taking the invoice line qty or total as a factor
					*/
					foreach proforma in cashRec.allProformaDetails discreteLock do           //02.10.2019 cnwma1 #46853
					
						if proforma.transactionType = 0 then
							continue;
						endif;
						
						if proforma.myInvoiceLineType.invoiceType &lt;&gt;  self.invoiceType then   //08.12.2018 cnwma1 TFS #42441
							continue;
						endif;
						
						if proforma.myInvoiceLineType &lt;&gt; invLine.invoiceLineDesc then
							continue;
						endif;
						
						
						if invLine.myTransactionHMS &lt;&gt; null then
							if proforma.transactionType &lt;&gt; invLine.myTransactionHMS.type then
								continue;
							endif;
						endif;
						_cashRecMatched.addExclusive(cashRec);
						cashRecsExcluded.addExclusive(cashRec);
					endforeach;
					/*
						08.12.2018 cnwma1 Bug #42441
						3rd Iteration to handle creating invoices from estimations with diffrent invoice line type,
						The Only thing we going to match here the GL Code of the invoice line used by the esstimation and invoice line
						used by the invoice.
					*/
					foreach proforma in cashRec.allProformaDetails discreteLock do       //02.10.2019 cnwma1 #46853
					
						if proforma.transactionType = 0 then
							continue;	
						endif;
						if proforma.myInvoiceLineType.invoiceType &lt;&gt; invLine.invoiceLineDesc.invoiceType then
							continue;
						endif;
						
						/* Checking the GL Code*/
						
						if proforma.getServiceGLCode &lt;&gt;  invLine.getServiceGLCode  then
							continue;
						endif; 
						if proforma.getServiceGLCode &lt;&gt; null and invLine.getServiceGLCode &lt;&gt; null then 
							_cashRecMatched.addExclusive(cashRec);
							cashRecsExcluded.addExclusive(cashRec);
						endif;
					endforeach;
				endif;
			endforeach;
		endforeach; // Work Order Loop

	endforeach;   //Invoice Lines Loop
	
epilog
	delete cashRecsExcluded;
end;</source>
        <Parameter name="_cashRecMatched" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findCashReceiptsForTax" id="34f6de58-5794-4964-b916-17ffe6a9dfb9">
        <source>findCashReceiptsForTax(_cashRecMatched : ObjectArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2019	jlgndl1	Initial creation	TFS 44651 Test for fix to SAP 1.2 with tax split invoices

*/

vars

	voyage : CM_Voyage;
	prospects : CM_CashReceiptSet;
	cashReceipt : CM_CashReceipt;
	workOrder : CM_WorkOrder;
	skipMe : Boolean;
	proforma : CM_ProformaDetails;
	matchingInvoice : CM_Invoice;
	invLine: CM_InvoiceLine;
	resourceUsed : HMS_ResourceUsed;
	allWorkOrders : CM_WorkOrderSet;	//07 Jun 2019	NDL	TFS 44995
	match : Boolean;	//07 Jun 2019	NDL	TFS 44995
	woToMatchId : CM_WorkOrder; 	//07 Jun 2019	NDL	TFS 44995

begin

	if self.myOriginalAddFeesInvoice = null then
		return;
	endif;

	//This is a TAX ONLY invoice split from its original.
	
	voyage := self.myVoyage;
	if voyage = null then
		return;
	endif;
	
	create prospects transient;
	create allWorkOrders transient;	//07 Jun 2019	NDL	TFS 44995
	
	workOrder := self.myWorkOrder;
	if workOrder = null then
		//see if we can find one from the original invoice.
		workOrder := self.myOriginalAddFeesInvoice.myWorkOrder;
		if workOrder = null then
			//try the invoicelines on the original with HMS transactions
			foreach invLine in self.myOriginalAddFeesInvoice.invoiceLines discreteLock where invLine.myTransactionHMS &lt;&gt; null do	
				resourceUsed := invLine.myTransactionHMS.myResourceUsed;
				if resourceUsed &lt;&gt; null and resourceUsed.myWorkOrderVoyageDtl &lt;&gt; null then
					workOrder := resourceUsed.myWorkOrderVoyageDtl.getMyParent;
					if workOrder &lt;&gt; null and workOrder.taskStatus &lt;&gt; WO_STATUS_CANCELLED then	//07 Jun 2019	NDL	TFS 44995
						allWorkOrders.addNoDuplicates( workOrder, false );
					endif;
				endif;
			endforeach;
			//07 Jun 2019	NDL	TFS 44995
			if allWorkOrders.size = 1 then
				workOrder := allWorkOrders.first();
			else
				//if there are multiples, we can't choose.
				workOrder := null;
			endif;
		endif;
	endif;
	if workOrder &lt;&gt; null and workOrder.taskStatus = WO_STATUS_CANCELLED then
		return;
	endif;
	
	foreach cashReceipt in voyage.allCashReceipts do
	
		matchingInvoice := cashReceipt.getMyMatchingInvoice;
		
		if matchingInvoice &lt;&gt; null then
			// it has already been matched, is it me?
			if matchingInvoice = self then
				// Yes, well that's the one.
				_cashRecMatched.add( cashReceipt );
				return;
			else
				// Not me, skip it
				continue;
			endif;
		endif;
		
		if workOrder &lt;&gt; null then
			//exact match to a work order
			if cashReceipt.cashId1 &lt;&gt; workOrder.id then
				continue;
			endif;
			
		elseif not allWorkOrders.isEmpty then	//07 Jun 2019	NDL	TFS 44995
			//multiples, must natch at least one.
			match := false;
			foreach woToMatchId in allWorkOrders do
				if cashReceipt.cashId1 = woToMatchId.id then
					match := true;
					break;
				endif;
			endforeach;
			if not match then
				continue;
			endif;
		endif;
		
		if cashReceipt.getDebtor &lt;&gt; self.getDebtor then
			continue;
		endif;
		if cashReceipt.paymentType &lt;&gt; self.paymentType then
			continue;
		endif;
		if cashReceipt.cashPayment1 &lt;&gt; self.getTotalAmount then
			continue;
		endif;
		
		skipMe := false;
		foreach proforma in cashReceipt.allProformaDetails do		
			if proforma.transactionType &lt;&gt; 0 then
				//Tax (surcharges) have no transaction type
				skipMe := true;
				break;
			endif;	
		endforeach;
		if skipMe then
			continue;
		endif;
		// this one seems to match, and doesn't belong to anyone else
		prospects.add( cashReceipt );
		
	endforeach;
	
	if prospects.isEmpty then
		return;
	endif;
	
	// cashReceipts now contains a list of prospects
	foreach cashReceipt in prospects do
		_cashRecMatched.add( cashReceipt );
		matchingInvoice := self;
		if process.isInTransactionState then
			app.myUtilityUA.utlUpdateCashReceiptMI( cashReceipt, matchingInvoice, app.myPassport );
		else
			app.myTrxUA.trxUpdateCashReceiptMI( cashReceipt, matchingInvoice, app.myPassport );
		endif;
		break; // no point in reading more this is the one we are going to use...
		
	endforeach;
	
epilog

	delete prospects;
	delete allWorkOrders;	//07 Jun 2019	NDL	TFS 44995

end;</source>
        <Parameter name="_cashRecMatched" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="generateTax" id="ce95de6e-60bd-4bdf-a41e-990c952d9fbf">
        <updating/>
        <source>generateTax()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Nov 2018	cnwma1	ChangeRequest 42118: PEL1 - Generate tax number and invoice date
21 Dec 2018 cnwma1	Bug 42689: PEL1 - Tax Date on Post Pay Invoice
01 Jan 2019 cnwma1	Bug 42754: PEL1 - Sequence and Format Tax Number for 2019
29 Jan 2019 cnwma1	Bug 43124: PEL1 - Container Services - SAP SIT issues
*/

vars
	finIOClass    : CM_ExtFinanceIO;
	pxyInvoice    ,
	otherInvoice  : CM_Invoice;
	paymentType   : Integer;
	genTaxCode       : String;
	orginalPrefix,
	newPrefix     ,
	orginalTaxCode,
	replaceTaxCode: String;
	genTaxDT      ,
	orginalTaxDT  : TimeStamp;
	generateTax   ,
	isReplacement ,
	isPrevMonth   : Boolean;
	msg			  : String;
	nowAsNumber : Integer;
	now : TimeStamp;
begin
	now := app.actualTimeAppServer; // TFS 43820 JLGAB1 
	app.writeLog(method.qualifiedName,LogINFO);
	
	paymentType   := self.paymentType;
	
	if paymentType = PaymentType_None then
		return;
	endif;
	
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass &lt;&gt; null then
		if not finIOClass.isKindOf(CM_Pelindo1Interface) then 
			return;
		endif;
	endif;
	
	if self.isPending then 
	// // TFS 43820 self is either just had status changed from prepend to pending, or self is  a clone of a returned posted invoice
	// if from posted must be paid, pending must not be paid.
		if paymentType = PaymentType_AutoCollection then
			
			if self.isPaymentPaid then
				generateTax := true;
			endif;
			
		elseif paymentType = PaymentType_PostPay then
			if self.myPostedPendingInvoice &lt;&gt; null then
				 // TFS 43820 i am the 'new' pending invoice cloned from a returned posted invoice
				if self.myPostedPendingInvoice.status = CM_Invoice.INVOICE_POSTED_REVERSE then
					if self.isPaymentPaid then // POSTED must be paid
						generateTax := true;
					endif;
				 // TFS 43820 i am the 'new' pending invoice cloned from a returned pending invoice
				elseif self.myPostedPendingInvoice.status = CM_Invoice.INVOICE_PENDING_REVERSE then
					if self.isPaymentCancelled then // Cancelled Pending must be cancelled payment status
						generateTax := true;
					endif;
				endif;
			else
				if self.isPaymentNotPaid then 
					generateTax := true;
				endif;
			endif;
			
		elseif paymentType = PaymentType_PrePay then	//05 Apr 2019	NDL	TFS 44175
			if self.isPaymentPaid then
				generateTax := true;
			endif;
			
		endif;
		
	elseif self.isPrepend then                    //29.01.2019 cnwma1 #43124
		if paymentType = PaymentType_PrePay then
			if self.isPaymentPaid then
				generateTax := true;
			endif;
		endif;
	elseif self.status = CM_Invoice.INVOICE_PENDING_REVERSE or self.status = CM_Invoice.INVOICE_POSTED_REVERSE  then
		generateTax := true;
	endif;
	
	/* Replacement Logic */
	if self.myPostedPendingInvoice &lt;&gt; null  then
		otherInvoice       := self.myPostedPendingInvoice;
		newPrefix          := finIOClass.CM_Pelindo1Interface.getPelindoInvTaxStatusStr(self);
		
		isReplacement      := true;
		
		//if otherInvoice.externalFinancialId &lt;&gt; null then
		if otherInvoice.getExternalFinancialId() &lt;&gt; null then //08/12/2025	navkc1 JIRA 36262
			orginalPrefix  := otherInvoice.externalTaxNumber[1:3];
			orginalTaxCode := otherInvoice.externalTaxNumber;
		endif;
		if otherInvoice.taxDT.isValid then
			orginalTaxDT := otherInvoice.taxDT;
		endif;	
		
		nowAsNumber := (now.date.year.String &amp;  now.date.month.padLeadingWith("0",2)).Integer; // TFS 43820 JLGAB1 
		
		 // TFS 43820 JLGAB1 if otherInvoice.getMonthForInvoice() &lt;&gt; self.getMonthForInvoice() then     /*Needs More Check Later*/
		if otherInvoice.getMonthForInvoice() &lt;&gt; nowAsNumber then     // TFS 43820 JLGAB1
			isPrevMonth := true;
		endif;
	
		if isPrevMonth then  
			/*
				Replacement for Prev Month
				Case1, Tax Number &gt;&gt; Only 3rd digit changes (010 -&gt; 011) Tax sequence remains same, TaxDT &gt;&gt; GenerateNew
				Case2, Tax Number &gt;&gt; 010 -&gt; 071 (nothing else changes) Tax sequence remains same  , TaxDT &gt;&gt; GenerateNew
			*/
			/*Case1*/
			
			if orginalPrefix = newPrefix  then 
				genTaxDT := app.actualTimeServer;                   // 21.12.2018 cnwma1 Bug #42689
				replaceTaxCode  	:= orginalTaxCode;
				replaceTaxCode[3:1] := "1";
				genTaxCode          := replaceTaxCode;
			/*Case:2*/
			else
				genTaxDT := app.actualTimeServer;                   // 21.12.2018 cnwma1 Bug #42689
				newPrefix[3:1] := "1";
				genTaxCode 	   := newPrefix &amp; orginalTaxCode[4:orginalTaxCode.length];
			endif;
		else
			/*
				Replacement for Current Month
				Case1, Tax Number &gt;&gt;Copy from Original, TaxDT &gt;&gt; Copy from Original
				Case2, Tax Number &gt;&gt; 010 -&gt; 071 (nothing else changes) Tax sequence remains same  , TaxDT &gt;&gt; GenerateNew
			*/
			/*Case1*/
			if orginalPrefix = newPrefix then
				genTaxDT   := orginalTaxDT;
				genTaxCode := orginalTaxCode;
			/*Case:2*/
			else
				genTaxDT       := orginalTaxDT;
				genTaxCode     := newPrefix &amp; orginalTaxCode[4:orginalTaxCode.length];
			endif;
		endif;
	else // TFS 43820 moved this logic up from below
		if paymentType = PaymentType_PostPay then
			if self.pendingDT.isValid then
				genTaxDT := self.pendingDT;                     // 21.12.2018 cnwma1 Bug #42689
			else
				genTaxDT := app.actualTimeServer;               // 21.12.2018 cnwma1 Bug #42689
			endif;
		else
			genTaxDT := app.actualTimeServer;                   // 21.12.2018 cnwma1 Bug #42689
		endif;
		genTaxCode := finIOClass.getTaxNumber(self,genTaxDT);   // 01.01.2018 cnwma1 Bug #42754

	endif;
	
	
	msg :=  method.qualifiedName &amp;
			' ' &amp; "**SAP**" &amp;
			' ' &amp; "Invoice: " &amp; self.String &amp; ' ' &amp; self.sequenceNum.String &amp; 
			' ' &amp; "Tax Code That Has Been Generated : '" &amp;
			' ' &amp; genTaxCode.asStringJMT &amp; "' Tax Date : " &amp; genTaxDT.asStringJMT();
	app.writeLog(msg,LogINFO);
	
	msg :=  method.qualifiedName &amp;
			' ' &amp; "**SAP**" &amp;
			' ' &amp; "Update Invoice Invoice Tax Details GenerateTax :" &amp;
			' ' &amp; generateTax.asStringJMT;
	app.writeLog(msg,LogINFO);
	
	if generateTax then
	/* // TFS 43820 moved this up so can include in logging
		if not isReplacement then
			//genTaxCode := finIOClass.getTaxNumber( self );        // 01.01.2018 cnwma1 Bug #42754
			if paymentType = PaymentType_PostPay then
				if self.pendingDT.isValid then
					genTaxDT := self.pendingDT;                     // 21.12.2018 cnwma1 Bug #42689
				else
					genTaxDT := app.actualTimeServer;               // 21.12.2018 cnwma1 Bug #42689
				endif;
			else
				genTaxDT := app.actualTimeServer;                   // 21.12.2018 cnwma1 Bug #42689
			endif;
			genTaxCode := finIOClass.getTaxNumber(self,genTaxDT);   // 01.01.2018 cnwma1 Bug #42754
		endif;
			*/
		

		msg :=  method.qualifiedName &amp; 
				' ' &amp;   "**SAP**" &amp;
				' ' &amp;   "Update Invoice Invoice Tax Details"&amp;
				' ' &amp;   "Tax Code :" &amp; genTaxCode.String &amp;
				' ' &amp;   "Tax DT :"   &amp; genTaxDT.asStringJMT;
		app.writeLog(msg,LogINFO);
		
		if genTaxCode &lt;&gt; null then
			if process.isInTransactionState then 
				self.setTaxDetails(genTaxCode,genTaxDT);
			else 			
				pxyInvoice := app.createUpdateProxy(self).CM_Invoice;
				app.myTrxUA.trxUpdateInvoiceTaxCode(pxyInvoice, genTaxCode,genTaxDT,app.myPassport);
			endif;
			
			if app.myPassport.hasErrors then
				msg :=  method.qualifiedName &amp; 
						' ' &amp; "**SAP**" 	 &amp;
						' ' &amp; "Invoice :"   &amp; self.exportCurrencyCode &amp;
						' ' &amp; "ERRORS : "   &amp; app.myPassport.getErrorsAndWarningsAsString;
				app.writeLog(msg,LogINFO);
			endif;
		endif;
	endif;

epilog
	delete pxyInvoice;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAllMergeInvoicesExtSql" id="a008c69d-2254-4b81-9bb7-e6edbd524620">
        <source>getAllMergeInvoicesExtSql() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/10/2024	navkc1	JIRA Bug MTN-12545: MTN - Merged Into/Merged Invoice missing the External Equivalent

*/

vars

	mergeInvoice : CM_Invoice;
	returnStr : String;

begin

	foreach	mergeInvoice in self.allMergedInvoices do
 
 		if returnStr = "" then
			returnStr := mergeInvoice.externalNumber.asStringJMT();
		else
			returnStr := returnStr &amp; "," &amp; mergeInvoice.externalNumber.asStringJMT();
		endif;

	endforeach;
	
	return returnStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
