    <JadeMethod name="getAllCriteriaValues" id="44f94284-2e1b-4104-888c-a85cf3ff8b8a">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
vars
begin
	app.myRoot.allToDoTaskDescriptions.copy(_allCriteriaValues);
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForTi" id="81701653-ad75-47b9-902c-487752b4a1f8">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*
Purpose:			// PAR 33892	
Date		Who		Reason
11 April 2014	cnwab1	Initial creation
*/

vars
	objs : ObjectSet;
	todo : CM_ToDoTask;
begin
	create objs transient;
	foreach todo in _ti.allToDoTasksToDo discreteLock do
		objs.add(todo.toDoTaskDesc);
	endforeach;

	_criteriaValue:= objs;
epilog

end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="52da0789-8d3b-4fb0-9e5e-7350234ae944">
        <source>getDataDisplay(pDataObj : CM_YAData) : String;
//01 August 2008	cnwdw1
begin
	return pDataObj.CM_YADataObjects.getDataDisplay(self);
end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="8c1977b6-b4fb-4451-8d0b-813943c5e528">
        <source>getDisplay(dataObj : Object) : String;
// 01 Aug 2008	cnwdw1
// 15 Sep 2025	navdap1	MTN-35615 ENS | Bulk Creation of Yard Allocations
vars
	ti : CM_TrackedItem;
	mess : String;
	task : CM_ToDoTask;
begin
	if dataObj.isKindOf(CM_ToDoTaskDesc) then
		return dataObj.CM_ToDoTaskDesc.shortDescription;
	// PAR 33892
	elseif dataObj.isKindOf(CM_TrackedItem) then
		ti := dataObj.CM_TrackedItem;
		
		foreach task in ti.allToDoTasksToDo discreteLock do
			if mess = "" then
				mess := task.toDoTaskDesc.shortDescription;					// MTN-35615
			else
				mess := mess &amp; ", " &amp; task.toDoTaskDesc.shortDescription;	// MTN-35615
			endif;
		endforeach;
		// MTN-35615 Original implementation of this didn't actually return anything,
		// so the CM_TrackedItem implementation was just wrong. Changed to return the same thing 
		// as the CM_ToDoTaskDesc implementation
		return mess;
	endif;
	
	return "";
end;
</source>
        <Parameter name="dataObj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getObjects" id="6deb983a-93e5-4984-a84b-5d0505030f5c">
        <source>getObjects(objects: ObjectLongNameDict input);
//03 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	todo     : CM_ToDoTaskDesc;
	dupFound : String;
	msg      : String;
begin
	//11 March 2016	NDL	TFS 1651
	on Exception do self.handleDuplicateNicely( exception, todo, dupFound );
	
	foreach todo in app.myRoot.allToDoTaskDescriptions 	where todo.type = TODO_TYPE_GROUP_TI do 	// ### TFS  #56634[54259] 22NOV2022 NAVAB1
		objects[todo.getYAIdentifier] := todo;
	endforeach;
	
	//11 March 2016	NDL	TFS 1651
	if dupFound &lt;&gt; null then
		msg := app.getErrorString1( More_task_descr_using_their_sh, dupFound );
		app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
	endif;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="fb8b366c-7b34-49ae-9954-263144680167">
        <source>getTypeName(): String;
// --------------------------------------------------------------------------------
// Created:		16 March 2005 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "To Do Tasks";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleDuplicateNicely" id="62aa3ab3-28f6-4422-8e00-d5d7463255c2">
        <source>handleDuplicateNicely(_exc : Exception; _todo: CM_ToDoTaskDesc; _duplicate: String io) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2016	cnwndl1	Initial creation	TFS 1651

*/

constants

	DupKey = 1310;
	
vars

	returnVal		: Integer;

begin

	returnVal := Ex_Pass_Back;

	if _todo = null then				
		return returnVal;
	endif;
	
	if _exc.errorCode = DupKey then
		_duplicate := _todo.shortDescription;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

epilog

	return returnVal;

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_todo" type="CM_ToDoTaskDesc"/>
        <Parameter name="_duplicate" type="String" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="8c747aa6-f3e2-4057-a865-6b15e0b538b2">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	return _cmifAutoPlan.isToDoTasks_Match(_yaData);


end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSnapShotDataMatch" id="4f06f481-f4f8-436f-8d8f-d88f69ff84d1">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;

vars

begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	if _criteria.myYAData.isKindOf(CM_YADataBoolean) then
		//epr TFS 37176 21/2/18
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _propertyValue.Boolean);
	endif;
	
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;

	return false;
end;</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
