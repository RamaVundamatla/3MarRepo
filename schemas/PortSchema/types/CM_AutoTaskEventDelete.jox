&lt;display&gt;Delete Expired Events&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <CompAttribute name="allEventTypes" id="908ddafd-8449-487f-8f7c-e64880482326">
        <type name="IntegerArray"/>
        <access>readonly</access>
    </CompAttribute>
    <PrimAttribute name="daysOld" id="b037f95e-2c49-4150-ba18-bf0424f9adf7">
