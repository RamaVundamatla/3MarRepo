    <JadeMethod name="buildChildTags" id="ede8e9a4-c9c2-4450-bdd3-7c25c6c2c14b">
        <source>buildChildTags():String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Iterate the eceiver's collection of child tags and assemble their
//				HTML into a single stream and return it.
//
// Parameters:	None
//
// Returns:		The HTML stream.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	childTagObj	: CnEcHtmlBodyTag;
	htmlString	: String;
	
begin
	foreach childTagObj in self.allTags do
		htmlString	:=	htmlString &amp; childTagObj.getHtml();
	endforeach;
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createAnchor" id="13083d8e-bbe5-4eaf-a5dd-6b04e03b94cf">
        <source>createAnchor():CnEcHtmlAnchorTag;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Create an anchor tag for the receiver.
//
// Parameters:	None
//
// Returns:		The new tag object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	anchorTagObj	: CnEcHtmlAnchorTag;
	
begin
	create anchorTagObj transient;
	anchorTagObj.setTag(self);
	
	return anchorTagObj;
end;</source>
        <ReturnType type="CnEcHtmlAnchorTag"/>
    </JadeMethod>
