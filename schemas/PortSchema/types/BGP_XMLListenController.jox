        <length>129</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="tcpIpPort" id="ff834366-c026-4125-9109-8b4f2846e756">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="workerClass" id="94ccf30d-efbb-456c-9247-1018b7958ade">
