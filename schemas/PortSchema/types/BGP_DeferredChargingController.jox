    </JadeMethod>
    <JadeMethod name="sysNotification" id="19cc4eab-92fb-4567-83f2-fb49fde8e2d6">
        <updating/>
        <source>sysNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2021	navndl1	Initial creation	TFS 51443

*/

vars

begin

	if _theObject &lt;&gt; null then
		if _theObject.isKindOf(BGP_DeferredChargingRequest) then
			//A new request has been created, if I haven't already processed it, wake me up
			if not self.myDeferredChargesRoot.allNewDeferredReqs.isEmpty then
				app.writeLog(method.qualifiedName &amp; "-New request, waking up", LogTRACE);
				//I'm resting.
				self.wakeMeUp();
			endif;
		else
			inheritMethod(_eventType, _theObject, _eventTag);
		
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="terminateProcessing" id="f05cad72-3375-4590-8437-fa52753c070a">
        <updating/>
        <source>terminateProcessing(_userCode: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2021	navndl1	Initial creation	TFS 51443

*/

vars

begin
	
	if self.timerInProgress then
		self.endTimer( DeferredMinTimer );
	endif;
	beginTransaction;
	self.dateTimeLastCompleted := app.actualTimeServer;
	self.working := false;
	commitTransaction;
	
	self.causeEvent( EVENT_Upd_BGP_Deferred_Cont, true, 0 );
	
	inheritMethod(_userCode);
		
epilog

	

end;</source>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="7fb94cdb-218f-4bf5-b872-b2d7a1bc02c5">
        <updating/>
        <source>timerEvent(_eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2021	navndl1	Initial creation	TFS 51443

*/

vars

begin
	if _eventTag = DeferredMinTimer then
		beginTransaction;
		self.timerInProgress := false;
		commitTransaction;
		app.writeLog(method.qualifiedName &amp; "-I'm waking up", LogTRACE);
		self.wakeMeUp();
	else
		inheritMethod(_eventTag);
	endif;

epilog

end;</source>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="wakeMeUp" id="b76566cd-2a43-4257-bfdb-b05d53fc1f85">
        <updating/>
        <source>wakeMeUp()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2021	navndl1	Initial creation	TFS 51443

*/

vars

	doSetTimer : Boolean;
	noneLeft : Boolean;

begin

	if self.myDeferredChargesRoot = null then
		beginTransaction;
		self.myDeferredChargesRoot := CM_DeferredChargingRoot.firstInstance;
		if self.myDeferredChargesRoot = null then
			create self.myDeferredChargesRoot persistent;
			app.myDeferredChargingRoot := CM_DeferredChargingRoot.firstInstance;
		endif;
		commitTransaction;
	endif;
	
	if self.timerInProgress then
		self.endTimer( DeferredMinTimer );
	endif;
	
	while true do
		self.processCharges( doSetTimer, noneLeft );
		if doSetTimer then
			app.writeLog(method.qualifiedName &amp; "-Setting a Timer", LogTRACE);
			self.beginTimer( 60 * 1000, Timer_OneShot, DeferredMinTimer );
			beginTransaction;
			self.timerInProgress := true;
			commitTransaction;
			app.writeLog(method.qualifiedName &amp; "-Going idle waiting on the timer", LogTRACE);
			break;
		elseif noneLeft then
			app.writeLog(method.qualifiedName &amp; "-Back to sleep", LogTRACE);
			break;
		endif;
	endwhile;

epilog

end;</source>
    </JadeMethod>
</Class>
