    <JadeMethod name="create" id="507763ea-c968-4c40-bb6d-7a7f8d19ea2d">
        <updating/>
        <source>create() updating;
/* ---------------------------------------------------------------------------
Created:	27 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.permissionView  := PmAdmConnectView;
	self.permissionMaint := PmAdmConnectMaint;

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="e2f5c58f-2df2-4f5d-b60d-409f5351265d">
        <updating/>
        <source>doOK() updating;
/* ---------------------------------------------------------------------------
Created:	27 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 30 Oct 2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking
------------------------------------------------------------------------------*/
vars
	nowTimeStamp,
	connectTimeStamp,
	localConTS		: TimeStamp;
	connectParams	: CMIF_ConnectParams;
	loadState		: Boolean;
	date			: Date;
	time			: Time;
	pxyTI,
	pxyGen			: CM_TrackedItem;
	targetController: CM_LocationsController;
	foundHeight		: Integer;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	if self.myTrackedItem = null then
		return;
	endif;

	//getting the location from string
	self.myTerminal.findLocationFromString( self.txtLocation.text, false, targetController, foundHeight);
	if targetController = null then
		app.raiseCMException1(ERR_INVALID_LOCN, self.txtLocation.text, ETRow_NewLocn, null);
		return;
	endif;
	
	nowTimeStamp := app.actualTimeServer;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	date := txtDate.text.asDateJMT();
	time := txtTime.text.asTimeJMT();
	
	if date.isValid() and time.isValid() then					// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		localConTS.cnEcSetDateAndTime(date,time);				// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		connectTimeStamp := self.localToSystemTime(localConTS);	// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		connectTimeStamp := nowTimeStamp;						// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;

	create connectParams transient;

 	app.cmsBeginLoad(loadState);
 		pxyTI := self.myTrackedItem.pxyCreateUpdateProxy();	// also creates pxyGen // TFS 46767 - no it doesn't!
	app.cmsEndLoad(loadState);

	connectParams.dateTime := connectTimeStamp;
	connectParams.noCharge := self.chkCharge.value;	//Par 17972
	connectParams.myTerminal := self.myTerminal;
	connectParams.myTrackedItem := pxyTI;
	connectParams.locationsController := targetController;
	connectParams.userId := app.getMyUserCode();
	connectParams.action := ACTION_DETACH;
	connectParams.radioTelemetryUser := false;
	if self.myTrackedItem.isKindOf(CM_Container) then
		pxyGen := pxyTI.CM_Container.getGenerator; 
	else
		pxyGen := pxyTI.CM_TILC.myGenerator; 
	endif;
	connectParams.myOtherTrackedItem := pxyGen;
	connectParams.type := TRANS_TYPE_DetachGenerator;

	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateDetach(connectParams, app.myPassport);	
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Connect', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	inheritMethod(); //closing the form

epilog

	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347 
	
	delete pxyTI;
	//delete pxyGen; // TFS 46767 - pxyGen isn't a proxy, only ref to attached generator...
	if connectParams &lt;&gt; null then
		connectParams.allTrackedItems.purge(); // proxies
		delete connectParams;
	endif;

	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadData" id="ef66acd5-6a2a-4f80-ab01-e6d134674b94">
        <source>loadData();
/* ---------------------------------------------------------------------------
Created:	27 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
------------------------------------------------------------------------------*/
vars
	aTS : TimeStamp;
	
begin

	if self.myTrackedItem = null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'there is no trackedItem' );
		return;
	endif;

	self.lblGenSetID.caption := "";

	if self.myTrackedItem.isKindOf( CM_Container ) then
		if self.myTrackedItem.CM_Container.getGenerator = null then
			app.raiseUnexpectedProgramError( class.name, method.name, 'there is no trackedItem' );
			return;
		endif;
		self.lblGenSetID.caption := self.myTrackedItem.CM_Container.getGenerator.id;
		
	elseif self.myTrackedItem.isKindOf( CM_TILC ) then
		if self.myTrackedItem.CM_TILC.myGenerator = null then
			app.raiseUnexpectedProgramError( class.name, method.name, 'there is no trackedItem' );
			return;
		endif;
		self.lblGenSetID.caption := self.myTrackedItem.CM_TILC.myGenerator.id;
	
	else
		app.raiseUnexpectedProgramError( class.name, method.name, 'unknown trackedItem type' );
		
	endif;
	
	
	aTS := self.systemToLocalTime(app.actualTimeServer);			// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	txtDate.text := aTS.date.asStringJMT();
	txtTime.text := aTS.time.asStringJMT();

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b6b95716-2aa8-4fb7-9e9d-1b483d5c525e">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2008	cnwer1	Initial creation

*/

vars

begin

	inheritMethod();
	self.setCaption( self.myTrackedItem.id &amp; " detach a Gen set");
	
	self.loadData();

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0eb00c9c-c27d-4444-befa-7943e17431cc">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009835, locale);
	lblCharge.translateCaption(Xlat_0009836, locale);
	lblDate.translateCaption(Xlat_0009837, locale);
	lblGenSet.translateCaption(Xlat_0009838, locale);
	lblLocation.translateCaption(Xlat_0009839, locale);
	lblTime.translateCaption(Xlat_0009840, locale);
end;</source>
    </JadeMethod>
</GUIClass>
