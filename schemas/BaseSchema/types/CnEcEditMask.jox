    <JadeMethod name="controlNamePrefix" id="eb9f3cd9-5350-485b-81c8-7b4646cdb14e">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		24 June 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "jem";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="9eacd339-2928-446a-8800-c1b09ea7b3aa">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		12 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.focusColor		:=	self.backColor;
	self.colorNoFocus	:=	self.backColor;
	
	self.show3D			:=	Control.Show3D_Use3D;
end;</source>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="9f54a0ed-1517-4b12-b979-2bb42832e664">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>gotFocus(editMask: JadeEditMask input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		12 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(editMask);
	
	if (not self.readOnly) and self.isFocusColorUsed and self.backColor &lt;&gt; self.focusColor then
		self.colorNoFocus	:=	self.backColor;
		self.backColor		:=	self.focusColor;
	endif;
end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="f0541711-c975-43fc-8a75-9a7909ef9ea0">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>lostFocus(editMask: JadeEditMask input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		12 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(editMask);
	
	if (not self.readOnly) and self.isFocusColorUsed and self.backColor &lt;&gt; self.colorNoFocus then
		self.backColor		:=	self.colorNoFocus;
	endif;
end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="readOnly" id="d2071911-0a2e-4d90-b2fc-070fabfa632f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>readOnly(set: Boolean; value: Boolean io) updating, mapping, clientExecution;
// --------------------------------------------------------------------------------
// Created:		19 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isTransient() = true then
		if set then
			inheritMethod(set, value);
			
			if app.getName() = "Jade" then
				if (not self.isReadOnlyDefaultColor) then
					if value then
						self.backColor	:=	self.getSystemColor(Window.Color_3DFace);
						self.tabStop	:=	false;
					else
						self.backColor	:=	self.getSystemColor(Window.Color_Window);
						self.tabStop	:=	false;
					endif;
				endif;
			else
				if value then
					self.backColor	:=	Gray;
					self.tabStop	:=	false;
				else
					self.backColor	:=	White;
					self.tabStop	:=	true;
				endif;
			endif;

			// Make sure that a repaint is done.
			self.refresh();
		else
			inheritMethod(set, value);
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="ca22509b-a131-434c-971f-67e23c4ce112">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		12 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.isRequired then
		self.autoRedraw	:=	true;
		self.drawSolidRectangle(self.clientWidth()-4, 0, self.clientWidth(), 4, Red);
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
