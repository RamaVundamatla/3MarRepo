    <JadeMethod name="btnDetails_click" id="6c1eddfe-e75c-44c5-874a-364f938395d9">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDetails_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.showDetails();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSearch_click" id="3e7237e0-e177-4b1e-a5aa-3ed98b309272">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSearch_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		12 August 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doSearch();
epilog
	app.mousePointer	:=	Idle;
end;</source>
