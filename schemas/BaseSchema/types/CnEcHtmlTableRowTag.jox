Identifies the cells within a single row of a table.</text>
    <DbClassMap file="basehtml"/>
    <ExplicitInverseRef name="allTableDatas" id="71ea3173-41c8-45c7-846e-bfe8135dc6d2">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="CnEcHtmlTableDataTagArray"/>
        <access>readonly</access>
        <text>Contains a set of all Table Data objects for this table row.  Note that
table datas may also be created independantly of a table row, which
therefore will not have a reference to any table row object.</text>
        <Inverse name="CnEcHtmlTableDataTag::myRow"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myTable" id="1ec4dd48-2daa-4b75-adf7-b928a814905d">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CnEcHtmlTableTag"/>
        <access>readonly</access>
        <Inverse name="CnEcHtmlTableTag::allRows"/>
    </ExplicitInverseRef>
    <PrimAttribute name="tableVAlign" id="5c5c2f66-350f-438b-a38d-2715217dcfe7">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Specifies that the text in the row can be aligned with the TOP, CENTER,
BASELINE or BOTTOM of the cells.</text>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="54748d6b-a550-492b-a558-9bf8e75eae27">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString		: String;
	tableDataObj	: CnEcHtmlTableDataTag;

begin
	// Build the opening table row tag.

	if self.tableVAlign &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' VALIGN="' &amp; self.tableVAlign &amp; '"';
	endif;

	if self.tableWidth &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' WIDTH="' &amp; self.tableWidth &amp; '"';
	endif;

	htmlString	:=	htmlString &amp; inheritMethod() &amp; '&gt;';

	// Now get the table data tags.

	foreach tableDataObj in self.allTableDatas do
		htmlString	:=	htmlString &amp; tableDataObj.getHtml;
	endforeach;

	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearTableDatas" id="66f4c1e1-0867-4696-b1f8-640dd9038995">
        <updating/>
        <source>clearTableDatas() updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Deletes all of the receiver's table datas (cells).
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allTableDatas.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="createTableData" id="16e276b8-9df9-4450-9ac7-f04a4be26a75">
        <source>createTableData():CnEcHtmlTableDataTag;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		Creates a table data (cell) object for the receiver.
//
// Parameters:	None
//
// Returns:		The newly created table data object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableDataObj	: CnEcHtmlTableDataTag;

begin
	create tableDataObj transient;
	tableDataObj.setRow(self);
	
	return tableDataObj;
end;</source>
        <ReturnType type="CnEcHtmlTableDataTag"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="43a3ed98-92f4-467b-97fe-bef9236a3b07">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;TR' &amp; self.buildTagBody() &amp; CrLf &amp; '&lt;/TR&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidVAlign" id="953e4474-85b7-4bc5-966c-f7e4ec23ac61">
        <source>isValidVAlign(pVAlign:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		Validates the receiver's vertical alignment setting.
//
// Parameters:	pVAlign - The receiver's vertical alignment setting.
//
// Returns:		True if the vertical alignment setting is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pVAlign = self.ALIGN_TOP
	or pVAlign = self.ALIGN_CENTER
	or pVAlign = self.ALIGN_BASELINE
	or pVAlign = self.ALIGN_BOTTOM
	then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22000, '"' &amp; pVAlign &amp; '" is not a valid Table Row tag vertical alignment');
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pVAlign" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTable" id="c0250ae9-89b3-48b5-b6e6-8abd7b80883e">
        <updating/>
        <source>setTable(pTableTagObj:CnEcHtmlTableTag) updating;
// -----------------------------------------------------------------------------
// Created:		30 November 2001 by cnwdad1
//
// Purpose:		Sets a reference to the receiver's table tag object.
//
// Parameters:	pTableTagObj - The table tag object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.myTable &lt;&gt; pTableTagObj then
		self.myTable	:=	pTableTagObj;
	endif;
end;</source>
        <Parameter name="pTableTagObj" type="CnEcHtmlTableTag"/>
    </JadeMethod>
    <JadeMethod name="setTableVAlign" id="641ac63d-432c-44d4-83e2-f91e71666bac">
        <updating/>
        <source>setTableVAlign(pVAlign:String) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Sets the receiver's vertical alignment setting.
//
// Parameters:	pVAlign - The vertical alignment setting.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isValidVAlign(pVAlign) then
		self.tableVAlign	:=	pVAlign;
	endif;
end;</source>
        <Parameter name="pVAlign" type="String"/>
    </JadeMethod>
</Class>
