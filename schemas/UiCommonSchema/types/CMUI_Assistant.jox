    <JadeMethod name="sendItemsToReport" id="e731b6e7-f503-4938-9712-afaa4880fd1a">
        <source>sendItemsToReport( _objArray : ObjectArray input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2011	cnwndl1	Initial creation	par 28236

*/

vars
	
	jrwReportName	: String;
	selectedOnly,
	printPreview 	: Boolean;
	outputType		: Integer;
	filePath		: String;
	
begin

	if _objArray.isEmpty then
		return;
	endif;
	
	selectedOnly := false;
	if app.getReportToSendItems(CM_TrackedItemView, null, selectedOnly, jrwReportName, printPreview, outputType, filePath) then
		app.sendItemsToReport(CM_JRWTrackedItems, _objArray, jrwReportName, printPreview, outputType, filePath);
	endif;

epilog

end;</source>
