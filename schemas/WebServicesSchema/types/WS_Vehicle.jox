<Class name="WS_Vehicle" id="d47f73ed-0eb4-4fb4-beb1-b51f474054bf">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents Terminal Vehicles</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="regNumber" id="f8750847-2735-4951-942a-6c0ac0001ee0">
        <type name="String"/>
        <access>readonly</access>
        <text>Vehicle Registration Number</text>
    </PrimAttribute>
    <PrimAttribute name="releaseTrailerId" id="d9501660-71d5-45e1-b9b6-2e605cee131e">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="releaseTrailerOid" id="21d96b15-c1c3-44b3-a6c0-c43ecbc6bbb8">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="state" id="bebe31db-d0ee-4aad-830f-5e136ce73b7d">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="92b1fdb1-7e21-411c-b523-7d1087e44f12">
        <updating/>
        <source>setProxyFromObject(_object : CM_Vehicle) updating;
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
08 May 2013	cnwndl1	Par 31393	Initial creation
11 Jul 2019	jlgka1 	TFS 45289	JMT Handheld Apps - Pack by Request - Truck Loader Jade
============================================================================*/
begin

	inheritMethod(_object);

	self.regNumber := _object.regNumber;

	self.state	   := _object.state;	
	self.setTrailerInformation(_object);

end;</source>
        <Parameter name="_object" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="setTrailerInformation" id="bb90709f-71fd-486d-b27f-fde26fba9b4d">
        <updating/>
        <source>setTrailerInformation(vehicle : CM_Vehicle) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 10 July 2019
TFS#		: 45289
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	trackedItem	: CM_TrackedItem;
	count		: Integer;
	invalidLoc	: Boolean;
	invalidTI	: Boolean;
	vvr : CM_VehicleVisitRecord;
	trailer : CM_TILC;
begin
	count := 1;
	
	on Exception do app.handleDeletedObject(exception, vehicle.locationsController, invalidLoc);
	vehicle.locationsController.edition;
	
	on Exception do null;
	
	on Exception do app.handleDeletedObject(exception, trackedItem, invalidTI);
	
	if invalidLoc then
		return;
	endif;
	
	if vehicle.locationsController &lt;&gt; null then
		foreach trackedItem in vehicle.locationsController.allTrackedItems do
			trackedItem.edition;
			if  invalidTI then
				invalidTI := false;
				continue;
			endif;
			if trackedItem.isROB then
				if trackedItem.isChassis then
					if count = 1 then
						self.releaseTrailerId := trackedItem.id;
						count := count + 1;
					else
						self.releaseTrailerId := self.releaseTrailerId &amp; " " &amp; trackedItem.id;
					endif;
				endif;
			endif;			
		endforeach;
	endif;
	
	vvr:=vehicle.getCurrentVisit;
	if vvr &lt;&gt; null then
		if vvr &lt;&gt; null then
			if vvr.myOutCMGTE_Chassis &lt;&gt; null then
				trailer := vvr.myOutCMGTE_Chassis.getTI.CM_TILC;
				if trailer &lt;&gt; null then
					self.releaseTrailerOid:=trailer.getOidAsString;
				endif;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="vehicle" type="CM_Vehicle"/>
    </JadeMethod>
</Class>
