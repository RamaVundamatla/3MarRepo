reports that require multiple prints to various printers.</text>
    <ImplicitInverseRef name="btnAdd" id="0c615570-3529-4a4e-bff9-eb2767fbe055">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnCancel" id="dfe6c404-7de7-4530-bd80-2878407ad96a">
