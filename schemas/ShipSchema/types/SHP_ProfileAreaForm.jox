	self.showTableStatsColumnLabels();
	
	theTable.accessRow(StatsTableRowLabel).fontBold := true;
	theTable.accessColumn(1).backColor := self.colorHeadingColumn;
	theTable.accessRow(StatsTableRowLabel).backColor := self.colorHeadingColumn;
	theTable.fitColumnWidth(1,5);
epilog

