    <JadeMethod name="addTI" id="d9820c9e-23d9-4efe-bb42-ef318fd7b1c9">
        <source>addTI( _ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.allTis.addExclusive( _ti );

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="consumeChildComponents" id="23af3553-a865-40a3-a06d-30f650b16536">
        <source>consumeChildComponents( _parentBlendTrx : CM_Blend input; _passport : CM_Passport input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	ti : CM_TrackedItem;
	totQuantityRequired : Integer;
	totWeightRequired : Decimal[14,4];
	totVolumeRequired : Decimal[14,4];
	
	localTIs : CM_TIArray;
	totQuantity : Integer;
	totWeight : Decimal[14,4];
	totVolume : Decimal[14,4];
	
	exact : Boolean;
	splitReqd : Boolean;
	newSplitTi : CM_TrackedItem;
	splitQuantity : Integer;
	splitWeight : Decimal[14,4];
	splitVolume : Decimal[14,4];
	
	tisToBeZombied : CM_TIArray;
	adjustTi : CM_TrackedItem;
	parentBlendTi : CM_TrackedItem;
	
	newId : String;

begin

	totQuantityRequired := ( self.quantity * factor ).Integer;
	totWeightRequired := self.weight * factor;
	totVolumeRequired := self.volume * factor;
	parentBlendTi := _parentBlendTrx.myTrackedItem;
	
	create localTIs transient;
	create tisToBeZombied transient;
	
	//Rip thru the associated TI s in order, collect up as many as we need to fulfill the amount required. (They are allowd to over assign)
	foreach ti in self.allTis do
		if ti.hasBeenMerged then
			//may have already been consumed
			continue;
		endif;
		
		localTIs.addExclusive( ti );
		
		if totQuantityRequired &gt; 0 then
			totQuantity := totQuantity + ti.totalQuantity;
			if totQuantity = totQuantityRequired then
				exact := true;
				break;
			elseif totQuantity &gt; totQuantityRequired then
				splitReqd := true;
				break;
			endif;
		elseif totWeightRequired &gt; 0 then
			totWeight := totWeight + ti.totalWeight;
			if totWeight = totWeightRequired then
				exact := true;
				break;
			elseif totWeight &gt; totWeightRequired then
				splitReqd := true;
				break;
			endif;
		elseif totVolumeRequired &gt; 0 then
			totVolume := totVolume + ti.totalVolume;
			if totVolume = totVolumeRequired then
				exact := true;
				break;
			elseif totVolume &gt; totVolumeRequired then
				splitReqd := true;
				break;
			endif;
		endif;
	endforeach;
	
	if exact then
		//we have the exact amount we require.
		localTIs.copy( tisToBeZombied );
		
	elseif splitReqd then
		//we have too much and will need to 'split' OR 'adjust' the last one we added.
		ti := localTIs.last;
		localTIs.remove( ti );
		if not localTIs.isEmpty then
			localTIs.copy( tisToBeZombied );
		endif;
		
		if totQuantityRequired &gt; 0 then
			totQuantity := totQuantity - ti.totalQuantity;
			splitQuantity := totQuantityRequired - totQuantity;
			splitWeight := ti.weight * ( splitQuantity / ti.totalQuantity );
			if not self.myCargoType.isAllowDuplicates then
				//doesn't do splits, so just adjust the qty weight in real time.
				adjustTi := ti;
				adjustTi.setTotalQuantity( ti.totalQuantity - splitQuantity );
				adjustTi.setTotalWeightWithoutTrans( ti.totalWeight - splitWeight );
			endif;
			
		elseif totWeightRequired &gt; 0 then
			totWeight := totWeight - ti.totalWeight;
			splitWeight := totWeightRequired - totWeight;
			splitQuantity := 1;
			if not self.myCargoType.isAllowDuplicates then
				//doesn't do splits, so just adjust the weight in real time.
				adjustTi := ti;
				adjustTi.setTotalWeightWithoutTrans( ti.totalWeight - splitWeight );
			endif;
			
		elseif totVolumeRequired &gt; 0 then
			totVolume := totVolume - ti.totalVolume;
			splitVolume := totVolumeRequired - totVolume;
			splitQuantity := 1;
			splitWeight := splitVolume * ti.getDensity;
			if not self.myCargoType.isAllowDuplicates then
				//doesn't do splits, so just adjust the volume weight in real time.
				adjustTi := ti;
				adjustTi.setTotalWeightWithoutTrans( ti.totalWeight - splitWeight );
				adjustTi.setMyTotalVolume( ti.totalVolume - splitVolume );
			endif;
			
		endif;
		
		if self.myCargoType.isAllowDuplicates then
			//Need a differnt id otherwise the split will merge the original value and the remainder values....
			if ti.id.length &lt; 20 then
				newId := ti.id &amp; "_";
			else
				newId := ti.id[1:19] &amp; "_";
			endif;
			app.myUtilityUA.utlSplitBreakBulkToNewID( 	ti.CM_Cargo,	//_sourceTi : CM_Cargo input;
														newId,	//_newId : String;
														newSplitTi,	//_newTi : CM_Cargo output; 
														splitQuantity,	//_quantity : Integer;
														splitWeight,	//_weight : Decimal;
														null,	//_operator : CM_Operator; 
														false,	//_includeStops : Boolean;
														false,	//_includeToDo : Boolean;
														false,	//_includeDamage : Boolean;
														false,	//_includeHaz : Boolean;
														null,
														_passport	//_passport : CM_Passport input
														);

			if newSplitTi &lt;&gt; null then
				tisToBeZombied.add( newSplitTi );
			else
				//must have had an error
				return;
			endif;
		endif;

	endif;
	
	foreach ti in tisToBeZombied do
		//Put the id back (as much as possible) so its recorded properly on the trx.
		if ti.id[ ti.id.length ] = "_" then
			ti.setPropertyValue( "id", ti.id[ 1: ti.id.length - 1] );
		endif;
		ti.createChildBlendTransaction( _parentBlendTrx, true, ti.totalQuantity, ti.totalWeight, ti.totalVolume, _passport );
		if _passport.hasErrors then
			return;
		endif;
		ti.consumeTIDuringBlend( parentBlendTi );
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	
	if adjustTi &lt;&gt; null then
		//The non splittable dude.
		adjustTi.createChildBlendTransaction( _parentBlendTrx, false, splitQuantity, splitWeight, splitVolume, _passport );
		if _passport.hasErrors then
			return;
		endif;
	endif;

epilog

	delete localTIs;
	delete tisToBeZombied;

end;</source>
        <Parameter name="_parentBlendTrx" type="CM_Blend" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAmountString" id="4992ab57-d3b0-42c2-967a-540c778d899b">
        <source>getAmountString( _perItem : Boolean ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	returnVal : String;
	measureType : CM_MeasurementType;
	type : String;

begin

	if self.myCargoType.isTrackByVolume then
		if self.myProduct &lt;&gt; null then
			measureType := self.myProduct.getDefaultMeasurementForType(Type_Volume);
		else
			measureType := self.myCargoType.getDefaultMeasurementForType(Type_Volume);
		endif;
		type := measureType.shortName;
		if self.volume &lt;&gt; 0 then
			if _perItem then
				returnVal := app.convertMeasurementForDisplay(type, (self.volume * self.factor ) ) &amp; " " &amp; type;
			else
				returnVal := app.convertMeasurementForDisplay(type, (self.volume * self.factor * self.outputCargoIdCount ) ) &amp; " " &amp; type;
			endif;
		endif;
	elseif self.myCargoType.isTrackByWeight then
		if self.myProduct &lt;&gt; null then
			measureType := self.myProduct.getDefaultMeasurementForType(Type_Weight);
		else
			measureType := self.myCargoType.getDefaultMeasurementForType(Type_Weight);
		endif;
		type := measureType.shortName;
		if self.weight &lt;&gt; 0 then
			if _perItem then
				returnVal := app.convertMeasurementForDisplay(type, (self.weight * self.factor ) ) &amp; " " &amp; type;
			else
				returnVal := app.convertMeasurementForDisplay(type, (self.weight * self.factor * self.outputCargoIdCount ) ) &amp; " " &amp; type;
			endif;
		endif;
	else
		if self.quantity &lt;&gt; 0 then
			if _perItem then
				returnVal := "x" &amp; ( self.quantity * self.factor ).Integer.asStringJMT;
			else
				returnVal := "x" &amp; ( self.quantity * self.factor * self.outputCargoIdCount ).Integer.asStringJMT;
			endif;
		endif;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_perItem" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypeProdString" id="ca29dd6a-4ac6-4ded-bc39-ceb40152f77c">
        <source>getCargoTypeProdString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	str : String;

begin

	if self.myProduct = null then
		if self.myCargoType &lt;&gt; null then
			str := self.myCargoType.description;
		endif;
	else
		str := self.myProduct.myCargoType.abbreviation &amp; " / " &amp; self.myProduct.code;
	endif;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPerItemAmountString" id="dd944258-ad33-48de-bb84-cbc02491c2b4">
        <source>getPerItemAmountString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	returnVal : String;
	measureType : CM_MeasurementType;
