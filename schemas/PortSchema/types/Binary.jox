<PrimType name="Binary">
    <JadeMethod name="asHex" id="92ceee17-c3b1-46ed-9a17-61d7b573a84d">
        <source>asHex(): String;

vars
	i:       Integer;
	hexstr:  String;
begin
	foreach i in 1 to self.length do
		hexstr[(2 * i) - 1:2] := self[i].Character.toHex;
	endforeach;

	return hexstr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
