    <JadeMethod name="mdhTestStackDumpEmail" id="f0d71acd-1da8-4b3b-937f-d4a76dc4bb35">
        <source>mdhTestStackDumpEmail();

/*

Purpose:		

Date			Who		Reason
24 January 2014	cnwmh5	Initial creation

*/

vars

	codeV						: UT_JMTCodeVerification;
	file						: File;
	runTestDailyONSave			: UM_UnitTestRun;	
	association					: CM_Association;

	userSummaryDict				: CM_AssociationDict;
	userIgnoreDict				: CM_AssociationDict;
	
	iter						: Iterator;
	
	line						: String;
	startTime 					: TimeStamp;
	endTime						: TimeStamp;
	user						: String;
	
	fileFolder								: FileFolder;
	fileNode								: FileNode;
	unitTestResult							: UM_UnitTestResult;
	
	outputStr								: String;
	methStartTS								: TimeStamp;
	methEndTS								: TimeStamp;
	elapsedTime								: TimeStampInterval;
	resultStr								: String;
	
begin

	app.initialize();

	create file transient;
	file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	file.fileName := app.cnGetServerMiscPath &amp; "\UnitTestTransientLeaks\unitTestRunTime.txt";
	file.usePresentationFileSystem := false;
	
	startTime := file.readLine().TimeStamp;
	endTime := file.readLine().TimeStamp;
	
	write startTime.String &amp; Tab &amp; Tab &amp; endTime.String;
	
	runTestDailyONSave := UM_UnitTestRun.instances.last.UM_UnitTestRun;
	
	create userSummaryDict transient;
	create userIgnoreDict transient;
	
	userSummaryDict.clear();
	userIgnoreDict.clear();
	
	/*
	methStartTS := app.cnGetServerTime();

	create fileFolder transient;
	fileFolder.fileName := app.getAppServerLogDir() &amp; "\";
	fileFolder.usePresentationFileSystem := false;
	fileFolder.mask := "*dump_*_cnwchcs11*";
	
	outputStr := null;
	foreach fileNode in fileFolder.files do
		if fileNode.createdTime &gt;= startTime and fileNode.createdTime &lt;= endTime then
			outputStr := outputStr.trimBlanks() &amp; CrLf &amp; fileNode.fileName;
		endif;
	endforeach;

	methEndTS := app.cnGetServerTime();
	elapsedTime := (methEndTS - methStartTS).TimeStampInterval;
	
	if outputStr &lt;&gt; null then
		//_userSummary.addAssociation(app.getUTAdminUserCode(), "Fail " &amp; method.getSchemaType().name &amp; " " &amp; 
		//	method.name &amp; " ADMIN    " &amp; _startTS.date.String &amp; " " &amp; _startTS.time.String &amp; CrLf &amp; outputStr);
		resultStr := 'FAIL ';
		write resultStr &amp; Tab &amp; app.getUTAdminUserCode() &amp; Tab &amp; "Fail " &amp; method.getSchemaType().name &amp; " " &amp; 
			method.name &amp; " ADMIN    " &amp; startTime.date.String &amp; " " &amp; startTime.time.String &amp; CrLf &amp; outputStr;
	else	
		resultStr := "PASS ";
		write resultStr;
	endif;
	*/
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	
	create codeV transient;
	codeV.sendMsgWithIOParams('vCheckForStackDumps', startTime, endTime, userSummaryDict, runTestDailyONSave);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		//self.emailReports(association.asStringWithoutFailures(), "Stack Dumps", 2, testRunner);
		write 'Stack Dumps' &amp; CrLf &amp; association.asStringWithoutFailures();
	endwhile;
	
	
epilog

	delete userIgnoreDict;
	delete userSummaryDict;
	delete iter;

end;</source>
    </JadeMethod>
