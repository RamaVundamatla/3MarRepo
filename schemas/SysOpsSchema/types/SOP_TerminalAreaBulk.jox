    <JadeMethod name="doAdd" id="26515a7c-b586-4e0f-a44c-946ee2f11804">
        <source>doAdd();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2022	navhl20	ChangeRequest 53921: MTN - GC Area Terminal Area Defn Transfer Areas.

*/

vars
	int				:Integer;
	lc				:CM_LocationsController;
	coll			:CM_IntegerArray;
	invalidObject 	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, lc, invalidObject);
	create coll transient;
	
	lstAvailArea.getSelectedEntries (coll);
	
	foreach int in coll do
		lc	:= lstAvailArea.itemObject[int].CM_LocationsController;
		if lc.CM_IrregularBlockController.getInterChangeArea &lt;&gt; null then
			int := lstSelectedArea.addItem(lc.ident &amp; Tab &amp; "(" &amp; lc.CM_IrregularBlockController.getInterChangeArea.id &amp; ")");    ////16 Aug 2022 navhl20 TFS 53921
		else
			int := lstSelectedArea.addItem(lc.ident);
		endif;
		
		if invalidObject then			
			invalidObject	:= false;	
			continue;					
		endif;							
		
		lstSelectedArea.itemObject[int] := lc;
		allSelectedAreas.addNoDuplicates(lc,false);
	endforeach;
	lstAvailArea.removeSelectedObjects;
epilog
	btnRemove.enabled	:= false;
	
	delete coll;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAddAll" id="f23877e3-c0bc-45f3-b8b0-9abe02eb5ad3">
        <source>doAddAll();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2022	navhl20	ChangeRequest 53921: MTN - GC Area Terminal Area Defn Transfer Areas.

*/

vars
	listBoxCount 		: Integer;
	lc 				: CM_LocationsController;
	invalidObject		: Boolean;
	count 				: Integer;
	countSelectedItems 	: Integer;
begin
	on Exception do app.handleDeletedObject (exception, lc, invalidObject);
	listBoxCount := lstAvailArea.listCount;
	countSelectedItems := lstSelectedArea.listCount;
	
	count := 1;
    while count &lt;= listBoxCount do
		countSelectedItems += 1;
		lc := lstAvailArea.itemObject[count].CM_LocationsController;
		if lc.CM_IrregularBlockController.getInterChangeArea &lt;&gt; null then
			lstSelectedArea.addItem(lc.ident &amp; Tab &amp; "(" &amp; lc.CM_IrregularBlockController.getInterChangeArea.id &amp; ")");    ////16 Aug 2022 navhl20 TFS 53921
		else
			lstSelectedArea.addItem(lc.ident);
		endif;
		if invalidObject then			
			invalidObject	:= false;	
			continue;					
		endif;
		lstSelectedArea.itemObject[countSelectedItems] := lc;
		allSelectedAreas.addNoDuplicates(lc,false);
		count += 1;
    endwhile;
	lstAvailArea.clear;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemove" id="10dbf1b2-a29b-41f8-ba0c-845b36148608">
        <source>doRemove();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2022	navhl20	ChangeRequest 53921: MTN - GC Area Terminal Area Defn Transfer Areas.

*/

vars
	int				:Integer;
	lc				:CM_LocationsController;
	coll			:CM_IntegerArray;
	invalidObject 	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, lc, invalidObject);	
	create coll transient;
	
	lstSelectedArea.getSelectedEntries (coll);
	
	foreach int in coll do
		invalidObject	:= false;	
		
		lc	:= lstSelectedArea.itemObject[int].CM_LocationsController;
		if lc.CM_IrregularBlockController.getInterChangeArea &lt;&gt; null then
			int := lstAvailArea.addItem(lc.ident &amp; Tab &amp; "(" &amp; lc.CM_IrregularBlockController.getInterChangeArea.id &amp; ")");    ////16 Aug 2022 navhl20 TFS 53921
		else
			int := lstAvailArea.addItem(lc.ident);
		endif;
		allSelectedAreas.remove(lc);
		
		if not invalidObject then	
			lstAvailArea.itemObject[int] := lc;
		endif;						
	endforeach;
	
	lstSelectedArea.removeSelectedObjects;
epilog
	btnRemove.enabled	:= false;
	
	delete coll;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRemoveAll" id="d82ed462-88d0-4829-b9e9-b13123229ca3">
        <source>doRemoveAll();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2022	navhl20	ChangeRequest 53921: MTN - GC Area Terminal Area Defn Transfer Areas.

*/

vars
	lc					: CM_LocationsController;
	invalidObject		: Boolean;
	listBoxCount 		: Integer;
	count 				: Integer;
	countAvailableItems : Integer;
begin
	on Exception do app.handleDeletedObject (exception, lc, invalidObject);
	
	listBoxCount := lstSelectedArea.listCount;
	countAvailableItems := lstAvailArea.listCount;
	
	count := 1;
    while count &lt;= listBoxCount do
		countAvailableItems +=1;
		lc := lstSelectedArea.itemObject[count].CM_LocationsController;
		if lc.CM_IrregularBlockController.getInterChangeArea &lt;&gt; null then
			lstAvailArea.addItem(lc.ident &amp; Tab &amp; "(" &amp; lc.CM_IrregularBlockController.getInterChangeArea.id &amp; ")");    ////16 Aug 2022 navhl20 TFS 53921
		else
			lstAvailArea.addItem(lc.ident);
		endif;
		if invalidObject then
			continue;			
		endif;
		lstAvailArea.itemObject[countAvailableItems] := lc;
		allSelectedAreas.remove(lc);
		count += 1;
    endwhile;
	lstSelectedArea.clear();
epilog

end;</source>
    </JadeMethod>
