    <JadeMethod name="getXMLSettingsForSave" id="abd57054-45aa-4bc6-9edf-4ce69bd504d1">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	xmlStr	: String;
begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblDeckItems.getXmlStrForColumns(true);
 	xmlStr := xmlStr &amp; 
			global.formatAsXML("ROROREMIND",self.xmlRotateReminder.Integer.String);

		// PAR 28011
	xmlStr := xmlStr &amp; 
			global.formatAsXML("ROROMULTI",self.xmlMultiReminder.Integer.String);

	return xmlStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="95ef27af-d7cf-4741-9d3b-fd14b70e8656">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
/*
Purpose:			
Date		Who		Reason
19 May 2011	cnwab1	Initial creation
*/

vars

	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	flipH, flipV, bigFont,hideL,hideT,hideM : Boolean;
	zoomScale : Real;
begin

	self.xmlRotateReminder := true;
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;

	theXML := userWindow.xmlInfo;
	
	
	self.xmlRotateReminder := true;
	theXMLValue := theXML.cnEcGetTagValueOfName("ROROREMIND");
	if theXMLValue &lt;&gt; null then
		self.xmlRotateReminder := theXMLValue.Integer.Boolean;
	endif;
	// PAR 28011
	self.xmlMultiReminder := true;
	theXMLValue := theXML.cnEcGetTagValueOfName("ROROMULTI");
	if theXMLValue &lt;&gt; null then
		self.xmlMultiReminder := theXMLValue.Integer.Boolean;
	endif;
	
epilog

end;</source>
    </JadeMethod>
