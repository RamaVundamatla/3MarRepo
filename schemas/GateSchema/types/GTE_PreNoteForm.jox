    <JadeMethod name="moveTrackedItems" id="5c5cd363-e04f-4707-8c6d-112f1c84f818">
        <updating/>
        <source>moveTrackedItems(_moveControl : CMIF_MoveController input)updating;
//--------------------------------------------------------------
//Created: 10 June 2003 By: cnwgd1
//--------------------------------------------------------------
// 26/02/2010	cnwmh5		PAR22517 - Change app.myPassport.myTerminal to self.myTerminal
//--------------------------------------------------------------
vars
	result,
	event 	: Integer;
	obj 	: Object;
	ti 		: CM_TrackedItem;
begin
	app.mousePointer := MousePointer_HourGlass;
	if _moveControl = null then
		return;
	endif;
	
	foreach obj in self.tblData.allSelectedObjects do
		_moveControl.allOtherTrackedItems.add(obj.CM_TrackedItem);
	endforeach;
	
	if _moveControl.allOtherTrackedItems.isEmpty then
		return;
	endif;
	
	ti := _moveControl.allOtherTrackedItems.first;
	_moveControl.setMyTrackedItem(ti);
	_moveControl.allOtherTrackedItems.remove(ti);

	//event := app.myPassport.myTerminal.getTerminalEvent(TIEvent_Terminal_Receival);
	event := self.myTerminal.getTerminalEvent(TIEvent_Terminal_Receival);	// 26/02/2010 cnwmh5 #22517
	
	while true do
		app.myTrxUA.trxMoveTrackedItem(_moveControl, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// No errors, so commit
			// Par 10591 Send out the receival note if everything was ok
			foreach obj in self.tblData.allSelectedObjects do
				obj.causeEvent(event, true,null); 
			endforeach;
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Receive Cargo', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog	
	app.mousePointer := MousePointer_Default;
//	app.myMoveController := null; //cnwrs1 Mar 2007 just creates a memory leak
end;</source>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resetNotifications" id="9aa8114c-7092-4211-b610-b41632f1959b">
