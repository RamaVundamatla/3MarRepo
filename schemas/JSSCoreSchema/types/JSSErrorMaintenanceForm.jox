    <JadeMethod name="btnFindNext_click" id="871e454f-9ca2-46ec-b465-e334a45b92bf">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFindNext_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		10 April 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	exceptionCode	: Integer;
	
begin
	app.mousePointer	:=	Busy;
	exceptionCode		:=	self.findNextAvailableExceptionCode();
	
	if exceptionCode = 0 then
		app.msgBox(	"The next available exception code could not be determined.",
					"System Error",
					MsgBox_Stop_Icon + MsgBox_OK_Only);
	else
		app.msgBox(	"The next available exception code is '" &amp; exceptionCode.padLeadingWith("0", 5) &amp; "'.",
					"Exception Code",
					MsgBox_Information_Icon + MsgBox_OK_Only);
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
