        <source>getFirstLocationId() : String;
/*
Purpose:			

Date		Who		Reason
04 January 2024	navab1	CR 58499 TASK 61458
*/

vars

begin

	if self.myRoadJob&lt;&gt; null then
		//return self.myRoadJob.getFirstLocationId(); 
		return self.myRoadJob.getFirstLocationId(false);  //26/08/2024	navkc1 CR 63588 Task 63589
