    <JadeMethod name="userNotification" id="d8ca4525-4685-4da0-9234-e67b154037d8">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		18 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 18/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
vars
	machine : CM_Machine;
	cmifWorkzone : CMIF_MachineWorkzone;
	termEventType : Integer;
	found : Boolean;
begin
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. theObject: " &amp; theObject.String &amp; " eventType: " &amp; eventType.String  &amp; " userInfo: " &amp; userInfo.String);
	inheritMethod(eventType, theObject, eventTag, userInfo);
	
	termEventType:=self.myTerminal.getEventFromTerminalEvent(eventType);
	if eventType = EVENT_ColourStackHeightsUpdate then
		
		if not app.myRoot.coloursForTALevels.compareTheSame(self.myDrawingAttrController.yardStackColours) then
			self.myDrawingAttrController.yardStackColours.clear;
			app.myRoot.coloursForTALevels.copy(self.myDrawingAttrController.yardStackColours);
			self.myGridOverviewForm.frmColLegendTIs.redisplayViewModeCodes();

			if self.viewMode = VIEW_HEIGHT then
				self.drawSelf(false);
			endif;
		endif;
	elseif termEventType = Event_Mach_Workzone_Update then
		if theObject.isKindOf(CM_Machine) then
			machine:=theObject.CM_Machine;
			
			foreach cmifWorkzone in self.allCMIFMachineWorkzones do
				if cmifWorkzone.myMachine = machine then
					found:=true;
					break;
				endif;
			endforeach;
		
			if found &lt;&gt; null then
				self.allCMIFMachineWorkzones.remove(cmifWorkzone);
				delete cmifWorkzone;
			endif;	
			
			cmifWorkzone:=machine.getCMIFMachineWorkzone();
			if cmifWorkzone &lt;&gt; null then
				self.drawRTGMachinesWorkzone(cmifWorkzone);
				self.allCMIFMachineWorkzones.add(cmifWorkzone);
			endif;
			
		endif;
	elseif termEventType = Event_Mach_Last_Know_Location then
		if theObject.isKindOf(CM_Machine) then
			machine:=theObject.CM_Machine;
			self.drawRTGLastKnowPosition(machine);
		endif;
		
	// TFS 49453
	elseif termEventType = Event_TerminalAreaUpdate then
		if theObject.isKindOf(CM_GeneralCargoAllocRowArea) then
			self.drawFromNote := true;
			self.drawGCAllocRowAreaFromNote(theObject.CM_GeneralCargoAllocRowArea);
			self.drawFromNote := false;
		endif;
	// TFS 49453 end
	endif;
epilog
	self.drawFromNote := false;			// TFS 49453
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationAreaUpdate" id="fd32f393-8cc3-4950-8897-66637aba88cc">
        <updating/>
        <source>userNotificationAreaUpdate(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2008	cnwkpd1	PAR #16814 - Replace global.commonResumInvalidObjHandler
10/03/2011	cnwmh5	PAR #27142 - Change where handleDeleteObject is armed
19/06/2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

	anLC : CM_LocationsController;
	breakOut, gotException : Boolean;
	aTI : CM_TrackedItem;
	ta : CM_RTGArea;
	statsFrame : CMUI_Frame;
	taViewPos : CM_TerminalAreaViewPosition;
	gridColumn : CM_GridColumn;
	bs : CM_BlockStack;
	
begin
	
	if userInfo.isKindOf(CM_GridController) then
		anLC := userInfo.CM_GridController;
	endif;
	
	// cnwjk3 ccms 1018 27/01/10
	if userInfo.isKindOf(CM_RoRoController) then
		anLC := userInfo.CM_RoRoController;
	endif;
	
	if userInfo.isKindOf(CM_BlockController) then
		anLC := userInfo.CM_BlockController;
	endif;
	
	if userInfo.isKindOf(CM_GeneralCargoAllocController) then		// TFS 49453
		anLC := userInfo.CM_GeneralCargoAllocController;			// TFS 49453
	endif;															// TFS 49453
	
	if anLC = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, anLC, gotException);		// PAR #16814
	
	if eventType = self.noteTAMove or eventType = self.noteTIUpdate then
		// ###########################
		// Check to see if this location controller is on our form
		self.drawFromNote := true;
		if self.useSelectorObjects then
			foreach aTI in anLC.allTrackedItems do
				self.userNotificationHandleSelector(aTI,breakOut);
			endforeach;
		endif;
		
		self.drawObject(self.myDrawingFrame, anLC);
		
		//epr ccms 1076 24/8/09
		if anLC.isKindOf(CM_RTGController) then
			ta := anLC.myTerminalArea.CM_RTGArea;
			taViewPos:=self.myTerminalAreaView.findViewPositionForTA(ta);
			statsFrame:=self.getStatsFrameForTA(ta,false);
			if statsFrame &lt;&gt; null then
				statsFrame.beginBatchDrawing;
		
				statsFrame.clearGraphics;
				foreach gridColumn in ta.allGridColumns do
					self.drawFromNote:=true;
					self.drawQueuedInOutStatsForColumn(gridColumn,taViewPos,statsFrame);		// cnwjk3 ccms 1018 27/01/10	
				endforeach;
				statsFrame.endBatchDrawing;
			endif;
		
		//30 Aug 2011	NDL	Par 28076
		elseif anLC.isKindOf(CM_BlockController) or anLC.isKindOf(CM_BulkLocation) then
		
			self.drawBlockStackFromNote(  anLC.CM_BlockController.myTerminalArea );
			
		//21 Sep 2011	NDL	Par 28076
		elseif anLC.myTerminalArea &lt;&gt; null and anLC.myTerminalArea.isKindOf(CM_YardInterchangeArea) then
				self.drawYardInterchangeFromNote( anLC.myTerminalArea.CM_YardInterchangeArea );
				
		elseif anLC.isKindOf(CM_GeneralCargoAllocController) then									// TFS 49453
			self.drawGCAllocRowAreaFromNote(anLC.CM_GeneralCargoAllocController.myTerminalArea);	// TFS 49453
			
		endif;
		
		if gotException then
			// Exception handler resumes here if anLC was invalid.
			return;
		endif;
	endif;
epilog
	self.drawingAll := false;
	self.drawFromNote := false;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationHandleSelector" id="f613bd24-e41e-4f48-a0c0-a6d6c13de336">
        <updating/>
        <source>userNotificationHandleSelector(aTI : CM_TrackedItem; breakOut : Boolean io) updating;
// ---------------------------------------------------------------------------
// Created:		02 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	selForm 	: CMUI_Selector;
	noteRecord	: CMIF_NotificationRecord;
begin
	
	if self.myGridOverviewForm &lt;&gt; null then
		selForm := self.myGridOverviewForm.mySelectorForm;
	endif;
	if not global.isValidObject(self.mySelectorEnquiryController) then
		self.mySelectorEnquiryController := null;
	endif;
	if self.mySelectorEnquiryController &lt;&gt; null then
		if not self.mySelectorEnquiryController.includesObject(aTI,breakOut,app.myPassport) then
			if self.allSelectorTIs.includes(aTI) then
				self.allSelectorTIs.remove(aTI);
				if self.allSelectedObjects.includes(aTI) then
					self.allSelectedObjects.remove(aTI); 
				endif;
				if selForm &lt;&gt; null then
					selForm.doRemoveTIObject(aTI);
				endif;
				if self.mySelectorEnquiryController.allObjects.includes(aTI) then
					self.mySelectorEnquiryController.allObjects.remove(aTI);
				endif;
			endif;
		else
			if self.myGridOverviewForm &lt;&gt; null then
			
			else
				if not self.allSelectorTIs.includes(aTI) then
					self.allSelectorTIs.add(aTI);
					if selForm &lt;&gt; null then
						selForm.doAddTIObject(aTI);
					endif;
				endif;
			endif;
		endif;
		self.doPostSelector();
	endif;
epilog
	endLoad;
end;</source>
        <Parameter name="aTI" type="CM_TrackedItem"/>
        <Parameter name="breakOut" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="userNotificationTI" id="ed49f91b-0697-4afb-ab1a-dc887dfedbae">
        <updating/>
        <source>userNotificationTI(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2008	cnwkpd1	PAR #16814 - Replace global.commonResumInvalidObjHandler
01 Sep 2009   CNWAB1     PAR 19468  copied method from YRD_ContainerDrawingController and changed to draw LCs not TIs.
*/

vars
	lController : CM_LocationsController;
	event		: Integer;
	breakOut, gotException : Boolean;
	aTI : CM_TrackedItem;
	selForm : CMUI_Selector;

begin
	on Exception do app.handleDeletedObject(exception, lController, gotException);		// PAR #16814

	if userInfo.isKindOf(CM_TrackedItem) then
		aTI := userInfo.CM_TrackedItem;
	else
		return;
	endif;

	if self.displayMode = DISPLAY_MODE_PLAN then
		lController := aTI.myPrimaryPlannedLocation;
	elseif self.displayMode = DISPLAY_MODE_QUEUE then
		lController := aTI.myPrimaryQueuedLocation;
	elseif self.displayMode = DISPLAY_MODE_ACTUAL then
		lController := aTI.myPrimaryActualLocation;
	endif;	
	
	if lController &lt;&gt; null then 
		self.userNotificationAreaUpdate(eventType,theObject, eventTag, lController);
	endif;
epilog
	self.drawFromNote := false;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationYardAllocALL" id="734cd9bf-3f48-4038-b29a-d16e31a776e0">
        <updating/>
        <source>userNotificationYardAllocALL(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2008	cnwkpd1	PAR #16814 - handle invalid objects in notifications

*/

vars
	yalloc 			: CM_YardAllocation;
	anObject 		: Object;
	aTA 			: CM_TerminalArea;
	inCLUDED 		: Boolean;
	invalidObject	: Boolean;
	
begin
	if self.allTerminalAreas.isEmpty then
		return;
	endif;
	
	
	anObject := userInfo.Object;


	if anObject &lt;&gt; null then
		yalloc := anObject.CM_YardAllocation;
		
		on Exception do app.handleDeletedObject(exception, yalloc, invalidObject);	// PAR #16814

		foreach aTA in self.allTerminalAreas discreteLock do
			if aTA.isRTGLane then // we do not do yard allocations when showing RTG LANES
				continue;
			endif;
			
			if yalloc.allTerminalAreas.includes(aTA) then
				inCLUDED := true;
			endif;
		endforeach;
		
		// ### Not showing allocations so do nothing
		if not self.myDrawingFrame.myOverlayViewingFrame.visible 
		and   eventType &lt;&gt; self.noteTAYardAllocationDelete then // ### PAR 10552

			if  inCLUDED and eventType = Event_YardAllocationUpdate  then // ### PAR 10552
				self.myGridOverviewForm.setYardAllocLegend();
				return;
			endif;
		endif;
		
		if  eventType = self.noteTAYardAllocationDelete then
			self.myDrawingFrame.myOverlayDrawingFrame.allObjects.clear;
			self.myDrawingFrame.myOverlayDrawingFrame.allPoints.clear;
			// Carry on through to update lengend.
		else
			// ### not for my terminal area so do nothing.
			if not inCLUDED then // ### PAR 10552
				if self.myDrawingAttrController.allYardAllocations.includes(yalloc) then // as delete. We were displaying this but our TA has been removed from the allocation
					self.myDrawingFrame.myOverlayDrawingFrame.allObjects.clear;
					self.myDrawingFrame.myOverlayDrawingFrame.allPoints.clear;
				else
					return;
				endif;			
			endif;
		endif;
						
		self.myDrawingFrame.myOverlayDrawingFrame.myCurrentYardAllocation := null;
		self.myDrawingFrame.myOverlayViewingFrame.myCurrentYardAllocation := null;

		self.getYardAllocationPoints(false); // draw on viewing frame
		self.myDrawingAttrController.allYardAllocations.clear;

		foreach aTA in self.allTerminalAreas discreteLock do
			if aTA.isRTGLane then // we do not do yard allocations when showing RTG LANES
				continue;
			endif;
			foreach yalloc in aTA.CM_GridArea.allYardAllocations discreteLock where (not yalloc.isDisabled and yalloc.includeInYardDisplays()) do
				self.myDrawingAttrController.allYardAllocations.addNoDuplicates(yalloc,false);
			endforeach;
		endforeach;

		self.myGridOverviewForm.setYardAllocLegend();

		self.myDrawingFrame.myOverlayDrawingFrame.drawAllYAFrames();
		
	endif;
epilog
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationYardAllocation" id="e5c03886-42be-4775-b646-787677842330">
        <updating/>
        <source>userNotificationYardAllocation(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2008	cnwkpd1	PAR #16814 - handle invalid objects in notifications

*/

vars
	yalloc 			: CM_YardAllocation;
	anObject 		: Object;
	invalidObject	: Boolean;
begin

	if self.isForSatelliteView then
		// The update of the Sat view is controlled by the form
		self.myGridOverviewForm.YRD_SatelliteViewForm.doYAMTableSelection();
		return;
	endif;

	if not self.allTerminalAreas.isEmpty then
		self.userNotificationYardAllocALL(eventType,theObject,eventTag, userInfo);
		return;
	endif;
	
	if self.myTerminalArea.isRTGLane then // we do not do yard allocations when showing RTG LANES
		return;
	endif;

	anObject := userInfo.Object;


	if anObject &lt;&gt; null then
		yalloc := anObject.CM_YardAllocation;
		
		on Exception do app.handleDeletedObject(exception, yalloc, invalidObject);	// PAR #16814

		// ### Not showing allocations so do nothing
		if not self.myDrawingFrame.myOverlayViewingFrame.visible 
		and   eventType &lt;&gt; self.noteTAYardAllocationDelete then // ### PAR 10552

			if  yalloc.allTerminalAreas.includes(self.myTerminalArea.CM_GridArea) and eventType = Event_YardAllocationUpdate  then // ### PAR 10552
				self.myGridOverviewForm.setYardAllocLegend();
				return;
			endif;
		endif;
		
		if  eventType = self.noteTAYardAllocationDelete then
			self.myDrawingFrame.myOverlayDrawingFrame.allObjects.clear;
			self.myDrawingFrame.myOverlayDrawingFrame.allPoints.clear;
			// Carry on through to update lengend.
		else
			// ### not for my terminal area so do nothing.
			if not yalloc.allTerminalAreas.includes(self.myTerminalArea.CM_GridArea) then // ### PAR 10552
				if self.myDrawingAttrController.allYardAllocations.includes(yalloc) then // as delete. We were displaying this but our TA has been removed from the allocation
					self.myDrawingFrame.myOverlayDrawingFrame.allObjects.clear;
					self.myDrawingFrame.myOverlayDrawingFrame.allPoints.clear;
				else
					return;
				endif;			
			endif;
		endif;
						
		self.myDrawingFrame.myOverlayDrawingFrame.myCurrentYardAllocation := null;
		self.myDrawingFrame.myOverlayViewingFrame.myCurrentYardAllocation := null;

		self.getYardAllocationPoints(false); // draw on viewing frame
		self.myDrawingAttrController.allYardAllocations.clear;
		// CCMS 1013
		//foreach yalloc in self.myTerminalArea.allYardAllocations discreteLock where yalloc.isDisabled = false do
		foreach yalloc in self.myTerminalArea.CM_GridArea.allYardAllocations discreteLock where (not yalloc.isDisabled and yalloc.includeInYardDisplays()) do
			self.myDrawingAttrController.allYardAllocations.addNoDuplicates(yalloc,false);
		endforeach;

		self.myGridOverviewForm.setYardAllocLegend();

		self.myDrawingFrame.myOverlayDrawingFrame.drawAllYAFrames();
		
	endif;
epilog
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
