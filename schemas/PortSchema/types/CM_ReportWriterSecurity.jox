    <JadeMethod name="userCanDo" id="de065532-90e5-408c-91d8-98748a2da7c7">
        <source>userCanDo(userName: String; pRead, pFull : Integer): Integer protected;

vars
	theUser	: CM_User;

begin

	theUser := app.myRoot.allUsers[userName.toUpper];
	if theUser = null then
		return NO_ACCESS;
	endif;

	if (not theUser.canDo(app.getMyTerminalDO_NOT_USE(), pRead)) then
		return NO_ACCESS;
	endif;

	if theUser.canDo(app.getMyTerminalDO_NOT_USE(), pFull) then
		return FULL_ACCESS;
	endif;

	return READ_ONLY_ACCESS;

end;</source>
        <access>protected</access>
        <Parameter name="userName" type="String"/>
        <Parameter name="pRead" type="Integer"/>
        <Parameter name="pFull" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
