	wsMethods.add(CM_SAPWSConsumerAgent::preBillCheckLimitRequest_SI.name);
	requestClasses.add(CMIF_SAPPreBillCheckLimitReq);
	responseClasses.add(CMIF_SAPWSResponse);
	
	wsMethods.add(CM_SAPWSConsumerAgent::preBillPaidInvoiceRequest_SI.name);
	requestClasses.add(CMIF_SAPPreBillPaidInvReq);
	responseClasses.add(CMIF_SAPWSResponse);
	
	wsMethods.add(CM_SAPWSConsumerAgent::preBillProdDataReq_SI.name);
	requestClasses.add(CMIF_SAPPreBillProdDataReq);
	responseClasses.add(CMIF_SAPWSResponse);
*/	
	foreach i in 1 to wsMethods.size() do
		delete req;
