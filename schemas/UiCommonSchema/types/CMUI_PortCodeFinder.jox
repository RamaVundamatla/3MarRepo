    <JadeMethod name="doLocodeSearch" id="6672d593-308d-49d5-999b-459f7b59a495">
        <source>doLocodeSearch() protected;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/6/2006	RBarr		CM_Port::codeDisplay attribute obsolete
// 26 May 2008	cnwkpd1		PAR #16810 - Increase in Jade table row limit
// 11 Jan 2011	cnwkpd1		PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------

vars

	country,
	code,
	str,
	portDesc	 : String;
	countryObj	: CM_Country;
	iter		: Iterator;
	dict		: CM_PortByCodeDict;
	count,
	idx,
	length		: Integer;
	port		: CM_Port;
		
begin

	self.tblLocodes.rows := 1;
	
	code		:= self.txtPortCode.text.trimBlanks();
	portDesc	:= self.txtPortDescr.text.trimBlanks();
	
	countryObj 	:= self.cmbCounty.myObject.CM_Country;
	
	
	if self.isPort then
		dict := app.myRoot.allPortLocodes;
	else
		dict := app.myRoot.allPorts;
	endif;
	
	iter := dict.createIterator();
	
	if countryObj &lt;&gt; null then
		dict.startKeyGeq(countryObj.code, iter);
	endif;
	
	length := code.length;
	
	while iter.next(port) do
		
		if port.isActiveDestination then
			continue;
		endif;
			
		if not length = 5 then
			if countryObj &lt;&gt; null and port.myCountry &lt;&gt; countryObj then
				continue;
			endif;
		endif;
		
		if code &lt;&gt; null then
			
			if length &lt; 4 then
				if not (code[1:length] = port.portCode[1:length]) then
					continue;
				endif; 
			else
				if 	code &lt;&gt; port.portCode and
				code &lt;&gt; port.code then
					continue;
				endif;
			endif;
		endif;
		
		if not length = 5 then
			if portDesc &lt;&gt; null then
				length := portDesc.length;
				// cnwrs1 July 2006 make the search work on subStrings 
				if length &lt; 4 then
					if not (portDesc[1:length] = port.description[1:length].toUpper()) then
						length := 0;
						continue;
					endif;
				else
					if not port.description.toUpper().cnContains(portDesc) then
						length := 0;
						continue;
					endif;
				endif;
			endif;
		endif;
		
		length := 0;
		count := count + 1;
//		idx := self.tblLocodes.addItem(port.code &amp; Tab &amp; port.description &amp; Tab &amp; port.countryCode &amp; Tab &amp;  port.isPort.getYesNo());	// cnwrl1 29/05/2009 PAR 19672 - what it was
		idx := self.tblLocodes.addItem(port.code &amp; Tab &amp; port.description &amp; Tab &amp; port.getCountryCodeForDisplay( Space ) &amp; Tab &amp;  port.isPort.getYesNo());
		self.tblLocodes.accessRow(idx).itemObject := port;
		if count &gt;= JadeTableRowLimit then		// PAR #16810
			app.msgBox('Unable to display more than ' &amp; JadeTableRowLimit.String &amp; ' rows', 'Maximum Rows Reached',  MsgBox_Exclamation_Mark_Icon);
			break;
		endif;
	endwhile;
	
	self.tblLocodes.sortColumn[1] := 1;
	self.tblLocodes.sortAscending := true;
	
	self.tblLocodes.resort();
	self.lblResults.caption := 'UN Locode Search Results - ' &amp; count.String;

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="makeActive" id="5541932e-578c-4b41-a328-bfaba2ad29c1">
        <updating/>
        <source>makeActive() protected, updating;

// Created by cnwdvb1 on 07 April 2006

vars


	port		: CM_Port;
	obj			: Object;
	idx			: Integer;
	strDesc,
	strC		: String;
	objectArray	: ObjectArray;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815

begin

	create objectArray transient;
	port := self.tblLocodes.allSelectedObjects.first.CM_Port;
	if port = null then
		return;
	endif;
	objectArray.add(port);
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxPortCodeMakeActiveInactive(objectArray, true, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Make Code Active', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

	self.myCombobox.setObject(port);
	self.myCombobox.lostFocus(self.myCombobox);

	self.unloadForm();
epilog
	delete objectArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="74e9a74d-dc86-42aa-940c-4524ccb53157">
