    <JadeMethod name="xDeleteVessel" id="ea061a0e-e190-4adc-aa32-c95395355623">
        <source>xDeleteVessel();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2022		navma1	Initial creation

*/

vars
	vessel	: CM_Vessel;
	voyage  : CM_Voyage;
	invalid : Boolean;
	errors	: String;
begin
	
	self.opts.purge();
	self.opts.addAssoc(UT_Profile.P_TERMINAL,'UT');
	
	vessel	:= self.getVessel( self.code );
	
	if vessel &lt;&gt; null then
	
		on Exception do app.handleDeletedObject( exception, voyage, invalid );
		
		foreach voyage in vessel.allVoyagesByTermCodeArrival do
			self.deleteVoyage(voyage.code);
		endforeach;
		
		self.ignoreTrxWarnings(true);
		app.myTrxDA.trxDeleteVessel(vessel, app.myPassport); 
		
		
		if app.myPassport.hasErrors()then
			errors := app.myPassport.getErrorsAsString;
			self.assertTrueMsg(false ,
			'Test : ' 						      		  &amp;   self.testname   &amp; CrLf &amp; 
			'Error : Failed to Delete Vessel : ' 		  &amp;   self.code  	  &amp; CrLf &amp; 
			'Trx Errors: '						 		  &amp;   errors  );
		endif;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="xUpdateCustomsAction" id="c2c525b2-3972-4600-9537-654e9124e342">
        <source>xUpdateCustomsAction(_actionName : String; _actionKeyword, _actionKeyField, _actionType, _roleCode : String; _actionObject : CM_Object) : CM_EDIAction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2023	navpw1	Initial creation TFS: 61364 (61375)

*/

vars
	pxyCustomsAction,
	realCustomsAction	: CM_EDIAction;
	
begin
	realCustomsAction := app.myRoot.allEDIActions[_actionName];
	self.assertNotNullMsg(realCustomsAction, "realCustomsAction");
	
	pxyCustomsAction := app.createUpdateProxy(realCustomsAction).CM_EDIAction;
	self.assertTrueMsg(pxyCustomsAction.isTransient, "Expected: 'transient object' | Actual: 'Non-transient object'");
	
	pxyCustomsAction.setProxy(_actionName, _actionKeyword, _actionKeyField, _actionType, _actionObject, CM_EDIFileTypeXMLJMTInternal.firstInstance, null, null, null, _roleCode);
	
	app.myTrxUA.trxUpdateEDIAction(pxyCustomsAction, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	realCustomsAction := app.myRoot.allEDIActions[_actionName];
	self.assertNotNullMsg(realCustomsAction, "realCustomsAction");
	
	return realCustomsAction;
	
epilog
	delete pxyCustomsAction;
	
end;</source>
        <Parameter name="_actionName" type="String"/>
        <Parameter name="_actionKeyword" type="String"/>
        <Parameter name="_actionKeyField" type="String"/>
        <Parameter name="_actionType" type="String"/>
        <Parameter name="_roleCode" type="String"/>
        <Parameter name="_actionObject" type="CM_Object"/>
        <ReturnType type="CM_EDIAction"/>
    </JadeMethod>
