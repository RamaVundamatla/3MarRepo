    <JadeMethod name="pxyCreateUpdateProxy" id="13e64ad9-bfa0-4d93-959f-b0ee553d89ae">
        <source>pxyCreateUpdateProxy() : SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 PEl1 Work Order Changes
// 20/06/2018   cnwma1		ChangeRequest 38815: PEL1 - WP TI Work Order Changes
// 27/12/2022   navdp20     ChangeRequest 56661:[56012] - Add Transport Mode to Receive and Release work orders
// 2 Feb 2023 	navhl20		ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
// 17 Apr 2023  navhl20 	ChangeRequest 57322:[57323] EUP - VAS Task linked with Receive Cargo work Order
// 27 Jun 2023	navlw1		ChangeRequest 58730: EUP | Link bill of lading item to Receive work orders
vars
	pxy 		: SelfType;
	completedOK : Boolean;

begin
	pxy := inheritMethod();
	
	pxy.myBookingRef 		    := self.myBookingRef;
	pxy.myBookingRefItem		:= self.myBookingRefItem;				//17.4.2023 navhl20 #57322[57323]
	pxy.customExportEntryNumber := self.customExportEntryNumber;		//20.6.2018 cnwma1 TFS #38815
	pxy.transport 				:= self.transport;						//28.12.2022 navdp20 TFS 56661[56012]
	pxy.myBillOfLading 			:= self.myBillOfLading; 				//2.2.2023 navhl20 #55443[54991]
	pxy.myVoyage 				:= self.myVoyage; 						//2.2.2023 navhl20 #55443[54991]
	pxy.myTrain 				:= self.myTrain; 						//2.2.2023 navhl20 #55443[54991]
	pxy.myBillOfLadingDtl		:= self.myBillOfLadingDtl;				//27.6.2023 navlw1 #58730
	
	completedOK := true;
	return pxy;
	
epilog
	if not completedOK then
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6ca070c7-9098-449c-8117-97f5e6b4d9d1">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WorkOrderDtl) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
// 27/12/2022   navdp20     ChangeRequest 56661:[56012] - Add Transport Mode to Receive and Release work orders
// 2 Feb 2023 	navhl20 	ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
// 17 Apr 2023  navhl20 	ChangeRequest 57322:[57323] EUP - VAS Task linked with Receive Cargo work Order
// 27 June 2023	navlw1		ChangeRequest 58730: EUP | Link bill of lading item to Receive work orders
vars

begin
	inheritMethod(_pxyWoDDtl);
	
	self.myBookingRef 			 := _pxyWoDDtl.CM_WodReceive.myBookingRef;
	self.myBookingRefItem		 := _pxyWoDDtl.CM_WodReceive.myBookingRefItem;				//17.4.2023 navhl20 #57322[57323]
	self.customExportEntryNumber := _pxyWoDDtl.CM_WodReceive.customExportEntryNumber; 		//20.6.2018 cnwma1 TFS #38815
	self.transport 				 :=_pxyWoDDtl.CM_WodReceive.transport;						//28.12.2022 navdp20 TFS 56661[56012]
	self.myVoyage 			     := _pxyWoDDtl.CM_WodReceive.myVoyage;						//2.2.2023 navhl20 #55443[54991]
	self.myTrain 				 := _pxyWoDDtl.CM_WodReceive.myTrain;						//2.2.2023 navhl20 #55443[54991]
	self.myBillOfLading 		 := _pxyWoDDtl.CM_WodReceive.myBillOfLading;				//2.2.2023 navhl20 #55443[54991]
	self.myBillOfLadingDtl		 := _pxyWoDDtl.CM_WodReceive.myBillOfLadingDtl;				//27.6.2023 navlw1 #58730
	
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="setMyBookingRef" id="567b85d6-bd6b-44e9-8c0c-2598ff062631">
        <updating/>
        <source>setMyBookingRef(_booking : CM_BookingRef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 October 2022	navgm20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements

*/

vars

begin
