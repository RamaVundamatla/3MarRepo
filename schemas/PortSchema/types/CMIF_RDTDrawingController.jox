        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resizeDrawingFrames" id="ba74f0a7-89c2-4f87-9392-9ab9f58d68c8">
        <updating/>
        <source>resizeDrawingFrames() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwjk3	Initial creation

*/

vars
	theFrame	: Frame;
begin
	// I check for a parent here, as the RDT form has a frmGraphic which is the direct parent of the 
	// viewport frame. In this case, I need the top and left offsets of the parent frame to get the
	// offsets of the drawing frame correct.  
	if self.myViewportFrame &lt;&gt; null and self.myViewportFrame.isKindOf(Frame) then
		theFrame := self.myViewportFrame.parent.Frame;
	else
		theFrame := self.myViewportFrame;
	endif;
	
	
	self.myDrawingFrame.left := -theFrame.left - self.getScrollOffsetSize();
	self.myDrawingFrame.top := -theFrame.top - self.getScrollOffsetSize();
	self.myDrawingFrame.width := theFrame.width + self.getScrollOffsetSize()*2 + theFrame.left;
	self.myDrawingFrame.height := theFrame.height + self.getScrollOffsetSize()*2 + theFrame.top;
	
	self.myTIFrame.left := -theFrame.left - self.getScrollOffsetSize();
	self.myTIFrame.top := -theFrame.top - self.getScrollOffsetSize();
	self.myTIFrame.width := theFrame.width + self.getScrollOffsetSize() * 2 + theFrame.left;
	self.myTIFrame.height := theFrame.height + self.getScrollOffsetSize() * 2 + theFrame.top;
	
	//05/11/2010 cnwdz2 par26196
	self.rePositionHVLabelFrames(theFrame);
	
	self.leftStartOffset := -theFrame.left - self.getScrollOffsetSize();
	self.topStartOffset := -theFrame.top - self.getScrollOffsetSize();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resizeTIFrame" id="53e0117f-c9e8-4a11-b1c2-1b4cb7c87b74">
        <source>resizeTIFrame();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwjk3	Initial creation

*/

vars

begin
	self.myTIFrame.left := self.myDrawingFrame.left;
	self.myTIFrame.top := self.myDrawingFrame.top;
	self.myTIFrame.width := self.myDrawingFrame.width;
	self.myTIFrame.height := self.myDrawingFrame.height;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="scrollDown" id="fb514730-3d36-438f-8203-024e55a04a49">
        <updating/>
        <source>scrollDown() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 Apr 2010	cnwjk3	Initial creation
12 Jul 2010 cnwer1	Par 24901 at smaller scaleFactor need to increase the number of rows that are incremented
*/

vars
	prevScrollOffset : Integer;
	scrollByNumRows : Integer;
begin
	
	//self.debugRows( "-------- " &amp; method.name &amp; " Before Rows ------- " );
	
	// New
	if self.myDrawingFrame.top &lt; self.topStartOffset then
		// We need to adjust the top offset to maintain the buffer around the viewport
		self.myDrawingFrame.top := self.myDrawingFrame.top + self.vScrollAmount;
		self.myTIFrame.top := self.myTIFrame.top + self.vScrollAmount;
		//24/09/2010 cnwdz2 25642
		if self.myLeftVLabelsFrame &lt;&gt; null then
			self.myLeftVLabelsFrame.top := self.myLeftVLabelsFrame.top + self.vScrollAmount;
		endif;
		if self.myDrawingFrame.top &gt; self.topStartOffset then
			self.myDrawingFrame.top := self.topStartOffset;
			self.myTIFrame.top := self.topStartOffset;
			//24/09/2010 cnwdz2 25642
			if self.myLeftVLabelsFrame &lt;&gt; null then
				self.myLeftVLabelsFrame.top := self.topStartOffset;
			endif;
		endif;
	endif;
	//
	
	if self.flipV and self.vScrollOffset = 0 then
		if self.topGridRow &gt;=  self.maxGridRow then
			// New
			self.scrollDrawingFramesDown();
			//
			return;
		endif;	
	elseif self.vScrollOffset = 0 then
		if self.topGridRow = 1 then
			// New
			self.scrollDrawingFramesDown();
			//
			return;
		endif;	
	endif;
	
	if self.topOffset &gt; 0 then
		return;
	endif;
	
	
	if self.bottomOffset &gt; 0 then
		self.bottomOffset := (self.bottomOffset - self.vScrollAmount).Integer;
		if self.bottomOffset &lt; 0 then
			self.bottomOffset := 0;
		endif;
	else
		prevScrollOffset := self.vScrollOffset;		
		self.vScrollOffset := (self.vScrollOffset + self.vScrollAmount).Integer;		
		
		if self.vScrollOffset.abs() &gt; self.getGridHeight()-1 then
			scrollByNumRows:=(self.vScrollOffset.abs()/self.getGridHeight()).Integer.max(1);
			self.vScrollOffset := 0;
			if self.flipV then
				if self.topGridRow = self.maxGridRow then			
					self.vScrollOffset := prevScrollOffset;
					// New
					self.scrollDrawingFramesDown();
					//
				else
					self.topGridRow := self.topGridRow  + scrollByNumRows;
				
				
					// Only adjust bottom column if it doesn't fit on screen anymore
					if not self.canBottomRowFitOnScreen(self.bottomGridRow) then
						self.bottomGridRow := self.bottomGridRow + scrollByNumRows;
					endif;

				
				endif;
			else
				if self.topGridRow = 1 or self.bottomGridRow = 1 then 
					self.vScrollOffset := prevScrollOffset;
					// New
					self.scrollDrawingFramesDown();
					//
				else
		
					self.topGridRow := self.topGridRow - scrollByNumRows;
			
					// Only adjust bottom row if it doesn't fit on screen anymore
					if not self.canBottomRowFitOnScreen(self.bottomGridRow) then
						self.bottomGridRow := self.bottomGridRow - scrollByNumRows;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	self.calcViewSizes();
	self.reCalcRowsCols();
	self.calcDrawRows();
	self.drawEverything();
	
	
	//self.debugRows( "-------- " &amp; method.name &amp; " After Rows ------- " );
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="scrollDown_new" id="6f01ce45-5ede-4d69-8c85-00389d466426">
        <updating/>
        <source>scrollDown_new() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 Sep 2010	cnwdz2	Initial creation 25641
*/

vars
	prevScrollOffset,
	frameHeight,
	drawingHeight,
	scrollByNumRows : Integer;
	
	viewFrameHeight,
	labelOffset,
	yStart,
	gridHeightPixels,
	drawingFrameTop,
	spareSpaceAtTop,
	scrollAmount		: Real;
begin
	
	//self.debugRows( "-------- " &amp; method.name &amp; " Before Rows ------- " );
	
	gridHeightPixels := self.getGridHeight();
	frameHeight := self.myDrawingFrame.clientHeight();
	drawingFrameTop := self.myDrawingFrame.top;
	
	if self.myTopHLabelsFrame &lt;&gt; null then
		labelOffset := self.myTopHLabelsFrame.top + self.myTopHLabelsFrame.height;
	endif;
	
	if self.flipV then
		yStart := drawingFrameTop + self.yDrawEnd;
	else				
		yStart := drawingFrameTop + self.yDrawStart;
	endif;

	if yStart &gt;= labelOffset then
		return;
	endif;
	
	if labelOffset &gt; 0 then
		if yStart &gt;= 0 and yStart &lt; labelOffset then
			scrollAmount := labelOffset - yStart;
		elseif self.vScrollAmount - yStart.abs() &gt; labelOffset then
			scrollAmount := yStart + labelOffset;
		else
			scrollAmount := self.vScrollAmount;
		endif;
	elseif labelOffset = 0 then
		if yStart.abs() &lt; self.vScrollAmount then
			scrollAmount := yStart.abs();
		else
			scrollAmount := self.vScrollAmount;
		endif;
	endif;
	
	self.myDrawingFrame.top := drawingFrameTop + scrollAmount;
	self.myTIFrame.top := self.myTIFrame.top + scrollAmount;
	//24/09/2010 cnwdz2 25642
	if self.myLeftVLabelsFrame &lt;&gt; null then
		self.myLeftVLabelsFrame.top := self.myLeftVLabelsFrame.top + scrollAmount;
	endif;
	
	if self.myRightVLabelsFrame &lt;&gt; null then
		self.myRightVLabelsFrame.top := self.myRightVLabelsFrame.top + scrollAmount;
	endif;

	//self.debugRows( "-------- " &amp; method.name &amp; " After Rows ------- " );
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="scrollDrawingFramesDown" id="e6268413-2d32-47ab-a684-9aa0bec2e478">
        <source>scrollDrawingFramesDown() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2010	cnwjk3	Initial creation

*/

vars
	topMin : Real;
begin
	//29/09/2010 cnwdz2 25641
	if self.myTopHLabelsFrame &lt;&gt; null then
		topMin := self.myTopHLabelsFrame.top + self.myTopHLabelsFrame.height;
	else
		topMin := self.myViewportFrame.top;
	endif;
	
	if self.myDrawingFrame.top &lt; topMin then
		self.myDrawingFrame.top := 	self.myDrawingFrame.top + self.vScrollAmount;
		self.myTIFrame.top := 	self.myTIFrame.top + self.vScrollAmount;
		//24/09/2010 cnwdz2 25642
		if self.myLeftVLabelsFrame &lt;&gt; null then
			self.myLeftVLabelsFrame.top := self.myLeftVLabelsFrame.top + self.vScrollAmount;
		endif;
		if self.myDrawingFrame.top &gt;= topMin then
			//24/09/2010 cnwdz2 25642
			self.myDrawingFrame.top := topMin;
		
			self.myTIFrame.top := topMin;
			if self.myLeftVLabelsFrame &lt;&gt; null then
				self.myLeftVLabelsFrame.top := topMin;
			endif;
		endif;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="scrollDrawingFramesLeft" id="cbd42bf8-9bdb-4721-a10b-25fee28ab20c">
        <source>scrollDrawingFramesLeft() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2010	cnwjk3	Initial creation

*/

vars
	leftMax : Real;
begin
	leftMax := -self.getScrollOffsetSize() * 2 - self.myViewportFrame.left;
	if self.myDrawingFrame.left &gt;  leftMax  then
		self.myDrawingFrame.left := self.myDrawingFrame.left - self.hScrollAmount;
		self.myTIFrame.left := 	self.myTIFrame.left - self.hScrollAmount;
		//24/09/2010 cnwdz2 25642
		if self.myTopHLabelsFrame &lt;&gt; null then
			self.myTopHLabelsFrame.left := self.myTopHLabelsFrame.left - self.hScrollAmount;
		endif;
		/*
		if self.myDrawingFrame.left &gt; leftMax then
			self.myDrawingFrame.left := leftMax;
			self.myTIFrame.left := self.myDrawingFrame.left;
			//24/09/2010 cnwdz2 25642
			if self.myHLabelsFrame &lt;&gt; null then
				self.myHLabelsFrame.left := self.myDrawingFrame.left;
			endif;
		endif;
		*/
		
		
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
