<Class name="CM_SourceSubLocation">
    <JadeMethod name="loadTreeViewArray" id="68108c74-def8-4c5b-8f80-97ee0f8bd458">
        <source>loadTreeViewArray(_collection: Collection input; _level: Integer; _form : CMUI_CodesMaintTree; _parent : SOP_ViewModelObject);
// -----------------------------------------------------------------------------
// Created:		08 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	iter : Iterator;
	subLocation : CM_SourceSubSubLocation;
	obj  : SOPVM_SourceSubLocation;
	includeNotAvail : Boolean;	//	//21 Jun 2013	NDL	Par 31770
begin
	create obj transient;
	
	obj.initializeMe(self, _level, _parent);
	obj.myForm := _form;
	_collection.add(obj);
	
	includeNotAvail := _form.chkInclNotAvail.visible and _form.chkInclNotAvail.value;	//21 Jun 2013	NDL	Par 31770
	
	iter := self.allSubSubLocations.createIterator();
	while iter.next(subLocation) do
		if includeNotAvail or not subLocation.notAvailableForEntry then	//21 Jun 2013	NDL	Par 31770
			subLocation.loadTreeViewArray(_collection, _level +1, _form, obj);
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_form" type="CMUI_CodesMaintTree"/>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="replaceDummyInTreeViewArray" id="7959a6e5-04b5-4eec-b8b9-783691aa51d8">
        <source>replaceDummyInTreeViewArray(_collection: Collection input; _level: Integer; _form: CMUI_CodesMaintTree; _parent: SOP_ViewModelObject; _insertIndex : Integer io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2013	cnwndl1	Initial creation	Par 31770

*/

vars
	iter : Iterator;
	subSubLocation : CM_SourceSubSubLocation;
	obj  : SOPVM_SourceSubLocation;
	includeNotAvail : Boolean;
begin
	create obj transient;
	
	obj.initializeMe(self, _level, _parent);
	obj.myForm := _form;
	_collection.ViewModelObjectArray.insert(_insertIndex,obj);
	
	_form.lstData.addItemAt(obj.displayEntryListbox, _insertIndex);
	_form.lstData.itemLevel[_insertIndex] := _level;
	_form.lstData.itemExpanded[_insertIndex] := obj.expanded;
	_form.lstData.itemObject[_insertIndex] := obj;
	
	_insertIndex := _insertIndex + 1;
	
	includeNotAvail := _form.chkInclNotAvail.visible and _form.chkInclNotAvail.value;	
	
	iter := self.allSubSubLocations.createIterator();
	while iter.next(subSubLocation) do
		if includeNotAvail or not subSubLocation.notAvailableForEntry then
			subSubLocation.replaceDummyInTreeViewArray(_collection, _level +1, _form, obj, _insertIndex);
		endif;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_form" type="CMUI_CodesMaintTree"/>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
        <Parameter name="_insertIndex" type="Integer" usage="io"/>
    </JadeMethod>
</Class>
