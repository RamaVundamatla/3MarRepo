//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
// 10/03/2022	navdap1		TFS 52746 PNL Custom Hold Clearance for Export Units using BOL with TSW EDI
//
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	//app.myUtilityUA.utlUpdateTSWWebService(_tswWebService, _passport);								// TFS 52746
	app.myUtilityUA.utlUpdateTSWWebService(_tswWebService, _cmifConfig, _expectedEdition, _passport);	// TFS 52746

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
