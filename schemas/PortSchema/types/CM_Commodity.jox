    <JadeMethod name="getTotalTIQty" id="f7a4b0f3-7d70-4c14-b1b8-33d2c52bc0f3">
        <source>getTotalTIQty(_tiSet : CM_TISet) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation

*/

vars
	total : Integer;
	ti : CM_TrackedItem;
	
begin
	foreach ti in _tiSet do
		total := total + ti.totalQuantity;
	endforeach;
	
	return total;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalTIVolume" id="c40a6cdd-aefa-4e76-bc37-fc2d81a0defa">
        <source>getTotalTIVolume(_tiSet : CM_TISet) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation

*/

vars
	totalVolume	: Real;
	ti			: CM_TrackedItem;
	
begin
	
	foreach ti in _tiSet do
		totalVolume := totalVolume + ti.getMyTotalVolume;
	endforeach;
	
	return totalVolume;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalTiWeight" id="77f732ae-e8f3-493a-8ba3-c186bf27f70b">
        <source>getTotalTiWeight(_tiSet : CM_TISet) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation

*/

vars
	totalWeight	: Real;
	ti			: CM_TrackedItem;
	
begin
	
	foreach ti in _tiSet do
		totalWeight := totalWeight + ti.totalWeight;
	endforeach;
	
	return totalWeight;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <ReturnType type="Real"/>
    </JadeMethod>
