    <JadeMethod name="doSave" id="1e1ab091-23cf-46de-854b-9dcb522335fb">
        <source>doSave() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2016	cnwrh7	Initial creation

*/

vars
	pxyTCPConnection,
	realTCPConnection			:	CM_DeviceTCPConnectionDetails;
	tcpAddress							:	String;
	tcpPortNumb,
	tcpTimeout,
	tcpDeviceType					:	Integer;
	usePresentationClient	:	Boolean;
	
begin
	// 5 attribute fields
	tcpAddress := self.txtTCPAddr.text;
	tcpPortNumb := self.txtTCPPortNum.text.Integer;
	tcpTimeout := self.txtTimeout.text.Integer;
	if self.cmbTCPDeviceType.listIndex &lt;&gt; -1 then
		tcpDeviceType := self.myAssistant.getTCPDeviceTypeFromDesc(cmbTCPDeviceType.itemText[self.cmbTCPDeviceType.listIndex].String);
	endif;
	usePresentationClient := self.chkUsePresentation.value;
	
	create pxyTCPConnection transient;
	pxyTCPConnection.setProxy (tcpAddress,
																tcpPortNumb,
																tcpTimeout,
																tcpDeviceType,
																usePresentationClient
																);
	
	if self.myDevice.myTCPConnectionDetails = null then
		app.myTrxCA.trxCreateTCPConnectionDetails(pxyTCPConnection, realTCPConnection,self.myDevice, app.myPassport);
	else
		app.myTrxUA.trxUpdateTCPConnectionDetails(pxyTCPConnection, self.myDevice.myTCPConnectionDetails, app.myPassport);
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadTCPDetails" id="8c3dad06-7224-4329-b697-22f3e35c59f9">
        <source>loadTCPDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwrh7	Initial creation

*/

vars
		tcpConnDetails : CM_DeviceTCPConnectionDetails;
		indx : Integer;
begin
		tcpConnDetails := self.myDevice.myTCPConnectionDetails;
		if tcpConnDetails = null then
			return;
		endif;
		
		//the text fields
		self.txtTCPAddr.text := tcpConnDetails.tcpAddress;
		self.txtTCPPortNum.text := tcpConnDetails.tcpPortNumber.String;
		self.txtTimeout.text := tcpConnDetails.tcpTimeOut.String;
		self.chkUsePresentation.value := tcpConnDetails.useTCPPresentationClient.Boolean;
		
		// the Device Type Combo Box
		indx := self.cmbTCPDeviceType.findStringExact (1, self.myAssistant.getTCPDeviceTypeDesc(tcpConnDetails.tcpDeviceType));
		if indx &lt;&gt; -1 then
			self.cmbTCPDeviceType.listIndex := indx;
		endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyDevice" id="d606d503-aa58-4a03-9b34-9f81508abd59">
        <updating/>
        <source>setMyDevice(_device : CM_RadioTelemetryDevice input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwrh7	Initial creation

*/
vars

begin

	if self.myDevice &lt;&gt; _device then
		self.myDevice:=_device;
	endif;
epilog

end;</source>
        <Parameter name="_device" type="CM_RadioTelemetryDevice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5f3e3093-e2ce-4728-a912-5db422b46189">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 August 2016	cnwrh7	Initial creation

*/

vars

begin
	inheritMethod();
	if self.myDevice = null then
		self.unloadForm;
	endif;
	
	self.grpDetails.left := (self.clientWidth/2)-(self.grpDetails.width/2);
	self.grpDetails.top := 10;
	
	self.caption:="TCP Connection details";
	self.lblDeviceName.caption:=self.myDevice.id;
	
	self.myAssistant.comboTCPDeviceType (self.cmbTCPDeviceType);
	
	if self.myDevice.myTCPConnectionDetails &lt;&gt; null then		//loading TCP content
			loadTCPDetails();
	endif;
	
	self.txtTCPAddr.setFocus;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e58b58f3-bdfa-44ac-b17e-100d0e0b5996">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 October 2016 09:00:52.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021368, locale);
	lblDevice.translateCaption(Xlat_0021369, locale);
	lblDeviceType.translateCaption(Xlat_0021370, locale);
	lblTCPAddr.translateCaption(Xlat_0021371, locale);
	lblTCPPortNum.translateCaption(Xlat_0021372, locale);
	lblTimeOut.translateCaption(Xlat_0021373, locale);
	lblUsePresentation.translateCaption(Xlat_0021374, locale);
end;</source>
    </JadeMethod>
</GUIClass>
