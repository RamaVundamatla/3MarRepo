    <JadeMethod name="getTIs" id="675e9942-297c-4290-a3ce-a2df7504b106">
        <source>getTIs(tis: CM_TIArray input; _mode : Integer);
// ---------------------------------------------------------------------------
// Created:    June 2001 By Andrew Bishop cnwab1
//
// Purpose:     Add all of the TI's in this Terminal Area to the TIArray passed in.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lc : CM_GridController;
	ti : CM_TrackedItem;
begin
	inheritMethod(tis, _mode);
	foreach lc in self.allGridControllersByRowColumn do
		if lc.numTIs &gt; 0 then
			foreach ti in lc.allTrackedItems do
				if not tis.includes(ti) then	//40' are in 2 positions
					tis.add(ti);
				endif;
			endforeach;
		endif;
	endforeach;
end;</source>
        <Parameter name="tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
