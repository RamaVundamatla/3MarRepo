    <JadeMethod name="getCargoSubTypeId" id="713922d3-dfe8-4e11-a7cd-75584b5ff3b1">
        <source>getCargoSubTypeId() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 12th June 2024

*/

vars

begin
