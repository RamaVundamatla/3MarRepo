    <JadeMethod name="pxyCreateUpdateProxy" id="14ae13f8-e121-4f8d-8ce4-d4bb59179fd6">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/12/2016	cnwdap1		Initial creation TFS 3039 SNO Empty Container Pool Management
// 10/05/2017	cnwdap1		TFS 4370 Allow pooling parties acroos multiple terminals
//
vars
	proxyPoolParty : CM_MTPoolingParty;
	poolPartner, pxyPoolPartner : CM_MTPoolingPartner;
	opTerm, pxyOpTerm : CM_OperatorTerminal;
	completedOK : Boolean;
	
begin
	proxyPoolParty := inheritMethod();

	// RJS - need to add other references here, including collections
	
	foreach poolPartner in self.allPoolingPartners do
		create pxyPoolPartner transient;
		//pxyPoolPartner.setProxy(poolPartner.myOperator, poolPartner.percentageOfCharges);								// TFS 4370
		pxyPoolPartner.setProxy(poolPartner.myOperator, poolPartner.myTerminal, poolPartner.percentageOfCharges);		// TFS 4370
		pxyPoolPartner.setMyPoolingParty(proxyPoolParty);
	endforeach;
	
	foreach opTerm in self.allOperatorTerminals do
		pxyOpTerm := opTerm.pxyCreateUpdateProxy();
		pxyOpTerm.setMyTerminal(opTerm.myTerminal);
		pxyOpTerm.setMyOperator(opTerm.myOperator);
		pxyOpTerm.setMyPoolingParty(proxyPoolParty);
	endforeach;
	
	completedOK := true;
	return proxyPoolParty;
	
epilog
	if not completedOK then	
		delete proxyPoolParty;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6fb48da9-fa70-44a8-ad67-31e1fa95aa56">
        <updating/>
        <source>setForCreate(_proxyPoolParty : CM_MTPoolingParty) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/12/2016	cnwdap1		Initial creation TFS 3039 SNO MT Container Pool Management
//
vars

begin
	self.setForUpdate( _proxyPoolParty );
epilog

end;</source>
        <Parameter name="_proxyPoolParty" type="CM_MTPoolingParty"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e93173c8-8776-427c-a333-74677c9e3a77">
        <updating/>
        <source>setForUpdate(_proxyPoolParty : CM_MTPoolingParty) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/12/2016	cnwdap1		Initial creation TFS 3039 MT Container Pool Management
//
vars
	pxyPoolPartner, realPartner : CM_MTPoolingPartner;

begin
	self.code := _proxyPoolParty.code;
	self.description := _proxyPoolParty.description;
	
	self.myTerminal := _proxyPoolParty.myTerminal;
	
	self.allPoolingPartners.purge;
	foreach pxyPoolPartner in _proxyPoolParty.allPoolingPartners do
		create realPartner persistent;
		realPartner.setForCreate(pxyPoolPartner);
		realPartner.setMyPoolingParty(self);
	endforeach;
epilog

end;</source>
        <Parameter name="_proxyPoolParty" type="CM_MTPoolingParty"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="f23506c9-793b-4102-abf9-cb48f2c98a55">
        <updating/>
        <source>setProxy(	_code : String;
			_description : String;
			_terminal : CM_Terminal;
			_poolingPartners : CM_MTPoolingPartnerByOperator	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/12/2016	cnwdap1		Initial creation TFS 3039 SNO MT Container Pool Management
//
vars
	partner : CM_MTPoolingPartner;

begin
	self.code := _code;
	self.description := _description;
	
	self.myTerminal := _terminal;
	
	foreach partner in self.allPoolingPartners where not _poolingPartners.includes(partner) do
		delete partner;
	endforeach;
	foreach partner in _poolingPartners do
		if partner.myPoolingParty &lt;&gt; self then
			partner.setMyPoolingParty(self);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_poolingPartners" type="CM_MTPoolingPartnerByOperator"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="78c55875-8638-4afe-813b-bbee69d923c1">
        <source>validateForCreate();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/12/2016	cnwdap1		Initial creation TFS 3039 SNO MT Container Pool Management
//
vars

begin
	if self.myTerminal.allMTPoolingParties.getAtKey( self.code ) &lt;&gt; null then
		app.raiseCMException1(Pool_Party_Already_Exists, self.code, null, null);
		return;
	endif; 

	self.validateMe();
epilog

end;</source>
    </JadeMethod>
