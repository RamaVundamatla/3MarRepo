    <JadeMethod name="loadDataForFirstTime" id="699f15e4-b5aa-40c9-b1d4-537dccdba476">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//
//19 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
//
vars
	showCaptions : Boolean;
begin
	if self.frmToolbar.showCaptions then
		showCaptions := self.frmToolbar.showCaptions;
		self.frmToolbar.showCaptions := false;
		self.toolbarShowCaptions(showCaptions);
	endif;
	inheritMethod();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateAgentCombo" id="b9193d70-9333-4811-a7d1-7b47ad95479d">
        <updating/>
        <source>populateAgentCombo() updating, protected;
// populate all consignee/customs agent etc
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------
// 10/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars
	type			: String;
	comboText		: String;
	consignoree		: CM_ConsigneeConsignor;
	customsAgent	: CM_CustomsAgent;
	stevedore		: CM_Stevedore;					// TFS 44554
	passport		: CM_Passport;
	failedDAC  		: CM_DataAccessController;
begin
	self.cmbAgent.clear();
	if self.myAgentType = null then
		return;
	endif;

	passport := app.myPassport;
	type := self.myAgentType.code;
	
	if type = CM_DebtorType.DT_CUSTOMS_AGENT then
		foreach customsAgent in app.myRoot.allCustomsAgents do
			if not customsAgent.canUserAccessSelf(null, failedDAC, passport) or customsAgent.isNotAvailableForEntry then
				continue;
			endif;

			comboText := self.getAgentDescription(customsAgent);
			self.cmbAgent.itemObject[self.cmbAgent.addItem(comboText)] := customsAgent;
		endforeach;
		
	// TFS 44554
	elseif type = CM_DebtorType.DT_STEVEDORE_VOYAGE then  //04.11.2020 cnwma1 TFS #50112
		foreach stevedore in app.myRoot.allStevedores discreteLock do
			if not stevedore.canUserAccessSelf(null, failedDAC, passport) or stevedore.notAvailableForEntry then
				continue;
			endif;
			
			comboText := self.getAgentDescription(stevedore);
			self.cmbAgent.itemObject[self.cmbAgent.addItem(comboText)] := stevedore;
		endforeach;
	// TFS 44554
	
	else
		foreach consignoree in app.myRoot.allConsigneeConsignors do
			if not consignoree.canUserAccessSelf(null, failedDAC, passport) or consignoree.isNotAvailableForEntry then
				continue;
			endif;

			if type = CM_DebtorType.DT_FREIGHT_FORWARDER and not consignoree.isFreightFwdr then
				continue;
			elseif type = CM_DebtorType.DT_CONSIGNEE and not consignoree.isConsignee then
				continue;
			elseif type = CM_DebtorType.DT_CONSIGNOR and not consignoree.isConsignor then
				continue;
			endif;

			comboText := self.getAgentDescription(consignoree);
			self.cmbAgent.itemObject[self.cmbAgent.addItem(comboText)] := consignoree;
		endforeach;
	endif;

	// select and populate the first entry
	if self.cmbAgent.listCount &gt; 0 then
		self.cmbAgent.listIndex := 1;
		self.cmbAgent_click(self.cmbAgent);
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateAgentTable" id="fbfbe50a-63ab-42c5-a6ee-10d7f27a2351">
        <updating/>
        <source>populateAgentTable(_object : CM_Object) updating, protected;
// populate the table with the current agent and debtor details
// Changed On	By 			Reason
// ----------	--------	-------------------------------------------------------
// 10/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars
	addressRow		: Integer;
	consigneeor 	: CM_ConsigneeConsignor;
	customsAgent	: CM_CustomsAgent;
	stevedore		: CM_Stevedore;					// TFS 44554
	debtor			: CM_Debtor;
	table			: CM_EntryTable;

begin

	if _object = null then
		return;
	endif;
	self.btnChangeDebtor.enabled := false;
	table := self.tblAgents;
	table.clearValues;

	if _object.isKindOf(CM_ConsigneeConsignor) then
		consigneeor := _object.CM_ConsigneeConsignor;
		debtor := consigneeor.debtor;
		table.setValueByName(ETRow_Code, consigneeor.code);
		table.setValueByName(ETRow_Description,	consigneeor.description);
		table.setValueByName(ETRow_IsConsignor, consigneeor.isConsignor);
		table.setValueByName(ETRow_IsConsignee, consigneeor.isConsignee);
		table.setValueByName(ETRow_IsFreightFwdr, consigneeor.isFreightFwdr);
		
	// TFS 44554
	elseif _object.isKindOf(CM_Stevedore) then
		stevedore := _object.CM_Stevedore;
		debtor := stevedore.myDebtor;
		table.setValueByName(ETRow_StevedoreCode, stevedore.code);
		table.setValueByName(ETRow_Description,	stevedore.description);
	// TFS 44554

	elseif _object.isKindOf(CM_CustomsAgent) then
		customsAgent := _object.CM_CustomsAgent;
		debtor := customsAgent.myDebtor;
		table.setValueByName(ETRow_CustomsAgentCode, customsAgent.code);
		table.setValueByName(ETRow_Description,	customsAgent.name);
	endif;
	
	if debtor &lt;&gt; null then
		table.setValueByName(ETRow_Debtor, debtor.name);
		table.setValueByName(ETRow_Address, debtor.getBillingAddressString());
		table.setValueByName(ETRow_IsCashOnly, debtor.isCashOnlyDebtorAllTerminals());
    endif;
	// set the address row height for easier multi-line entry
	addressRow := table.getRow(ETRow_Address);
	if table.rowHeight[addressRow] &lt; 70 then
		table.rowHeight[addressRow] := 70;
	endif;
	table.adjustHeight(self.clientHeight);	
	table.userInputEnabled := false;

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="populateAgentTypeCombo" id="6ea6d835-2cb2-438a-8c2a-a8c141b653a9">
        <updating/>
        <source>populateAgentTypeCombo() updating, protected;
// consignee, consignor etc
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------
// 10/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars
	debtorType	: CM_DebtorType;
begin

	self.cmbAgentType.clear();
	debtorType := app.myRoot.allDebtorTypes[CM_DebtorType.DT_CONSIGNEE];
	self.cmbAgentType.itemObject[self.cmbAgentType.addItem(debtorType.description)] := debtorType;
	debtorType := app.myRoot.allDebtorTypes[CM_DebtorType.DT_CONSIGNOR];
	self.cmbAgentType.itemObject[self.cmbAgentType.addItem(debtorType.description)] := debtorType;
	debtorType := app.myRoot.allDebtorTypes[CM_DebtorType.DT_CUSTOMS_AGENT];
	self.cmbAgentType.itemObject[self.cmbAgentType.addItem(debtorType.description)] := debtorType;
	debtorType := app.myRoot.allDebtorTypes[CM_DebtorType.DT_FREIGHT_FORWARDER];
	self.cmbAgentType.itemObject[self.cmbAgentType.addItem(debtorType.description)] := debtorType;
	debtorType := app.myRoot.allDebtorTypes[CM_DebtorType.DT_STEVEDORE_VOYAGE];							// TFS 44554 //04.11.2020 cnwma1 TFS #50112
	self.cmbAgentType.itemObject[self.cmbAgentType.addItem(debtorType.description)] := debtorType;		// TFS 44554

	if self.savedAgentDesc &lt;&gt; null then
		self.cmbAgentType.listIndex := self.cmbAgentType.findStringExact(1, self.savedAgentDesc);
	endif;
	if self.cmbAgentType.listIndex &lt; 1 then
		self.cmbAgentType.listIndex := 1;
	endif;

	self.cmbAgentType_click(self.cmbAgentType);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupAgentTable" id="e1fba01b-9069-434c-ae65-46daf7f09c24">
        <updating/>
        <source>setupAgentTable() updating, protected;
// show/hide consignee-specific rows based on agent type.  
//	A different 'code' row is used for customs agents (max length 10) and consignees (max length 5)
//	The cash-only row is only shown if the cash module is licensed.
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars
	table	: CM_EntryTable;
begin
	table := self.tblAgents;
	table.hideRowByName(ETRow_MyDebtor, false);
	
	if self.myAgentType.code = CM_DebtorType.DT_CUSTOMS_AGENT then
		table.hideRowByName(ETRow_Code, false);
		table.hideRowByName(ETRow_StevedoreCode, false);				// TFS 44554
		table.showRowByName(ETRow_CustomsAgentCode, false);
		table.hideRowByName(ETRow_IsConsignor, false);
		table.hideRowByName(ETRow_IsConsignee, false);
		table.hideRowByName(ETRow_IsFreightFwdr, false);
	
	elseif self.myAgentType.code = CM_DebtorType.DT_STEVEDORE_VOYAGE then		// TFS 44554 //04.11.2020 cnwma1 TFS #50112
		table.showRowByName(ETRow_StevedoreCode, false);				// TFS 44554
		table.hideRowByName(ETRow_Code, false);							// TFS 44554
		table.hideRowByName(ETRow_CustomsAgentCode, false);				// TFS 44554
		table.hideRowByName(ETRow_IsConsignor, false);					// TFS 44554
		table.hideRowByName(ETRow_IsConsignee, false);					// TFS 44554
		table.hideRowByName(ETRow_IsFreightFwdr, false);				// TFS 44554
	
	else
		table.showRowByName(ETRow_Code, false);
		table.hideRowByName(ETRow_CustomsAgentCode, false);
		table.hideRowByName(ETRow_StevedoreCode, false);				// TFS 44554
		table.showRowByName(ETRow_IsConsignor, false);
		table.showRowByName(ETRow_IsConsignee, false);
		table.showRowByName(ETRow_IsFreightFwdr, false);
	endif;
	if not app.isCashOnlyEnabled then
		table.hideRowByName(ETRow_IsCashOnly, false);
	endif;
	self.txtAgent.text := "";
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0d35ed2b-8997-45fd-b107-34690888707c">
        <updating/>
        <source>setupForm() updating;
// form initialisation
vars

begin
	inheritMethod();
	
	if self.myAssistant = null then
		create self.myAssistant transient;
	endif;
	self.addToolbarControls();
	self.initAgentTable();
	self.populateAgentTypeCombo();
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNew.enabled:= false;
		self.btnEdit.enabled:= false;
		self.btnDelete.enabled:= false;
		
		
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="6a2a954a-fb94-4970-8fdd-41fdf30b38b2">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
//19 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
//
vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	self.btnAgentSearch.top := self.btnAgentSearch.top + heightDiff;
	self.txtAgent.top := self.txtAgent.top + heightDiff;
	self.btnResetSearch.top := self.btnResetSearch.top + heightDiff;
	self.cmbAgent.top := self.cmbAgent.top + heightDiff;
	self.lblAgent.top := self.lblAgent.top + heightDiff;
	self.cmbAgentType.top := self.cmbAgentType.top + heightDiff;
	self.lblAgentType.top := self.lblAgentType.top + heightDiff;
	self.tblAgents.top := self.tblAgents.top + heightDiff;
	self.tblAgents.height := self.tblAgents.height - heightDiff;
	self.height := self.height + heightDiff;
	self.doResize();
end;

</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="84ffc860-4eaf-4a05-a9c0-fbb0db3b1756">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 March 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019514, locale);
	btnAgentSearch.translateBubbleHelp(Xlat_0019584, locale);
	btnChangeDebtor.translateBubbleHelp(Xlat_0019516, locale);
	btnChangeDebtor.translateCaption(Xlat_0019517, locale);
	btnClose.translateCaption(Xlat_0019515, locale);
	btnDelete.translateBubbleHelp(Xlat_0019518, locale);
	btnDelete.translateCaption(Xlat_0019519, locale);
	btnEdit.translateBubbleHelp(Xlat_0019520, locale);
	btnEdit.translateCaption(Xlat_0019521, locale);
	btnNew.translateBubbleHelp(Xlat_0019522, locale);
	btnNew.translateCaption(Xlat_0019523, locale);
	btnResetSearch.translateBubbleHelp(Xlat_0019585, locale);
	lblAgent.translateCaption(Xlat_0019524, locale);
	lblAgentType.translateCaption(Xlat_0019525, locale);
	tblAgents.translateBubbleHelp(Xlat_0019530, locale);
end;</source>
    </JadeMethod>
</GUIClass>
