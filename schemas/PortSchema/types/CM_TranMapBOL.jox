    <JadeMethod name="validateInvLineDescUsedTranMap" id="a04cfa1d-0b69-499d-8b87-45ed0c597f28">
        <source>validateInvLineDescUsedTranMap(_invLineDesc: CM_InvoiceLineDesc): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation

*/

vars

	bolSB : CM_BOLServiceBroker;
	
begin

	foreach bolSB in self.allBOLServiceBrokers discreteLock do
		if bolSB.validateInvLineDescUsedTranMap(_invLineDesc) then
			return true;
		endif;
	endforeach;
	
	return false;
	
end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
