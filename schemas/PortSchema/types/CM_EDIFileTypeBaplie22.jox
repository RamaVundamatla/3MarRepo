<Class name="CM_EDIFileTypeBaplie22" id="30f1fa01-62d0-48ff-9b81-d0a59aa7d3d6">
    <superclass name="CM_EDIFileTypeBaplie"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="buildFTXForVGM" id="ada2c349-5c27-4d5c-904f-b10247bd7817">
        <source>buildFTXForVGM(_ediTI : CM_EDIBayPlanTI) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 05/07/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
// 03/07/2018	jlgrh7 TFS39259 PNL - Apostrophe in weight certified field cause baplie to fail
// 04/09/2018	jlgka1 TFS 40546	Change "+" with ":" after the docs issued date in FTX+AAY in vgmCommsType.   
// 09/09/2022	navkc1 Bug 54633: SNO - Issue with BAPLIE 2.2 VGM Output - Replace ";" with ",". Calling escapeEDIInvalidChars
vars
	str, substr : String;
	refStr, nameStr : String;

begin
	if _ediTI.weightCertifiedReference &lt;&gt; null or _ediTI.weightCertifiedName &lt;&gt; null then	
		// if we have a weigh authority send the certified reference and person
		if app.myRoot.allWeighAuthorities[_ediTI.weightCertifiedReference, _ediTI.weightCertifiedName] &lt;&gt; null then				
			//str := str &amp; "FTX+AAY++SHP+" &amp; _ediTI.weightCertifiedReference &amp; ":" &amp; _ediTI.weightCertifiedName &amp; "'" &amp; CrLf;								//-TFS39259																																
			str := str &amp; "FTX+AAY++SHP+" &amp; _ediTI.weightCertifiedReference .escapeEDIInvalidChars(":","+","?") &amp;  ":" &amp; _ediTI.weightCertifiedName .escapeEDIInvalidChars(":","+","?");	//+TFS39259;
			str := str.replaceString("'","?'")&amp;  "'" &amp; CrLf;	
			
		else
			// if we have a weight certified name or reference, send them
			if _ediTI.weightCertifiedReference &lt;&gt; null or _ediTI.weightCertifiedName &lt;&gt; null then
				//str := str &amp; "FTX+AAY++SHP+" &amp; _ediTI.weightCertifiedReference &amp; ":" &amp;_ediTI.weightCertifiedName &amp; "'" &amp; CrLf								//-TFS39259
					str := str &amp; "FTX+AAY++SHP+" &amp; _ediTI.weightCertifiedReference.escapeEDIInvalidChars(":","+","?") &amp; ":" &amp;										//+TFS39259
								_ediTI.weightCertifiedName.escapeEDIInvalidChars(":","+","?")  ;
					str := str.replaceString("'","?'")&amp; "'" &amp; CrLf;
			endif;
		endif;
		
		// if we have any SM1 or SM2 details, send them
		if _ediTI.vgmCommsType.isOneOf("SM1", "SM2") then
			str := str &amp; "FTX+AAY++" &amp; _ediTI.vgmCommsType &amp; "+";
			if _ediTI.vgmDeterminationDT &lt;&gt; null then
				str := str &amp; _ediTI.vgmDeterminationDT.date.shortYearEDI &amp; 
							_ediTI.vgmDeterminationDT.time.shortFormatEDI &amp; ":";  // jlgka1 TFS 40546 04/09/2018
			elseif _ediTI.vgmDocsIssuedDT &lt;&gt; null then
				str := str &amp; _ediTI.vgmDocsIssuedDT.date.shortYearEDI &amp; 
							_ediTI.vgmDocsIssuedDT.time.shortFormatEDI &amp; ":";  // jlgka1 TFS 40546 04/09/2018
			endif;
			refStr := _ediTI.weightCertifiedReference.escapeEDIInvalidChars(":", "+", "?");		// TFS 39259
			refStr := refStr.replaceString("'", "?'");											// TFS 39259
			nameStr := _ediTI.weightCertifiedName.escapeEDIInvalidChars(":", "+", "?");			// TFS 39259
			nameStr := nameStr.replaceString("'", "?'");										// TFS 39259
			//str := str &amp; _ediTI.weightCertifiedReference &amp; ";" &amp; 								// TFS 39259
			//str := str &amp; refStr &amp; ";" &amp; 														// TFS 39259
			str := str &amp; refStr &amp; "," &amp;																// 09/09/2022	navkc1	#54633
						//_ediTI.vgmMail&amp; ";" &amp;														// 09/09/2022	navkc1	#54633
						_ediTI.vgmMail.escapeEDIInvalidChars(":", "+", "?")&amp; "," &amp;					// 09/09/2022	navkc1	#54633
						//_ediTI.vgmPhone &amp; ";" &amp;													// 09/09/2022	navkc1	#54633
						_ediTI.vgmPhone.escapeEDIInvalidChars(":", "+", "?") &amp; "," &amp;				// 09/09/2022	navkc1	#54633
						//_ediTI.vgmElectronicMail &amp; ":" &amp;											// 09/09/2022	navkc1	#54633
						_ediTI.vgmElectronicMail.escapeEDIInvalidChars(":", "+", "?") &amp; ":" &amp;		// 09/09/2022	navkc1	#54633
						//_ediTI.weightCertifiedName &amp; ":" &amp;									// TFS 39259
						nameStr &amp; ":" &amp;															// TFS 39259
						//_ediTI.vgmAuthSignature &amp; ":'" &amp; CrLf;									// 09/09/2022	navkc1	#54633
						_ediTI.vgmAuthSignature.escapeEDIInvalidChars(":", "+", "?") &amp; ":'" &amp; CrLf;	// 09/09/2022	navkc1	#54633
		elseif _ediTI.vgmDocsIssuedDT &lt;&gt; null then
			str := str &amp; "FTX+AAY++DRF+" &amp; _ediTI.vgmDocsIssuedDT.date.shortYearEDI &amp; 
						_ediTI.vgmDocsIssuedDT.time.shortFormatEDI &amp; ":" &amp;
						//_ediTI.vgmMail&amp; ":";													// 09/09/2022	navkc1	#54633
						_ediTI.vgmMail.escapeEDIInvalidChars(":", "+", "?")&amp; ":";				// 09/09/2022	navkc1	#54633
			if _ediTI.vgmTelephone &lt;&gt; null then
				//substr := _ediTI.vgmTelephone;												// 09/09/2022	navkc1	#54633
				substr := _ediTI.vgmTelephone.escapeEDIInvalidChars(":", "+", "?");				// 09/09/2022	navkc1	#54633
			endif;
			if _ediTI.vgmElectronicMail &lt;&gt; null then
				if substr &lt;&gt; null then
					//substr := substr &amp; ";" &amp; _ediTI.vgmElectronicMail;									// 09/09/2022	navkc1	#54633
					substr := substr &amp; "," &amp; _ediTI.vgmElectronicMail.escapeEDIInvalidChars(":", "+", "?");	// 09/09/2022	navkc1	#54633
				else
					//substr := _ediTI.vgmElectronicMail;										// 09/09/2022	navkc1	#54633
					substr := _ediTI.vgmElectronicMail.escapeEDIInvalidChars(":", "+", "?");	// 09/09/2022	navkc1	#54633
				endif;
			endif;
			str := str &amp; substr &amp; ":" &amp;
						//_ediTI.vgmDocumentDetails &amp; "'" &amp; CrLf;										// 09/09/2022	navkc1	#54633
						_ediTI.vgmDocumentDetails.escapeEDIInvalidChars(":", "+", "?") &amp; "'" &amp; CrLf;	// 09/09/2022	navkc1	#54633
		endif;
	endif;
								
	return str;
epilog

end;</source>
        <Parameter name="_ediTI" type="CM_EDIBayPlanTI"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="03a809fa-480b-417c-b529-60f3b4ef6668">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/05/2016	cnwdap1		Initial creation TFS #1881 BAPLIE/EDI VGM Update
//
vars

begin
	self.name	:= "BAPLIE 95B  SMDG 2.2";
	self.type	:= EDIFileType_Baplie22;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="extractFile" id="e284c809-738d-475a-9d89-02fcf489437b">
        <updating/>
        <source>extractFile(_ediFile: CM_EDIFile io; _number: Integer; _recipient: CM_Operator) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/05/2016	cnwdap1		Initial creation TFS #1881 BAPLIE/EDI VGM Updates
// 22/01/2021	jlgdap1		TFS 50553 Handling of Nested Child Cargo in BAPLIE EQA Segment
//
vars
	ediDataBayPlan	: CM_EDIDataBayPlan;
	ediTI			: CM_EDITrackedItem;
	tisByLocation	: CM_EDIBayPlanTIByLocation;
	operatorOid		: CM_Operator;
	voyageOid		: CM_Voyage;
	now				: TimeStamp;
	ediFile			: CM_EDIFile;
	ediData			: CM_EDIData;
	terminal		: CM_Terminal;
	foundMatch		: Boolean;
	str 			: String;

begin
	ediFile 	:= _ediFile;
	ediData		:= ediFile.ediData;
	terminal	:= app.myPassport.myTerminal;

	if (not CM_EDIDataBayPlan.hasInstance(ediData)) then
		app.raiseCMException2(ERR_INVALID_EDI_FORMAT, self.name, ediData.class.name, null, null);
		return;
	endif;

	ediDataBayPlan := ediData.CM_EDIDataBayPlan;
	
	create tisByLocation transient;
	
	foreach ediTI in ediDataBayPlan.allEDITrackedItems do
		// TFS 50553 ignore child flat racks - we'll do these later when we extract their parent
		if ediTI.myParent &lt;&gt; null then
			continue;
		endif;
		// TFS 50553 end
		tisByLocation.add(ediTI.CM_EDIBayPlanTI);
	endforeach;
	
	if _recipient = null then
		operatorOid := app.myRoot.allOperators[ediDataBayPlan.operatorCode];
	else
		operatorOid := _recipient;
	endif;
	
	voyageOid := terminal.lookupVoyage(ediDataBayPlan.voyageCode, null, false);
	
	// to comply with v6 behaviour - no xlation on our port
	str := str &amp; "UNB+UNOA:2+" &amp; ediDataBayPlan.fromPort.toUpper &amp; "+" &amp; ediDataBayPlan.shipperCode.trimBlanks.toUpper &amp; "+" &amp; now.date.shortYearEDI() &amp; ":" &amp; now.time.format("HHmm") &amp; "+" &amp; _number.String &amp; "+++++" &amp; ediDataBayPlan.shipperCode.trimBlanks.toUpper &amp; "'" &amp; CrLf;
	str := str &amp; "UNH+" &amp; voyageOid.getEDIMessageCode() &amp; "+BAPLIE:D:95B:UN:SMDG22'" &amp; CrLf;
	str := str &amp; "BGM++" &amp; _number.String &amp; "+9'" &amp; CrLf;
	str := str &amp; "DTM+137:" &amp; now.date.shortYearEDI() &amp; now.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;
	str := str &amp; "TDT+20+" &amp; operatorOid.getXlationForeignCode(ediData.CM_EDIDataBayPlan.voyageCode,XLATION_TYPE_VOYAGETERMINAL, foundMatch).removeEDIInvalidChars.trimBlanks.toUpper &amp; "+++" &amp; ediDataBayPlan.shipperCode.trimBlanks.toUpper &amp; ":172:20+++" &amp; voyageOid.callSign.trimRight &amp; ":103:11:" &amp; ediDataBayPlan.vesselName.trimBlanks.toUpper &amp; "'" &amp; CrLf;
	str := str &amp; "LOC+5+" &amp; operatorOid.getXlationForeignCode(ediDataBayPlan.fromPort,XLATION_TYPE_PORT_BYOP, foundMatch).removeEDIInvalidChars.trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
	str := str &amp; "LOC+61+" &amp; operatorOid.getXlationForeignCode(ediDataBayPlan.toPort,XLATION_TYPE_PORT_BYOP, foundMatch).removeEDIInvalidChars.trimBlanks.toUpper &amp; ":139:6'" &amp; CrLf;
	str := str &amp; "DTM+132:" &amp; ediDataBayPlan.arriveTime.date.shortYearEDI() &amp; ediDataBayPlan.arriveTime.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;

	if ediDataBayPlan.departTime &lt;&gt; null then
		str := str &amp; "DTM+133:" &amp; ediDataBayPlan.departTime.date.shortYearEDI() &amp; ediDataBayPlan.departTime.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;
	else
		str := str &amp; "DTM+133:" &amp; now.date.shortYearEDI() &amp; ediDataBayPlan.arriveTime.time.shortFormatEDI() &amp; ":201'" &amp; CrLf;
	endif;

	foreach ediTI in tisByLocation do
		str := str &amp; self.extractTI(ediTI.CM_EDIBayPlanTI, 0, operatorOid);
	endforeach;

	str := str &amp; "UNT+" &amp; (str.countOccurrences("'")).String &amp; "+" &amp; voyageOid.getEDIMessageCode &amp;"'" &amp; CrLf;
	str := str &amp; "UNZ+1+" &amp; _number.String &amp; "'" &amp; CrLf;
	_ediFile.setRawDataString(str);
	ediFile.writeFile();

epilog
	delete tisByLocation;
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_recipient" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="extractTI" id="1c521941-2327-4e58-a181-f3d025fdd211">
        <updating/>
        <source>extractTI(_ediTI: CM_EDITrackedItem input; _number: Integer; _operator: CM_Operator): String updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/05/2016	cnwdap1		Initial creation TFS #1881 BAPLIE/EDI VGM Updates
// 07/07/2017	cnwdap12	TFS 4492 SNO VERMAS Changes
// 23/08/2017	cnwma1  	TFS #5834-PNL - EDI Translation - ISO Code foreign out
// 12/09/2017	jlgdap1		TFS 6939 POL Remove CTA segment from Baplie
// 15 May 2018	jlgrs1	TFS 38414 - QNS Sundry
// 06 Jul 2018  cnwma1		Bug 39347: SNO - Error in BAPLIE when reporting reefer temepratures
// 29 Oct 2018	jlgrs1	TFS 38414 Remain on Board defaults
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 29 Oct 2018	jlgrs1	TFS 38414 Remain on Board defaults
// 11 Nov 2019	jlgrs1	TFS 47382 donot include the dischrage port as an additional discharge port
// 22 Jan 2021	jlgdap1	TFS 50553 PNL Handling of Nested Child Cargo in BAPLIE EQA Segment
//
constants
	RawEDIHeader = "Baplie 2.2";
vars
	rem, 
	fullCode,
	imCode,
	port,
	xlatedIsoType,
	imEx						: String;
	int							: Integer;
	foundMatch					: Boolean;
	str 						: String;
	ediTI 						: CM_EDIBayPlanTI;
	voyageOid 					: CM_Voyage;
	terminal  				    : CM_Terminal;
	enableControlledAtmosphere  : Boolean;
	ti 							: CM_TrackedItem;
	dischargePortCount 			: Integer;
	child						: CM_EDITrackedItem;				// TFS 50553
begin
	ediTI     := _ediTI.CM_EDIBayPlanTI;
	terminal  := app.myPassport.myTerminal;
	voyageOid := terminal.lookupVoyage(_ediTI.myEDIData.getVoyageCode, null, false);
	
	if terminal.getConfig(EDIBaplieROBExtRawData).Boolean then
		ti := voyageOid.allOnshipTIsByCargoTypeId[ediTI.cargoType, ediTI.id];
		if ti &lt;&gt; null and
		   ti.getRawEDIDataDetail = RawEDIHeader then
			if ti.isRehandle or 
			   ti.isSOB then
				str := "LOC+147+" &amp; ediTI.locationId &amp; "::5'" &amp; CrLf &amp; ti.getRawEDIDataNo147();
				return str;
			elseif ti.isInTransitOnShip then
				str := ti.getRawEDIData();
				return str&amp;CrLf;
			endif;
		endif;
	endif;
	str := str &amp; "LOC+147+" &amp; ediTI.locationId &amp; "::5'" &amp; CrLf;
	
	enableControlledAtmosphere := false;
	enableControlledAtmosphere := self.getEnableControlledAtmosphere(voyageOid.myOperator.code);	
	
	if ediTI.commodity.trimBlanks &lt;&gt; null then
		if _operator = null then
			str := str &amp; "GDS+" &amp; ediTI.commodity.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		else
			str := str &amp; "GDS+" &amp; _operator.getXlationForeignCode(ediTI.commodity,XLATION_TYPE_COMMODITY_BYOP, foundMatch).removeEDIInvalidChars.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endif;
	endif;
	
	if ediTI.commodityDescription.trimBlanks &lt;&gt; null then
		str := str &amp; "FTX+AAA+++" &amp; ediTI.commodityDescription.removeEDIInvalidChars.trimBlanks.toUpper &amp; "'" &amp; CrLf;
	endif;
	
	// Weight Certified By and Authorised Person
	//if ediTI.weightCertifiedReference &lt;&gt; null or ediTI.weightCertifiedName &lt;&gt; null then								// TFS 4492
		//str := str &amp; "FTX+AAY++SHP+" &amp; ediTI.weightCertifiedReference &amp; ":" &amp; ediTI.weightCertifiedName &amp; "'" &amp; CrLf;	// TFS 4492
	//endif;																											// TFS 4492
	str := str &amp; self.buildFTXForVGM(ediTI);																			// TFS 4492
	
	if ediTI.remarks.trimBlanks &lt;&gt; null then
		rem := ediTI.remarks.removeEDIInvalidChars.trimBlanks.toUpper;
		if rem &lt;&gt; null then
			str := str &amp; "FTX+HAN+++" &amp; rem[1:20] &amp; "'" &amp; CrLf;
		endif;
	endif;
	
	//if ediTI.vgmAuthSignature &lt;&gt; null then															// TFS 4492		// TFS 6939
	//	str := str &amp; "CTA+RP+" &amp; ediTI.vgmAuthSignature &amp; "'" &amp; CrLf;									// TFS 4492 	// TFS 6939
	//endif;																							// TFS 4492 	// TFS 6939
	
	// MEA is compulsory
	if ediTI.isCertifiedWeight then 
		// VGM for certified weight
		str := str &amp; "MEA+VGM++KGM:" &amp; ediTI.weight.asStringWeightJMT() &amp; "'" &amp; CrLf;
	else
		str := str &amp; "MEA+WT++KGM:" &amp; ediTI.weight.asStringWeightJMT() &amp; "'" &amp; CrLf;
	endif;
	
	if enableControlledAtmosphere then
		if ediTI.vent &lt;&gt; -1  then
			str := str &amp; "MEA+AAE+AAS+MTQ:"&amp;ediTI.vent.asStringJMT()&amp;"'" &amp; CrLf;
		endif;
		if ediTI.getHumidity &lt;&gt; -1.Decimal  then
			str := str &amp; "MEA+AAE+AAO+PCT:"&amp;ediTI.getHumidity.asStringJMT()&amp;"'" &amp; CrLf;
		endif;
		if ediTI.getOxygen &lt;&gt; -1.Decimal  then
			str := str &amp; "MEA+AAE+ZO+PCT:"&amp;ediTI.getOxygen.asStringJMT()&amp;"'" &amp; CrLf;
		endif;
		if ediTI.getCarbonDioxide &lt;&gt; -1.Decimal  then
			str := str &amp; "MEA+AAE+CD+PCT:"&amp;ediTI.getCarbonDioxide.asStringJMT()&amp;"'" &amp; CrLf;
		endif;
	endif;

	if ediTI.cargoType &lt;&gt; TI_CargoType_Container then	//process as gross dimensions
		str := str &amp; "DIM+1+CMT:" &amp; ediTI.length.asStringMeasurementJMT() &amp; ":" &amp; ediTI.width.asStringMeasurementJMT() &amp; ":" &amp; ediTI.height.asStringMeasurementJMT() &amp; "'" &amp; CrLf; 
	else			//process as overdimensions 
		if ediTI.overLengthFront &lt;&gt; 0 
		and ediTI.overLengthFront &lt;&gt; NULL_INTEGER then
			str := str &amp; "DIM+5+CMT:" &amp; ediTI.overLengthFront.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		endif;
		if ediTI.overLengthBack &lt;&gt; 0 
		and ediTI.overLengthBack &lt;&gt; NULL_INTEGER then
			str := str &amp; "DIM+6+CMT:" &amp; ediTI.overLengthBack.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		elseif (ediTI.overLengthFront = null and ediTI.length &lt;&gt; null) then // do old version
			str := str &amp; "DIM+9+CMT:" &amp; ediTI.length.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		endif;
		if ediTI.overWidthRight &lt;&gt; 0 
		and ediTI.overWidthRight &lt;&gt; NULL_INTEGER then
			str := str &amp; "DIM+7+CMT::" &amp; ediTI.overWidthRight.asStringMeasurementJMT() &amp; "'" &amp; CrLf; 
		endif;
		if ediTI.overWidthLeft &lt;&gt; 0 
		and ediTI.overWidthLeft &lt;&gt; NULL_INTEGER then
			str := str &amp; "DIM+8+CMT::" &amp; ediTI.overWidthLeft.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		elseif (ediTI.overWidthRight = null and ediTI.width &lt;&gt; null) then // do old version
			str := str &amp; "DIM+9+CMT::" &amp; ediTI.width.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		endif;
		if ediTI.overHeight &lt;&gt; 0 
		and ediTI.overHeight &lt;&gt; NULL_INTEGER then
			str := str &amp; "DIM+9+CMT:::" &amp; ediTI.overHeight.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		elseif ediTI.height &lt;&gt; null then // do old version
			str := str &amp; "DIM+9+CMT:::" &amp; ediTI.height.asStringMeasurementJMT() &amp; "'" &amp; CrLf;
		endif;
	endif;
	
	if ediTI.temperature &lt;&gt; NULL_TEMPERATURE then
		if _operator &lt;&gt; null and 
		   _operator.getConfig(EDITempFormat).Boolean then
			if ediTI.temperature &lt; 0 then
				str := str &amp; "TMP+2+-" &amp; ediTI.temperature.Integer.positive.stringWithLeadingZeros(3) &amp; ":CEL'" &amp; CrLf;
			else
				str := str &amp; "TMP+2+" &amp; ediTI.temperature.Integer.positive.stringWithLeadingZeros(3) &amp; ":CEL'" &amp; CrLf;
			endif;
		else
			//str := str &amp; "TMP+2+" &amp; ediTI.temperature.asStringJMTWithPrecision($CM_CamEDIFACTTemp.decimalPlaces, false) &amp; ":CEL'" &amp; CrLf; //02/07/2018  cnwma1 Bug38633
			str := str &amp; "TMP+2+" &amp; ediTI.temperature.asStringEDIWithPrecision($CM_CamEDIFACTTemp.decimalPlaces) &amp; ":CEL'" &amp; CrLf;  //02/07/2018  cnwma1 Bug38633
		endif;
	endif;
	
	if ediTI.loadPort &lt;&gt; null then
		if _operator = null then
			str := str &amp; "LOC+9+" &amp; ediTI.loadPort.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		else
			str := str &amp; "LOC+9+" &amp; _operator.getXlationForeignCode(ediTI.loadPort,XLATION_TYPE_PORT_BYOP, foundMatch).removeEDIInvalidChars.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endif;
	endif;
	
	if ediTI.dischargePort &lt;&gt; null then
		if _operator = null then
			str := str &amp; "LOC+11+" &amp; ediTI.dischargePort.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		else
			str := str &amp; "LOC+11+" &amp; _operator.getXlationForeignCode(ediTI.dischargePort,XLATION_TYPE_PORT_BYOP, foundMatch).removeEDIInvalidChars.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endif;
	endif;
	int := 0;
	foreach port in ediTI.dischargePorts do
		int := int + 1;
		if port.trimBlanks = ediTI.dischargePort then
			continue;
		endif;
		dischargePortCount := dischargePortCount + 1;
		if dischargePortCount = 1 then
			if _operator = null then
				str := str &amp; "LOC+64+" &amp; ediTI.dischargePorts[int].trimBlanks.toUpper &amp; "'" &amp; CrLf;
			else
				str := str &amp; "LOC+64+" &amp; _operator.getXlationForeignCode(ediTI.dischargePorts[int],XLATION_TYPE_PORT_BYOP, foundMatch).removeEDIInvalidChars.trimBlanks.toUpper &amp; "'" &amp; CrLf;
			endif;
		elseif dischargePortCount = 2 then
			if _operator = null then
				str := str &amp; "LOC+68+" &amp; ediTI.dischargePorts[int].trimBlanks.toUpper &amp; "'" &amp; CrLf;
			else
				str := str &amp; "LOC+68+" &amp; _operator.getXlationForeignCode(ediTI.dischargePorts[int],XLATION_TYPE_PORT_BYOP, foundMatch).removeEDIInvalidChars.trimBlanks.toUpper &amp; "'" &amp; CrLf;
			endif;
		elseif dischargePortCount = 3 then
			if _operator = null then
				str := str &amp; "LOC+70+" &amp; ediTI.dischargePorts[int].trimBlanks.toUpper &amp; "'" &amp; CrLf;
			else
				str := str &amp; "LOC+70+" &amp; _operator.getXlationForeignCode(ediTI.dischargePorts[int],XLATION_TYPE_PORT_BYOP, foundMatch).removeEDIInvalidChars.trimBlanks.toUpper &amp; "'" &amp; CrLf;
			endif;
		endif;
	endforeach;
	
	if ediTI.ediTranshipPort &lt;&gt; null then
		str := str &amp; "LOC+152+" &amp; ediTI.ediTranshipPort.trimBlanks.toUpper &amp; "'" &amp; CrLf;
	endif;
	
	if ediTI.destinationPort &lt;&gt; null then
		if _operator = null then
			str := str &amp; "LOC+83+" &amp; ediTI.destinationPort.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		else
			str := str &amp; "LOC+83+" &amp; _operator.getXlationForeignCode(ediTI.destinationPort,XLATION_TYPE_PORT_BYOP, foundMatch).removeEDIInvalidChars.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endif;
	endif;
	
	if ediTI.cargoType = TI_CargoType_Container then
		str := str &amp; "RFF+BM:1'" &amp; CrLf;
	else
		str := str &amp; "RFF+ET:" &amp; ediTI.locationId &amp; "'" &amp; CrLf; //Excess Transportation Number (lead stowage position)
	endif;
	
	if ediTI.fullOrMT = "F" then
		fullCode := "5";
	else
		fullCode := "4";
	endif;
	
	if ediTI.exportImport = "E" then //Export
		imEx := "2";
	elseif ediTI.exportImport = "I" then //Import
		imEx := "3";
	elseif ediTI.exportImport = "R" then //Restow either DLR or SOB
		imEx := "5";
	else
		imEx := "4";
	endif;
	
	if _operator &lt;&gt; null then
			xlatedIsoType := _operator.getXlationForeignCode(ediTI.isoType,XLATION_TYPE_ISOTYPE_BYOP,foundMatch);
	else
			xlatedIsoType := ediTI.isoType;
	endif;
		
	if ediTI.cargoType = TI_CargoType_Container then
		//str := str &amp; "EQD+CN+" &amp; ediTI.id.trimBlanks.toUpper &amp; "+" &amp; ediTI.isoType &amp; "++" &amp; imEx &amp; "+" &amp; fullCode &amp; "'" &amp; CrLf; //23/08/2017 cnwma1 TFS #5834
		str := str &amp; "EQD+CN+" &amp; ediTI.id.trimBlanks.toUpper &amp; "+" &amp; xlatedIsoType &amp; "++" &amp; imEx &amp; "+" &amp; fullCode &amp; "'" &amp; CrLf; //23/08/2017 cnwma1 TFS #5834
	else //handle as  BBLK
		//str := str &amp; "EQD+BB+" &amp; ediTI.id.trimBlanks.toUpper &amp; "+" &amp; ediTI.isoType &amp; "+++'" &amp; CrLf; //23/08/2017 cnwma1 TFS #5834
		str := str &amp; "EQD+BB+" &amp; ediTI.id.trimBlanks.toUpper &amp; "+" &amp; xlatedIsoType &amp; "+++'" &amp; CrLf; //23/08/2017 cnwma1 TFS #5834
	endif;
	// TFS 50553 handle child flat racks
	if ediTI.myAttachedItems.size &gt; 0 then
		foreach child in ediTI.myAttachedItems do
			str := str &amp; "EQA+CN+" &amp; child.id.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endforeach;
	endif;
	// TFS 50553

	if ediTI.couId &lt;&gt; null then
		str := str &amp; "EQA+RG+" &amp; ediTI.couId.trimBlanks.toUpper &amp; "'" &amp; CrLf;
	endif;

	if ediTI.operatorCode &lt;&gt; null then
		str := str &amp; "NAD+CA+" &amp; self.myRoot.getXlationForeignOperatorCode(_operator, ediTI.operatorCode, foundMatch).removeEDIInvalidChars.trimBlanks.toUpper &amp; ":172:20'" &amp; CrLf; 
	endif; 
	
	if ediTI.imCodes.size &gt; 0 then
		foreach imCode in ediTI.imCodes do
			str := str &amp; "DGS+IMD+" &amp; imCode.trimBlanks.toUpper &amp; "'" &amp; CrLf;
		endforeach;
	endif;
	
	return str;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDITrackedItem" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIPartyRules" id="aaa14979-f4c9-4b07-84a6-777f44ab81eb">
        <source>getEDIPartyRules(_ediParty: CM_EDIParty): CM_EDIPartyRules protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/05/2016	cnwdap1		Initial creation TFS #1881 BAPLIE/EDI VGM Updates
//
vars

begin
	if _ediParty = null then
		return null;
	endif;
	
	return _ediParty.getRulesForFileType (EDIFileType_Baplie20);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediParty" type="CM_EDIParty"/>
        <ReturnType type="CM_EDIPartyRules"/>
    </JadeMethod>
    <JadeMethod name="getEnableControlledAtmosphere" id="30317639-4b2f-42b3-84dd-624ee150deaf">
        <source>getEnableControlledAtmosphere(_operatorCode : String) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/05/2016	cnwdap1		Initial creation TFS #1881 BAPLIE/EDI VGM Updates
//
vars
	enableControlledAtmoshpere	: Boolean;
	senderParty					: CM_EDIParty;
	senderPartyRules 			: CM_EDIPartyRules;	
	terminal 					: CM_Terminal;
	ediPartyDict  		 		: CM_EDIPartyDict;

begin
	terminal 		:= app.myPassport.myTerminal;
	
	if _operatorCode &lt;&gt; null and terminal &lt;&gt; null then
		foreach  senderParty in  terminal.allEDIParties do
			if senderParty.myTranslationOperator &lt;&gt; null then
				if senderParty.myTranslationOperator.code = _operatorCode then
					if senderParty &lt;&gt; null then
						senderPartyRules 	:= self.getEDIPartyRules (senderParty);
						break;
					endif;
				endif;
			endif;
		endforeach;
		
		if senderPartyRules &lt;&gt; null and senderPartyRules.isKindOf(CM_EDIPartyBaplieRules) then  
			enableControlledAtmoshpere := senderPartyRules.CM_EDIPartyBaplieRules.enableAtmosphere;			
		endif;
	endif;

	return enableControlledAtmoshpere;
epilog

end;</source>
        <Parameter name="_operatorCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTDTOperator" id="8e7a5106-5a22-4adb-a496-60234f8ffff7">
        <updating/>
        <source>getTDTOperator(_msgHelper: CMIF_EDIFACTHelper input): CM_Operator updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/05/2016	cnwdap1		Initial creation TFS #1881 BAPLIE/EDI VGM Updates
//
vars
	group			: Integer;
	operatorCode	: String;
	operatorOid		: CM_Operator;

begin
	_msgHelper.setNextField;
	if _msgHelper.currentField = "20" then
		if group = 0 then
			group := 1;
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			_msgHelper.setNextField;
			operatorCode := _msgHelper.currentSubItem;
	
			operatorOid := app.myRoot.allOperators[operatorCode];
		endif;
	endif;
	
	return operatorOid;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="input"/>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="c4295817-4c58-407c-b1dd-df6123193bf7">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/05/2016	cnwdap1		Initial creation TFS #1881 BAPLIE/EDI VGM Updates
// 04 Aug 2016	cnwrs1		Par 38117 make deleted EDI for finable
// 22/06/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// 27 Mar 2018	jlgrs1	TFS 37419 - QNS Sundry
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 29 Oct 2018	jlgrs1	TFS 38414 Remain on Board defaults
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 11 Nov 2019	jlgrs1	TFS 47382 donot include the dischrage port as an additional discharge port
// 21/12/2020	jlgdap1	TFS 50553 PNL Handling of Nested Child Cargo in Baplie EQA Segment
// 11/12/2024	navlw1  JIRA-19149: SPT - Over Height Dimension is displayed incorrectly in Baplie file while it get Extracted
//
constants
	ProgressBarRefresh	: Integer = 2000;	
	RawEDIHeader = "Baplie 2.2";
vars
	container				: CM_EDIBayPlanTI;
	ediDataBayPlan			: CM_EDIDataBayPlan;
	lineStr					: String;
	message					: String;
	int						: Integer;
	generatedContainerNo	: Integer;
	voyageCode				: String;
	operatorVoyageCode		: String;
	vesselName				: String;
	lloydsNumber			: String;
	callSign				: String;
	commodityStr			: String;
	loadPortStr				: String;
	destPortStr				: String;
	dischargePortStr		: String;
	dischargePorts			: StringArray;
	operatorSenderCode		: String;
	group					: Integer;
	code					: String;
	rngType					: String;
	temperature				: Real;
	tmpMin					: Real;
	tmpMax					: Real;
	operatorSender			: CM_Operator;
	operatorVoyage			: CM_Operator;
	operatorContainer		: CM_Operator;
	mtCmdty					: String;
	defCmdty				: String;
	refCmdty				: String;
	hazCmdty				: String;
	portDestCode			: String;
	pISOType				: CM_ISOType;
	terminal				: CM_Terminal;
	isotype					: String;
	msgCount				: Integer;
	numMsgs					: Integer;
	passport				: CM_Passport;
	haz						: String;
	undg					: String;
	useDefCmdty				: Boolean;
	msgHelper				: CMIF_EDIFACTHelper;
	showProgress			: Boolean;
	tmpRawEDIData			: String;
	tmpStr					: String;
	foundMatch				: Boolean;
	theLines 				: HugeStringArray;
	rawSenderCode 			: String;
	creationTS 				: TimeStamp;
	sequence 				: String;
	fileType 				: String;
	version 				: String;
	recipientCode 			: String;
	progressInt				: TimeStampInterval;
	progressTS 				: TimeStamp;
	vgmContext				: String;							// TFS 4492
	pos 					: Integer;							// TFS 4492
	portStr : String;
	isoTypeObj				: CM_ISOType;					// TFS 50553
	child					: CM_EDIBayPlanTI;				// TFS 50553
begin
	progressTS := app.actualTimeServer();
	passport 		:= app.myPassport;	
	showProgress	:= passport.myCMIFMonitor &lt;&gt; null;
	terminal 		:= passport.myTerminal;
	
	app.getTerminalDefCmdty(mtCmdty, defCmdty, refCmdty, hazCmdty);
	
	portDestCode	:= terminal.getConfig(PortDestCode).String;
	commodityStr	:= defCmdty;
	
	// For baplie and master plan, we should show the gross TIs and the total of the TIs
	// For the user's port . This is purely for a check or review purpose.
	ediDataBayPlan := _ediFile.ediData.CM_EDIDataBayPlan;
	ediDataBayPlan.loadRecordsForPort := 0;
	create dischargePorts transient;
	create msgHelper transient;
	msgHelper.setEDIFile(_ediFile);

	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach lineStr in theLines do
		msgCount := msgCount + 1;
		
		progressInt := app.actualTimeServer() - progressTS;
		if showProgress and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();
		endif;

		msgHelper.setNextMessage(lineStr);	//set the current message
		
		//get current
		message := msgHelper.currentMessage;	
//BGM
	
//CTA
	if msgHelper.currentTag = "CTA" then													// TFS 4492
		msgHelper.setNextField();															// TFS 4492
		if msgHelper.currentField = "RP" then												// TFS 4492
			// signature of VGM authorised person											// TFS 4492
			msgHelper.setNextField;															// TFS 4492
			container.vgmAuthSignature := msgHelper.currentSubItem;							// TFS 4492
		elseif msgHelper.currentField = "BN" then											// TFS 4492
			// details on subsequent COM segment											// TFS 4492
		endif;																				// TFS 4492

//DGS
	elseif msgHelper.currentTag = "DGS" then
			if group = 3 then
				group := 4;
			endif;
			
			if group = 4 then
				msgHelper.setNextField;
				
				if msgHelper.currentField = "IMD" then
					msgHelper.setNextField;
					
					haz := msgHelper.currentSubItem;
					
					msgHelper.setNextField;
					
					undg := msgHelper.currentSubItem;
					
					container.imCodes.add(haz &amp; ":+" &amp; undg);
					
					if useDefCmdty and (container.commodity = defCmdty or container.commodity = "") then
						//change to default hazardous commodity
						container.commodity := hazCmdty;
						commodityStr		:= container.commodity;
					endif;
					
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			endif;
//DIM
		elseif msgHelper.currentTag = "DIM" then
			if group = 2 then
				msgHelper.setNextField;
				code := msgHelper.currentField;
				msgHelper.setNextField;
				if msgHelper.currentSubItem = "CMT" or
				   msgHelper.currentSubItem = "CM" then //valid baplie 1 still used by some systems
					msgHelper.setNextSubItem;
					if code = "5" then
						if container.overLengthFront = null
						or container.overLengthFront = NULL_INTEGER then
							container.overLengthFront:= msgHelper.currentSubItem.Integer;
						endif;
					elseif code = "6" then
						if container.overLengthBack = null
						or container.overLengthBack = NULL_INTEGER then
							container.overLengthBack := msgHelper.currentSubItem.Integer;
						endif;
					else // old version
						container.length := msgHelper.currentSubItem.Integer;
					endif;
					msgHelper.setNextSubItem;
					if code = "7" then
						if container.overWidthRight = null
						or container.overWidthRight = NULL_INTEGER then
							container.overWidthRight:= msgHelper.currentSubItem.Integer;
						endif;
					elseif code = "8" then
						if container.overWidthLeft = null
						or container.overWidthLeft = NULL_INTEGER then
							container.overWidthLeft := msgHelper.currentSubItem.Integer;
						endif;
					else // old version
						container.width := msgHelper.currentSubItem.Integer;
					endif;
					msgHelper.setNextSubItem;
					if container.overHeight	= null	// if old version, height returned from mapping method
					or container.overHeight = NULL_INTEGER then	
						container.overHeight := msgHelper.currentSubItem.Integer;
					endif;
					// navlw1 #JIRA-19149
					// store the current message string to the raw data so we can process this when EDIBaplieROBExtRawData is set
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
					// tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentSubItem &amp; "'";
				elseif msgHelper.currentSubItem = "INH" then
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			endif; 
//DTM
		elseif msgHelper.currentTag = "DTM" then
			if group = 0 then
				msgHelper.setNextField;
			elseif group = 1 then
				msgHelper.setNextField;
				if msgHelper.currentSubItem = "136" then
					msgHelper.setNextSubItem;
					ediDataBayPlan.arriveTime := msgHelper.currentSubItem[1:10].getEDITimeStamp;
				elseif msgHelper.currentSubItem = "178" then
					msgHelper.setNextSubItem;
					ediDataBayPlan.departTime := msgHelper.currentSubItem[1:10].getEDITimeStamp;
				elseif msgHelper.currentField = "798" then												// TFS 4492
					// VGM determination date/time														// TFS 4492
					msgHelper.setNextSubItem;															// TFS 4492
					container.vgmDeterminationDT := msgHelper.currentSubItem[1:10].getEDITimeStamp;		// TFS 4492
				elseif msgHelper.currentField = "137" then												// TFS 4492
					// VGM documentation issue date/time												// TFS 4492
					msgHelper.setNextSubItem;															// TFS 4492
					container.vgmDocsIssuedDT := msgHelper.currentSubItem[1:10].getEDITimeStamp;		// TFS 4492
				endif;
			endif;
//EQA
		elseif msgHelper.currentTag = "EQA" then
			if group = 3 then
				msgHelper.setNextField;
				if msgHelper.currentField = "CN" then
					// TFS 50553 create child cargo if the parent is an import flat rack container
					if container &lt;&gt; null and container.isoType &lt;&gt; null then
						isoTypeObj := app.myRoot.allISOTypes[container.isoType];
					//	if isoTypeObj.isFlat and container.dischargePort = portDestCode then
						if isoTypeObj &lt;&gt; null and isoTypeObj.isFlat and container.dischargePort = portDestCode then	//15 Jul 2021	NDL	TFS 51598
							create child persistent;
							msgHelper.setNextField;
							child.isoType := container.isoType;
							child.commodity := defCmdty;
							child.loadPort := container.loadPort;
							child.dischargePort := container.dischargePort;
							child.destinationPort := container.destinationPort;
							child.operatorCode := container.operatorCode;
							child.locationId := container.locationId;
							child.setForCreateNew(_ediFile.ediData);
							child.id := msgHelper.currentField;
							child.rawEDIData := msgHelper.currentMessage &amp; "'";
							child.myParent := container;
						endif;
					endif;
					// TFS 50553 end
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				elseif msgHelper.currentField = "CH" then
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				elseif msgHelper.currentField = "RG" then
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				//elseif msgHelper.currentField = "BB" then										// TFS 50553
				//	tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";		// TFS 50553
				endif;
			endif;
//EQD
		elseif msgHelper.currentTag = "EQD" then
			if group = 2 then
				group := 3;
				msgHelper.setNextField;
				if msgHelper.currentField = "CN" then
					container.setCargoType(TI_CargoType_Container);
					msgHelper.setNextField;
					
					container.setId(msgHelper.currentField.replaceString(" ", "")[1:11]);
					
					msgHelper.setNextField;
					isotype := msgHelper.currentField[1:4];
					
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextField;
					if msgHelper.currentField = "4" then
						container.fullOrMT := "E";
						// Do not overwrite if commodity already determined by GDS or FTX+AAA
						if commodityStr.trimBlanks = null or
						   commodityStr = defCmdty then
							container.commodity := mtCmdty;
							commodityStr	:= container.commodity;
						endif;
					elseif msgHelper.currentField = "5" then
						container.fullOrMT := "F";
						// Do not overwrite if commodity already determined by GDS or FTX+AAA
						if commodityStr.trimBlanks = null or
						   commodityStr = defCmdty then
							useDefCmdty := true;
							if container.temperature = NULL_TEMPERATURE then
								container.commodity := defCmdty;
								commodityStr	:= container.commodity;
							else
								container.commodity := refCmdty;
								commodityStr	:= container.commodity;
							endif;
						endif;
					endif;
					// Set these values on the container here because the NAD record is optional,
					// if the NAD record is subsequently found then this will do translations as required.
					container.commodity 		:= commodityStr.trimBlanks[ 1 : container.commodity.maxLength ];
					container.loadPort			:= loadPortStr.trimBlanks[ 1 : container.loadPort.maxLength ];
					container.dischargePort		:= dischargePortStr.trimBlanks[ 1 : container.dischargePort.maxLength ];
					if container.dischargePorts.isEmpty then
						dischargePorts.copy(container.dischargePorts);
					endif;
					container.destinationPort 	:= destPortStr.trimBlanks[ 1 : container.destinationPort.maxLength ];
					if container.cargoType = TI_CargoType_Container then
						container.isoType		:= isotype.trimBlanks[ 1 : container.isoType.maxLength ];
					endif;
					
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
					int := int + 1;
				elseif msgHelper.currentField = "BB" then
					container.setCargoType(TI_CargoType_BreakBulk);
					msgHelper.setNextField;
					if msgHelper.currentField.trimBlanks = null then
						generatedContainerNo := generatedContainerNo + 1;
						container.setIdDefault(generatedContainerNo.String);
					else
						container.setId(msgHelper.currentField.replaceString(" ", ""));
					endif;
					container.isoType := "BBLK";
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			endif;
//FTX
		elseif msgHelper.currentTag = "FTX" then
			if group = 2 then
				msgHelper.setNextField;
				if msgHelper.currentField = "AAA" then
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextField;
					container.commodityDescription := msgHelper.currentSubItem[1:30];
					// Do not overwrite if commodity already determined by GDS
					if commodityStr.trimBlanks = null or commodityStr = defCmdty then
						commodityStr := msgHelper.currentSubItem[1:30].trimBlanks;
						
						if commodityStr.trimBlanks = null then
							msgHelper.setNextSubItem;
							
							commodityStr := msgHelper.currentSubItem[1:30].trimBlanks;
						endif;
						// If they are both blank on this FTX+AAA then reset to the default
						if commodityStr.trimBlanks = null then
							commodityStr	:= defCmdty;
						endif;
					endif;
					
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				elseif msgHelper.currentField = "AAY" then
					msgHelper.setNextField;
					msgHelper.setNextField;
					vgmContext := msgHelper.currentField;												// TFS 4492
					if vgmContext = "SM1" or vgmContext = "SM2" then									// TFS 4492
						container.vgmCommsType := msgHelper.currentField;								// TFS 4492
					endif;																				// TFS 4492
					msgHelper.setNextField;
					if vgmContext = "SHP" then															// TFS 4492
						container.weightCertifiedReference := msgHelper.currentSubItem;		// Weight Certified By 
						msgHelper.setNextSubItem;
						container.weightCertifiedName := msgHelper.currentSubItem;			// Authorised Person for Certified Weight
					elseif vgmContext = "SM1" or vgmContext = "SM2" then								// TFS 4492
						container.vgmDeterminationDT := msgHelper.currentSubItem[1:10].getEDITimeStamp;	// TFS 4492
						msgHelper.setNextSubItem;														// TFS 4492
						pos := msgHelper.currentSubItem.pos(";", 1);									// TFS 4492
						if pos &lt;&gt; null then																// TFS 4492
							container.weightCertifiedReference := msgHelper.currentSubItem[1:pos-1];	// TFS 4492
							if pos &lt;&gt; msgHelper.currentSubItem.length() then							// TFS 42772 jlgzm1
								container.vgmMail := msgHelper.currentSubItem[pos+1:end];				// TFS 4492
							endif;
						endif;																			// TFS 4492
						msgHelper.setNextSubItem;														// TFS 4492
						pos := msgHelper.currentSubItem.pos(";", 1);									// TFS 4492
						if pos &lt;&gt; null then																// TFS 4492
							container.weightCertifiedName := msgHelper.currentSubItem[1:pos-1];			// TFS 4492
						endif;																			// TFS 4492
						msgHelper.setNextSubItem;														// TFS 4492
						container.vgmAuthSignature := msgHelper.currentSubItem;							// TFS 4492
					elseif vgmContext = "DRF" then														// TFS 4492
						container.vgmDocsIssuedDT := msgHelper.currentSubItem[1:10].getEDITimeStamp;	// TFS 4492
						msgHelper.setNextSubItem;														// TFS 4492
						container.vgmMail := msgHelper.currentSubItem;									// TFS 4492
						msgHelper.setNextSubItem;														// TFS 4492
						pos := msgHelper.currentSubItem.pos(";", 1);									// TFS 4492
						if pos &lt;&gt; null then																// TFS 4492
							container.vgmTelephone := msgHelper.currentSubItem[1:pos-1];				// TFS 4492
							container.vgmElectronicMail := msgHelper.currentSubItem[pos+1:end];			// TFS 4492
						else																			// TFS 4492
							container.vgmTelephone := msgHelper.currentSubItem;							// TFS 4492
						endif;																			// TFS 4492
						msgHelper.setNextSubItem;														// TFS 4492
						container.vgmDocumentDetails := msgHelper.currentSubItem;						// TFS 4492
					endif;																				// TFS 4492
						
				elseif msgHelper.currentField = "HAN" then
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextField;

					container.remarks	:= msgHelper.currentSubItem;
	
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				elseif msgHelper.currentField = "CLR" then
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				elseif msgHelper.currentField = "SIN" then
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				elseif msgHelper.currentField = "AAI" then
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				elseif msgHelper.currentField = "XXX" then	//various uses
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				elseif msgHelper.currentField = "ZZZ" then	//agreed between parties
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			elseif group = 4 then
				msgHelper.setNextField;
				if msgHelper.currentField = "AAC" or
				   msgHelper.currentField = "AAD" then
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextField;
					container.remarks := msgHelper.currentSubItem[1:20];
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			endif;
//GDS
		elseif msgHelper.currentTag = "GDS" then
			if group = 2 then
				msgHelper.setNextField;
				
				commodityStr := msgHelper.currentSubItem[1:4].trimBlanks;
				
				if commodityStr.trimBlanks = null then
					msgHelper.setNextSubItem;
					commodityStr := msgHelper.currentSubItem[1:4].trimBlanks;
				endif;
				// If they are both blank on this GDS then reset to the default	// cnwrl1 28/04/2010 PAR 23951
				if commodityStr.trimBlanks = null then
					commodityStr	:= defCmdty;
				endif;
				
				tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
			endif;
//GID
		elseif msgHelper.currentTag = "GID" then
			if group = 2 then
				tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
			endif;
//LOC
		elseif msgHelper.currentTag = "LOC" then
			msgHelper.setNextField;
			if msgHelper.currentField = "9" then
				if group = 2 then
					msgHelper.setNextField;
					loadPortStr := msgHelper.currentSubItem[1:5].trimBlanks;
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			elseif msgHelper.currentField = "11" then
				if group = 2 then
					msgHelper.setNextField;
					dischargePortStr := msgHelper.currentSubItem[1:5].trimBlanks;
					if operatorContainer &lt;&gt; null then
						dischargePortStr := operatorContainer.getXlationSystemCode(dischargePortStr, XLATION_TYPE_PORT_BYOP, foundMatch);
					endif;
					container.dischargePort := dischargePortStr[1:5];
					// For baplie and master plan, we should show the gross TIs and the total of the TIs
					// For the user's port . This is purely for a check or review purpose.
					if container.dischargePort =  portDestCode then
						ediDataBayPlan.loadRecordsForPort := ediDataBayPlan.loadRecordsForPort + 1;
					endif;
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			elseif msgHelper.currentField = "13" then
				if group = 2 then
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			elseif msgHelper.currentField = "64" then
				if group = 2 then
					msgHelper.setNextField;
					portStr := msgHelper.currentSubItem[1:5].trimBlanks;
					if portStr &lt;&gt; container.dischargePort then
						dischargePorts.add(portStr);
						tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; portStr &amp; "'";
					endif;
				endif;
			elseif msgHelper.currentField = "68" then
				if group = 2 then
					msgHelper.setNextField;
					portStr := msgHelper.currentSubItem[1:5].trimBlanks;
					if portStr &lt;&gt; container.dischargePort then
						dischargePorts.add(portStr);
						tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; portStr &amp; "'";
					endif;
				endif;
			elseif msgHelper.currentField = "70" then
				if group = 2 then
					msgHelper.setNextField;
					portStr := msgHelper.currentSubItem[1:5].trimBlanks;
					if portStr &lt;&gt; container.dischargePort then
						dischargePorts.add(portStr);
						tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; portStr &amp; "'";
					endif;
				endif;
			elseif msgHelper.currentField = "76" then
				if group = 2 then
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			elseif msgHelper.currentField = "83" then
				if group = 2 then
					msgHelper.setNextField;
					destPortStr := msgHelper.currentSubItem[1:5].trimBlanks;
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			elseif msgHelper.currentField = "97" then
				if group = 2 then
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			elseif msgHelper.currentField = "147" then
				if group = 1 or group = 3 or group = 4 then
					group := 2;
				endif;
				if group = 2 then
					if container &lt;&gt; null then // not first time through
						if container.id = null then // if the last container has no id
							generatedContainerNo := generatedContainerNo + 1;
							container.setIdDefault(generatedContainerNo.String);
						endif;
						container.rawEDIData := tmpRawEDIData;
						self.updateChildFlatRacks(container);				// TFS 50553
					endif;
		
					create container persistent;
					container.setForCreateNew(_ediFile.ediData);
					//reset this on each new ti
					useDefCmdty := false;
					commodityStr		:= defCmdty;
					loadPortStr			:= "";
					dischargePortStr	:= "";
					dischargePorts.clear();
					destPortStr			:= "";
					isotype				:= "";
					
					container.temperature := NULL_TEMPERATURE;
					msgHelper.setNextField;
					container.locationId := msgHelper.currentSubItem[1:7];
					tmpRawEDIData := RawEDIHeader &amp; Tab &amp; msgHelper.currentMessage;
				endif;
			elseif msgHelper.currentField = "152" then
				if group = 2 then
					msgHelper.setNextField;
					container.ediTranshipPort := msgHelper.currentSubItem[1:5].trimBlanks;
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			endif;
//MEA
		elseif msgHelper.currentTag = "MEA" then
			if group = 2 then
				msgHelper.setNextField;
				if msgHelper.currentField = "WT" then
					msgHelper.setNextField;
					msgHelper.setNextField;
					if msgHelper.currentSubItem = "KGM" then
						msgHelper.setNextSubItem;
						container.weight := msgHelper.currentSubItem.Decimal;
						tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
					elseif msgHelper.currentSubItem = "LBR" then
						msgHelper.setNextSubItem;
						container.weight := (msgHelper.currentSubItem.asEDIReal()/2.2).Decimal;
						tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
					endif;
				elseif msgHelper.currentField = "VGM" then
					container.isCertifiedWeight := true;
					msgHelper.setNextField;
					msgHelper.setNextField;
					if msgHelper.currentSubItem = "KGM" then
						msgHelper.setNextSubItem;
						container.weight := msgHelper.currentSubItem.Decimal;
						tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
					elseif msgHelper.currentSubItem = "LBR" then
						msgHelper.setNextSubItem;
						container.weight := (msgHelper.currentSubItem.asEDIReal()/2.2).Decimal;
						tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
					endif;
				elseif msgHelper.currentField = "AAE" then
					msgHelper.setNextField;
					if msgHelper.currentField = "AAO" then
						// get the actual value
						msgHelper.setNextField;
						msgHelper.setNextSubItem;
						container.setHumidity( msgHelper.currentSubItem.trimBlanks.asDecimalJMT );
					elseif msgHelper.currentField = 'AAS' then	// Air Flow - ie Vent
						// get the actual value
						msgHelper.setNextField;
						msgHelper.setNextSubItem;
						container.vent := msgHelper.currentSubItem.trimBlanks.asEDIReal;
					elseif msgHelper.currentField = 'ZO' then	// Oxygen
						// get the actual value
						msgHelper.setNextField;
						msgHelper.setNextSubItem;
						container.setOxygen( msgHelper.currentSubItem.trimBlanks.asDecimalJMT );
					elseif msgHelper.currentField = 'CD' then	// CarbonDioxide 
						// get the actual value
						msgHelper.setNextField;
						msgHelper.setNextSubItem;
						container.setCarbonDioxide( msgHelper.currentSubItem.trimBlanks.asDecimalJMT );
					endif;
				endif;
			endif;
//NAD
		elseif msgHelper.currentTag = "NAD" then
			msgHelper.setNextField;
			if msgHelper.currentField = "CA" then		// sender operator aka carrier
				if group = 3 then
					msgHelper.setNextField;
					
					operatorSenderCode 		:= msgHelper.currentSubItem.trimBlanks;
					container.operatorCode 	:= app.myRoot.getXlationSystemOperatorCode(operatorSender, operatorSenderCode, foundMatch)[1:4];
					operatorContainer 		:= app.myRoot.allOperators[container.operatorCode];

					// do translations
					if operatorContainer &lt;&gt; null then
						container.commodity 		:= operatorContainer.getXlationSystemCode_Commodity(commodityStr, foundMatch, container.temperature)[1:4];	// par 31259
						container.loadPort			:= operatorContainer.getXlationSystemCode(loadPortStr, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
						container.dischargePort		:= operatorContainer.getXlationSystemCode(dischargePortStr, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
						if not container.dischargePorts.isEmpty then
							container.dischargePorts.clear;
						endif;
						foreach tmpStr in dischargePorts do
							container.dischargePorts.add( operatorContainer.getXlationSystemCode(tmpStr, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5] );
						endforeach;
						
						container.destinationPort 	:= operatorContainer.getXlationSystemCode(destPortStr, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
						
						if container.cargoType = TI_CargoType_Container then
							container.isoType 		:= operatorContainer.getXlationSystemCode(isotype, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4];
						endif;
						
					else
						container.commodity 		:= commodityStr.trimBlanks[1:4];
						container.loadPort			:= loadPortStr.trimBlanks[1:5];
						container.dischargePort		:= dischargePortStr.trimBlanks[1:5];
						if container.dischargePorts.isEmpty then
							dischargePorts.copy(container.dischargePorts);
						endif;
						container.destinationPort 	:= destPortStr.trimBlanks[1:5];
						
						if container.cargoType = TI_CargoType_Container then
							container.isoType		:= isotype.trimBlanks[1:4];
						endif;
					endif;
					commodityStr		:= defCmdty;
					loadPortStr			:= "";
					dischargePortStr	:= "";
					dischargePorts.clear();
					destPortStr			:= "";
					isotype				:= "";
					
					// The bay file should handle different cargo types based on isoType;
					pISOType := app.myRoot.allISOTypes[container.isoType];
					if (pISOType &lt;&gt; null) and (pISOType.myCargoType &lt;&gt; null) then
						container.setCargoType(pISOType.myCargoType.id);
					endif;
					
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			endif;
//RFF
		elseif msgHelper.currentTag = "RFF" then
			msgHelper.setNextField;
			if msgHelper.currentSubItem = "VON" then
				if group = 1 then
					if container &lt;&gt; null then
						tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
					endif;
				endif;
			elseif msgHelper.currentSubItem = "BM" then
				if group = 2 then
					msgHelper.setNextSubItem;
					code := msgHelper.currentMessage;
					code := msgHelper.currentField;
					code := msgHelper.currentSubItem;
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			elseif msgHelper.currentSubItem = "ET" then
				if group = 2 then
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
				endif;
			endif;
//RNG
		elseif msgHelper.currentTag = "RNG" then
			if group = 2 then
				msgHelper.setNextField;
				if msgHelper.currentField = "4" then
					msgHelper.setNextField;
					rngType := msgHelper.currentField;
					msgHelper.setNextSubItem;
					tmpMin := msgHelper.currentSubItem.asEDIReal();
					msgHelper.setNextSubItem;
					tmpMax := msgHelper.currentSubItem.asEDIReal();
			//		tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";	//16 Mar 2021	NDL	TFS 50940
					if rngType[1:3] = "CEL" then
						if container.temperature = NULL_TEMPERATURE then
							container.temperature := tmpMin;
						endif;
						tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
					elseif rngType[1:3] = "FAH" then
						if container.temperature = NULL_TEMPERATURE then
							container.temperature := app.temperatureConversion(false,tmpMin);
						endif;
						tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
					endif;
				endif;
			endif;
//SEL
		elseif msgHelper.currentTag = "SEL" then
			if group = 2 then
				msgHelper.setNextField;
				container.sealNum := msgHelper.currentField;
			endif;
//TDT
		elseif msgHelper.currentTag = self.TDT then 
			msgHelper.setNextField;
			if msgHelper.currentField = "20" then
				if group = 0 then
					group := 1;
					// Note: We are no longer worried about the code for ccms 1049 and PAR 11149 above.
					// Note: We might not use all of the returned strings but this is a standard method for TDT+20.
					self.getVoyageDetailsFromTDT(	msgHelper,
													voyageCode,
													operatorVoyageCode,
													operatorVoyage,
													vesselName,
													lloydsNumber,
													callSign );
					
					// Because some of Nelson's clients (ANL and COS) in particular do not send
					// through the mandatory UNB record the operator is not getting set up.
					// To cater for this we will use the first valid TDT+20 operator
					// if and only if the operator is not already set up. - see PAR 25093
					if operatorSender = null then
						operatorSender		:= operatorVoyage;
						operatorSenderCode	:= operatorVoyageCode;
					endif;
					
					voyageCode	:= self.getXlationOperatorVoyageCode(	operatorSender,
																		operatorVoyage,
																		voyageCode,
																		vesselName,
																		lloydsNumber,
																		callSign );
					ediDataBayPlan.setOperator( operatorSender );
					ediDataBayPlan.shipperCode	:= operatorSenderCode;
					ediDataBayPlan.voyageCode	:= voyageCode;
					ediDataBayPlan.vesselName	:= vesselName; 
				endif;
			endif;
//TMP
		elseif msgHelper.currentTag = "TMP" then
			if group = 2 then
				msgHelper.setNextField;
				if msgHelper.currentField = "2" then
					msgHelper.setNextField;
					temperature := msgHelper.currentSubItem.asEDIReal();
					msgHelper.setNextSubItem;
					tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";
					if msgHelper.currentSubItem = "CEL" then
						container.temperature := temperature;
					//	tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";	//16 Feb 2021	NDL	TFS 50806 NDL - remove extra line
					elseif msgHelper.currentSubItem = "FAH" then
						container.temperature := app.temperatureConversion(false,temperature);
					//	tmpRawEDIData := tmpRawEDIData &amp; CrLf &amp; msgHelper.currentMessage &amp; "'";	//16 Feb 2021	NDL	TFS 50806 NDL - remove extra line
					endif;
				endif;
			endif;

//UNA

//UNB
		elseif msgHelper.currentTag = "UNB" then

			msgHelper.setNextField;
			msgHelper.setNextField;
			rawSenderCode := msgHelper.currentSubItem;
			ediDataBayPlan.fromPort := msgHelper.currentSubItem[1:10];
			msgHelper.setNextField;
			recipientCode := msgHelper.currentSubItem;
			ediDataBayPlan.toPort := msgHelper.currentSubItem[1:10];
			msgHelper.setNextField;
			tmpStr := msgHelper.currentField[1:11];
			tmpStr := tmpStr.removeString(":");
			ediDataBayPlan.sendTime := tmpStr.getEDITimeStamp;
			creationTS := ediDataBayPlan.sendTime;
			msgHelper.setNextField;
			sequence := msgHelper.currentSubItem;
			msgHelper.setNextField;
			msgHelper.setNextField;
			msgHelper.setNextField;
			msgHelper.setNextField;
			msgHelper.setNextField;
			operatorSenderCode := msgHelper.currentSubItem; 
			_ediFile.ediData.operatorCode  := app.myRoot.getXlationSystemOperatorCode(operatorSender, operatorSenderCode, foundMatch)[1:4];
			operatorSender := app.myRoot.allOperators[_ediFile.ediData.operatorCode];
			if operatorSender = null then
				operatorSenderCode := null;
				_ediFile.ediData.operatorCode := null;
			endif;
			_ediFile.ediData.CM_EDIDataBayPlan.shipperCode := _ediFile.ediData.operatorCode;

//UNH
		elseif msgHelper.currentTag = "UNH" then
			self.getUNHData(_ediFile.ediData, msgHelper, fileType, version);
			if _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE and
			   not self.processSenderRecipientSeq(rawSenderCode, recipientCode, fileType, version, _ediFile.ediData.fileName, creationTS, sequence, _ediFile.ediData, passport.myTerminal) then
				ediDataBayPlan.status := CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE;
			endif;
//UNT
		elseif msgHelper.currentTag = "UNT" then
			if container &lt;&gt; null then //first time through
				container.rawEDIData := tmpRawEDIData; //do the last record 
				self.updateChildFlatRacks(container);						// TFS 50553
			endif;
			group := 0;
			msgHelper.setNextField;
		endif;
	endforeach;

	if showProgress then
		passport.myCMIFMonitor.updateProgress("Processing file", numMsgs, msgCount);
	endif;

	// 29 Oct 2018	jlgrs1	TFS 38414 Remain on Board defaults
	if terminal.getConfig(EDIBaplieROBReplaceDef).Boolean then
		self.loadROBDefaults(ediDataBayPlan);
	endif;
epilog
	delete msgHelper;
	delete dischargePorts;
	delete theLines;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
