    <JadeMethod name="addToolbarControls" id="3b83d694-f595-48bb-99ba-172670814784">
        <updating/>
        <source>addToolbarControls() updating, protected;
// -------------------------------------------
// Created 09 September 2003 by cnwdvb1
// -------------------------------------------
vars
	toolbarObj	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbarObj	:=	self.frmToolbar;
	toolbarObj.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
end;</source>
        <access>protected</access>
    </JadeMethod>
