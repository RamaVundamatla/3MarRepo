    <JadeMethod name="displayDirectorCargo" id="b32047ca-ada4-47cd-ab96-647ded92f43f">
        <source>displayDirectorCargo();
/*

Date		Who		Reason
21 August 2014	cnwer1	Initial creation PAR

*/

vars
	ti : CM_TrackedItem;
	ct : CM_CargoType;
	margin : Integer;
	amount : String;
begin
	if self.tblDirector.row &lt;= self.tblDirector.fixedRows then
		return;
	endif;
	
	ti:=self.tblDirector.accessedRow.itemObject.CM_TrackedItem;
	
	ct:=ti.myCargoType;
	margin:=20;
	
	if ct.isBreakBulkMulti or ct.isBulkMulti then
		self.lbDirAmount.visible:=true;
		
		self.txtDirQuantity.visible:=ct.isBreakBulkMulti;
		
		self.tblDirWeight.visible:=ct.isBulkMulti;
		if self.tblDirWeight.visible then
			if ct.isTrackByWeight then
				self.tblDirWeight.setup(Type_Weight,self.backColor);
			else
				self.tblDirWeight.setup(Type_Volume,self.backColor);
			endif;
			
			self.tblDirWeight.setValues( ct.getBulkTrackByDisplayForWeight(ti.totalWeight,ti.getDensity,true));
		endif;
		
		if self.txtDirQuantity.visible then
			self.txtDirQuantity.text:=ti.totalQuantity.asStringJMT;
		endif;
		
		self.tblDirector.height:= self.frmDirector.clientHeight - self.frmTopDirector.clientHeight - self.lbDirAmount.clientHeight - (self.btnPickupDir.clientHeight + (margin* 2));
		self.lbDirAmount.top:=self.tblDirector.top + self.tblDirector.clientHeight + margin;
		self.tblDirWeight.top:=self.lbDirAmount.top;
		self.txtDirQuantity.top:=self.lbDirAmount.top;
	else
		if not self.lbDirAmount.visible then
			return;
		endif;
		self.lbDirAmount.visible:=false;
		self.txtDirQuantity.visible:=false;
		self.tblDirWeight.visible:=false;
		self.tblDirector.height:= self.frmDirector.clientHeight - self.frmTopDirector.clientHeight - (self.btnPickupDir.clientHeight + (margin* 2));
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayWorkingTask" id="31e24fef-7a1a-4bca-b54e-ef70e343001f">
        <source>displayWorkingTask();
/*

Date		Who		Reason
07 August 2014	cnwer1	Initial creation PAR
16 Nov    2015  cnwma1	PAR #363825 Error 4 when picking up a container from Rail
*/

vars
	dtoRTQueueEntry : DTO_RTQueueEntry;
	rtQueueEntry : CM_RTQueueEntry;
	task : CM_RTQueueTask;
	amountLeftToMove : String;
	ct : CM_CargoType;
	objEdition      : Integer;
	invalidObj : Boolean;
begin

	
	self.btnPickup.visible:=false;
	self.btnReject.visible:=false;
	self.btnSetdown.visible:=false;
	self.frmTaskDetails.visible:=false;
	self.txtTarget.visible:=false;
	self.lblTaskTarget.visible:=true;
	self.lblAmount.visible:=false;
	self.txtQuantity.visible:=false;
	self.tblWeight.visible:=false;
	if self.tblWorkingTasks.row &lt;= self.tblWorkingTasks.fixedRows then
		return;
	endif;
	
	dtoRTQueueEntry:=self.tblWorkingTasks.accessedRow.itemObject.DTO_RTQueueEntry;
	
	on Exception do app.handleDeletedObject( exception, dtoRTQueueEntry, invalidObj);   // 16/11/2015 cnwma1 PAR #36825
	objEdition := dtoRTQueueEntry.edition;								
	if invalidObj then
		return;
	endif;
	
	if dtoRTQueueEntry = null then
		return;
	endif;
	self.frmTaskDetails.visible:=true;
	
	
	self.lblTaskCargo.caption:=dtoRTQueueEntry.containerID;
	self.lblTaskSource.caption:=dtoRTQueueEntry.getLocationSourceExtra();
	self.lblTaskTarget.caption:=dtoRTQueueEntry.getLocationTargetString();
	
	rtQueueEntry:= dtoRTQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
	if rtQueueEntry &lt;&gt; null then
		
		task := rtQueueEntry.getDirectorOrPickupTask();
	endif;
	

	if task &lt;&gt; null then
		if task.isPickUp and task.status &lt;&gt; TASK_COMPLETE then
			if rtQueueEntry.myBreakBulkMaster &lt;&gt; null then
				self.lblAmount.visible:=true;
				amountLeftToMove:=rtQueueEntry.getAmountLeftToMoveDisplay;
				if rtQueueEntry.isBulkMove then
					ct:= rtQueueEntry.getCargoType;
					if ct &lt;&gt; null then
						if ct.isTrackByWeight then
							self.tblWeight.setup(Type_Weight,self.backColor);
						else
							self.tblWeight.setup(Type_Volume,self.backColor);
						endif;
					endif;
					self.tblWeight.visible:=true;
					self.tblWeight.setValues(amountLeftToMove);
				else
					self.txtQuantity.visible:=true;
					self.txtQuantity.text:=amountLeftToMove;
				endif;	
			endif;
			self.btnPickup.visible:=true;
			self.btnReject.visible:=true;
			self.btnPickup.caption:=app.getErrorString(Pickup);
		elseif task.taskType = TASK_DIRECTOR and task.status &lt;&gt; TASK_COMPLETE then
			self.btnReject.visible:=true;
			self.btnPickup.visible:=true;
			self.btnPickup.caption:="Cargo";
		else
			task := rtQueueEntry.getDirectorOrSetDownTask();
			if task &lt;&gt; null and task.isSetDown and task.status &lt;&gt; TASK_COMPLETE then
				self.btnSetdown.visible:=true;
				self.txtTarget.visible:=app.myVMAgent.canChangeTargetLocation;
				self.txtTarget.text:=dtoRTQueueEntry.getLocationTargetString();
				if task.targetLocation = null then
					self.txtTarget.text:=null;
				endif;
				self.lblTaskTarget.visible:=not self.txtTarget.visible;
			endif;
		endif;
	endif;
	
	if self.lblAmount.visible then
		self.btnPickup.top:=self.lblAmount.top + self.lblAmount.clientHeight + 5;
	else
		self.btnPickup.top:=self.lblTarget.top + self.lblTarget.clientHeight + 5;
	endif;
	
		
	self.btnSetdown.top:=self.btnPickup.top;
	self.btnReject.top:=self.btnPickup.top;
		
		
	if task.ti &lt;&gt; null then
		if app.myMobileAgent &lt;&gt; null then
			app.myMobileAgent.setMySelectedTI(task.ti);
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
