    <JadeMethod name="setHarbourCombos" id="d74ccc32-9187-4087-9347-9786850d385d">
        <updating/>
        <source>setHarbourCombos()updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
begin
	if (not app.myRoot.allHarbours.isEmpty) then
		self.myHarbour := app.myRoot.allHarbours.first();
	else
		self.myHarbour := null;
	endif;
	
	self.myAssistant.comboBoxHMSHarbour(self.cmbFiltHarbour, self.myHarbour);
	self.myAssistant.comboBoxHMSHarbour(self.cmbHarbour, null);

	self.mulSelect1.setAvailable(null, true);
	self.mulSelect2.setAvailable(null, true);
end;</source>
