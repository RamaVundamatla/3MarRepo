    <JadeMethod name="setLeftToRightRatio" id="0fbe41c4-f85f-4ea3-b7f4-021a400d09bb">
        <updating/>
        <source>setLeftToRightRatio(value : Integer) updating;
//Purpose:		Update the ratio (in percent) that the left control uses of the parent
//				control width
begin
	if value &lt;&gt; self.leftToRightRatio then
		self.leftToRightRatio	:=	value;
		self.resizeChildrenAndSplitter(false);
	endif;
end;</source>
        <Parameter name="value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupChildControls" id="0fd6fb3d-35a5-4734-af66-ce0a4ab25ab4">
        <updating/>
        <source>setupChildControls() updating;
// Purpose:	Setup the left and right child controls the children of the receiver, and
//			setup the starting ratio to reflect the painted ratios of the visible child 
//			controls.
//
// Note:	The container control only supports two child controls.
vars
	controlObj		: Control;
	controlIndex	: Integer;
	totalSize		: Real;
	errorMessage	: String;

begin
	// First delete any existing splitter bars
	if self.myVerticalSplitter &lt;&gt; null then
		delete self.myVerticalSplitter;
	endif;

	if self.myHorizontalSplitter &lt;&gt; null then
		delete self.myHorizontalSplitter;
	endif;

	// Forget existing controls
	self.myLeftControl	:=	null;
	self.myRightControl	:=	null;

	// Look through the controls of the form for children of self
	foreach controlIndex in 1 to self.form.controlCount do
		controlObj := self.form.controls(controlIndex);
		
		if controlObj.isKindOf(ScrollBar) or
			controlObj.isKindOf(CnEcVerticalSplitter) or
			controlObj.isKindOf(CnEcHorizontalSplitter) then
			continue;
		endif;

		if (not controlObj.isKindOf(ScrollBar)) then		// ignore scroll bars
			if controlObj.parent = self then
				if self.myLeftControl = null then
		    		self.myLeftControl := controlObj;
		    	else
		    		if self.myRightControl = null then
			    		if (not self.isSplitHorizontal)
			    		and (controlObj.left &gt; self.myLeftControl.left)
			    		or self.isSplitHorizontal
			    		and (controlObj.top &gt; myLeftControl.top)
			    		then
			    			self.myRightControl	:=	controlObj;
			    		else
			    			self.myRightControl	:=	self.myLeftControl;
			    			self.myLeftControl	:=	controlObj;
			    		endif;
					else
						errorMessage	:=	self.class().name &amp; '::' &amp; method.name &amp;
											"  Error&gt;&gt; you can only have 2 child controls.";
						app.msgBox(errorMessage, $CNEC_ERROR, MsgBox_OK_Only);
					endif;
				endif;
			endif;
	 	endif;
	endforeach;

	if self.myRightControl = null then
		//JASFormException.raise_(6, "JASSplitContainer must have 2 child controls");
		// write self.class().name &amp; '::' &amp; method.name &amp; '  Error&gt;&gt; you must have 2 child controls';
		// return added to avoid null object ref if cloning at run time (RJS 7Feb01)
		return;
	endif;

	if self.myLeftControl.visible and self.myRightControl.visible then
		// Setup the ratios of the children based on their current widths/heights if not
		//  defined in Painter
	 	if self.leftToRightRatio = 0 then
	 		if self.isSplitHorizontal then
	 			totalSize				:=	self.myLeftControl.height + self.myRightControl.height;
				self.leftToRightRatio	:=	(self.myLeftControl.height / totalSize * 100).Integer;
 			else
				totalSize				:=	self.myLeftControl.width + self.myRightControl.width;
				self.leftToRightRatio	:=	(self.myLeftControl.width / totalSize * 100).Integer;
			endif;
 		endif;
 	else
 		if self.myLeftControl.visible then
 			self.leftToRightRatio	:=	100;
 		else
			self.leftToRightRatio	:=	0;
		endif;
	endif;
	
	// Following was moved from windowCreated to allow for control to be cloned at runtime (RJS 7Feb01).
	if (self.myLeftControl &lt;&gt; null)
	and self.myLeftControl.visible
	and (self.myRightControl &lt;&gt; null)
	and self.myRightControl.visible
	then
		self.initializeSplitter();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showLeftControl" id="fc9cb020-cff2-4f18-b7d0-b8bbc06c5766">
        <updating/>
        <source>showLeftControl(pRatio : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     14 November 2000 by cnwrs2
//
// Purpose:     Make visible the reciever's left-hand control and spliter bar.
//
// Parameters:  pRatio - The ratio (in percent) that the left control uses of
//					the parent control's width.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible	:=	true;
	else
		self.myVerticalSplitter.visible		:=	true;
	endif;

	self.myLeftControl.visible	:=	true;

	self.setLeftToRightRatio(pRatio);
end;</source>
        <Parameter name="pRatio" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showRightControl" id="f7202adc-1c3c-434e-ae34-c46551fb1290">
        <updating/>
        <source>showRightControl(pRatio : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     Make visible the reciever's right-hand control and spliter bar.
//
// Parameters:  pRatio - The ratio (in percent) that the right control uses of
//					the parent control's width.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.isSplitHorizontal then
		self.myHorizontalSplitter.visible	:=	true;
	else
		self.myVerticalSplitter.visible		:=	true;
	endif;

	self.myRightControl.visible	:=	true;
	self.setLeftToRightRatio(100 - pRatio);
end;</source>
        <Parameter name="pRatio" type="Integer"/>
    </JadeMethod>
    <ExternalMethod name="splitterMove" id="5bfe038f-6581-45e6-9356-1cc8949fe421">
        <updating/>
        <entrypoint>CallControlEvent</entrypoint>
        <library name="jadpmap"/>
        <source>splitterMove(pSplitContainer: CnEcSplitContainer input) is "CallControlEvent" in "jadpmap" updating, number = 1018;</source>
        <Parameter name="pSplitContainer" type="CnEcSplitContainer" usage="input"/>
    </ExternalMethod>
    <JadeMethod name="stretchHeight" id="fb2726cc-077f-4c60-82cd-3d6c47814300">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>stretchHeight(set: Boolean; _value: Boolean io) mapping, updating;

begin
	if set and _value then
		if self.lockBottom then
			self.lockBottom	:=	false;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="stretchWidth" id="e1d06b37-49ad-46d4-ae16-c64560943241">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>stretchWidth(set: Boolean; _value: Boolean io) mapping, updating;

begin
    if set and _value then
    	if self.lockRight then
    		self.lockRight	:=	false;
    	endif;
   	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="163f7c9d-7f0b-468b-bd12-b9d78ca3b2a4">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/02/2003	cnwdad1		Changed from setting background color with a global
//							constant to use the getSystemColor() method.
// ---------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);

	if self.isInPainter then
		self.borderStyle	:=	Window.BorderStyle_Single;
	else	
		self.borderStyle	:=	Window.BorderStyle_None;
		self.setupChildControls;
// Moved to setupChildControls to allow for control to be cloned at runtime (RJS 7Feb01).
//		if (myLeftControl &lt;&gt; null) and myLeftControl.visible and (myRightControl &lt;&gt; null) and myRightControl.visible then
//			self.initializeSplitter;
//		endif;
		self.resizeChildrenAndSplitter(false);
	endif;

	self.transparent	:=	false;
// cnwdad1 16/10/2002 - Changed to use 3D Face color for the background.
//	self.backColor		:=	Gray;
//	self.backColor		:=	Window.Color_3DFace + CNEC_SYSTEM_COLOUR;		// cnwdad1 28/02/2003.
	self.backColor		:=	self.getSystemColor(Window.Color_3DFace);		// cnwdad1 28/02/2003.
	
	if self.lockRight or self.stretchWidth then
 		self.distanceFromRight := persistCntrl.parent.width - persistCntrl.width - persistCntrl.left;
 	endif;

	if self.lockBottom or self.stretchHeight then
		self.distanceFromBottom := persistCntrl.parent.height - persistCntrl.height - persistCntrl.top;
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
