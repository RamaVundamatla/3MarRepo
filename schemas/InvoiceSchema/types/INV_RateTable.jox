    <JadeMethod name="keyDown" id="8edc9533-ee6a-45dd-b0a6-38791d8d660b">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 05 April 2006
//
//********************************************************************
vars

begin
	inheritMethod(keyCode, shift);
	if keyCode = CMUI_Key_F11 then
		self.doEditItem();
	elseif keyCode = CMUI_Key_F8 then	// 24052
		self.showHistoryForm(true);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadRateTableByColumnBerths" id="ae372484-1081-4626-aaf6-b393a07b47a8">
        <source>loadRateTableByColumnBerths(_berth : HMS_Berth; 
							_company : CM_Bank; 
							_level : Integer; 
							_rateTable : Table io; 
							_col : Integer io; 
							_timeStamp : TimeStamp; 
							_progress : CMS_Progress io	);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
//
vars
	obj	: Object;
	service : CM_Service;
	i,j : Integer;
	rateEntry : CM_RateEntry;
	rate : Real;
	tmpNode	: CM_DebtorNode;
	dpl : Integer;
	symbol : Character;
	berthName: String;
	
begin
	_rateTable.column := _col;
	_rateTable.row := 1;
	_rateTable.accessColumn(_col).itemObject := _berth;
	
	berthName := self.displayBerth(_berth);
	_rateTable.row := 1;
	_rateTable.text := berthName;
	j := _rateTable.fixedRows;
	_progress.setAction("Getting rates for berth: " &amp; berthName);
	_progress.progress.partsDone := _col - 1;
	_progress.doWindowEvents(0);
	
	// TFS 36954 MPD 20 Feb 2018
	dpl := self.getRateEntryDecimalPlaces;
	symbol := app.myRoot.getInvoiceCurrencySymbol.Character;

	foreach obj in self.allSelectedBerthServices do
		service := obj.CM_Service;
		j := j + 1;
		_rateTable.row := j;
		rateEntry := _berth.getBerthServiceTimeRate(service, _timeStamp);
		if rateEntry &lt;&gt; null then
			rate := rateEntry.getDerivedCostPerUnit(self.effectiveDate.TimeStamp);
			if rate = 0.0 then
				// leave blank
			else
				_rateTable.text := symbol &amp; rate.asStringJMTWithPrecision(dpl, false);
			endif;
			
			_rateTable.accessCell(j, _col).itemObject := rateEntry;
			if rateEntry.rate.CM_BerthRate.myBerth = _berth then
				_rateTable.accessedCell.fontBold := true;
			else
				_rateTable.accessedCell.fontBold := false;
			endif;
		endif;
	endforeach;
	
	_progress.doWindowEvents(0);

epilog

end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_company" type="CM_Bank"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_rateTable" type="Table" usage="io"/>
        <Parameter name="_col" type="Integer" usage="io"/>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <Parameter name="_progress" type="CMS_Progress" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadRateTableByColumnDebtor" id="f660d7ee-4794-4ccc-ae99-9a84b9177ea6">
        <source>loadRateTableByColumnDebtor(_debtor : CM_DebtorNode; company : CM_Bank; startDepth: Integer; rt : Table io; col : Integer io; ts : TimeStamp; pd : CMS_Progress io);

vars
	obj	: Object;
	service : CM_Service;
	i,j : Integer;
	rateEntry : CM_RateEntry;
	rate:       Real;
	tmpNode		: CM_DebtorNode;
	dpl : Integer;
	symbol : Character;
begin

	rt.column := col;
	rt.row := 1;
	rt.accessColumn(col).itemObject := _debtor;

	rt.row := startDepth;
	rt.text := _debtor.getListName();
	j := rt.fixedRows;
	pd.setAction("Getting rates for debtor: " &amp; _debtor.name);
	pd.progress.partsDone := col - 1;
	pd.doWindowEvents(0);
	
	// TFS 36954 MPD 20 Feb 2018
	dpl := self.getRateEntryDecimalPlaces;
	symbol := app.myRoot.getInvoiceCurrencySymbol.Character;

	// 24052 multi-select services
	foreach obj in self.allSelectedServices do
		service := obj.CM_Service;
		j := j + 1;
		rt.row := j;
		rateEntry := _debtor.getServiceTimeRate(service, ts);
		if rateEntry &lt;&gt; null then
			rate := rateEntry.getDerivedCostPerUnit(self.effectiveDate.TimeStamp);
			if rate = 0.0 then
				// leave blank
			else
				//rt.text := rate.userCurrencyFormat($CM_RateMoney);
				rt.text := symbol &amp; rate.asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
			endif;
			
			rt.accessCell(j,col).itemObject := rateEntry;
			if rateEntry.rate.CM_DebtorRate.debtorNode = _debtor then
				rt.accessedCell.fontBold := true;
			else
				rt.accessedCell.fontBold := false;
			endif;
			
		endif;
	endforeach;
	pd.doWindowEvents(0);

	// don't show the children of the Root debtor, so that the default rates can be shown alone, plus any selected debtors for comparison
	if  not _debtor.isRootDebtorGroup then
		foreach tmpNode in _debtor.allChildDebtorNodes do
			col := col + 1;
			self.loadRateTableByColumnDebtor(tmpNode, company, startDepth + 1, rt, col, ts, pd);
			pd.doWindowEvents(0);
		endforeach;
	endif;

end;</source>
        <Parameter name="_debtor" type="CM_DebtorNode"/>
        <Parameter name="company" type="CM_Bank"/>
        <Parameter name="startDepth" type="Integer"/>
        <Parameter name="rt" type="Table" usage="io"/>
