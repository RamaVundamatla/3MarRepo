    <JadeMethod name="trxCreateCargoGroup" id="7e189e5a-8dfc-4e6b-8b64-f64d0af791c4">
        <updating/>
        <source>trxCreateCargoGroup(	_proxy : CM_TrackedItem input;
						_realTI : CM_TrackedItem output;
						_passport : CM_Passport input
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars
	terminal		: CM_Terminal;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	terminal := _proxy.CM_CargoGroup.myCargoGroupTerminal;
	
	self.exclusiveLock(terminal.allCargoGroupsByCargoTypeId);
	self.exclusiveLock(terminal.allCargoGroupsByIdCargoType);		

	// Start the transaction
	beginTransaction;

	app.myUtilityCA.utlCreateTrackedItem(_proxy, _realTI, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_proxy" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateCargoGroupDetails" id="15482a8f-6be4-44be-8d4e-c5e5250be087">
        <updating/>
        <source>trxCreateCargoGroupDetails(_controller : CMIF_CargoGroupDtlController; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2022	navam1	Initial creation
//TFS 53390
11 Apr 2025	navhl20 CR MTN-34569: MTN - Enable Deferred update for events Cargo Group TRX.
*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.useEventDeferUpdate		  := true;			//11.04.2025 navhl20 #34569	

	app.setContinueCMExceptions(true);
	// Start the transaction
	beginTransaction;
	
	app.myUtilityCA.utlCreateCargoGroupDetails(_controller, _passport);
	
	if _passport.noErrors then								//11.04.2025 navhl20 #34569
		_passport.doDeferredUpdates();
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_controller" type="CMIF_CargoGroupDtlController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
