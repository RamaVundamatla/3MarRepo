    <JadeMethod name="doCheckForDataBaseChanges" id="d3b75cfd-83d9-4291-a5a0-e1131f683a32">
        <updating/>
        <source>doCheckForDataBaseChanges() updating, protected;

vars
	classObj		: Class;
	classCollObj	: ClassColl;
	baseRootObj		: CnEcBaseRoot;
	
begin
	classCollObj	:=	app.myCnEcXmlSchema.allClasses();
	baseRootObj		:=	app.myBaseRoot;
			
	if baseRootObj.getAllXmlExcludedClasses() &lt;&gt; null then
		foreach classObj in classCollObj do
			if not baseRootObj.getAllXmlExcludedClasses().includes(classObj.name) then
				if classObj.creationTime() &gt; baseRootObj.xmlDefaultFormatLastRebuilt then
					self.doRebuild();
					break;
				endif;
			endif; 
		endforeach;
	endif;
epilog
	delete classCollObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormActivate" id="dce6d2ff-21e4-4d1d-9f3c-a6b20eedcc6e">
        <updating/>
        <source>doFormActivate()updating, protected;

begin
	if self.aIsRebuildDefFormatsRequired then
		self.doRebuild();
	endif; 
end;</source>
        <access>protected</access>
    </JadeMethod>
