    <JadeMethod name="btnAddItems_click" id="9d5f1f78-521b-4049-9437-de248d773443">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddItems_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2023 navmv20 CR 58233 Task 58236: UI - Add Item

*/

vars
	form   : CMUI_CargoSearchFormModal;
	ti 	   : CM_TrackedItem;
	object : Object;
begin
	form := app.loadForm(CMUI_CargoSearchFormModal, 
							CMUI_Assistant, 
							false, 
							false,
							true, 
							self.myTerminal,
							null).CMUI_CargoSearchFormModal;	

	if form = null then
		return;
	endif;
	
	object := self.cmbCurrentOperator.listObject;
	if object &lt;&gt; null then
		form.setMyOperator(object.CM_Operator);
	endif;
	
	form.setColumnsAndControlWidth(3, 175);
	form.setParentForm(self);
	form.showModal();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
