    <JadeMethod name="setProxyObject" id="72d4e295-59c4-4982-a4eb-7385dbd8a0cd">
        <updating/>
        <source>setProxyObject(_any : Any) updating;
/*

Purpose:			
	Mapping 
	MTN : CM_Job
	N4  : xps_craneshift
Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022	navra1 	TFS53028 	
*/

vars
	helper 	: CMIF_XpsCraneshift;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);

	self.tableName		:= helper.tableName;
	self.gkey			:= helper.gkey;
	self.owner_pow		:= helper.owner_pow;
	self.owner_pow_gkey := helper.owner_pow_gkey;
	self.pkey 			:= helper.pkey;
	self.visit			:= helper.visit;
	
epilog
	delete helper;
	delete ewsOpsView;
end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
</Class>
