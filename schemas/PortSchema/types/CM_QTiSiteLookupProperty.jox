    <JadeMethod name="getValueForObject" id="26a700c5-1a6d-4703-b965-957acf978a27">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/10/2017	jlgdap1		Initial creation TFS 7523 SNO Selector and Notified items
//
vars

begin
	if _obj.isKindOf(CM_TrackedItem) and _obj.CM_TrackedItem.isPreNote then
		return SEL_QUERYSITE_NOTIFIED;
	endif;
	
	return inheritMethod(_obj, _op);

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
