    <JadeMethod name="setForCreateController" id="11c4ce2c-b494-40a2-922e-e033202ffb1c">
        <updating/>
        <source>setForCreateController(_theController : CMIF_InvoiceLineDescDebtor) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

