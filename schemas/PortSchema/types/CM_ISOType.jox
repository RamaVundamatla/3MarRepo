    <JadeMethod name="isSameGroup" id="084f2227-7279-4429-b66c-b83f546f251d">
        <source>isSameGroup(isoToCompareTo : CM_ISOType): Boolean;
//Returns true if the passed in isoType has the same group ref.
vars

begin
	if isoToCompareTo = self then
		return true;
	endif;
	if isoToCompareTo = null then
		return false;
	endif;
	if self.myISOTypeGroup &lt;&gt; isoToCompareTo.myISOTypeGroup then
		return false;
	endif;
	//-------------
	//Groups are the same
	//-------------
	return true;

end;</source>
        <Parameter name="isoToCompareTo" type="CM_ISOType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSameHeight" id="e1e6fa2c-1dc7-4c04-be56-57d112f921d6">
        <source>isSameHeight(isoToCompareTo : CM_ISOType): Boolean;
// ---------------------------------------------------------------------------
// Created:		17 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if isoToCompareTo = null then
		return true;
	endif;
	if isoToCompareTo = self then // PAR 15332
		return true;
	endif;
	
	if isoToCompareTo.is4ft3High and self.is4ft3High then
		return true;
	endif;
	if isoToCompareTo.is4ftHigh and self.is4ftHigh then
		return true;
	endif;
	if isoToCompareTo.is8ft6High and self.is8ft6High then
		return true;
	endif;
	if isoToCompareTo.is8ftHigh and self.is8ftHigh then
		return true;
	endif;
	if isoToCompareTo.is9ft6High and self.is9ft6High then
		return true;
	endif;
	
	
	
	return false;
end;</source>
        <Parameter name="isoToCompareTo" type="CM_ISOType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSimilarISOType" id="12cc1c87-db03-4055-818a-d411db6c51c7">
        <source>isSimilarISOType(isoToCompareTo : CM_ISOType): Boolean;
//When passed an isoType instance, compares to see if its similar.
//Used to determine if isoTypes have similar properties
//for requests for TI's...
vars
begin
	if isoToCompareTo = null then
		return false;
	endif;
	if isoToCompareTo = self then
		return true;
	endif;
	if self.myCargoType &lt;&gt; isoToCompareTo.myCargoType then
		return false;
	endif;
	if self.typeAttributes &lt;&gt; isoToCompareTo.typeAttributes then
		return false;
	endif;
	if self.sizeAttributes &lt;&gt; isoToCompareTo.sizeAttributes then
		return false;
	endif;
	//-------------
	//Types are exactly the same
	//-------------
	return true;
end;</source>
        <Parameter name="isoToCompareTo" type="CM_ISOType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTank" id="1bb7a54d-0cfd-446c-85c6-13c2938da8d7">
        <source>isTank(): Boolean;

begin
	return typeAttributes.bitAnd(ISO_TANK) &lt;&gt; 0;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTypeOK" id="c3f5e20c-ee0d-4fb6-a393-09a5cb12f64d">
        <source>isTypeOK() : Boolean;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 24 July 2003
//
// Check to ensure types are not conflicting
//
//----------------------------------------------------------

vars

begin
	if self.isPorthole and (self.isIntegral or self.isFantainer or self.isFlat or self.isOpenTop) then
		return false;
	endif;
		
	//could do this in JMTv6 PAR 8071 - removing fantainer from this.  JC 22/04/2004
	//if self.isIntegral and (self.isPorthole or self.isFantainer or self.isFlat) then
	if self.isIntegral and (self.isPorthole or self.isFlat) then
		return false;
	endif;
	
	//could do this in JMTv6 PAR 8071 - removing integral from this.  JC 22/04/2004
	//if self.isFantainer and (self.isPorthole or self.isIntegral or self.isFlat) then
	if self.isFantainer and (self.isPorthole or self.isFlat) then
		return false;
	endif;
	
	if self.isFlat and (self.isPorthole or self.isIntegral or self.isFantainer or self.isOpenTop or self.isReefer) then
		return false;
	endif;
	
	if self.isTank and (self.isPorthole or self.isOpenTop or self.isFlat or self.isOpenTop or self.isFantainer) then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="outputAsCSV" id="85ebc193-b4bb-4d3a-9619-a9b6c0b827ef">
        <source>outputAsCSV(_header : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     02 May 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	Seperator	= ',';
vars
	tmpLen,
	tmpHeight	: String;

begin

/*
JadeScript to output
vars
	f	: File;
	first	: Boolean;
	i	: CM_ISOType;
begin

	create f transient;
	f.fileName := 'c:\tmp\isoTypes.csv';
	
	first := true;
	
	foreach i in CM_ISOType.instances do
		if first then
			f.writeLine(i.outputAsCSV(true));
			first := false;
		endif;
		f.writeLine(i.outputAsCSV(false));
	endforeach;
	

epilog
	f.close;
	delete f;
*/

	if _header then
		return	'Code'.csvFormat() &amp; Seperator &amp;
				'Description'.csvFormat() &amp; Seperator &amp;
				'Cargo Type'.csvFormat() &amp; Seperator &amp;
				'General'.csvFormat() &amp; Seperator &amp;
				'Flat'.csvFormat() &amp; Seperator &amp;
				'Crib'.csvFormat() &amp; Seperator &amp;
				'Tank'.csvFormat() &amp; Seperator &amp;
				'Open Top'.csvFormat() &amp; Seperator &amp;
				'Reefer'.csvFormat() &amp; Seperator &amp;
				'Porthole'.csvFormat() &amp; Seperator &amp;
				'Integral'.csvFormat() &amp; Seperator &amp;
				'Fan'.csvFormat() &amp; Seperator &amp;
				'Length'.csvFormat() &amp; Seperator &amp;
				'Tare Weight (kgs)'.csvFormat() &amp; Seperator &amp;
				'Height'.csvFormat();
	endif;
	
	if self.is40ftLong then
		tmpLen	:= '40';
	elseif self.is45ftLong then
		tmpLen	:= '45';
	elseif self.is30ftLong then
		tmpLen	:= '30';
	elseif self.is53ftLong then
		tmpLen	:= '53';
	elseif self.is20ftLong then
		tmpLen	:= '20';
	else
		tmpLen := null;
	endif;
	
	if self.is4ft3High then
		tmpHeight := '4ft 3in';
	elseif self.is4ftHigh then
		tmpHeight := '4ft';
	elseif self.is8ft6High then
		tmpHeight := '8ft 6in';
	elseif self.is8ftHigh then
		tmpHeight := '8ft';
	elseif self.is9ft6High then
		tmpHeight := '9ft 6in';
	else
		tmpHeight := null;
	endif;
	return	self.code.csvFormat() &amp; Seperator &amp;
			self.description.csvFormat() &amp; Seperator &amp;
			self.myCargoType.description.csvFormat() &amp; Seperator &amp;
			self.isGeneral.String.csvFormat() &amp; Seperator &amp;
			self.isFlat.String.csvFormat() &amp; Seperator &amp;
			self.isCrib.String.csvFormat() &amp; Seperator &amp;
			self.isTank.String.csvFormat() &amp; Seperator &amp;
			self.isOpenTop.String.csvFormat() &amp; Seperator &amp;
			self.isReefer.String.csvFormat() &amp; Seperator &amp;
			self.isPorthole.String.csvFormat() &amp; Seperator &amp;
			self.isIntegral.String.csvFormat() &amp; Seperator &amp;
			self.isFantainer.String.csvFormat() &amp; Seperator &amp;
			tmpLen &amp; Seperator &amp;
			self.tareKilos.String &amp; Seperator &amp;
			tmpHeight.csvFormat();
	
	

end;</source>
        <Parameter name="_header" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="70af9ba0-6a8b-437e-9e4c-51ff2610c8a9">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	tmpISOType : CM_ISOType;
	completedOK		: Boolean;
begin
	tmpISOType := inheritMethod();
	tmpISOType.myCargoType := self.myCargoType;
	tmpISOType.myISOTypeGroup := self.myISOTypeGroup;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpISOType;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpISOType;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="cbb2a998-aaa1-4f41-b14f-528b6693155e">
        <updating/>
        <source>setForCreate(pProxyISOType:CM_ISOType) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	setForUpdate(pProxyISOType);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyISOType" type="CM_ISOType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7b3f751b-69c3-4f24-8fdf-282c5f7571b0">
        <updating/>
        <source>setForUpdate(pProxyISOType:CM_ISOType) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	needsRefresh : Boolean;

begin
	// TFS 1847 cnwjre1 20/04/2016 upper-case ISO code on save to avoid the problem with '22gp' and '22GP' getting
	//		1310 in CM_YATypeISO::getObjects from upperCased code value
	self.code 						:= pProxyISOType.code.trimBlanks.toUpper();
	if self.description &lt;&gt; pProxyISOType.description then	//21 Jun 2019	NDL	TFS 44895
		self.description 			:= pProxyISOType.description.trimBlanks;
		needsRefresh 				:= true;	//21 Jun 2019	NDL	TFS 44895
	endif;
	self.tareKilos					:= pProxyISOType.tareKilos;
	self.colour 					:= pProxyISOType.colour;
	self.myISOTypeGroup 			:= pProxyISOType.myISOTypeGroup;
	self.sizeAttributes 			:= pProxyISOType.sizeAttributes;
	self.myCargoType 				:= pProxyISOType.myCargoType;
	self.typeAttributes 			:= pProxyISOType.typeAttributes;
	self.isNotAvailableForEntry		:= pProxyISOType.isNotAvailableForEntry;
	self.isNotTwinLiftCapable		:= pProxyISOType.isNotTwinLiftCapable;
	// CCMS 1496
	self.maxTotalWeight				:= pProxyISOType.maxTotalWeight;
	self.maxTareWeight				:= pProxyISOType.maxTareWeight;
	
	//21 Jun 2019	NDL	TFS 44895
	if needsRefresh then
		if app.myAlternateDict &lt;&gt; null then
			app.myAlternateDict.setIsoTypeDictNeedsRefresh();
		endif;
	endif;

end;</source>
        <Parameter name="pProxyISOType" type="CM_ISOType"/>
    </JadeMethod>
    <JadeMethod name="setMyISOTypeGroup" id="20193244-be9f-43b6-8162-ae621a5501bf">
        <updating/>
        <source>setMyISOTypeGroup( _isoTypeGroup	:	CM_ISOTypeGroup) updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 01 September 2003
//
//-----------------------------------------------------------------------

vars

begin
	if self.myISOTypeGroup &lt;&gt; _isoTypeGroup then
		self.myISOTypeGroup := _isoTypeGroup;
	endif;
end;</source>
        <Parameter name="_isoTypeGroup" type="CM_ISOTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="43227c3f-fc5d-43dc-9123-27225222c696">
        <updating/>
        <source>setMyRoot() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
