    <JadeMethod name="tCreateDeckItemLayout" id="6c95ec7d-1a3e-4705-84d7-29abd2cef04a">
        <source>tCreateDeckItemLayout();
// cnwmp6
// CNWMC5
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	pxyItemLayout, realItemLayout: CM_DeckItemLayout;
	pointsPolygon : PointArray;
	pxyLayout : CM_DeckLayerLayout;
	pxyDeckLayout : CM_DeckLayout;
begin
	// ## PROXY
	create pointsPolygon transient;
	create pxyDeckLayout transient;
	// ## PROXY
	create pxyLayout transient;
	pxyLayout.setProxy("Layer 1", "Layer One", null, pxyDeckLayout, true,ROROLayerType_Structure);

	create pxyItemLayout transient;
	pxyItemLayout.setDefaultOutline4(0,0, 100, 100,pointsPolygon);

	pxyItemLayout.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,"UT_NEW", pxyLayout, Black, Frame.DrawFillStyle_Transparent, 1, true, DeckItemLayoutType_Graphic);
	
	// ## CREATE
	app.myTrxCA.trxCreateDeckItemLayout(pxyItemLayout, realItemLayout, pxyLayout, app.myPassport); 
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realItemLayout, " realItemLayout ");

	// ## DELETE
	app.myTrxDA.trxDeleteDeckItemLayout(realItemLayout, app.myPassport); 
	self.assertNoTrxErrorsOrWarnings();
	self.assertIsDeletedMsg(realItemLayout, " realItemLayout "); 
	
epilog
	delete pointsPolygon;
	delete pxyItemLayout;
	delete pxyDeckLayout;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateDeckLayerLayout" id="2f8734c5-e02b-4b42-acfa-08fca1a02db7">
        <source>tCreateDeckLayerLayout();
// cnwmp6
// CNWMC5
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	pxyItemLayout, realItemLayout: CM_DeckLayerLayout;

begin
	// ## PROXY
	create pxyItemLayout transient;
	pxyItemLayout.setProxy("Layer 1", "Layer One", null, null, true,ROROLayerType_Structure);

	// ## CREATE
	app.myTrxCA.trxCreateDeckLayerLayout(pxyItemLayout, realItemLayout, false, app.myPassport); 
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realItemLayout, " realLayerLayout ");

	// ## DELETE
	app.myTrxDA.trxDeleteDeckLayerLayout(realItemLayout, app.myPassport); 
	self.assertNoTrxErrorsOrWarnings();
	self.assertIsDeletedMsg(realItemLayout,"realLayerLayout"); 
	
epilog
	delete pxyItemLayout;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateROROVesselDeck" id="e809bc57-05d5-47b5-b477-733b46086527">
