    <JadeMethod name="hasVoyageStartedPlanning" id="e41ba799-e5a0-4026-b329-2e5f6e3c2725">
        <source>hasVoyageStartedPlanning() : Boolean;
// cnwrs1 june 2006 ccms 1022
vars
	aBayVoyage : CM_BayVoyage;
begin
	if self.myCellularVoyageStructure = null then
		return false;
	endif;
	if not self.allVoyageJobs.isEmpty then
		return true;
	endif;
	foreach aBayVoyage in self.myCellularVoyageStructure.allBayVoyagesByOrdinal do
		if not aBayVoyage.allSlotRequestByMoveType.isEmpty then
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
