    <JadeMethod name="getNumTIOnHOLD" id="3cce67cd-7240-4eb9-8619-c3f92a6fe0d1">
        <source>getNumTIOnHOLD() : Integer;
// ---------------------------------------------------------------------------
// Created:     06 August 2014 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aTI : CM_TrackedItem;
	lc : CM_LocationsController;
	num : Integer;
begin
	foreach aTI in self.allOnshipTIsByCargoTypeId discreteLock do
		lc := aTI.myPrimaryActualLocation;
		if lc &lt;&gt; null then
			if lc.isKindOf(CM_GeneralCargoController) then
				num := num + 1;
			endif;
		endif;
	endforeach;
	
	return num;
epilog

end;</source>
