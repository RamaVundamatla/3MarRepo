    <JadeMethod name="setFormCaption" id="7dda4e35-d404-484a-bcc8-555dbe7c8634">
        <updating/>
        <source>setFormCaption() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 January 2012	cnwndl1	Initial creation	Par 25297

*/

vars

	str : String;
	currentVoyage : CM_Voyage;
	invalidVoyage : Boolean;
	msg : String;

begin

	on Exception do app.handleDeletedObject(exception, currentVoyage, invalidVoyage); //10/10/08 cnwdz2 Par 17732
		
	str := app.getErrorString(SHP_Load_List);

	currentVoyage := self.myCurrentVoyage;
	if currentVoyage &lt;&gt; null then
		str := str &amp; currentVoyage.code &amp; " ";
		if invalidVoyage then		
			return;
		endif;
	endif;

	if fldMain.topSheet = self.shtAll then
		self.btnUserColours.enabled := true;
		if self.newQuery  then
			str:= str &amp; app.getErrorString(LOADLIST_ALL);
		endif;
	elseif fldMain.topSheet = self.shtDLR then
		str := str &amp; app.getErrorString(SHP_DLR_NON_PLANNED);
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblDLR.allSelectedObjects.size.asStringJMT;
	elseif fldMain.topSheet = self.shtTranship then
		str:= str &amp; app.getErrorString(SHP_Tranship_Export_Items);
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblTranShip.allSelectedObjects.size.asStringJMT;
	elseif fldMain.topSheet = self.shtTBA then // TFS 45590
		str:= str &amp; app.getErrorString(TBANONPLANNED);
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblTBA.allSelectedObjects.size.asStringJMT;
	elseif fldMain.topSheet = self.shtNonplanned then
		str := str &amp; app.getErrorString(SHP_NON_PLANNED);
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblData.allSelectedObjects.size.asStringJMT;
	elseif fldMain.topSheet = self.shtPlanned then
		str := str &amp; app.getErrorString(SHP_PLANNED);
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblPlanned.allSelectedObjects.size.asStringJMT;
	elseif fldMain.topSheet = self.shtSummary then
		str := str &amp; app.getErrorString(SHP_SUMMARY);
	endif;
	
	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		msg := self.getFilteredTableList();
		str := str &amp; " - " &amp; app.getErrorString1(Column_filters_applied,msg);
		self.btnQuitSmmryMode.enabled := true;
	endif;
	
	self.setCaption(str); //epr TFS 2362 4/8/16
	self.updateShtCaptions();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVoyage" id="f202e274-d1c1-47f2-b821-1391f8331692">
        <updating/>
        <source>setMyCurrentVoyage(_voyage : CM_Voyage input ; _initVoyage : Boolean) updating;
/*

Date		Who		Reason
04 August 2016	cnwer1	Initial creation TFS 2362

*/

vars
	
begin
	if not _initVoyage and self.myCurrentVoyage = _voyage then
		return;
	endif;
	
	if not _initVoyage and self.myCurrentVoyage &lt;&gt; null then
		self.doNotableRemove( self.myCurrentVoyage);
		self.endNotification( self.myCurrentVoyage,  self.myTerminal.getTerminalEvent(VoyageJob_Create_Event));
		self.endNotification( self.myCurrentVoyage,  self.myTerminal.getTerminalEvent(VoyageJob_Update_Event));
		self.endNotification( self.myCurrentVoyage,  self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event));
		self.endNotification( self.myCurrentVoyage,  self.myTerminal.getTerminalEvent(EVENT_STOP_CARGO_RECEIVAL));
		self.endNotification( self.myCurrentVoyage,  self.myTerminal.getTerminalEvent(EDI_ColourCode_Update));   //epr TFS 5617 23/8/17
		self.endNotification( self.myCurrentVoyage,  self.myTerminal.getTerminalEvent(Event_SlotRequest_Update));
		self.endNotification( self.myCurrentVoyage,  self.myTerminal.getTerminalEvent(Event_SlotRequest_Delete));
		self.endNotification( self.myCurrentVoyage,  self.myTerminal.getTerminalEvent(Event_SlotRequest_Create));
		self.endNotification( self.myCurrentVoyage,  self.myTerminal.getTerminalEvent(EVENT_FULL_PLAN_START));
		self.endNotification( self.myCurrentVoyage,  self.myTerminal.getTerminalEvent(EVENT_FULL_PLAN_STOP));
		self.endNotification( self.myCurrentVoyage,  self.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA));
		
	endif;
	
	
	self.myCurrentVoyage:=_voyage;
	
	if self.myCurrentVoyage &lt;&gt; null then
		if app.getMyCurrentVoyage() &lt;&gt; self.myCurrentVoyage then
			app.setMyCurrentVoyage(self.myCurrentVoyage);
		endif;
	
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Update_Event), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_STOP_CARGO_RECEIVAL), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EDI_ColourCode_Update), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Event_SlotRequest_Update), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Event_SlotRequest_Delete), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Event_SlotRequest_Create), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_FULL_PLAN_START), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_FULL_PLAN_STOP), Response_Continuous, null);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), Response_Continuous, null);
	endif;
	
	
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_initVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSelector" id="956f8b83-a8bb-4c9f-a816-57539919a753">
        <updating/>
        <source>setSelector(_theSelector : CMUI_Selector input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	critLine		: CM_SelectorCriteriaLine;
	taSet			: ObjectSet;

begin
	
	_theSelector.myTerminal := self.myTerminal;
	_theSelector.myEnquiryCollectionClass := CM_TIArray;
	_theSelector.defaultSiteStr := TI_SITE_ONSHIP_str;
	_theSelector.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Container];
	_theSelector.disableMnuEnquiry := false;
	_theSelector.myDefaultVoyage := self.myCurrentVoyage;

end;</source>
        <access>protected</access>
        <Parameter name="_theSelector" type="CMUI_Selector" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="f35a96a1-904d-488a-bb06-f8cd12661785">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	09 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	if not _theTable.allTblDataSortColumns.isEmpty() then
		self.resortTableObjects(_theTable);
	endif;
	//epr par 16713 stop the showing of cargo after each column sorting
	//	self.resetForSummary(); // PAR 11069

	self.progressFinish();					
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c56a8eb8-7cb1-4852-9a45-595637bb7620">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/11/2010	cnwdap1		PAR #26426 Release requests on ship load list - notifications
// ---------------------------------------------------------------------------

vars

begin
	// cnwrl1 236/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	// The user can access the summarise functionality only if they have at least view security role.
	self.bAllowSummaryDefn	:= app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );
	
	self.usesQueryFrame := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.useTableInfo := true;
	self.useTableSorting := true;
	self.getXMLSettingsForSetup();
	
	inheritMethod();

	//epr TFS 2362 4/8/16
	if self.myCurrentVoyage &lt;&gt; null then
		self.setMyCurrentVoyage(self.myCurrentVoyage,true);
	else
		self.setMyCurrentVoyage(app.getMyCurrentVoyageForTerminal(self.myTerminal),true);
	endif;
	
	self.doCmbVoyageBuild();
	self.doComboCargoBuild();
	self.doComboPortBuild();
	self.doComboOperatorBuild();
	self.splMain.top := 0;
	

	self.btnCargoUnplan.enabled := false;
	self.btnQuitSmmryMode.enabled := false;

	self.setNavigatorHeading(self.caption);
	self.initTableData(ETDef_LlHeadings);
	
	self.btnDelete.caption := "&amp;Edit";
//	self.mnuLLLocateGridArea.caption := 	"Locate In Yard Row Enquiry Form...";
	self.mnuLLLocateGridArea.caption := app.getErrorString(Locate_yard_enquiry_form);
	self.mode := self.Mode_Enquire;
	self.fldQuery.topSheet := self.shtQuery1;
	self.btnUserColours.enabled := false;
	beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(TIEvent_PreNote_Add), Response_Continuous, 0);
	beginClassNotification(CM_TrackedItem, false, self.myTerminal.getTerminalEvent(TIEvent_PreNote_Update), Response_Continuous, 0);
	// PAR #26462 register for notifications
	if self.myTerminal.getConfig(ShowRelReqOnShipLoadList).Boolean then
		beginClassNotification(CM_WorkListEntry, false, self.myTerminal.getTerminalEvent(WLE_Update_Event), Response_Continuous, 0);
	endif;

	if self.initWithObject then
		self.doQuery();
		//self.showTableRowsForObjects(self.allQueryInitObjects,self.Column_LoadToPlan); // PAR 14285 DO NOT comment this out.
		self.createFiltersFromObjects(self.allQueryInitObjects); //25 Jan 2012	NDL	Par 25297
		
	endif;
	
	//22 Dec 2011	NDL	Par 25297
	self.tblData.setForm (self);
	self.tblPlanned.setForm (self);
	self.tblDLR.setForm (self);
	self.tblAll.setForm (self);
	self.tblTranShip.setForm (self);
	self.tblTBA.setForm (self); // TFS 45590

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.tblData.userInputEnabled := false;
		self.tblDLR.userInputEnabled := false;
		self.tblPlanned.userInputEnabled := false;
	endif;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showCargoSelection" id="fe7d7f98-4099-4201-85d5-8f3eddd8346d">
        <source>showCargoSelection(_objects: CM_ObjectArray; _table: CM_DataTable): Integer;
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	rowPointer		: Integer;
	rowCount		: Integer;
	tableObj		: CM_DataTable;
	rowItemObj		: Object;
	allSelectedObj	: CM_ObjectArray;
	startRow		: Integer;
	maxRow			: Integer;
//	allDidntMakeIt	: ObjectArray;
	
begin
	tableObj		:=	_table;
	allSelectedObj	:=	_objects;
	startRow		:=	tableObj.fixedRows + 1;
	maxRow			:=	tableObj.rows;
	
//	create allDidntMakeIt transient;
//	allSelectedObj.copy(allDidntMakeIt);
	
//	foreach rowPointer in tableObj.fixedRows to tableObj.rows do
	foreach rowPointer in startRow to maxRow do
		rowItemObj	:=	tableObj.accessRow(rowPointer).itemObject;
		
	 	if allSelectedObj.includes(rowItemObj) then
	 		rowCount	:=	rowCount + 1;
	 		tableObj.accessedRow.visible := true;
//	 		allDidntMakeIt.remove(rowItemObj);
	 		continue;
	 	endif;
	 	
	 	if rowItemObj = null then
	 		continue;
	 	endif;
	 	
	  	tableObj.accessedRow.visible := false;
	endforeach; 
	
//if app.computerName().toLower() = "cnwdad1a" and allDidntMakeIt.cnEcIsNotEmpty() then
//	allDidntMakeIt.inspectModal();
//endif;
	return rowCount;
epilog
//	delete allDidntMakeIt;
end;</source>
        <Parameter name="_objects" type="CM_ObjectArray"/>
        <Parameter name="_table" type="CM_DataTable"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="c4ee5991-8823-42b9-927a-f30f75ef0999">
        <source>showColumnOrganiser();
// ---------------------------------------------------------------------------
// Created:		22 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	if self.fldMain.topSheet = self.shtNonplanned then
		self.tblData.showColumnOrganiserFrm(self.myTerminal, null);
	elseif self.fldMain.topSheet = self.shtPlanned then
		self.tblPlanned.showColumnOrganiserFrm(self.myTerminal, null);
	elseif self.fldMain.topSheet = self.shtTranship then
		self.tblTranShip.showColumnOrganiserFrm(self.myTerminal, null);
	elseif self.fldMain.topSheet = self.shtTBA then // TFS 45590
		self.tblTBA.showColumnOrganiserFrm(self.myTerminal, null);
	elseif self.fldMain.topSheet = self.shtAll then
		self.tblAll.showColumnOrganiserFrm(self.myTerminal, null);
	else
		self.tblDLR.showColumnOrganiserFrm(self.myTerminal, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showPreferences" id="777e4c99-beaf-490e-a008-263c571b518f">
        <updating/>
        <source>showPreferences()updating;
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	self.myFunctionObject := null;
	
	self.optAskMe.value := true;
	
	if self.defaultDblClickFunction = self.Function_Enquiry then
		self.optEnquire.value := true;
	elseif self.defaultDblClickFunction = self.Function_LocateGridRows then
		self.optLocateCargo.value := true;
	elseif self.defaultDblClickFunction = self.Function_ShowInLoadList then
		self.optLoadList.value := true;
	endif;
	
	self.optAskMe.visible := true;
	self.chkRemember.value := true;
	self.chkRemember.enabled := false;
	
	self.lblPreference.caption := "Summary double click preference.";
	self.frmPreferences.visible := true;
	self.frmPreferences.centreWindow();
	self.frmPreferences.zOrder(1);
end;</source>
    </JadeMethod>
    <JadeMethod name="showStowageIDs" id="9581c5d5-5cd9-4107-bacc-93175a53b381">
        <source>showStowageIDs(_summObj: CMIF_LoadListSummaryObject);
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	intU,intP	: Integer;
	sr			: CM_SlotRequest;
	r			: CM_Request;
	strUnplan,
	strPlan		: String;
	wle			: CM_WorkListEntry;
begin
	
	intU := 1;
	intP := 1;

//	foreach sr in _summObj.allLoadRequests do
	foreach r in _summObj.allLoadRequests do	//20 Nov 2012	NDL	Par 30754
		if not r.isKindOf(CM_SlotRequest) then
			continue;
		else
			sr := r.CM_SlotRequest;
		endif;
		
		if sr.mySlotDefinition = null
		or sr.mySlotDefinition.myBay = null then
			continue;
		endif;
		wle := sr.allWorkListEntries.first;
		
		if wle = null
		or wle.myTrackedItem = null then
			intU := intU + 1;
			if sr.getAttrIs40() then
				strUnplan := strUnplan &amp; sr.mySlotDefinition.myBay.idBay40&amp;sr.id &amp; ", ";
			else
				strUnplan := strUnplan &amp; sr.mySlotDefinition.myBay.id&amp;sr.id &amp; ", ";
			endif;
			if intU mod 6 = 1 then
				strUnplan := strUnplan &amp; CrLf &amp; Tab; 
			endif;
		else
			intP := intP + 1;
			if sr.getAttrIs40() then
				strPlan := strPlan &amp; sr.mySlotDefinition.myBay.idBay40&amp;sr.id &amp; ", ";
			else
				strPlan := strPlan &amp; sr.mySlotDefinition.myBay.id&amp;sr.id &amp; ", ";
			endif;		
			if intP mod 6 = 1 then
				strPlan := strPlan &amp; CrLf &amp; Tab; 
			endif;
		endif;

	endforeach;
	
	app.msgBoxScroll("Slots Coloured for Load and Planned" &amp; CrLf &amp; Tab &amp; strPlan &amp; CrLf &amp; CrLf &amp; "Slots Coloured for Load and Not Planned" &amp; CrLf &amp; Tab &amp; strUnplan, null, null, self.caption, null);
//	app.msgBox("Slots Coloured for Load and Planned" &amp; CrLf &amp; Tab &amp; strPlan &amp; CrLf &amp; CrLf &amp; "Slots Coloured for Load and Not Planned" &amp; CrLf &amp; Tab &amp; strUnplan, self.caption, null);

end;</source>
        <Parameter name="_summObj" type="CMIF_LoadListSummaryObject"/>
    </JadeMethod>
    <JadeMethod name="showTableRowsForObjects" id="8daca0a3-18cd-4eb9-b4c2-cbe01193cc06">
        <source>showTableRowsForObjects(_objects: CM_ObjectArray; _columnKey: Integer);
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	dlrCount,
	plannedCount,
	nonplannedCount,
	tsCount,tbaCount,
	allCount : Integer;
begin
	tbaCount			:=	self.showCargoSelection(_objects, self.tblTBA);// TFS 45590
	tsCount			:=	self.showCargoSelection(_objects, self.tblTranShip);
	dlrCount		:=	self.showCargoSelection(_objects, self.tblDLR);
	plannedCount	:=	self.showCargoSelection(_objects, self.tblPlanned);
	nonplannedCount	:=	self.showCargoSelection(_objects, self.tblData);
	allCount		:=	self.showCargoSelection(_objects, self.tblAll);

	//set captions	
	self.shtPlanned.caption := app.getErrorString(Planned) &amp; " (" &amp; plannedCount.String &amp; "/" &amp; (self.tblPlanned.rows - self.tblPlanned.fixedRows).String &amp; ")";
	self.shtNonplanned.caption := app.getErrorString(SHP_Non_Plann01) &amp; " (" &amp; nonplannedCount.String &amp; "/" &amp; (self.tblData.rows - self.tblData.fixedRows).String &amp; ")";
	self.shtDLR.caption := app.getErrorString(SHP_DLR_Non_Planned) &amp; " (" &amp; dlrCount.String &amp; "/" &amp; (self.tblDLR.rows - self.tblDLR.fixedRows).String &amp; ")";
	self.shtTranship.caption := app.getErrorString(SHP_Tranship_Export_Items) &amp; " (" &amp; tsCount.String &amp; "/" &amp; (self.tblTranShip.rows - self.tblTranShip.fixedRows).String &amp; ")";
	self.shtTBA.caption := app.getErrorString(TBANONPLANNED) &amp; " (" &amp; tbaCount.String &amp; "/" &amp; (self.tblTBA.rows - self.tblTBA.fixedRows).String &amp; ")"; // TFS 45590
	self.shtAll.caption := app.getErrorString(LOADLIST_ALL) &amp; " (" &amp; allCount.String &amp; "/" &amp; (self.tblAll.rows - self.tblAll.fixedRows).String &amp; ")";

	if (plannedCount &gt;= nonplannedCount
	and plannedCount &gt;= dlrCount)
	then
		self.fldMain.topSheet	:=	self.shtPlanned;
	elseif (nonplannedCount &gt;= plannedCount
	and nonplannedCount &gt;= dlrCount)
	then
		self.fldMain.topSheet	:=	self.shtNonplanned;
	else
		self.fldMain.topSheet	:=	self.shtDLR;
	endif;
end;</source>
        <Parameter name="_objects" type="CM_ObjectArray"/>
        <Parameter name="_columnKey" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showUserColourFrame" id="001e83b1-a2cd-48e6-b6cb-491340c4ed0e">
        <source>showUserColourFrame();
// ---------------------------------------------------------------------------
// Created:		04 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
