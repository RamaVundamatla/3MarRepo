    <JadeMethod name="getDisplayStringForAttribute" id="768c6d36-3aac-4b3a-91a8-755e41c32591">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 September 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description
05/10/2023		jlika1		TFS 60754	POB | QShip 55715.070 - Default Vessel Type 
09/10/2023		jlika1		TFS 60753	POB | Q-Ships 55717.080 - Date Range of QShips Query
****************************************************/

begin		
	if _attrName = ETRow_ClientType then
		return self.clientType.asStringJMT;
	elseif _attrName = ETRow_DomainName then
		return self.domainName;
	elseif _attrName = ETRow_LastSuccessfullTS then
		return self.lastSuccessfullTS.asStringJMT;	
	elseif _attrName = ETRow_ServiceVersion then
		return self.serviceVersion;
	elseif _attrName = ETRow_WebServiceType then
		return ExternalWebServiceQships;
	elseif _attrName = ETRow_VesselType then
		if self.myVesselType &lt;&gt; null then
			return self.myVesselType.displayEntryListbox;
		else
			return null;
		endif;
	elseif _attrName = ETRow_QueryDaysAfterRT then
		return self.queryDaysAfterRT.asStringJMT;
	elseif _attrName = ETRow_QueryHrsBeforeLSD then
		return self.queryHrsBeforeLSD.asStringJMT;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setExtras" id="0c0bbb0b-81a9-4834-8d39-ee71a5a6c863">
        <updating/>
        <source>setExtras(_domainName: String; 
		  _serviceVersion: String; 
		  _clientType: Integer;
		  _lastSuccessfulTimestamp : TimeStamp;
		  _vesselType : HMS_VesselType;
		  _qDaysAfterRT: Integer;
		  _qHrsBeforeLSD: Integer) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 September 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description
31 Aug 2023 	navra1 		TFS 59839 - POB | QShips Integration - Editable Last Run Time
05 Oct 2023		jlika1		TFS 60754	POB | QShip 55715.070 - Default Vessel Type 
****************************************************/
begin	
	self.domainName := _domainName;
	self.serviceVersion := _serviceVersion;
	self.clientType := _clientType;
	self.lastSuccessfullTS := _lastSuccessfulTimestamp;				//navra1 - TFS 59839 - 31 Aug 2023
	self.myVesselType := _vesselType;	
	self.queryDaysAfterRT := _qDaysAfterRT;
	self.queryHrsBeforeLSD := _qHrsBeforeLSD;
end;</source>
        <Parameter name="_domainName" type="String"/>
        <Parameter name="_serviceVersion" type="String"/>
        <Parameter name="_clientType" type="Integer"/>
        <Parameter name="_lastSuccessfulTimestamp" type="TimeStamp"/>
        <Parameter name="_vesselType" type="HMS_VesselType"/>
        <Parameter name="_qDaysAfterRT" type="Integer"/>
        <Parameter name="_qHrsBeforeLSD" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="49bd524f-ab36-4800-8b5e-b8a0468215b2">
        <updating/>
        <source>setForUpdate(_extWebService: CM_ExternalWebServiceDef) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 September 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description
05 Oct 2023		jlika1		TFS 60754	POB | QShip 55715.070 - Default Vessel Type 
09 Oct 2023		jlika1		TFS 60753	POB | Q-Ships 55717.080 - Date Range of QShips Query
****************************************************/
vars
	qshipWebService : CM_QshipsWebServiceDef;	
begin
	inheritMethod(_extWebService);
	
	qshipWebService := _extWebService.CM_QshipsWebServiceDef;
	if qshipWebService &lt;&gt; null then
		self.clientType := qshipWebService.clientType;
		self.domainName := qshipWebService.domainName;
		self.lastSuccessfullTS := qshipWebService.lastSuccessfullTS;
		self.serviceVersion := qshipWebService.serviceVersion;
		self.myVesselType := qshipWebService.myVesselType;
		self.queryDaysAfterRT := qshipWebService.queryDaysAfterRT;
		self.queryHrsBeforeLSD := qshipWebService.queryHrsBeforeLSD;
	endif;
end;</source>
        <Parameter name="_extWebService" type="CM_ExternalWebServiceDef"/>
    </JadeMethod>
    <JadeMethod name="setLastSuccessfulTS" id="1ba9b946-e9b3-4962-bd14-bc6070767c8d">
