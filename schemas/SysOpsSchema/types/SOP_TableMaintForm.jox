    </JadeMethod>
    <JadeMethod name="loadCmbVBSProcess" id="2bf9c7d4-52da-497d-a74a-1c889fa20c9d">
        <source>loadCmbVBSProcess();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2022	navhl20	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars
	vbsProcess  : CM_VBSProcess;
	index 		: Integer;
begin
	self.cmbDefaultVbsProcess.clear();
	
	foreach vbsProcess in  app.myRoot.allVBSProcesses discreteLock do
		index := self.cmbDefaultVbsProcess.addItem( vbsProcess.description );
		self.cmbDefaultVbsProcess.itemObject[index] := vbsProcess;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbWBridgeType" id="85ee954f-37b3-4146-b35e-140c9c52291f">
        <source>loadCmbWBridgeType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	iter : Iterator;
	wBridgeType : CM_WeighBridgeObjType;
	index : Integer;

begin

	self.cmbWBridgeType.clear();
	
	iter := app.myRoot.allWeighBridgeTypes.createIterator;
	while iter.next( wBridgeType ) do
	//	if wBridgeType.isNotAvailableForEntry then
	//		continue;
	//	endif;
		index := self.cmbWBridgeType.addItem( wBridgeType.code );
		self.cmbWBridgeType.itemObject[index] := wBridgeType;
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbWPTData" id="ec42dd3b-bcf8-43e8-a851-d1d0f73d22f7">
        <updating/>
        <source>loadCmbWPTData(_myWPT : CM_WorkPointType)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2023	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types
25 May 2023 	navhl20	Bug 58151:[58152] EUP - System Work Point Type Ship can be edited
*/

vars
	cmb : CMUI_ComboBox;
	wPT : CM_WorkPointType;
begin
	cmb := self.cmbWPTData;
	cmb.clear();
	
	foreach wPT in self.myTerminal.allWorkPointTypes do
		cmb.addItemObject(wPT.code,wPT);
	endforeach;
	
	if _myWPT &lt;&gt; null then
		cmb.listIndex := cmb.findObject(_myWPT);
	elseif not app.myPassport.isVASEnabled then										//25.5.2023 navhl20 #58151[58152]
		foreach wPT in self.myTerminal.allWorkPointTypes do
			if wPT.code = "SHIP" and wPT.type = WORK_POINT_TYPE_SHIP then
				cmb.listObject := wPT;
				self.cmbWPTData_lostFocus(self.cmbWPTData);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_myWPT" type="CM_WorkPointType"/>
    </JadeMethod>
    <JadeMethod name="loadCmbWPType" id="52fe43ca-2709-48c8-a1e9-36c51704da90">
        <source>loadCmbWPType(_type : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2023	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types 

*/

vars
	cmb : CMUI_ComboBox;
begin
	cmb := self.cmbWPType;
	cmb.clear();
	
	cmb.addItem(app.getWorkPointTypeString(WORK_POINT_TYPE_ROAD));
	cmb.addItem(app.getWorkPointTypeString(WORK_POINT_TYPE_RAIL));
	cmb.addItem(app.getWorkPointTypeString(WORK_POINT_TYPE_SHIP));
	cmb.addItem(app.getWorkPointTypeString(WORK_POINT_TYPE_TODO));
	cmb.addItem(app.getWorkPointTypeString(WORK_POINT_TYPE_PACKUNPACK));
	cmb.addItem(app.getWorkPointTypeString(WORK_POINT_TYPE_YARD));

	
	cmb.listIndex := cmb.findString(1,_type);
epilog

end;</source>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadCmbWebService" id="10ca797e-94bb-46e9-9e1b-b1a85460d1c7">
        <source>loadCmbWebService();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/12/2022	navdap1		Initial creation TFS 55159 MTN - Export CAMS to JSON API Endpoint
//
vars
	webService : CM_ExternalWebServiceDef;

begin
	self.cmbWebServiceType.clear;
	foreach webService in app.myRoot.allExternalWebServices discreteLock do
		if not webService.active then
			continue;
		endif;
		
		if webService.isKindOf(CM_APIEndpointServiceDef) and webService.CM_APIEndpointServiceDef.isForCams then
			self.cmbWebServiceType.itemObject[self.cmbWebServiceType.addItem(webService.name)] := webService;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadComboCargoCheckOptions" id="9433c8cc-1072-4811-b25a-55bdb0d56aee">
        <source>loadComboCargoCheckOptions(cargoCheckOption : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2019	jlgdi1	TFS# 41721 Initial creation

*/

begin
	self.cmbCargoCheckOption.clear();
	self.cmbCargoCheckOption.sorted := false;
	
	self.cmbCargoCheckOption.addItem(CARGO_CHECK_NONE_TEXT);
	self.cmbCargoCheckOption.addItem(CARGO_CHECK_OPTION_1_TEXT);
		
	if cargoCheckOption &lt;&gt; null then
		self.cmbCargoCheckOption.text := cargoCheckOption;
	endif;
end;</source>
        <Parameter name="cargoCheckOption" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadCombosRealEmail" id="5bef673a-905d-4a99-8915-305917a29967">
        <source>loadCombosRealEmail();
//
// 28 May 2013		cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
// 24 Jul 2020		jlgdap1	TFS 49764 MTN Retire Basic Authentication to Exchange Online
//
vars
	idx : Integer;
begin
	idx := self.cmbInwardSSL.addItem("NONE");
	self.cmbInwardSSL.itemData[idx] := BGP_EmailSendRequest.SSL_NONE;
	idx := self.cmbInwardSSL.addItem("SSL STARTTLS");
	self.cmbInwardSSL.itemData[idx] := BGP_EmailSendRequest.SSL_STARTTLS;
	idx := self.cmbInwardSSL.addItem("SSL DIRECT");
	self.cmbInwardSSL.itemData[idx] := BGP_EmailSendRequest.SSL_DIRECT;
	self.cmbInwardSSL.listIndex := 1;
	
	idx := self.cmbSoftware.addItem("NONE");
	self.cmbSoftware.itemData[idx] := BGP_EmailSendRequest.EMAIL_CARDSCHEMA;
	idx := self.cmbSoftware.addItem("IDSMAIL");
	self.cmbSoftware.itemData[idx] := BGP_EmailSendRequest.EMAIL_IDSMAIL;
	idx := self.cmbSoftware.addItem("EMAILARCHITECT");
	self.cmbSoftware.itemData[idx] := BGP_EmailSendRequest.EMAIL_EMAILARCHITECT;
	self.cmbSoftware.listIndex := 1;
	idx := self.cmbSoftware.addItem("EMAILARCHITECTOAUTH");								// TFS 49764
	self.cmbSoftware.itemData[idx] := BGP_EmailSendRequest.EMAIL_EMAILARCHITECTOAUTH;	// TFS 49764
end;</source>
    </JadeMethod>
