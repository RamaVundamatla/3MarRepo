    <JadeMethod name="shouldAuditProperty" id="96170d96-12cd-4eda-806d-3fc476b88018">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
//06 November 2023 navmv20 CR 60425 Task 60987: Jade - Cust Doc Cancellation TRX
begin
	//if _property.name = 'direction' then //06/11/2023 navmv20 CR 60425 Task 60987
	if _property.name = 'direction' or _property.name = 'status' then //06/11/2023 navmv20 CR 60425 Task 60987
