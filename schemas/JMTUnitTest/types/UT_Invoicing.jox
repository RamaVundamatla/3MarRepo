    <JadeMethod name="tranMapLoadVTMIS1" id="0c14382c-5c15-4765-9ccb-69a4b41abc09">
        <source>tranMapLoadVTMIS1();
// cnwjre1 load tran map for HMS water usage invoicing
// ### TFS CR 65336 TASK 65339 09AUG2024 NAVAB1 added new columns to tran map CSV 
vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	hmsMap	: CM_TranMapVoyage;

begin
	fileName := "VTMIS1";
	mapName := "UT_VTMIS1";

	fileContent := 'TranMap Type,TranMap Name,Resource,Debtor,Quantity Type,Quantity Range,In Contract,Cargo Type,Sub Type, Commodity,Vessel Category,Transfer Type,Invoice Line' &amp; CrLf &amp;
					'Voyage,'&amp;mapName&amp;',(Default),(Default),(Default) ›,(Default),X,(Default),(Default),(Default),,,VOID' &amp; CrLf &amp;
					'Voyage,'&amp;mapName&amp;',(Default),(Default),(Default) ›,(Default),,(Default),(Default),(Default),,,VOID' &amp; CrLf &amp;
					'Voyage,'&amp;mapName&amp;',UTWATER01 Water meter 1 usage,(Default),(Default) ›,(Default),X,(Default),(Default),(Default),,,UTWaterUsage' &amp; CrLf &amp;
					'Voyage,'&amp;mapName&amp;',UTWATER01 Water meter 1 usage,(Default),(Default) ›,(Default),,(Default),(Default),(Default),,,UTWaterUsage' &amp; CrLf;

	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := self.myBank;
	hmsMap := bank.allJMHTMs[mapName];
	self.assertNotNullMsg(hmsMap,"VTMIS map should not be null");

	app.myTrxUA.trxUpdateBankTMVActive(hmsMap,app.myPassport);

epilog

end;
</source>
    </JadeMethod>
