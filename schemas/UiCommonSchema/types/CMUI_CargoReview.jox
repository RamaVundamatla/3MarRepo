    <JadeMethod name="updateCriteriaLine" id="80936724-64d6-446d-bf10-4c30eba9c07a">
        <source>updateCriteriaLine() protected;
// ---------------------------------------------------------------------------
// Created:     11 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	row					: Integer;
	criteriaLine		: CM_SelectorCriteriaLine;
begin
	row:=self.tblCriteria.row;
	criteriaLine := self.tblCriteria.accessRow(row).itemObject.CM_SelectorCriteriaLine;
	if criteriaLine = null or not self.tblCriteria.accessRow(row).selected then
		return;
	endif;
	if criteriaLine = null then
		app.msgBox(app.getErrorString2(CMUI_MustSelect, app.getErrorString(CMUI_Selector_Criteria_Line), app.getErrorString(Update)), app.getErrorString(CMUI_Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if (not self.validateCriteriaLineUpdate(criteriaLine.myQueryProperty.propertyName)) then
		return;
	endif;
	
	self.setPropertyValueAndOperator(criteriaLine);
	self.tblCriteria.removeItem(row);
	self.tblCriteria.addItemAt(criteriaLine.getDescriptionString, row);
	self.tblCriteria.accessRow(row).itemObject := criteriaLine;
	self.tblCriteria.accessRow(row).backColor := criteriaLine.getPerformanceColour;	//02 Sep 2019	NDL	TFS 45891
	
	self.setCriteriaLabel(); //02/10/2023	navkc1	CR 60423 Task 60763

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateCriteriaLineRemoval" id="9b16b0dc-486e-4098-825c-4fa964253c78">
        <source>validateCriteriaLineRemoval(_crit : CM_SelectorCriteriaLine) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     05 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _crit = null then
		app.msgBox(app.getErrorString2(CMUI_MustSelect, app.getErrorString(CMUI_Selector_CriteriaLine), app.getErrorString(Delete)), app.getErrorString(CMUI_Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	if (self.myTerminal &lt;&gt; null) and 
	   (_crit.myQueryProperty.propertyName = CM_TrackedItem::myTerminal.name ) then		// 34364 getTerminal for invoice line
		app.msgBox(app.getErrorString1(CMUI_Selector_No_Retreive, app.getErrorString(Terminal)), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
		return false;

	elseif _crit.myQueryProperty.propertyName = CM_TrackedItem::cargoType.name then
		if _crit.myCriteriaLineHolder.allCriteriaByPropertyName.includesKey(CM_TrackedItem::myProduct.name, CM_TrackedItem.name) then
			app.msgBox(app.getErrorString(Remove_cargo_subtype_criteria), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	endif;


	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_crit" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCriteriaLineUpdate" id="a395142a-4114-42a0-9b72-1dc270decb1f">
        <source>validateCriteriaLineUpdate(_propertyName : String) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     24 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	criteriaHolder		: CM_QueryCriteriaLineHolder;
begin
	
	criteriaHolder := self.myCriteriaLineHolder;
	
	if _propertyName =  CM_TrackedItem::cargoType.name  then
		if criteriaHolder.allCriteriaByPropertyName.includesKey(CM_TrackedItem::myProduct.name, CM_TrackedItem.name) then
			app.msgBox(app.getErrorString(Remove_cargo_subtype_criteria), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	endif;


	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_propertyName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
