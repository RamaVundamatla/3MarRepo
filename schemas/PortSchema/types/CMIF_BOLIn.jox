    <JadeMethod name="actionForCreate" id="4093974f-d6a9-4d7d-852c-ff49d57985a9">
        <updating/>
        <source>actionForCreate(pProxy: CM_Object io; _passport : CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	job				: CM_RoadJob;
	tmpStr			: String;
	toDoType		: CM_ToDoRequestType;
	pxyToDoReq,
	realToDoReq		: CM_BOLToDoRequest;
	inOutAttach		: CMIF_TIObject;
	cancelSave		: Boolean;
	request : CM_Request;	
begin
	
	if self.transportMode &lt;&gt; TI_TRANSMODE_SHIP then
		job := self.getInOutJob();
		if job = null then
			return false;
		endif;
	endif;

	self.myPersistentBOL := self.myTerminal.createBillOfLading(self.myProxyBOL, _passport);

	if job &lt;&gt; null then
		if _passport.noErrors and (not self.myPersistentBOL.allTrackedItems.isEmpty) then
			//Receive the TI into the yard 
			self.myPersistentBOL.receiveFromRoad(job.CM_RoadJob, _passport);
		endif;
		
		if not _passport.noErrors then
			return false;
		endif;
		
		self.myPersistentBOL.setMyJobReceive(job);
		foreach tmpStr in self.myBOLType.allToDoReqsPreReceival do	
			toDoType := app.myRoot.allToDoRequestTypes[tmpStr].CM_ToDoRequestType;
			if toDoType &lt;&gt; null then
				create pxyToDoReq transient;
				pxyToDoReq.setProxy(self.myPersistentBOL, toDoType, app.getMyUserCode, job);
				// Should move the following to a utl method (or look at utl passing throuhg string array of task descs)
				create realToDoReq persistent;
				realToDoReq.setForCreate(pxyToDoReq);
			endif;
		endforeach;
	
		if _passport.noErrors then
			// create the request
			create self.myProxyBOLRequest transient;
			self.myProxyBOLRequest.setProxy(self.consignorCode, null /* _consignorVoyageCode */,
										    null /* _deliveryNumber */,
										    null /* _eirNumber */,
											null /* _FreightForwaderCode */,
										    null /* _freightPayerCode */,
										    true /* _isReceipt */,
										    null /* _reasonCode */,
										    null /* _reasonCodeDescr */,
										    null /* _remarks */,
										    true /* _removeStops */,
										    app.getMyUserCode,
										    null /* _voyageCode */,
										    job, self.myPersistentBOL);
		endif;
		
		if _passport.noErrors then	
			//Validate the request (TI is already validated)
			self.myProxyBOLRequest.validate(self.myUserObject);
		endif;
		
		if (not _passport.noErrors()) then
			return false;
		endif;
	
		//Add the request to the job	
		request := job.addRequest(self.myProxyBOLRequest, _passport);
		if request = null or _passport.hasErrors then
			return false;
		endif;
	
		//archive associated weighBridge object if any
		if self.myLogDocketData &lt;&gt; null then
			app.myUtilityUA.utlUpdateLogDocketDataArchive(self.myLogDocketData, self.myPersistentBOL, _passport);	
		endif;
	endif;
			
	if self.bolType = BOLType_GeneralDocket or self.bolType = BOLType_GeneralBillOfLading then
		self.actionForCreateGeneralDocket(_passport);
	endif;
	
	//No longer using this. Has it's own trx from EDI load of 309 file
	/*if self.isEDILoad then
		self.actionForCreateCustomsBOL(_passport);
	endif;*/
	
	// Par 8635
	if _passport.noErrors then
		app.myAA.auditCreateTrx(self.myPersistentBOL, self.myPersistentBOL.getAuditText(), null);
		
		self.myPersistentBOL.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_CREATE); // ### TFS 53105 30MAY2022 NAVAB1
	endif;
		
epilog
	return _passport.noErrors();
end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForCreateGeneralDocket" id="a89da01c-0c33-403c-b467-4cf0b45239e4">
        <updating/>
        <source>actionForCreateGeneralDocket(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     27 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	ti				: CM_TrackedItem;
	moveController	: CMIF_MoveController;
	tmpAttach		: CMIF_TIObject;
	totalBOLWeight		: Integer;
begin
	create moveController transient;
	moveController.setMoveMode(REAL_MODE);
	moveController.isForcedMove	:= true;
	moveController.isSystemMove := true;

	// not sure why this is using the sub items?
	if self.allSubItems.size &gt; 0 then
		foreach ti in self.myPersistentBOL.allTrackedItems do
			foreach tmpAttach in self.allSubItems do
				if tmpAttach.CMIF_InOutAttachment.id = ti.id then					
					moveController.setMyToPrimaryLocation(tmpAttach.CMIF_InOutAttachment.myLocationsController);
					moveController.setMyTrackedItem(ti);
					app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
				endif;
			endforeach;
		endforeach;

	elseif self.myPersistentBOL.allTrackedItems.size &gt; 0 then
		ti := self.myPersistentBOL.allTrackedItems.first;
		moveController.setMyTrackedItem(ti);
		moveController.setAllOtherTrackedItems(self.myPersistentBOL.allTrackedItems);
		moveController.allOtherTrackedItems.remove(ti);
		moveController.setMyToPrimaryLocation(self.myPersistentBOL.myPlannedLocation);		
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);		
	elseif self.allTrackedItems.size &gt; 0 then
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionForUpdateGeneralDocket" id="044db59f-5eb5-496f-a93e-1ef8281db894">
        <updating/>
        <source>actionForUpdateGeneralDocket(_proxy: CM_Object io; _cmifBOLIn: CMIF_BOLIn; _auditAgent: CM_UpdateTransactionAuditAgent io; _passport: CM_Passport input): Boolean updating;
//----------------------------------------------------------------
//	Created:	11 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	subItem		: CMIF_TIObject;
	nullObject	: CM_Object;
	txnParams	: CMIF_TITransactionController;
	expectedEdition	: Integer;
	realBOL		: CM_BOL;
//	ao			: CM_AuditObject;
	tiUpdateCntrlr : CMIF_TIUpdateController;
begin

	self.myProxyBOL.raiseExceptionIfNotProxy(method);
	self.myProxyBOL.pxyGetRealObjectAndEdition(realBOL, expectedEdition);

	if realBOL = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_BOLIn.name, null, null);
		return false;
	endif;

	exclusiveLock(realBOL);

	if _passport.noErrors and realBOL.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'tracked item', null, null);
		return false;
	endif;
	
	if _passport.noErrors then
		_auditAgent.CM_UpdateTransactionAuditAgent.audUpdateGeneric(realBOL, true);
	endif;
	
	foreach subItem in self.allSubItems do
		if not subItem.actionForUpdate(nullObject, _auditAgent, true, _passport) then
			break;
		endif;		
	endforeach;

	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode, null);
		
	if _passport.noErrors then
		if realBOL.bolType &lt;&gt; self.myProxyBOL.bolType then
			realBOL.erase(NORMAL_ERASE);
			//Create the persistent TI, using the proxy TI we already validated
			realBOL := self.myTerminal.createBillOfLading(self.myProxyBOL, _passport);
			
			if self.bolType = BOLType_GeneralDocket or self.bolType = BOLType_GeneralBillOfLading then
				self.actionForCreateGeneralDocket(_passport);
			endif;
		else
			realBOL.setForUpdateGeneralDocket(self.myProxyBOL, _cmifBOLIn, _passport);
		endif;
		
	endif;
	
	
	if _passport.noErrors then
		_auditAgent.CM_UpdateTransactionAuditAgent.audUpdateGeneric(realBOL, false);
	endif;

	if _passport.noErrors then
		self.myPersistentBOL := realBOL;
		
		self.myPersistentBOL.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE); // ### TFS 53105 30MAY2022 NAVAB1
	endif;

epilog
	delete tiUpdateCntrlr;
	return _passport.noErrors;

end;</source>
        <Parameter name="_proxy" type="CM_Object" usage="io"/>
        <Parameter name="_cmifBOLIn" type="CMIF_BOLIn"/>
        <Parameter name="_auditAgent" type="CM_UpdateTransactionAuditAgent" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createRequestsForGeneralDocket" id="96ccbb9d-589d-450e-a654-ce35cc6ce624">
        <source>createRequestsForGeneralDocket(_job : CM_RoadJob);
// ---------------------------------------------------------------------------
// Created:     22 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	ti					: CM_TrackedItem;
	tiDict				: CM_TIByCargoTypeLocationDict;
	cargoType			: Integer;
	lc					: CM_LocationsController;
	proxyBOLRequest		: CM_BOLYardRequest;
							
begin
	create tiDict transient;
	
	self.myProxyBOL.allTrackedItems.copy(tiDict);
	cargoType := tiDict.first.cargoType;
	lc := tiDict.first.getPrimaryLocation(REAL_MODE);
	foreach ti in tiDict do
	//	if cargoType &lt;&gt; ti.cargoType or lc &lt;&gt; ti.getPrimaryLocation(REAL_MODE) then
			create proxyBOLRequest transient;
			self.allBOLYardRequests.add(proxyBOLRequest);
			proxyBOLRequest.setProxy(self.consignorCode, null /* _consignorVoyageCode */,
									    null /* _deliveryNumber */,
									    null /* _eirNumber */,
										null /* _freightForwarderCode */,
									    null /* _freightPayerCode */,
									    true /* _isReceipt */,
									    null /* _reasonCode */,
									    null /* _reasonCodeDescr */,
									    null /* _remarks */,
									    true /* _removeStops */,
									    app.getMyUserCode,
									    null /* _voyageCode */,
									    _job, self.myPersistentBOL);	
	//	endif;
		cargoType := ti.cargoType;
		lc := ti.getPrimaryLocation(REAL_MODE);

	endforeach;
	
epilog
	delete tiDict;

end;</source>
        <Parameter name="_job" type="CM_RoadJob"/>
    </JadeMethod>
