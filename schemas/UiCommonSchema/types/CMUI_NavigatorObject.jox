    <JadeMethod name="actionForCreate" id="362d884e-4e37-4cd5-8d55-f6093b8d6466">
        <updating/>
        <source>actionForCreate(pDoFormShow : Boolean) : CM_BaseForm updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	navObj	: CMUI_NavigatorObject;

begin

	if self.actionType &lt;&gt; ActionType_Window then
		return null;
	endif;
	
	return self.goToObject(null, null, pDoFormShow);

end;</source>
        <Parameter name="pDoFormShow" type="Boolean"/>
        <ReturnType type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="addToListBox" id="28589502-7056-4dcd-af2a-6a0e23b1ce5c">
        <source>addToListBox(pListBox : CMUI_NavigatorListBox2 input);
// ---------------------------------------------------------------------------
// Created:     31 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	childObject	: CMUI_NavigatorObject;
begin

	pListBox.addCMUI_NavObject(self);
	foreach childObject in self.allChildren do
		childObject.addToListBox(pListBox);
	endforeach;

end;</source>
        <Parameter name="pListBox" type="CMUI_NavigatorListBox2" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createChildren" id="2cc87723-fd8d-48c0-8c4f-a8f9e3815ca9">
        <source>createChildren();
// ---------------------------------------------------------------------------
// Created:     27 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	grp		: CM_NavObjectGroup;
	navObj	: CMUI_NavigatorObject;
	s		: String;

begin

	if self.actionType &lt;&gt; ActionType_Children then
		return;
	endif;
	
	grp := app.myRoot.allNavObjectGroups[self.actionCode];
	if grp = null then
		return;
	endif;
	
	foreach s in grp.allNavObjectDefCodes do
		navObj := self.myController.createNavObject(s, null, self, self.myTerminal);
		navObj.createChildren();
	endforeach;
	
/*
	if self.code = NavObj_Terminal then
//		if app.name = NavObj_GateApp then
			self.createChildrenForGateApp();
//		elseif app.name = NavObj_SysOpsApp then
//		elseif app.name = NavObj_YardApp then
//		endif;
	endif;
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="getLocalFormDetails" id="cb2d2a0a-fce7-4132-a839-3e6131f0580a">
        <source>getLocalFormDetails(pFormName : String; pFormClass, pAssistantClass : Class output) protected;
// ---------------------------------------------------------------------------
// Created:     23 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	pFormClass := self.class.schema.getClass(pFormName);
	pAssistantClass := CMUI_Assistant;

end;</source>
        <access>protected</access>
        <Parameter name="pFormName" type="String"/>
        <Parameter name="pFormClass" type="Class" usage="output"/>
        <Parameter name="pAssistantClass" type="Class" usage="output"/>
    </JadeMethod>
    <JadeMethod name="goToObject" id="0e2a91eb-f7fc-4049-b706-46efa56f50da">
        <updating/>
        <source>goToObject(pWindow : Window; pFieldName : String; pDoFormShow : Boolean) : CM_BaseForm updating;
// ---------------------------------------------------------------------------
// Created:     06 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form		: CM_BaseForm;
	mdiForm		: Form;
	tbl			: CM_EntryTable;
	theRow		: Integer;
	fieldFound	: Boolean;
	cntrl		: Control;
	indx		: Integer;
	formCls,
	assistCls	: Class;
	subSys		: CMUI_SubSystem;
		
begin

//process.profilerReset();
//process.profilerStart();

	if self.myForm &lt;&gt; null then
		form := self.myForm;
	else
		// Always force new at this stage
		//form := app.getForm(self.actionCode).CM_BaseForm;

		if form = null then
		
			//cls := app.myController.allSubSystems.first.getFormClass(self.actionCode);
			subSys := app.myController.allSubSystems[self.schemaName];
			if subSys = null then
				self.getLocalFormDetails(self.actionCode, formCls, assistCls);
				//app.raiseUnexpectedProgramError(class.name, method.name, 'No schema found for (' &amp; self.schemaName &amp; ')');
				//return form;
			else
				subSys.getFormDetails(self.actionCode, formCls, assistCls);
			endif;
			
			form := app.loadForm(formCls, assistCls, false, false, false, self.myTerminal, null).CM_BaseForm;
//			form := app.loadForm(currentSchema.getClass(self.formName), false, false, false).CM_BaseForm;
			//create form as currentSchema.getClass(self.formName);
			if form = null then
				// user does not have permission to view this form
				return form;
			else
				self.myForm := form;
				self.myFormWhenMaster := form;
				self.setMyWindowControl(form, null);
				form.setMyTerminal(self.myTerminal);
				if pDoFormShow then
					form.show;
				else
					return form;
				endif;
			endif;
		endif;
	endif;

	if form.windowState = Form.WindowState_Minimized then
		form.windowState := Form.WindowState_Normal;
	endif;

	form.setFocus;
	form.zOrder(1);

	if self.myWindowControl &lt;&gt; null then
		if self.myWindowControl.isKindOf(Control) and self.controlId &lt;&gt; null then
			self.myWindowControl.Control.getControl(self.controlId).setFocus;
		else
			self.myWindowControl.setFocus;
		endif;
	endif;
	
	if pWindow &lt;&gt; null then
		pWindow.setFocus;
		
		if pFieldName &lt;&gt; null then
			fieldFound := false;
			
			if pWindow.isKindOf(CM_EntryTable) then
				tbl := pWindow.CM_EntryTable;
				if tbl.goToRowByName(pFieldName) then
					fieldFound := true;
				endif;
			endif;
			
			if not fieldFound then
				// search controls which have pWindow as a parent
				foreach indx in 1 to form.controlCount do
					cntrl := form.controls(indx);
					if cntrl.parent = pWindow then
						if cntrl.name = pFieldName then
							cntrl.setFocus;
							fieldFound := true;
							break;
						endif;
						if cntrl.isKindOf(CM_EntryTable) then
							tbl := cntrl.CM_EntryTable;
							if tbl.goToRowByName(pFieldName) then
								tbl.setFocus;
								fieldFound := true;
								break;
							endif;
						endif;
					endif;
				endforeach;
			endif;

			if not fieldFound then
				
			endif;

		endif;
	endif;

	return form;
	
epilog
//	process.profilerStop();
//	process.profilerReport('c:\tmp\gotoObject.log');
	
end;</source>
        <Parameter name="pWindow" type="Window"/>
        <Parameter name="pFieldName" type="String"/>
        <Parameter name="pDoFormShow" type="Boolean"/>
        <ReturnType type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="handleDblClick" id="2ec89644-ec3c-46c8-891b-47f4aa54076d">
        <updating/>
        <source>handleDblClick() updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	navObj	: CMUI_NavigatorObject;

begin

	if self.actionType = ActionType_Children then
		// This should already have been done at system startup so ignore here
		// self.createChildren();
	elseif self.actionType = ActionType_Child then
		navObj := self.myController.createNavObject(self.actionCode, null, self, self.myTerminal);
		if navObj &lt;&gt; null then
			navObj.actionForCreate(true);
		endif;
	elseif self.actionType = ActionType_Window then
		self.goToObject(null, null, true);
	elseif self.actionType = ActionType_Special then
		if not global.isValidObject(self.myWindowControl) then
		else		
			self.goToObject(self.myWindowControl, null, true);
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="set" id="f1f44b0f-799a-4764-86a2-68ee4755322f">
        <updating/>
        <source>set(pCode : String; pParent : CMUI_NavigatorObject; 
	pObject : Object; pTerminal : CM_Terminal; pControllor : CMUI_Controller) updating;
// ---------------------------------------------------------------------------
// Created:     06 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.code		:= pCode;
	self.myParent	:= pParent;
	
	self.myObject 	:= pObject;
	self.myTerminal	:= pTerminal;

	self.myController := pControllor;
	
	if pParent = null then
		self.level := 1;
		self.myRootController := pControllor;
	else
		self.level := pParent.level + 1;

		if level &gt; 2 then
			self.isChildObject := true;
		endif;
	endif;
	
	self.setItemText();

end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pParent" type="CMUI_NavigatorObject"/>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <Parameter name="pControllor" type="CMUI_Controller"/>
    </JadeMethod>
    <JadeMethod name="setFromNavObjDef" id="61d580aa-0222-4efb-b07a-471d0c301154">
        <updating/>
        <source>setFromNavObjDef(pNavObjDef : CM_NavObjectDef) updating;
// ---------------------------------------------------------------------------
// Created:     01 August 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.actionCode		:= pNavObjDef.actionCode;
	self.actionType		:= pNavObjDef.actionType;
	self.extraTableDef	:= pNavObjDef.extraTableDef;
	self.heading		:= pNavObjDef.heading;
	self.mainTableDef	:= pNavObjDef.mainTableDef;
	self.schemaName		:= pNavObjDef.schemaName;

	self.setItemText();
	
end;</source>
        <Parameter name="pNavObjDef" type="CM_NavObjectDef"/>
    </JadeMethod>
    <JadeMethod name="setHeading" id="cd730440-a654-481c-a0fd-3c0dcc70be79">
        <updating/>
        <source>setHeading(pHeading : String) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.heading = pHeading then
		return;
	endif;
	
	self.heading := pHeading[1:30];
	self.setItemText();	

end;</source>
        <Parameter name="pHeading" type="String"/>
    </JadeMethod>
    <JadeMethod name="setHeadings" id="5a54869a-1674-4df1-9e65-2975dacd8d86">
        <updating/>
        <source>setHeadings(pHeading, pSubHeading : String) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.heading = pHeading and self.subHeading = pSubHeading then
		return;
	endif;
	
	self.heading 	:= pHeading;
	self.subHeading	:= pSubHeading;
	
	self.setItemText();	

end;</source>
        <Parameter name="pHeading" type="String"/>
        <Parameter name="pSubHeading" type="String"/>
    </JadeMethod>
    <JadeMethod name="setItemText" id="72c9cdc1-fb07-4f91-be48-2fdf5eb614db">
        <updating/>
        <source>setItemText() updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.subHeading &lt;&gt; null then
		self.itemText := self.heading &amp; ' (' &amp; self.subHeading &amp; ')';
	else
		self.itemText := self.heading;
	endif;
	
	app.causeEvent(CMUI_NavObject_Update, true, self);

end;</source>
        <access>protected</access>
    </JadeMethod>
