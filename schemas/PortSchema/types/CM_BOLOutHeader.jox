    <JadeMethod name="validateForUpdate" id="e743be79-17ca-4dec-837a-7a46954c5532">
        <source>validateForUpdate();
//--------------------------------------------------------------
//Created: 24 October 2002 By: cnwgd1
//--------------------------------------------------------------
// 15/12/2014  cnwdb2	PAR 35364
vars
	tmpStr : String;
begin
	if self.bolNumber = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'docket number', ETRow_DocketNumber, null);
		app.raiseCMException(Input_required_field_docNumFld, ETRow_DocketNumber, null); // cnwdb2	PAR 35364
	endif;

	if (not self.inputDateTime.isValid) then
	//	app.raiseCMException1(REQUIRED_FIELD, 'input date/time', 'inputDateTime', null);
		app.raiseCMException(Input_required_field_dateTime, 'inputDateTime', null); // cnwdb2	PAR 35364
	endif;

	if self.operatorCode = null then
		tmpStr := app.getTerminologyAlternate(null, self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
	//	app.raiseCMException1(REQUIRED_FIELD, tmpStr , ETRow_OperatorCode, null);
		app.raiseCMException1(Input_required_field_Required, tmpStr , ETRow_OperatorCode, null); // cnwdb2	PAR 35364
	endif;

	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'terminal', ETRow_Terminal, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_Terminal, null); // cnwdb2	PAR 35364
	endif;

end;</source>
    </JadeMethod>
</Class>
