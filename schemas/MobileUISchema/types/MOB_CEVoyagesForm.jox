    <JadeMethod name="showObjSelected" id="64ebcefc-1e71-4955-8465-28e42821410b">
        <source>showObjSelected(_obj: CM_Object);
// ---------------------------------------------------------------------------
// Created:     29 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	form : MOB_CEOrdersForm;
	voyage : CM_Voyage;
	
begin
	if _obj &lt;&gt; null and _obj.isKindOf(CM_Voyage) then
		voyage := _obj.CM_Voyage;
		create form transient;
		form.setVoyage(voyage);
		form.show();
	endif;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="649b92bd-94c8-478f-aef7-aade7932b50a">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018476, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
