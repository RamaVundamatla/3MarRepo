    <JadeMethod name="initialiseForm" id="c536de2f-d5be-408c-a414-96f88f6daedf">
        <updating/>
        <source>initialiseForm() updating;
//09 February 2010	cnwml2


vars
	rule : CM_YADeckingRule;
begin
	inheritMethod();
	rule := self.myProxyDeckingOptions.getAdvancedRule(DeckingDirectionIn); 
	if rule.areaRule = DeckingRule_ByStack then				//By Position
		self.optByRowIn.value := true;
	elseif rule.areaRule = DeckingRule_ByRow then			//By Lane
		self.optByStackIn.value := true;
	endif;
	
	if rule.rowRule = DeckingRule_Increasing then
		self.optRowIncreasIn.value := true;
	endif;
	if rule.rowRule = DeckingRule_Decreasing then
		self.optRowDecreasIn.value := true;
	endif;
	
	self.showForm();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3f69c799-6bd4-456d-98d7-cdad28cc2938">
        <updating/>
        <source>setupForm() updating;
//02 February 2010	cnwml2


vars

begin
	inheritMethod();
	//set new captions
	
	self.optByRowIn.caption := "By Position";
	self.optByStackIn.caption := "By Lane";
	
	self.height := 550;
	self.width := 275;
	self.grpRowFillOrderI.left := 42;
	self.grpRowFillOrderI.width:= 160;
	self.grpRowFillOrderI.caption := "Fill Order";
	self.chkOutUseRevOfIn.enabled := false;
	self.chkOutUseRevOfIn.left := 42;
	
	self.frmOrderGraphic.height := 250;
	self.fldOptions.top := 250;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showForm" id="e0f17eec-58fe-47d6-9532-479ee65c7624">
        <source>showForm();
//02 February 2010	cnwml2


vars

begin
	//inheritMethod();
	
	//all fields that will be disabled at all times
	self.grpFillPatternIn.visible := false;
	self.grpRowFillOrderI.visible := true;
	self.optRowMiddleOutI.visible:= false;
	self.grpStkFillOrderI.visible := false;
	self.optCustomIn.visible := false;
	self.chkStkFillIn.visible := false;
	self.chkRowFillIn.visible := false;
	self.btnCustomIn.visible := false;
	self.optStkMiddleOutI.visible := false;
	self.chkOutUseRevOfIn.enabled := false;
	self.shtOut.enabled := false;

	self.drawArea(DeckingDirectionIn, 5, 3, 1, "L", "P");

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1a0f1800-496e-4f90-9ed3-7494967f5871">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018632, locale);
end;</source>
    </JadeMethod>
</GUIClass>
