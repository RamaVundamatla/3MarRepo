    <JadeMethod name="setForCreate" id="83f02842-9a0e-4134-8cb5-6229f15f9c0f">
        <updating/>
        <source>setForCreate(_proxy : CM_ActivityHistory) updating;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.activityType				:= _proxy.activityType;
	self.dateTime					:= _proxy.dateTime;
	self.description				:= _proxy.description;
	self.myRootNoInverse			:= _proxy.myRootNoInverse;
	self.myTerminalNoInverse		:= _proxy.myTerminalNoInverse;
	self.temp := self.temp;

end;</source>
        <Parameter name="_proxy" type="CM_ActivityHistory"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0675aded-ad7e-48a8-9e88-b0eeb8cd4445">
