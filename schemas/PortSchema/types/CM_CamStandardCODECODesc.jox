    <JadeMethod name="checkEditTransactionForUnpack" id="4989fa3d-20f3-4245-bcfb-67f31a7c2526">
        <source>checkEditTransactionForUnpack(_transaction: CM_TITransaction; _fieldName : String) : String  protected;
//
// 31 Aug 2017	jlgrs1	TFS 6770 SNO Unpack gate out Full wrong commodity
//
// 24 Apr 2018	jlgrs1	TFS 38206 SNO missing delivery release number in unpack full
vars
	field : String;
	oldValue : String;
	newValue : String;
	fieldValue : String;
	i : Integer;
	theTI : CM_TrackedItem;
begin
	if _transaction.class.findProperty(_fieldName) &lt;&gt; null then
		fieldValue := _transaction.getPropertyValue(_fieldName).String;
	endif;
	theTI := _transaction.CM_Edit.myTrackedItem;
	//we have an edit transaction see if it is intesteresting
	foreach i in 1 to _transaction.CM_Edit.fieldsValues.size do
		_transaction.CM_Edit.getFieldValues(i, field, oldValue, newValue);
		//see if it includes a voyage change
		if field = _fieldName then
			// if the old value is null voyage and the new value is not then find the last gate/rail in and process it
			if oldValue &lt;&gt; null then
				fieldValue := oldValue;
				break;
			endif;
		endif;
	endforeach;
	return fieldValue;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_fieldName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="d410f4eb-fbcc-4863-841b-63c453a2a6a8">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
//25 May 2017	cnwrs1	TFS 4465
// ---------------------------------------------------------------------------
//8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B
vars

begin
	self.name := "STANDARD CODECO SMDG162";
	self.type := EDIFileTypeCams_StandardCodeco;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getMessageType" id="98bc3e84-428f-4d15-9cee-4e4d604d10b4">
        <source>getMessageType(transaction		: CM_TITransaction; 
			   messageTypeArray	: IntegerArray input; 
			   camProtocol		: CM_CamProtocol; 
			   camAgent			: CM_CamControllerAgent input);
/****Changes

Date		Name	TFS#		Description
============================================================================
17/08/2017	jlgrs1	6560 	SNO Damaged/Repair
24/10/2018	jlggb1	37102 	STWR Codeco for Barge 'Gate' movements
04/11/2019	jlgdi1	46578	Add CODECO_CANCEL msg type to the list of messages to process when required conditions are met
============================================================================*/
vars
	trackedItem	: CM_TrackedItem;
	voyage 		: CM_Voyage;
begin
	messageTypeArray.clear;
	if transaction.type = TRANS_TYPE_DAMAGED then
		messageTypeArray.add(CODECO_DAMAGED);
	elseif transaction.type = TRANS_TYPE_REPAIR then
		messageTypeArray.add(CODECO_REPAIRED);
	elseif transaction.isCamsShipReceiveType() then  //jlggb1 37102 24.10.2018
		trackedItem := transaction.myTrackedItem;
		if trackedItem &lt;&gt; null and not trackedItem.isRehandle then
			voyage := transaction.getMyVoyage();
			if voyage &lt;&gt; null and voyage.isBarge then 
				messageTypeArray.add(CODECO_GATEIN);
			endif;
		endif;
	elseif transaction.isCamsShipReleaseType() then  //jlggb1 37102 24.10.2018
		trackedItem := transaction.myTrackedItem;
		if trackedItem &lt;&gt; null and not trackedItem.isRehandle then
			voyage := transaction.getMyVoyage();
			if voyage &lt;&gt; null and voyage.isBarge then 
				messageTypeArray.add(CODECO_GATEOUT);
			endif;
		endif;
	elseif (transaction.type = TRANS_TYPE_RCVROADCANCELLED) and (self.hasRoadReceiveBeenProcessed(transaction)) then 
		messageTypeArray.add(CODECO_CANCEL);
	else
		inheritMethod(transaction, messageTypeArray, camProtocol,camAgent);
	endif;
end;</source>
        <Parameter name="transaction" type="CM_TITransaction"/>
        <Parameter name="messageTypeArray" type="IntegerArray" usage="input"/>
        <Parameter name="camProtocol" type="CM_CamProtocol"/>
        <Parameter name="camAgent" type="CM_CamControllerAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getXlatedVoyageCodes" id="23b1af67-8b43-4cb5-a0db-313ccdd26314">
        <source>getXlatedVoyageCodes(_operatorCode : String; _inVoyageCode : String; _outOpVoyageCode, _outVoyVoyageCode : String io; _terminal: CM_Terminal);
//
//25 May 2017	cnwrs1	TFS 4465
//
vars
	voyOperator : CM_Operator;
	opOperator : CM_Operator;
	matchFound : Boolean;
	voyage : CM_Voyage;
begin
	if _inVoyageCode.trimBlanks &lt;&gt; null then
		voyage := _terminal.lookupVoyage(_inVoyageCode, null, true);
		if voyage &lt;&gt; null then
			voyOperator := voyage.myOperator;
			if voyOperator &lt;&gt; null then
				_outVoyVoyageCode := voyOperator.getXlationForeignCode (_inVoyageCode, XLATION_TYPE_VOYAGETERMINAL, matchFound);
			else 
				_outVoyVoyageCode := _inVoyageCode.trimBlanks;
			endif;
		endif;
		opOperator := app.myRoot.allOperators[_operatorCode];
		if opOperator &lt;&gt; null then
			_outOpVoyageCode := opOperator.getXlationForeignCode (_inVoyageCode, XLATION_TYPE_VOYAGETERMINAL, matchFound);
		else //par15042 oct 2007 cnwrs1
			_outOpVoyageCode := _inVoyageCode.trimBlanks;
		endif;
	endif;
end;
</source>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_inVoyageCode" type="String"/>
        <Parameter name="_outOpVoyageCode" type="String" usage="io"/>
        <Parameter name="_outVoyVoyageCode" type="String" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
