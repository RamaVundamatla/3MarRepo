    <JadeMethod name="doLstDataDblClick" id="e466b65b-0f65-44f8-b614-c19e50ecb7b5">
        <updating/>
        <source>doLstDataDblClick(listbox: ListBox input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theForm : INV_ServiceSchedule;
begin
	inheritMethod(listbox);
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	theForm := self;
	self.myCurrentServiceObject := listbox.itemObject[listbox.listIndex].CM_ServiceObject;
	if self.myCurrentServiceObject.isKindOf(CM_ServiceGroup) then
		self.myCurrentServiceGroup := self.myCurrentServiceObject.CM_ServiceGroup;
