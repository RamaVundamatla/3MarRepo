<Class name="CMIF_JsonDeliveryPartyEUP" id="688d5371-2999-4648-9849-9eb5778b37d7">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <ImplicitInverseRef name="address" id="83c4a140-1961-4a9c-8a3f-89eaf5dd4f4a">
        <embedded/>
        <type name="CMIF_JsonAddressEUP"/>
    </ImplicitInverseRef>
    <PrimAttribute name="code" id="5a7acd78-d1c4-4c59-8a1b-26a5c2e0f654">
        <length>21</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="name" id="db4a8263-84f1-4348-8536-461e6c2bdb3e">
        <length>201</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setFromReserveDetail" id="a276b74a-bbe2-4cea-9faa-20872b7bfc85">
        <updating/>
        <source>setFromReserveDetail(_reserveDetail : CM_ReserveDetail) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 24 July 2023
TFS#		: 55938
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	address : CMIF_JsonAddressEUP;
	resAddress : CM_Address;
begin
	if _reserveDetail.myDeliveryParty &lt;&gt; null then
		self.code := _reserveDetail.myDeliveryParty.code;
		self.name := _reserveDetail.myDeliveryParty.name;
	endif;
	resAddress := _reserveDetail.myDeliveryAddress ;
	if resAddress &lt;&gt; null then
		if self.address &lt;&gt; null then
			address := self.address;
			address.setFromAddress(resAddress);
		else
			create address transient;
			address.setFromAddress(resAddress);
			self.address := address;
		endif;
	endif;
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
</Class>
