    <JadeMethod name="getCargoGroupDestPortDesc" id="741eb403-bbab-49b0-84e2-1723bb29ad17">
        <source>getCargoGroupDestPortDesc() : String;
/*

Purpose:			Gets the Cargo Groups Destination Port Description

Parameters:			NONE

Return Value:		String: Which contains the destination port if there is only 1, otherwise it will return the text "Multiple"

Date		Who		Reason
29 Mar 2023	navpw1	Initial creation TFS: 57198
09 Jan 2023 navbk1  Bug 61943: FR | 53422 - Cargo Group overview in Mobile Apps (part II)
28 May 2024 navrv30 CR 64323 Task 64327: Jade - Chnage Existing Get methods to use Details
01 Jul 2024 navhl20	Bug 64983: FR | 53422 - Cargo Group overview in Mobile Apps showing code instead of description for destination port.
24/03/2025	navkc1 JIRA Story MTN-34256: MTN | Cargo Group Details for non Euroports Clients
*/

vars
	cgd 		: CM_CargoGroupDetail;
	retStr, 
	retStrDesc,
	valueStr,
	valueStrDesc: String;
	port		: CM_Port;
	strArr		: StringArray;		
	ti			: CM_TrackedItem;
begin
	create strArr transient;
	
	//24/03/2025	navkc1 JIRA Story MTN-34256
	if self.allCargoGroupDetails.isEmpty() then
		foreach ti in self.allAssignedTrackedItems discreteLock do
			retStr.addStringToList(ti.destinationPort, ", ");
		endforeach;
	else
		foreach cgd in self.allCargoGroupDetails discreteLock do
			valueStr := cgd.destinationPort;
			/*
			if valueStr &lt;&gt; null then
				if retStr.pos(valueStr, 1) = 0 then
					if retStr = null then
						retStr := valueStr;
					else
						retStr := retStr &amp; "," &amp; valueStr;
					endif;
				endif;
			endif;
			*/
			
			retStr.addStringToList(valueStr, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
		endforeach;
	endif;
	
	retStr.getTokensForDelimiter(Comma,strArr);
	
	foreach valueStr in strArr do
		port := app.myRoot.allPorts[valueStr];
		valueStrDesc := port.description;
		/*
		if valueStrDesc &lt;&gt; null and retStrDesc.pos(valueStrDesc, 1) = 0 then
			if retStrDesc = null then
				retStrDesc := retStrDesc &amp; valueStrDesc;
			else
				retStrDesc := retStrDesc &amp; Comma &amp; valueStrDesc;
			endif;
		endif;
		*/
		
		retStrDesc.addStringToList(valueStrDesc, Comma); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return retStrDesc;
epilog
	delete strArr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
