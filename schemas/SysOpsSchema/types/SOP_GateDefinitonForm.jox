    <JadeMethod name="handleNotificationRefreshView" id="7d98d01f-0b85-496b-9bdd-ec816cfc7647">
        <updating/>
        <source>handleNotificationRefreshView(_eventType: Integer; _object: Object; _eventTag: Integer; _userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	event	:Integer;
begin 
	event 	:= self.myTerminal.getEventFromTerminalEvent(_eventType);
	
	// this is a fairly blunt approach to updating the gate list 
	// the framework handles catching changes to the gate currently being edited butnot the item being viewed
	// we don't expect gates etc to be very volitile and will generally be maintined by only one person
	if event = EVENT_GATE_DELETE and
		self.mode = self.Mode_View and
		self.myCurrentObject = _userInfo.CM_Gate then
		// they have deleted the gate we are viewing
		// this is not ideal but the framework does not seem to handle the object being
		// viewed getting deleted
		self.zLstDataSysNotifyDelete (Object_Delete_Event, _userInfo.CM_Gate, _eventTag);
		return;	// this will refresh list as well
	endif;
	
	if event = EVENT_GATE_CREATE or
		event = EVENT_GATE_UPDATE or
		event = EVENT_GATE_DELETE then
		self.zBeginTimerForRefresh;
	endif;
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
