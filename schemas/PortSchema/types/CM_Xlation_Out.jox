<Class name="CM_Xlation_Out" id="7a9374fc-84dd-4ff0-8b04-2edee99a6d20">
    <superclass name="CM_Xlation"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <JadeMethod name="erase" id="3d14d330-699a-4b82-91e2-71ba12cbb73f">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
Date		Who		Reason
12 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	xlationTable	:CM_XlationTable;
begin
	self.exclusiveLock(self);
	
	xlationTable := self.myXlationTable;
	
	if xlationTable &lt;&gt; null then
		self.exclusiveLock(xlationTable);

		if _eraseLevel = NORMAL_ERASE and
			xlationTable.allInwardTranslations.size = 0 and		// there are no inward translations
			xlationTable.allOutwardTranslations.size = 1 then	// I am the last outward translation
			
			// if last sibling in parent(xlationTable) then nuke the olds who will nuke me
			xlationTable.erase(NORMAL_ERASE);
		else
			// parent still has other children just nuke myself
			inheritMethod(_eraseLevel);
		endif;
	else
		inheritMethod(_eraseLevel);
	endif;
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="73206069-0550-4b5c-8237-9f2af6bda0e3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Date		Who		Reason
11 Mar 2013	cnwcs5	Initial Creation - CCMS PNL 2243 / par 31185 
03 Jul 2013	cnwcs5	par 31261 - remove redundant propertyies/ETRow_ constants
*/
vars

begin
	if _attrName = ETRow_Criteria then
		return null;	// does not apply
	
	elseif _attrName = 	ETRow_ForeignIn then
		return null;
		
	elseif _attrName = ETRow_ForeignOut then
		return self.foreignCode;
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="b3f1b795-9fe4-4960-9c9d-6da7f2521d2c">
        <source>validateMe();
/*
Date		Who		Reason
25 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	xlationTable, pxyXlationTable	: CM_XlationTable;
	realXlation, xlationOut			: CM_Xlation_Out;
begin
	inheritMethod();

	pxyXlationTable := self.myXlationTable;
	xlationTable	:= pxyXlationTable.pxyGetRealObject;
	
	
	//  there should be no other xlation out there for the same system code
	if xlationTable &lt;&gt; null then
		realXlation := self.pxyGetRealObject;

		if realXlation &lt;&gt; null and realXlation.systemCode = self.systemCode then
			// we are not changing system code so don't bother checking for duplicates
			
		else
		
			foreach xlationOut in xlationTable.allOutwardTranslations where xlationOut.systemCode = self.systemCode do
				if not xlationOut.isDisabled then
					if realXlation &lt;&gt; null and xlationOut = realXlation then
						// OK 
						continue;
					endif;
					// there is another outward translations for this system code - we don't allow duplicates
					// GUI should take care of this
					app.raiseUnexpectedProgramError (self.class.name, method.name, 'Duplicate Outward Translation');
				endif;
			endforeach;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
