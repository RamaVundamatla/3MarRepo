    <JadeMethod name="updateMeasurementInCargoType" id="fdd0e87d-fe2c-4856-846d-68c60154db94">
        <source>updateMeasurementInCargoType( _controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2022	navsp1	Initial creation TFS#52718

*/

vars
	cargotype			: CM_CargoType;						
	systemSubType 		: CM_Product;						
	prodAttr 			: CM_ProductAttr;					
	measurementType 	: CM_MeasurementType;
	defWeightType 		: CM_MeasurementType;
	defVolumeType 		: CM_MeasurementType;
	defDensityType 		: CM_MeasurementType;
	defLinearType 		: CM_MeasurementType;
	defStowageFactorType: CM_MeasurementType;
		
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog( method.qualifiedName &amp; 'Update measurement type changes in cargotype ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Update measurement type changes in cargotype ") ;
	endif;
	
	beginTransaction;
	
	defWeightType	 	:= app.getDefaultMeasurementForType(Type_Weight);	
	defVolumeType 		:= app.getDefaultMeasurementForType(Type_Volume);
	defDensityType 		:= app.getDefaultMeasurementForType(Type_Density);
	defLinearType 		:= app.getDefaultMeasurementForType(Type_Linear);
	defStowageFactorType:= app.getDefaultMeasurementForType(Type_StowageFactor);
	
		foreach cargotype in app.myRoot.allCargoTypesById do
			if cargotype.mySystemProductType &lt;&gt; null then
				systemSubType := cargotype.mySystemProductType;
					if defWeightType &lt;&gt; null and systemSubType.getMyWeight &lt;&gt; null 
					and systemSubType.getMyWeight.myMeasurementType &lt;&gt; defWeightType then
						prodAttr := systemSubType.getMyWeight;
						prodAttr.setMyMeasurementType(defWeightType);
					endif;
					
					if defVolumeType &lt;&gt; null and systemSubType.getMyVolume &lt;&gt; null 
					and systemSubType.getMyVolume.myMeasurementType &lt;&gt; defVolumeType then
						prodAttr := systemSubType.getMyVolume;
						prodAttr.setMyMeasurementType(defVolumeType);
					endif;
					
					if defDensityType &lt;&gt; null and systemSubType.getMyDensity &lt;&gt; null 
					and systemSubType.getMyDensity.myMeasurementType &lt;&gt; defDensityType then
						prodAttr := systemSubType.getMyDensity();
						prodAttr.setMyMeasurementType(defDensityType);
					endif;	
					
					if defLinearType &lt;&gt; null then
						if systemSubType.getMyHeight &lt;&gt; null
						and systemSubType.getMyHeight.myMeasurementType &lt;&gt; defLinearType then
							prodAttr := systemSubType.getMyHeight();
							prodAttr.setMyMeasurementType(defLinearType);
						endif;
						if systemSubType.getMyWidth &lt;&gt; null
						and systemSubType.getMyWidth.myMeasurementType &lt;&gt; defLinearType then
							prodAttr := systemSubType.getMyWidth();
							prodAttr.setMyMeasurementType(defLinearType);
						endif;
						if systemSubType.getMyLength &lt;&gt; null
						and systemSubType.getMyLength.myMeasurementType &lt;&gt; defLinearType then
							prodAttr := systemSubType.getMyLength();
							prodAttr.setMyMeasurementType(defLinearType);
						endif;
					endif;
					
					if defStowageFactorType &lt;&gt; null and systemSubType.getMyStowageFactor() &lt;&gt; null
					and systemSubType.getMyStowageFactor.myMeasurementType &lt;&gt; defStowageFactorType then
						prodAttr := systemSubType.getMyStowageFactor();
						prodAttr.setMyMeasurementType(defStowageFactorType);
					endif;	
					
			endif;
		endforeach;
		
	
	commitTransaction;
	
	app.writeLog( method.qualifiedName &amp; 'Update measurement type changes in cargotype ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry('Update measurement type changes in cargotype ') ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updatePermissionViewType" id="a747cc0a-1ff2-4db4-914b-5a9295a9e5a1">
        <source>updatePermissionViewType(_releaseController : CnEcReleaseController);

/*
Purpose: Update the new attribute 'formType' of all CM_Permission objects that are suspected to be of View-Type.
		 The idea is to check for the word 'View' in the constant name or in the constant description (eg.PmAdmCargoEnquiryConfigView).
		 Basically we have 2 form types associated with the global constants (ie. PmAdmActivitiyHistoryView, PmAdmActivitiyHistoryMaint)
		 1. View Type 
		 2. Maintenance Type 

Parameters:			

Return Value:		

Date		Who		TFS		Reason
04 Sep 2019	jlgdi1	45802	Initial creation
13 Sep 2019	NDL				Added the list of hard-coded items
25 Oct 2019	jlgdi1	46820	Added a method call to resetMenuForJMTSupportUser()
*/

constants
	PERMTYPE_SPECIAL : Integer = 2;
	
vars
	permAgent : CM_PermissionAgent;
	permObj : CM_PermissionObject;
	result : String;
	identified : Boolean;
	niether : String;
	otherMaintPermissions : IntegerArray;
	otherViewPermissions : IntegerArray;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _releaseController) then
		return;
	endif;
	
	result := "Updating the form type attribute of all Permissions based on Constant name or description started";
	self.createLogEntry(_releaseController,
						method.qualifiedName,
						result);
	
	create permAgent transient;
	permAgent.populatePermissionDict(true, false, 0);
	
	create otherMaintPermissions transient;
	create otherViewPermissions transient;
	
	self.createOtherMaintPermissionList(otherMaintPermissions);
	self.createOtherViewPermissionList(otherViewPermissions);
		
	foreach permObj in permAgent.allPermissionsByName do
		if permObj.permType = PERMTYPE_SPECIAL then
			continue;
		endif;
		
		// Meaning permission hasn't been updated by the script nor PermissionApp
		if permObj.formType = 0 then 
			if (permObj.constName.pos("View", 1) &gt; 0) or (permObj.description.pos("View", 1) &gt; 0) then 
				identified := true;
				permObj.formType := ViewType;
			elseif (permObj.constName.pos("Maint", 1) &gt; 0) or (permObj.description.pos("Maint", 1) &gt; 0) then 
				identified := true;
				permObj.formType := MaintenanceType;
			elseif otherMaintPermissions.includes( permObj.constValue ) then
				identified := true;
				permObj.formType := MaintenanceType;
			elseif otherViewPermissions.includes( permObj.constValue ) then
				identified := true;
				permObj.formType := ViewType;
			else
				identified := false;
				niether := niether &amp; permObj.constName &amp; CrLf;
			endif;
			if identified then 
				permObj.constText := permObj.outputAsXML();
				permAgent.trxSaveDataToGlobalConstants(permObj);
			endif;
		endif;
	endforeach;
	
	self.resetMenuForJMTSupportUser();
	
	result := "Updating the form type attribute of all Permissions based on Constant name or description completed ";
	
	if niether.length &gt; 0 then
		self.createLogEntry(_releaseController,
							method.qualifiedName,
							niether);
		result := result &amp; " but could not identify some of the permissions";
	else
		result := result &amp; " successfully";
		
		self.addScriptRun(method.name);
	endif;
	
	self.createLogEntry(_releaseController,
						method.qualifiedName,
						result);
epilog
	delete permAgent;
	delete otherMaintPermissions;
	delete otherViewPermissions;	
end;</source>
        <Parameter name="_releaseController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateQueryProperties" id="2701de24-33ce-47fe-810a-40f2b46b4099">
        <source>updateQueryProperties(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2019	jlger1	Initial creation 47132 
		* renamed query property Location to Location ID
		* renamed query propety Chassis Type to Chassis Type Code
        * added query property Location which is a lookup type ie user selects from combo
		* added query property Chassis Type which is a lookup type ie user selects from combo
		* added query property Queued Terminal Area
		* For BOLs added
				- sub terminal and voyage 
*/

vars
	os : ObjectArray;
	obj : Object;
	critHolder : CM_QueryCriteriaLineHolder;
	critLine : CM_SelectorCriteriaLine;
begin	
		
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog( method.qualifiedName &amp; 'Updating Query Properties ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Updating Query Properties") ;	
	endif;		

	create os transient;
	CM_MenuUserQuery.allInstances(os,null,true);
	
	foreach obj in os discreteLock do
		foreach critHolder in obj.CM_MenuUserQuery.allCriteriaLineHolders discreteLock do
			critLine:=critHolder.findCriteriaByName(CM_TrackedItem::locationId.name);
			if critLine &lt;&gt; null and critLine.myQueryProperty.niceName &lt;&gt; 'Location ID' then
				beginTransaction;
				critLine.myQueryProperty.setNiceName('Location ID');
				commitTransaction;
				
			endif;
			critLine:=critHolder.findCriteriaByName(CM_TrackedItem::getTrailerType.name);
			if critLine &lt;&gt; null and critLine.myQueryProperty.niceName &lt;&gt; 'Chassis Type Code' then
				beginTransaction;
				critLine.myQueryProperty.setNiceName('Chassis Type Code');
				commitTransaction;
				
			endif;
		endforeach;	
	endforeach;
	

	app.writeLog(method.qualifiedName &amp; " update Query Properties  complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry(" update Query Properties complete") ;	
	endif;
	
	//self.addScriptRun(method.name);
	
epilog
	delete os;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateRoadGateReleasedCargo" id="ad51a244-003d-40bf-acd5-0793e5c664bb">
        <source>updateRoadGateReleasedCargo(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2019	jlgmp6	Initial creation	TFS40701

*/

vars
	term : CM_Terminal;

begin
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Setting up Term Config 'UpdateReleasedCargo'", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting up Term Config 'UpdateReleasedCargo'") ;	
	endif;

	beginTransaction;
	foreach term in app.myRoot.allTerminals do
		term.setConfig(UpdateReleasedCargo, 3.Integer);
	endforeach;
	commitTransaction;

	app.writeLog(method.qualifiedName &amp; " Setting up Term Config 'UpdateReleasedCargo' complete", LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting up Term Config 'UpdateReleasedCargo' complete") ;	
	endif;

	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageProcesses" id="d5bdb7f8-559b-43f2-95bb-c809088b8bad">
        <source>updateVoyageProcesses(_controller: CnEcReleaseController);
/*

Purpose:			Delete InaPortNet Voyage Process and Statuses
					Delete Pel1 voyage process
					Rename some old statuses

Parameters:			

Return Value:		

Date				Who		Reason
21 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars
	defaultProcess,
	inaPortNetProcess,
	pelindoProcess,
	woProcess				: CM_VoyageProcess;
	pxyStatus, realStatus 	: CM_VoyageStatus;
	terminal 				: CM_Terminal;
	defaultEmail 			: CM_VoyStatusDefaultEmail;
	defaultVP : String;
begin
	
	
	
	app.writeLog(method.qualifiedName &amp; " Deleting Unused Voyage Processes and Statuses", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Deleting Unused Voyage Processes and Statuses") ;	
	endif;
	
	beginTransaction;
	// inaportnet process is no longer needed, remove process and all statuses 
	inaPortNetProcess := CM_VoyageProcessIPN1.firstInstance;
	if inaPortNetProcess &lt;&gt; null then
		foreach realStatus in inaPortNetProcess.allStatusesById do
			delete realStatus;
		endforeach;
		delete inaPortNetProcess;	
	endif;
	
	// If the pelindo process was set as the default process, update to use mtnwo process
	foreach terminal in app.myRoot.allTerminals do
		defaultVP:=terminal.getConfig(DefaultVoyageProcess).String;
		if defaultVP = VoyageProcessPelindo1 then
			terminal.setConfig(DefaultVoyageProcess, VoyageProcessWO);
		elseif defaultVP = "JMT"  or defaultVP = null  then
			terminal.setConfig(DefaultVoyageProcess, VoyageProcessDefault);
		endif;
	endforeach;
	
	// pelindo process is being replaced by mtn work orders process.
	pelindoProcess := CM_VoyageProcessPEL1.firstInstance;	
	if pelindoProcess &lt;&gt; null then
		// status should have already by transfered by createWOVoyageProcess script run in specificPreStandard
		// but for sake of completeness, delete any that remain
		foreach realStatus in pelindoProcess.allStatusesById do
			delete realStatus;
		endforeach;
		delete pelindoProcess;
	endif;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Deleting Unused Voyage Processes and Statuses COMPLETE", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Deleting Unused Voyage Processes and Statuses COMPLETE") ;	
	endif;
	//jlier1 TFS 52213 lets make sure terminals have default set
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	
	app.writeLog(method.qualifiedName &amp; " Renaming old voyage statuses to MTNWO status names", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Renaming old voyage statuses to MTNWO status names") ;	
	endif;
	
	beginTransaction;
	woProcess := CM_VoyageProcessWO.firstInstance;
	if woProcess &lt;&gt; null then
		realStatus := woProcess.allStatusesById[Voyage_Status_VoyRequested];
		if realStatus &lt;&gt; null then
			// Rename voyage status 'Voyage Request - Manual ETMAL Required' to be 'Voyage Requested'
			pxyStatus := realStatus.pxyCreateUpdateProxy();
			pxyStatus.setProxy(pxyStatus.id, pxyStatus.priority, "Voyage Requested", woProcess, null, pxyStatus.reportToRun,false);
			app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
			delete pxyStatus;
		endif;
		
		realStatus := woProcess.allStatusesById[Voyage_Status_VoyReqSubmitted];
		if realStatus &lt;&gt; null then
			// Rename voyage status 'ETMAL Calculated' to be 'Voyage Request Submitted'.
			pxyStatus := realStatus.pxyCreateUpdateProxy();
			pxyStatus.setProxy(pxyStatus.id, pxyStatus.priority, "Voyage Request Submitted", woProcess, null, pxyStatus.reportToRun,false);
			app.myUtilityUA.utlUpdateVoyageStatus(pxyStatus, app.myPassport);
			delete pxyStatus;
		endif;
		
		// If default emails using the default subject line, update to new name
		defaultEmail := app.myRoot.allVoyStatusDefaultEmails[PINEmail_VoyVoyageRequested];
		if defaultEmail &lt;&gt; null and defaultEmail.subjectLine = "Voyage Requested (Manual PKK)" then
			defaultEmail.setPropertyValue( CM_VoyStatusDefaultEmail::subjectLine.name, "Voyage Requested");
		endif;
		defaultEmail := app.myRoot.allVoyStatusDefaultEmails[PINEmail_VoyReqSubmitted];
		if defaultEmail &lt;&gt; null and (defaultEmail.subjectLine = "ETMAL Calculated" or defaultEmail.subjectLine = "Voyage Requested (Manual PKK)") then
			defaultEmail.setPropertyValue( CM_VoyStatusDefaultEmail::subjectLine.name, "Voyage Request Submitted");
		endif;
	endif;		
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Renaming old voyage statuses to MTNWO status names COMPLETE", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Renaming old voyage statuses to MTNWO status names COMPLETE") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete pxyStatus;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
</Class>
