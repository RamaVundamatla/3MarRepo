<Class name="CM_GeneralCargoAllocRowArea" id="da2e1c23-9854-4b05-b86c-c1e2e3936a61">
    <superclass name="CM_RowArea"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <JadeMethod name="createFromProxy" id="782ebd7d-6d5b-46bd-a8dd-3ce48a61bf28">
        <updating/>
        <source>createFromProxy(_proxy : SelfType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	pxyRow, realRow : CM_RowAreaRow;
	lc, colLC : CM_LocationsController;
	pxyGroup, realGroup : CM_GeneralCargoAllocGroup;
	pxyCol, realCol : CM_GeneralCargoAllocController;
	rowIdx : Integer;
	exObj : CM_Exception;
	prodMinMax : CM_TerminalAreaProductMinMax;

begin
	self.lengthOfArea := _proxy.lengthOfArea;
	self.widthOfArea := _proxy.widthOfArea;
	
	//06 Apr 2021	NDL	TFS 49912
	//clear out capacities tied to group locations before purge of locations.
	foreach prodMinMax in self.allProductMinMax do
		if prodMinMax.myLocationsController &lt;&gt; null then
			delete prodMinMax;
		endif;
	endforeach;
	
	// Clear all rows
	self.allRows.purge;
	
	// And all groups
	self.allRowControllersById.purge;
	
	// Create from scratch - Rows
	foreach pxyRow in _proxy.allRows do
		create realRow persistent;
		self.allRows.add(realRow);
		realRow.setAttributes(pxyRow.width);
	endforeach;
	
	// Groups
	foreach lc in _proxy.allRowControllersById do
		pxyGroup := lc.CM_GeneralCargoAllocGroup;
		create realGroup persistent;
		realGroup.setDetails(pxyGroup.id, self);
		realGroup.setProductMinMax( lc );	//06 Apr 2021	NDL	TFS 49912
		
		// And locations in group
		foreach colLC in pxyGroup.allLocations do
			pxyCol := colLC.CM_GeneralCargoAllocController;
			create realCol persistent;
			realCol.setDetails(pxyCol.id, realGroup);
			
			rowIdx := rowIdx + 1;
			realRow := self.allRows[rowIdx];
			realRow.addController(realCol);
		endforeach;
	endforeach;
	
	rowIdx := 1;
	while rowIdx &lt;= self.allRows.size do
		realRow := allRows[rowIdx];
		if realRow.allRowControllers.isEmpty then
			create exObj transient;
			exObj.set(99999, "Row " &amp; rowIdx.String &amp; " has no controllers", false, null, null, null);
			raise exObj;
		endif;
		rowIdx := rowIdx + 1;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="createProxyLCsAndGroups" id="c24650a6-f130-4a46-8419-3bb0145deff9">
        <updating/>
        <source>createProxyLCsAndGroups(_colArray, _divArray : StringArray) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// 16/12/2020	jlgdap1		TFS 50110 ASPA General Cargo Allocation Row - Label
//
vars
	divider, column, lastDiv : String;
	pxyGroup : CM_GeneralCargoAllocGroup;
	pxyLC : CM_GeneralCargoAllocController;
	pxyRow : CM_GeneralCargoAllocRow;
	label : String;
	firstCols, lastCols, rangeLabels : StringArray;			// TFS 50110
	lc : CM_LocationsController;							// TFS 50110
	idx : Integer;											// TFS 50110
	firstCol, lastCol, range, lastRange : String;			// TFS 50110
	objArrayArray : ObjectArray;	//29 Mar 2021	NDL	TFS 49912
	minMaxSet : CM_TerminalAreaProdMinMaxSet;	//29 Mar 2021	NDL	TFS 49912
	minMax : CM_TerminalAreaProductMinMax;	//29 Mar 2021	NDL	TFS 49912
	minMaxIdArray : StringArray;

begin
	self.raiseExceptionIfNotTransient(method);
	
	// TFS 50110 Save off the current range labels and columns they match
	create firstCols transient;
	create lastCols transient;
	create rangeLabels transient;
	create objArrayArray transient;
	create minMaxIdArray transient;
	foreach lc in self.allRowControllersById do
		pxyGroup := lc.CM_GeneralCargoAllocGroup;
		if pxyGroup.rangeLabel &lt;&gt; null then
			firstCols.add(pxyGroup.firstColumn);
			lastCols.add(pxyGroup.lastColumn);
			rangeLabels.add(pxyGroup.rangeLabel);
			//29 Mar 2021	NDL	TFS 49912 - save off and remove the references to their parents so they aren't deleted below
			create minMaxSet transient;
			objArrayArray.add( minMaxSet );
			if not lc.CM_GeneralCargoAllocGroup.allProductMinMax.isEmpty then
				lc.CM_GeneralCargoAllocGroup.allProductMinMax.copy( minMaxSet );
				foreach minMax in minMaxSet do
					minMax.setMyParents( null, null );
				endforeach;
			endif;
		endif;
	endforeach;
	// TFS 50110 end of this bit
	
	//06 Apr 2021	NDL	TFS 49912 - save off and remove the references to their parents so they aren't deleted below
	foreach lc in self.allRowControllersById do
		pxyGroup := lc.CM_GeneralCargoAllocGroup;
		minMaxIdArray.add( pxyGroup.ident );
		create minMaxSet transient;
		objArrayArray.add( minMaxSet );
		if not lc.CM_GeneralCargoAllocGroup.allProductMinMax.isEmpty then
			lc.CM_GeneralCargoAllocGroup.allProductMinMax.copy( minMaxSet );
			foreach minMax in minMaxSet do
				minMax.setMyParents( null, null );
			endforeach;
		endif;
	endforeach;
	
	
	self.allRows.purge;
	self.allRowControllersById.purge;
	
	// allow for an empty divider range - so we're just going to have one group with all the columns in it
	if _divArray.isEmpty then
		lastDiv := _colArray.first;
	endif;
	foreach divider in _divArray do
		create pxyGroup transient;
		foreach column in _colArray do
			if column &gt;= lastDiv and column &lt; divider then										// TFS 51904
			//if column &gt; lastDiv and column &lt;= divider then	// TFS 51904
				create pxyLC transient;
				pxyLC.setDetails(column, pxyGroup);
				
				create pxyRow transient;
				self.allRows.add(pxyRow);
				pxyRow.addController(pxyLC);
			endif;
		endforeach;
		
		if pxyGroup.allLocations.first = pxyGroup.allLocations.last then
			label := pxyGroup.allLocations.first.CM_GeneralCargoAllocController.id;
		else
			label := pxyGroup.allLocations.first.CM_GeneralCargoAllocController.id &amp; Hyphen &amp; pxyGroup.allLocations.last.CM_GeneralCargoAllocController.id;
		endif;
		pxyGroup.setDetails(label, self);
		
		lastDiv := divider;
	endforeach;
	
	// now the last group
	if lastDiv &lt;&gt; null then
		create pxyGroup transient;
		foreach column in _colArray do
			if column &gt;= lastDiv then
				create pxyLC transient;
				pxyLC.setDetails(column, pxyGroup);
				
				create pxyRow transient;
				self.allRows.add(pxyRow);
				pxyRow.addController(pxyLC);
			endif;
		endforeach;
		
		if pxyGroup.allLocations.first = pxyGroup.allLocations.last then
			label := pxyGroup.allLocations.first.CM_GeneralCargoAllocController.id;
		else
			label := pxyGroup.allLocations.first.CM_GeneralCargoAllocController.id &amp; Hyphen &amp; pxyGroup.allLocations.last.CM_GeneralCargoAllocController.id;
		endif;
		pxyGroup.setDetails(label, self);
	endif;
	
	// TFS 50110 restore the range labels to their appropriate group
	foreach lc in self.allRowControllersById do
		pxyGroup := lc.CM_GeneralCargoAllocGroup;
		foreach idx in 1 to firstCols.size do
			firstCol := firstCols[idx];
			lastCol := lastCols[idx];
			range := rangeLabels[idx];
			if pxyGroup.firstColumn = firstCol then
				pxyGroup.updateRangeLabel(range);
				lastRange := range;
				break;
			elseif ((firstCol &gt;= pxyGroup.firstColumn and firstCol &lt; pxyGroup.lastColumn) 
					or (pxyGroup.firstColumn &gt; firstCol and lastCol = pxyGroup.lastColumn))
					and range &lt;&gt; lastRange then
				pxyGroup.updateRangeLabel(range);
				lastRange := range;
				break;
			endif;
			lastRange := range;
		endforeach;
	endforeach;
	// TFS 50110 end of this bit
	
	//06 Apr 2021	NDL	TFS 49912 - associate cargo max capacity objects back to the 'new' parent column groups, BUT
	// only if they have the same id. Becuase this means they haven't changed size or position.  If the column group
	// definitions have changed, then new capacities will need to be be manually created by teh user.
	foreach lc in self.allRowControllersById do
		pxyGroup := lc.CM_GeneralCargoAllocGroup;
		idx := minMaxIdArray.indexOf( pxyGroup.ident );
		if idx &gt; 0 and idx &lt;= minMaxIdArray.size then
			minMaxSet := objArrayArray[idx].CM_TerminalAreaProdMinMaxSet;		
			foreach minMax in minMaxSet do			
				minMax.setMyParents( self, lc );	
			endforeach;								
			minMaxSet.clear();
		endif;
	endforeach;
	
epilog
	delete firstCols;			// TFS 50110
	delete lastCols;			// TFS 50110
	delete rangeLabels;			// TFS 50110
	if objArrayArray &lt;&gt; null then	 //29 Mar 2021	NDL	TFS 49912
		//clean up those that were no longer valid.
		objArrayArray.purge();	 //29 Mar 2021	NDL	TFS 49912
	endif;	 //29 Mar 2021	NDL	TFS 49912
	delete objArrayArray; //29 Mar 2021	NDL	TFS 49912
	delete minMaxIdArray; //06 Apr 2021	NDL	TFS 49912
end;</source>
        <Parameter name="_colArray" type="StringArray"/>
        <Parameter name="_divArray" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="doesNewRangeOverlapExisting" id="43f2e567-3f2e-45b5-a012-d015b13b878e">
        <source>doesNewRangeOverlapExisting(_first, _last : CM_GeneralCargoAllocController; _alloc : CM_YardAllocation) : Boolean;
//
// Purpose:			Check whether the columns between _first and_last are already in a yard allocation
//
// Parameters:			
//
// Return Value:	True if already covered by an allocation, false otherwise
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	ya : CM_YardAllocation;
	block : CM_YABlock;

begin
	foreach ya in self.allYardAllocations discreteLock where ya &lt;&gt; _alloc do
		foreach block in ya.allYABlocksIn discreteLock do
			if block.allYardControllers.includes(_first) or block.allYardControllers.includes(_last) then
				return true;
			endif;
		endforeach;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_first" type="CM_GeneralCargoAllocController"/>
        <Parameter name="_last" type="CM_GeneralCargoAllocController"/>
        <Parameter name="_alloc" type="CM_YardAllocation"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findYABlock" id="86027976-ee6c-4c7f-994a-d835a4cfad9f">
        <source>findYABlock(_locationText: String; _topLeftLC: CM_LocationsController output; _bottomRightLC: CM_LocationsController output; _taViewPos: CM_TerminalAreaViewPosition): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	locText : String;
	colFrom, colTo, tempCol : String;
	group : CM_GeneralCargoAllocGroup;

begin
	if _locationText = null then
		if not self.getMaxRowColString(locText) then
			return false;
		endif;
	else
		locText := _locationText.trimBlanks;
	endif;
	
	self.parseColString(locText, colFrom, colTo);
	
	if colFrom &gt; colTo then
		tempCol := colFrom;
		colFrom := colTo;
		colTo := tempCol;
	endif;
	
	_topLeftLC := self.getColumnControllerForCol(colFrom);
	if _topLeftLC = null then
		group := self.allRowControllersById.first.CM_GeneralCargoAllocGroup;
		if group &lt;&gt; null then	//10 May 2021	NDL	TFS 51156
			_topLeftLC := group.allLocations.first;
		endif;
		if _topLeftLC = null then
			return false;
		endif;
	endif;
	
	_bottomRightLC := self.getColumnControllerForCol(colTo);
	if _bottomRightLC = null then
		group := self.allRowControllersById.last.CM_GeneralCargoAllocGroup;
		_bottomRightLC := group.allLocations.last;
		if _bottomRightLC = null then
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_locationText" type="String"/>
        <Parameter name="_topLeftLC" type="CM_LocationsController" usage="output"/>
        <Parameter name="_bottomRightLC" type="CM_LocationsController" usage="output"/>
        <Parameter name="_taViewPos" type="CM_TerminalAreaViewPosition"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllLCsWithCargo" id="36c9a81a-e897-4bae-8168-4ae8f807f641">
        <source>getAllLCsWithCargo(_locationControllerArray: ObjectArray io);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	lc, lcCol : CM_LocationsController;
	group : CM_GeneralCargoAllocGroup;

begin
	foreach lc in self.allRowControllersById discreteLock do
		foreach lcCol in lc.CM_GeneralCargoAllocGroup.allLocations discreteLock do
			// no tracked items then don't require it
			if lcCol.allTrackedItems.isEmpty then
				continue;
			endif;
			// if not already in the array then add to the array
			if not _locationControllerArray.includes(lcCol) then
				_locationControllerArray.add(lcCol);
			endif;
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_locationControllerArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllLocationsControllers" id="d75baff6-d2a0-46b6-ae1d-155f1dac45b7">
        <source>getAllLocationsControllers(_locationControllerArray: ObjectArray io);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 30/06/2020		jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	lcGroup, lc : CM_LocationsController;

begin
	foreach lcGroup in self.allRowControllersById discreteLock do
		foreach lc in lcGroup.CM_GeneralCargoAllocGroup.allLocations do
			_locationControllerArray.addExclusive(lc);
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_locationControllerArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllLocationsControllersById" id="e4bf17e1-5b8a-41fd-9a97-876b4b591058">
        <source>getAllLocationsControllersById(_lcById : CM_LCByIdExtKeyDict input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite Area Screen for Flexible Terminal Areas
//
vars
	lc, subLC : CM_LocationsController;
	group : CM_GeneralCargoAllocGroup;

begin
	foreach lc in self.allRowControllersById do
		group := lc.CM_GeneralCargoAllocGroup;
		foreach subLC in group.allLocations do
			_lcById.add(subLC);
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_lcById" type="CM_LCByIdExtKeyDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllPlannedQueuedTIs" id="d9364b15-ed11-438f-a114-8f7274bbdd14">
        <source>getAllPlannedQueuedTIs(_tiArray : CM_TIArray input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 10/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	lc : CM_LocationsController;
	column : CM_GeneralCargoAllocController;

begin
	foreach lc in self.allLocationsControllers discreteLock do
		lc.getAllPlannedTrackedItems(_tiArray, false, false);
		lc.getAllQueuedTrackedItems(_tiArray, false);
	endforeach;
epilog

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllRowGroupControllers" id="303d99c1-8081-463e-89f8-57d57e5a3eb4">
        <source>getAllRowGroupControllers(_lcSet : CM_LCSet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2021	navndl1	Initial creation	TFS 51336

*/

vars

begin

	self.allRowControllersById.copy( _lcSet );

epilog

end;</source>
        <Parameter name="_lcSet" type="CM_LCSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllRowGroups" id="5a6c51f7-6bb6-42a7-9337-87d206dee280">
        <source>getAllRowGroups() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 26/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	group : CM_LocationsController;
	result : String;
	length : Integer;

begin
	foreach group in self.allRowControllersById discreteLock do
		result := result &amp; group.CM_GeneralCargoAllocGroup.id &amp; Comma;
	endforeach;
	length := result.length;
	if result[length:end] = Comma then
		result := result[1:length-1];
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllTrackedItems" id="18c44d13-fef1-4f70-9332-eddad74ea605">
        <source>getAllTrackedItems(_tiArray : CM_TIArray input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	row : CM_RowAreaRow;
	lc : CM_LocationsController;
	ti : CM_TrackedItem;

begin
	foreach row in self.allRows discreteLock do
		lc := row.allRowControllers.first;		// one to one relationship
		lc.allTrackedItems.copyNoDuplicates(_tiArray);
	endforeach;
epilog

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="ac0ea85a-586b-4fb8-810a-5a8f758ab461">
        <source>getAuditText(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	result : String;

begin
	result[10000] := '*';
	result := null;
	result := inheritMethod();
	
	result := result &amp; self.formatAuditText(ETRow_ColumnLabels, self.getColumnLabels)
					&amp; self.formatAuditText(ETRow_DividersBefore, self.getDividers);
	
	return result;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getColumnControllerForCol" id="cc55a2be-58b7-473d-af49-a16243ad6b14">
        <source>getColumnControllerForCol(_col : String) : CM_LocationsController;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	lc, columnLC : CM_LocationsController;
	group : CM_GeneralCargoAllocGroup;

begin
	foreach lc in self.allRowControllersById discreteLock do
		group := lc.CM_GeneralCargoAllocGroup;
		foreach columnLC in group.allLocations discreteLock do
			if columnLC.ident = _col then
				return columnLC;
			endif;
		endforeach;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_col" type="String"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getColumnLabels" id="12c87e20-e022-42b1-83ea-f62f60189cce">
        <source>getColumnLabels() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	allLCs : CM_LCByIdExtKeyDict;
	lc : CM_LocationsController;
	str : String;

begin
	create allLCs transient;
	self.getAllLocationsControllersById(allLCs);
	foreach lc in allLCs do
		str := str &amp; lc.ident &amp; Comma;
	endforeach;
	str := str.stripTrailingChar(Comma);
	return str;

epilog
	delete allLCs;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="622dfb19-103d-4380-b578-0619518fa826">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars

begin
	if _attrName = ETRow_ColumnLabels then
		return self.getColumnLabels;
		
	elseif _attrName = ETRow_DividersBefore then
		return self.getDividers;
		
	else
		return inheritMethod(_attrName, _short);
		
	endif;

epilog
	
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDividers" id="1097a58a-de8e-4224-a568-407467fd2790">
        <source>getDividers() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	dividers : StringArray;
	lc : CM_LocationsController;
	lastGroup : CM_GeneralCargoAllocGroup;
	str, divd : String;

begin
	if self.allRowControllersById.size = 1 then
		// no dividers - all in one
		return null;
	endif;
	create dividers transient;
	foreach lc in self.allRowControllersById reversed do
		if lastGroup &lt;&gt; null then
			dividers.add(lastGroup.allLocations.first.CM_GeneralCargoAllocController.id);
		endif;
		lastGroup := lc.CM_GeneralCargoAllocGroup;
	endforeach;
	foreach divd in dividers reversed do
		str := str &amp; divd &amp; Comma;
	endforeach;
	str := str.stripTrailingChar(Comma);
	return str;
	
epilog
	delete dividers;
end;</source>
        <ReturnType type="String"/>
