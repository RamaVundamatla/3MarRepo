<Class name="CMQF_CamTransactionTemplate" id="03dc5543-7c32-4829-a953-efab489e29c9">
    <superclass name="CMQF_CamTransactions"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
27/7/09 JMH  MES 1011 JMT to CICS Interfaces -  Class added

For filtering data on Cam Protocol, over and above the Transaction Types.

The subclass will only have properties unique to Cams. Any filter attributes will be added at the superclass so they can be utilised
by Report queries if necessary. One persistent instance will be created for each unique combinations of filters required for
the MES Interfaces. 
 
They are system created objects, maintained by the method CM_ CamUserDefRepDesc.setupQFCamTransactions.
The transient query will use superclass CMQF_CamTransactionQuery.

New filters can be added, or existing filters modified. A Cam Protocol can only have one Transaction Filter nominated, so 
it may be necessary to add new ones if the existing ones are not quite what they want. Be careful changing an 
existing filter if it is used by multiple refs or other users may be using it and the filter is okay for them.

Empty Containers                             (not used, intiially added for MES1004, have left cause could be useful) 
Empty Containers,with Consignee, no Booking  MES1004
Export Containers, excl Empty                (not used, initially was MES1006 but then they wanted empty containers too, have left)
Export Containers			                 MES1006
Empty Storage Containers                     MES1007
General Cargo                                MES1008
None                                         MES1009  MES1011 MES1012 MES1046


To create a new Template Query
------------------------------
1. Add a global constant for the queryDesc  key 	- start with "QfCam_"
2. CM_CamUserDefRepDesc.setupQFCamTransactions   	- add section for new queryDesc to create if it doesn't exist, or update parameters
3. CMQF_CamTransactionTemplate.setForCreateSystem   - modifyt o set parameters requried for query

To translate the queryDesc 
4. Create a global constant for the queryDesc using the 'Text Translation' form in DMAST. Start the name with CMQF_
   (Must be separate global constant to the one used for the key, cause this is what we access it by).
5. CMQF_CamTransactionTemplate.getXlatedQueryDesc - handle new global constant


</text>
    <DbClassMap file="query"/>
    <ExplicitInverseRef name="allCamProtocol" id="a115a98c-b507-41cd-a5fa-ad22eff23d94">
        <updateMode>automatic</updateMode>
        <type name="CM_CamProtocolSet"/>
        <access>readonly</access>
        <text>
Only populated on the persistent Template</text>
        <Inverse name="CM_CamProtocol::myQFCamTransactionTemplate"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myCamProtocolDesc" id="50a8cfbb-dd8a-4dd6-88b6-4d571db52b1f">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_CamUserDefRepDesc"/>
        <access>readonly</access>
        <text>
There is only one instance of the CamUserDefRepDesc, and it will be the parent of all these queries</text>
        <Inverse name="CM_CamUserDefRepDesc::allQFCamTransactionTemplates"/>
    </ExplicitInverseRef>
    <PrimAttribute name="queryDesc" id="8b5da951-3c2c-4abf-8972-213d2c6a7488">
        <length>51</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="clearParameterArrays" id="0cfe7478-5b57-4ca3-9d16-fa6440721313">
        <updating/>
        <source>clearParameterArrays() updating;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich    278/7/09  MES1011

 Purpose:     Clear out the filter parameters that are arrays. musch easier to then maintain existing query cause can just add

 Parameters:  None

 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 
 ---------------------------------------------------------------------------
*/
vars
begin
	allQryContentStatus.clear;
	allQryImexStatus.clear;
	allQryCargoTypesExcluded.clear;
	allQryCargoTypesIncluded.clear;	
end;</source>
    </JadeMethod>
    <JadeMethod name="getXlatedQueryDesc" id="6b373e2a-222d-4e9c-9adf-c86dcbb72121">
        <source>getXlatedQueryDesc() : String;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     

 Parameters:  None

 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 
 ---------------------------------------------------------------------------
*/

vars
	
begin
	if 		queryDesc = QFCam_EditSettings				then
			return 	app.getErrorString (CMQF_Edit_Settings);
		
	elseif  queryDesc = QFCam_None						then
			return 	app.getErrorString (None);
			
	elseif  queryDesc = QFCam_EmptyContainers 			then
			return 	app.getErrorString (CMQF_Empty_Containers);
		
	elseif  queryDesc = QFCam_EmptyContainers4Release 			then
			return 	app.getErrorString (CMQF_EmptyContain4Release);
			
	elseif  queryDesc = QFCam_EmptyStorageContainers 	then
			return 	app.getErrorString (CMQF_EmptyStorageContainers);
			
	elseif  queryDesc = QFCam_ExportContainerExclEmpty 			then
			return 	app.getErrorString (CMQF_ExportContainExclEmpty);
			
	elseif  queryDesc = QFCam_ExportContainers 			then
			return 	app.getErrorString (CMQF_Exportcontainers);
		
	elseif  queryDesc = QFCam_GeneralCargo 				then			
			return 	app.getErrorString (CMQF_GeneralCargo);
	endif;
	return queryDesc;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreateSystem" id="7be4d040-6e2a-4f3a-bcd2-de3f736a06a0">
        <updating/>
        <source>setForCreateSystem(	pUserDefDesc : CM_CamUserDefRepDesc; 
							pQueryDesc : String) updating;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich    278/7/09  MES1011

 Purpose:     Create or maintain the system-generated queries required for MES Interfaces. 
			  If maintaining existing thru script then you should call method setClearParameters first so this can just add details   

 Parameters:  pUserDefDesc 
              pQueryDesc - they key of the object being created. Should be a global constant from category QFCam_KeyDescriptions

 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 07/06/2010	  cnwdap1	  CCMS 1116 Tranship changes - include new tranship imex status for export queries
 ---------------------------------------------------------------------------
*/
vars

begin

	if 	queryDesc 	= null  or
		queryDesc &lt;&gt;  pQueryDesc then 
		queryDesc 			:= pQueryDesc;
		myCamProtocolDesc 	:= pUserDefDesc;
	endif;
	
	clearParameterArrays;
	
	onlyBookingRefWith 	:= Only_State_All;
	onlyConsigneeWith 	:= Only_State_All;
	
	if  queryDesc = QFCam_None								then
		// no extra filters required, leave everything null
		
	elseif  queryDesc = QFCam_EmptyContainers 				then
	
		allQryContentStatus.add 		(TI_CONTENTS_STATUS_EMPTY);
		allQryCargoTypesIncluded.add 	(TI_CargoType_Container);			// if only one could we use myCargoType but then need to do database read

	elseif  queryDesc = QFCam_EmptyContainers4Release		then
	
		allQryContentStatus.add 		(TI_CONTENTS_STATUS_EMPTY);
		allQryCargoTypesIncluded.add 	(TI_CargoType_Container);			// if only one could we use myCargoType but then need to do database read
		onlyBookingRefWith 				:= OnlyState_NullValue;				// must not have a booking
		onlyConsigneeWith 				:= OnlyState_WithValue;				// must have a consignee


	elseif  queryDesc = QFCam_EmptyStorageContainers 	then
	
		allQryContentStatus.add 		(TI_CONTENTS_STATUS_EMPTY);
		allQryCargoTypesIncluded.add 	(TI_CargoType_Container);			// if only one could we use myCargoType but then need to do database read
		allQryImexStatus.add 			(TI_IMEX_STATUS_STORAGE);
		
	elseif  queryDesc = QFCam_ExportContainerExclEmpty 			then		// MES said they want to include empty ones, so added another template with just export. This one may not be used but have left just in case
	
		allQryContentStatus.add 		(TI_CONTENTS_STATUS_FCL);
		allQryContentStatus.add 		(TI_CONTENTS_STATUS_LCL);
		allQryContentStatus.add 		(TI_CONTENTS_STATUS_NULL);
		allQryCargoTypesIncluded.add 	(TI_CargoType_Container);
		allQryImexStatus.add 			(TI_IMEX_STATUS_EXPORT);
		allQryImexStatus.add 			(TI_IMEX_STATUS_TRANSHIP);			// PAR #23645 CCMS 1116
		
	elseif  queryDesc = QFCam_ExportContainers 			then
	
		allQryCargoTypesIncluded.add 	(TI_CargoType_Container);
		allQryImexStatus.add 			(TI_IMEX_STATUS_EXPORT);
		allQryImexStatus.add 			(TI_IMEX_STATUS_TRANSHIP);			// PAR #23645 CCMS 1116
		
	elseif  queryDesc = QFCam_GeneralCargo 				then			
	
		allQryCargoTypesExcluded.add 	(TI_CargoType_Container);				/// mm not sure about these parameters?. Is there going to be a cargo type of 'General Cargo'?
	endif;
end;
</source>
        <Parameter name="pUserDefDesc" type="CM_CamUserDefRepDesc"/>
        <Parameter name="pQueryDesc" type="String"/>
    </JadeMethod>
</Class>
