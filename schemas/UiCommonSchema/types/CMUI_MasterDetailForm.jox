    <JadeMethod name="queryUnload" id="1604c208-e079-4419-ba1f-2eb68f10daf3">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	CANCEL_UNLOAD = 1;
vars
	result : Integer;
begin

	if self.mode = Mode_New or self.mode = Mode_Edit then
		if reason = QueryUnload_User or
		   reason = QueryUnload_UnloadMethod or
		   reason = QueryUnload_MdiChild then
			result := app.msgBox(app.getErrorString(EditChangedAndClosing), self.caption &amp; " Window Closing !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			if result = MsgBox_Return_No then
				cancel := CANCEL_UNLOAD;	//Do not close form
			endif;			
		endif;
	endif;

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
