    <JadeMethod name="getAllocationForSOHLocn" id="b384c310-bc95-4f39-99fe-4a4d7dabca88">
        <source>getAllocationForSOHLocn(_sohLocn : CM_SOHLocation) : CM_StockOrderAllocation;
//--------------------------------------------------------------
//Created: 25 October 2002 By: cnwgd1
