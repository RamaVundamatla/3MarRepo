    <JadeMethod name="doBaseFormSave" id="95218d7d-7653-4d61-a4c1-16b0ac0a8083">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 30/04/2018	jlgdap1		TFS 38248 Next Invoice Number not updated on Invoice Configuration
vars

	theController : CMIF_InvoiceSystemDefaults;
	theReturn : Integer;
	error : CM_Error;					// TFS 38248
	
begin

	create theController transient;
	self.setControllerFromTable(theController);
	
	while true do
		app.myTrxUA.trxUpdateInvoiceSystemDefaults(theController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			self.unloadForm();
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Invoice_System_Defaults), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			foreach error in self.allErrorWarnings do						// TFS 38248
				if error.errorCode = User_updated_invoice_number then		// TFS 38248
					self.doQuery;											// TFS 38248
					break;													// TFS 38248
				endif;														// TFS 38248
			endforeach;														// TFS 38248
			return;
		endif;
		break;
	endwhile;
epilog
	delete theController;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbBUsBuild" id="6dc45ed1-7511-4f1b-bf8f-955e54b9f4ed">
        <source>doCmbBUsBuild();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aTerm : CM_Terminal;
	combobox : ComboBox;
	def,
	co		: CM_Bank;
begin
	combobox := self.cmbBUs;

	combobox.clear;

//	def := app.getMyTerminalConfigDO_NOT_USE(DefCompany).CM_Bank;

//	foreach aTerm in app.myRoot.allTerminals do
	aTerm := self.myTerminal; //app.getMyTerminal();
	
	def := aTerm.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393
	
	foreach co in aTerm.companies do
		if co.isBusinessUnit and not co.isSuspended then
			combobox.addItem(co.mailingName);
			combobox.itemObject[combobox.newIndex] := co;
			if co = def then
				combobox.listIndex := combobox.newIndex;
			endif;
		endif;
	endforeach;
//	endforeach;
	if combobox.listIndex = -1 and combobox.listCount &gt; 0 then
		combobox.listIndex := 1;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorBuild" id="7187ed06-fae8-4f18-8ba0-55a3995dea2b">
        <source>doCmbDebtorBuild();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	debtor, defDebtor : CM_Debtor;
	combobox : ComboBox;
begin
	combobox := self.cmbDebtor;

	combobox.clear;

	combobox.clear;
	combobox.addItem("");
	defDebtor := app.getMyTerminalConfigDO_NOT_USE(DefDebtor).CM_Debtor;
	foreach debtor in app.myRoot.myRootCompany.debtors do
		combobox.addItem(debtor.name);
		combobox.itemObject[combobox.newIndex] := debtor;
		if debtor = defDebtor then
			combobox.listIndex := combobox.newIndex;
		endif;		
	endforeach;


end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbReeferOptionsBuild" id="9d915080-5c3d-46ee-8ddb-3dc56e97d976">
        <source>doCmbReeferOptionsBuild();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.cmbReeferOptions.clear;
	self.cmbReeferOptions.addItem(app.getErrorString(Charge_temperatur_readings));
	self.cmbReeferOptions.addItem(app.getErrorString(Charge_only_first_temper_readi));
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbStorConfigTypeBuild" id="17f7bd10-af31-468d-8186-1e00695aa681">
        <source>doCmbStorConfigTypeBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2017	jlgndl1	Initial creation	TFS 7032

*/

vars

	aTerm : CM_Terminal;
	combobox : ComboBox;
	storConType : CM_StorageConfigType;
	tmpStorConType : CM_StorageConfigType;
	index : Integer;
	
begin

	combobox := self.cmbStorConType;
	combobox.clear;
	
	aTerm := self.myTerminal; 
	if aTerm =  null then
		return;
	endif;
	storConType := aTerm.getMyStorageConfigType();
	
	foreach tmpStorConType in app.myRoot.allStorageConfigTypes discreteLock do
		index := combobox.addItem( tmpStorConType.getNiceName );
		combobox.itemObject[index] := tmpStorConType;
	endforeach;
	
	combobox.listIndex := combobox.findObject( storConType );

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doHideShow" id="a2bf9943-5986-4cdf-873a-529fa5ecb636">
        <source>doHideShow() protected;

vars

begin

	if not app.myCurrentUserCan(self.myTerminal, PmAdmMultiCompany) then
		self.tblDataEntry.hideRowByName(ETRow_MultiCompany, false);
		self.tblDataEntry.hideRowByName(ETRow_DefCompany, false);
	else
		self.tblDataEntry.showRowByName(ETRow_MultiCompany, false);
		self.tblDataEntry.showRowByName(ETRow_DefCompany, false);
	endif;
	
// TFS 2734	if not app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceSDExInterfaceMaint) then
	if not app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceSDExInterfaceView) then // TFS 2734
		self.tblDataEntry.hideRowByName(ETRow_FinancialIOClass, false);
		self.tblDataEntry.hideRowByName(ETRow_FirstMonthOfFinYear, false);
		self.tblDataEntry.hideRowByName(ETRow_ExportPath, false);
		self.tblDataEntry.hideRowByName(ETRow_GlPeriod, false);
		self.tblDataEntry.hideRowByName(ETRow_GlYear, false);
	else
		self.tblDataEntry.showRowByName(ETRow_FinancialIOClass, false);
		self.tblDataEntry.showRowByName(ETRow_FirstMonthOfFinYear, false);
		self.tblDataEntry.showRowByName(ETRow_ExportPath, false);
		self.tblDataEntry.showRowByName(ETRow_GlPeriod, false);
		self.tblDataEntry.showRowByName(ETRow_GlYear, false);
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceSDInvoicingView) then
		self.tblDataEntry.hideRowByName(ETRow_Sn_invoice, false);
	else
		self.tblDataEntry.showRowByName(ETRow_Sn_invoice, false);
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceSDReeferView) then
		self.tblDataEntry.hideRowByName(ETRow_ChargeFirstTempOnly, false);
	else
		self.tblDataEntry.showRowByName(ETRow_ChargeFirstTempOnly, false);
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceSDDebtorView) then
		self.tblDataEntry.hideRowByName(ETRow_DefDebtor, false);
	else
		self.tblDataEntry.showRowByName(ETRow_DefDebtor, false);
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceSDBusUnitsView) then
		self.tblDataEntry.hideRowByName(ETRow_DefCompany, false);
	else
		self.tblDataEntry.showRowByName(ETRow_DefCompany, false);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQuery" id="f4c27251-509f-4055-a9c8-f7951a37d5a5">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 19 Mar 2021 cnwma1 ChangeRequest 50925: ASPA - New Total Column in Invoice Form
// 4/11/2022   navcs2 ChangeRequest 54898: EUP - Invoice currency symbol - Euro € 
// 16 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
// 23 November 2023 navra1 TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61386/Task - 61389)
// 30/04/2024 navnk30 Bug 63894: MTN - Stop Creating Unqualified Audits for invoices Config not showing correct setting
// 11/06/2024 navbk1  Bug 64564: MTN - Invoice Configuration Screen doesn't show correct values
// ---------------------------------------------------------------------------

vars
	ioClass 		: CM_ExtFinanceIO;
	keyseries		:  CM_KeySeries;
	serieskey		:  CM_SeriesKey;
	nextInvNum,
	currSymbol 		: Integer;
	bu 				: CM_Bank;
	cls 			: Class;
	term            : CM_Terminal;
	defModeSelected : String;
	
begin
	
	term := self.myTerminal;
	bu 	 := term.getDefaultCompanyBank();
	
	
	self.setCaption("Invoice Configuration" &amp; " " &amp; bu.code); // 	TFS 2682
	
	keyseries  := bu.keySeries[SN_INVOICE];
	serieskey  := keyseries.nextKey;
	nextInvNum := serieskey.root;

	// TFS 39618 next invoice number is now on business unit maint
	// TFS 39618	idx := self.tblDataEntry.getRowByName(ETRow_NextInvoiceNumber);
	// TFS 39618	self.tblDataEntry.accessCell(idx,1).text := bu.code &amp; " " &amp; self.tblDataEntry.accessCell(idx,1).text;
	
	self.tblDataEntry.setValueByName(ETRow_AllowInvPostUnqualAudits,term.getConfig(InvPostWithoutAuditQual).Boolean);
	
	if term.myCalendar &lt;&gt; null then
		self.tblDataEntry.setValueByName(ETRow_FinancialsCalendar,term.myCalendar.code);
		self.cmbCalendar.setObject(term.myCalendar);  
	else
		self.tblDataEntry.setValueByName(ETRow_FinancialsCalendar,"");
		self.cmbCalendar.setObject(null);  
	endif;
	
	self.tblDataEntry.setValueByName(ETRow_MTsByDebtor,				term.getConfig(MTsByDebtor).Boolean);
	self.tblDataEntry.setValueByName(ETRow_MTsByDebtorExport,		term.getConfig(MTsByDebtorExport).Boolean);
	self.tblDataEntry.setValueByName(ETRow_InvoicePrintRemarks,		term.getConfig(InvoicePrintRemarks).Boolean);
	self.tblDataEntry.setValueByName(ETRow_InvoiceHMSNoShiftCharge,	term.getConfig(InvoiceHMSNoShiftCharge).Boolean);
	self.tblDataEntry.setValueByName(ETRow_NextInvoiceNumber,		nextInvNum);
	self.tblDataEntry.setValueByName(ETRow_MultiCompany,			term.getConfig(MultiCompany).Boolean);
	self.tblDataEntry.setValueByName(ETRow_FinancialsEnabled,		term.getConfig(FinancialsEnabled).Boolean);
	self.tblDataEntry.setValueByName(ETRow_FinancialRateDPlaces,	term.getConfig(FinancialRateDPlaces).Integer);
	self.tblDataEntry.setValueByName(ETRow_InvoiceMultiTaxRates,	term.getConfig(InvoiceMultiTaxRates).Boolean);
	self.tblDataEntry.setValueByName(ETRow_CashProcessingEnabled,	term.getConfig(CashProcessingEnabled).Boolean);
	self.populateCmbDebtAction( term.getConfig(CashOnlyInDebtOption).Integer );											//30 May 2018	NDL	TFS 38952
	self.tblDataEntry.setValueByName(ETRow_DotMatrixInvoiceRep,		term.getConfig(DotMatrixInvoiceRep).String);	
	self.tblDataEntry.setValueByName(ETRow_AllowInvPostUnqualAudits,term.getConfig(InvPostWithoutAuditQual).Boolean);	
	self.tblDataEntry.setValueByName(ETRow_InvUseInvoiceCargoAlloc, term.getConfig(InvUseInvoiceCargoAlloc).Boolean);	// PAR 35833
	self.tblDataEntry.setValueByName(ETRow_InvInvoicePrintJRW,		term.getConfig(InvInvoicePrintJRW).String);			// PAR 36180
	self.tblDataEntry.setValueByName(ETRow_AutoVoidExternalReefers, term.getConfig(AutoVoidExternalReefers).Boolean);
	self.tblDataEntry.setValueByName(ETRow_AutoNormalReefers,		term.getConfig(AutoNormalReefers).Boolean);
	//self.tblDataEntry.setValueByName(ETRow_InvoiceRoundLineTotal,   term.getConfig(InvoiceRoundLineTotal).Boolean);	// 20/8/18 MAP TFS40270      // 19.03.2021 cnwma1 #50925
	self.populateCmbRoundInvLine( term.getConfig(InvoiceRoundLineTotal).Integer );                        				// 19.03.2021 cnwma1 #50925
	self.tblDataEntry.setValueByName(ETRow_InvoiceRoundDownLineTax, term.getConfig(InvoiceRoundDownLineTax).Boolean);	// 20/8/18 MAP TFS40272
	self.tblDataEntry.setValueByName(ETRow_InvWOVoyageTranOnAction, term.getConfig(InvWOVoyageTranOnAction).Boolean);	// TFS 42161
	self.tblDataEntry.setValueByName(ETRow_InvShowAllSeparation, term.getConfig(InvShowAllSeparation).Boolean);         // 16/03/2023  navmv20 TFS 56128 Task 56129
	self.tblDataEntry.setValueByName(ETRow_InvAuditCargoEdits, term.getConfig(InvAuditCargoEdits).Boolean);				// 30/04/2024 navnk30 #63894 
	self.tblDataEntry.setValueByName(ETRow_DeferredCharging, term.getConfig(DeferredCharging).Boolean);					// 11/06/2024 navbk1  #64564
	
	if term.getConfig(ChargeFirstTemperatureOnly).Boolean then
		self.cmbReeferOptions.listIndex := 2;
	else
		self.cmbReeferOptions.listIndex := 1;
	endif;
	
	currSymbol 						:= app.myRoot.getInvoiceCurrencySymbol();
	self.cmbCurrency.setIndexForItemData(currSymbol); 																	// 4/11/2022   navcs2 ChangeRequest 54898 
	self.tblDataEntry.setValueByName(ETRow_InvoiceCurrencySymbol,currSymbol.Character);

	ioClass := app.getMyTerminalConfigDO_NOT_USE(FinancialIOClass).CM_ExtFinanceIO;
	if ioClass = null then					
		cls		:= CM_DefaultFinanceIO;
		ioClass := cls.firstInstance().CM_ExtFinanceIO;
	else
		self.showIOClass(ioClass);
	endif;
	
	//navra1 - TFS 54090(CR 61386/Task - 61389) - 24th Nov 2023 - start
	if ioClass.isKindOf(CM_InvoiceAPI) then	
		defModeSelected := term.getConfig(InvoiceAPIOpModeConfig).String;
		if defModeSelected = null then
			defModeSelected := CM_InvoiceAPI.CONSMODE_NO_CONS;
		endif;
		self.tblDataEntry.setValueByName(ETRow_InvoiceAPIOutputMode, defModeSelected);
		//navra1 - TFS 54090(CR-61386/Task-61389)  - 13 Dec 2023 - this is configured in the BGP, should not be a term config - start
		/*if term.getConfig(ExtWebServiceConfig) &lt;&gt; null then
			self.tblDataEntry.setValueByName(ETRow_ExtWebService, term.getConfig(ExtWebServiceConfig).CM_InvoiceAPIServiceDef.name);
		endif;*/
		//navra1 - TFS 54090(CR-61386/Task-61389)  - 13 Dec 2023 - this is configured in the BGP, should not be a term  - end
	endif;
	//navra1 - TFS 54090(CR 61386/Task - 61389) - 24th Nov 2023 - end
	
	self.tblDataEntry.setValueByControlName(self.cmbFinancialIO.name,  self.cmbFinancialIO.text);	
	self.tblDataEntry.setValueByControlName(self.cmbReeferOptions.name,self.cmbReeferOptions.text);
	self.tblDataEntry.setValueByControlName(self.cmbBUs.name,          self.cmbBUs.text);
	self.tblDataEntry.setValueByControlName(self.cmbDebtor.name,       self.cmbDebtor.text);
	self.tblDataEntry.setValueByControlName(self.cmbStorConType.name,  self.cmbStorConType.text);	//03 Nov 2017	NDL	TFS 7032
	self.tblDataEntry.cnEcSelectRow();
epilog
	if (not app.myCurrentUserCan(term, PmAdmFinancialsystemdefauMaint)) then
		self.btnSaveBase.enabled   := false;
		self.tblDataEntry.readOnly := true;		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="aff1e5de-de55-4b05-9a8e-9efe584f8131">
