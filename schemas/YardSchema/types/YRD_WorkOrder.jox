        <updating/>
        <source>doSaveToDoNonOperational(wodtl : CM_WodToDoNonOperational input): Boolean updating;
/*

Purpose:

Parameters:			

Return Value:		

Date		Who		Reason
28 December 2022	navcs2	ChangeRequest 56632:[56057] EUP - VAS Non Operational Work Order
14 Mar 2023 navma1  ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Screen
24 Mar 2023 navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
*/

vars
	allToDoTasks 			: CM_ToDoTaskDescSet;
	allDebtors				: CM_DebtorSet;
begin
	// Get the Todo tasks 
	create allToDoTasks transient;
	self.mulToDoTasks.getSelected( allToDoTasks );
	
	// Get the debtors
	create allDebtors transient;
	self.mulToDoEntity.getSelected(allDebtors);
	
	// Set the proxy from the collected data
	wodtl.CM_WodToDoNonOperational.setProxyToDo(allDebtors);			//24.3.2023 navhl20	#57301[57303]
	return true;
epilog

end;</source>
