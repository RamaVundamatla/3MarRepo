    <JadeMethod name="setMyCurrentSOHLocation" id="4f26a8d4-ddce-49df-8707-e180ba8b1ff9">
        <updating/>
        <source>setMyCurrentSOHLocation()updating;
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if tblDetails.row &lt;= tblDetails.fixedRows then
		return;
	endif;
	self.myCurrentSOHLocation := tblDetails.accessRow(tblDetails.row).itemObject.CM_SOHLocation;
	self.populateTblNewSpecs();
end;</source>
