        <source>setPxyWeight(_weight:Decimal) updating;
// --------------------------------------------------------------------------------
// Created:		09 August 2010 by cnwdad1
//
// Purpose:		Updates the receiver's weight property for a proxy object only.
//
// Parameters:	_weight - The decimal weight value to set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.weight	:=	_weight;
end;</source>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setSeqNumDefSingle" id="78627378-7318-414d-a381-2215d0cc52f9">
        <updating/>
        <source>setSeqNumDefSingle(_number, _overDeckSingleConfig, _underDeckSingleConfig, _overDeckSingleConfig40, _underDeckSingleConfig40 : Integer;  _isStarboard : Boolean) updating;
// -------------------------------------------
// Created 29 August 2005 by cnwdvb1
// -------------------------------------------
vars

	seqNum	: Integer;
	tWle	: CM_WorkListEntry;
	idx		: Integer;
	oldSeqNum,
 	newSeqNum	: Integer; //ccms 2323 28/4/14
	voyage : CM_Voyage;
begin

	oldSeqNum:= self.getSeqNum;
	//----------------------
	//Get the config
	//----------------------
	
	// Using 20 configurable values for twin lifts only to keep jobs together.
	if self.ordinalDeck = DeckOnDeck then
		//if self.fortyFront then
		if not self.is20() then // PAR 21917
			seqNum := _number + _overDeckSingleConfig40;
		else
//		seqNum := _number + self.myTerminal.getConfig(StartSeqNum20_OverDeck).Integer;
			seqNum := _number + _overDeckSingleConfig;
		endif;
	else
		//if self.fortyFront then
		if not self.is20() then// PAR 21917
			seqNum := _number + _underDeckSingleConfig40;
		else
//		seqNum := _number + self.myTerminal.getConfig(StartSeqNum20_UnderDeck).Integer;
			seqNum := _number + _underDeckSingleConfig;
		endif;
			
	endif;
	
	if _isStarboard then
		self.numSeqStarBoard 		:= seqNum;
		self.numSeqStarboardCustom	:= seqNum;
	else
		self.numSeqPort				:= seqNum;
		self.numSeqPortCustom		:= seqNum;
		// This sets up any sequencing within a slot.
		foreach tWle in self.allWorkListEntries do
			idx := idx + 1;
			tWle.CM_VoyageWLE.setSeqNumWorkOrder(idx);
		endforeach;
	endif;
	
	newSeqNum:= self.getSeqNum;
	voyage:= self.getVoyage;
	if voyage &lt;&gt; null and oldSeqNum &lt;&gt; newSeqNum then
		voyage.incrementPlanningVersion;
	endif;
	
	
end;</source>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_overDeckSingleConfig" type="Integer"/>
        <Parameter name="_underDeckSingleConfig" type="Integer"/>
        <Parameter name="_overDeckSingleConfig40" type="Integer"/>
        <Parameter name="_underDeckSingleConfig40" type="Integer"/>
        <Parameter name="_isStarboard" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSeqNumDefTwin" id="0660b6ac-12c4-4833-a926-4f1e4dcaea90">
        <updating/>
        <source>setSeqNumDefTwin(	_number, 
					_overDeckSingleConfig,
					_underDeckSingleConfig,
					_overDeckSingleConfig40,
					_underDeckSingleConfig40	: Integer;
					_isStarboard,
					_isTwinLift,
					_boldLine					: Boolean;
					_nextCraneId				: Integer) updating;
// -------------------------------------------
// Created 29 August 2005 by cnwdvb1
// -------------------------------------------
vars

	seqNum	: Integer;
	wle		: CM_WorkListEntry;

begin

	//----------------------
	//Get the config
	//----------------------

	// Using 20 configurable values for twin lifts only to keep jobs together.
	if self.ordinalDeck = DeckOnDeck then
		//if self.fortyFront then
		if not self.is20() then// PAR 21917
			seqNum := _number + _overDeckSingleConfig40;
		else
//		seqNum := _number + self.myTerminal.getConfig(StartSeqNum40_OverDeck).Integer;
			seqNum := _number + _overDeckSingleConfig;
		endif;
	else
		//if self.fortyFront then
		if not self.is20() then// PAR 21917
			seqNum := _number + _underDeckSingleConfig40;
		else
//		seqNum := _number + self.myTerminal.getConfig(StartSeqNum40_UnderDeck).Integer;
			seqNum := _number + _underDeckSingleConfig;
		endif;
	endif;
	
	if _isStarboard then	
		self.numSeqStarboardTwin 		:= seqNum;
		self.numSeqStarboardTwinCustom	:= seqNum;
		self.isTwinLiftStarboard := _isTwinLift;
		// Need to change.
		self.defaultCraneLoadLaneStarboard := _nextCraneId;
	else
		self.numSeqPortTwin 		:= seqNum;
		self.numSeqPortTwinCustom	:= seqNum;
		self.isTwinLiftPort			:= _isTwinLift;
		// Need to change
		self.defaultCraneLoadLanePort := _nextCraneId;
		// Sets up aft foread relationship.
		self.setSeqNumWorkOrder(_boldLine);
	endif;

	
end;</source>
        <Parameter name="_number" type="Integer"/>
        <Parameter name="_overDeckSingleConfig" type="Integer"/>
        <Parameter name="_underDeckSingleConfig" type="Integer"/>
        <Parameter name="_overDeckSingleConfig40" type="Integer"/>
        <Parameter name="_underDeckSingleConfig40" type="Integer"/>
        <Parameter name="_isStarboard" type="Boolean"/>
        <Parameter name="_isTwinLift" type="Boolean"/>
        <Parameter name="_boldLine" type="Boolean"/>
        <Parameter name="_nextCraneId" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSeqNumDefTwinCustom" id="823de40c-e2bc-45fe-ae5f-8877e2b52618">
        <updating/>
        <source>setSeqNumDefTwinCustom(_sorter : CMIF_CustomSequenceObject; _isStarboardBerthed : Boolean) updating;
// -------------------------------------------
// Created 30 August 2005 by cnwdvb1
// -------------------------------------------
vars

	wle	: CM_VoyageWLE;
	
begin

	if _isStarboardBerthed then
		self.numSeqPortTwinCustom 		:= _sorter.seqNumOtherTwin;
		self.numSeqStarboardTwinCustom	:= _sorter.seqNumTwin;
		self.isTwinLiftStarboard 		:= _sorter.isTwinLiftProperty;
		self.isTwinLiftPort				:= _sorter.isTwinLiftProperty;
		// This needs new attrbibute.
		self.defaultCraneLoadLaneStarboard	:= _sorter.nextCraneLane;
		self.defaultCraneLoadLanePort		:= _sorter.nextCraneLaneOther;
	else
		self.numSeqPortTwinCustom 		:= _sorter.seqNumTwin;
		self.numSeqStarboardTwinCustom	:= _sorter.seqNumOtherTwin;
		self.isTwinLiftPort				:= _sorter.isTwinLiftProperty;
		self.isTwinLiftStarboard 		:= _sorter.isTwinLiftProperty;
		self.defaultCraneLoadLanePort		:= _sorter.nextCraneLane;
		self.defaultCraneLoadLaneStarboard	:= _sorter.nextCraneLaneOther;
	endif;
	
		// Do wle manipulation to force correct twin lift order
	
	wle := self.allWorkListEntries.first.CM_VoyageWLE;
	if wle = null then
		return;
	endif;

	if _sorter.isTwinLiftProperty and self.mySlotDefinition.myBay.isAftBay() then
		wle.setSeqNumWorkOrder(2);
	endif;
	
	wle.setUseBoldOrDifferentColour(_sorter.useBold.Integer);
	
	
	
	
	
	
	


end;</source>
        <Parameter name="_sorter" type="CMIF_CustomSequenceObject"/>
        <Parameter name="_isStarboardBerthed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSeqNumWorkOrder" id="78022161-7382-4548-aa13-cadac909dafe">
        <updating/>
        <source>setSeqNumWorkOrder(_boldLine : Boolean) updating;
// -------------------------------------------
// Created 30 September 2005 by cnwdvb1
// -------------------------------------------
vars

	wle : CM_WorkListEntry;

begin
	
	wle := self.allWorkListEntries.first;
	if wle = null then
		return;
	endif;
	
	// Do wle manipulation to force correct twin lift order if sequence numbers are the same we need this.
	if self.isTwinLiftPort then
		if  self.mySlotDefinition.myBay.isAftBay() then
			wle.CM_VoyageWLE.setSeqNumWorkOrder(2);
		endif;
	endif;
	wle.CM_VoyageWLE.setUseBoldOrDifferentColour(_boldLine.Integer);


end;</source>
        <Parameter name="_boldLine" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSequenced" id="8aa05ac9-f9fd-49fe-b2c3-a038e33ab947">
        <updating/>
        <source>setSequenced(_sequenced : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin



	if self.sequenced &lt;&gt; _sequenced then
		self.sequenced := _sequenced;
	endif;
end;</source>
        <Parameter name="_sequenced" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSlotSeqNums" id="35005f6c-fd71-4c51-8cec-44737cb53cd8">
        <updating/>
        <source>setSlotSeqNums(_params : CMIF_SeqParams input) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     This should only be called from job CREATE.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	oldSeqNum,
 	newSeqNum	: Integer; //ccms 2323 28/4/14
	voyage : CM_Voyage;
begin
	oldSeqNum:= self.getSeqNum();

	_params.isStarBoard := true;
	self.numSeqStarBoard := getSeqNumDefn(_params);
	

	_params.isStarBoard := false;
	self.numSeqPort := getSeqNumDefn(_params);

	newSeqNum:= self.getSeqNum();
	//ccms 2323 28/4/14
	voyage:=self.getVoyage;
	if oldSeqNum &lt;&gt; newSeqNum and voyage &lt;&gt;null then
		voyage.incrementPlanningVersion();
	endif;
	
end;</source>
        <Parameter name="_params" type="CMIF_SeqParams" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTmpSRFromBETI" id="20c4a2bc-bd8d-476d-8c88-e2d4ac1d697a">
        <updating/>
        <source>setTmpSRFromBETI(_ti : CM_TrackedItem; _lc : CM_SlotController) updating;
// ---------------------------------------------------------------------------
// Created:		23 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		This is only used by the drawing so will never use vouyage allocations
//
// ---------------------------------------------------------------------------
vars
	aCon : CM_Container;
begin
	self.mySlotController := _lc;
	if not _ti.isKindOf(CM_Container) then
		return;
	endif;
	aCon := _ti.CM_Container;
	self.fortyBack := false;
	self.fortyFront := false;
	self.is30 := false;
	self.is53 := false;
	self.is45 := false;
	
	if aCon.is30 then
		self.is30 := true;
	elseif aCon.is53 then
		self.is53 := true;
	elseif aCon.is45 then // PAR 18682
		self.is45 := true;
	elseif aCon.is40 then
		self.fortyFront := true;
		self.fortyBack := true;
		
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_lc" type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="setToTrackedItemProperties" id="5ac09f8b-d0de-49de-9371-413ebabc2d9d">
        <updating/>
        <source>setToTrackedItemProperties(_ti : CM_Container; _isFirst : Boolean output) updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 April 2002 by cnwdwq1
//
// Purpose:     Used to map the TI onto this request
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	workedDT : TimeStamp;
	isForty : Boolean;
begin
	sharedLock(_ti);

	if _ti.isRehandle then
		workedDT := _ti.receivedDT;
	else
		workedDT := _ti.releasedDT;
	endif;
	if workedDT.isValid() = true then
		// worked, ignore
		return;
	endif;
	//------------------------	
	// If Not worked then use their details to set the colour code
	// get the commodity and discharge port from the first ti, these apply to all.
	//------------------------	
	if _isFirst then
		self.cargoType := _ti.cargoType;
		self.commodity := _ti.commodity;		
		self.dischargePort := _ti.dischargePort;
		//Set so we dont overwrite
		_isFirst := false;
	endif;
	//---------------------------
	// if any of the other attributes are pertinent for any of the ti then set them
	//---------------------------
	self.empty := _ti.isAttributeTrue(TI_Attrib_IsEmpty);
	
	if _ti.isAttributeTrue(TI_Attrib_IsForty) then
		if self.mySlotController.isTIPrimaryLocation(_ti, REAL_MODE) then
			isForty := true;
		else
			app.raiseCMException(ERR_SLOT_DIS_40, null, null);
			return;
		endif;
	endif;

	self.halfHeight := _ti.isAttributeTrue(TI_Attrib_IsHalfHeight);
	self.hazardous := _ti.isHazardous;
	self.overDimension := _ti.isOverDimensions;

// PAR7496 AKB2004FEB		if _ti.isAttributeTrue(TI_Attrib_IsPortHole) and _ti.isAttributeTrue(TI_Attrib_HasCOU) = false then
		// if non empty porthole without a cou
// PAR7496 AKB2004FEB			self.reefer := _ti.isAttributeTrue(TI_Attrib_RequiresTemperature);
// PAR7496 AKB2004FEB		else
		self.power := _ti.isAttributeTrue(TI_Attrib_RequiresPower);
		self.waterCooled := _ti.isAttributeTrue(TI_Attrib_IsWaterCooled);
// PAR7496 AKB2004FEB		endif;

	if _isFirst then
		// if still true no ti therefore use defaults
		self.commodity := null;
	endif;
	if self.dischargePort = null then
		self.dischargePort := self.myTerminal.getConfig(PortDestCode).String;
	endif;
	self.setFortyFoot(isForty);	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_isFirst" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setTwinLift" id="955c2a62-2e49-4446-945f-b7a7348c449a">
        <updating/>
        <source>setTwinLift(_isTwinLift, _isStarboard : Boolean) updating;
// -------------------------------------------
// Created 02 September 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if _isStarboard then
		self.isTwinLiftStarboard := _isTwinLift;
	else
		self.isTwinLiftPort := _isTwinLift;
	endif;


end;</source>
