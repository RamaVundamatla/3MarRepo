    <JadeMethod name="getMyParent" id="dd836ee3-1b8d-481e-bb39-f5ee91c550f6">
        <source>getMyParent(): CM_WorkOrder;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2018	jlger1	Initial creation

*/

vars

begin
	if self.myMarineServiceDepart &lt;&gt; null then
		return self.myMarineServiceDepart.myParent;
	elseif self.myMarineServiceInitial &lt;&gt; null then
		return self.myMarineServiceInitial.myParent;
	elseif self.myShiftMovement &lt;&gt; null then
		return self.myShiftMovement.myParent;
	elseif self.myMarineServiceVoyageCargo &lt;&gt; null then
		return self.myMarineServiceVoyageCargo.myParent;
	elseif self.myExtension &lt;&gt; null then
		return self.myExtension.myParent;
	endif;

	return null;
epilog

end;</source>
