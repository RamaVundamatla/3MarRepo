    <JadeMethod name="setControlsForAddEdit" id="31fe9ed4-1aba-443f-bb63-162d02a36063">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;

begin
 	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;

	if theForm.mode = theForm.Mode_Add then
		//not an option
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_FileFormatEDI);
		// cannot update some rows
		theForm.tblInput1.disableRowByName(ETRow_Description);		
		//theForm.tblInput1.enableRowByName(ETRow_Name);
		//theForm.tblInput1.enableRowByName(ETRow_Operator);
		//theForm.tblInput1.enableRowByName(ETRow_NoLongerUsed);
	endif;

	

end;</source>
    </JadeMethod>
