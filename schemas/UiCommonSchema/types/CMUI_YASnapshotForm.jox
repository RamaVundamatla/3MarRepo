    <JadeMethod name="translateForm" id="32e41383-468d-4ceb-a094-575750f8ac29">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010307, locale);
	btnCancel.translateCaption(Xlat_0010308, locale);
	btnCancel_1.translateCaption(Xlat_0010309, locale);
	btnDelete.translateCaption(Xlat_0010310, locale);
	btnEdit.translateCaption(Xlat_0010311, locale);
	btnNew.translateCaption(Xlat_0010312, locale);
	grpCriteria.translateCaption(Xlat_0010313, locale);
	grpSnapshot.translateCaption(Xlat_0010314, locale);
	lblSnapshot.translateCaption(Xlat_0010315, locale);
	lblYACode_1.translateCaption(Xlat_0010316, locale);
	voyage.translateCaption(Xlat_0010317, locale);
	voyage_1.translateCaption(Xlat_0010318, locale);
	voyage_2.translateCaption(Xlat_0010319, locale);
	voyage_3.translateCaption(Xlat_0010320, locale);
end;</source>
    </JadeMethod>
