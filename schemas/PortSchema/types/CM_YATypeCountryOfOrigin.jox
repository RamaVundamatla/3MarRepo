    </JadeMethod>
    <JadeMethod name="isSnapShotDataMatch" id="3d1739af-a914-49e1-a17c-b25e83f457e8">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/
vars
	match	: Boolean;
	obj		: Object;
	yaData  : CM_YAData;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	yaData := _criteria.myYAData;							
	
	foreach obj in yaData.CM_YADataObjects.allObjects do
		if obj.CM_Country.code = _propertyValue then
			return true;
		endif;
	endforeach;
	
	if yaData.isKindOf(CM_YADataPattern) and
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="4efefcce-caa5-4a49-833d-6ec1c3c277f7">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/

vars
	country		: CM_Country;
	yaData		: CM_YAData;
begin

	if _tiTrx &lt;&gt; null then
		if _tiTrx.myCountryOfOrigin &lt;&gt; null then
			country := app.myRoot.allCountries[ _tiTrx.getCountryOfOriginCode() ];
		endif;
	else
		country := _ti.myCountryOfOrigin;
	endif;
	
	yaData := _criteria.myYAData;
	
	if yaData.CM_YADataObjects.matchesStorage(country) then
		return true;
	endif;
	
	if yaData.isKindOf(CM_YADataPattern) and
	   yaData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
