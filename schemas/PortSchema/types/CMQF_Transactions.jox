    <JadeMethod name="filterObjects" id="eca2a31b-8ef2-42da-9d2c-05e69c51f2dc">
        <updating/>
        <source>filterObjects(_collection : Collection input; _passport	: CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     21 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
//constants										// cnwrl1 07/09/2009 PAR 20198 - what it was
//	TRANS_TYPE_UNKNOWN = -1;					// cnwrl1 07/09/2009 PAR 20198 - what it was
// 01-MAY-2015  cnwma1     PAR #36129 CCMS 1416 TFS 323 Break Bulk Reporting - Batch 1
vars
	terminal			: CM_Terminal;
//	strType				: String;				// cnwrl1 07/09/2009 PAR 20198 - what it was
	intType				: Integer;
	endTS,
	startTS				: TimeStamp;
	
begin
	//cnwmc5 - par 29983 - 11/07/2012
	//Added for selector queries, wouldn't populate selector critera without this.
	if (not self.allQueryCriteriaHolders.isEmpty) then
		self.filterSelectorQuery(_collection, _passport);
		return;
	endif;
	
	self.needFilterUsers := (not self.allUsers.isEmpty) or (self.allUsers.size &gt;= app.myRoot.allUsers.size);  //cnwma1 01/05/2015  PAR #36129
	
	startTS.setDate(self.startDate);
	startTS.setTime('00:00:00:000'.Time);
	endTS.setDate(self.endDate);
	endTS.setTime('23:59:59:999'.Time);
	
	foreach terminal in self.allTerminals do
		if self.transType &lt;&gt; null then
			terminal.getTITxnsForTypeAdvanced(	self.transType,
												startTS,
												endTS, 
												CMQF_Transactions::checkStatusIncludesObject.name, 
												self,
												_collection);
		else
//			foreach strType in self.allTransTypeDescriptions do : transType_loop	// cnwrl1 07/09/2009 PAR 20198 - what it was
//				intType := self.getTransTypeFromString( strType );					// cnwrl1 07/09/2009 PAR 20198 - what it was
			foreach intType in self.allTxnTypes do : transType_loop
				// cnwrl1 21/07/2009 PAR 20198 - SFW1070 - start of coding
				if intType = self.TRANS_TYPE_UNKNOWN then
					continue transType_loop;
				endif;
				// cnwrl1 21/07/2009 PAR 20198 - SFW1070 - end of coding
				terminal.getTITxnsForTypeAll(	intType,
												startTS,
												endTS, 
												CMQF_Transactions::checkStatusIncludesObject.name, 
												self,
												_collection);
				endLoad;
			endforeach transType_loop;
		endif;
	endforeach;
epilog
	endLoad;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterSelectorQuery" id="c1d47d2f-8bee-419e-9237-7e0b30b444d1">
        <source>filterSelectorQuery(_collection  : Collection input;
					_passport : CM_Passport) protected;
/*

Purpose:	Had to be created to get the information that was defined in the selector query,
	without this, the selector query would not work.		

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2012	cnwmc5	Initial creation - par 29983
	

*/

vars
	criteriaHolder 		: CM_QueryCriteriaLineHolder;
	qDef				: CM_QueryDefinition;
	enqController		: CM_EnquiryController;
	queryAgent			: CM_QueryAgentFilter;

begin

	// Special one because we need the copy
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	
	queryAgent := app.myQAFilter;
	if queryAgent = null then
		return;
	endif;
	
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Transaction_Query_Type, self.selectorMode];
	queryAgent.createEnqControllerForMode(self.selectorMode, CM_QueryDefinition.Transaction_Query_Type, enqController);
	delete enqController.allObjects;
	create enqController.allObjects as _collection.class transient;
	
	foreach criteriaHolder in self.allQueryCriteriaHolders discreteLock do
		enqController.myCriteriaLineHolder := criteriaHolder;
		enqController.doQuery(qDef);
	endforeach;

	enqController.allObjects.copy(_collection);
	
epilog
	if enqController &lt;&gt; null then
		delete enqController.allObjects;
	endif;
	delete enqController;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getChargeTypeFromString" id="ce216a02-b5d4-4c23-8afb-48fbde83de95">
        <source>getChargeTypeFromString(_str : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     30 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if _str = Transaction_Charged_All_Str then
		return Transaction_Charged_All;
	elseif _str = Transaction_Charged_True_Str then
		return Transaction_Charged_True;
	elseif _str = Transaction_Charged_False_Str then
		return Transaction_Charged_False;
	endif;
end;</source>
        <Parameter name="_str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3a68cb0b-a3cb-4164-b5fe-69aa25d06fa4">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate : Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
vars
	bln : Boolean;
	oid : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
/*
	if _attrName = ETRow_LogTxnType then
		return self.transTypeStr;
	elseif _attrName = ETRow_TransactionType then
		return self.getTransTypeString();
		
	elseif _attrName = 	ETRow_DeletedTrans then 
	// display in row is 'include deleted transactions' 
	// this is opposite of Ignore Deleted 
		bln := 	not self.ignoreDeleted;

		return bln.cnEcGetTableCheckBoxValue;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate);
*/
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoString" id="3af9220d-3d64-42d4-80fe-ceb88b971f0b">
        <source>getExtraInfoString(): String;
// -------------------------------------------
// Created 01 April 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	// CCMS 1327
	
	if self.getMyVoyage &lt;&gt; null then
		return self.getMyVoyage.getId();
	endif;
	return inheritMethod();

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyCarrier" id="d4cbf35f-3d4e-4cc4-b428-e4f01cd80ebc">
        <source>getMyCarrier():CM_Carrier;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_Carrier;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myCarrier;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
