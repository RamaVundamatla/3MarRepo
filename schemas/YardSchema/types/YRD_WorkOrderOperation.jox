    <JadeMethod name="loadTable" id="675262f6-4153-4635-ab97-4b59e5d14ed3">
        <source>loadTable(_tbl : CM_DataTable io;_entDef: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023 navma1  ChangeRequest 57878: EUP - Delivery Dispatch – Screen Design
07 June 2023 navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
25 Aug 2025 navhl20 Story MTN-35317: MTN | Pagination - Work Order Operations
*/

vars
	entTableDef		: EntTableDef;
	xmlStr			: String;
begin
	_tbl.allSelectedObjects.clear();
	
	_tbl.userInputEnabled := false;
	_tbl.selectMode 	:= CM_EntryTable.SelectMode_FixedRow;
	_tbl.selectionType  := CM_EntryTable.SelectionType_Row;
	
	entTableDef 		:= app.myController.getEntTableDef(_entDef);
	
	if _tbl = self.tblJobsUnallocated then									//07.6.2023 navhl20 #58543
		xmlStr := self.defJobUnAllocatted;
	elseif _tbl = self.tblJobsAllocated then
		xmlStr := self.defJobAllocatted;
	elseif _tbl = self.tblJobSheet then
		xmlStr := self.defJobSheet;
	elseif _tbl = self.tblWlesAllocated then
		xmlStr := self.defWleAllocated;
	elseif _tbl = self.tblWlesUnallocated then
		xmlStr := self.defWleUnallocated;
	endif;
	
	if xmlStr &lt;&gt; null then													//07.6.2023 navhl20 #58543
		_tbl.setTblDataEntRowsFromXML(entTableDef, xmlStr);	
	else	
		_tbl.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	_tbl.readOnly 	  := false;	
	_tbl.fixedColumns := 0;
	_tbl.fixedRows 	  := 1;
epilog

end;</source>
        <Parameter name="_tbl" type="CM_DataTable" usage="io"/>
        <Parameter name="_entDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadTableView" id="b915c923-f8ee-438f-be53-7e99ebf7d2d4">
        <source>loadTableView(_tbl : CM_DataTable io;_entDef: String;_view:String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2023	navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
25 Aug 2025 navhl20 Story MTN-35317: MTN | Pagination - Work Order Operations
18 Sep 2025 navhl20 Bug MTN-36084: MTN | Work Order Operations Pagination column issue with view
*/

vars
	entTableDef		: EntTableDef;
	xmlStr,
	cmbTxt			: String;
begin
	_tbl.allSelectedObjects.clear();
	
	_tbl.userInputEnabled := false;
	_tbl.selectMode 	:= CM_EntryTable.SelectMode_FixedRow;
	_tbl.selectionType  := CM_EntryTable.SelectionType_Row;
	
	entTableDef 		:= app.myController.getEntTableDef(_entDef);
	
	if _tbl = self.tblJobsUnallocated then
		xmlStr := self.defJobUnAllocatted;
	elseif _tbl = self.tblJobsAllocated then
		xmlStr := self.defJobAllocatted;
	elseif _tbl = self.tblJobSheet then
		xmlStr := self.defJobSheet;
	elseif _tbl = self.tblWlesAllocated then
		xmlStr := self.defWleAllocated;
	elseif _tbl = self.tblWlesUnallocated then
		xmlStr := self.defWleUnallocated;
	endif;
	
	cmbTxt := self.cmbMode.text;															//18.09.2025 navhl20 #36084
	if xmlStr.cnEcGetTagValueOfName(cmbTxt) = null and self.operationMode &lt;&gt; cmbTxt then	//18.09.2025 navhl20 #36084
		xmlStr := null;
	endif;
	
	_tbl.setTblEntRowsFromView(entTableDef,_view,xmlStr);
	
	_tbl.readOnly 	  := false;	
	_tbl.fixedColumns := 0;
	_tbl.fixedRows 	  := 1;
epilog

end;</source>
        <Parameter name="_tbl" type="CM_DataTable" usage="io"/>
        <Parameter name="_entDef" type="String"/>
        <Parameter name="_view" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadTblAllocated" id="ccb79afd-1be7-4328-af21-3e7f945dd403">
        <source>loadTblAllocated();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2023	navma1	Initial creation
29 May 2023	navhl20 ChangeRequest 57747:[57748] EUP - Delivery Dispatch ? Allocate Jobs to Gangs
07 Jun 2023	navhl20 ChangeRequest 58543: EUP - Delivery Dispatch ? Allocation List - VAS
08 Jun 2023	navhl20 ChangeRequest 57745: EUP - Delivery Dispatch ? Allocation List - Road
15 Jun 2023	navhl20 ChangeRequest 57762: EUP - Delivery Dispatch ? Un Allocated Pack/UnPack
22 Jun 2023	navhl20 ChangeRequest 57758: EUP - Delivery Dispatch ? Un Allocated Rail
04 Jul 2023 navhl20 Defect 58906: MTN - The Allocated and Unallocated list is not refreshing correctly using the filter criteria
15 Sep 2023 navlc30 ChangeRequest 60211: EUP | Delivery Dispatch Colour Legend
05 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
09 Feb 2024 navnk30 ChangeRequest 62420: EUP | Retrospective Operations - [54177.020] - Allocate Road Jobs
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
10 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
24 Apr 2024 navlc30 ChangeRequest 63823: EUP | Performance Async Workers workorder operations
28 Jun 2024 navbs1  CR 64897 Task 64898: UI - Operation Combo add ALL
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
06 Jun 2025 navhn30 MTN -35013 | Error 4 When searching at Work Order operation Screen
25 Aug 2025 navhl20 Story MTN-35317: MTN | Pagination - Work Order Operations
*/

vars
	job 		 		 : CM_Job;
	idx					 : Integer;
	tbl			 		 : CM_DataTable;
	workPointJobSheet	 : CM_WorkPointJobSheet;
	mode			  	 : Integer;
	allFilteredJobs 	 : CM_JobsByRequiredDTPriority;
	voyage			  	 : CM_Voyage;
	isShipMode		  	 : Boolean;
	isModeAll			 : Boolean;
	jobSheetDict		 : CM_WPJobSheetByDate;
	jobDict				 : CM_JobsByPriorityRequiredDT;
	invalid				 : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, job, invalid);			//06.06.2025 navhn30 MTN-35013
	mode := self.operationModeInt;												//25.03.2025 navhl20 #34425
	if mode = YRD_WorkOrderOperation.Mode_ALL then								//25.02.2025 navma1 #MTN-34075
		isModeAll		:= true;											
	endif;
	
	tbl			 	:= self.tblJobsAllocated;
	tbl.multiSelect := CM_BaseTable.MultiSelect_Simple;								//25.5.2023 navhl20 #57747[57748]
	isShipMode	    := self.chkCurrentVoyage.value and self.operationMode = app.getErrorString(WO_Ship);			//25.03.2025 navhl20 #34425
	//isAsycEnabled	:= app.myRoot.isAsynchronousMethodEnabled();													//25.08.2025 navhl20 #35317
	
	create allFilteredJobs transient;																				//24.04.2024 navlc30 #63823
	
	create jobSheetDict transient;	
	self.myTerminal.allJobSheetsForWorkPoints.copy(jobSheetDict);					//25.02.2025 navma1 #MTN-34075
	
	foreach workPointJobSheet in jobSheetDict discreteLock do						//25.02.2025 navma1 #MTN-34075
		
		create jobDict transient;
		workPointJobSheet.allJobsByPriorityRequiredDT.copy(jobDict);				//25.02.2025 navma1 #MTN-34075
		
		foreach job in jobDict discreteLock do 										//25.02.2025 navma1 #MTN-34075
			invalid := false;														//06.06.2025 navhn30 MTN-35013 start
			job.edition;
			if invalid then
				continue;
			endif;																	//06.06.2025 navhn30 MTN-35013 end
		
			if idx &gt;= JadeTableRowLimit then
				app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; 
							JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
				break;
			endif;
			
			if not isModeAll and not job.isJobMatchingMode(mode) then			//28.06.2024 navbs1 CR 64897 Task 64898	//25.02.2025 navma1 #MTN-34075
				continue;
			endif;
			
			if isShipMode then													//05.10.2023 navhl20 #60033
				voyage := job.getMyVoyage();
				if voyage &lt;&gt; null and not voyage.isCurrentOnPort() then
					continue;
				endif;
			endif;
			
			if not self.includeObject(job,null) then							//23.5.2023 navhl20 #57714[57764]	//06.03.2025 navma1 #MTN-34179
				continue;
			endif;
		
			allFilteredJobs.add(job);
			
		endforeach;
		
		delete jobDict;
	endforeach;
	
	//navra1 - TFS 63751/Task 63752 - 13th May 2024	

	//25.08.2025 navhl20 #35317
	/*
	//25.08.2025 navhl20 #35317
	form := self;
	tbl.getDataAndDisplayRowsMultith(allFilteredJobs, true, form, true);*/
	//25.08.2025 navhl20 #35317
	self.allAllocatedJobs.clear;
	tbl.clearAllData();
	tbl.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, allFilteredJobs, true);
	allFilteredJobs.tryCopy(self.allAllocatedJobs);
	
	self.setShtCaption(tbl);											//01.6.2023 navhl20 #57747[57748]

epilog
	//navra1 - TFS 63751/Task 63752 - 13th May 2024 - start
	if tbl.allTblDataObjDict &lt;&gt; null then
		tbl.allTblDataObjDict.purge();				
		delete tbl.allTblDataObjDict;
	endif;
	delete jobDict;						//25.02.2025 navma1 #MTN-34075
	delete jobSheetDict;
	delete allFilteredJobs;				//24.04.2024 navlc30 #63823
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTblJobSheets" id="dac75e4f-9879-437e-b0bf-21e31662e142">
        <source>loadTblJobSheets();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet
01 Jun 2023 navhl20 ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
08 Jun 2023 navhl20 ChangeRequest 57745: EUP - Delivery Dispatch – Allocation List - Road
08 Jun 2023 navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
25 Oct 2023 navhl20 Bug 60931: EUP - Delivery Dispatch Remedial [2]
21 Nov 2023	navmd1	TFS 61353 Refactor to avoid 14011 on start up
25 Feb 2025 navma1 MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
05 Mar 2025 navbs1	Story MTN-34213: MTN - Work Order Operations screen loading data twice on start-up
*/

vars
	jobSheet 	 	: CM_WorkPointJobSheet;
	idx			 	: Integer;
	term		 	: CM_Terminal;
	theDataLine  	: String;
	tbl			 	: CM_DataTable;
	jobSheetDict	: CM_WPJobSheetByDate;
begin
	tbl  	  := self.tblJobSheet;
	if not tbl.visible then															//05.03.2025 navbs1 #34213
		return;
	endif;
	self.loadTable(tbl,ETDef_WoJobSheet);
	term 	  := self.myTerminal;
	
	create jobSheetDict transient;
	term.allJobSheetsForWorkPoints.copy(jobSheetDict);								//25.02.2025 navma1 #MTN-34075
	
	tbl.rows  := 1;

	foreach jobSheet in jobSheetDict discreteLock do								//25.02.2025 navma1 #MTN-34075	
		if idx &gt;= JadeTableRowLimit then
			app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; 
						JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
			break;
		endif;
		
		if not self.includeObject(null,jobSheet) then							//01.6.2023 navhl20 #57747[57748]
			continue;
		endif;
		
		tbl.addObject(jobSheet);
		idx := idx + 1;
	endforeach;
	
epilog
	delete jobSheetDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTblUnAllocated" id="935b5b91-f18b-4f78-8033-d1b4189daf0f">
        <updating/>
        <source>loadTblUnAllocated() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet
23 May 2023 navhl20 ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
25 May 2023 navhl20 ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
07 Jun 2023 navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
08 Jun 2023 navhl20 ChangeRequest 57745: EUP - Delivery Dispatch – Allocation List - Road
15 Jun 2023 navhl20 ChangeRequest 57762: EUP - Delivery Dispatch – Un Allocated Pack/UnPack
22 Jun 2023 navhl20 ChangeRequest 57758: EUP - Delivery Dispatch – Un Allocated Rail
04 Jul 2023 navhl20 Defect 58906: MTN - The Allocated and Unallocated list is not refreshing correctly using the filter criteria
15 Sep 2023 navlc30 ChangeRequest 60211: EUP | Delivery Dispatch Colour Legend
05 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
09 Feb 2024 navnk30 ChangeRequest 62420: EUP | Retrospective Operations - [54177.020] - Allocate Road Jobs
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
10 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
24 Apr 2024 navlc30 ChangeRequest 63823: EUP | Performance Async Workers workorder operations
28 Jun 2024 navbs1  CR 64897 Task 64898: UI - Operation Combo add ALL
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
25 Aug 2025 navhl20 Story MTN-35317: MTN | Pagination - Work Order Operations
*/

vars
	job 		 	  : CM_Job;
	roadJobSheet 	  : CM_RoadJobSheet;
	tbl				  : CM_DataTable;
	term			  : CM_Terminal;
	workOrderJobSheet : CM_WorkOrderJobSheet;
	mode			  : Integer;
	allFilteredJobs   : CM_JobsByRequiredDTPriority;
	voyage			  : CM_Voyage;
	isShipMode		  : Boolean;
	jobDict			  : CM_JobsByRequiredDTPriority;
	isModeAll		  : Boolean;
begin
	mode := self.operationModeInt;											//25.03.2025 navhl20 #34425
	if mode = YRD_WorkOrderOperation.Mode_ALL then
		isModeAll := true;
	endif;
	
	term				:= self.myTerminal;
	tbl			 		:= self.tblJobsUnallocated;
	roadJobSheet 		:= term.myRoadJobSheet;
	workOrderJobSheet	:= term.myWOJobSheet;
	tbl.multiSelect 	:= CM_BaseTable.MultiSelect_Simple;			//25.5.2023 navhl20 #57747[57748]
	isShipMode		    := self.chkCurrentVoyage.value and self.cmbMode.text = app.getErrorString(WO_Ship);
	//isAsycEnabled		:= app.myRoot.isAsynchronousMethodEnabled();		//25.08.2025 navhl20 #35317
	
	create allFilteredJobs transient;										//24.04.2024 navlc30 #63823
	
	create jobDict transient;
	workOrderJobSheet.allJobsByRequiredDTPriority.copy(jobDict);			//25.02.2025 navma1 #MTN-34075
	foreach job in jobDict discreteLock do 
		
		if job.myJobSheetForWorkPoint &lt;&gt; null then            				 // Already Assigned 
			continue;
		endif;			
		
		if not isModeAll and not job.isJobMatchingMode(mode) then			//28.06.2024 navbs1 CR 64897 Task 64898
			continue;
		endif;
		
		if isShipMode then													//05.10.2023 navhl20 #60033
			voyage := job.getMyVoyage();
			if  voyage &lt;&gt; null and not voyage.isCurrentOnPort() then
				continue;
			endif;
		endif;
		
		if not self.includeObject(job,null) then							//23.5.2023 navhl20 #57714[57764] //06.03.2025 navma1 #MTN-34179
			continue;
		endif;		
		
		allFilteredJobs.add(job);											//24.04.2024 navlc30 #63823
	endforeach;
	
	//navra1 - TFS 63751/Task 63752 - 13th May 2024	
	/*
	//25.08.2025 navhl20 #35317
	form := self;
	tbl.getDataAndDisplayRowsMultith(allFilteredJobs, true, form, true);*/
	//25.08.2025 navhl20 #35317
	self.allUnAllocatedJobs.clear;
	tbl.clearAllData();
	tbl.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, allFilteredJobs, true);
	allFilteredJobs.tryCopy(self.allUnAllocatedJobs);
	
	self.setShtCaption(tbl);
	
epilog
	//navra1 - TFS 63751/Task 63752 - 13th May 2024 - start
	if tbl.allTblDataObjDict &lt;&gt; null then
		tbl.allTblDataObjDict.purge();				
		delete tbl.allTblDataObjDict;
	endif;
	
	delete jobDict;
	delete allFilteredJobs;				//24.04.2024 navlc30 #63823
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTblWPJobSheets" id="d11f4542-6ebf-4166-a777-ddccaced3ae6">
        <source>loadTblWPJobSheets();
/*
 
Purpose:			
 
Parameters:			
 
Return Value:		
 
Date		Who		Reason
08 Jul 2024	navbs1	ChangeRequest 64778: EUP | Delivery Dispatch Multi Select Search
06 Aug 2024 navlc30 Task 65393 : UI - Work Order Ops Multi Work Points
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
 
*/
 
vars
	iter		 	: Iterator;
	jobSheet		: CM_WorkPointJobSheet;
	selectedObjs	: ObjectArray;
	fromShift,
	toShift			: CM_Shift;
	fromDate,
	toDate			: TimeStamp;	
	jobSheetDict	: CM_WPJobSheetByDate;
	shift			: CM_Shift;
	wpType			: CM_WorkPointType;
begin
 
	create jobSheetDict transient;
	self.myTerminal.allJobSheetsForWorkPoints.copy(jobSheetDict);
	
	selectedObjs	:= self.tblWorkPointTypes.allSelectedObjects;
	fromShift 		:= self.cmbShiftFrom.listObject.CM_Shift;							//06.08.2024 navlc30 #65393[65412]
	toShift 		:= self.cmbShiftTo.listObject.CM_Shift;								//06.08.2024 navlc30 #65393[65412]
	
	fromDate.setDate(self.txtFromDate.getDate());										//06.08.2024 navlc30 #65393[65412]
	if self.txtFromTime.text = "  :  " then
		fromDate.setTime('00:01'.Time);
	else
		fromDate.setTime(self.txtFromTime.getTime);
	endif;
	
	toDate.setDate(self.txtToDate.getDate());												//06.08.2024 navlc30 #65393[65412]
	if self.txtFromTime.text = "  :  " then
		toDate.setTime('00:01'.Time);
	else
		toDate.setTime(self.txtToTime.getTime);
	endif;
	
	self.tblWPJobSheet.clearTable;
	self.tblWPJobSheet.sortColumn[1]:=2;
	
	foreach jobSheet in jobSheetDict discreteLock do
		
		wpType := jobSheet.myWorkPoint.myWorkPointType;									//25.02.2025 navma1 #MTN-34075
		
		if wpType = null then
			continue;
		endif;
		
		if not selectedObjs.includes(wpType) then										//25.02.2025 navma1 #MTN-34075
			continue;
		endif;
		
		shift := jobSheet.myShift;														//25.02.2025 navma1 #MTN-34075
		
		if shift &lt;&gt; null then															//25.02.2025 navma1 #MTN-34075
			if fromShift &lt;&gt; null and fromDate &lt;&gt; null and fromDate.isValid and  fromDate &gt; shift.startDateTime then				//06.08.2024 navlc30 #65393[65412]
				continue;
			endif;
			
			if toShift &lt;&gt; null and toDate &lt;&gt; null and toDate.isValid and  toDate &lt; shift.startDateTime then						//06.08.2024 navlc30 #65393[65412]
				continue;
			endif;
		endif;
		
		self.tblWPJobSheet.addItemObject(jobSheet.externalName, jobSheet);
	endforeach; 
	
epilog
	delete jobSheetDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTblWleAllocated" id="faf5bc69-6b7c-4f66-b28a-5b8a0b3d7f2d">
        <source>loadTblWleAllocated(_obj : Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Jun 2023 navhl20 ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
19 Jun 2023 navlw1 	CHangeRequest 58294: EUP | Delivery Dispatch Screen - Setting Priority
16 Oct 2023 navhl20 Bug 60863: EUP - Delivery Dispatch Remedial [1]
21 Nov 2023	navmd1	TFS 61353 Only populate the table if its visible
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
06 Aug 2024 navhl20	Bug 65424: EUP | 53729 - WO Jobs - Split Pack or Unpack job issues
20 Aug 2024 navlc30 Task 65695: Jade - Show same WLE for each TI
11 Nov 2024 navlc30 JIRA 33404 EUP - To Do Task Job for which a WO Transaction is set on Complete - Total Qty and Operator are not shown correctly
04 Dec 2024 navlc30 JIRA 32992 EUP | VAS WO - Show Each TI for WO To Do Job - Refinement
25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
25 Aug 2025 navhl20 Story MTN-35317: MTN | Pagination - Work Order Operations
*/

vars
	wle			: CM_WorkListEntry;
	i			: Integer;
	tbl			: CM_DataTable;
	job			: CM_Job;
	mnuChild 	: MenuItem;
	wleArr,
	tempWleArr  : CM_WLEArray;
	form 		: CM_BaseForm;
begin
	if not self.tblWlesAllocated.visible or _obj = null then
		return;
	endif;

	// Clear the table
	tbl 		:= self.tblWlesAllocated;
	tbl.clearAllData();
	
	job := _obj.CM_Job;
	wle := job.workListEntries.first;													//20.08.2024 navlc30 #65695 [65352]

	//wles := job.workListEntries;
	
	create wleArr transient;															//25.03.2024 navhl20 #62300
	create tempWleArr transient;														//04.12.2024 navlc30 #32992
	
	self.getWLEsforJob(job, wleArr, tempWleArr);										//25.03.2025 navhl20 #34425
	
	//navra1 - TFS 63751/Task 64183 - 17th May 2024 - start
	/*
	//25.08.2025 navhl20 #35317
	form := self;
	tbl.getDataAndDisplayRowsMultith(wleArr, true, form, true);*/
	tbl.clearAllData();
	tbl.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, wleArr, true);	//25.08.2025 navhl20 #35317
	
	// 19June2023 TFS 58294 navlw1
	foreach i in 1 to 3 do
		mnuChild := self.mnuSetPriority.getMenuItem(i);
		mnuChild.checked := (i = job.priority);
	endforeach;
	
epilog	
	if tempWleArr &lt;&gt; null  and tempWleArr.size() &gt; 0 then	//04.12.2024 navlc30 #32992
		tempWleArr.purge();
	endif;
	delete tempWleArr;										//04.12.2024 navlc30 #32992
	delete wleArr;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="loadTblWleUnAllocated" id="4c7f9e24-ec77-4310-9004-4192109dd19c">
        <source>loadTblWleUnAllocated(_obj : Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navhl20	ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
12 Oct 2023 navhl20 Bug 60863: EUP - Delivery Dispatch Remedial [1]
21 Nov 2023	navmd1	TFS 61353 Only populate the table if its visible
29 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
20 Aug 2024 navlc30 Task 65695: Jade - Show same WLE for each TI
21 Aug 2024 navhl20	Bug 65424: EUP | 53729 - WO Jobs - Split Pack or Unpack job issues
11 Nov 2024 navlc30 JIRA 33404 EUP - To Do Task Job for which a WO Transaction is set on Complete - Total Qty and Operator are not shown correctly
04 Dec 2024 navlc30 JIRA 32992 EUP | VAS WO - Show Each TI for WO To Do Job - Refinement
25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
25 Aug 2025 navhl20 Story MTN-35317: MTN | Pagination - Work Order Operations
*/

vars
	wle			: CM_WorkListEntry;
	tbl			: CM_DataTable;
	wleArr,
	tempWleArr	: CM_WLEArray;
	job			: CM_Job;
	form 		: CM_BaseForm;
begin
	
	if not self.tblWlesUnallocated.visible or _obj = null then
		return;
	endif;
	
	// Clear the table
	tbl 		:= self.tblWlesUnallocated;
	tbl.clearAllData();
	
	job := _obj.CM_Job;																	//20.08.2024 navlc30 #65695 [65352]
	wle := job.workListEntries.first;													//20.08.2024 navlc30 #65695 [65352]	
	
	create wleArr transient;															//25.03.2024 navhl20 #62300
	create tempWleArr transient;														//04.12.2024 navlc30 #32992	
	self.getWLEsforJob(job, wleArr, tempWleArr);										//25.03.2025 navhl20 #34425
	
	//navra1 - TFS 63751/Task 64183 - 17th May 2024 - start
	/*
	//25.08.2025 navhl20 #35317
	form := self;
	tbl.getDataAndDisplayRowsMultith(wleArr, true, form, true);*/
	tbl.clearAllData();
	tbl.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, wleArr, true);	//25.08.2025 navhl20 #35317
epilog
	if tempWleArr &lt;&gt; null  and tempWleArr.size() &gt; 0 then	//04.12.2024 navlc30 #32992
		tempWleArr.purge();
	endif;
	delete tempWleArr;										//04.12.2024 navlc30 #32992
	delete wleArr;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="loadtblWorkPointTypes" id="62c00652-b61e-4724-96e8-d4cea58c662b">
        <updating/>
        <source>loadtblWorkPointTypes()updating;
/*
 
Purpose:			
 
Parameters:			
 
Return Value:		
 
Date		Who		Reason
09 Jul 2024	navbs1	ChangeRequest 64778: EUP | Delivery Dispatch Multi Select Search
06 Aug 2024 navlc30 Task 65393 : UI - Work Order Ops Multi Work Points
 25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
*/
 
vars
	iter		 	: Iterator;
	workPointType	: CM_WorkPointType;
	opMode,index	: Integer;
begin
 
	iter := self.myTerminal.allWorkPointTypes.createIterator;
	self.tblWorkPointTypes.clearTable();
	self.tblWorkPointTypes.sortColumn[1]:=2;
	opMode := self.operationModeInt;																							//25.03.2025 navhl20 #34425
 
	while iter.next(workPointType) do
		if workPointType.notAvailableForEntry then
			continue;
		endif;
		index := self.tblWorkPointTypes.addItemObject(workPointType.code &amp;" "&amp; workPointType.description, workPointType);		//06.08.2024 navlc30 #65393[65412]
		if opMode = Mode_ALL or  workPointType.type = opMode then
			if not opMode = Mode_ALL then
			self.tblWorkPointTypes.setRowSelect(index,true);
			endif;
		endif;
	endwhile;
	self.tblWorkPointTypes_click(self.tblWorkPointTypes);

epilog
	delete iter;
end;</source>
    </JadeMethod>
