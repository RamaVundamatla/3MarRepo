    <JadeMethod name="gridXMLpopulate" id="223f8b24-62dd-4259-a77e-a6cc4efbd68a">
        <updating/>
        <source>gridXMLpopulate(_theXMLString : String) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theXMLTag,gridPointCoOrds : String;
	pos : Integer;
	theRow, theCol : Integer;
	aPoint : CMUI_GridPoint;
//	theLog : JadeLog;
begin
//	create theLog;
//	theLog.fileName := "gridxml4.txt";
//	theLog.filePath := "C:\temp";

	pos := 1;
	while (pos &gt; 0) do
		theXMLTag := _theXMLString.cnEcGetNextTagValueOfName("GP",pos);
//		theXMLTag := _theXMLString.getNextTagValueOfName("GP",pos);
		if theXMLTag = null then
//			app.writeStatement( "ERROR " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. TAG GP not Found. " &amp; pos.String);
			break;
		endif;
		
		gridPointCoOrds := theXMLTag.cnEcGetTagValueOfName("Ord");
		theCol := gridPointCoOrds[1:2].Integer;
		theRow := gridPointCoOrds[3:2].Integer;
//theLog.info("gridPointCoOrds: " &amp; gridPointCoOrds	&amp; " pos: " &amp; pos.String &amp; " theRow: " &amp; theRow.String &amp; " theCol: " &amp; theCol.String);
		aPoint := self.allGridPoints[theRow, theCol];
		if aPoint = null then
			app.writeStatement( "ERROR " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. my ROW/COL: " &amp; self.row.String &amp; "/" &amp; self.column.String &amp; " -  Point NOT FOUND.. Aborting &gt;&gt;&gt;" &amp; gridPointCoOrds &amp; "&lt;&lt;&lt;");
			continue;
		endif;
		
		aPoint.populateGridXML(theXMLTag);
	endwhile;	
//theLog.commitLog();

end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="hasColLabel" id="aa88dd73-0df2-4854-9411-8a9fb3f3c418">
        <source>hasColLabel(_label:String): Boolean;
// ---------------------------------------------------------------------------
// Created:		01 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	gCol : CMUI_GridColumn;
begin
	
	foreach gCol in self.allGridColumns do
		if _label = gCol.label then
			//duplicate label
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_label" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
