    <JadeMethod name="doCriteriaChanged" id="183f8926-be6b-4ba0-85a5-9356eda25833">
        <source>doCriteriaChanged();

/*

Purpose:		Call back method for change of criteria value (refer frmCriteria::formCriteriaChangeMethodName)

Parameters:			

Return Value:		


Date			Who		Reason
06 August 2008	consw1	Initial creation
*/

vars
	currentCritType : CM_YACriteriaType;
	objs : ObjectSet;
	object : CM_Object;
	control : CMUI_YACriteriaCntl;
	colour : Integer;
begin
	
	self.formatName(false);

	if self.myDefaultConfigColourType = null or self.userChangedColour  then
		return;
	endif;
	
	if self.myCurrentYAControl = null then
		return;
	endif;

	control := self.myCurrentYAControl;
	
	if control = null then
		return;
	endif;
	
	currentCritType := control.getCriteriaType();
	
	if currentCritType &lt;&gt; null and currentCritType = self.myDefaultConfigColourType  then
	create objs transient;
		if control.txtCriteriaValue.text &lt;&gt; null then
		
			self.myDefaultConfigColourType.resolvePattern(control.txtCriteriaValue.text,objs, true);	
			
			if not objs.isEmpty() then
				object := objs.first().CM_Object;
				
				// Do this to save having to write hundreds of YA methods to get the colour
				colour := object.getPropertyValue("colour").Integer;				
				self.clrYAColour.setColor(colour);
			endif;
		endif;
	endif;
	

epilog
	delete objs;
end;</source>
