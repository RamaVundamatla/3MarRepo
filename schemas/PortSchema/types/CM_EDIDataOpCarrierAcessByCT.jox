    <JadeMethod name="verifyEDIData" id="cfda3929-7e7b-4b98-8844-b94b04c11d51">
        <updating/>
        <source>verifyEDIData(): Integer updating;
//
// 08 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//
vars

begin
	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);

	if self.myOperator = null then
		app.raiseCMException1(ERR_INVALID_OPERATOR, self.operatorCode, null, self);
	endif;
epilog
	return app.myPassport.allErrorWarnings.size;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="817d5d3a-ecfd-49dd-8db1-76f0c09f7e6c">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
//
// 08 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//
vars
	ediTI : CM_EDITrackedItem;
begin
	on Exception do validationExceptionHandler(exception, _passport);
	foreach ediTI in self.allEDITrackedItems do
		ediTI.verifySelf();
	endforeach;
	return _passport.allErrorWarnings.size;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
