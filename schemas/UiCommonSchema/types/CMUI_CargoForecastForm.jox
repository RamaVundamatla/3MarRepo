    <JadeMethod name="doPermissionCheck" id="15a0e595-aba4-4aa0-ab43-82bbd34cfbcc">
        <source>doPermissionCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2022	navtnr20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars

begin
	if  app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSave.enabled:= true;
		self.btnNew.enabled:= true;
	endif;
epilog

end;</source>
