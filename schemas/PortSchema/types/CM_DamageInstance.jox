    <JadeMethod name="setProxy" id="5d8d5dbb-3427-4658-b602-1c2fb830cbd0">
        <updating/>
        <source>setProxy(	_pxyTI 			: CM_TrackedItem;
			_pxyTIMaster 	: CM_TIMaster;
			_damageDefCode 	: CM_DamageDefinitionCode;
			_damagePosition : CM_DamagePosition;
			_remarks 		: String;
			_isNewDamage	: Boolean;
			_quantity		: Integer;
			_severity		: CM_DamageSeverity;	// 11.07.2022 navak20 TFS 53862
			//_repaired		: Boolean;	// 11.07.2022 navak20 TFS 53862
			_locationStr 	: String;	//01 Mar 2016	NDL	TFS 1593
			_damagePlace	: CM_DamagePlace;	// Jun 28, 2022 navak20 TFS 53862
			_damageParty	: CM_DamageParty;	// Jun 28, 2022 navak20 TFS 53862
			_damageReason	: CM_DamageReason;	// Jun 28, 2022 navak20 TFS 53862
			_repairReason	: CM_RepairReason;	// Jun 28, 2022 navak20 TFS 53862
			_damageSize		: Decimal;			// Jun 28, 2022 navak20 TFS 53862
			_damageDateTime	: TimeStamp;		// Jun 28, 2022 navak20 TFS 53862
			_status			: Integer;		// Jun 28, 2022 navak20 TFS 53862
			_repairRemarks	: String;		// Jun 28, 2022 navak20 TFS 53862	
			_repairedDateTime : TimeStamp	// Jun 28, 2022 navak20 TFS 53862
			) updating;
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
// 28/07/2009 cnwsh3 CCMS SFW1066 PAR20321 - Recording Damage Details Changes. 
//                   Damage location is now user definable and can be allocated
//					 to machines, wagons with depedency on cargo types.
----------   ----------  --------------------------------------------------
// cnwrd1 ccms 1034 13.8.2008
// 04/06/2019 jlgam15 TFS 44621 - Allow multiple damage reports of same code
//24 June 2022 navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details

27/06/2022	navak20		 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
*/
vars


begin
	//self.damageLocation		:= _damageLocation;
	
	self.myDamageSeverity := _severity;		// 11.07.2022 navak20 TFS 53862
	self.myTrackedItem 		:= _pxyTI;
	//self.myTIMasterTILC		:= _pxyTIMasterTILC;
	self.myTIMaster			:= _pxyTIMaster;
	self.myDamageDefinition := _damageDefCode;
	self.myDamagePosition   := _damagePosition;
	self.remarks			:= _remarks;
	self.isNewDamage 		:= _isNewDamage;
	self.quantity			:= _quantity;
	//self.repaired			:= _repaired;	Jun 28, 2022 navak20 TFS 53862
	self.locationString  	:= _locationStr;
	self.setTimeStamp(app.actualTimeServer()); //TFS 44621
	
	// Jun 28, 2022 navak20 TFS 53862
	self.myDamagePlace := _damagePlace;
	self.myDamageParty := _damageParty;
	self.myDamageReason := _damageReason;
	self.myRepairReason := _repairReason;
	self.damageSize := _damageSize;
	self.damageDateTime := _damageDateTime;
	self.status := _status;
	self.repairedDateTime := _repairedDateTime;
	self.repairRemarks := _repairRemarks;
	// Jun 28, 2022 navak20 TFS 53862
	
end;

</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
        <Parameter name="_pxyTIMaster" type="CM_TIMaster"/>
        <Parameter name="_damageDefCode" type="CM_DamageDefinitionCode"/>
        <Parameter name="_damagePosition" type="CM_DamagePosition"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_isNewDamage" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_severity" type="CM_DamageSeverity"/>
        <Parameter name="_locationStr" type="String"/>
        <Parameter name="_damagePlace" type="CM_DamagePlace"/>
        <Parameter name="_damageParty" type="CM_DamageParty"/>
        <Parameter name="_damageReason" type="CM_DamageReason"/>
        <Parameter name="_repairReason" type="CM_RepairReason"/>
        <Parameter name="_damageSize" type="Decimal"/>
        <Parameter name="_damageDateTime" type="TimeStamp"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_repairRemarks" type="String"/>
        <Parameter name="_repairedDateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setRepairDetailDeleted" id="2bc69993-d5ac-4309-ac03-e3f4484de975">
        <updating/>
        <source>setRepairDetailDeleted() updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 28 November 2018
TFS#		: 41225
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	repairDetail : CM_RepairDetail;
begin
	repairDetail := self.myRepairDetail;
	if repairDetail &lt;&gt; null then
		repairDetail.setForDelete("Instance has been removed from the Cargo.");
		self.setMyRepairDetail(null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setRepairTransactionDeleted" id="82ff3275-485f-4c01-ba7a-8ed292b99592">
        <source>setRepairTransactionDeleted(deletionReason : String);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 28 November 2018
TFS#		: 41225
Function	:

*** Changes ***
Date			Name		TFS#		Description
27 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
****************************************************/

vars
	repairTransaction : CM_Repair;
begin
	repairTransaction := self.myTrackedItem.getRepairTransaction();
	if repairTransaction &lt;&gt; null then
		repairTransaction.setForDelete(deletionReason);
	endif;
	//self.myTrackedItem.setDamagedDT();			//27.07.2022 navsrk20 TFS 53862
	self.myTrackedItem.setDamagedDT(false);			//27.07.2022 navsrk20 TFS 53862
end;</source>
        <Parameter name="deletionReason" type="String"/>
    </JadeMethod>
