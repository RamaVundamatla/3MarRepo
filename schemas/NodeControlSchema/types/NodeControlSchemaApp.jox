    <JadeMethod name="cnStandardizePathName" id="800c5b77-036b-4ddf-a672-7c0fcbdba6d7">
        <updating/>
        <source>cnStandardizePathName(pathname : String) : String updating;

vars
 	i 		: Integer;
 	str		: String;
 	len		: Integer;
 	fname	: String;
begin
	///    Changes path names with backslashes to forward slashes   ////

	fname := pathname;

	if fname.length &gt; 1 and fname[1:2] = "\\" then			// retain UNC name
		fname.replaceChar("\", "/");
		fname[1:2]	:= "\\";
	else
		fname.replaceChar("\", "/");
	endif;	

	return fname;
end;</source>
        <Parameter name="pathname" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="commandProcessorFinalize" id="2caac0e1-14f8-4c15-a0cc-c43a56b2a59a">
        <updating/>
        <source>commandProcessorFinalize() updating;

begin
	beginTransientTransaction;
	delete myCommandProcessor;
	commitTransientTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="commandProcessorInitialize" id="01fadedd-1a25-45f5-851b-b4231ede1adf">
        <updating/>
        <source>commandProcessorInitialize(supervisor:CommandProcessor io) updating;

begin
	beginTransientTransaction;
	create myCommandProcessor sharedTransient;
	myCommandProcessor.cmdLine:=supervisor.cmdLine;
	myCommandProcessor.stdOut:="";
	myCommandProcessor.reportWhenFinished:=true;
	supervisor.myCP:=myCommandProcessor;
	myCommandProcessor.myCP:=supervisor;
	myCommandProcessor.logFileName:=supervisor.logFileName;
	myCommandProcessor.doingWinZip:=supervisor.doingWinZip;
	myCommandProcessor.doingSchemaExtract:=supervisor.doingSchemaExtract;
	myCommandProcessor.doingJdbutil:=supervisor.doingJdbutil;
	commitTransientTransaction;

	myCommandProcessor.run;

	beginTransientTransaction;
	supervisor.stdOut:=myCommandProcessor.stdOut;
	supervisor.exitCode:=myCommandProcessor.exitCode;
	supervisor.result:=myCommandProcessor.result;
	commitTransientTransaction;
//	write myCommandProcessor.stdOut.display;
	if supervisor.logFileName=null then  // wait till supervisor is finished with our stdOut
		while myCommandProcessor.stdOut&lt;&gt;Command_Finished do
			app.doWindowEvents(250);
		endwhile;
	endif;
	terminate;
end;</source>
        <Parameter name="supervisor" type="CommandProcessor" usage="io"/>
    </JadeMethod>
    <JadeMethod name="displayInterval" id="9a72aa0c-426f-46f7-ac27-c2a3df1abdf1">
        <source>displayInterval(beginTimeStamp,endTimeStamp:TimeStamp):String;

constants
	OneHour=60*60*1000;
vars
	bdate,edate:Date;
	btime,etime:Time;
	elapsed:Decimal[23];
begin
	bdate:=beginTimeStamp.date;
	edate:=endTimeStamp.date;
	btime:=beginTimeStamp.time;
	etime:=endTimeStamp.time;
	elapsed:=(etime.Decimal+(edate.Decimal-bdate.Decimal)*24*OneHour-btime.Decimal);
	if elapsed&gt;24*OneHour then
		return ((elapsed/(24*OneHour)).truncatedTo(0)).String&amp;"d,"&amp;(elapsed mod (24*OneHour)).Time.format("H:mm:ss");
	elseif elapsed.Time&gt;=OneHour.Time then
		return elapsed.Time.format("H:mm:ss");
	else
		return elapsed.Time.format("m:ss");
	endif;
end;</source>
        <Parameter name="beginTimeStamp" type="TimeStamp"/>
        <Parameter name="endTimeStamp" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="executeOnServer" id="8335b5b5-9dea-4a9f-9409-f31022f424f7">
        <executionLocation>server</executionLocation>
        <source>executeOnServer(obj:Object; meth:String):Any serverExecution;

begin
	return obj.sendMsg(meth);
end;</source>
        <Parameter name="obj" type="Object"/>
        <Parameter name="meth" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="fatClientStart" id="603ca285-cb49-4a2b-ab13-f0672e3ac092">
        <updating/>
        <source>fatClientStart(schemaname,appname:String) updating;

vars
	retCode,i,j:Integer;
	s,path,envName:String;
	sa:StringArray;
begin
	create sa transient;
	s:=app.dbPath;
	i:=s.pos("\",1);
	j:=s.pos("\",i+1);
	envName:=s[i+1:j-i-1];
	path:=app.getJadeInstallDirAppServer.toLower;
//	logMessage(path);
	sa[1]:="path="&amp;app.dbPath;
	sa[2]:="app="&amp;appname&amp;" schema="&amp;schemaname&amp;" server=multiuser";
	sa[3]:="ini="&amp;path&amp;"\"&amp;envName&amp;".ini";
//	sa[4]:='JadeClient.ServerNodeSpecifications="JadeLocal,'&amp;transport&amp;'"';
//	sa[5]:='JadeClient.AutomaticCacheCoherency=false';
	node.createExternalProcess(path,path&amp;"\jade.exe",sa,null,false,false,retCode);
epilog
	delete sa;
end;</source>
        <Parameter name="schemaname" type="String"/>
        <Parameter name="appname" type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnvid" id="0530ec03-7e02-4f03-9096-5dcf52f105a4">
        <source>getEnvid():String;

vars
	i,j:Integer;
	s:String;
begin
	s:=app.dbPath;
	i:=s.pos("\",1);
	j:=s.pos("\",i+1);
	return s[i+1:j-i-1];
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInstanceId" id="6481aff9-75d6-4e3d-a781-f30cbf351a22">
        <source>getInstanceId(o:Object):Integer;

vars
	s:String;
	posn,i:Integer;
begin
	posn:=1;
	s:=getOidStringForObject(o);
	posn:=s.reversePos(".")+1;
	return s[posn:end].Integer;
end;</source>
        <Parameter name="o" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getUserCmdLine" id="14b5b915-cbf7-4ebc-a4c9-6b9af96324e7">
        <updating/>
        <source>getUserCmdLine():String updating;

vars
	s,t:String;
	i,j:Integer;
begin
	if app.isUnicode then
		s:=(call getCommandLineW);
	else
		s:=(call getCommandLine);
	endif;
	logMessage("&lt;"&amp;s&amp;"&gt;");
	i:=s.toLower.pos(" endjade ",1);
	if i=0 then return null; endif;  // No endJade token
	return s[i+8:end].trimBlanks;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="killerInitialize" id="4cba2b29-efac-44af-85d1-0c20f5821ace">
        <updating/>
        <source>killerInitialize() updating;

vars
	nod:Node;
	proc:Process;
begin
	logMessage("forcing off users");
	foreach nod in system.nodes where nod &lt;&gt; node and nod.isServerNode=false and (nod.isApplicationServer=false or name="KillerAll") do
		foreach proc in nod.processes where proc&lt;&gt;process and proc.schema.name&lt;&gt;"RootSchema" do
			logMessage("forcing off "&amp;nod.name&amp;"/"&amp;proc.persistentApp.name&amp;"/"&amp;getInstanceId(proc).String&amp;" ("&amp;proc.signOnUserCode&amp;")");
			system.forceOffUser(nod,proc);
		endforeach;
	endforeach;
	logMessage("finished");
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="logMessage" id="74d9e0c5-e0af-44a9-bd43-f0241d7594da">
        <updating/>
        <source>logMessage(s:String) updating;
/*  Uses the JadeLog class to write a message to msg&lt;n&gt;.log  */
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
begin
	if msgLog=null then
		create msgLog;
		msgLog.fileName:="msg";
		msgLog.formatOutput:=false;
		msgLog.maxFileSize:=getProfileStringAppServer(getIniFileNameAppServer,"JadeLog","MaxLogFileSize","1000000").Integer;
	endif;
	msgLog.log(actualTimeServer.logFormat&amp;" "			// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
					&amp;name&amp;"/"&amp;getInstanceId(process).String&amp;": "
					&amp;s&amp;CrLf);
end;</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="makePathIfPossible" id="dc49ac2e-5cdf-423a-ac16-583a355ea9a5">
        <source>makePathIfPossible(pFileSpecifier:String; pLocal:Boolean): Boolean;
/*
	Pass in a file specifier and this will attempt to make a path to it!

	Expects a full file specifier e.g. '\\servername\dir1\dir2\dir3\filename.blah' 
									or 'd:\dir1\dir2\dir3\filename.blah'

	If (using the examples above) dir2 and dir3 don't exist, it'll try to create \dir1\dir2 and 
	then dir1\dir2\dir3. It will work through the path until all necessary directories have
	been created.

	NB this DOES NOT work for $ shares
*/
vars
	folder		: FileFolder;
	i			: Integer;
	checkPath	: String;
	filename	: String;
begin
	create folder transient;

	filename:=app.cnStandardizePathName(pFileSpecifier);	// Changes '\' to '/' slash apart from '\\'
	folder.usePresentationFileSystem:=pLocal;

	i:=filename.reversePos( '/' );

	if i &gt; 0 then
		checkPath:=filename[1:i-1];
		if folder.isValidPathName(checkPath) then
			folder.fileName:=checkPath.toLower;
			if not folder.isAvailable then
				folder.make();					
				app.logMessage(method.qualifiedName &amp; 'Made '&amp;checkPath &amp; " local=" &amp; pLocal.String);
			endif;
			return true; 
		else
			app.logMessage(method.qualifiedName &amp; ' Invalid path: '&amp;checkPath &amp; " local=" &amp; pLocal.String &amp; " " &amp; pFileSpecifier);
			return false;
		endif;
	endif;
epilog
	delete folder;
end;</source>
        <Parameter name="pFileSpecifier" type="String"/>
        <Parameter name="pLocal" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processLoggerFinalize" id="21d75998-5e7a-4c1e-a486-b2e82f192cfb">
