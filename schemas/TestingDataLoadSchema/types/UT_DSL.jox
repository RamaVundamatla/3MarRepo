    <JadeMethod name="webServiceCall" id="1f12d9da-c22a-4404-ab80-e630dda4fc30">
        <source>webServiceCall( _methodName : String );
/*

Purpose:
		
		Use this method to test the WebServiceProvider classes in WebServicesSchema
		
		First create a method on the class "CM_UnitTestAgent" on PortSchema (gives you a reference
		to the method when calling from the JMTUnitTest Schema ). Your method should return a
		string containing the error when it fails or a null when it passes.
		
		Re-implement the method on the clas "WS_UnitTestAgent" in the Schema 'WebServicesSchema'
		that represents the actual test.
		
		In your subclass of UT_DSL call this method passing in the name of the method via
		its reference.
		
Parameters:			

Return Value:		

Date		Who		Reason
09 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

	webServicesSchema : Schema;
	class : Class;
	wsTestAgent : Object;
	returnString : String;

begin

	webServicesSchema := rootSchema.getSchema("WebServicesSchema");
	class := webServicesSchema.getClass("WS_UnitTestAgent");
	create wsTestAgent as class transient;
	returnString := wsTestAgent.sendMsg( _methodName ).String;
	self.assertTrueMsg( returnString = null, returnString );

epilog

	delete wsTestAgent;
	
	// 23 Sep 2015	NDL, using the web service clears the passport term and user.
	app.myPassport.setMyTerminal(CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString]);
	app.myPassport.setMyUserFromCode(self.getProfileSetting(UT_Profile.P_USER).asString);
	app.setSpecial(null);								// 09/06/2016 cnwmh5

end;</source>
        <Parameter name="_methodName" type="String"/>
    </JadeMethod>
    <JadeMethod name="webServiceCallWithParams" id="f0a033c2-999b-499b-b280-c86ce77e2d03">
        <source>webServiceCallWithParams( _methodName : String; _paramList: ParamListType io );
/*

Purpose:		
		XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
		
		same as "webServiceCall" method but with params
		see "webServiceCall" method for instructions....
		
		XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
Parameters:			

Return Value:		

Date		Who		Reason
09 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

	webServicesSchema : Schema;
	class : Class;
	wsTestAgent : Object;
	returnString : String;

begin

	webServicesSchema := rootSchema.getSchema("WebServicesSchema");
	class := webServicesSchema.getClass("WS_UnitTestAgent");
	create wsTestAgent as class transient;
	returnString := wsTestAgent.sendMsgWithIOParams(_methodName,_paramList).String;
	self.assertTrueMsg( returnString = null, returnString );

epilog

	delete wsTestAgent;
	
	// 23 Sep 2015	NDL, using the web service clears the passport term and user.
	app.myPassport.setMyTerminal(CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString]);
	app.myPassport.setMyUserFromCode(self.getProfileSetting(UT_Profile.P_USER).asString);
	app.setSpecial(null);								// 09/06/2016 cnwmh5

end;</source>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_paramList" type="ParamListType" usage="io"/>
    </JadeMethod>
    <JadeMethod name="workVehicle" id="737cf32d-8bb9-44b8-95d6-955f5cffe699">
        <source>workVehicle(_vvr: CM_VehicleVisitRecord);
//19 August 2009	cnwdw1	
// 05/08/2011 cnwmh5 Remove opts from signature as not used
vars
	wleArray,
	wlesWithWarnings : CM_WLEArray;	
begin

	create wleArray transient;
	create wlesWithWarnings transient;
	_vvr.myRoadJob.getAllWLEs(wleArray);
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWLEsDoMove(wleArray, wlesWithWarnings, REAL_MODE, false, null,  app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
