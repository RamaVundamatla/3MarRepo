    <JadeMethod name="doReviewAlert" id="ea4d1594-3176-4ca8-b4e5-ab60c4d3076b">
        <source>doReviewAlert();
// 08 Dec 2008 CNWDW1
// Set the selected Alert to reveiwed
//03 July 2025	naviv1	MTN-35171 : MTN - Optimize Satellite View Screen to Handle Large Volumes of Failed Auto Plan Alerts Efficiently
vars
	alert: CM_SystemAlert;
	oa : ObjectArray;				//+cwnml2 PAR19594
	obj : Object;					//+cnwml2 PAR19594
	isFailAutoPlan, isFailRequest : Boolean;
begin
	//alert := self.tblFailAutoPlan.getSelectedObject();
	alert := self.getAlert();	//10 Jan 2012	NDL	Par 28953
	if alert = null then
		return;
	endif;
	
	//MTN-35171 -- Code Refactoring Start
	isFailAutoPlan := self.fldFailAutoPlan.topSheet = self.shtFailAutoPlan; 
	isFailRequest := self.fldFailAutoPlan.topSheet = self.shtFailRequest; 
	
	if isFailAutoPlan then 
		oa := self.tblFailAutoPlan.getSelectedObjects();
	elseif isFailRequest  then	
		oa := self.tblFailRequest.getSelectedObjects();
	endif;
	foreach obj in oa do
		alert := obj.CM_SystemAlert;
		beginTransaction;
			alert.setReviewed(true);
		commitTransaction;
	endforeach;
	
	if isFailAutoPlan then
		self.tblFailAutoPlan.refresh();
	else
		self.tblFailRequest.refresh();
	endif;
	//MTN-35171 -- Code Refactoring End
epilog
	//+cnwml2 PAR19594 start
	if oa &lt;&gt; null then
		delete oa;
	endif;
	//+cnwml2 PAR19594 end
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveAlertRemarks" id="c6a367ab-161a-4dcb-8f0c-2310324c85aa">
        <source>doSaveAlertRemarks();
// 08 Dec 2008 CNWDW1
// Save Remarks for the FTP Alert
vars
	alert: CM_SystemAlert;
begin
	//alert := self.tblFailAutoPlan.getSelectedObject();
	alert := self.getAlert();	//10 Jan 2012	NDL	Par 28953
	if alert = null then
		return;
	endif;

	beginTransaction;
		alert.setRemarks(self.txtRemarks.text);
	commitTransaction;
	
	self.frmRemarks.visible := false;
	self.tblFailAutoPlan.enabled := true;
	self.tblFailRequest.enabled := true;	//11 Jan 2012	NDL	Par 28953
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveYALocations" id="c44da409-9cb8-4fa3-a4d8-287bd4d6b5f0">
        <updating/>
        <source>doSaveYALocations() updating;
// Save updated locations to Yard Allocation
vars
	ydc : YRD_ContainerDrawingController;
	blocks : ObjectArray;
	olf : YRD_ContainerOverDrawingFrame;
	ya: CM_YardAllocation;
	yaAgent: CM_YAAgent;
	allYABlocks : CM_YABlockArray;
	yas: CM_YardAllocationSet;
begin
	create blocks transient;
	create allYABlocks transient;
	ydc := self.myCurrentDrawingController;
	olf := ydc.getOverlayEditFrame;
	create yas transient;
	olf.getAllChangedYAs(yas);
	//ya := olf.getSelectedYA();
	self.tblYAM.clearAllSelected();
	
	foreach ya in yas do
		blocks.clear; 
		allYABlocks.clear;
		olf.getRectFrameBlocks(ya, blocks, allYABlocks, ydc);
		self.getNonVisibleBlocks(blocks, allYABlocks, ya);
		create yaAgent transient;
		if not yaAgent.updateYALocations(ya, blocks, allYABlocks) then
			app.showErrorWarningDialog("Yard Allocation", app.myPassport, ErrWarnMode_Update);
		endif;
	endforeach;

	self.frmYALocation.visible := false;
	self.btnViewYardAllEd.value := false;
	self.btnDeleteYA.enabled := true; //cnwrd1 par 19182 18.3.09
	self.doBtnEditYardAllocClick();

epilog
	if blocks &lt;&gt; null then
		blocks.purge;
	endif;	
	delete blocks;
	if allYABlocks &lt;&gt; null then
		allYABlocks.purge;
	endif;
	delete allYABlocks;
	delete yaAgent;
	delete yas;
end;</source>
    </JadeMethod>
