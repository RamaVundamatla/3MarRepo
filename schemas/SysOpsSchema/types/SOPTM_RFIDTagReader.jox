    <JadeMethod name="doSave" id="1d660cf6-1d10-4176-8b62-bf178d6a9ebb">
        <updating/>
        <source>doSave(): Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/

vars
	form 			: SOP_TableMaintForm;
	tbl				: CM_EntryTable;
	str				: String;
	isAvailable 	: Boolean;
	pxyTagReader 	: CM_RFIDTagReader;
	context			: Integer;
	gateLane		: CM_LaneController;
	type			: Integer;
begin

	form 	:= self.myForm;
	tbl 	:= form.tblInput1;
	
	if form.myProxyObject = null then
		if form.mode = form.Mode_Add then
			create form.myProxyObject as CM_RFIDTagReader transient;
		endif;
		
		if form.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	context := form.myAssistant.getSelectedContext (form.cmbReaderContext);

	if form.cmbGateLane.listObject.isKindOf(CM_LaneController) then
		gateLane 	:= form.cmbGateLane.listObject.CM_LaneController;
		
		str := tbl.getValueByName(ETRow_RfidReadAssign).String;
		
		if str = app.getErrorString (XLAT_RFID_Read) then
			type := CM_LaneDevice.Type_RFIDTagReaderRead;
		elseif str = app.getErrorString (XLAT_RFID_Assign) then
			type := CM_LaneDevice.Type_RFIDTagReaderAssign;
		endif;
	endif;

	pxyTagReader := form.myProxyObject.CM_RFIDTagReader;
	
	pxyTagReader.setProxy(tbl.getValueByName(ETRow_Code).String,
						tbl.getValueByName(ETRow_Description).String,
						tbl.getValueByName(ETRow_DeviceName).String,
						tbl.getValueByName(ETRow_IpAddressListener).String,
						tbl.getValueByName(ETRow_IPAddress).String,
						tbl.getValueByName(ETRow_PortNumber).Integer,
						context,
						type,
						gateLane,
						form.cmbMachine.listObject.CM_Machine,
						tbl.getValueByName(ETRow_WindowsMachineName).String);						
	
	if form.mode = form.Mode_Add then
		app.myTrxCA.trxCreateRFIDTagReader(pxyTagReader, form.myCurrentObject, form.myTerminal, app.myPassport);
	else
		app.myTrxUA.trxUpdateRFIDTagReader(pxyTagReader, form.myTerminal, app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK;
end;


</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
