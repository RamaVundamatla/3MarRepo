    <JadeMethod name="availableTransactions" id="150951c2-bfa2-4c13-8972-0498f804efda">
        <source>availableTransactions(_classColl: ClassColl input);
//
//11 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//
vars

begin
	_classColl.add(CM_Move);
	_classColl.add(CM_Edit);
end;
</source>
        <Parameter name="_classColl" type="ClassColl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="ebc2c4af-3de7-4496-b2b1-58b67cbc845c">
        <updating/>
        <source>create() updating;
//
//11 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//
vars

begin
	self.name := "Alabama Steel Upd Del";
	self.type := EDIFileTypeCams_AlabamalUpdDl;
end;
</source>
