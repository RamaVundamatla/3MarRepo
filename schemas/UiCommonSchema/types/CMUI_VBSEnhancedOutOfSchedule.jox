    <JadeMethod name="setMyReleaseRequest" id="31a55fc8-afd7-4870-bc9a-9229fc6ca6de">
        <updating/>
        <source>setMyReleaseRequest(_bulkRelease : CM_BulkRelease) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Mar 2025	navlc30	Initial creation
31 Mar 2025 navlc30 JIRA 34265 TPT | FR 33661.030 VBS - One Release Request and One VBS slot - Off Schedule

*/

vars

begin
	if _bulkRelease &lt;&gt; null then
		self.myReleaseRequest := _bulkRelease;
	endif;
epilog

end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
    </JadeMethod>
