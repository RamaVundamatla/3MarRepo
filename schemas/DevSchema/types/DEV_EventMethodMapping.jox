    <JadeMethod name="create" id="105fd28c-142c-4719-ba44-5a03f209099f">
        <updating/>
        <source>create(_name,
		_value : String;
		_class : DEV_Class) ::super(_name) updating;
/*

Purpose:			Constructor for DEV_EventMethodMapping class

Parameters:			_name:	The name of the event method mapping
					_value:	The value of the event method mapping
					_class:	The class object the event method mapping belongs to

Return Value:		

Date		Who		Reason
10 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	//Set Attributes
	self.name		:= _name;
	self.value		:= _value;
	
	//Set References
	self.myClass	:= _class;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_class" type="DEV_Class"/>
    </JadeMethod>
</Class>
