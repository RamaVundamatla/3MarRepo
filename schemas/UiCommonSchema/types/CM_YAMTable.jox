    <JadeMethod name="mouseDown" id="309c4ed7-c1c7-444d-848f-cfcf1f0911c0">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//27 August 2008	cnwdw1	
//
vars

begin
	self.dragMode := DragMode_None;
	self.enableEvent(CM_YAMTable::mouseMove.name, true);

	inheritMethod(table, button, shift, x, y);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="209fa829-8499-4cfe-a2ea-c3ff215169e4">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
//27 August 2008	cnwdw1	
//
vars
	sourceYABlock, targetYABlock: CM_YABlock;
begin
	if x &lt;= 0 or y &lt;= 0 or x &gt;= self.width -1 or y &gt;= self.height -1 or button &lt;&gt; Window.MouseButton_Left then
		self.dragMode := DragMode_None;
		return;
	endif;
	
	if self.isChildRow(table.row) then
		self.dragMode := DragMode_Drag;
		self.enableEvent(CM_YAMTable::dragOver.name, true);
		return;
	endif;
	self.dragMode := DragMode_None;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="e97154d9-641a-4ca4-b153-151d503e0742">
        <controlMethod name="CM_DataTable::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mouseUp(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//27 August 2008	cnwdw1	
//
vars

begin
	inheritMethod(table, button, shift, x, y);

	self.enableEvent(CM_YAMTable::mouseMove.name, false);
	self.enableEvent(CM_YAMTable::dragOver.name, false);
	self.dragMode := DragMode_None;
	
// cnwdad1 06/04/2009 - PAR #19399.
//	self.accessColumn(1).width := 20;
//	self.accessColumn(2).width := 254;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="openDeckingOptionsForm" id="c0df05ae-d213-4208-961f-818f6ef29f70">
        <source>openDeckingOptionsForm(_yaBlock: CM_YABlock);
//12 January 2009	cnwdw1	
//
vars
	theForm : CMUI_DeckingRulesForm;
	proxyYABlock: CM_YABlock;
begin
	if _yaBlock.myTerminalArea.isKindOf(CM_RoRoLaneArea) then
		theForm := app.loadForm(CMUI_DeckingRoRoRulesForm, CMUI_Assistant, false, false, false, self.getTerminal(), null).CMUI_DeckingRulesForm;
	else
		theForm := app.loadForm(CMUI_DeckingRulesForm, CMUI_Assistant, false, false, false, self.getTerminal(), null).CMUI_DeckingRulesForm;
	endif;	
	
	if theForm = null then
		return;
	endif;
	
	proxyYABlock := app.createUpdateProxy(_yaBlock).CM_YABlock;	

	theForm.onCreate(proxyYABlock.myDeckingOptions, _yaBlock, null);
	theForm.setParentForm(self.myForm.CM_BaseForm);
	theForm.showModal();

epilog
	delete proxyYABlock;
end;</source>
        <Parameter name="_yaBlock" type="CM_YABlock"/>
    </JadeMethod>
    <JadeMethod name="openLocationOptionsForm" id="c87e6cce-7d77-4362-94e8-c3b308b77cbf">
        <updating/>
        <source>openLocationOptionsForm(_yaBlock: CM_YABlock)updating;
//19 August 2008	cnwdw1	
//
vars
	theForm : CMUI_YALocationOptionsForm;
	column : Integer;
	invalidYaBlock : Boolean;
begin

	theForm := app.loadForm(CMUI_YALocationOptionsForm, CMUI_Assistant, false, false, false, self.getTerminal(), null).CMUI_YALocationOptionsForm;
	
	if theForm = null then
		return;
	endif;
	
	//15/03/2011 cnwdz2 27171
	on Exception do app.handleDeletedObject(exception, _yaBlock, invalidYaBlock);
		
	theForm.setYABlock(_yaBlock);
	theForm.setParentForm(self.myForm.CM_BaseForm);
	theForm.showModal();

	column := self.getColumnByRowName(ETRow_Stacking);
	if column &gt; 0 then																							// cnwjk3 PAR 22723	 11/03/2010
		self.accessCell(self.row, column).text := _yaBlock.getDisplayStringForAttribute(ETRow_Stacking, false);
		self.showDecking(_yaBlock, self.row);																	// cnwjk3 PAR 22723	 11/03/2010
	endif;

	//15/03/2011 cnwdz2 27171 start
	if invalidYaBlock then	
		app.msgBox(app.getErrorString(ERR_INVALID_YA), theForm.caption, MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only );
		theForm.unloadForm();		
	endif;
	//15/03/2011 cnwdz2 27171 end
end;</source>
        <Parameter name="_yaBlock" type="CM_YABlock"/>
    </JadeMethod>
    <JadeMethod name="openYAGroupMaintForm" id="e9977396-2d96-4a04-b2dc-4a04f51e8f15">
        <updating/>
        <source>openYAGroupMaintForm(_yaBlockGroup: CM_YABlockGroup) updating;
//22 January 2009	cnwdw1	
//
vars
	caption: String;
	oldGroupName, groupName: String;
	pxyYA: CM_YardAllocation;
	group, pxyGroup: CM_YABlockGroup;
	yaBlocks: CM_YABlockArray;
	criterias: CMIF_Array;

begin
	// PAR 19177
	if self.getSelectedObjectsYA() = null then
		return;
	endif;
	if _yaBlockGroup &lt;&gt; null then
		// Modify group
		// PAR 19249
		//caption := "Edit Group";
		caption := app.getErrorString(YAM_Msg_EditGroup);
		pxyYA := app.createUpdateProxy(_yaBlockGroup.myYardAllocationIn).CM_YardAllocation;
		oldGroupName :=  _yaBlockGroup.description;
	else
		// New Group
		// PAR 19249
		//caption := "New Group";
		caption := app.getErrorString(YAM_Msg_NewGroup);
		pxyYA := app.createUpdateProxy(self.getSelectedObjectsYA()).CM_YardAllocation;
	endif;
	while true do
		// PAR 19249
		//groupName := self.cnEcGetUserInput(caption, "Enter the name of the Group:", oldGroupName);
		groupName := self.cnEcGetUserInput(caption, app.getErrorString(YAM_Msg_EnterNameGroup), oldGroupName);
		if groupName &lt;&gt; null and groupName &lt;&gt; oldGroupName then
			if _yaBlockGroup &lt;&gt; null then
				// Modify group name
				foreach pxyGroup in pxyYA.allYABlockGroupsIn do
					if pxyGroup.description = _yaBlockGroup.description then
						break;
					endif;
				endforeach;
				if pxyGroup = null then
					return;
				endif;
				pxyGroup.setDescription(groupName);
				group := pxyGroup.pxyGetRealObject();
				app.myTrxUA.trxUpdateYABlockGroup(pxyGroup, group, app.myPassport);
			else
				// New Group
				create pxyGroup transient;  
				create yaBlocks transient;
				pxyGroup.setProxy(groupName, yaBlocks, yaBlocks);
				pxyYA.allYABlockGroupsIn.add(pxyGroup);
				pxyYA.allYABlockGroupsOut.add(pxyGroup);
				create criterias transient;
				app.myTrxUA.trxUpdateYardAllocation(pxyYA, criterias, app.myPassport);
			endif;
			if not app.myPassport.trxCompletedOK then
				// PAR 19249
				//app.showErrorWarningDialog('Group', app.myPassport, ErrWarnMode_Update);
				app.showErrorWarningDialog(app.getErrorString(YAM_Msg_Group), app.myPassport, ErrWarnMode_Update);
			else
				break;
			endif;
		else
			break;
		endif;
	endwhile;
epilog
	app.mousePointer := Idle;
	delete pxyYA;
	delete yaBlocks;
	delete criterias;
end;</source>
        <Parameter name="_yaBlockGroup" type="CM_YABlockGroup"/>
    </JadeMethod>
    <JadeMethod name="openYAMaintForm" id="2fd22e8e-04b1-4f05-a4c0-417c7db3093b">
        <source>openYAMaintForm(_yas: ObjectArray; _trackedItem: CM_TrackedItem; _sheetIndex : Integer) : CM_YardAllocation;
//19 August 2008	cnwdw1	
//
vars
	assistant: CMUI_Assistant;
begin
	create assistant transient;
	assistant.myTerminal := self.getTerminal();
	return assistant.showYAMaintForm(_yas, _trackedItem, self.myForm.CM_BaseForm, null, _sheetIndex);
epilog
	delete assistant;
end;</source>
        <Parameter name="_yas" type="ObjectArray"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_sheetIndex" type="Integer"/>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="recalcYATotals" id="4786c485-e6a3-40c8-973c-96d8bd264955">
        <updating/>
        <source>recalcYATotals(_ya: CM_YardAllocation;_yaRow : Integer) updating;
/*

Purpose:			Recalculate the totals in the table for the passed in YA

Parameters:			Allocation to be recalculated

Return Value:		None


Date		Who		Reason
21 Aug 2008	cnwdw1	
28 Jun 2010	cnwkpd1	PAR #24605 - Improve performance by replacing asIntegerJMT and asStringJMT 
					with straight JADE primitive casting.  This is OK, because the values are all Integers
					with no separators.
09 Nov 2010 cnwer1 - PAR 26189 added the passed in yaRow so we don't always have to iterate through the table to find the row
*/

vars
	yaRow, yaBlockGroupRow, row: Integer;
	column: Integer;
	resultString : String;
	additionOperand1,
	additionOperand2,
	additionResult    :Integer;
	entRow : EntTableRow;
	blockGroupRow,clearOldTotals: Boolean;
begin
	clearOldTotals:=false;
	if _yaRow &lt;&gt; null then
		yaRow:=_yaRow;
	else
		//if we do not have the row passed it is because this is a update from a not
		// find the row in the table and make sure we clear the old totals;
		self.findObjectInRowReversed(_ya, yaRow);
		clearOldTotals:=true;
	endif;

	if yaRow &gt; 0 then
		foreach row in yaRow  to self.rows do :mainLoop // where self.isChildRow(row)
			
			if self.accessRow(row).itemObject.isKindOf(CM_YardAllocation) and 
				  self.accessRow(row).itemObject &lt;&gt; _ya then
				break;
			endif;
						
			blockGroupRow:=self.isBlockGroupRow(row);	
			//07/12/2009 cnwdz2 par21859
			column:=0;
			
			foreach entRow in self.allTblDataEntRows do 
				column:=column + 1;
				
				if entRow.name = ETRow_HideShow or
						entRow.name = ETRow_Code or
						entRow.name =  ETRow_PriorityValue or
						entRow.name =  ETRow_Stacking or
						self.isGenFilterableYAMcolumn( entRow.name ) or	//04 Jan 2012	NDL	Par 28889
						entRow.name =  ETRow_DeckingSequence then
						continue;
				endif;
				if row = yaRow then
					//self.setCellText(row, column, null);
					if clearOldTotals then
						self.setCellText(row, column, null);	//05 Nov 2013	NDL	Par 31801 - moved down.
						continue;
					else
						continue mainLoop;
					endif;
				endif;
				
				if blockGroupRow then
					//self.setCellText(row, column, null);
					yaBlockGroupRow := row;
					if clearOldTotals then
						self.setCellText(row, column, null);	//05 Nov 2013	NDL	Par 31801 - moved down.
						continue;
					else
						continue mainLoop;
					endif;
				endif;
				
				
				additionOperand1 := self.getCellText(yaRow, column).Integer;
				additionOperand2 := self.getCellText(row, column).Integer;
				additionResult := additionOperand1 + additionOperand2;
				if additionResult = 0 then
					resultString:=null;
				else
					resultString:=additionResult.String;
				endif;
			
				self.setCellText(yaRow, column, resultString);
			
				
				if yaBlockGroupRow &gt; 0 then
					//07/12/2009 cnwdz2 par21859
					additionOperand1 := self.getCellText(yaBlockGroupRow, column).Integer;
					additionOperand2 := self.getCellText(row, column).Integer;
					additionResult := additionOperand1 + additionOperand2;
				
					if additionResult = 0 then
						resultString:=null;
					else
						resultString:=additionResult.String;
					endif;
					
					self.setCellText(yaBlockGroupRow, column, resultString);
					
				endif;
			endforeach;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <Parameter name="_yaRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="refreshMe" id="545c3f0e-4514-44b8-a216-6557f2bf54b0">
        <updating/>
        <source>refreshMe() updating;
//18 February 2009	cnwdw1	
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	loadState	: Boolean;
	allocationObj: CM_YardAllocation;
	
begin
	self.clear();
	self.gridLines := false;
	self.fixedRows := 1;
	self.rows					:=	self.fixedRows;
	self.partialTextIndication	:=	true;
	self.wordWrap 				:=	true;
	self.selectionType := CM_BaseTable.SelectionType_Row;
	self.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.disallowColumnSorter := false;
	self.maxSortColumns:=1;
	//self.disallowColumnSorter  :=true;
	self.backColor := self.myForm.CM_BaseForm.colorControlBack;
	self.allowResize := Table.AllowResize_Column;
	
	// Do the Column Headings
	if self.myEntTableDef = null then
		self.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_YAMDataTbl));
	else
		self.setColumns(true);
	endif;
	
	self.addHeading();
	self.clearSort();
	self.alignment	:=	Table.Alignment_Left_Middle;
	self.fixedRows := 2;
	self.fixedColumns := 2;

	// par 26721 Jan 2011 beginLoad exception
	app.cmsBeginLoad(loadState);
	if self.isManuallyMaintained then
		// PAR #19322 - When refreshing, say from Column Organiser, do so from previously loaded collection.
		foreach allocationObj in self.allYardAllocationsByPriority where not allocationObj.isDisabled do
			// TFS 1775 Apr 2016 cnwjre1 stop invoice allocations as showing as yard allocations
			if allocationObj.isInvoiceAllocation then
				continue;
			endif;
			self.addItemYAAt(allocationObj, 0);
		endforeach;
	else
		foreach allocationObj in self.getTerminal.allYardAllocations where not allocationObj.isDisabled do
			// TFS 1775 Apr 2016 cnwjre1 stop invoice allocations as showing as yard allocations
			if allocationObj.isInvoiceAllocation then
				continue;
			endif;
			self.addItemYAAt(allocationObj, 0);
		endforeach;
	endif;
	app.cmsEndLoad(loadState);
	
	self.setSelectAll();
	self.drawTableGrid();
	self.expandAllYALocations(false);
	self.column := 2; //so it wont expand column 1 when resize other columns
	
	//self.setSortColumnsForMaxNumCols();
epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
end;</source>
    </JadeMethod>
    <JadeMethod name="refreshPriorities" id="adac25ef-9db0-4a6d-9242-3e5c22084ad3">
        <updating/>
        <source>refreshPriorities() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2017	jlgns1	Initial creation TFS 4566:CPL - Users encountered 1309 error at same time in Master Terminal

*/

vars

begin
	
	self.allYardAllocationsByPriority.rebuild();
	self.refreshMe();
	
epilog

