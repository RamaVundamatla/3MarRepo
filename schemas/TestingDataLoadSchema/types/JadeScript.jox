    <JadeMethod name="testLoadTesting2" id="ef4d4630-c73f-4069-bf0f-90e3fbb9b559">
        <source>testLoadTesting2();

/*

Purpose:	Load those values which are specific to the system we are in
			Things like:
				Colour
				Web Config


Date		Who		Reason
02/02/2018	jlgmh5	Initial	 

*/

vars
	
	webSiteConfig				: CM_WebSiteConfig;
	user						: CM_User;
	printer						: CM_PrinterDef;
	form						: HiddenDataLoadForm;

	systemName					: String;
	pos							: Integer;

begin

	app.initialize();
	
	create form transient;

	// get the sytsem that we are running in
	systemName := app.cnGetServerMiscPath()[4:end];
	pos := 1;
	systemName := systemName[1:end].scanUntil("\", pos);
	
	// get the web user
	user := app.myRoot.allUsers["WEB"];
	if user = null then
		app.msgBox("Unable to find Web user (WEB).   Please create this user and rerun this application.", 
			"Unable to find Web User", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;	
	
	// get the PDF Printer
	printer := app.myRoot.allPrinterDefsByLogicalName["PDF"];
	if printer = null then
		app.msgBox("Unable to find PDF Printer (PDF).   Please create this printer and rerun this application.", 
			"Unable to find PDF Printer", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	beginTransaction;
	if systemName.toUpper() = "JLGOJMT" then
		// set the system colour
		app.myRoot.setConfig(AppBackgroundColor, 5280398, true);
		app.myRoot.setConfig(SystemBackgroundPic, form.picManila.picture, true);
		app.myRoot.setConfig(SystemTitle, "8.5.1 Regression Testing - Manila", true);
		
		// update the webstie config stuff
		webSiteConfig := app.myRoot.allWebSiteConfigs["WebServiceDefault"];
		if webSiteConfig &lt;&gt; null then
			webSiteConfig.setPropertyValue("sessionTimeoutMinutes", 30);
			webSiteConfig.setPropertyValue("downloadFileRemoteCopy", true);
			webSiteConfig.setPropertyValue("publicUser", user.code);
			webSiteConfig.setPropertyValue("myPDFPrinter", printer);
			webSiteConfig.setPropertyValue("downloadFileDirectoryPath" ,"D:\jlgOjmt\server\c_misc\report_extract_temp");
			webSiteConfig.setPropertyValue("downloadFileDirectoryURL", "https://jlgojmt.jadelogistics.com/downloads");
			webSiteConfig.setPropertyValue("downloadFileTimeout", 5);
			webSiteConfig.setPropertyValue("helpFileURL", "https://jlgojmt.jadelogistics.com/HTML5");
		endif;
		
		webSiteConfig := app.myRoot.allWebSiteConfigs["WebService_JLGOJMT"];
		if webSiteConfig &lt;&gt; null then
			webSiteConfig.setPropertyValue("sessionTimeoutMinutes", 30);
			webSiteConfig.setPropertyValue("downloadFileRemoteCopy", true);
			webSiteConfig.setPropertyValue("publicUser", user.code);
			webSiteConfig.setPropertyValue("myPDFPrinter", printer);
			webSiteConfig.setPropertyValue("downloadFileDirectoryPath" ,"D:\jlgOjmt\server\c_misc\report_extract_temp");
			webSiteConfig.setPropertyValue("downloadFileDirectoryURL", "https://jlgojmt.jadelogistics.com/downloads");
			webSiteConfig.setPropertyValue("downloadFileTimeout", 5);
			webSiteConfig.setPropertyValue("helpFileURL", "https://jlgojmt.jadelogistics.com/HTML5");
		endif;
	
	elseif systemName.toUpper() = "CNWHMAST" then
		// set the system colour
		app.myRoot.setConfig(AppBackgroundColor, 12615808, true);
		app.myRoot.setConfig(SystemBackgroundPic, form.picCreate.picture, true);
		app.myRoot.setConfig(SystemTitle, "8.5.1 Regression Testing - Create / Design", true);
		
		// update the webstie config stuff
		webSiteConfig := app.myRoot.allWebSiteConfigs["WebServiceDefault"];
		if webSiteConfig &lt;&gt; null then
			webSiteConfig.setPropertyValue("sessionTimeoutMinutes", 30);
			webSiteConfig.setPropertyValue("downloadFileRemoteCopy", true);
			webSiteConfig.setPropertyValue("publicUser", user.code);
			webSiteConfig.setPropertyValue("myPDFPrinter", printer);
			webSiteConfig.setPropertyValue("downloadFileDirectoryPath" ,"D:/cnwhmast/server/c_misc/report_extract_temp");
			webSiteConfig.setPropertyValue("downloadFileDirectoryURL", "https://web1.cnwhmast.cnw.co.nz/downloads");
			webSiteConfig.setPropertyValue("downloadFileTimeout", 5);
			webSiteConfig.setPropertyValue("helpFileURL", "");
		endif;
	
	elseif systemName.toUpper() = "CNWTMAST" then
		// set the system colour
		app.myRoot.setConfig(AppBackgroundColor, 12687648, true);
		app.myRoot.setConfig(SystemBackgroundPic, form.picReview.picture, true);
		app.myRoot.setConfig(SystemTitle, "8.5.1 Regression Testing - Review", true);
		
		// update the webstie config stuff
		webSiteConfig := app.myRoot.allWebSiteConfigs["WebServiceDefault"];
		if webSiteConfig &lt;&gt; null then
			webSiteConfig.setPropertyValue("sessionTimeoutMinutes", 30);
			webSiteConfig.setPropertyValue("downloadFileRemoteCopy", true);
			webSiteConfig.setPropertyValue("publicUser", user.code);
			webSiteConfig.setPropertyValue("myPDFPrinter", printer);
			webSiteConfig.setPropertyValue("downloadFileDirectoryPath" ,"D:/cnwtmast/server/c_misc/report_extract_temp");
			webSiteConfig.setPropertyValue("downloadFileDirectoryURL", "https://web1.cnwtmast.cnw.co.nz/downloads");
			webSiteConfig.setPropertyValue("downloadFileTimeout", 5);
			webSiteConfig.setPropertyValue("helpFileURL", "");
		endif;
		
	elseif systemName.toUpper() = "CNWXMAST" then
		// set the system colour
		app.myRoot.setConfig(AppBackgroundColor, 16776960, true);
		app.myRoot.setConfig(SystemBackgroundPic, form.picMaster.picture, true);
		app.myRoot.setConfig(SystemTitle, "8.5.1 Regression Testing - Master", true);
		
		// update the webstie config stuff
		webSiteConfig := app.myRoot.allWebSiteConfigs["WebServiceDefault"];
		if webSiteConfig &lt;&gt; null then
			webSiteConfig.setPropertyValue("sessionTimeoutMinutes", 30);
			webSiteConfig.setPropertyValue("downloadFileRemoteCopy", true);
			webSiteConfig.setPropertyValue("publicUser", user.code);
			webSiteConfig.setPropertyValue("myPDFPrinter", printer);
			webSiteConfig.setPropertyValue("downloadFileDirectoryPath" ,"D:/cnwxmast/server/c_misc/report_extract_temp");
			webSiteConfig.setPropertyValue("downloadFileDirectoryURL", "https://web1.cnwxmast.cnw.co.nz/downloads");
			webSiteConfig.setPropertyValue("downloadFileTimeout", 5);
			webSiteConfig.setPropertyValue("helpFileURL", "");
		endif;
		
	elseif systemName.toUpper().cnContains("DataBaseTestLoad".toUpper()) then
		// set the system colour
		app.myRoot.setConfig(AppBackgroundColor, 11037868, true);
		app.myRoot.setConfig(SystemBackgroundPic, form.picDevelopment.picture, true);
		app.myRoot.setConfig(SystemTitle, "8.5.1 Regression Testing - Development", true);
		
		// update the webstie config stuff
		webSiteConfig := app.myRoot.allWebSiteConfigs["WebServiceDefault"];
		if webSiteConfig &lt;&gt; null then
			webSiteConfig.setPropertyValue("sessionTimeoutMinutes", 30);
			webSiteConfig.setPropertyValue("downloadFileRemoteCopy", true);
			webSiteConfig.setPropertyValue("publicUser", user.code);
			webSiteConfig.setPropertyValue("myPDFPrinter", printer);
			webSiteConfig.setPropertyValue("downloadFileDirectoryPath" ,"D:/cnwxmast/server/c_misc/report_extract_temp");
			webSiteConfig.setPropertyValue("downloadFileDirectoryURL", "https://web1.cnwxmast.cnw.co.nz/downloads");
			webSiteConfig.setPropertyValue("downloadFileTimeout", 5);
			webSiteConfig.setPropertyValue("helpFileURL", "");
		endif;
		
	else
		
		app.msgBox("Trying to update a system other than CNWXMAST; CNWHMAST; CNWTMAST; or JLGOJMT." &amp; CrLf &amp;
			"Please run in one of these systems or change the code to include this system.", 
			"Unable to Update", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	
	endif;
	commitTransaction;
	
epilog

	delete form;

end;
</source>
    </JadeMethod>
