    <JadeMethod name="clearInvalidReferences" id="d18d4193-96e9-46dd-a16e-837416c22f02">
        <source>clearInvalidReferences();

vars
	js:JadeScript;
	action : Boolean;
	userExitCode: Integer;
	file : File; //add application file for Jari
	fileMessage : String;
begin
	userExitCode := 63;
	app.initialize();
	create file transient;
	file.mode := File.Mode_IO;
	file.fileName := app.myCnCntrl.logPath&amp;"\app_upgrade.log";
	if file.isAvailable then
		file.purge;
	endif;
	fileMessage := "UpgradeError";
	app.isConverting := true;
	action := true;
	create js transient;
//	cnwjr2  -  commented out next line as it called a JadeScript method - these methods were deleted 12/12/2011 - temporarily in DummySchema
	js.checkInvalidReferences(action);
	js.checkInvalidCollections(action);
	userExitCode := 0;
	fileMessage := "completedOK";
	file.writeLine(fileMessage);
epilog
	file.close;
	delete file;
	app.writeStatement( "completed");
	delete js;
	beginTransaction;
	node.userExitCode := userExitCode;
	commitTransaction; 
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="doInitializeAppBatch" id="8cc90acb-67d9-42a6-876c-6778c7d3d68a">
        <updating/>
        <source>doInitializeAppBatch() updating;
//
//05 Nov 2012	cnwrs1	allow the default initailize to run from JAPInstaller
//28 Jul 2020	jlgmd1		StarterDB - Prevent dialogs while the batch init app is (re)initialising the system
vars
	initForm : DEV_InitiateForm;
	userExitCode : Integer;
	file : File;
	fileMessage : String;
begin
	self.initializeInitiateApp;
	self.setIsBackGroundApp(true);
	
	userExitCode := 63;
	fileMessage := "UpgradeError";
	
	create file transient;
	file.mode := File.Mode_IO;
	file.fileName := app.myCnCntrl.logPath&amp;"\app_InitializeBatch.log";
	if file.isAvailable then
		file.purge;
	endif;
	
	create initForm transient;
	initForm.intialTestSettings;
	initForm.doInitializeSystem;
	
	if app.myPassport.trxCompletedOK then	
		app.writeStatement("End Initialize App in Batch mode");	
		userExitCode := 0;	
		fileMessage := "completedOK";
	endif;
	
	file.writeLine(fileMessage);
epilog
	file.close;
	delete file;
	delete initForm;
	beginTransaction;
	node.userExitCode := userExitCode;
	commitTransaction;
	terminate;
end;
</source>
    </JadeMethod>
    <JadeMethod name="extractNewXLATFormConstViaUT" id="7455d3b0-8d32-4064-97d7-eb2011c60cb0">
        <source>extractNewXLATFormConstViaUT(_errorArray  : StringArray512 io; _userSummaryDict : CM_AssociationDict io);

/*

Purpose:		

Date			Who		Reason
04/11/2015		cnwmh5	Initial creation
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	formCaptionsTfr						: FormCaptionsAgentXLATGenerate;
	folderServer						: FileFolder;
	folderNonServer						: FileFolder;
	
	args								: StringArray;
	
	iter								: Iterator;
	
	result								: Integer;
	tempStr								: String;
	today								: TimeStamp;
	dontContinue						: Boolean;


begin

	app.initialize();
	
	create formCaptionsTfr transient;
	formCaptionsTfr.initAllForms();
	formCaptionsTfr.populatelSchemasClassesConsts();
	
	// Create the folder (NON Server) for the constants to retrieve
	today := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	create folderNonServer transient;
	folderNonServer.fileName := "c:\temp\translationsRun\" &amp; app.computerName &amp; "\Transfer" &amp;
		today.date.year.String &amp; today.date.month.padLeadingWith("0", 2) &amp; today.date.day.padLeadingWith("0", 2);
	folderNonServer.usePresentationFileSystem := true;
	if not folderNonServer.isAvailable then
		folderNonServer.make();
	endif;
	
		
	///*
	formCaptionsTfr.outputFileConstantsToGet(folderNonServer);
		
	///*
	// Go off and get the global constant details from DMAST
	app.writeLog("Opening development envirnoment (dmast)...", LogINFO);
	create args transient;
	args.add('appServer=jade1.navdmast.nav.cnw.co.nz');
	args.add('appServerPort=50667');
	args.add('app=JMTExtractXLATFormConstants');
	args.add('schema=DevSchema');
	args.add('ini="C:\DevelopmentEnvs\navdmast\navdmast.ini"');
	args.add('endJade');
	
	node.createExternalProcess("C:\DevelopmentEnvs\navdmast\c_bin", '"C:\DevelopmentEnvs\navdmast\c_bin\jade.exe"', args, null, true, true, result);
	//*/
	
	// Create the folder (Server)
	create folderServer transient;
	folderServer.fileName := app.cnGetServerMiscPath() &amp; "\translationsRun\" &amp; app.computerName &amp; "\Transfer" &amp;
		today.date.year.String &amp; today.date.month.padLeadingWith("0", 2) &amp; today.date.day.padLeadingWith("0", 2);
	folderServer.usePresentationFileSystem := false;
	if not folderServer.isAvailable then
		folderServer.make();
	endif;
	
	// reload the schema and jadescript files
	app.writeLog("Portschema loading...", LogINFO);
	dontContinue := formCaptionsTfr.loadSchemaFile(folderServer, folderNonServer, "PortSchema-FormCaptions-*.scm", true);
	// no files so nothing to do
//	if folderNonServer.files.size = 0 then
//		return;
//	endif;
//	if dontContinue then
//		app.writeLog("Error loading Constants schema file.  Exiting...", LogAlways);
//		return;
//	endif;
	// create the constant objects for the newly loaded constants
	app.writeLog("createObjsForNewConstants...", LogINFO);
	dontContinue := formCaptionsTfr.createObjsForNewConstants(folderServer);
	///if dontContinue then
	///	app.writeLog("Error schema file not found.  Exiting...", LogAlways);
	///	return;
	///endif;
	// generate new translateForm method
	dontContinue := formCaptionsTfr.generateNewTranslateFormMethod(folderServer);
	//if dontContinue then
	///	app.writeLog("Error loading schema file.  Exiting...", LogAlways);
	///	return;
	///endif;
	// now check to see if there are any errors
	formCaptionsTfr.generateErrorDetails();
	//formCaptionsTfr.errorDetailsDict.copy(_errorArray);
	formCaptionsTfr.returnErrorDetails(_userSummaryDict);
	//*/
epilog

	delete args;
	delete iter;
	delete folderNonServer;
	delete folderServer;

end;</source>
        <Parameter name="_errorArray" type="StringArray512" usage="io"/>
        <Parameter name="_userSummaryDict" type="CM_AssociationDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="extractNewXLATFormConstants" id="94e36eb8-f8e3-449c-8485-9a95aa5e75e5">
        <source>extractNewXLATFormConstants();

/*

Purpose:		Extract available new xlat form constants

Date			Who		Reason
04/11/2015		cnwmh5	Initial creation

*/

vars

	formCaptionsTfr					: FormCaptionsAgentXLATGenerate;
	file							: File;
	lsSchema						: LSschema;
	lsClass							: LSclass;
	formCaption						: XLAT_FormCaption;
	
	tokens							: HugeStringArray;
	
	xlatDict						: DynaDictionary;
	
	line							: String;
	constantName					: String;

begin

	app.initialize();
		
	create formCaptionsTfr transient;
	formCaptionsTfr.createFileFolder("Transfer");
	
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	file.fileName := formCaptionsTfr.fileFolder.fileName &amp; "\ConstantsToGet.csv";
	
	if not file.tryOpen then
		return;
	endif;
		
		
	create xlatDict transient;
	xlatDict.setMembership(XLAT_FormCaption);
	xlatDict.addMemberKey("vSchemaName", true, false);
	xlatDict.addMemberKey("vFormClass", true, false);
	xlatDict.addMemberKey("vControlName", true, false);
	xlatDict.addMemberKey("vControlProperty", true, false);
	xlatDict.endKeys(true);
	XLAT_FormCaption.instances.copy(xlatDict);	
	

	
	// create portschema 
	lsSchema := formCaptionsTfr.getLSschema("PortSchema");
	lsSchema.mySchema := rootSchema.getSchema("PortSchema");	
	
	
	
	create tokens transient;
	
	while not file.endOfFile do
	
		line := file.readLine();
		
		if line = null then
			break;
		endif;
		
		// read the line into an array
		tokens.clear();
		line.getTokensForDelimiterHuge(",", tokens);
		
		// If you really need this, please wrap it in a process.isX call
		//write method.qualifiedName() &amp; Tab &amp; line;
		
		formCaption := xlatDict.getAtKey(tokens[2], tokens[3], tokens[4], tokens[5]).XLAT_FormCaption;
		if formCaption = null then
			continue;
		endif;
		
		// If you really need this, please wrap it in a process.isX call
		//write Tab &amp; method.qualifiedName() &amp; Tab &amp; tokens[2] &amp; Tab &amp; tokens[3] &amp; Tab &amp; tokens[4] &amp; Tab &amp; tokens[5] &amp; Tab &amp; Tab &amp; formCaption.String;
		app.writeLog(method.qualifiedName() &amp; Tab &amp; tokens[2] &amp; Tab &amp; tokens[3] &amp; Tab &amp; tokens[4] &amp; Tab &amp; tokens[5] &amp; Tab &amp; Tab &amp; formCaption.String, LogINFO);
		
		// create the schmea, class and constant
		lsSchema := formCaptionsTfr.getLSschema(tokens[2]);
		lsClass := lsSchema.getLSclass(tokens[3]);
		formCaptionsTfr.handleFormTranslationTransfer(lsClass, formCaption.vConstantName, tokens[4], tokens[5], null, null, null, false, false, true);		
	
	endwhile;
	
	// extract out the global constants
	foreach lsSchema in formCaptionsTfr.allSchemas do
		if lsSchema.name = PortSchemaName then
			lsSchema.produceScmFile_FormXLATGlbTfr(formCaptionsTfr.fileFolder, formCaptionsTfr.allSchemas);
		endif;
	endforeach;
	
epilog

	delete file;
	delete tokens;
	
	delete xlatDict;
	delete formCaptionsTfr;
	
	terminate;

end;</source>
    </JadeMethod>
    <JadeMethod name="finalizeGenXlatSchemas" id="b4bded9e-eff9-41b9-b30e-09e9131d961c">
        <updating/>
        <source>finalizeGenXlatSchemas() updating;
// --------------------------------------------------------------------------------
// Created:		18 March 2009 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.finalize();
end;</source>
    </JadeMethod>
    <JadeMethod name="getClientLicenseKeys" id="75d278b6-a0b7-4aba-8925-b95cb50fdb3d">
        <source>getClientLicenseKeys();

/*

Purpose:		Generate and update a systems license
				Going to use the form to get the key details and then
				pass them back via a file

Date			Who		Reason
29/06/2015		cnwmh5	Initial creation

*/
constants

	LicenseName						: String = "License Name : ";
	LicenseKey						: String = "License Key  : ";
	ClientName						: String = "clientName=";

vars

	licForm							: DEV_LicenseForm;
	outputFile						: File;
	
	detailsArray					: HugeStringArray;
	
	index							: Integer;
	keyStrs							: String;
	outputLine						: String;
	line							: String;
	clientName						: String;
	commandFlag						: String;
	
begin

	app.initialize();

	clientName := process.getCommandLine();
	clientName := clientName[clientName.pos(ClientName, 1) + ClientName.length : end];

	if clientName = null then
		return;
	endif;

	create licForm transient;
	licForm.sendMsg("init");
	index := licForm.cmbClient.findStringExact(1, clientName);
	if index = -1 then
		return;
	endif;
	
	licForm.cmbClient.listIndex := index;
	licForm.cmbClient_click(licForm.cmbClient);
	licForm.btnGenerate_click(licForm.btnGenerate);
	
	create outputFile transient;
	outputFile.usePresentationFileSystem := true;
	outputFile.fileName := app.getTempDir() &amp; method.name &amp; ".txt";
	//outputFile.kind := File.Kind_ANSI;
	outputFile.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	if outputFile.isAvailable() then
		outputFile.purge();
	endif;
	
	line := licForm.txtLicense.text;
	
	create detailsArray transient;
	line.getHugeTokensForDelimiter(Lf, detailsArray);
	
	foreach index in 1 to detailsArray.size do
		if detailsArray[index].cnContains(LicenseName) then
			outputLine := detailsArray[index][LicenseName.length+1:end] &amp; ":";
		elseif detailsArray[index].cnContains(LicenseKey) then
			outputLine := outputLine &amp; detailsArray[index][LicenseKey.length+1:end];
			outputLine := outputLine.replaceString(Cr, "");
			outputFile.writeLine(outputLine);
			outputLine := null;
		endif;	
	endforeach;
	
	outputFile.close();
	
epilog

	delete licForm;
	delete outputFile;
	
	terminate;

end;
</source>
    </JadeMethod>
    <JadeMethod name="getTestLinkRunDetails" id="5efdf103-546a-47af-b6ff-ebdf533ed454">
        <source>getTestLinkRunDetails();

/*

Purpose:		From the CSV dump from TestLink check to see what version the test was last run in

Date			Who		Reason
23/09/2013		cnwmh5	Initial creation
20/09/2016		cnwmh5	Rewrite

*/

vars

	file						: File;
	fileFolder					: FileFolder;
	fileNode					: FileNode;
	
	xmlDoc						: JadeXMLDocument;
	elementTestCase				: JadeXMLElement;
	xmlAttribute				: JadeXMLAttribute;
	xmlElement					: JadeXMLElement;
	xmlCDATA					: JadeXMLCDATA;
	
	testCaseXMLArray			: JadeXMLElementArray;
	
	testCaseDict				: DynaDictionary;
	
	tokens						: HugeStringArray;
	inactiveIds					: StringArray;
	releaseIdArray				: RealArray;
	resultArray					: HugeStringArray;
	resultArray2				: HugeStringArray;
	priorityArray				: StringArray;
	testCaseNameArray			: HugeStringArray;
	dummyArray					: StringArray;
	
	allFiles					: FileNodeArray;
	
	iter						: Iterator;

	directoryName				: String;
	line						: String;
	lastId						: String;
	activeFlag					: Integer;
	releaseIdStr				: String;
	posUnderscore				: Integer;
	posComma					: Integer;
	testCaseName				: String;
	externalId					: String;
	testSuite					: String;
	index						: Integer;
	indexOf						: Integer;
	priority					: String;
	lastExecution				: String;
	testCaseName2				: String;
	releaseIdHdrStr				: String;
	results						: String;
	notLessThanThisIndex		: Integer;
	lastRun						: String;
	lastRunIndex				: Integer;
	lastRunResult				: String;
	suiteName					: String;
	suiteName2					: String;
	needsAttention				: String;
	includeThisRun				: String;
	indexOf2					: Integer;
	tempStr						: String;
	tempStr2					: String;
	posFirstDblQuote			: Integer;
	posNextDblQuote				: Integer;
	posColon					: Integer;

begin

	// initialisations
	delete testCaseDict;
	create testCaseDict transient;
	testCaseDict.setMembership(HugeStringArray);
	testCaseDict.addExternalKey(String, 150, false, false);			// suite  name
	testCaseDict.addExternalKey(String, 150, false, false);			// test name
	testCaseDict.endKeys(false);
	
	directoryName := "C:\TestLink_Additional\results";
	
	/*******************************************************************
	* get the inactive tests
	*******************************************************************/
	write 'Getting inactive test details.  Please wait...';
	create tokens transient;
	create inactiveIds transient;
	create priorityArray transient;
	create testCaseNameArray transient;
	create dummyArray transient;
	
	delete file;
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := directoryName &amp; "\inactiveTests.csv";
	
	while not file.endOfFile do
		line := file.readLine();
		
		if line.trimBlanks().length() = 0 then
			continue;
		endif;
		
		tokens.clear();
		line.getHugeTokensForDelimiter(",", tokens);
		
		if lastId = null then
			lastId := tokens[1];
			activeFlag := tokens[tokens.size].Integer;
		endif;
		
		if lastId &lt;&gt; tokens[1] then
			if not inactiveIds.includes("01-" &amp; lastId) and activeFlag = 0 then
				inactiveIds.add("01-" &amp; lastId);
			endif;
			lastId := tokens[1];
		endif;
		
		activeFlag := tokens[tokens.size].Integer;
		
	endwhile;
	file.close();
	
	// get the files we are going to get details for
	// read through the csv files
	write 'Getting release id(s) from available files.  Please wait...';
	create fileFolder transient;
	fileFolder.fileName := directoryName;
	fileFolder.mask := "resultsTC_*.csv";
	if not fileFolder.isValidPathName(fileFolder.fileName) or not fileFolder.isAvailable() then
		write "Unable to find directory (" &amp; fileFolder.fileName &amp; ")";
		return;
	endif;

	// get the files in the directory
	allFiles := fileFolder.files();
	
	// get the release ids
	releaseIdHdrStr := null;
	create releaseIdArray transient;
	foreach fileNode in allFiles do
	
		// don't care about directory's
		if not fileNode.isKindOf(File) then
			continue;
		endif;
	
		posUnderscore := fileNode.fileName.reversePos("_");
		posComma := fileNode.fileName.reversePos(".");
		releaseIdStr := fileNode.fileName[posUnderscore+1:posComma-posUnderscore-1];
		releaseIdStr := releaseIdStr.replaceString(".", "");
		releaseIdArray.add(releaseIdStr.Real);
	
	endforeach;
	releaseIdArray.cnEcSort(true);
	notLessThanThisIndex := 8;
	foreach index in 1 to releaseIdArray.size do
		if releaseIdHdrStr &lt;&gt; null then
			releaseIdHdrStr := releaseIdHdrStr &amp; ",";
		endif;
		line := "00" &amp; releaseIdArray[index].String;
		tempStr := line[1:3] &amp; "." &amp; line[4:3] &amp; "." &amp; line[7:3];
		if line.length &gt; 9 then
			tempStr := tempStr &amp; "." &amp; line[10:end];
		endif;
		releaseIdHdrStr := releaseIdHdrStr &amp; tempStr;
	endforeach;
	
	/*******************************************************************
	* create and load the test project xml docuemnt
	*******************************************************************/
	write 'Getting active test details.  Please wait...';
	create xmlDoc transient;
	xmlDoc.parseFile(directoryName &amp; "\Master Terminal.xml");
	
	// get the test suite elements
	create testCaseXMLArray transient;
	xmlDoc.getElementsByTagName('testcase', testCaseXMLArray);
	
	foreach elementTestCase in testCaseXMLArray do
				
		// get the test case id
		xmlElement := elementTestCase.getElementByTagName("externalid");
		externalId := null;
		if xmlElement &lt;&gt; null then
			xmlCDATA := xmlElement.childNodes.first.JadeXMLCDATA;
			externalId := xmlCDATA.data.String;
		endif;
			
		// if in the ignore list then don't need to process any further
		if inactiveIds.includes("01-" &amp; externalId) then				
			continue;
		endif;		
		
		// get the test case name
		testCaseName := null;
		xmlAttribute := elementTestCase.getAttributeByName("name");
		if xmlAttribute.value = null then
			continue;
		endif;
		testCaseName := xmlAttribute.value.String.trimBlanks();
		
		// get the test suite details for the test
		xmlElement := elementTestCase;
		testSuite := null;
		while true do
			xmlElement := xmlElement.parentElement;
			if xmlElement = null then
				break;
			endif;
			xmlAttribute := xmlElement.getAttributeByName("name");
			if xmlAttribute &lt;&gt; null and xmlAttribute.value &lt;&gt; null then
				testSuite := xmlAttribute.value.String &amp; "/" &amp; testSuite.trimBlanks();
			endif;
		endwhile;
		testSuite := testSuite[1:testSuite.length-1].trimBlanks();
		
		testCaseName := testCaseName.replaceString(",", " ").trimBlanks();
		create resultArray transient;
		create resultArray2 transient;
		foreach index in 1 to releaseIdArray.size step 1 do
			resultArray.add(null);
		endforeach;
		tempStr := ("01-" &amp; externalId &amp; ":" &amp; testCaseName)[1:150].trimBlanks();
		testCaseDict.putAtKey(testSuite[1:150], tempStr, resultArray);
		///write "****XML LOAD****" &amp; tempStr;
		testCaseNameArray.add(tempStr);
		priorityArray.add("");
		
	endforeach;
	testCaseXMLArray.clear();
	delete xmlDoc;
	
	/*******************************************************************
	* read thorugh the results file(s)
	*******************************************************************/
	write 'Reading through all test results.  Please wait...';
	foreach fileNode in allFiles do
	
		// don't care about directory's
		if not fileNode.isKindOf(File) then
			continue;
		endif;
		
		// get the release id and it's index
		posUnderscore := fileNode.fileName.reversePos("_");
		posComma := fileNode.fileName.reversePos(".");
		releaseIdStr := fileNode.fileName[posUnderscore+1:posComma-posUnderscore-1];
		releaseIdStr := releaseIdStr.replaceString(".", "");
		indexOf := releaseIdArray.indexOf(releaseIdStr.Real);
		
		// read through the file and update the appropriate record
		delete file;
		create file transient;
		file.kind := File.Kind_Unknown_Text;	
		file.fileName := fileNode.fileName;
		
		line := null;
		file.readLine();
		while not file.endOfFile do
		
			line := file.readLine;
			
			// need to check to see if there are any " in the line and sort any commas between then out
			posFirstDblQuote := 1;
			posFirstDblQuote := line.pos('"', posFirstDblQuote);
			if posFirstDblQuote &gt; 0 then
				tempStr := line[1:posFirstDblQuote-1];
				while posFirstDblQuote &gt; 0 do
					
					posNextDblQuote := posFirstDblQuote + 1;
					posNextDblQuote := line.pos('"', posNextDblQuote);
					
					tempStr2 := line[posFirstDblQuote:posNextDblQuote-posFirstDblQuote+1];
					tempStr2 := tempStr2.replaceString(",", " ");
					tempStr := tempStr &amp; tempStr2;
					
					posFirstDblQuote := posNextDblQuote + 1;
					posFirstDblQuote := line.pos('"', posFirstDblQuote);
				endwhile;
				tempStr := tempStr &amp; line[posNextDblQuote+1:end];
				tempStr := tempStr.replaceString('"', "");
				line := tempStr;
			endif;
			
			tokens.clear();
			line.getHugeTokensForDelimiter(",", tokens);
			
			suiteName := tokens[1].trimBlanks(); 
			suiteName := suiteName.replaceString(",", "");
			testCaseName := tokens[2].trimBlanks();
			testCaseName := testCaseName.replaceString(",", "");
			posColon := 1;
			tempStr := testCaseName.scanUntil(":", posColon) &amp; ":";
			if testCaseName[posColon+1:1] = " " then
				testCaseName := tempStr &amp; testCaseName[posColon+2:end];
			endif;
			lastExecution := tokens[tokens.size];
			index := 1;
			lastExecution := lastExecution.scanUntil("[", index).trimBlanks();
			priority := tokens[3];
	
			//if testCaseName.cnContains("01-1131") then
			//	write 'lets debug';
			//endif;
	
			// check the testcase dict and update the appropriate resultArray object
			delete iter;
			iter := testCaseDict.createIterator;
			testCaseDict.startKeyLeq(suiteName, testCaseName, iter);
			while iter.next(resultArray) do
			
				testCaseDict.getIteratorKeys(suiteName2, testCaseName2, iter);
				///write Tab &amp; suiteName &amp; Tab &amp; suiteName2 &amp; Tab &amp; testCaseName &amp; Tab &amp; testCaseName2;
				if suiteName2 &lt;&gt; suiteName or testCaseName2 &lt;&gt; testCaseName then
					break;
				endif;
				
				// update the resultArray
				resultArray[indexOf] := lastExecution;
				indexOf2 := testCaseNameArray.indexOf(testCaseName);
				///write '****File Load****' &amp; testCaseName &amp; Tab &amp; indexOf2.String;
				if indexOf2 &gt; 0 then
					priorityArray[indexOf] := priority;
				endif;			
				
				break;
			
			endwhile;
		
		endwhile;
		
	endforeach;
	file.close();
	
	/*******************************************************************
	* Ouptut the details to file
	*******************************************************************/
	write 'Outputing Test Case Details.  Please wait...';
	delete file;
	create file transient;
	file.mode := File.Mode_Output;
	file.fileName := directoryName &amp; "\TestCaseDetails.csv";
	if file.isAvailable() then
		file.purge();
	endif;
	file.writeLine("Test Case,ID,Priority,Last Run,Last Run Result,Needs Attention,Include This Run,No Longer Required,Done," &amp; releaseIdHdrStr);
	
	delete iter;
	iter := testCaseDict.createIterator;
	while iter.next(resultArray) do
	
		results := null;
		lastRun := null;
		lastRunIndex := null;
		lastRunResult := null;
		needsAttention := null;
		includeThisRun := null;
		indexOf2 := null;
	
		testCaseDict.getIteratorKeys(suiteName, testCaseName, iter);
		
		foreach index in 1 to resultArray.size step 1 do
			results := results &amp; resultArray[index] &amp; ",";
			if resultArray[index] &lt;&gt; null then
				line := "00" &amp; releaseIdArray[index].String;
				tempStr := line[1:3] &amp; "." &amp; line[4:3] &amp; "." &amp; line[7:3];
				if line.length &gt; 9 then
					tempStr := tempStr &amp; "." &amp; line[10:end];
				endif;
				if lastRun = null then
					lastRun := tempStr;
					lastRunIndex := index;
					lastRunResult := resultArray[index];
				endif;
			endif;
		endforeach;
		
		// work out whether test needs attention
		write suiteName &amp; "," &amp; testCaseName &amp; "," &amp; priority &amp; "," &amp; lastRun &amp; "," &amp; 
			lastRunResult &amp; "," &amp; needsAttention &amp; "," &amp; includeThisRun &amp; Tab &amp; lastRunIndex.String &amp; Tab &amp; 
			notLessThanThisIndex.String;
		if lastRunIndex = 0 then
			needsAttention := "Y";
		elseif lastRunIndex &lt; notLessThanThisIndex and lastRunResult &lt;&gt; "Passed" then
			needsAttention := "Y";
		elseif lastRunIndex &gt; notLessThanThisIndex then
			needsAttention := "Y";
		endif;
		
		// 17/02/2017 cnwmh5 - Don't really need to output if lastRunResult = Passed and needsAttention &lt;&gt; "Y"
		if lastRunResult = "Passed" and needsAttention &lt;&gt; "Y" then
			continue;
		endif;
		
		indexOf2 := testCaseNameArray.indexOf(testCaseName);
		////write "**testCaseName**" &amp; Tab &amp; testCaseName &amp; Tab &amp; indexOf2.String;
		if indexOf2 &gt; 0 then
			priority := priorityArray[indexOf2];
			if priority = "High" then
				needsAttention := null;
				includeThisRun := "Y";
			endif;
		endif;
	
		// write the line to the file
		file.writeLine(suiteName &amp; "," &amp; testCaseName &amp; "," &amp; priority &amp; "," &amp; lastRun &amp; "," &amp; 
			lastRunResult &amp; "," &amp; needsAttention &amp; "," &amp; includeThisRun &amp; ",,," &amp; results );
		write suiteName &amp; "," &amp; testCaseName &amp; "," &amp; priority &amp; "," &amp; lastRun &amp; "," &amp;
			lastRunResult &amp; "," &amp; needsAttention &amp; "," &amp; includeThisRun &amp; ",,," &amp; results ;
	
	endwhile;
	file.close();
	
	write '*** FINISHED ***';

epilog

	delete file;
	
	delete tokens;
	delete inactiveIds;
	delete releaseIdArray;
	delete xmlDoc;
	delete testCaseDict;
	delete testCaseXMLArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initExtractGlobalConstants" id="4327ce74-48d8-46d0-bfe9-38ba77438e45">
        <source>initExtractGlobalConstants();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2024	navpw1	Initial creation

*/

vars
	objectEntity					: CMIF_SchemaObjectEntity;
	formCaptionsTfr					: FormCaptionsAgentXLATGenerate;
	file							: File;
	lsSchema						: LSschema;
	lsClass							: LSclass;
	formCaption						: XLAT_FormCaption;
	
	tokens							: HugeStringArray;
	
	xlatDict						: DynaDictionary;	//Rename
	
	line							: String;
	constantName					: String;
	schema							: Schema;
	constantCategory				: ConstantCategory;
	constant						: GlobalConstant;
	
begin
	app.initialize();
	
	create formCaptionsTfr transient;
	formCaptionsTfr.createFileFolder("Transfer");
	
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	file.fileName := formCaptionsTfr.fileFolder.fileName &amp; "\ConstantsToGet.csv";
	
	if not file.tryOpen then
		return;
	endif;
	
	create xlatDict transient;
	xlatDict.setMembership(CMIF_SchemaObjectEntity);
	xlatDict.addMemberKey(CMIF_SchemaObjectEntity::vSchemaName.name, true, false);
	xlatDict.addMemberKey(CMIF_SchemaObjectEntity::vGlobalConstantCategory.name, true, false);
	xlatDict.addMemberKey(CMIF_SchemaObjectEntity::vGlobalConstant.name, true, false);
	xlatDict.endKeys(true);
	
	create tokens transient;
	
	//Populate Dictionary
	while not file.endOfFile do
		line := file.readLine();
		
		if line = null then
			break;
		endif;
		
		// read the line into an array
		tokens.clear();
		line.getTokensForDelimiterHuge(",", tokens);
		
		create objectEntity transient;
		objectEntity.setPropertyValue("vSchemaName", tokens[2]);
		objectEntity.setPropertyValue("vGlobalConstantCategory", tokens[3]);
		objectEntity.setPropertyValue("vGlobalConstant", tokens[4]);
		
		xlatDict.add(objectEntity);
		
	endwhile;
	
	
	foreach objectEntity in xlatDict as CMIF_SchemaObjectEntity do
		app.writeLog(objectEntity.vSchemaName &amp; "::" &amp; objectEntity.vGlobalConstantCategory &amp; "::" &amp; objectEntity.vGlobalConstant, LogINFO);
		
		schema := rootSchema.getSchema(objectEntity.vSchemaName);
		if schema = null then
			app.writeLog("Could not find schema", LogINFO);
			continue;
		endif;
		
		constantCategory := schema.getConstantCategory(objectEntity.vGlobalConstantCategory);
		if constantCategory = null then
			app.writeLog("Could not find constantCategory", LogINFO);
			continue;
		endif;
		
		constant := schema.getConstant(objectEntity.vGlobalConstant);
		if constant = null then
			app.writeLog("Could not find constant", LogINFO);
			continue;
		endif;
		
		app.writeLog("Found constantCategory: " &amp; constantCategory.name, LogINFO);
		app.writeLog("Found constant: " &amp; constant.name, LogINFO);
		
	endforeach;
	
	//Create an agent
	
	//Use dev entites to hold the data
	
	
	/*
	file	: File;
	constantCategory : ConstantCategory;
	lsSchema : LSschema;
	lsClass : LSclass;
	lsConstant : LSconstant;
	text : String;
	constantNumberOut : Integer;
	
	
	create file transient;
	file.usePresentationFileSystem := folder.usePresentationFileSystem;
	file.openOutput(folder.fileName &amp; '\' &amp; mySchema.name &amp; '-FormCaptions-partial.scm');

	self.myAgent.log('Creating scm: ' &amp; file.fileName, false);	
	
	file.writeLine(zScmHeader);
	
	constantCategory := rootSchema.getSchema(PortSchemaName).getConstantCategory(XLAT_FormCaptions);
	file.writeLine('constantDefinitions');

	// constant category
	file.writeLine(Tab &amp; 'categoryDefinition ' &amp; constantCategory.name);
	file.writeLine(Tab &amp; 'documentationText');
	file.writeLine('`' &amp; XML_Version &amp; 'TranslationClass ClassName="' &amp; XLAT_FormCaption.name &amp; '"&gt;');
	file.writeLine('&lt;/TranslationClass&gt;`');

	foreach lsSchema in allSchemas do
		foreach lsClass in lsSchema.allClasses do
			foreach lsConstant in lsClass.allConstants do
			
				app.writeLog(method.qualifiedName() &amp; Tab &amp; lsClass.myClass.name &amp; Tab &amp; lsConstant.schemaName &amp; Tab &amp; 
					lsConstant.formName &amp; Tab &amp; lsConstant.controlName &amp; Tab &amp; lsConstant.controlProperty, LogINFO);
		
				// now write the constant definition to the scm file	
				file.writeLine(Tab &amp; Tab &amp; lsConstant.name &amp; ':	Integer = ' &amp; lsConstant.number.String &amp; ';');
				file.writeLine(Tab &amp; 'documentationText');
				file.writeLine('`' &amp; XML_Version &amp; XMLTag_Header &amp; ' ' &amp;
								XML_Tag_SchemaName &amp; '="' &amp; lsConstant.schemaName &amp; '" ' &amp;
								XML_Tag_FormClass &amp; '="' &amp; lsConstant.formName &amp; '" ' &amp;
								XML_Tag_ControlName &amp; '="' &amp; lsConstant.controlName &amp; '" ' &amp;
								XML_Tag_ControlProperty &amp; '="' &amp; lsConstant.controlProperty &amp; '"&gt;');
				file.writeLine('&lt;' &amp; XMLTag_LocaleMsg &amp; ' ' &amp; XMLTag_LocaleName &amp; '="' &amp; StandardTextLocaleStr &amp; '"&gt;');
				file.writeLine('&lt;' &amp; XMLTag_Msg &amp; '&gt;' &amp; lsConstant.text.xmlReplaceReservedChars(true) &amp; '&lt;/' &amp; XMLTag_Msg &amp; '&gt;');
				file.writeLine('&lt;/' &amp; XMLTag_LocaleMsg &amp; '&gt;');
				file.writeLine('&lt;/' &amp; XMLTag_Header &amp; '&gt;`');
		
			endforeach;
		endforeach;
	endforeach;

	self.myAgent.log('	Complete: ' &amp; file.fileLength.String &amp; ' bytes', false);
	*/
epilog
	delete file;
	delete tokens;
	
	if xlatDict &lt;&gt; null and xlatDict.isNotEmpty then
		xlatDict.purge;
	endif;
	
	delete xlatDict;
	delete formCaptionsTfr;
	
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="initGenXlatSchemas" id="0f229ff1-cf09-46d8-9f13-fe10227ff8c7">
        <updating/>
        <source>initGenXlatSchemas() updating;
// --------------------------------------------------------------------------------
// Created:		18 March 2009 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	
	on Exception do app.generalExceptionHandler(exception) global;
	on UserInterfaceException do app.xHandlerUI(exception) global;
	
	self.initialize();
	self.myPassport.setMyUserFromCode("SUPERUSER");
end;</source>
    </JadeMethod>
    <JadeMethod name="initJMTBatchReleaseExtractApp" id="2e0d81d1-1147-4f3a-808a-b054e6d355af">
        <updating/>
        <source>initJMTBatchReleaseExtractApp(_initializeParam : Object) updating;
/*

Purpose:			Initialisation method for the internal batch release extract application
					Release Extract agent will be initialised with the default values for 
					a full release, but these can all be optionally overriden on the command line
					following the endJade, using the syntax:
					
						&lt;propertyName&gt;=&lt;string value&gt;
					
					where &lt;propertyName&gt; is a valid public property name on the DEV_ReleaseExtractAgent
					class, and &lt;string value&gt; is a string representing the value to be set
					
						e.g. extractSingleSchema=true
						
					If the parameter value has embedded spaces, then it must be enclosed in double quotes					

					
Parameters:			Dummy object parameter to allow jadclient run

Return Value:		None


Date		Who		Reason
17 Nov 2011	cnwkpd1	CCMS SFW 1223 - New Release Mechanism
12 Nov 2019	jlgmd1	TFS 45294 Log to thinclient log so the TFS release can read it
19 Nov 2019 jlgmd1	TFS 45294 Return a non zero exit code on failure

*/

constants
	PublicAccess	= "public";
	
vars
	commandLine,
	searchString,
	delimiter,
	stringValue,
	userData		: String;
	paramValue		: Any;
	pos,
	startPos		: Integer;
	agent			: DEV_ReleaseExtractAgent;
	prop			: Property;
	userExitCode	: Integer;
	
begin
	userExitCode := 63;
	
	self.initialize();
	
	// Initialise JMT and CardSchema exception handling - do not pass anything back, because
	// we are a background application
	app.setPassBackExceptions(false, false);
	
	// Needs to be a background app so no lock dialogs are shown
	app.setIsBackGroundApp(true);

	commandLine := process.getCommandLine;
	pos := commandLine.toLower().pos('endjade', 1);
	if pos &lt;&gt; 0 then
		userData := commandLine[pos + 7:end];
	endif;
	
	app.writeLog('Initializing ' &amp; app.name &amp; ' with (' &amp; userData &amp; ')', LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	create agent transient;
	agent.setDefaultsForFullRelease();
	
	// Set any overridden parameters
	foreach prop in DEV_ReleaseExtractAgent.getProperties where prop.accessDisplay = PublicAccess do
		
		searchString := prop.name &amp; "=";
		pos := userData.pos(searchString, 1);
		
		// If this property has been overridden
		if pos &gt; 0 then
		
			app.writeLog('Found value for property ' &amp; prop.name, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			startPos := pos + searchString.length;
			stringValue := null;
			if userData.length &gt;= startPos then		// Not at the end of the user data string
				if userData[startPos:1] = '"' then
					startPos := startPos + 1;
					delimiter := '"';
				else
					delimiter := ' ';
				endif;
				
				stringValue := userData.scanUntil(delimiter, startPos).trimBlanks;
			endif;
			
			// Convert the string to the correct type
			paramValue := stringValue.asAnyOfType(prop.type);
			
			// And set the parameter
			app.writeLog('Setting value of ' &amp; prop.name &amp; " to '" &amp; paramValue.String &amp; "'", LogINFO);	//25 Nov 2019	NDL	TFS 47053
			agent.setPropertyValue(prop.name, paramValue);
		endif;
	endforeach;
	
	// Setup the thinclient log if we've been requested to do so
	searchString := "thinclientlog=";
	pos := userData.pos(searchString, 1);
	if pos &gt; 0 then
		startPos := pos + searchString.length;
		userData.scanWhile('"', startPos);
		stringValue := userData.scanUntil(' "', startPos);
		app.writeLog("Thin Client log attribute detected: " &amp; stringValue, LogINFO);
		agent.setupThinClientLog(stringValue);
	endif;

	// Now start the extract
	if agent.doReleaseExtract() then
		userExitCode := 0;
	endif;
	

epilog
	delete agent;
	
	beginTransaction;
	process.userExitCode := userExitCode;
	commitTransaction;
	
	terminate;
	
end;</source>
        <Parameter name="_initializeParam" type="Object"/>
    </JadeMethod>
    <JadeMethod name="initJMTBuildAutoDeployApp" id="35b6da98-b6cd-4f73-8d9a-2871e2bb60f4">
        <updating/>
        <source>initJMTBuildAutoDeployApp(_initializeParam : Object) updating;

/*

Purpose:			Initialisation method for the internal create of an auto deploy directory

Parameters:			Dummy object parameter to allow jadclient run

Return Value:		None


Date		Who		Reason
07 Jul 2015	cnwkpd1	Auto deployment to BA and Implementation environments
26 Jul 2017	jlgkpd1	Add optional base directory parameter

*/

constants
	ServerString		= "ServerDirectory=";
	AutoDeployString	= "AutoDeployDirectory=";
	IsDevelopment		= "IsDevelopment=";
	BaseString			= "BaseDirectory=";
	
vars
	serverDir,
	autoDeployDir,
	baseDir,
	commandLine,
	userData		: String;
	pos				: Integer;
	agent			: DEV_ReleaseExtractAgent;
	ff				: FileFolder;
	isDevelopment	: Boolean;
	
begin
	self.initialize();
	
	// Initialise JMT and CardSchema exception handling - do not pass anything back, because
	// we are a background application
	app.setPassBackExceptions(false, false);
	
	// Needs to be a background app so no lock dialogs are shown
	app.setIsBackGroundApp(true);

	commandLine := process.getCommandLine;
	pos := commandLine.toLower().pos('endjade', 1);
	if pos &lt;&gt; 0 then
		userData := commandLine[pos + 7:end];
	endif;
	
	app.writeLog('Initializing ' &amp; app.name &amp; ' with (' &amp; userData &amp; ')', LogINFO);	//25 Nov 2019	NDL	TFS 47053

    pos := userData.pos(ServerString, 1);
	if pos = 0 then
		app.writeLog('Error - "' &amp; ServerString &amp; '" not found on command line (' &amp; userData &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
	pos := pos + ServerString.length;
	if pos &lt;= userData.length then
		serverDir := userData.scanUntil(" ", pos).trimBlanks;
	endif;
	if serverDir = null then
		app.writeLog('Error - Server directory is null (' &amp; userData &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;

	create ff transient;
	ff.usePresentationFileSystem := false;
	ff.fileName := serverDir;
	if not ff.isAvailable() then
		app.writeLog('Error - Server directory is not available (' &amp; serverDir &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
	// Check for Auto Deployment directory
	pos := userData.pos(AutoDeployString, 1);
	if pos = 0 then
		app.writeLog('Error - "' &amp; AutoDeployString &amp; '" not found on command line (' &amp; userData &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
	pos := pos + AutoDeployString.length;
	if pos &lt;= userData.length then
		autoDeployDir := userData.scanUntil(" ", pos).trimBlanks;
	endif;
	if autoDeployDir = null then
		app.writeLog('Error - Auto Deploy directory name is null (' &amp; userData &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
	delete ff;
	create ff transient;
	ff.usePresentationFileSystem := true;
	ff.fileName := autoDeployDir;
	if not ff.isAvailable() then
		app.writeLog('Error - Auto Deploy directory is not available (' &amp; autoDeployDir &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
	// Check for IsDevelopment setting
	pos := userData.pos(IsDevelopment, 1);
	if pos = 0 then
		app.writeLog('Error - "' &amp; IsDevelopment &amp; '" not found on command line (' &amp; userData &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
	pos := pos + IsDevelopment.length;
	if pos &lt;= userData.length then
		isDevelopment := userData.scanUntil(" ", pos).trimBlanks.toLower.Boolean;
	endif;
	
	app.writeLog('Running with isDevelopment = ' &amp; isDevelopment.String, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	// Check for Base release directory (optional)
	pos := userData.pos(BaseString, 1);
	if pos &lt;&gt; 0 then
		pos := pos + BaseString.length;
		if pos &lt;= userData.length then
			baseDir := userData.scanUntil(" ", pos).trimBlanks;
		endif;
		
		if baseDir = null then
			app.writeLog('Error - Base directory name is null (' &amp; userData &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
			return;
		endif;
	
		delete ff;
		create ff transient;
		ff.usePresentationFileSystem := true;
		ff.fileName := baseDir;
		if not ff.isAvailable() then
			app.writeLog('Error - Base directory is not available (' &amp; baseDir &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
			return;
		endif;
	endif;	
	
	create agent transient;
	agent.doBuildAutoDeployDirectory(serverDir, autoDeployDir, baseDir, isDevelopment);
	

epilog
	delete ff;
	delete agent;
	terminate;
	
end;</source>
        <Parameter name="_initializeParam" type="Object"/>
    </JadeMethod>
    <JadeMethod name="initJMTDailyEncExtractApp" id="cc399f11-e9d7-4b92-a94e-836b33486265">
        <updating/>
        <source>initJMTDailyEncExtractApp(_initializeParam : Object) updating;

/*

Purpose:			Initialisation method for the internal daily encypted extract application

Parameters:			Dummy object parameter to allow jadclient run

Return Value:		None


Date		Who		Reason
07 Jul 2015	cnwkpd1	Auto deployment for BAs and Implementation team
					
*/

constants
	ServerString		= "ServerDirectory=";
	
vars
	serverDir,
	commandLine,
	userData		: String;
	pos				: Integer;
	agent			: DEV_ReleaseExtractAgent;
	ff				: FileFolder;
	
begin
	self.initialize();
	
	// Initialise JMT and CardSchema exception handling - do not pass anything back, because
	// we are a background application
	app.setPassBackExceptions(false, false);
	
	// Needs to be a background app so no lock dialogs are shown
	app.setIsBackGroundApp(true);

	commandLine := process.getCommandLine;
	pos := commandLine.toLower().pos('endjade', 1);
	if pos &lt;&gt; 0 then
		userData := commandLine[pos + 7:end];
	endif;
	
	app.writeLog('Initializing ' &amp; app.name &amp; ' with (' &amp; userData &amp; ')', LogINFO);	//25 Nov 2019	NDL	TFS 47053

    pos := userData.pos(ServerString, 1);
	if pos = 0 then
		app.writeLog('Error - "' &amp; ServerString &amp; '" not found on command line (' &amp; userData &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
	pos := pos + ServerString.length;
	if pos &lt;= userData.length then
		serverDir := userData.scanUntil(" ", pos).trimBlanks;
	endif;
	if serverDir = null then
		app.writeLog('Error - Server directory is null (' &amp; userData &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;

	create ff transient;
	ff.usePresentationFileSystem := false;
	ff.fileName := serverDir;
	if not ff.isAvailable() then
		app.writeLog('Error - Server directory is not available (' &amp; serverDir &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
	create agent transient;
	agent.doDailyEncryptedExtracts(serverDir);
	
epilog
	delete ff;
	delete agent;
	terminate;
	
end;</source>
        <Parameter name="_initializeParam" type="Object"/>
    </JadeMethod>
    <JadeMethod name="initJMTDailyExtractApp" id="a411c1e7-625b-4db6-ad11-48a97bccc74d">
        <updating/>
        <source>initJMTDailyExtractApp(_initializeParam : Object) updating;

/*

Purpose:			Initialisation method for the internal daily extract application

Parameters:			Dummy object parameter to allow jadclient run

Return Value:		None


Date		Who		Reason
17 Nov 2011	cnwkpd1	CCMS SFW 1223 - New Release Mechanism
17/03/2015	cnwmh5	Transient Leak
30 Oct 2018 jlgmd1	Make extracting src from wmast easier
					
*/

constants
	ServerString		= "ServerDirectory=";
	ClientString		= "ClientDirectory=";
	ExtractOnlyString	= "ExtractOnly=";
	
vars
	serverDir,
	clientDir,
	commandLine,
	userData,
	extractOnlyStr	: String;
	pos				: Integer;
	agent			: DEV_ReleaseExtractAgent;
	ff				: FileFolder;
	extractOnly		: Boolean;
	
begin
	self.initialize();
	
	// Initialise JMT and CardSchema exception handling - do not pass anything back, because
	// we are a background application
	app.setPassBackExceptions(false, false);
	
	// Needs to be a background app so no lock dialogs are shown
	app.setIsBackGroundApp(true);

	commandLine := process.getCommandLine;
	pos := commandLine.toLower().pos('endjade', 1);
	if pos &lt;&gt; 0 then
		userData := commandLine[pos + 7:end];
	endif;
	
	app.writeLog('Initializing ' &amp; app.name &amp; ' with (' &amp; userData &amp; ')', LogINFO);	//25 Nov 2019	NDL	TFS 47053

    pos := userData.pos(ServerString, 1);
	if pos = 0 then
		app.writeLog('Error - "' &amp; ServerString &amp; '" not found on command line (' &amp; userData &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
	// Get server extract directory
	pos := pos + ServerString.length;
	if pos &lt;= userData.length then
		serverDir := userData.scanUntil(" ", pos).trimBlanks;
	endif;
	if serverDir = null then
		app.writeLog('Error - Server directory is null (' &amp; userData &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;

	// and check if it exists
	create ff transient;
	ff.usePresentationFileSystem := false;
	ff.fileName := serverDir;
	if not ff.isAvailable() then
		app.writeLog('Error - Server directory is not available (' &amp; serverDir &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
	// Get the (optional) extract only flag
	pos := userData.pos(ExtractOnlyString, 1);
	if pos &gt; 0 then
		// Get the extract only flag
		pos := pos + ExtractOnlyString.length;
		if pos &lt;= userData.length then
			extractOnlyStr := userData.scanUntil(" ", pos).trimBlanks;
			extractOnly := extractOnlyStr.Boolean;
		endif;
	endif;
	
	if not extractOnly then
		pos := userData.pos(ClientString, 1);
		if pos = 0 then
			app.writeLog('Error - "' &amp; ClientString &amp; '" not found on command line (' &amp; userData &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
			return;
		endif;
		
		// Get the client extract directory
		pos := pos + ClientString.length;
		if pos &lt;= userData.length then
			clientDir := userData.scanUntil(" ", pos).trimBlanks;
		endif;
		if clientDir = null then
			app.writeLog('Error - Client directory name is null (' &amp; userData &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
			return;
		endif;
		
		// and check if it exists
		delete ff;
		create ff transient;
		ff.usePresentationFileSystem := true;
		ff.fileName := clientDir;
		if not ff.isAvailable() then
			app.writeLog('Error - Client directory is not available (' &amp; clientDir &amp; ')', LogERROR);	//26 Nov 2019	NDL	TFS 47053
			return;
		endif;
	endif;
	
	create agent transient;
	if not extractOnly then
		agent.doDailyExtractsForSVN(serverDir, clientDir);
	else
		agent.doDailySrcExtracts(serverDir);
	endif;
	

epilog
	delete ff;
	delete agent;
	terminate;
	
end;</source>
        <Parameter name="_initializeParam" type="Object"/>
    </JadeMethod>
    <JadeMethod name="initJMTExtractEDIXSDsApp" id="ea6681ae-ef07-4dfd-910d-ecabc52efcef">
        <updating/>
        <source>initJMTExtractEDIXSDsApp(_initializeParam : Object) updating;

/*

Purpose:			Used by the automated release extract to get the latest EDI XSD files

Parameters:			Expects a directory to put the XSD files in

Return Value:		None


Date				Who		Reason
02 July 2019		jlgmd1	Initial creation

*/

	
vars
	commandLine,
	userData,
	dir,
	searchString,
	stringValue		: String;
	startPos,
	pos				: Integer;
	agent			: DEV_ReleaseExtractAgent;
begin
	self.initialize();
	
	// Initialise JMT and CardSchema exception handling - do not pass anything back, because
	// we are a background application
	app.setPassBackExceptions(false, false);
	
	// Needs to be a background app so no lock dialogs are shown
	app.setIsBackGroundApp(true);

	commandLine := process.getCommandLine;
	startPos := commandLine.toLower().pos('endjade', 1);
	
	if startPos &gt; 0 then
		userData := commandLine[startPos + 7:end];
		app.writeLog(Tab &amp; Tab &amp; "UserData: [" &amp; userData &amp; "]", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		
		// Directory=&lt;string&gt;
		pos := userData.toLower().pos('directory=', 1);
		if pos &gt; 0 then
			pos := pos + 10;	// sizeof directory=
			dir := userData.scanUntil(" ", pos);
		endif;
	endif;

	if dir = null then
		app.writeLog("**** ERROR: To use this app you must include a 'directory=&lt;path&gt;' parameter ****", LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		terminate;
	endif;
	
	app.writeLog('Initializing ' &amp; app.name &amp; ' with (' &amp; userData &amp; ')', LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	create agent transient;
	
	// Write to a TC log so the TFS Agent can read it back
	searchString := "thinclientlog=";
	pos := userData.pos(searchString, 1);
	if pos &gt; 0 then
		startPos := pos + searchString.length;
		userData.scanWhile('"', startPos);
		stringValue := userData.scanUntil(' "', startPos);
		app.writeLog("Thin Client log attribute detected: " &amp; stringValue, LogINFO);
		agent.setupThinClientLog(stringValue);
	endif;
	
	agent.extractXSDs(dir);

epilog
	delete agent;
	terminate;
end;</source>
        <Parameter name="_initializeParam" type="Object"/>
    </JadeMethod>
    <JadeMethod name="initJMTReleaseChecksApp" id="30782718-0717-4957-8596-afb7165f90ee">
        <updating/>
        <source>initJMTReleaseChecksApp() updating;
/*

Purpose:			Used by the automated release extract to check if any methods are in error

Parameters:			

Return Value:		

Date				Who		Reason
03 October 2019		jlgmd1	Initial creation TFS 45294

*/

vars
	agent			: DEV_ReleaseExtractAgent;
	errorsFound		: Boolean;
	userExitCode	: Integer;
	commandLine,
	userData,
	searchString,
	stringValue		: String;
	pos,
	startPos		: Integer;
begin
	userExitCode := 63;

	self.initialize();
	
	// Initialise JMT and CardSchema exception handling - do not pass anything back, because
	// we are a background application
	app.setPassBackExceptions(false, false);
	
	// Needs to be a background app so no lock dialogs are shown
	app.setIsBackGroundApp(true);
	
	commandLine := process.getCommandLine;
	pos := commandLine.toLower().pos('endjade', 1);
	if pos &lt;&gt; 0 then
		userData := commandLine[pos + 7:end];
	endif;
	
	app.writeLog('Initializing ' &amp; app.name &amp; ' with (' &amp; userData &amp; ')', LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	create agent transient;
	
	// Write to a TC log so the TFS Agent can read it back
	searchString := "thinclientlog=";
	pos := userData.pos(searchString, 1);
	if pos &gt; 0 then
		startPos := pos + searchString.length;
		userData.scanWhile('"', startPos);
		stringValue := userData.scanUntil(' "', startPos);
		app.writeLog("Thin Client log attribute detected: " &amp; stringValue, LogINFO);
		agent.setupThinClientLog(stringValue);
	endif;
	
	if	agent.checkRelMethForErr() and
		agent.check30CharLimit() then
		userExitCode := 0;
	endif;

epilog
	delete agent;
	
	beginTransaction;
	process.userExitCode := userExitCode;
	commitTransaction;
	
	terminate;
end;</source>
    </JadeMethod>
