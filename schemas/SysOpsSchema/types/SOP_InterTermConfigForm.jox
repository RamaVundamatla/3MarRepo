    <JadeMethod name="doLoadTerminalAreas" id="d40c7746-32d8-439d-8980-425a3297462f">
        <updating/>
        <source>doLoadTerminalAreas() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 February 2010	conkc1	Initial creation
*/
vars
	ta      : CM_TerminalArea;
begin

	self.allAvailableTerminalAreas.clear;
	self.allSelectedTerminalAreas.clear;

	foreach ta in self.myTerminal.allTerminalAreas do
		if ta.myType = null then
			continue;
		endif;
		allAvailableTerminalAreas.add(ta);
	endforeach;

	if self.myInterTerminalConfig &lt;&gt; null then
		foreach ta in self.myInterTerminalConfig.allSourceAreas do
			self.allSelectedTerminalAreas.add(ta);
		endforeach; 
	endif;

epilog

end;</source>
    </JadeMethod>
