    <JadeMethod name="getLocationController" id="0dceb019-2418-4a6c-b04b-3e9a2346d194">
        <source>getLocationController(): CM_LocationsController;
//--------------------------------------------------------------
//Created: 05 September 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 19/11/2010	cnwdap1		PAR #23794 CCMS MES 1102 Return WLE location if the WLE has one
vars
	location : CM_LocationsController;		// PAR #23794

begin
	if self.myCurrentWLE &lt;&gt; null and self.myCurrentWLE.myTrackedItem &lt;&gt; null then
		//return self.myCurrentWLE.job.CM_RailJob.getWagonLCForTI(self.myCurrentWLE.myTrackedItem);									// PAR #23794
		location := self.myCurrentWLE.job.CM_RailJob.getWagonLCForTI(self.myCurrentWLE.myTrackedItem);								// PAR #23794
		if location = null then																										// PAR #23794
			if CM_YardWLE.hasInstance(self.myCurrentWLE) and not self.myCurrentWLE.CM_YardWLE.allLocationControllers.isEmpty then	// PAR #23794
				location := self.myCurrentWLE.CM_YardWLE.allLocationControllers.first;												// PAR #23794
			endif;																													// PAR #23794
		endif;																														// PAR #23794
		return location;																											// PAR #23794
	endif;
	return null;
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
