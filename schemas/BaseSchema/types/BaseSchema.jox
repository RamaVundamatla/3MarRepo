    <JadeMethod name="msgBox" id="02036e91-2979-44f7-b0af-64e490acba3c">
        <source>msgBox(msg: String; title: String; flags: Integer): Integer;
// --------------------------------------------------------------------------------
// Created:		30 January 2000 by cnwndl1
//
// Purpose:		Re-implementation of app.msgBox to allow auto-close by a timer.
//
//				If the 'flags' parameter value is positive, then the normal
//				app.msgBox will be presented.
//
//				If the 'flags' value is negative, then the CnEcMsgBoxForm will be
//				presented with the normal message and title, but just an OK button.
//				The CnEcMsgBoxForm will then wait until either the OK button is
//				depressed, or until the timer limit is reached, at which time the
//				dialog form will close.  The timer period is determined by the flags
//				parameter's (absolute) value.
//
// Parameters:	Refer to the "msgBox" method in the JADE Online Help.
//
// Returns:		Refer to the "msgBox" method in the JADE Online Help.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	messageFormObj	: CnEcMsgBoxForm;
	returnValue		: Integer;
	
begin
	if flags &lt; 0 then
		create messageFormObj;
		messageFormObj.aCloseSeconds	:=	flags.abs;
		messageFormObj.caption			:=	title;
	    messageFormObj.aDialogMessage	:=	msg;
		//theMessageForm.centreWindow;
		messageFormObj.showModal();
		returnValue						:=	MsgBox_Return_OK;
	else
		returnValue	:=	inheritMethod(msg, title, flags);
	endif;		

	return returnValue;
end;</source>
        <Parameter name="msg" type="String"/>
        <Parameter name="title" type="String"/>
        <Parameter name="flags" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zSetProfileString" id="405a53eb-441e-4686-9379-6d466004e8e5">
        <executionLocation>server</executionLocation>
        <source>zSetProfileString() protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		19 May 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	SECURITY_SECTION	: String = "JadeSecurity";
	SECURITY_ENABLED	: String = "AuthenticationEnabled";
	LIBRARY_SETTING		: String = "DevelopmentSecurityLibrary";
	SECURITY_LIBRARY	: String = "&lt;none&gt;";
	
begin
	app.setProfileString(app.getIniFileName(), SECURITY_SECTION, LIBRARY_SETTING, SECURITY_LIBRARY);
	app.setProfileString(app.getIniFileName(), SECURITY_SECTION, SECURITY_ENABLED, "false");
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
