        <Parameter name="_back" type="Decimal"/>
        <Parameter name="_front" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_addingToDo" type="Boolean"/>
        <ReturnType type="Boolean"/>
