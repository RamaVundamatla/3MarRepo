// add any required code
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="024c798b-221f-4c83-982d-a55a06af9e11">
        <source>validateForUpdate();
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
// 21 Jul 2017			cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
//16/06/2023			navkc1	CR 58221 Task 58222: UI - Ownership Change Free Days
begin

	if self.myStorageConfig = null then
		app.raiseCMException(Input_required_field_strConDet, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	//20 Sep 2017	NDL	TFS 7032
	if self.freeDaysType = Working_Days
	or self.chargedDaysType = Working_Days
	or self.cooFreeDaysType = Working_Days then //16/06/2023	navkc1	CR 58221 Task 58222
		if self.myStorageConfig.myWorkingDaysCalendar = null then
			app.raiseCMWarning1(Calend_curren_declar_storag_co, app.getErrorString(Days_excluded), null, null, null );
		endif;
	elseif self.freeDaysType = Working_Compulsory_Days
	or self.chargedDaysType = Working_Compulsory_Days 
	or self.cooFreeDaysType = Working_Compulsory_Days then //16/06/2023	navkc1	CR 58221 Task 58222
		if self.myStorageConfig.getMyCompulsoryCalendar = null then
			app.raiseCMWarning1(Calend_curren_declar_storag_co, app.getErrorString(Compulsory_days), null, null, null );
		endif;
	endif;
	
	
	if self.myFutureStorageStop &lt;&gt; null then  //21.07.2017 cnwma1 TFS #5409
		validateStopCargoType();
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateStopCargoType" id="7cdb0230-0588-48ef-8d22-0a6482362c92">
        <source>validateStopCargoType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jul 2017	cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
20 Oct 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
*/

vars
	 storageCriteria, stopCriteria, matchingCriteria : CM_YACriteria;
	 obj : Object;
	 stptbl : CM_StopsTable;
	 stopYA : CM_StopCriteria;

begin
	//START 20.10.2022	navsj20	TFS 53862
	/*criteria := self.allCriteriaByType[YACriteriaType_CargoType];
	if criteria &lt;&gt; null then
		if criteria.myYAData&lt;&gt; null then
			if not  criteria.myYAData.CM_YADataObjects.allObjects.isEmpty then //21.07.2017 cnwma1 TFS #5409
				foreach obj in criteria.myYAData.CM_YADataObjects.allObjects do 
					 //if not  self.myFutureStorageStop.allCargoTypesNew.includes(obj.CM_CargoType) then		//20 Jul 2022	navsj20	TFS 53862
					 if self.myFutureStorageStop.myStopCriteria &lt;&gt; null then									//27 Jul 2022	navsj20	TFS 53862
						foreach criteria in self.myFutureStorageStop.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType 
							and not criteria.myYAData.CM_YADataObjects.allObjects.includes(obj.CM_CargoType) do		//27 Jul 2022	navsj20	TFS 53862
							app.raiseCMWarning1(Warn_FS_Stop_CargoType,self.myFutureStorageStop.heading,null,null,null);
						endforeach;
					endif;
				endforeach;
			endif;
		endif;
	endif;*/
	
	stptbl := self.myFutureStorageStop;
	if stptbl &lt;&gt; null then
	
		stopYA := stptbl.myStopCriteria;
		if stopYA &lt;&gt; null then
	
			// Go through all the criteria on this storage detail
			foreach storageCriteria in self.allCriteriaByType do
				// is the storage criteria part of the criteria on the given stop?
				matchingCriteria := null;
				foreach stopCriteria in stopYA.allCriteria do
					if stopCriteria.myYACriteriaType.type = storageCriteria.myYACriteriaType.type then
						matchingCriteria := stopCriteria;
						break;
					endif;
				endforeach;
				
				if matchingCriteria &lt;&gt; null then // yes it is
					// go through all the objects in the storage criteria; are they all included in the objects on the stops matching criteria?
					foreach obj in storageCriteria.myYAData.CM_YADataObjects.allObjects do 
						// if the object is not in the stops collection they are incompatible
						if not matchingCriteria.myYAData.CM_YADataObjects.allObjects.includes(obj) then
							app.raiseCMWarning2(Stora_crite_not_compa_with_cri,matchingCriteria.myYACriteriaType.description, matchingCriteria.myYACriteriaType.getDisplay(obj) ,null,null,null);
						
						endif;
					endforeach;
				endif;
			
			endforeach;
		endif;
	endif;
	//END 20.10.2022	navsj20	TFS 53862

epilog

end;</source>
    </JadeMethod>
</Class>
