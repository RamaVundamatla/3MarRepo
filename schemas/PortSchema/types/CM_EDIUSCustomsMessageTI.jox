Date		Who		Reason
08 July 2014	cnwmc5	Initial creation

*/

vars

begin

	self.billOfLading	:= _bolNum;
	self.dispositionCode:= _dispCode;
	self.controlNumber  := _controlNumber.Integer;
	self.entryType      := _entryType;
	self.entryNumber	:= _entryNumber;
