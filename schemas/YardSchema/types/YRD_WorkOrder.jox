    <JadeMethod name="getListOperators" id="ad5ef8f4-bd99-4492-b22d-dc04cc2c140b">
        <source>getListOperators(_operatorSet		 : CM_OperatorSet io ;
			  _includeNullVoyage : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Mar 2023 navhl20 Defect 57233: MTN - Editing Vas Tasks is not working correctly

*/

vars
	iter 		: Iterator;
	operator	: CM_Operator;
	failedDAC   : CM_DataAccessController;
	passport	: CM_Passport;
	gracePeriod : Integer;
begin
	iter 	 := self.myTerminal.myRoot.allOperators.createIterator;
	
	while iter.next(operator) do
	
		if not operator.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;

		if not _includeNullVoyage then
			if operator.isKindOf(CM_NullOperator) then
				continue;
			endif;
		endif;
		
		_operatorSet.add(operator);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_operatorSet" type="CM_OperatorSet" usage="io"/>
        <Parameter name="_includeNullVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getListTrains" id="4e055211-75d2-44bc-9922-2579f1493469">
        <source>getListTrains(_trainSet		 	 : CM_TrainSet io ;
			  _includeNullVoyage : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Mar 2023 navhl20 Defect 57233: MTN - Editing Vas Tasks is not working correctly

*/

vars
	iter 		: Iterator;
	train		: CM_Train;
	failedDAC   : CM_DataAccessController;
	passport	: CM_Passport;
	gracePeriod : Integer;
begin
	iter 	 := self.myTerminal.allTrainsOnTerminal.createIterator;
	
	while iter.next(train) do
	
		if not train.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		
		if train.isDeparted then 
			continue;
		endif;

		if not _includeNullVoyage then
			if train.isNullTrain() then
				continue;
			endif;
		endif;
		
		_trainSet.add(train);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_trainSet" type="CM_TrainSet" usage="io"/>
        <Parameter name="_includeNullVoyage" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getListVoyages" id="34338d94-9de8-4abe-a93e-e12a6a2bdff6">
        <source>getListVoyages(_voyageSet		 : CM_VoyageSet io ;
			  _includeNullVoyage : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2023 navma1 ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Screen
*/

vars
	iter 		: Iterator;
	voyage		: CM_Voyage;
	failedDAC   : CM_DataAccessController;
	passport	: CM_Passport;
	gracePeriod : Integer;
	checkDT     : TimeStamp;
begin
	
	passport 	:= app.myPassport;
	iter 	 	:= self.myTerminal.allVoyagesByCode.createIterator;
	checkDT  	:= app.actualTimeServer();
	checkDT  	:= checkDT.changeByXXHours(-gracePeriod);
	gracePeriod := self.myTerminal.getConfig(VoyDepartedGracePeriod).Integer;
	
	if gracePeriod = null then
		gracePeriod := 24;
	endif;
	
	while iter.next(voyage) do
	
		if not voyage.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;
		
		if voyage.isCancelled then 
			continue;
		endif;
		
		if not voyage.isActiveDisplay(checkDT) then		
			continue;
		endif;	

		if not _includeNullVoyage then
			if voyage.isNullVoyage() then
				continue;
			endif;
		endif;
		
		_voyageSet.add(voyage);
		
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_voyageSet" type="CM_VoyageSet" usage="io"/>
        <Parameter name="_includeNullVoyage" type="Boolean"/>
    </JadeMethod>
