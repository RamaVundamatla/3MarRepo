<Class name="JadeScript">
    <JadeMethod name="deleteRoot" id="28143eb6-ee99-40c8-bb9d-27991a25fb71">
        <updating/>
        <source>deleteRoot() updating;

vars
	root        : Root;
	environment : Environments;
	classname   : ClassNames;
	methodname  : MethodNames;
	count       : Integer;
begin
	root := Root.firstInstance;
	if root = null then
		return;
	endif;
	beginTransaction;
	foreach environment in root.allEnvironments do
		foreach classname in environment.allClassnames do
			count := count + 1;
			if count mod 5000 = 0 then
				commitTransaction;
				beginTransaction;
			endif;
			delete classname;
		endforeach;
		foreach methodname in environment.allMethodnames do
			count := count + 1;
			if count mod 5000 = 0 then
				commitTransaction;
				beginTransaction;
			endif;
			delete methodname;
		endforeach;
		delete environment;
	endforeach;
	delete root;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadClassnames" id="3cf0daec-664f-4e88-a4eb-9eeade45c51c">
        <updating/>
        <source>loadClassnames() updating;

vars
	v_file      : File;
	cmd         : CMDFileOpen;
	root        : Root;
	data        : String;
	count       : Integer;	environment : Environments;
	environ     : String;
	methods     : Boolean;

begin

	create cmd transient;
	create v_file transient;
	cmd.filter := ' | *.txt';

	if cmd.open = 0 then
	    v_file.fileName := cmd.fileName;
	else
		return;
	endif;
	
	v_file.mode     := File.Mode_Input;
	//v_file.kind     := File.Kind_ANSI;
	v_file.kind     := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	
	if v_file.isAvailable = false then
		return;
	endif;

	root     := Root.firstInstance;
	if root = null then
		beginTransaction;
		create root;
		commitTransaction;
	endif;

	read environ;
	if environ.trimBlanks = null then
		write 'Must supply a name';
		return;
	endif;
	if environ.trimBlanks.length &gt; 30 then
		write 'Supplied name must be less than 31 characters';
		return;
	endif;
	environment := root.allEnvironments[environ];
	if environment = null then
		beginTransaction;

		create environment;
		environment.name := environ;
		environment.myRoot := root;

		commitTransaction;
	endif;
	v_file.open;

	app.mousePointer := Window.MousePointer_HourGlass;
	beginTransaction;
	while not v_file.endOfFile do : outter 

		data  := v_file.readLine();
		if data.length &gt; 4 then
			if data[ 1 : 5 ] = '-----' then
				methods := true;
			endif;
		endif;
		if methods then
			setupMethodname(data, environment);
		else
			setupClassname(data, environment);
		endif;

	endwhile;

	commitTransaction;
	app.mousePointer := Window.MousePointer_Default;
epilog
	delete v_file;
	delete cmd;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupClassname" id="9c82ed01-e32f-4b3c-bb33-bb22667404e5">
        <updating/>
        <source>setupClassname(_data : String; _root : Environments io) updating;

vars
	pos     : Integer;
	number  : Integer;
	aclass  : String;
	aschema : String;
	aClass  : ClassNames;
begin

	pos := 1;
	pos := _data.pos ('::', pos);
	if pos = 0 then
		return;
	endif;
	aschema := _data[1 : pos - 1];
	pos := pos + 2;
	aclass := _data.getNextToken (pos);
	number := _data.getNextToken (pos).Integer;
	aClass := _root.allClassnames [ number ];
	if aClass = null then
		create aClass;
		aClass.number        := number;
		aClass.schema        := aschema;
		aClass.name          := aclass;
		aClass.myEnvironment := _root;
	endif;
end;</source>
        <Parameter name="_data" type="String"/>
        <Parameter name="_root" type="Environments" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setupEnvironment" id="e02ba462-9101-4121-b1a4-ffad0bf85667">
        <updating/>
        <source>setupEnvironment() updating;
constants

vars
	e : Environments;
begin
	beginTransaction;
	create e;
	e.name := 'c\jade5208';
	e.myRoot := Root.firstInstance;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMethodname" id="2717b3e6-f504-488d-a435-45ab62c85ec7">
        <updating/>
        <source>setupMethodname(_data : String; _root : Environments io) updating;
//
// Format
// RootSchema::WindowException::text 23.221
//
vars

	pos        : Integer;
	sPos       : Integer;
	number     : Integer;
	aschema    : String;
	methodName : String;
	aclass     : String;
	aMethod    : MethodNames;
	oid        : String;
begin

	pos := 1;
	pos := _data.pos ('::', pos);
	if pos = 0 then
		return;
	endif;
	aschema    := _data[1 : pos - 1];
	pos        := pos + 2;
	aclass     := _data.getNextToken (pos);
	sPos       := pos;
	pos        := _data.pos ('::', sPos);
	sPos       := sPos + 1;
	methodName := _data.getNextToken (sPos);
	oid        := _data.getNextToken (sPos);

	aMethod := _root.allMethodnames [ oid ];
	if aMethod = null then
		create aMethod;
		aMethod.className     := aclass;
		aMethod.oid           := oid;
		aMethod.schema        := aschema;
		aMethod.name          := methodName;
		aMethod.myEnvironment := _root;
	endif;

end;</source>
        <Parameter name="_data" type="String"/>
        <Parameter name="_root" type="Environments" usage="io"/>
    </JadeMethod>
    <JadeMethod name="testDriver" id="c62e5b4d-b51f-4c3d-a56e-6c55af7e7859">
        <updating/>
        <source>testDriver() updating;

vars
	startTime : Integer;
	endTime   : Integer;
	count     : Integer;
	token     : String;

begin

	startTime := app.clock;
	foreach count in 1 to 100000 do
		token := testTimeX;
	endforeach;
	endTime := app.clock;
	write endTime - startTime;
	write token;
end;</source>
    </JadeMethod>
    <JadeMethod name="testEmpty" id="368c7968-9684-4144-bc62-8987bb623477">
        <updating/>
        <source>testEmpty() updating;

vars

begin

end;
</source>
    </JadeMethod>
    <JadeMethod name="testReverseToken" id="5ec69f66-9ad3-476b-b3df-8bdc4fae3089">
        <updating/>
        <source>testReverseToken() updating;

vars
	st    : String;
	index : Integer;
	token : String;
begin
	st := 'a bb ccc dddd eeeee ffff ggg hh i';
	st := '                                 ';
	index := st.length;
	while index &gt; 1 do
		token := st.getReverseToken(index);
		write token;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="testTime" id="dcd68b47-917b-4fc9-bd59-ac0cf1df8db7">
        <updating/>
        <source>testTime() : String updating;

vars
	pos           : Integer;
	token         : String;
	length        : Integer;
	ticks         : Integer;
	cpuTime       : Integer;
	waitTime      : Integer;
	type          : String;
	nodeNumber    : String;
	processNumber : String;
	classId       : String;
	class         : Integer;
	instance      : Integer;
	parClass      : Integer;
	requestType   : Integer;
	mode          : Integer;
	sampleObject  : SampleObjects;
	data          : String;
begin

	data := '10 4 1 20454658 39896 903831 190 6519 1 1 1 0 1 1 0 60 0 0 0 0 0 151 193 1 1 0 404 1302 7 3 2 0 0 0 0 0 0 0 6848 271 0 0 0 0';
	pos  := 1;
	length := data.length;

	type         := data.getToken(pos);

	if type &lt;&gt; '10' then
		return type;
	endif;
	nodeNumber    := data.getToken(pos);
	processNumber := data.getToken(pos);
	ticks         := data.getToken(pos).Integer; // clock ticks
	cpuTime       := data.getToken(pos).Integer; // node cpu
	token         := data.getToken(pos); // node ticks
	token         := data.getToken(pos); // process cpu
	token         := data.getToken(pos); // process ticks
	token         := data.getToken(pos); // process logical clocks
	token         := data.getToken(pos); // user number
	token         := data.getToken(pos); // request count
	token         := data.getToken(pos); // request level
	requestType   := data.getToken(pos).Integer; // request type
	mode          := data.getToken(pos).Integer; // mode

	return requestType.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="testTimeX" id="2668cdff-0969-48d4-b42e-9950377c46d9">
        <updating/>
        <source>testTimeX() : String updating;

vars
	pos           : Integer;
	token         : String;
	length        : Integer;
	ticks         : Integer;
	cpuTime       : Integer;
	waitTime      : Integer;
	type          : String;
	nodeNumber    : String;
	processNumber : String;
	classId       : String;
	class         : Integer;
	instance      : Integer;
	parClass      : Integer;
	requestType   : Integer;
	mode          : Integer;
	sampleObject  : SampleObjects;
	data          : String;
begin

	data := '10 4 1 20454658 39896 903831 190 6519 1 1 1 0 1 1 0 60 0 0 0 0 0 151 193 1 1 0 404 1302 7 3 2 0 0 0 0 0 0 0 6848 271 0 0 0 0';
	pos  := 1;
	length := data.length;

	type         := data.getTokenX(pos);

	if type &lt;&gt; '10' then
		return type;
	endif;
	nodeNumber    := data.getTokenX(pos);
	processNumber := data.getTokenX(pos);
	ticks         := data.getTokenX(pos).Integer; // clock ticks
	cpuTime       := data.getTokenX(pos).Integer; // node cpu
	token         := data.getTokenX(pos); // node ticks
	token         := data.getTokenX(pos); // process cpu
	token         := data.getTokenX(pos); // process ticks
	token         := data.getTokenX(pos); // process logical clocks
	token         := data.getTokenX(pos); // user number
	token         := data.getTokenX(pos); // request count
	token         := data.getTokenX(pos); // request level
	requestType   := data.getTokenX(pos).Integer; // request type
	mode          := data.getTokenX(pos).Integer; // mode

	return requestType.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
