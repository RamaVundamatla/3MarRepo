    <JadeMethod name="create" id="0b096b95-a873-4e87-a715-6c21d0e8fd64">
        <updating/>
        <source>create(_timeStamp : TimeStamp; _reportType : Integer; _createdBy : String) updating;
/*

Purpose:			Creates a CM_SourceCompareReport object

Parameters:			_timeStamp:	TimeStamp	The timestamp for the report

Return Value:		

Date		Who		Reason
08 December 2021	navpw1	Initial creation TFS: 52202

*/

begin
	self.timeStamp 		:= _timeStamp;
	self.reportType		:= _reportType;
	self.createdBy		:= _createdBy;
	self.isAvailable 	:= false;
	
end;</source>
