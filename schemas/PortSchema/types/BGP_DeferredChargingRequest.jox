        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="hasFailed" id="db032aa0-50cc-4679-bb31-b40f2436323d">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="lastAlertTS" id="bde906b7-9b9b-4a9f-b12b-7cf86ca3ebd6">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="lastRetryTS" id="d6295371-baa5-427c-abd6-e8f83b413098">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myDeferredChargingRoot" id="d877cc89-6b8b-46b4-a3cd-ff322194d4b6">
