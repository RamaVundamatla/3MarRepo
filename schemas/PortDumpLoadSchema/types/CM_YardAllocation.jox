<Class name="CM_YardAllocation">
    <JadeMethod name="exportPDXMLMyCollections" id="a92387d1-557c-42ec-b709-1f268e1f2172">
        <source>exportPDXMLMyCollections(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars
	obj: Object;
begin
	if _property.name = CM_YardAllocation::allYABlockGroupsIn.name then
		_file.writeLine('&lt;'&amp;CM_YardAllocation::allYABlockGroupsIn.name&amp;'&gt;');
		foreach obj in self.allYABlockGroupsIn do
			_file.writeLine('&lt;class&gt;'&amp;obj.class.name&amp;'&lt;/class&gt;');
			obj.CM_YABlockGroup.exportPDXML(_file, _objArray, true, true);
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_YardAllocation::allYABlockGroupsIn.name&amp;'&gt;');
	elseif _property.name = CM_YardAllocation::allYABlockGroupsOut.name then
		_file.writeLine('&lt;'&amp;CM_YardAllocation::allYABlockGroupsOut.name&amp;'&gt;');
		foreach obj in self.allYABlockGroupsOut do
			_file.writeLine('&lt;class&gt;'&amp;obj.class.name&amp;'&lt;/class&gt;');
			obj.CM_YABlockGroup.exportPDXML(_file, _objArray, true, true);
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_YardAllocation::allYABlockGroupsOut.name&amp;'&gt;');

	elseif _property.name = CM_YardAllocation::allTerminalAreas.name then
		_file.writeLine('&lt;'&amp;CM_YardAllocation::allTerminalAreas.name&amp;'&gt;');
		foreach obj in self.allTerminalAreas do
			_file.writeLine('&lt;class&gt;' &amp; obj.class.name &amp; '&lt;/class&gt;');
			_file.writeLine('&lt;theKey&gt;' &amp; obj.theKey &amp; '&lt;/theKey&gt;');
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_YardAllocation::allTerminalAreas.name&amp;'&gt;');
	endif;
epilog
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLCollections" id="d70d0591-76ab-41a7-8d11-f876c1d3c6e3">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);

vars
	proxyArray: ObjectArray;
	newObject: Object;
begin
	create proxyArray transient;
	if _name = CM_YardAllocation::allYABlocksIn.name then
		self.importPLXMLNewCollectionWorker(_collectionsBlock, _name, proxyArray);
		foreach newObject in proxyArray do
			self.allYABlocksIn.add(newObject.CM_YABlock);
		endforeach;
	elseif _name = CM_YardAllocation::allTerminalAreas.name then
		if self.myTerminal &lt;&gt; null then
			self.importPLXMLOldDictWorkerStr(_collectionsBlock, _name, self.myTerminal.allTerminalAreas, proxyArray);
			foreach newObject in proxyArray do
				self.allTerminalAreas.add(newObject.CM_TerminalArea);
			endforeach;
		endif;
	endif;
epilog
	delete proxyArray;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="e71f9bda-01ec-49b3-b97b-ce969445ac8c">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_YardAllocation::myTerminal.name then
		return app.myRoot.allTerminals[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
