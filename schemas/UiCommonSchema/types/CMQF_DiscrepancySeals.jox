<Class name="CMQF_DiscrepancySeals">
    <JadeMethod name="setFromAgent" id="356e016a-b713-4a77-a15d-62378ee2e856">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 20 November 2008
// 
// Implemented version: 7.7.1
// CCMS1765 GDANSK - Maersk reporting requirements. 
//----------------------------------------------------------------------
vars

begin
	inheritMethod(_agent);
	
	if _agent.isRowIncluded(ETRow_IMEXStatuses) then
		_agent.getSelectedIMEXStatuses(self.allIMEXStatusCodes);
	endif;
	
	//Seals are only set on containers
	self.setMyCargoType ( app.myRoot.allCargoTypesById[TI_CargoType_Container] );
epilog
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
