    <JadeMethod name="isChildOf" id="8dc2e81e-70bf-4a4b-92bf-5e0965f7b6fc">
        <source>isChildOf(_parent : CM_SecurityRole) : Boolean;
// ---------------------------------------------------------------------------
// Created:     21 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myParentRole = null then
		return false;
	endif;
	
	if self.myParentRole = _parent then
		return true;
	endif;
	
	return self.myParentRole.isChildOf(_parent);

end;</source>
        <Parameter name="_parent" type="CM_SecurityRole"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInternalOnly" id="638cb9f9-8a5a-4b36-8ceb-67beed394efe">
        <source>isInternalOnly() : Boolean;
// ---------------------------------------------------------------------------
// Created:			26 March 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
