<Class name="DEV_SourceCompareRoot" id="ee4a3eaa-e069-428a-8013-2f575ed507f6">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <ExplicitInverseRef name="allSourceCompareReports" id="af94f595-1063-4093-a0d5-43fa99b12a71">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="DEV_SourceCompareReports"/>
        <access>readonly</access>
        <Inverse name="DEV_SourceCompareReport::myRoot"/>
    </ExplicitInverseRef>
    <PrimAttribute name="averageFullDuration" id="bb63743a-d5bd-498d-8985-82afb23691bd">
        <embedded/>
        <type name="Time"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="averageWeeklyDuration" id="cade0120-270a-4998-81fa-36f6151b2d15">
        <embedded/>
        <type name="Time"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isRunningComparison" id="3e911304-e0fc-494d-9c17-32d2f1147c3b">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setIsRunningComparison" id="429b3bef-ae8c-47e4-8302-a70f1853518c">
        <updating/>
        <source>setIsRunningComparison(_isRunningComparison : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2022	navpw1	Initial creation

*/

begin
	beginTransaction;
	self.isRunningComparison := _isRunningComparison;
	commitTransaction;

end;</source>
        <Parameter name="_isRunningComparison" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateDuration" id="cb73369b-b1ce-47b2-bfd2-bcfa53dc6c7a">
        <updating/>
        <source>updateDuration(_report : DEV_SourceCompareReport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 June 2023	navmd1	Initial creation

*/

vars
	rpt			: DEV_SourceCompareReport;
	rptType,
	count,
	avg			: Integer;
	duration	: Time;
begin
	duration := null;
	rptType := _report.reportType;
	
	foreach rpt in self.allSourceCompareReports where rpt.reportType = rptType and rpt.isAvailable do
		if rpt.generationTime = null then
			continue;	// skip old/incomplete reports with no data
		endif;
		
		count += 1;
		duration += rpt.generationTime;
	endforeach;
	
	if count = 0 then
		return;
	endif;
	
	avg := (duration.Integer / count).Integer;
	
	if rptType = DEV_SourceCompareReport.ReportType_Automatic then
		beginTransaction;
		self.averageWeeklyDuration := avg.Time;
		commitTransaction;
		
	elseif rptType = DEV_SourceCompareReport.ReportType_Manual then
		beginTransaction;
		self.averageFullDuration := avg.Time;
		commitTransaction;
	endif;
epilog

end;</source>
        <Parameter name="_report" type="DEV_SourceCompareReport"/>
    </JadeMethod>
</Class>
