vars
	tbl : CM_EntryTable;
	saveRowHeight : Real;
begin
	tbl := tblInput1;
	self.myAssistant.listTableLostFocus(tbl, saveRowHeight, self.tblProcessStop, 'string', false);
//	tbl.adjustHeight(200);
	
	if tbl.getValueByName(ETRow_ProcessStopAreas).String = Any_String then
		tbl.setValueByName(ETRow_ProcessStopAreas, None_Selected_String);
	endif;
	tbl.optimiseValueRowHeights();
	tbl.scrollBars := Table.ScrollBars_Vertical;	
end;</source>
