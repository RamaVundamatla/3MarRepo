    <JadeMethod name="displayEventType" id="5276033c-feff-4882-a701-2d2668ba8bee">
        <source>displayEventType( _obj : Object ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars
	
begin

	if _obj &lt;&gt; null and _obj.isKindOf( CM_EventType ) then
		return _obj.CM_EventType.name;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doEnableDisableCargoFields" id="7271d0b9-d0b0-4fd6-8aa6-c8fa5c38c7ef">
        <updating/>
        <source>doEnableDisableCargoFields(_enable : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/05/2021	navdap1		Initial creation TFS 50878 ASPA Bulk Barge Cargo Creation
//
vars

begin
	// don't enable anything if we have some TIs from the cargo details form
	if _enable and not self.allTrackedItems.isEmpty then
		return;
	endif;
	
	self.lblCargoType.enabled := _enable;
	self.cmbCargoType.enabled := _enable;
	self.lblCargoSubtype.enabled := _enable;
	self.cmbCargoSubtype.enabled := _enable;
	self.lblTotalWeight.enabled := _enable;
	self.txtTotalWeight.enabled := _enable;
	self.lblSpecialStow.enabled := _enable;
	self.cmbSpecialStow.enabled := _enable;
	self.btnDetails.enabled := _enable;
	
	if not self.allTrackedItems.isEmpty then
		self.btnDetails.enabled := true;
	endif;
epilog

end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="ae25b649-85b3-43ee-ab24-207492eabe58">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2020	jlgndl1	Initial creation	TFS 49417

*/

vars

begin

