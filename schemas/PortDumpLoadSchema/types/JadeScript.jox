    <JadeMethod name="clearRTG" id="e23d801a-7766-4fa2-89eb-76b57b75a13e">
        <source>clearRTG();
vars
	rtgArea : CM_RTGArea;
	lc : CM_LocationsController;
begin
	foreach rtgArea in CM_RTGArea.instances do
		beginTransaction;
		foreach lc in rtgArea.allLocationsControllers do
			if lc.allTrackedItems.size &gt; 0 then
				lc.allTrackedItems.purge;
			endif;
		endforeach;
		commitTransaction;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteUsers" id="9956bcc2-8b59-4c85-a27d-4e85a3dbabe4">
        <source>deleteUsers();

vars
	user: CM_User;
	secRole: CM_SecurityRole;
	tmpObjs	: ObjectArray;
	tmpObj	: Object;
begin
	create tmpObjs transient;
	CM_User.allInstances(tmpObjs, 0, true);
	beginTransaction;
	foreach tmpObj in tmpObjs do
		user := tmpObj.CM_User;
		if user.code.toUpper.trimBlanks &lt;&gt; "SUPERUSER" and
		   user.code.toUpper.trimBlanks &lt;&gt; "ADMIN" and
		   user.code.toUpper.trimBlanks &lt;&gt; "BGPUSER" then
			delete user;
		endif;
	endforeach;
	commitTransaction;
	beginTransaction;
	foreach secRole in CM_SecurityRoleTerminal.instances do
		if secRole.name.toUpper.trimBlanks &lt;&gt; "ADMIN TERMINAL" then
			delete secRole;
		endif;
	endforeach;
	foreach secRole in CM_SecurityRoleSystem.instances do
		if secRole.name.toUpper.trimBlanks &lt;&gt; "ADMIN SYSTEM" then
			delete secRole;
		endif;
	endforeach;
	commitTransaction;	

epilog
	delete tmpObjs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSingleData" id="bf054e35-34d4-4695-aa47-865589426ff0">
        <source>doSingleData();
// ---------------------------------------------------------------------------
// Created:     18 March 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars
	dirName: String;
	theUser: CM_User;
	result: Boolean;
	deleteAll	: Boolean;
begin
	dirName := DIR_NAME;
	app.initialize;
	on Exception do handleException(exception);
	app.setPassBackExceptions(true, true);
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers[SUPERUSER_Str];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
	app.myPassport.warningsAcknowledged	:= true;
	if dirName = null then
		dirName := 'C:\temp\';
	elseif dirName[dirName.length] &lt;&gt; '\' then
		dirName := dirName &amp; '\';
	endif;
	
	deleteAll	:= false;	// true means choose to delete all existing objects first
	self.importObjects(CM_Commodity, dirName, 0, deleteAll);
	result := true;
epilog
	if result then
		write method.name&amp;" Completed.";
	else
		write method.name&amp;" Crashed.";
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="exportCMObjectData" id="a08a8a0e-f79b-4d90-8e18-f90d1fdd4bd9">
        <source>exportCMObjectData();
// ---------------------------------------------------------------------------
// Created:     18 March 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	dirName: String;
	tmpClass: Class;
	subs : ClassColl;
	fileFolder: FileFolder;
	result : Boolean;
	restart : Boolean;
begin
	dirName := DIR_NAME;

	if dirName = null then
		dirName := 'C:\temp\';
	elseif dirName[dirName.length] &lt;&gt; '\' then
		dirName := dirName &amp; '\';
	endif;
	create fileFolder transient;
	fileFolder.fileName := dirName;
	if not fileFolder.isAvailable then
		fileFolder.make();
	endif;
	if not fileFolder.isAvailable then
		write "cannot create folder requested";
		return;
	endif;	

	app.initialize();
	app.myCnCntrl.setExceptionHandlerType(0);

	create subs transient;
	CM_Object.allSubclasses(subs);
//	restart := true;
	foreach tmpClass in subs do
	write tmpClass.name&amp;' '&amp;tmpClass.instances.size.String;
		if tmpClass.instances.size = 0 then
			continue;
		endif;
		if tmpClass = CM_YADataObjects then
			restart := false;
			continue;
		endif;
		if restart then
			continue;
		endif;
		if not tmpClass = CM_EDIFile and
		   not tmpClass = CM_Terminal and
		   not tmpClass = CM_Root and
		   not tmpClass = CM_Locale and
//		   not tmpClass = CM_Debtor and
		   not tmpClass = CM_CamTaskHistory and
		   not tmpClass = CM_DataDumpExtractClass and
		   not tmpClass = CM_DataDumpExtractDef and
		   not tmpClass.firstInstance.isKindOf(CM_KPI) and
		   not tmpClass.firstInstance.isKindOf(CM_FinancialObject) and
		   not tmpClass.firstInstance.isKindOf(CM_Request) and
		   not tmpClass.firstInstance.isKindOf(CM_TITransaction) and
		   not tmpClass.firstInstance.isKindOf(CM_ActivityHistory) and
		   not tmpClass.firstInstance.isKindOf(CM_Bay) and
		   not tmpClass.firstInstance.isKindOf(CM_EDIData) and
		   not tmpClass.firstInstance.isKindOf(CM_EDITrackedItem) and
		   not tmpClass.firstInstance.isKindOf(CM_EDIData) and
		   not tmpClass.firstInstance.isKindOf(CM_Job) and
		   not tmpClass.firstInstance.isKindOf(CM_LocationsController) and
		   not tmpClass.firstInstance.isKindOf(CM_TrackedItem) and
		   not tmpClass.firstInstance.isKindOf(CM_CargoTypeAttribPlan) then
			self.exportObjects(tmpClass, dirName, true, true, 1000);
		else
			write "ignoring "&amp;tmpClass.name;
		endif;
	endforeach;
	self.exportObjects(CMIF_ConfigRoot, dirName, true, false, 0);
	self.exportObjects(CMIF_ConfigTerminal, dirName, true, false, 0);
	self.exportObjects(CMIF_ConfigOperator, dirName, true, false, 0);
	result := true;
epilog
	if result then
		write "Fin Successfully.";
	else
		write "Fin failure.";
	endif;
	delete subs;
	delete fileFolder;
end;</source>
    </JadeMethod>
    <JadeMethod name="exportCMObjectDataRestart" id="45e9792f-dbc9-4028-a50a-846c90ea64f4">
        <source>exportCMObjectDataRestart();
// ---------------------------------------------------------------------------
// Created:     18 March 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	dirName: String;
	tmpClass: Class;
	subs : ClassColl;
	fileFolder: FileFolder;
	restartClass : Class;
	stopSkip : Boolean;
	result: Boolean;
begin
	restartClass := CM_Voyage;
	dirName := DIR_NAME;

	if dirName = null then
		dirName := 'C:\temp\';
	elseif dirName[dirName.length] &lt;&gt; '\' then
		dirName := dirName &amp; '\';
	endif;
	create fileFolder transient;
	fileFolder.fileName := dirName;
	if not fileFolder.isAvailable then
		fileFolder.make();
	endif;
	if not fileFolder.isAvailable then
		write "cannot create folder requiested";
		return;
	endif;	

	app.initialize();
	app.myCnCntrl.setExceptionHandlerType(0);

	create subs transient;
	CM_Object.allSubclasses(subs);	
	foreach tmpClass in subs do
		if tmpClass = CM_YACriteria then
			stopSkip := true;
		endif;
		if stopSkip then
			self.exportObjects(tmpClass, dirName, true, true, 1000);
		endif;
	endforeach;
	self.exportObjects(CMIF_ConfigRoot, dirName, true, false, 0);
	self.exportObjects(CMIF_ConfigTerminal, dirName, true, false, 0);
	self.exportObjects(CMIF_ConfigOperator, dirName, true, false, 0);
	result := true;
epilog
	if result then
		write "Fin Successfully.";
	else
		write "Fin failure.";
	endif;
	delete subs;
	delete fileFolder;
end;</source>
    </JadeMethod>
    <JadeMethod name="exportConfigConstants" id="19cb06d7-a28f-4e02-a050-577ed92c519f">
        <source>exportConfigConstants(_file : File) protected;

vars
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;
	passport	: CM_Passport;
begin

	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory(ConfigConstants);
	constDict := category.getConstants();
	passport := app.myPassport;

	foreach const in constDict do
		_file.writeLine('&lt;'&amp;const.getName()&amp;"&gt;"&amp;app.myRoot.getConfig(const.getName()).String&amp;'&lt;/'&amp;const.getName()&amp;"&gt;");
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
