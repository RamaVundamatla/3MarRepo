<Class name="CMIF_JsonLoadEUP" id="0a649b03-490c-4893-9845-626c68f8599c">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="city" id="fb7e81fe-382f-4f16-a93f-d8af1a9b7cb9">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="country" id="85542dab-ccca-4da9-ade9-46ddc5e1d226">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="date" id="1bda15af-5dd9-433c-a523-c195eb7b3b92">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <PrimAttribute name="name" id="21054a47-5fb6-447d-b816-9df8f8fd2886">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="number" id="115d4e6d-e089-4287-8fee-8fbc8d638e1e">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="reference" id="eb39dffe-f61a-4169-942f-93b91ecb8dc3">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="street" id="861bede2-2a36-4c52-81b4-e5ca3a4e51d2">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="street2" id="85e9d198-6c05-4dd6-aece-d2c1f94747c2">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="zipcode" id="71a687ab-6717-4d4f-9621-1f8c94d09a07">
