    <JadeMethod name="releaseRequestTypeEnumToString" id="220e3317-1bef-44d5-afe9-cfd6bf76f4a3">
        <source>releaseRequestTypeEnumToString(_value :Integer):String;
/*
Date		Who		Reason
22 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	result	:String;
begin
	if _value = BR_TYPE_PACKING then
		result :=  BR_TYPE_PACKING_STR;		
		
	elseif _value = BR_TYPE_ROAD then
		result :=  BR_TYPE_ROAD_STR;						
		
	elseif _value = BR_TYPE_RAIL then
		result :=  BR_TYPE_RAIL_STR;						
		
	elseif _value = BR_TYPE_SHIP then
		result :=  BR_TYPE_SHIP_STR;						
		
	elseif _value = BR_TYPE_UNKNOWN then
		result :=  BR_TYPE_UNKNOWN_STR;
	
	else
		// hopefully does not happen
		result :=  "N/A";	
	endif;
	
	return result;
end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="releaseRequestTypeStringToEnum" id="34689053-d425-4ee4-8e95-b49786192094">
        <source>releaseRequestTypeStringToEnum( _value : String ) : Integer;

/*
Purpose:	This method takes the input string and attempts to match it to the appropriate string.
			If a matched is found then the Release Request Type integer is returned (else -1) and the
			input string is returned with the correct case.
			Currently (25/05/2010) for Release Requests the only valid Request Types are:
			Road, Rail, Ship and Packing.
			
Date			Who		Reason
25 May 2010		cnwrl1	Initial creation as part of PAR 24131 - EDI Release Request Type as translatable
21/11/2011		cnwcs5	CCMS POL 2122/ par 28696 -  new type called Unklnown.  Changed method to use BR_TYPE_ constants
													instead of TI_TRANSMODE_ constants
*/
	
vars
	value	: String;
	
begin
	value	:= _value.properCase();
	
	// Attempt to match in the most like order?
	if value = BR_TYPE_ROAD_STR then
		
		return BR_TYPE_ROAD;
	endif;
	
	if value = BR_TYPE_RAIL_STR then
	
		return BR_TYPE_RAIL;
	endif;
	
	if value = BR_TYPE_SHIP_STR then
	
		return BR_TYPE_SHIP;
	endif;
	
	if value = BR_TYPE_PACKING_STR then
		return BR_TYPE_PACKING;
	endif;
	
	if value = BR_TYPE_UNKNOWN_STR then

		return BR_TYPE_UNKNOWN;
	endif;
	
	return BR_TYPE_INVALID;			// ie -1
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
