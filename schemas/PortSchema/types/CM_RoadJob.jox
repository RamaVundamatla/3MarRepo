    <JadeMethod name="vehicleStillOnSite" id="b02c72a0-93df-4eeb-b61b-a015853be581">
        <source>vehicleStillOnSite() : Boolean;
/*

Purpose:			Checks if this vehicle still has other jobs that it is involved with. If so it
					will still remain on site after this job is erased

Parameters:			None

Return Value:		True if the Vehicle attached to this job has other jobs linked

Date		Who		Reason
22 Jan 2018	jlgkpd1	TFS 36660 - Locking issues at Penn
	
*/

vars
	job 			: CM_RoadJob;
	iter			: Iterator;
	
begin
	// TFS 36660 - change to use inversed collection on myVehicle, instead of searching all
	// current Road Jobs
	if self.myVehicle &lt;&gt; null then
		iter := self.myVehicle.allRoadJobs.createIterator();
		while iter.next(job) do 
			if job &lt;&gt; self then
				return true;
			endif;	
		endwhile;
	endif;	

	return false;
	
epilog
	delete iter;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
