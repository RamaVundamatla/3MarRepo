    <JadeMethod name="initialiseTable" id="af2780ca-55e9-4628-8f11-a59552316ed5">
        <source>initialiseTable();
/*
Purpose:			

Date		Who		Reason
18 October 2021	navab1	TFS 51853
*/

vars

	table : CM_Table;
begin
	table := self.tblMain;
	
	table.selectMode	:= Table.SelectMode_CurrentRow;
	
	
	table.columns := 9;
	table.rows := 0;
	
	table.addItem("Count" &amp; Tab &amp; "Class" &amp; Tab &amp; "Heading" &amp; Tab &amp; "Icon" &amp; Tab &amp;  "Pic Up" &amp; Tab &amp;  "Pic Down" &amp; Tab &amp; "Icon" &amp; Tab &amp;  "Pic Up" &amp; Tab &amp;  "Pic Down");
	table.fixedRows := 1;


epilog

end;</source>
    </JadeMethod>
