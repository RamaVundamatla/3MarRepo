//	self.assertIsDeleted(booking);
/*	coparnInput := self.zCoparnFileHLL("12", null);
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"2"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);

	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 2);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	prenote := self.getTrackedItem(Prenote1);
	self.assertNotNull(prenote);
	
	release := self.getReleaseRequest(BookingNo);
	self.assertNotNull(release);
	
	prenote := self.getTrackedItem(Prenote1);
	self.deleteTrackedItem(prenote, true);
	prenote := self.getTrackedItem(Prenote1);
	self.assertIsDeleted(prenote);
	coparnInput := self.zCoparnFileHLL("27", Prenote1);
	ediFile	:=	self.ediLoadFileName(coparnInput, EDIFileType_Unknown, "COPARN", USER_DEF_NAME&amp;"3"&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.ediVerify(ediFile);
	errorMsg :=	"Verify failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertIsOneOf(	ediFile.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	errorMsg :=	"Load failed with - " &amp; app.myPassport.getErrorsAsString();
	self.assertTrueMsg(ediFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
*/
//	self.assertEqual(ediFile.ediData.allEDITrackedItems.size, 2);
	if ediFile.ediData.isKindOf(CM_EDIDataBooking) then
		return;
	endif;
	release := self.getReleaseRequest(BookingNo);
	self.assertNotNull(release);
//	self.assertEqual(release.myBookingRefStock.code, BookingNo);
	self.assertEqual(release.myVoyage.code, Voyage_Code);
//	self.assertEqual(release.vesselCode, VesselCode);
	self.assertEqual(release.myOperator.code, "MSK");
	
//	prenote := self.getTrackedItem(Prenote1);
//	self.assertNotNull(prenote);
//	self.assertEqual(prenote.bookingReference, BookingNo);
//	self.assertEqual(prenote.voyageCode, Voyage_Code);
//	self.assertEqual(prenote.vesselCode, VesselCode);
//	self.assertEqual(prenote.operatorCode, "HLL");
epilog
	self.deleteEDIInwardXlation("EST", XLATION_TYPE_OPERATOR, null, null);
	self.deleteEDIOutwardXlationFCode("EST", XLATION_TYPE_OPERATOR, null, null);
end;</source>
