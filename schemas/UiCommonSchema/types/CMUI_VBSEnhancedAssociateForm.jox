    <JadeMethod name="populateBookings" id="ab430f3c-c3d0-4d40-8abd-67a07075fc88">
        <source>populateBookings();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2025	navlc30	Initial creation
04 Apr 2025 navlc30 JIRA 34266 TPT | FR 33661.040 VBS - One Release Request and Multiple VBS - On Schedule
07 Apr 2025	navnk30	JIRA 34267: TPT | FR 33661.050 VBS - One Release Request and Multiple VBS Appointments ? Off Schedule
*/

vars
	allVbsOnSch,
	allVbsOffSch	: CM_VehicleBookingByTs;
begin
	create allVbsOffSch transient;
	create allVbsOnSch transient;
	self.myReleaseRequest.getAllVbsOnSchedule(allVbsOnSch, self.myVehicleVisitRecord, false);
	self.myReleaseRequest.getAllVbsOffSchedule(allVbsOffSch, self.myVehicleVisitRecord, false);
	
	self.tblBookings.clearAllData();
	if allVbsOnSch.isNotEmpty() then
		self.tblBookings.displayRowsForCollection(allVbsOnSch, self.colorRow1, self.colorRow2, app.myPassport);
	else
		self.tblBookings.displayRowsForCollection(allVbsOffSch, self.colorRow1, self.colorRow2, app.myPassport);
	endif;
epilog

end;</source>
    </JadeMethod>
