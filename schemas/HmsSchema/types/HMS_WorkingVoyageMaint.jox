    <JadeMethod name="check_PreferredBerth" id="c0e6df6c-00f5-4a15-af25-7d61046786b0">
        <updating/>
        <source>check_PreferredBerth(_validateDT : Boolean):Boolean updating;

// 10/12/2014  cnwdb2	PAR 35364

vars
 	arrvToBerthPref:	HMS_BerthPreference;
 	arrvBerth:			HMS_Berth;
 	arrvMove:			CMIF_HMS_WorkingMovement;
 	deptMove:			CMIF_HMS_WorkingMovement;
 	arrivedDT:			TimeStamp;
 	departedDT:			TimeStamp;
 	loa: 				Decimal[6,2];
 	msgBoxType:			Integer;
 	msgString:			String;
 	autoPosition:		Boolean;
	arrivedLocal,
	departedLocal:		TimeStamp;
begin

	if self.myHarbour.defaultDepartBerth = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Default Departure Berth not found', 'Set the Default Departure Berth for Harbour and try again.', null, null);
		return false;	
	endif;
	// Modified by Russell 16/03/99
	// ------------------------------------------------------------------------------------------------
	// Check that the departed date is after the arrived date
// cnwdad1 17/06/2009 - PAR #19942.
//	arrivedDT := (txtDateArrival.text &amp; ", " &amp; txtTimeArrival.getTime().roundToNearestMinute.String).TimeStamp;
//	departedDT := (txtDateDepart.text &amp; ", " &amp; txtTimeDepart.getTime().roundToNearestMinute.String).TimeStamp;
	arrivedLocal.setDate(txtDateArrival.text.asDateJMT());
	arrivedLocal.setTime(txtTimeArrival.getTime().roundToNearestMinute());
	arrivedDT := self.localToSystemTime(arrivedLocal);
	departedLocal.setDate(txtDateDepart.text.asDateJMT());		// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
	departedLocal.setTime(txtTimeDepart.getTime().roundToNearestMinute());
	departedDT := self.localToSystemTime(departedLocal);

	if _validateDT
	and arrivedDT &gt;= departedDT then
		// Display error message - the arrived date must be before the departed date
		fldVoyageMaint.topSheet := shtMovements;
		txtDateArrival.setFocus;
		app.raiseCMException2(HMSMovementDateTime, HMSMovementTypeArrival, 'before', null, null);
		return false;		
	endif;
	// ------------------------------------------------------------------------------------------------

	if myCurrentWorkingVoyage = null then
		return false;
	endif;

	if cbxPrefBerth.listIndex &gt; 0 and optPrefBerth.value = true then
		arrvToBerthPref := cbxPrefBerth.listObject.HMS_BerthPreference;
		arrvBerth := arrvToBerthPref.getMyBerth;
		arrvMove := self.myCurrentWorkingVoyage.allClonedMovements.first.CMIF_HMS_WorkingMovement;
		arrvMove.myBerth := arrvBerth;
		arrvMove.setBerthMark(arrvToBerthPref.defaultBowMark, arrvToBerthPref.defaultSternMark, arrvToBerthPref.orientation, arrvMove.foreClearanceTo, arrvMove.aftClearanceTo); 
		// PAR 10805 - check and correct the stern
		arrvMove.clonedMove_CalcSternPosn();				
		autoPosition := false;
	else
		arrvBerth := cbxOtherBerth.listObject.HMS_Berth;
		if arrvBerth = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Arrival Berth', null, null);
			app.raiseCMException(Input_required_field_arivlBrth, null, null); // cnwdb2	PAR 35364

			return false;
		endif;						
		arrvMove := myCurrentWorkingVoyage.allClonedMovements.first.CMIF_HMS_WorkingMovement;
		arrvMove.myBerth := arrvBerth;
		arrvMove.setBerthMark(arrvMove.bowMarkTo, arrvMove.sternMarkTo, OrientPortSideTo, arrvMove.foreClearanceTo, arrvMove.aftClearanceTo); 		
		// Centre ship on berth
		arrvMove.clonedMove_CentreShip(myCurrentWorkingVoyage.myHMSVoyageData.dim_LengthOverall);
		//Berth may hve changed if vessel couldn't fit on selected berth
		self.cbxOtherBerth.listIndex := cbxOtherBerth.findObject(arrvMove.myBerth);		
		autoPosition := true;
	endif;
	
	deptMove := myCurrentWorkingVoyage.allClonedMovements.last.CMIF_HMS_WorkingMovement;
	deptMove.myBerth := self.myHarbour.defaultDepartBerth;

	//deptMove.vesselName:=selectedVoyage.ofVessel.name;
	// Set movement arrival and departure dates
	deptMove.setInitialiseValues(deptMove.isAgentDefault, myCurrentWorkingVoyage.departedDT, deptMove.moveType);
	arrvMove.setInitialiseValues(arrvMove.isAgentDefault, myCurrentWorkingVoyage.arrivedDT, arrvMove.moveType);
	
	if self.myCurrentWorkingVoyage.myHMSVoyageData.isTransient then
		self.myCurrentWorkingVoyage.myHMSVoyageData.setMyBerth(arrvMove.myBerth);
	endif;
	// Check arrvMove 
	if (not arrvMove.isLogicalBerth()) then
		// Modified by Russell 14/05/99
		// Only check clearances for physical wharves
		if (not arrvMove.check_Clearances(autoPosition, arrvMove.raiseClearanceWarnings())) then
			// Set arrv berth to default berth
			arrvMove.myBerth := self.myHarbour.defaultArrvBerth;
			if arrvMove.myBerth &lt;&gt; null then
				cbxOtherBerth.listIndex := cbxOtherBerth.findObject(arrvMove.myBerth);
				cbxOtherBerth.text := cbxOtherBerth.itemText[cbxOtherBerth.listIndex];
			endif;
			arrvMove.setBerthMark(0, 0, arrvMove.sideTo, arrvMove.foreClearanceTo, arrvMove.aftClearanceTo);
	 		arrvMove.clonedMove_CalcSternPosn();					
			optPrefBerth.value := false;
 			cbxPrefBerth.enabled := false;
 			optOtherBerth.value := true;
 			cbxOtherBerth.enabled := true;
 			return false;
 		else
 			return true;
		endif;
	else
 		return true;
	endif;

end;</source>
        <Parameter name="_validateDT" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
