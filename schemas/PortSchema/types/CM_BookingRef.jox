        <source>getTranshipTIsForRoll(_tis : CM_TISet input; _voyage : CM_Voyage);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2018	jlgrh7	Initial creation TFS38548
31 AUG 2018	jlgab1	TFS 40417 Pass in voyage so can be called in TRX after the voyage has changed on the booking

*/

vars
	realTi : CM_TrackedItem;
begin
// TFS 40417	if self.myVoyage &lt;&gt; null then
// TFS 40417		foreach realTi in self.myVoyage.allTranshipTIsExport where  realTi. isTranshipOnInboundVoyage do
	if _voyage &lt;&gt; null then
		foreach realTi in _voyage.allTranshipTIsExport where  realTi. isTranshipOnInboundVoyage do
			if realTi.myTranshipDetail.exportBookingReference = self.bookingReference then
				_tis.addNoDuplicates(realTi,false);
			endif;
		endforeach;
	endif;
epilog

end;</source>
