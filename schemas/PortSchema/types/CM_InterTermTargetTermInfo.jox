<Class name="CM_InterTermTargetTermInfo" id="1a019449-1314-4347-aafd-72b887072926">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="InterTermMove"/>
    <PrimAttribute name="autoPlanAtDestTerminal" id="908b5182-b8e0-4783-8996-3195742bf910">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myDefaultTargetTermArea" id="3ac0b290-a7e4-42b3-b4c1-d0719e94c213">
        <embedded/>
        <type name="CM_TerminalArea"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myTargetTerminal" id="818cc05b-a04b-45ed-95f0-9d1e2f1ef088">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
