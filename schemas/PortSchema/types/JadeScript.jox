			typeLoadPort.setPropertyValue(CM_YATypeLoadPort::type.name, YACriteriaType_LoadPort);
		endforeach; 
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="vbsChange" id="69d710bf-4d0a-400a-b707-93ce7aace7c0">
        <source>vbsChange();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2023	navhl2	Initial creation

*/

vars
    vbts : CM_VehicleBookingTimeSlot;
    vbtsi : CM_VehicleBookingTimeSlotItem;
    terminal : CM_Terminal;
    vbt : CM_VehicleBookingTerminal;
begin
    terminal := app.myRoot.allTerminals["JBL"];
    vbt := terminal.myVehicleBookingTerminal;
    beginTransaction;
    foreach vbts in vbt.allVBTimeslotsById do
        if vbts.myCarrier &lt;&gt; null and not global.isValidObject(vbts.myCarrier) then
            delete vbts;
			continue;
        endif;
		
		if vbts.myVehicle &lt;&gt; null and not global.isValidObject(vbts.myVehicle) then
            delete vbts;
			continue;
        endif;
        
        foreach vbtsi in vbts.allVehicleBookingItems do
            if vbtsi.myTrackedItem &lt;&gt; null and not global.isValidObject(vbtsi.myTrackedItem) then
                delete vbts;
				break;
            endif;
        endforeach;
    endforeach;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="workorder" id="d8414f77-605c-4a2e-86fd-69494885af53">
        <source>workorder();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023	navhl20	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
*/

vars
	wod			: CM_WorkOrderDtl;
	booking		: CM_BookingRef;
	term		: CM_Terminal;
	workOrder	: CM_WorkOrder;
begin
	beginTransaction;
	foreach term in app.myRoot.allTerminals do 
		foreach workOrder in term.allWorkOrders do
			if not workOrder.isKindOf(CM_WorkOrderTI) then
				continue;
			endif;
			foreach wod in workOrder.allWoDtls do
				if not wod.isKindOf(CM_WodRelease) then
					continue;
				endif;
				
				if wod.CM_WodRelease.exportBookingNumber = null then
					continue;
				endif;
				
				booking := term.allBookingRefsByRef[wod.CM_WodRelease.exportBookingNumber];
				if booking &lt;&gt; null then
					wod.CM_WodRelease.setBooking(booking);
				endif;
			endforeach;
		endforeach;
	endforeach;
	/*foreach wod in CM_WodRelease.instances do
		if wod.exportBookingNumber &lt;&gt; null then
			write wod.exportBookingNumber &amp;Space&amp; wod.myBookingRef.bookingReference &amp;Space&amp; wod.myBookingRefItem.description;
		endif;
	endforeach;*/
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
</Class>
