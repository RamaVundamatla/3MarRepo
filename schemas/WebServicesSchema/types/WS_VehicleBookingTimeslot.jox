<Class name="WS_VehicleBookingTimeslot" id="b910dc38-ba42-4815-bad7-dbb8baa8737c">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Booking for a Vehicle to access the Port, including some detail of the anticipated activity that will occur during the appointment.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="allBookingIds" id="3f3b72f4-d8b5-4530-be90-3db9ce843001">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="allBulkReleaseIds" id="cdfb5400-941c-4643-8eee-e91f49fbe84d">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="allDeliveryTiIds" id="0fd28a8d-cb0f-4737-b4e6-7240c9cf0a87">
        <type name="String"/>
        <access>readonly</access>
        <text>The list of JMT known 'pre-noted' cargo items being delivered.</text>
    </PrimAttribute>
    <PrimAttribute name="allPuTiIds" id="35929bd9-69a1-42be-9f6b-d7ab00317ef1">
        <type name="String"/>
        <access>readonly</access>
        <text>The list of JMT known cargo items being picked up.</text>
    </PrimAttribute>
    <PrimAttribute name="arrivedString" id="1203253d-bc8f-4055-83ed-5f9e633413fe">
        <type name="String"/>
        <access>readonly</access>
        <text>Actual arrival date.</text>
    </PrimAttribute>
    <PrimAttribute name="bookingDateEnd" id="4002821c-035b-4d80-8284-f13e4f8f3ab4">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The date that the 'appointment' ends on.</text>
    </PrimAttribute>
    <PrimAttribute name="bookingDateStart" id="8daaed13-55fb-467e-8154-4cd8925d3577">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The date that the 'appointment' starts on. I.e. The date that the truck is expected to arrive.</text>
    </PrimAttribute>
    <PrimAttribute name="bookingTimeEnd" id="a47981e6-056a-45cc-b203-d1f7a38549f3">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The time within the 'bookingDateEnd' day that the 'appointment' ends. I.e. The latest time that the truck is expected to arrive.</text>
    </PrimAttribute>
    <PrimAttribute name="bookingTimeStart" id="5a74160d-ec2a-4e8b-8083-590fdd5926c5">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The time within the 'bookingDateStart' day that the 'appointment' starts. I.e. The earliest time that the truck is expected to arrive.</text>
    </PrimAttribute>
    <ImplicitInverseRef name="carrier" id="011a31d5-76cc-4a95-ae33-ce17ae008b83">
        <embedded/>
        <type name="WS_Carrier"/>
        <access>readonly</access>
        <text>The carrier that the booking belongs to.</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="driver" id="bb5b9bbb-9cd6-4977-bf62-1ff48b0c0604">
        <embedded/>
        <type name="WS_Driver"/>
        <access>readonly</access>
        <text>If populated, the expected driver of the truck.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="id" id="2e347a95-d406-463a-8706-7817cfe922db">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Unique VBS ID.</text>
    </PrimAttribute>
    <PrimAttribute name="includesDelivery" id="c113d21d-a564-4762-a493-51a3f11cf1c6">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Whether the visit is expected to include cargo being delivered to the terminal.</text>
    </PrimAttribute>
    <PrimAttribute name="includesPickup" id="d4f41117-a420-49b6-b2f7-2ffb5a6df861">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Whether the visit is expected to pick up cargo to take from the terminal.</text>
    </PrimAttribute>
    <PrimAttribute name="remarks" id="0fd109d9-dc97-45d4-bd01-101005a5ceb7">
        <type name="String"/>
        <access>readonly</access>
        <text>General comments about the booking, and Cargo Ids entered via the Web that were not known to JMT at the time of entry.</text>
    </PrimAttribute>
    <PrimAttribute name="statusString" id="4fb54782-b1ff-47e2-be64-29f48fc98442">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="timeSlotTypeString" id="eaa65dcf-9459-4136-b6c8-959e36057fd9">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="vbTimeSlotType" id="65b45599-b569-4885-a562-f88b1c0c5423">
        <embedded/>
        <type name="WS_VehicleBookingTimeSlotType"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="vehicle" id="dfbc0905-0b80-4f0f-986b-5506d17226d0">
        <embedded/>
        <type name="WS_Vehicle"/>
        <access>readonly</access>
        <text>If populated, the expected truck.</text>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="63430684-fda6-480d-95f1-a8bc7cd7849d">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	delete self.carrier;
	delete self.driver;
	delete self.vehicle;
	delete self.vbTimeSlotType;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="98fbecc7-3e44-4443-a962-769f417cf638">
        <updating/>
        <source>setProxyFromObject( _bookingTS: CM_VehicleBookingTimeSlot ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2013	cnwndl1	Initial creation	Par 31393
06 May 2021 navma1 ChangeRequest 51051: PRP - WebPortal VBS - Driver and Vehicle fields rework 
*/

vars

	booking : CM_BookingRef;
	bulkRel : CM_BulkRelease;
	
	wsBooking : WS_Booking;
	wsBulkRel : WS_BulkRelease;

begin

	inheritMethod( _bookingTS );
	
	self.allDeliveryTiIds := _bookingTS.getDeliveryIds(",");
	self.allPuTiIds := _bookingTS.getPickUpIds(",");
	
	self.bookingDateEnd := _bookingTS.bookingTSend.asStringForWebInterface();
	self.bookingDateStart := _bookingTS.bookingTSstart.asStringForWebInterface();
	self.bookingTimeEnd := _bookingTS.bookingTSend.asStringForWebInterface();
	self.bookingTimeStart := _bookingTS.bookingTSstart.asStringForWebInterface();
	
	if _bookingTS.myCarrier &lt;&gt; null then
		create self.carrier transient;
		self.carrier.setProxyFromObject(_bookingTS.myCarrier);
	endif;
	
	if _bookingTS.myDriver &lt;&gt; null then
		create self.driver transient;
		//self.driver.setProxyFromObject(_bookingTS.myDriver);  		//navma1 20.05.2021 Temp #51051
		self.driver.setProxyFromObjDriverOnly(_bookingTS.myDriver);     //navma1 20.05.2021 Temp #51051
	endif;
	
	if _bookingTS.myVehicle &lt;&gt; null then
		create self.vehicle transient;
		self.vehicle.setProxyFromObject(_bookingTS.myVehicle);
	endif;
	
	//cnwmc5 - PAR 32206 - 5 Sep 2013
	//self.includesDelivery := app.getYesNo(_bookingTS.includesDelivery);
	//self.includesPickup := app.getYesNo(_bookingTS.includesPickUp);
	self.includesDelivery := _bookingTS.includesDelivery.String;
	self.includesPickup := _bookingTS.includesPickUp.String;
	self.remarks := _bookingTS.remarks;
	
	//24 Oct 2014	NDL	Par 35008
	self.id := _bookingTS.id;
	
	if _bookingTS.myVBTimeSlotType &lt;&gt; null then
		create self.vbTimeSlotType transient;
		self.vbTimeSlotType.setProxyFromObject(_bookingTS.myVBTimeSlotType);
		self.timeSlotTypeString := self.vbTimeSlotType.comboboxDescription;		//cnwmc5 - 31 Oct 2014 - PAR 35008
	else 																		//cnwmc5 - 31 Oct 2014 - PAR 35008
		self.timeSlotTypeString := app.getErrorString(None);					//cnwmc5 - 31 Oct 2014 - PAR 35008
	endif;
	
	//cnwmc5 - 29 Oct 2014 - PAR 35008
	self.allBookingIds := _bookingTS.getBookingRefIdsAsString();
	self.allBulkReleaseIds := _bookingTS.getReleaseIdsAsString();
	
	//cnwmc5 - 31 Oct 2014 - PAR 35008
	self.statusString := _bookingTS.getStatusString();
	self.arrivedString := _bookingTS.getDisplayStringForAttribute(ETRow_Arrived, false);

epilog

end;</source>
        <Parameter name="_bookingTS" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
</Class>
