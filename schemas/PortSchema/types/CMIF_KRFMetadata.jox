<Class name="CMIF_KRFMetadata" id="c5fb5196-00d7-489b-a78b-bd472086c743">
    <superclass name="CMIF_KRFWSProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="credentials" id="c0c09bdc-8106-4943-ae07-8afbdc2d1c50">
        <embedded/>
        <type name="CMIF_KRFCredentials"/>
    </ImplicitInverseRef>
    <PrimAttribute name="replyOrganisation" id="d007986d-965f-4c65-b8f2-c96494682663">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="requestID" id="e1082f37-7205-49da-acfc-76f702ceee38">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="requestOrganisation" id="0ee6acb7-4cb5-4de4-8f02-f561ce16a005">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="responseID" id="5e938bdb-62dc-4c61-bd6f-40036e3d281d">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="timestamp" id="7084e24f-903c-4d77-9aa7-de541d78d873">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <JadeMethod name="copyToRealWSObject" id="0e94ba05-26e7-4bb2-9b46-162cf643a35d">
        <source>copyToRealWSObject(_realRequest: KRF_Metadata input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Feb 2019	jlgsl4	TFS 40360 - KiwiRail EDI message

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.replyOrganisation := self.replyOrganisation;
	_realRequest.requestID := self.requestID;
	_realRequest.requestOrganisation := self.requestOrganisation;
	_realRequest.responseID := self.responseID;
	_realRequest.timestamp := self.timestamp;
	
	// manual population of credentials required
	create _realRequest.credentials transient;
	_createdObjects.add(_realRequest.credentials);
	credentials.copyToRealWSObject(_realRequest.credentials, _createdObjects);
epilog

end;</source>
        <Parameter name="_realRequest" type="KRF_Metadata" usage="input"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCredentials" id="02e49236-db1c-44b0-9481-a4c7416fe003">
        <updating/>
        <source>setCredentials(_credentials : CMIF_KRFCredentials) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
*/

vars

begin
	self.credentials := _credentials;
epilog

end;</source>
        <Parameter name="_credentials" type="CMIF_KRFCredentials"/>
    </JadeMethod>
    <JadeMethod name="setFromWSDef" id="250d90ff-aeca-4d8d-a20e-765296c3afd4">
        <updating/>
        <source>setFromWSDef(_wsDefinition : CM_KiwiRailCheckInWSDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2019	jlgsl4	TFS 40360 - NXL - KIwiRail EDI message
*/

vars
	timeStamp : TimeStamp;
begin
	self.timestamp := timeStamp.localToUTCTime(); // current time GMT/UTC
	self.requestOrganisation := _wsDefinition.requestOrganisation;
	self.replyOrganisation := _wsDefinition.replyOrganisation;
epilog

end;</source>
        <Parameter name="_wsDefinition" type="CM_KiwiRailCheckInWSDef"/>
    </JadeMethod>
    <JadeMethod name="setRequestResponseID" id="dafad9b3-8953-4dbc-ad53-e87fb674834c">
        <updating/>
        <source>setRequestResponseID(_container : CM_Container) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
*/

vars
	timedate : TimeStamp;
	minSec : String;
begin
	minSec := timedate.String; // get minutes and seconds to make requ/resp 'unique'
	minSec := minSec[minSec.length - 4 : 2] &amp; minSec[minSec.length - 1 : 2];
	self.requestID := "REQ" &amp; minSec &amp; "_" &amp; _container.id;
	self.responseID := "RSP" &amp; minSec &amp; "_" &amp; _container.id;	
epilog

end;</source>
        <Parameter name="_container" type="CM_Container"/>
    </JadeMethod>
</Class>
