    <JadeMethod name="setProxyFromObject" id="b25ca1d7-afaa-465e-b841-049b4bbf3461">
        <updating/>
        <source>setProxyFromObject(_object: CM_WodHMSRequestCancel) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlger1	Initial creation

*/

vars

begin
	inheritMethod(_object);
	if _object.myWorkOrderToCancel &lt;&gt; null then
		self.cancelWorkOrderOid := _object.myWorkOrderToCancel.getOidAsString;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_WodHMSRequestCancel"/>
    </JadeMethod>
    <JadeMethod name="updateProxyWorkOrder" id="dfdf700c-4bf5-4028-b509-f4d9da1416b8">
        <source>updateProxyWorkOrder(_pxyWorkOrder: CM_WodHMSRequestCancel input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2018	jlger1	Initial creation

*/

vars
	workOrder : CM_WorkOrder;
begin
	inheritMethod(_pxyWorkOrder);
	
	if self.cancelWorkOrderOid &lt;&gt; null then
		workOrder := app.myPassport.getObjectOfTypeFromOid(self.cancelWorkOrderOid,CM_WorkOrder).CM_WorkOrder;
		if workOrder &lt;&gt; null then
			_pxyWorkOrder.setProxyWodHMSRequestCancel(workOrder);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_pxyWorkOrder" type="CM_WodHMSRequestCancel" usage="input"/>
    </JadeMethod>
</Class>
