    <JadeMethod name="isAssignedAnyAmountTrue" id="069d13e4-cede-4609-b51c-f6a8bb525136">
        <source>isAssignedAnyAmountTrue(assignedAnyAmount:String) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Dec 2022	navra1	Initial creation
28 Nov 2024 navma1	MTN-19124 STWO - Uploading an EDI file 'freezes' MTN.
*/

vars
	assignedAnyAmountUpper : String;
begin
	
	assignedAnyAmountUpper := assignedAnyAmount.toUpper();		//28.11.2024 navma1 #MTN-19124
	
	if assignedAnyAmountUpper  = "TRUE" or 
		assignedAnyAmountUpper = "T"    or 
		assignedAnyAmountUpper = "YES"  or 
		assignedAnyAmountUpper = "Y" 	or 			
		assignedAnyAmountUpper = "1" 	then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <Parameter name="assignedAnyAmount" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b8b087e0-e89e-4c56-a500-666ca6b9a326">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/12/2022	navdap1		Initial creation TFS 55617 EUP EDI for Assigning Rleases to Wagons
//
vars
	prop : Property;
	propDict : PropertyNDict;
begin
	inheritMethod(_proxyEDITI);
	
	propDict := self.class.getProperties;
	foreach prop in propDict do
		if self.canUserSet(prop.name) then
			// bypass all type integrity checking in the name of convenience!!!
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
</Class>
