        <updating/>
        <source>tblQEntries_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Date		Who		Reason
17 September 2014	cnwer1	Initial creation PAR

*/

vars
	row : Integer;
begin

	// TFS 52945 NAVCS2 22/03/2022
	if not self.canMaintainRTQueue then
		return;
	endif;

	if not app.dragDetected(x, y, self.origXPos, self.origYPos) then
		return;
	endif;
	if button = Window.MouseButton_Left then
		//epr par 36138 30/4/15
		row:= table.row;
		if row &lt;= table.rows then
			self.myFromListObject := table.accessRow(row).itemObject;
		endif;
		if self.myFromListObject &lt;&gt; null then
			table.dragCursor := self.picEntryIco.picture;
			table.dragMode := DragMode_Drag;
		else
			table.dragMode := DragMode_None;
		endif;
	else
		table.dragMode := DragMode_None;
	endif;
epilog

end;</source>
