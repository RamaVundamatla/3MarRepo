    <JadeMethod name="doManualOverstowMove" id="b24b6319-32e9-4302-9680-b3a66e8c5d0a">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::doManualOverstowMove"/>
        </interfaceImplements>
        <updating/>
        <source>doManualOverstowMove(_allOSTIs : CM_TIArray input) updating;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwer1	Initial creation
23 Feb 2010 cnwer1	PAR 28126
*/

vars
	ti : CM_TrackedItem;
begin

	if _allOSTIs = null or _allOSTIs.size = 0 then
		self.isShowOverstowCargo:=false;
		return;
	endif;
	
	self.isShowOverstowCargo:=true;
	
	self.setupFrmMoveFields(null,null);
	self.frmMove.visible:=true;
	self.frmTaskTable.visible:=false;
	self.frmGetTask.visible:=false;
	self.frmGraphic.visible:=true;
	//self.frmMoveEntry.visible:=true;
	self.frmDirector.visible:=true;
	self.frmMoveTbl.visible:=false;
	ti:=app.myVMAgent.currentOverstowedTask.ti;
	self.frmDirector.caption:=app.getErrorString1(Cargo_overstowing,ti.id);
	self.loadEnquiryCargo(self.tblDirector,_allOSTIs);
	if  app.myVMAgent.currentAccessDirection &lt;&gt; null then
		self.lblMode.visible:=true;
		self.lblMode.caption:=app.getErrorString(Access_direction);
		self.grpAccessDir.visible:=true;

		//15 Feb 2012	NDL	Par 28205
		if ti.myPrimaryActualLocation &lt;&gt; null then
			self.setAccessDirBtnNames( ti.myPrimaryActualLocation.myTerminalArea );
		endif;
		
		if app.myVMAgent.currentAccessDirection = CM_YABlock.SideAccess_Front then
			self.btnAccessFront.value:=true;
		else
			self.btnAccessBack.value:=true;
		endif;
	endif;
	if app.myVMAgent.doesSeperatePickupSetdown then
		self.btnAccept.caption:=app.getErrorString(Pickup);
	else
		self.btnAccept.caption:=app.getErrorString(Move);
	endif;
		
	
epilog

end;</source>
        <Parameter name="_allOSTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveEnquiryCargo" id="91f78599-81db-48e1-adb2-22b21ab5623b">
        <updating/>
        <source>doMoveEnquiryCargo() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwer1	Initial creation
23 Feb 2010 cnwer1	PAR 28126
*/

vars
	theAcceptedRow : Integer;
	allTIs 			: CM_TIArray;
	acceptedTI		: CM_TrackedItem;
	toLoc			: CM_LocationsController;
	allTasks		: CM_RTQueueTaskArray;
begin
	if self.frmTaskTable.visible then
		//accept selected tasks
		theAcceptedRow:=0;
		//nothing to check
		if self.tblTasks.rows =  self.tblTasks.fixedRows then 
			return;
		endif;
		theAcceptedRow:=self.tblTasks.row;
	
		acceptedTI := self.tblTasks.accessRow(theAcceptedRow).itemObject.CM_TrackedItem;
		 		
		self.setupFrmMoveForTI(acceptedTI);
		//epr par 25047 19/7/10
		self.btnGraphic.click(self.btnGraphic);
	elseif self.hasWorkingTask() then

		if self.isShowOverstowCargo and self.frmDirector.visible then
			acceptedTI:=self.tblDirector.accessRow(tblDirector.row).itemObject.CM_TrackedItem;
		else
			acceptedTI:=self.getNonRTMoveCargo();
		endif;		
	
		if acceptedTI = null then
			self.addInfoDisplay(app.getErrorString(Please_select_cargo_itemPOP));
			return;
		endif;
		app.myVMAgent.doMoveTI(self.getSetdownLocID,acceptedTI);
		if not app.myPassport.trxCompletedOK then
			return;
		endif;
		toLoc:=	app.myVMAgent.findLocationFromString( self.getSetdownLocID);
		
		//epr par 31915 6/1/14
		if self.myMachine.myMachineController.allTrackedItems.size = 0 then		
			if self.isShowOverstowCargo then
				
				if app.myVMAgent.currentOverstowedTask &lt;&gt; null then
					create allTasks transient;
					app.myVMAgent.allOverstowedTasks.copy(allTasks);
					app.myVMAgent.doAcceptTasks(allTasks,app.myVMAgent.currentAccessDirection,allTasks.size &gt; 1,null);
				endif;
				
				if app.myVMAgent.currentOverstowedTask &lt;&gt; null and
					 self.myMachine.currentQueueTask = null then
					return;
				endif;
				
				self.isShowOverstowCargo:=false;
				if app.myPassport.hasErrorsOrNonIgnoredWarnings then
					self.doMoveFramesRefresh();
					return;
				endif;
			endif;
			
			
			self.goToTaskFrame();
			self.setupTasksTable();
			self.doResetSearch();
			self.btnAccept.caption:= app.getErrorString(Accept);
		else
			if self.isShowOverstowCargo then 
				self.setupFrmMoveFields(acceptedTI,null);
				create allTIs transient;
				allTIs.add(acceptedTI);
				self.loadEnquiryCargo(self.tblMoveInfo,allTIs);
			endif;
			//epr par 31915 6/1/14 if breakbulk cargo and split onto the machine will be a different ti reload the ti info
			if self.myMachine.myMachineController.allTrackedItems.first &lt;&gt; acceptedTI then
				self.setupFrmMoveForTI(self.myMachine.myMachineController.allTrackedItems.first);
			endif;
			self.btnAccept.caption:= app.getErrorString(Setdown);
		endif;
	endif;

epilog
	delete allTIs;
	delete allTasks;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMoveFramesRefresh" id="e487d580-cfd3-4e8d-8f67-d63aaee2f786">
        <updating/>
        <source>doMoveFramesRefresh() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2010	cnwer1	Initial creation
15 Aug 2016 cnwma1  TFS 2475:PNL- Missing error relating to Loadrite interface
17/08/2016 	cnwrh7		TFS	2501
05/02/2018 jlgns1	Bug 36870: PNL - Weigh warning when not required 851.121
*/

vars
	ti 		: CM_TrackedItem;
begin
	self.setFramesVisible();
	
	//+cnwml2 CCMS 1099 PAR26347
	self.btnAccept.value := false;
	self.btnReject.value := false;
	self.btnRejectTask.value := false;
	self.btnRejectTwin.value := false;
	self.btnGetWeight.visible := false;				//+TFS2501
	self.btnSaveWeight.visible := false;			//+TFS2501
	
	self.btnAccept.caption:=app.myVMAgent.getMoveTaskStr;
	if not app.myPassport.trxCompletedOK then
	
		if app.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.ACCEPT_TASK then
			self.doRejectTasks(false);
		endif;
		return;
	endif;
	
	if app.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.ACCEPT_TASK then
		if self.myWeightInterfaceController &lt;&gt; null then
			self.myWeightInterfaceController.stopListening;
		endif;
		
		if self.myTCPWeightInterfaceController  &lt;&gt; null then					//+TFS2501
			self.myTCPWeightInterfaceController.closeConnection();
		endif;
		
		//self.goToTaskFrame();
	elseif  app.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.GETNEXT_TASK then
		if self.myWeightInterfaceController &lt;&gt; null then
			self.myWeightInterfaceController.stopListening;
		endif;
		
		if self.myTCPWeightInterfaceController  &lt;&gt; null then					//+TFS2501
			self.myTCPWeightInterfaceController.closeConnection();
		endif;
		
	elseif app.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.PICKUP_TASK then
		//make sure frmMove is visible
		//self.frmMove.visible := true;
		// self.setupFrmMove() will be called from note if frmMove is visible
	elseif app.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.SETDOWN_TASK then
		if self.myWeightInterfaceController &lt;&gt; null then
			self.myWeightInterfaceController.startListening;	
			// Warning if there is no ToDo Task or the weight is not Forced    
			
			/*				//Bug 36870
			if self.myVMAgent.myMachine.getCurrentTwinTask() = null then    //15/08/2016 cnwma1 TFS #2475
				ti := self.myVMAgent.myMachine.currentQueueTask.ti;
				if ti &lt;&gt; null then
					if ti.isKindOf(CM_Container) and ti.weighStatus &lt;&gt; WEIGH_STATUS_FORCED then       
						if not ti.CM_Container.hasToDoTasksWithTransClass(TRANS_TYPE_WEIGH, false) then
							app.msgBox(app.getErrorString1(Contai_not_marked_weighi_requi,null),"Warnning",MsgBox_OK_Only);
						endif;	
					endif;
				endif;
			endif;
			//*/			//Bug 36870
		endif;
		
		if self.myTCPWeightInterfaceController  &lt;&gt; null then					//+TFS2501 For TCP Weight Interface then we can use Get Weight button to do Open TCP Connection
			self.btnGetWeight.visible := true;
			self.btnSaveWeight.visible := true;
		else
			self.btnGetWeight.visible := false;
			self.btnSaveWeight.visible := false;
		endif;

		//make sure frmMove is visible
		//self.frmMove.visible := true;
		// self.setupFrmMove() will be called from note if frmMove is visible
	elseif app.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.COMPLETE_TASK then
		//make sure frmMove is visible
		//self.frmMove.visible := true;
		// self.setupFrmMove() will be called from note if frmMove is visible
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMoveTask" id="6aefa035-981e-4a5f-bd27-c8952490212a">
        <updating/>
        <source>doMoveTask() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2010	cnwer1	Initial creation
23 Feb 2010 	cnwer1	PAR 28126
07/05/2017 		cnwrh7 TFS4180       #Cursor Position in RT Enquiry Mode
*/

vars
	temTargeIDRow   : Integer;				//+TFS4180
begin
	
	app.mousePointer	:=	Busy;
	if self.isEnquiryMode or self.isShowOverstowCargo then
		self.doMoveEnquiryCargo();
		self.setFramesVisible();
		return;
	elseif self.isInDischargeMode and
		(not self.frmMove.visible) then //epr par 25994 
		
		self.btnVoyDischarge.enabled := false; //cnwrd1 par 27559 5.8.2011		
		
		self.doAcceptCranePickup();
		if not app.myPassport.trxCompletedOK then
			self.btnVoyDischarge.enabled := true;
			return;
		endif;
	else
		self.beginMoveTimer();
		if app.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.ACCEPT_TASK then
		//epr par 26032 13/10/10		
			self.frmMoveTbl.visible:=false;
			self.frmMoveEntry.visible:=false;	
			app.setAckTIConnectError(false);
		endif;
		
		app.myVMAgent.doMoveTasks();
		
		if app.myVMAgent.currentOverstowedTask &lt;&gt; null and 
			self.myMachine.currentQueueTask = null then
			return;
		endif;
		// TFS 2357 only show the 'is certified' checkbox if the machine and both weigh and certify, AND is in setdown mode
		self.myMoveTableDetails.setEntRowVisible(ETRow_IsWeightCertified,false);
		if app.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.SETDOWN_TASK and
		   self.myMachine.canWeighCargo and
		   self.myMachine.canCertifyWeight then
			self.myMoveTableDetails.setEntRowVisible(ETRow_IsWeightCertified,true);
		endif;
	endif;	
	
	self.doMoveFramesRefresh();

	
epilog

	//+cnwml2 CCMS 1099 PAR26347
	self.btnAccept.value := false;
	self.btnReject.value := false;
	self.btnRejectTask.value := false;
	self.btnRejectTwin.value := false;
	//epr par 26666 clear the last input numbers in the search field
	self.txtSearch.text:=null;
	self.txtSearch.lostFocus(self.txtSearch);
	//self.txtSearch.setFocus;
	app.mousePointer	:=	Idle;
	if self.isEnquiryMode and self.btnAccept.caption =app.getErrorString(Pickup)  then						//+TFS4180
		temTargeIDRow := self.myMoveTableDetails.findRowWithEntRowName(ETRow_TargetID);
		if temTargeIDRow &lt;&gt; null then
			self.tblMoveEntry.accessCell(temTargeIDRow,3);
			self.tblMoveEntry.setFocus();
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
