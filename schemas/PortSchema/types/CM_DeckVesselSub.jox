        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="8de47160-b76a-4792-b485-e2f48f84439d">
        <source>validateCreate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	iter : Iterator;
	deck : CM_DeckVessel;
begin
	inheritMethod(_passport);

	iter:=self.myParentDeck.allSubDecks.createIterator;
	while iter.next(deck) do
		if deck.code = self.code then
			app.raiseCMException1(Duplicate_code_must_unique,app.getErrorString(Vessel) &amp; " " &amp; app.getErrorString(Deck),null,null);
			return;
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="edab68c0-128f-45ff-bfa2-e35567566f66">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	realSelf : CM_DeckVesselSub;
	parentDeck , subDeck: CM_DeckVessel;
	iter : Iterator;
begin
	inheritMethod(_passport);
	
	realSelf:=self.pxyGetRealObject;

	if realSelf &lt;&gt; null then
		parentDeck:=realSelf.myParentDeck;
		iter:=parentDeck.allSubDecks.createIterator;
		while iter.next(subDeck) do
			if subDeck.code = self.code and subDeck &lt;&gt; realSelf then
				app.raiseCMException1(Duplicate_code_must_unique,app.getErrorString(Vessel) &amp; " " &amp; app.getErrorString(Deck),null,null);
				return;
			endif;	
		endwhile;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
