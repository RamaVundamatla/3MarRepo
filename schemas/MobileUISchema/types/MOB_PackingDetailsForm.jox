    </JadeMethod>
    <JadeMethod name="loadTblPacked" id="c24fcc1a-cff3-41b1-bd96-f7def9c0ed54">
        <source>loadTblPacked();
// ---------------------------------------------------------------------------
// Created:     16 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
begin
	foreach ti in self.myResereveSelection.allTrackedItemsReleased do
		if ti &lt;&gt; null then
			if ti.myParent &lt;&gt; null then
				self.tbl_Packed.addItem(ti.id &amp; Tab &amp; ti.myParent.id);
			endif;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTblToPack" id="f2347fdc-fbca-45be-901b-054d88dff33a">
        <source>loadTblToPack();
// ---------------------------------------------------------------------------
// Created:     16 May 2008 by cnwaer1
//
// Purpose:     
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// ---------------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
	reserve : CM_ReserveSelection;
	br : CM_BookingRef;
	brItem : CM_BookingRefItem;
	toPackCollection : CM_TISet;
	loc 		    : CM_LocationsController;
	allTis	: CM_TISet;
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	create toPackCollection transient;
	reserve := self.myResereveSelection;
	reserve.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//foreach ti in reserve.allTrackedItems do
	foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
		if ti.site = TI_SITE_ONSITE then	// 06/03/2012 cnwar2 #29170
			toPackCollection.add(ti);
		endif;
	endforeach;

	br := reserve.myReserveHeader.myBookingRefStock;
	if br &lt;&gt; null then
		foreach  brItem in br.allBookingRefItems do
			foreach ti in brItem.allTIs do
				if ti.site = TI_SITE_ONSITE and ti.myProduct = reserve.CM_ReserveSelection.myProduct and ti.myParent = null and (not toPackCollection.includes(ti)) then 
					toPackCollection.add(ti);
				endif;
			endforeach;
		endforeach;
	endif;

	foreach ti in toPackCollection do
		loc := ti.getPrimaryLocation(REAL_MODE);
		if loc &lt;&gt; null then
			self.tbl_ToPack.addItem(ti.id &amp; Tab &amp; loc.getFullId);
		else
			self.tbl_ToPack.addItem(ti.id &amp; Tab &amp; ti.locationId);
		endif;	
	endforeach;
epilog
	delete toPackCollection;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyRequest" id="5ee10698-d0ee-4d47-a696-fd3386775301">
        <updating/>
        <source>setMyRequest( _obj : CM_ReserveSelection) updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myResereveSelection := _obj;
end;</source>
        <Parameter name="_obj" type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="635a6355-083b-499d-84b0-b8433f19e711">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	if self.myResereveSelection &lt;&gt; null then
		self.setupTablePacked(tbl_Packed);
		self.setupTableToPack(tbl_ToPack);
		self.loadTblToPack;
		self.loadTblPacked;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTablePacked" id="aa0c525c-adce-4250-ac09-96c216c87985">
        <source>setupTablePacked(tbl : CM_MobTable input);
// ---------------------------------------------------------------------------
// Created:     16 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	intColumns 		: Integer;
	strHeader 		: String;
	
begin		
	self.getTablePackedSettings(intColumns, strHeader);
	tbl.setMargins();
	tbl.selectMode := tbl.SelectMode_Row;
	tbl.fontSize := 14;
	tbl.alignment := Table.Alignment_Center;
	tbl.columns := intColumns;
	tbl.accessCell(1,1).mergeCells := Table.MergeCells_MergeSelectable;
	
	if self.myResereveSelection &lt;&gt; null then
		if self.myResereveSelection.myProduct &lt;&gt; null then
			tbl.accessCell(1,1).text := self.myResereveSelection.myProduct.code.String &amp; " packed";
		else
			tbl.accessCell(1,1).text := self.myResereveSelection.myCargoType.description &amp; " packed";
		endif;
	else
		tbl.accessCell(1,1).text := self.myResereveSelection.myCargoType.description &amp; " packed";
	endif;
	tbl.accessCell(2,1).text := strHeader;
	tbl.gridLines := true;
	tbl.fixed3D := false;
	tbl.setFixedColours();
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupTableToPack" id="a27bed36-060a-4099-a710-a839d8f61dda">
        <source>setupTableToPack(tbl : CM_MobTable input);
// ---------------------------------------------------------------------------
// Created:     16 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	intColumns 		: Integer;
	strHeader 		: String;
	
begin		
	self.getTableToPackSettings(intColumns, strHeader);
	tbl.setMargins();
	tbl.selectMode := tbl.SelectMode_Row;
	tbl.fontSize := 14;
	tbl.alignment := Table.Alignment_Center;
	tbl.columns := intColumns;
	tbl.accessCell(1,1).mergeCells := Table.MergeCells_MergeSelectable;
	
	if self.myResereveSelection.myProduct &lt;&gt; null then
		tbl.accessCell(1,1).text := self.myResereveSelection.myProduct.code.String &amp; " to pack" ;
	else
		tbl.accessCell(1,1).text := self.myResereveSelection.myCargoType.description &amp; " to pack" ;
	endif;
	
	tbl.accessCell(2,1).text := strHeader;
	tbl.gridLines := true;
	tbl.fixed3D := false;
	tbl.setFixedColours();
end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4b4e9f17-3b2a-48c5-982f-d82b6a088fbf">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017616, locale);
	btn_Close.translateCaption(Xlat_0013211, locale);
	lbl_Title.translateCaption(Xlat_0013212, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
