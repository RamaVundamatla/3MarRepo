    <JadeMethod name="doBtnSummariseAll" id="773176f2-063f-4ef9-bc9a-d845d7056663">
        <source>doBtnSummariseAll();

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
18 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	coll				: ObjectSet;
	
begin
	app.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of ALL the objects to pass to the Summary Definition form.
	self.tblData.getAllRowObjects( coll );
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, false, true );
	
epilog
	delete coll;
	app.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doBulkEdit" id="7842b7d6-9fe8-4e6d-bcf0-129f6daaf39d">
        <source>doBulkEdit();
// ---------------------------------------------------------------------------
// Created:     Feb 2006 Russell Sargent (cnwrs1)
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars
	objArray : ObjectArray;
	tiArray : ObjectArray;
	tbl : CM_DataTable;
	numRows, row : Integer;
	obj : Object;
	ediTI : CM_EDITrackedItem;
	llcTi : CM_EDILoadListComparisonTI;
begin
	tbl := self.tblData;
	numRows := tbl.rows;
	//get a list of CM_EDILoadListComparisonTI to be updated
	// the llc or the DB or both lines for the same ti maybe selected
	create objArray	 transient;
	foreach row in tbl.fixedRows + 1 to numRows do
		if tbl.accessRow(row).selected = true then
			obj := tbl.accessRow(row).itemObject;
			if not obj.isKindOf(CM_EDILoadListComparisonTI) then
				foreach ediTI in myLLCAgent.allDiscrepancyTIs do
					if obj &lt;&gt; null and
					   obj.isKindOf(CM_EDILoadListTI) and
					   ediTI.id = obj.CM_EDILoadListTI.id then
						obj := ediTI;
						break;
					endif;
				endforeach;
			endif;
			if obj &lt;&gt; null and 
			   not objArray.includes(obj) then

				objArray.add(obj);
			endif;
		endif;
	endforeach;
	if objArray.size &lt; 1 then
		return;
	endif;
	create tiArray transient;
	foreach obj in objArray do
		// PAR 11657 Lorcan Changes to we can edit TIs with this method
		if obj.isKindOf(CM_EDILoadListComparisonTI) then
			llcTi := obj.CM_EDILoadListComparisonTI;
			tiArray.add(llcTi.myTrackedItem);
		elseif obj.isKindOf(CM_TrackedItem) then
			tiArray.add (obj);
		endif;
	endforeach;
	//changed by cnwyl1 for par 12204
	//it was...
	//if tiArray.size &gt; 1 then
	if tiArray.isNotEmpty() then
		self.myAssistant.showCargoEnquiryForTIs(tiArray[1].CM_TrackedItem, tiArray, self.myMasterMenuAction, true);
	endif;
epilog
	delete tiArray;
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBulkEnquiry" id="262c4c86-6523-41d0-9a0a-18d5d78eafb6">
        <source>doBulkEnquiry();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwas3	Initial creation

*/
vars
	objArray : ObjectArray;
	tiArray : ObjectArray;
	tbl : CM_DataTable;
	numRows, row : Integer;
	obj : Object;
	ediTI : CM_EDITrackedItem;
	llcTi : CM_EDILoadListComparisonTI;
begin
	tbl := self.tblData;
	numRows := tbl.rows;
	//get a list of CM_EDILoadListComparisonTI to be updated
	// the llc or the DB or both lines for the same ti maybe selected
	create objArray	 transient;
	foreach row in tbl.fixedRows + 1 to numRows do
		if tbl.accessRow(row).selected = true then
			obj := tbl.accessRow(row).itemObject;
			if not obj.isKindOf(CM_EDILoadListComparisonTI) then
				foreach ediTI in myLLCAgent.allDiscrepancyTIs do
					if obj &lt;&gt; null and
					   obj.isKindOf(CM_EDILoadListTI) and
					   ediTI.id = obj.CM_EDILoadListTI.id then
						obj := ediTI;
						break;
					endif;
				endforeach;
			endif;
			if obj &lt;&gt; null and 
			   not objArray.includes(obj) then

				objArray.add(obj);
			endif;
		endif;
	endforeach;
	if objArray.size &lt; 1 then
		return;
	endif;
	create tiArray transient;
	foreach obj in objArray do
		// PAR 11657 Lorcan Changes to we can edit TIs with this method
		if obj.isKindOf(CM_EDILoadListComparisonTI) then
			llcTi := obj.CM_EDILoadListComparisonTI;
			tiArray.add(llcTi.myTrackedItem);
		elseif obj.isKindOf(CM_TrackedItem) then
			tiArray.add (obj);
		endif;
	endforeach;
	//changed by cnwyl1 for par 12204
	//it was...
	//if tiArray.size &gt; 1 then
	if tiArray.isNotEmpty() then
		self.myAssistant.showCargoEnquiryForTIs(tiArray[1].CM_TrackedItem, tiArray, self.myMasterMenuAction, false);
	endif;
epilog
	delete tiArray;
	delete objArray;
end;</source>
    </JadeMethod>
