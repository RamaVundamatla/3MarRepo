    <JadeMethod name="canUserAccessObject" id="afc7999c-841b-45f9-b90f-85cb4605c575">
        <source>canUserAccessObject(_obj : Object) : Boolean protected;
//--------------------------------------------------
// Created:	04 August 2005 By: cnwgd1
//--------------------------------------------------
