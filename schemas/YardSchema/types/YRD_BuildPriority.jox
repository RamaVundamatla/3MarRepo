    <JadeMethod name="addToolbarControls" id="e0cddf31-ff27-4dd6-9303-9b413ac97ed9">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	08 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	self.btnSaveBase.visible := true;
	toolbar.addButton(self.btnClear, CMUI_Toolbar.Control_Alignment_Left);
	self.btnClear.visible := true;	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	self.btnCancelBase.enabled 	:= true;
end;</source>
        <access>protected</access>
    </JadeMethod>
