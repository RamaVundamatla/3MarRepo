    <JadeMethod name="doBaseFormSave" id="a1000f89-8ca4-435c-9162-7b06b0090d32">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	result	: Integer;
	realChild : CM_Object;
begin

	
	self.setProxy();
	
	while true do
		if self.mode = self.Mode_New then
			// call new method in sub class
			self.doNewTrx(realChild);
		elseif self.mode = self.Mode_Edit then
			//call method in sub class
			self.doEditTrx();
		endif;
		if app.myPassport.trxCompletedOK then
			if realChild &lt;&gt; null then
				self.myCurrentChild:=realChild;
			else
				self.myCurrentChild:=self.myProxyChild.pxyGetRealObject.CM_Object;
			endif;
			break;
		else
			result := app.showErrorWarningDialog(self.getChildTypeName, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		
		endif;
		break;
	endwhile;
	
	if app.myPassport.trxCompletedOK then
		self.doChangeMode(self.Mode_View);

	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doChangeChild" id="c6121b47-4b99-45ef-9f3e-d2e33cd2bbab">
        <updating/>
        <source>doChangeChild(_tank : CM_Object) protected, updating ;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if self.myCurrentChild = _tank then
		return;
	endif;
		
	self.myCurrentChild:=_tank;
	self.loadChildDetails();
	
	
epilog
	self.setCaption(null);
end;</source>
        <access>protected</access>
        <Parameter name="_tank" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doChangeMode" id="0d28cdca-5927-4a1d-ad6d-0b9143382e9e">
        <updating/>
        <source>doChangeMode(	_mode : Integer) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars

begin

	//doing this first because i don't want to change the enabled controls until after the proxy is created because if there is an exception it aborts and 
	// i don't get an opportunity to change the enabled controls and mode back
	//epr par 27474 17/5/11
	if _mode = self.Mode_Edit then
		// create the proxy from real object
			if self.myCurrentChild = null then
				return;
			endif;
		self.myProxyChild:=app.createUpdateProxy(self.myCurrentChild).CM_Object;
	
	endif;

	self.mode:=_mode;
	self.enableControls();
	
	

	
	self.loadChildDetails();
	
	if self.mode = self.Mode_View then
		//if there is a proxy object then delect the proxy
		if self.myProxyChild &lt;&gt; null then
			delete self.myProxyChild;
		endif;
			
		return;
	endif;
	
	//if mode = new we create the proxy on save don't know what type to create yet

	
	
epilog
	self.setCaption(null);
end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doChangeParent" id="ea34d751-f0d0-430b-b271-8b986a727655">
        <updating/>
        <source>doChangeParent(	_parent : CM_Object;
				_child : CM_Object) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if self.myParent = _parent then
		return;
	endif;
	
	self.endNotes();
	
	self.cmbParent.setIndexFromObject(_parent);
	self.myParent:=_parent;
	
	self.startNotes();
	
	
	self.loadChildCombo(_child);
	
	self.doChangeChild(_child);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_child" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doClearChildDetails" id="f8ab6a7f-da82-4300-b9d2-2b4eea9ad9a5">
        <source>doClearChildDetails() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	cntrl : Control;	
	indx : Integer;
begin
	
	foreach indx in 1 to self.controlCount do
		cntrl := self.controls(indx);
		if cntrl.isKindOf(CMUI_TextBox) and cntrl.parent = self.picDetails then

			cntrl.CMUI_TextBox.text:=null;	
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteChild" id="bc3d82d6-911e-4070-ad99-e8808f2ad91a">
        <source>doDeleteChild() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	result : Integer;
	niceName,
	typeName : String;
	
begin
	//get niceName
	niceName:=self.getChildNiceName(self.myCurrentChild);
	typeName:=self.getChildTypeName;
	if app.msgBox(app.getErrorString2(ConfirmDelete,typeName,niceName),app.getErrorString(Warning), MsgBox_Yes_No) &lt;&gt;  MsgBox_Return_Yes then
		return;
	endif;

	while true do
	
		//call in sub class the delete transaction
		//app.myTrxDA.trxDeleteVesselTank(self.myCurrentChild,app.myPassport);
		self.doDeleteTrx();
		
		if app.myPassport.trxCompletedOK then
			
			break;
		else
			result := app.showErrorWarningDialog(typeName, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		
		break;
	endwhile;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
