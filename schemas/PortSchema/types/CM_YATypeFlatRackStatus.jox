    <JadeMethod name="getAllYAIdentifiers" id="a6ba26da-1ad7-4b75-9bf2-eb9047514398">
        <source>getAllYAIdentifiers(_yaIdentifiers: StringArray input): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars

begin
	_yaIdentifiers.clear;
	_yaIdentifiers.add(app.getErrorString(Ends_Up));
	_yaIdentifiers.add(app.getErrorString(Ends_Down));

	return true;
epilog

end;</source>
        <Parameter name="_yaIdentifiers" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
