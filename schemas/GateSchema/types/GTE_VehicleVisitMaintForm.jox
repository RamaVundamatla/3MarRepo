    <JadeMethod name="setVehicleVisitRecord" id="d11a0290-79f8-408c-85b3-2ccdbaeafeae">
        <updating/>
        <source>setVehicleVisitRecord( _vehicleVisitRecord : CM_VehicleVisitRecord )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2020	jlgndl1	Initial creation	TFS 49189

