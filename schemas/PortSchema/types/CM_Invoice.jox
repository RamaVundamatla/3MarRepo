    <JadeMethod name="getGLSummary" id="508ea08f-9869-4177-997c-a78306cc60ac">
        <source>getGLSummary(_dict : CM_GLSummaryByGLCodeRateDict input);
/*

Purpose:			
		CCMS CPL 2120 used in XML extract via report
Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2016	cnwrs1	TFS2107 change rate/cost per unit from 12,6 to 16,6
05 Mar 2020 cnwma1 ChangeRequest 48524: CPL - Credit Invoice Details for Print
18 Jan 2022 jlika1	TFS 51891 CPL - Reprint Posted Returned Invoice
07 Sep 2022	navpw1	TFS: 54564 (54379) - EUP - Inv Config - Debtor Currencies and Countries
*/

vars
	glSumm			: CM_GLSummary;
	invLine			: CM_InvoiceLine;
	desc			: String;
	rate			: Decimal[23,6];				   //11 May 2018	NDL	TFS 38528
	includeVoided   : Boolean;
	printOrder      : Integer;
	printTis        : Boolean;
begin

	includeVoided := self.isReverseCredit() or self.isPostedReturned()  ;			   //05/03/2020 cnwma1 TFS #48524
	
	foreach invLine in self.invoiceLines  do
	
		if not includeVoided and invLine.voided then    //05/03/2020 cnwma1 TFS #48524
			continue;
		endif;
	
		rate    	:= invLine.getRate();
		//desc    	:= invLine.invoiceLineDesc.narration;
		desc    	:= invLine.getNarrationFromInvoiceLocale();			// ### TFS 54564 (54379) 05Sep2022 NAVPW1
		printOrder  := invLine.invoiceLineDesc.printingOrder;			//09/03/2020 cnwma1 TFS #48524
		printTis    := invLine.invoiceLineDesc.bPrintTrackedItems;   	//09/03/2020 cnwma1 TFS #48524
		
		glSumm  := _dict[desc, rate, null];
		if glSumm = null then
			create glSumm transient;
			glSumm.glCode            := desc;
			glSumm.rate              := rate;
			glSumm.serviceName       := null;
			glSumm.printOrder        := printOrder;   //05/03/2020 cnwma1 TFS #48524
			glSumm.printTrackedItems := printTis;     //05/03/2020 cnwma1 TFS #48524
			glSumm.myInvoiceLine     := invLine;
			_dict.add(glSumm);
		endif;

		glSumm.quantity  := glSumm.quantity  + invLine.quantity;
		glSumm.amount 	 := glSumm.amount    + invLine.lineTotal;
		glSumm.taxAmount := glSumm.taxAmount + invLine.getTaxAmountForLine();
		glSumm.allInvoiceLines.add(invLine);
		
	endforeach;
epilog

end;</source>
        <Parameter name="_dict" type="CM_GLSummaryByGLCodeRateDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvLinesConsByNarrCri" id="416350c2-f6d6-45c6-b9a9-c12792c61017">
        <source>getInvLinesConsByNarrCri(transientInvoice : CM_Invoice);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2024	navrv30	Initial creation for CR 61911/ Task 61393

*/

vars
	invLinesSumm	   : CM_InvLineCons;
	invLine			   : CM_InvoiceLine;
	transientInvLine   : CM_InvoiceLine;
	invLineNarration   : String;
	rate			   : Decimal[23,6];	
	controller         : CMIF_InvoiceLineCopy;
	contractCriteria   : String;
	dict               : CM_InvLineByNarrRateDict;
	charge : CM_Charge;
begin
	create dict transient;
	create controller transient;
	foreach invLine in self.invoiceLines  do	
		controller.setValues(false,false,false,self,null,null);
		controller.myInvoice := transientInvoice;
		
		 // ### JIRA 34949 22MAY2025 NAVAB1
		//rate    	:= invLine.getRate();
		// if the line is void getRate() returns the rate is always zero.
		
		rate := 0;  // ### JIRA 35899 02SEP2025 NAVAB1
		foreach charge in invLine.charges do
			rate := rate + charge.getRate();
		endforeach;

		 // ### JIRA 35902 22SEP2025 NAVAB1
		contractCriteria := null;
		if invLine.myInvoiceContractDetail &lt;&gt; null then
				contractCriteria := invLine.myInvoiceContractDetail.invoiceContractCriteria();
		endif;
		invLineNarration   := invLine.getNarrationFromInvoiceLocale() &amp; contractCriteria;
		invLineNarration   := invLineNarration[1:512];
		invLinesSumm  := dict[invLineNarration, rate];
		if invLinesSumm = null then
			create invLinesSumm transient;
			transientInvLine := invLine.cloneForConsNarrRate(controller, invLine.trackedItem, true);			
			invLinesSumm.narration         := invLineNarration;
			invLinesSumm.rate              := rate;			
			invLinesSumm.myInvoiceLine     := transientInvLine;
			invLinesSumm.contractCriteria  := contractCriteria;
			dict.add(invLinesSumm);
		endif;
		
		invLinesSumm.quantity  := invLinesSumm.quantity  + invLine.quantity;	
		invLinesSumm.myInvoiceLine.setQuantityAndTotal(invLinesSumm.quantity);
	endforeach;
epilog	
	delete controller;
	if dict &lt;&gt; null then
		dict.purge();
	endif;
	delete dict;	
end;</source>
        <Parameter name="transientInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getInvLinesConsByNothing" id="e6fb6a46-1f2e-43a8-a7b3-55dc83de1ae8">
        <source>getInvLinesConsByNothing(transientInvoice : CM_Invoice);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
 // ### JIRA 35848 27AUG2025 NAVAB1

*/

vars

	invLine			   : CM_InvoiceLine;
	transientInvLine   : CM_InvoiceLine;
	controller         : CMIF_InvoiceLineCopy;
	transientObjs	   : ObjectArray;
	charge 			   : CM_Charge;
	seqNum			   : Integer;
begin
	create transientObjs transient;
	create controller transient;
	transientObjs.add(controller);
	seqNum := 1000000;
	foreach invLine in self.invoiceLines  do	
		controller.setValues(false,false,false,transientInvoice,null,null);
		controller.myInvoice := transientInvoice;
		foreach charge in invLine.charges do 
			transientInvLine := invLine.cloneForConsChargeRate(controller, invLine.trackedItem, seqNum, true);			
			charge.cloneForConsolidation( transientInvLine);				
			seqNum := seqNum + 1;
		endforeach;
	endforeach;
epilog
	if transientObjs &lt;&gt; null then
		transientObjs.purge();
	endif;
	delete transientObjs;

end;</source>
        <Parameter name="transientInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getInvLinesConsByServiceRate" id="4b30f2c8-1145-4436-8030-bcc6ecc76c8a">
        <source>getInvLinesConsByServiceRate(transientInvoice : CM_Invoice);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2024	navrv30	Initial creation for CR 61911/ Task 61392

*/

vars
	invLinesSumm	   : CM_InvLineCons;
	invLine			   : CM_InvoiceLine;
	transientInvLine   : CM_InvoiceLine;
	invLineNarration   : String;
	rate			   : Decimal[23,6];	
	controller         : CMIF_InvoiceLineCopy;
	transientObjs	   : ObjectArray;
	charge 			   : CM_Charge;
	seqNum			   : Integer;
	dict               : CM_InvLineByNarrRateDict;
begin
	create transientObjs transient;
	create dict transient;
	create controller transient;
	transientObjs.add(controller);
	seqNum := 1000000;
	foreach invLine in self.invoiceLines  do	
		controller.setValues(false,false,false,transientInvoice,null,null);
		controller.myInvoice := transientInvoice;
		foreach charge in invLine.charges do 
			invLineNarration   := charge.service.name;
			rate := charge.getRate();
			invLinesSumm  := dict[invLineNarration, rate];
			if invLinesSumm = null then
				create invLinesSumm transient;
				transientInvLine := invLine.cloneForConsChargeRate(controller, invLine.trackedItem, seqNum, true);			
				invLinesSumm.narration         := invLineNarration;
				invLinesSumm.rate              := rate;			
				invLinesSumm.myInvoiceLine     := transientInvLine;
				charge.cloneForConsolidation( transientInvLine);				
				dict.add(invLinesSumm);
				seqNum := seqNum + 1;
			endif;
			
			invLinesSumm.quantity  := invLinesSumm.quantity  + invLine.quantity;	
			invLinesSumm.myInvoiceLine.setQuantityAndTotal(invLinesSumm.quantity );
		endforeach;
	endforeach;
epilog
	if transientObjs &lt;&gt; null then
		transientObjs.purge();
	endif;
	delete transientObjs;
	if dict &lt;&gt; null then
		dict.purge();
	endif;
	delete dict;
end;</source>
        <Parameter name="transientInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getInvLinesConsExternalRef4" id="eb9fcf9d-bece-4f68-9689-687066bd7d88">
        <source>getInvLinesConsExternalRef4(transientInvoice : CM_Invoice);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2024	jlier1	Initial creation 65961 : CR 65949 NSW | Dynamic Integration Development
15 Jan 2025			navhl20 Bug MTN-33758: NSW | D365 - Issues with Invoice Line Call for Voyage Invoices
20 Feb 2025			jlier1 JIRA#34105 19/2/25 - issues with credit invoices and manual txn/hms txns - now calcluating rate/quantity/tax becuase can't rely on the cloned 
*/

vars
	
	invLinesSumm	   : CM_InvLineCons;
	invLine			   : CM_InvoiceLine;
	transientInvLine   : CM_InvoiceLine;
	controller         : CMIF_InvoiceLineCopy;
	dict               : DynaDictionary;
	isNSW			   : Boolean; 			//10/02/2025	navkc1 JIRA Story MTN-33896
	finIOClass		   : CM_ExtFinanceIO; 	//10/02/2025	navkc1 JIRA Story MTN-33896
	terminal	 	   : CM_Terminal;		//10/02/2025	navkc1 JIRA Story MTN-33896
	isCreditReturn 		: Boolean;
	lineTaxValue,
	chargeTotal,
	lineTotal 			: Decimal [23,6];
	charge : CM_Charge;
begin	
	create dict transient;
	dict.setMembership(CM_InvLineCons);
	dict.addExternalKey(String,300,false,false);
	dict.endKeys(true);
	
	terminal := self.getMyTerminal(); //10/02/2025	navkc1 JIRA Story MTN-33896
	
	//10/02/2025	navkc1 JIRA Story MTN-33896
	if terminal &lt;&gt; null then
		finIOClass := terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		
		if finIOClass &lt;&gt; null then
			isNSW := finIOClass.isNSW();
		endif;
	endif;
	
	create controller transient;
	controller.setValues(false,false,false,self,null,null);						//15.01.2025 navhl20 #33758 //Moved here from foreach
	controller.myInvoice := transientInvoice;									//15.01.2025 navhl20 #33758 //Moved here from foreach
	
	isCreditReturn:=self.status = CM_Invoice.INVOICE_POSTED_CREDIT_ERROR or	
					self.status = CM_Invoice.INVOICE_POSTED_CREDIT_PENDING;	
	
	foreach invLine in self.invoiceLines discreteLock  do	
		//jlier1 JIRA#34066 17/2/25
		if isNSW and (not isCreditReturn and invLine.voided) then
			continue;
		endif;
		
		if isNSW and //10/02/2025	navkc1 JIRA Story MTN-33896
			invLine.myTransactionHMS &lt;&gt; null then								//15.01.2025 navhl20 #33758
			transientInvLine := invLine.cloneForConsNarrRate(controller, invLine.trackedItem, true);
			lineTotal:=0;
			chargeTotal:=0;
			lineTaxValue:=0;
			foreach charge in invLine.charges discreteLock do
				chargeTotal:=(invLine.quantity * charge.getRate);
				lineTotal:=lineTotal  +  chargeTotal;
				lineTaxValue :=lineTaxValue +  ((chargeTotal  * (charge.getTaxRateForCharge / 100)));				
			endforeach;
			transientInvLine.setTaxValue(lineTaxValue);
			transientInvLine.setQuantityAndTotalAmount(transientInvLine.quantity,lineTotal);
			continue;
		else
			invLinesSumm  := dict.getAtKey(invLine.externalRef4).CM_InvLineCons;
			if invLinesSumm = null then
				create invLinesSumm transient;
				transientInvLine := invLine.cloneForConsNarrRate(controller, invLine.trackedItem, true);
				invLinesSumm.myInvoiceLine     := transientInvLine;
				dict.putAtKey(invLine.externalRef4,invLinesSumm);
			endif;
		endif;
		invLinesSumm.quantity  := invLinesSumm.quantity  + invLine.quantity;
		
		//jlier1 JIRA#34105 19/2/25 - manual transactions some others don't get totalAmount set	
		if isCreditReturn  and invLine.voided then
			lineTotal:=0;
			chargeTotal:=0;
			lineTaxValue:=0;
			foreach charge in invLine.charges discreteLock do
				chargeTotal:=(invLine.quantity * charge.getRate);
				lineTotal:=lineTotal  +  chargeTotal;
				lineTaxValue :=lineTaxValue +  ((chargeTotal  * (charge.getTaxRateForCharge / 100)));				
			endforeach;
			invLinesSumm.totalAmount := invLinesSumm.totalAmount + lineTotal;
			invLinesSumm.taxValue :=invLinesSumm.taxValue + lineTaxValue;
		else
			if invLine.totalAmount &lt;&gt; 0 then
				invLinesSumm.totalAmount := invLinesSumm.totalAmount + invLine.totalAmount;
			else
				invLinesSumm.totalAmount := invLinesSumm.totalAmount + invLine.lineTotal;
			endif;
			invLinesSumm.taxValue:=invLinesSumm.taxValue + invLine.getTotalTaxAmountForLine();
		endif;
		invLinesSumm.myInvoiceLine.setTaxValue(invLinesSumm.taxValue);
		invLinesSumm.myInvoiceLine.setQuantityAndTotalAmount(invLinesSumm.quantity,invLinesSumm.totalAmount);
	endforeach;
epilog	
	delete controller;
	if dict &lt;&gt; null then
		dict.purge();
	endif;
	delete dict;	
end;</source>
        <Parameter name="transientInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getInvLinesConsInfo" id="62d53d3f-3380-47e6-95ed-62a070379c3c">
        <source>getInvLinesConsInfo(transientInvoice : CM_Invoice);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2024	navrv30	Initial creation for CR 61911/ Task 61391

*/

vars
	invLinesSumm	   : CM_InvLineCons;
	invLine			   : CM_InvoiceLine;
	transientInvLine   : CM_InvoiceLine;
	invLineNarration   : String;
	rate			   : Decimal[23,6];	
	controller         : CMIF_InvoiceLineCopy;
	dict               : CM_InvLineByNarrRateDict;
	charge : CM_Charge;
begin
	
	create controller transient;
	create dict transient;
	foreach invLine in self.invoiceLines  do	
		controller.setValues(false,false,false,self,null,null);
		controller.myInvoice := transientInvoice;
		
		 // ### JIRA 34949 22MAY2025 NAVAB1
		//rate    	:= invLine.getRate();
		// if the line is void getRate() returns the rate is always zero.
		rate := 0;  // ### JIRA 35902 02SEP2025 NAVAB1
		foreach charge in invLine.charges do
			rate := rate + charge.getRate();
		endforeach;
		invLineNarration   := invLine.getNarrationFromInvoiceLocale();
		invLinesSumm  := dict[invLineNarration, rate];
		if invLinesSumm = null then
			create invLinesSumm transient;
			transientInvLine := invLine.cloneForConsNarrRate(controller, invLine.trackedItem, true);			
			invLinesSumm.narration         := invLineNarration;
			invLinesSumm.rate              := rate;			
			invLinesSumm.myInvoiceLine     := transientInvLine;
			dict.add(invLinesSumm);
		endif;
		
		invLinesSumm.quantity  := invLinesSumm.quantity  + invLine.quantity;	
		invLinesSumm.myInvoiceLine.setQuantityAndTotal(invLinesSumm.quantity);
	endforeach;
epilog	
	delete controller;
	if dict &lt;&gt; null then
		dict.purge();
	endif;
	delete dict;
end;</source>
        <Parameter name="transientInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getInvLinesConsRef4TypeRate" id="de9980da-ea72-4887-a877-ae12de5800b2">
        <source>getInvLinesConsRef4TypeRate(transientInvoice : CM_Invoice);
// ### JIRA 34735 07MAY2025 NAVAB1
vars
	
	invLinesSumm	   : CM_InvLineCons;
	invLine			   : CM_InvoiceLine;
	transientInvLine   : CM_InvoiceLine;
	controller         : CMIF_InvoiceLineCopy;
	dict               : DynaDictionary;
	isNSW			   : Boolean; 	
	finIOClass		   : CM_ExtFinanceIO; 
	terminal	 	   : CM_Terminal;	
	isCreditReturn 		: Boolean;
	lineTaxValue,
	chargeTotal,
	lineTotal 			: Decimal [23,6];
	charge : CM_Charge;
	invLineNarration, extRef4   : String;
	rate			   : Decimal[23,6];	
begin	
	create dict transient;
	dict.setMembership(CM_InvLineCons);
	dict.addExternalKey(String,100,false,false); // EXTREF4
	dict.addExternalKey(String,100,false,false); // NARR
	dict.addExternalKey(Decimal,1,false,false); // RATE
	dict.endKeys(true);
	
	terminal := self.getMyTerminal(); 
	
	if terminal &lt;&gt; null then
		finIOClass := terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		
		if finIOClass &lt;&gt; null then
			isNSW := finIOClass.isNSW();
		endif;
	endif;
	
	create controller transient;
	controller.setValues(false,false,false,self,null,null);
	controller.myInvoice := transientInvoice;	
	
	isCreditReturn:=self.status = CM_Invoice.INVOICE_POSTED_CREDIT_ERROR or	
					self.status = CM_Invoice.INVOICE_POSTED_CREDIT_PENDING;	
	
	foreach invLine in self.invoiceLines discreteLock  do	
		if isNSW and (not isCreditReturn and invLine.voided) then
			continue;
		endif;
		
		// No consolidation for HMS
		if isNSW 
		and invLine.myTransactionHMS &lt;&gt; null then
			transientInvLine := invLine.cloneForConsNarrRate(controller, invLine.trackedItem, true);
			lineTotal:=0;
			chargeTotal:=0;
			lineTaxValue:=0;
			foreach charge in invLine.charges discreteLock do
				chargeTotal:=(invLine.quantity * charge.getRate);
				lineTotal:=lineTotal  +  chargeTotal;
				lineTaxValue :=lineTaxValue +  ((chargeTotal  * (charge.getTaxRateForCharge / 100)));				
			endforeach;
			transientInvLine.setTaxValue(lineTaxValue);
			transientInvLine.setQuantityAndTotalAmount(transientInvLine.quantity,lineTotal);
			continue;
		else
			// ### JIRA 34949 22MAY2025 NAVAB1
			rate := 0;
			// if the line is void getRate() returns the rate is always zero.
			//rate    	:= invLine.getRate();
			foreach charge in invLine.charges do
				rate := rate + charge.getRate();
			endforeach;

			invLineNarration   := invLine.getNarrationFromInvoiceLocale();
			extRef4 := invLine.externalRef4;
			
			invLinesSumm  := dict.getAtKey(extRef4, invLineNarration, rate).CM_InvLineCons;
			if invLinesSumm = null then
				create invLinesSumm transient;
				transientInvLine := invLine.cloneForConsNarrRate(controller, invLine.trackedItem, true);
				invLinesSumm.myInvoiceLine     := transientInvLine;
				dict.putAtKey(extRef4, invLineNarration, rate,invLinesSumm);
			endif;
		endif;
		invLinesSumm.quantity  := invLinesSumm.quantity  + invLine.quantity;
//		invLinesSumm.totalAmount  := invLinesSumm.totalAmount  + invLine.lineTotal;
		
		if isCreditReturn  and invLine.voided then
			lineTotal:=0;
			chargeTotal:=0;
			lineTaxValue:=0;
			foreach charge in invLine.charges discreteLock do
				chargeTotal:=(invLine.quantity * charge.getRate);
				lineTotal:=lineTotal  +  chargeTotal;
				lineTaxValue :=lineTaxValue +  ((chargeTotal  * (charge.getTaxRateForCharge / 100)));				
			endforeach;
			invLinesSumm.totalAmount := invLinesSumm.totalAmount + lineTotal;
			invLinesSumm.taxValue :=invLinesSumm.taxValue + lineTaxValue;
		else
			if invLine.totalAmount &lt;&gt; 0 then
				invLinesSumm.totalAmount := invLinesSumm.totalAmount + invLine.totalAmount;
			else
				invLinesSumm.totalAmount := invLinesSumm.totalAmount + invLine.lineTotal;
			endif;
			invLinesSumm.taxValue:=invLinesSumm.taxValue + invLine.getTotalTaxAmountForLine();
		endif;
		invLinesSumm.myInvoiceLine.setTaxValue(invLinesSumm.taxValue);
		invLinesSumm.myInvoiceLine.setQuantityAndTotalAmount(invLinesSumm.quantity,invLinesSumm.totalAmount);
	endforeach;
epilog	
	delete controller;
	if dict &lt;&gt; null then
		dict.purge();
	endif;
	delete dict;	
end;</source>
        <Parameter name="transientInvoice" type="CM_Invoice"/>
    </JadeMethod>
