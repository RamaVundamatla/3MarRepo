    <JadeMethod name="parseRowRangeText" id="3530dce0-9693-4890-898a-759b9b8f7f18">
        <source>parseRowRangeText(_rowRangeText : String; _rowFrom, _rowTo : String output );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 January 2010	cnwjk3	Initial creation

*/

vars
	textLength,
	pos			: Integer;
begin
	/*
		Need to cope with the following string patterns:
		RR-RR
		RR
	*/
	if _rowRangeText = null then
		return;
	endif;

	pos := 1;
	textLength := _rowRangeText.length();

	_rowFrom := _rowRangeText.scanUntil(" -",pos);

	if pos &lt;&gt; 0 and pos &lt; textLength and _rowRangeText[pos] = '-' then
		// Assume RR-RR
		pos := pos + 1;
		_rowTo := _rowRangeText.scanUntil(" ",pos);	
	else
		// Assume RR
		_rowTo := _rowFrom;
	endif;
	
epilog

end;</source>
        <Parameter name="_rowRangeText" type="String"/>
        <Parameter name="_rowFrom" type="String" usage="output"/>
        <Parameter name="_rowTo" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateNewLane" id="02b8e17d-5b79-4593-850c-d375b9a4db7d">
        <updating/>
        <source>pxyCreateNewLane(maxLaneLen : Real) : CM_RoRoController protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwjk3	ccms 1018

*/

constants
	MaxTries = 150;	//07 Dec 2015	NDL	Par 37272 - increase limit from 99 to 150 
vars
	pxyLane		: CM_RoRoController;
	count		: Integer;
	id 			: String;
	laneIdOk 	: Boolean;
	
begin
	self.raiseExceptionIfNotTransient (method);
	
	self.laneCount := self.laneCount + 1;
	
	create pxyLane transient;
	
	
	// It's possible that the newly generated lane id may already exist, which is why we loop for a bit 
	// here if necessary.
	foreach count in  self.laneCount to MaxTries do
		id := count.String;			
		if id.length &lt; 2 then
			id := '00' &amp; id;	//07 Dec 2015	NDL	Par 37272 - increase limit from 99 to 150 
		elseif id.length = 2 then	//07 Dec 2015	NDL	Par 37272 - increase limit from 99 to 150 
			id := '0' &amp; id;
		endif;
		if not self.allLanesById.includesKey(id) then
			laneIdOk := true;
			break; // get out asap
		endif;
	endforeach;
	
	if not laneIdOk then
		app.raiseUnexpectedProgramError(class.name, method.name, "Problem generating new line id");
	endif;
	
	pxyLane.setForProxy(
		id,
		self.laneCount,
		CM_RoRoController.ACCESS_DIRECTION_BOTH,
		CM_RoRoController.PARK_DIRECTION_LEFT_TO_RIGHT,
		CM_RoRoController.NUMBERING_DIRECTION_L_TO_R,
		//CM_RoRoController.DEFAULT_LENGTH,					// cnwjk3 PAR 23760 19/04/2010		
		maxLaneLen,											// cnwjk3 PAR 23760 19/04/2010		
		CM_RoRoController.DEFAULT_WIDTH,
		CM_RoRoController.DEFAULT_START_OFFSET,
		self);	
		
	pxyLane.setMyTerminalAreaProxy (self);
	return pxyLane;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="maxLaneLen" type="Real"/>
        <ReturnType type="CM_RoRoController"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="50680cfc-c2ea-4ff5-ada0-158300911d6f">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
18 November 2009	cnwjk3	CCMS 1018
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars
	proxy		: SelfType;
	pxyLane,
	realLane	: CM_RoRoController;
	completedOK		: Boolean;
begin
	proxy :=  inheritMethod();
	foreach  realLane in self.allLanesByLaneNumber do
		pxyLane := realLane.pxyCreateUpdateProxy();
		pxyLane.setRoRoLaneAreaIfProxy(proxy);
	endforeach;	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
