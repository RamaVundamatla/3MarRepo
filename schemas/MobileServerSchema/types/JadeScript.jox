<Class name="JadeScript">
    <JadeMethod name="eprRemoveInternalJob" id="051165e0-994d-484e-81a2-151aa6401d72">
        <source>eprRemoveInternalJob();
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	job : CM_YardInternalJob;
begin

	job:="2736.28".asOid.CM_YardInternalJob;
	
