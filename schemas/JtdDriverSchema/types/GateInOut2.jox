<Class name="GateInOut2" id="c376edb2-2438-4a8c-a583-85f66764bffe">
    <superclass name="JmtTransactionGenerator"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
