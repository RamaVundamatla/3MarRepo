    <JadeMethod name="rel792_par28303" id="053d193f-01b8-4f01-9f69-736246e65cec">
        <source>rel792_par28303();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2012	cnwer1	Initial creation CCMS MES 1033

*/

vars
	transAgent : CM_TranslationAgent;
	entTblAgent : EntTableAgent;
	tmpArray : StringArray;
	termRole : CM_SecurityRoleTerminalRoot;
	sysRole : CM_SecurityRoleSystemRoot;
	newPerms : IntegerArray;
begin
	app.initialize();
	
	create entTblAgent transient;
	entTblAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	
	create tmpArray transient;	
	tmpArray.add("ETRow_Voyage");
	tmpArray.add("ETRow_StowageType");
	tmpArray.add("ETRow_PlannedLocation");
	tmpArray.add("ETRow_Job");
	tmpArray.add("ETRow_ConfirmedLocation");
	tmpArray.add("ETDef_TITMaint");

	
	entTblAgent.trxUpdateFromConstant(tmpArray);	
	
	create transAgent transient;
	tmpArray.clear;
	tmpArray.add("Confirmed_Location");
	tmpArray.add("Work_point_not_found");
	tmpArray.add("Invalid_Cargo_Check_Details");
	tmpArray.add("Invalid_Damage_Details");
	transAgent.trxLoadSpecificErrors(tmpArray);
	
	
	// load new permissions
	create newPerms transient;
	newPerms.add(PmHHTallyman);
	newPerms.add(PmHHTallymanAdmin);
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	beginTransaction;
		termRole.setPermissionsFromIntArray(newPerms, true);	//true if terminal permission
		sysRole.setPermissionsFromIntArray(newPerms, false);	//true if system permission
	commitTransaction;	
	return;
	
	write 	ETRow_Voyage;
	write	ETRow_StowageType;
	write	ETRow_PlannedLocation;
	write	ETRow_Job;
	write	ETRow_ConfirmedLocation;
	write	ETDef_TITMaint;
	write 	Confirmed_Location;
	write 	PmHHTallyman;
	write  	PmHHTallymanAdmin;
	write ETView_TIStowageConfirm;
	write Work_point_not_found;
	write Invalid_Cargo_Check_Details;
	write Invalid_Damage_Details;
epilog
	delete tmpArray;
	delete entTblAgent;
	delete transAgent;
	delete newPerms;
end;</source>
    </JadeMethod>
