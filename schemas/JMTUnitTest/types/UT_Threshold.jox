    <JadeMethod name="addAllPreNotes" id="dbcbbf94-c78f-4820-bde6-dd32042995b8">
        <source>addAllPreNotes(	_mTGrade : CM_MTGrade;
				_operator : CM_Operator
				) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	isoType : String;
	grade : CM_MTGrade;
	cargoType : CM_CargoType;
	
begin

	//threshold priority 1 data
	//2 by rail and 2 by road
	
	isoType := "2200";
	cargoType := app.myRoot.allCargoTypesById[ TI_CargoType_Container ];
	
	self.addPreNotes(	"THRS1110113",	//_id : String;
						isoType,	//_isoType : String;
						_mTGrade,	//_mTGrade : CM_MTGrade;
						_operator,	//_operator : CM_Operator;
						cargoType,	//_cargoType : CM_CargoType;
						TI_TRANSMODE_RAIL	//_transMode : Integer
						);
					
	self.addPreNotes(	"THRS1110114",	//_id : String;
						isoType,	//_isoType : String;
