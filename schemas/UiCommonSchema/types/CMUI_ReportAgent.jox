    <JadeMethod name="initQryReportForBuilder" id="2b153cd9-5f48-4b8d-acba-22156cdeb645">
        <updating/>
        <source>initQryReportForBuilder(_qryReport : CM_QryReport) updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2004 by cnwrs2
//
// Purpose:     called from screens when user selects a report or template
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18 Mar 2010	consw1		PAR #22886 - Leaking report transients
// ---------------------------------------------------------------------------
vars
	jrwReport		: JadeReportWriterReport;

begin
	delete self.myJRWReport;

	if _qryReport = null then
		self.myJRWReport := null;
		self.myQryReport := null;
		self.allCriteriaLineHolders.purge();
		return;
	endif;
	
	self.myQryReport := _qryReport;
	//self.myEntTableDef := app.myController.getEntTableDef(_qryReport.getETDefName());

	self.myJRWReport := self.myJadeReportWriterManager.getReport(_qryReport.jrwReportName.first);
	
	self.doLoadTerminalsForBuilder(_qryReport);

end;</source>
        <Parameter name="_qryReport" type="CM_QryReport"/>
    </JadeMethod>
    <JadeMethod name="initQryReportForRunner" id="e600c8c0-43d2-4929-a870-d5e4438dcf82">
        <updating/>
        <source>initQryReportForRunner(_menuEntity : CM_MenuEntity) updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2004 by cnwrs2
//
// Purpose:     called from screens when user selects a report or template
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18 Mar 2010	consw1		PAR #22886 - Leaking report transients
// 20 May 2021	navmd1		TFS 51190 Handle crap data a bit better
// ---------------------------------------------------------------------------
vars
	tmpQryReport	: CM_QryReport;
	jrwReport		: JadeReportWriterReport;
	newState		: String;

begin

	if _menuEntity = null then
		self.myMenuEntity	:= null;
		self.myQryReport 	:= null;
		
		self.allCriteriaLineHolders.purge();

		return;
	endif;
	
	self.myMenuEntity := _menuEntity;

	if CM_MenuUserReport.hasInstance(_menuEntity) then 
		// This is a template
		tmpQryReport := _menuEntity.CM_MenuUserReport.myQryReport;
		//self.showTableForReport();
		//self.showTableForTemplate(_menuEntity.CM_MenuUserReport);
		newState := STATE_TEMPLATE_VIEW;
	
	elseif CM_MenuUserDtl.hasInstance(_menuEntity) then
		tmpQryReport := _menuEntity.CM_MenuUserDtl.myMenuItem.CM_QryReport;
		newState := STATE_QRYREPORT;
	else
		return;
	endif;
	
	if tmpQryReport = null then
		return;	// Bad data, nothing to do
	endif;
	
	self.myQryReport := tmpQryReport;
	self.setState(newState);
	
	self.myEntTableDef := app.myController.getEntTableDef(tmpQryReport.getETDefName());

	self.doLoadTerminals(tmpQryReport);

	delete self.myJRWReport;
	self.myJRWReport := self.myJadeReportWriterManager.getReport(tmpQryReport.jrwReportName.first);

end;</source>
        <Parameter name="_menuEntity" type="CM_MenuEntity"/>
    </JadeMethod>
