<Class name="CMIF_TimeZoneHelper" id="2e906ceb-0b37-491e-ac99-197d76a1ae7d">
    <superclass name="CMIF_DotNetWrap"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myTimeZoneHelper" id="8f6d89b1-e529-4a30-b004-30c5ec7b9eb0">
        <embedded/>
        <type name="JMTTimeZoneHelper"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="convertTime" id="445ad979-bd9e-4c0e-946a-8916d0d9ebb7">
        <source>convertTime(_ts : TimeStamp; 
			_sourceTimeZoneId : String;
			_destinationTimeZoneId : String) : TimeStamp;

/*

Purpose:			Convert the passed in TimeStamp from the TimeZone identified by _sourceTimeZoneId to
					the TimeZone identified by _destinationTimeZoneId 

Parameters:			TimeStamp to convert, source TimeZone id, destination TimeZone id

Return Value:		Converted TimeStamp

Date		Who		Reason
04 Mar 2016	cnwkpd1	TFS 488 - Multi Timezone Support
21 Apr 2016	cnwkpd1	TFS 1893 - Protect against invalid TimeStamp values, which cause an exception in 
					the JADE conversion to .NET DateTime

*/

vars
	excOccurred		: Boolean;
	returnVal		: TimeStamp;
	
begin
	returnVal := _ts;		// Just in case there is an exception
	
	//jlier1 TFS 64530 10/6/24 noticed hit perfomance to call the C# helper 
	//don't if same timezone as server
	if _sourceTimeZoneId =  _destinationTimeZoneId then
		return returnVal;
	endif;
	
	if _ts.isValid() then	// TFS 1893
		on Exception do self.handleExceptions(exception, excOccurred);
		returnVal := self.myTimeZoneHelper.convertTime(_ts, _sourceTimeZoneId.StringUtf8, _destinationTimeZoneId.StringUtf8);
	endif;
	
	return returnVal;
	
epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_sourceTimeZoneId" type="String"/>
        <Parameter name="_destinationTimeZoneId" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="convertTimeFromUtc" id="246c05cf-4d6e-4278-9472-e277b3030cdf">
        <source>convertTimeFromUtc(_ts : TimeStamp;
				   _destinationTimeZoneId : String) : TimeStamp;

/*

Purpose:			Convert the passed in TimeStamp from UTC to
					the TimeZone identified by _destinationTimeZoneId 

Parameters:			TimeStamp to convert (UTC), destination TimeZone id

Return Value:		Converted TimeStamp

Date		Who		Reason
04 Mar 2016	cnwkpd1	TFS 488 - Multi Timezone Support
21 Apr 2016	cnwkpd1	TFS 1893 - Protect against invalid TimeStamp values, which cause an exception in 
					the JADE conversion to .NET DateTime

*/

vars
	excOccurred		: Boolean;
	returnVal		: TimeStamp;
	
begin
	returnVal := _ts;		// Just in case there is an exception
	
	if _ts.isValid() then	// TFS 1893
		on Exception do self.handleExceptions(exception, excOccurred);
		returnVal := self.myTimeZoneHelper.convertTimeFromUtc(_ts, _destinationTimeZoneId.StringUtf8);
	endif;
	
	return returnVal;
	
epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_destinationTimeZoneId" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="convertTimeToUtc" id="cc97c161-de46-4b63-a3bc-1a28f5ad8721">
        <source>convertTimeToUtc(_ts : TimeStamp;
				 _sourceTimeZoneId : String) : TimeStamp;

/*

Purpose:			Convert the passed in TimeStamp from the TimeZone identified by _sourceTimeZoneId 
					to UTC
					
Parameters:			TimeStamp to convert, source TimeZone id

Return Value:		Converted TimeStamp

Date		Who		Reason
04 Mar 2016	cnwkpd1	TFS 488 - Multi Timezone Support
21 Apr 2016	cnwkpd1	TFS 1893 - Protect against invalid TimeStamp values, which cause an exception in 
					the JADE conversion to .NET DateTime

*/

vars
	excOccurred		: Boolean;
	returnVal		: TimeStamp;
	
begin
	returnVal := _ts;		// Just in case there is an exception
	
	if _ts.isValid() then	// TFS 1893
		on Exception do self.handleExceptions(exception, excOccurred);
		returnVal := self.myTimeZoneHelper.convertTimeToUtc(_ts, _sourceTimeZoneId.StringUtf8);
	endif;
	
	return returnVal;
	
epilog

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_sourceTimeZoneId" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="create" id="e2388b12-cf76-49ee-9327-352f743fcb74">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Mar 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars
	hadException	: Boolean;
	fileName		: String;
	iniValue		: String;
	usePresentation	: Boolean;
	
begin
	on Exception do self.handleExceptions(exception, hadException);
	
	create self.myTimeZoneHelper transient;
	if self.myTimeZoneHelper &lt;&gt; null then
		self.myTimeZoneHelper.usePresentationClient := self.usePresentationClient;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="5886d9ed-74ba-4ba7-87fb-21eba3b37492">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2016	cnwkpd1	TFS 488 - Multi Timezone Support


*/

vars

begin
	delete self.myTimeZoneHelper;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getSystemTimeZoneID" id="393d3a36-35c1-48f3-b356-82341cd98028">
        <source>getSystemTimeZoneID() : String;
/*

Purpose:			Get the Windows Id of the database server local TimeZone

Parameters:			None

Return Value:		

Date		Who		Reason
03 Mar 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars
	excOccurred		: Boolean;
	returnVal		: String;
	
begin
	if self.myTimeZoneHelper = null then
		return null;
	endif;
	
	on Exception do self.handleExceptions(exception, excOccurred);
	returnVal := self.myTimeZoneHelper.getSystemTimeZoneID().String;
	
	return returnVal;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSystemTimeZones" id="1f6b9b6d-7643-4f2f-999f-3fae757276f0">
        <source>getSystemTimeZones(_timeZones : Collection input);
/*

Purpose:			Get all the available TimeZones for the system and add them to the 
					passed in collection.
					Note it is the caller's responsibility to delete the transient CMIF_TimeZoneInfo 
					objects that are returned.

Parameters:			Collection to be populated with CMIF_TimeZoneInfo transients

Return Value:		

Date		Who		Reason
04 Mar 2016	cnwkpd1	TFS 488 - Multi Timezone Support


*/

vars
	xmlString		: String;
	xml				: JadeXMLDocument;
	elements 		: JadeXMLElementArray;
	element			: JadeXMLElement;
	timeZoneInfo	: CMIF_TimeZoneInfo;
	excOccurred		: Boolean;
	
begin
	if self.myTimeZoneHelper = null then
		return;
	endif;
	
	on Exception do self.handleExceptions(exception, excOccurred);
	xmlString := self.myTimeZoneHelper.getSystemTimeZones().String;
	if xmlString = null then
		return;
	endif;
	on Exception do null;
	
	create xml transient;
	xml.parseString(xmlString);
	create elements transient;
	xml.findElementsByTagName("TimeZoneProxy", elements);
	foreach element in elements do
		create timeZoneInfo transient;
		timeZoneInfo.id := element.getElementByTagName("Id").text();
		timeZoneInfo.displayName := element.getElementByTagName("DisplayName").text();
		
		_timeZones.add(timeZoneInfo);
	endforeach;
		
epilog
	delete xml;
	delete elements;
	
end;</source>
        <Parameter name="_timeZones" type="Collection" usage="input"/>
    </JadeMethod>
</Class>
