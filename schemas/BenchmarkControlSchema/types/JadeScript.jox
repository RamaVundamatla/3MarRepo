    <JadeMethod name="checkCardinalBin" id="254dc1f5-5fe7-4151-aea7-adfd7938b839">
        <source>checkCardinalBin(machineName:String);

vars
	f,g:File; ff:FileFolder; fn:FileNode;
	m : Machine;
begin

	create ff; create g; create m transient;
	g.usePresentationFileSystem := false;
	ff.fileName := "\\cnwchcm24\cnwjbl$\Tools\circ\production\";
	//ff.fileName := "\\cnwchcm24\cnwjbl$\Tools\circ\pending\";
	m.hostName := machineName;

	foreach fn in ff.files where fn.isKindOf(File) do
		f := fn.File;
		f.usePresentationFileSystem := false;
		g.fileName := "\\" &amp; m.hostName &amp; "\c$\cardinal\bin\" &amp; f.name;
		if not g.isAvailable then
			write "File does not exist: " &amp; g.fileName;
			continue;
		endif;
		if g.lastModifiedTime &lt;&gt; f.lastModifiedTime then
			write g.fileName &amp; " " &amp; g.lastModifiedTime.String &amp; " timestamp does not match circ\production";
		endif;
	endforeach;

epilog
	delete ff; delete g; delete m;
end;</source>
        <Parameter name="machineName" type="String"/>
    </JadeMethod>
    <JadeMethod name="checkCardinalBins" id="c421543d-6531-4627-996b-d13c720bd2de">
        <source>checkCardinalBins();

vars
	machine:Machine;
begin
	write CrLf &amp; "Starting";
	
	write "checking cnwchcs118";
	checkCardinalBin("cnwchcs118");
	
	foreach machine in Machine.instances do
		if machine.hostName = "cnwchcs113" or machine.hostName = "wynchcs238" then  // these machines are currently dead, so don't bother
			continue;
		endif;
		write "checking " &amp; machine.hostName;
		if machine.respondsToPing then
			checkCardinalBin(machine.hostName);
		else
			write machine.hostName &amp; " isn't responding to ping";
		endif;
	endforeach;
	
	write "Finished";
epilog
	
end;</source>
    </JadeMethod>
