        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInput1_click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin 
	if table.row &lt;= table.fixedRows then
		return;
	endif;
    if self.mode = self.Mode_View then
    	return;
    endif;  
	
	self.doTblInput1Click(table);
end;</source>
