    <JadeMethod name="setComboValues" id="57f80c52-0db6-43db-9ed7-aa6444791244">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
09/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/
vars
	grade	: CM_MTGrade;
	coll	: CM_MTGradeByCodeDict;
begin
	_combo.clear();
	
	coll := app.myRoot.allAvailabilityGrades;
	
	foreach grade in coll do
		_combo.itemObject[_combo.addItem(grade.code.String &amp; Tab &amp; grade.description)] := grade;
	endforeach;

	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := coll[_queryOperator.CM_QStringLookup.selectionValue.Integer];
		
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := coll[_queryOperator.CM_QStringLookupNotEqual.selectionValue.Integer];	
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="47470b49-29a6-4e32-bb84-b5a0baaaf493">
        <source>translateToDisplayValue(_value: Any): String;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
09/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
01/03/2010	cnwcs5	PAR 22454 - use description instead of code
*/
vars

begin
	if _value.isKindOf(CM_MTGrade) then
		if _value &lt;&gt; null then
			return _value.CM_MTGrade.description.String;	// 01/03/2010 par 22454 cnwcs5 
			//return _value.CM_MTGrade.code.String;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="466f1d4c-08bb-4f6d-9232-9b5f37d6eab8">
        <source>translateToSearchValue(_value: Any): Any;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/
vars
			
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_MTGrade) then
			return _value.CM_MTGrade;
		endif;
	endif;
	
	return app.myRoot.allAvailabilityGrades[_value.Integer];
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="53983176-53c8-4813-800b-fe523d880a50">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	if _value.isKindOf(Integer) then
		return app.myRoot.allAvailabilityGrades[_value.Integer];
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
