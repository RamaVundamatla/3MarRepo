    <JadeMethod name="createVoyageQueue" id="7b801d9e-b1f1-49e3-a86e-cb776542229a">
        <updating/>
        <source>createVoyageQueue(voy : CM_Voyage input;  createdQueue : CM_RadioTelemetryQueue output) updating;
//Call this to create a NEW VOYAGE Queue under the master.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/10/2025	jlizm1		MTN 35861 RTQueue configuration - cargo attribute criteria
// ---------------------------------------------------------------------------
vars
	tStr				: String;
	theQueue			: CM_RadioTelemetryQueue;			
	proxyVoyageQueue	: CM_VoyageQueue;
begin
	if voy = null then
		//No voyage Oid! Quit
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_VOY_QUEUE_VOY, null, null);
		return;
	endif;
	//--------------
	//Id here is made up of the voyage ID automatically. The users cannot specify it.
	//--------------
	tStr := voy.code.trimBlanks;		
	if tStr = null then
		//No ID!!! Error
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_NO_QUEUE_ID, null, null);
		return;
	endif;
	if self.allSubQueuesById[tStr] &lt;&gt; null then
		//Duplicated, error!
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_QUEUE_EXISTS, tStr, null, null);
		return;
	endif;
	//--------------
	//New Queue entry.
	//--------------
	create proxyVoyageQueue transient;
	proxyVoyageQueue.setProxy(tStr, voy, self);
	app.myUtilityCA.utlCreateRTQueue(proxyVoyageQueue, theQueue, null, app.myPassport );

	createdQueue := theQueue;
epilog
	delete proxyVoyageQueue;
end;</source>
        <Parameter name="voy" type="CM_Voyage" usage="input"/>
        <Parameter name="createdQueue" type="CM_RadioTelemetryQueue" usage="output"/>
    </JadeMethod>
    <JadeMethod name="erase" id="06266b58-3ee4-459d-8573-10dc467d6323">
