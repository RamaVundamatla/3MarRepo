    <JadeMethod name="scrMenu_change" id="e80572b3-8e20-493c-972d-614e16db2f5b">
        <controlMethod name="ScrollBar::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>scrMenu_change(scroll: ScrollBar input) updating;
// ---------------------------------------------------------------------------
// Created:	07 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	
	self.setMenuScrollStart( scroll, self.btnMenuTemplate, self.frmMenu, self.getSessionAgent().allAvailableForms.size );
	
epilog
end;</source>
        <Parameter name="scroll" type="ScrollBar" usage="input"/>
