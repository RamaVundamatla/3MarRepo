<CollClass name="CM_RTQueueMultiRuleByTAMasters" id="39c1d091-fee0-432e-9762-98e8fe762a9d">
    <loadFactor>66</loadFactor>
    <memberType name="CM_RTQueueMultiRuleTAMaster"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="planning"/>
    <MemberKey>
        <property name="CM_RTQueueMultiRuleTAMaster::myFromTAMaster"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_RTQueueMultiRuleTAMaster::myToTAMaster"/>
    </MemberKey>
    <JadeMethod name="includesRulesFor" id="cb6ce1f4-b1f9-4afc-8faa-39bffe277235">
        <source>includesRulesFor( _termArea : CM_TerminalArea ): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 November 2011	cnwndl1	Initial creation	Par 28727

*/

vars

	iter : Iterator;
	rule : CM_RTQueueMultiRuleTAMaster;

begin

	iter := self.createIterator;
	while iter.next( rule ) do
		if rule.myFromTAMaster = _termArea then
			return true;
		endif;
		if rule.myToTAMaster = _termArea then
			return true;
		endif;
	endwhile;

	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
