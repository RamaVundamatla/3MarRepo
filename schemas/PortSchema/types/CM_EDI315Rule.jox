    <JadeMethod name="getFunctionCode" id="e3012999-2b1b-4dc4-b41f-16b51fd28c32">
        <source>getFunctionCode(_description: String): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2015	cnwrd1	Initial creation
22 May 2018 jlggb1	Add Release Rule TFS 36933

*/

vars

begin
	if _description = self.Function_B403_StopAdd_Desc then
		return self.Function_B403_StopAdd;
	elseif _description = self.Function_B403_StopRemove_Desc then
		return self.Function_B403_StopRemove;
	elseif _description = self.Function_N903_CreateRelease_D then
		return self.Function_N903_CreateRelease;
	else
		return null;
	endif;
	
epilog

end;</source>
        <Parameter name="_description" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFunctionDescription" id="3d085c7c-905c-401b-b0f5-7db711409225">
        <source>getFunctionDescription(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2015	cnwrd1	Initial creation
22 May 2018 jlggb1	Add Release Rule TFS 36933
*/

vars

	code : Integer;
begin

	code := self.function;
	
	if code = self.Function_B403_StopAdd then
		return self.Function_B403_StopAdd_Desc;
	elseif code = self.Function_B403_StopRemove then
		return self.Function_B403_StopRemove_Desc;
	elseif code = self.Function_N903_CreateRelease then
		return self.Function_N903_CreateRelease_D;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
