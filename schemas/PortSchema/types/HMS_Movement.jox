    <JadeMethod name="getIfLegSameAsLastDeparture" id="0791cb20-3fa0-4b19-9664-f26171c79bf0">
        <source>getIfLegSameAsLastDeparture() : HMS_Movement;
//-----------------------------------------------------------------------
//	Created:	12 February 2007 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
begin
	
	if self.myPreviousMovement &lt;&gt; null then
		if self.getMyBerth().myHarbourRegion = self.myPreviousMovement.getMyBerth().myHarbourRegion then
			return self.myPreviousMovement;
		endif;
	endif;
	
	return null;
end;</source>
