    <JadeMethod name="getSelectedEventTypes" id="1493393e-2afe-48cb-bc53-8c6313f1f4e8">
        <source>getSelectedEventTypes(_eventTypes: IntegerArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 March 2009	#cnwdz2	 PAR19281  Correct selection of event types
*/

vars
	str 		: String;
	strArray	: StringArray; //HugeStringArray;
	eventType		: Integer;
	reportParam	: WS_ReportParameter;
	
begin

	reportParam := self.allWSReportParams.getAtKey(ETRow_AllEventTypes);
	if reportParam &lt;&gt; null then
		str := reportParam.value;
	endif;	
	
	_eventTypes.clear();
	
	if str.length &gt; 0 then
		create strArray transient;
		str.getTokensForDelimiter("|", strArray);
		foreach str in strArray do
			_eventTypes.add(str.Integer);
		endforeach;
	endif;


epilog
	delete strArray;
end;</source>
        <Parameter name="_eventTypes" type="IntegerArray" usage="input"/>
    </JadeMethod>
