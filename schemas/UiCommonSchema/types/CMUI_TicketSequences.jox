end;</source>
    </JadeMethod>
    <JadeMethod name="initTables" id="9998097e-c184-4311-8e05-6935b7d3cb9c">
        <updating/>
        <source>initTables() updating;
//--------------------------------------------------------------
//Created: 01 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entTableDef 	: EntTableDef;
	intFaceTicketSeq: CMIF_TIObject;
	remaining,
	tmpRow			: Integer;
	ticketSeq		: CM_TicketSequence;

begin

	self.isScaleVisible := true;

	tblItem.warningMethod := 'entTableWarning';
	entTableDef := app.myController.getEntTableDef('TicketSequence');
	tblItem.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');

	self.myCurrentView := entTableDef.allEntTableViews['LogTicketSeq'];	
	if self.myCurrentView &lt;&gt; null then
		tblItem.showHideRowsByView(self.myCurrentView, CM_EntryTable.ShowHideRows, false);
	else
		tblItem.showHideRowsByList(null, CM_EntryTable.ShowHideRows, false);
	endif;
	
	self.tblItem.setValueByName(ETRow_Scale, true);	
	if not self.myTicketSequenceRules.jasScaled then
		tblItem.hideRowByName(ETRow_Scale, false);
		self.isScaleVisible := false;		
	endif;
	
	if self.myTicketSequenceRules.ticketedAll then
		if self.myTicketSequenceRules.percentageScaled = 100 then
			tblItem.hideRowByName(ETRow_Scale, false);
			self.isScaleVisible := false;		
		else
			self.tblItem.setValueByName(ETRow_Scale, true);
		endif;
	endif;	

	if (not self.myTicketSequenceRules.ticketedAll) and
	   self.myTicketSequenceRules.percentageScaled = 100 then
		tblItem.hideRowByName(ETRow_Scale, false);
		self.isScaleVisible := false;		
	endif;		

	if self.isScaleVisible then
		tblAll.addItemAt('From Id' &amp; Tab &amp; 'To Id' &amp; Tab &amp; 'Quantity' &amp; Tab &amp; 'Scale', 1);
	else
		tblAll.addItemAt('From Id' &amp; Tab &amp; 'To Id' &amp; Tab &amp; 'Quantity', 1);
	endif;
	tblAll.rows := 1;

	foreach ticketSeq in self.myTicketSequenceRules.allTicketSequences do
		tmpRow := self.tblAll_ShowTicketSeq(ticketSeq, 0);
	endforeach;	

	txtRequired.text := self.calculateRequired().String;
	remaining := self.calculateRemaining();
	if remaining &lt; 0 then
		remaining := 0;
	endif;
	txtRemaining.text := remaining.String;
	//self.showRemaining();
	self.setFieldScale();
	btnAdd.default := true;
	btnUpdate.enabled := false;
	btnRemove.enabled := false;
	lbScale.caption := lbScale.caption &amp; ' ' &amp; self.myTicketSequenceRules.totalToScale.String;
	tblItem.setFocus();
	tblItem.moveFirst();
	self.tblItem.goToRowByName(ETRow_FromId);	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="ec61e41b-8864-4c5a-934c-c6342ae27636">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------------------
//Created: 26 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	theActiveControl	: Control;
	
begin

	if keyCode = J_key_Tab then

		tblItem.handleFormTab(keyCode, shift, btnCancelBase, tblItem);
		self.setFieldToID();
		theActiveControl := app.activeControl;
		if theActiveControl.parent.isKindOf(CM_EntryTable) then
			theActiveControl := theActiveControl.parent.Control;
		endif;
		if theActiveControl.isKindOf(CM_EntryTable) then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;
	else
		inheritMethod(keyCode, shift);
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeItem" id="beaa5cc1-6e76-4d0f-a665-8bd4334c2c05">
        <updating/>
        <source>removeItem() updating, protected;
//--------------------------------------------------------------
//Created: 20 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj		: Object;
	//intFaceAttach : CMIF_InOutTicketSequence; 
	row ,original : Integer;
begin
	if app.msgBox(app.getErrorString2(ConfirmDelete, 'selected', 'ticket sequence'), 'Confirm Delete', MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;
	
	if tblAll.row &gt; 1 and tblAll.row &lt;= tblAll.rows then
		obj := tblAll.accessRow(tblAll.row).itemObject;
		row:=tblAll.row;
		if obj &lt;&gt; null then
			self.myTicketSequenceRules.allTicketSequences.remove(obj.CM_TicketSequence);
			//self.allTicketSequences.remove(obj.CMIF_InOutTicketSequence);
			delete obj;
		endif;
		tblAll.removeItem(tblAll.row);
	  if tblAll.rows&lt;&gt;1 then
	     original:= tblAll.rows+1;
	     if row=original then	        
	        row:=2;
	     endif;   
	     //self.mySelectedItem := tblAll.accessRow(row).itemObject.CMIF_InOutTicketSequence;
		 self.myCurrentTicket := tblAll.accessRow(row).itemObject.CM_TicketSequence;	     
	     tblAll.accessRow(row).selected := true;
			 selectedRow := row;
			 if self.myCurrentTicket &lt;&gt; null then
	      	self.showSelectedItem();
	     endif;
	  else 
	     tblItem.clearValues;
	     self.myCurrentTicket := null;
	  endif;  
	endif;
	self.showRemaining();
	self.setFieldScale();
	tblItem.setFocus();
epilog
	self.tblItem.setFocus;
	self.tblItem.goToRowByName(ETRow_FromId);	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="8b92841c-f84d-4964-a1ea-b3e7dfb1f951">
        <updating/>
        <source>setEnableObjects() updating, protected;
//--------------------------------------------------------------
//Created: 26 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
/*	if txtRemaining.text.Integer &lt;= 0 then
		btnAdd.enabled := false;
	else
		btnAdd.enabled := true;
	endif;
*/
	if self.myCurrentTicket &lt;&gt; null then
		self.btnRemove.enabled := true;
		self.btnUpdate.enabled := true;
	else
		self.btnRemove.enabled := false;
		self.btnUpdate.enabled := false;	
	endif;
	
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFieldFromID" id="f3b78dac-a5c1-490d-9001-af1ddd36f231">
        <updating/>
        <source>setFieldFromID() updating, protected;
//--------------------------------------------------------------
//Created: 26 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	numTo,
	numFrom,
	lastNum : String;
begin
	numTo := tblItem.getValueByName(ETRow_ToId).String;

	if numTo &lt;&gt; null then
		numFrom := numTo.incrementID(1);
	endif;
	
	self.tblItem.setValueByName(ETRow_FromId, numFrom);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFieldScale" id="f046b060-da24-437f-8213-558f1bf7536c">
        <source>setFieldScale() protected;
//--------------------------------------------------------------
//Created: 07 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	toScale : Integer;
begin
	if not self.isScaleVisible then
		return;
	endif;
	
	toScale := (self.myTicketSequenceRules.totalToScale - self.myTicketSequenceRules.calculateExisting());
	
	if toScale &gt; 0 then
		self.tblItem.setValueByName(ETRow_Scale, true);	
	else
		self.tblItem.setValueByName(ETRow_Scale, false);			
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFieldToID" id="6047fbca-c28c-46e1-8c1e-608df862add4">
        <updating/>
        <source>setFieldToID() updating, protected;
//--------------------------------------------------------------
//Created: 26 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	numTo,
	numFrom,
	lastNum : String;
	numReq, padNum : Integer;
	toScale : Boolean;
	trailingNum  : String;
begin
	
	numFrom := 	tblItem.getValueByName(ETRow_FromId).String;
	numTo := tblItem.getValueByName(ETRow_ToId).String;
		
	if numFrom = null then
		return;
	endif;
	if self.isScaleVisible then
		toScale := self.tblItem.getValueByName(ETRow_Scale).Boolean;
		if toScale then
			numReq := (self.myTicketSequenceRules.totalToScale - 1);
		else
			numReq := (self.calculateRemaining() - 1);		
		endif;
			
	else
		numReq := (self.calculateRemaining() - 1);
	endif;
	
	if numReq &gt; 0 then
		numTo := numFrom.incrementID(numReq);
		self.tblItem.setValueByName(ETRow_ToId, numTo);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFieldsTblItem" id="3fee795e-53fd-4f05-b821-0d001e4540b2">
        <updating/>
        <source>setFieldsTblItem(_qty : Integer output) : Boolean updating, protected;
//--------------------------------------------------------------
//Created: 29 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	strTo,
	strFrom	: String;
	numTo,
	numFrom	: Integer;
begin
	strFrom := tblItem.getValueByName(ETRow_FromId).String;
	
	if strFrom = null then
		return true;
	endif;
	
	strTo := tblItem.getValueByName(ETRow_ToId).String;
	
	if strTo = null then
		self.setFieldToID();
		return true;
	endif;
	
	numFrom := strFrom.getTrailingInteger();
	numTo := strTo.getTrailingInteger();
	
	on CM_Exception do addExceptionHandler(exception, app.myPassport);

	app.setContinueCMExceptions(true);
	
	self.validateSequence(numFrom, numTo);

	if app.myPassport.hasErrors then
		app.showErrorWarningDialog('Ticket Sequences', app.myPassport, ErrWarnMode_Update);
		return true;
	endif;	
	
	_qty := (numTo.Integer - numFrom.Integer) + 1;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_qty" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a0b11239-f766-47bc-aeca-9bdc1fce2685">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     16 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	self.sptMain.setLeftToRightRatioAndResize(30);
	self.doResize();
end;</source>
    </JadeMethod>
    <JadeMethod name="showRemaining" id="529b3022-2882-4c35-b479-1c93e0db0c94">
        <updating/>
        <source>showRemaining() : Boolean updating, protected;
// -----------------------------------------------------------------------------
// Created:		09 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	remaining : Integer;
begin
	remaining := self.calculateRemaining();
	
	if remaining &lt; 0 then
		app.raiseCMException1(NUM_TICKETS_EXCEEDED, txtRemaining.text, null, null);
		return false;
	endif;

	self.txtRemaining.text := remaining.String;
	self.setEnableObjects();
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showSelectedItem" id="1bbbcaf0-7fc9-4266-b2d6-a53b5136be89">
        <updating/>
        <source>showSelectedItem()updating, protected;
//--------------------------------------------------------------
//Created: 19 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	selectedItem : CM_TicketSequence;
begin
	

	
	self.tblItem.clearValues();
	self.tblItem.setValueByName(ETRow_FromId, myCurrentTicket.fromId);
	self.tblItem.setValueByName(ETRow_ToId, myCurrentTicket.toId);
	self.tblItem.setValueByName(ETRow_Scale, myCurrentTicket.scale);

	btnUpdate.enabled := true;
	btnRemove.enabled := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblAll_ShowTicketSeq" id="d9739a08-67f6-45dd-95a6-422ec7d4b4a8">
        <updating/>
        <source>tblAll_ShowTicketSeq(_ticketSeq : CM_TicketSequence; pRow : Integer) : Integer updating, protected;
//--------------------------------------------------------------
//Created: 19 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str		: String;
	theRow	: Integer;
	toScale : String;	
begin

	if _ticketSeq.scale then
		toScale := 'Yes';
	else
		toScale := 'No';
	endif;
	
	str := _ticketSeq.fromId &amp; Tab &amp;
			_ticketSeq.toId &amp; Tab &amp;
			_ticketSeq.quantity.String;

	if self.isScaleVisible then
		str := str &amp; Tab &amp; toScale;
	endif;
	
	if pRow = 0 then
		theRow := tblAll.addItem(str);
	else
		theRow := pRow;
		tblAll.accessCell(theRow, 1).text := str;
	endif;
	
	tblAll.accessRow(theRow).itemObject := _ticketSeq;
	
	return theRow;

end;</source>
        <access>protected</access>
        <Parameter name="_ticketSeq" type="CM_TicketSequence"/>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblAll_click" id="e563dec8-9d91-42c5-8085-e3bb292adc9e">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAll_click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theObject : Object;
begin
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	table.accessRow(table.row).selected := true;
	self.myCurrentTicket := table.accessRow(table.row).itemObject.CM_TicketSequence;
	self.showSelectedItem();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c5255d09-1378-4dbd-9f80-0bbc7060234d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008209, locale);
	lbScale.translateCaption(Xlat_0001076, locale);
	lblRemaining.translateCaption(Xlat_0001074, locale);
	lblRequired.translateCaption(Xlat_0001075, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateItem" id="ff5588db-10fa-4ea1-86ca-722765a3b8d8">
        <updating/>
        <source>updateItem() : Boolean updating;
//--------------------------------------------------------------
//Created: 22 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	qty,
	cargoType	: Integer;
	rtValue 	: Boolean;
	oldToId,
	oldFromId	: String;
begin

	if self.tblAll.row &lt;= self.tblAll.fixedRows then
		return false;
	endif;
	if self.myCurrentTicket = null then
		return false;
	endif;

	oldFromId := self.myCurrentTicket.fromId;
	rtValue := self.setFieldsTblItem(qty);
	if rtValue then
		return false;	//Just a reset of the table fields then
	endif;

	self.myCurrentTicket.setProxy(tblItem.getValueByName(ETRow_FromId).String,
					 		tblItem.getValueByName(ETRow_ToId).String, qty,					 
					 		tblItem.getValueByName(ETRow_Scale).Boolean);

	// check all fields have been entered

	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();

	self.myCurrentTicket.checkFieldNotNull();
	if oldFromId &lt;&gt; self.myCurrentTicket.fromId then
		self.checkForDuplicateId(self.myCurrentTicket);	
	endif;

	if app.myPassport.hasErrors then
		app.showErrorWarningDialog('Ticket Sequences', app.myPassport, ErrWarnMode_Update);
		return false;
	endif;

	if (not self.showRemaining()) then
		app.showErrorWarningDialog('Ticket Sequences', app.myPassport, ErrWarnMode_Update);
		return false;
	endif;
	
	on CM_Exception do null;

	tblAll_ShowTicketSeq(self.myCurrentTicket, self.tblAll.row);
	self.setFieldScale();

	return true;
epilog
	self.tblItem.setFocus;
	self.tblItem.goToRowByName(ETRow_FromId);	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSequence" id="972edd23-9287-4321-a6bd-8758ee546630">
        <source>validateSequence(_from, _to: Integer) protected;
//--------------------------------------------------------------
//Created: 03 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _from &gt; _to then
		app.raiseCMException(ERR_BASE_NOT_GT_CURRENT, ETRow_FromId, null);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_from" type="Integer"/>
        <Parameter name="_to" type="Integer"/>
    </JadeMethod>
</GUIClass>
