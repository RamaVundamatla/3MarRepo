    <JadeMethod name="formatLengthAsFFFII" id="7c6b4336-0a39-4a38-abcf-bc2b3ea57a52">
        <source>formatLengthAsFFFII( _cms : Decimal ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2019	jlgndl1	Initial creation	TFS 44710 - Format length in feet and inches for X12
										up to 999 feet and 11 inches.

*/

vars

	overFlowed : Boolean;
	rawInchesDec : Decimal [10,1];
	msg : String;
	feet : Integer;
	remInchesDec : Decimal [4,1];
	inches : Integer;
	returnString : String;

begin

	if _cms &lt;= 0 then
		return '000';  //i.e. 0 feet 00 inches.
	endif;
	
	on Exception do app.handlePrecisionError(exception, overFlowed );

	rawInchesDec := (_cms / 2.54).roundedTo(1);
	if overFlowed then
		msg := app.getErrorString( Precision_overflow_error );
		msg := msg &amp; "  " &amp; app.getErrorString3( Unable_convert_for_display, _cms.String, "2.54", method.qualifiedName );
		app.createAlertWithProcessStack(msg, true);
		return null;
	endif;
		
	if rawInchesDec &gt;= 12 then
		feet := ( rawInchesDec / 12 ).Integer;
		remInchesDec := rawInchesDec mod 12;
	else
		remInchesDec := rawInchesDec;
	endif;
	
	if remInchesDec &gt; 0 then
		inches := remInchesDec.Integer;
		if remInchesDec - inches &gt;= 0.5 then
			//round up.
			inches := inches + 1;
			if inches = 12 then
				//increment feet.
				feet := feet + 1;
				inches := 0;
			endif;
		endif;
	endif;
	
	if feet = 0 then
		returnString := '0';
	elseif feet &gt; 999 then
		returnString := '999';
	else
		returnString := feet.String;
	endif;
	
	if inches = 0 then
		returnString := returnString &amp; "00";
	else
		returnString := returnString &amp; inches.padLeadingWith('0',2);
	endif;
	
	return returnString;

epilog

end;</source>
        <Parameter name="_cms" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAssociatedBOL" id="80ae83cc-f381-4051-ab3b-321ea9e73f00">
        <source>getAssociatedBOL(_trackedItem : CM_TrackedItem; _camProtocol: CM_CamProtocol) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2019	jlgsl4	TFS 44525 - PEN - use child BOL for X12322 if no container BOL

*/

vars
	children : CM_TISet;
	child : CM_TrackedItem;
begin
	if _trackedItem.billOfLading &lt;&gt; null then
		return _trackedItem.billOfLading;
	else // if parent has no BOL
		children := _trackedItem.getAllChildrenCollection();
		if children.isNotEmpty() then // use child BOL details
			foreach child in children where child.billOfLading &lt;&gt; null do
				return child.billOfLading; // return BOL for first child which has one
			endforeach;
		endif;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <ReturnType type="String"/>
    </JadeMethod>
