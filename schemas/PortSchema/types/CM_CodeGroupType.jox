    <JadeMethod name="myCodeClassToCreate" id="b85e7aa7-ec3d-4f70-aef2-b88c5d435bc1">
        <methodInvocation>mapping</methodInvocation>
        <source>myCodeClassToCreate(set: Boolean; _value: Class io) mapping;
// ---------------------------------------------------------------------------
// Created:     06 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := currentSchema.getClass(self.codeClassNameToCreate);
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Class" usage="io"/>
    </JadeMethod>
