    <JadeMethod name="applyDeckingRulesToCellOrder" id="59e64b5e-af23-45c5-b47f-bec1dd535c8b">
        <source>applyDeckingRulesToCellOrder();
//----------------------------------------------------------------
//	Created:	26 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	inheritMethod();

	//do non-custom options
	self.myTerminalArea.applyDeckingRulesToCellOrder();
	
	//fire note here
	self.myTerminalArea.causeEvent(self.myTerminalArea.myTerminal.getTerminalEvent(EVENT_DECKING_CHANGE),false,self.myTerminalArea);

end;</source>
    </JadeMethod>
    <JadeMethod name="fixupForDecking" id="c0190944-8844-4a1a-8742-30a321d2ab72">
        <source>fixupForDecking();
//----------------------------------------------------------------
//	Created:	28 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	locnCell		: CM_YALocationCell;
begin

	if self.allYALocationCellsIn.isEmpty
	and (not self.allYALocationCellsOut.isEmpty) then
		foreach locnCell in self.allYALocationCellsOut reversed do
			self.allYALocationCellsIn.add(locnCell);
		endforeach;
	endif;

	if (not self.allYALocationCellsIn.isEmpty)
	and self.allYALocationCellsOut.isEmpty then
		foreach locnCell in self.allYALocationCellsIn reversed do
			self.allYALocationCellsOut.add(locnCell);
		endforeach;
	endif;

	if self.allYALocationCellsIn.size &lt;&gt; self.allYALocationCellsOut.size then
		//what can we do here?
		foreach locnCell in self.allYALocationCellsIn do
			if not self.allYALocationCellsOut.includes(locnCell) then
				self.allYALocationCellsOut.add(locnCell);
			endif;
		endforeach;
	
		foreach locnCell in self.allYALocationCellsOut do
			if not self.allYALocationCellsIn.includes(locnCell) then
				self.allYALocationCellsIn.add(locnCell);
			endif;
		endforeach;

		//perhaps better to start over from stratch

	endif;

	

end;</source>
    </JadeMethod>
    <JadeMethod name="getDefaultRuleIn" id="850a2949-f8e7-474e-91f0-01e19554a6a9">
        <source>getDefaultRuleIn(_height: Integer): Integer;
//----------------------------------------------------------------
//	Created:	20 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

begin
	
	if self.myTerminalArea = null then
		return inheritMethod(_height);
	endif;
	
	if self.myTerminalArea.type	= TA_TYPE_FORK_LIFT_STACK then
		return Height_Then_Next_Col_Pos;
	else
		return Height_Then_Next_Row_Pos;
	endif;
end;</source>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="93d51af4-bd2d-4e3b-80cd-9051df6281c9">
        <source>getDisplayString(): String;
//----------------------------------------------------------------
//	Created:	09 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str	: String;
begin
	str := app.getErrorString(TerminalArea);
	str.firstCharToUpper();
	
	return str &amp; " " &amp; self.myTerminalArea.id;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGridArea" id="f4264084-06d6-42c0-b2fd-9f7b0bdd813e">
        <source>getGridArea(): CM_GridArea;
//----------------------------------------------------------------
//	Created:	26 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if CM_GridArea.hasInstance(self.myTerminalArea) then
		return self.myTerminalArea.CM_GridArea;
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="getLocationCellArray" id="eae61f19-e04f-4a73-84cb-44590cd48415">
        <source>getLocationCellArray(_in: Boolean): CM_YALocationCellArray;
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _in then
		return self.allYALocationCellsIn;
	else
		return self.allYALocationCellsOut;
	endif;

end;</source>
        <Parameter name="_in" type="Boolean"/>
        <ReturnType type="CM_YALocationCellArray"/>
    </JadeMethod>
    <JadeMethod name="getStackHeight" id="330269bb-1f67-4cca-94cc-f84a90af1892">
        <source>getStackHeight(): Integer;
//----------------------------------------------------------------
//	Created:	14 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if CM_GridArea.hasInstance(self.myTerminalArea) then
		return self.myTerminalArea.CM_GridArea.heightOfStack;
	endif;
	
	return 1; //the number of LocationCells for the location controller
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTerminalArea" id="d8bc661f-dbff-4681-bd28-c1436de80658">
        <source>getTerminalArea(): CM_TerminalArea;
//----------------------------------------------------------------
//	Created:	20 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	return self.getGridArea();

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="initialiseForDecking" id="88ab08b7-594b-42f8-aec5-2edcb59d5e3d">
        <updating/>
        <source>initialiseForDecking() updating;
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
begin
	
	if self.allYALocationCellsIn.isEmpty
	and self.allYALocationCellsOut.isEmpty then
		self.myTerminalArea.initialiseForDecking(self);
	else
		//fixup
		self.fixupForDecking();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="isDeckingDirectionDown" id="82e40c4b-7e10-426f-a375-37c184aa76f2">
        <source>isDeckingDirectionDown(_row: CM_GridRow): Boolean;
//----------------------------------------------------------------
//	Created:	02 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	int				: Integer;
	gridArea		: CM_GridArea;
	row				: CM_GridRow;
	gridController,
	gridContBefore,
	gridContAfter	: CM_GridController;
	index			: Integer;
	yaCell1,
	yaCell2			: CM_YALocationCell;
begin

	gridArea := self.getGridArea();
	
	if gridArea = null then
		return false;
	endif;
	
	index := gridArea.allGridRowsByLabel.indexOf(_row);
	
	if index = null then
		return false;
	endif;
	
	foreach row in gridArea.allGridRowsByLabel do
		int := int + 1;
		if int = (index-1) then
			gridContBefore := row.allControllersByColumn.first;
			break;
		endif;
		if int = (index+1) then
			gridContAfter := row.allControllersByColumn.first;
			break;
		endif;
	endforeach;		
	
	gridController := _row.allControllersByColumn.first;
	
	if gridContBefore &lt;&gt; null then
		yaCell1 := gridContBefore.allYAYardLocationCells.first;
		yaCell2 := gridController.allYAYardLocationCells.first;
	elseif gridContAfter &lt;&gt; null then
		yaCell1 := gridController.allYAYardLocationCells.first;
		yaCell2 := gridContAfter.allYAYardLocationCells.first;
	else
		return false;
	endif;	

	if self.allYALocationCellsIn.indexOf(yaCell1) &lt; self.allYALocationCellsIn.indexOf(yaCell2) then
		return true;
	endif;
	
	return false;	
				
end;</source>
        <Parameter name="_row" type="CM_GridRow"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDeckingDirectionUp" id="0e52b513-0c00-41c3-abb3-0997b03e4c5a">
        <source>isDeckingDirectionUp(_row: CM_GridRow): Boolean;
//---------------------------------------------------------
//	Created:	02 June 2005	by Jason Chapman  (cnwjc2)
//---------------------------------------------------------
vars
	int				: Integer;
	gridArea		: CM_GridArea;
	row				: CM_GridRow;
	gridController,
	gridContBefore,
	gridContAfter	: CM_GridController;
	index			: Integer;
	yaCell1,
	yaCell2			: CM_YALocationCell;
begin

	gridArea := self.getGridArea();
	
	if gridArea = null then
		return false;
	endif;
	
	index := gridArea.allGridRowsByLabel.indexOf(_row);
	
	if index = null then
		return false;
	endif;
	
	foreach row in gridArea.allGridRowsByLabel do
		int := int + 1;
		if int = (index-1) then
			gridContBefore := row.allControllersByColumn.first;
			break;
		endif;
		if int = (index+1) then
			gridContAfter := row.allControllersByColumn.first;
			break;
		endif;
	endforeach;		
	
	gridController := _row.allControllersByColumn.first;
	
	if gridContBefore &lt;&gt; null then
		yaCell1 := gridContBefore.allYAYardLocationCells.first;
		yaCell2 := gridController.allYAYardLocationCells.first;
	elseif gridContAfter &lt;&gt; null then
		yaCell1 := gridController.allYAYardLocationCells.first;
		yaCell2 := gridContAfter.allYAYardLocationCells.first;
	else
		return false;
	endif;	

	if self.allYALocationCellsIn.indexOf(yaCell1) &gt; self.allYALocationCellsIn.indexOf(yaCell2) then
		return true;
	endif;
	
	return false;	
				
end;</source>
        <Parameter name="_row" type="CM_GridRow"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
