        <source>addWLE(_qty: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2009	cnwrd1	Initial creation

*/

vars

begin
	inheritMethod(_qty);
	
	if self.myRelease &lt;&gt; null then
		self.myRelease.setNumberWLECreated( self.myRelease.numberWLECreated + _qty);	
	endif;

epilog

end;</source>
