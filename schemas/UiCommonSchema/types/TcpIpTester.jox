    </JadeMethod>
    <JadeMethod name="readBinaryAsynchCB" id="42485a78-12db-4177-a71d-9c24a3302cf9">
        <source>readBinaryAsynchCB(_tcp:    TcpIpConnection; _buffer: Binary);
// -----------------------------------------------------------------------------
// Created:		26 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if _tcp = self.myConnection then
		self.writeToFile(_buffer);
		self.myConnection.readBinaryAsynch(BufferLength, self, 'readBinaryAsynchCB');		
	endif;
end;</source>
        <Parameter name="_tcp" type="TcpIpConnection"/>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="unload" id="f2b34ad0-afc6-41ab-9cbd-9221492c54c4">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// -----------------------------------------------------------------------------
// Created:		25 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.doExit;
end;</source>
    </JadeMethod>
    <JadeMethod name="writeToFile" id="aa7ba6ed-2361-440f-8363-f5b42d7f03a8">
        <source>writeToFile(_buffer : Binary);
// -----------------------------------------------------------------------------
// Created:		26 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	outFile : File;
begin
	create outFile;
	outFile.kind := File.Kind_Binary;
	outFile.mode := File.Mode_Append;
	outFile.fileName := self.txtFileReply.text;
	outFile.open();
	outFile.writeBinary(_buffer);
	outFile.close();
	
	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '=== RESPONSE =========' &amp; CrLf &amp;
		_buffer.String &amp; CrLf &amp; '==========================');
epilog
	delete outFile;
end;</source>
        <Parameter name="_buffer" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="xhandlerConnection" id="4bf3b0cd-c105-4c6a-8dce-120302c54985">
        <source>xhandlerConnection(_exObj : ConnectionException) : Integer;
// -----------------------------------------------------------------------------
// Created:		26 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin

	if _exObj.errorCode = 31001 then
		app.msgBox('no target host name specified', 'Error', MsgBox_Stop_Icon);
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31002 then
		app.msgBox('target host not found', 'Error', MsgBox_Stop_Icon);
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31003 then
		app.msgBox('invalid port specification', 'Error', MsgBox_Stop_Icon);
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31004 then
		app.msgBox('failed to connect', 'Error', MsgBox_Stop_Icon);
		return Ex_Abort_Action;
	elseif _exObj.errorCode = 31008 or _exObj.errorCode = 31009 or _exObj.errorCode = 31017 then
		self.doConnectionClose();
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
		
end;</source>
        <Parameter name="_exObj" type="ConnectionException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
