    <JadeMethod name="getTiNumbers" id="86e3b6ec-e848-48b7-9282-35e81104da16">
        <source>getTiNumbers(_coll :StringArray input);
// ---------------------------------------------------------------------------
// Created:     05 September 2008 by concms1
// Purpose:     PAR 17884/CCMS 1742 - ToDoo tasks interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	array		:StringArray;
	inString	:String;
begin
	inString := txtContainers.text.trimBlanks;
	
	array := inString.getTokens;
	array.copy(_coll);
	
epilog
	delete array;
end;</source>
        <Parameter name="_coll" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadTaskTypeCombo" id="a3747c90-95b4-4d81-9023-48ff66e38d2f">
        <source>loadTaskTypeCombo() protected;
// ---------------------------------------------------------------------------
// Created:     05 September 2008 by concms1
// Purpose:     PAR 17884/CCMS 1742 - ToDoo tasks interim solution
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	taskDict		: CM_ToDoTaskDescByCode;
	tmpToDo			: CM_ToDoTaskDesc;
begin
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	
	if taskDict.isEmpty then
		// there are no tasks they can add
		return;
	endif;

//	cmbTaskType.displayCollection (taskDict, false, null, null, null);  //-- cnwrd1 par #18179 13.10.08
	
	foreach tmpToDo in taskDict do //++ cnwrd1 par #18179 13.10.08
		cmbTaskType.addItemObject( tmpToDo.description, tmpToDo );
	endforeach;
	

epilog
	delete taskDict;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="ee8b3887-6611-4dfb-9923-00b530be0785">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2008 by concms1
// Purpose:     PAR 17884/CCMS 1742 - ToDoo tasks interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.isFormChanged then
		if not self.confirmCancel (app.getErrorString (The_Current_Item)) then
			cancel := 1;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f690ea35-c47b-4c56-b6ff-32c3ceae2dc6">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2008 by concms1
// Purpose:     PAR 17884/CCMS 1742 - ToDoo tasks interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if not app.myRoot.getConfig (UseInterimJobRequestForm).Boolean then
		// system config flag is not set
		app.msgBox('Your system is not set up to use this form - please see your system administrator', "Config Warning", MsgBox_Stop_Icon);
		
		self.unloadForm;
		return;
	endif;
	
	self.isSelectorCapable	:= true;
	
	inheritMethod();
	
	self.setNavigatorHeading(self.caption);
	
	self.loadTaskTypeCombo;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnOK.enabled:= false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ce337e0c-51bc-496d-99eb-e32e2c0f17d8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009099, locale);
	btnCancel.translateCaption(Xlat_0009100, locale);
	btnOK.translateCaption(Xlat_0009101, locale);
	lblContainers.translateCaption(Xlat_0009102, locale);
	lblDateTime.translateCaption(Xlat_0009103, locale);
	lblInstructions.translateCaption(Xlat_0009104, locale);
	lblSpecInstr.translateCaption(Xlat_0009105, locale);
	lblTaskType.translateCaption(Xlat_0009106, locale);
end;</source>
    </JadeMethod>
</GUIClass>
