    <JadeMethod name="canUserAccessSelf" id="7f6e0e3c-ea86-4a32-b201-64fb81ed5f65">
        <source>canUserAccessSelf(_user: CM_User; _failedDAC  :CM_DataAccessController output; _passport: CM_Passport): Boolean;
//------------------------------------------------
// Created: 12 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	
	if self.myOperator &lt;&gt; null then
		return self.myOperator.canUserAccessSelf(_user, _failedDAC, _passport);
	endif;
	return inheritMethod(_user, _failedDAC, _passport);

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoType" id="7f9d0025-24d3-4b7d-9bec-a30380679ca8">
        <methodInvocation>mapping</methodInvocation>
        <source>cargoType(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     07 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.myCargoType &lt;&gt; null then
			_value := self.myCargoType.id;
		endif;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="b2311296-9d2b-4722-9933-19fe5852fce6">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     11 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/03/2010	cnwcs5		par 22762 - set can be deleted flag
// ---------------------------------------------------------------------------
vars

begin
	self.createProductAttributes();

	self.hasNoNonInversedUsages := true;	// 04/03/2010 par 22762
end;</source>
    </JadeMethod>
