    <JadeMethod name="typeString" id="98ed62c7-cfcd-44c4-9b49-64e005f238c3">
        <methodInvocation>mapping</methodInvocation>
        <source>typeString(set: Boolean; _value: String io) mapping;
/*
----------   ----------  --------------------------------------------------
Created:	01 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
26 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window
*/
vars

begin
	if set then
		//does nothing - should be setting responseStatus
	else
		if self.responseStatus = Customs_Export_Cleared then
			_value :=  "Export Cleared";
		elseif self.responseStatus = Customs_Export_Cancel then
			_value :=  "Export Cancel";
		elseif self.responseStatus = Customs_Import_Cleared or 
				self.responseStatus = CustomsX12_Hold1C then
			_value :=  "Import Cleared";
		elseif self.responseStatus = Customs_Import_Cancel or
				self.responseStatus = CustomsX12_Hold1H then
			_value :=  "Import Cancel";
		elseif self.responseStatus = Customs_Tranship_Cleared then
			_value :=  "Tranship Cleared";
		elseif self.responseStatus = Customs_Tranship_Cancel then
			_value :=  "Tranship Cancel";
		elseif self.isTSWExport() or self.isTSWImport() then // TFS 39133 - 819 clearance used by TSW
			_value := self.getTSWType(); // TFS 39133 -  files, so do TSW before Deliver Break Bulk
		elseif self.responseStatus = Customs_Deliver_BreakBulk then
			_value :=  "Deliver BBLK";
		elseif self.responseStatus = MAF_ContainerCancellation then
			_value :=  "MAF Container Cancel";
		elseif self.responseStatus = MAF_ActionRequired then
			_value :=  "MAF Action Required";
		elseif self.responseStatus = SEP_ContainerCancellation then
			_value :=  "SEP Export Cancel";
		elseif self.responseStatus = SEP_ContainerRelease then
			_value :=  "SEP Export Cleared";
		elseif self.responseStatus = SEP_InspectionRequired then
			_value :=  "SEP Inspection Required";
		elseif self.responseStatus = Polish_Customs_Cleared then
			_value :=  "Polish Customs Clearance";
		elseif self.responseStatus = CustomsX12_DispCode69 then
			_value := "Bill on File";
		elseif self.responseStatus = EDIFileType_XMLOneStopCust.String then	//09 Sep 2016	NDL	TFS 2278 / 2670
			_value := "One Stop Customs";
		else
			_value :=  self.responseStatus;
		endif;
	endif;
end;


</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="typeStringVerify" id="79654419-3094-441d-b388-649fcc4b910c">
