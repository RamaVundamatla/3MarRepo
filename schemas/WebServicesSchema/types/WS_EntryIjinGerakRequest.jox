    <JadeMethod name="getValidCurrentStatuses" id="7440c64a-9643-4cb8-ab2b-d3b65596ec09">
        <source>getValidCurrentStatuses(_validStatuses: IntegerArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	pelindo1VoyProcess : CM_VoyageProcess;
	voyageStatus : CM_VoyageStatus;

begin

	//Nothing in the tech specv so currently any 

	voyageStatus := app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IVoyRequested );
	if voyageStatus &lt;&gt; null then
		pelindo1VoyProcess := voyageStatus.myProcess;
	
		foreach voyageStatus in pelindo1VoyProcess.allStatusesById do
			_validStatuses.add( voyageStatus.id );
		endforeach;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_validStatuses" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isCancelRequest" id="5549f6ef-72df-4456-b9f6-54166cab8e16">
        <source>isCancelRequest() : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2018	jlger1	Initial creation

*/

vars

begin
	return self.jenisIjin.toUpper = "PEMBATALAN";
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processMessage" id="77ce5500-8eeb-4f40-b219-ebee393a4cf0">
        <source>processMessage( voyage : CM_Voyage io );
/*  CANCEL OR TIME CHANGE WORK ORDER

Purpose:			

Parameters:	
"	This is the INAPORTNET Web Service equivalent functionality to making a change to a previous Marine Services Request.
"	Voyage must be able to be identified by PKK number.
"	Voyage must be at the "Voyage Arrived" status, otherwise the request will be rejected.
"	Update - TBC.  Some further design work required here with AB and KPD to deal with probable additional statuses
	in the INAPORTNET process based on recent updated INAPORTNET process flow.
"	Further update - changes to this are still pending the Work Order processing of Shift requests.
		

Return Value:		

Date		Who		Reason
24 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	workOrder : CM_WorkOrderVoyageDtl;
	pxyWorkOrder : CM_WorkOrderVoyage;
	pxyWorkOrderCancel : CM_WodHMSRequestCancel;
	pxyWorkOrderTimeChange : CM_WodTimeChange;
	realWorkOrder : CM_WorkOrder;
	requiredDT 	: TimeStamp;
	workOrderOid : String;
	rpkroSubString : String;

begin
	
	rpkroSubString:=app.myPassport.myTerminal.getDefaultPort().code &amp; "-RPKRO-";
	if self.nomorRpkRo.length &gt; rpkroSubString.length then
		workOrderOid:=self.nomorRpkRo[rpkroSubString.length + 1 : end];
	endif;
	
	if workOrderOid &lt;&gt; null then
		workOrder:=app.myPassport.getObjectOfTypeFromOid(workOrderOid,CM_WorkOrderVoyageDtl).CM_WorkOrderVoyageDtl;
	endif;	
	
	if workOrder = null then
		return;
	endif;
	
	//get the Work Order we are cancelling 
	if self.isCancelRequest then
		if workOrder.detailType &lt;&gt; WO_TASK_MARINEDEPART then
			create pxyWorkOrder  transient;
			pxyWorkOrder.setProxy(null,null,false,app.actualTimeAppServer,app.myPassport.myUser,null,null,app.myPassport.myTerminal,null,null,null, WO_STATUS_PENDING);
			pxyWorkOrder.setMyVoyage(voyage);
			create pxyWorkOrderCancel  transient;
			pxyWorkOrderCancel.setProxyWodHMSRequestCancel(workOrder.myParent);
			pxyWorkOrder.allWoDtls.add(pxyWorkOrderCancel);
			
		endif;
	else
		//epr TFS 42057 21/11/18 - use the mulai for initial as well
		/*if workOrder.detailType = WS_TASK_VOY_MARINEINITIAL then
			//use selesai time
			requiredDT.setDate(self.tanggalSelesai.asDateFromInaportnet);
			requiredDT.setTime(self.jamSelesai.asTimeFromWebInterface);
		else*/
			//use mulai time
			requiredDT.setDate(self.tanggalMulai.asDateFromInaportnet);
			requiredDT.setTime(self.jamMulai.asTimeFromWebInterface);
		//endif;
		
		create pxyWorkOrder  transient;
		pxyWorkOrder.setProxy(null,null,false,app.actualTimeAppServer,app.myPassport.myUser,null,null,app.myPassport.myTerminal,null,null,null, WO_STATUS_PENDING);
		pxyWorkOrder.setMyVoyage(voyage);
		create pxyWorkOrderTimeChange  transient;
		pxyWorkOrderTimeChange.setProxyWodTimeChange(requiredDT,null,  workOrder.myParent);
		pxyWorkOrder.allWoDtls.add(pxyWorkOrderTimeChange);
		
		
	endif;
	
	if pxyWorkOrder &lt;&gt; null then
		app.myPassport.setWarningsIgnored( true);
		app.myPassport.setWarningsAcknowledged( true);
		app.myTrxCA.trxCreateWorkOrder(pxyWorkOrder,realWorkOrder,app.myPassport);
	endif;
	//What we actually do with this was still unknown at the time of writing.

epilog
	delete pxyWorkOrder;
end;</source>
        <Parameter name="voyage" type="CM_Voyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateForVoyageUpdate" id="392b7453-1f4f-4a74-9172-1a5a9e8157e2">
        <source>validateForVoyageUpdate( _voyage : CM_Voyage output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	term : CM_Terminal;
	date: Date;
	time : Time;

begin

	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.
	
	term := app.myPassport.myTerminal;
	
	_voyage := term.allVoyagesByExternalCode.getAtKey( self.nomorPkk);
	if _voyage = null then
		app.raiseCMException3(Value_field_not_resolve, self.nomorPkk, WS_EntryIjinGerakRequest::nomorPkk.name, app.getErrorString(Voyage), null, null);
		return false;
	endif;
	if _voyage &lt;&gt; null then
		self.validateVoyageStatusForMsg( _voyage );
	endif;
	
	//4. self.nomorIjin -Number PPKB, Optional

	//5. self.jenisIjin - Canceled / Edited (Mandatory)
	if self.jenisIjin.toUpper &lt;&gt; "PEMBATALAN" // Cancelled
	and self.jenisIjin.toUpper &lt;&gt; "PERUBAHAN"	// Edited
	then
		app.raiseCMException3(Value_field_not_resolve, self.jenisIjin, WS_EntryIjinGerakRequest::jenisIjin.name, "'PEMBATALAN' or 'PERUBAHAN'", null, null);
	endif;
	

	//6. self.nomorPpkb - Mandatory
	
	
	//7. self.nomorRpkRo - Mandatory
	
	
	//8. self.kade
	
	//9. self.tanggalPandu - Dste
	if self.tanggalPandu &lt;&gt; null then
		date:=self.tanggalPandu.asDateFromInaportnet;
		if not date.isValid then
			app.raiseCMException1(Invalid_date_expect_format,"yyyy-mm-dd " &amp; WS_EntryIjinGerakRequest::tanggalPandu.name, null, null); 
		endif;
	endif;
	
	//10. self.jamPandu	- Time
	if self.jamPandu &lt;&gt; null then
		time:=self.jamPandu.asTimeFromInaportnet;
		if not time.isValid then
			app.raiseCMException1(Invalid_time_expect_format,"hh:mm " &amp; WS_EntryIjinGerakRequest::jamPandu.name, null, null); 
		endif;
	endif;
	
	//11. self.tanggalTunda	- Date
	if self.tanggalTunda &lt;&gt; null then
		self.tanggalTunda.asDateFromInaportnet;
		if not date.isValid then
			app.raiseCMException1(Invalid_date_expect_format,"yyyy-mm-dd " &amp; WS_EntryIjinGerakRequest::tanggalTunda.name, null, null); 
		endif;
	endif;
	
	//12. self.jamTunda	- Time
	if self.jamTunda &lt;&gt; null then
		time:= self.jamTunda.asTimeFromInaportnet;
		if not time.isValid then
			app.raiseCMException1(Invalid_time_expect_format,"hh:mm " &amp; WS_EntryIjinGerakRequest::jamTunda.name, null, null); 
		endif;
	endif;
	
	//13. self.tanggalMulai - Date
	if self.tanggalMulai &lt;&gt; null then
		date:=self.tanggalMulai.asDateFromInaportnet;
		if not date.isValid then
			app.raiseCMException1(Invalid_date_expect_format,"yyyy-mm-dd " &amp; WS_EntryIjinGerakRequest::tanggalMulai.name, null, null); 
		endif;
	endif;
	
	//14. self.jamMulai	- Time
	if self.jamMulai &lt;&gt; null then
		time:= self.jamMulai.asTimeFromInaportnet;
		if not time.isValid then
			app.raiseCMException1(Invalid_time_expect_format,"hh:mm " &amp; WS_EntryIjinGerakRequest::jamMulai.name, null, null); 
		endif;
	endif;
	
	//15. self.tanggalSelesai	- Date
	if self.tanggalSelesai &lt;&gt; null then
		date:=self.tanggalSelesai.asDateFromInaportnet;
		if not date.isValid then
			app.raiseCMException1(Invalid_date_expect_format,"yyyy-mm-dd " &amp; WS_EntryIjinGerakRequest::tanggalSelesai.name, null, null); 
		endif;
	endif;
	
	//16. self.jamSelesai	- Time
	if self.jamSelesai &lt;&gt; null then
		time:= self.jamSelesai.asTimeFromInaportnet;
		if not time.isValid then
			app.raiseCMException1(Invalid_time_expect_format,"hh:mm " &amp; WS_EntryIjinGerakRequest::jamSelesai.name, null, null); 
		endif;
	endif;

epilog

	return not app.myPassport.hasErrors;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMandFieldsPresent" id="54f95b58-e44d-442c-be6a-811b262a4e66">
        <source>validateMandFieldsPresent():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin

	on Exception do self.handleCMExcDuringValidation(exception);	//So we don't bail on the first exception we raise.
	
	
	//1. self.user - Checked in superClass ::validareCredentials
	
	//2. self.password - Checked in superClass ::validareCredentials
	
	//3. self.nomorPkk -Number PKK, Mandatory
	if self.nomorPkk = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryIjinGerakRequest::nomorPkk.name, null, null);
	endif;

	//4. self.nomorIjin -Number PPKB, Optional

	//5. self.jenisIjin - Canceled / Edited (Mandatory)
	if self.jenisIjin = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryIjinGerakRequest::jenisIjin.name, null, null);
	endif;

	//6. self.nomorPpkb - Mandatory
	if self.nomorPpkb = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryIjinGerakRequest::nomorPpkb.name, null, null);
	endif;
	
	//7. self.nomorRpkRo - Mandatory
	if self.nomorRpkRo = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryIjinGerakRequest::nomorRpkRo.name, null, null);
	endif;
	
	//8. self.kade
	
	//9. self.tanggalPandu - Dste
	
	//10. self.jamPandu	- Time
	
	//11. self.tanggalTunda	- Date
	
	//12. self.jamTunda	- Time
	
	//13. self.tanggalMulai - Date
	
	//14. self.jamMulai	- Time
	
	//15. self.tanggalSelesai	- Date
	
	//16. self.jamSelesai	- Time
	
	//17. self.portCode - Checked in superClass ::validareCredentials


epilog

	return not app.myPassport.hasErrors;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
