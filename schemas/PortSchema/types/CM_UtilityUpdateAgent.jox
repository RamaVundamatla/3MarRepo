    <JadeMethod name="utlUpdateInvLineDescMap" id="96b2d6b5-e820-4558-91db-8421fe349dd2">
        <source>utlUpdateInvLineDescMap(_pxyInvoiceLineDescMap : CM_InvoiceLineDescMapping; _passport : CM_Passport input);
/*

Purpose:			Updates a Invoice Line Mapping

Parameters:			_pxyInvoiceLineDescMap	CM_InvoiceLineDescMapping	A proxy invoice line mapping to update
					_passport				CM_Passport					The passport to use for the transaction

Return Value:		NONE

Date		Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	cancelSave				: Boolean;
	realInvoiceLineDescMap	: CM_InvoiceLineDescMapping;
	expectedEdition			: Integer;
	
begin
	self.initialiseActivity();
	
	_pxyInvoiceLineDescMap.raiseExceptionIfNotProxy(method);
	
	app.setContinueCMExceptions(true);
	
	_pxyInvoiceLineDescMap.pxyGetRealObjectAndEdition(realInvoiceLineDescMap, expectedEdition);
	
	if realInvoiceLineDescMap = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_InvoiceLineDescMapping.name, null, null);
		return;
	endif;
	
	app.myValUA.valInvoiceLineDescMap(realInvoiceLineDescMap, _pxyInvoiceLineDescMap);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	exclusiveLock(realInvoiceLineDescMap);
	
	if _passport.noErrors and realInvoiceLineDescMap.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice Line Desc', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceLineDescMap, true);
	endif;
	
	if _passport.noErrors then
		realInvoiceLineDescMap.setForUpdate(_pxyInvoiceLineDescMap);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realInvoiceLineDescMap, false);
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_MAPPING_UPDATE),false,realInvoiceLineDescMap);
		//_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE),false,realInvoiceLineDescMap);
	endif;
	
end;</source>
        <Parameter name="_pxyInvoiceLineDescMap" type="CM_InvoiceLineDescMapping"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
