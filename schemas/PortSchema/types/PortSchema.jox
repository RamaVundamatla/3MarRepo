    <JadeMethod name="setupAppVersion" id="01b98b25-e4de-40ff-a9a7-c82b97c14d07">
        <updating/>
        <source>setupAppVersion() updating;
/*

Purpose:			Setup appVersion from CM_Root version info (if available)
					To be used prior to activating CnKarmaCntrl, to ensure the
					correct JMT version info is passed to JSM after a deploy

Parameters:			None

Return Value:		None

Date		Who		Reason
07 Feb 2012	cnwkpd1	PAR #28381 - Update JSM version info correctly in managed environments

*/

vars
	root			: CM_Root;
	
begin
	root := app.myRoot;
	if root = null then
		root := CM_Root.firstInstance();
	endif;
	if root = null then
		return;
	endif;
	
	self.appVersion := root.getVersionAndPatchLevel();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupCarterNote" id="56b20ff2-f313-401e-9de3-77e8437a488a">
        <source>setupCarterNote(_ti: CM_TrackedItem; _terminal: CM_Terminal): JadeReportWriterReport;
//----------------------------------------------------------------
//	Created:	28 February 2006	by Jason Chapman  (cnwjc2)
//
//	Moved here from Gate Schema
//
// Changed On	Changed By	Reason
// -----------	----------	--------------------------------------
// 22 Feb 2010	consw1		PAR #21156 - Gate Config Report Names
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 01/06/2020	jlgdap1		TFS 49477 PNL Carter Note Report Broken
//----------------------------------------------------------------
vars
	ti				: CM_TrackedItem;
	isPoweredItem,
	isReefer,
	showVentilation,
	showHumidity	: Boolean;
	tmpISOType		: CM_ISOType;
	tmpOperator		: CM_Operator;
	rep				: JadeReportWriterReport;
	co				: CM_Bank;
	addressLine,
	strAddress		: String;
	rm				: JadeReportWriterManager;
	reportName		: String;
	jrwTransient	: CM_JRWTrackedItems;		// TFS 49477
begin

	rm := app.createReportWriterManager();

	ti := _ti;
	app.allReportTIs.clear;
	app.allReportTIs.add(ti);

	isPoweredItem := false;
	isReefer := false;
	showVentilation := false;
	showHumidity := false;
	tmpISOType := ti.getISOTypeObject();
	tmpOperator := ti.myOperator;
	if (tmpISOType &lt;&gt; null) and ( tmpOperator &lt;&gt; null) then
		isPoweredItem := (tmpISOType.isReefer or tmpISOType.isFantainer);
		isReefer := tmpISOType.isReefer;

		if isPoweredItem and tmpOperator.requiresHumidity then
			showHumidity := true;
		endif;		
		if isPoweredItem and tmpOperator.requiresVentilation then
			showVentilation := true;
		endif;	
	endif;
	
	//Get report from new carter note configuration here.
	
	//changed for par 15928
	//Use this section to output to printer
	
	reportName := _terminal.getConfig(GateCarterNoteReport).String;
	if reportName = null then
		reportName := DefRep_GateCarterNoteReport;
	endif;
	
	rep := rm.getReport(reportName);
	//No report from config found so use default.
	
	//Stil no report so raise a program error as CM_CarterNote is a system report.
	if rep = null then
		//app.raiseUnexpectedProgramError(class.name, method.name, 'report design (' &amp; 'CM_CarterNote' &amp; ') not found');
		app.raiseUnexpectedProgramError(class.name, method.name, 'report design. A Carter Note report design cannot be located');
	endif;
	
	// TFS 49477
	if reportName = DefRep_GateCarterNoteReport then
		foreach co in _terminal.companies do
			if co.isBusinessUnit and not co.isSuspended and co.mailingAddress.size &lt;&gt; 0 then
				rep.setParameter('portName', co.mailingName);
				foreach addressLine in co.mailingAddress do
					if strAddress = null then
						strAddress := addressLine;
					else
						strAddress := strAddress &amp; CrLf &amp; addressLine;
					endif;
				endforeach;
				rep.setParameter('portLine01', strAddress);
				break;
			endif;
		endforeach;
	else
		jrwTransient := app.myQAFilter.createJRWTransient(CM_JRWTrackedItems).CM_JRWTrackedItems;
		jrwTransient.allTerminals.clear;
		jrwTransient.allTerminals.add(ti.myTerminal);
		jrwTransient.allTrackedItems.clear;
		jrwTransient.allTrackedItems.add(ti);
	endif;
	rep.setParameter('showHumidity', showHumidity);
	rep.setParameter('showVentilation', showVentilation);
	
	return rep;

epilog
	delete rm;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="JadeReportWriterReport"/>
    </JadeMethod>
    <JadeMethod name="setupClient" id="1212ecdd-42dc-4bec-ad38-d58bad053ee0">
        <source>setupClient();

vars
	licenseName, licenseKey, licenseNameEDI, licenseKeyEDI: String;
	userExitCode: Integer;
	jSSLPublicInterface: JSSLPublicInterface;
	terminal : CM_Terminal;
	currPortDestCode : String;
	client : String;
	file : File; //add application file for Jari
	fileMessage : String;
begin
	
	userExitCode := 63;
	app.initialize();
	create file transient;
	file.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := app.myCnCntrl.logPath&amp;"\app_upgrade.log";
	if file.isAvailable then
		file.purge;
	endif;
	fileMessage := "UpgradeError";
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	create jSSLPublicInterface transient;
	app.setPropertyValue("myCheckerObject", jSSLPublicInterface);

	terminal := CM_Terminal.firstInstance;
	currPortDestCode := terminal.getConfig(PortDestCode).String.trimBlanks();
	beginTransaction;
	if currPortDestCode = "POE" or currPortDestCode = "NZPOE" then
		app.myRoot.setPropertyValue('client', Client_PortOtago);
	elseif currPortDestCode = "WLG" or currPortDestCode = "NZWLG" then
		app.myRoot.setPropertyValue('client', Client_CentrePort);
	elseif currPortDestCode = "NSN" or currPortDestCode = "NZNSN" then
		app.myRoot.setPropertyValue('client', Client_PortNelson);
	elseif currPortDestCode = "WHG"or currPortDestCode = "NZWHG"  then
		app.myRoot.setPropertyValue('client', Client_TollOwens);
	elseif currPortDestCode = "BLU" or currPortDestCode = "NZBLU" then
		app.myRoot.setPropertyValue('client', Client_SouthPort);
	elseif currPortDestCode = "POT" or currPortDestCode = "NZPOT" then
		app.myRoot.setPropertyValue('client', Client_Tauranga);
	elseif currPortDestCode = "" then
		currPortDestCode := terminal.code;
		if currPortDestCode = "POE" or currPortDestCode = "NZPOE" then
			app.myRoot.setPropertyValue('client', Client_PortOtago);
		elseif currPortDestCode = "WLG" or currPortDestCode = "NZWLG" then
			app.myRoot.setPropertyValue('client', Client_CentrePort);
		elseif currPortDestCode = "NSN" or currPortDestCode = "NZNSN" then
			app.myRoot.setPropertyValue('client', Client_PortNelson);
		elseif currPortDestCode = "WHG"or currPortDestCode = "NZWHG"  then
			app.myRoot.setPropertyValue('client', Client_TollOwens);
		elseif currPortDestCode = "BLU" or currPortDestCode = "NZBLU" then
			app.myRoot.setPropertyValue('client', Client_SouthPort);
		elseif currPortDestCode = "POT" or currPortDestCode = "NZPOT" then
			app.myRoot.setPropertyValue('client', Client_Tauranga);
		endif;
	endif;		 
	commitTransaction;
	if app.myRoot.client = Client_PortOtago then
		licenseName := "Port Otago Ltd";
		licenseKey := "AF000000FD000000CEFDB7B0A9FDFDFDFDFDFDFDFDFDFDFD7D01D7FDC0FC6106C0FF";
	elseif app.myRoot.client = Client_CentrePort then
		licenseName := "CentrePort Wellington Limited";
		licenseKey := "330000008F000000BC8FC5C2DB8F8F8F8F8F8F8F9A8F8F8F0F73A58FB68ECB6D8C8D";
	elseif app.myRoot.client = Client_PortNelson then
		licenseName := "Port Nelson Ltd";
		licenseKey := "4C0000007700000044773D3A237777777777777777777777F78B5D770E76FBBC4674";
	elseif app.myRoot.client = Client_SouthPort then
		licenseName := "South Port Ltd";
		licenseKey := "83000000080000003B0842455C080808080808080808080888F422083909048A090A";
	endif;
	if licenseName &lt;&gt; null and licenseKey &lt;&gt; null then
		app.myTrxUA.trxUpdateLicense(app.myRoot, licenseName, licenseKey, ProductCode_JMT, app.myRoot.edition, app.myPassport);
	endif;
	if not app.myPassport.noErrors then
		return;
	endif;
	if licenseKeyEDI &lt;&gt; null then
		app.myTrxUA.trxUpdateLicense(CM_Root.firstInstance, licenseNameEDI, licenseKeyEDI, ProductCode_JMT_EDI, CM_Root.firstInstance.edition, app.myPassport);
		if not app.myPassport.noErrors then
			return;
		endif;
	endif;
	app.writeStatement( "end Client Setup");	
	userExitCode := 0;	
	fileMessage := "completedOK";
	file.writeLine(fileMessage);
	///////////////////////////////////////
epilog
	file.close;
	delete file;
	delete jSSLPublicInterface;
	beginTransaction;
	node.userExitCode := userExitCode;
	commitTransaction;
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupEDICAMS" id="7bec1e85-c72a-4016-8009-59c9961bd804">
