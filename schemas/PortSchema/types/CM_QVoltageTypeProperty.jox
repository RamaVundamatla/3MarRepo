<Class name="CM_QVoltageTypeProperty" id="a108066e-7f9c-4570-8400-f679855b8f74">
    <superclass name="CM_QIntegerLookupProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="5f7bbf91-2efa-4d3a-aafb-dcea9193ed32">
        <updating/>
        <source>create() updating;
//-----------------------------------------
// Created: 03 October 2005 By: cnwgd1
//-----------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QIntegerLookupEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QIntegerIsOneOf persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="4961f8e7-8ba6-4173-965f-df1bac1664c5">
        <source>getKeyLengthForXTABDictionary(): Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	length	:Integer;
begin
	// just incase the global constant values change !!!
	length := ContainerDualVoltStr.length;
	length := length.max (ContainerSingleVoltStr.length);
	length := length.max (ContainerVoltNullStr.length);
	length := length.max (app.getErrorString(Unknown).length);
	
	return length;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getListBoxPropertyName" id="1d770a1f-1797-40aa-8fef-08bf59bded63">
