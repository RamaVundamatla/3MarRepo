    <JadeMethod name="initLengthReportingOptions" id="e3427629-6ebf-4675-ac15-a5dd57282f81">
        <updating/>
        <source>initLengthReportingOptions() updating;
// ---------------------------------------------------------------------------
// Created:	03 June 2008 By Graeme Black cnwgb1
// Purpose:	PAR 16415 Set flags to determine which totals get accumulated
// ---------------------------------------------------------------------------
vars
	show30 : Integer;
	show45 : Integer;
	show53 : Integer;
begin
	show30 := app.myPassport.myTerminal.getConfig(Is30IncludedForReports).Integer;
	show45 := app.myPassport.myTerminal.getConfig(Is45IncludedForReports).Integer;
	show53 := app.myPassport.myTerminal.getConfig(Is53IncludedForReports).Integer;
	self.showLen30 := (show30 = 1);
	self.showLen45 := (show45 = 1);
	self.showLen53 := (show53 = 1);
	self.showLen30AsOther := (show30 = 2);
	self.showLen45AsOther := (show45 = 2);
	self.showLen53AsOther := (show53 = 2);
	self.showLenOther := 
		self.showLen30AsOther or 
		self.showLen45AsOther or 
		self.showLen53AsOther;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="fbbc2db4-9a55-4d79-be22-fab06e49b3c1">
        <source>noOutputReturned(): Boolean;
// -------------------------------------------
// Created 21 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.allCMIFJobTITotals.isEmpty() and
	   self.allVoyageBookingSummary.isEmpty() and
	   self.allVoyageSummaryObjects.isEmpty()and
	   self.allVoyageLoadSumObjects.isEmpty() then
		return true;
	endif;
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
