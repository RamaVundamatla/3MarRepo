    <JadeMethod name="getLatestStopClearedDate" id="a6b02c0f-f48b-409c-b357-c38cf2f0147f">
        <source>getLatestStopClearedDate() : Date;
// Oct 2015 36704 used in Ghana cash receipt report
vars

	trns		: CM_BOLTransaction;
	ts			: TimeStamp;

begin

	ts := null;
	// collection by date
	foreach trns in self.allBOLTransactions reversed do
		if trns.type = TRANS_TYPE_BOL_STOP_CLEARED then
			ts := trns.dateTime;
			break;
		endif;
	endforeach;

	if ts = null then
		return null;
	else
		return ts.date;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getLocationDescription" id="c57a8167-85cb-46a6-b8be-0dc19848405f">
        <source>getLocationDescription() : String;
// -----------------------------------------------------------------------------
// Created:		15 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	locn	: CM_LocationsController;
	ta		: CM_TerminalArea;
begin
	locn := self.myPlannedLocation;
	if locn &lt;&gt; null then
		ta := locn.myTerminalArea;
		if ta &lt;&gt; null then
			return locn.getID &amp; ' ' &amp; ta.id;
		else
			return locn.getID;
		endif;
	endif;
	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
