    <JadeMethod name="canUserAccessSelf" id="389db58c-c733-4bb9-a84d-f4ae87445ede">
        <source>canUserAccessSelf(_user: CM_User; _failedDAC: CM_DataAccessController output; _passport: CM_Passport): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2014	cnwmc5	Initial creation		CCMS 2429

*/

vars
	carrier 		: CM_Carrier;	
	consignee,
	consignor 		: CM_ConsigneeConsignor;
	operator		: CM_Operator;
begin
	
	consignee := self.myConsignee;
	
	if consignee &lt;&gt; null and (not consignee.canUserAccessSelf(_user, _failedDAC, _passport)) then
		return false;
	endif;
	
	consignor := self.myConsignor;
	if consignor &lt;&gt; null and (not consignor.canUserAccessSelf(_user, _failedDAC, _passport)) then
		return false;
	endif;
	
	operator := self.myOperator;
	if operator &lt;&gt; null and (not operator.canUserAccessSelf(_user, _failedDAC, _passport)) then
		return false;
	endif;
	
	return inheritMethod(_user, _failedDAC, _passport);

epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
