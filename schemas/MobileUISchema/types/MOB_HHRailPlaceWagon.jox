    <JadeMethod name="wagonSelect" id="58692a4d-d404-4d92-b107-1fa92497a827">
        <updating/>
        <source>wagonSelect(_restore : Boolean) updating;
// moved from cmbWagon_click to btnAdd action for 27069, 27015 Apr 2011
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215 in cmbWagon_click
Apr 2011	cnwjre1	27069, 27015 usability pars
*/

vars

	wagon : CM_Wagon;
	returnValue : Integer;
	opt1Str : String;
	opt2Str : String;
	opt3Str : String;
	rakePos : Integer;
	rakePosStr : String;
	wagonBeingOusted : CM_Wagon;
	
begin

	wagon := cmbWagon.listObject.CM_Wagon;
	if wagon &lt;&gt; null then
		rakePos := cmbRakePos.itemData[cmbRakePos.listIndex];
//		if rakePos &gt; 0 then PAR 26301
		if rakePos &gt; 0 and self.myMobileGenericAgent.myCurrentRailLine.allWagons.size &gt;= rakePos then
			wagonBeingOusted := self.myMobileGenericAgent.myCurrentRailLine.allWagons[rakePos];
			if wagonBeingOusted = null or self.checkWagonIsForTrain(wagonBeingOusted,false) or self.wagonIsForNullTrain(wagonBeingOusted) then
				// 27069 if selected wagon is current, don't need to do anything, except re-display the wagon if coming from wagon id change
				if wagonBeingOusted = wagon then
					if _restore then
						self.displayWagon();
					endif;
					return;
				endif;
				rakePosStr := cmbRakePos.text;
				opt1Str := app.getErrorString2(Move_wagon_into_postion, wagon.id, rakePosStr);//"Move wagon %1 into postion %2";
				opt2Str := app.getErrorString1(Show_exist_posit_wagon, wagon.id);//"Show the existing position for wagon %1 on this rake";
				opt3Str := app.getErrorString(Neither_above_cancel);//"Neither of the above, Cancel.";
				returnValue := self.optBox(opt1Str, opt2Str, opt3Str, null, 3, app.getErrorString(Select_option) );
				if returnValue = 2 then	// User wants to switch view to selected wagon.
					// nothing extra to do, this is the default behaviour below, just carry on
				elseif returnValue = 1 then	// User wants to do the swap thing.
					if self.swapWagonPositions(wagon,rakePos) then
						// nothing extra to do, should be all good to carry on.
					else
						//some error occurred, that the user has been notified of, do the same as a cancel
						self.cmbRakePos.click(cmbRakePos);
						wagon := cmbWagon.listObject.CM_Wagon;
					endif;
				else // User selected 'cancel' option.
					self.cmbRakePos.click(cmbRakePos);
					wagon := cmbWagon.listObject.CM_Wagon;
				endif;
			endif;
		endif;
	endif;
	
	self.setRakePositionFromWagon( wagon );
	// 27015 allow edit of wagon id
	if returnValue &lt;&gt; 2 then
		self.placeWagonWithNoExistingPosi( wagon );
	endif;
	self.displayWagon();
	
epilog

end;</source>
        <Parameter name="_restore" type="Boolean"/>
    </JadeMethod>
</GUIClass>
