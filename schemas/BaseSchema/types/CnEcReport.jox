<GUIClass name="CnEcReport" id="cde84fc8-f54b-4fc6-bb52-dfc33f21bf17">
    <superclass name="Form"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

