    </JadeMethod>
    <JadeMethod name="doSaveDLRT" id="20371b1a-ab7c-4fbc-9345-8059bde5cd6d">
        <updating/>
        <source>doSaveDLRT() updating;
// ### JIRA 19932 21OCT2024 NAVAB1
//7/3/2025 navsaa30 TFS 14818 MTN | Silent Deadlock Retry Technical Debt
// 03/11/2025 jlier1 	MTN-34531 - Deadlock retry for everyone	
vars
	allInvoicesSet	: CM_InvoiceSet;
	pxyCreditNote,
	realCreditNote	: CM_Invoice;
	theReturn 		: Integer;
	date			: Date;
	time			: Time;
	timeStamp		: TimeStamp;
	localCaption : String;
begin
	
	create allInvoicesSet transient;
	
	self.allInvoicesToLink.copy(allInvoicesSet);
	
	realCreditNote := self.myCreditNote;
	
	if self.mode = Mode_CreateCreditNote then // Create Credit Note mode
		create pxyCreditNote transient;
	elseif self.mode = Mode_UpdateCreditNote then	// Update Credit Note mode
		pxyCreditNote := app.createUpdateProxy(realCreditNote).CM_Invoice;
	else
		return;
	endif;
	
	date := self.mskCreditStartDate.getDate();
	time := self.mskCreditStartTime.getTime();
	
	timeStamp.setDate(date);
	timeStamp.setTime(time);
	
	pxyCreditNote.setProxyCreditNote(self.cmbCreditDebtor.listObject.CM_Debtor,self.cmbCreditInvoiceType.listObject.CM_InvoiceDesc,self.cmbCreditStatus.listObject.CM_InvoiceStatus.id, self.cmbDebtorAddress.listObject.CM_Address, self.localToSystemTime(timeStamp));
	
	localCaption := self.caption;
	
	//set up the silent deadlock handler to attempt to retry
	app.myPassport.setupForDeadlockReplay(220, 3000);
	app.myPassport.silentDeadlockLimit := 10;	
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	while true do 
		while true do
			if mode = Mode_CreateCreditNote then
				app.myTrxCA.trxCreateCreditFromInvoice(allInvoicesSet, pxyCreditNote, realCreditNote, app.myPassport);
			elseif mode = Mode_UpdateCreditNote then
				app.myTrxUA.trxUpdateCreditNote(allInvoicesSet, pxyCreditNote, realCreditNote, app.myPassport);
			endif;
			
			if app.myPassport.hadDeadlock then //jlier1 4/11/25 break to deadlock loop
				break;
			endif;
			
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				if self.mode = self.Mode_CreateCreditNote then
					if realCreditNote.externalNumber = null then
						app.msgBox( app.getErrorString1(Credit_note_create_success, realCreditNote.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
					else
						app.msgBox( app.getErrorString2(Credit_note_ext_create_success, realCreditNote.sequenceNum.String, realCreditNote.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
					endif;
				else
					if realCreditNote.externalNumber = null then
						app.msgBox( app.getErrorString1(Credit_note_update_success, realCreditNote.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
					else
						app.msgBox( app.getErrorString2(Credit_note_ext_update_success, realCreditNote.sequenceNum.String, realCreditNote.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
					endif;
				endif;
				self.myCreditNote := realCreditNote;
				self.unloadForm();
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors 
				and theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
				return;
			endif;
			break;
		endwhile;
				
		if app.myPassport.noTrxReplayAllowed() then
			if app.myPassport.hadDeadlock then //had a deadlock and reached the limit show the deadlock error
				app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			endif;
			break;
		endif;
		
		self.updateCaptionDeadlockRetry(localCaption);

	endwhile;
	
	
epilog

	//set the silent deadlock handler back to the default values i.e. OFF
	app.myPassport.resetSilentDeadlockHandler;  //7/3/25  navsaa30 #14818
	self.caption := localCaption;
	self.mousePointer := Window.MousePointer_Default;

	delete pxyCreditNote;
	delete allInvoicesSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveUpdateInvoice" id="40e7da17-f72c-4680-8d8a-4c413ec0f555">
        <updating/>
        <source>doSaveUpdateInvoice() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2023	navkc1	Initial creation Task 55536: UI - Invoice Credit Note UI
09-June-2023 navtnr20 Bug 58472: EUP | Invoicing - Configuration Enhancements - Debtor Address update on Invoice
*/

vars
	debtorInvType	: CM_DebtorInvType;
	pxyInvoice,
	realInvoice 	: CM_Invoice;
	theReturn,
	theRow 			: Integer;
	theDataLine		: String;
	package			: CM_PackageInvoice;
	runPackage 		: Boolean;
	task			: CM_AutoTask;
	schedule		: CM_AutoSchedule;
	debtorAddress   : CM_Address;
	theTable		: CM_DataTable;
begin
	realInvoice := self.myFirstInvoiceFromParent;
	
	if realInvoice = null then 
		app.msgBox("Please select an invoice.","Invoice Update",MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	pxyInvoice := app.createUpdateProxy(realInvoice).CM_Invoice;

	if self.cmbDebtorAddressProp.listObject.CM_Address &lt;&gt; null then
		debtorAddress := self.cmbDebtorAddressProp.listObject.CM_Address;
	else
		debtorAddress := pxyInvoice.myBillingAddress;
	endif;
	pxyInvoice.setProxyForUpdate(	self.txtNarr.text,
									self.tblInvoice.getValueByName(ETRow_IsZeroRated).Boolean, 
									self.tblInvoice.getValueAsDate(ETRow_EndDate),
									self.tblInvoice.getValueByName(ETRow_PurchaseOrderNumber).String,
									self.tblInvoice.getValueByName(ETRow_DebtorReference).String,
									debtorAddress,null, null, null, null);	//navtnr20 09-06-2023 Bug 58472
									
	runPackage := self.tblInvoice.getValueByName(ETRow_RunPackage).Boolean;

	while true do
		app.myTrxUA.trxUpdateInvoice(pxyInvoice,app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			theTable := theTable;
			if theTable &lt;&gt; null then
				theDataLine := realInvoice.getAttributeStringForDefArray(theTable.allTblDataEntRows);
				if theTable.findObjectInRow(realInvoice,theRow) then
					theTable.accessCell(theRow,1).text := theDataLine;
					if realInvoice.isZeroRatedTax then
						theTable.accessedRow.backColor := CM_Invoice.ZeroTaxColour;
					else
						theTable.accessedRow.backColor := White;
					endif;	
				endif;
			endif;
			if realInvoice.externalNumber = null then
				app.msgBox( app.getErrorString1(Invoice_updated_successful, realInvoice.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
			else
				app.msgBox( app.getErrorString2(Invoice_ext_updated_successful, realInvoice.sequenceNum.String, realInvoice.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
			endif;
			self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return;
		endif;
		break;
	endwhile;
	
	if realInvoice.isPosted
		and  runPackage then
		app.mousePointer := MousePointer_HourGlass;
		
		debtorInvType := realInvoice.debtor.allDebtorInvTypes[realInvoice.invoiceType];
		
		if debtorInvType &lt;&gt; null then
			foreach package in debtorInvType.allPackageInvoices do
				foreach task in package.allTasks do
					schedule := task.allAutoSchedules.first;
					app.runEventScheduleInvoice(schedule, realInvoice, null);
				endforeach;
			endforeach;
		endif;
	endif;
epilog
	app.mousePointer := MousePointer_Default;
	delete pxyInvoice;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTableContext" id="cd717163-89da-45e0-a931-0304101e5d56">
        <updating/>
        <source>doTableContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2023	navkc1	Initial creation TFS CR 55305 TASK 55536

*/

vars
	xLeft	: Real;
	yTop	: Real;
	
begin
	
	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);	
	self.screenToWindow(xLeft, yTop);
	
	self.mnuMenuContext.userObject := cntrl;
	
	self.popupMenu(self.mnuMenuContext, xLeft.Integer, yTop.Integer);
	
	return false;
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="07c9cb94-9967-456d-9119-cd431d0ad8ec">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2023	navkc1	Initial creation  TFS CR 55305 TASK 55536

*/

vars
	xmlStr	: String;
begin
	xmlStr := inheritMethod();
	xmlStr &amp;= self.tblInvoiceLink.getXmlStrForColumns(false);
	xmlStr &amp;= self.tblInvoiceResult.getXmlStrForColumns(false);
	
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="haltProgress" id="9b0495ff-d3d2-4b73-ae76-1c6da6029a23">
        <source>haltProgress(pe : CM_ProgressException) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation Task 55536: UI - Invoice Credit Note UI

*/

vars

begin
	if app.msgBox(self.myBank.getMsgString(WARN_CANCEL_PROGRESS ,
										"",
										"",""),
										"Cancel Progress",
										MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		return Ex_Abort_Action;
	else
		return Ex_Continue;
	endif;
epilog

end;</source>
        <Parameter name="pe" type="CM_ProgressException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initCreditNoteDetails" id="eda2e4c0-aedc-4053-98a9-2c3bdede7046">
        <source>initCreditNoteDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2023	navkc1	Initial creation Task 55536: UI - Invoice Credit Note UI

*/

vars
	creditNote,
	linkedInv	: CM_Invoice;
//	dateStr,
//	timeStr,
	lineStr		: String;
	linkTable	: CM_DataTable;
	invProcess	: CM_InvoiceProcess;
	invStatus	: CM_InvoiceStatus;
	localTS : TimeStamp;
begin
	
	creditNote := self.myCreditNote;
	
	if creditNote = null then
		return;
	endif;
	
	/*  // ### TFS BUG 58795 26JUN2023 NAVAB1
	if creditNote.fromDT.isValid() then
		dateStr := creditNote.fromDT.date().format("dd/MM/yyy");
		timeStr := creditNote.fromDT.time().format("HH:mm");
	endif;
	*/
	
	invProcess := creditNote.getMyInvoiceProcess();	
	if invProcess = null then
		invProcess := CM_InvoiceProcess.instances.first().CM_InvoiceProcess;
	endif;
	
	invStatus := invProcess.allStatuses[creditNote.status];
	
	self.cmbCreditDebtor.setIndexFromObject(creditNote.debtor);
	self.doPopulateCmbCreditAddress();
	self.cmbDebtorAddress.setIndexFromObject(creditNote.myBillingAddress);
	self.cmbCreditInvoiceType.setIndexFromObject(creditNote.invoiceType);
	self.cmbCreditStatus.setIndexForItemData(creditNote.status);
	/*  // ### TFS BUG 58795 26JUN2023 NAVAB1
	self.mskCreditStartDate.text := dateStr;
	self.mskCreditStartTime.text := timeStr;
	*/
	localTS := self.systemToLocalTime(creditNote.fromDT);// ### TFS BUG 58796 26JUN2023 NAVAB1
	
	self.mskCreditStartDate.setDate(localTS.date());// ### TFS BUG 58795 26JUN2023 NAVAB1
	self.mskCreditStartTime.setTime(localTS.time());// ### TFS BUG 58795 26JUN2023 NAVAB1
	self.cmbCreditStatus.setIndex(self.cmbCreditStatus.findStringExact(1, invStatus.description));
	self.allInvoicesToLink.clear();
	
	linkTable := self.tblInvoiceLink;	
	
	foreach linkedInv in creditNote.allOtherInvoices discreteLock do
		lineStr := linkedInv.getAttributeStringForDefArray(linkTable.allTblDataEntRows);
		linkTable.addItemObject(linkedInv, lineStr);
		self.allInvoicesToLink.addNoDuplicates(linkedInv, false);
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initInvoiceSheet" id="43b514c6-f085-4029-a93c-77a39bd379e7">
        <source>initInvoiceSheet();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2023	navkc1	Initial creation Task 55536: UI - Invoice Credit Note UI

*/

vars
	theTable 		: CM_EntryTable;
	entTableDef		: EntTableDef;
	entTableView 	: EntTableView;
	finIO			: CM_ExtFinanceIO;
	textHeight,
	narrHeight		: Integer;
	packageNames	: String;
	theNarrRow 		: Integer;
	isASPAInterface : Boolean;
	theInvoice		: CM_Invoice;
	
begin

	theTable := self.tblInvoice;
	
	theInvoice := self.myFirstInvoiceFromParent;
	if theInvoice = null then
		return;
	endif;
	
	entTableDef := theTable.myEntTableDef;
	entTableView := entTableDef.allEntTableViews[ETView_InvListInvPropUpdate];
	theTable.setEntTableFromView(entTableDef, entTableView, null, null);
	
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	
	finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;	
	if finIO &lt;&gt; null and finIO.isKindOf(CM_SALInterface) then
		theTable.hideRowByName(ETRow_Export,false);
	endif;
	
	theTable.hideRowByName(ETRow_ArrivalTS,false);
	theTable.hideRowByName(ETRow_DepartureTS,false);
	theTable.hideRowByName(ETRow_VoyageDesc,false);
	theTable.hideRowByName(ETRow_Voyage,false);
	
	if isASPAInterface then
		theTable.hideRowByName(ETRow_IsZeroRated,false);
	endif;
	
	theNarrRow := theTable.getRowByName(ETRow_Narration);
	if theNarrRow &gt; 0 then
		theTable.accessCell(theNarrRow,CM_EntryTable.ColumnValue).wordWrap := true;
	endif;
	
	theTable.setTableFromCM_Object(theInvoice,null);
	theTable.disableRowByName(ETRow_SequenceNum);	
	
	self.txtNarr.text := theInvoice.narration;
		
	if theInvoice.debtor.myTermsOfTrade &lt;&gt; null then
		theTable.setValueByName(ETRow_Terms,theInvoice.debtor.myTermsOfTrade.description);
	endif;
	
	if theInvoice.isPosted() then
		theTable.hideRowByName(ETRow_DebtorAddress,false);	
		theTable.setValueByName(ETRow_EndDate, theInvoice.toDT.date());
		theTable.disableRowByName(ETRow_EndDate);
		
		packageNames:=theInvoice.getDisplayStringForAttribute(ETRow_Packages,false);
		if packageNames &lt;&gt; null then
			theTable.showRowByName(ETRow_RunPackage, false);
			theTable.showRowByName(ETRow_Packages, false);
			theTable.setValueByName(ETRow_Packages, packageNames);
		endif;	
	endif;
	
	if theInvoice.invoiceType.accrualType = CM_InvoiceDesc.Accrue_Until_Manually_Closed then
		if theInvoice.status = CM_Invoice.INVOICE_PENDING then
			theTable.setValueByName(ETRow_EndDate, theInvoice.toDT.date());
			theTable.enableRowByName(ETRow_EndDate);
		else
			theTable.setValueByName(ETRow_EndDate, null);
			theTable.hideRowByName(ETRow_EndDate,false);
		endif;
	else
		theTable.setValueByName(ETRow_EndDate, theInvoice.toDT.date());
		theTable.enableRowByName(ETRow_EndDate);
	endif;
	
	theTable.hideRowByName(ETRow_RunPackage, false);
	theTable.hideRowByName(ETRow_Packages, false);
	
	if not theInvoice.isPostedOrReversal then
		theTable.showRowByName(ETRow_DebtorAddress,false);			
		self.doPopulateInvDebtorAddress(theInvoice.debtor);
	endif;
		
	if  theNarrRow &gt; 0 then
		textHeight := self.txtNarr.getTextHeightForWidth(self.txtNarr.text, self.txtNarr.width.Integer) + 10;
		narrHeight := textHeight;
		if textHeight &lt; 50 then
			narrHeight := 50;
		elseif textHeight &gt; 150 then
			narrHeight := 150;
		endif;
		theTable.accessRow(theNarrRow).height := narrHeight;
		self.txtNarr.height := narrHeight;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initLinkTable" id="1a8801f4-6670-4a7e-8771-bbeba2fcc27c">
        <source>initLinkTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2023	navkc1	Initial creation  Task 55536: UI - Invoice Credit Note UI

*/

vars
	allInvoices	: CM_InvoiceSet;
	invoice		: CM_Invoice;
	line		: String;
	theTable	: CM_DataTable;
begin
	
	allInvoices := self.allInvoicesFromParent;
	
	theTable := self.tblInvoiceLink;
	
	foreach invoice in allInvoices where not invoice.isCreditNote() do
		line := invoice.getAttributeStringForDefArray(theTable.allTblDataEntRows);
		
		theTable.addItemObject(invoice, line);
		
		self.allInvoicesToLink.addNoDuplicates(invoice, false);
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
