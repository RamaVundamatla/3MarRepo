/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Sep 2021 navma1  ChangeRequest 51485: PRP - Multi-Roll Pickup Enhancement

*/

vars

begin	
	return self.type = MACHINETYPE_FORK_LIFT;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isIMV" id="4c830e64-7eac-4d82-9d68-0f4c7217fef1">
        <source>isIMV() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 September 2017	jlger1	Initial creation

*/

vars

begin
		
	if self.myMachineTypeGroup = null then
		return false;
	endif;
	
	return self.myMachineTypeGroup.type = MACHINETYPEGRP_IMV;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="c8e69601-3501-4331-8e24-b069a259c689">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxyMachineType:CM_MachineType;
	completedOK		: Boolean;
	
begin

	proxyMachineType := inheritMethod();

	// RJS - need to add other references here, including collections
	// self.ports is inversed and this is the auto end so no need
	// to copy to the proxy
	
	self.allAllowedTATypes.copy(proxyMachineType.allAllowedTATypes);
	
	self.allAllowedCargoTypes.copy(proxyMachineType.allAllowedCargoTypes);
	
	self.allFaultQuestions.copy(proxyMachineType.allFaultQuestions);
	
	self.allDamagePositions.copy(proxyMachineType.allDamagePositions);
	
	self.allDamageDefinitionCodes.copy(proxyMachineType.allDamageDefinitionCodes);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyMachineType;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyMachineType;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setCargoTypes" id="ea359c5e-4c85-4aef-9f7f-b89309cbecaa">
        <updating/>
        <source>setCargoTypes(cargos : CM_CargoTypeSet input) updating;
//Given an array of cargoTypes, adds them to the list of ta's
//held in the system.
vars
	cargoType	: CM_CargoType;
	mach		: CM_Machine;

begin
	//--------------
	//Clear out the existing collection
	//--------------
	if self.allAllowedCargoTypes.size &gt; 0 then
		self.allAllowedCargoTypes.clear;
	endif;
	if cargos.size = 0 then
		return;
	endif;
	//-------------
	//Add these to the coll
	//-------------
	foreach cargoType in cargos do
		self.allAllowedCargoTypes.add(cargoType);
	endforeach; 

/*	NFS change which has not been approved yet
	if app.msgBox("Would you like to apply these cargo types to all machines of this type on site?", "Apply Cargo Type Changes", MsgBox_Yes_No) = MsgBox_Return_Yes then
		foreach mach in app.getMyTerminal().machines do
			if mach.machineType = type then
				allowedCargoTypes.clear;
				foreach cargoType in cargos do
					allowedCargoTypes.add(cargoType);
				endforeach; 
			endif;
		endforeach;
	endif;
*/
end;</source>
        <Parameter name="cargos" type="CM_CargoTypeSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="70a7b149-6d83-4b57-9295-b7fe98fbc8d9">
        <updating/>
        <source>setForCreate(pProxyMachineType:CM_MachineType) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	pProxyMachineType.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxyMachineType);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyMachineType" type="CM_MachineType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="21df66c7-85f5-4a2b-87fb-c35270bff156">
        <updating/>
        <source>setForUpdate(pProxyMachineType:CM_MachineType) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.type := pProxyMachineType.type;
	self.description := pProxyMachineType.description.trimBlanks;
	self.allAllowedCargoTypes.clear;
	self.allAllowedTATypes.clear;
	pProxyMachineType.allAllowedCargoTypes.copy(self.allAllowedCargoTypes);
	pProxyMachineType.allAllowedTATypes.copy(self.allAllowedTATypes);	
	// 30/07/2009 cnwsh3 - CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	self.allDamagePositions.clear();
	pProxyMachineType.allDamagePositions.copy(self.allDamagePositions);
	self.allDamageDefinitionCodes.clear();
	pProxyMachineType.allDamageDefinitionCodes.copy(self.allDamageDefinitionCodes);
end;</source>
        <Parameter name="pProxyMachineType" type="CM_MachineType"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="4d329483-5cf6-4062-a6a6-9ea3321aae1c">
        <updating/>
        <source>setMyRoot() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myRoot := app.myRoot;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e236a403-55cd-4856-9c8b-10681a4e6f56">
        <updating/>
        <source>setProxy(_type:Integer; _description:String; _cargoTypes, _taTypes :ObjectArray; _damagePositions, _damageDefintionCodesSet : CM_ObjectSet) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.type := _type;
	self.description := _description[1:25];
	self.allAllowedCargoTypes.clear;
	if _cargoTypes &lt;&gt; null then
		_cargoTypes.copy(self.allAllowedCargoTypes);
	endif;
	self.allAllowedTATypes.clear;
	if _taTypes &lt;&gt; null then
		_taTypes.copy(self.allAllowedTATypes);
	endif;
	
	// 30/07/2009 cnwsh3 - CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	self.allDamagePositions.clear();
	if _damagePositions &lt;&gt; null then
		_damagePositions.copy(self.allDamagePositions);
	endif;
	self.allDamageDefinitionCodes.clear();
	if _damageDefintionCodesSet &lt;&gt; null then
		 _damageDefintionCodesSet.copy(self.allDamageDefinitionCodes);
	endif;
	self.myRoot	:= app.myRoot;
	
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_cargoTypes" type="ObjectArray"/>
        <Parameter name="_taTypes" type="ObjectArray"/>
        <Parameter name="_damagePositions" type="CM_ObjectSet"/>
        <Parameter name="_damageDefintionCodesSet" type="CM_ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="supportsRT" id="d90e8126-0526-45d4-b463-ed0db6bbfe8d">
        <source>supportsRT() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
14 May 2018		jlgmd1	Initial creation TFS #38555 MSL - Portainer Crane in RT
14 Sep 2022 	jlier1 TFS 54701 - tractor now supports rt
*/

vars

begin
	if self.type = MACHINETYPE_FORK_LIFT or
		self.type = MACHINETYPE_IMV or
		//self.yupe = MACHINETYPE_PORTAINER_CRANE or
		self.type = MACHINETYPE_RMG or
		self.type = MACHINETYPE_RTG or
		self.type = MACHINETYPE_SIDE_LOADER or
		self.type = MACHINETYPE_STRADDLE or
		self.type = MACHINETYPE_TOP_LIFT or
		self.type = MACHINETYPE_TRUCK_TRACTOR //or
		//self.type = MACHINETYPE_WAGONRAIL
		then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
