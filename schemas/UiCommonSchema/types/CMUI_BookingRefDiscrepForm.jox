    <JadeMethod name="doTblDataContextMenu" id="15b5941a-9ed7-4db4-b3b8-43becc0b6513">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

	obj : Object;
	eventDiscrep : CMEVT_BookingRefDiscrep; 
	bookingRef : CM_BookingRef;
	ti : CM_TrackedItem;
	
	cloneCount : Integer;
	clonedItem : MenuItem;
	index : Integer;
	
begin

	obj := cntrl.accessRow(cntrl.row).itemObject;

	self.mnuAudit.visible := false;
	self.mnuEditBookingRef.visible := false;	
	self.mnuEditRemarks.visible := false;	
	self.mnuEditTI.visible := false;
	
	if CMEVT_BookingRefDiscrep.hasInstance( obj ) then
		eventDiscrep := obj.CMEVT_BookingRefDiscrep; 
	endif;
	
	if eventDiscrep &lt;&gt; null then
	
		self.mnuEditRemarks.visible := true;
		self.mnuEditRemarks.userObject := eventDiscrep;
		
		self.mnuAudit.visible := eventDiscrep.hasAudits;
		self.mnuAudit.userObject := eventDiscrep;
		
		bookingRef := eventDiscrep.myBookingRef;
		if CM_BookingRef.hasInstance(bookingRef) then
			self.mnuEditBookingRef.visible := true;
			self.mnuEditBookingRef.userObject := bookingRef;
		endif;
		
		ti := eventDiscrep.myTrackedItem;
		if CM_TrackedItem.hasInstance(ti) then
			self.mnuEditTI.visible := true;
			self.mnuEditTI.userObject := ti;
		endif;
		
	endif;
	
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;	
	
	cloneCount := 1;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuInspectObject, false, cloneCount);
	cloneCount := 2;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuColumnOrganiser, false, cloneCount);
	cloneCount := 3;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuContextColourLegend, false, cloneCount);
	
	if self.mnuContextColourLegend.visible
	or self.mnuColumnOrganiser.visible
	or self.mnuInspectObject.visible
	then
		mnuCloneSep1.visible := true;
	endif;
	
	self.popupMenu(mnuLocalContext, x.Integer, y.Integer);

	return false;
	

//	return inheritMethod(cntrl, conwin, mouse, x, y);

epilog
	
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateCargoFromBooking" id="89abb77a-32d1-45d8-8409-5f267866f970">
        <updating/>
        <source>doUpdateCargoFromBooking() : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/10/2011	cnwdap1	Initial creation PAR #28524 CCMS POL 2096
*/
vars
	discreps	: CM_BookingRefDiscrepsSet;
	result		: Integer;
	errObj		: CM_Error;

begin
	// do we have any discrepancies selected?
	create discreps transient;
	self.tblData.allSelectedObjects.copy(discreps);
	if discreps.isEmpty then
		return true;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateTIFromBookingDiscrep(discreps, app.myPassport);
		
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings
			self.clearErrorWarnings();
			return true;
		
		else	
			result := app.showErrorWarningDialog(app.getErrorString(Booking_reference_discrepanc), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			
			errObj := app.myPassport.allErrorWarnings.first();
			if errObj &lt;&gt; null then
				self.goToErrorItem(errObj);
			endif;
		endif;
		
		return false;
	endwhile;
		
epilog
	delete discreps;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getBookingRefDiscrep" id="2d926d6b-2fe9-4628-a1f2-46ef16e630f5">
        <source>getBookingRefDiscrep() : CMEVT_BookingRefDiscrep;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

	booking : CMEVT_BookingRefDiscrep;
	
begin

	if self.myCMEVT_BookingRefDiscrep &lt;&gt; null then
		return self.myCMEVT_BookingRefDiscrep;
	else
		booking := tblData.accessRow(tblData.row).itemObject.CMEVT_BookingRefDiscrep;
		if CMEVT_BookingRefDiscrep.hasInstance(booking) then
			return booking;
		endif;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="CMEVT_BookingRefDiscrep"/>
    </JadeMethod>
    <JadeMethod name="handleEventNotification" id="f4025a10-447a-4fe4-89de-a186e28a5b7d">
        <updating/>
        <source>handleEventNotification(eventType: Integer; _booking : CMEVT_BookingRefDiscrep; eventTag: Integer) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521
*/

vars
begin
	if eventType = Object_Create_Event or eventType = Object_Update_Event then 
		if self.allTableObjects.includes(_booking) then
			self.tblDataUpdateDisplay(_booking);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="_booking" type="CMEVT_BookingRefDiscrep"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initFilterDefaults" id="7aba5703-2231-42a4-bf87-2ebd9522f9f3">
        <source>initFilterDefaults() protected;
/* ---------------------------------------------------------------------------
Created:	10 November 2009	by cnwvu1

Purpose:	PAR 21523
   
Change Date		Who			Reason
-----------		--------	--------------------------------------------------
27/10/2011		cnwdap1		PAR #28524 CCMSPOL 2096 Default "Ignore Closed" to true
------------------------------------------------------------------------------*/
vars

begin

	self.tblSearcher.setValueByName(ETRow_IgnoreClosed, true);	//moved up 7 Oct 2014	NDL	for Test '01-867' Step 3.

	if self.myCM_BookingRef = null then
		return;
	endif;
	
	if self.myCM_BookingRef.myOperator &lt;&gt; null then
		self.cmbOperator.setObject( self.myCM_BookingRef.myOperator );
		self.tblSearcher.setValueByControlName(self.cmbOperator.name, self.cmbOperator.text);
	endif;
	self.tblSearcher.setValueByName(ETRow_Booking, self.myCM_BookingRef.bookingReference);
	
//	self.tblSearcher.setValueByName(ETRow_IgnoreClosed, true);		// PAR #28524
end;</source>
        <access>protected</access>
    </JadeMethod>
