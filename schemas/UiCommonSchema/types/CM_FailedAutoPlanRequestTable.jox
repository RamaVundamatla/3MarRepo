    <JadeMethod name="getSelectedObjects" id="f8774557-0e0f-4558-a090-5772d313c6be">
        <updating/>
        <source>getSelectedObjects() : ObjectArray updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2025 naviv1	Initial creation - MTN-35171 : MTN - Optimize Satellite View Screen to Handle Large Volumes of Failed Auto Plan Alerts Efficiently

*/
vars
	alert : CM_SystemAlert;
	rowNum : Integer;
	oa : ObjectArray;

begin
	create oa transient;
	rowNum := 2;
	while self.rows &gt;= rowNum do
		if self.accessRow(rowNum).selected then
			alert := self.accessRow(rowNum).itemObject.CM_SystemAlert;
			oa.add(alert);
		endif;
		rowNum := rowNum + 1;
	endwhile;
	
	return oa;
epilog

end;</source>
        <ReturnType type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getTableStringForDelRequest" id="2681cc67-0f58-4e85-9fdd-0902c4650426">
        <source>getTableStringForDelRequest( deliveryRequest : CM_DeliveryRequest ) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 January 2012	cnwndl1	Initial creation

*/

vars
	entRow		: EntTableRow;
	tmpStr,
	rtnStr		: String;
	firstTime	: Boolean;
begin

	if deliveryRequest = null then
		return null;
	endif;
	
	firstTime := true;

	foreach entRow in self.allTblDataEntRows do	
		tmpStr := deliveryRequest.getDataForFailedReqTbl(entRow.name, true);

		if entRow.inputType = Table.InputType_CheckBox then
			if tmpStr.Boolean = true or tmpStr.toLower='yes' or tmpStr = '1' then  //cnwjo3 par 24661
				tmpStr := '1';
			else
				tmpStr := '0';
			endif;
			
		endif;
		if firstTime then
			firstTime := false;
			rtnStr := tmpStr;
		else
			rtnStr := rtnStr &amp; Tab &amp; tmpStr;
		endif;
		
		if entRow.sortFieldName &lt;&gt; null then
			tmpStr := deliveryRequest.getDataForFailedReqTbl(entRow.sortFieldName, false);
			rtnStr := rtnStr &amp; Tab &amp; tmpStr;
		endif;
	endforeach;

	return rtnStr;
	
end;</source>
        <Parameter name="deliveryRequest" type="CM_DeliveryRequest"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="fcbcd244-8885-4eff-b785-aaf1793b1164">
        <updating/>
        <source>initialise() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 January 2012	cnwndl1	Initial creation
03 July 2025	naviv1	MTN-35171 : MTN - Optimize Satellite View Screen to Handle Large Volumes of Failed Auto Plan Alerts Efficiently
*/

vars

	entTable : EntTableDef;
	view : EntTableView;
	
begin

	self.clear();
	self.gridLines := true;
	self.fixedRows := 1;
	self.rows					:=	self.fixedRows;
	self.partialTextIndication	:=	true;
	self.wordWrap 				:=	true;
	self.selectionType := CM_BaseTable.SelectionType_Row;
	self.multiSelect := CM_BaseTable.MultiSelect_Simple; //MTN-35171
	self.disallowColumnSorter := false;
	self.backColor := self.myForm.CM_BaseForm.colorControlBack;
	self.inputType := Table.InputType_None;
	
	// Do the Column Headings
	//self.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_MTReleaseDataTable));
	entTable := app.myController.getEntTableDef(ETDef_MTReleaseDataTable);
	view := entTable.allEntTableViews[SystemDefault];
	self.setTblDataEntRowsFromView( entTable, view.name );
	
	self.refresh;
	
	self.registerNotes();

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="refresh" id="8b5bb76d-ca34-4dd7-b8a3-17a767642043">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>refresh() updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 January 2012	cnwndl1	Initial creation
03 July 2025	naviv1	MTN-35171 : MTN - Optimize Satellite View Screen to Handle Large Volumes of Failed Auto Plan Alerts Efficiently
*/

vars

	alert			: CM_SystemAlert;
	alertType		: CM_SystemAlertType;
	iter			: Iterator;
	terminal		: CM_Terminal;
	deliveryRequest : CM_DeliveryRequest;
	reserveSelection : CM_ReserveSelection;
	tableString		: String;
	linkedToAlertObj	: CM_Object;
	reserveDetail	: CM_ReserveDetail;
begin
	self.clearAllData();
	
	alertType := app.myRoot.allSystemAlertTypes[EVENT_AT_FailedAutoPlanRequest];
	if alertType &lt;&gt; null then
		iter := alertType.allSystemAlerts.createIterator();
		alertType.allSystemAlerts.startKeyGeq(false, null, iter);
	
		terminal := self.getTerminal();
		
		while iter.next(alert) do
		
			if alert.reviewed then			// Only interested in unreviewed alerts
				break;
			endif;
			if alert.myTerminal &lt;&gt; terminal then
				continue;
			endif;
			
			//MTN-35171 -- Start
			linkedToAlertObj := alert.getLinkedTo();			
			if linkedToAlertObj = null then
				continue;
			endif;
			
			deliveryRequest := linkedToAlertObj.CM_DeliveryRequest;
			
			if deliveryRequest = null then
				continue;
			endif;
			
			reserveDetail := deliveryRequest.myReserveDetail;
			
			if reserveDetail &lt;&gt; null then 
				reserveSelection := alert.getMyReserveSelection(reserveDetail);
			endif;
			
			//MTN-35171 -- End
			
			tableString := null;
			if reserveSelection &lt;&gt; null then
				tableString := reserveSelection.getAttributeStringForDefArray(self.allTblDataEntRows);
			elseif deliveryRequest &lt;&gt; null then
				tableString := self.getTableStringForDelRequest(deliveryRequest);
			endif;
			
			if tableString &lt;&gt; null then
				self.allNotableObjs.tryAdd(linkedToAlertObj);	//MTN-35171
				self.beginNotification(linkedToAlertObj, Object_Delete_Event, Response_Continuous, 0);	//MTN-35171
				self.addItemObject(alert, tableString);
			endif;
			
		endwhile;
	endif;
	
	self.setParentCaption();

epilog

	delete iter;
end;
</source>
    </JadeMethod>
    <JadeMethod name="registerNotes" id="c8ef050b-7e90-429d-abc3-124814348b5e">
        <source>registerNotes();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 January 2012	cnwndl1	Initial creation

*/

vars

	terminal: CM_Terminal;

begin

	terminal := self.getTerminal();
	self.beginNotification(terminal, terminal.getTerminalEvent(EventTerminalAlertAdd), Response_Continuous, 0);
	self.beginNotification(terminal, terminal.getTerminalEvent(EventTerminalAlertDelete), Response_Continuous, 0);
	self.beginNotification(terminal, terminal.getTerminalEvent(EventTerminalAlertUpdate), Response_Continuous, 0);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectRows" id="c0d5f6fe-50ce-4403-9bb6-17f26494fcbe">
        <updating/>
        <source>selectRows(_requests: CM_RequestArray) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 January 2012	cnwndl1	Initial creation

*/

vars

	rowObjects: ObjectSet;
	rowObject: Object;
	alert: CM_SystemAlert;
	first: Boolean;
	linkedTo : CM_Object;
	request : CM_Request;

begin

	create rowObjects transient;
	self.getAllRowObjects(rowObjects);
	first := true;
	foreach rowObject in rowObjects do
		alert := rowObject.CM_SystemAlert;
		linkedTo := alert.getLinkedTo;
		if linkedTo = null or not linkedTo.isKindOf(CM_Request) then
			continue;
		endif;
		request := linkedTo.CM_Request;
		if _requests.includes(request) then
			self.selectObject(alert, first);
			first := false;
		endif;
	endforeach;

epilog

	delete rowObjects;

end;</source>
        <Parameter name="_requests" type="CM_RequestArray"/>
    </JadeMethod>
    <JadeMethod name="setParentCaption" id="b4807f03-18e6-4fef-92d0-ae4d001b848d">
        <source>setParentCaption();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 January 2012	cnwndl1	Initial creation	Par 28953

*/

vars

	heading : String;
	count : Integer;
	sheet : CMUI_Sheet;

begin

	if self.parent  &lt;&gt; null and self.parent.isKindOf( CMUI_Sheet ) then
		sheet := self.parent.CMUI_Sheet;
		heading := "Failed 'Request' Auto Plan";
		if self.rows &gt; self.fixedRows then
			count := self.rows - self.fixedRows;
		endif;
		heading := "(x" &amp; count.String &amp; ") " &amp; heading;
		sheet.caption := heading;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="399469e2-b9d1-489f-916b-3c9b44e6c5d5">
        <controlMethod name="Table::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>sysNotify(table: Table input; eventType: Integer; theObject: Object; eventTag: Integer) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 January 2012	cnwndl1	Initial creation

*/

vars

	startIndex : Integer;
	endIndex : Integer;
	index : Integer;
	alert : CM_SystemAlert;
	linkedTo : CM_Object;
	invalid : Boolean;
	allAlertsToDelete : CM_AlertsArray;

begin
	inheritMethod(table, eventType, theObject, eventTag);
	
	if eventType = Object_Delete_Event and theObject &lt;&gt; null and self.allNotableObjs.includes(theObject) then
		
		self.allNotableObjs.remove(theObject);
		self.endNotification(theObject, Object_Delete_Event);
		
		create allAlertsToDelete transient;
		
		startIndex := self.fixedRows + 1;
		endIndex := self.rows;
		
		on Exception do app.handleDeletedObject( exception, alert, invalid );
		if endIndex &gt;= startIndex then
			foreach index in startIndex to endIndex do
				invalid := false;
				alert := self.accessRow(index).itemObject.CM_SystemAlert;
				if alert &lt;&gt; null then
					linkedTo := alert.getLinkedTo;
					if invalid or theObject = linkedTo or linkedTo = null then
						allAlertsToDelete.add( alert );
					endif;
				endif;
			endforeach;
		endif;
		
		if not allAlertsToDelete.isEmpty then
			foreach alert in allAlertsToDelete do
				self.removeItemObject(alert);
			endforeach;
			self.setParentCaption();
		endif;
		
	endif;

epilog

	delete allAlertsToDelete;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="0f11a757-89f4-4a85-bcf9-21769f60eb81">
        <controlMethod name="CM_DataTable::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>userNotify(table: Table input; eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, clientExecution;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 January 2012	cnwndl1	Initial creation
03 July 2025	naviv1	MTN-35171 : MTN - Optimize Satellite View Screen to Handle Large Volumes of Failed Auto Plan Alerts Efficiently
*/

vars

	localEvent : Integer;
	rowIndex: Integer;
    invalidObject : Boolean;
	alert: CM_SystemAlert;
	terminal : CM_Terminal;
	deliveryRequest : CM_DeliveryRequest;
	reserveSelection : CM_ReserveSelection;
	tableString		: String;
	linkedToAlertObj	: CM_Object;
	reserveDetail : CM_ReserveDetail;
begin
	
	if userInfo &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, userInfo.Object, invalidObject);
	endif;
	
	terminal := self.getTerminal();
	
	alert := userInfo.CM_SystemAlert;
	if alert &lt;&gt; null then
		localEvent := self.getTerminal.getEventFromTerminalEvent(eventType);
		
		if localEvent = EventTerminalAlertAdd and alert.isType(EVENT_AT_FailedAutoPlanRequest) then
	
			if alert.reviewed then			// Only interested in unreviewed alerts
				return;
			endif;
			if alert.myTerminal &lt;&gt; terminal then
				return;
			endif;
			
			//MTN-35171 -- start
			linkedToAlertObj := alert.getLinkedTo();
			if linkedToAlertObj = null then
				return;
			endif;
			
			deliveryRequest := linkedToAlertObj.CM_DeliveryRequest;
			
			if reserveDetail &lt;&gt; null then
				reserveDetail := deliveryRequest.myReserveDetail;
				
				if reserveDetail &lt;&gt; null then 
					reserveSelection := alert.getMyReserveSelection(reserveDetail);
				endif;
			endif;
			
			tableString := null;
			if reserveSelection &lt;&gt; null then
				tableString := reserveSelection.getAttributeStringForDefArray(self.allTblDataEntRows);
			elseif deliveryRequest &lt;&gt; null then
				tableString := self.getTableStringForDelRequest(deliveryRequest);
			endif;
			
			if tableString &lt;&gt; null then
				self.allNotableObjs.tryAdd( linkedToAlertObj );
				self.beginNotification(linkedToAlertObj, Object_Delete_Event, Response_Continuous, 0);
				self.addItemObject(alert, tableString);
			endif;
			//MTN-35171 -- End
		endif;
		
		if localEvent = EventTerminalAlertDelete 
		or (localEvent = EventTerminalAlertUpdate and alert.reviewed) then
			self.removeItemObject(alert);
		endif;
		
		self.setParentCaption();
		
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
