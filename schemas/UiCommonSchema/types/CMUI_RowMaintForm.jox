    <JadeMethod name="hideStartingLabels" id="847b2a8a-49e1-4411-a7dc-159341cde97a">
        <source>hideStartingLabels(_isMarkedUp : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     16 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
begin

	// This method hides and shows rows on the input table.
	
	// Is this area marked up.
	if  _isMarkedUp then
		// If we are in update mode or add mode and we aren't doing a split then enable.
		if not self.isRowSplit and (self.mode = self.Mode_Update or self.mode = self.Mode_Add) then		
			self.tblInput1.showRowByName(ETRow_StartRow, false);
			return;
		endif;
	endif;
	// Just hide.
	self.tblInput1.hideRowByName(ETRow_StartRow, false);
	
	
epilog
	
	if self.isRowSplit then
	//	self.tblInput1.hideRowByName(ETRow_DistanceFromPrevious, false);
		if (self.mode = self.Mode_Update or self.mode = self.Mode_Add) then
			self.tblInput1.showRowByName(ETRow_RowToSplit, false);
		else
			self.tblInput1.hideRowByName(ETRow_RowToSplit, false);
		endif;
		
	else
		self.tblInput1.hideRowByName(ETRow_RowToSplit, false);
		if self.myCurrentRowArea.isGapManaged then
			self.tblInput1.showRowByName(ETRow_DistanceFromPrevious, false);
		else
			self.tblInput1.hideRowByName(ETRow_DistanceFromPrevious, false);
		endif;
	endif;
	self.tblInput1.adjustHeight(1000);
end;</source>
        <access>protected</access>
        <Parameter name="_isMarkedUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="f9ad5abf-2263-44e2-bdde-3f10673af9e0">
