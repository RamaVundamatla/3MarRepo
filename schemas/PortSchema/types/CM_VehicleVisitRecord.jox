    <JadeMethod name="getGateEntityForTIID" id="57d7ee1c-66ab-469e-acec-307b1252b4d0">
        <source>getGateEntityForTIID(_tiID : String) : CMGTE_Entity;
/*

Date		Who		Reason
26 September 2013	cnwer1	Initial creation PAR

*/

vars
	entity : CMGTE_Entity;
	ti : CM_TrackedItem;
begin
	
	foreach entity in self.allGateEntities do
		ti:=entity.getTI;
		if ti = null then
			continue;
		endif;
		
		if ti.id = _tiID then
			return entity;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
