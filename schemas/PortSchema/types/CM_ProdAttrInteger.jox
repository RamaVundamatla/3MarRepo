    <JadeMethod name="validateForUpdate" id="e3879ef7-c6e7-4cbf-86e2-4da15be1abbf">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     08 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	
	if self.value * self.multiplier &gt; 9999.999 then 		
		app.raiseCMException2(ERR_EXPRESSION_OVERFLOW, (self.value * self.multiplier).Decimal.String, 9999999.999.Decimal.String, null,null);
		return;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateValue" id="528c3981-7f80-48e1-a7e6-5e2c055f2342">
        <source>validateValue(_value: Decimal): Boolean;
// ---------------------------------------------------------------------------
// Created:     04 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.minValue &lt;&gt; null and self.maxValue &lt;&gt; null then
		return (_value &gt;= self.minValue) and (_value &lt;= self.maxValue);
	else
		return true;
	endif;

end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
