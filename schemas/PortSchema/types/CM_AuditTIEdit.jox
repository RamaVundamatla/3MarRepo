    <JadeMethod name="setInvalidReference" id="c7ead858-8499-4585-8fcd-b72c0fa97e83">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>setInvalidReference(_pName: String; _fixit: Boolean) updating, serverExecution;
// cnwrs1 mar 2006
vars

begin
	if not _pName = CM_AuditTIEdit::trackedItem.name then
		inheritMethod(_pName, _fixit);
	endif;
end;</source>
