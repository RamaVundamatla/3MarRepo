<Class name="WS_Alert" id="c3cd3407-1fd3-4519-bfd5-44bfa1469a1c">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="alertMessage" id="bfd64bf7-2ffc-4323-aa98-c4f7a0e89418">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="code" id="59ba7509-8bd2-4bea-acc3-37fb71ac311c">
        <length>5</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="description" id="623bec33-5729-4ded-9b79-01a10ee2009a">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="6a7c7f0c-1043-49b0-bc41-ada540597bf0">
        <updating/>
        <source>setProxyFromObject(_realRemark: CM_PredefinedRemark) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2017	cnwhl1	Initial creation

*/

vars

begin
	inheritMethod(_realRemark);
	
	self.code 			:= _realRemark.code;
	self.description 	:= _realRemark.description;
	
	

epilog

end;</source>
        <Parameter name="_realRemark" type="CM_PredefinedRemark"/>
    </JadeMethod>
</Class>
