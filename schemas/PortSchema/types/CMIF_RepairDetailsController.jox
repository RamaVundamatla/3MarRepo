<Class name="CMIF_RepairDetailsController" id="3d99ba82-c431-4197-89a5-ba1bca191467">
    <superclass name="CMIF_TITransactionController"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="damageCode" id="714509a6-b0cf-45af-866f-8f0cbb6995d4">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="damageDesc" id="f9d54945-cd9f-47d0-a289-c26ecea52f3b">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="damagePositionCode" id="0ae0e2aa-2c2a-4d43-96d2-0b381dd8922e">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="damagePositionDesc" id="6d219c00-e08b-4dc2-8a1f-293e1c18d794">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="damageTS" id="d6cf708d-8dc0-4807-8a56-a18d51861a05">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <PrimAttribute name="locationString" id="ff36c97e-d320-45bf-b7ed-174eff9bd7a6">
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myDamageParty" id="da0fe53b-115e-44d4-9fda-ff157107902f">
        <embedded/>
        <type name="CM_DamageParty"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myRepairReason" id="541491d9-4bad-4fa7-ae38-90107a0ae300">
        <embedded/>
        <type name="CM_RepairReason"/>
    </ImplicitInverseRef>
    <PrimAttribute name="quantity" id="008aba25-f1e8-4aac-8951-3ef6a1da8e52">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="repairedDateTime" id="05c97d10-92f9-4861-9a2b-db45e1e85924">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <PrimAttribute name="severity" id="10bd5791-6f5c-45f0-8f61-fef81864c50c">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="setFromDamageInstance" id="7872e45b-682d-42f1-94ec-c4d098b37ce7">
        <updating/>
        <source>setFromDamageInstance(damageInstance: CM_DamageInstance; serverTime : TimeStamp) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 November 2018
TFS#		: 41225
Function	:

*** Changes ***
Date			Name		TFS#		Description
24 June 2022 	navhl20 	53862 		EUP - WMS - Damage Recording Extra Details
05 July 2022 	navsj20 	53862 		EUP - WMS - Damage Recording Extra Details
****************************************************/

begin
	self.damageCode 		:= damageInstance.getDamageCode();
	self.damageDesc 		:= damageInstance.getDamageDescr;
	self.damagePositionCode := damageInstance.getDamagePositionCode;
	self.damagePositionDesc := damageInstance.getDamagePositionDescr;
	self.damageTS 			:= serverTime;
	self.locationString 	:= damageInstance.locationString;
	self.quantity 			:= damageInstance.quantity;
	self.remarks 			:= damageInstance.remarks;
	//Start 24 June 2022 navhl20 TFS 53862
	//self.severity 			:= damageInstance.severity;		
	if damageInstance.myDamageSeverity &lt;&gt; null then 
		self.severity 		:= 	damageInstance.myDamageSeverity.level;			
	endif;
	//End 24 June 2022 navhl20 TFS 53862
	
	//Start 05 July 2022 navsj20 TFS 53862
	self.myRepairReason		:= damageInstance.myRepairReason;			
	self.repairedDateTime 	:= damageInstance.repairedDateTime;	
	self.myDamageParty		:= damageInstance.myDamageParty;
	if damageInstance.repairRemarks &lt;&gt; null then 
		self.remarks	:=	damageInstance.repairRemarks;			
	endif;
	//End 05 July 2022 navsj20 TFS 53862

end;</source>
        <Parameter name="damageInstance" type="CM_DamageInstance"/>
        <Parameter name="serverTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setFromTransaction" id="465e2685-4fcc-4b04-8747-7269e4294437">
        <updating/>
        <source>setFromTransaction(_txn: CM_RepairDetail) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 November 2018
TFS#		: 41225
Function	:

*** Changes ***
Date			Name		TFS#		Description
// 13 Oct 2022	navak20 53862 EUP - WMS - Damage Recording Extra Details
****************************************************/

begin
	inheritMethod(_txn);
	self.damageCode 		:= _txn.damageCode;
	self.damageDesc 		:= _txn.damageDesc;
	self.damagePositionCode := _txn.damagePositionCode;
	self.damagePositionDesc := _txn.damagePositionDesc;
	self.damageTS 			:= _txn.damageTS;
	self.locationString 	:= _txn.locationString;
	self.quantity 			:= _txn.quantity;
	self.remarks			:= _txn.remarks;
	//self.severity 			:= _txn.severity;	// 13.10.2022 navak20 TFS 53862
end;</source>
        <Parameter name="_txn" type="CM_RepairDetail"/>
    </JadeMethod>
</Class>
