    <JadeMethod name="doMnuReleaseItem" id="6ed611b8-a281-4104-ada9-1a8a46548205">
        <source>doMnuReleaseItem(menuItem: MenuItem);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 July 2011	cnwrd1	Initial creation

*/

vars
	obj : Object;
	theItem,
	proxyTI : CM_TrackedItem;
begin

	obj := menuItem.userObject;
	if not CM_TrackedItem.hasInstance( obj ) then
		return;
	endif;
	
	theItem := obj.CM_TrackedItem;
	
	
	self.myMasterProxyObject.CM_BulkRelease.addTIReleased(theItem, CM_ReserveDetail.PackType_Parent);
	
	//proxyTI :=  app.createUpdateProxy(theItem).CM_TrackedItem;	
	//self.myMasterProxyObject.CM_BulkRelease.addTIReleased(proxyTI, CM_ReserveDetail.PackType_Parent);

	
epilog

end;</source>
