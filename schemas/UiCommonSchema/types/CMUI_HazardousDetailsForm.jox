    <JadeMethod name="setupForm" id="93bfa8f3-63e0-4037-a44d-be8b8070420d">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/11/2016	cnwdap1		Initial creation TFS 2842 Hazardous Details Enhancements
//
vars
	hazard : CM_Hazard;
	coll : CM_HazardByCodeDict;
	obj : Object;
	hazsnap : CM_HazardSnapShot;
	snapshot : CM_SnapShot;
begin
	inheritMethod();

	self.setupTable();
	self.loadCombos();
	self.btnUpdate.enabled := false;
	self.btnRemove.enabled := false;
	self.setReadOnly();
	
	if self.myPxyTrackedItem &lt;&gt; null then
		coll := self.myPxyTrackedItem.allTIHazards;
	elseif self.myPxyBookingItem &lt;&gt; null then
		if not self.myPxyBookingItem.allTIHazards.isEmpty then
			coll := self.myPxyBookingItem.allTIHazards;
		endif;
	elseif self.myPxyBooking &lt;&gt; null then
		coll := self.myPxyBooking.allTIHazards;
		
	// TFS 40336
	elseif self.mySnapShot &lt;&gt; null then
		foreach snapshot in self.mySnapShot.allHazSnapShots	discreteLock do
			hazsnap := snapshot.CM_HazardSnapShot;
			self.tblHazards.updateItemObject(hazsnap, self.colorRow1, self.colorRow2, app.myPassport);
	
		endforeach;
	
		return;
	endif;
	
	if coll &lt;&gt; null and not coll.isEmpty then
		foreach hazard in coll do
			self.tblHazards.updateItemObject(hazard, self.colorRow1, self.colorRow2, app.myPassport);
		endforeach;
	else
		foreach obj in self.allHazardsToShow do
			hazard := obj.CM_TIHazard;
			self.tblHazards.updateItemObject(hazard, self.colorRow1, self.colorRow2, app.myPassport);
		endforeach;
	endif;
	
	// TFS 40336
	if not self.isReadOnly
	and not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.setIsReadOnly(true);
		self.setReadOnly();
	
	endif;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupTable" id="def05080-da0e-4402-917e-de3f8e31e821">
        <source>setupTable();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/11/2016	cnwdap1		Initial creation TFS 2842 Hazardous Details Enhancements
//
vars
	table : CM_DataTable;
	def : EntTableDef;

begin
	table := self.tblHazards;
	table.rows := table.fixedRows;
	
	table.columns := 7;
	def := app.myController.getEntTableDef(ETDef_HazardDetails);
	if def &lt;&gt; null then
		table.setTblDataEntRowsFromDef(def);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "EntTableDef 'Hazard Details' not found");
	endif;
	table.cnEcResizeContents();
	
	if self.mySnapShot &lt;&gt; null then
		self.btnAdd.visible := false;
		self.btnRemove.visible := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblHazards_click" id="78b929cb-114c-4fdc-83ad-442c10bf61e3">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblHazards_click(table: Table input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/11/2016	cnwdap1		Initial creation TFS 2842 Hazardous Details Enhancements
//
vars
	row : Integer;
	pxyObj : CM_TIHazard;
	obj : Object;
	pxyHazSnap : CM_HazardSnapShot;
begin
	foreach row in table.fixedRows + 1 to table.rows do
		table.accessRow(row).selected := false;
		if table.row = row then
			table.accessRow(row).selected := true;
		endif;
	endforeach;
	
	if table.row &gt; table.fixedRows and table.row &lt;= table.rows then
		if table.accessRow(table.row).itemObject &lt;&gt; null then
			if not self.isReadOnly then
				self.btnUpdate.enabled := true;
				self.btnRemove.enabled := true;
			endif;
			obj := table.accessRow(table.row).itemObject;
			if obj.isKindOf(CM_TIHazard) then
				pxyObj := obj.CM_TIHazard;
				self.populateDetails(pxyObj);
			elseif obj.isKindOf(CM_HazardSnapShot) then // TFS 40336
				pxyHazSnap := obj.CM_HazardSnapShot;
				self.populateDetailsSnap(pxyHazSnap);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4b3690d7-bacd-436b-812b-a0b0fbd62b25">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 02 December 2016 09:52:23.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021537, locale);
	btnAdd.translateCaption(Xlat_0021538, locale);
	btnRemove.translateCaption(Xlat_0021539, locale);
	btnUpdate.translateCaption(Xlat_0021540, locale);
	lblAcidBase.translateCaption(Xlat_0021541, locale);
	lblDegCT.translateCaption(Xlat_0021542, locale);
	lblFlashpoint.translateCaption(Xlat_0021543, locale);
	lblHazardClass.translateCaption(Xlat_0021544, locale);
	lblLimited.translateCaption(Xlat_0021545, locale);
	lblMarinePoll.translateCaption(Xlat_0021546, locale);
	lblPackGroup.translateCaption(Xlat_0021547, locale);
	lblUNCodes.translateCaption(Xlat_0021548, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtUNCodes_change" id="9ec1ded3-db5f-4d5b-90ff-22f845631466">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtUNCodes_change(textbox: TextBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/11/2016	cnwdap1		Initial creation TFS 2842 STWR Hazardous Details Enhancements
//
vars
	str : String;
	strs : StringArray;
	undg : CM_UNDangerousGoods;

begin
	self.cmbMarinePoll.listIndex := -1;
	self.cmbMarinePoll.enabled := true;
	
	// Need to check if the entered UNDG code has "Is Marine Pollutant" set
	str := textbox.text;
	create strs transient;
	str.getTokensForDelimiter(Comma, strs);
	foreach str in strs do
		undg := app.myRoot.allUNDangerousGoodsCodes[str];
		if undg &lt;&gt; null and undg.isMarinePollutant = MarinePollutant_Yes then
			self.cmbMarinePoll.listIndex := self.cmbMarinePoll.findStringExact(1, MarinePollutant_YesString);
			self.cmbMarinePoll.enabled := false;
		elseif undg &lt;&gt; null and undg.isMarinePollutant = MarinePollutant_No then
			self.cmbMarinePoll.listIndex := self.cmbMarinePoll.findStringExact(1, MarinePollutant_NoString);
			self.cmbMarinePoll.enabled := false;
		endif;
	endforeach;
epilog
	delete strs;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="715289b0-91dd-4403-a4c9-ba6b90fdf25b">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>unloadForm(): Boolean updating, clientExecution;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/11/2016	cnwdap1		Initial creation TFS 2842 Hazardous Details Enhancements
//
vars

begin
	self.allDeletedProxies.purge;
	return inheritMethod();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateDetails" id="153c9fa7-8699-4245-9ec4-90295778821c">
        <updating/>
        <source>validateDetails() : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/11/2016	cnwdap1		Initial creation TFS 2842 Hazardous Details Enhancements
// 2/8/24  		navsaa30	Bug 65355: MTN - Flashpoint Temperature Field behaviour
// 07 Jan 2025  navsck1 	MTN-33234 CUX - PUT /cargo with hazards error message
//
vars
	hazClass : CM_HazardClass;
	unCodes : StringArray;
	code : String;
	unCode : CM_UNDangerousGoods;
	hazTemp : Real;
	hazTempRange : CM_HazTempRange;
	validateHazUNDG : Boolean;
	packingGroup : String;
	rangeFound	: Boolean;

begin
	// validate the input
	// required field is hazard class 
	if self.cmbHazClass.listIndex &lt; 1 then
		app.raiseCMException(Input_Required_Hazard_Code, "Hazard Class", null);
		self.cmbHazClass.setFocus;
		return false;
	endif;
	
	hazClass := self.cmbHazClass.listObject.CM_HazardClass;
	// check undg number is valid, and associated with the selected hazard class
	validateHazUNDG := self.myTerminal.getConfig(ValidateHazardousUNDG).Boolean;
	if self.txtUNCodes.text.trimBlanks &lt;&gt; null then
		create unCodes transient;
		self.txtUNCodes.text.trimBlanks.getTokensForDelimiter(Comma, unCodes);
		foreach code in unCodes do
			unCode := app.myRoot.allUNDangerousGoodsCodes[code.trimBlanks()];
			if unCode = null and validateHazUNDG then
				app.raiseCMException2(WARN_UNKNOWN_UNDG, code, hazClass.code, "UNDG Code", null);
				return false;
			endif;
			if validateHazUNDG then
				if not unCode.allClassCodes.includes(hazClass.code) and unCode.myHazardClass &lt;&gt; hazClass then
					app.raiseCMException2(UNDG_Assoc_Haz_Class, code, hazClass.code, "UNDG Code", null);
					return false;
				endif;
				packingGroup := self.cmbPackGroup.text;
				if packingGroup &lt;&gt; null and not unCode.allPackingGroups.includes(packingGroup) then
					app.raiseCMException3(Packing_Group_Assoc_Hazard, packingGroup, hazClass.code, code, null, null); // 07/01/2025 navsck1 #MTN-33234
				endif;
			endif;
			
			if unCode &lt;&gt; null and unCode.isMarinePollutantMandatory and self.cmbMarinePoll.text = MarinePollutant_NullString then
				app.raiseCMException1(Marine_Pollutant_Required, unCode.code, "Marine Pollutant", null);
			endif;
		endforeach;
	endif;
	
	if self.txtFlashpoint.text &lt;&gt; null then
	//	hazTemp := self.txtFlashpoint.text.Real;
		hazTemp := self.txtFlashpoint.text.String.asRealJMT;	//03 May 2017	NDL	TFS 4054
		/*hazTempRange := app.myRoot.allHazTempRanges.getAtKeyLeq(hazTemp);
		if hazTempRange = null or hazTempRange.upper &lt; hazTemp then
			hazTempRange := app.myRoot.allHazTempRanges.getAtKeyGeq(hazTemp);
			if hazTempRange = null or hazTempRange.upper &lt; hazTemp or hazTempRange.lower &gt; hazTemp then    //2/8/24   navsaa30 #65355
				app.raiseCMException1(Flashpoint_Temp_Not_Found, hazTemp.asStringJMT, null, null);
				return false;
			endif;
		endif;*/
		foreach hazTempRange in app.myRoot.allHazTempRanges do						//2/8/24   navsaa30 #65355
			if  hazTempRange.lower &lt;= hazTemp and hazTempRange.upper &gt;= hazTemp then
				rangeFound := true;
				break;
			endif;
		endforeach;
		if not rangeFound then
			app.raiseCMException1(Flashpoint_Temp_Not_Found, hazTemp.asStringJMT, null, null);
		else
			return true;
		endif;
	endif;
		
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
