    <JadeMethod name="createEmptyChild" id="82ae6213-cf3c-4e42-a5bb-9b6db84ae5cc">
        <updating/>
        <source>createEmptyChild(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	emptySet 	: ObjectSet;
	emptyCMSet	: CM_ObjectSet;
begin
	create myObject as CM_LogGrade transient;
	create emptySet transient;
	create emptyCMSet transient;
	
	self.myObject.CM_LogGrade.setProxy(null, null, false,_parent.myObject.CM_LogSpecies, emptyCMSet, emptySet, emptySet,null,0,0,0,0);
	self.myParent := _parent;
epilog
	delete emptySet;
	delete emptyCMSet;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="createEmptyPeer" id="b020a14e-37c3-400c-ac7e-0702065c39e4">
        <updating/>
        <source>createEmptyPeer(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		19 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxyGrade	: CM_LogGrade;
	emptySet 	: ObjectSet;
	emptyCMSet	: CM_ObjectSet;
begin
	create proxyGrade transient;
	create emptySet transient;
	create emptyCMSet transient;		
	
	proxyGrade.setProxy(null, null, false, _parent.myObject.CM_LogSpecies, emptyCMSet, emptySet ,emptySet,null, 0,0,0,0);
	self.myObject := proxyGrade;
	self.myParent := _parent;	
epilog
	delete emptySet;
	delete emptyCMSet;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="07a7d68b-09d0-48ec-952c-bf94338cee95">
        <updating/>
        <source>doDelete(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	invalidObj : Boolean;
begin

 on Exception do app.handleDeletedObject(exception, self.myObject.CM_LogGrade, invalidObj); // cnwrd1 3.11.08 par 18090
 
	app.myTrxDA.trxDeleteLogGrade(self.myObject.CM_LogGrade, app.myPassport);
	
	return app.myPassport.trxCompletedOK;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="8296e6dd-ed5b-4072-84d7-9a8a35dc4f15">
        <updating/>
        <source>doSave(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxyGrade, newGrade 	: CM_LogGrade;
	lengthSet				: CM_ObjectSet; 
	typeSet, treatmentSet	: ObjectSet;
	aColour					: Integer;
	minSED,	maxSED,
	minMeanSED, maxMeanSED	: Decimal[6,2];
	
begin
	if self.myForm.mode = self.myForm.Mode_Add then
		if self.myForm.myProxyObject &lt;&gt; null then
			self.myForm.myProxyObject.erase(NORMAL_ERASE);
		endif;
		
		create self.myForm.myProxyObject as CM_LogGrade transient;
	endif;
	
	proxyGrade := self.myForm.myProxyObject.CM_LogGrade;
	
	create lengthSet transient;
	create typeSet transient;
	create treatmentSet transient;
	self.myForm.mulSelect1.getSelected(typeSet);
	self.myForm.mulSelect2.getSelected(treatmentSet);
	self.myForm.mulSelect3.getSelected(lengthSet);
	minSED 		:= 	self.myForm.tblInput1.getValueByName(ETRow_MinSED).Decimal;
	maxSED 		:= 	self.myForm.tblInput1.getValueByName(ETRow_MaxSED).Decimal;
	minMeanSED	:= 	self.myForm.tblInput1.getValueByName(ETRow_MinMeanSED).Decimal;
	maxMeanSED	:= 	self.myForm.tblInput1.getValueByName(ETRow_MaxMeanSED).Decimal;
	
	//clean up from failed update
	proxyGrade.allLogLengths.clear;
	proxyGrade.allLogLengthsBySortOrder.clear;
	proxyGrade.allLogTreatments.clear;
	proxyGrade.allLogTypes.clear;
	
	proxyGrade.setProxy(	self.myForm.tblInput1.getValueByName('code').String.removeTabCrLfs(),	// 18/04/2013 cnwar2 #27130
							self.myForm.tblInput1.getValueByName('description').String,
							self.myForm.tblInput1.getValueByName('notAvailableForEntry').Boolean,
							self.myObject.CM_LogGrade.myLogSpecies,
							lengthSet,
							treatmentSet,
							typeSet,
							self.myForm.tblInput1.getValueByName('colour').Integer,
							minSED, maxSED, minMeanSED, maxMeanSED);

	if self.myForm.mode = self.myForm.Mode_Add then
		app.myTrxCA.trxCreateLogGrade(proxyGrade, newGrade, app.myPassport);
		if app.myPassport.trxCompletedOK then
			delete self.myObject;  // delete the transient holder
			self.myObject := newGrade;
		endif;
	elseif self.myForm.mode = self.myForm.Mode_Update then
		app.myTrxUA.trxUpdateLogGrade(proxyGrade, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.myForm.mode.String &amp; ')');
	endif;
	
	self.myForm.myProxyObject := proxyGrade;
	return app.myPassport.trxCompletedOK;
epilog
	delete lengthSet;
	delete typeSet;
	delete treatmentSet;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
