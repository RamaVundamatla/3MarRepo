    <JadeMethod name="trxCreateJobAndRequest" id="a52a8951-d0f2-4810-aaa1-95cc89e5d874">
        <updating/>
        <source>trxCreateJobAndRequest(	pProxyJob:CM_Job input; 
						pNewJob:CM_Job output;
						pProxyRequest:CM_Request input; 
						pNewRequest:CM_Request output;
						pTI: CM_TrackedItem input; 
						pNewCon : CM_ConsigneeConsignor;
						_passport : CM_Passport input) updating;
// -------------------------------------------------------;--------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	app.myUtilityCA.utlCreateJobAndRequest(pProxyJob, pNewJob, pProxyRequest, pNewRequest, _passport);
	if _passport.hasErrors() then
		return;
	endif;

/*	// Perform the operation
	app.myUtilityCA.utlCreateJob(pProxyJob, pNewJob, _passport);

	if _passport.hasErrors() then
		return;
	endif;

	pProxyRequest.setJob(pNewJob);
	app.myUtilityCA.utlCreateRequest(pProxyRequest, pNewRequest, _passport);
	// this is called for TI Requests and Delivery Requests, the latter does not have a TI to update as yet, (a null consignee means no update required)

	if _passport.hasErrors() then
		return;
	endif;
*/	
		
	if pTI &lt;&gt; null and pNewCon &lt;&gt; null then
		app.myUtilityUA.utlUpdateTIConsignee(pTI, pNewCon, _passport);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pProxyJob" type="CM_Job" usage="input"/>
        <Parameter name="pNewJob" type="CM_Job" usage="output"/>
        <Parameter name="pProxyRequest" type="CM_Request" usage="input"/>
        <Parameter name="pNewRequest" type="CM_Request" usage="output"/>
        <Parameter name="pTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="pNewCon" type="CM_ConsigneeConsignor"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
