	actualString  := JadeRegex@replaceAll(actualString , "", InvSeqNumRegex, true);
	actualString  := JadeRegex@replaceAll(actualString , "", InvIdentifierRegex, true);
	
	self.assertTrueMsg(actualString.compareEql(expectedString,true,false,null),"The message sent was not as expected:" &amp; CrLf &amp; "SENT:" &amp; CrLf &amp; actualString &amp; CrLf &amp; "EXPECTED:" &amp; CrLf &amp; expectedString);
