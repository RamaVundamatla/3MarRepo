    <JadeMethod name="doTblDataDBClick" id="ed9a7cce-31c5-4aff-b5ad-cc0aae64d39e">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;
//----------------------------------------------------------------
//	Created:	08 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	summItem	: CMIF_CandHSummaryItem;
begin
	inheritMethod(table);
	
	if (self.canAddEdit()) then
		summItem := table.accessCell(table.row, table.column).itemObject.CMIF_CandHSummaryItem;
	
		if summItem = null then
			return;
		endif;
		 
		if summItem.allSnapShots.isNotEmpty then    //cnwas3 par 21982
		//if summItem.myCMIFTradeLineGeo.myParent.useSnapShots then
			self.showSnapShotForm(summItem);
			return;
		endif;
	endif;

	if app.isAllowedToInspect
	and summItem.allTrackedItems.size &gt; 0 then
		table.accessCell(table.row, table.column).itemObject.inspect;
	endif;

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
