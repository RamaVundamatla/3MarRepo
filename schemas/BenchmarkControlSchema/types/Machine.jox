    <JadeMethod name="buildQueues" id="0df4eb4b-c2a7-4671-a806-7bc516137c9b">
        <source>buildQueues():String;

vars
	multiLevelQueues:StringArray;
	ff : FileFolder;
	newQueues : StringArray;
	f : File;
	s,t,queues : String;
	okToOutput : Boolean;
begin
	okToOutput := true;
	create newQueues transient;
	create ff transient;
	create multiLevelQueues transient;
	if hostName &lt;&gt; "cnwXchcs55" then
		getMultiLevelQueues(multiLevelQueues);  // this is where IIS, SQL, physical etc machines are defined
	endif;

	newQueues.add(hostName);
	newQueues.add("buildjobs");

	//if hostName = "cnwchcs97"  // don't tie up SQL machine
	if hostName = "cnwchcs117"
	or hostName = "cnwchcs119" 
	//or hostName = "cnwchcs121"  // slow performance in StartStopTest transaction "Startup to Init Method"
	or hostName = "cnwchcs124"
	or hostName = "cnwchcs127" 
	or hostName = "cnwchcs148"
	or hostName = "cnwchcs149" then
	//or hostName = "cnwchcs155"
	//or hostName = "cnwchcs157"	then
		newQueues.add("benchmarkclientmachine");
	endif;
	
	foreach s in multiLevelQueues do 
		// 6.3.09 and earlier hotfixes do not run on windows 2k12
		/*if (hostName = "cnwchcs155" or hostName = "cnwchcs157") 
		and (s = "clientmachine" or s = "plantphysical" or s = "plant" or s = "contops") then
			continue;
		endif;/**/
		newQueues.add("urgent" &amp; s);
	endforeach;
	
	if hostName = "cnwchcs25" then
		newQueues.add("nextavailablejmt");
	endif;

	newQueues.add("next" &amp; hostName);
	if hostName = "cnwchcs97" then
	endif;
	
	foreach s in multiLevelQueues do 
		newQueues.add("nextavailable" &amp;  s);
	endforeach;
	
	newQueues.add("lowpriority" &amp; hostNameShort);
	//if hostName = "cnwchcs86"
	if hostName = "cnwchcs123" then
	//or hostName = "cnwchcs126" then
		newQueues.add("lowpriorityvm");
	endif;
	
	foreach s in multiLevelQueues do 
		newQueues.add("lowpriority" &amp; s);
	endforeach;
	
	foreach s in newQueues do 
		ff.fileName := "\\cnwchcs118\jobs\" &amp; s;
		if ff.isAvailable then 
			queues := queues &amp; s &amp; ";";
		else 
			write ff.fileName &amp;" Does not exist";
			okToOutput := false;
		endif;
	endforeach;
	
	if okToOutput then 
		create f transient;
		f.usePresentationFileSystem:=false;
		f.fileName:=app.miscPath&amp;"\QueueLists\"&amp;hostName&amp;".conf";
		s:=f.readString(f.fileLength);
		t:=s.getXMLValue("queuestoprocess");
		if t = queues then
			app.logMessage(hostName&amp;" - no change");
		else
			app.logMessage(hostName&amp;" queue list changed:");
			app.logMessage("was: "&amp;t);
			app.logMessage("now: "&amp;queues);
		endif;
		s:=s.replace(t, queues);
		f.close;
		/**/
		f.mode:=File.Mode_Output;
		f.writeString(s);
		f.close;
		
		beginTransaction;
		queuesToProcess.purge;
		foreach s in newQueues do
			queuesToProcess.add(s);
		endforeach;
		commitTransaction;
		
		f.fileName:=app.miscPath&amp;"\jobs\"&amp;hostName&amp;"\creatorin\SyncCardinalBin.job";
		f.writeLine("SyncCardinalBin,,,,,,,,");
		f.close;
		app.logMessage(process.getUserCode[4:3]&amp;' created file '&amp;f.fileName);
		/**/
	else 
		app.msgBox("New config not written out","???",MsgBox_Yes_No);
	endif;
	return queues;
epilog
	delete newQueues;
	delete f;
	delete ff;
	delete multiLevelQueues;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="checkFolder" id="e7cff76c-50a8-4320-8510-afe1d18d98e3">
        <source>checkFolder(s:String):Boolean;

vars
	ff:FileFolder;
begin
	create ff transient;
	ff.usePresentationFileSystem:=false;
	ff.fileName:=s;
	if ff.isAvailable then
		write s;
		return true;
	endif;
	return false;
epilog
	delete ff;
end;
</source>
        <Parameter name="s" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMultiLevelQueues" id="a1900c29-77d6-49f7-aaa6-a079d0caac4c">
        <source>getMultiLevelQueues(generics:StringArray input);

