    <JadeMethod name="addData" id="06c0ebcb-c1fb-4fe0-9078-f95df24579b6">
        <lockReceiver/>
        <updating/>
        <source>addData( 	_yaCont : CM_LocationsController; 
			_ti : CM_TrackedItem;
			_endOffset : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2013	cnwndl1	Initial creation	Par 32049
13 jan 	2016	cnwer1	PAR 37319 added offset for odd sized containers i.e 45 53 30s
20 Oct 2022		jlier1  TFS 54675 20/10/22 - can autoplan to a trailer location which is not a yard location
*/

vars

	testLoc : CM_YATestLocation;

begin

	create testLoc transient;
	testLoc.myTrackedItem := _ti;
	testLoc.myLocation := _yaCont;  
	testLoc.endOffset:=_endOffset; //epr par 37319 13/1/16
	self.add( testLoc );

epilog

end;</source>
        <Parameter name="_yaCont" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_endOffset" type="Integer"/>
    </JadeMethod>
