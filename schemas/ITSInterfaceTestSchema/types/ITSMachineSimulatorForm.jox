    <JadeMethod name="createXMLDocForNewMessage" id="5de10436-46f3-4223-9a38-0218e791b432">
        <source>createXMLDocForNewMessage(_messageType : String) : JadeXMLDocument protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
	xml				: JadeXMLDocument;
	rootElement,
	element			: JadeXMLElement;
	
begin
	create xml transient;
	xml.outputDeclaration := false;
	xml.indentString := null;
	
	rootElement := xml.addElement(XML_Tag_Message);
	element := rootElement.addElement(XML_Tag_Header);
	element.setElementValue(XML_Tag_MessageType, _messageType);
	
	element.setElementValue(XML_Tag_MachineId, self.myMachine.machineName);
	element.setElementValue(XML_Tag_MessageVersion, "1");
		
	rootElement.addElement(XML_Tag_Body);
		
	return xml;
	
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_messageType" type="String"/>
        <ReturnType type="JadeXMLDocument"/>
    </JadeMethod>
    <JadeMethod name="doCheckForSendACK" id="02048bd7-0732-444a-80e0-48110605b33d">
        <updating/>
        <source>doCheckForSendACK(_xmlMessage : JadeXMLDocument) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
	delay			: Integer;
	originalMessageNo : Integer;
	element			: JadeXMLElement;
	
begin
	element := _xmlMessage.rootElement.getElementByTagName(XML_Tag_Header).getElementByTagName(XML_Tag_MessageNumber);
	if element &lt;&gt; null then
		originalMessageNo := element.text.Integer;
	endif;
	
	self.txtLastMsgNo.text := originalMessageNo.String;
	
	if self.chkAutoACK.value then
		delay := self.txtACKDelay.text.Integer * 1000;
		process.sleep(delay);
	
		self.doSendACK();
	endif;
	
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_xmlMessage" type="JadeXMLDocument"/>
    </JadeMethod>
    <JadeMethod name="doReceiveDeleteQueueEntry" id="81f84cd0-1398-4f37-89ef-f7220a69d4f7">
        <updating/>
        <source>doReceiveDeleteQueueEntry(_message : JadeXMLDocument) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
	header,
	body,
	element			: JadeXMLElement;
	xmlNode			: JadeXMLNode;
	row,
	column,
	queueEntryId	: Integer;
	table			: Table;
	
begin
	header := _message.rootElement.getElementByTagName(XML_Tag_Header);
		
	body := _message.rootElement.getElementByTagName(XML_Tag_Body);
	if body = null then
		self.logMessage("Error: no " &amp; XML_Tag_Body &amp; " found");
		return;
	endif;
	
	// Get the unique Queue Id
	element := body.getElementByTagName(XML_Tag_QueueEntryId);
	if element = null then
		self.logMessage("Error: no " &amp; XML_Tag_QueueEntryId &amp; " found");
		return;
	endif;
	
	table := self.tblQueueEntries;
	
	if element.text = null then
		// Check it is a Delete All
		element := body.getElementByTagName(XML_Tag_CargoId);
		if element &lt;&gt; null and element.text = "ALL" then
			self.clearQueueTable();
		else
			self.logMessage("Error: no " &amp; XML_Tag_QueueEntryId &amp; " found");
		endif;
		return;
	endif;
	
	// Is the Queue Entry in the table?
	queueEntryId := element.text.Integer;
	row := self.findQueueEntryRow(queueEntryId);
	
	if row &lt;&gt; null then
		table.removeItem(row);
		self.refreshValuesFromSelected();
	endif;
	
	
epilog

end;</source>
