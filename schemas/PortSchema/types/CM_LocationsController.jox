    <JadeMethod name="testOverstowMoveLocation" id="d1356c51-0b4e-4bde-b605-0937277c7022">
        <updating/>
        <source>testOverstowMoveLocation(obj : CMIF_AutoMovePlan input) updating;
/* AJA 30/11/99: This is similar to testAutoPlan. We want to know if this location is OK,
but since this is an overstow move, we are not as fussy.
*/
vars
	anId	:	String;
	isIn    : Boolean;
	myYAAutoPlanA : CM_YAAutoplanAgent;
	cmif_AutoNorm : CMIF_YAAutoPlanNormal;
begin

	//Presume this a good LC, cleared later if not
	obj.updateController(self);
	//-------------
	//Start the tests
	//-------------
	anId := self.getFullId;

	obj.addVerboseLogEntry(app.getErrorString1(Testing_availability, anId), IsForLogging, Testing_availability); 
	self.testIsControllerAvailable(obj);
	if obj.getController = null then
		//obj.addLogEntry(anId &amp; " is unavailable.", IsError); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString1(Unavailable ,anId), IsError, Unavailable);
	  	return;
	endif;

	obj.addVerboseLogEntry(app.getErrorString1(Testing_capacity ,anId), IsForLogging, Testing_capacity);
	self.testIsControllerFull(obj);
	if obj.getController = null then
		//obj.addLogEntry(anId &amp; " is unsuitable due to capacity issues.", IsError); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString1(Unsuitable_capacity_issues, anId), IsError, Unsuitable_capacity_issues);
	  	return;
	endif;

	//obj.addVerboseLogEntry(anId &amp; " testing restrictions.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_restrictions_param,anId), IsForLogging,Testing_restrictions_param);
	self.testIsControllerRestricted(obj);
	if obj.getController = null then
		//obj.addLogEntry(anId &amp; " is Restricted in some way (labour/Location).", IsError); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString1(Restricted_some_labourloca, anId), IsError, Restricted_some_labourloca);
	  	return;
	endif;

	//obj.addVerboseLogEntry(anId &amp; " testing Power Requirement.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_power_requiremen, anId), IsForLogging, Testing_power_requiremen);
	self.testIsRequirePower(obj);
	if obj.getController = null then
		//obj.addLogEntry(anId &amp; " has Power problem (as above).", IsWarning); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString1(Power_problem_above, anId), IsWarning, Power_problem_above);
 		return;
	endif;

	//obj.addVerboseLogEntry(anId &amp; " testing Tower Requirement.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_tower_requiremen, anId), IsForLogging, Testing_tower_requiremen);
	self.testIsRequireTower(obj);
	if obj.getController = null then
		//obj.addLogEntry(anId &amp; " has Tower problem (as above).", IsWarning); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString1(Tower_problem_above, anId), IsWarning, Tower_problem_above);
 		return;
 	endif;
 	
 	//obj.addVerboseLogEntry(anId &amp; " testing Overstow Planned/Queued status.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_oversto_planned_status, anId), IsForLogging, Testing_oversto_planned_status);
	self.testOverstowPlannedOrQueued(obj);
	if obj.getController = null then
		obj.addLogEntry(app.getErrorString1(Over_stow_planne_proble_above ,anId), IsWarning, Over_stow_planne_proble_above);
 		return;
 	endif;
	
	//cnwjo3 par 19883
 	//obj.addVerboseLogEntry(anId &amp; " testing Hazardous Segragation Rules.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_hazardo_segraga_rules, anId), IsForLogging, Testing_hazardo_segraga_rules);
	
	self.testIsHazardSegRulesMet(obj);
	if obj.getController = null then
		//obj.addLogEntry(anId &amp; " has Over stow Haz Seg Rules problem (as above).", IsWarning); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString1(Over_stow_rules_proble_above, anId) , IsWarning, Over_stow_rules_proble_above);
 		return;
 	endif;
	
	
	//cnwjo3 NFS, from par 19883.  Not implemented at this time
	//   ************************************  //
	//           Currently commented out       //
	//   ************************************  //
	
	/*
	if obj.myTrackedItem.isHazardous then
		if self.isKindOf(CM_GridController) then  //if it falls under these types!
			obj.addVerboseLogEntry(anId &amp; " testing Hazardous TI if meets YA.", IsForLogging);

			
			if self.CM_GridController.allYardAllocations.size &lt; 1 then
				obj.addLogEntry(anId &amp; " Nope.  Its not a YA or something", IsWarning);
				obj.updateController(null); 
				return;
			else
				myYAAutoPlanA := app.myYAAgent;
				
				//for some reason YAAgent can be null.   not sure what to do apart from fail it
				if myYAAutoPlanA = null then
					app.initialiseForStartAutoPlan(app.myPassport);
					myYAAutoPlanA := app.myYAAgent;
				endif;
				
				if myYAAutoPlanA = null then
					app.msgBox("You fail big time","Major fail",0);
				endif;
				
				
				create cmif_AutoNorm transient;
				myYAAutoPlanA.setCurrentYAAutoPlan(cmif_AutoNorm);
				//myYAAutoPlanA.myCurrentAllocation := self.CM_GridController.allYardAllocations.first();
				myYAAutoPlanA.setPropertyValue("myCurrentAllocation",self.CM_GridController.allYardAllocations.first());
				cmif_AutoNorm.attachTI(obj.myTrackedItem);

				isIn := true;  //i think i need to set this to true.  not sure what it means
			
				if not self.CM_GridController.testLocationYA(myYAAutoPlanA, isIn) then
					obj.addLogEntry(anId &amp; " Nope.  Its not a YA or something", IsWarning);
					obj.updateController(null);  //i think that should work, ideally it should be in testLocationYA
					return;
				endif;
				

				//myYAAutoPlanA.allPassedLocations.inspect;
				
			endif;
		endif;
	endif;*/
epilog
	delete cmif_AutoNorm;
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
