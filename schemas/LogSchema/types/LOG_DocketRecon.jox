    <JadeMethod name="cmbOperators2_lostFocus" id="877d20e1-a625-496d-bd22-1960df8cd939">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOperators2_lostFocus(combobox: ComboBox input) updating;
// -----------------------------------------------------------------------------
// Created:		05 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	code : String;
begin
	if combobox.listIndex &lt;&gt; -1 then
		code := combobox.itemObject[combobox.listIndex].CM_Operator.code;
		tblTicketEntry.setValueByName(ETRow_Supplier, code);
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
