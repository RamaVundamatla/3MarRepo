    <JadeMethod name="doDataComparison" id="fa412429-5cf6-4bf2-9214-d8d0bfc93f20">
        <source>doDataComparison(_yaData: SelfType): Boolean;
// -------------------------------------------
// Created 14 March 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	//23 Mar 2015	NDL	Par 35886
	if _yaData.value = self.VALUE_EITHER then
		return true;
	endif;
	
	return (self.value = _yaData.value);


end;</source>
        <Parameter name="_yaData" type="SelfType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDataComparisonWithResolution" id="5fd6b0ff-71a8-44e0-82d1-b1ff5de22ef0">
