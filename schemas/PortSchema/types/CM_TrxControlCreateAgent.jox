    <JadeMethod name="trxCreateEDIDataOutwardRail" id="3d44a0c3-0d05-4ac4-959b-e57cd068facc">
        <updating/>
        <source>trxCreateEDIDataOutwardRail(pEDIDataOR : CM_EDIDataOutwardRail io; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: December 2001 By: cnwgd1
//--------------------------------------------------------------
vars
begin
	// Always initialize the activity first
	//fd shift consingor-consignee maintainance code from vb to jade
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	create pEDIDataOR persistent;
	//Update obejct
	pEDIDataOR.setForCreate();
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pEDIDataOR" type="CM_EDIDataOutwardRail" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDIDeckPlan" id="acd777a4-ff4d-4ed0-b905-8bb851b51e33">
        <updating/>
        <source>trxCreateEDIDeckPlan(_validateOnly : Boolean; _ediData : CM_EDIDataDeckPlan input; _cmifDeckPlan : CMIF_EDIDeckPlan input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     25 October 2011 ANDREW BISHOP
// Purpose:     CCMS 1150 RORO Ship manifest  
// 					We will run through the file items several times.
//					The EDI items are basically deck items (locations mainly) and their  polygons and cargo. 
//					The cargo has a location ID. This matches the deck item's code.
//					Some of the locations will already exist, others will not, so we run through the items and create all the new locations and their polygon.
//					Then we run through all the cargo and we should have a location for all the cargo to be moved to.
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23 Jan 2012	cnwrs1		Par 29024 leaking in unit test
// 16 Feb 2012	cnwrs1		Par 29131 fail with unused OTL layouts
// 21 Feb 2012	cnwrs1		Par 29157 error is rotation location is invalid
// 28 Feb 2012	cnwrs1		Par 29186 - add deck item code to the error message
// 29 Feb 2012	cnwrs1		Par 29205 - setup status after a crash
// 09 Mar 2012	cnwrs1		Par 29246 - EDI RORO Deck Plan Extract not including rotation
// 13 Mar 2012	cnwrs1		Par 29216 - EDI RORO Deck Plan can get duplicate on aft endof 40'
// 11 Apr 2012	cnwrs1		Par 29396 - sort Ship Cargo by messgaenum
// 24 Apr 2012	cnwrs1		Par 29476 - When a Voyage is not defined "Will Be Planned" and "Will Be Planned" the RORO Deck Plan nor the RORO Stowage Advice will fail verification.
// 24 Apr 2012	cnwab1		PAR 29489 - switch the primary for a 40 footer
// 27 Apr 2012	cnwrs1		par 29502
// 24 May 2012	cnwcs5		par 29583 - refactor code into val/utl methods
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
// ---------------------------------------------------------------------------
vars
	status : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	// this will probably be reset later but we can but try
	app.setContinueCMExceptions (true);
	
	app.myValCA.valEDIDeckPlan (_ediData, _passport);
	
	if _passport.noErrors then
		// Start the transaction
		beginTransaction;
		
		_passport.useTIDictDeferUpdate 			:= true;
		_passport.useTITransactionDeferUpdate 	:= true;
	
		app.myUtilityCA.utlCreateEDIDeckPlan (_validateOnly, _ediData, _cmifDeckPlan, _passport);
	endif;
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_ediData" type="CM_EDIDataDeckPlan" usage="input"/>
        <Parameter name="_cmifDeckPlan" type="CMIF_EDIDeckPlan" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDIDeckStowageAdvice" id="0dacde4e-a9d8-42e4-b590-63499b01f4ff">
        <updating/>
        <source>trxCreateEDIDeckStowageAdvice(_validateOnly : Boolean; _ediData : CM_EDIDataDeckStowageAdvice input;  _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     25 October 2011 ANDREW BISHOP
// Purpose:     CCMS 1150 RORO Ship manifest  
// 					We will run through the file items several times.
//					The EDI items are basically deck items (locations mainly) and their  polygons and then colour coding. 
//					The Colour coding has a location ID. This matches the deck item's code.
//					Some of the locations will already exist, others will not, so we run through the items and create all the new locations and their polygon.
//					Then we run through all the colour coding and we should have a location for all the colour coding to be created for.
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30 Mar 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
// 11 Apr 2012	cnwab1		Par 29396 - Mixed 20/40 stack
// 24 Apr 2012	cnwrs1		Par 29476 - When a Voyage is not defined "Will Be Planned" and "Will Be Planned" the RORO Deck Plan nor the RORO Stowage Advice will fail verification.
// 27 Apr 2012	cnwrs1		par 29502
// 11 Jul 2012	cnwrs1		Par 29988 EDI When loading a Deck Plan file with OOTLs needa unique name
// 23 Jul 2012	cnwcs5		CCMS MES 2168 / par 29124
// 09 Aug 2012	cnwcs5		CCMS MES 2168 / par 29124 - moved code into val/utl methods so exception handling will work
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
// ---------------------------------------------------------------------------
vars
	status 			: Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;

	app.myValCA.valEDIDeckStowageAdvice (_validateOnly, _ediData, _passport);
		
	if _passport.noErrors then
		// Start the transaction
		beginTransaction;
		
		_passport.useTIDictDeferUpdate 			:= true;
		_passport.useTITransactionDeferUpdate 	:= true;
			
		app.myUtilityCA.utlCreateEDIDeckStowageAdvice (_validateOnly, _ediData, _passport);	
	endif;
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_ediData" type="CM_EDIDataDeckStowageAdvice" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDIDiskFile" id="c3c514a6-361b-4326-b591-42358d2303b6">
        <updating/>
        <source>trxCreateEDIDiskFile(_ediFile: CM_EDIFile io; _messageNumber: Integer; _ediDataDetails: CMIF_EDIDataDetails; _passport: CM_Passport input)updating;
//----------------------------------------------------------------
//	Created:	25 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	on FileException do app.fileExceptionWriteError(exception, _passport);	//03 Dec 2019	NDL	TFS 47781

	app.setContinueCMExceptions(false);
	
	// Start the transaction
	beginTransaction;
	
	app.myUtilityCA.utlCreateEDIDiskFile(_ediFile, _messageNumber, _ediDataDetails, _passport);
	
	if _passport.noErrors then
		app.myUtilityUA.utlSetEDIDataStatus(_ediFile.ediData, CM_EDIFile.EDI_STATUS_EXTRACTED, _passport);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_messageNumber" type="Integer"/>
        <Parameter name="_ediDataDetails" type="CMIF_EDIDataDetails"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDIFile" id="55973344-741d-458f-b696-0ee2d47312f9">
        <updating/>
        <source>trxCreateEDIFile(
	_realEdiFile	: CM_EDIFile io;
	_ediFileType	: CM_EDIFileType;
	_fileName		: String;
	_fileCreatedTs	: TimeStamp;
	_ediData		: CM_EDIData input;
	_status			: Integer;
	_ediConfig		: CM_EDIConfig;
	_passport		: CM_Passport input;
	_ediClientRef	: String;					// cnwrl1 12/08/2009 PAR 20318 - MES 1011 Web EDI Link
	_messageType	: String;					// cnwrl1 25/09/2009 PAR 20320 - MES 1011 New Messina Messages
	_message		: Binary ) updating;		// cnwrl1 12/08/2009 PAR 20318 - MES 1011 Web EDI Link

// cnwdvb1 29 January 2003 
// 19 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage3
// 25 Mar 2019	jlgzm1	TFS 42276 transformMessage running twice per message
vars
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
//	app.myUtilityCA.utlCreateEdiFile(_realEdiFile, _ediFileType, _fileName, _fileCreatedTs, _status, _ediConfig, _passport);	// cnwrl1 10/08/2009 PAR 20318 - MES 1011 Web EDI Link - what it was
	app.myUtilityCA.utlCreateEDIFile(	_realEdiFile,
										_ediFileType,
										_fileName,
										_fileCreatedTs,
										_status,
										_ediConfig,
										_passport,
										_ediClientRef,
										_messageType,
										_message,
										null, //tfs42276
										false);
	
	if _ediData &lt;&gt; null and
	   _realEdiFile &lt;&gt; null and
	   _passport.noErrors() then
		app.myUtilityUA.utlUpdateEDIData(_ediData, _realEdiFile, _passport);
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_ediFileType" type="CM_EDIFileType"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_fileCreatedTs" type="TimeStamp"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_ediClientRef" type="String"/>
        <Parameter name="_messageType" type="String"/>
        <Parameter name="_message" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDIFileData" id="75a5aa9e-b62e-432d-a2ce-a9dfd0cb0ce4">
        <updating/>
        <source>trxCreateEDIFileData(
	_realEdiFile	: CM_EDIFile io;
	_ediFileType	: CM_EDIFileType;
	_realEdiData	: CM_EDIData io;
	 _ediDataClass	: Class;
	 _ediDataType 	: Integer;
	_fileName		: String;
	_fileCreatedTs	: TimeStamp;
	_status			: Integer;
	_ediConfig		: CM_EDIConfig input;
	_passport		: CM_Passport input;
	_ediClientRef	: String;					// cnwrl1 12/08/2009 PAR 20318 - MES 1011 Web EDI Link
	_messageType	: String;					// cnwrl1 25/09/2009 PAR 20320 - MES 1011 New Messina Messages
	_message		: Binary;					// cnwrl1 12/08/2009 PAR 20318 - MES 1011 Web EDI Link
	_transformedMsg: String;					// tfs42276
	_synchronous 	 : Boolean; 	
	_incomingMessage : String) updating;		

/* Changes

Purpose: this createsa an EDI File and an EDI data.

Date		Name	TFS#		Description
============================================================================
04 Feb 2015	cnwrs1	Par 		EDI Refactor for fileload 
19 Sep 2018	jlgrs1	TFS 40627 	STWR Make EDI MultiThreaded Stage 3
25 Mar 2019	jlgzm1	TFS 42276 	transformMessage running twice per message
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateEDIFile(	_realEdiFile,
										_ediFileType,
										_fileName,
										_fileCreatedTs,
										_status,
										_ediConfig,
										_passport,
										_ediClientRef,
										_messageType,
										_message,
										_transformedMsg,
										true);
	
	if _realEdiFile &lt;&gt; null and _passport.noErrors() then
		//jlgka1 TFS 45332 --&gt;
		if _incomingMessage &lt;&gt; null then
			_realEdiFile.requestTimestamp := _passport.myTerminal.systemToLocalTime(app.actualTimeServer );
			_realEdiFile.setWebReqString(_incomingMessage);			//navra1 - TFS 54078 - 21st July 2023
			if _synchronous then
				_realEdiFile.mode := _realEdiFile.EDI_Mode_Synchronous;
			else
				_realEdiFile.mode := _realEdiFile.EDI_Mode_Asynchronous;
			endif;
		endif;
		//jlgka1 TFS 45332 &lt;--
		app.myUtilityCA.utlCreateEDIData(_realEdiData, _ediDataClass, _ediDataType, _ediFileType.type, _ediConfig, _realEdiFile, _ediFileType, _passport); // cnwrs1 Par 24207 ccms 1117 11 May 2010
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_ediFileType" type="CM_EDIFileType"/>
        <Parameter name="_realEdiData" type="CM_EDIData" usage="io"/>
        <Parameter name="_ediDataClass" type="Class"/>
        <Parameter name="_ediDataType" type="Integer"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_fileCreatedTs" type="TimeStamp"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_ediClientRef" type="String"/>
        <Parameter name="_messageType" type="String"/>
        <Parameter name="_message" type="Binary"/>
        <Parameter name="_transformedMsg" type="String"/>
        <Parameter name="_synchronous" type="Boolean"/>
        <Parameter name="_incomingMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDIFileDataSyncWeb" id="37e4f412-e8e9-485c-a8fc-68cafb8d56b7">
        <updating/>
        <source>trxCreateEDIFileDataSyncWeb(
	_realEdiFile	: CM_EDIFile io;
	_ediFileType	: CM_EDIFileType io;
	_realEdiData	: CM_EDIData io;
	_ediDataClass	: Class io;
	_ediDataType 	: Integer;
	_fileName		: String io;
	_fileCreatedTs	: TimeStamp;
	_status			: Integer;
	_ediConfig		: CM_EDIConfig input;
	_passport		: CM_Passport input;
	_ediClientRef	: String;
	_messageType	: String;
	_message		: Binary;
	_fileExt 		: String input;
	_agent 			: CM_EDIControllerAgent input;
	_synchronous 	: Boolean; 
	_incomingMessage : String) : Boolean updating;

/*
Date		Name	TFS#		Description
============================================================================
25 Oct 2018	jlgrs1	TFS 40627 	STWR Make EDI MultiThreaded Stage 6
28 Nov 2018	jlgrs1	TFS 42276 	STWR Make EDI MultiThreaded Stage 7
18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
29 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 9
22 Feb 2019 jlgdi1  TFS 43367 	Used _ediClientRef as the file name if the _fileName is null 
								which is same process when the request is queue or synchronous set to false.
08 Apr 2019	jlgrs1	TFS 41913 	STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading
25 Mar 2019	jlgzm1	TFS 42276 	transformMessage running twice per message
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
08 May 2020 jlgmd1	TFS 49214	STWR Better handle deadlocks in MOB HH apps (eg, Pack Container)
17 Jun 2020 jlgmd1	TFS 49599	STWR Refactored and added comments to make code paths clearer
21 Jul 2020 jlgmd1	TFS 49690	STWR - Fix dumps not being taken due to the 'retry + 1 final time' logic was incorrect for everything except the LoadDB section
10/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt
*/

constants
	//MAX_ERROR_COUNT : Integer = 5;	// TFS 49214 use app.myPassport.silentDeadlockLimit instead
vars
	realEdiData : CM_EDIData;
	ediFileType : CM_EDIFileType;
	myCurrentEDIFileFormat : CM_FileFormatEDI;
	myFileFormatOperator : CM_Operator;
	terminal : CM_Terminal;
	fileName : String; 
	ediDataType	: Integer;
	tmpStr : String;
	fileType : String;
	fileTypeCode : Integer;
	version : String;
	fileData : String;
	association : String;
	result : Boolean;
	invalidEdiFile : Boolean;
	error : CM_Error;
	lockError : Boolean;
	errorCountCreateEDIData : Integer;
	errorCountProcessFile : Integer;
	errorCountVerify : Integer;
	errorCountDBLoad : Integer;
	ediUserDefinedAssist  : CMIF_EDIUserDefinedAssist;
	transformedMsg : String; 		//tfs42276
	trxStartTimestamp : TimeStamp; // ### TFS 52639 18Mar2022 NAVPW1
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	//We need to keep a local copy of the trx start Timestamp for this trx as it calls other trx's lower down and this gets overridden
	//It helps to avoid a case whereby there are Lockkeeper transactions that are not finalized with an end timestamp
	trxStartTimestamp := app.serverTimestampAtTrxStart; 	// ### TFS 52639 18Mar2022 NAVPW1
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	on Exception do app.handleDeletedObject(exception, _realEdiFile, invalidEdiFile);
	
	app.setContinueCMExceptions(false);
	create ediUserDefinedAssist transient;

	// Make sure the message type is valid
	terminal := _agent.myTerminal;
	if _messageType.trimBlanks = null then
		_agent.setEDIStatusCode(CM_EDIFile.EDI_WEB_STATUS_INVALIDFILETYPE.display);		// ie -2
		_agent.setEdiStatusDesc(app.getString(Valid_MsgType_Must_Be_Supplied));
		app.writeLog(method.qualifiedName &amp; ' Error: Message type supplied is null for Terminal ' &amp; terminal.code, LogERROR);
		return false;
	endif;
	if _messageType.trimBlanks.toUpper &lt;&gt; System_EDIFileType then
		
		// Check for a matching User Defined EDI file type
		_ediFileType := app.myRoot.findEDIFileType( _messageType.trimBlanks.toUpper );
		
		// Otherwise, look up a 'special' type
		if _ediFileType = null then
			_agent.findEDIFileType(_messageType.trimBlanks, version, association, _ediFileType, ediDataType);				//05.Jun.2023 navsp1 TFS 58054
		endif;
		
		if _ediFileType = null then
			_agent.setEDIStatusCode(CM_EDIFile.EDI_WEB_STATUS_INVALIDFILETYPE.display);		// ie -2
			_agent.setEdiStatusDesc(app.getString(MsgType_Supplied_Is_Invalid, _messageType.trimBlanks.toUpper));
			app.writeLog(method.qualifiedName &amp; ' Error: Message type supplied (' &amp; _messageType &amp; ') is invalid for Terminal ' &amp; terminal.code, LogERROR);
			return false;
		endif;
	endif;
	
	
	lockError := true;
	while lockError do
		// Reset loop
		app.myPassport.clearErrorsWarnings();
		lockError := false;
		invalidEdiFile := false;
		
// ######## 1. Create the EDIData ########
		// First time round the loop ? or did processing fail ? then (re)create the EDI File Data
		if realEdiData = null then
			//fileData := _message.String;
			fileData := _message.ansiToString; // ### TFS 54082 04Aug2022 NAVPW1
			
			// Have a go guessing the fileType
			if _ediFileType = null then
				//Check UN/EDIFACT stuff first so binary files can be checked here before user defined csv's
				_agent.getFileTypeFromString(fileData, _fileName, _fileExt, fileType, version, association, transformedMsg); //tfs42276
				result := _agent.findEDIFileType(fileType, version, association, _ediFileType, ediDataType);
				if not result then
					_ediFileType := null;
					_agent.setEDIStatusCode(CM_EDIFile.EDI_WEB_STATUS_INVALIDFILETYPE.display);		// ie -2
					_agent.setEdiStatusDesc(app.getString(MsgType_Supplied_Is_Invalid, _messageType.trimBlanks.toUpper));
					app.writeLog(method.qualifiedName &amp; ' Error: Message type supplied (' &amp; _messageType &amp; ') is invalid for Terminal ' &amp; terminal.code, LogERROR);
					return false;
				endif;
				if _ediFileType = null or 
				   (_ediFileType.type = EDIFileType_CSV or _ediFileType.type = EDIFileType_XML) then
					_agent.findEDIFileTypeUserDefined(_ediFileType, fileData);	//try and find a user defined format
				endif;
				if _ediFileType = null then
					_agent.setEDIStatusCode(CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display());		// ie -1
					_agent.setEdiStatusDesc(app.getString(Input_required_field_ediFleCls));
					app.writeLog(method.qualifiedName &amp; ' Error: Unable to determine EDI file type for Terminal ' &amp; terminal.code, LogERROR);
					return false;
				endif;
			endif;
			
			// Is the terminal licensed for the file type being processed
			if (not app.myRoot.canDoEDIFileType(_ediFileType.type)) then
				_agent.setEDIStatusCode(CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display());		// ie -1
				_agent.setEdiStatusDesc(app.getString(NotLicensedToPerformAction));
				app.writeLog(method.qualifiedName &amp; ' Error: Unlicensed for that file type ' &amp; _ediFileType.type.String &amp; ' For Terminal ' &amp; terminal.code, LogERROR);
				return false;
			endif;
		
			// Specific file types can't be processed
			if _ediFileType.isKindOf(CM_EDIFileTypeBaplie10) or 
				_ediFileType.isKindOf(CM_EDIFileTypeBaplie14) then
				_agent.setEDIStatusCode(CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display());		// ie -1
				_agent.setEdiStatusDesc(app.getString(Unsupor_baplie_file_version));
				app.writeLog(method.qualifiedName &amp; ' Error: Unsupported Baplie version ' &amp; _ediFileType.type.String &amp; ' for Terminal ' &amp; terminal.code, LogERROR);
				return false;
			endif;
			
			// Get/Set the EDI Data Type
			if _agent.myCurrentEDIFileFormat &lt;&gt; null then
				_agent.myCurrentEDIFileFormat.findEDIDataType(_ediDataClass, ediDataType); // cnwrs1 Par 24207 ccms 1117 11 May 2010
			else
				if ediDataType &lt;&gt; null then
					_ediDataClass := terminal.myEdiConfig.getEDIDataClassForType(ediDataType);
					fileTypeCode := _ediFileType.type;
				else
					if fileType = "COPARN" and 
					   association = "COPARNVGM" then
						_ediDataClass := CM_EDIDataVGM;
						ediDataType := EDIDataType_VGM;
						fileTypeCode := _ediFileType.type;
					else
						_ediFileType.findEDIDataType(_ediDataClass, ediDataType, fileTypeCode); // cnwrs1 Par 24207 ccms 1117 11 May 2010
					endif; 
				endif;
			endif;
			
			if _ediDataClass = null then
				_agent.setEDIStatusCode(CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display());		// ie -1
				_agent.setEdiStatusDesc(app.getString(Input_required_field_ediDtaCls));
				app.writeLog(method.qualifiedName &amp; ' Error Finding EDIData Class ' &amp; _ediFileType.type.String &amp; ' for Terminal ' &amp; terminal.code, LogERROR);
				return false;
			endif;
			
			// 28 Nov 2018	jlgrs1	TFS 42276 STWR Make EDI MultiThreaded Stage 7
			// Always try and set a useful filename, or at least some unique id
			if _fileName = null then
				if _ediClientRef &lt;&gt; null then 
					_fileName := _ediClientRef;
				else 
					_fileName := fileType&amp;version&amp;_fileCreatedTs.formatAsYYYYMMDDHHMMSSMMM.trimBlankCharacters;
				endif;
			endif;
			
			// Start the transaction
			beginTransaction;
			app.myUtilityCA.utlCreateEDIFile(	_realEdiFile,
												_ediFileType,
												_fileName,
												_fileCreatedTs,
												_status,
												_ediConfig,
												_passport,
												_ediClientRef,
												_messageType,
												_message,
												transformedMsg, //tfs42276
												true);
			
			if _realEdiFile &lt;&gt; null and _passport.noErrors() then			   
				//jlgka1 TFS 45332 --&gt;
				// Keep track of useful information for the EDI Web Service Viewer
				if _incomingMessage &lt;&gt; null then
					_realEdiFile.requestTimestamp := terminal.systemToLocalTime(app.actualTimeServer);								
					_realEdiFile.setWebReqString(_incomingMessage);		//navra1 - TFS 54078 - 21st July 2023
					if _synchronous then
						_realEdiFile.mode := _realEdiFile.EDI_Mode_Synchronous;
					else
						_realEdiFile.mode := _realEdiFile.EDI_Mode_Asynchronous;
					endif;
				endif;
				//jlgka1 TFS 45332 &lt;--
				
				app.myUtilityCA.utlCreateEDIData(_realEdiData, _ediDataClass, _ediDataType, _ediFileType.type, _ediConfig, _realEdiFile, _ediFileType, _passport); // cnwrs1 Par 24207 ccms 1117 11 May 2010
			endif;
			if _realEdiFile &lt;&gt; null then
				realEdiData := _realEdiFile.ediData;
			endif;
			
			// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
			// If we hit a lock error then increment our count and try again
			lockError := false;
			if _passport.hasErrors then
				foreach error in _passport.allErrors do
					if error.errorCode = 1027 or
					   error.errorCode = 1081 then
						lockError := true;
						errorCountCreateEDIData := errorCountCreateEDIData + 1;
						app.writeLog(method.qualifiedName &amp; " **** LOCK (1) ERROR DETECTED IN WEB EDI - retrying (" &amp; errorCountCreateEDIData.String &amp;")" , LogWARN);
					endif;
				endforeach;
			endif;
			
			if lockError and
			   errorCountCreateEDIData &lt;= app.myPassport.silentDeadlockLimit then
				process.sleep(app.myPassport.silentDeadlockSleepTime);
				continue;
			else
				// Some other error happened, so bail
				if invalidEdiFile or _passport.hasErrors then
					_agent.setEDIStatusCode(CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display);		// ie -1
					_agent.setEdiStatusDesc(app.getString(Failed_ToLoad_JMT_Database));		
					app.writeLog(method.qualifiedName &amp; ' Error Creating EDIData for type  ' &amp; _ediFileType.name &amp; '. For Terminal ' &amp; terminal.code, LogERROR);
					return false;
				endif;
			endif;
			
		endif;		// readEdiData = null
		errorCountCreateEDIData := 0;	// if we had this lock error we are now past it
		
		// Make sure we are the only ones dealing with our EDI data
		if self.tryLock(realEdiData, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
			
			
// ######## 2. Process the EDIData ########
			// If we haven't yet verified or loaded this file, then 'process' it
			if errorCountVerify = 0 and errorCountDBLoad = 0 then
			
				ediFileType := _realEdiFile.myEDIFileType;
				
				// Make sure we are the only ones deading with this File, as well as data
				if self.tryLock(_realEdiFile, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
					
					if _agent.myCurrentEDIFileFormat &lt;&gt; null then
					   myCurrentEDIFileFormat := _agent.myCurrentEDIFileFormat;
						myCurrentEDIFileFormat.processFileData(_realEdiFile, myFileFormatOperator, _passport);
					else
						ediFileType.processFileData(_realEdiFile, _passport);
						
						if _realEdiFile.ediData.allEDITrackedItems.size &gt; 0 then
							// Lock the terminals EDI Config, effectivly preventing anyone else from processing any more EDI files for the time beeing
							// This gets released when we commit just before verify starts
							if not tryLock(_realEdiFile.ediData.ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
								self.exclusiveLock(_realEdiFile.ediData.ediConfig);
							endif;
							// Lock out anyone that already has a reference to our TI collection
							if not tryLock(_realEdiFile.ediData.ediConfig.allEDITrackedItemsByIdStatus, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
								self.exclusiveLock(_realEdiFile.ediData.ediConfig.allEDITrackedItemsByIdStatus);
							endif;
							
							// Add all our tracked items to the EDI Config
							_realEdiFile.ediData.addEDIConfigToEDITis(ediUserDefinedAssist);
						endif;
						
					endif;
				endif;
				
				// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
				// If we hit a lock error then increment our count and try again
				lockError := false;
				if _passport.hasErrors then
					foreach error in _passport.allErrors do
						if error.errorCode = 1027 or
						   error.errorCode = 1081 then
							lockError := true;
							errorCountProcessFile := errorCountProcessFile + 1;
							app.writeLog(method.qualifiedName &amp; " **** LOCK (2) ERROR DETECTED IN WEB EDI - retrying (" &amp; errorCountProcessFile.String &amp;")" , LogWARN);
						endif;
					endforeach;
				endif;
				
				if lockError and
				   errorCountProcessFile &lt;= app.myPassport.silentDeadlockLimit then
					if realEdiData &lt;&gt; null then
						if self.isLockedByMe(realEdiData) then
							self.unlock(realEdiData);
						endif;
					endif;
					if _realEdiFile &lt;&gt; null then
						if self.isLockedByMe(_realEdiFile) then
							self.unlock(_realEdiFile);
						endif;
					endif;
					
					realEdiData := null;
					_realEdiFile := null;
					
					continue;
				else
					if _passport.hasErrors then
						// Too many errors, can't continue
						_agent.setEDIStatusCode(CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display());		// ie -1
						_agent.setEdiStatusDesc(app.getString(Failed_ToProcess_EDIFile));
						return false;
					else
						_realEdiFile.setFileStatus(CM_EDIFile.EDI_STATUS_LOADED);
					endif;
				endif;
			endif;
			errorCountProcessFile := 0;	// if we had this lock error we are now past it
			
			
// ######## 3. Verify the EDIData ########
			// If we haven't yet loaded this file/data, then 'verify' it (if we need to)
			if not errorCountDBLoad &lt;&gt; 0 and
			   realEdiData.isVerifyBeforeDBLoad then
				
				if (realEdiData.status = CM_EDIFile.EDI_STATUS_LOADED or
				   realEdiData.status = CM_EDIFile.EDI_STATUS_LOCKERROR or
				   realEdiData.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or 
				   realEdiData.status = CM_EDIFile.EDI_STATUS_VERIFYING) then
					
					fileName := realEdiData.myEDIFile.fileName; // ccms1117 cnwrs1 29 Apr 2010
					// Can we actually verify this data ? (Superuser can allways do this)
					if app.isSpecial() or 
					   realEdiData.canBeVerified then
						
						tmpStr := realEdiData.class.name&amp;' '&amp;method.qualifiedName;
						app.writeLog(tmpStr&amp;' '&amp;realEdiData.getVoyageCode&amp;' '&amp;realEdiData.fileName, LogINFO);	//25 Nov 2019	NDL	TFS 47053
						
						// If we've got this far, then commit our ediFile/Data objects
						if process.isInTransactionState then
							app.cmsCommitTransaction(_passport);
						endif;
						
						// Do the needful
						realEdiData.verifyAll();
						
						// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
						// If we hit a lock error then increment our count and try again
						lockError := false;
						if _passport.hasErrors then
							foreach error in _passport.allErrors do
								if error.errorCode = 1027 or
								   error.errorCode = 1081 then
									lockError := true;
									errorCountVerify := errorCountVerify + 1;
									app.writeLog(method.qualifiedName &amp; " **** LOCK (3) ERROR DETECTED IN WEB EDI - retrying (" &amp; errorCountVerify.String &amp;")" , LogWARN);
								endif;
							endforeach;
						endif;
						
						if lockError and
						   errorCountVerify &lt;= app.myPassport.silentDeadlockLimit then
							process.sleep(app.myPassport.silentDeadlockSleepTime);
							continue;
						else
							if realEdiData.status = CM_EDIFile.EDI_STATUS_VERIFIED or
								realEdiData.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS or 
								realEdiData.status = CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X then //epr tfs 2292
							else
								// Too many errors, can't continue
								_agent.setEDIStatusCode(CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display());		// ie -1
								_agent.setEdiStatusDesc(app.getString(EDIData_Failed_To_Verify));
								app.writeLog(method.qualifiedName &amp; ' Error Verifying Data ' &amp; realEdiData.displayName &amp; ' For Terminal ' &amp; terminal.code, LogERROR);
								return false;
							endif;
						endif;
					endif;		// ediData.canBeVerified
					
					ediDataType := realEdiData.getEDIDataType;
					
					if _passport.hasErrors then
						// Some other error happened, so bail
						_agent.setEDIStatusCode(CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display());		// ie -1
						_agent.setEdiStatusDesc(app.getString(EDIData_Failed_To_Verify));
						app.writeLog(method.qualifiedName &amp; ' Error Verifying Data ' &amp; realEdiData.displayName &amp; ' For Terminal ' &amp; terminal.code, LogERROR);
						return false;
					endif;
				endif;
			endif;
			errorCountVerify := 0;	// if we had this lock error we are now past it
			
			
// ######## 4. LoadDB the EDIData ########
			// Make sure we can be loaded
			if realEdiData.canBeDBLoaded then
			
				// Relock our data if we commited everything just before verify and for some reason don't have the lock any more
				if not self.isLockedByMe(realEdiData) then
					if not self.tryLock(realEdiData, Share_Lock, Transaction_Duration, LockTimeout_Immediate) then
						_agent.setEDIStatusCode(CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display);		// ie -1
						_agent.setEdiStatusDesc(app.getString(Failed_ToLoad_JMT_Database));
						app.writeLog(method.qualifiedName &amp; ' Error Locking DEDIata ' &amp; realEdiData.displayName &amp; ' For Terminal ' &amp; terminal.code, LogERROR);
						return false;
					endif;
				endif;
				
				// This ignores warnings.
				_passport.setIsBackgroundWarningsIgnored(true);
				
				// Are we still sure we can be loaded (really?)
				if realEdiData.canBeDBLoaded then
					_passport.clearErrorsWarnings();	// par 30210 August 2012
		
					tmpStr := method.qualifiedName;
					app.writeLog(tmpStr&amp;' '&amp;realEdiData.getVoyageCode&amp;' '&amp;realEdiData.fileName, LogINFO);	//25 Nov 2019	NDL	TFS 47053
					
					// (If) We skipped verification, so if we've got this far, then commit our ediFile/Data objects
					if process.isInTransactionState then
						app.cmsCommitTransaction(_passport);
					endif;
					
					// Do the needful
					realEdiData.loadDB(false, _passport);
					
					// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
					// If we hit a lock error then increment our count and try again
					lockError := false;
					if _passport.hasErrors then
						foreach error in _passport.allErrors do
							if error.errorCode = 1027 or
							   error.errorCode = 1081 then
								lockError := true;
								errorCountDBLoad := errorCountDBLoad + 1;
								app.myPassport.silentDeadlockRetryCount := errorCountDBLoad;
								app.writeLog(method.qualifiedName &amp; " **** LOCK (4) ERROR DETECTED IN WEB EDI - retrying (" &amp; errorCountDBLoad.String &amp;")" , LogWARN);
							endif;
						endforeach;
					endif;
					if lockError and
					   errorCountDBLoad &lt;= app.myPassport.silentDeadlockLimit then	// Have one final go at it if the limit has been reached, so any stacks are dumped
						process.sleep(app.myPassport.silentDeadlockSleepTime);
						continue;
					else
						if _passport.hasErrors then
							// Too many errors, can't continue
							_agent.setEDIStatusCode(CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display);		// ie -1
							_agent.setEdiStatusDesc(app.getString(Failed_ToLoad_JMT_Database));
							app.writeLog(method.qualifiedName &amp; ' Error DBLoading Data ' &amp; realEdiData.displayName &amp; ' For Terminal ' &amp; terminal.code, LogERROR);
							return false;
						endif;
					endif;
					errorCountDBLoad := 0;	// if we had this lock error we are now past it
					
				endif;	// canBeLoaded
			endif;	// canBeLoaded
		else
			// Unable to get an exclusive lock on our EDI data, so give up and try again later
			_agent.setEDIStatusCode(CM_EDIFile.EDI_WEB_STATUS_CREATION_ERROR.display);		// ie -1
			_agent.setEdiStatusDesc(app.getString(Failed_ToLoad_JMT_Database));		
			app.writeLog(method.qualifiedName &amp; ' Error Locking EDIData ' &amp; realEdiData.displayName &amp; ' For Terminal ' &amp; terminal.code, LogERROR);
			return false;
		endif;
		
		// lockError should be false if we get this far, and the loop should end
	endwhile;
	
	// All ok
	return true;
epilog
	//We need to use our local local copy of the trx start Timestamp for this trx
	//This means our Lockkeeper transaction for this trx is finalized with an end timestamp when finaliseActivityWithPassport is called
	app.setServerTimestampAtTrxStart(trxStartTimestamp);	// ### TFS 52639 18Mar2022 NAVPW1

	self.finaliseActivityWithPassport(_passport);
	
	// If something goes wrong with commit/aborting then make sure we unlock things
	if realEdiData &lt;&gt; null then
		if self.isLockedByMe(realEdiData) then
			self.unlock(realEdiData);
		endif;
	endif;
	if _realEdiFile &lt;&gt; null then
		if self.isLockedByMe(_realEdiFile) then
			self.unlock(_realEdiFile);
		endif;
	endif;
	
	app.myPassport.resetSilentDeadlockHandler;	//10/3/25 navsaa30 #14818
	
	delete ediUserDefinedAssist;
end;</source>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_ediFileType" type="CM_EDIFileType" usage="io"/>
        <Parameter name="_realEdiData" type="CM_EDIData" usage="io"/>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_ediDataType" type="Integer"/>
