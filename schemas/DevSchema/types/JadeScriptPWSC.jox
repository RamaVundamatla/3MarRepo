    <JadeMethod name="pwSourceCompareReportType" id="a68866d5-d12d-4a9c-816f-8fd21ff7a181">
        <source>pwSourceCompareReportType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2022	navpw1	Initial creation TFS: 52791

*/

vars
	report : DEV_SourceCompareReport;
	
begin
	beginTransaction;

	foreach report in DEV_SourceCompareReport.instances do
		report.setPropertyValue(DEV_SourceCompareReport::reportType.name, 1);
	endforeach;

	commitTransaction;

end;</source>
    </JadeMethod>
