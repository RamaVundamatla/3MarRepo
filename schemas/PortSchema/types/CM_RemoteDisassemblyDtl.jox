    <JadeMethod name="doGetDisassemblyLogs" id="dcc5d3f0-5857-4504-9978-3bbd6ecbaefb">
        <source>doGetDisassemblyLogs(_myTerminal : CM_Terminal; _allNewLogs : CMIF_LogRegradeArray input) : Boolean;

// cnwdvb1 22 November 2002 

vars

	newLog 				: CMIF_LogRegrade;
	theNewArea			: CM_TerminalArea;
	theNewLocation		: CM_LocationsController;
begin
	
	theNewArea := _myTerminal.allTerminalAreas[self.newArea];
	if theNewArea = null then
		app.raiseCMException1(BackgroundErrorGeneral, self.newId &amp; " - " &amp; app.getErrorString(Input_Required_For_TA), null, null);
		return false;
	endif;
	theNewLocation := theNewArea.getLocationsControllerFromId(self.newLcn);

	if theNewLocation = null then
		app.raiseCMException1(BackgroundErrorGeneral, self.newId &amp; " - " &amp; app.getErrorString(Input_Required_For_Location), null, null);
		return false;
	endif;
	create newLog transient;
	newLog.isDissasembly := true;		//related to PAR 9826
	newLog.id 			:= self.newId;
	newLog.gradeCode	:= self.newGrade;
	newLog.myLocation	:= theNewLocation;
	newLog.length		:= self.newLength;
	newLog.sedMax		:= self.newSedMax;
	newLog.sedMin		:= self.newSedMin;
	newLog.treatment	:= self.newTreatment;
	newLog.type			:= self.newType;
	newLog.weight		:= self.weight;
	_allNewLogs.add(newLog);
	return true;
end;</source>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
        <Parameter name="_allNewLogs" type="CMIF_LogRegradeArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="107c34c6-2521-4bb9-a208-22854b9b0dc4">
        <source>getDescription(): String;

// cnwdvb1 25 November 2002 

vars

begin
	return 'Disassembly Detail';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="6c85cea9-d188-44d6-82c9-a7e21cc9c7e1">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns : Integer) updating;

// cnwdvb1 25 November 2002 

vars

begin

	self.newArea			:= _table.accessCell(2,_entryTableColumns).text.trimBlanks;
	self.newLcn				:= _table.accessCell(3,_entryTableColumns).text.trimBlanks;
	self.newId				:= _table.accessCell(4,_entryTableColumns).text.trimBlanks;
/*	self.newGrade			:= _table.accessCell(5,5).text.trimBlanks;
	self.newType			:= _table.accessCell(6,5).text.trimBlanks;
	self.newTreatment		:= _table.accessCell(7,5).text.trimBlanks;
	self.newLength			:= _table.accessCell(8,5).text.trimBlanks;
	self.newSedMax			:= _table.accessCell(9,5).text.Decimal;
	self.newSedMin			:= _table.accessCell(10,5).text.Decimal;
	self.weight				:= _table.accessCell(11,5).text.Integer;*/
	
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8716e8ad-c692-4b8b-ba63-a5363be45567">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteDisassemblyDtl; _realRemoteHdr: CM_RemoteDataHdr) updating;

// cnwdvb1 22 November 2002 

vars

begin

	inheritMethod(_proxy, _realRemoteHdr);
	self.newGrade		:= _proxy.newGrade;
	self.newId			:= _proxy.newId;
	self.newLcn			:= _proxy.newLcn;
	self.newArea		:= _proxy.newArea;
	self.newLength		:= _proxy.newLength;
	self.newSedMax		:= _proxy.newSedMax;
	self.newSedMin		:= _proxy.newSedMin;
	self.newTreatment	:= _proxy.newTreatment;
	self.newType		:= _proxy.newType;
	self.weight			:= _proxy.weight;

end;</source>
        <Parameter name="_proxy" type="CM_RemoteDisassemblyDtl"/>
        <Parameter name="_realRemoteHdr" type="CM_RemoteDataHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxyForDisassembly" id="aab62ba1-6e0a-4a59-9f9a-b7dbac9f9f65">
        <updating/>
        <source>setProxyForDisassembly(	_remoteHdr 			: CM_RemoteDataHdr;
						_newId,
						_newLength,
						_newLcn,
						_newArea,
						_newGrade,
						_newTreatment,
						_newType			: String;
						_newSedMax,
						_newSedMin			: Decimal;
						_weight				: Decimal) updating;

// cnwdvb1 22 November 2002 

vars

begin

	self.newId			:= _newId;
	self.newLcn			:= _newLcn[1:30];
	self.newLength		:= _newLength;
	self.newArea		:= _newArea;
	self.newSedMax		:= _newSedMax;
	self.newSedMin		:= _newSedMin;
	self.newTreatment	:= _newTreatment;	// PAR 21218 24/10/2010
	self.newGrade		:= _newGrade;
	self.newType		:= _newType;
	self.weight			:= _weight;
	self.setProxy(_remoteHdr);
	
		
end;</source>
        <Parameter name="_remoteHdr" type="CM_RemoteDataHdr"/>
        <Parameter name="_newId" type="String"/>
        <Parameter name="_newLength" type="String"/>
        <Parameter name="_newLcn" type="String"/>
        <Parameter name="_newArea" type="String"/>
        <Parameter name="_newGrade" type="String"/>
        <Parameter name="_newTreatment" type="String"/>
        <Parameter name="_newType" type="String"/>
        <Parameter name="_newSedMax" type="Decimal"/>
        <Parameter name="_newSedMin" type="Decimal"/>
        <Parameter name="_weight" type="Decimal"/>
    </JadeMethod>
</Class>
