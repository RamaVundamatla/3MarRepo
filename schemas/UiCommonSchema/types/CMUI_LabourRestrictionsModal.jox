    <JadeMethod name="doBaseFormSave" id="a0ac3d25-a90b-4fa8-80e4-89f356bfda5d">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	realLabRestrict,
	pxyLabRestrict		: CM_LabourRestriction;
	intHours			: Time;
	intDays,
	colour 				: Integer;
	reason				: CM_LabourRestrictionReasonCode;
	comment,
	userCode,
	orgname				: String;
	termArea			: CM_TerminalArea;
	obArray				: ObjectArray;
	termSubArea			: CM_TerminalSubArea;
	allTermSubArea		: CM_TerminalSubAreaDict;
	//email				: CM_EmailEntity;
	yardControllersArray,
	completeArray			: CM_LCArray;
	locController		: CM_LocationsController;
	user				: CM_User;
	labRestID			: String;
	ignoreLights		: Boolean;		// cnwdad1 03/06/2010 - CCMS 1947.
	organisation		: CM_Organisation;
	ob					: Object;
	allTermSubAreas 	: CM_ObjectArray;
	allSelected			: Boolean;
	tmpSort				: CM_GridControllersByRowColumn;
	result				: Integer;
	emails : CM_EmailAddressByAddressDict;
	
begin
	obArray			:=	self.lstBxSubArea.allSelectedObjects;
	intDays			:=	self.txtDays.text.Integer;
	intHours		:=	self.txtHrs.getTime();
	comment			:=	self.txtComment.text;
	reason			:=	self.cmbReason.myObject.CM_LabourRestrictionReasonCode;
	organisation	:=	self.cmbOrganisation.myObject.CM_Organisation;
	//email			:=	self.cmbNotify.myObject.CM_EmailEntity;
	userCode		:=	app.myPassport.myUser.code;
	ignoreLights	:=	false;
	
	if organisation &lt;&gt; null then 
		orgname	:= ' - ' &amp; organisation.name;
	endif;
	// create from termsubaArea	

	create yardControllersArray transient;
	create completeArray transient;
	create pxyLabRestrict transient;
	create allTermSubAreas transient;
	create tmpSort transient;// ### PAR 11363
	create emails transient;

	termArea := self.myTerminalArea;
	
	foreach ob in obArray do // for each termsub area selected 
		if ob = null then // all is checked 
			allSelected := true;
			break;
		endif;
		
		allTermSubAreas.add(ob);	
	endforeach;
	
	//08 Jul 2015	NDL	Par 36588
	self.mulNotifyEmails.getSelected(emails);
	
	if allSelected then 
		allTermSubAreas.clear();
		
	//	labRestID := 'All' &amp; orgname;
		labRestID := termArea.id &amp; orgname;	//27 Aug 2014	NDL	Par 34734
		colour := Red; // any colour would do?
		
// cnwdad1 03/06/2010 - CCMS 1947.
		if self.isIgnoreLightsUsed then
			ignoreLights	:=	chkIgnoreLights.value;
		endif;
		
		// ### PAR 11363
		if termArea.isKindOf(CM_GridArea) then
			termArea.allLocationsControllers.copy(tmpSort);
			tmpSort.copy(yardControllersArray);
		else
			termArea.allLocationsControllers.copy(yardControllersArray);
		endif;
		
		yardControllersArray.copy(completeArray);
		pxyLabRestrict.setProxy(colour,
								userCode,
								comment,
								intHours,
								intDays,
								reason,
								yardControllersArray,
								labRestID,
								ignoreLights,
								organisation,
								null,
								emails,
								termArea);					
	endif;
	
	//----------------------------------------------------------------------------
	//			allSelected - one Labour Restriction on whole yard area
	//----------------------------------------------------------------------------
	if allSelected then 
		while true do
			app.myTrxCA.trxCreateRestrictionLabour(pxyLabRestrict, realLabRestrict, app.myPassport);		
			
			if app.myPassport.trxCompletedOK() then
				self.clearErrorWarnings();
				self.unloadForm();
				break;
			else
				result := app.showErrorWarningDialog("Labour Restrictions", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors() and result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				
				if allTermSubAreas.size() &gt; 1 then 
					app.msgBox(	'Not all Labour Restrictions were successfully created. Labour Restrictions that returned errors will need to be created again.',
								'Labour Restriction',
								MsgBox_Information_Icon + MsgBox_OK_Only);
				endif;	
				
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			
			break;
		endwhile;
	else
	//----------------------------------------------------------------------------
	//					Labour Restrictions for each Sub Area 
	//----------------------------------------------------------------------------
		
		foreach ob in allTermSubAreas do // for each termsub area selected 
			termSubArea := ob.CM_TerminalSubArea;
			yardControllersArray.clear();
			tmpSort.clear();
			
			labRestID := termSubArea.id &amp; orgname;
			colour := termSubArea.colour;
			
// cnwdad1 03/06/2010 - CCMS 1947.
			if self.isIgnoreLightsUsed then
				ignoreLights	:=	chkIgnoreLights.value;
			endif;
			
			// ### PAR 11363
//			termSubArea.allYardControllers.copy(yardControllersArray);
			termSubArea.allYardControllers.copy(tmpSort);
			tmpSort.copy(yardControllersArray);
			yardControllersArray.copy(completeArray);
			
			pxyLabRestrict.setProxy(colour,
									userCode,
									comment,
									intHours,
									intDays,
									reason,
									yardControllersArray,
									labRestID,
									ignoreLights,
									organisation,
									null,
									emails,
									termArea);
			
			while true do
				app.myTrxCA.trxCreateRestrictionLabour(pxyLabRestrict, realLabRestrict, app.myPassport);
				
				if app.myPassport.trxCompletedOK() then
					self.clearErrorWarnings();
					break;
				else
					result := app.showErrorWarningDialog("Labour Restrictions - "&amp; labRestID, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors() and result = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					
					self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
					return;
				endif;
				
				break;
			endwhile;
		endforeach;
		
		self.unloadForm();
	endif;
	
	app.checkLabourRestrictionHook(termArea, completeArray); // PAR 21639 cnwgb1 28.4.2010
epilog
	delete pxyLabRestrict;
	delete yardControllersArray;
	delete completeArray;
	delete allTermSubAreas;
	delete tmpSort;
	delete emails;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="17bd882b-5e60-4ebc-b313-abf3041c1107">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2022	navkc1	Initial creation #53919 - Fix controls not reacting to having captions showing or not.

*/

vars

begin
	inheritMethod();
	self.frmMain.top := self.frmToolbar.height; //#53919, navkc1
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFormForSubArea" id="23ea3690-1ced-4208-a1db-337b49958dfd">
        <source>setFormForSubArea();
// ---------------------------------------------------------------------------
// Created:     01 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tmpTermArea : CM_TerminalArea;
	tmpTermSubArea : CM_TerminalSubArea;
	index : Integer;
	bool : Boolean;
	all : String;
begin
	tmpTermArea 	:= self.myTerminalArea;
//	tmpTermSubArea := self.myTerminalSubArea;

	self.lstBxSubArea.clear();
	self.lstBxSubArea.addItemObject('All',null);	
	
	foreach tmpTermSubArea in tmpTermArea.allSubAreas do 
		self.lstBxSubArea.addItemObject(tmpTermSubArea.id,tmpTermSubArea);
	endforeach;	 
	
	if self.myTerminalSubArea &lt;&gt; null then 
		self.lstBxSubArea.addSelectedObject(self.myTerminalSubArea);
	else
		self.lstBxSubArea.setSelectedString('All');
		self.lstBxSubArea.allSelectedObjects.add(null); // add this to be able to check against later
	endif;	
	
	self.cmbOrganisation.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="setTeminalArea" id="d6aaa407-213a-4f69-bcb4-9c894616a27d">
        <updating/>
        <source>setTeminalArea(_ta : CM_TerminalSubArea; _termArea : CM_TerminalArea) updating;
// ---------------------------------------------------------------------------
// Created:     01 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
begin
	self.myTerminalSubArea := _ta;
	
	if _ta &lt;&gt; null then
		self.myTerminalArea := _ta.myTerminalArea;
	else // when setting labour restriction over whole termArea the sub area is passed in as null
		self.myTerminalArea := _termArea;
	endif;
	
	if self.myTerminalArea &lt;&gt; null then
		self.caption := 'Labour Restriction for Terminal Area ' &amp; self.myTerminalArea.id;
		self.isIgnoreLightsUsed	:=	self.myTerminalArea.isOtagoStraddleAreaAorC();	// cnwdad1 03/06/2010 - CCMS 1947.
	endif;
end;</source>
        <Parameter name="_ta" type="CM_TerminalSubArea"/>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b534ef59-714e-40c2-8f25-9332f9bade25">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     01 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
begin
	self.toolbarStyle				:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar				:=	true;
	self.btnOk.visible				:=	false; 	
	self.btnCancel.visible			:=	false;
	self.chkIgnoreLights.visible	:=	self.isIgnoreLightsUsed;		// cnwdad1 03/06/2010 - CCMS 1947.
	
	inheritMethod();
	
//	self.move(self.left, self.top, 350, 400);
	//08 Jul 2015	NDL	Par 36588
	self.move(self.left, self.top, 400, 600);
	
	self.mulNotifyEmails.multiSelect := ListBox.MultiSelect_Simple;
	self.mulNotifyEmails.formDisplayEntryMethodName := CMUI_LabourRestrictionsModal::displayEmailAddress.name;
	self.mulNotifyEmails.availableHeading := app.getErrorString(Available_email_addresses);
	self.mulNotifyEmails.selectedHeading :=  app.getErrorString(Selected_email_addresses);
	self.mulNotifyEmails.caption := app.getErrorString(Notify_adddeleteexpiry);
	self.mulNotifyEmails.myBaseForm	:= self;
	self.mulNotifyEmails.mySelectedListBox.sorted := true;
	self.mulNotifyEmails.cnEcResizeContents();

	
//	self.mulNotifyEmails.setAvailable(app.myRoot.allEmailAddressesByAddress, true);
	self.mulNotifyEmails.setAvailable( null, true );	//	31 Dec 2018	NDL	TFS 42699 - Bish says don't show any addresses until org selected.
	
	self.doResize;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnOk.enabled:= false;
	endif;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4e42d67a-a8ef-4aee-a6e2-1118e5595c3c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007780, locale);
	cMUI_Label3.translateCaption(Xlat_0000508, locale);
	cMUI_Label4.translateCaption(Xlat_0000507, locale);
	cMUI_Label4_1.translateCaption(Xlat_0000506, locale);
	cMUI_Label4_2.translateCaption(Xlat_0000503, locale);
	cMUI_Label4_2_1.translateCaption(Xlat_0000502, locale);
	cMUI_Label4_2__1.translateCaption(Xlat_0000501, locale);
	cMUI_Label4_3.translateCaption(Xlat_0000505, locale);
	cMUI_Label4_4.translateCaption(Xlat_0000504, locale);
	chkIgnoreLights.translateCaption(Xlat_0014993, locale);
	lblHeader.translateCaption(Xlat_0000509, locale);
end;</source>
    </JadeMethod>
</GUIClass>
