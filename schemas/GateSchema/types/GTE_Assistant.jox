    <JadeMethod name="addPreNoteFromCargoReceiptForm" id="544d38e4-e56d-4268-9ee5-683e69f9386e">
        <updating/>
        <source>addPreNoteFromCargoReceiptForm(_parentForm : CM_BaseForm input; _trackedItem: CM_TrackedItem) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2009	cnwdap1	Initial creation
*/
vars

begin
	inheritMethod(_parentForm, _trackedItem);		// so references at the superschema level finds this implementation
	
	if _parentForm  = null then
		return;
	endif;
	
	if _parentForm.isKindOf(GTE_PreNoteForm) then	
		_parentForm.GTE_PreNoteForm.addPreNote(_trackedItem);
	endif;

epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm" usage="input"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="checkRoadQueue" id="21b7b03b-b974-4d27-b8ab-74fa5ab05304">
        <updating/>
        <source>checkRoadQueue(_isIn : Boolean; _terminal : CM_Terminal) updating;

vars

	errorForm			: CMUI_BGPErrorForm;
	result,pointer		: Integer;

begin

	if (not self.myTerminal.getConfig(GateInAutoCompleteBkgrnd).Boolean) then
		return;
	endif;

	pointer := app.mousePointer;
	if self.isHideBGPErrorForm then
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_Default;	
	if _terminal.myRoadJobSheet.checkRoadQueue(_isIn) then
		create errorForm transient;
		errorForm.centreWindow();
		result := errorForm.showModal();
		if result = 1 then
			self.isHideBGPErrorForm := true;
		endif;
	endif;
epilog
	app.mousePointer := pointer;
end;</source>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="clearAttachmentLines" id="e1f2d964-2a84-4942-8fa8-4710efec3fbe">
        <source>clearAttachmentLines(pTbl : CM_EntryTable input);

vars
	tmpRow	: Integer;
	
begin

	tmpRow := pTbl.getRow('addAttachment');
