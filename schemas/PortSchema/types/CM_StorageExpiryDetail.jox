    <JadeMethod name="getName" id="fd6570a3-624c-4fad-accc-2cbccb476f5a">
        <source>getName() : String;
/*
Purpose - 	
Who - NAVAB1
Date - 30JAN2024
ADO -  CR 58263 TASK 58264
*/

vars
	returnStr	: String;
	term 		: CM_Terminal;
	ti 			: CM_TrackedItem;
	invalid 	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, term, invalid);	
	on Exception do app.handleDeletedObject(exception, ti, invalid);	
	
	returnStr	:= inheritMethod();
	
	returnStr	:= returnStr &amp; Tab &amp; Tab &amp; self.operatorCode &amp; Tab &amp; self.freeStorageExpiry.date.String; 
	
	if self.myTrackedItem &lt;&gt; null then
		ti := self.myTrackedItem;
		returnStr	:= returnStr &amp; Tab &amp; ti.id;
	endif;
	
	return returnStr;
	
epilog
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
