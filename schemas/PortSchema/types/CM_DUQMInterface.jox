<Class name="CM_DUQMInterface" id="4e64f0ec-5938-416e-8d36-c09eada2240a">
    <superclass name="CM_ExtFinanceIO"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>#######################
Port of Duqm's EXTERNAL FINANCIAL SYSTEM
#######################</text>
    <DbClassMap file="invoice"/>
    <JadeMethod name="createInvoiceXML" id="e044d445-7b4c-41df-b461-790a26bde43c">
        <source>createInvoiceXML(file : File input; _invoice : CM_Invoice) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		Returns true if any order lines were produced

Date		Who		Reason
01 November 2017	cnwma1  TFS #7562 DQM - IFS Financial Interface
01/05/2018	jlgmd1	TFS #37904 DQM - Prevent Posting/Exporting and export of 'Void' lines and 'No invoice line' Invoices

*/

vars

	invLine : CM_InvoiceLine;
	charge: CM_Charge;
	chargeStr : String;
	vslTypeStr : String;
	hmsVslTypeCode,hmsVslTypeDesc : String;
	hmsVslType   : HMS_VesselType;
	userCode	 : String;
	purchaseOrderCode,
	termCode,
	debtorName,
	decfinName	: String;
	hasOrderLines : Boolean;
	reversedInv : Boolean;	//	23 May 2018	NDL	TFS 38716
begin

	userCode := app.getMyUserCode;
	
	if _invoice.myTerminal &lt;&gt; null then
		termCode := _invoice.myTerminal.code;
	endif;
	
	if _invoice.debtor &lt;&gt; null then
		purchaseOrderCode := _invoice.debtor.purchaseOrderCode;
		debtorName        := _invoice.debtor.name;
		decfinName		  := _invoice.debtor.decfinName;
	endif;
	
	if _invoice.myVoyage &lt;&gt; null then
		hmsVslTypeCode := _invoice.myVoyage.getVesselTypeObjStr;
		if hmsVslTypeCode &lt;&gt; null then
			hmsVslType := app.myRoot.allVesselTypes[hmsVslTypeCode];
			if hmsVslType &lt;&gt; null then
				hmsVslTypeDesc := hmsVslType.description;
			endif;
		endif;
	endif;
	
	file.writeLine('&lt;?xml version="1.0"?&gt;');
	//////////////////
	/////Header//////
	////////////////
	file.writeLine("&lt;CUSTORDER&gt;");
	file.writeLine(self.formatAsXML("termsOfTrade", 			_invoice.termsOfTrade.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("termsOfTradeCode", 		_invoice.termsOfTradeCode.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("postedDT", 				_invoice.postedDT.Date.format("dd/MM/yyyy").String.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("usercode", 				userCode.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("purchaseOrderNumber",		_invoice.purchaseOrderNumber.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("purchaseOrderCode",		purchaseOrderCode.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("myTerminalCode", 			termCode.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("sequenceNum", 				_invoice.sequenceNum.String.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("description", 				_invoice.getInvoiceType.description.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("debtorName", 				debtorName.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("decfinName", 				decfinName.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("fromDT", 					_invoice.fromDT.Date.format("dd/MM/yyyy").String.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("toDT", 					_invoice.toDT.Date.format("dd/MM/yyyy").String.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("voyageCode",				_invoice.voyageCode.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("vesselName", 				_invoice.vesselName.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("vesselTypeObject", 		hmsVslTypeDesc.xmlReplaceReservedChars(true)));
	file.writeLine(self.formatAsXML("status", 				   _invoice.status.String.xmlReplaceReservedChars(true)));

	//////////////////
	/////Details/////
	////////////////
	file.writeLine("&lt;ORDER_LINES&gt;");
	//foreach invLine in _invoice.invoiceLines do	
//	foreach invLine in _invoice.invoiceLines where not invLine.voided do	// TFS 37904 jlgmd1 10/04/2018
	
	reversedInv := _invoice.isReverseCredit;
	foreach invLine in _invoice.invoiceLines do	//	23 May 2018	NDL	TFS 38716 - Needs to export the credit during reversal if selected (and they will be voided.)
		if invLine.voided then
			if not reversedInv then
				continue;
			endif;
		endif;
		
		hasOrderLines := true;		// TFS 37904 jlgmd1 01/05/2018
		
		foreach charge in invLine.charges do
			file.writeLine("&lt;ORDER_LINE&gt;");
				self.exportChargesAsXML( file,charge );
			file.writeLine("&lt;/ORDER_LINE&gt;");

		endforeach;	
	endforeach;
	file.writeLine("&lt;/ORDER_LINES&gt;");
	file.writeLine("&lt;/CUSTORDER&gt;");

	return hasOrderLines;	// TFS 37904 jlgmd1 01/05/2018
epilog

end;</source>
        <Parameter name="file" type="File" usage="input"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="export" id="050e3f0e-f3aa-4e36-a3a7-60fa9edefac5">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>export(invoice: CM_Invoice input) updating, serverExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
31 October 2017		jlgma1  TFS #7562 DQM - IFS Financial Interface
21 February 2018 	jlgmd1	TFS #36911 DQM - FInancial Interface
01 May 2018			jlgmd1	TFS #37904 DQM - Prevent Posting/Exporting and export of 'Void' lines and 'No invoice line' Invoices
22 July 2019	    cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
*/
constants
	FixedPrefix : String = "CUSTOMER_ORDER_CREATE_";
vars
	file 		 : File;
	path 	     : String; 
	exportDir 	 : String; 
	fFolder		 : FileFolder;
	runDate 	 : Date;
	baseFileName : String;
	fileName 	 : String;
	message  	 : String;
begin
	path := self.exportPath.normaliseDirectory().substituteDirectory();
	exportDir := path;
	
	create fFolder;
	fFolder.fileName := path;

	if not app.isJMTUnitTest then	
		fFolder.usePresentationFileSystem := false;
	endif;
	
	if not fFolder.isAvailable() then
		if not process.isInTransactionState then
			message := app.getErrorString2(Expor_path_does_not_exist_cann,path,invoice.sequenceNum.String);
			app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		else
			app.raiseCMException3(Error_statu_chang_invoi_not_al, invoice.sequenceNum.String, path,invoice.sequenceNum.String,null, null);		
			return;
		endif;
	endif;

	baseFileName := FixedPrefix &amp; invoice.sequenceNum.String.padLeadingZeros(8) &amp;".xml";
	
	fileName := exportDir  &amp; baseFileName;
	
	create file;
	file.fileName := fileName;
	file.mode := File.Mode_Output;
	file.allowReplace := true;
	
	if not app.isJMTUnitTest then	
		file.usePresentationFileSystem := false;
	endif;
	
	// TFS 37904 jlgmd1	01/05/2018
	if not self.createInvoiceXML(file,invoice) then
		file.purge();
		file.close();
		app.msgBox(app.getErrorString(Inv_xml_not_created),app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	file.close;
	
	invoice.incrementExportCount(true);		//22.07.2019 cnwma1 TFS #45577
	
epilog
	delete file; 
	delete fFolder;
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportChargesAsXML" id="12507cd3-b9a1-4a62-80c1-4a75d4633135">
        <source>exportChargesAsXML(_file: File; _charge : CM_Charge);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2017	jlgma1  TFS #7562 DQM - IFS Financial Interface

*/


vars

	allProperties : PropertyColl;
	property : Property;
	ti : CM_TrackedItem;
	imexStatus,
	operatorCode,
	billOfLading,
	bookingReference,
	operatorDescription,	
	directDelivery,		
	consignee,
	consigneeDesc,
	shippingReference,
	cargoType,
	cargoTypeDescr ,
	subCargoTypeCode,
	subCargoTypeDesc,
	commodityCode,	
	commodityDesc,
	cargoId,
	totalQuantity,
	totalWeight,
	totalVolume,
	hazList,
 	hazListDisc,
	dwellDays,
	isOverDimensions,
	isHazardous	,
	weightUom,
	volumeUom,
	qtyUom,
	hmsResCode,
	hmsResDesc,
	hmsResFrom,
	hmsResTo,
	hmsResUnits,
	hmsResUOM,
	todoCode,
	todoDesc		: String;
	isImport		: Boolean;
	charge : 		CM_Charge;
begin
			
	charge :=_charge;
	
	_file.writeString(charge.formatAsXML("taxRate", 	 charge.getTaxRateForCharge().String.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("taxCode", 	 charge.getTaxCode(false).String.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("sequenceNum", charge.invoiceLine.sequenceNum.String.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("narration",   charge.invoiceLine.invoiceLineDesc.narration.String.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("quantity",    charge.invoiceLine.quantity.String.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("salesUom",    charge.invoiceLine.invoiceLineDesc.unitNarration.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("rate", 		 charge.getRate.String.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("name",        charge.service.name.String.xmlReplaceReservedChars(true)));
	
	ti := charge.getTI();
	if ti&lt;&gt; null then
		imexStatus 			:= ti.getImExStatusString;
		billOfLading 		:= ti.billOfLading;
		bookingReference 	:= ti.bookingReference;
		isImport			:= ti.isImport;
		directDelivery 		:= ti.directDelivery.String;
		consignee 			:= ti.consignee;
		shippingReference 	:= ti.shippingReference;
		consigneeDesc 		:= ti.getConsigneeDesc;
		operatorCode 		:= ti.operatorCode;
		operatorDescription := ti.operatorDescription;
		cargoType 			:= ti.cargoType.String;
		cargoTypeDescr 		:= ti.cargoTypeDescr;
		subCargoTypeCode 	:= ti.getCargoSubTypeCode;
		if ti.myProduct &lt;&gt; null then
			subCargoTypeDesc 	:= ti.myProduct.description;
		endif;
		commodityCode 		:= ti.commodity;
		commodityDesc 		:= ti.getCommodityDesc;
		cargoId       		:= ti.id;
		totalQuantity  		:= ti.totalQuantity.String;
		totalWeight    		:= ti.totalWeight.String;
		totalVolume    		:= ti.totalVolume.String;
		isHazardous			:= ti.isHazardous.String;
		hazList				:= ti.getHazardsAsString;
		hazListDisc			:= ti.getHazardsDescAsString;
		isOverDimensions    := ti.isOverDimensions.String;
		dwellDays			:= ti.getDwellDays.String;
		qtyUom				:= "qty";
		if ti.myTerminal &lt;&gt; null then
			weightUom:= ti.myTerminal.getDefaultMeasurementForType(Type_Weight).shortName;
			volumeUom := ti.myTerminal.getDefaultMeasurementForType(Type_Volume).shortName;
		else
			weightUom :="kg";
			volumeUom :="m3";
		endif;
	endif;
	
	
	_file.writeString(charge.formatAsXML("imexStatus",      imexStatus.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("operator",        operatorCode.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("operatorName",    operatorDescription.xmlReplaceReservedChars(true)));
	
	if isImport then
		_file.writeString(charge.formatAsXML("bolBook",      billOfLading.xmlReplaceReservedChars(true)));
	else
		_file.writeString(charge.formatAsXML("bolBook", 	   bookingReference.xmlReplaceReservedChars(true)));
	endif;
	
	_file.writeString(charge.formatAsXML("directDelivery",   directDelivery.String.xmlReplaceReservedChars(true)));
	
	if consignee  &lt;&gt; null then 
		_file.writeString(charge.formatAsXML("conShipCode",  consignee.xmlReplaceReservedChars(true)));
	else
		_file.writeString(charge.formatAsXML("conShipCode",  shippingReference.xmlReplaceReservedChars(true)));
	endif;
	
	if consignee &lt;&gt; null then
		_file.writeString(charge.formatAsXML("conShipDesc",  consigneeDesc.xmlReplaceReservedChars(true)));
	else
		_file.writeString(charge.formatAsXML("conShipDesc",  shippingReference.xmlReplaceReservedChars(true)));
	endif;
	
	_file.writeString(charge.formatAsXML("cargoTypeCode",    cargoType.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("cargoTypeDesc",    cargoTypeDescr .xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("subCargoTypeCode", subCargoTypeCode.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("subCargoTypeDesc", subCargoTypeDesc.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("commodityCode",    commodityCode.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("commodityDesc",    commodityDesc.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("cargoId", 		   cargoId.xmlReplaceReservedChars(true)));
	
	_file.writeString(charge.formatAsXML("totalQuantity",	   totalQuantity.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("totalQuantityUOM", qtyUom.xmlReplaceReservedChars(true)));
	
	_file.writeString(charge.formatAsXML("totalWeight", 	   totalWeight.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("totalWeightUOM",   weightUom.xmlReplaceReservedChars(true)));

	_file.writeString(charge.formatAsXML("totalVolume", 	   totalVolume.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("totalVolumeUOM",   volumeUom.xmlReplaceReservedChars(true)));

	
	_file.writeString(charge.formatAsXML("isHazardous", 	   isHazardous.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("hazList", 		   hazList.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("hazListDesc",	   hazListDisc.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("isOverDimensions", isOverDimensions.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("dwellDays", 	   dwellDays.xmlReplaceReservedChars(true)));
	
	///ToDo Task
	if charge.invoiceLine &lt;&gt; null 
	and charge.invoiceLine.myTransactionTI &lt;&gt; null 
	and charge.invoiceLine.myTransactionTI.getMyToDoTaskCode &lt;&gt; null then
		todoCode := charge.invoiceLine.myTransactionTI.getMyToDoTaskCode.String;
		todoDesc := charge.invoiceLine.myTransactionTI.getMyToDoTaskDescription;
	endif;
	_file.writeString(charge.formatAsXML("todoCode",         todoCode.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("todoDesc",         todoDesc.xmlReplaceReservedChars(true)));
	
	///ToD Task Resources
	if charge.invoiceLine &lt;&gt; null 
	and charge.invoiceLine.myTransactionHMS &lt;&gt; null 
	and charge.invoiceLine.myTransactionHMS.myResourceUsed &lt;&gt; null then
	
		hmsResCode := charge.invoiceLine.myTransactionHMS.myResourceUsed.code;
		hmsResDesc := charge.invoiceLine.myTransactionHMS.myResourceUsed.description;
		hmsResFrom := charge.invoiceLine.myTransactionHMS.myResourceUsed.getFromDateTimeLocalTZ.Date.format("dd/MM/yyyy").String;
		hmsResTo   := charge.invoiceLine.myTransactionHMS.myResourceUsed.getToDateTimeLocalTZ.Date.format("dd/MM/yyyy").String;
		hmsResUnits:= charge.invoiceLine.myTransactionHMS.myResourceUsed.unitsUsed.String;
		hmsResUOM  := charge.invoiceLine.myTransactionHMS.myResourceUsed.myResourceType.quantityUnits;
	endif;
	_file.writeString(charge.formatAsXML("hmsResCode", 	   hmsResCode.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("hmsResDesc",       hmsResDesc.xmlReplaceReservedChars(true)));

	_file.writeString(charge.formatAsXML("hmsResFrom",       hmsResFrom.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("hmsResTo",         hmsResTo.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("hmsResUnits",      hmsResUnits.xmlReplaceReservedChars(true)));
	_file.writeString(charge.formatAsXML("hmsResUOM",        hmsResUOM.xmlReplaceReservedChars(true)));
	
	
epilog

end;
</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_charge" type="CM_Charge"/>
    </JadeMethod>
    <JadeMethod name="exportToFile" id="d8007f22-3a73-4492-85d9-daff7f71210a">
        <source>exportToFile(invoice: CM_Invoice input; fileNameBase: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2017	jlgma1	  TFS #7562 DQM - IFS Financial Interface
01/05/2018	jlgmd1	TFS #37904 DQM - Prevent Posting/Exporting and export of 'Void' lines and 'No invoice line' Invoices
22/07/2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
*/
constants
	FixedPrefix : String = "CUSTOMER_ORDER_CREATE_";
vars

	file 	   : File;
	fFolder    : FileFolder;
	filePrefix : String;
	fileDirStr : String;
	prefixIdx  : Integer;
	message    : String;
begin
	
	filePrefix := FixedPrefix &amp; invoice.sequenceNum.String.padLeadingZeros(8) &amp;".xml";
	
	prefixIdx := fileNameBase.pos(filePrefix,1);
	if prefixIdx &lt;=0 then
		prefixIdx := fileNameBase.reversePos("\");
	endif;
	fileDirStr := fileNameBase[1:prefixIdx-1];
	
	create fFolder;

	fFolder.fileName := fileDirStr;
	if not fFolder.isAvailable then
	
		message := app.getErrorString2(Expor_path_does_not_exist_cann,fileDirStr,invoice.sequenceNum.String);
		app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);			
		return;
	endif;

	create file;
	file.mode := File.Mode_Output;
	file.allowReplace := true;
	file.fileName := fileNameBase; 
	
	// TFS 37904 jlgmd1 01/05/2018
	if not self.createInvoiceXML( file, invoice ) then
		file.purge();
		file.close();
		app.msgBox(app.getErrorString(Inv_xml_not_created),app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	file.close;
	
	invoice.incrementExportCount(true);			//22.07.2019 cnwma1 TFS #45577
	
epilog

	delete file; 
	delete fFolder;
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="fileNameBase" type="String"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="3d8bb61e-48e0-47cf-8359-db352c85af93">
        <source>getNiceName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Oct 2017	cnwma1  TFS #7562 DQM - IFS Financial Interface

*/

vars

begin
	return 'Industrial &amp; Financial Systems - DQM';

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
