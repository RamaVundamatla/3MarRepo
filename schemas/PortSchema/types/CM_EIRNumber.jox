    <JadeMethod name="setDetails" id="e3013727-7e0c-4764-a66e-575b4b919b0d">
        <updating/>
        <source>setDetails(_vvr 		: CM_VehicleVisitRecord input ;
		   _term 		: CM_Terminal;
		   _eirNumer 	: String ) updating;
/*

Date		Who		Reason
20 Jan 2015	cnwer1	Initial creation PAR 35553 CCMS 1409
11 Apr 2025 navma1  MTN-34621 MTN - 1081 dead lock on CM_EIRNumberDict
*/

vars

begin
	
	self.eirNumber		:=	_eirNumer;							//11.04.2025 navma1 #MTN-34621
	self.myVVR			:=	_vvr;
	self.myTerminal		:=	_term;								//22.04.2025 navma1 #MTN-34621
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_eirNumer" type="String"/>
    </JadeMethod>
</Class>
