    <JadeMethod name="setInfo_sms" id="90111e20-fedc-4823-b08c-112531c9c57c">
        <updating/>
        <source>setInfo_sms() updating;

begin
	copies:=1;
	port := myBmkControl.bmkBasePort.Integer;
	
	//port:=port+(appSequenceId div 4);
	port:=port+(appSequenceId mod 4);
	if      appSequenceId &gt;= 0 and appSequenceId &lt;= 5 then
		profile:='Enrol';
	elseif appSequenceId &gt;= 6 and appSequenceId &lt;= 7 then
		profile:='Inquiries';
	elseif appSequenceId = 8 then
		profile:='AddressChange';
	elseif appSequenceId = 9 then
		profile:='AgendaMonitor';
	else
		profile:='Timeout';
	endif;
	/*profile:='Inquiries';
	profile:='AddressChange';
	profile:='Enrol';
	profile:='AgendaMonitor';
	profile:='Timeout';/**/
end;</source>
    </JadeMethod>
    <JadeMethod name="setInfo_sst" id="f880edb9-7c31-483d-b6bd-39885a46bb2d">
        <updating/>
        <source>setInfo_sst() updating;

begin
	if myBmkControl.owner[1:6] = 'cnwjbl'  then
//		copies:=30;		// must set this back for normal stdruns
		copies := 20;	// adjusted for 64-bit high load
		//profile:="All5";  // in startApp method
		//port:=myBmkControl.bmkBasePort.Integer + appSequenceId mod 2;
		//port:=myBmkControl.bmkBasePort.Integer + (appSequenceId div 4);
		//port:=myBmkControl.bmkBasePort.Integer + appSequenceId mod 4;
		
		port:=myBmkControl.bmkBasePort.Integer + appSequenceId mod 10;	// must set this back for normal stdruns
//		port:=myBmkControl.bmkBasePort.Integer + appSequenceId mod 20;	// adjusted for 64-bit high load
	else
		copies:=20;  // normal setting
		//copies:=40;  // 1600 total with 40 appservers
		//copies:=3; if appSequenceId &gt;= 20 then copies:=2; endif;  // 100 total with 40 appservers
		//copies:=25;  // 1000 total with 40 appservers
		//copies:=1; if appSequenceId &gt;=10 then copies:=0; endif;
		//profile:="All5";  // in startApp method
		port:=myBmkControl.bmkBasePort.Integer + appSequenceId mod 60; // was this 01/03/2008
