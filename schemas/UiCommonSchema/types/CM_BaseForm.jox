    <JadeMethod name="getControl" id="2b2176dd-9f0a-4ccc-bcbf-eef5037f0165">
        <source>getControl(pName : String) : Control;
// ---------------------------------------------------------------------------
// Created:     03 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cntrl	: Control;
	idx		: Integer;
	
begin

	foreach idx in 1 to self.controlCount do
		cntrl := self.controls(idx);
		if cntrl.name = pName then
			return cntrl;
			break;
		endif;
	endforeach;
	
	return null;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Control"/>
    </JadeMethod>
