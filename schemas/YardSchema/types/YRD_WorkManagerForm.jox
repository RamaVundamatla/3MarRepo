epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateSchedule" id="d2325396-170d-49a5-969e-27e9a8a14d57">
        <updating/>
        <source>updateSchedule(_schedule : CM_WorkOrderSchedule) updating;
// -----------------------------------------------------------------------------
// Created:		19 August 2009 by consw1
//
// Purpose:		Update table for changed _schedule
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	col, row : Integer;
	iter: Iterator;
	newDT : TimeStamp;
	oldDT : TimeStamp;
	oldSchedule : CM_WorkOrderSchedule;
	oldWorkOrder : CM_WorkOrder;
	rowDT : TimeStamp;
	lastMonth,
	lastDay : String;
	monthText,
	dayText,
	tmpDayText	: String;	
begin
	oldDT := null;
	newDT := null;
	
	iter := self.allSchedules.createIterator();
	
	while iter.next(oldSchedule) do
		if oldSchedule.String = _schedule.String then
			oldDT := iter.getCurrentKey(1).TimeStamp;
			oldWorkOrder := iter.getCurrentKey(2).CM_WorkOrder;
			self.allSchedules.removeKeyEntry(oldDT, oldWorkOrder, oldSchedule);
			self.clearRowOnSchedule(oldDT);
			break;
		endif;
	endwhile;
			
	if global.isValidObject(_schedule) then
		if self.filterSchedule(_schedule)
		and self.filterWorkOrderDetail(_schedule.myParent)
		and self.filterWorkOrder(_schedule.myParent.myParent) then
			self.allSchedules.add(_schedule);
			if _schedule.scheduledDT &lt;&gt; oldDT then
				newDT := _schedule.scheduledDT;
				self.clearRowOnSchedule(newDT);
			endif;
		endif;
	endif;
	
	if oldDT = null and newDT = null then
		return;
	endif;

	//  Refresh effected rows
	
	row := self.tblSchedule.rows;
	
	while true do
		rowDT := self.getScheduledDT(row);
		//  New DT?
		if newDT &lt;&gt; null and row &lt;= self.tblSchedule.fixedRows or rowDT &lt; newDT then
			rowDT := newDT;
			row := row + 1;			
	
			if lastMonth &lt;&gt;  rowDT.date.monthName() then
				lastMonth := rowDT.date.monthName();
				monthText := lastMonth;
			else
				monthText := '';			
			endif;
			
			tmpDayText :=  rowDT.date.dayName()[1:3] &amp; ' ' &amp; rowDT.date.day.asStringJMT();
			
			if lastDay &lt;&gt;  tmpDayText then
				lastDay := tmpDayText;
				dayText := lastDay;
			else
				dayText := '';			
			endif;		
			
			self.addRowToSchedule(rowDT,monthText  , dayText , rowDT.time.asStringJMT()  , 0);
		endif;
		if rowDT = null or row &lt;= self.tblSchedule.fixedRows then
			return;
		endif;
		//  Refresh rows
		if rowDT = newDT or rowDT = oldDT then
			self.allSchedules.startKeyGeq(rowDT, null, iter);
			while iter.next(oldSchedule) do
				if oldSchedule.scheduledDT &lt;&gt; rowDT then
					break;
				endif;
				self.addScheduleDetails(oldSchedule, row);
			endwhile;
			if rowDT = newDT then
				newDT := null;
			endif;
			if rowDT = oldDT then
				oldDT := null;
			endif;
		endif;
		//  Done yet?
		if oldDT = null and newDT = null then
			return;
		endif;
		row := row - 1;
	endwhile;
	
//	if newDT &gt; self.currentTS and newDT &lt; self.timerTS then
//		self.timerSetup();
//	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_schedule" type="CM_WorkOrderSchedule"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="ca2e5923-dc65-4206-83b7-1a2d88ea1ecc">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// -----------------------------------------------------------------------------
// Created:		17 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// -----------------------------------------------------------------------------

vars
	event : Integer;
	
begin
	event := self.myTerminal.getEventFromTerminalEvent(eventType);

	if event = Event_WorkOrderSchedule_Update and self.filterSet then
		self.currentTS := self.systemToLocalTime(app.actualTimeServer());//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.updateSchedule(userInfo.CM_WorkOrderSchedule);
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
