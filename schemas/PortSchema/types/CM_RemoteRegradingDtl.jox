end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTis" id="f003f18e-ef6f-4c9b-bf47-9212497d12a9">
        <source>getTis(_myTerminal : CM_Terminal; _errorSet : CM_ErrorSet input; _allTis : StringArray input) : CM_TISet protected;

// cnwdvb1 21 November 2002 
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	huge	: HugeStringArray;
	str		: String;
	ti		: CM_TrackedItem;
	tiSet	: CM_TISet;

begin

	if not _allTis.size &gt; 0 then
		create huge transient;
		self.allCsvTis.parseCSV(huge);	
		beginTransaction;
		huge.copy(self.allTis);
		commitTransaction;
	endif;
	create tiSet transient;
	foreach str in self.allTis do
		if str &lt;&gt; null then // Checking just incase a null as been added during remote editing.
			ti := _myTerminal.lookupTrackedItem(str, TI_CargoType_Log, TI_STATE_NORMAL, null, false);
			if ti = null then
				self.addError(Err_TrackedItemsNotFound, app.getErrorString1(Err_TrackedItemsNotFound, str), _errorSet);
			else
				tiSet.add(ti);				
			endif;
		endif;
	endforeach;	
	return tiSet;			// 09/21/2013 cnwmh5 - Deleted by calling method

epilog
	delete huge;
end;</source>
        <access>protected</access>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_allTis" type="StringArray" usage="input"/>
        <ReturnType type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="saveFromArray" id="f54857e9-9f53-4117-af9f-8f910643e855">
        <updating/>
        <source>saveFromArray(_array: StringArray) updating;

// cnwdvb1 21 November 2002 

vars

	ti		: Integer;
	string	: String;

begin

	if _array.size &gt; 0 then
		if _array[1] = RegradeItemArray then
			self.allTis.clear;
			foreach ti in 2 to _array.size do
				if _array[ti] &lt;&gt; null then
					self.allTis.add(_array[ti]);
				endif;
			endforeach;
		endif;
	endif;

end;</source>
        <Parameter name="_array" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="51a4c8ab-691a-4658-8553-a8defd82d8c7">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns : Integer) updating;

// cnwdvb1 21 November 2002 

vars
	
	area, loc : String;

begin

/*	self.operator			:= _table.accessCell(2,5).text.trimBlanks;
	self.species			:= _table.accessCell(3,5).text.trimBlanks;
	self.grade				:= _table.accessCell(4,5).text.trimBlanks;
	self.type				:= _table.accessCell(5,5).text.trimBlanks;
	self.treatment			:= _table.accessCell(6,5).text.trimBlanks;
	self.length				:= _table.accessCell(7,5).text.trimBlanks;*/
	area 					:= self.terminalArea;
	loc						:= self.location; 
	self.terminalArea		:= _table.accessCell(8,_entryTableColumns).text.trimBlanks;
	self.location			:= _table.accessCell(9,_entryTableColumns).text.trimBlanks;
	if area &lt;&gt; self.terminalArea or loc &lt;&gt; self.location then
		self.isMove := true;
	endif;

/*	if self.isLogId then
		self.sedMax			:= _table.accessCell(8,5).text.Decimal;
		self.sedMin			:= _table.accessCell(9,5).text.Decimal;
	endif;*/
	
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="616f3388-65bf-4137-ad9e-3aa9103c4696">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteRegradingDtl; _realRemoteHdr: CM_RemoteDataHdr) updating;

// cnwdvb1 21 November 2002 

vars

begin

	inheritMethod(_proxy, _realRemoteHdr);
	self.myRegradeCode	:= _proxy.myRegradeCode;
	self.grade			:= _proxy.grade;
	self.length			:= _proxy.length;
	self.isLogId		:= _proxy.isLogId;
	self.operator		:= _proxy.operator;
	self.sedMax			:= _proxy.sedMax;
	self.sedMin			:= _proxy.sedMin;
	self.species		:= _proxy.species;
	self.treatment		:= _proxy.treatment;
	self.type			:= _proxy.type;
	self.allCsvTis		:= _proxy.allCsvTis;
	self.isMove			:= _proxy.isMove;
	self.location		:= _proxy.location;
	self.terminalArea	:= _proxy.terminalArea;

end;</source>
        <Parameter name="_proxy" type="CM_RemoteRegradingDtl"/>
        <Parameter name="_realRemoteHdr" type="CM_RemoteDataHdr"/>
    </JadeMethod>
    <JadeMethod name="setProxyForRegrading" id="adcadfd3-1bfc-4835-aad1-27ca902df2f9">
        <updating/>
        <source>setProxyForRegrading(	_remoteHdr : CM_RemoteDataHdr;
						_operator, _species,
						_grade, _type, _treatment,
						_length, _allTis,
						_terminalArea,
						_location					: String;
						_sedMin, _sedMax			: Decimal;
						_isLogId,
						_isMove						: Boolean;
						_regradeCode 				: CM_LogRegradeCode) updating;

// cnwdvb1 21 November 2002 

vars

begin
	self.myRegradeCode	:= _regradeCode;
	self.operator		:= _operator;
	self.species		:= _species;
	self.grade 			:= _grade;
	self.type			:= _type;
	self.treatment		:= _treatment;
	self.length			:= _length;
	self.allCsvTis		:= _allTis;
	self.sedMin			:= _sedMin;
	self.sedMax			:= _sedMax;
	self.isLogId		:= _isLogId;
	self.isMove			:= _isMove;
	self.terminalArea	:= _terminalArea;
	self.location		:= _location;
	self.setProxy(_remoteHdr);

end;</source>
        <Parameter name="_remoteHdr" type="CM_RemoteDataHdr"/>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_species" type="String"/>
        <Parameter name="_grade" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_treatment" type="String"/>
        <Parameter name="_length" type="String"/>
        <Parameter name="_allTis" type="String"/>
        <Parameter name="_terminalArea" type="String"/>
        <Parameter name="_location" type="String"/>
        <Parameter name="_sedMin" type="Decimal"/>
        <Parameter name="_sedMax" type="Decimal"/>
        <Parameter name="_isLogId" type="Boolean"/>
        <Parameter name="_isMove" type="Boolean"/>
        <Parameter name="_regradeCode" type="CM_LogRegradeCode"/>
    </JadeMethod>
</Class>
