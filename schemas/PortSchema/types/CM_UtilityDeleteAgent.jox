    <JadeMethod name="utlDeleteVehicleVisitGTE" id="6f91e79c-c2f4-40fd-b850-625a4188fb41">
        <source>utlDeleteVehicleVisitGTE(_realGTE : CMGTE_Entity io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     	August 2008 	ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 05/10/2015       cnwma1 			PAR # 36948 Unloading-reloading cargo using Truck Loader results in offsite item on dock receipt
// 27 Feb 2018		cnwma1  		ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
// ---------------------------------------------------------------------------

vars
	realVVR 	: CM_VehicleVisitRecord;
	job 		: CM_Job;
	wle 		: CM_WorkListEntry;
	generator 	: CM_Generator;
	ti 			: CM_TrackedItem;
	controller 	: CMIF_TIUpdateController;
	invalidTI 	: Boolean;
begin

	self.initialiseActivity();

	if _realGTE = null then
		return;
	endif;
	
	realVVR := _realGTE.myVehicleVisitRecord;
	if realVVR = null then
		return;
	endif;
	
	//27 May 2011	NDL	Par 27585
	wle := realVVR.getWLEForGateEntity(_realGTE);
	
	if wle &lt;&gt; null then	//27 May 2011	NDL	Par 27585
		job := realVVR.getMyJob();
		if job &lt;&gt; null and job.status = JOB_COMPLETE then //epr par 35023 22/10/14
			app.raiseCMException2(Canno_remov_item_from_being_wo,_realGTE.tranNumber, job.jobId, null, null);
		endif;
	endif;
	
	if _realGTE.isKindOf(CMGTE_Release) 								// 05/10/2015 cnwma1 PAR #36948
	and global.isValidObject( _realGTE.CMGTE_Release.myTrackedItem) then // ### TFS CR 59942 TASK 59943 23AUG2023 NAVAB1
		
		//27.02.2018 cnwma1 ChangeRequest #36813
		if _realGTE.CMGTE_Release.myTrackedItem &lt;&gt; null then
			generator := _realGTE.CMGTE_Release.myTrackedItem.getGenerator;
		endif;
		//27.02.2018 cnwma1 ChangeRequest #36813
		
		if realVVR.allReleasedTrackedItems.includes(_realGTE.CMGTE_Release.myTrackedItem) then
			realVVR.allReleasedTrackedItems.remove(_realGTE.CMGTE_Release.myTrackedItem);
			
			//27.02.2018 cnwma1 ChangeRequest #36813
			if generator &lt;&gt; null then
				if realVVR.allReleasedTrackedItems.includes(generator) then
					realVVR.allReleasedTrackedItems.remove(generator);
				endif;
			endif;
			//27.02.2018 cnwma1 ChangeRequest #36813
		endif;
	endif;
	
	//jlier1 TFS 64964 5/8/24
	if _realGTE.isKindOf(CMGTE_Receival) and _realGTE.CMGTE_Receival.myTrackedItem &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,ti,invalidTI); 
		ti:=_realGTE.CMGTE_Receival.myTrackedItem;
		if not ti.isTransient then
			if ti &lt;&gt; null and not ti.isPreNote  and ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then // jlier1 TFS 64964 2/8/24
				//jlier1 TFS 64964 1/7/24
				//set to Remain on board so we know that it shouldn't show on the Truck loader/ unloader
				controller := app.createTIUpdateControl( TI_UPDMODE_NORMAL, app.myPassport.userCode, null );
				controller.saveTIDataPriorUpdate(ti,app.myPassport);	
				ti.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);
				ti.endUpdate(controller,  app.myPassport);
			endif;
		endif;	
	endif;
	
	_realGTE.erase(NORMAL_ERASE);
	
	realVVR.causeEvent(realVVR.myTerminal.getTerminalEvent(EVENT_VEH_VISIT_TRANSACTION), false, _realGTE);

epilog
	delete controller;
end;</source>
        <Parameter name="_realGTE" type="CMGTE_Entity" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteVessel" id="999b0456-a7b3-440e-aa60-539eb8be9c52">
        <source>utlDeleteVessel(_vessel:CM_Vessel input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realVessel : CM_Vessel;
	expectedEdition : Integer;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valVessel(_vessel);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;
	
	if _vessel.isTransient then
		 _vessel.pxyGetRealObjectAndEdition(realVessel, expectedEdition);
	else
		realVessel := _vessel;
	endif;

	if realVessel = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Vessel.name, null, null);
		return;
	endif;
	
	if not _passport.noErrors() then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if expectedEdition &lt;&gt; null // If null the a real vessel was passed in
	and realVessel.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Vessel', null, null);
		return;
	endif;		
	
	self.exclusiveLock(realVessel);	

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(realVessel);
	endif;

	if _passport.noErrors then
		realVessel.erase(NORMAL_ERASE);
	endif;

end;</source>
        <Parameter name="_vessel" type="CM_Vessel" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
