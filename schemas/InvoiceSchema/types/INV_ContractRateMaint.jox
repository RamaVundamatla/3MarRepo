    <JadeMethod name="handleService" id="c8000d70-28ec-4e31-8f89-ad46688569ae">
        <updating/>
        <source>handleService() updating;
/*
Purpose:			

Date		Who		Reason
16 February 2023	navab1	TFS CR 56446 TASK 56447
16 February 2023  	CR 55646 Task 55667: UI - Contracts Rates
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes
*/
vars
	prevRate : CM_InvoiceContractRate;
	entry : CM_InvoiceContractRateEntry;
	service : CM_Service;
	tbl					: CM_DataTable;
	idx					: Integer;
	str 				: String;
	contractRangeEntry  : CMIF_ContractRangeEntry; //25/10/2023 navmv20 CR 60503 Task 60505
	contractRangeEntryDates : CMIF_ContractRateEntryDates; ///25/10/2023 navmv20 CR 60503 Task 60505
begin

	service := self.cmbService.listObject.CM_Service;
	
	// In COPY mode, we always want the rate entries on the table, we'll "fix" the  rate.myService reference upon saving.
	if not self.mode = self.MODE_COPY then
		self.tblData.rows := self.tblData.fixedRows; // ### TFS BUG 56879 02MAR2023 NAVAB1 - moved up from being inside 'if service = null then'
	endif;
	
	if service = null then
		// ### TFS BUG 56879 02MAR2023 NAVAB1 self.tblData.rows := self.tblData.fixedRows;
		return;
	endif;
	
	prevRate := self.myInvoiceContractRate;
	if prevRate &lt;&gt; null then
		self.endNotificationForSubscriber(prevRate);
	endif;
	
	// This is UPDATE/COPY mode
	if self.myContractDetails &lt;&gt; null then// ### TFS BUG 56765 03MAR2023 NAVTNR20
		self.myInvoiceContractRate := self.myContractDetails.allInvContractRatesByService[service];
		
	/*else
		return;	// ### TFS BUG 56765 03MAR2023 NAVTNR20*/
	endif;
	
	// In NEW/COPY mode, return here as we don't need notifications //31/01/2023	navkc1 Bug 61578
	if self.mode = self.MODE_CREATE or self.mode = self.MODE_COPY then
		return;
	endif;
	
	if self.myInvoiceContractRate &lt;&gt; null then
		tbl := self.tblData;
		tbl.rows := tbl.fixedRows;
		//25/10/2023 navmv20 CR 60503 Task 60505 - start
		delete self.myCMIFContractRangeEntry;
		create self.myCMIFContractRangeEntry transient;
		contractRangeEntry := self.myCMIFContractRangeEntry;
		contractRangeEntry.createCMIFRateEntryDates(self.myInvoiceContractRate);
		foreach contractRangeEntryDates in contractRangeEntry.allDateRanges do
			str := contractRangeEntryDates.getAttributeStringForDefArray(tbl.allTblDataEntRows);
			idx := tbl.addItem(str);
			tbl.accessRow(idx).itemObject := contractRangeEntryDates;
		endforeach;
	
			/*foreach entry in self.myInvoiceContractRate.allInvoiceContractRateEntries do
				str := entry.getAttributeStringForDefArray(tbl.allTblDataEntRows);
				idx := tbl.addItem(str);
				tbl.accessRow(idx).itemObject := entry;
			endforeach;*/
		
		//25/10/2023 navmv20 CR 60503 Task 60505 - end

		self.beginNotification(self.myInvoiceContractRate, self.myTerminal.getTerminalEvent(Event_InvContractRateEntCreate), Response_Continuous, null);
		self.beginNotification(self.myInvoiceContractRate, self.myTerminal.getTerminalEvent(Event_InvContractRateEntUpdate), Response_Continuous, null);
		self.beginNotification(self.myInvoiceContractRate, self.myTerminal.getTerminalEvent(Event_InvContractRateEntDelete), Response_Continuous, null);
		
		
	else
		// ### TFS CR 61579 TASK 62453 13FEB2024 NAVAB1
		tbl := self.tblInfo;
		tbl.rows := tbl.fixedRows;
		self.beginNotification(self.myContractDetails, self.myTerminal.getTerminalEvent(Event_InvContractRateCreate), Response_Continuous, null);
		self.beginNotification(self.myContractDetails, self.myTerminal.getTerminalEvent(Event_InvContractRateUpdate), Response_Continuous, null);
		self.beginNotification(self.myContractDetails, self.myTerminal.getTerminalEvent(Event_InvContractRateDelete), Response_Continuous, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblContractRateMaint" id="dbec22a6-7d9b-41e5-9dc6-1977e8ce1b66">
        <source>initTblContractRateMaint(_theEntDef :String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes
*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := self.tblData;
	theTable.allSelectedObjects.clear;
	
	if _theEntDef &lt;&gt; null then
		theTable.userInputEnabled := false;
		theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
		theTable.selectionType := CM_EntryTable.SelectionType_Row;
		theTable.rows := theTable.fixedRows;		
		entTableDef := app.myController.getEntTableDef(_theEntDef);
		theTable.setTblDataEntRowsFromDef(entTableDef);
		theTable.setMyDataClass(CMIF_ContractRateEntryDates); //25/10/2023 navmv20 CR 60503 Task 60505
		//theTable.setMyDataClass(CM_InvoiceContractRateEntry); //25/10/2023 navmv20 CR 60503 Task 60505
		
		theTable.readOnly := false;	
		theTable.fixedColumns := 0;
		theTable.fixedRows := 1;
		self.setColorsForTable(self.tblData);	
	else
		theTable.rows := 1;	
	endif;
end;</source>
