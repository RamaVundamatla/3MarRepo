//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theRowHeight,
	theColWidth : Real;
	thePaddingRows : Real;
	theTopMargin,theBottomMargin : Integer;
	aRow : CMUI_GridRow;
	isLidRow, smallOutput, mediumOutput,largeOutput : Boolean;
begin
	if not self.drawMe then
		self.totalPointHeight := 0;
		return;
	endif;
//	self.myGridAreaFrame.backColor := Red;
	smallOutput :=  self.scaleXFactor = 1 or (self.amPrinting and self.scaleXFactor = self.PrintScaleSmall);
	mediumOutput := (self.amPrinting and self.scaleXFactor = self.PrintScaleMedium);
	largeOutput := (self.amPrinting and self.scaleXFactor = self.PrintScaleLarge);
	
	if largeOutput then
		theRowHeight := self.PrintScaleLargeHeight;
		theColWidth	 := self.PrintScaleLargeWidth;
	else
		theRowHeight := RowHeight *  self.scaleXFactor;
		theColWidth	 := ColWidth * self.scaleXFactor;
	endif;

	// work out if the last row is a hatch lid row
	isLidRow := isLastRowAHatchLidRow(aRow);
	theTopMargin := self.getTopMargin();
	
	if self.displayMode = ShpDisplayMode_Defn then // no pile weights displayed
		theBottomMargin := 2;
	elseif  smallOutput or mediumOutput then
		theBottomMargin := 2;
	elseif  largeOutput then
		if isLidRow then
			theBottomMargin := BottomMargin;
		else
			theBottomMargin := 20;
		endif;
	else
		theBottomMargin := BottomMargin;
	endif;
	
	self.totalPointHeight := theTopMargin + theBottomMargin;
	if  self.amPrinting then
		if isLidRow then
			if smallOutput then
				self.totalPointHeight := ((self.allGridRows.size - 1) * theRowHeight).Integer + 10;
			elseif mediumOutput then
				self.totalPointHeight := self.totalPointHeight + ((self.allGridRows.size - 1) * theRowHeight).Integer + 10;
			else
				self.totalPointHeight := self.totalPointHeight + ((self.allGridRows.size - 1) * theRowHeight).Integer + LidHeight;
			endif;
		else
			self.totalPointHeight := totalPointHeight + ((self.allGridRows.size) * theRowHeight).Integer;
		endif;
	elseif isLidRow then
		self.totalPointHeight := self.totalPointHeight + ((self.allGridRows.size - 1) * theRowHeight).Integer + LidHeight;
	else
		self.totalPointHeight := self.totalPointHeight + (self.allGridRows.size * theRowHeight).Integer + 5;
	endif;
	inheritMethod();
end;</source>
    </JadeMethod>
</Class>
