    <JadeMethod name="checkEditTransaction" id="0ef91a6d-7be9-482e-9200-565939787b83">
        <source>checkEditTransaction(_transaction : CM_Transaction) : Boolean;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//09/05/2016    cnwma1	TFS 1964 CPL - Missing EDI CAMS Report transaction line on VERMAS messages

//
vars

	field : String;
	oldValue : String;
	newValue : String;
	i : Integer;
begin
	if not _transaction.CM_TITransaction.isCamsEditType() then     //09/05/2016 cnwma1 TFS #1964
		return false;
	endif;

	//we have an edit transaction see if it is intesteresting
	//epr TFS 2395 removed the step 2 was skipping if isWeightCertified was the 2nd field edited (or just an even edited field)
	foreach i in 1 to _transaction.CM_Edit.fieldsValues.size   do
		_transaction.CM_Edit.getFieldValues(i, field, oldValue, newValue);
		//see if it includes a Is weight Certified change
		if field = CM_TrackedItem::isWeightCertified.name  then
			return newValue.asBooleanJMT();		//09/05/2016 cnwma1 TFS #1964			
		endif;		
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_transaction" type="CM_Transaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
