    <JadeMethod name="getDisplayStringForAttribute" id="45e82510-0cc9-4dbd-915e-a74c116c890c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     20 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_ManifestId then
		return self.id;
	elseif _attrName = ETRow_MyConsignee then
		if self.myConsignee &lt;&gt; null then 
			return self.myConsignee.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyOperator then
		if self.myOperator &lt;&gt; null then 
			return self.myOperator.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyVoyage then
		if self.myGCVoyage &lt;&gt; null then 
			return self.myGCVoyage.myVoyage.code;
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="a6efe5d3-0bc9-4527-bfd0-aa737b78afac">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     31 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	prxManifest : CM_Manifest;
	completedOK		: Boolean;
	
begin
	prxManifest := inheritMethod();
	
	prxManifest.myConsignee	:= self.myConsignee;
	prxManifest.myGCVoyage	:= self.myGCVoyage;
	prxManifest.myOperator	:= self.myOperator;
	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	prxManifest.myVoyage	:= self.myVoyage;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return prxManifest;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete prxManifest;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9c5f1dcd-af0d-415a-a7ae-98acf4683c2e">
        <updating/>
        <source>setForUpdate(_pxyManifest : CM_Manifest) updating;
// ---------------------------------------------------------------------------
// Created:     31 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	self.id 					:= _pxyManifest.id.trimBlanks;
	self.myConsignee 			:= _pxyManifest.myConsignee;
	self.myOperator 			:= _pxyManifest.myOperator;
	self.myGCVoyage				:= _pxyManifest.myGCVoyage;
	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	self.myVoyage				:= _pxyManifest.myVoyage;

end;</source>
        <Parameter name="_pxyManifest" type="CM_Manifest"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyage" id="7826abdb-a5e2-4a67-ac6b-d9821fcb933a">
        <updating/>
        <source>setMyVoyage(_voyage : CM_Voyage) updating;

vars

begin
	self.myVoyage := _voyage;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="f54a1dc9-27e1-4cb2-b1f4-d802f171909d">
        <updating/>
        <source>setProxy(_id : String; _consignee : CM_ConsigneeConsignor; _operator : CM_Operator; _voyage : CM_GeneralCargoVoyageStructure) updating;
// ---------------------------------------------------------------------------
// Created:     31 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	calendar : CM_Calendar;
begin
	self.raiseExceptionIfNotTransient(method);
	self.id				:= _id[1:30];
	self.myConsignee	:= _consignee;
	self.myOperator		:= _operator;
	self.myGCVoyage		:= _voyage;
	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	self.myVoyage		:= _voyage.myVoyage;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_consignee" type="CM_ConsigneeConsignor"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_GeneralCargoVoyageStructure"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="d36deee2-5c66-4b97-b59a-a8f103f0a351">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     02 February 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 08/12/2014 cnwdb2 PAR 35364

vars

begin
//	app.raiseCMWarning2(CONF_DELETE, 'Manifest ' &amp; self.id, 'Deleting this manifest will delete any BOLs and cargo associated with it' , null, null, self);
	app.raiseCMWarning1(Sure_want_delete35364c, self.id, null, null, self); //cnwdb2 PAR 35364

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="818c7230-8a93-4c82-9dca-29fa2c4ea237">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     31 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Id', null, null);
		app.raiseCMException(Input_required_field_Id, null, null); // cnwdb2	PAR 35364

	endif;
	if self.myOperator= null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Shipper', null, null);
		app.raiseCMException(Input_required_field_shipper, null, null); // cnwdb2	PAR 35364
	endif;	
	if self.myConsignee= null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Consignee', null, null);
		app.raiseCMException(Input_required_field_consignee, null, null); // cnwdb2	PAR 35364

	endif;	
	if self.myGCVoyage= null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage', null, null);
		app.raiseCMException(Input_required_field_voyage, null, null); // cnwdb2	PAR 35364


	endif;	

end;</source>
    </JadeMethod>
</Class>
