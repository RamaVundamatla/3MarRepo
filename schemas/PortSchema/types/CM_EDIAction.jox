    <JadeMethod name="setForUpdate" id="b4105b32-1fcb-47ee-b44d-a8d81f39d472">
        <updating/>
        <source>setForUpdate(_theProxy : SelfType) updating;
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.name			:= _theProxy.name;
	self.keyword		:= _theProxy.keyword;
	self.keyFileSegment	:= _theProxy.keyFileSegment;
	self.myActionObject	:= _theProxy.myActionObject;
	self.actionType		:= _theProxy.actionType;
	self.myEDIFileType	:= _theProxy.myEDIFileType;
	self.description	:= _theProxy.description;	//cnwgb1 17.09.2008 CCMS SFW 1012 Customs AMS Interface (PAR 17931)
	self.actionText		:= _theProxy.actionText;    //cnwgb1 17.09.2008 CCMS SFW 1012 Customs AMS Interface (PAR 17931)
	self.actionNumber	:= _theProxy.actionNumber;  //cnwgb1 17.09.2008 CCMS SFW 1012 Customs AMS Interface (PAR 17931)
	self.roleCode		:= _theProxy.roleCode;		// ### TFS 58831 (58833) 03July2023 NAVPW1
	
end;</source>
        <Parameter name="_theProxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1772abe8-f334-4fc7-bbcd-4c997b9cf88d">
        <updating/>
        <source>setProxy(_name, _keyWord, _keySegment, _actType : String; _actObject: CM_Object; _ediFileType: CM_EDIFileType; _description, _actionText: String; _actionNumber: Integer; _roleCode : String) updating;
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//Date			Who		Reason
//03 July 2023	navpw1	TFS: 58831 (58833) - Added role code
//----------------------------------------------------------------
vars

begin

	self.name			:= _name[1:63];
	self.keyword		:= _keyWord[1:50];
	self.keyFileSegment	:= _keySegment;
	self.myActionObject	:= _actObject;
	self.actionType		:= _actType[1:30];
	self.myEDIFileType	:= _ediFileType;
	self.description 	:= _description[1:60];
	self.actionText		:= _actionText[1:30];
	self.actionNumber	:= _actionNumber;
	self.roleCode		:= _roleCode;				// ### TFS 58831 (58833) 03July2023 NAVPW1
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_keyWord" type="String"/>
        <Parameter name="_keySegment" type="String"/>
        <Parameter name="_actType" type="String"/>
        <Parameter name="_actObject" type="CM_Object"/>
        <Parameter name="_ediFileType" type="CM_EDIFileType"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_actionText" type="String"/>
        <Parameter name="_actionNumber" type="Integer"/>
        <Parameter name="_roleCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="09e8e56f-88ea-4036-be19-2d5960841257">
        <source>validateForCreate();
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//Date		  Who			Reason
// 10/10/23   navsaa30    Bug 58986: TML - "Custom Stops" Remove via "One Stop Customs" EDI File Type
// 16/10/23   navpw1	Bug 58986: Refactored code to make it more efficient
//----------------------------------------------------------------
vars
	action 	: CM_EDIAction;
	iter 	: Iterator;
	isOneStopEdiFileType : Boolean;
//	coll 	: CM_EDIActionByNameDict;
begin
	isOneStopEdiFileType := self.myEDIFileType.type = EDIFileType_XMLOneStopCust;
	
	if not self.myEDIFileType.allowDuplicateEDIActions() then
		if app.myRoot.allEDIActions[name] &lt;&gt; null then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.name.String, null, null);
		endif;
		
	elseif isOneStopEdiFileType then
		//If an EdiAction's keyFileSegment and keyword matches what we are creating and the edi action file type is 
		//	EDIFileType_XMLOneStopCust then raise an exception
		foreach action in app.myRoot.allEDIActions discreteLock do
			if action.getEdiFileType() &lt;&gt; EDIFileType_XMLOneStopCust then
				continue;
			endif;
			
			if self.keyFileSegment = action.keyFileSegment and
				self.keyword = action.keyword and
				self.name = action.name
			then
				app.raiseCMException1(VB_DUPLICATED_ITEM, "Keyword: " &amp; self.keyword &amp; Comma &amp; " Key File Segment: " &amp; self.keyFileSegment , null, null);		// ### TFS 58986 16Aug2023 NAVPW1 - Refactor
				break;
			endif;
			
		endforeach;
		
	else
		//Don't care about the name but we do want to check there isn't already the same action and data application with the same name.
//		coll := app.myRoot.allEDIActions;
		//Jumps to the point in the collection whereby the name is the same and checks if there is a duplicate keyword, actionType and action object
		iter := app.myRoot.allEDIActions.createIterator();
		app.myRoot.allEDIActions.startKeyGeq(self.name, iter);
		
		while iter.next(action) do
			if self.name &lt;&gt; action.name then
				break;
			endif;
			
			if self.keyword = action.keyword and
			    self.actionType = action.actionType and
				self.myActionObject = action.myActionObject
			then
				app.raiseCMException1(VB_DUPLICATED_ITEM, self.name.String, null, null);
				break;
			endif;
		endwhile;
	endif;
	self.validateForUpdate();
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="a5451133-9faf-4ff4-9b1a-f99ac30b7ad9">
