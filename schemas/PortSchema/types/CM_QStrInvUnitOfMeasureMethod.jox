    <JadeMethod name="create" id="40dd4d98-191f-43e1-a9a4-5c9ef71e1705">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/02/2023	navvt20 TFS 56132 Task 56137: Jade - Invoice Line Selector - UOM
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	operator : CM_QueryOperator;

begin
	if self.isTransient then
		return;
	endif;
	
	//create operator as CM_QStringIsOneOf persistent; //17/02/2023 navmv20 TFS 55626 TASK 55688 
	create operator as CM_QStringLookupIsOneOf persistent; //17/02/2023 navmv20 TFS 55626 TASK 55688 
	self.allAllowedOperators.add(operator);
epilog

end;</source>
    </JadeMethod>
