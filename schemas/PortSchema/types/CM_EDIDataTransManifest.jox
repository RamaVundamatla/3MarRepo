    <JadeMethod name="verifyAll" id="ff4c4174-e12d-4dfe-86f3-dd481536a790">
        <updating/>
        <source>verifyAll() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2025	navsp1	Initial creation MTN-33568
14 May 2025 naviv1    MTN-19104 - MTN - Transport Manifest Handling of locking in EDI Operations
*/

vars

begin
	if self.allErrorWarnings.size &gt; 0 then
		beginTransaction;
		self.allErrorWarnings.purge();
		if self.myGateDocument &lt;&gt; null then
			self.myGateDocument.allErrorWarnings.purge();
		elseif self.myShipManifest &lt;&gt; null then		//MTN-19104
			self.myShipManifest.allErrorWarnings.purge();
		endif;
		commitTransaction;
	endif;
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="verifyAssignedCargoGroup" id="6dad51c1-46a3-4947-94c5-8df32165f331">
        <source>verifyAssignedCargoGroup() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/09/2023	navdap1		Initial creation TFS 60387 EUP | FR 53824 - Transport Manifest - Multiple Pre-notes, same Cargo ID
//
vars
	terminal : CM_Terminal;
	tiColl : CM_EDITIById;
	ediTI : CM_EDITrackedItem;
	onSiteTI : CM_EDICargoOnSiteTI;
	ediShipTI : CM_EDICargoOnShipTI;
	prenoteTI : CM_EDIPrenoteTI;
	existingItem : CM_TrackedItem;
	voyage : CM_Voyage;
	errStr : String;
	existCG : CM_CargoGroup;
begin
	terminal := self.getMyTerminal;	
	
	if self.myCargoOnSite &lt;&gt; null then
		tiColl := self.myCargoOnSite.allEDITrackedItems;
	elseif self.myShipManifest &lt;&gt; null then
		tiColl := self.myShipManifest.allEDITrackedItems;
	elseif self.myGateDocument &lt;&gt; null then
		tiColl := self.myGateDocument.allEDITrackedItems;
	elseif self.myTrainConsist &lt;&gt; null then
		tiColl := self.myTrainConsist.allEDITrackedItems;
	endif;
	
	if tiColl &lt;&gt; null then
	
		foreach ediTI in tiColl do
		
			existingItem := null;
			if ediTI.isKindOf(CM_EDICargoOnSiteTI) then
				onSiteTI := ediTI.CM_EDICargoOnSiteTI;
				existingItem := terminal.allOnsiteTIsByCargoTypeId[onSiteTI.cargoType, ediTI.id];
				
			elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
				ediShipTI := ediTI.CM_EDICargoOnShipTI;
				voyage := terminal.lookupVoyage(ediShipTI.getVoyageCode, null, false);
				if voyage &lt;&gt; null then
					
					//Verify voyage cut-offs - 31.Aug.2023 navsp1 TFS 57809
					self.checkEDICutoff(ediShipTI.getVoyageCode, ediShipTI.getOperatorCode, ediShipTI);	
					
					existingItem := voyage.allOnshipTIsByCargoTypeId[ediShipTI.cargoType, ediTI.id];
				endif;
				
			elseif ediTI.isKindOf(CM_EDIPrenoteTI) then
				prenoteTI := ediTI.CM_EDIPrenoteTI;
				existingItem := terminal.allNotifiedTIsByCargoTypeId[prenoteTI.cargoType, ediTI.id];
				
			endif;
			
			if existingItem &lt;&gt; null and existingItem.myCargoGroup &lt;&gt; null and existingItem.myCargoGroup.id &lt;&gt; ediTI.getCargoGroupId then
				// Followup from Eurports: "The file indeed gets uploaded but a warning is still shown. 
				//							This warning should not be shown as it will only make people doubt whether it is wrong or right"
				//errStr := app.getErrorString2(Cargo_item_already_assigne, ediTI.id, " Cargo Group ("&amp;existingItem.myCargoGroup.id&amp;")");			
				//app.myPassport.addWarningFull(Cargo_item_already_assigne, errStr, null, null, null);
			endif;
			
		endforeach;	
		
		
		//Check cargo group exists with a different operator is different											//14.Nov.2023 navsp1 TFS 61127 - //30.May.24 navsp1 uncommented
		existCG := terminal.getCargoGroupItem(tiColl.first.getCargoGroupId);
		if existCG &lt;&gt; null and existCG.operatorCode &lt;&gt; tiColl.first.getOperatorCode then
			app.writeLog( method.qualifiedName &amp; "Cargo group ("&amp;existCG.id&amp;") already exists with a different operator", LogERROR);
			errStr := app.getErrorString2(Already_exists, "Cargo Group ("&amp;existCG.id&amp;")", " different Operator ("&amp;existCG.operatorCode&amp;")");	
			app.myPassport.addErrorFull(Already_exists, errStr, null, null, null);
		endif;
		
		
	endif;		

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyEDIData" id="b3840e96-c68b-4d13-b92c-97911520c88f">
        <updating/>
        <source>verifyEDIData(): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jun 2023	jlirs1	Initial creation
18 Jul 2023	navdap1	TFS 58923 EUP Calloff EDI Daat Type / EDI Load
03 Aug 2023	navra1	TFS 59648 - EUP - Train Cancel - Cancel file for a non-existing manifest number can be DB loaded
30 Aug 2023	navdap1	TFS 60150 EUP | FR 53824 - Road Manifest IMPORT cargo
06 Sep 2023	navdap1	TFS 60387 EUP | FR 53824 - Transport Manifest - Multiple Pre-notes, same Cargo ID
*/

vars
	result : Integer;
	existingEdiFile : CM_EDIFile;
	canBeUpdatedOrCancelled : Boolean;
	wo : CM_WorkOrder;	
	errStr : String;
	terminal : CM_Terminal;
	existingItem : CM_TrackedItem;
	ediShipTI : CM_EDICargoOnShipTI;
	onSiteTI : CM_EDICargoOnSiteTI;
	prenoteTI: CM_EDIPrenoteTI;	
	tiColl: CM_EDITIById;
	voyage : CM_Voyage;
	ediTI : CM_EDITrackedItem;
begin
	
	app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_VERIFYING); //12.Mar.24 navsp1 TFS 60793
	
	//check if its an update or cancel and it is DB loaded and if so, can it be updated/cancelled
	if self.statusString = CMIF_JsonHeaderEUP.Status_Replace or self.statusString = CMIF_JsonHeaderEUP.Status_Cancel then	
		//get the old file
		self.myEDIFile.myEDIFileType.findExistingEDIFile(self.myEDIFile.ediClientRef, self.myEDIFile, existingEdiFile);
	
		//an edi file can be updated or cancelled until it is db loaded, if it is db loaded, we need to check if anything has arrived - the transport or cargo, which is done just below
		canBeUpdatedOrCancelled := true;//13.Jul.2023 navsp1 TFS 58055
		//if there did exist an ediFile with the same clientref and it has a edidata and the ststus of it is DB loaded, check if it can be replaced/deleted
		if existingEdiFile &lt;&gt; null and existingEdiFile.ediData &lt;&gt; null then
			
			if existingEdiFile.ediData.status = CM_EDIFile.EDI_STATUS_DBLOADED then	
				canBeUpdatedOrCancelled := existingEdiFile.canFileBeUpdatedOrCancelled();		// TFS 58923
			endif;
		endif;
		
		//navra1 - TFS 59648 - 3rd Aug 2023 - start
		//if a create was sent for a manifest that did not exist, we fail the verify
		if self.statusString = CMIF_JsonHeaderEUP.Status_Cancel and existingEdiFile = null then
			app.writeLog(method.qualifiedName &amp; Tab &amp;"EDI item with that reference ("&amp;self.myEDIFile.ediClientRef&amp;") does not exist, and so cannot be cancelled",LogERROR);															
			errStr := app.getErrorString(Manif_numbe_does_not_exi);			
			app.myPassport.addErrorFull(Manif_numbe_does_not_exi, errStr, null, null, null);			
			return app.myPassport.allErrorWarnings.size();
		endif;
		//navra1 - TFS 59648 - 3rd Aug 2023 - end
		
		//if it cannot be updated(ie. some cargo item has been received, or the transport has already come, we cannot update or delete,
		//log error and return
		if canBeUpdatedOrCancelled &lt;&gt; true then
			app.writeLog(method.qualifiedName &amp; Tab &amp;"EDI item with that reference ("&amp;self.myEDIFile.ediClientRef&amp;") has items cannot be updated/deleted since items/transport has arrived",LogERROR);															
			errStr := app.getErrorString(Transpo_cargo_already_arrived);			
			app.myPassport.addErrorFull(Transpo_cargo_already_arrived, errStr, null, null, null);			
			return app.myPassport.allErrorWarnings.size();
		endif;		
	else
		//check if there already exists a WO with the same name - we would not be able to create a WO, so return logging an error
		wo := app.myPassport.myTerminal.allWorkOrders[self.manifestNumber];
		if wo &lt;&gt; null then
			app.writeLog(method.qualifiedName &amp; Tab &amp;"Work order exists - " &amp; wo.id,LogERROR);		
			errStr := app.getErrorString1(Work_order_with_name_alrea_exi, wo.id);			
			app.myPassport.addErrorFull(Work_order_with_name_alrea_exi, errStr, null, null, null);			
			return app.myPassport.allErrorWarnings.size();
		endif;
	endif;			// TFS 60387
	
	// TFS 60387 For Create or Replace, check whether the TI is already assigned to another cargo group
	if self.statusString = CMIF_JsonHeaderEUP.Status_Create or self.statusString = CMIF_JsonHeaderEUP.Status_Replace then
		self.verifyAssignedCargoGroup();
		
		// TFS 60150 only return here if passpor has errors, otherwise we skip all the validation after this
		if app.myPassport.hasErrors then
			return app.myPassport.allErrorWarnings.size();		//22.Aug.2023 navsp1 TFS 59872 &lt;&lt;&lt;&lt;
		endif;
		
	endif;
	
	if self.myCargoOnSite &lt;&gt; null then
		result := self.myCargoOnSite.verifyEDIData();
	elseif self.myGateDocument &lt;&gt; null then
		result	:= self.verifyEDIDataGateDoc();		//16Jun2023 navsp1 TFS 57805
	elseif self.myShipManifest &lt;&gt; null then
		result := self.myShipManifest.verifyEDIData();
	elseif self.myTrainConsist &lt;&gt; null then
		result := self.myTrainConsist.verifyEDIData();	//navra1 - TFS 57808- 29th June 2023		
	endif;
	return result;

epilog
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataGateDoc" id="0d51c146-b0a1-4431-95eb-ab4946c3d470">
        <updating/>
        <source>verifyEDIDataGateDoc():Integer updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Jun 2023	navsp1	Initial creation TFS ChangeRequest 57805: EUP - Manifest Processing - Truck - Create
30 Aug 2023	navdap1	TFS 60150 EUP | FR 53824 - Road Manifest IMPORT cargo
31 Aug 2023	navdap1	TFS 60186 EUP | FR 53824 - Road Manifest VBS Booking
13 Nov 2023 navlw1 	Bug 60951: EUP | 53824 - Transport Manifest - VBS Slot Not Always Being Created
17 Apr 2024	navhn30	Bug 63125: EUP* | Transport Manifest UDF - Transport Reference customer error when try to Verify Road manifest
*/

vars
	result			: Integer;
	errStr			: String;
	vbsType			: CM_VehicleBookingTimeSlotType;
	ediTi 			: CM_EDITrackedItem;
	ediPrenote		: CM_EDIPrenoteTI;
	cargoType		: Integer;
	terminal 		: CM_Terminal;
	allowVBSInPast 	: Boolean;
	estArvDate		: TimeStamp;
	cargoSubType, operator, commodity, carrier : String;
	
begin
	result := self.myGateDocument.verifyEDIData();
	
	// TFS 60186 New rules - if a slot isn't found, we will create one. If a slot is found, we will update it
	// So the only thing to verify here is if we can derive a slot type 
	// - either from the slot type in the message
	// - or derived from message criteria if there is no slot type in the message
	foreach ediTi in self.myGateDocument.allEDITrackedItems where ediTi.isEDIPrenote do
		ediPrenote := ediTi.CM_EDIPrenoteTI;
		break;
	endforeach;
	
	vbsType := app.findVBSlotType(self.vehicleBookingSlotType, ediPrenote);
	if vbsType = null then
		errStr := app.getErrorString(Vehicle_booking_slot_type_fail);
		app.myPassport.addErrorFull(Vehicle_booking_slot_type_fail, errStr, null, null, null);
		result := app.myPassport.allErrors.size;
	endif;
	
	// Start #60951
	terminal := self.getMyTerminal();
	allowVBSInPast := terminal.getConfig(AllowVBSInPast).Boolean;
	estArvDate := estimatedDateTimeOfArrival;
	
	if estArvDate.isValid and estArvDate.date &lt; app.actualTimeServer.date then		//17.04.24		navhn30		TFS #63125
		if not allowVBSInPast then
			errStr := app.getErrorString(Vehic_sched_booki_not_added_th);
			app.myPassport.addErrorFull(Vehic_sched_booki_not_added_th, errStr, null, null, null);
			result := app.myPassport.allErrors.size;
		endif;
	endif;
	// End #60951
	
	if self.transportReferenceCustomer = null then		//25.Sep.2023 navsp1 TFS 60476
		errStr := app.getErrorString(Transp_refere_custom_mandat_fi);
		app.myPassport.addErrorFull(Transp_refere_custom_mandat_fi, errStr, "transportReferenceCustomer", null, null);
		result := app.myPassport.allErrors.size;
	endif;
	
	/*if self.transportReferenceCustomer &lt;&gt; null then
		vbsts := vbt.allVBTimeslotsByExtRef.getAtKey(self.transportReferenceCustomer);
	elseif self.transportReferenceInternal &lt;&gt; null then
		vbsts := vbt.allVBTimeslotsById.getAtKey(self.transportReferenceInternal);
	endif;
	// TFS 60150 only raise an error if the manifest file had transport references
	if vbsts = null and (self.transportReferenceCustomer &lt;&gt; null or self.transportReferenceInternal &lt;&gt; null) then
		//raise an error
		errStr := app.getErrorString(Vehicle_schedul_booking_slot);			
		app.myPassport.addErrorFull(Vehicle_schedul_booking_slot, errStr, null, null, null);
		result := app.myPassport.allErrorWarnings.size(); //02.Aug.2023 navsp1 TFS 59622
		//app.raiseCMException(Vehicle_schedul_booking_slot, null, null);
	endif;*/
	
	return result;
epilog

end;</source>
