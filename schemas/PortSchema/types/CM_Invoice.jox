/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2018	jlgndl1	Initial creation	TFS 41309 - migrated from WS_WorkOrderDetail

*/

vars
	dt : TimeStamp;
	fa : CM_OfflineFutureActor;
begin
	if self.status &lt;&gt; CM_Invoice.INVOICE_PREPEND  then
		return null;
	endif;
	
	fa := app.myRoot.allOfflineFutureActorParents[self];
	if fa &lt;&gt; null then
