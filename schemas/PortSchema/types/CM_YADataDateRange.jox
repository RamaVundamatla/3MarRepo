<Class name="CM_YADataDateRange" id="f0c29126-17a9-4602-93bc-019af8e1fa37">
    <superclass name="CM_YAData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <PrimAttribute name="endDate" id="71bf0ce8-0e6c-4c71-a688-4a28e858def8">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <PrimAttribute name="startDate" id="84cddc2b-b302-4794-afe8-304c1e3236c0">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <JadeMethod name="doDataComparison" id="040e6b41-e025-4f17-998d-eefc43d799b9">
        <source>doDataComparison(_yaData: SelfType): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars

begin
	if self.startDate = null and self.endDate = null then
		return true;
	endif;
	
	if _yaData.startDate = null and _yaData.endDate &gt;= self.startDate and _yaData.endDate &lt;= self.endDate then
		return true;
	elseif _yaData.endDate = null and _yaData.startDate &gt;= self.startDate and _yaData.startDate &lt;= self.endDate then
		return true;
	elseif _yaData.startDate = null and _yaData.endDate = null then
		return true;
	else
		if _yaData.startDate &gt;= self.startDate and _yaData.startDate &lt;= self.endDate 
		and _yaData.endDate &gt;= self.startDate and _yaData.endDate &lt;= self.endDate then
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_yaData" type="SelfType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDataValue" id="eb986b0f-b2fd-4523-a9af-f817dcca7392">
        <source>getDataValue(): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars

begin
	return self.getYAIdentifier();
	
epilog

end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="7638bd18-01cc-4aec-8b5f-8a4db9a6a30e">
        <source>getDescription(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars

begin
	return self.startDate.asStringJMT &amp; " - " &amp; self.endDate.asStringJMT;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYAIdentifier" id="480f16ea-3a1d-4715-a537-6ed9a4aec43e">
