        <updating/>
        <source>txtBooking_gotFocus(textbox: TextBox input) updating;
//01 June 2010	cnwml2


vars

begin
	//+cnwml2 PAR24347
	if self.tblContainer.getValueByName(ETRow_BookingReference) &lt;&gt; null then
		self.txtBooking.text := self.tblContainer.getValueByName(ETRow_BookingReference).String;
