    <JadeMethod name="createStopStartTransaction" id="9d2683f8-98bd-4b03-9fad-5d4b4fd4617c">
        <source>createStopStartTransaction(_action: Integer; _ts: TimeStamp; _obj : CM_Object); 		//23.09.2024  navbs1  #12445
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62897: Jade - Job Create Transactions and Events
23 Sep 2024 navbs1 Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues
30 Oct 2024 navhl20 CR MTN-33232: EUP - Start End Times for Road and Rail jobs
19 Nov 2024	navhl20 Bug MTN-33397: EUP | Start and End time for rail load multiple wagon
04 Mar 2024 navbk1  Bug 34242: Halt Timer is displayed when clicking on Done on an Any Amount Rail Job
*/

vars
	woTrans			: CM_WOTransaction;
	woJobTrans		: CM_WOJobDetail;
	eventTrans		: CM_EventTransaction;
	wagonEvent		: CMEVT_WagonTransaction;
	woDtl			: CM_WorkOrderDtl;
	eventType,
	woTransType,
	cargoTransType,
	vvrType 		: Integer;
	isStart,
	canCreate		: Boolean;
	wagon			: CM_Wagon;
	wagons			: CM_ObjectSet;
	cmifEventCtrl	: CMIF_WagonEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	// Get the type based on the action
	self.getTypesToCreate(_action, eventType, vvrType, woTransType, cargoTransType);
	
	isStart := _action = Job_Action_Start or _action = Job_Action_Resume;
	
	wagon := _obj.CM_Wagon;												//30.10.2024 navhl20 #33232
	
	// Create WO Transaction
	woDtl := self.getMyWorkOrderDtl();
	if _action = Job_Action_Complete then
		//04.03.2025  navbk1 #34242
		/* wle := self.allCompletedWLEsByDate.first;
		if wle &lt;&gt; null then
			woWle := wle.myWorkOrderWLE;
		endif;
		if woWle &lt;&gt; null then
			woJob := woWle.job;
		endif;
		if woJob &lt;&gt; null and woJob.status = JOB_COMPLETE then
			canCreate := true;
		endif; */
		if self.status = JOB_COMPLETE then						//04.03.2025 navbk1 #34242
			canCreate := true;
		endif;
	endif;
	if woDtl &lt;&gt; null and (canCreate or wagon = null) then
		woTrans := woDtl.createWOTransaction(woTransType, null, null);
		if woTrans &lt;&gt; null then
			woJobTrans := woTrans.CM_WOJobDetail;
			woJobTrans.setJobActionDetails(self, isStart, _ts);
		endif;
	endif;
	
	create wagons transient;
	if wagon = null then													//07.11.2024 navbs1 #33232
		self.getWagonTrainsFromWles(wagons);	
		if wagons.isNotEmpty then 											//07.11.2024 navbs1 #33232
			if wagons.size = 1 then											//19.11.2024 navhl20 #33397
				wagon := wagons.first.CM_Wagon; 
			endif;
		else
			wagon := self.getMyWagon();
		endif;
	endif;
	
	if wagon &lt;&gt; null then
		if eventType = EVT_WagonJobStart then
			wagonEvent := wagon.getLastTransactionOfType(eventType).CMEVT_WagonTransaction;
			if wagonEvent &lt;&gt; null and self.getJobId() = wagonEvent.jobId then
				eventType := EVT_WagonJobResume;
			endif;
		endif;
		
		/* //17/02/2025	navkc1 JIRA Bug MTN-33582
		eventTrans := app.createEvent(eventType, _ts, self.myTerminal, app.myPassport.userCode, false, false, null);
		if eventTrans &lt;&gt; null then
			wagonEvent := eventTrans.CMEVT_WagonTransaction;
			wagonEvent.setJobActionDetails(self, isStart, _ts);
			if woJobTrans = null then
				woJobTrans := woDtl.getLastTransOfType(woTransType).CM_WOJobDetail;
			endif;
			wagonEvent.setMyWOTransaction(woJobTrans);
			if wagon &lt;&gt; null then
				wagon.allTransactions.add(wagonEvent);
			endif;
		endif;
		*/
		
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
		create cmifEventCtrl transient;
		cmifEventCtrl.type := eventType;
		cmifEventCtrl.dateTime := _ts;
		cmifEventCtrl.myTerminal := self.myTerminal;
		cmifEventCtrl.userCode := app.myPassport.userCode;
		cmifEventCtrl.myRailJob := self;
		cmifEventCtrl.myWorkOrderDetail := woDtl;
		cmifEventCtrl.myWorkOrderTransaction := woJobTrans;
		cmifEventCtrl.workOrderTransactionType := woTransType;
		cmifEventCtrl.myWagon := wagon;
		cmifEventCtrl.isStart := isStart;
		cmifEventCtrl.startEndTimeStamp := _ts;
		
		wagonEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_WagonTransaction;
	
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
		
	endif;
epilog
	delete wagons;
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_action" type="Integer"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="departureProcess" id="1acb8ec0-b50b-4b61-91b2-2bf469ebddd7">
        <updating/>
        <source>departureProcess(_passport: CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 07 April 2003 By: cnwgd1
//17 Mar 2025 navma1 MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
//--------------------------------------------------------------
vars
	wle    : CM_WorkListEntry;
	wleArr : CM_WLEArray;
begin
	inheritMethod(_passport);
	
	if app.myPassport.isOpsViewEnabled(self.myTerminal) then 			// ### TFS 51855 06JAN2022 NAVAB1
		
		self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB,self); // ### TFS 51855 06JAN2022 NAVAB1 // ### TFS 52914 02MAR2022 NAVAB1 changed to UPDATE
		
		create wleArr transient;
		self.workListEntries.copy(wleArr);								//17.03.2025 navma1 #MTN-34120
		foreach wle in wleArr discreteLock  do 							//17.03.2025 navma1 #MTN-34120// ### TFS 51855 06JAN2022 NAVAB1
			wle.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_WLE,wle); // ### TFS 51855 06JAN2022 NAVAB1 // ### TFS 52914 02MAR2022 NAVAB1 changed to UPDATE
		endforeach;
	endif;
	
	if _passport.noErrors then
		//Finally (Maybe !), erase the rail job
		self.erase(NORMAL_ERASE);
	endif;
epilog
	delete wleArr;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="enqueueJob" id="af19c0d1-8155-426b-91de-e337c236c476">
        <source>enqueueJob();
//Works to queue a job
vars
	wle	: CM_WorkListEntry;
	arbiter	: CM_RTQueueArbiter;
begin
	//epr par 36229 17/7/17 removed references to RadioTelemetryEnabled 
	//--------------	
	//For each WLE (a unit of work), ask it to enqueue itself
	//(Note, this can be called from that level if required.
	//--------------
	create arbiter;
	arbiter.job := self;

	foreach wle in workListEntries do
		arbiter.reset();
		wle.enqueueWLE(arbiter);
	endforeach;


epilog
	arbiter.erase(0);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="99c548bf-ee3b-434d-8765-cce038f6ee74">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//--------------------------------------------------------------
//Created: Feb 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	requestObj	: CM_Request;
	tiObj		: CM_TrackedItem;
	wle		: CM_WorkListEntry;
	iter01Obj	: Iterator;
	iter02Obj	: Iterator;

begin
	exclusiveLock(self);
	/* 20 June 2012	NDL	Par 28769
// cnwdad1 07/07/2006 - PAR #11895.
	if self.isTransitJob() then
		iter01Obj	:=	self.workListEntries.createIterator();
		
		while iter01Obj.next(wleObj) do
			if wleObj.status = WLE_COMPLETED then
				continue;
			endif;
			
			// Move the TI offsite immediately.
			tiObj	:=	wleObj.myTrackedItem;
			//tiObj.moveToLocation(null, null, null, null, REAL_MODE, true, false, false, false, false,  0, false, app.myPassport);
			tiObj.moveToLocation(null, null, wleObj, null, REAL_MODE, true, false, false, false, false,  0, false, app.myPassport);	//15 Mar 2011	NDL	Par 27070
		endwhile;
	endif;
	*/
	
	//epr par 25495 19/8/10 
	// if its not a release with multi machine moves there could be rt queue entries for wles that have not been completed yet
	// ti create new internal job and set change the rt queue entries references to that
	if self.hasReceipt then
		self.updateUnfinishedQEntries();
	endif;

	if app.myPassport.noErrors then // ### TFS 51855 06JAN2022 NAVAB1
		if app.myPassport.isOpsViewEnabled(self.myTerminal) then // ### TFS 51855 06JAN2022 NAVAB1
			self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB,self); // ### TFS 51855 06JAN2022 NAVAB1 // ### TFS 52914 02MAR2022 NAVAB1 changed to UPDATE
			foreach wle in self.workListEntries do // ### TFS 51855 24MAY2022 NAVAB1
				wle.setStatus(WLE_COMPLETED); // ### TFS 51855 24MAY2022 NAVAB1
			endforeach;
		endif;
	endif;
	
	
	iter02Obj	:=	self.allRequests.createIterator();
	
	while iter02Obj.next(requestObj) do
		self.myTerminal.removeFromRailSortColl(requestObj);
		requestObj.erase(_eraseLevel);
	endwhile;

	self.causeTerminalEvent(self.Event_Mode_Delete);	
	

	inheritMethod(_eraseLevel);
epilog
	delete iter01Obj;
	delete iter02Obj;
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllWLEs" id="725a2018-b9f4-49f8-8b12-50fb5080362c">
        <source>getAllWLEs(_wleArray: CM_WLEArray input);
// ---------------------------------------------------------------------------
// Created:     02 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 14/06/2022 		navcs2	 		ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
// 06 Mar 2025 		navma1 			MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
// ---------------------------------------------------------------------------

vars
	wle,
	relatedWle	: CM_WorkListEntry;
	ti 			: CM_TrackedItem;
begin

	foreach wle in self.workListEntries discreteLock do					//06.03.2025 navma1 #MTN-34179
		//To get the order correct, skip the toDo we get it later
		if wle.isKindOf(CM_WOToDoWLE) then //14/06/2022 navcs2 TFS 53038
			continue;
		endif;
		//Now get the related toDo
		relatedWle := wle.getRelatedWLE();
		if relatedWle &lt;&gt; null then
			_wleArray.add(relatedWle);
		endif;
		
		ti := wle.myTrackedItem;
		
		if ti &lt;&gt; null then
			if not self.isRelease() then // PAR 21570
				if ti.isInTransitOnShip then // OR ON TRAIN
					continue;
				endif;
			endif;
		endif;
		
		_wleArray.add(wle);			
	endforeach;

end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
