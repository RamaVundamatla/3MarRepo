    <JadeMethod name="actionForCreate" id="eb0f628a-1e89-42dc-b139-382ee80acef5">
        <updating/>
        <source>actionForCreate(pProxy : CM_Object io; _passport : CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

/*
	tmpCarrier := app.myRoot.allCarriers[self.carrierCode];

	if tmpCarrier = null then
		tmpCarrier := self.myTerminal.createCarrier(self.carrierCode, _passport);
	endif;

	if tmpCarrier = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Carrier not found');
		return false;
	endif;

	self.myProxyRoadJob.carrierId := tmpCarrier.code;
*/	
/*
following refactored and moved to CM_Terminal::createRoadJob - 29 April 08 - RS2
	vta:=self.myTerminal.allTerminalAreaMastersById[self.roadTransAreaId].CM_VehicleTransferArea;
	//if it is dual gate then add the wles to the job that is assoicated to the vechicle else just create a new job everytime
	if vta.isDualGate then
		vehicle:=self.myProxyRoadJob.myVehicle;
		if vehicle = null or vehicle.isTransient then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,"Vehicle is null",null,self);
		else
			
			if vehicle.allRoadJobs.size &gt; 0 then
				if vehicle.myPrimaryActualLocation &lt;&gt; vta.allPreGateControllers.first then
					app.raiseCMException1(Full_Replacement_Message,"The vehicle specified is not off-site or in the pre-gate.", null,self);
					return false;//return here so that the allRoadJobs collection doesn't get something put into it preventing this error from coming up a subsiquent time
				endif;
			
				self.myRoadJob := vehicle.allRoadJobs.first.CM_RoadJob;
			else
				self.myRoadJob := self.myTerminal.createRoadJob(self.myProxyRoadJob, self.myUserObject, _passport);
			endif;
		endif;
	else
		self.myRoadJob := self.myTerminal.createRoadJob(self.myProxyRoadJob, self.myUserObject, _passport);
	endif;
*/
// PAR 16908.  If we get any secondary warnings, e.g. 'Cannot Auto Plan This Item' the transaction is aborted and this job is an invalid object.
//					we must create this always, after all this is a CREATE method
//	if self.myRoadJob = null then // dh 24/06/08  backed this out as it broke warehousing
	if self.myRoadJob = null 
	or not global.isValidObject(self.myRoadJob) then 
		self.myRoadJob := self.myTerminal.createRoadJob(self.myProxyRoadJob, self.myUserObject, _passport);
		
	endif;
//	endif;


epilog
	return inheritMethod(pProxy, _passport);

end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForCreatePost" id="507d6add-2390-4bd6-9c4b-bf6fb45036ee">
        <updating/>
        <source>actionForCreatePost(_obj : Object; _passport : CM_Passport input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	gogo : Boolean;
begin

	if _passport = null then
		return false;
	endif;
	
	if self.myRoadJob &lt;&gt; null then
//		self.myRoadJob.createVisitRequests(self);

		// PAR 17703 Set the Errors and Warnings onto the Vehicle Visit Record
		if self.myRoadJob.myVehicle &lt;&gt; null then
			self.myRoadJob.myVehicle.setErrorsFromPassport(_passport); // PAR 17703
		endif;
		
		if gogo // never set see AKB
		and self.usePrecheckGate then
			if self.myRoadJob.myVehicleVisit.isOK() then
				self.myRoadJob.changeStatus(JOB_UNVERIFIED);
			else
				self.myRoadJob.changeStatus(JOB_TROUBLE);
			endif;
		endif;
		
	endif;
	
	return _passport.noErrors();
epilog
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="f71b15d5-7cce-4c79-96be-5d62bb059154">
        <updating/>
        <source>create() updating;

// Created by cnwdvb1 on 07 August 2007
// 06/10/2016 cnwma1 TFS #2707 C3 - Docket Reconciliation
vars

begin
	if app.myPassport.myTerminal.getConfig(LogDocketAutoMatch).Boolean then //06/10/2016 cnwma1 TFS #2707
		self.isAttemptMatch := true;
	endif;
end;</source>
    </JadeMethod>
