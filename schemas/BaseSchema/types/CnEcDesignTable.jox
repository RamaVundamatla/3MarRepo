    <JadeMethod name="getSelectedObjects" id="76fd5e63-604e-45ec-919f-b6931e629f4c">
        <source>getSelectedObjects():ObjectArray;
// --------------------------------------------------------------------------------
// Created:		19 November 2001 by cnwdad1
//
// Purpose:		
//
