    <JadeMethod name="doResize" id="bb6be739-7e35-4373-a171-749ee21cb3b5">
        <updating/>
        <source>doResize() updating;
//----------------------------------------------------------------
//	Created:	27 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
begin
	inheritMethod();

	if self.lblCRP.visible then
		self.lstColours.move(0,	0, self.clientWidth, self.height - 65);
		self.lblCRP.move(4,2,self.clientWidth - 25,13);
		
		// above added as result of CCMS1304. Legend needed an list item added that would be in bold. 
		// unable to do by adding picture or bolding list item (bolds all items)
		// label added to form and is set as visible by form and placed over listbox. 
	else
		self.lstColours.move(0, 0, self.clientWidth, self.height - 65);
	//	app.writeStatement(class.name &amp; " " &amp; method.name &amp; " " &amp; self.clientHeight.String);
	endif;
	
	self.btnCancel.left := self.width - (self.btnCancel.width+25);
	self.btnCancel.top := self.height - (self.btnCancel.height+42);
		

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="46b7afda-2657-4db6-9283-134ec53af0ba">
        <updating/>
        <source>setupForm() updating;
//----------------------------------------------------------------
//	Created:	29 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
begin
	self.btnOk.visible := false;
	self.btnCancel.visible := true;
	self.btnCancel.caption := "&amp;Close";
	
	self.handleMenusForModalDisplay();
	self.toolbarStyle := self.ToolbarStyle_None;
	self.showToolbar := false;

	self.lstColours.stretchHeight	:= true;
	self.lstColours.stretchWidth	:= true;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4bd23218-5a94-4340-ae5e-fed5d4c036ce">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014543, locale);
	lblCRP.translateCaption(Xlat_0000261, locale);
end;</source>
    </JadeMethod>
</GUIClass>
