    <JadeMethod name="delete" id="cd56f0e9-451f-4e21-9e76-259a348cf40e">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2017	cnwsc8	Initial creation

*/

vars

begin
	if self.allLocations &lt;&gt; null and not self.allLocations.isEmpty() then
		self.allLocations.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="a4c3d91b-c562-4cd1-a481-c0b3489e939d">
        <updating/>
        <source>setProxyFromObject(_wagon: CM_Wagon) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 November 2016	cnwmp6	Initial creation
16 November 2022	jlizm1	TFS 54118 Assigning Releases to Wagons

*/

vars
	cm_controller : CM_LocationsController;
	ws_controller : WS_LocationsController;
	ti : CM_TrackedItem;
	requests	: CM_DeliveryRequestSet;
	req			: CM_DeliveryRequest;
begin
	inheritMethod(_wagon);

	self.id := _wagon.id;
	if _wagon.myRailLine &lt;&gt; null then
		self.railId := _wagon.myRailLine.myRailArea.id;
		self.railLineId := _wagon.myRailLine.id;
	endif;
	self.railLinePosition  := _wagon.getWagonPosition().asIntegerJMT();

	self.isBoxcar := _wagon.isBoxcar;
	self.isFlatcar := _wagon.isFlatcar;
	self.isSkeletoncar := _wagon.isSkeletonCar;
	self.confirmedInwards := _wagon.confirmed;
	self.confirmedOutwards := _wagon.confirmedOutwards;

	foreach cm_controller in _wagon.allLocationsControllersArray discreteLock do
		create ws_controller transient;
		ws_controller.setProxyFromObject(cm_controller);
		//epr TFS 44883 27/6/19 - when wagon cargo format is UP/SP standards postion id depends on the cargo that is in the position 
		ti:= cm_controller.allTrackedItems.first;
		if ti &lt;&gt; null and ti.myPrimaryActualLocation = cm_controller then
			ws_controller.id:=cm_controller.getFullIdTI(ti);
		endif;
		self.allLocations.add(ws_controller);
	endforeach;
	
	create requests transient;
	_wagon.getAllAssignedDelRequests(requests);
	
	foreach req in requests do
		if req.isAnyAmount or 
		  (req.myCargoType &lt;&gt; null and req.myCargoType.allowDuplicates) then
			self.canCompleteLoad := true;
			break;
		endif;
	endforeach;
	
epilog
	
	delete requests;
	
end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="setProxyLocationCargo" id="e8e23e5c-96b0-49a8-8bb4-aa1610755a71">
        <source>setProxyLocationCargo();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 June 2022
TFS#		: 53971
Function	:

*** Changes ***
Date			Name		TFS#		Description
****************************************************/

vars
	wsLoc 			: WS_LocationsController;
	realLoc 		: CM_LocationsController;
	wc 				: CM_WagonController;
	tiArray			: CM_TIArray;
	ti 				: CM_TrackedItem;
	wsCargoSummary 	: WS_CargoSummary;
	failedDAC 		: CM_DataAccessController;	
begin
	create tiArray transient;
	
	foreach wsLoc in self.allLocations discreteLock do
			realLoc:=wsLoc.cmObjectId.asOid().CM_LocationsController;
			if realLoc = null then
				continue;
			endif;
			foreach ti in realLoc.allTrackedItems discreteLock do
				if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
					continue;
				endif;	
				
				if not tiArray.includes(ti) then	
					create wsCargoSummary transient;
					wsCargoSummary.setProxyFromObject(ti);
					wsLoc.myCargo:=wsCargoSummary;		
					tiArray.add(ti);
				endif;
			endforeach;
	
	endforeach;

epilog
	delete tiArray;
end;</source>
    </JadeMethod>
</Class>
