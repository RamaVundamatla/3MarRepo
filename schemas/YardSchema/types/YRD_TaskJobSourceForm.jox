    <JadeMethod name="doSourceSelect" id="e573de70-a8b4-4697-b216-458fe09e3025">
        <updating/>
        <source>doSourceSelect() updating;
// -----------------------------------------------------------------------------
// Created:		31 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 11/05/2018	jlgdap1		TFS 38501 PEL1 Work Order Changes
// -----------------------------------------------------------------------------

vars
	idx : Integer;
	heading : String;
	obj : Object;
	
begin
	idx := self.lstSources.listIndex;
	if idx &lt; 1 then
		idx := 1;
	endif;
	
	if self.lstSources.itemLevel[idx] = 1 then
		heading := self.lstSources.text;
		if heading = self.headingCargoIDs then
			self.displayCargoIDs();
		elseif heading = self.headingBulkReleases then
			if self.isWorkOrderRelease then					// TFS 38501
				self.displayCargoIDs;					// TFS 38501
				self.setForWorkOrderRelease;					// TFS 38501
			else										// TFS 38501
				self.displayBulkReleases(null);
			endif;										// TFS 38501
		elseif heading = self.headingRequests then
			self.displayRequests(null);
		elseif heading = self.headingWorkOrders then
			self.displayWorkOrders(null);
		elseif heading = self.headingBookings then
			if self.isWorkOrderBooking then					// TFS 38501
				self.displayCargoIDs;					// TFS 38501
				self.setForWorkOrderBooking;					// TFS 38501
			else										// TFS 38501
				self.displayBookings(null);
			endif;										// TFS 38501
		else
			self.showGroup(null);
		endif;
		return;
	endif;

	obj := self.lstSources.listObject;
	
	if obj.isKindOf(CM_BulkRelease) then
		self.displayBulkReleases(obj.CM_BulkRelease);
	elseif obj.isKindOf(CM_WorkOrderRequestByType) then
		self.displayRequests(obj.CM_WorkOrderRequestByType);
	elseif obj.isKindOf(CM_WorkOrder) then
		self.displayWorkOrders(obj.CM_WorkOrder);
	elseif obj.isKindOf(CM_BookingRef) then
		self.displayBookings(obj.CM_BookingRef);
	else
		self.showGroup(null);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateRequest" id="41a77d1a-9139-4c36-aaeb-1d218698ec4d">
        <updating/>
        <source>doUpdateRequest() updating;
// -----------------------------------------------------------------------------
// Created:		04 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	woRequest : CM_WorkOrderRequestByType;
	
begin
	woRequest := self.lstSources.listObject.CM_WorkOrderRequestByType;

	self.updateRequestProxy( woRequest );
	
	self.lstSources.itemText[ self.lstSources.listIndex ] := woRequest.getListDisplay();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doViewSource" id="b8701304-6a12-4b6c-91b3-5bdbae64102b">
        <source>doViewSource();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2010	cnwrd1	Initial creation

*/

vars
	//brset : CM_BookingRefSet;
begin

	//create brset transient;


	if self.fldDetails.topSheet = shtBooking then
		if self.cmbBookingRef.listObject &lt;&gt; null then
			//show selected booking ref.
			//brset.add(self.cmbBookingRef.listObject.CM_BookingRef );
			
			self.myAssistant.showBookingForm(self.cmbBookingRef.listObject.CM_BookingRef,self.myMasterMenuAction , self.myTerminal );
			//self.myAssistant.doBookingEnquiry( brset);			
		endif;
	elseif self.fldDetails.topSheet = shtRelease then	
		if self.cmbBulkRelease.listObject &lt;&gt; null then
			//show selected bulkrelease.
			self.myAssistant.releaseRequestView(self.cmbBulkRelease.listObject.CM_BulkRelease, self.myMasterMenuAction );

		endif;
	elseif self.fldDetails.topSheet = shtWorkOrder then
		if self.cmbWorkOrder.listObject &lt;&gt; null then
			//show selected workorder.			
			self.myAssistant.showWorkOrderForm(self.cmbWorkOrder.listObject.CM_WorkOrder,self.myMasterMenuAction , self.myTerminal );
			
		endif;	
	else //nothing selected we can show
		return;
	endif;

epilog
	//delete brset;
end;


</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="b87cdc23-5701-4722-8ff8-c790ab5fc964">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// -----------------------------------------------------------------------------
// Created:		03 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 11/05/2018	jlgdap1		TFS 38501 PEL1 Work Order Changes
// -----------------------------------------------------------------------------

vars

begin
	inheritMethod();

	self.doRefresh();

	self.cmbCargoType.setObject( self.myProxySource.getMyCargoType() );
	self.txtCargoIDs.text := self.myProxySource.tiTextList;
	
	if self.isWorkOrderBooking then								// TFS 38501
		self.loadSources( self.headingBookings );			// TFS 38501
	elseif self.isWorkOrderRelease then							// TFS 38501
		self.loadSources( self.headingBulkReleases );		// TFS 38501
	else													// TFS 38501
		self.loadSources( self.headingCargoIDs );
	endif;													// TFS 38501
	
	self.selectSourceFromObject( self.myInitSourceObject);
	
	btnOK.enabled := self.canSourcesBeAdded;
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSourceItem" id="c2b3dbf1-8c34-41d9-bed5-6db966d92b9e">
        <source>loadSourceItem(_desc : String; _obj : Object);
// -----------------------------------------------------------------------------
// Created:		13 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 14 Mar 2011	cnwkpd1		PAR #27142 - Correct handleDeletedObject exception arming
//							Removed unnecessary invalidObject parameter
// -----------------------------------------------------------------------------

vars

begin
	self.lstSources.addTreeObject(_desc, _obj, 2, true);
	
epilog

end;</source>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="loadSources" id="40ab4999-1a29-4853-8cca-483d6480b57a">
        <updating/>
        <source>loadSources( _selectedHeading : String ) updating;
// -----------------------------------------------------------------------------
// Created:		31 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming
// 11/05/2018	jlgdap1		TFS 38501 PEL1 Work Order Changes
// -----------------------------------------------------------------------------

vars
	bookingRef : CM_BookingRef;
	bulkRelease : CM_BulkRelease;
	invalidObj : Boolean;
	saveTopIndex : Integer;
	woRequest : CM_WorkOrderRequestByType;
	workOrder : CM_WorkOrder;
	
begin
	saveTopIndex := self.lstSources.topIndex;
	
	self.lstSources.clear();

	//  Cargo IDs
	if self.isWorkOrderBooking then														// TFS 38501
		self.lstSources.addTreeObject(self.headingBookings, null, 1, true);			// TFS 38501
		self.shtCargoIDs.caption := self.headingBookings;							// TFS 38501
	elseif self.isWorkOrderRelease then													// TFS 38501
		self.lstSources.addTreeObject(self.headingBulkReleases, null, 1, true);		// TFS 38501
		self.shtCargoIDs.caption := self.headingBulkReleases;						// TFS 38501
	else																			// TFS 38501
		self.lstSources.addTreeObject(self.headingCargoIDs, null, 1, true);
	endif;																			// TFS 38501
	self.txtCargoIDs.text := self.myProxySource.tiTextList;
	
	if not self.isWorkOrderBooking and not self.isWorkOrderRelease then						// TFS 38501
		//  Bulk Releases
		self.lstSources.addTreeObject(self.headingBulkReleases, null, 1, true);
		on Exception do app.handleDeletedObject(exception, bulkRelease, invalidObj);
		foreach bulkRelease in self.myProxySource.allBulkReleases do
			self.loadSourceItem(bulkRelease.code, bulkRelease);	
		endforeach;
		
		//	Requests
		self.lstSources.addTreeObject(self.headingRequests, null, 1, true);
		foreach woRequest in self.myProxySource.allWORequestByType do
			self.loadSourceItem(woRequest.getListDisplay(), woRequest);
		endforeach;
		
		//  Work Orders
		self.lstSources.addTreeObject(self.headingWorkOrders, null, 1, true);
		on Exception do app.handleDeletedObject(exception, workOrder, invalidObj);
		foreach workOrder in self.myProxySource.allSourceWorkOrders do
			self.loadSourceItem(workOrder.id, workOrder);
		endforeach;
		
		//  Booking References
		self.lstSources.addTreeObject(self.headingBookings, null, 1, true);
		on Exception do app.handleDeletedObject(exception, bookingRef, invalidObj);
		foreach bookingRef in self.myProxySource.allBookings do
			self.loadSourceItem(bookingRef.bookingReference, bookingRef);
		endforeach;
	endif;																			// TFS 38501
	
	if self.lstSources.listCount() &gt;= saveTopIndex then
		self.lstSources.topIndex := saveTopIndex;
	endif;

	if _selectedHeading &lt;&gt; null then
		self.selectSource(_selectedHeading);
	endif;
	
	self.doSourceSelect();
	
epilog

end;</source>
        <Parameter name="_selectedHeading" type="String"/>
    </JadeMethod>
    <JadeMethod name="lstSources_click" id="518458a4-9031-4163-9820-bcb73a007307">
        <controlMethod name="CMUI_ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSources_click(listbox: ListBox input) updating;
// -----------------------------------------------------------------------------
// Created:		31 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	self.doSourceSelect();

epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectSource" id="50005671-2160-45c4-a39b-8c8668d608cd">
        <source>selectSource( _heading : String );
// -----------------------------------------------------------------------------
// Created:		04 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	i		: Integer;
	numItems : Integer;
	
begin
	numItems := self.lstSources.listCount;
	
	foreach i in 1 to numItems do
		if self.lstSources.itemText[i] = _heading then
			self.lstSources.listIndex := i;
			self.lstSources.itemSelected[i] := true;
			break;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_heading" type="String"/>
    </JadeMethod>
    <JadeMethod name="selectSourceFromObject" id="2bdd1b01-a793-456d-a582-5f128c656d78">
        <updating/>
        <source>selectSourceFromObject( _obj : Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2009	cnwrd1	Initial creation

*/

vars

rowPointer	: Integer;
	
begin

	if _obj = null then
		return;
	endif;
	
	rowPointer	:=	self.lstSources.findObject(_obj);
	

	if rowPointer &lt;&gt; CNEC_NULL_INDEX then
		self.lstSources.itemSelected[rowPointer]	:=	true;
		self.lstSources.listIndex := rowPointer;
	else
		self.lstSources.listIndex := 1;
	endif;

	self.doSourceSelect();
	
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="set" id="c3004023-a9ee-46ac-931f-7d674830efdf">
        <updating/>
        <source>set( _parent : CM_BaseForm; _pxySource : CM_WorkOrderTISource ) updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	_pxySource.raiseExceptionIfNotTransient(method);
	_pxySource.getWorkOrder().raiseExceptionIfNotTransient(method);

	
	self.myMainForm := _parent;
	self.setParentForm(_parent);
	
	self.myProxySource := _pxySource;
	self.myRealWorkOrder := _pxySource.getWorkOrder().pxyGetRealObject();
	
	self.canSourcesBeAdded := self.myRealWorkOrder = null or self.myRealWorkOrder.canSourcesBeAdded();
	self.canSourcesBeRemoved := self.myRealWorkOrder = null or self.myRealWorkOrder.canSourcesBeRemoved();	
	
	//  Save off initial values in case proxy needs to be restored (form cancelled).
	self.initialCargoType := self.myProxySource.cargoType;
	self.initialTiTextList := self.myProxySource.tiTextList;
	self.myProxySource.allBookings.copy(self.initialBookings);
	self.myProxySource.allBulkReleases.copy(self.initialBulkReleases);
	self.myProxySource.allSourceWorkOrders.copy(self.initialSourceWorkOrders);
	self.myProxySource.allWORequestByType.copy(self.initialWORequestByType);
	
	self.initialTiTextListLength := self.initialTiTextList.length;
	
epilog

end;</source>
        <Parameter name="_parent" type="CM_BaseForm"/>
        <Parameter name="_pxySource" type="CM_WorkOrderTISource"/>
    </JadeMethod>
    <JadeMethod name="setDeleteProxy" id="7390ec23-b711-4bd7-98cd-7801d9fbbc3b">
        <updating/>
        <source>setDeleteProxy( _value : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 December 2009	cnwrd1	Initial creation

*/

vars

begin

	self.deleteProxy := _value;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForWorkOrderBooking" id="31f0baea-c28a-4ca0-8e79-38d4efa514f6">
        <updating/>
        <source>setForWorkOrderBooking() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//
vars
	wo : CM_WorkOrderTI;
	realWO : CM_WorkOrderTI;	//06 Jun 2018	NDL	TFS 38948
	wodtl : CM_WorkOrderDtl;
	booking : CM_BookingRef;
	ti : CM_TrackedItem;
	ids : HugeStringArray;
	id : String;
	row : Integer;

begin
	self.lblCargoIDs.visible := false;
	self.lblCargoType.visible := false;
	self.cmbCargoType.visible := false;
	self.btnCargoSelector.visible := false;
	
	if self.txtCargoIDs.visible then
		self.lblBookings.parent := self.shtCargoIDs;
		self.lblBookingRef.parent := self.shtCargoIDs;
		self.cmbBookingRef.parent := self.shtCargoIDs;
		self.tblThumb.visible := false;
		self.txtCargoIDs.visible := false;
		self.tblCargoIDs.visible := true;
		self.tblCargoIDs.rows := 0;
		self.tblCargoIDs.selectMode := Table.SelectMode_Multiple;
		self.tblCargoIDs.move(self.txtCargoIDs.left, self.txtCargoIDs.top, self.txtCargoIDs.width, self.txtCargoIDs.height);
		self.cmbBookingRef.clear;
		wo := self.myProxySource.myParent.CM_WorkOrderTI;
		foreach wodtl in wo.allWoDtls where wodtl.isWorkOrderForReceival do
			booking := wodtl.CM_WodReceive.myBookingRef;
		endforeach;
		if booking &lt;&gt; null then
			realWO := wo.pxyGetRealObject();	//06 Jun 2018	NDL	TFS 38948
			self.cmbBookingRef.listIndex := self.cmbBookingRef.addItemObject(booking.bookingReference, booking);
			foreach ti in booking.allTIs where ti.isNotified do
				if ti.allWorkOrders.includesMeOrHasNoneSimilar( realWO , CM_WodReceive ) then	//06 Jun 2018	NDL	TFS 38948
					self.tblCargoIDs.addItem(ti.id);
				endif; 
			endforeach;
			
			create ids transient;
			if self.myProxySource.tiTextList &lt;&gt; null then
				self.myProxySource.getTIsAsStringArray(ids);
				foreach id in ids do
					foreach row in self.tblCargoIDs.fixedRows + 1 to self.tblCargoIDs.rows do
						if self.tblCargoIDs.accessCell(row, 1).text = id then
							self.tblCargoIDs.accessRow(row).selected := true;
						endif;
					endforeach;
				endforeach;
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForWorkOrderRelease" id="564cb280-dd9b-47cd-9d1e-a3abb619d721">
        <source>setForWorkOrderRelease();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//1/04/2019	JLGNS1	Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
//
vars
	wo : CM_WorkOrderTI;
	realWO : CM_WorkOrderTI;	//06 Jun 2018	NDL	TFS 38948
	wodtl : CM_WorkOrderDtl;
	release : CM_BulkRelease;
	ti : CM_TrackedItem;
	ids : HugeStringArray;
	id : String;
	row : Integer;

begin
	self.lblCargoIDs.visible := false;
	self.lblCargoType.visible := false;
	self.cmbCargoType.visible := false;
	self.btnCargoSelector.visible := false;
	
	if self.txtCargoIDs.visible then
		self.lblBulkReleases.parent := self.shtCargoIDs;
		self.lblBulkRelease.parent := self.shtCargoIDs;
		self.cmbBulkRelease.parent := self.shtCargoIDs;
		self.tblThumb.visible := false;
		self.txtCargoIDs.visible := false;
		self.tblCargoIDs.visible := true;
		self.tblCargoIDs.rows := 0;
		self.tblCargoIDs.selectMode := Table.SelectMode_Multiple;
		self.tblCargoIDs.move(self.txtCargoIDs.left, self.txtCargoIDs.top, self.txtCargoIDs.width, self.txtCargoIDs.height);
		self.cmbBulkRelease.clear;
		wo := self.myProxySource.myParent.CM_WorkOrderTI;
		foreach wodtl in wo.allWoDtls where wodtl.isWorkOrderForRelease do
			release := wodtl.CM_WodRelease.getMyReleaseRequest();				//Bug 44134
		endforeach;
		if release &lt;&gt; null then
			self.cmbBulkRelease.listIndex := self.cmbBulkRelease.addItemObject(release.code, release);
			realWO := wo.pxyGetRealObject();	//06 Jun 2018	NDL	TFS 38948
			foreach ti in release.allTrackedItemsAssigned do
				if ti.allWorkOrders.includesMeOrHasNoneSimilar( realWO , CM_WodRelease ) then	//06 Jun 2018	NDL	TFS 38948
					self.tblCargoIDs.addItem(ti.id);
				endif;
			endforeach;
			
			create ids transient;
			if self.myProxySource.tiTextList &lt;&gt; null then
				self.myProxySource.getTIsAsStringArray(ids);
				foreach id in ids do
					foreach row in self.tblCargoIDs.fixedRows + 1 to self.tblCargoIDs.rows do
						if self.tblCargoIDs.accessCell(row, 1).text = id then
							self.tblCargoIDs.accessRow(row).selected := true;
						endif;
					endforeach;
				endforeach;
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setInitSource" id="aa88d246-7b03-4b43-931c-1b7bc41e254b">
