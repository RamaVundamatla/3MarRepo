    <JadeMethod name="setBusinessUnit" id="05ac4413-d8ea-461d-b068-359152c96c76">
        <updating/>
        <source>setBusinessUnit() updating;
/*
Purpose:			

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance
*/

vars
	shipTerm : CM_InvoiceINCOMapping;
begin
	self.endNotificationForSubscriber(self.myCurrentBank);

	self.beginNotification(self.myCurrentBank, self.myTerminal.getTerminalEvent(Event_InvINCOMappingCreate), Response_Continuous, null);
	self.beginNotification(self.myCurrentBank, self.myTerminal.getTerminalEvent(Event_InvINCOMappingUpdate), Response_Continuous, null);
	self.beginNotification(self.myCurrentBank, self.myTerminal.getTerminalEvent(Event_InvINCOMappingDelete), Response_Continuous, null);
	
	self.setCaption("Invoice INCO Terms Maintenance " &amp; self.myCurrentBank.code );
	
epilog

end;</source>
