    <JadeMethod name="setForDelete" id="13210285-d07e-4ddf-8268-d56e794268eb">
        <updating/>
        <source>setForDelete(_reason: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/05/2024	navkc1 CR64385 Task 64395: JADE - Receive Deletion

*/

vars
	
	ti : CM_TrackedItem;
	
begin
	inheritMethod(_reason);

	ti := self.myTrackedItem;
	
	// When deleting any receival transaction, we also want to delete the future storage BGP
	if ti &lt;&gt; null then
		app.myRoot.deleteFutureActor(ti, CM_FutureStorageProcess);
	endif;
	
epilog

end;</source>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
