    </JadeMethod>
    <JadeMethod name="createCMGTE_ReceivalProxy" id="85a5412c-b68e-448b-9414-e93bcba373d4">
        <source>createCMGTE_ReceivalProxy( _cargoType : CM_CargoType ):CMGTE_Receival;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	gateReceival : CMGTE_Receival;
	
begin

	// create a CMGTE_Receival proxy and populate from this flexi gate controller
	if _cargoType.id  = TI_CargoType_Generator then
		create gateReceival as CMGTE_Generator transient;
	elseif _cargoType.id = TI_CargoType_Container then
		create gateReceival as CMGTE_Container transient;			
	elseif _cargoType.isTrailer() then			
		create gateReceival as CMGTE_TILC transient;	
	elseif _cargoType.productType = ProductType_Vehicle then
		create gateReceival as CMGTE_Car transient;			
	else
		create gateReceival as CMGTE_Receival transient;
	endif;
	
	gateReceival.setPXYFromController( self );
	
	return gateReceival;
	
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <ReturnType type="CMGTE_Receival"/>
    </JadeMethod>
    <JadeMethod name="delete" id="a178ea10-c35f-480f-8abe-de146f766d65">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2010	cnwndl1	Initial creation	Par 26567

*/

vars

begin

	if not self.allSeals.isEmpty then
		self.allSeals.purge;
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCarbonDioxide" id="fc2637cc-a6ad-4e4f-8b29-d0b868cf05ed">
        <source>getCarbonDioxide():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	//All Carbon Dioxide display fields are limited to Decimal 6,2  so don't returm bigger than that
	if self.carbonDioxide &gt; 999.99 then
		return 999.99;
	endif;

	return self.carbonDioxide;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
