    <JadeMethod name="getXMLSettingsForSave" id="963b0ed3-e677-4625-a858-5ca2e81b1caa">
        <updating/>
        <source>getXMLSettingsForSave() : String updating;


vars

	xmlStr	: String;
begin
	
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblSelectData.getXmlStrForColumns(true);

	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initTables" id="8d2ea34f-d519-46db-a79a-7e03644686b1">
        <updating/>
        <source>initTables() updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	entTableControl	: EntTableDef;
	tblDef			: EntTableDef;
	terminologyCargoBOLType		: CM_CargoBOLType;

begin
	terminologyCargoBOLType := self.logCargoType;
	
	
//	self.tblActionData.setTerminologyRelevant(terminologyCargoBOLType, self.myTerminal);
	self.setButtons(false);
	// Setup selection table.
	self.splitContainer.setDistanceFromRight(0);
	self.splitContainer.setDistanceFromBottom(0);
	
	self.txtDetails.height := self.splitContainer.height - self.txtDetails.top;
	entTableControl := app.myController.getEntTableDef(ETDef_TALogSelection);
	self.tblSelection.setTerminologyRelevant(terminologyCargoBOLType, self.myTerminal);
	self.tblSelection.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblSelection.resetSize();
	self.tblSelection.optimiseHeadingColumn();
	
	// Setup action table.
	self.tblActionData.userInputEnabled := false;
	entTableControl := app.myController.getEntTableDef(ETDef_TAAction);
	self.tblActionData.setTerminologyRelevant(terminologyCargoBOLType, self.myTerminal);
	self.tblActionData.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	self.tblActionData.optimiseHeadingColumn();
	self.setActionTableView();

	self.doOptTicketClick();
	self.optLogId.value := true;
	
	// Do resizing stuff.		
	self.tblSelection.setDistanceFromRight(WinRightMargin);
	self.tblSelection.lockBottom := false;
	self.tblSelection.lockRight := false;
	self.tblSelection.stretchHeight := false;
	self.tblSelection.stretchWidth := true;
	self.tblSelection.optimiseRowHeight := true;
	self.tblSelection.cnEcResizeContents();
	
	self.tblActionData.setDistanceFromRight(WinRightMargin);
//	self.tblActionData.setDistanceFromBottom(self.clientHeight - btnCancel.top + VerticalSpacing);
	self.tblActionData.lockBottom := true;
	self.tblActionData.lockRight := false;
	self.tblActionData.stretchHeight := false;
	self.tblActionData.stretchWidth := true;
	self.tblActionData.optimiseRowHeight := true;
	self.tblActionData.cnEcResizeContents();

	self.btnBackground.value := false;
	if app.myRoot.getConfig(BackgroundReportsAvailable).Boolean then
		self.btnBackground.enabled := true;
	else
		self.btnBackground.enabled := false;
	endif;
	self.splitterFrame.distanceFromRight := WinRightMargin;
	tblDef := app.myController.getEntTableDef(ETDef_SelectionTable);
	self.tblSelectData.setTerminologyRelevant(terminologyCargoBOLType, self.myTerminal);
	self.tblSelectData.setTblDataEntRowsFromDef(tblDef);
	
//lorcan // Par 11589
	self.tblSelectData.selectMode := Table.SelectMode_CurrentRow;
	self.tblSelectData.selectionType := CM_DataTable.SelectionType_Row;
//	self.tblSelectData.multiSelect := CM_DataTable.MultiSelect_Simple;
//lorcan
	
	self.centreWindow;
//	self.resize();
//	self.setDistances();
//	self.doResize();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="2501e8ca-3f83-4ad6-bc40-8a230b4a171d">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

vars
	theActiveControl	: Control;
	
begin

	theActiveControl := app.activeControl;
	if theActiveControl.parent.isKindOf(CM_EntryTable) then
		theActiveControl := theActiveControl.parent.Control;
	endif;
	if keyCode = J_key_Tab then
		if self.tblSelectData.tabStop then
			tblSelection.handleFormTab(keyCode, shift, optLocation, tblSelectData);
			tblActionData.handleFormTab(keyCode, shift, tblSelectData, btnNextT);
		else
			tblSelection.handleFormTab(keyCode, shift, optLocation, tblActionData);
			tblActionData.handleFormTab(keyCode, shift, tblSelection, btnNextT);
		endif;

		if theActiveControl.isKindOf(CM_EntryTable) and theActiveControl.visible then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;

	elseif keyCode = CMUI_Key_F5 then
		// F5 does a refresh of the screen.
		self.doRefresh;
	else
		inheritMethod(keyCode, shift);
	endif;
	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="927589cf-4e79-451c-8bb1-ae818e9a9a74">
        <source>loadCombos() protected;

/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars

	iter			: Iterator;
	ta				: CM_TerminalArea;
	logArea			: Object;

begin

	// Setup location combo box.
	iter := self.myTerminal.allTerminalAreas.createIterator;
	self.allLogAreas.clear;
	while iter.next(ta) do
		if ta.type &lt;&gt; TA_TYPE_LOGAREA then
			continue;
		endif;
		self.allLogAreas.add(ta);
	endwhile;
	// Temporary.
	//### also moved to cmbLocation.gotFocus PAR 9693
	self.allLocations.clear;
	self.myTerminal.getLocationsForType(TA_TYPE_LOGAREA, false, self.allLocations);
	self.cmbLocation.listCollection(allLocations, false, 0);
	//### end 
//	else
//		self.cmbLogArea.listCollection(allLogAreas, false, 0);
//	endif;
	
//now done on ComboObject gotFocus		
	// Setup supplier combo box.
//	self.myAssistant.comboBoxOperator(self.cmbSupplier, null, null);

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <access>protected</access>
    </JadeMethod>
