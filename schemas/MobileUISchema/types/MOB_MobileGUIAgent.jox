    <JadeMethod name="loadLocnMaintForm" id="36b9abfb-e877-4d87-ac0c-018c5e96ea3c">
        <source>loadLocnMaintForm(_strLoc : String) : Integer;
// --------------------------------------------------------------------------------
// Created:		03 June 2008 by cnwdad1
//
// Purpose:		Loads the Location Maintenance form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	form		: MOB_LocationMaintenanceForm;
begin
	form := findExistingForm(MOB_LocationMaintenanceForm, null).MOB_LocationMaintenanceForm;
	if form = null then
		create form transient;
		form.setLocationStr(_strLoc);
		return form.showModal();
	endif;
end;</source>
        <Parameter name="_strLoc" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
