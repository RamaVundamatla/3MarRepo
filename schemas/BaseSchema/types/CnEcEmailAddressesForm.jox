    <JadeMethod name="lstAddressPerson_click" id="e0baf2f1-9fbe-4bfb-9b6e-6510827e325c">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstAddressPerson_click(listbox: ListBox input) updating;

begin
	if listbox.listIndex &gt; 0 then
		lstLdapPerson.listIndex := CNEC_NULL_INDEX;
		btnSelect.enabled := true;
		btnAddressMaint.enabled := true;
	else
		if lstLdapPerson.listIndex &lt; 0 then 
			btnSelect.enabled := false;
		endif;
	endif;	
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
