    <JadeMethod name="doCloneCodes" id="f6720a6c-bf58-454b-8d97-2ec6184e9162">
        <source>doCloneCodes();
// ---------------------------------------------------------------------------
// Created:     01 November 2002		cnwth2	
//
// Purpose:     This method will either append to, or overwrite the codes in the code table for a particular
//				attribute.
//			 
// ----------   ----------  --------------------------------------------------
vars
	cloneProdAttr,
	prodAttr	: CM_ProductAttr;
	newCode,
	cloneCode	: CM_ProductAttributeCode;
	row			: Integer;
	codeTable	: CM_DataTable;
begin
	codeTable := self.tblCodeData;
	cloneProdAttr := self.cmbCloneAttr.listObject.CM_ProductAttr;
	prodAttr := self.myCurrentProdAttr;
	
	if cloneProdAttr = null then
		app.msgBox(app.getErrorString(SelecCargoSubAttrFromWithToClo),'Error', 0);
		return;
	endif;
	
	if cloneProdAttr.allCodes.isEmpty then
		app.msgBox(app.getErrorString(SelectCargoSubAttrHasNoCodes), 'Error', 0);
		return;
	endif;
	
	//if we're over writing then clear the codes table
	if self.chkOverwriteCode.value then
		codeTable.rows := codeTable.fixedRows;
		foreach row in codeTable.fixedRows + 1 to codeTable.rows do
			newCode := codeTable.accessRow(row).itemObject.CM_ProductAttributeCode;
			prodAttr.allCodes.remove(newCode);
			codeTable.removeItem(row);
		endforeach;
	endif;
	
	foreach cloneCode in cloneProdAttr.allCodes do
		create newCode transient;
		newCode := cloneCode.cloneSelf(true);
		prodAttr.allCodes.add(newCode);
		row := self.tblCodeData.addItem(newCode.code &amp; Tab &amp; newCode.description);
		self.tblCodeData.accessRow(row).itemObject := newCode;
	endforeach;	

	self.hideCloneOptions();
end;</source>
    </JadeMethod>
    <JadeMethod name="doCloneProduct" id="74da8589-e0a5-4d07-9e72-07572af4cb81">
        <updating/>
        <source>doCloneProduct() updating;
// ---------------------------------------------------------------------------
// Created:     11 October 2002 by cnwth2
//
// Purpose:     Gets the selected product to clone and clones it's values into the current pxy product
//				also updates all the attribute references and thier codes.
//				Then re-populates the entry table and the attribute table with the new products' values, hides
//				all the clone stuff and sets focus to the code field- which should then be changed by the 
//				user - no duplicate codes allowed (unless different operator). The code field is not 'nulled' because
//				often just the last character/digit will be changed 
//			 
//
// ----------   ----------  --------------------------------------------------
vars
	newPro,
	clonePro			: CM_Product;
	entRow				: EntTableRow;
	entDef				: EntTableDef;
	displayValue		: String;
	row					: Integer;
begin
	
	clonePro := self.cmbCloneProduct.listObject.CM_Product;
	if clonePro = null then
		app.msgBox(app.getErrorString(SelectCargoSubFromWhichToClone), app.getErrorString(Select_Cargo_Subtype), 0);
		return;
	endif;
	
	if self.myProxyObject &lt;&gt; null then
		delete self.myProxyObject;
	endif;
	
	self.myProxyObject := clonePro.copySelf(true);
	newPro := self.myProxyObject.CM_Product;
	newPro.setForCreate(clonePro);
	
		
	self.cmbEntCargoType.listObject := newPro.myCargoType;
	self.cmbEntOperator.setObject(newPro.myOperator);
	self.cmbEntHandling.listObject := newPro.myHandlingType;
	
	entDef := self.getTblEntDetailDef();
	foreach entRow in entDef.allEntTableRows do
		displayValue := newPro.getDisplayStringForAttribute(entRow.name, false).String;
		tblEntDetail.setValueByName(entRow.name, displayValue);		
	endforeach;
	
	self.displayAttributes(newPro);
	self.tblAttributes.userInputEnabled := true;
	self.tblAttributes.inputType := CM_DataTable.InputType_TextBox;
	
	foreach row in self.tblAttributes.fixedRows + 1 to self.tblAttributes.rows do
		self.disableProdAttrCells(row, false);
	endforeach;
	
	self.hideCloneOptions();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCargoTypeClick" id="95ebc7ed-abdd-4f7f-9ce8-ea03f0a87dcc">
        <source>doCmbCargoTypeClick();
// ---------------------------------------------------------------------------
// Created:     01 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// cnwdad1		03/04/2006	Added a method call to load the Product Groups combobox.
// 21 May 2008	cnwkpd1		PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
//							Fixed display of Cargo Type colour

vars
	theColour,
	row				: Integer;
	cargoType		: CM_CargoType;
	handlingType	: CM_HandlingType;
	
begin
	cargoType := self.cmbEntCargoType.listObject.CM_CargoType;
	self.myProxyObject.CM_Product.setProductDefaults(cargoType);
	self.displayAttributes(self.myProxyObject.CM_Product);
	
	if cargoType &lt;&gt; null then
		theColour := cargoType.getDrawColour;		/// PAR #16753
//		self.tblEntDetail.accessRow(self.tblEntDetail.getRowByName(ETRow_Colour)).backColor := theColour;
		self.tblEntDetail.accessCell(self.tblEntDetail.getRowByName(ETRow_Colour), self.tblEntDetail.ColumnValue).backColor := theColour;

		handlingType := cargoType.myDefaultHandlingType;
		// This is the new one for after 7.4.1 release	
		//handlingType := cargoType.getAttributeValue(CM_CargoTypeExtBreakBulkGen::myDefaultHandlingType.name).CM_HandlingType;
		if handlingType &lt;&gt; null then
			self.cmbEntHandling.listObject := handlingType;
			self.tblEntDetail.setValueByName(ETRow_EntHandling, handlingType.description);
		endif;
		
		self.loadProductGroups(cargoType);
	endif;
	
	foreach row in self.tblAttributes.fixedRows + 1 to self.tblAttributes.rows do
		self.disableProdAttrCells(row, false);
	endforeach;
	
	self.showHideDefaultCommodity();	//CCMS 1080 PAR19704 July 2009
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCodeClick" id="4565548f-46e6-4179-a722-f6c6c1507cff">
        <updating/>
        <source>doCmbCodeClick()updating;
// ---------------------------------------------------------------------------
// Created:     04 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	cmbText			: String;
	
begin
	cmbText := self.cmbCode.text;
	self.tblAttributes.setCellText(tblAttributes.row, tblAttributes.getColumnByRowName(ETRow_ColumnCode), cmbText);
	
	if cmbText = EditCodeString then
//		self.showEditCodes();
		self.showEditCodesForm();
	else
		self.myCurrentProdAttr.setMyCode(self.cmbCode.listObject.CM_ProductAttributeCode);
	endif;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbValidationClick" id="a06ddfcd-5777-496a-a767-0092dd58e564">
        <source>doCmbValidationClick();
// ---------------------------------------------------------------------------
// Created:     03 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	table				: CM_DataTable;
begin
	table := self.tblAttributes;
	
	self.myCurrentProdAttr.setValidation(cmbValidation.text);
	self.disableProdAttrCells(table.row, true);
