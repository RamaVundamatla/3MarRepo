    <JadeMethod name="picLoadMethod" id="1714603a-44e9-4462-ba51-e5d3ef74b195">
        <updating/>
        <source>picLoadMethod(_filename : String output) : Binary updating;
/*
Purpose:			

Date		Who		Reason
14OCT2021	NAVAB1	TFS 52401
*/

vars
	file		: File;
	cmdFile		: CMDFileOpen;
	thePic		: Binary;
	pos : Integer;
begin

	create cmdFile;
	cmdFile.dialogTitle	:= 'Select a picture file';
	cmdFile.initDir	:= 'c:\temp';
	
//	PictureType_None		: Integer = 0;		// Not a valid picture
//	PictureType_Bitmap		: Integer = 1;		// Bitmap
//	PictureType_NotUsed		: Integer = 2;		// Not used
//	PictureType_Icon		: Integer = 3;		// Icon
//	PictureType_Metafile	: Integer = 4;		// Metafile
//	PictureType_Cursor		: Integer = 5;		// Cursor
//	PictureType_TIF			: Integer = 6;		// Tag Image File Format (.tif file)
//	PictureType_JPEG		: Integer = 7;		// Joint Photographic Experts Group (JPEG)
//	PictureType_PNG			: Integer = 8;		// Portable Network Graphics (PNG)
//	PictureType_Gif			: Integer = 9;		// Graphic Interchange Format (GIF)
	
	cmdFile.filter := "Pictures(*.bmp;*.ico;*.jpg;*.gif;*.png;*.tiff)|*.bmp;*.ico;*.jpg;*.gif;*.png;*.tif"; 

	
	if cmdFile.open = 0 then
		create file;
		file.mode		:= file.Mode_Input;
		file.kind		:= file.Kind_Binary;
		file.fileName	:= cmdFile.fileName;
		
		if not file.tryOpen() then
			app.msgBox("Can't open picture file ' " &amp; file.fileName &amp; "'",
					   "Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return thePic;
		endif;
		
		_filename := file.name;
		if _filename= null then
			pos := file.fileName.reversePos("\");
			_filename := file.fileName[pos + 1:end];
		endif;
		
		
		thePic := file.readBinary(file.fileLength);
		if not thePic.isPictureValid then 
			app.msgBox("Invalid Picture file ' " &amp; file.fileName &amp; "'",
					"Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return null;
		endif;
	endif;
	
	return thePic;

epilog
	delete file;
	delete cmdFile;
end;</source>
        <Parameter name="_filename" type="String" usage="output"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="populateTable" id="5c60b617-3f8a-4825-8c5d-0fa941b37787">
        <updating/>
        <source>populateTable() updating;
 // ### TFS 50421 17SEP2021 NAVAB1
vars
	root : CMUI_Root;
	table : CM_DataTable;
	iconFile : CMUI_IconFile;
	dataline : String;
	idx, icon2002, icon2021 : Integer;
	temppic : Picture;
	icon : CMUI_IconFile;
	key : Binary;
begin
	app.mousePointer := Form.MousePointer_HourGlass;

	root := CMUI_Root.firstInstance;
	
	table := self.tblData;
	
	table.rows := table.fixedRows;
	table.selectMode := Table.SelectMode_CurrentRow;
	
	root := CMUI_Root.firstInstance;
	
	
	foreach iconFile in root.allIconFilesByName do
	
		dataline := iconFile.year.String &amp; Tab &amp;  iconFile.name  &amp; Tab &amp; iconFile.keyname &amp; Tab ;
			
		idx := table.addItemObject(iconFile, dataline);
		
		table.accessCell(idx,4).picture := iconFile.icon;
		table.accessedCell.alignment := Table.Alignment_Center_Top;
		table.accessRow(idx).height := 33;

		if iconFile.year = 2002 then
			icon2002 := icon2002 + 1;
		endif;
		if iconFile.year = 2021 then
			icon2021 := icon2021 + 1;
		endif;
		
		
	endforeach;
	
	
	self.btnLoadIcons.caption := "Load OLD Icons (" &amp; icon2002.String &amp; ")";
	self.btnLoadIconsNew.caption := "Load NEW Icons (" &amp; icon2021.String &amp; ")";

	app.mousePointer := Form.MousePointer_Default;

end;
</source>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="ee840fcf-9e56-4d0c-bda0-c590ccc63df1">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;

vars

begin
	if table.row &gt; table.fixedRows then
		return;
	endif;
	
	table.sortColumn[1] := table.column;
	table.sortAsc[1] := not table.sortAsc[1] ;
//		table.sortType[1]   := table.SortType_Alpha; // TFS 7496
	table.resort;
	

end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
</GUIClass>
