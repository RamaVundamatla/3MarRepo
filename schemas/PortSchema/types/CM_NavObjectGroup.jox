<Class name="CM_NavObjectGroup" id="88ea1538-5e7e-4d6e-a2e1-ee625eb2f1f6">
    <superclass name="CM_NavigationEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="navObj"/>
    <CompAttribute name="allNavObjectDefCodes" id="8aa626b7-ef01-47ab-851e-73ccb6fe3e10">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <ExplicitInverseRef name="myRoot" id="f7353f01-0b81-4c86-b36f-d9cd549f5dc8">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Root"/>
        <access>readonly</access>
        <Inverse name="CM_Root::allNavObjectGroups"/>
    </ExplicitInverseRef>
    <PrimAttribute name="name" id="7c83d307-8254-425d-9a04-a8e48e862d70">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="set" id="de504283-5772-453e-9c1d-680a7e844bd9">
        <updating/>
        <source>set(pName : String; pDefCodes : StringArray; pRoot : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     31 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name	:= pName;
	pDefCodes.copy(self.allNavObjectDefCodes);
	
	self.myRoot	:= pRoot;

end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pDefCodes" type="StringArray"/>
        <Parameter name="pRoot" type="CM_Root"/>
    </JadeMethod>
</Class>
