    <JadeMethod name="getCargoByBOL" id="3ffda20d-54e4-4a50-b84d-b1673e603e8f">
        <source>getCargoByBOL(_voyage : CM_Voyage; _bolId : String; _results : CM_TISet input);
// this is the same code as in the Cash Receipt screen to find cargo by voyage and BOL
vars
	ti	: CM_TrackedItem;
begin
	foreach ti in _voyage.allOnsiteTIsByIdCargoType do
		if ti.billOfLading  = _bolId then
			_results.add(ti);
		endif;
	endforeach;

end;
</source>
