    <JadeMethod name="myHandHeldAgent" id="02f57b39-420d-43bc-90c8-d6ef62b566c0">
        <methodInvocation>mapping</methodInvocation>
        <source>myHandHeldAgent(set: Boolean; _value: HandHeldAgent io) mapping;
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
