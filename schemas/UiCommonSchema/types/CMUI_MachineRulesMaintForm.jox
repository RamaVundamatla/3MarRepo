    <JadeMethod name="tblDataDisplayRow" id="f5721376-c4e8-480a-ac12-75f283d5aba7">
        <source>tblDataDisplayRow(_rule : CM_RTQueueMultiRule);

// Created by cnwdvb1 on 05 September 2006

vars

begin

	if _rule.isTATypeRule() then
		self.tblDataDisplayRowTAType(_rule.CM_RTQueueMultiRuleTAType);
	else
		self.tblDataDisplayRowMaster(_rule.CM_RTQueueMultiRuleTAMaster);
	endif;

end;</source>
