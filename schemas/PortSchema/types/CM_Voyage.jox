    <JadeMethod name="shouldAuditProperty" id="17fab55f-ae62-4422-9a0b-5894cbc4bb43">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//----------------------------------------------------------------
//	Created:	01 September 2005	by Jason Chapman  (cnwjc2)
// 08/06/2020 	cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 09/11/2022   navmv20 Bug 55318: LNX - Estimated Arrival/Departure and Actual Arrival/Departure dates are mismatched in audit
//----------------------------------------------------------------
vars

begin
	if _property = null or
		_property.name = CM_Voyage::tiPerHour.name or
		_property.name = CM_Voyage::seedJobNum.name or
		_property.name = CM_Voyage::seedJobNumLoad.name or
		//_property.name = CM_Voyage::myTerminalForGroupCode.name then //03/06/2020 cnwma1 TFS #49400 		//09/11/2022 navmv20 TFS 55318
		//START - 09/11/2022 navmv20 TFS 55318
		_property.name = CM_Voyage::myTerminalForGroupCode.name or
		_property.name = CM_Voyage::arrivedDT.name or
		_property.name = CM_Voyage::departedDT.name or
		_property.name = CM_Voyage::estimatedArrivalDT.name or
		_property.name = CM_Voyage::estimatedDepartureDT.name then
		//END - 09/11/2022 navmv20 TFS 55318
		return false;						
	endif;

	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
