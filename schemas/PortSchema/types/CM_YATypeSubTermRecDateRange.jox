    <JadeMethod name="isCMIFDataMatch" id="3da63a5f-9201-4487-8c8b-3afb7fd5e776">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YAData): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/05/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars
	ti : CM_TrackedItem;
	trans : CM_TITransaction;
	reserveCriteria : CM_ReleaseByTypeCriteria;
	criteria : CM_YACriteria;
	startDate, endDate : Date;

begin
	startDate := null;
	endDate := null;
	
	ti := _cmifAutoPlan.getMyTrackedItem;
	if ti &lt;&gt; null then
		foreach trans in ti.allTransactions discreteLock do
			if trans.isSubTermRecOrRel or (trans.isInternalReceive and not trans.isInternalRelease) then
				if trans.dateTime.date &gt;= _yaData.CM_YADataDateRange.startDate and trans.dateTime.date &lt;= _yaData.CM_YADataDateRange.endDate then
					return true;
				endif;
			endif;
		endforeach;
		
	else
		// We're a release request match criteria
		reserveCriteria := _cmifAutoPlan.getReserveSelectionCriteria();
		if reserveCriteria &lt;&gt; null then
			foreach criteria in reserveCriteria.allCriteria where criteria.myYACriteriaType.isSubTermRecDateRange do
				startDate := criteria.myYAData.CM_YADataDateRange.startDate;
				endDate := criteria.myYAData.CM_YADataDateRange.endDate;
				break;
			endforeach;
			
			if startDate.isValid then
				// Let's only match if the date range in the release request is entirely within the range on the yard allocation
				if startDate &gt;= _yaData.CM_YADataDateRange.startDate and startDate &lt;= _yaData.CM_YADataDateRange.endDate
				and endDate &gt;= _yaData.CM_YADataDateRange.startDate and endDate &lt;= _yaData.CM_YADataDateRange.endDate then
					return true;
				endif;
			endif;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YAData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSubTermRecDateRange" id="b554fb3f-e608-4fdb-bdf2-ee38ec99fe08">
        <source>isSubTermRecDateRange(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/06/2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
