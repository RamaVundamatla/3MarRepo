    <JadeMethod name="doResizeControls" id="3ae918e9-d094-417a-80ac-7f0707a0f7ae">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2015	cnwndl1	Initial creation	Par 35406

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - self.getSearchButtonSpace();
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move(	self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	//epr par 33025 20/11/13
	cHeight:= (self.clientHeight - cTop  - self.getCMDButtonsHeight() - self.resizedMargin - self.resizedMargin); //- margin); //- 
	if _initialSetup then
		self.tblStops.setAndIncrementTabIndex( tabIndex );
		self.tblStops.visible := true;
	endif;
	self.tblStops.move(	self.resizedMargin, 
						cTop, 
						stdWidth, 
						cHeight);

	if _initialSetup then
		self.setupTable();
	else
		self.tblStops.cnAdjustColumnWidths();
	endif;
	self.tblStops.cnAdjustLastColumn(); 
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="1ec61482-e0af-4b6f-81a8-572a42efbade">
        <updating/>
        <source>doSave() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:	16 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
	extraFields : IntegerArray;
	extraFieldValues : StringArray;
	inputForm : MOB_HandHeldInputForm;
begin
	
	if self.myTrackedItem = null then
		self.msgBox(app.getErrorString(NO_Container_selected), app.getErrorString(Error), MsgBox_OK_Only, false);
		return false;
	endif;
	
	create extraFields transient;
	self.getSessionAgent().findIfStopsRemovalNeedsInfo( tblStops, extraFields, self.myTrackedItem );
	if extraFields.size &lt;&gt; 0 then
		create inputForm transient;
		create extraFieldValues transient;
		inputForm.init(extraFields);
		if inputForm.showModal() =  IDOK then
			inputForm.getValues( extraFieldValues );
		else
			// They hit cancel so that's it
			return false;
		endif;
	endif;
	return self.getSessionAgent().updateStops(  self.myTrackedItem,tblStops, extraFields, extraFieldValues );
epilog
	delete inputForm;
	delete extraFields;
	delete extraFieldValues;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="3edb0dc4-e03f-485f-ab11-fbc7237ea42a">
        <updating/>
        <source>handleBtnOne() updating, protected;
// ---------------------------------------------------------------------------
// Created:	31 December 2008 By Graeme Black cnwgb1
// Purpose:	Edit/Save Button
// ---------------------------------------------------------------------------
vars
begin
	if self.btnOne.caption = app.getErrorString(Edit) then
		self.setForEdit();
	elseif self.btnOne.caption = app.getErrorString(Save) then
		if somethingChanged then
			if self.doSave() then
				somethingChanged := false;
				self.displayStops();
			endif;
		endif;
	endif;
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
