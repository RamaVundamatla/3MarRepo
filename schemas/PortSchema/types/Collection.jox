    <JadeMethod name="includesAny" id="ca40c59f-0617-4b5c-baf1-0c79f547b14e">
        <source>includesAny( _coll : Collection input) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2019	jlger1	Initial creation TFS 47132

*/

vars
	obj : Object;
	iter : Iterator;
begin
	if _coll.first = null then
		return false;
	endif;
	iter := self.createIterator;
	while iter.next(obj) do
		if _coll.includes(obj) then
			return true;
		endif;
	endwhile;
	
	return false;
epilog
	delete iter;
end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isNotEmpty" id="de818e18-d742-4127-8b98-a76463767180">
        <source>isNotEmpty(): Boolean;
begin
	return (not self.isEmpty);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listString" id="c39321dd-7f4e-410e-9adc-b179f2ef0e5a">
        <source>listString(_delim : String; _attrName : String) : String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 Apr 2007	cnwer1	Initial creation - PAR#xxxx
04 Oct 2023	navma1  ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
*/
vars
	obj  			: Object;
	str 			: String;
	iter 			: Iterator;
	invalidObject	: Boolean;
	edition			: Integer;
begin
	on Exception do app.handleDeletedObject(exception, obj, invalidObject);
	
	iter := self.createIterator;
	
	while iter.next(obj) do
		
		invalidObject := false;
		edition 	  := obj.edition;
		
		if invalidObject then
			continue;
		endif;
		
		if str &lt;&gt; null then
			str := str &amp; _delim;
		endif;
		
		str := str &amp; obj.getPropertyValue(_attrName).String.trimBlanks;
	endwhile;

	return str;

epilog
	delete iter;
end;</source>
        <Parameter name="_delim" type="String"/>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="listStringNoDuplicate" id="aba06050-09c0-4953-89b6-99355a1efd92">
        <source>listStringNoDuplicate(_delim : String; _attrName : String) : String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
04 Aug 2023	navlw1	ChangeRequest 59284:[59660] EUP | FR - VAS Work Order Transactions - Fixing Duplicate Values 
*/
vars
	obj     : Object;
	str     : String;
	iter    : Iterator;
	attrStr : String;
	invalid	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, obj, invalid);
	
	iter := self.createIterator;
	while iter.next(obj) do
		obj.edition;
		if invalid then
			continue;
		endif;
		
		attrStr := obj.getPropertyValue(_attrName).String.trimBlanks;
		
		if attrStr &lt;&gt; null and not str.cnContains(attrStr)then
			if str &lt;&gt; null then
				str :=  str &amp; _delim &amp; attrStr ;
			else
				str := attrStr;
			endif;
		endif;
	endwhile;

	return str;

epilog
	delete iter;
end;</source>
        <Parameter name="_delim" type="String"/>
        <Parameter name="_attrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="membersSame" id="b7bc12af-b7e5-4490-8aa0-d6667cdf2562">
        <source>membersSame(coll :Collection) :Boolean;

vars
	selfAny,
	collAny : Any;
	iterSelf,
	iterColl: Iterator;

begin

	if self.size &lt;&gt; coll.size then
		return false;
	endif;	

	if self.size = 0 and coll.size = 0 then
		return true;
	endif;	

	iterSelf := self.createIterator;
	iterColl := coll.createIterator;

	//iterSelf.reset; 
	//iterColl.reset;

	while iterSelf.next(selfAny) and iterColl.next(collAny) do 
 		if selfAny &lt;&gt; collAny then
			return false;                     		
		endif;	
    endwhile;

   return true;
epilog
	delete iterSelf;    
	delete iterColl;    
end;</source>
        <Parameter name="coll" type="Collection"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="noDuplicatesExceptionhandler" id="1bbade93-5ae5-4a35-bae9-46dbef907ca5">
        <source>noDuplicatesExceptionhandler(exObj : Exception;_hasDuplicate : Boolean io) : Integer;

constants
	ObjectAlreadyInCol = 1309;
	DuplicateKey = 1310;
vars
	errorCode : Integer;		
begin
	errorCode := exObj.errorCode;
	
	// Is this one of the errors we want to handle...?	
	if errorCode = ObjectAlreadyInCol or errorCode = DuplicateKey then
		// ...Yes, so resume back to the method that armed us
		_hasDuplicate:=true;
		return Ex_Resume_Next;
	endif;

	// Otherwise an unexpected error, so pass back to the next handler
	return Ex_Pass_Back;
end;
</source>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_hasDuplicate" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateFromXMLElement" id="a0b860f3-9f52-4d17-8840-8a3ace6aa4a3">
        <lockReceiver/>
        <updating/>
        <source>populateFromXMLElement(_element: JadeXMLElement;
					   _createdObjects : ObjectSet input) updating, lockReceiver;

/*

Purpose:			Inverse of populateXMLElement - populate the receiver from an XML element
					containing XML representations of its members


Return Value:		None.
					Will populate _createdObjects with any other objects created below the receiver
					in a hierarchy, to allow the caller to tidy them up

Date		Who		Reason
12 Dec 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	member			: Any;
	obj				: Object;
	memberElement	: JadeXMLElement;
	memberType		: Type;
	iter			: Iterator;
	membersArePrim  : Boolean;
	
begin
	// For primitive arrays, determine type once
	memberType := self.class.CollClass.memberType;
	membersArePrim := memberType.isKindOf(PrimType);
	
	iter := _element.childNodes.createIterator;
	while iter.next(memberElement) do
		if membersArePrim then
			self.add(memberElement.text.asAnyOfType(memberType));
		else
			obj := memberElement.returnAsObject(self.isTransient, _createdObjects);
			if obj &lt;&gt; null then
				_createdObjects.add(obj);
				self.add(obj);
			endif;
		endif;
	endwhile;
		

epilog
	delete iter;
	
end;</source>
        <Parameter name="_element" type="JadeXMLElement"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateXMLElement" id="46c28112-00a4-47b7-82ed-f39f7a0d58bd">
        <source>populateXMLElement(_element: JadeXMLElement input;
				   _processedObjects: ObjectSet input);

/*

Purpose:			


Return Value:		


Date		Who		Reason
12 December 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	member			: Any;
	obj				: Object;
	newElement		: JadeXMLElement;
	memberTag		: String;
	
begin
	// For primitive arrays, set up the member tag name once
	memberTag := self.class.CollClass.memberType.name;
	
	_element.addAttribute("membership", memberTag);
	_element.addAttribute("size", self.size.String);
	
	foreach member in self do
	
		if member.isKindOf(Object) then
			obj := member.Object;
			if obj &lt;&gt; null and obj.canConvertToXML then
				newElement := _element.addElement(obj.class.name);
				obj.populateXMLElement(newElement, _processedObjects);
			endif;
		else
			newElement := _element.addElement(memberTag);
			newElement.setText(member.String);
		endif;
	
	endforeach;
	

epilog

end;</source>
        <Parameter name="_element" type="JadeXMLElement" usage="input"/>
        <Parameter name="_processedObjects" type="ObjectSet" usage="input"/>
    </JadeMethod>
