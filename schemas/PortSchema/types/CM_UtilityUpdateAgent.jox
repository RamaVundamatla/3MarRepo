    <JadeMethod name="utlUpdateDebtorAddress" id="5090979c-06ff-4e44-ac19-9de6ad393c49">
        <updating/>
        <source>utlUpdateDebtorAddress(_pxyAddress : CM_Address input ; _realAddress : CM_Address output; _passport  : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle

*/

vars
	realAddress 	: CM_Address;
	expectedEdition	: Integer;

begin
	self.initialiseActivity();

	_pxyAddress.raiseExceptionIfNotProxy(method);
	_pxyAddress.pxyGetRealObjectAndEdition(realAddress, expectedEdition);
	
	if realAddress = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Address.name, null, null);
		return;
	endif;
	
	app.myValUA.valDebtorAddress( _pxyAddress );
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realAddress);

	if _passport.noErrors and realAddress.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Address', null, null);
		return;
	endif;
	
	if _passport.noErrors and realAddress.myDebtor &lt;&gt; null  then
		self.myUpdateAuditAgent.audUpdateGeneric(realAddress.myDebtor, true);
	endif;
	
	if _passport.noErrors then
		realAddress.setForUpdate(_pxyAddress);
	endif;

	if _passport.noErrors  and realAddress.myDebtor &lt;&gt; null  then
		self.myUpdateAuditAgent.audUpdateGeneric(realAddress.myDebtor, false);
	endif;

epilog

end;</source>
        <Parameter name="_pxyAddress" type="CM_Address" usage="input"/>
        <Parameter name="_realAddress" type="CM_Address" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDebtorAndParties" id="19839bf6-a2f3-47b1-9736-5e329877874f">
        <updating/>
        <source>utlUpdateDebtorAndParties(_cmifDebtor : CMIF_DebtorNode input; _realDebtor : CM_Debtor io; _createIfMissing : Boolean; _updateEntityDescriptions : Boolean; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/04/2022	navdap1		Initial creation TFS 53362 EUP Master Data interface customers between TOS and ERP
// 08/08/2022	navmd1		TFS 54664 Refactor to make this handle multiple related entities of the same type
// 09/05/2023   navsp1      ChangeRequest 57447: EUP - Customer Update - Process Customer info from API method
// 16/05/2023   navra1      ChangeRequest 57447: EUP - Customer Update - Process Customer info from API method
// 21/06/2023`	navmd1		TFS 57447 (yes, the 3rd person working on this) Fixes and refactoring
vars
	pxyDebtorNode, realDebtorNode : CM_DebtorNode;
	isCreate : Boolean;
	expectedEdition : Integer;
	pxyCarrier : CM_Carrier;
	pxyConsign : CM_ConsigneeConsignor;
	pxyCustomsAgents : CM_CustomsAgent;
	pxyOperator : CM_Operator;
	pxyShippingLine : CM_ShippingLine;
	pxyStevedore : CM_Stevedore;
	auditCreate : CM_CreateTransactionAuditAgent;
	oidAsHex : String;
	autoGenerateId : String;
	pxyAddress, realAddress : CM_Address;											//navra1 - TFS 57447 - 17th May 2023
	cmifAddress	: CMIF_Address;														//navra1 - TFS 57447 - 17th May 2023
	otherAddressesByCodeCm : CM_AddressByCode;										//navra1 - TFS 57447 - 18th May 2023
	realObject : CM_Object;
	debtorHexOid : String;
	carrierCount, consignCount, custAgentCount, operCount, shipCount, stevCount : Integer;
	country : CM_Country;
	twoCharCountryCode : String;
	first : Boolean;
begin
	self.initialiseActivity();
	
	pxyDebtorNode := _cmifDebtor.myPxyDebtorNode;
	
	// We're expecting a CM_Debtor NOT a CM_Debtor node. Complain otherwise
	if not pxyDebtorNode.isKindOf(CM_Debtor) then
		app.raiseUnexpectedProgramError(self.class.name, method.name, "CM_Debtor expected, but got CM_DebtorNode");
		return;
	endif;
	
	if _realDebtor &lt;&gt; null then
		pxyDebtorNode.raiseExceptionIfNotProxy(method);
		pxyDebtorNode.pxyGetRealObjectAndEdition(realDebtorNode, expectedEdition);
		if realDebtorNode = null then	
			app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DebtorNode.name, null, null);
			return;
		endif;
	else
		pxyDebtorNode.raiseExceptionIfNotTransient(method);
		isCreate := true;
	endif;

	app.setContinueCMExceptions(true);

	if isCreate then
		pxyDebtorNode.validateForCreate();
	else
		pxyDebtorNode.validateForUpdate();
	endif;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	// create the persistent debtor if we need to
	if isCreate then
		create realDebtorNode as _cmifDebtor.myPxyDebtorNode.class persistent;		
		
		//Check if any related entities using the auto generated code exists.  					//15.May.2023 navsp1 TFS 57447 &gt;&gt;&gt;&gt;
		//If it does, increment it.
		//If it does not, then break.
		oidAsHex := realDebtorNode.getOidAsHex.reverse;
		autoGenerateId := oidAsHex[1:4];// 4 characters
		debtorHexOid := autoGenerateId;
		while true do
			if _cmifDebtor.isAnyRelEntExistsWithSameCode(autoGenerateId) then
				autoGenerateId.incrementHex();
			else
				break;
			endif;			
		endwhile;																				//15.May.2023 navsp1 TFS 57447 &lt;&lt;&lt;&lt;
		
	else
		realDebtorNode := _realDebtor;
		
		oidAsHex := realDebtorNode.getOidAsHex.reverse;
		autoGenerateId := oidAsHex[1:4];// 4 characters
		debtorHexOid := autoGenerateId;
		
		carrierCount 	:= _realDebtor.allCarriers.size;
		consignCount 	:= _realDebtor.consignors.size;
		custAgentCount 	:= _realDebtor.allCustomsAgents.size;
		operCount 		:= _realDebtor.operators.size;
		shipCount 		:= _realDebtor.allShippingLines.size;
		stevCount 		:= _realDebtor.allStevedores.size;
		
	endif;
	
	// We need to grab the lock on the debtor early as instantiating empty collections bumps the owners edition
	// Which then breaks our edition checks later
	exclusiveLock(realDebtorNode);

	if not isCreate and _passport.noErrors and realDebtorNode.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'DebtorNode', null, null);
		return;
	endif;
	
	//Carrier
	if not _cmifDebtor.allCarriers.isEmpty then												//24.May.2023 navsp1 TFS 57447    &gt;&gt;&gt;&gt;
		foreach pxyCarrier in _cmifDebtor.allCarriers where pxyCarrier.isTransient do
			_cmifDebtor.createRelatedEntities(pxyCarrier, realObject, isCreate, autoGenerateId, debtorHexOid, _passport, _cmifDebtor, realDebtorNode, _createIfMissing, _updateEntityDescriptions, carrierCount);			
			if _passport.hasErrors then
				app.writeLog(method.qualifiedName &amp; "Passport has errors ("&amp;_passport.allErrors.first.text&amp;")", LogDEBUG);
				return;
			endif;
				
			_cmifDebtor.allCarriers.remove(pxyCarrier);
			_cmifDebtor.allCarriers.add(realObject.CM_Carrier);
		endforeach;
	endif;
	
	//Consignor
	if not _cmifDebtor.allConsignors.isEmpty then
		foreach pxyConsign in _cmifDebtor.allConsignors where pxyConsign.isTransient do
			_cmifDebtor.createRelatedEntities(pxyConsign, realObject, isCreate, autoGenerateId, debtorHexOid, _passport, _cmifDebtor, realDebtorNode, _createIfMissing, _updateEntityDescriptions, consignCount);			
			if _passport.hasErrors then
				app.writeLog(method.qualifiedName &amp; "Passport has errors ("&amp;_passport.allErrors.first.text&amp;")", LogDEBUG);
				return;
			endif;
				
			_cmifDebtor.allConsignors.remove(pxyConsign);
			_cmifDebtor.allConsignors.add(realObject.CM_ConsigneeConsignor);
		endforeach;
	endif;

	//CustomsAgent
	if not _cmifDebtor.allCustomsAgents.isEmpty then
		foreach pxyCustomsAgents in _cmifDebtor.allCustomsAgents where pxyCustomsAgents.isTransient do			
			_cmifDebtor.createRelatedEntities(pxyCustomsAgents, realObject, isCreate, autoGenerateId, debtorHexOid, _passport, _cmifDebtor, realDebtorNode, _createIfMissing, _updateEntityDescriptions, custAgentCount);			
			if _passport.hasErrors then
				app.writeLog(method.qualifiedName &amp; "Passport has errors ("&amp;_passport.allErrors.first.text&amp;")", LogDEBUG);
				return;
			endif;
				
			_cmifDebtor.allCustomsAgents.remove(pxyCustomsAgents);
			_cmifDebtor.allCustomsAgents.add(realObject.CM_CustomsAgent);
		endforeach;
	endif;
	
	//Operators
	if not _cmifDebtor.allOperators.isEmpty then
		foreach pxyOperator in _cmifDebtor.allOperators where pxyOperator.isTransient do			
			_cmifDebtor.createRelatedEntities(pxyOperator, realObject, isCreate, autoGenerateId, debtorHexOid, _passport, _cmifDebtor, realDebtorNode, _createIfMissing, _updateEntityDescriptions, operCount);			
			if _passport.hasErrors then
				app.writeLog(method.qualifiedName &amp; "Passport has errors ("&amp;_passport.allErrors.first.text&amp;")", LogDEBUG);
				return;
			endif;
				
			_cmifDebtor.allOperators.remove(pxyOperator);
			_cmifDebtor.allOperators.add(realObject.CM_Operator);
		endforeach;
	endif;
	
	//ShippingLine
	if not _cmifDebtor.allShippingLines.isEmpty then
		foreach pxyShippingLine in _cmifDebtor.allShippingLines where pxyShippingLine.isTransient do			
			_cmifDebtor.createRelatedEntities(pxyShippingLine, realObject, isCreate, autoGenerateId, debtorHexOid, _passport, _cmifDebtor, realDebtorNode, _createIfMissing, _updateEntityDescriptions, shipCount);			
			if _passport.hasErrors then
				app.writeLog(method.qualifiedName &amp; "Passport has errors ("&amp;_passport.allErrors.first.text&amp;")", LogDEBUG);
				return;
			endif;
				
			_cmifDebtor.allShippingLines.remove(pxyShippingLine);
			_cmifDebtor.allShippingLines.add(realObject.CM_ShippingLine);
		endforeach;
	endif;
	
	//Stevedore
	if not _cmifDebtor.allStevedores.isEmpty then
		foreach pxyStevedore in _cmifDebtor.allStevedores where pxyStevedore.isTransient do			
			_cmifDebtor.createRelatedEntities(pxyStevedore, realObject, isCreate, autoGenerateId, debtorHexOid, _passport, _cmifDebtor, realDebtorNode, _createIfMissing, _updateEntityDescriptions, stevCount);			
			if _passport.hasErrors then
				app.writeLog(method.qualifiedName &amp; "Passport has errors ("&amp;_passport.allErrors.first.text&amp;")", LogDEBUG);
				return;
			endif;
				
			_cmifDebtor.allStevedores.remove(pxyStevedore);
			_cmifDebtor.allStevedores.add(realObject.CM_Stevedore);
		endforeach;
	endif;																						//24.May.2023 navsp1 TFS 57447    &lt;&lt;&lt;&lt;
	
	// Addresses
	
	// Delete any addresses that no longer exist
	if not isCreate then
		foreach realAddress in realDebtorNode.CM_Debtor.allAddressesByCode do : outerLoop
			foreach cmifAddress in _cmifDebtor.addresses do
				if cmifAddress.code = realAddress.code then
					continue outerLoop;
				endif;
			endforeach;
			
			// Default addresses can't be deleted
			if realAddress.isDefault then
				continue;
			endif;
			
			// realAddress not found on CMIF, delete
			app.myUtilityDA.utlDeleteDebtorAddress(realAddress, _passport);
			
			// Again, ignore errors for now
		endforeach;
	endif;
	
	// Update existing / Create new addresses
	first := true;	// Assumption - the first address is always the Default one
	foreach cmifAddress in _cmifDebtor.addresses do
		realAddress := null;
		if not isCreate then
			if first then
				// The Default address can't be deleted, so just update it if it exists but is compeltely different
				realAddress := realDebtorNode.CM_Debtor.getDefaultDebtorAddress();
				// Make sure the Default flag is set
				cmifAddress.isDefault := true;
				first := false;
			else
				realAddress := realDebtorNode.CM_Debtor.allAddressesByCode[cmifAddress.code];
			endif;
		endif;
		
		if realAddress &lt;&gt; null then
			pxyAddress := app.createUpdateProxy(realAddress).CM_Address;
			if pxyAddress = null then
				continue;	// Something very wrong
			endif;
		else
			create pxyAddress transient;
		endif;
		
		country := CM_Country@lookupCountryByCode(cmifAddress.isoCountryCode);
		if country &lt;&gt;  null then
			twoCharCountryCode := country.code;
		else
			twoCharCountryCode := null;
		endif;
		
		pxyAddress.setProxy(cmifAddress.code, cmifAddress.description, cmifAddress.addr1, cmifAddress.addr2, cmifAddress.addr3, cmifAddress.region, cmifAddress.postCode,
								twoCharCountryCode, cmifAddress.city, cmifAddress.email, null, cmifAddress.isDefault, cmifAddress.isAlternative, realDebtorNode.CM_Debtor);						
		
		if realAddress &lt;&gt; null then
			app.myUtilityUA.utlUpdateDebtorAddress(pxyAddress, realAddress, _passport);
		else
			app.myUtilityCA.utlCreateDebtorAddress(pxyAddress, realAddress, _passport);
		endif;
		
		// Ignore any errors for now
		
		delete pxyAddress;
		pxyAddress := null;
	endforeach;
	
	// If we've hit any errors, now return
	if _passport.hasErrors then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	if not isCreate then
		self.myUpdateAuditAgent.audUpdateGeneric(realDebtorNode, true);
		
		if _passport.noErrors then
			realDebtorNode.setForUpdate(_cmifDebtor);
		endif;
		
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(realDebtorNode, false);
		endif;
		
		if _passport.noErrors then
			//app.myRoot.causeEvent(EVENT_DEBTORNODE_UPDATE, false, realDebtorNode);
		endif;
	else
		realDebtorNode.setForCreate(_cmifDebtor);
		
		if _passport.noErrors then
			create auditCreate transient;
			auditCreate.audCreateGeneric(realDebtorNode);
		endif;
		
		if _passport.noErrors then
			app.myRoot.causeEvent(EVENT_DEBTORNODE_CREATE, false, realDebtorNode);
		endif;
	endif;

epilog
	delete pxyAddress;
	delete auditCreate;
	delete otherAddressesByCodeCm;//26.May.2023 navsp1 TFS 57447
end;</source>
        <Parameter name="_cmifDebtor" type="CMIF_DebtorNode" usage="input"/>
        <Parameter name="_realDebtor" type="CM_Debtor" usage="io"/>
        <Parameter name="_createIfMissing" type="Boolean"/>
        <Parameter name="_updateEntityDescriptions" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateDebtorInvLineType" id="0a4fcc1d-fdef-45f3-bcc8-088e6bca5e72">
        <source>utlUpdateDebtorInvLineType(_proxyDebtorInvLineType : CM_DebtorInvLineType; _passport : CM_Passport input);
// 20 September 2011	cnwjre1	CCMS 2120 Electronic Invoicing
vars
	realDebtorInvLineType	: CM_DebtorInvLineType;
	expectedEdition	: Integer;

begin
	self.initialiseActivity();

	_proxyDebtorInvLineType.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyDebtorInvLineType.pxyGetRealObjectAndEdition(realDebtorInvLineType, expectedEdition);

	if realDebtorInvLineType= null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DebtorInvLineType.name, null, null);
		return;
	endif;

	app.myValUA.valDebtorInvLineType(_proxyDebtorInvLineType);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realDebtorInvLineType);

	if _passport.noErrors and realDebtorInvLineType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "debtorInvLineType", null, null);
		return;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDebtorInvLineType, true);
	endif;

	if _passport.noErrors then
		realDebtorInvLineType.setForUpdate(_proxyDebtorInvLineType);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realDebtorInvLineType, false);
	endif;

end;</source>
        <Parameter name="_proxyDebtorInvLineType" type="CM_DebtorInvLineType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
