<Class name="CM_TestDataProductCode" id="89c9660d-f8e9-4d73-9cdc-1de3bb5eb035">
    <superclass name="CM_TestDataEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="testData"/>
    <ImplicitInverseRef name="myProduct" id="b55304ad-1eb5-4655-8891-d515f379ccce">
        <embedded/>
        <type name="CM_Product"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myTestDataOperator" id="3259cd8e-3a5d-4b25-950c-5ed1fd943c78">
        <kind>child</kind>
        <embedded/>
        <type name="CM_TestDataOperator"/>
        <access>readonly</access>
        <Inverse name="CM_TestDataOperator::allTestProducts"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myTestDataRoot" id="8008363d-b41d-4a25-94b4-e9d5fca44d2f">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_TestDataRoot"/>
        <access>readonly</access>
        <Inverse name="CM_TestDataRoot::allTestProducts"/>
    </ExplicitInverseRef>
    <PrimAttribute name="operatorCode" id="c6e2bbd3-a7fd-4970-a3e1-0d9eaaf82832">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setForCreate" id="0bc2ecbc-8175-4a4c-8bac-2d92695a8c76">
        <updating/>
        <source>setForCreate(_operator : CM_Operator; _product : CM_Product) updating;

vars

begin

	self.operatorCode	:= _operator.code;
	self.myProduct		:= _product;

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="setIntFaceBOLIn" id="9ec9f54b-b3f7-4bae-9ae9-e87d9f2171bc">
        <source>setIntFaceBOLIn(intFaceBOLIn : CMIF_BOLIn input);

vars
	logProd	: CM_ProductLog;
begin

	intFaceBOLIn.myOperator		:= app.myRoot.allOperators[self.operatorCode];
	intFaceBOLIn.operatorCode 	:= self.operatorCode;

	if CM_ProductLog.hasInstance(self.myProduct) then
		logProd	:= self.myProduct.CM_ProductLog;
		
		intFaceBOLIn.logSpeciesCode 	:= logProd.speciesCode;
		intFaceBOLIn.lengthRandom 		:= logProd.lengthCode;
		intFaceBOLIn.logGradeCode 		:= logProd.gradeCode;
		intFaceBOLIn.logTypeCode 		:= logProd.typeCode;
		intFaceBOLIn.logTreatmentCode 	:= logProd.treatmentCode;
	endif;

end;</source>
        <Parameter name="intFaceBOLIn" type="CMIF_BOLIn" usage="input"/>
    </JadeMethod>
</Class>
