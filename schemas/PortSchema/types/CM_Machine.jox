    <JadeMethod name="canMachineMoveBreakBulkWeight" id="12ea97a4-51c6-4b47-918b-73a03cebfaaf">
        <source>canMachineMoveBreakBulkWeight(	_ti : CM_TrackedItem;
								_moveQuantity : Integer;
								_moveWeight : Decimal) : Boolean protected;
/*

Date		Who		Reason
06 November 2014	cnwer1	Initial creation PAR 35156
02 Jul 2024	jlika1	TFS 64996 CUX - CUX - Cargo Weight is Multiplied when Determining Machine Eligibility
*/

vars
	cargoType 				: CM_CargoType;
	onMachineCargoWeight,
	totalWeight				: Decimal[14,4];
	tiWeight				: Decimal[14,4];
begin
	if _ti = null then
		return true;
	endif;
	
	cargoType:=_ti.myCargoType;
	if not cargoType.isBreakBulkMulti and not cargoType.isBulkMulti then
		return true;
	endif;
	
	if not cargoType.isCheckMaxLift then
		return true;
	endif;
	
	onMachineCargoWeight:=self.getCargoWeightOnMachine(_ti);
	if cargoType.isBulkMulti then
		totalWeight := onMachineCargoWeight + _moveWeight;
		tiWeight := _moveWeight;
	else
		totalWeight := onMachineCargoWeight + ((_moveQuantity / _ti.totalQuantity) * _ti.totalWeight);
		tiWeight := ((_moveQuantity / _ti.totalQuantity) * _ti.totalWeight);
	endif;
	
	if totalWeight &gt; self.maxLiftWeight then		
		app.raiseCMException5(MACH_MAX_LIFT_WEIGHT,self.id.trimRight,self.maxLiftWeight.asStringWeightJMT,_ti.id.asStringJMT,tiWeight.asStringWeightJMT(), onMachineCargoWeight.asStringWeightJMT(),null,null);
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_moveQuantity" type="Integer"/>
        <Parameter name="_moveWeight" type="Decimal"/>
        <ReturnType type="Boolean"/>
