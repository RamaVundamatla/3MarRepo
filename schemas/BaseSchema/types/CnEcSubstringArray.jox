    <JadeMethod name="removeString" id="723f28e7-298f-452f-b82e-0c0f53d884b0">
        <lockReceiver/>
        <updating/>
        <source>removeString(pStringValue: String): Boolean updating, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		30 June 2001 by cnwdad1
//
// Purpose:		Removes an array element which has a specified string value.
//
// Parameters:	pStringValue (String) - The value to scan for in the array.
//
// Returns:		Boolean - True is an element was removed, false if not.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	elementsToDelete	: ObjectArray;
	deleteObj			: Object;
	substringObj		: CnEcSubstringObject;
	isRemoved			: Boolean;

begin
	create elementsToDelete transient;

	// Find the array elements to be removed.

	foreach substringObj in self do
		if substringObj.getStringValue() = pStringValue then
			elementsToDelete.add(substringObj);
		endif;
	endforeach;

	// Now removed the matching array elements.

	foreach deleteObj in elementsToDelete do
		self.remove(deleteObj.CnEcSubstringObject);

		if (not isRemoved) then
			isRemoved	:=	true;
		endif;
	endforeach;
epilog
	delete elementsToDelete;

	return isRemoved;
end;</source>
        <Parameter name="pStringValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
