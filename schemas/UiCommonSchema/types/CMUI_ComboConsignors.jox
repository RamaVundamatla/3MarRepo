    <JadeMethod name="displayEntry" id="d46cfb9c-baa8-42de-aa93-cc2c7d1f4bf1">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input;  _con : CM_ConsigneeConsignor; lstIndex: Integer): String updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     08 December 2004	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	failedDAC  :CM_DataAccessController;
	invalid : Boolean;
	str : String;
begin
	if _con = null then
		return null;
	endif;
	on Exception do app.handleDeletedObject(exception, _con, invalid);
	str := _con.code;
	if invalid then
		return null;
	endif;

	if (not _con.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;

	if _con.isNotAvailableForEntry then
		if self.myObject &lt;&gt; _con then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
	
	if self.type = CONSIGNOR_NULL_TYPE then
		// Continue.
// TFS 8120	elseif not _con.isFreightFwdr and  not _con.isConsignee and not _con.isConsignor then 
		// Continue
	elseif self.type = FREIGHT_FORWARDER and not _con.isFreightFwdr then
		return null;
	elseif self.type = CONSIGNEE and not _con.isConsignee then
		return null;
	elseif self.type = CONSIGNOR and not _con.isConsignor then
		return null; 
	endif;
	
	//Par 10110 - removed as causing performance issues, this should be set when initialised
	//self.consigneeConsignorCmbOrdDescr := app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean;	
	// above line added to prevent error if system config changed while certian forms are being edited. 
	// eg forms using GTE_Assistant::saveEntTblSpecial method

	if self.consigneeConsignorCmbOrdDescr then
		return _con.description.trimRight &amp; Tab &amp; _con.code.trimRight; // Par#13674 Mohammad 27/4/2007
 		//return _con.description.trimRight &amp; '  '&amp; _con.code.trimRight;
	else
		return _con.code.trimRight &amp; Tab &amp;  _con.description; // Par#13674 Mohammad 27/4/2007
		//return _con.code.trimRight &amp; '  ' &amp;  _con.description;
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_con" type="CM_ConsigneeConsignor"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="6e5118bb-4365-4385-9767-ffeba0da784d">
        <source>getCollectionJMT(): Collection protected;
// ---------------------------------------------------------------------------
// Created:     08 December 2004	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	
begin

	return app.myRoot.allConsigneeConsignors;
end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="init" id="1e8db747-a62c-49ba-87fb-638405d8d744">
        <updating/>
        <source>init() updating, protected;
//--------------------------------------------------
// Created:	13 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	consignDict		: CM_ConsignByCodeDict;
	idx				: Integer;
	displayStr,
	saveText		: String;
	consign			: CM_ConsigneeConsignor;
begin
	self.endNotificationForSubscriber(self);
	self.beginClassNotification(CM_ConsigneeConsignor, false, Any_System_Event, Response_Continuous, null);
	self.consigneeConsignorCmbOrdDescr := app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean;

	consignDict := app.myRoot.allConsigneeConsignors;
	
	if consignDict = null then
		self.amInitialised := false;
		return;
	endif;

	// save the current text as calling listCollection
	// clears the current text
	saveText := self.text;
	
	self.sorted := true;
	
	foreach consign in consignDict discreteLock do
		displayStr := self.displayEntry(self, consign, null);//listIndex param not used so OK to be null
		if displayStr = null then
			continue;
		endif;
		
		self.itemObject[self.addItem(displayStr)] := consign;
	endforeach;
	
	self.selLength := 1000;			
	idx := self.findString(1, saveText);

	if idx &gt; 0 then
		self.listIndex := idx;
		self.setEntryTableCell();
		self.text := saveText;
	else
		self.text := null;
	endif;
		
	self.amInitialised := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setType" id="982cdd33-57e1-4ce2-a896-607f2c683dad">
        <updating/>
        <source>setType(_type : Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 December 2006 By cnwmo1

