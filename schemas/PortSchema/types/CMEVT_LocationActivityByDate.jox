<CollClass name="CMEVT_LocationActivityByDate" id="3042d4c7-78eb-46d2-ba5a-411251090227">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CMEVT_LocationActivity"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="locationTransactions"/>
    <MemberKey>
