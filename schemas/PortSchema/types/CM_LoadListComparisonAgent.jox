    <JadeMethod name="compare" id="94cccdf9-617c-4373-be59-07426318babc">
        <updating/>
        <source>compare(_ignoreFields: StringArray;
		_passport: CM_Passport input;
//		_chkISOGroup : Boolean;  //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
		_compareStatus : Integer;
		_includeOnSiteDiffVoyage : Boolean;	//19 May 2010	NDL	Par 24243
		_excludeImportsAndStorage : Boolean;	//19 May 2010	NDL	Par 24243
		_excludeEmpty : Boolean	//19 May 2010	NDL	Par 24243
		) protected, updating;
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
//13 Aug 2015	cmwrs1	Par 36763 Change CargoComparison to Allow it to be run via Unit Test
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 30 Aug 2017	cnwrs1	TFS 6763 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	loadListTI	: CM_EDITrackedItem;
	matchedTI	: CM_EDILoadListComparisonTI;
	tisToRemove	: CM_EDITIById;
	igFields	: StringArray;
	passport	: CM_Passport;
	updateProg	: Boolean;
	intCount,
	tiTotal		: Integer;	
	realTi		: CM_TrackedItem;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	// Full matches go to allMatchingTIs
	// Part matches (id must match) go to allDiscrepancyTIs
	// The rest can stay where they are.
	
	create igFields transient;
	create tisToRemove transient;
	
	app.setContinueCMExceptions(true);
	
	self.setComparisonMode(_compareStatus); //PAR25362 cnwsh3 22/09/2010
	
	_ignoreFields.copy(igFields);
	passport := _passport;
	updateProg := passport.hasMonitor;
	tiTotal := self.allUnmatchedLLTIs.size;

	foreach loadListTI in self.allUnmatchedLLTIs do
		if CM_EDISealTI.hasInstance(loadListTI) then
			continue;
		endif;
		intCount := intCount + 1;
		progressInt := app.actualTimeServer() - progressTS;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null and 
		   updateProg and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgress("Comparing Load List to Exports...", tiTotal, intCount);
			progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		if self.allUnmatchedDBTIs.includesKey(loadListTI.id.toUpper) then
			//so the ids match at least - get it
			matchedTI := self.allUnmatchedDBTIs[loadListTI.id.toUpper].CM_EDILoadListComparisonTI;
			
			//compare it to the list ti
			//th2 added 25/01/07 - user defined types as loadlists
			if CM_EDICargoTI.hasInstance(loadListTI) then
				matchedTI.compareToUserDefinedTI(loadListTI.CM_EDICargoTI, igFields); //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
			else
				matchedTI.compareTo(loadListTI.CM_EDILoadListTI, igFields);	  //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
			endif;
			//perfect match?
			if matchedTI.allDiscrepancyAttributes.isEmpty then
				//matches ok
				self.allMatchingTIs.add(matchedTI);
			else
				//match with discrepancy
				self.allDiscrepancyTIs.add(matchedTI);
				
				//only do this for discrepancies - this is mainly so both items can be displayed in the table
				matchedTI.setMyDiscrepancyTI(loadListTI);
			endif;
			
			//removals
			self.allUnmatchedDBTIs.remove(matchedTI);
			tisToRemove.add(loadListTI);
		else
			
			//	26 Apr 2010	NDL	Par 23912 - If we get to here we have not found the trackeditem in the DB, this may be because
			//	its voyage is wrong ( but matching id ) so we wont have tried to find it in the 'getAllTisForVoyage' method.
			//  So a quick direct call against the terminals 'On site' and 'pre notes', and if we find the real one, 
			// we will add the discrepancy here.
			if _includeOnSiteDiffVoyage and _compareStatus = TI_IMEX_STATUS_EXPORT then				
				realTi := null;
				realTi := self.myVoyage.myTerminal.allNotifiedTIsByIdCargoType.getAtKey(loadListTI.id, loadListTI.cargoType);
				if realTi = null then
					realTi := self.myVoyage.myTerminal.allOnsiteTIsByIdCargoType.getAtKey(loadListTI.id, loadListTI.cargoType);
				endif;				
				
				if realTi = null then
					continue;
				endif;
				
				if _excludeImportsAndStorage then	//19 May 2010	NDL	Par 24243
					if realTi.getImExStatus() = TI_IMEX_STATUS_IMPORT or realTi.getImExStatus() = TI_IMEX_STATUS_STORAGE then
						realTi := null;
						continue;
					endif;
				endif;
				
				if _excludeEmpty then	//19 May 2010	NDL	Par 24243
					if realTi.isEmpty then
						realTi := null;
						continue;
					endif;
				endif;
				
				matchedTI := realTi.pxyCreateLoadListProxy(self.comparisonMode);
				
				// it will be a discrepancy on voyage, but check the other bits too (populates matchedTI.allDiscrepancyAttributes).
				if CM_EDICargoTI.hasInstance(loadListTI) then
					matchedTI.compareToUserDefinedTI(loadListTI.CM_EDICargoTI, igFields);  //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
				else
					matchedTI.compareTo(loadListTI.CM_EDILoadListTI, igFields);	 //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
				endif;
				matchedTI.allDiscrepancyAttributes.add(ETRow_VoyageCode);
				self.allDiscrepancyTIs.add(matchedTI);
				matchedTI.setMyDiscrepancyTI(loadListTI);
				tisToRemove.add(loadListTI);
				
			endif;
			// End of 23912.
			
			continue;
			
		endif;
	endforeach;

	//update the allUnmatchedLLTIs
	foreach loadListTI in tisToRemove do
		if self.allUnmatchedLLTIs.includes(loadListTI) then
			self.allUnmatchedLLTIs.remove(loadListTI);
		endif;	
	endforeach;
	
	app.myPassport.clearErrorsWarnings();

epilog
	if passport.myCMIFMonitor &lt;&gt; null then 
		passport.myCMIFMonitor.updateProgress("Comparing Load List to Exports...", tiTotal, tiTotal);
	endif;
	delete tisToRemove;
	delete igFields;
end;</source>
        <access>protected</access>
        <Parameter name="_ignoreFields" type="StringArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_compareStatus" type="Integer"/>
        <Parameter name="_includeOnSiteDiffVoyage" type="Boolean"/>
        <Parameter name="_excludeImportsAndStorage" type="Boolean"/>
        <Parameter name="_excludeEmpty" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doComparison" id="3c347f5e-1dc9-4a63-859e-5d626fe10a21">
        <updating/>
        <source>doComparison(	_ediLoadList: CM_EDIDataLoadList;
				_voyage: CM_Voyage;
				_ignoreFields: StringArray;
//				_checkISOGroup : Boolean; //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
				_operators: CM_OperatorSet;
				_compareStatus : Integer;
				_includeOnSiteDiffVoyage : Boolean;	//18 May 2010	NDL	Par 24243
				_excludeImportsAndStorage : Boolean;	//18 May 2010	NDL	Par 24243
				_excludeEmpty : Boolean;	//18 May 2010	NDL	Par 24243
				_passport: CM_Passport
				) : Boolean updating;
//				) updating;					// cnwrl1 09/08/2010 PAR 24337 - what it was
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
//09/08/2010	cnwrl1		PAR 24337 - UE 4 from CM_LoadListComparisonAgent.
//13 Aug 2015	cmwrs1	Par 36763 Change CargoComparison to Allow it to be run via Unit Test
vars
	skipMsg		: Boolean;					// cnwrl1 09/08/2010 PAR 24337
	isInvalid	: Boolean;					// cnwrl1 09/08/2010 PAR 24337
	iEdition	: Integer;					// cnwrl1 09/08/2010 PAR 24337
	passport	: CM_Passport;
	
begin
	passport := _passport;
	self.comparisonComplete := false;
	self.setComparisonMode(_compareStatus); //PAR25362 cnwsh3 22/09/2010
	
	// cnwrl1 09/08/2010 PAR 24337 - start of coding
	// Attempt to validate all of the potential data that could have been deleted by a user.
	on Exception do app.handleDeletedObject( exception, _ediLoadList, isInvalid );
	// Check availability by doing a de-reference
	iEdition	:= _ediLoadList.edition();
	if isInvalid then
		self.validateAgentReferences( _ediLoadList );
		skipMsg	:= true;
		return false;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _voyage, isInvalid );
	// Check availability by doing a de-reference
	iEdition	:= _voyage.edition();
	if isInvalid then
		self.validateAgentReferences( _voyage );
		skipMsg	:= true;
		return false;
	endif;
	// cnwrl1 09/08/2010 PAR 24337 - end of coding
	
	//--------------------------------------------------------------------
	//	Clear collections
	//--------------------------------------------------------------------
	if passport.myCMIFMonitor &lt;&gt; null then
		passport.myCMIFMonitor.updateProgress(app.getErrorString(Initializing), 5, 0);
	endif;
	self.initialise(_voyage, _operators, _ediLoadList);
	
	//--------------------------------------------------------------------
	// Set unmatched LL TIs
	//--------------------------------------------------------------------
	if passport.myCMIFMonitor &lt;&gt; null then
		passport.myCMIFMonitor.updateProgress(app.getErrorString(Initializing), 5, 1);
	endif;
	self.myEDILoadList.allEDITrackedItems.copy(self.allUnmatchedLLTIs);
	
	//--------------------------------------------------------------------
	// Set unmatched DB TIs
	//--------------------------------------------------------------------
	if passport.myCMIFMonitor &lt;&gt; null then
		passport.myCMIFMonitor.updateProgress(app.getErrorString(Initializing), 5, 2);
	endif;
	self.getTIsForVoyage(_compareStatus, passport);	//step 3 and 4 in here //ccms1690 cnwrs1 mar 2008

	//--------------------------------------------------------------------
	//	Do the comparison and put the matches in the appropriate collection
	//--------------------------------------------------------------------
	if passport.myCMIFMonitor &lt;&gt; null then
		passport.myCMIFMonitor.updateProgress(app.getErrorString(Initializing), 5, 5);
	endif;
	self.compare(	_ignoreFields,
					passport,
//					_checkISOGroup, //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
					_compareStatus,
					_includeOnSiteDiffVoyage,	//18 May 2010	NDL	Par 24243
					_excludeImportsAndStorage,	//18 May 2010	NDL	Par 24243
					_excludeEmpty	//18 May 2010	NDL	Par 24243
					);

	//--------------------------------------------------------------------
	// If we get to this point all is well
	//--------------------------------------------------------------------
	self.comparisonComplete := true;
	return true;							// cnwrl1 09/08/2010 PAR 24337

epilog
//	if not self.comparisonComplete then			// cnwrl1 09/08/2010 PAR 24337 - what it was
	if not skipMsg and not self.comparisonComplete then
		app.raiseUnexpectedProgramError(class.name, method.name,app.getErrorString(Error_loaddis_list_compari));
	endif;
end;
</source>
        <Parameter name="_ediLoadList" type="CM_EDIDataLoadList"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_ignoreFields" type="StringArray"/>
        <Parameter name="_operators" type="CM_OperatorSet"/>
        <Parameter name="_compareStatus" type="Integer"/>
        <Parameter name="_includeOnSiteDiffVoyage" type="Boolean"/>
        <Parameter name="_excludeImportsAndStorage" type="Boolean"/>
        <Parameter name="_excludeEmpty" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doComparisonVoyagePorts" id="3e4ede39-a00f-4914-9872-d5c7c976ae86">
        <updating/>
        <source>doComparisonVoyagePorts(_voyage : CM_Voyage; _passport : CM_Passport) updating;
/*
Date		Who		Reason
24 November 2009	cnwas3	Initial creation
*/
vars
	ti 					: CM_TrackedItem;
	loadListComparisonTI: CM_EDILoadListComparisonTI;
	transhipPorts		: CM_PortArray;
	dischargePorts	 	: CM_PortArray;
	port				: CM_Port;
	portRotation		: CM_PortRotation;	
	passport 			: CM_Passport;
	missplacedTranship	: Boolean;
	skipMsg				: Boolean;					// cnwrl1 09/08/2010 PAR 24337
	isInvalid			: Boolean;					// cnwrl1 09/08/2010 PAR 24337
	iEdition			: Integer;					// cnwrl1 09/08/2010 PAR 24337
	
begin
	self.comparisonComplete := false;
	
	// cnwrl1 09/08/2010 PAR 24337 - start of coding
	// Attempt to validate all of the potential data that could have been deleted by a user.
	on Exception do app.handleDeletedObject( exception, _voyage, isInvalid );
	// Check availability by doing a de-reference
	iEdition	:= _voyage.edition();
	if isInvalid then
		self.validateAgentReferences( _voyage );
		skipMsg	:= true;
		return;
	endif;
	// cnwrl1 09/08/2010 PAR 24337 - end of coding
	
	dischargePorts := _voyage.allPorts;
	
	passport := _passport;
	
	self.getAllTIsForVoyage(_voyage, passport);
	
	create transhipPorts transient;
	
	foreach portRotation in _voyage.allPortRotations discreteLock where portRotation.allTranshipPorts.size() &gt; 0 do
		foreach port in portRotation.allTranshipPorts discreteLock where not transhipPorts.includes(port) do
			transhipPorts.add(port);
		endforeach;
	endforeach;
	
	foreach ti in self.allTIsOnTerminal discreteLock do
		//checking for removed discharge ports
		if ti.dischargePort &lt;&gt; null and not dischargePorts.includes(app.myRoot.allPorts[ti.dischargePort]) then
			loadListComparisonTI := ti.pxyCreateLoadListProxy(self.comparisonMode);//22/09/2010 - cnwsh3	method signature change PAR25362
			self.allDiscrepancyPortsTIs.add(loadListComparisonTI);
		endif;
		//checking for removed tranship ports
		if ti.myTranshipToPort &lt;&gt; null and not transhipPorts.includes(ti.myTranshipToPort) then
			loadListComparisonTI := ti.pxyCreateLoadListProxy(self.comparisonMode);//22/09/2010 - cnwsh3	method signature change PAR25362
			self.allDiscrepancyTranshipsTIs.add(loadListComparisonTI);
		endif;
		//checking for tranship ports that have been moved under different discharge ports
		if ti.dischargePort &lt;&gt; null and ti.myTranshipToPort &lt;&gt; null then
			missplacedTranship := true;
			foreach portRotation in _voyage.allPortRotations discreteLock where portRotation.allTranshipPorts.size() &gt; 0 and portRotation.myPort = app.myRoot.allPorts[ti.dischargePort] do
				foreach port in portRotation.allTranshipPorts discreteLock where port = ti.myTranshipToPort do
					missplacedTranship := false;
				endforeach;
			endforeach;
			if missplacedTranship then
				loadListComparisonTI := ti.pxyCreateLoadListProxy(self.comparisonMode);//22/09/2010 - cnwsh3	method signature change PAR25362
				self.allDiscrepancyTranshipsTIs.add(loadListComparisonTI);
			endif;
		endif;
		
	endforeach;
	
	self.comparisonComplete := true;
	
epilog
//	if not self.comparisonComplete then		// cnwrl1 09/08/2010 PAR 24337 - what it was
	if not skipMsg and not self.comparisonComplete then
		app.raiseUnexpectedProgramError(class.name, method.name,app.getErrorString(Error_voyage_details_compari));
	endif;
	delete transhipPorts;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getAllTIsForVoyage" id="1c252bf5-86ba-409e-b39f-309d4d871f45">
        <updating/>
        <source>getAllTIsForVoyage(_voyage : CM_Voyage;_passport: CM_Passport input) updating;

/*
Date		Who		Reason
24 November 2009	cnwas3	Initial creation
*/
//13 Aug 2015	cmwrs1	Par 36763 Change CargoComparison to Allow it to be run via Unit Test
vars
	ti 					: CM_TrackedItem;
	tranShipImportDict,
	tranShipExportDict	: CM_TIByIdCargoTypeDict;

begin
	self.initialise(_voyage, null, null);
	
	self.allTIsOnTerminal.clear();
	self.allDiscrepancyPortsTIs.clear();
	self.allDiscrepancyTranshipsTIs.clear();
	//process.debugAdi();
	tranShipImportDict := self.myVoyage.allTranshipTIsImport;
	tranShipExportDict := self.myVoyage.allTranshipTIsExport;	

	if _passport.myCMIFMonitor &lt;&gt; null then
		_passport.myCMIFMonitor.updateProgress(app.getErrorString(Initializing), 5, 3);
	endif;
	//notified exp cargo
	foreach ti in self.myVoyage.allNotifiedTIsByCargoTypeId discreteLock do
		if not self.allTIsOnTerminal.includesKey(ti.id)  then
			self.allTIsOnTerminal.add(ti);	
			//self.allDiscrepancyTIs.add(ti.pxyCreateLoadListProxy);
		endif;
	endforeach;
	
	if _passport.myCMIFMonitor &lt;&gt; null then
		_passport.myCMIFMonitor.updateProgress(app.getErrorString(Initializing), 5, 4);
	endif;
	//onsite exp cargo
	foreach ti in self.myVoyage.allOnsiteTIsByCargoTypeId discreteLock do
		if not self.allTIsOnTerminal.includesKey(ti.id) then
			self.allTIsOnTerminal.add(ti);			
		endif;
	endforeach;


	foreach ti in self.myVoyage.allOnshipTIsByCargoTypeId discreteLock do
		if not self.allTIsOnTerminal.includesKey(ti.id) then
			self.allTIsOnTerminal.add(ti);			
		endif;
	endforeach;

	// TFS 45590
	foreach ti in self.myVoyage.allTbaTIsByCargoTypeId discreteLock do
		if not self.allTIsOnTerminal.includesKey(ti.id) then
			self.allTIsOnTerminal.add(ti);			
		endif;
	endforeach;
	
	foreach ti in self.myVoyage.allRRPTIsByCargoTypeId discreteLock do	//31 Mar 2020	NDL	TFS 47004
		self.allTIsOnTerminal.add(ti);			
	endforeach;

	foreach ti in tranShipImportDict discreteLock do
		if not self.allTIsOnTerminal.includesKey(ti.id) then
			self.allTIsOnTerminal.add(ti);			
		endif;
	endforeach;
	
	foreach ti in tranShipExportDict discreteLock do
		if not self.allTIsOnTerminal.includesKey(ti.id) then
			self.allTIsOnTerminal.add(ti);			
		endif;
	endforeach;

	if _passport.myCMIFMonitor &lt;&gt; null then
		_passport.myCMIFMonitor.updateProgress(app.getErrorString(Initializing), 5, 5);
	endif;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTIsForVoyage" id="73f3253c-8daf-48ae-baa4-174425f521e8">
        <updating/>
        <source>getTIsForVoyage(_compareStatus : Integer; _passport: CM_Passport input) protected, updating;
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//13 Aug 2015	cmwrs1	Par 36763 Change CargoComparison to Allow it to be run via Unit Test
//08 Oct 2015   cnwma1  PAR 36537 Error 1309 in Cargo Comparison
vars
	ti, 
	ti2 					: CM_TrackedItem;
	tranShipDict			: CM_TIByIdCargoTypeDict;
	currPortDestCode 		: String;
	loadListComparisonTI 	: CM_EDILoadListComparisonTI;	
begin
	if _compareStatus = TI_IMEX_STATUS_IMPORT then //par 16600 cnwrs1 comparison status match ti imexStatus
		currPortDestCode := self.myVoyage.myTerminal.getConfig(PortDestCode).String.trimBlanks();
		tranShipDict := self.myVoyage.allTranshipTIsImport;
	else
		tranShipDict := self.myVoyage.allTranshipTIsExport;
	endif;
	
	self.allTIsOnTerminal.clear();//ccms 1096
	
	// DVB Par 15187 Added discrete locking to free up dicts.
	if _passport.myCMIFMonitor &lt;&gt; null then
		_passport.myCMIFMonitor.updateProgress(app.getErrorString(Initializing), 5, 3);
	endif;
	// search for duplicates first
	foreach ti in self.myVoyage.allNotifiedTIsByCargoTypeId discreteLock do
		foreach ti2 in self.myVoyage.allOnsiteTIsByCargoTypeId discreteLock do
			if ti.id = ti2.id then
				self.allDuplicateTIsOnTerminal.addNoDuplicates(ti,false);
				self.allDuplicateTIsOnTerminal.addNoDuplicates(ti2,false);
			endif;
		endforeach;	
		foreach ti2 in self.myVoyage.allOnshipTIsByCargoTypeId discreteLock do
			if ti.id = ti2.id then
				self.allDuplicateTIsOnTerminal.addNoDuplicates(ti,false);
				self.allDuplicateTIsOnTerminal.addNoDuplicates(ti2,false);
			endif;
		endforeach;	
	endforeach;
	foreach ti in self.myVoyage.allOnshipTIsByCargoTypeId discreteLock do
		foreach ti2 in self.myVoyage.allOnsiteTIsByCargoTypeId discreteLock do
			if ti.id = ti2.id then
				self.allDuplicateTIsOnTerminal.addNoDuplicates(ti,false);
				self.allDuplicateTIsOnTerminal.addNoDuplicates(ti2,false);
			endif;
		endforeach;
	endforeach;
		
	//notified exp cargo
	foreach ti in self.myVoyage.allNotifiedTIsByCargoTypeId discreteLock do
		if self.includeTI(ti, _compareStatus) and  //ccms1690 cnwrs1 mar 2008
		   (not self.allTIsOnTerminal.includes(ti)) and
		   (not self.allDuplicateTIsOnTerminal.includes(ti)) then
			self.allTIsOnTerminal.add(ti);
			loadListComparisonTI := ti.pxyCreateLoadListProxy(self.comparisonMode);//22/09/2010 - cnwsh3	method signature change PAR25362
			self.allUnmatchedDBTIs.add(loadListComparisonTI);
		endif;
	endforeach;
	
	if _passport.myCMIFMonitor &lt;&gt; null then
		_passport.myCMIFMonitor.updateProgress(app.getErrorString(Initializing), 5, 4);
	endif;
	//onsite exp cargo
	foreach ti in self.myVoyage.allOnsiteTIsByCargoTypeId discreteLock do
		if self.includeTI(ti, _compareStatus) and  //ccms1690 cnwrs1 mar 2008
		   (not self.allTIsOnTerminal.includes(ti)) and
		   (not self.allDuplicateTIsOnTerminal.includes(ti)) then
			self.allTIsOnTerminal.add(ti);
			loadListComparisonTI := ti.pxyCreateLoadListProxy(self.comparisonMode);//22/09/2010 - cnwsh3	method signature change PAR25362
			self.allUnmatchedDBTIs.add(loadListComparisonTI);
		endif;
	endforeach;

	//onship exp cargo
	// Par 14212
	// Changed the code below so tranships are ignored until the tranship section.
	// The system was adding tranships to the allExports collection but not to the unmatched collection
	// and then in the tranship section these tis were being ignored so they were effectively not making it into the search.
	foreach ti in self.myVoyage.allOnshipTIsByCargoTypeId discreteLock do
		if self.includeTI(ti, _compareStatus) and //and (not self.allExportTIsOnTerminal.includesKey(ti.id)) then  //ccms1690 cnwrs1 mar 2008
		   (not self.allDuplicateTIsOnTerminal.includes(ti)) and
		   ((not ti.isTranshipItem and
		     ti.releaseVoyage &lt;&gt; null) or
		   (_compareStatus = TI_IMEX_STATUS_IMPORT and  //ccms1690 cnwrs1 mar 2008
		    ti.dischargePort = currPortDestCode)) and //ccms1690 may 2008 cnwrs1
			ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD  then //par 99999 6 July 2010
			self.allTIsOnTerminal.add(ti);
			// cnwrs1 Mar 2007 par 13586 need to include on ship items that we loaded, tranships done later
			//if not ti.isTranshipItem and
			   //ti.releaseVoyage &lt;&gt; null then // we released this onto the ship
			   loadListComparisonTI := ti.pxyCreateLoadListProxy(self.comparisonMode);//22/09/2010 - cnwsh3	method signature change PAR25362
				self.allUnmatchedDBTIs.add(loadListComparisonTI);
			//endif;		
		endif;
	endforeach;

	//TRANSHIP
	foreach ti in tranShipDict discreteLock do
		if self.includeTI(ti, _compareStatus) and  //ccms1690 cnwrs1 mar 2008
		   (not self.allTIsOnTerminal.includes(ti)) and
		   (not self.allDuplicateTIsOnTerminal.includes(ti)) then
			self.allTIsOnTerminal.add(ti);
			loadListComparisonTI := ti.pxyCreateLoadListProxy(self.comparisonMode);//22/09/2010 - cnwsh3	method signature change PAR25362
			self.allUnmatchedDBTIs.add(loadListComparisonTI);
		endif;
	endforeach;

	// TFS 45590
	foreach ti in self.myVoyage.allTbaTIsByCargoTypeId discreteLock do
		if self.includeTI(ti, _compareStatus) and  
		   (not self.allTIsOnTerminal.includes(ti)) and
		   (not self.allDuplicateTIsOnTerminal.includes(ti)) then
			self.allTIsOnTerminal.add(ti);
			loadListComparisonTI := ti.pxyCreateLoadListProxy(self.comparisonMode);
			self.allUnmatchedDBTIs.add(loadListComparisonTI);
		endif;
	endforeach;
	
	foreach ti in self.myVoyage.allRRPTIsByCargoTypeId discreteLock do	//16 Mar 2020	NDL	TFS 47004
		if self.includeTI(ti, _compareStatus) and  
		   (not self.allTIsOnTerminal.includes(ti)) and
		   (not self.allDuplicateTIsOnTerminal.includes(ti)) then
			self.allTIsOnTerminal.add(ti);
			loadListComparisonTI := ti.pxyCreateLoadListProxy(self.comparisonMode);
			self.allUnmatchedDBTIs.add(loadListComparisonTI);
		endif;
	endforeach;

	if _passport.myCMIFMonitor &lt;&gt; null then
		_passport.myCMIFMonitor.updateProgress(app.getErrorString(Initializing), 5, 5);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_compareStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="includeTI" id="335b5542-08d1-4e53-9bea-917a4fe138c3">
        <source>includeTI(_ti: CM_TrackedItem; _imexStatus : Integer): Boolean protected;
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
vars

begin
	// PAR 25021
	if _ti.cargoType = TI_CargoType_LCL or
	   _ti.isChild then
		return false;
	endif;
	
	if (not self.allOperators.includesKey(_ti.operatorCode)) then
		return false;
	endif;
	
	if _ti.isTranshipItem then
		// need to look at what voyage
		if _imexStatus = TI_IMEX_STATUS_EXPORT and
		   _ti.myExportVoyage = self.myVoyage then
			return true;
		elseif _imexStatus = TI_IMEX_STATUS_IMPORT and
		   _ti.myImportVoyage = self.myVoyage then
			return true;
		endif;
		
	elseif ((_ti.isExport and _imexStatus = TI_IMEX_STATUS_EXPORT) or
	    (_ti.isImport and _imexStatus = TI_IMEX_STATUS_IMPORT) or 
		_ti.state = TI_STATE_ONSHIP) then
		return true;
	endif;
	
	return false;
	/*
	WAS THIS
	
	//only want exports, no packed stuff
	if ((_ti.isExport and _imexStatus = TI_IMEX_STATUS_EXPORT) or
	    (_ti.isImport and _imexStatus = TI_IMEX_STATUS_IMPORT) or 
		_ti.state = TI_STATE_ONSHIP)  //ccms1690 cnwrs1 mar 2008
//	if (_ti.isExport or _ti.state = TI_STATE_ONSHIP)
	and _ti.cargoType &lt;&gt; TI_CargoType_LCL
	and _ti.myParent = null then
		if _ti.myOperator &lt;&gt; null then
			if self.allOperators.includesKey(_ti.myOperator.code) then
				return true;
			endif;
		else
			return true;
		endif;
	endif;

	*/
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="0e8299a1-8b0f-4e83-8bf4-7ada5ef7c79d">
        <updating/>
        <source>initialise(_voyage: CM_Voyage; _operators: CM_OperatorSet; _ediLoadList: CM_EDIDataLoadList) updating, protected;
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	//clear query collection
	self.allTIsOnTerminal.clear;
	self.myEDILoadList := _ediLoadList;
	
	//clear comparison collections - only proxies here...
	self.allDiscrepancyTIs.purge;
	self.allMatchingTIs.purge;
	self.allUnmatchedDBTIs.purge;
	//self.allDiscrepancyPortsTIs.purge();
	//self.allDiscrepancyTranshipsTIs.purge();
	
	//not here though
	self.allUnmatchedLLTIs.clear;
	self.allOperators.clear;
	self.allDuplicateTIsOnTerminal.clear();

	self.myVoyage := _voyage;
	if _operators &lt;&gt; null then
		_operators.copy(self.allOperators);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operators" type="CM_OperatorSet"/>
        <Parameter name="_ediLoadList" type="CM_EDIDataLoadList"/>
    </JadeMethod>
    <JadeMethod name="reCompareEDITI" id="9aaad6bc-4f9e-4316-b415-f89a175ed80c">
        <source>reCompareEDITI(_ediLLTI: CM_EDILoadListTI; _igFields: StringArray; _updateEDITIs: CM_EDITISet input) protected;
//----------------------------------------------------------------
//	Created:	04 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	theEDITI	: CM_EDILoadListTI;
	matchedTI	: CM_EDILoadListComparisonTI;
	loadListTI	: CM_EDILoadListTI;
	
begin
	theEDITI := _ediLLTI;
	
	if self.allUnmatchedDBTIs.includesKey(theEDITI.id) then
		//an unmatched LL TI has been updated now matches an unmatched DB TI
		//have a new match - id must have been changed
		matchedTI := self.allUnmatchedDBTIs[theEDITI.id].CM_EDILoadListComparisonTI; 
		loadListTI := theEDITI;
		_updateEDITIs.add(loadListTI);
		_updateEDITIs.add(matchedTI);
		matchedTI.compareTo(loadListTI, _igFields); //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
			
		//perfect match?
		if matchedTI.allDiscrepancyAttributes.isEmpty then
			//matches ok - need to move about
			self.allUnmatchedDBTIs.remove(matchedTI);
			self.allMatchingTIs.add(matchedTI);
			matchedTI.setMyDiscrepancyTI(null);
		else
			//matches with discreps - need to move about
			self.allUnmatchedDBTIs.remove(matchedTI);
			self.allDiscrepancyTIs.add(matchedTI);
			matchedTI.setMyDiscrepancyTI(loadListTI);
		endif;
		
		if self.allUnmatchedLLTIs.includes(loadListTI) then
			self.allUnmatchedLLTIs.remove(loadListTI);
		endif;
			
	elseif self.allUnmatchedLLTIs.includes(theEDITI) then
		// can't do much about this
			
	elseif self.allDiscrepancyTIs.includesKey(theEDITI.id) then
		//a matched edi has been updated - check for changes in discreps
		//find it	
		matchedTI := self.allDiscrepancyTIs[theEDITI.id].CM_EDILoadListComparisonTI;
		loadListTI := theEDITI;
		_updateEDITIs.add(loadListTI);
		_updateEDITIs.add(matchedTI);
		matchedTI.compareTo(loadListTI, _igFields); //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
			
		//perfect match?
		if matchedTI.allDiscrepancyAttributes.isEmpty then
			//matches ok - need to move about
			self.allDiscrepancyTIs.remove(matchedTI);
			self.allMatchingTIs.add(matchedTI);
			matchedTI.setMyDiscrepancyTI(null);
			
		else
			//still in the same boat - return and redisplay changes to discreps
			return;
		endif;

	elseif self.allMatchingTIs.includesKey(theEDITI.id) then
		//possibly wont match anymore
		matchedTI := self.allMatchingTIs[theEDITI.id].CM_EDILoadListComparisonTI;
		loadListTI := theEDITI;
		matchedTI.compareTo(loadListTI, _igFields); //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
		
		//perfect match?
		if matchedTI.allDiscrepancyAttributes.isEmpty then
			//still in the same boat - return and do nothing 
			return;
		else
			//add to list
			_updateEDITIs.add(loadListTI);
			_updateEDITIs.add(matchedTI);
			
			//matches with discrep - need to move about
			self.allMatchingTIs.remove(matchedTI);
			self.allDiscrepancyTIs.add(matchedTI);
			matchedTI.setMyDiscrepancyTI(loadListTI);
		endif;
	endif;

end;
</source>
        <access>protected</access>
        <Parameter name="_ediLLTI" type="CM_EDILoadListTI"/>
        <Parameter name="_igFields" type="StringArray"/>
        <Parameter name="_updateEDITIs" type="CM_EDITISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="reCompareItem" id="9598c801-de7c-4cd6-8939-3f536726d0fe">
        <updating/>
        <source>reCompareItem(_item: CM_Object; _voyage: CM_Voyage; _ignoreFields: StringArray; 
				_updateEDITIs: CM_EDITISet input; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	04 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	isInvalid	: Boolean;								// cnwrl1 09/08/2010 PAR 24337
	iEdition	: Integer;								// cnwrl1 09/08/2010 PAR 24337
	ti			: CM_TrackedItem;
	ediLLTI		: CM_EDILoadListTI;
	
begin
	// cnwrl1 09/08/2010 PAR 24337 - start of coding
	on Exception do app.handleDeletedObject( exception, _item, isInvalid );
	// Check availability by doing a de-reference
	iEdition	:= _item.edition();
	if isInvalid then
		self.validateAgentReferences( _item );
		return;
	endif;
	// cnwrl1 09/08/2010 PAR 24337 - end of coding
	
	if CM_EDILoadListTI.hasInstance(_item) then
		ediLLTI := _item.CM_EDILoadListTI;
		self.reCompareEDITI(ediLLTI, _ignoreFields, _updateEDITIs);  //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
	elseif CM_TrackedItem.hasInstance(_item) then
		ti := _item.CM_TrackedItem;
		self.reCompareRealTI(ti, _ignoreFields, _updateEDITIs); //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
	else
		return;
	endif;

end;
</source>
        <Parameter name="_item" type="CM_Object"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_ignoreFields" type="StringArray"/>
        <Parameter name="_updateEDITIs" type="CM_EDITISet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="reCompareRealTI" id="121990c2-2ea6-4dc6-b60b-ec7df92abd5f">
        <updating/>
        <source>reCompareRealTI( _ti : CM_TrackedItem; _igFields : StringArray; _updateEDITIs : CM_EDITISet input ) updating, protected;
// reCompareRealTI(_ti: CM_TrackedItem; _igFields: StringArray; _updateEDITIs: CM_EDITISet input) protected; //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list	// cnwrl1 16/08/2010 PAR 24337 - what it was
//----------------------------------------------------------------
//	Created:	04 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	found		: Boolean;
	isInvalid	: Boolean;						// cnwrl1 16/08/2010 PAR 24337
	iEdition	: Integer;						// cnwrl1 16/08/2010 PAR 24337
	oldID		: String;
	theTI		: CM_TrackedItem;
	matchedTI	: CM_EDILoadListComparisonTI;
	loadListTI	: CM_EDITrackedItem;
	ediTI		: CM_EDITrackedItem;
	
begin
	theTI := _ti;
		
	on Exception do app.handleDeletedObject( exception, self.myEDILoadList, isInvalid );	//20 Mar 2019	NDL	TFS 43481
	
	loadListTI := self.myEDILoadList.allEDITrackedItems[theTI.id];
	
	if isInvalid then	//20 Mar 2019	NDL	TFS 43481
		return;
	endif;
	
	// cnwrl1 16/08/2010 PAR 24337 - start of coding
	on Exception do app.handleDeletedObject( exception, loadListTI, isInvalid );
	if loadListTI &lt;&gt; null then
		// Check availability by doing a de-reference
		iEdition	:= loadListTI.edition();
		if isInvalid then
			self.validateAgentReferences( loadListTI );
			return;
		endif;
	endif;
	// cnwrl1 16/08/2010 PAR 24337 - end of coding
	
	if self.allUnmatchedDBTIs.includesKey(theTI.id) then
		//an unmatched Export TI has been updated - still unmatched
		//can't do much about this
		return;
	elseif loadListTI &lt;&gt; null and 
	   self.allUnmatchedLLTIs.includes(loadListTI) then
		//have a new match - id must have been changed
		found := false;
		oldID := "";
		foreach ediTI in self.allUnmatchedDBTIs do
			matchedTI := ediTI.CM_EDILoadListComparisonTI;
			if matchedTI.myTrackedItem &lt;&gt; null and 
			   matchedTI.myTrackedItem = theTI then
				//found it
				oldID := matchedTI.id;
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			return;
		endif;
		
		matchedTI.setFromTI(theTI);	//cnwrs1 CCMS 1137 15 June 2010
		_updateEDITIs.add(matchedTI);
		//th2 added 25/01/07 - user defined types as loadlists
		if CM_EDICargoTI.hasInstance(loadListTI) then
			matchedTI.compareToUserDefinedTI(loadListTI.CM_EDICargoTI, _igFields); //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
		else
			matchedTI.compareTo(loadListTI.CM_EDILoadListTI, _igFields);	 //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
		endif;
			
		//perfect match?
		if matchedTI.allDiscrepancyAttributes.isEmpty then
			//matches ok - need to move about
			self.allUnmatchedDBTIs.remove(matchedTI);
			self.allUnmatchedLLTIs.remove(loadListTI);
			self.allMatchingTIs.add(matchedTI);
			matchedTI.setMyDiscrepancyTI(null);
		else
			//matches with discreps - need to move about
			self.allUnmatchedDBTIs.remove(matchedTI);
			self.allUnmatchedLLTIs.remove(loadListTI);
			self.allDiscrepancyTIs.add(matchedTI);
			matchedTI.setMyDiscrepancyTI(loadListTI);
		endif;
		
	elseif self.allDiscrepancyTIs.includesKey(theTI.id) then
		//a matched Export has been updated - check for changes in discreps
		//find it	
		matchedTI := self.allDiscrepancyTIs[theTI.id].CM_EDILoadListComparisonTI;
		loadListTI := matchedTI.myDiscrepancyEDITI;
		
		// cnwrl1 16/08/2010 PAR 24337 - start of coding
		if loadListTI = null then
			return;
		else
			// Check availability by doing a de-reference
			iEdition	:= loadListTI.edition();
			if isInvalid then
				self.validateAgentReferences( loadListTI );
				return;
			endif;
		endif;
		// cnwrl1 16/08/2010 PAR 24337 - end of coding
		
		matchedTI.setFromTI(theTI);
		_updateEDITIs.add(matchedTI);
		//th2 added 25/01/07 - user defined types as loadlists
		if CM_EDICargoTI.hasInstance(loadListTI) then
			matchedTI.compareToUserDefinedTI(loadListTI.CM_EDICargoTI, _igFields);  //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
		else
			matchedTI.compareTo(loadListTI.CM_EDILoadListTI, _igFields);	 //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
		endif;
			
		//perfect match?
		if matchedTI.allDiscrepancyAttributes.isEmpty then
			//matches ok - need to move about
			self.allDiscrepancyTIs.remove(matchedTI);
			self.allMatchingTIs.add(matchedTI);
			matchedTI.setMyDiscrepancyTI(null);
			
		else
			//still in the same boat - return and redisplay changes to discreps
			return;
		endif;

	elseif self.allMatchingTIs.includesKey(theTI.id) then
		//possibly wont match anymore
		matchedTI := self.allMatchingTIs[theTI.id].CM_EDILoadListComparisonTI;
		loadListTI := self.myEDILoadList.allEDITrackedItems[theTI.id].CM_EDILoadListTI;
		
		// cnwrl1 16/08/2010 PAR 24337 - start of coding
		if loadListTI = null then
			return;
		else
			// Check availability by doing a de-reference
			iEdition	:= loadListTI.edition();
			if isInvalid then
				self.validateAgentReferences( loadListTI );
				return;
			endif;
		endif;
		// cnwrl1 16/08/2010 PAR 24337 - end of coding
		
		matchedTI.setFromTI(theTI);
		//th2 added 25/01/07 - user defined types as loadlists
		if CM_EDICargoTI.hasInstance(loadListTI) then
			matchedTI.compareToUserDefinedTI(loadListTI.CM_EDICargoTI, _igFields); //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
		else
			matchedTI.compareTo(loadListTI.CM_EDILoadListTI, _igFields);	 //cnwrs1 CCMS 1137 15 June 2010 put chkIsoGroup in ignoreFields list
		endif;
		
		//perfect match?
		if matchedTI.allDiscrepancyAttributes.isEmpty then
			//still in the same boat - return and do nothing 
			return;
		else
			//add to list
			_updateEDITIs.add(matchedTI);
			
			//matches with discrep - need to move about
			self.allMatchingTIs.remove(matchedTI);
			self.allDiscrepancyTIs.add(matchedTI);
			matchedTI.setMyDiscrepancyTI(loadListTI);
		endif;
	endif;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_igFields" type="StringArray"/>
        <Parameter name="_updateEDITIs" type="CM_EDITISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setComparisonMode" id="56c7c485-6436-439b-96fa-7e21f8677a86">
        <updating/>
        <source>setComparisonMode(_mode : Integer) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 31 August 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
// 31/08/2010	cnwsh3		PAR25362
//----------------------------------------------------------------------
vars

begin
	self.comparisonMode := _mode;
epilog
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateAgentReferences" id="f9f522c2-691a-496b-8762-5ee889458a76">
        <updating/>
        <source>validateAgentReferences( _invalidObject : Object ) updating;

/*
Purpose:	To check that the various references on this agent are still valid prior to them being used.
			As At 08/08/2010 the possible references that need to be checked are:
			myEDILoadList
			myVoyage
			the Database TrackItem collections
			the EDI TrackItem collections
			
Date		Who		Reason
06/08/2010	cnwrl1	Initial creation as part of PAR 24337 - UE 4 from CM_LoadListComparisonAgent.
*/
	
vars
	
begin
	if _invalidObject.isKindOf( CM_EDIDataLoadList ) then
		self.comparisonComplete	:= false;		// in case this has been set to true
		app.msgBox(	app.getString( EDILoadList_HasBeenDeleted ),
					app.getErrorString( ERR_ErrorBoxTitle ),
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		return;
	
	elseif _invalidObject.isKindOf( CM_Voyage ) then
		self.comparisonComplete	:= false;		// in case this has been set to true
		app.setMyCurrentVoyage( null );
		app.msgBox(	app.getString( EDILoadList_VoyageBeenDeleted ),
					app.getErrorString( ERR_ErrorBoxTitle ),
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		return;
	
	elseif _invalidObject.isKindOf( CM_TrackedItem ) then
		// attempt to remove this invalid object from the relevent collection(s).
		self.allDuplicateTIsOnTerminal.removeInvalidObjects();
		self.allTIsOnTerminal.removeInvalidObjects();
		return;
	
	elseif _invalidObject.isKindOf( CM_EDITrackedItem ) then
		// attempt to remove this invalid object from the relevent collection(s).
		self.allDiscrepancyPortsTIs.removeInvalidObjects();
		self.allDiscrepancyTIs.removeInvalidObjects();
		self.allDiscrepancyTranshipsTIs.removeInvalidObjects();
		self.allMatchingTIs.removeInvalidObjects();
		self.allUnmatchedDBTIs.removeInvalidObjects();
		self.allUnmatchedLLTIs.removeInvalidObjects();
		return;
	
	else
		app.writeLog(app.getString( Process_UnknownInvalid_Object, method.qualifiedName ), LogERROR);	//26 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_invalidObject" type="Object"/>
    </JadeMethod>
</Class>
