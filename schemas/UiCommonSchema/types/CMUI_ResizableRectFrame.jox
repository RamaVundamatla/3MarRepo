    <JadeMethod name="getIntPoints" id="568f4a18-133d-4c53-a3bb-0e48874fdead">
        <source>getIntPoints( _x1, _y1, _x2, _y2 : Integer output);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2009	cnwjk3	Initial creation

*/

vars

begin
	_x1 := self.left.Integer;
	_y1 := self.top.Integer;
	_x2 := (self.left + self.width).Integer;
	_y2 := (self.top + self.height).Integer;
epilog

end;</source>
        <Parameter name="_x1" type="Integer" usage="output"/>
        <Parameter name="_y1" type="Integer" usage="output"/>
        <Parameter name="_x2" type="Integer" usage="output"/>
        <Parameter name="_y2" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getPoints" id="c206a3ea-ff55-448f-bc73-5033781a3a96">
        <source>getPoints( _x1, _y1, _x2, _y2 : Real output);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2009	cnwjk3	Initial creation

*/

vars

begin
	_x1 := self.left;
	_y1 := self.top;
	_x2 := self.left + self.width;
	_y2 := self.top + self.height;
epilog

end;</source>
        <Parameter name="_x1" type="Real" usage="output"/>
        <Parameter name="_y1" type="Real" usage="output"/>
        <Parameter name="_x2" type="Real" usage="output"/>
        <Parameter name="_y2" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="hasChanged" id="0a6ab267-1b6b-40d2-ac37-52eb8c52bf6f">
        <source>hasChanged(): Boolean;
/*
Purpose:	Return true if the size or position of the rect has changed, or it has been deleted

Date		Who		Reason
28 April 2011	cnwdw1	Initial creation
*/
vars

begin
	return self.changed or not self.visible;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="inResizeMode" id="ec1abe7a-53d0-4024-adec-5f2f93bc55a9">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>inResizeMode(set : Boolean; _value : Boolean io) updating, mapping, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 January 2009	cnwjk3	Initial creation

*/

vars

begin
	if set then
		self.inResizeMode := _value;
		if self.origWidth &lt;&gt; self.width or self.origHeight &lt;&gt; self.height or self.origLeft &lt;&gt; self.left or self.origTop &lt;&gt; self.top then
			self.changed := true;
		endif;
		self.origWidth := self.width;
		self.origHeight := self.height;
		self.origLeft := self.left;
		self.origTop := self.top;
	
		self.inDragMode := false;
		self.enableEvent('mouseMove', _value);
		if not _value then
			self.resizingLeft := false;
			self.resizingRight := false;
			self.resizingTop := false;
			self.resizingBottom := false;			
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="init" id="ab30bc35-d105-48ab-9f9b-7bbf4a1872c7">
        <updating/>
        <source>init() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2009	cnwjk3	Initial creation

*/

vars

begin

	self.top := 0;
	self.left := 0;
	self.height := 0;
	self.width := 0;
	self.origTop := 0;
	self.origLeft := 0;
	self.origHeight := 0;
	self.origWidth := 0;
	self.isSelected := false;
	self.isFirstMove := true;
	self.resizingBottom := false;
	self.resizingLeft := false;
	self.resizingRight := false;
	self.resizingTop := false;
	self.inResizeMode := false;
	self.canResizeHeight:=true;
	self.canResizeWidth:=true;
	self.thickness := self.DefThickness;	
	self.boundaryWidth := 0;
	self.borderStyle := Frame.BorderStyle_None;
	self.bevelInner := Frame.Bevel_None;
	self.bevelOuter := Frame.Bevel_None;	
	self.transparent := true;
	self.zOrder(1);
	
	self.visible := true;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isInResizeMode" id="0ad1d77b-4e1c-4f3f-b4ad-d1d07420944e">
        <source>isInResizeMode() : Boolean;
