    <JadeMethod name="setTxnDeleteStatus" id="e1259c52-85b0-41ae-a3ff-3aa8b0bd0107">
        <updating/>
        <source>setTxnDeleteStatus(_tiTransaction:CM_TITransaction) updating;
// --------------------------------------------------------------------------------
// Created:		26 August 2010 by cnwdad1
//
// Purpose:		Updates the receiver's delete status with the status flags of the TI
//				transaction that caused this EDI Info Sent transaction.
//
// Parameters:	_tiTransaction - A reference to the TI Transaction who's status flags
//					to use for the receiver's Txn Delete Status.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.txnDeleteStatus	:=	_tiTransaction.flags;
end;</source>
        <Parameter name="_tiTransaction" type="CM_TITransaction"/>
    </JadeMethod>
