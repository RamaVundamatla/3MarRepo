    <JadeMethod name="resetHookType" id="f9ca1c32-9305-4a2a-b941-8d7755b8c992">
        <source>resetHookType(pConstant : Constant; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     04 Feb 2005 by cnwdvb1
//
// Purpose:     This is used as a "callBack" method 

vars

	realHookType,
	pxyHookType	: CM_HookType;
	str,
	text		: String;
		
begin

	if pConstant.valueAsInteger &lt;=HookType_Null or
	   pConstant.valueAsInteger &gt; HookType_Max then
	   	return;
	endif;

	realHookType := self.allHookTypes[pConstant.valueAsInteger];
	
	str := pConstant.text;
	
	text := str.cnEcGetTagValueOfName('HookType');
	
	if text = null then
		return;
	endif;

	if realHookType = null then
		// treat as a create
		create pxyHookType transient;
		pxyHookType.setProxyFromXML(pConstant.valueAsInteger, text, self);
		app.myUtilityCA.utlCreateHookType(pxyHookType, realHookType, _passport);
	else
		pxyHookType := app.createUpdateProxy(realHookType).CM_HookType;
		pxyHookType.setProxyFromXML(pConstant.valueAsInteger, text, self);
		app.myUtilityUA.utlUpdateHookType(pxyHookType, _passport);
	endif;

epilog
	delete pxyHookType;
end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
