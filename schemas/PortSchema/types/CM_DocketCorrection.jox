<Class name="CM_DocketCorrection" id="d6b0616a-0dda-4a53-a231-36fd0fc237b3">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <Constant name="TAG_Details" id="2147b553-6482-4816-a081-0ef8ba786ba5">
        <source>"Details"</source>
        <type name="String"/>
    </Constant>
    <Constant name="TAG_New" id="ea54f871-47e7-44ab-b012-4a443403dd52">
        <source>"New"</source>
        <type name="String"/>
    </Constant>
    <Constant name="TAG_Old" id="4c24eb95-bb54-42bb-932a-417f09233dfa">
        <source>"Old"</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="fieldsValues" id="fd3ed86f-e78f-424c-b4e8-b7e9f0609ace">
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="createXMLLine_ForFieldsValues" id="b2111529-05b4-45f3-8bd5-844686fa55a1">
        <updating/>
        <source>createXMLLine_ForFieldsValues( _property : Property; _oldValue, _newValue : String) updating;
// --------------------------------------------------------------------------------------------------------
// Created:     22 Feb 2008 by cnwvu1
// ----------------------------------------------------------------------------------------------------------

vars
	value : String;
	
begin

	value := self.myTrackedItem.getAuditTextForProperty( _property );	// gives text type of auditText sort of: myOperator^15^Operator - TIOP^
	value := value.extractFieldNameFromAuditText();						// gives field name: "myOperator"
	self.fieldsValues := self.fieldsValues	&amp;'&lt;'&amp; value &amp;' '&amp; TAG_Old &amp;'="'&amp; _oldValue &amp;'" '&amp; TAG_New &amp;'="'&amp; _newValue &amp;'"/&gt;'&amp; CrLf;

end;
</source>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_oldValue" type="String"/>
        <Parameter name="_newValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="displayFieldsValues" id="ee31e3ba-b76b-4b15-8b1d-1fb43ff622df">
        <source>displayFieldsValues() : String protected;
// --------------------------------------------------------------------------------------------------------
// Created:     01 Feb 2008 by cnwvu1
// ----------------------------------------------------------------------------------------------------------

vars
	
begin

	return self.getFieldsValuesFromXML();
	
end;
</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="8bfe71af-4877-45a4-82d5-a20ece1d5dc5">
        <source>getDisplayString(): String;
// ---------------------------------------------------------------------------
// Created:     31 Jan 2008 by cnwvu1
// ---------------------------------------------------------------------------

vars

begin

	return self.displayFieldsValues();
	
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="750b5665-1ff1-4967-84bc-ad99e0570bc6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			return self.getDisplayString();
			
		endif;
							
	
	elseif _attrName = ETRow_DocketCorrection then
		return self.displayFieldsValues();
	
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="44c5981f-6fc8-484a-9721-61d13981abac">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:     31 Jan 2008 by cnwvu1
// ---------------------------------------------------------------------------

vars
	str : String;
	
begin

	str := inheritMethod();
	str := str &amp; self.getDisplayString();
	return str;

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFieldsValues" id="557ad1da-1939-4eb8-aaaa-7eddf72df2ef">
        <source>getFieldsValues() : String;
/* ---------------------------------------------------------------------------
Created:	29 July 2009	by cnwvu1

Purpose:	PAR 20040 - fixing historical data
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	return self.fieldsValues;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFieldsValuesFromXML" id="02b2807d-5485-4d52-8b4b-3e2b97d5d8d6">
        <source>getFieldsValuesFromXML() : String protected;
// --------------------------------------------------------------------------------------------------------
// Created:     04 Feb 2008 by cnwvu1
// ----------------------------------------------------------------------------------------------------------

vars
	str, s	: String;
	xmlDoc	: CM_XMLDocument;
	rootElement	: JadeXMLElement;
	
begin

	create xmlDoc transient;
	
	xmlDoc.parseString( self.fieldsValues );

	
	rootElement := xmlDoc.rootElement;
	if rootElement = null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'CM_DocketCorrection transaction. There is no XML information for the transaction' );
		return null;
	elseif rootElement.tagName &lt;&gt; 'Details' then
		app.raiseUnexpectedProgramError( class.name, method.name, 'CM_DocketCorrection transaction. The XML tag Details has not been found' );
		return null;
	endif;
	
	// location
	str := str &amp; getFieldsValuesFromXML_Move( rootElement );
	
	// operator
	s	:= getFieldsValuesFromXML_Usual( CM_TrackedItem::operatorCode, rootElement );
	if s.length() &gt; 0 then
		if str.length() &gt; 0 then
			str := str &amp; ': ';
		endif;
		str := str &amp; s;
	endif;

	// product
	s := getFieldsValuesFromXML_Usual( CM_TrackedItem::productCode, rootElement );
	if s.length() &gt; 0 then
		if str.length() &gt; 0 then
			str := str &amp; ': ' &amp; CrLf;
		endif;
		str := str &amp; s;
	endif;

	// jasVolume
	s := getFieldsValuesFromXML_Usual( CM_Log::jasVolume, rootElement );
	if s.length() &gt; 0 then
		if str.length() &gt; 0 then
			str := str &amp; ': ' &amp; CrLf;
		endif;
		str := str &amp; s;
	endif;
	
	// volume
	s := getFieldsValuesFromXML_Usual( CM_TrackedItem::volume, rootElement );
	if s.length() &gt; 0 then
		if str.length() &gt; 0 then
			str := str &amp; ': ';
		endif;
		str := str &amp; s;
	endif;
	
	
	return str;

epilog
	delete xmlDoc;
	
end;
</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFieldsValuesFromXML_Move" id="e128989e-5ed1-445f-be26-acbe07adf68a">
        <source>getFieldsValuesFromXML_Move( _rootElement : JadeXMLElement ) : String protected;
// --------------------------------------------------------------------------------------------------------
// Created:     04 Feb 2008 by cnwvu1
// ----------------------------------------------------------------------------------------------------------

vars
	s : String;
	xmlElement	: JadeXMLElement;
	xmlAttribute: JadeXMLAttribute;
	fieldName	: String;
	
begin

	fieldName := self.myTrackedItem.getAuditTextForProperty( CM_TrackedItem::locationId );	// gives text type of auditText sort of: myOperator^15^Operator - TIOP^
	fieldName := fieldName.extractFieldNameFromAuditText();	// gives field name: "locationId"
	xmlElement := _rootElement.getElementByTagName( fieldName );
	if xmlElement = null then
		return null;
	endif;
	
	xmlAttribute := xmlElement.getAttributeByName( TAG_Old );
	if xmlAttribute = null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'The XML attribute Old has not been found for the location. Transaction DocketCorrection ' &amp; self.String );
		return null;
	endif;

	s := 'From ' &amp; xmlAttribute.value;
	
	xmlAttribute := xmlElement.getAttributeByName( TAG_New );
	if xmlAttribute = null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'The XML attribute New has not been found for the location. Transaction DocketCorrection ' &amp; self.String );
		return null;
	endif;
	
	s := s &amp; ' To ' &amp; xmlAttribute.value;

	return s;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_rootElement" type="JadeXMLElement"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFieldsValuesFromXML_Usual" id="2357a3d2-dcdd-480f-bd73-5134500c5694">
        <source>getFieldsValuesFromXML_Usual( _property : Property; _rootElement : JadeXMLElement ) : String protected;
// --------------------------------------------------------------------------------------------------------
// Created:     21 Feb 2008 by cnwvu1
//
// Purpose:		Gives the string from fieldsValues for the transaction's info for the _xmlField 
// ----------------------------------------------------------------------------------------------------------

vars
	s : String;
	xmlElement	: JadeXMLElement;
	xmlAttribute: JadeXMLAttribute;
	fieldName	: String;
	
begin

	fieldName := self.myTrackedItem.getAuditTextForProperty( _property );	// gives text type of auditText sort of: myOperator^15^Operator - TIOP^	
	fieldName := fieldName.extractFieldNameFromAuditText();		// gives field name: "myOperator" etc.
	xmlElement := _rootElement.getElementByTagName( fieldName );
	if xmlElement = null then
		return null;	// there is no field information in the transaction
	endif;
	
	xmlAttribute := xmlElement.getAttributeByName( TAG_Old );
	if xmlAttribute = null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'The XML attribute Old has not been found for the Supplier. Transaction DocketCorrection ' &amp; self.String );
		return null;
	endif;

	s := fieldName &amp;': '&amp; xmlAttribute.value;
	
	xmlAttribute := xmlElement.getAttributeByName( TAG_New );
	if xmlAttribute = null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'The XML attribute New has not been found for the Supplier. Transaction DocketCorrection ' &amp; self.String );
		return null;
	endif;
	
	s := s &amp; ' =&gt; ' &amp; xmlAttribute.value;

	return s;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_rootElement" type="JadeXMLElement"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFieldsValues" id="4e947513-0309-46d5-9a7c-ebe10cb512d7">
        <updating/>
        <source>setFieldsValues( _locationOld, _locationNew, _supplierOld,_supplierNew, _productOld, _productNew, _oldJasVolume,_newJasVolume: String ) updating;
// --------------------------------------------------------------------------------------------------------
// Created:     01 Feb 2008 by cnwvu1
// ----------------------------------------------------------------------------------------------------------

vars
	value		: String;
	volumeOld,
	volumeNew	: Decimal[16,4];	// following the CM_TrackedItem::volume attribute
	volumeOldStr,
	volumeNewStr: String;
begin

	if _locationOld = _locationNew
	and _supplierOld = _supplierNew
	and _productOld = _productNew 
	then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Should be at least one field corrected for the Docket Correction' );	
		return;
	endif;
	
	// organize string as XML
	self.fieldsValues := '&lt;'&amp; TAG_Details &amp;'&gt;' &amp; CrLf;

	// -----------------------------------------------------------------------
	// 								Location
	// -----------------------------------------------------------------------
	// getting atribute locationId as string
	if _locationOld &lt;&gt; _locationNew then
		self.createXMLLine_ForFieldsValues( CM_TrackedItem::locationId, _locationOld, _locationNew );
	endif;
	
	// -----------------------------------------------------------------------
	// 								Supplier
	// -----------------------------------------------------------------------
	if _supplierOld &lt;&gt; _supplierNew then
		self.createXMLLine_ForFieldsValues( CM_TrackedItem::operatorCode, _supplierOld, _supplierNew );
	endif;
	
	// -----------------------------------------------------------------------
	// 								Product and Volumes
	// -----------------------------------------------------------------------
	if _productOld &lt;&gt; _productNew then
		// Product
		self.createXMLLine_ForFieldsValues( CM_TrackedItem::productCode, _productOld, _productNew );
		if _oldJasVolume &lt;&gt; _newJasVolume then
			// jasVolume
			self.createXMLLine_ForFieldsValues( CM_Log::jasVolume, _oldJasVolume, _newJasVolume );
			// Volume
			volumeOld := _oldJasVolume.Real;	// from 3 to 4 digits after decimal. We can do this according to CM_Log::recalcJASVolume()
			volumeNew := _newJasVolume.Real;	// from 3 to 4 digits after decimal. We can do this according to CM_Log::recalcJASVolume()
			volumeOldStr := volumeOld.String;
			volumeNewStr := volumeNew.String;
			self.createXMLLine_ForFieldsValues( CM_TrackedItem::volume, volumeOldStr, volumeNewStr );
		endif;
	endif; 
	
	self.fieldsValues := self.fieldsValues	&amp; '&lt;/Details&gt;';
	
end;
</source>
        <Parameter name="_locationOld" type="String"/>
        <Parameter name="_locationNew" type="String"/>
        <Parameter name="_supplierOld" type="String"/>
        <Parameter name="_supplierNew" type="String"/>
        <Parameter name="_productOld" type="String"/>
        <Parameter name="_productNew" type="String"/>
        <Parameter name="_oldJasVolume" type="String"/>
        <Parameter name="_newJasVolume" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="4f2f361c-b853-4f1c-bf4f-394fc2d88732">
        <updating/>
        <source>updateTI(_passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     31 Jan 2008 by cnwvu1
// ---------------------------------------------------------------------------

vars
	ti: CM_TrackedItem;

begin

	inheritMethod(_passport);
	
	ti := self.myTrackedItem;

	if ti = null then
		return;
	endif;
	
	if not ti.isKindOf(CM_Log) then
		app.raiseCMException( Docket_correction_only_log,null,null);
		return;
	endif;
	
end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
