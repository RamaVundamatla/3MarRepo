    <JadeMethod name="tblBRItems_dblClick" id="26d6a1b6-0e78-4157-8604-fb61d2554a24">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblBRItems_dblClick(table: Table input) updating;
/*
	Created on 28 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	brItem : CMIF_BookingRefItem;
begin
	if mode &lt;&gt; Mode_View and itemEditMode &lt;&gt; Mode_View then // we already have the edit dockbar open.  
		return;
	endif;
	
	if tblBRItems.allSelectedObjects.size = 0 then
		return;
	endif;
	
	//+cnwml2 PAR21322
	if self.isEnhanced then
		self.myAssistant.GTE_Assistant.doAddEditBookRequest(self.tblData.allSelectedObjects.first.CM_BookingRef);
	else
		self.doEditBookRefItem(getSelectedBRItem);
	endif;
end;</source>
