	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateMobileCompleteTruck(_job, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_job" type="CM_RoadJob" usage="io"/>
        <Parameter name="_dev" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateMoveBOLs" id="779f31e0-6aee-4206-b9fc-2040bbe80a40">
        <updating/>
        <source>trxUpdateMoveBOLs(_bolSet : CM_BOLSet; _moveMode : Integer; _alertCreated : Boolean io; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: 10 December 2002 By: cnwgd1
//-----------------------------------------
vars
	bol : CM_BOL;
	partsDone : Integer;
	cmifMonitor : CMIF_Monitor;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	if _passport.myCMIFMonitor &lt;&gt; null then
		cmifMonitor := _passport.myCMIFMonitor;
		if (not cmifMonitor.updateProgress(cmifMonitor.message, _bolSet.size, 0)) then
			app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);			
			return;
		endif;
	endif;

	foreach bol in _bolSet do
		// need to clear out the allErrors/Warnings collections
//		self.initialiseActivityWithPassport(_passport, method);
		exclusiveLock(bol);
		if cmifMonitor &lt;&gt; null then
			if (not cmifMonitor.updateProgress('Loading ' &amp; bol.bolTypeDesc &amp; ' ' &amp; bol.number &amp; ' for ' &amp; bol.numTIs.String &amp; ' items.', cmifMonitor.partsInJob, partsDone)) then
				app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);	
				return;
			endif;
		endif;		
		app.writeLog('   Loading ' &amp; bol.bolTypeDesc &amp; ' ' &amp; bol.number &amp; '  number of TIs: ' &amp; bol.numTIs.String, LogINFO);

		// need to reset each time as doDefferedUpdate sets back to false
		_passport.useTITransactionDeferUpdate := true;
		_passport.useTIDictDeferUpdate := true;

		beginTransaction;
		exclusiveLock(bol);

		if _passport.noErrors then
			bol.executeMoveForMode(_moveMode, _passport);
		endif;

		if _passport.noErrors then
			_passport.doDeferredUpdates();
		endif;

		if _passport.noErrors then
			//global.causeEvent(LogVoyageOps_Update_Event, false, bol.getMyVoyage());			
			app.cmsCommitTransaction(_passport);
		else
			app.convertErrorsWarningsToAlert(bol.bolTypeDesc &amp; ' ' &amp; bol.number &amp; ' could not be Moved.', _passport.allErrorWarnings);		
			_alertCreated := true;
			app.cmsAbortTransaction;
		endif;
		partsDone := partsDone + 1;		

		// RJS - need to consulte with Jason, etc before putting in
		// Allow other users time to get in between locks
		//process.sleep(1500);

	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;

	if _alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'Loading Dockets/Bill Of Ladings', null, self);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_bolSet" type="CM_BOLSet"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_alertCreated" type="Boolean" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
