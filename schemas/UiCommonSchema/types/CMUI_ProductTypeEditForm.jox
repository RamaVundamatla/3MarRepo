        <source>doOK() updating;
/* ---------------------------------------------------------------------------
Created:	02 June 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.saveDataForProdAttribute();
	
	if self.validateForSave() then
		inheritMethod();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getEntRowNameFromCmbSystemName" id="9b356469-a212-464c-ba6a-4ec9f0ee3d33">
        <source>getEntRowNameFromCmbSystemName() : String protected;
/* ---------------------------------------------------------------------------
Created:	28 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	allAttribNamesForProdType : StringArray;

begin

	create 	allAttribNamesForProdType transient;

	self.myAssistant.getAllAttribNamesForProductTyp(self.myCargoType, allAttribNamesForProdType);

	return allAttribNamesForProdType[self.cmbSystemName.listIndex];
	
epilog
	delete 	allAttribNamesForProdType;


end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadData" id="265c5536-8a2a-48e4-b786-023914aaf9a9">
        <updating/>
        <source>loadData() protected, updating;
/* ---------------------------------------------------------------------------
Created:	27 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who			Reason
-----------		--------	--------------------------------------------------
------------------------------------------------------------------------------*/
vars

begin

	self.setCmbSystemName();
	
	self.loadDataForProdAttribute();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataForProdAttribute" id="af13f7fa-9d9a-4d06-972a-ce31adcc6ad2">
        <updating/>
        <source>loadDataForProdAttribute() updating, protected;
/* ---------------------------------------------------------------------------
Created:	27 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who			Reason
-----------		--------	--------------------------------------------------
28/03/2013		cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
------------------------------------------------------------------------------*/
vars
	entDef		: EntTableDef;
	entRow		: EntTableRow;
	
begin

	if self.myCurrentProdAttr = null then
		return;
	endif;
	
	entDef := app.myController.getEntTableDef(ETDef_ProdAttrEntry);
	
	self.disableProdAttributes(true);
	
	foreach entRow in entDef.allEntTableRows do
		
		if entRow.name = ETRow_IsViewable then
			self.loadSetIsViewable(true);
		
		elseif entRow.name = ETRow_DisplayName then
			self.loadSetDisplayName(true, entRow.name);
		
		elseif entRow.name = ETRow_ValidationType then
			self.loadSetValidationType(true);
		
		elseif entRow.name = ETRow_ColumnCode then
			self.loadSetCode(true);

		elseif entRow.name = ETRow_Range then
			self.loadSetRange(true, entRow.name);
		
		elseif entRow.name = ETRow_Value then
			self.loadSetValue(true, entRow.name);
		
		elseif entRow.name = ETRow_Multiplier then
			self.loadSetMultiplier(true, entRow.name);
		
		elseif entRow.name = ETRow_DisplayValue then
			self.loadSetDisplayValue(true, entRow.name);
			
		elseif entRow.name = ETRow_MeasurementType then			// PAR #31155
			self.loadSetMeasurementType(true, entRow.name);		// PAR #31155
		
		endif;
		
	endforeach;

	self.disableProdAttributes(false);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
