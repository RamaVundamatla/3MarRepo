    <JadeMethod name="initialise" id="2315cb7a-de4b-4662-a9c7-52b602e1dee1">
        <updating/>
        <source>initialise(_bank : CM_Bank) updating;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/
vars
	woSB : CM_WorkOrderServiceBroker;
begin

	self.myBank := _bank;

	woSB := self.allWorkOrderSBs[CM_WorkOrderServiceBroker.DEFAULT_SERVICEBROKER_MAP];
	if woSB = null then
		create woSB;
		woSB.initialiseRes(self);
	endif;

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ce4334b0-ea3b-43ec-ae47-9586a94cad70">
        <updating/>
        <source>setForCreate(_pxyTranMap : CM_TranMapWorkOrder) updating;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars

begin
	_pxyTranMap.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	self.name := _pxyTranMap.name;
	self.description := _pxyTranMap.description;
	self.initialise(_pxyTranMap.myBank);
end;</source>
        <Parameter name="_pxyTranMap" type="CM_TranMapWorkOrder"/>
    </JadeMethod>
