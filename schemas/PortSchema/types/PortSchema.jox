    <JadeMethod name="setPrinter" id="b93c35ae-a1bb-43f2-8086-733fc89d9f17">
        <source>setPrinter(_printer : String) : Boolean;
//--------------------------------------------------
// Created:	21 November 2005 By: cnwgd1
//--------------------------------------------------
constants

	Printer_Ok				= 0;
	DefaultPrinterError		= 15014;

vars

	findPrinterValue	: Integer;
	tempStr,
	thePrinterName		: String;
	stringArray			: StringArray;

begin

	thePrinterName := _printer;
	// If printer name is null then Jade uses default printer.
	findPrinterValue :=  app.printer.setPrinter(thePrinterName);
	app.writeLog('Set Printer Return Value = ' &amp; findPrinterValue.String, LogINFO);
	if findPrinterValue = Printer_Ok then
		return true;
	endif;
	app.writeLog('(' &amp; thePrinterName &amp; ') was not located. Trying for default printer', LogINFO);
	create stringArray transient;
	app.printer.getAllPrinters(stringArray);
	foreach tempStr in stringArray do
		app.writeLog('Available Printer (' &amp; tempStr &amp; ')', LogINFO);
	endforeach;
	
	stringArray.insert(1, 'Available Printers are:');
	app.remoteErrorWarningToAlert('Unable To Locate Printer ' &amp; thePrinterName, null, null, stringArray, false, false);

	// If we have failed we try to set to default printer.
	if thePrinterName &lt;&gt; null then
		thePrinterName := null;
		findPrinterValue := app.printer.setPrinter(thePrinterName);
	endif;
	// Have we succeed on our second try?
	if findPrinterValue = Printer_Ok then
		return true;
	endif;
	app.writeLog('Set printer call for ' &amp; thePrinterName &amp; ' failed with error ' &amp; findPrinterValue.String, LogINFO);
	app.raiseCMException(findPrinterValue, null, null);
	return false;
epilog	
	delete stringArray;
end;</source>
        <Parameter name="_printer" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
