    <JadeMethod name="isStretchWidth" id="4d338087-90d2-44d9-9fdd-1ba109904122">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>isStretchWidth(set: Boolean; _value: Boolean io) mapping, updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
