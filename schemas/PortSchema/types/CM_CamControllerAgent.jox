    <JadeMethod name="setStatusAndSeqNumber" id="a2982d43-494e-4977-8d77-d8414c920fd1">
        <updating/>
        <source>setStatusAndSeqNumber(_newStatus : Integer; _seqNumber : Integer; _camProtocol : CM_CamProtocol) updating;
//
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask - from CM_CamTask - not used
//
vars

begin
	self.status := _newStatus;
	// dont load error status to task history.
	// it needs to know the state it was in when the error occured.
	if status &lt;&gt; CAM_ERRORSTATUS and
	   _camProtocol.taskHistoryByProtocolSeq[_camProtocol, _seqNumber] &lt;&gt; null then
		_camProtocol.taskHistoryByProtocolSeq[_camProtocol, _seqNumber].setStatus(_newStatus);
		if _newStatus = CAM_COMPLETESTATUS or 
		   _newStatus = CAM_IDLESTATUS then
			_camProtocol.taskHistoryByProtocolSeq[_camProtocol, _seqNumber].setErrorMessage(null);
		endif;

	endif;
end;</source>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
    </JadeMethod>
