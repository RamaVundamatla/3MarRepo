    <JadeMethod name="getNumUnactionedEntries" id="ecf4c092-e041-4bde-864c-22b2c0a0f2e1">
        <source>getNumUnactionedEntries() : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/07/2021	navdap1		Initial creation TFS 51409 PNL Queued Jobs in Driver Mode
//
vars
	entry : CM_RTQueueEntry;
	unactioned : Integer;

begin
	foreach entry in self.allEntries where entry.status = WLE_UNACTIONED do
		unactioned := unactioned + 1;
	endforeach;
	
	return unactioned;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPrimaryMachines" id="560707c3-912a-44e6-92d8-31e19e36e936">
        <source>getPrimaryMachines(_machines : CM_MachineByIdDict input; _includeCraneQueueMachines, _includeCranes : Boolean);
// -------------------------------------------
// Created 30 October 2003 by cnwdvb1
// -------------------------------------------
/*

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
	3/7/08		EPR			Par 17526 added parameter _inlcludeCranes should be able to see them on the YRD_QueuesForm
*/
vars

	machine : CM_Machine;

begin

	foreach machine in self.allPrimaryMachines do
		if not _machines.includes(machine) then
			_machines.add(machine);
		endif;
	endforeach;
	//epr par 17426
	if _includeCranes then
		foreach machine in self.allPrimaryCranes do
			if not _machines.includes(machine) then
				_machines.add(machine);
			endif;
		endforeach;
	endif;
	
end;</source>
        <Parameter name="_machines" type="CM_MachineByIdDict" usage="input"/>
        <Parameter name="_includeCraneQueueMachines" type="Boolean"/>
        <Parameter name="_includeCranes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getQueueDisplay" id="377b9d8f-f817-448d-901c-5ea2dbc232cf">
        <source>getQueueDisplay(_colour : Integer output) : String;
// -------------------------------------------
// Created 16 March 2004 by cnwdvb1
// -------------------------------------------
// Changed On	By			Reason
// ----------	-------		------------------
// 17/09/2020	jlgdap1		TFS 49316 MTN Machine Idle Time
// 03/10/2021 navds21       TFS 50083 MTN - Machine Delay Idle Time
vars

	numOfEntries	: Integer;
	numIdleMachines,numDelayMachines	: Integer;				// TFS 49316
	machine			: CM_Machine;			// TFS 49316
	mins			: Integer;				// TFS 49316
	idleHist,delayHist		: CM_MachineHistory;	// TFS 49316 //03.10.2022 navds21 TFS 50083
	returnStr : String; //12.10.2022 navds21 TFS 50083

begin
	foreach machine in self.allPrimaryMachines discreteLock do
		if machine.isIdle(mins, idleHist) then
			numIdleMachines := numIdleMachines + 1;
		elseif machine.isSetdownDelayed(mins,delayHist)then //03.10.2022 navds21 TFS 50083
			numDelayMachines := numDelayMachines +1; //03.10.2022 navds21 TFS 50083
		endif;
	endforeach;
	
	if numIdleMachines &gt; null then
		_colour := self.getMyTerminal.getConfig(IdleTimeColour).Integer;
	elseif numDelayMachines &gt; null then								//03.10.2022 navds21TFS 50083
		_colour := self.getMyTerminal.getConfig(DelayTimeColour).Integer;   //03.10.2022 navds21TFS 50083
	endif;
	
	numOfEntries := self.allEntries.size;
	// Start 03.10.2022 navds21 TFS 50083
	if numOfEntries &gt; 0 then
		returnStr := self.id &amp; ' (' &amp; numOfEntries.String &amp; ' entries';  
		if numIdleMachines &gt; 0 then
			returnStr := returnStr &amp; ', ' &amp; numIdleMachines.String &amp; ' idle machines';
		endif;
		if numDelayMachines &gt; 0 then														
			returnStr := returnStr &amp; ', ' &amp; numDelayMachines.String &amp; ' delayed machines)';	
		else
			returnStr := returnStr &amp; ')';
		endif;
	else
		returnStr := self.id;
		if numIdleMachines &gt; 0 then
			returnStr := ' (' &amp; numIdleMachines.String &amp; ' idle machines';
		endif;
		if numDelayMachines &gt; 0 then														
			returnStr := returnStr &amp; ', ' &amp; numDelayMachines.String &amp; ' delay machines)';	
		else
			returnStr := returnStr &amp; ')';
		endif;
	endif;
	return returnStr;
	// End 03.10.2022 navds21 TFS 50083
end;</source>
        <Parameter name="_colour" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSecondaryMachines" id="cc92117b-08f3-4f02-9395-9f7ec43eb7ba">
        <source>getSecondaryMachines(machs	:	CM_MachineByIdDict input);
//Add in all the machines in this queue that are secondary
vars
	mach	:	CM_Machine;
begin

	foreach mach in self.allMachines do
		//If this machine is in this queue as a secondary, but its not its PRIMARY
		//Queue, then add it.
		if mach.myPrimaryQueue &lt;&gt; self and not machs.includes(mach) then
			machs.add(mach);
		endif;
	endforeach;
end;</source>
        <Parameter name="machs" type="CM_MachineByIdDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTaskImportForWLE" id="72405192-296e-40bf-9c4e-92569cbd7915">
        <source>getTaskImportForWLE(_wle : CM_WorkListEntry; _task : CM_RTQueueTask io; _machine : CM_Machine) : Boolean;
// ---------------------------------------------------------------------------
// Created:		01 December 2006 By Andrew Bishop cnwab1
//
// Purpose:		CALLED BY GDANSK SHIP HAND HELD
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
17 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Change to use queryMachineAssign
21 May 2019	jlgzm1	TFS 42840 MSL Direct Release between Voyages and Rail

*/

vars
	term : CM_Terminal;
	alert : CM_SystemAlert;
	msgStr : String;
	laneLC : CM_LocationsController;
	ti : CM_TrackedItem;
	//job : CM_Job;
	messageLogger  : CM_MachineRTQueueEntryLogger;
	vjob : CM_VoyageJob; //tfs42840
	
begin
	ti := _wle.myTrackedItem;
	//job := _wle.job;

	term := ti.myTerminal;
	
	_task := self.locateTaskForTI(ti, -1);
	
	if _task = null and 
	   _wle.queue &lt;&gt; null and
	   ti.myPrimaryQueuedLocation &lt;&gt; null then
		_task := _wle.queue.locateTaskForTI(ti, -1);
	endif;//cnwas3 par 23602 - it's probably on a different queue,better spot it here then after (possibly) several useless method calls
	
	if _task = null then
		if self.myParentQueue &lt;&gt; null then
			_task := self.myParentQueue.locateTaskForTI(ti, -1);
		else
			_task := self.locateTaskForTI(ti, -1);
		endif;
	endif;
	if _task = null then
		//----------------
		//Try the Master Queue as a last resort.
		//----------------
		_task := term.radioTelemetry.masterQueue.locateTaskForTI(ti, -1);
	endif;
	if _task = null then
		if ti.myPrimaryQueuedLocation = null then
			app.raiseCMException3(Could_find_task_machi_check_wh, ti.id, _machine.id, self.id, null, null);
		else
			if not self.isVoyageQueue() then
				app.raiseCMException2(Voyag_crane_queue_contr_move_i, _machine.id, self.id, null, null);
			else
				app.raiseCMException3(Could_find_task_machine, ti.id, _machine.id, self.id, null, null);
			endif;
		endif;
		return false;
	endif;

	//---------------------
	//Test the task's job (is it a move!)
	//---------------------
	// TFS 42840 start
	vjob := null;
	if _task &lt;&gt; null then
		if _task.myEntry.myJob.isKindOf(CM_VoyageJob) then
			vjob := _task.myEntry.myJob.CM_VoyageJob;
		endif;
		if vjob = null then
			if _wle.job.isVoyageTypeJob then	// TFS 42872 jlgzm1 09/09/2019
				vjob := _wle.job.CM_VoyageJob;	// TFS 42872
			else
				vjob := _wle.getDRLinkedVoyageJob();
			endif;
		endif;
	endif;
	if vjob = null then
		//Error! Not a voyage Job
		app.raiseCMException(Task_voyage, null, null);
	else
		//---------------
		//Update the Tasks' location with the ref of the new lane. (if its on the ship)
		//---------------
		laneLC := vjob.getDefaultDischargeLane();
		_task.setSourceLocation(laneLC);
	endif;
	// TFS 42840 end

	create messageLogger transient;
	messageLogger.myMachine:=_machine;
	if _machine &lt;&gt; null and not _task.queryMachineAssign(_machine, false, false,false, true,true,messageLogger) then
	//Error! Machine cannot MOVE
		app.raiseCMException1(Suita_this_check_machi_area_ac, _machine.id, null, null);
	endif;
	//---------------
	//Is the job "released" to ops?
	//---------------
	if _task &lt;&gt; null
	and _task.myEntry.myJob.isKindOf(CM_VoyageJob) then
		if (not _task.myEntry.myJob.CM_VoyageJob.isLoadedToOperations) then
		//-------------------
		//Job is not loaded to ops, therefore its not "workable"
		//Create a System Alert!!!
		//-------------------
			app.raiseCMException1(Voyag_been_loade_voyag_opera_c, _task.myEntry.myJob.jobId, null, null);
		endif;
	endif;
	return true;
	
epilog
	delete messageLogger;
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_task" type="CM_RTQueueTask" usage="io"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
