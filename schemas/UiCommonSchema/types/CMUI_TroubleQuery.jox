    <JadeMethod name="displayTransactions" id="8dc84a31-3817-4f84-8d24-74ed5751373b">
        <updating/>
        <source>displayTransactions(_vvr : CM_VehicleVisitRecord; _reset : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	table : CM_DataTable;
	tmpStr : String;
	lines : HugeStringArray;
	vvr : CM_VehicleVisitRecord;
	idx : Integer;
	stIDX, endIDX : Integer;
begin
	table := self.tblData;
	
	if _reset then
		table.rows := table.fixedRows;
	endif;
	
	if _vvr = null then
		return;
	endif;
	
	create lines transient;
	_vvr.getTroubleTableString(lines);
	
	foreach tmpStr in lines do
		table.addItemObject(_vvr, tmpStr);
	endforeach;
		
epilog
	delete lines;
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_reset" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="4557212c-7cdb-4593-b35a-9d8b7bf934c2">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:     06 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	row : Integer;
	gate : CMGTE_Entity;
	vvRec : CM_VehicleVisitRecord;
	reset : Boolean;
	fromTS, toTS : TimeStamp;
	table : CM_DataTable;
	tmpStr : String;
	tranNum, driver : String;	// concms1 21/10/2008
	length : Integer;	// concms1 21/10/2008
begin
	table := self.tblData;

	table.rows := table.fixedRows;
	
	reset := true;
	
	fromTS.setDate(self.dteFrom.getDate());
	toTS.setDate(self.dteTo.getDate());
	
	fromTS.setTime(self.tmeFrom.getTime());
	toTS.setTime(self.tmeTo.getTime());
	
	driver 	:= txtDriverID1.text.toUpper;		// concms1 21/10/2008
	tranNum	:= txtTransaction.text.trimBlanks;	// concms1 21/10/2008
	length	:= tranNum.length;					// concms1 21/10/2008
	
	foreach gate in self.myTerminal.allGateEntityByDateTranNum discreteLock 
		where (gate.date &gt;= fromTS.date and gate.date &lt;= toTS.date) do : outerLoop
		
		if gate.status &lt;&gt; CMGTE_Entity.Status_Trouble then
			continue outerLoop;
		endif;
		
		if driver &lt;&gt; null and 							// concms1 21/10/2008
			gate.getDriverName.toUpper &lt;&gt; driver then	// concms1 21/10/2008
			continue outerLoop;							// concms1 21/10/2008
		endif;											// concms1 21/10/2008
		
		if tranNum &lt;&gt; null and 							// concms1 21/10/2008
			tranNum &lt;&gt; gate.tranNumber[1:length] then	// concms1 21/10/2008
				continue outerLoop;						// concms1 21/10/2008
		endif;											// concms1 21/10/2008
		
		foreach row in 1 to table.rows do
			if table.accessRow(row).itemObject = gate.myVehicleVisitRecord then
				continue outerLoop;
			endif;
		endforeach;
		
		
		tmpStr := gate.myVehicleVisitRecord.getTroubleTableString(null);
		table.addItemObject(gate.myVehicleVisitRecord, tmpStr);
	endforeach;

	table.colourRows(self.colorRow1, self.colorRow2);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDataClick" id="9aeffc7a-dffc-4afe-8ed4-826bd19fbca5">
        <updating/>
        <source>doTblDataClick() updating;
// ---------------------------------------------------------------------------
// Created:     24 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	tranNum : String;
	vvRec : CM_VehicleVisitRecord;
	row : Integer;
	table : Table;
begin
	table := self.tblData;
	
	row := table.row;
	
	if row &lt;= table.fixedRows then
		return;
	endif;
	
	tranNum := table.accessCell(row,4).text;
	self.myCurrentVehicleVisit := table.accessRow(row).itemObject.CM_VehicleVisitRecord;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDataDblClick" id="ade7385e-b7df-4ec8-b948-a2a5d053feec">
        <source>doTblDataDblClick();
// ---------------------------------------------------------------------------
// Created:     24 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	tranNum : String;
	vvRec : CM_VehicleVisitRecord;
	gate : CMGTE_Entity;
	row : Integer;
	table : Table;
begin
	table := self.tblData;
	
	row := table.row;
	
	if row &lt;= table.fixedRows then
		return;
	endif;
	
	tranNum := table.accessCell(row, 1).text;
	vvRec := table.accessRow(row).itemObject.CM_VehicleVisitRecord;
	
	self.myAssistant.showAPMTrouble(self, vvRec, tranNum, false);


epilog

end;</source>
    </JadeMethod>
