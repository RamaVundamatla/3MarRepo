    <JadeMethod name="btnCancel_click" id="672e3952-a227-4d5c-8b39-c26e0ab946ad">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="c1c792e8-fe3f-40d1-a1eb-92a4d45685d2">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.doSave() then
		self.modalResult	:=	self.MB_MODAL_UPDATE;
		self.unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doApplyScreenColors" id="df660201-bc8d-458b-97a6-e785d68ff0d2">
        <updating/>
        <source>doApplyScreenColors() updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	bgColor		: Integer;
	fgColor		: Integer;
	
begin
	inheritMethod();
	
	bgColor	:=	app.colorBackGeneral;
	fgColor	:=	app.colorForeGeneral;
	
	grpDetails.backColor	:=	bgColor;
	grpDetails.foreColor	:=	fgColor;
	lblName.backColor		:=	bgColor;
	lblName.foreColor		:=	fgColor;
	lblOldPSW.backColor		:=	bgColor;
	lblOldPSW.foreColor		:=	fgColor;
	lblNewPSW.backColor		:=	bgColor;
	lblNewPSW.foreColor		:=	fgColor;
	lblConfirmPSW.backColor	:=	bgColor;
	lblConfirmPSW.foreColor	:=	fgColor;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="699c9d36-c20b-47ed-8033-3f26b545b40a">
        <updating/>
        <source>doSave():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		Standard save method.
//
// Parameters:	None
//
// Returns:		True if the save was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorString	: String;
	warnings	: Boolean;
	state		: Integer;
	userName	: String;
	oldPSW		: String;
	newPSW		: String;
	confirmPSW	: String;
	
begin
	userName	:=	txtName.text.trimBlanks();
	oldPSW		:=	txtOldPSW.text.trimBlanks();
	newPSW		:=	txtNewPSW.text.trimBlanks();
	confirmPSW	:=	txtConfirmPSW.text.trimBlanks();
	
	if app.myRTGuiAgent.changePassword(userName, oldPSW, newPSW, confirmPSW, errorString, state, warnings) then
		self.modalResult	:=	self.MB_MODAL_UPDATE;
		return true;
	else
		app.msgBox(errorString, "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setUserName" id="c8f86f17-ee77-4d99-b6a9-289cff4f0a2b">
        <updating/>
        <source>setUserName(_userName : String) updating;
// -------------------------------------------
// Created 09 February 2006 by cnwdvb1
// -------------------------------------------
vars

begin

	self.txtName.text := _userName;

end;</source>
        <Parameter name="_userName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f0ce187c-a427-4373-a486-e3abe1eacb34">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		Standard setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	centreWindow();
	self.doApplyScreenColors();
	self.txtOldPSW.setFocus();
epilog
	self.modalResult	:=	self.MB_MODAL_CANCEL;
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
</GUIClass>
