<Class name="CM_ToDoWLE" id="12460da6-bff9-4264-9f2e-1db0609c315f">
    <superclass name="CM_WorkListEntry"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>DO NOT USE - Been replaced with CM_WOToDoWLE</text>
    <DbClassMap file="operatn"/>
    <ExplicitInverseRef name="myToDoTask" id="59ca5f28-dc9a-42f6-9547-98f165e0ed88">
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_TiToDoTask"/>
        <access>readonly</access>
        <Inverse name="CM_ToDoTask::myToDoWLE"/>
    </ExplicitInverseRef>
    <JadeMethod name="createTiToDoTask" id="14d8f902-7f0c-4970-b9ef-04b20b32e19a">
        <updating/>
        <source>createTiToDoTask() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwrd1	Initial creation

*/


vars
	toDoDesc 			: CM_ToDoTaskDesc;
	task , tiTask 		: CM_ToDoTask;
	passport 			: CM_Passport;

begin

	if self.myTrackedItem = null then
		//throw error
		return;
	endif;
	
	passport := app.myPassport;
	
	toDoDesc := self.job.CM_ToDoJob.myToDoTaskDesc;
	
	foreach task in self.myTrackedItem.allToDoTasksToDo where task.toDoTaskDescDesc.trimBlanks = toDoDesc.description.trimBlanks do
		tiTask := task;
	endforeach;

	if tiTask = null then //add task
		tiTask := self.myTrackedItem.addToDoTask( toDoDesc.description.trimBlanks , passport );
	endif;
	
	// if task = null then for some reason we cant add, return
	if tiTask &lt;&gt; null then
		
		if tiTask.myWOToDoWLE = null then		
		self.myToDoTask := tiTask.CM_TiToDoTask; // inverse to todotask.myToDoWLE		
			if self.job.myWODtl &lt;&gt; null then		
				tiTask.setMyWodToDo ( self.job.myWODtl.CM_WodToDo );
			endif;
			
		endif;
		
	endif;
	

epilog

end;

</source>
    </JadeMethod>
    <JadeMethod name="erase" id="ff997d7c-737d-4504-9606-9fd54e4f74d9">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 January 2010	cnwrd1	Initial creation

*/

vars
begin
	
	// Lock all for update
	exclusiveLock(self);
	sharedLock(myRequest);
	if self.myRequest.myJob &lt;&gt; null then
		//AJA 31/3/00: Yard internals
		sharedLock(self.myRequest.myJob);
	endif;

	
	//=======================
	// automatics should take care
	// of the job.wles and request.wles collections.
	//=======================

	self.causeEvent(self.job.getMyTerminal.getTerminalEvent(WLE_Delete_Event), false, self);				  	

  	inheritMethod(_eraseLevel);
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a8ac0a07-69c1-4cf5-9477-acf86a115915">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 13 May 2002 By: cnwgd1
// 11 Sep 2024 navma1 Bug 65777: EUP | 53729 - Delivery Dispatch Screen - wrong WO info when multiple in one Job
//--------------------------------------------------------------
vars
	wo	  : CM_WorkOrder;
begin

	if _attrName = ETRow_WorkEntry then
		return "ToDo";
	elseif _attrName = ETRow_Remarks then
		return null;			
	elseif _attrName = ETRow_RadioTelemetry then
		return '';
	elseif _attrName = ETRow_WorkOrder then						//14.6.2023 navhl20 #58543				
		wo := self.getWorkOrder();
		if wo &lt;&gt; null then
			return wo.id;
		endif;
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInstruction" id="e05de2c5-9fac-4ddb-bf5f-f807241332f6">
        <source>getInstruction():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2023	navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
06 Mar 2025		navah1	Bug 34283: EUP | Additional Operational Instructions - further issues
*/

vars
	instruction : CM_InstructionsIssued;
begin
	if self.myToDoTask &lt;&gt; null then
		instruction := self.myToDoTask.getInstructions();
	endif;
	if instruction &lt;&gt; null then	
		//return instruction.internalInstructions; //10.03.2025 navah1 #34283
		return instruction.getInstructionDesc();   //10.03.2025 navah1 #34283
	endif;
	return inheritMethod();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRequestType" id="d71ba660-7a53-44bf-bae6-92378d101421">
        <source>getRequestType(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwrd1	Initial creation

*/

vars

begin

	if self.job.myWODtl &lt;&gt; null then
		return REQ_TI_WORKORDER;
	else
		return REQ_TI_RELEASE;
	endif;


epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTaskTypeDesc" id="9a3be81b-20e7-4dab-9ee4-39e19bcd9135">
        <source>getTaskTypeDesc(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwrd1	Initial creation

*/

vars

begin

	if self.myToDoTask &lt;&gt; null then
		return self.myToDoTask.toDoTaskDescDesc ;
	else
		if self.job &lt;&gt; null then
			if self.job.CM_ToDoJob.myToDoTaskDesc &lt;&gt; null then
				return  self.job.CM_ToDoJob.myToDoTaskDesc.description;
			endif;
		endif;
	endif;

	return '';
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
