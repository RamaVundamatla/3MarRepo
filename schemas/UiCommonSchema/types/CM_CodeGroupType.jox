    <JadeMethod name="loadTreeViewArray" id="a81852b3-a506-40f3-82a5-598eb5e18c57">
        <source>loadTreeViewArray(_collection : Collection input; _level : Integer);//CMUI_CodesMaintTree
// ---------------------------------------------------------------------------
// Created:     07 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
vars
	codeGroup : CM_CodeGroup;	
	iter : Iterator;
	obj  : SOPVM_CodeGroupType;
begin
	create obj transient;

	obj.initializeMe(self, _level, null);
	_collection.add(obj);
	
	iter := self.allCodeGroups.createIterator();
	while iter.next(codeGroup) do
		codeGroup.loadTreeViewArrayWithoutCodes(_collection, _level + 1,obj);
	endwhile;
	
epilog
	delete iter;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_level" type="Integer"/>
    </JadeMethod>
</Class>
