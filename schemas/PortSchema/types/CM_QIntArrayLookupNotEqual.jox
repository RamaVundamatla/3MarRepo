<Class name="CM_QIntArrayLookupNotEqual" id="2392c7a5-d3da-4d6f-b42b-51ba7e2a33dd">
    <superclass name="CM_QIntegerLookupNotEqual"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="doMatch" id="a2921550-b091-4cbe-b616-9a20ce814525">
        <source>doMatch(_value: Any): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2023	navmv20	Bug 60677: FR | EUP 54086 - Invoicing Maintenance enhancements - Selector Query - Invoice mode

*/

vars
	intValue : Integer;
begin
	if _value = null or _value.IntegerArray.isEmpty() then
		return true;
	endif;
	
	foreach intValue in _value.IntegerArray do
		if  intValue &lt;&gt; self.searchValue then
			return true;
		endif;	
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
