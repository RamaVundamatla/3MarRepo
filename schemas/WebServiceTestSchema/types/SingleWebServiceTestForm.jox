    <JadeMethod name="cmbOperation_click" id="0fede92b-1f7c-480e-a5ce-d5037a80046a">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOperation_click(combobox: ComboBox input) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
18 December 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	allPropertyNames,
	allPropertyValues : StringArray ;
begin
	
	create allPropertyNames transient;
	allPropertyNames.add(Logon::userId.name);
	allPropertyNames.add(Logon::password.name);
	allPropertyNames.add(WS_LogonMachineRequest::machineId.name);
	allPropertyNames.add(WS_LogonMachineRequest::terminalId.name);
	allPropertyNames.add("organisationName");
	create allPropertyValues transient;
	allPropertyValues.add(txtUser.text.trimBlanks);
	allPropertyValues.add(txtPassword.text.trimBlanks);
	allPropertyValues.add(txtMachine.text.trimBlanks);
	allPropertyValues.add(txtTerminal.text.trimBlanks);
	allPropertyValues.add(txtOrg.text.trimBlanks);
	
	createEmptyInputMessage(allPropertyNames,allPropertyValues);

epilog
	delete allPropertyValues;
	delete allPropertyNames;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
