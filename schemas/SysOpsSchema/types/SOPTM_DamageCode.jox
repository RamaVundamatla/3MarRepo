epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="f00cb09d-b6ad-4e4f-9354-015c1ef26551">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*
----------   ----------  --------------------------------------------------
Created:	19 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_DamageMaint);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_DamageMaint);
	theForm.shtTblInput1.visible := true;


epilog

end;

</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="6cbac74c-ce37-449b-b34f-ce8ec86e5a7f">
        <updating/>
        <source>showThumbnail(_damageDefCode: CM_DamageDefinitionCode) updating;
/*
----------   ----------  --------------------------------------------------
Created:	19 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, _damageDefCode.code);
	theForm.tblInput1.setValueByName(ETRow_Description, _damageDefCode.description);
	
	theForm.mulSelect1.setSelected(_damageDefCode.allCargoTypes);
	theForm.mulSelect2.setSelected(_damageDefCode.allMachineTypesByType);
epilog

end;


</source>
        <Parameter name="_damageDefCode" type="CM_DamageDefinitionCode"/>
    </JadeMethod>
</Class>
