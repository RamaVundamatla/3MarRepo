        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstStopSet_displayRow(_table: Table input; _theSheet: Integer; _obj: Object; _theRow: Integer; _bcontinue: Boolean io):String updating;

