Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	assignment : CM_CargoGroupAssignment;

begin

	assignment := getMyCargoGroupAssignment;
	if assignment &lt;&gt; null then
		return assignment.id;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
