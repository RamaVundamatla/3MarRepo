	request.myWorkOrderDetail := wsRelease;
	
	wsRelease.cargoTypeId := TI_CargoType_Container;
	wsRelease.releaseRequestOid := _release.getOidAsString;
	wsRelease.releaseRequestNum := _release.code;
	foreach container in _containers do
		/* 29.09.2021 navma1 #51925
		wsRelease.allCargoIds.add( container.id );
		wsRelease.allCargoOids.add( container.getOidAsString );
	    */
