    <JadeMethod name="isStorageByDays" id="e6086ad7-0559-4029-add9-7c36fd76a0db">
        <source>isStorageByDays() : Boolean;
// ---------------------------------------------------------------------------
// Created:     11 June 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//// PAR 24160
//	Aug 2010		cnwjre1			par 24024 use getChargeByUnits
//	Nov 2010		cnwjre1			par 26107 CCMS 2020 Invoice storage by first/last cargo item on/off voyage
//									add INV_CALC_TYPE_DAYSINCE_SHIP tests
// ---------------------------------------------------------------------------

vars
	calcType	: CM_CalculationType;
	unit	: Integer;
begin
	
	
	if self.myTransactionTI = null or not self.myTransactionTI.isKindOf(CM_Storage) then
		return false;
	endif;
	
	calcType:=self.invoiceLineDesc.myCalculationType;
	if calcType = null then
		unit := self.invoiceLineDesc.chargeByUnits;
	else
		
		//epr TFS 1693 23/3/16 if they are this type they can also be by days 
		// stored on theCalcTypeUnit
		if calcType.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT 
			or calcType.calculationType = INV_CALC_TYPE_CARGOVOLUMECONVT 
			or calcType.calculationType = INV_CALC_TYPE_CARGOLENGTHCONVT then
			unit := calcType.theCalcTypeUnit;
		else
			unit :=calcType.calculationType;
		endif;
	endif;
	
	
	if unit = INV_CALC_TYPE_DAYS_SINCE_RECVL 
	or unit = INV_CALC_TYPE_DAYSINCE_SUBTERM 	//28 Jun 2018	NDL	TFS 39338
	or unit = INV_CALC_TYPE_DAYSINCE_SHIP_ST 
	or unit = INV_CALC_TYPE_DAYSINCE_SHIP_EN 
	or unit = INV_CALC_TYPE_DAYSINCE_VOY_IN
	or unit = INV_CALC_TYPE_DAYSINCE_VOY_OUT
	or unit = INV_CALC_TYPE_DAYSINCE_REC_TEU 
	or unit = INV_CALC_TYPE_DAYSINCE_REC_RT 	//08 May 2018	NDL	TFS 38525
	or unit = INV_CALC_TYPE_DAYS_WEIGHT
	or unit = INV_CALC_TYPE_DAYS_VOLUME
	or unit = INV_CALC_TYPE_DAYS_ONSITE_AT
	or unit = INV_CALC_TYPE_DAYS_CONNECTED
	then	
		return true;	
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTPPBarang" id="3bc6ed8d-6699-496f-b257-58c7a70f715c">
        <source>isTPPBarang(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2019	jlgmp6	Initial creation	TFS42036

*/

vars

begin
	if self.invoice.paymentType = PaymentType_AutoCollection then
		return isWSDL13Successful();
	elseif self.invoice.paymentType = PaymentType_PostPay then
		return isWSDL17Successful();
	elseif self.invoice.paymentType = PaymentType_PrePay then
		return isWSDL112Successful();
	else
		return false;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTPPKapal" id="3d649b0c-0643-44b9-80a9-92ae0b6ea942">
