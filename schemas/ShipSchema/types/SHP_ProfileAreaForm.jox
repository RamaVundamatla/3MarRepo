    <JadeMethod name="initTblWOOpHrs" id="3d2f2913-04c7-4391-b6b0-209a2d99b08d">
        <source>initTblWOOpHrs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	entDef : EntTableDef; 

begin

	self.tblWPOpHrs.clear();
	
	self.tblWPOpHrs.fixedRows:=1;
	self.tblWPOpHrs.selectionType := CM_DataTable.SelectionType_Row;	
  	self.tblWPOpHrs.userInputEnabled := false;
	
	entDef := app.myController.getEntTableDef(ETDef_WorkPointOpHrsDisp);
	if entDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntDef ETDef_WorkPointOpHrsDisp not found');
		return;
	endif;
	
	self.tblWPOpHrs.setTblDataEntRowsFromDef(entDef);
	
	self.loadTblWPOpHrs();

epilog

end;</source>
