    <JadeMethod name="keyDown" id="663bc0fa-d471-4c4e-b15e-cdd83a0542db">
        <updating/>
        <source>keyDown(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/11/2002	cnwdad1		If the control is read-only, then do not allow scrolling.
// 23/01/2003	cnwdad1		Added a check of the isChanged flag to determine whether
//							to invoke the firstChange event method.
// --------------------------------------------------------------------------------
begin
	if self.readOnly then
		keyCode	:=	0;
		return;
	endif;
	
	if (keyCode &gt;= J_key_0 and keyCode &lt;= J_key_9)
	or (keyCode &gt;= JSS_KEY_PAD0 and keyCode &lt;= JSS_KEY_PAD9)
	then
		self.processNumberKey(keyCode);
		
	elseif (keyCode &gt;= JSS_KEY_ARROWLEFT and keyCode &lt;= JSS_KEY_ARROWDOWN) then
		self.processArrowKey(keyCode);
		
	else
		keyCode	:=	0;
		
	endif;
	
	if (not self.isChanged) then
		self.isChanged	:=	true;
		self.firstChange(self);
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyPress" id="89447e5b-467d-44d0-92b5-e68c65dd724d">
