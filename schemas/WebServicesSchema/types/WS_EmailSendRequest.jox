<Class name="WS_EmailSendRequest" id="60e11a1d-e7bd-4aae-b917-2e12daed0af4">
    <superclass name="WS_Request"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="bccAddress" id="3f74ac5d-1909-45a3-a30c-b686027cd518">
        <type name="String"/>
        <text>Optional BCC addressee(s) for the email to be sent.</text>
    </PrimAttribute>
    <PrimAttribute name="body" id="47e156e4-42ed-4f0c-98bd-16fe0b9913ae">
        <type name="String"/>
        <text>Message body for the email to be sent.</text>
    </PrimAttribute>
    <PrimAttribute name="ccAddress" id="df3ee749-0af9-4d0d-9ad5-a9bdc4f5da06">
        <type name="String"/>
        <text>Optional CC addressee(s) for the email to be sent.</text>
    </PrimAttribute>
    <PrimAttribute name="subject" id="a49f892d-b87b-4288-9c27-5a3f0a859643">
        <type name="String"/>
        <text>Subject line for the email to be sent.</text>
    </PrimAttribute>
    <PrimAttribute name="toAddress" id="a8d09233-1974-40da-92eb-8d55668ec922">
        <type name="String"/>
