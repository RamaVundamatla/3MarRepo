        <source>getWorkOrderVoyageRequestDates(_fromTS, _toTS : TimeStamp output) : CM_WorkOrder;

/*

Purpose:		TFS 39721	

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2018	jlgab1	Initial creation
24 Sep 2021	jlier1	TFS 51963
*/

vars
	wo : CM_WorkOrder;
begin
	foreach wo in self.allWorkOrders discreteLock where wo.isWorkOrderForVoyageRequest do

		wo.getWorkOrderVoyageRequestDates(_fromTS, _toTS);
