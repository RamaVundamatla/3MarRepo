    <JadeMethod name="getMyTerminalArea" id="5c0e2b06-1445-41cf-a959-22a3a3ea8f34">
        <source>getMyTerminalArea() : CM_TerminalArea;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2019	jlgndl1	Initial creation	TFS 47123

*/

vars

	str : String;
	foundLC : CM_LocationsController;
	foundHeight : Integer;

begin

	str := self.getLocationStr();
	
	if str &lt;&gt; null and self.myTerminal &lt;&gt; null then
		self.myTerminal.findLocationFromString( str, true, foundLC, foundHeight );
		if foundLC &lt;&gt; null then
			return foundLC.getMyTerminalArea;
		endif;
	endif;

	return null;

epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getOperatingUser" id="548a8a7e-14e3-4536-a5dd-c092a1b5d0b6">
        <source>getOperatingUser():CM_User;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2018	cnwma1	ChangeRequest 41080: PEL1 - Assigning Operators ID to Cranes/Work-Points

*/

vars
	user : CM_User;
	wpOH   : CM_WorkPointOperatingHours;
	voy   : CM_Voyage;
begin
	
	voy := self.getMyVoyage;
	if voy &lt;&gt; null   then
		foreach wpOH in voy.allWorkPointOperatingHours do 
			if wpOH.craneWorkPointId  = self.craneID then
				
				if self.dateTime &gt;= wpOH.exchangeStart and  self.dateTime &lt;= wpOH.exchangeEnd then
					return wpOH.myUser;
				endif;
			endif;
			
		endforeach;
	endif;
	return  null;
	
epilog

end;</source>
        <ReturnType type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="getPointOfWork" id="23289f58-ec53-4ddc-93b6-de59b5c94f07">
        <source>getPointOfWork():Any;
/*

Purpose:			
This method has been added to be used by JRW reports and Data Extract
to show Workpoints or Machines used to create the Receive and Release ship tranasctions
Parameters:			

Return Value:		

Date		Who		Reason
30 Jan 2023 navhl20 ChangeRequest 55111: GPHA -- Adding Workpoint to Tracked Item and Transaction Views

*/

vars
	wp			: CM_WorkPoint;
	machine		: CM_Machine;
	term		: CM_Terminal;
begin
	if self.craneID = null then
		return null;
	endif;
	
	term 	:= self.myTerminal;
	machine := term.machines[self.craneID];
	
	if machine &lt;&gt; null then
		return machine;
	endif;
	
	wp := self.myTerminal.allWorkPointsByCode[self.craneID];
	
	if wp &lt;&gt; null then
		return wp;
	endif;
	
	return null;
epilog
	
end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getPointOfWorkCode" id="e16ece66-0b59-4c7d-8690-b52af1abd93d">
        <source>getPointOfWorkCode():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jan 2023 navhl20 ChangeRequest 55111: GPHA -- Adding Workpoint to Tracked Item and Transaction Views

*/

vars
	obj			: Any;
begin
	obj := self.getPointOfWork();
	
	if obj = null then
		return null;
	endif;
	
	if obj.isKindOf(CM_Machine) then
		return obj.CM_Machine.code;
	elseif  obj.isKindOf(CM_WorkPoint) then
		return obj.CM_WorkPoint.getTypeDescription;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
