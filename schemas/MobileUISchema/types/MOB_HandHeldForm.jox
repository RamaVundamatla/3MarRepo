    <JadeMethod name="insertMeasurementTypeRow" id="7ef692ed-7d6d-4e58-abf0-40534929a6fa">
        <updating/>
        <source>insertMeasurementTypeRow(	_tbl : CM_MobEntryTable io; 
							_entRow : EntTableRow;
							_atRow : Integer; 
							_controlId : Integer io;
							_columnDispObj : CM_Object;	// Object we set the special Product columns from Tracked Item or Cargo Type
							_dataObj : CM_Object // Object we get the actual data from Tracked item
							):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 March 2013	cnwrd1	Initial creation
02 Sep 2013	NDL	Par 32368
02 Sep 2013	NDL	Par 32407
05 Sep 2013	NDL	Par 32413

*/
vars

	newHeaderName : String;
	hideRow : Boolean;
	measure : CM_MeasurementType;
	aRow			: Integer;
	originalColor	: Integer;
	originalEnabled	: Boolean;
	controlPrefix	: String;
	rowHeading		: String;
	rowName			: String;
	newRow			: Integer;
	entRowTrans		: EntTableRowTransient;
	rawDataValue	: Decimal [23,10];
	measureControl	: CMUI_MeasurementTable;
	controlName		: String;
	
begin
	if _columnDispObj = null then
		return false;
	endif;
	if not _columnDispObj.hasEntTableSpecialConditions(	_entRow,	// : EntTableRow;
														newHeaderName,	//_alteredHeaderName : String output;
														hideRow,	//_hideRow : Boolean output;
														measure	//_measureType : CM_MeasurementType output
														) then
		return false;
	endif;
	if measure = null then
		return false;
	endif;
	// is the row we're going to replace even in the table?
	// e.g. length, width, height for containers, overlength, overwidth, overheight for non-containers
	aRow := _tbl.getRowByName(_entRow.name);
	if aRow = null or not _tbl.accessRow(aRow).visible then
		return false;
	endif;
	
	originalColor := _tbl.accessCell(aRow, 2).backColor;
	originalEnabled := _tbl.accessCell(aRow, 2).enabled;
	
	app.getRowHeadingFromMeasure(_entRow, measure, controlPrefix, rowHeading, rowName);
	
	newRow 			:= _tbl.addAttributeAt(rowName, _entRow.getHeadingUnaltered, Table.InputType_TextBox, null, true, _atRow);
	entRowTrans 	:= _tbl.accessRow(newRow).itemObject.EntTableRowTransient;
	
	if _dataObj &lt;&gt; null then
		rawDataValue := _dataObj.getRawMeasurementValue(_entRow.name);
	endif;
	if rawDataValue = null then
		_tbl.setValueByName(rowName, " " &amp; measure.shortName);
	else
		_tbl.setValueByName(rowName, app.convertMeasurementForDisplay(measure.shortName, rawDataValue) &amp; " " &amp; measure.shortName);
	endif;
	
	if newHeaderName &lt;&gt; null and newHeaderName &lt;&gt; rowName then
		_tbl.setCellText( _tbl.getRow(rowName), 1, newHeaderName);
	endif;
		
	_tbl.accessCell(_atRow, 2).backColor 	:= originalColor;
	_tbl.accessCell(_atRow, 2).enabled 	:= originalEnabled;
	
	// create a measurement table control for this row of the table
	measureControl := self.allMeasurementControls[controlName].CMUI_MeasurementTable;
	if measureControl = null then
		_controlId := _controlId + 1;
		measureControl := self.tblMeasurement.loadControl(_controlId).CMUI_MeasurementTable;
		measureControl.visible := true;
		measureControl.name := rowName;
		measureControl.setEventMapping("lostFocus", "tblMeasurement_lostFocus");
		measureControl.setEventMapping("gotFocus", "tblMeasurement_gotFocus");
		measureControl.setMeasurementType(measure.measurementType);
		measureControl.setHeading(_entRow.getHeadingUnaltered);
		measureControl.accessCell(1, measureControl.ColumnSpacer).text := null;
		self.allMeasurementControls.add(measureControl);
	endif;
	measureControl.setRowName(_entRow.name);
	
	_tbl.setControl(_atRow, measureControl);
	
	return true;
	
epilog

end;</source>
        <Parameter name="_tbl" type="CM_MobEntryTable" usage="io"/>
        <Parameter name="_entRow" type="EntTableRow"/>
        <Parameter name="_atRow" type="Integer"/>
        <Parameter name="_controlId" type="Integer" usage="io"/>
        <Parameter name="_columnDispObj" type="CM_Object"/>
        <Parameter name="_dataObj" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
