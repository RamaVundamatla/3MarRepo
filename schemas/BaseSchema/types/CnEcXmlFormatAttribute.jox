    <PrimAttribute name="noCDataCheck" id="f7d66d16-4f9c-4550-836e-898dac03cfc9">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="cnEcXmlFormatOutput" id="70a840a9-fd9f-4636-ad50-9da2ecb671d0">
        <source>cnEcXmlFormatOutput(pObject: Object; pDebug: Boolean; pMaxObjectCount: Integer io; pCurrentObjectCount: Integer io; pMaxResponseSize: Integer io): String;

begin
	return cnEcXmlOutput(pObject, pDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pDebug" type="Boolean"/>
        <Parameter name="pMaxObjectCount" type="Integer" usage="io"/>
        <Parameter name="pCurrentObjectCount" type="Integer" usage="io"/>
        <Parameter name="pMaxResponseSize" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlOutput" id="7c2f0530-5dfd-4287-a819-ade8173fd1af">
        <source>cnEcXmlOutput(	pObject:Object;
				pIsDebug:Boolean;
				pMaxObjectCount:Integer io;
				pCurrentObjectCount:Integer io;
				pMaxResponseSize:Integer io): String;

vars
	xmlString 	: String;
	value 		: Any;
	pos			: Integer;
	arrayType	: String;
	arrayValue	: String;
	smtp 		: CnSmtpConnection;
	size		: Integer;
	
begin
    if not self.isShowTagData then
    	return null;
    endif;

	value := pObject.getPropertyValue(self.propertyName);
    if value.isKindOf(Binary) then
		
	// KBA - I don't argee with this idea of creating an object just to use 1 method
	//		 maybe the it should be refactored and put as a primitive method on binary
	//		 that is up to the CardSchema people.

		if value &lt;&gt; null then
			create smtp;
			xmlString := cnEcXmlTagIt(self.tagName, "&lt;![CDATA[" &amp; smtp.emBase64Encode(value.Binary) &amp; "]]&gt;", pIsDebug);
		else 
			xmlString := cnEcXmlTagIt(self.tagName, "" , pIsDebug);  		
		endif;
	elseif value.isKindOf(Array) then
		size := value.Array.size();
	
		if value.isKindOf(BinaryArray) then
			arrayType := "Binary";			
		elseif value.isKindOf(BooleanArray) then
			arrayType := "Boolean";
		elseif value.isKindOf(CharacterArray) then
			arrayType := "Character";
		elseif value.isKindOf(DateArray) then
			arrayType := "Date";
		elseif value.isKindOf(DecimalArray) then
			arrayType := "Decimal";
		elseif value.isKindOf(HugeStringArray) then
			arrayType := "HugeString";
		elseif value.isKindOf(IntegerArray) then
			arrayType := "Integer";
		elseif value.isKindOf(PointArray) then
			arrayType := "Point";
		elseif value.isKindOf(RealArray) then
			arrayType := "Real";
		elseif value.isKindOf(StringArray) then
			arrayType := "String";			
		elseif value.isKindOf(TimeArray) then
			arrayType := "Time";
		elseif value.isKindOf(TimeStampArray) then
			arrayType := "TimeStamp";
		endif;
		
		if size = 0 then
			if pIsDebug then 
				arrayValue := "&lt;" &amp; arrayType &amp; "&gt;&lt;/"&amp; arrayType &amp;"&gt;";
			endif;
		else 
			if arrayType = "Binary" then			
				create smtp;
				foreach pos in 1 to size do
					arrayValue := arrayValue &amp; "&lt;" &amp; arrayType &amp; "&gt;" &amp; cnEcXmlTagIt(self.tagName, "&lt;![CDATA[" &amp; smtp.emBase64Encode(value.Array[pos].Binary) &amp; "]]&gt;", pIsDebug) &amp; "&lt;/"&amp; arrayType &amp;"&gt;";
				endforeach;			
			elseif arrayType = "String" then			
				foreach pos in 1 to size do
					arrayValue := arrayValue &amp; "&lt;" &amp; arrayType &amp; "&gt;" &amp; value.StringArray[pos].cnEcAsXml() &amp; "&lt;/"&amp; arrayType &amp;"&gt;";
				endforeach;			
			elseif arrayType = "Integer" then			
				foreach pos in 1 to size do
					arrayValue := arrayValue &amp; "&lt;" &amp; arrayType &amp; "&gt;" &amp; value.IntegerArray[pos].String.cnEcAsXml() &amp; "&lt;/"&amp; arrayType &amp;"&gt;";
				endforeach;			
			else		
				foreach pos in 1 to size do
					arrayValue := arrayValue &amp; "&lt;" &amp; arrayType &amp; "&gt;" &amp; value.Array[pos].String.cnEcAsXml() &amp; "&lt;/"&amp; arrayType &amp;"&gt;";
				endforeach;						
			endif;
		endif;
		xmlString := cnEcXmlTagIt(self.tagName, arrayValue, pIsDebug);
	 		
	elseif value.isKindOf(Character) then
	
		if value.Character.toHex = "00" then
			xmlString := cnEcXmlTagIt(self.tagName, "", pIsDebug);
		else
			if self.noCDataCheck then
				xmlString := cnEcXmlTagIt(self.tagName, value.String, pIsDebug);
			else
				xmlString := cnEcXmlTagIt(self.tagName, value.String.cnEcAsXml(), pIsDebug);
			endif;
		endif;
	else
		if self.noCDataCheck then
			xmlString := cnEcXmlTagIt(self.tagName, value.String, pIsDebug);
		else
			xmlString := cnEcXmlTagIt(self.tagName, value.String.cnEcAsXml(), pIsDebug);
		endif;					
	endif;

	return xmlString;
epilog
	delete smtp;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pIsDebug" type="Boolean"/>
        <Parameter name="pMaxObjectCount" type="Integer" usage="io"/>
        <Parameter name="pCurrentObjectCount" type="Integer" usage="io"/>
        <Parameter name="pMaxResponseSize" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createNewCopy" id="b112e7dd-902d-4d5b-9c4c-2d4f1b4bffca">
        <updating/>
        <source>createNewCopy(pNewFormatClass: CnEcXmlFormatClass): CnEcXmlFormatProperty updating;

vars
	retVal : CnEcXmlFormatAttribute;
	
begin
	create retVal;
	retVal.initializeMe(self.propertyName, self.tagName, self.isShowTagData, pNewFormatClass);

	return retVal;
end;</source>
        <Parameter name="pNewFormatClass" type="CnEcXmlFormatClass"/>
        <ReturnType type="CnEcXmlFormatProperty"/>
    </JadeMethod>
    <JadeMethod name="setNoCDataCheck" id="183f586b-2986-4e64-8f41-57eef2c6d141">
        <updating/>
        <source>setNoCDataCheck(pValue	: Boolean) updating;

begin
	self.noCDataCheck := pValue;
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
</Class>
