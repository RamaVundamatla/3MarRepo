    <JadeMethod name="translateForm" id="6cdaf7ca-d659-43ed-9be8-671e2ef031a4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 28 February 2024 13:35:14.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025648, locale);
	btnChangeTransport.translateCaption(Xlat_0025649, locale);
	btnClose.translateCaption(Xlat_0025650, locale);
	chkSelectAll.translateCaption(Xlat_0026039, locale);
	grpCargo.translateCaption(Xlat_0025651, locale);
	grpCompletedCargo.translateCaption(Xlat_0026040, locale);
	grpTransport.translateCaption(Xlat_0026041, locale);
	lblBol.translateCaption(Xlat_0026042, locale);
	lblBooking.translateCaption(Xlat_0026043, locale);
	//lblFilter.translateCaption(Xlat_0026044, locale);
	lblNewBol.translateCaption(Xlat_0026045, locale);
	lblNewBook.translateCaption(Xlat_0026046, locale);
	lblNewReleaseRequest.translateCaption(Xlat_0026740, locale);
	lblNewTransportMode.translateCaption(Xlat_0025653, locale);
	lblOldTransport.translateCaption(Xlat_0025654, locale);
	lblQuantity.translateCaption(Xlat_0026693, locale);
	lblReleaseRequest.translateCaption(Xlat_0026741, locale);
	lblVoyage.translateCaption(Xlat_0025652, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0025655, locale);
	mnuWorkOrderChangeTrans.translateCaption(Xlat_0025656, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="a05d6590-7b9e-473d-a35b-65e8a322984b">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
17 April 2024	navpw1	Initial creation TFS: 63647 (63694)

*/

vars
	wodRelease		: CM_WodRelease;
	releaseRequest	: CM_BulkRelease;
	
begin
	if self.myWorkOrderDtl.isWodRelease then
		wodRelease := self.myWorkOrderDtl.CM_WodRelease;
		
	endif;
	
	if wodRelease &lt;&gt; null then
		releaseRequest := wodRelease.myReleaseRequest;
	endif;
	
	if releaseRequest &lt;&gt; null and releaseRequest.releaseByType then
		self.minimumHeight -= 25; //Reset the minimum height for the form which will adjust the height if necessary
		
	endif;
	
	inheritMethod();
	
end;</source>
    </JadeMethod>
</GUIClass>
