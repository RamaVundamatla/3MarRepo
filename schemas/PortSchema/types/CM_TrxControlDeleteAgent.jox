/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2022	navak20	ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots

*/

vars
	vbsTimeSlot : CM_VehicleBookingTimeSlot;
begin
	self.initialiseActivityWithPassport(_passport, method);
	
	//Arm base exception handlers
	on Exception do self.agtPassportExHandler(exception, _passport);
	on LockException do self.agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);
	
	beginTransaction;
	
	foreach vbsTimeSlot in _selectedObject as CM_VehicleBookingTimeSlot do
		app.myUtilityDA.utlDeleteVVSBooking(vbsTimeSlot, _passport);
	endforeach;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
