    <JadeMethod name="nswDataCleanup_34158" id="60883022-fa9a-421a-a288-0d48e92df2de">
        <source>nswDataCleanup_34158();
/*

Purpose:	 Update all the voyage movements to "chargeable".		

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2025	navsp1	Initial creation JIRA 34158

*/

vars
	terminal 		: CM_Terminal;
	voyage 			: CM_Voyage;
	mvmt, pxyMvmnt 	: HMS_VoyageMovement;
	hmsData 		: HMS_VoyageData;
	msg 			: String;
	theUser         : CM_User;
begin
	app.initialize;
	theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(theUser);
	msg := "";
	beginTransaction;
	//Execute for all the terminals
	foreach terminal in app.myRoot.allTerminals do
		foreach voyage in terminal.allVoyagesByCode do
			hmsData := voyage.myHMSVoyageData;
			if hmsData &lt;&gt; null then
				foreach mvmt in hmsData.allVoyageMovements do
					if mvmt.chargeForMove = false then
						mvmt.setPropertyValue(HMS_VoyageMovement::chargeForMove.name, true);
						msg := msg &amp; "Voyage("&amp;voyage.code&amp;") movement( "&amp; mvmt.moveType.String&amp;" ( OID : "&amp;mvmt.getOidString&amp;" ) ) has been updated to chargeable.";
						write msg;
					endif;
				endforeach;
			endif;
		endforeach;
	endforeach;	
	commitTransaction;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="operatorCargoGroup" id="7bf1a018-c831-47eb-8a1a-c328f9c847d6">
        <source>operatorCargoGroup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2025	navsp1	Initial creation

*/

vars
	op : CM_Operator;
begin
	foreach op in CM_Operator.instances do
		if not op.allCargoGroups.isEmpty then
			write op.code &amp; Tab &amp; op.allCargoGroups.size.String;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="regex" id="d9c401a4-3350-45d7-b3ad-6457fae1f5e4">
        <source>regex();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2025	navsp1	Initial creation

*/
constants
	PatternStr = "";
	JSONStrin = '';
	ExpectedJsonResponse 	= '{"allErrors":null,"allInfo":null,"allWarnings":null,"result":0,"arrivalDT":&lt;ArrivalDT&gt;,"cargoSummary":{"offSite":["UAT0457278"],"onShip":["UAT0157278"],"onSite":["UAT0257278"],"preNotified":["UATV572785"]},"departureDT":&lt;DepartureDT&gt;,"estimatedArrivalDT":&lt;EstimatedArrivalDT&gt;,"estimatedDepartureDT":&lt;EstimatedDepartureDT&gt;,"externalCode":"UAT57278","id":"UAT57278","inwardsCode":"","operatorId":"LAUR","portRotation":[{"id":"AUBNE","tranship":false}],"remarks":"Test","shippingLineId":"ABC","status":0,"tradeId":"AAL Shipping","vessel":{"callSign":"","id":"LAURA OLD VESSEL","imo":"","loa":0,"name":"LAURA Old VESSEL","operatorId":"LAUR"},"voyageType":{"holds":true,"lolo":false,"roro":false}}';
vars
	jsonStr : String;
	jadeJSON : JMTJadeJson;
	regex : CMIF_RegexPattern;
begin
	jsonStr := ExpectedJsonResponse;
	//regexPattern := CMIF_RegexPattern('\"\\\/Date\(\-62135596800000\)\\\/\"|"-4713-11-23T12:00:00:000Z"', 'null', true);
	create jadeJSON transient;
	foreach regex in jadeJSON.allRegexPatterns as CMIF_RegexPattern do
		regex.replaceAll(jsonStr);
	endforeach;
	write jsonStr;

epilog
delete jadeJSON;
end;</source>
    </JadeMethod>
    <JadeMethod name="table" id="49dfdc42-e9c5-466c-a01d-c2442a49162b">
        <source>table();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2024	navsp1	Initial creation

*/

vars
	row, size : Integer;
	fixed :Integer;
begin
	
	
	/*Foreach reverse order*/
	size := 5;fixed := 1;
	foreach row in size to (fixed + 1)step-1 do		
		write row;
	endforeach; 
end;


</source>
    </JadeMethod>
    <JadeMethod name="vbs" id="72b16bf8-5d04-4dea-b4a1-2e859c70290e">
        <source>vbs();
/*

Purpose:			

Parameters:			






		*************************************** Sample reference codes *******************************************

		
		
		
		
Return Value:		

Date		Who		Reason
31 October 2023	navsp1	Initial creation

*/
constants
	VBSID = "ABCDEF";

vars
	terminal 	: CM_Terminal;
	vbsTerminal : CM_VehicleBookingTerminal;
	passport 	: CM_Passport;
	vbsType 	: CM_VehicleBookingTimeSlotType;
	vbs 		: CM_VehicleBookingTimeSlot;
begin
	/*--------------------------------------------------------*/
	//UT to delete and create the VBS
	passport := app.myPassport;
	terminal := self.getMyTerminal;
	vbsTerminal := terminal.myVehicleBookingTerminal;
	//delete and create VBS
	// Delete the VBS Timeslot Type and any vehicle booking slots
	vbsType := terminal.allTerminalVBSSlotTypes[VBSID];
	if vbsType &lt;&gt; null then
		foreach vbs in vbsType.myTerminal.myVehicleBookingTerminal.allVBTimeslotsById do
			if vbs.myVBTimeSlotType = vbsType then
			//	self.deleteVbsTimeSlotAdv(vbs.id);//UT_EDI
			endif;
		endforeach;
		//self.deleteVbsTimeslotType(VBSID);//UT_EDI
	endif;	
	/*--------------------------------------------------------*/
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="vbsentry" id="43180797-f94a-4697-b477-b0f64653b679">
        <updating/>
        <source>vbsentry() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2025	navsp1	Initial creation

*/

constants
     CONTID    = "TI15J25";
     TRUCKNO = "TRS";
      DRIVERID = "DRS";
     
     
    VOYAGEID = "VOYSP888";
    TERMINALID = "SPT";
   
   
    CARRIERCODE = "ABC";
    
    OPERATORID = "ABC";
    DisPort			: String = "AUSYD";
    DISCHID = "PUS";
    TotalNumber : Integer = 1000;
vars
	ti: CM_TrackedItem;
    i : Integer;
    cont : String;
    terminal : CM_Terminal;
    voyage: CM_Voyage;
    ifArray				: CMIF_TIObjectArray;
    	ifPreNote			: CMIF_PreNote;
        pxyVVR, vVR: CM_VehicleVisitRecord; 
        	gate				: CM_Gate;
            	lane : CM_YardController;
                agent								: CM_TrxControlCreateAgent;
                                updateagent								: CM_TrxControlUpdateAgent;
                	theUser : CM_User;
                    	wleArray,
	wlesWithWarnings : CM_WLEArray;	
    gateEntity, pxyGateEntity: CMGTE_Entity;
    flexiController : CMIF_FlexiGateController;
    jobQueueNum : Integer;
    cargoTypeObj : CM_CargoType;
begin
    jobQueueNum := 1000;
    app.initialize();
    	theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	app.myPassport.setMyUser(theUser);
    create ifArray transient;
    terminal := app.myRoot.allTerminals[TERMINALID];
    app.myPassport.setMyTerminal(terminal);
    if terminal = null then
        return;
    endif;
    voyage := terminal.allVoyagesByCode.getAtKeyGeq(VOYAGEID, null);
    gate := terminal.getDefaultGate_IN();
    lane := gate.getFirstAGateLane_IN;

    cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev("CONT");
    create agent transient;
    create updateagent transient;
    i := 0;
	while i &lt; TotalNumber do
        i := i+1;
        cont := CONTID&amp;i.String;
        //Create prenote
        create ifPreNote transient;	
        ifPreNote.id := cont;
        ifPreNote.myTerminal := terminal;	
        ifPreNote.cargoType := cargoTypeObj.id;
        ifPreNote.isoType := "2200";
        ifPreNote.weightTotal := '10000'.Decimal;
        ifPreNote.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
        ifPreNote.operatorCode := OPERATORID;
        ifPreNote.dischargePort := DisPort;
        ifPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
       	ifPreNote.consigneeCode 		:= app.myRoot.allConsigneeConsignors.first.code;
        ifPreNote.consignorCode 		:= app.myRoot.allConsigneeConsignors.first.code;
        ifPreNote.voyageCode := voyage.code;
        if terminal.allNotifiedTIsByIdCargoType.getAtKey( cont, TI_CargoType_Container ) = null then
            ifArray.add(ifPreNote);
        endif;
    endwhile;
    if ifArray .size &gt; 0 then
        //TRX
        app.myPassport.warningsAcknowledged := true;
        app.myPassport.setWarningsIgnored(true);
        agent.trxCreatePreNotes(ifArray, false, app.myPassport);
        if app.myPassport.hasErrors() then
            return;
        endif;
     endif; 
      
    i := 0;
    while i &lt; TotalNumber do  
        
        //create prenote end
        i := i+1;
        cont := CONTID&amp;i.String;
       
        ti := terminal.allNotifiedTIsByIdCargoType.getAtKey( cont, TI_CargoType_Container ).CM_Container;
       // ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  cont);
        create pxyVVR transient;
        pxyVVR.setProxyFlexiGate(DRIVERID&amp;i.String, DRIVERID&amp;i.String, CARRIERCODE, null, TRUCKNO &amp; i.String, "", null, terminal, gate, lane, "");
       
        app.myPassport.warningsAcknowledged := true;
        app.myPassport.setWarningsIgnored(true);
       agent.trxCreateVehicleVisitFlexi(pxyVVR, vVR, app.myPassport);
     
    create pxyGateEntity as ti.getGTEClassToCreate() transient;
		//pxyGTERelease.setre(true);
		pxyGateEntity.setPxyFromTI(ti);
		
		create flexiController transient;
		flexiController.setFromExistingPrenote( ti );	// sets up the majority of the std fields
		
        flexiController.myTerminal:=terminal;
        flexiController.jobType 				:= CMGTE_Entity.JobType_GeneralIN;
        flexiController.id 					:= ti.id;
        flexiController.myVehicleVisitRecord :=vVR;
		pxyGateEntity.setPXYFromController( flexiController );
		
		
		pxyGateEntity.setJobQueueNum( jobQueueNum );
   
    app.myPassport.warningsAcknowledged := true;
        app.myPassport.setWarningsIgnored(true);
        agent.trxCreateInOutFlexiGateEntity(vVR, pxyGateEntity, gateEntity, app.myPassport);
       pxyVVR := app.createUpdateProxy(vVR).CM_VehicleVisitRecord;
	//self.ignoreTrxWarnings(true);  // Need to ignore the id check digit warning
	
     app.myPassport.warningsAcknowledged := true;
        app.myPassport.setWarningsIgnored(true);
    agent.trxCreateInOutFlexiJob(pxyVVR, vVR,null, app.myPassport);
    
    create wleArray transient;
	create wlesWithWarnings transient;
	vVR.myRoadJob.getAllWLEs(wleArray);

	//app.myPassport.setWarningsIgnored(true);
	updateagent.trxUpdateWLEsDoMove(wleArray, wlesWithWarnings, REAL_MODE, false,null, app.myPassport);

	endwhile;
	

	
epilog
	//self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
    delete ifArray;
    delete agent;
    delete updateagent;
    delete wleArray;
    delete wlesWithWarnings;
end;</source>
    </JadeMethod>
    <JadeMethod name="workOrder" id="8e93da21-16fc-436b-8622-23cc0d784875">
        <source>workOrder();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2025	navsp1	Initial creation

*/

vars
	wo : CM_WorkOrder;
	wod : CM_WorkOrderDtl;
	wodArr				: 	CM_WorkOrderDtlArray;
begin
	/////////////////////////////////////////////////////////////////////////////////
	//Delete tasks
	wo :=  "10412.80724".asOid.CM_WorkOrder;//
	create wodArr transient;
	//beginTransaction;
	foreach wod in wo.allWoDtls do
		wodArr.add(wod);
		//if wod &lt;&gt; null and wod.CM_WodReceive.allSelectedTIs.size &gt; 0 then
		//	write "Yes";
		//endif;
		//.allWoDtls.remove(wod);
		//app.myUtilityDA.utlDeleteWorkOrderTaskMani(wod, app.myPassport);
		
	endforeach;
	beginTransaction;
	foreach wod in wodArr do
		wo.allWoDtls.remove(wod);
	endforeach;
	commitTransaction;
	///////////////////////////////////////////////////////////////////////////////////
	
epilog
	delete wodArr;
		
end;
</source>
    </JadeMethod>
</Class>
