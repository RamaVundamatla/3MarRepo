    <JadeMethod name="getGoodVIN" id="484cbf76-b5a7-4ed2-ad18-495ea2872864">
        <source>getGoodVIN(_barcode : String) : String;
// ---------------------------------------------------------------------------
// Created:		13 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		the barcode may have control characters appended on the front 
//					and end of the VIN, so strip the bad characters off
//
// ---------------------------------------------------------------------------
vars
	tiID, vin : String;
	ascii, idx, endd, matches : Integer;
	char : Character;
	tmpTI : CM_TrackedItem;
begin
	endd := _barcode.length;
	
	foreach idx in 1 to endd do
		char := _barcode[idx:1].Character;
		ascii :=  char.Integer;
		
		if (ascii &gt;= 65 and ascii &lt;= 90) // A to Z
		or (ascii &gt;=97 and ascii &lt;= 122) // a to z
		or (ascii &gt;= 48 and ascii &lt;= 57) then // 0 to 9
			vin := vin &amp; char;
		endif;
	endforeach;
	
	// this is the VIN so pass it back
	if vin.length &lt;= 17 then // less than is in there cos of the chnage event on the HH screen
		return vin;
	endif;
	
	// possibly some 'valid' characters that need to be stripped off.
	// we take off 1 character off the front and then use teh next 17 characters to match in our collection of cars.
	endd := vin.length();
	tiID := vin;
	
	foreach idx in 2 to endd do
		if (endd - idx + 1) &lt; 17 then
			break;
		endif;
		tiID := vin[idx:17];
		if self.myVoyage &lt;&gt; null then
			tmpTI := self.myVoyage.lookupTrackedItem(tiID.toUpper(), TI_CargoType_Car, false);
		endif;
		if tmpTI = null then
			tmpTI := self.myTerminal.searchForOnsiteTI(tiID.toUpper(), matches, TI_CargoType_Car);
		endif;
		if tmpTI &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	return tiID;

end;</source>
        <Parameter name="_barcode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIPort" id="b7663ec7-151b-45d2-8242-fa09092206f6">
