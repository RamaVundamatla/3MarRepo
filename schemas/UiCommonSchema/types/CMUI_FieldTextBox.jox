    <JadeMethod name="setValue" id="3a8b278c-dc6a-4753-9b85-3707e54a5f04">
        <updating/>
        <source>setValue(_value: Any) updating;
// --------------------------------------------------------------------------------
// Created:		22 February 2006 by cnwdad1
//
// Purpose:		Sets the receiver's field value.
//
// Parameters:	_value - The field value to set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

	//self.myTextBox.text	:=	_value.String;
	self.myTextBox.text	:=	_value.asStringJMT();	// 25592 18/11/2010

end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setWidths" id="3fe26530-d58d-4b4e-abe4-5b54729b3956">
        <updating/>
        <source>setWidths(_controlWidth: Integer; _labelWidth: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2009	cnwdap1	Initial creation

*/

vars
	textWidth : Real;

begin
	inheritMethod(_controlWidth, _labelWidth);
	if self.myTextBox.maxLength &lt;&gt; null then
		textWidth 				:= getTextExtent(self.TEXTEXTENT[1:self.myTextBox.maxLength]);
		if textWidth &gt; _controlWidth then
			self.myTextBox.width	:= _controlWidth;
		else
			self.myTextBox.width	:= textWidth;
		endif;
	else
		self.myTextBox.width	:= _controlWidth;
	endif;
	self.myTextBox.left		:= self.width - _controlWidth;
epilog

end;</source>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_labelWidth" type="Integer"/>
    </JadeMethod>
