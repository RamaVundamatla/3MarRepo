<Class name="ReportViewInPatch" id="58827869-b124-475c-8fe7-7b600fcca712">
    <superclass name="Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="HotFixesCommonSchema"/>
    <ExplicitInverseRef name="myPatch" id="30ac5ba2-c51e-4b13-bd58-4b20625d4924">
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="Patch"/>
        <Inverse name="Patch::allReportViewsInPatch"/>
    </ExplicitInverseRef>
    <PrimAttribute name="name" id="da1b6463-e8fb-46f9-a518-e6bb649b5ebd">
        <length>257</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="extractReportView" id="2d594e37-2db5-487e-9422-0d9b89dab290">
        <source>extractReportView(_jadeMaster, _client : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2014	cnwmc5	Initial creation

*/

vars
	agent			: DEV_ReleaseExtractAgent;
	rptViewFileName	: String;
	serverStr		: String;
begin
	create agent transient;
	
	rptViewFileName := self.getNameWithDetails &amp; '.rwv';
	
	serverStr := app.cnGetServerMiscPath() &amp; '\';
	
	agent.extractReportView(serverStr &amp; rptViewFileName, self.name);
	
	app.copyAFile(serverStr &amp; rptViewFileName, false, _jadeMaster &amp; rptViewFileName, true);
	app.copyAFile(serverStr &amp; rptViewFileName, false, _client &amp; rptViewFileName, true);
	
	app.deleteAFile(serverStr &amp; rptViewFileName, false);
epilog
	delete agent;
end;</source>
        <Parameter name="_jadeMaster" type="String"/>
        <Parameter name="_client" type="String"/>
    </JadeMethod>
    <JadeMethod name="getNameWithDetails" id="4f5f001d-377d-4931-bd86-3a9fd1f285bc">
        <source>getNameWithDetails() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2014	cnwmc5	Initial creation

*/

vars

begin
	return self.name &amp; '_' &amp; app.myRootHotFix.releaseVersionNo &amp; '_' &amp; self.myPatch.patchNo;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="598f3dfe-248a-41bb-8b3b-13f03d134c8d">
        <updating/>
        <source>setForCreate( _name: String; _patch: Patch ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2014	cnwmc5	Initial creation

*/

vars

begin
	self.name := _name;
	self.myPatch := _patch;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_patch" type="Patch"/>
    </JadeMethod>
    <JadeMethod name="validate" id="73cdb820-54dd-46c1-a92b-07198dc83170">
        <source>validate() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2014	cnwmc5	Initial creation

*/

vars
	agent: DEV_ReleaseExtractAgent;
begin
	create agent transient;
	
	if not agent.validateReportView(self.name) then
		app.writeLogMessage('Report View ' &amp; self.name &amp; ' - not found.');
		return false;
	endif;
	
	app.writeLogMessage('Report View ' &amp; self.name &amp; ' - ok.');
	return true;
epilog
	delete agent;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
