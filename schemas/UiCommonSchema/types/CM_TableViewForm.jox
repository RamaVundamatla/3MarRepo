    <JadeMethod name="queryUnload" id="e50252f7-84b6-4723-884c-08325ab07aec">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
/* AA 29/6/01: If adding or editing then ask user if they want to abandon edits.
This happens when the form itself is closed or the MDI frame is closed. When the
MDI frame is closed, the user gets a message box for each window being edited.

*/
constants
	CANCEL_UNLOAD = 1;
vars
	result : Integer;
begin


	self.doQueryUnload(cancel, reason);
/*	if self.mode = Mode_Add or self.mode = Mode_Update then
		if reason = QueryUnload_User or
		   reason = QueryUnload_UnloadMethod or
		   reason = QueryUnload_MdiChild then
		   if self.checkHasChanged() then
				result := app.msgBox($EditChangedAndClosing, self.caption &amp; " Window Closing !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
				if result = MsgBox_Return_No then
					cancel := CANCEL_UNLOAD;	//Do not close form
				endif;			
			endif;
		endif;
	endif;*/
end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
