    <JadeMethod name="comboBoxCalendar" id="d693d486-c7b2-4d13-a594-f9b3a42bbd4a">
        <source>comboBoxCalendar(_terminal : CM_Terminal ; _combo : CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 September 2012	cnwer1	Initial creation CCMS SFW 1295

*/

vars
	calendar : CM_Calendar;
begin
	if _terminal = null then
		return;
	endif;
	_combo.clear;
	_combo.sorted:=true;
	_combo.addItem( null );	//20 Sep 2017	NDL	TFS 7032
	foreach calendar in _terminal.allCalendars discreteLock do
		_combo.addItemObject(calendar.code,calendar);
	endforeach;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
