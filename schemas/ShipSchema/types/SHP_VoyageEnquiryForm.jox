    <JadeMethod name="doShowCargoReview" id="24436320-c7d9-4b19-b02f-1eb50a8cd2eb">
        <source>doShowCargoReview();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60702: UI - Cargo Review Option in Transport UI

*/

vars
	cgReviewForm			: CMUI_CargoReview;
	criteriaLine			: CM_SelectorCriteriaLine;
	qdef					: CM_QueryDefinition;
	voyage					: CM_Voyage;
	sa						: StringArray;
	criteriaLines			: CM_SelectorCriteriaLineArray;
	sites					: IntegerArray;
begin
	
	if self.tblData.allSelectedObjects.isEmpty() then
		return;
	endif;
	
	cgReviewForm := app.loadForm(CMUI_CargoReview, CMUI_Assistant, true, true, false, self.getMyTerminal(), null).CMUI_CargoReview;
	
	if cgReviewForm = null then
		return;
	endif;
	
	qdef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, CM_QueryDefinition.TrackedItem_Query_Mode];
	
	if qdef = null then
		return;
	endif;
	
	create criteriaLines transient;
	create sa transient;
	create sites transient;
	
	foreach voyage in self.tblData.allSelectedObjects as CM_Voyage do
		sa.add(voyage.code);
	endforeach;
	
	criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::voyageCode.name, CM_QueryOperator.Operator_IsOneOf, sa);
	criteriaLines.add(criteriaLine);
	
	sites.add(TI_SITE_ONSITE);
	sites.add(TI_SITE_ONSHIP);
	
	criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_IsOneOf, sites);
	criteriaLines.add(criteriaLine);
	
	cgReviewForm.createCriteriaLinesFromParent(criteriaLines);
	cgReviewForm.setParentForm(self);
	cgReviewForm.show();
	cgReviewForm.autoDoCustDocFromParent(); //23/02/2023	navkc1 CR 62580 Task 62581
epilog
	delete sa;
	delete criteriaLines;
	delete sites;
end;</source>
    </JadeMethod>
    <JadeMethod name="doViewManifestCargoClick" id="9e8e38ba-ce86-431c-84a0-9912b110ce67">
        <source>doViewManifestCargoClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/01/2023	navkc1 CR 61998 Task 62000: UI - Voyage Enq Manifested Cargo Query
17/07/2024	navnk30	Bug 65037: MTN - Unexpected Program Error when there is no manifested cargo on ship

*/

vars
	allTIs		: CM_TISet;
	objArray	: ObjectArray;
begin
	
	create allTIs transient;
	create objArray transient;
	
	self.myCurrentVoyage.getAllDischargedTIs(allTIs);
	
	if allTIs.isEmpty() then			//17.07.2024 navnk30 #65037
		app.msgBox(app.getErrorString(SHP_No_Manifested_TI), app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only);
		return;
	endif;
	
	allTIs.copy(objArray);
	
	self.myAssistant.showCargoEnquiryForTIs(allTIs.first().CM_TrackedItem, objArray, self.myMasterMenuAction, false);
	
epilog
	
	delete allTIs;
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="79296b69-debb-4901-bfde-97a772055e22">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	xmlStr	: String;
	rowIndex : Integer;	//02 Jun 2020	NDL	TFS 49417
	voyStatus : CM_VoyageStatus;	//02 Jun 2020	NDL	TFS 49417
	statuses : String;	//02 Jun 2020	NDL	TFS 49417
begin

	//02 Jun 2020	NDL	TFS 49417
	foreach rowIndex in 1 to self.lstStatus.rows do
		if self.lstStatus.accessCell(rowIndex,1).text = "1" then
			voyStatus := self.lstStatus.accessRow(rowIndex).itemObject.CM_VoyageStatus;
			if voyStatus &lt;&gt; null then
				if statuses = null then
					statuses := voyStatus.id.String;
				else
					statuses := statuses &amp; " " &amp; voyStatus.id.String;
				endif;
			endif;
		endif;
	endforeach;
	
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblData.getXmlStrForColumns(true) &amp;
			global.formatAsXML(XMLTag_HideExtraInfo, (not self.dkbDetails.visible).String) &amp;			
			global.formatAsXML(XMLTag_InPortFrom, self.filterDateInPortFrom.asXMLFormat()) &amp;
			global.formatAsXML(XMLTag_InPortTo, self.filterDateInPortTo.asXMLFormat()) &amp;
			global.formatAsXML(XMLTag_ArrivalsFrom, self.filterDateArrivalsFrom.asXMLFormat()) &amp;
			global.formatAsXML(XMLTag_ArrivalsTo, self.filterDateArrivalsTo.asXMLFormat()) &amp;
			global.formatAsXML(XMLTag_DeparturesFrom, self.filterDateDeparturesFrom.asXMLFormat()) &amp;
			global.formatAsXML(XMLTag_DeparturesTo, self.filterDateDeparturesTo.asXMLFormat()) &amp;
			global.formatAsXML(XMLTag_Archived, self.filterArchivedVoyages.String) &amp;
			global.formatAsXML(XMLTag_All, self.ckbAll.value.String) &amp;
			global.formatAsXML(XMLTag_Future, self.ckbFuture.value.String) &amp;
			global.formatAsXML(XMLTag_Cancelled, self.ckbIncludeCancel.value.String) &amp;  // cnwrd1 par 23993 25.5.2010 
			global.formatAsXML(XMLTag_Departed, self.ckbIncludeDeparted.value.String) &amp;	//02 Jun 2020	NDL	TFS 49417
			global.formatAsXML(XMLTag_NoQuery, self.ckbNoQueryOnStartUp.value.String) &amp;	//02 Jun 2020	NDL	TFS 49417
			global.formatAsXML(XMLTag_Statuses, statuses) &amp;	//02 Jun 2020	NDL	TFS 49417
			global.formatAsXML(XMLTag_NoDates, self.chkNoDates.value.String);

	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleSystemNotification" id="435c74c1-e967-4c7e-9fd8-c1702d8caad5">
        <updating/>
        <source>handleSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
// 20/05/2010	cnwcs5	Fixed exception when theObject has been deleted
vars
	idx				: Integer;
	voyageObj		: CM_Voyage;
	gotException	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, voyageObj, gotException);	// 20/05/2010 cnwcs5
	
	if CM_Voyage.hasInstance(theObject) then
		voyageObj	:=	theObject.CM_Voyage;
		
		if eventType &lt;&gt; Object_Delete_Event and voyageObj.myTerminal &lt;&gt; self.myTerminal then
			return;
		endif;
	else
		return;
	endif;
	
	if gotException then 	// 20/05/2010 cnwcs5
		return;				// 20/05/2010 cnwcs5
	endif;					// 20/05/2010 cnwcs5
	
	if eventType = Object_Update_Event then
		if self.includeVoyage(voyageObj, app.myPassport) then
			idx := self.tblData.updateItemObject(voyageObj, self.colorRow1, self.colorRow2, app.myPassport);
			
			if idx &gt; self.tblData.fixedRows then
				self.tblDataDisplayColourColumn(idx, voyageObj.colour);
				self.displayExtraInfo();
			endif;
		else
			self.tblData.removeItemObject(voyageObj);
			
			if voyageObj = self.myCurrentVoyage then
				self.myCurrentVoyage := null;
				self.displayExtraInfo();
			endif;
		endif;
	
	elseif eventType = Object_Create_Event then
		if self.includeVoyage(voyageObj, app.myPassport) then
			idx := self.tblData.updateItemObject(voyageObj, self.colorRow1, self.colorRow2, app.myPassport);
			
			if idx &gt; self.tblData.fixedRows then
				self.tblDataDisplayColourColumn(idx, voyageObj.colour);
			endif;
		endif;
		
	elseif eventType = Object_Delete_Event then
		self.tblData.removeDeletedObject(theObject);
		
		if theObject = self.myCurrentVoyage then
			self.myCurrentVoyage := null;
			self.displayExtraInfo();
		endif;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeVoyage" id="7552a0d1-ae2f-4eb6-b2af-e444bcf27503">
        <source>includeVoyage(_voyage : CM_Voyage; _passport : CM_Passport) : Boolean;
//--------------------------------------------------
// Created:	18 May 2005 By: cnwgd1
// 6/5/2016		cnwmp6	TFS 488 - Multi timezone support
// 03/06/2020 	cnwma1 	ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 04 Apr 2022  navhl20 TFS 53352 EUP - Voyage External Reference Field Usability - UI
// 08 June 2022 navhl20	Bug 53799: EUP - Voyage External reference search in Voyage Enquiry
//--------------------------------------------------
vars
	validDate,
	check : Boolean;						// 08 June 2022 navhl20	#53799
	failedDAC  :CM_DataAccessController;
	systemInPortFrom,
	systemInPortTo,
	systemArrivalsFrom,
	systemArrivalsTo,
	systemDeparturesFrom,
	systemDeparturesTo: TimeStamp;
	arrivalDT,
	departDT	: TimeStamp;
begin
	if _voyage = null then
		return false;
	endif;
// temp code - fix after lunch
	if not global.isValidObject (_voyage) or _voyage.isNullVoyage then
		return false;
	endif;	

	if (not _voyage.canUserAccessSelf(null, failedDAC,_passport)) then
		return false;
	endif;

//	if self.filterStatus &gt;= 0 then
//		if self.filterStatus &lt;&gt; _voyage.status then
	if not self.filterStatuses.isEmpty then	//02 Jun 2020	NDL	TFS 49417
		if not self.filterStatuses.includes( _voyage.status ) then
			return false;
		endif;
	else
		//cnwrd1 par 23993 24.5.2010 CCMS 1928
		if not self.ckbIncludeCancel.value and _voyage.isCancelled then  //jlier1 TFS51963 5/10/21
			return false;
		endif;
	endif;

	if self.filterVessel &lt;&gt; null then
		// false is arrived after this date
		if _voyage.vesselCode &lt;&gt; self.filterVessel.code then
			return false;
		endif;	
	endif;

	//Start 08 June 2022 navhl20	#53799
	/*if self.filterCode &lt;&gt; null  then
		if self.filterCode = "*" then
			return true;
		endif;
		
		// return as dates not applicaable to code search
		if _voyage.code.startsWith(self.filterCode) then
			if self.filterGroupCode &lt;&gt; null then                                    //03/06/2020 cnwma1 Tfs #49400
				if _voyage.voyageGroupCode.startsWith(self.filterGroupCode) then
					return true;
				else
					return false;
				endif;
			else
				return true;
			endif;
		else
			return false;
		endif;
	endif;			
	
	if self.filterGroupCode &lt;&gt; null  then                                           //03/06/2020 cnwma1 Tfs #49400
		if self.filterGroupCode = "*" then
			return true;
		endif;
		if _voyage.voyageGroupCode.startsWith(self.filterGroupCode) then
			return true;
		else
			return false;
		endif;
	endif;	
	
	//Start 04 Apr 2022 navhl20 TFS 53352
	if self.filterExtCode &lt;&gt; null  then                                          
			if self.filterExtCode = "*" then
				return true;																
			endif;
			if _voyage.voyageCodeExternal.startsWith(self.filterExtCode) then
				return true;													
			else
				return false;													
			endif;
		endif;	
		
		if self.filterExtRef &lt;&gt; null  then 
			if self.filterExtRef = "*" then
				return true;													
			endif;
			if _voyage.externalRef.toUpper.pos(self.filterExtRef,1) &gt; 0 then
				return true;													
			else
				return false;						
			endif;
		endif;*/
	//End 04 Apr 2022 navhl20 TFS 53352
	
	//Start 04 Apr 2022 navhl20 TFS 53352
	if self.filterCode &lt;&gt; null or self.filterGroupCode &lt;&gt; null or self.filterExtCode &lt;&gt; null or self.filterExtRef &lt;&gt; null then
		check := true;
		if self.filterCode &lt;&gt; null then
			if self.filterCode = "*" then
				check := true;
			endif;
			
			if _voyage.code.startsWith(self.filterCode) then
				check := true;
			else
				check := false;
			endif;
		endif;			
	
		if self.filterGroupCode &lt;&gt; null and check = true then                                           //03/06/2020 cnwma1 Tfs #49400
			if self.filterGroupCode = "*" then
				check := true;
			endif;
			if _voyage.voyageGroupCode.startsWith(self.filterGroupCode) then
				check := true;
			else
				check := false;
			endif;
		endif;
	
		if self.filterExtCode &lt;&gt; null and check = true then    
			if self.filterExtCode = "*" then
				check := true;																
			endif;
			if _voyage.voyageCodeExternal.startsWith(self.filterExtCode) then
				check := true;													
			else
				check := false;													
			endif;
		endif;	
		
		if self.filterExtRef &lt;&gt; null and check = true then 
			if self.filterExtRef = "*" then
				check := true;													
			endif;
			if _voyage.externalRef.toUpper.pos(self.filterExtRef,1) &gt; 0 then
				check := true;													
			else
				check := false;						
			endif;
		endif;	
		
		return check;
	endif;
	//End 04 Apr 2022 navhl20 TFS 53352
	//End 08 June 2022 navhl20	#53799
	// The following check for no dates must be done BEFORE checking for future dates.
	
	if self.chkNoDates.value then
		if _voyage.arrivedDT &lt;&gt; null or _voyage.departedDT &lt;&gt; null then
			return false;
		endif;
	endif;
	
	if self.ckbFuture.value then
		if (not _voyage.arrivedDT.isValid) then
			// always include voyages that do not have an arrival date set
			return true;
		endif;
	endif;								
	
	//epr TFS 5479  28/817
	arrivalDT:=_voyage.arrivedDT;
	if arrivalDT = null or not _voyage.arrivedDT.isValid then
		arrivalDT:=_voyage.estimatedArrivalDT;
	endif;
	departDT :=_voyage.departedDT;
	if departDT = null or not _voyage.departedDT.isValid then
		departDT:=_voyage.estimatedDepartureDT;
	endif;
	// we have a match if it is between these dates
	if self.filterDateInPortFrom.isValid() then
		systemInPortFrom := self.localToSystemTime(self.filterDateInPortFrom.TimeStamp);
		if self.filterDateInPortTo.isValid() then
			systemInPortTo := self.localToSystemTime((self.filterDateInPortTo + 1).TimeStamp);
			if departDT &gt;= systemInPortFrom
			and arrivalDT &lt; systemInPortTo then		
				// we have a match for this range		
				return true;
			endif;
		elseif arrivalDT &gt;= systemInPortFrom then
			// we have a match for arrival date
			return true;
		endif;
		validDate := true;
	endif;
	// we have a match if it is between these dates
	if self.filterDateArrivalsFrom.isValid() then
		systemArrivalsFrom := self.localToSystemTime(self.filterDateArrivalsFrom.TimeStamp);
		if arrivalDT &gt;= systemArrivalsFrom then
			// false is arrived after this date
			if self.filterDateArrivalsTo.isValid() then
				systemArrivalsTo := self.localToSystemTime((self.filterDateArrivalsTo + 1).TimeStamp);
				if arrivalDT &lt; systemArrivalsTo then
					// we have a match for this range
					return true;
				endif;
			endif;
		endif;
		validDate := true;
	endif;

	// we have a match if it is between these dates
	if self.filterDateDeparturesFrom.isValid() then
		systemDeparturesFrom := self.localToSystemTime(self.filterDateDeparturesFrom.TimeStamp);
		if departDT &gt;= systemDeparturesFrom then
			// false is arrived after this date
			if self.filterDateDeparturesTo.isValid() then
				systemDeparturesTo := self.localToSystemTime((self.filterDateDeparturesTo + 1).TimeStamp);
				if departDT &lt; systemDeparturesTo then
					// we have a match for this range
					return true;
				endif;
			endif;
		endif;
		validDate := true;
	endif;

	if self.ckbFuture.value then
		if (arrivalDT.date &gt;= app.actualTimeServer.date) then
			// always include voyages that arrive after current date
			return true;
		endif;
	endif;
	
	if (not validDate) then
		if self.ckbAll.value then
			return true;	
		elseif self.filterArchivedVoyages then
			// no valid date entered so display all archived
			if _voyage.myTerminalArchived &lt;&gt; null then
				return true;
			else
				return false;
			endif;
		elseif self.ckbIncludeDeparted.value then	//02 Jun 2020	NDL	TFS 49417
			if _voyage.departedDT.date.isValid then
				return true;
			else
				return false;
			endif;
		else
			return true;
		endif;
	endif;

	return false;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="6a26ea18-eacd-4a8a-bd41-52df4437e926">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
//--------------------------------------------------
// Created:	14 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	pos				: Integer;
	xmlInfo			: String;
	hideExtraInfo	: Boolean;
	statusesStr : String;
	statuses : IntegerArray;
	statusStrArray : CnStringArray;
	str : String;
	
begin
	if _userWindow = null then
		return;
	endif;
	
	inheritMethod(_userWindow);
	
	xmlInfo			:=	_userWindow.xmlInfo;
	pos				:=	1;
	hideExtraInfo	:=	xmlInfo.cnEcGetNextTagValueOfName(XMLTag_HideExtraInfo, pos).Boolean;
	
	if hideExtraInfo then
		self.mnuHideShowInfo.caption	:=	app.getErrorString(Hide_Additional_Info);
	else
		self.mnuHideShowInfo.caption	:=	app.getErrorString(Show_Additional_Info);
	endif;
	
	self.mnuHideShowInfo.click(self.mnuHideShowInfo);

	pos := 1;
	self.dateInPortFrom.setDate(xmlInfo.cnEcGetNextTagValueOfName(XMLTag_InPortFrom, pos).asDateFromXMLFormat());
	pos := 1;
	self.dateInPortTo.setDate(xmlInfo.cnEcGetNextTagValueOfName(XMLTag_InPortTo, pos).asDateFromXMLFormat());
	pos := 1;
	self.dateArrivalsFrom.setDate(xmlInfo.cnEcGetNextTagValueOfName(XMLTag_ArrivalsFrom, pos).asDateFromXMLFormat());
	pos := 1;
	self.dateArrivalsTo.setDate(xmlInfo.cnEcGetNextTagValueOfName(XMLTag_ArrivalsTo, pos).asDateFromXMLFormat());
	pos := 1;
	self.dateDepartFrom.setDate(xmlInfo.cnEcGetNextTagValueOfName(XMLTag_DeparturesFrom, pos).asDateFromXMLFormat());
	pos := 1;
	self.dateDepartTo.setDate(xmlInfo.cnEcGetNextTagValueOfName(XMLTag_DeparturesTo, pos).asDateFromXMLFormat());
	pos := 1;
	self.ckbArchived.value	:=	xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Archived, pos).Boolean;
	pos := 1;
	self.ckbAll.value		:=	xmlInfo.cnEcGetNextTagValueOfName(XMLTag_All, pos).Boolean;
	pos := 1;
	self.ckbFuture.value	:=	xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Future, pos).Boolean;
	pos := 1;
	self.ckbIncludeCancel.value	:=	xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Cancelled, pos).Boolean; // cnwrd1 par 23993 25.5.2010
	pos := 1;
	self.chkNoDates.value	:=	xmlInfo.cnEcGetNextTagValueOfName(XMLTag_NoDates, pos).Boolean;
	
	//02 Jun 2020	NDL	TFS 49417
	pos := 1;
	self.ckbIncludeDeparted.value	:=	xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Departed, pos).Boolean;
	pos := 1;
	self.ckbNoQueryOnStartUp.value	:=	xmlInfo.cnEcGetNextTagValueOfName(XMLTag_NoQuery, pos).Boolean;	
	pos := 1;
	statusesStr := xmlInfo.cnEcGetNextTagValueOfName(XMLTag_Statuses, pos);
	if statusesStr &lt;&gt; null then
		statusStrArray := statusesStr.cnGetTokens(" ");
		foreach str in statusStrArray do
			self.savedVoyageStatuses.add( str.Integer );
		endforeach;
	endif;
			
	self.initialising	:=	true;
	
epilog

	delete statusStrArray;
	
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblData" id="d6750914-969b-49ff-983a-936cbd137101">
        <source>initTblData();
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
begin
	//11 Aug 2021	NDL	TFS 51746
	self.tblData.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_HMSVoyageData));
/*	if app.myCurrentUserCan(self.myTerminal, PmVTMISMod)  then
		if app.myCurrentUserCan(self.myTerminal, PmContainerMod) then
			//Display HMS and Cargo fields
			self.tblData.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_HMSVoyageData));
		else
			//Display HMS fields only
			self.tblData.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_VoyageData));
		endif;
	else
		//Display Cargo fields only
		self.tblData.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_VoyageEnquiryCargo));
	endif; */
	
	self.tblData.setMyDataClass(CM_Voyage);
	self.tblData.userInputEnabled	:=	false;
	self.tblData.selectMode			:=	Table.SelectMode_CurrentRow;
	self.tblData.selectionType		:=	CM_DataTable.SelectionType_Row;
	self.tblData.multiSelect		:=	self.tblData.MultiSelect_Simple;
	self.tblData.stretchWidth		:=	true;
	self.tblData.stretchHeight		:= 	false;
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="4e11def2-a060-4578-941b-509df053be79">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if keyCode = CMUI_Key_F3 then
		self.showHideSearcher();
	elseif keyCode = J_key_Enter then
		if self.frmSearch.visible then
			self.doSearch();
		endif;	
	elseif keyCode = CMUI_Key_F11 and 
	  (app.isAllowedToInspect() or app.isDevelopmentSystem()) then
		if self.myCurrentVoyage &lt;&gt; null then
			self.myCurrentVoyage.inspect();
		endif;
	
	else
		inheritMethod(keyCode, shift);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="3480e882-04bf-41ec-af8c-08ba6f50285d">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	if self.ckbNoQueryOnStartUp.value then	//02 Jun 2020	NDL	TFS 49417
		self.showHideSearcher();
	else
		self.doSearch();
	endif;
	self.initialising := false;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstTableDisplayRow" id="abc0c53a-6a21-40aa-9074-513e7ec48315">
        <updating/>
        <source>lstTableDisplayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	return null;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
