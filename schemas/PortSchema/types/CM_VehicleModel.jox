    <JadeMethod name="setForCreate" id="8edb8695-f7ed-4f4c-bb8c-a07cad002d9a">
        <updating/>
        <source>setForCreate(_proxyVehicleModel : CM_VehicleModel) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	_proxyVehicleModel.raiseExceptionIfNotTransient(method);
	
	self.myDutyDocRoot := _proxyVehicleModel.myDutyDocRoot;
	self.setForUpdate(_proxyVehicleModel);
epilog

end;</source>
        <Parameter name="_proxyVehicleModel" type="CM_VehicleModel"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="de66bb80-d562-4e68-8fcc-e39cd627b638">
        <updating/>
        <source>setForUpdate(_proxyVehicleModel : CM_VehicleModel) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.model := _proxyVehicleModel.model;
epilog

end;</source>
        <Parameter name="_proxyVehicleModel" type="CM_VehicleModel"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="2b824f7a-07cd-47a4-8e29-1ec6e9233c18">
        <updating/>
        <source>setProxy( _model : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);

	self.model 			:= _model;
	self.myDutyDocRoot 	:= app.myDutyDocRoot;
epilog

end;</source>
        <Parameter name="_model" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b53d7148-3588-43fa-9cf3-96da80b0131b">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	if app.myDutyDocRoot.allVehicleModels[self.model] &lt;&gt; null then 
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.model, null, null);
		return;
	endif;
	
	validateMe();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="562f584a-5506-47c4-bbef-f278ec240574">
