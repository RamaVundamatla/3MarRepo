    <JadeMethod name="utlCreateExtWebService" id="ebbfc048-9dcb-45e4-8622-1dd52bbb3424">
        <source>utlCreateExtWebService(_proxyExtWebService : CM_ExternalWebServiceDef; 
					_realExtWebService : CM_ExternalWebServiceDef output;
					_passport : CM_Passport input);
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
// 13 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
vars
	realMapping : CM_ExtWebServiceEventMapping; // TFS 40360
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.myValCA.valExtWebService(_proxyExtWebService);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);
	create _realExtWebService as _proxyExtWebService.class persistent;
	_realExtWebService.setForCreate(_proxyExtWebService);
	if _proxyExtWebService.myEventMapping &lt;&gt; null then // TFS 40360 - create real mapping
		create realMapping persistent; // TFS 40360 - if there's one on proxy
		realMapping.setEventType(_proxyExtWebService.myEventMapping.myEventType); // TFS 40360
		_realExtWebService.setMyEventMapping(realMapping); // TFS 40360
	endif; // TFS 40360
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_realExtWebService);
	endif;
epilog

end;</source>
