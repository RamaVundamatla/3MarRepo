    <JadeMethod name="getRateDateRangeString" id="19fd115a-848c-4912-b6ee-f8fd01481b97">
        <source>getRateDateRangeString():String;
/*

Purpose:			Report writer method

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2021	navndl1	Initial creation	TFS 50838

*/

vars

	firstCharge : CM_Charge;
	rateEntry : CM_RateEntry;
	retValue : String;

begin

	if self.charges.isEmpty then
		return null;
	endif;

	firstCharge := self.charges.first;
	
	if firstCharge &lt;&gt; null then
		rateEntry := firstCharge.getRateEntry();
	endif;
	
	if rateEntry &lt;&gt; null then
		retValue := rateEntry.startTimestamp.date.format("d MMMM yyy");
		if rateEntry.expiryTimestamp &lt;&gt; null and rateEntry.expiryTimestamp.date.isValid then
			retValue := retValue &amp; " to " &amp; rateEntry.expiryTimestamp.date.format("d MMMM yyy");
		endif;
	endif;
	
	return retValue.trimBlanks();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRateStartDate" id="1b93a35c-5392-48ae-95b3-939dab4a252b">
        <source>getRateStartDate():Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2021	navndl1	Initial creation	TFS 51914

*/

vars

	firstCharge : CM_Charge;
	rateEntry : CM_RateEntry;
	retValue : Date;

begin

	if self.charges.isEmpty then
		return null;
	endif;

	firstCharge := self.charges.first;
	
	if firstCharge &lt;&gt; null then
		rateEntry := firstCharge.getRateEntry();
	endif;
	
	retValue := null;
	
	if rateEntry &lt;&gt; null then
		retValue := rateEntry.startTimestamp.date;
	endif;
	
	if retValue.isValid then
		return retValue;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
