    <JadeMethod name="deleteEventType" id="6b851d1d-6482-4f8d-aae3-8ab19a17b9bf">
        <source>deleteEventType(_eCategory : Integer; _eName : String) : Boolean;
// --------------------------------------------------------------------------------
// Created:		03 Novemeber 2009 by cnwjo3
//
// Purpose:		Delete an Event type.  Basically emulate System Admin::Event Types
//				This is some what risky.  It appears the primary key is event type number :-(
vars
	event			: CM_EventType;
	success			: Boolean;
begin
	foreach event in app.myRoot.allEventTypesByType do
		if event.category = _eCategory and event.name = _eName then
			if event.category = CM_EventType.SYSTEM_EVENT then
				continue;  //no i won't let you delete system events here
			endif;
			
			app.myTrxDA.trxDeleteEventType(event, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				success := true;
			endif;
		endif;
	endforeach;
	
	return success;
epilog

end;</source>
        <Parameter name="_eCategory" type="Integer"/>
        <Parameter name="_eName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteFolderContents" id="3746596b-35fc-43ed-a147-8216449e7e92">
        <source>deleteFolderContents(exportPath : String; prefix : String);
/*
Purpose:			
Date		Who		Reason
29 April 2015	cnwab1	Initial creation
*/

vars

	fFolder	: FileFolder;
	file,
	tmpFile 	: File;
	filenode : FileNode;
	path,exportDir 		: String; 
	fileEx		: FileException; 
	answer		: Integer;
	invoiceTotal	: Decimal[12, 2];
	taxTotal		: Decimal[12, 2];
	idx : Integer;
	now : Date;
begin
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	path := exportPath.normaliseDirectory();
	
	create fFolder transient;
	fFolder.fileName := path;

	foreach filenode in fFolder.files do
		if filenode.name[1:prefix.length] = prefix then
		//	write " REMOVE: " &amp; filenode.name;
			filenode.cnEcRemove();
		endif;
		delete filenode; // transient leak
	endforeach;


epilog
	delete fFolder;
end;</source>
        <Parameter name="exportPath" type="String"/>
        <Parameter name="prefix" type="String"/>
    </JadeMethod>
