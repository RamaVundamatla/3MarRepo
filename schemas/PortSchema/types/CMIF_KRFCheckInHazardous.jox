        <source>copyToRealWSObject(_realRequest: KRF_CheckInHazardous input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Feb 2019	jlgsl4	TFS 40360 - KiwiRail EDI message

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.hazardousClass := self.hazardousClass;
	_realRequest.hazardousUN := self.hazardousUN;

epilog

end;</source>
