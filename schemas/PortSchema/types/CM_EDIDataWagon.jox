    <JadeMethod name="getRealTrain" id="29fb79d4-4b30-461f-95ba-310d46ec2402">
        <source>getRealTrain(
	_terminal	: CM_Terminal;
	_code		: String;
	_dateTime	: TimeStamp ) : CM_Train protected;

/*
Purpose:	This attempts to find the exist real train matching the supplied criteria.
			This is usually the train code and the scheduled arrival date

Date				Who		Reason
28 September 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
*/
	
vars
	train			: CM_Train;
	
begin
	// the train is unique for a code and arrival date/time.
	train	:= _terminal.allTrainsOnTerminal.getAtKeyGeq(_code, _dateTime);
	
	if train = null or train.code &lt;&gt; _code then
		return null;
	else
		return train;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <ReturnType type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="getRealWagon" id="306e20ee-9458-4631-8cee-de0d34532a2e">
        <source>getRealWagon(
	_train		: CM_Train;
	_code		: String ) : CM_Wagon protected;

/*
Purpose:	This attempts to find the exist real wagon matching the supplied criteria.
			This is usually on the the train allWagonsByIdInward collection.

Date				Who		Reason
28 September 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
*/
	
vars
	
begin
	if _train = null then
		return null;
	endif;
	
	return _train.allWagonsByIdInward[_code];
end;
</source>
        <access>protected</access>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="getTIProperties" id="de0996bc-0a81-486a-99ec-06801c5d0a5d">
        <source>getTIProperties(_propArray: ObjectArray io);
//
// cnwrs1 sept 2009 CCMS Messina 1008
//
vars
	popColl: PropertyNDict;
	property: Property;
begin
	inheritMethod(_propArray);
	popColl := CM_EDIWagonTI.getProperties();
	
	foreach property in popColl do
		_propArray.add(property);
	endforeach;
end;
</source>
        <Parameter name="_propArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="ef7d2f54-3edf-4800-b107-6b5df4352442">
        <updating/>
        <source>loadDB(_mergeCargo : Boolean; _passport : CM_Passport input) updating;

// NOTE:	_mergeCargo - Only relevant when loading a Bay Plan.

/*
Date				Who		Reason
28 September 2009	cnwrl1	Initial creation as part of PAR 20230 - New Messina Messages
*/
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 4

constants
	ProgressBarRefresh	= 2000;				// how often the progress bar gets refreshed ie 2 seconds
	
vars
	updateProg			: Boolean;
	partsDone			: Integer;
	partsInJob			: Integer;
	progressStr			: String;
	progressTS			: TimeStamp;
	progressInterval	: TimeStampInterval;
	ediTI 				: CM_EDITrackedItem;
	cmifMonitor			: CMIF_Monitor;
	passport			: CM_Passport;
	terminal			: CM_Terminal;
	
begin
	app.myTrxUA.trxProcessEDIWagon(self, false, _passport);	//par 26215 cnwrs1 15 Nov 2010

	// Arm our base exception handlers
//	on Exception do validationExceptionHandler(exception, app.myPassport);
/*	app.setContinueCMExceptions(true);	// get as many error messages in 1 go as possible
	
	passport	:= _passport;
	cmifMonitor	:= passport.myCMIFMonitor;
	updateProg	:= cmifMonitor &lt;&gt; null;
	partsInJob	:= self.allEDITrackedItems.size();
	partsDone	:= null;
	terminal	:= self.getMyTerminal();
	
	if terminal = null then
		// should never happen but just in case!
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
		return;
	endif;
	
	if app.getMyUser() = null then
		// should never happen but just in case!
		app.raiseCMException(UnknownUser, null, null);
		return;
	endif;
	
	progressStr	:= app.getString(Loading_EDI_Data_Total, partsInJob.display);
	progressTS	:= app.actualTimeAppServer();
	
	if updateProg then
		// start of process
		cmifMonitor.updateProgress(progressStr, partsInJob, partsInJob);
	endif;
	
	foreach ediTI in self.allEDITrackedItems do
		partsDone			:= partsDone + 1;
		progressInterval	:= app.actualTimeAppServer() - progressTS;
		
		if updateProg and progressInterval.getMilliseconds() &gt;= ProgressBarRefresh then
			cmifMonitor.updateProgress(progressStr, partsInJob, partsDone);
			progressTS	:= app.actualTimeAppServer();
		endif;
		
		self.zLoadDB(ediTI.CM_EDIWagonTI, terminal, passport);
		
		if passport.hasErrors() then
			return;
		endif;
	endforeach;
	
	if updateProg then
		// show we have finished this part of the process
		cmifMonitor.updateProgress(progressStr, partsInJob, partsInJob);
	endif;
	
	if _passport.noErrors() then
		app.myTrxUA.trxSetEDIDataStatus(self, CM_EDIFile.EDI_STATUS_DBLOADED);
	endif;
*/
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
