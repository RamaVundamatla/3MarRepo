    <JadeMethod name="pxyCreateUpdateProxy" id="4bb98967-556c-41bf-8232-f1f9cd3a8668">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2022	jlier1	Initial creation

*/

vars
	proxy 		: CM_HSCodeSubCode;
	completedOK	: Boolean;
	
begin

	proxy := inheritMethod();
	
	proxy.myHSCode := self.myHSCode;

	completedOK := true;
	return proxy;
	
epilog

	if not completedOK then
		delete proxy;
	endif;


end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
