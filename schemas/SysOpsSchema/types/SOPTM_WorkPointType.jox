    <JadeMethod name="setControlsForAddEdit" id="ef12d75f-a967-4729-961e-77bda103b3c2">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Apr 2023 navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars
	theForm : SOP_TableMaintForm;
	tbl		: CM_EntryTable;
begin
	theForm := self.myForm;
	tbl     := theForm.tblInput1;
	
	tbl.userInputEnabled  := true;
	theForm.mulSelect1.userInputEnabled := true;
	theForm.loadCmbWPType(null);
	
	tbl.disableRowByName(ETRow_IsSystemType);
		
	if theForm.mode = theForm.Mode_Add then 
		tbl.clearValues;
		tbl.enableRowByName(ETRow_Code);
		tbl.enableRowByName(ETRow_Description);
		tbl.enableRowByName(ETRow_Type);
		tbl.enableRowByName(ETRow_NotAvailableForEntry);
		tbl.setFocus;
		tbl.moveFirst();
		tbl.gotFocus(tbl);		
		
		theForm.mulSelect1.setSelected(null);
	else
		self.showThumbnail(theForm.myCurrentObject.CM_WorkPointType);
		tbl.disableRowByName(ETRow_Code);
		tbl.enableRowByName(ETRow_Description);
		tbl.enableRowByName(ETRow_Type);
		tbl.enableRowByName(ETRow_NotAvailableForEntry);
	endif;
	
    tbl.cnEcResizeContents;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="f08963af-1118-4bdb-beca-f93691e03ceb">
