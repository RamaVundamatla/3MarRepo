    <JadeMethod name="doAutoplan" id="b00884f4-d1f5-4c46-b32b-4de2b804979a">
        <updating/>
        <source>doAutoplan(_tiArray: CM_TIArray; _alertArray: CM_AlertsArray; _mode: Integer) updating;
//30 January 2009	cnwdw1	
//
vars
	ti		: CM_TrackedItem;
	str		: String;
	result	: Integer;
	params : CMIF_AutoplanParams;
begin
	if _tiArray = null and _alertArray = null then
		return;
	endif;
	// PAR 19450
	create params transient;
	if _tiArray &lt;&gt; null then
		_tiArray.copy(params.allTrackedItems);
	endif;
	if _alertArray &lt;&gt; null then
		_alertArray.copy(params.allAlerts);		// 27/04/2009 cnwar2 #19401, #19524, #19522
	endif;
	params.moveMode := _mode;
	params.myTerminalArea := null;
	params.myJob := null;
	params.showWarningWhenNoPlan := false; // PAR 19442
	
	while true do
		str := app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;	
	if str.trimBlanks &lt;&gt; null then		// PAR 19442
		app.msgBox(str, "Could Not Autoplan", MsgBox_Information_Icon + MsgBox_OK_Only);
	endif;

epilog
		delete params;
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray"/>
        <Parameter name="_alertArray" type="CM_AlertsArray"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBtnEditYardAllocClick" id="9a974ff4-75e8-463e-ab41-208d884b65bd">
        <updating/>
        <source>doBtnEditYardAllocClick() updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ydc							: YRD_ContainerDrawingController;
	obj							: Object;
	showYAF 					: Boolean;
	yalloc 						: CM_YardAllocation;

begin

	foreach obj in self.allDrawingControllers do
		ydc := obj.YRD_ContainerDrawingController;
		yalloc := self.doDisplayYardAllocationForEdit(ydc,showYAF);
		
	endforeach;

	self.doDisplayYardAllocationForm(yalloc,showYAF);

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSummariseAll" id="0933ed49-1efe-4e56-ad63-140c34e36aa1">
        <source>doBtnSummariseAll();

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
16 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	coll				: ObjectSet;
	cm_TerminalArea		: CM_TerminalArea;
	iter1				: Iterator;
	
begin
	app.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of ALL the objects (containers) to pass to the Summary Definition form.
	iter1	:= self.allTerminalAreas.createIterator;
	while iter1.next( cm_TerminalArea ) do : cm_TerminalArea_loop
		cm_TerminalArea.getAllLocationsTrackedItems( coll );
	endwhile cm_TerminalArea_loop;
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, false, true );
	
epilog
	delete coll;
	delete iter1;
	app.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
