    <JadeMethod name="determinant" id="be9fc537-56a2-41b5-930c-25f6ad469721">
        <source>determinant( pointB : Point) : Real;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2012	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	return self.x * pointB.y - self.y * pointB.x;
epilog

end;</source>
        <Parameter name="pointB" type="Point"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="inside" id="35d14458-13a7-4836-b193-d0f8fa153d24">
        <source>inside(topLeft, bottomRight : Point) : Boolean;
// return if self is inside a rectangle described by topLeft and bottomRight (includes topLeft and bottomRight)
vars

begin
	return not self.outside(topLeft, bottomRight);
end;
</source>
        <Parameter name="topLeft" type="Point"/>
        <Parameter name="bottomRight" type="Point"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="insidePolygon" id="91463600-e4ca-49b4-9255-da1f9dcc082a">
        <source>insidePolygon(polygon : PointArray) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2012	cnwer1	Initial creation CCMS MES 1033

*/

vars
	i, j     : Integer;
	c : Boolean;
begin

	c:=false;
	i := 1;
	j := polygon.size;
	
	while i &lt;= polygon.size do
 
		if (((polygon[i].y&gt;self.y) &lt;&gt; (polygon[j].y&gt;self.y)) and ( self.x &lt; (polygon[j].x- polygon[i].x) * (self.y-polygon[i].y)/(polygon[j].y-polygon[i].y)+polygon[i].x)) then
			c:=not c;
		endif;
	 
		i:=i+1;
		j:=i - 1;
	endwhile;
	 
	return c;
epilog

end;</source>
        <Parameter name="polygon" type="PointArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="left" id="421ca1ed-6b2a-45ab-bff6-9babd0b3c7a1">
        <source>left() : Integer;
begin
	return self.x;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="leftOf" id="281ff224-9c50-4d04-9b2f-935dacc6fd32">
        <source>leftOf(point : Point) : Boolean;
// Return true if self is left of point
begin
	return self.x &lt; point.x;
end;
</source>
        <Parameter name="point" type="Point"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="outside" id="52d3b8da-66c0-490f-8f1b-9288266112cb">
        <source>outside(topLeft, bottomRight : Point) : Boolean;
// return if self is outside a rectangle described by topLeft and bottomRight
begin
	return self.above(topLeft) or self.leftOf(topLeft) or
			self.below(bottomRight) or self.rightOf(bottomRight);
end;
</source>
        <Parameter name="topLeft" type="Point"/>
        <Parameter name="bottomRight" type="Point"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="right" id="623085dd-6f84-4974-9b7f-1c3a53b5380d">
        <source>right() : Integer;
begin
	return self.x;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="rightOf" id="3dd7778a-80a0-4307-9c20-3cb187148cdc">
        <source>rightOf(point : Point) : Boolean;
// Return true if self is left of point
begin
	return self.x &gt; point.x;
end;
</source>
        <Parameter name="point" type="Point"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="subtract" id="ca458bfe-be95-458a-bb10-1079ff6b2b72">
        <source>subtract(x, y: Integer) : Point;
//subtract x and y and return a new point
vars
	newPoint: Point;
begin
	newPoint.setX(self.x - x);
	newPoint.setY(self.y - y);
	return newPoint;
end;
</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Point"/>
    </JadeMethod>
    <JadeMethod name="top" id="f4f2797d-6207-492c-9c27-96559c6a8a22">
        <source>top() : Integer;
begin
	return self.y;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</PrimType>
