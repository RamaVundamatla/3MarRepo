    <JadeMethod name="addObjectsToTable" id="7cbaa5e3-c812-45f4-a860-ea6c8d8cf0fa">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:	2 April 2008 By Graeme Black cnwgb1
// Adds Debtor types to the left side
// ---------------------------------------------------------------------------

vars
	aDebtorType 	: CM_DebtorType;
	theDebtorTypes 	: CM_DebtorTypeByCodeDict;
	tmpPassport		: CM_Passport;
	breakOut		: Boolean;
begin

	self.setMyDataClass();
	beginClassNotification(CM_DebtorType, false, Object_Create_Event, Response_Continuous, 0); 

	theDebtorTypes := app.myRoot.allDebtorTypes;
	tmpPassport := app.myPassport;
	
	foreach aDebtorType in theDebtorTypes do
		if self.includeObject(aDebtorType, tmpPassport) then
			self.addObjectToTable(aDebtorType, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cmbDebtor_lostFocus" id="74e2a885-c36a-45ab-9035-222fa75c9949">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDebtor_lostFocus(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:	07 April 2008 By Graeme Black cnwgb1 CP CCMS 1047 Par 16666
// Move the value from the combo box to the table cell
// ---------------------------------------------------------------------------
begin
	self.tblEntDetail.setValueByControlName(combobox.name,combobox.text);

end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
