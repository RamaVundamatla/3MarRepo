    <JadeMethod name="trxDeleteFile" id="5b6b2694-6156-4d1f-b798-3dc5751d50bd">
        <updating/>
        <source>trxDeleteFile(_parent   : CM_Object;
			  _fileData : CM_FileData; 
			  _passport : CM_Passport input) updating;
/*
Created:     24 January 2007 by cnwaer1

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Mar 2022 navma1	ChangeRequest 52821: EUP - Documents Linked to Cargo Types

*/
vars
	fData		: CM_FileData;
	tmpParent	: CM_Object;
begin
    self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(true);
	
	fData:=_fileData;
	
	app.myValDA.valDeleteFile(_parent, fData);
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	tmpParent := fData.myParent;
	
	beginTransaction;
	delete fData;
	
	//22.03.2022 navma1 #52821
	if _passport.noErrors and tmpParent &lt;&gt; null then
		tmpParent.causeEvent(EventFileDelete, false, null);
		if tmpParent.isKindOf(CM_CargoBOLType) then
			self.updateObjectEdition(tmpParent);
		endif;
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);	
end;</source>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_fileData" type="CM_FileData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
