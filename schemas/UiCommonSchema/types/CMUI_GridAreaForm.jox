        <updating/>
        <source>tblGridAreaInfo_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
