    <JadeMethod name="initDefaultLayout" id="41a7d4e0-9822-4e21-9105-9c9aedaff66a">
        <updating/>
        <source>initDefaultLayout() updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lWidth, 
	lLength		: Integer;
	pointsPolygon : PointArray;

begin

	if self.myLayoutGraphic &lt;&gt; null then
		return;
	endif;

	if (not self.isTransient) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'cannot call for persistent terminal area');
		return;
	endif;

	create self.myLayoutGraphic transient;

	self.getDefaultLayoutValues(lWidth, lLength);

	create pointsPolygon transient;
	self.myLayoutGraphic.setDefaultOutline4(0,0, lWidth, lLength, pointsPolygon);
	self.myLayoutGraphic.setProxy(0, 0, self, Black, 0, 0, null, pointsPolygon, "Terminal Area " &amp; self.id,null);
	
epilog
	delete pointsPolygon;
end;</source>
    </JadeMethod>
