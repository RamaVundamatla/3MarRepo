    <JadeMethod name="validateForUpdate" id="0dafa223-e3ff-4bc4-bf3f-c4f961d821f1">
        <source>validateForUpdate();
/*
----------   ----------  --------------------------------------------------
Created:	31 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
08/12/2014   cnwdb2		PAR 35364	
----------   ----------  --------------------------------------------------
*/
vars
//	pxyFieldMapping		: CM_EDIFieldMapping;
//	pxyFieldHook		: CM_EDIFieldHookCode;
	realFileType,
	existingFileType		: CM_EDIFileTypeUser;
	mappingType : CM_EDIFieldMappingType;
begin

	if self.type = null then
		app.raiseUnexpectedProgramError(class.name, method.name, '_pxyFileTypeUser.type = null');
	endif;
	
	if self.name = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'File definition name', ETRow_Name, null);
		app.raiseCMException(Input_required_field_fleDefnNm, ETRow_Name, null);

	endif;
	
	if self.fileType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'File type', null, null);
		app.raiseCMException(Input_required_field_fleType, null, null); // cnwdb2	PAR 35364
	endif;
	
	existingFileType := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, self.name].CM_EDIFileTypeUser;
	realFileType	:= self.pxyGetRealObject();
	if existingFileType &lt;&gt; null
	   and existingFileType &lt;&gt; realFileType then
	//	app.raiseCMException3(ERR_DUPLICATE_KEY, 'A file type with', self.name, null, null, null);		
		app.raiseCMException1(Already_exists35364c, self.name, null, null); //cnwdb2 PAR 35364

	endif;	
	
	if (not self.allEDIFiles.isEmpty) then
		app.raiseCMWarning1(WARN_GENERIC, 'There are currently files loaded against this file type. These changes will have no effect on data already loaded.', null, null, self);
	endif;
//ccms1008 messina  cnwrs1 Sept 2009	
//	if self.allEDIFieldMappings.isEmpty then
//		app.raiseCMException1(Full_Replacement_Message, 'No field mappings entered. You must have at least one field.', null, null);
//	endif;
//ccms1008 messina  cnwrs1 Sept 2009 add validation for controlcolumn not greater than number of columns
	
	if self.emailActive then
		if self.emailNumLinesToSearch &lt; 1 then
//			app.raiseCMException1(Full_Replacement_Message, 'If auto-emailing is to be active you must specify at least one line to search', null, null);	// cnwrl1 28/10/2009 PAR 19893 - what it was
			app.raiseCMException(AutoEmailing_SearchLines_Error, null, null);
		endif;
		
		if self.emailSearchWords.size &lt; 1 then
//			app.raiseCMException1(Full_Replacement_Message, 'If auto-emailing is to be active you must specify at least one search word.', null, null);	// cnwrl1 28/10/2009 PAR 19893 - what it was
			app.raiseCMException( AutoEmailing_SearchWord_Error, null, null );
		endif;
	endif;
	
	if self.applyTranslations and self.myXlationOperator = null then // adm 180909 Par 19893 only warning
//		app.raiseCMWarning1(Full_Replacement_Message, 'Xlations are to be active but operator is not specified or invalid.', null, null, null);	// cnwrl1 27/10/2009 PAR 19893 - what it was
		app.raiseCMWarning( TranslationOperator_Error, null, null, null );
	endif;
	
//	foreach pxyFieldMapping in self.allEDIFieldMappings do
//		pxyFieldMapping.validateForUpdate();
//	endforeach;
	
//	foreach pxyFieldHook in self.allEDIFieldHookCodes do
//		pxyFieldHook.validateForUpdate();
//	endforeach;
	
	if self.myIncludeLineHookCode &lt;&gt; null then
		self.myIncludeLineHookCode.validateForUpdate();
	endif;
	
	foreach mappingType in self.allEDIFieldMappingTypes do
		mappingType.validateForUpdate();
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="xmlExceptionHandler" id="2a4031a7-c2c2-4b9f-aa78-582d1cfa0660">
        <source>xmlExceptionHandler(_exObj : Exception) :Integer;
//
// ccms 2044 cnwrs1 05 May 2011
//
vars
	returnValue : Integer;
	errStr : String;
begin
	returnValue := Ex_Resume_Next;
	errStr := app.getErrorString1(ERR_Parsing_XML, _exObj.errorItem)&amp;' ('&amp;_exObj.errorCode.String&amp;'). '&amp;_exObj.extendedErrorText;
	self.addFileErrors(errStr, null, null);
	return returnValue;
end;
</source>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
