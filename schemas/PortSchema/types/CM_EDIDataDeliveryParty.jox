    <JadeMethod name="verifyEDIDataTIs" id="2b1dced3-4e73-4879-8434-04c4867a499c">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2025	jlier1	Initial creation

*/

vars
	ediTI : CM_EDITrackedItem;
	errors : CM_ErrorSet; //par17172 cnwrs1 July 2008
	error : CM_Error;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(true);


	foreach ediTI in self.allEDITrackedItems discreteLock do
		ediTI.verifySelf();
	endforeach;
	
	create errors transient; //par17172 cnwrs1 July 2008
	app.myPassport.allErrors.copy(errors);
	foreach error in errors do
		error.setMyErrorPassport(null);
	endforeach;
	
	app.myTrxUA.trxProcessEDIData(self, true, false, _passport);
	
	foreach error in errors do
		error.setMyErrorPassport(app.myPassport);
	endforeach;
	
	return _passport.allErrorWarnings.size;
epilog
	delete errors;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
