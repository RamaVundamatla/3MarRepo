    <JadeMethod name="getStatusFromEDITrackedItems" id="1f056959-fade-4285-88db-6dca4043e720">
        <source>getStatusFromEDITrackedItems(_verifyOnly: Boolean): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2023	jlirs1	Initial creation ChangeRequest 57074: EUP - Ship Manifest EDI

*/

vars
	ediTI			: CM_EDITrackedItem;
	loadCount, todoCount, total	:Integer;
	verifyWarnings, 
	verifyErrors	: Boolean;
	statusCode		: Integer;
	ediData : CM_EDIData;
begin
	if not self.canGetStatusFromEDITrackedItem then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Method called for invalid EDI data type");
		return null;
	endif;
	
	if self.myCargoOnSite &lt;&gt; null then
		ediData := self.myCargoOnSite;
	elseif self.myGateDocument &lt;&gt; null then
		ediData :=  self.myGateDocument;
	elseif self.myShipManifest &lt;&gt; null then
		ediData :=  self.myShipManifest;
	elseif self.myTrainConsist &lt;&gt; null then
		ediData :=  self.myTrainConsist;
	endif;
	
	total := ediData.allEDITrackedItems.size;
	
	foreach ediTI in ediData.allEDITrackedItems discreteLock do
		if ediTI.status = CM_EDIFile.EDI_STATUS_DBLOADED then
			loadCount := loadCount + 1;
		else
			todoCount := todoCount + 1;
		endif;
		
		if ediTI.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS then
			verifyErrors	:=	true;
			
			break;
			
		elseif ediTI.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then	
			verifyWarnings	:=	true;
		endif;
	endforeach;
	
	if total = 0 then
		// nothing to do
		statusCode := CM_EDIFile.EDI_STATUS_UNPROCESSED;
		
	elseif loadCount = total then
		// everything is loaded
		if _verifyOnly then
			statusCode := CM_EDIFile.EDI_STATUS_VERIFIED;
		else
			statusCode := CM_EDIFile.EDI_STATUS_DBLOADED;
		endif;
		
	elseif loadCount &gt; 0 then
		// we have some EDi TIs that have DBLoaded and some not
		statusCode := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;		
		
	else
		// nothing has loaded - there are some that have not loaded (obviously)
		if verifyErrors then
			// there are some with verify errors
			statusCode := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
		elseif verifyWarnings then
			// there are some with verify warnings
			statusCode := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
		else
			// must be all OK
			statusCode := CM_EDIFile.EDI_STATUS_VERIFIED;
		endif;
	endif;

	return statusCode;

epilog

end;</source>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
