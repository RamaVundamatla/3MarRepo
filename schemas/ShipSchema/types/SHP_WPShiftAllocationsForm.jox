    <JadeMethod name="tblAllocatedGang_mouseMove" id="e24e4632-b8de-416a-a4fd-051b515b1a82">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAllocatedGang_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2019	jlgzm1	Initial creation TFS 42872 Direct Release Hold Voyages

*/

vars
	tmpHeight : Real;	
begin
	if table.fixedRows &gt; 0 then
		tmpHeight := table.accessRow(table.fixedRows).height;
		if self.origYPos &lt;= tmpHeight then
			return;
		endif;
	endif;
	
	if table.row &gt; table.fixedRows then	
		self.tblWLEMouseMoveEvent(table, button, shift, x, y);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
