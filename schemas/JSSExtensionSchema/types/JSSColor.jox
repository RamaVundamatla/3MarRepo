    <JadeMethod name="clearValues" id="6c988891-7806-4f95-a696-2680ae1593ee">
        <updating/>
        <source>clearValues() updating, protected;

begin
	self.blueValue		:=	0;
	self.greenValue 	:=	0;
	self.hexValue		:=	"";
	self.integerValue	:=	0;
	self.redValue		:=	0;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="hexEquivalent" id="babe0f0c-69e6-497d-9ad3-f474fc706454">
        <source>hexEquivalent(pInputValue : Integer): String protected;

vars
	returnValue	: String;
	
begin
	if pInputValue &lt; 10 then
		returnValue	:=	pInputValue.String;
		
	elseif pInputValue = 10 then
		returnValue	:=	"A";
		
	elseif pInputValue = 11 then
		returnValue	:=	"B";
		
	elseif pInputValue = 12 then
		returnValue	:=	"C";
		
	elseif pInputValue = 13 then
		returnValue	:=	"D";
		
	elseif pInputValue = 14 then
		returnValue	:=	"E";
		
	elseif pInputValue = 15 then
		returnValue	:=	"F";
		
	endif;
epilog
	return returnValue;	
end;</source>
        <access>protected</access>
        <Parameter name="pInputValue" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hexValue" id="b501d5da-04be-487d-af20-a9322002b015">
        <methodInvocation>mapping</methodInvocation>
        <source>hexValue(set: Boolean; _value: String io) mapping;
// -----------------------------------------------------------------------------
// Created:		29 January 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if (not set) then
		_value	:=	"#" &amp; _value;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="integerToHex" id="16dea4a6-c3d5-49b3-82a6-b3193a38c555">
        <source>integerToHex(pInteger : Integer):String protected;
	// Valid for integers less than or equal to 255.
	// returns the equivalent Hex value as a string. 
vars
	remainder		: Integer;
	result			: Integer;
	resultString	: String;
	remainderString	: String;
	
begin
	result			:=	(pInteger div 16);
	remainder		:=	(pInteger mod 16);
	
	resultString	:=	self.hexEquivalent(result);
	remainderString	:=	self.hexEquivalent(remainder);					
	
	return remainderString &amp; resultString;
end;</source>
        <access>protected</access>
        <Parameter name="pInteger" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setHex" id="cb45c5c2-910d-4430-9725-8e788f076031">
        <updating/>
        <source>setHex(pHexValue : String) updating;

vars
	workHex 	: String;
	red			: Integer;
	green		: Integer;
	blue		: Integer;
	position	: Integer;
	stringSize	: Integer;
	
begin
	self.clearValues();
	
	// If the hash prefix is supplied, then strip it off.
	
	if pHexValue[1] = "#" and pHexValue.length() &gt; 1 then
		workHex	:=	pHexValue[2:end].trimBlanks();
	elseif pHexValue[1] = "#" and pHexValue.length() = 1 then
		workHex	:=	"";		
	else
		workHex	:=	pHexValue.trimBlanks();
	endif;
	
	stringSize	:=	workHex.length();
	
	if stringSize = 0 then
		JSSException.raise_(JSS_X_03008, "No color hex value supplied.");
	elseif stringSize &gt; 6 then
		JSSException.raise_(JSS_X_03008, "Color hex value (" &amp; workHex &amp; ") is out of range (1-6 characters, excluding the '#').");
	endif;
		
	foreach position in 1 to stringSize do
		if not workHex[position].Character.isHex() then
			JSSException.raise_(JSS_X_03008, "Invalid color hex value (" &amp; workHex[position] &amp; ").");
		endif;
	endforeach;
	
	self.hexValue	:=	workHex;
	self.setIntegerColorFromHex(self.hexValue);
	
	self.integerValue.jssGetRGBValues(red, green,  blue);
	
	self.redValue	:=	red;
	self.greenValue	:=	green;
	self.blueValue	:=	blue;
end;</source>
        <Parameter name="pHexValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="setInteger" id="fe8df60a-da19-4221-a2e9-53e0bc0e7a69">
        <updating/>
        <source>setInteger(pColor : Integer) updating;

vars
	red		: Integer;
	green	: Integer;
	blue	: Integer;
	
begin
	self.clearValues();
	
	if pColor &gt; White then
		JSSException.raise_(JSS_X_03008, "Color value (" &amp; pColor.String &amp; ") is out of range (0-" &amp; White.String &amp; ").");
	endif;
	
	self.integerValue := pColor;
	
	self.integerValue.jssGetRGBValues(red, green,  blue);
	
	self.redValue	:=	red;
	self.greenValue	:=	green;
	self.blueValue	:=	blue;
	
	self.hexValue	:=	self.integerToHex(red) &amp;
						self.integerToHex(green) &amp;
						self.integerToHex(blue);
end;</source>
        <Parameter name="pColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setIntegerColorFromHex" id="dc6426cc-ba2f-48d4-9f56-c018f167bfdb">
        <updating/>
        <source>setIntegerColorFromHex(pHexValue : String) updating, protected;

vars
	char		: String;
	intArray	: IntegerArray;
	pos			: Integer;
	int			: Integer;
	size		: Integer;
	retValue	: Integer;
	
begin
	if pHexValue.trimBlanks().length() = 0 then
		return;
	endif;
		
	create intArray transient;
	
	pos		:=	0;
	size	:=	pHexValue.trimBlanks().length();
	
	foreach pos in 1 to size do
		char	:=	pHexValue[pos];
		
		if char = "A" then
			int := 10;
		elseif char = "B" then
			int := 11;
		elseif char = "C" then
			int := 12;
		elseif char = "D" then
			int := 13;
		elseif char = "E" then
			int := 14;
		elseif char = "F" then
			int := 15;
		else
			int := char.Integer;
		endif;
		
		intArray.add(int);				
	endforeach;
	
	pos		:=	0;
	size	:=	intArray.size();
	
	foreach pos in 1 to size do
		int := intArray[pos];
		
		if pos = 1 then
			retValue := retValue + int;
		elseif pos = 2 then
			retValue := retValue + (int * 16);
		elseif pos = 3 then
			retValue := retValue + (int * 256);
		elseif pos = 4 then
			retValue := retValue + (int * 4096);
		elseif pos = 5 then
			retValue := retValue + (int * 65536);
		elseif pos = 6 then
			retValue := retValue + (int * 1048576);
		endif;
	endforeach;
	
	self.integerValue	:=	retValue;
epilog
	delete intArray;
end;</source>
        <access>protected</access>
        <Parameter name="pHexValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="setRedGreenBlue" id="3fa6521e-cd89-4720-a097-47cac93ab3e5">
        <updating/>
        <source>setRedGreenBlue(pRed:Integer; pGreen:Integer; pBlue:Integer) updating;

begin
	self.clearValues();
	
	if pRed &gt; 255 or pRed &lt; 0 then
		JSSException.raise_(JSS_X_03008, "Red color value (" &amp; pRed.String &amp; ") is out of range (0-255).");
	elseif pGreen &gt; 255 or pGreen &lt; 0 then
		JSSException.raise_(JSS_X_03008, "Green color value (" &amp; pGreen.String &amp; ") is out of range (0-255).");
	elseif pBlue &gt; 255 or pBlue &lt; 0 then
		JSSException.raise_(JSS_X_03008, "Blue color value (" &amp; pBlue.String &amp; ") is out of range (0-255).");
	endif;

	self.redValue	:=	pRed;
	self.greenValue	:=	pGreen;
	self.blueValue	:=	pBlue;
	self.hexValue	:=	self.integerToHex(pRed) &amp; self.integerToHex(pGreen) &amp; self.integerToHex(pBlue);
	self.setIntegerColorFromHex(self.hexValue);
end;</source>
        <Parameter name="pRed" type="Integer"/>
        <Parameter name="pGreen" type="Integer"/>
        <Parameter name="pBlue" type="Integer"/>
    </JadeMethod>
</Class>
