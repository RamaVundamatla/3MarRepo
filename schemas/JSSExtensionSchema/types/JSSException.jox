    <DbClassMap file="jssxs_exception"/>
    <JadeMethod name="errorItem" id="7666b198-bc44-48e1-b872-6565b20eaef5">
        <methodInvocation>mapping</methodInvocation>
        <source>errorItem(set: Boolean; _value: String io) mapping;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		To ensure that the length of the error item (i.e. the error message)
//				will not exceed the maximum allowable length.  If the message is too
//				long, the remainder will be truncated.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	maximumLength	: Integer;
	
begin
	if set then
		maximumLength	:=	self.class().jssGetStringPropertyLength(method.name);
		
		if _value.length() &gt; maximumLength then
			_value	:=	_value[1:(maximumLength - 3)] &amp; "...";
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jssIsError" id="23d4b34c-19e3-4fc9-9be9-fe2da618c7eb">
        <source>jssIsError(): Boolean;
// --------------------------------------------------------------------------------
// Created:		08 April 2003 by cnwdad1
//
// Purpose:		Refer to implementation on the Exception superclass.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</ExceptionClass>
