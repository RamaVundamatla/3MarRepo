    <JadeMethod name="display" id="5c758499-cad4-4b00-bad3-a1497d999324">
        <source>display(): String;

/*

Purpose:			Actually show the association key/value pairs

Parameters:			

Return Value:		


Date				Who		Reason
17 June 2019		jlgmd1	Initial creation

*/

vars
	str 		: String;
	allProps	: PropertyNDict;
	prop 		: Property;
	pVal		: Any;
	value		: CM_Association;
	iter		: Iterator;
begin
	// Oid
	str := "---" &amp; self.getName &amp; "/" &amp; self.getOidString &amp; "---" &amp; CrLf;
	
	// Properties
	allProps := selfType.getProperties();
	foreach prop in allProps do
		pVal := self.getPropertyValue(prop.name);
		str := str &amp; prop.name &amp; " = ";
		if pVal.isKindOf(Object) then
			 str := str &amp; pVal.String &amp; " : " &amp; pVal.Object.edition.String &amp; CrLf;
		else
			str := str &amp; pVal.String &amp; CrLf;
		endif;
	endforeach;

	// Keys/Values
	str := str &amp; CrLf &amp; "size = " &amp; self.size.String &amp; CrLf;
	str := str &amp; "(" &amp; CrLf;
	
	iter := self.createIterator;
	while iter.next(value) do
		str := str &amp; iter.getCurrentKey(1).String &amp; " = " &amp; value.getValue().String &amp; CrLf;
	endwhile;
	
	str := str &amp; ")";
	
	return str;

epilog
	delete iter;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
