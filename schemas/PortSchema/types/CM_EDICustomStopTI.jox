    <JadeMethod name="erase" id="a14de828-b6ab-4033-9328-8a80b64f93f5">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//----------------------------------------------------------------
//	Created:	08 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ediFile : CM_EDIFile;
begin

	ediFile := self.myEDIFile;
	if ediFile &lt;&gt; null then
		if ediFile.allEDITIs.size = 1
		and ediFile.allEDITIs.first = self then
			//ok to delete ediFile
			self.myEDIFile := null;
			ediFile.erase(_eraseLevel);
		endif;
	endif;
		
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fullOrMTVerify" id="5182ccaa-b3c2-4711-a19d-afc2c229ac7c">
        <source>fullOrMTVerify(_terminal: CM_Terminal) :String;
vars
	value: Integer;
	message: String;
begin
	if self.isXMLOneStopCust then	//13 Sep 2016	NDL	TFS 2278 / 2670
		return VALID.String;
	endif;

	value := WARNING;
	if fullOrMT = "F" or
	   fullOrMT = "E" or
	   fullOrMT = "L" or
	   fullOrMT = "B" then
		value := VALID;
	else
		message := "Must be F,E,L or B.";
	endif;
	return value.String &amp; message;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllCustomsSeals" id="6c27effe-f586-4c1e-9429-4fbbdfb2f0fd">
        <source>getAllCustomsSeals(_strArray : StringArray io);
//
// 30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
//
vars
	ediTI : CM_EDITrackedItem;
begin
	if not self.allCustomsSeals.isEmpty then
		self.allCustomsSeals.copy(_strArray);
		return;
	endif;
	foreach ediTI in self.myAttachedItems do
		if ediTI.isKindOf(CM_EDISealTI) then
			_strArray.add(ediTI.CM_EDISealTI.sealEDINum);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_strArray" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getBubbleText" id="f990a509-703c-4e90-8e3e-226e9d26cb80">
        <source>getBubbleText(): String;
//----------------------------------------------------------------
//	Created:	03 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	txt	: String;
begin
	if self.mafInstructions &lt;&gt; null then
		txt := "DIN: " &amp; self.mafInstructions;
	endif;
	if self.quarantineInstructions &lt;&gt; null then
		if txt &lt;&gt; null then
			txt := txt &amp; CrLf;
		endif;
		txt := txt &amp; "QIN: " &amp; self.quarantineInstructions;
	endif;
	
	return txt;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCancelResponseCode" id="0e00b07f-0d86-4ddf-85aa-a1c6b0256e4a">
        <source>getCancelResponseCode(): String;
//----------------------------------------------------------------
//	Created:	09 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.responseStatus = Customs_Export_Cleared or 
		self.responseStatus = CustomsX12_Hold1C then
		return Customs_Export_Cancel;
	elseif self.responseStatus = Customs_Import_Cleared then//or
			//self.responseStatus = CustomsX12_Hold1H then
		return Customs_Import_Cancel;
	elseif self.responseStatus = Customs_Tranship_Cleared then
		return Customs_Tranship_Cancel;
	elseif self.responseStatus = SEP_ContainerRelease then
		return SEP_ContainerCancellation;
	else
		return Customs_Deliver_Null;
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayRowColour" id="1ddf845b-a6eb-4b43-bbaf-5972c58dfc64">
        <source>getDisplayRowColour(): Integer;
//----------------------------------------------------------------
//	Created:	27 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
//	if self.myVoyage &lt;&gt; null then	// cnwrl1 13/05/2010 PAR 24221 - what it was
	if self.getMyVoyage() &lt;&gt; null then
		return 12648384;
	else
		return 15269887;
	endif;

epilog

end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f68a5dd1-8685-4273-adbb-e7d1c1525448">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str		: String;
	cType	: CM_CargoType;
begin

	if _attrName = ETRow_CustomExportEntryNumber then
		return self.entryNumber;
	elseif _attrName = ETRow_TypeString then
		return self.typeString;
	endif;
		
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="989591e0-be4b-4ea5-8de4-fe7ab178141d">
        <source>getExtraInfo(_dataCont: CM_DataContainer);
//----------------------------------------------------------------
//	Created:	26 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	block : CM_DataContainerBlock;

begin
	// This needs to be carefully reviewed to see if it is really required.
	
	inheritMethod(_dataCont);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_VoyageExtra), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('voyageCode', false), DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Booking_Reference), DC_Label, 1, null);
//	block.addNewItem(self.bookingRef, DC_Data, 1, null);	// cnwrl1 26/02/2010 PAR 20113 - what it was
	block.addNewItem(self.billOfLading, DC_Data, 1, null);
	
	block := _dataCont.addNewBlock;
	block.addNewItem(app.getErrorString(System_Voyage), DC_Label, 1, null);
	block.addNewItem(self.getDisplayStringForAttribute('myVoyage', false), DC_Data, 1, null);

	block := _dataCont.addNewBlock;
	block.addNewItem("File/Sequence number ", DC_Label, 1, null);
	block.addNewItem(self.sequenceNum, DC_Data, 1, null);

	block := _dataCont.addNewBlock;
	block.addNewItem("Status ", DC_Label, 1, null);
	block.addNewItem(self.responseStatus, DC_Data, 1, null);

	block := _dataCont.addNewBlock;
	block.addNewItem("Comment ", DC_Label, 1, null);
	block.addNewItem(self.userNotes, DC_Data, 1, null);

end;
</source>
        <Parameter name="_dataCont" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getLast" id="4a885a07-94e4-4e22-8111-607498a35203">
        <source>getLast(): CM_EDICustomStopTI;
//----------------------------------------------------------------
//	Created:	17 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ediTI	: CM_EDICustomStopTI;
	int		: Integer;
begin
	return null;
	/*

	ediTI := self;

		
	while ediTI.mySubsequentClearance &lt;&gt; null
	and ediTI.id = ediTI.mySubsequentClearance.id 
	and ediTI.mySubsequentClearance &lt;&gt; ediTI do
		int := int + 1;
		if int &gt; 100 then	//check
			break;
		endif;
		ediTI := ediTI.mySubsequentClearance;
	endwhile;
	
	return ediTI;
	*/
end;</source>
        <ReturnType type="CM_EDICustomStopTI"/>
    </JadeMethod>
    <JadeMethod name="getMatchingBOLins" id="dafde194-4761-4196-b984-732be184edcb">
        <source>getMatchingBOLins(_tiArray : CM_TIArray input; _someIgnored : Boolean io) : CM_BOL;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 18/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 15/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
// 07/03/2013	cnwcs5		CCMS POL 2097 / par 31259 - include _foundMatch in method signatures
// 17/10/2014 	cnwmh5		Unit Test transient leak fix
// 21/10/2014 	cnwmh5		#35105 - Fix transient leak found my unit test UT_EDI::tTestVoyage_ProcessCustomsEDI
// 04 Mar 2019	jlgrs1		TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 29 Nov 2023	navpw1		TFS: 61364 (61375) - Modified to find bol on terminal by number and pack count. If the config setting is set 'Enforce Vessel Name Match for Customs EDI'
// 29 Apr 2024	navpw1		TFS: 63819 (63846) - Added logging for issue whereby house bol is being processed.
// 25 Mar 2025  naviv1		JIRA-19185 - PNL - Custom Stops not Added/Cleared for Motor Vehicles - DTR
//30/6/2025 navsaa30 MTN-35121 CPL | TSW 819 Clearance - Clarify Error Message
vars
	trackedItem 				: CM_TrackedItem;
	mainVoyage, altVoyage 		: CM_Voyage; //par20061 June 2009
	bolIn 						: CM_BOLIn;
	iter 						: Iterator;
	objArray 					: ObjectArray;
	tiCount 					: Integer;
	supportEmail, sendersEmail, vesselCode, 
	vesselName 					: String; //par23854 cnwrs1 28 Apr 2010
	vessel 						: CM_Vessel; //par23854 cnwrs1 28 Apr 2010
	foundMatch,
	eDIEnforceVeslMatchExprt	: Boolean;
	terminal					: CM_Terminal;	// ### TFS 61364 (61375) 24Nov2023 NAVPW1
	isProcOnSiteForBOLDTR		: Boolean;
	valid						: Integer;
begin

	// ### TFS 61364 (61375) 24Nov2023 NAVPW1
	terminal := self.getMyTerminal();
	isProcOnSiteForBOLDTR := terminal.getConfig(ProcOnSiteForBOLDTR).Boolean; //JIRA-19185
	
	//first determine main voyage
	mainVoyage := self.getMyVoyage();

	if mainVoyage = null then
		app.writeLog("Looking for voyage on terminal. Voyage: '" &amp; self.getVoyageCode() &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		mainVoyage := terminal.lookupVoyage(self.getVoyageCode(), null, false); //JIRA-19185
	endif;

	if mainVoyage = null then //par 14237 June 2007
		app.writeLog("Looking for voyage from vessel. Vessel: '" &amp; self.vesselName.trimBlanks() &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		vesselName 	:= app.myRoot.getXlationSystemCode(self.vesselName.trimBlanks(), XLATION_TYPE_VESSEL, foundMatch); // par 31259, par23854 cnwrs1 28 Apr 2010
		vessel 		:= app.myRoot.getVesselByName(vesselName); //par23854 cnwrs1 28 Apr 2010
		
		if vessel &lt;&gt; null then
			app.writeLog("Found vessel for vessel code. Looking up voyage on terminal from vessel.", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
			vesselCode := vessel.code; //par23854 cnwrs1 28 Apr 2010
			mainVoyage := terminal.getVoyageFromVesselCusRes(vesselCode, self.createdTime); //JIRA-19185
			
		endif;
		
	endif;
	
	if mainVoyage &lt;&gt; null then
		//now setup altvoyage
		app.writeLog("Found voyage '" &amp; mainVoyage.code &amp; "' related to vessel '" &amp; vesselCode &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		if mainVoyage.myCusresAltVoyage &lt;&gt; null then
			app.writeLog("Voyage has a cusres alt voyage. Voyage: '" &amp; self.getVoyageCode(), LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
			// ccms 1038 try cusres alternative voyage
			altVoyage := mainVoyage.myCusresAltVoyage; //par20061 June 2009
		endif;
	//  cmwrs1 June 2006 par 11961 ccms 1022
		app.writeLog("Looking for BOL. BOL Type: '" &amp; app.bolTypeAsEnumToString(BOLType_GeneralBillOfLading) &amp; "' | BOL Status: '" &amp; app.bolStatusEnumToString(BOL_STATUS_NORMAL) &amp; "' | Bol Number: '" &amp; self.billOfLading &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		bolIn := mainVoyage.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralBillOfLading, BOL_STATUS_NORMAL, self.billOfLading, null);
		
		if bolIn = null then //th2 temporary back stop for change over of BOL types
			app.writeLog("Looking for BOL. BOL Type: '" &amp; app.bolTypeAsEnumToString(BOLType_GeneralDocket) &amp; "' | BOL Status: '" &amp; app.bolStatusEnumToString(BOL_STATUS_NORMAL) &amp; "' | Bol Number: '" &amp; self.billOfLading &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
			bolIn := mainVoyage.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralDocket, BOL_STATUS_NORMAL, self.billOfLading, null);
		else
			if bolIn.number &lt;&gt; self.billOfLading then //par 14260 June 2007
				app.writeLog("Looking for BOL again as numbers do not match. BOL Type: '" &amp; app.bolTypeAsEnumToString(BOLType_GeneralDocket) &amp; "' | BOL Status: '" &amp; app.bolStatusEnumToString(BOL_STATUS_NORMAL) &amp; "' | Bol Number: '" &amp; self.billOfLading &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
				bolIn := mainVoyage.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralDocket, BOL_STATUS_NORMAL, self.billOfLading, null);
			endif;
		endif;
		
		if bolIn &lt;&gt; null and 
		   bolIn.number &lt;&gt; self.billOfLading then
			app.writeLog("BOL numbers do not match, setting bolIn to null. Bol Number Found: '" &amp; bolIn.number &amp; "' | Bol Number Requested: '" &amp; self.billOfLading &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
			bolIn := null;
		endif;
	endif;
	
	// Problem with following code as it changes the voyage local variable so that the house bol code in next section is
	// looking at the wrong voyage (refer PAR 20061) - the house bol code needs to check both voyages.
	
	if bolIn = null then
		if altVoyage &lt;&gt; null then //par20061 June 2009
			app.writeLog("BOL not found. Checking Alt Voyage", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
			app.writeLog("Looking for BOL on alt voyage. Voyage: '" &amp; altVoyage.code &amp; "' | BOL Type: '" &amp; app.bolTypeAsEnumToString(BOLType_GeneralBillOfLading) &amp; "' | BOL Status: '" &amp; app.bolStatusEnumToString(BOL_STATUS_NORMAL) &amp; "' | Bol Number: '" &amp; self.billOfLading &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
			bolIn := altVoyage.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralBillOfLading, BOL_STATUS_NORMAL, self.billOfLading, null); //par20061 June 2009
			if bolIn = null then //th2 temporary back stop for change over of BOL types
				app.writeLog("Looking for BOL on alt voyage. Voyage: '" &amp; altVoyage.code &amp; "' | BOL Type: '" &amp; app.bolTypeAsEnumToString(BOLType_GeneralDocket) &amp; "' | BOL Status: '" &amp; app.bolStatusEnumToString(BOL_STATUS_NORMAL) &amp; "' | Bol Number: '" &amp; self.billOfLading &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
				bolIn := altVoyage.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralDocket, BOL_STATUS_NORMAL, self.billOfLading, null);
			endif;
			if bolIn &lt;&gt; null and 
			   bolIn.number &lt;&gt; self.billOfLading then
				app.writeLog("BOL numbers do not match, setting bolIn to null. Bol Number Found: '" &amp; bolIn.number &amp; "' | Bol Number Requested: '" &amp; self.billOfLading &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
				bolIn := null;
			endif;
		endif;
	endif;
	
	
	
	eDIEnforceVeslMatchExprt := terminal.getConfig(EDIEnforceVeslMatchExprt).Boolean;
	app.writeLog("Is EDIEnforceVoyageMatch Turned on: '" &amp; eDIEnforceVeslMatchExprt.String, LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
	
	if mainVoyage = null and eDIEnforceVeslMatchExprt then
		app.writeLog("Looking for BOL on terminal. BOL Type: '" &amp; app.bolTypeAsEnumToString(BOLType_GeneralBillOfLading) &amp; "' | BOL Status: '" &amp; app.bolStatusEnumToString(BOL_STATUS_NORMAL) &amp; "' | Bol Number: '" &amp; self.billOfLading &amp; "' | Pack Count: '" &amp; self.packCount.String &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		bolIn := terminal.getBOLInByNumberPackCount(self.billOfLading, self.packCount,valid);			//navsaa30 #35121
		
	endif;
	// ### TFS 61364 (61375) 24Nov2023 NAVPW1
	
	// ccms 1058 try looking for a house bol cnwrs1 May 2007  //par20061 June 2009 try main voyage first
	if bolIn = null then
		if mainVoyage &lt;&gt; null then
			app.writeLog("Could not find Bol. Looking for House Bol Tis on voyage tis matching Voyage: '" &amp; mainVoyage.code &amp; "' | BOL: '" &amp; self.billOfLading &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 29Apr2024 NAVPW1
			create objArray transient;
			foreach trackedItem in mainVoyage.allTisByHouseBol where trackedItem.houseBillOfLading = self.billOfLading do
				objArray.add(trackedItem);
			endforeach;
			if objArray.size &gt; 0 then
				iter := objArray.createIterator();
				tiCount := objArray.size;
				app.writeLog("Found: " &amp; tiCount.String &amp; " tis matching Voyage: '" &amp; mainVoyage.code &amp; "' | BOL: '" &amp; self.billOfLading &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 29Apr2024 NAVPW1
			else
				// havent found a bolin as yet so retry the altvoyage with house bol
				if altVoyage &lt;&gt; null then  //par20061 June 2009
					app.writeLog("Looking for House Bol Tis on alt voyage tis matching Voyage: '" &amp; altVoyage.code &amp; "' | BOL: '" &amp; self.billOfLading &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 29Apr2024 NAVPW1
					/////create objArray transient;						// 21/10/2014 cnwmh5 #35105
					foreach trackedItem in altVoyage.allTisByHouseBol where trackedItem.houseBillOfLading = self.billOfLading do
						objArray.add(trackedItem);
					endforeach;
					if objArray.size &gt; 0 then
						iter := objArray.createIterator();
						tiCount := objArray.size;
						app.writeLog("Found: " &amp; tiCount.String &amp; " tis matching alt Voyage: '" &amp; altVoyage.code &amp; "' | BOL: '" &amp; self.billOfLading &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 29Apr2024 NAVPW1
					else	
						return bolIn;
					endif;					
				endif;
			endif;
		else
			if bolIn = null and isProcOnSiteForBOLDTR then //JIRA-19185 --&gt; if bolIn not found still, search for on-site cargo matching House BOL only when the "ProcOnSiteForBOLDTR" terminal config is enabled
				app.writeLog("Searching for On-Site Cargo with matching House BOL: '" &amp; self.billOfLading &amp; "'", LogDEBUG);
				create objArray transient;
				foreach trackedItem in terminal.allOnsiteTIsByIdCargoType discreteLock where trackedItem.houseBillOfLading = self.billOfLading  do
					objArray.add(trackedItem);
				endforeach;

				if objArray.size &gt; 0 then
					iter := objArray.createIterator();
					tiCount := objArray.size;
					app.writeLog("Found: " &amp; tiCount.String &amp; " On-Site Cargo TIs matching House BOL: '" &amp; self.billOfLading &amp; "'", LogDEBUG);
				else
					app.writeLog("No matching On-Site Cargo found for House BOL: '" &amp; self.billOfLading &amp; "'", LogDEBUG);
					return bolIn;
				endif;
			endif;
		endif;
	else
		if bolIn.number &lt;&gt; self.billOfLading then
			app.writeLog("BOL numbers do not match, setting bolIn to null. Bol Number Found: '" &amp; bolIn.number &amp; "' | Bol Number Requested: '" &amp; self.billOfLading &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
			bolIn := null;
			return bolIn;
		endif;
		app.writeLog("BOL has been found. Now processing BOL and getting a count of tis assigned", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		iter := bolIn.allTrackedItems.createIterator();
		if self.isXMLOneStopCust then	//16 Jun 2017	NDL	TFS 4844
			while iter.next( trackedItem ) do
				tiCount := tiCount + trackedItem.totalQuantity.max(1);
			endwhile;
			app.writeLog("One Stop Cust BOL Processing. TI Count: '" &amp; tiCount.String &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
			if tiCount &lt;&gt; self.packCount then
				app.writeLog("One Stop Cust BOL Processing. BOL Ti Count does not match the pack count. BOL Ti Count: '" &amp; tiCount.String &amp; "' | Pack Count: '" &amp; self.packCount.String &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
				bolIn := null;
				return bolIn;
			endif;
		else
			tiCount := bolIn.allTrackedItems.size;
			app.writeLog("BOL has been found. Now processing BOL and getting a count of tis assigned", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		endif;
	endif;
	
	if tiCount &lt;&gt; 0 and tiCount &lt;&gt; self.packCount then //ccms 1072
		app.writeLog("Ti Count is not 0 as we have found some tis (Can be due to House BOl Processing). But BOL Ti Count does not match the pack count. BOL Ti Count: '" &amp; tiCount.String &amp; "' | Pack Count: '" &amp; self.packCount.String &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		supportEmail := app.myRoot.getConfig(AutoSupportEmailAddress).String;
		sendersEmail := app.myRoot.getConfig(AutoSendersEmailAddress).String;
		app.writeLog("Cusres for BOL "&amp;self.billOfLading&amp;" has pack count "&amp;self.packCount.String&amp;" but BOL has "&amp;tiCount.String&amp;" tis.", LogINFO);
		app.remoteErrorWarningToAlert("Cusres for BOL "&amp;self.billOfLading&amp;" has pack count "&amp;self.packCount.String&amp;" but BOL has "&amp;tiCount.String&amp;" tis.",
									  null, app.myPassport.allErrors, null, false, true);
		app.myTrxCA.trxCreateEmailSendRequest('EDI', supportEmail, sendersEmail, null, null, "Cusres failed " ,
											  "Cusres for BOL "&amp;self.billOfLading&amp;" has pack count "&amp;self.packCount.String&amp;" but BOL has "&amp;tiCount.String&amp;" tis.", null, null, null, null, EmailSource_EDI, self, app.myPassport);
		return bolIn;
	endif;

	if iter &lt;&gt; null then
		while iter.next(trackedItem) do //ccms 1058
			// PAR 13018
			if trackedItem.isOnShip and
			   not self.getMyTerminal.myEdiConfig.allVoyagesToProcess.includes(trackedItem.myVoyage) then
				_someIgnored := true; //par14635 cnwrs1 Aug 2007
				app.writeLog("Ti is on ship and voyage is not in the terminal's edi config allVoyagesToProcess collection. Some Ti's ignored. Voyage: '" &amp; trackedItem.myVoyage.code, LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
				continue;
			endif;
			//PAR 8442
			// PAR #23645 CCMS 1116 move tranship check to first check, as isExport/isImport can return true for a tranship
			// PAR #25021 this is no longer true, isImport/isExport do not return true for tranships, but no need for any changes
			if self.responseStatus = Customs_Tranship_Cleared
			and (not trackedItem.isTranshipItem) then
				app.writeLog("Ignoring Tranship Cleared for Ti Id: '" &amp; trackedItem.id &amp; "'. Response status: '" &amp; self.responseStatus &amp; "' | Is Tranship: '" &amp; trackedItem.isTranshipItem.String &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
				continue;
			elseif (self.responseStatus = Customs_Export_Cleared
			or self.responseStatus = SEP_ContainerRelease)
			and (not trackedItem.isExport) then
				app.writeLog("Ignoring Export Cleared for Ti Id: '" &amp; trackedItem.id &amp; "'. Response status: '" &amp; self.responseStatus &amp; "' | Is Export: '" &amp; trackedItem.isExport.String &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
				continue;
			elseif (self.responseStatus = Customs_Import_Cleared
			or self.responseStatus = MAF_ActionRequired)
			and (not trackedItem.isImport) then
				app.writeLog("Ignoring Import Cleared for Ti Id: '" &amp; trackedItem.id &amp; "'. Response status: '" &amp; self.responseStatus &amp; "' | Is Import: '" &amp; trackedItem.isImport.String &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
				continue;
			endif;
			if self.tryLock(trackedItem, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate) then
				app.writeLog("Ti added to the array. Ti Id: '" &amp; trackedItem.id &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
				_tiArray.add(trackedItem);
			endif;
		endwhile;
	endif;
	return bolIn;
epilog
	delete objArray;
	delete iter;	// cnwdad1 13/09/2010.
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_someIgnored" type="Boolean" usage="io"/>
        <ReturnType type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="getMatchingTI" id="3d776ece-ddd6-4239-9c0b-29a7a3e292fe">
        <source>getMatchingTI(_term: CM_Terminal; _tiArray : CM_TIArray input);
//----------------------------------------------------------------
//	Created:	05 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 25 Oct 2018	jlgsl4	TFS 39133 - TSW - process stops for not-onsite cargo
// 03 May 2021	navdap1	TFS 51121 POL Retain Storage as Import Stop configuration not working for TSW message processing
// 21 Mar 2023  navsp1 TFS 56275 ChangeRequest 56275: PNL - New Terminal Config 'Enforce Vessel Name Match for Customs EDI' for Export Container Only
vars
	trackedItem					: CM_TrackedItem;
	terminal					: CM_Terminal;
	ediCargoType				: Integer;
	eDICusresTSExpOnImp,
	eDIEnforceVoyageMatch,
	eDIEnforceVeslMatchExprt	: Boolean;
	voyage						: CM_Voyage;
	invalidVoyage				: Boolean; //cnwgb1 PAR 20335 23.7.09
	train						: CM_Train;
	lVesselName					: String; //par 25961 cnwrs1 6 oct 2010 this is the vessel we have match to be used with the vessel name match	
	
begin
	on Exception do app.handleDeletedObject( exception, voyage, invalidVoyage ); //cnwgb1 PAR 20335 23.7.09 Skip invalid voyages
	
	trackedItem := null;
	
	if _term = null then
		return;
	else
		terminal := _term;
	endif;
	
	eDICusresTSExpOnImp := terminal.getConfig(EDICusresTSExpOnImp).Boolean;
	
	app.writeLog("Is EDICusresTSExpOnImp Turned on: '" &amp; eDICusresTSExpOnImp.String, LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
	
	if self.cargoType &lt; 1 then
		//not set - assume container
		ediCargoType := TI_CargoType_Container;
	else
		ediCargoType := self.cargoType;
	endif;
	
	app.writeLog("EDI Cargo Type: '" &amp; ediCargoType.String, LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
	
	// Can we find it onsite?
	trackedItem := terminal.allOnsiteTIsByIdCargoType[self.id, ediCargoType];	
	app.writeLog("Looking for tracked item in on site tis by cargo type. Ti Id: '" &amp; self.id &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
	
	//PAR 7828
	if trackedItem = null then
		if self.isForExport then
			app.writeLog("Tracked item not found on site and this is an export custom message.", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
			//check notified
			trackedItem := terminal.allNotifiedTIsByIdCargoType[self.id, ediCargoType];
			app.writeLog("Looking for tracked item in notified tis by cargo type.", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
			
			if trackedItem = null then
				if eDICusresTSExpOnImp then
					app.writeLog("Tracked item not found in notified tis. Looking through all voyages to process that have not departed", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
					//check the onship stuff
					// CCMS 1488 - check for tranships
					foreach voyage in terminal.myEdiConfig.allVoyagesToProcess do
						if not voyage.hasDeparted then //cnwgb1 PAR 20335 23.7.09
							trackedItem := voyage.allTranshipTIsExport[self.id, ediCargoType];
							
							if trackedItem &lt;&gt; null then
								app.writeLog("Tracked item found on a voyage in all tranship tis export.", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
								lVesselName := voyage.vesselName.toUpper.trimBlanks; //cnwrs1 par 25961 5 Oct 2010
								break;
							endif;
						endif;
					endforeach;
				endif;
			endif;
			
		elseif self.isForImport then
			app.writeLog("Tracked item not found on site and this is an import custom message. Looking through all voyages to process that have not departed", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
			//check the onship stuff
			foreach voyage in terminal.myEdiConfig.allVoyagesToProcess do
				if not voyage.hasDeparted then //cnwgb1 PAR 20335 23.7.09
					trackedItem := voyage.allOnshipTIsByIdCargoType[self.id, ediCargoType];
					
					if trackedItem &lt;&gt; null then
						app.writeLog("Tracked item found on a voyage in all on ship tis.", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
						lVesselName := voyage.vesselName.toUpper.trimBlanks; //cnwrs1 par 25961 5 Oct 2010
						break;
					endif;
				endif;
			endforeach;
			
			//30 Nov 2009	NDL	- CCMS 1013 Par 21519
			//check the inward cargo on train's if the tracked item hasn't already been found on a ship.
			if trackedItem = null then
				app.writeLog("Tracked item not found on ship and this is an import custom message. Looking through all trains to process", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
				foreach train in terminal.myEdiConfig.allTrainsToProcess do
					trackedItem := train.getInwardCargoByTIAndType(self.id, ediCargoType);
					
					if trackedItem &lt;&gt; null then
						app.writeLog("Tracked item found on a train. Train Code: '" &amp; train.code &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
						break;
					endif;
				endforeach;
			endif;
		endif;
	else
		app.writeLog("Tracked item found on site", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
	endif;
	
	if trackedItem = null then
		app.writeLog("Tracked item not found.", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		return;
	endif;
	
	// cnwrl1 07/04/2009 PAR 19400 CCMS 1825 - start of coding
	// This terminal configuration is now Enforce by Vessel Name (not Voyage).
	eDIEnforceVoyageMatch := terminal.getConfig(EDIEnforceVoyageMatch).Boolean;
	app.writeLog("Is EDIEnforceVoyageMatch Turned on: '" &amp; eDIEnforceVoyageMatch.String, LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
	
	if self.vesselName &lt;&gt; null and eDIEnforceVoyageMatch then
		app.writeLog("lVesselName: '" &amp; lVesselName, LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		if lVesselName = null then  //cnwrs1 par 25961 5 Oct 2010
			lVesselName := trackedItem.vesselName.toUpper.trimBlanks;
			app.writeLog("Changing lVesselName: '" &amp; lVesselName, LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		endif;
		
		eDIEnforceVeslMatchExprt := terminal.getConfig(EDIEnforceVeslMatchExprt).Boolean;
		app.writeLog("Is eDIEnforceVeslMatchExprt Turned on: '" &amp; eDIEnforceVeslMatchExprt.String, LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		
		if (not eDIEnforceVeslMatchExprt) or (eDIEnforceVeslMatchExprt and trackedItem &lt;&gt; null and trackedItem.isExport) then //21.Mar.2023 navsp1 TFS 56275
			if self.vesselName.toUpper.trimBlanks &lt;&gt; lVesselName then  //cnwrs1 par 15961 5 Oct 2010
				// cnwrl1 11/08/2009 PAR 20301
				/* Otago, who requested CCMS 1825 now do not want emails generated from this exception. */
				app.writeLog("Vessel names do not match. self.vesselName: '" &amp; self.vesselName.toUpper.trimBlanks &amp; "' | lVesselName: '" &amp; lVesselName &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
				return;
			endif;
		endif;
	endif;

	//PAR 8442
	if (self.responseStatus = Customs_Export_Cleared or self.responseStatus = SEP_ContainerRelease	// TFS 39133
		or (self.hasValidTSWResponse(false) and self.isTSWExport)) and (not trackedItem.isExport and not trackedItem.isTranshipItem) then   //cnwrs1 par 25961 5 Oct 2010 // TFS 39133
		app.writeLog("Ignoring Export Cleared for Ti Id: '" &amp; trackedItem.id &amp; "'. Response status: '" &amp; self.responseStatus &amp; "' | Has valid TSW Response: '" &amp; self.hasValidTSWResponse(false).String &amp; "' | Is TSW Export: '" &amp; self.isTSWExport.String &amp; "' | Is Export: '" &amp; trackedItem.isExport.String &amp; "' | Is Tranship: '" &amp; trackedItem.isTranshipItem.String &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		return;
		
 	elseif ((self.responseStatus = Customs_Import_Cleared or self.responseStatus = MAF_ActionRequired ) and not trackedItem.isImport)	// TFS 39133 // 04/12/18
		or ((self.hasValidTSWResponse(true) and self.isTSWImport) and // TFS 39133 // 04/12/18 - allow import TSW messages to affect tranship 
			//(not trackedItem.isImport and not trackedItem.isTranshipItem)) then // TFS 39133 // 04/12/18						// TFS 51121
			(not trackedItem.isImport and not trackedItem.isTranshipItem and not trackedItem.isStorageWasImportOnShip and 		// TFS 51121
			not trackedItem.isStorage)) then																					// ### JIRA: MTN-35793 02Oct2025 NAVPW1
		app.writeLog("Ignoring Import Cleared for Ti Id: '" &amp; trackedItem.id &amp; "'. Response status: '" &amp; self.responseStatus &amp; "' | Is Import: '" &amp; trackedItem.isImport.String &amp; "' | Has valid TSW Response: '" &amp; self.hasValidTSWResponse(true).String &amp; "' | Is TSW Import: '" &amp; self.isTSWImport.String &amp; "' | is Tranship: '" &amp; trackedItem.isTranshipItem.String &amp; "' | Is Storage Was Import on Ship: '" &amp; trackedItem.isStorageWasImportOnShip.String &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		return;
		
	elseif self.responseStatus = Customs_Tranship_Cleared and (not trackedItem.isTranshipItem) then
		app.writeLog("Ignoring Tranship Cleared for Ti Id: '" &amp; trackedItem.id &amp; "'. Response status: '" &amp; self.responseStatus &amp; "' | Is Tranship: '" &amp; trackedItem.isTranshipItem.String &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		return;
	endif;

	if trackedItem &lt;&gt; null and self.tryLock(trackedItem, Exclusive_Lock, Transaction_Duration, LockTimeout_Immediate) then
		app.writeLog("Ti added to the array. Ti Id: '" &amp; trackedItem.id &amp; "'", LogDEBUG); // ### TFS 63819 (63846) 02May2024 NAVPW1
		_tiArray.add(trackedItem);
	endif;
	
epilog
	return;
end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyTIDisplayDefName" id="ad8d3c9b-6ede-4ad5-bbe1-98e43bab691f">
