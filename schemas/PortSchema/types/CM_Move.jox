    <JadeMethod name="getMyStockMovement" id="6650f27c-cd76-41cb-842d-3bfb56dfbdb6">
        <source>getMyStockMovement(): CM_StockMovement;
//--------------------------------------------------------------
//Created: 10 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
