end;</source>
        <ReturnType type="CM_Error"/>
    </JadeMethod>
    <JadeMethod name="getLastWarningsAsString" id="dd1ddba4-5e83-4fc6-9d2b-f71304fb4900">
        <source>getLastWarningsAsString(_number : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2012	cnwer1	Initial creation PAR 30025

*/

vars
	warningIter		: Iterator;
	warning : CM_Error;
	warningCount : Integer;
	str : String;
begin
	if _number = 0 or self.allWarnings.size = 0  then
		return null;
	endif;
	warningIter:=self.allWarnings.createIterator;
	warningCount:=0;
	while warningIter.back(warning) do
		if str = null then
			str := warning.getDetailsAsString;
		else
			str := str &amp; CrLf &amp; warning.getDetailsAsString;
		endif;
		warningCount := warningCount + 1;
		if warningCount = _number then
			break;
		endif;
	endwhile;
	
	return str;
epilog	
	delete warningIter;
end;</source>
        <Parameter name="_number" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyBGPAgent" id="005c2084-3fd9-4a59-b82f-b38dbf9c6504">
