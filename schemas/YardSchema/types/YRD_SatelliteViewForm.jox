    <JadeMethod name="showSearchParameters" id="a1a8cb4b-bf94-4d2f-bd6d-35fab1b3fb5d">
        <source>showSearchParameters();

/*

Purpose:			Display current search parameters

Parameters:			

Return Value:		


Date				Who		Reason
05 September 2008	consw1	Initial creation

*/

vars
	proxyCriteria	: CM_YACriteria;
	searchParams	: CMIF_YACriteriaSearch;
	tmpObj			: CMIF_Object;

begin
	self.tblSearch.rows := 0;
	self.tblSearch.accessColumn(1).visible := false;

	if not self.tblYAM.hasSearchParameters() then
		self.dkbSearch.visible := false;
		return;
	endif;

	searchParams := self.tblYAM.mySearchParameters;
	
	foreach tmpObj in searchParams.allSearchCriteria do
		proxyCriteria := tmpObj.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
		tblSearch.addItem( Tab &amp; proxyCriteria.getDescription() );
	endforeach;

	tblSearch.addItem( Tab &amp; searchParams.getStatusDisplay() );

	tblSearch.adjustHeight(2000);

	self.dkbSearch.visible := true;
	
	tblSearch.top 	:= self.frmSearchToolbar.height;
	tblSearch.width	:= self.frmSearchToolbar.width;
	
	self.doExpandSearchParameters();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showUserSelectedRegions" id="aaf9e2d5-5f75-4397-9300-b7c2c4a00528">
        <source>showUserSelectedRegions( cdf : YRD_ContainerOverDrawingFrame io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 September 2011	cnwndl1	Initial creation	Par 28236

*/

vars

	region : CMUI_Region;
	x1, y1, x2, y2 	: Integer;

begin

	if cdf = null then
		return;
	endif;

	cdf.drawStyle := DrawStyle_Dash;
	foreach region in  self.allSelectedRegionObjs do
		x1 := region.x1;
		y1 := region.y1;
		x2 := region.x2;
		y2 := region.y2;
		cdf.drawRectangle( x1, y1, x2, y2, Red);
	endforeach;

epilog

end;</source>
        <Parameter name="cdf" type="YRD_ContainerOverDrawingFrame" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tblFailAutoPlanDblClick" id="aa84880c-53eb-43f2-b8c2-2f0e38b4c0fb">
        <updating/>
        <source>tblFailAutoPlanDblClick(table : Table input) updating;
// --------------------------------------------------------------------------------
// Created:		11 May 2009 by cnwjo3
//
// Purpose:		Deal with sorting and other functions

vars
	theRow : Integer;
	heading : String;
	theCol : Integer;
begin
	theRow := table.row;

	if theRow &lt;= 0 then
		return;
	endif;
	
	theCol := table.column;
	
	if theRow = 1 then
		if theCol &gt; 0 and theCol &lt;= table.columns then
			table.sortColumn[1] := theCol;
			table.sortAsc[1] := not table.sortAsc[1];
			table.sortCased[1] := false;
			if table.CM_DataTable.getColumnByRowName(ETRow_FailDate) = theCol then
				table.sortType[1] := Table.SortType_TimeStamp;
			else
				table.sortType[1] := Table.SortType_Alpha;
			endif;
			table.resort();
		endif;
	else
		self.doPositionAt();
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
