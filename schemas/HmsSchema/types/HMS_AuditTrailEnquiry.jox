    </JadeMethod>
    <JadeMethod name="setupForm" id="ad6e686a-3537-4509-a5f4-c80b4b15d5e4">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------------------
//Created: 18 July 2003 By: cnwgd1
//--------------------------------------------------------------
begin
	inheritMethod();

	self.myHarbour := self.myTerminal.myHarbour;
	
// cnwdad1 11/07/2008 - PAR #17493.
	if self.myHarbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
		self.unloadForm();
		return;
	endif;
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;		
	self.setNavigatorHeading(self.caption);
	self.initDataTables();
	
	self.fldCriteria.useSheetBackColors := true;
	self.fldCriteria.setDefaultSheetBackColors();
	self.fldCriteria.initSheetBackColors();
	self.fldMain.useSheetBackColors := true;
	self.fldMain.setDefaultSheetBackColors();
	self.fldMain.initSheetBackColors();

	self.beginClassNotification(CM_User, false, Any_System_Event, Response_Continuous,1);
	self.beginClassNotification(CM_Vessel, false, Any_System_Event, Response_Continuous,1);

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="1a9beef9-1632-4bca-941c-cda989aad4b5">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	12 January 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.handleNotifications(eventType, theObject.CM_Object, eventTag, theObject.CM_Object);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDetails_contextMenu" id="f9e5e2dd-0092-4eff-9b0c-9739bf3fea35">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDetails_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	16 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	x1, y1 : Real;
begin

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.mnuColumnOrganizer.userObject := table;	
	popupMenu(self.mnuContextTable, x1.Integer, y1.Integer);
	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
