			m.checkFolder("\\" &amp; m.hostName &amp; "\c$\Users\cnwjbl6\AppData\Local\Temp");
		endif;
	endforeach;/**/
	
	// back up jblworker.conf
	/*foreach m in Machine.instances where m.hostName &lt;&gt; "cnwchcs91" and m.hostName &lt;&gt; "cnwchcs131" do // and m.hostName = "cnwchcs127" do
		f.fileName:="\\" &amp; m.hostName &amp; "\c$\thinbin\tools\jblworker.conf";
		s:=f.readString(f.fileLength);
		f.close;
		//g.fileName:="\\" &amp; m.hostName &amp; "\c$\thinbin\tools\jblworker" &amp; app.actualTime.date.format("_yyyyMMdd") &amp; ".conf";
		g.fileName:=miscPath &amp; "\jblworker_backup\jblworker_" &amp; m.hostName &amp; app.actualTime.date.format("_yyyyMMdd") &amp; ".conf";
		g.writeString(s);
		g.lastModifiedTime:=f.lastModifiedTime;
		g.close;
	endforeach;/**/
	
	/*foreach m in Machine.instances where m.hostName &lt;&gt; "cnwchcs91" and m.hostName &lt;&gt; "cnwchcs131" do // and m.hostName = "cnwchcs127" do
		f.fileName:="\\" &amp; m.hostName &amp; "\c$\thinbin\tools\jblworker.conf";
		g.fileName:="\\" &amp; m.hostName &amp; "\c$\thinbin\tools\jblworker.conf";
		s:=f.readString(f.fileLength);
