    <JadeMethod name="doOK" id="6dac22ac-a8d4-418b-96a8-c1a4e35eccaa">
        <updating/>
        <source>doOK() updating;
//--------------------------------------------------
// Created:	24 Feb 2006 By: cnwjc2
//--------------------------------------------------
vars
	retVal		: Integer;
begin
	if self.doUpdateEmailDefaults() then
		inheritMethod();	
	else
		//retVal := app.msgBox("Saving to terminal defaults failed.  Continue without saving?","Continue?", MsgBox_Yes_No);
		//if retVal = MsgBox_Return_Yes then
			//continue without saving
		//	self.chkSave2Terminal.value := false;
		//	self.doOK();
		//else
			//stop
			return;
	//	endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateEmailDefaults" id="c636b762-cc8f-4c94-b6b0-fd96e92f0447">
        <source>doUpdateEmailDefaults(): Boolean;
//----------------------------------------------------------------
//	Created:	22 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	sa				: StringArray;
	cmString		: CM_String;
	returnValue		: Boolean;
	termEmailDefaults,
	proxyPINEmail	: CM_PINObjectDefaultEmail;
	emailTempl		: CMIF_EmailTemplateController;
begin

	create sa transient;
	
	self.mulSelectFields.getSelectedDisplayEntries(sa);	
	
//	self.myEmailDefaults.setProxyPINEmail(self.txtSubject.text,self.txtMessage.text, sa, self.chkCartersNote.value, self.myEmailDefaults.enabled);	// cnwrl1 29/07/2009 PAR 20349 - what it was
	self.myEmailDefaults.setProxyPINEmail(	self.txtSubject.text,
											self.txtMessage.text,
											sa,
											self.chkCartersNote.value,
											self.myEmailDefaults.enabled,
											self.myEmailDefaults.copyTo,
											self.myEmailDefaults.sendToCarrier,
											self.myEmailDefaults.sendToConsignee );
	
	emailTempl := self.myEmailController;
	
	//these are the only email sources we can trust 100% - what they see is what they get
	emailTempl.freeTxtToAddesses := self.txtToAddress.text.trimBlanks;
	emailTempl.freeTxtCcAddesses := self.txtCcAddress.text.trimBlanks;
	emailTempl.freeTxtBccAddesses := self.txtBccAddress.text.trimBlanks;
	
	if self.myEmailDefaults.allCarrierAddresses.isEmpty
	and emailTempl.freeTxtToAddesses = null
	and emailTempl.freeTxtCcAddesses = null
	and emailTempl.freeTxtBccAddesses = null then
		//noone to send to???
		app.msgBox("An email will not be sent as there are no valid addresses.","Warning", 0 + MsgBox_Information_Icon);
		//return false;
		return true;	//inform and save. Par 19427 April 2009 cnwvu1
	endif;
	
	returnValue := true;
	if self.chkSave2Terminal.value = true then
		//update the terminal copy
//		termEmailDefaults := self.myTerminal.getCarrierEmailDefaultsForType(self.myEmailDefaults.type);	// cnwrl1 30/07/2009 PAR 20349 - what it was
		termEmailDefaults := self.myTerminal.getEmailDefaultsSettings( self.myEmailDefaults.type );
		
		//added by cnwyl1 11072006
		//termEmailDefaults.myEmailController := emailTempl;
		//get a proper proxy for this update
		proxyPINEmail := app.createUpdateProxy(termEmailDefaults).CM_PINObjectDefaultEmail;
//		proxyPINEmail.setProxyPINEmail(self.txtSubject.text,self.txtMessage.text, sa, self.chkCartersNote.value, termEmailDefaults.enabled);	// cnwrl1 29/07/2009 PAR 20349 - what it was
		proxyPINEmail.setProxyPINEmail(	self.txtSubject.text,
										self.txtMessage.text,
										sa,
										self.chkCartersNote.value,
										termEmailDefaults.enabled,
										self.myEmailDefaults.copyTo,
										self.myEmailDefaults.sendToCarrier,
										self.myEmailDefaults.sendToConsignee );
		
		app.myTrxUA.trxUpdatePINEmail(proxyPINEmail, app.myPassport);
		if not app.myPassport.trxCompletedOK() then
			returnValue := false;
		endif;
	endif;
	
	return returnValue;
epilog
	delete sa;
	delete proxyPINEmail;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="125bbcae-2809-47dd-b940-bc44ab9f3612">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
//----------------------------------------------------------------
//	Created:	22 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpBackColor	: Integer;

begin
	inheritMethod(_colorControl);

	tmpBackColor	:= self.backColor;
	self.fldMain.backColor := tmpBackColor;
	
	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setup" id="f462ba9b-6568-462c-b9ae-7d07134341bb">
        <updating/>
        <source>setup(_carrier: CM_Carrier; _emailDefault: CM_PINObjectDefaultEmail; _limitedUpdate: Boolean; _sending: Boolean) updating;
//----------------------------------------------------------------
//	Created:	22 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.myCurrentCarrier := _carrier;

	if _emailDefault &lt;&gt; null then
		self.myEmailDefaults := _emailDefault;
		self.myEmailController := self.myEmailDefaults.myEmailController;
		
	//	self.txtCarrierAddres.text := self.myEmailDefaults.allCarrierAddresses.getAddresses();
		
		self.txtToAddress.text := self.myEmailController.allToAddresses.getAddresses();
		//self.txtToAddress.text := self.myEmailController.allToAddresses.getAddresses();
		self.txtCcAddress.text := self.myEmailController.allCcAddresses.getAddresses();
		self.txtBccAddress.text := self.myEmailController.allBccAddresses.getAddresses();
		self.txtSubject.text := self.myEmailDefaults.subjectLine;
		self.txtMessage.text := self.myEmailDefaults.message;
		
		self.chkCartersNote.enabled := false;
		self.chkCartersNote.value := false;
		if self.myEmailDefaults.type = PINEmail_Prenote then
			self.chkCartersNote.enabled := true;
			self.chkCartersNote.value := self.myEmailDefaults.attachCartersNote;
		endif;
		
	else
		self.myEmailDefaults := null;
	endif;
	
	if _sending then
		self.btnOk.caption := "Send";
	endif;
	
	if _limitedUpdate then
		//can only change the subject and message
		self.txtBccAddress.enabled := false;
		self.txtCcAddress.enabled := false;
		self.txtToAddress.enabled := false;
		self.btnBccAddress.enabled := false;
		self.btnCcAddress.enabled := false;
		self.btnToAddress.enabled := false;
		self.chkCartersNote.enabled := false;
		self.chkSave2Terminal.enabled := false;
		self.shtFields.enabled := false;
	endif;
	
end;</source>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_emailDefault" type="CM_PINObjectDefaultEmail"/>
        <Parameter name="_limitedUpdate" type="Boolean"/>
        <Parameter name="_sending" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="044edb6e-982c-4c70-a581-90f2f4250aab">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	
	self.modalResult := IDCANCEL;
	self.shtFields.enabled := true;
	self.mulSelectFields.formDisplayEntryMethodName := 'displayEntryEmailFields';
	self.mulSelectFields.availableHeading := 'Fields available';
	self.mulSelectFields.selectedHeading  := 'Fields selected';
	self.mulSelectFields.userInputEnabled := true;
	
	self.mulSelectFields.displayOrderBtns(true, true);
	self.mulSelectFields.multiSelect				:= ListBox.MultiSelect_Extended;
	self.mulSelectFields.setSorted(false);
	
	self.myAssistant.multiSelectEntityFields(self.mulSelectFields, self.myEmailDefaults.entTableName, self.myEmailDefaults.allIncludedFields);

//	self.mulSelectFields.setAvailable(app.myRoot.allEmailEntities, true);   
	
	
	self.btnOk.default := false;
	// check permission
//	if app.getMyUser.canDo(self.myTerminal, PmPDFBackground) then
		self.chkCartersNote.visible := true;
//	endif;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="showSelectRecipients" id="b195e96f-69f9-49ba-859f-467cba5cd601">
        <updating/>
        <source>showSelectRecipients(_mode	: Integer)updating, protected;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	form : CMUI_RecipientSelector;
begin
//	if self.myEmailController = null then
//		create self.myEmailController transient;
	//	self.myEmailDefaults.setEmailController(self.myEmailController);
//	endif;
	
	create form transient;
	
	self.setNavigatorHeading(form.caption);
	form.myEmailController := self.myEmailController;
	form.mode := _mode;
	form.centreWindow;
	form.showModal;

	if form.modalResult = IDOK then
		self.txtToAddress.text := self.myEmailController.allToAddresses.getAddresses();
		self.txtCcAddress.text := self.myEmailController.allCcAddresses.getAddresses();
		self.txtBccAddress.text := self.myEmailController.allBccAddresses.getAddresses();
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="92ad246c-a7e0-4a8a-9168-4f5b728402fb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007309, locale);
	btnBccAddress.translateBubbleHelp(Xlat_0000242, locale);
	btnBccAddress.translateCaption(Xlat_0000244, locale);
	btnCcAddress.translateBubbleHelp(Xlat_0000231, locale);
	btnCcAddress.translateCaption(Xlat_0000235, locale);
	btnToAddress.translateBubbleHelp(Xlat_0000232, locale);
	btnToAddress.translateCaption(Xlat_0000236, locale);
	chkCartersNote.translateBubbleHelp(Xlat_0000229, locale);
	chkCartersNote.translateCaption(Xlat_0000230, locale);
	chkSave2Terminal.translateCaption(Xlat_0000227, locale);
	lblMessage.translateCaption(Xlat_0000238, locale);
	lblSubject.translateCaption(Xlat_0000239, locale);
	shtDetail.translateCaption(Xlat_0000240, locale);
	shtFields.translateCaption(Xlat_0000241, locale);
	txtBccAddress.translateBubbleHelp(Xlat_0000243, locale);
	txtCcAddress.translateBubbleHelp(Xlat_0000233, locale);
	txtSubject.translateBubbleHelp(Xlat_0000237, locale);
	txtToAddress.translateBubbleHelp(Xlat_0000234, locale);
end;</source>
    </JadeMethod>
</GUIClass>
