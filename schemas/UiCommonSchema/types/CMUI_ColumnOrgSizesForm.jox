    <JadeMethod name="refreshCmbFilterColour" id="f58c50ff-449c-4ed1-87ec-084308469904">
        <source>refreshCmbFilterColour();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	index : Integer;
	column : Integer;
	entableRowHeading : String;
	count : Integer;
	str : String;

begin

	foreach index in 1 to self.cmbColumnFilter.listCount do
		column := self.myDataTable.allTblDataEntRows.indexOf( self.cmbColumnFilter.itemObject[ index ].EntTableRow );
		entableRowHeading := self.cmbColumnFilter.itemObject[ index ].EntTableRow.getHeading(self.myDataTable.myTerminologyCargoBOLType, self.myDataTable.myTerminologyTerminal, app.myCurrentLocale);
		if self.allFilterColumns.getColumnFilter( self.myDataTable, column, entableRowHeading ) &lt;&gt; null then
			self.cmbColumnFilter.itemForeColor[index] := Red;
			count := count + 1;
		else
			self.cmbColumnFilter.itemForeColor[index] := Black;
		endif;
	endforeach;
	
	if count = 0 then
		self.btnClearAll.enabled := false;
		self.btnShow.caption := "No filters applied";
		self.lblShowFilter.caption := null;
		self.btnShow.enabled := false;
	else
		self.btnClearAll.enabled := true;
		self.btnShow.caption := count.String &amp; " filter(s) applied";
		self.lblShowFilter.caption := self.getFilterDetailsForDisplay();
		self.btnShow.enabled := true;
	endif;
	
	self.enabledFilterButtons();
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resetDefaults" id="d2c3e4c9-bfb8-46c7-a562-abbdbee7890b">
        <updating/>
        <source>resetDefaults(_system : Boolean) updating, protected;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	allRowsObj	: EntTableRowArray;
	viewObj		: EntTableView;
	
begin
	create allRowsObj transient;
	
	//see if there is a system deafult first
	if _system then
		viewObj	:=	self.myEntTableDef.allEntTableViews[SystemDefault];
	endif;
	
	//if not then use the JMT default
	if viewObj	= null then
		viewObj	:=	self.myEntTableDef.allEntTableViews['Default'];
	endif;
	
	if viewObj &lt;&gt; null then
		viewObj.allEntTableRows.copy(allRowsObj);
	else
		self.myEntTableDef.allEntTableRows.copy(allRowsObj);
	endif;
	
	self.mulColumns.setAvailable(self.myEntTableDef.allEntTableRows, true);
	self.mulColumns.setSelected(allRowsObj);
	self.mulSizes.setAvailable(self.myEntTableDef.allEntTableRows, true);
	self.mulSizes.setSelected(allRowsObj);
epilog
	delete allRowsObj;
end;</source>
        <access>protected</access>
        <Parameter name="_system" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="eeb54fcc-4ea3-41ba-94c0-fa94c50deb24">
        <updating/>
        <source>setColorsFromController(_colorControl : CM_ColorController) updating;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_colorControl);

	self.setColorsForMultiSelectGrpBox(self.mulColumns);
	self.setColorsForMultiSelectGrpBox(self.mulSizes);
	
//	self.fldMain.useSheetBackColors := true;
//	self.fldMain.setDefaultSheetBackColors();
//	self.fldMain.initSheetBackColors();		
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setMyDataTable" id="c044e9da-6a68-4782-a757-307f67c4b660">
        <updating/>
        <source>setMyDataTable(table : CM_DataTable) updating;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/
vars
	entRowObj	: EntTableRow;
	entDef 		: EntTableDef;
begin
	self.myDataTable	:=	table;
	self.myEntTableDef	:=	app.myController.getEntTableDef(ETDef_YAMDataForCO);
	
	if self.myEntTableDef &lt;&gt; null then
		self.myEntTableView	:=	self.myEntTableDef.allEntTableViews[self.SystemDefault];
	endif;
	
	foreach entRowObj in self.myEntTableDef.allEntTableRows do
		if entRowObj.name = ETRow_20s
		or entRowObj.name = ETRow_30s
		or entRowObj.name = ETRow_40s
		or entRowObj.name = ETRow_45s
		or entRowObj.name = ETRow_53s
		or entRowObj.name = ETRow_ColTotals //cnwjo3 21189
		then
			self.allSizeRows.add(entRowObj);
		else
			if self.myDataTable.isKindOf(CM_LocnStatsTable) then
				if entRowObj.name = ETRow_DeckingSequence
				or entRowObj.name = ETRow_Stacking
				or entRowObj.name = ETRow_PriorityValue
				//cnwjo3 ccms 1018
				or entRowObj.name = ETRow_AllowOthers
				or entRowObj.name = ETRow_IfNoLocationFound
				or entRowObj.name = ETRow_OverstowRule
				//04 Jan 2012	NDL	Par 28889
				or table.isGenFilterableYAMcolumn( entRowObj.name )
				then
					continue;
				endif;
			endif;
			
			self.allColumnRows.add(entRowObj);
		endif;
		
	
	endforeach;
	
end;</source>
        <Parameter name="table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e60f0d9b-a238-45f6-b598-b940cb99ac2e">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------------------
//Created: 24 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	criteriaType: CM_YACriteriaType;
begin
	
	self.refreshToolbar();	//05 Jan 2012	NDL	Par 28889
	
	inheritMethod();
	
	self.isSortAllowed	:=	(self.myDataTable &lt;&gt; null and (not self.myDataTable.disallowColumnSorter));

	if app.getMyUser().canDo(self.myTerminal, PmCmpColumnOrgSystemMaint) then
		if not self.hideSaveAsSysDefault then	//09 May 2018	NDL	TFS 38460

			self.chkSystem.enabled	:=	true;
		endif;
	endif;
	
	if self.myDataTable &lt;&gt; null and self.myDataTable.maxSortColumns &gt; self.maxSortingColumns then
		self.maxSortingColumns	:=	self.myDataTable.maxSortColumns;
	endif;
	
	self.modalResult	:=	IDCANCEL;
	self.initMultiSelectShts();
	self.showAllTableRows();
	
	self.caption	:=	self.Caption &amp; ' ' &amp; self.myDataTable.form.caption;
	
	//20 Dec 2011	NDL	Par 28889
	if self.myDataTable &lt;&gt; null and self.myDataTable.allowsColumnFilters then
		self.shtColumnFilter.visible := true;
		self.tblFilterValues.fixedRows := 1;
		self.tblFilterValues.rows := 1;
		create self.allFilterColumns transient;
		self.myDataTable.form.getTableColumFilters( self.myDataTable, self.allFilterColumns );
	endif;
	
	self.doResize();
	
	self.printOrientation:=Print_Landscape;
end;</source>
    </JadeMethod>
    <JadeMethod name="showAllTableRows" id="5b19df42-1f18-49b6-b817-de7b869e3242">
        <updating/>
        <source>showAllTableRows() updating, protected;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tableObj			: CM_DataTable;
	selectedColRows		: EntTableRowArray;
	selectedSizeRows	: EntTableRowArray;
	entRowObj			: EntTableRow;
	allRowsObj			: EntTableRowArray;
begin
	tableObj	:=	self.myDataTable;
	
	// This method gets all the available columns for the table.
	if tableObj = null then
		return;
	endif;
	
	create allRowsObj transient;
	
	self.getAllEntTableRows(allRowsObj);
	
	create selectedColRows transient;
	create selectedSizeRows transient;
	
	//foreach entRowObj in self.myDataTable.allTblDataEntRows do
	foreach entRowObj in allRowsObj do
		if entRowObj.name = ETRow_Total20 or entRowObj.name = ETRow_Used20 or entRowObj.name = ETRow_QueuedIn20 or entRowObj.name = ETRow_QueuedOut20
		or entRowObj.name = ETRow_Free20 or entRowObj.name = ETRow_Projected20 or entRowObj.name = ETRow_PlannedIn20 or entRowObj.name = ETRow_PlannedOut20
		then
			selectedSizeRows.add(self.myEntTableDef.getEntTableRow(ETRow_20s));
		elseif entRowObj.name = ETRow_Total30 or entRowObj.name = ETRow_Used30 or entRowObj.name = ETRow_QueuedIn30 or entRowObj.name = ETRow_QueuedOut30
		or entRowObj.name = ETRow_Free30 or entRowObj.name = ETRow_Projected30 or entRowObj.name = ETRow_PlannedIn30 or entRowObj.name = ETRow_PlannedOut30
		then
			selectedSizeRows.add(self.myEntTableDef.getEntTableRow(ETRow_30s));
		elseif entRowObj.name = ETRow_Total40 or entRowObj.name = ETRow_Used40 or entRowObj.name = ETRow_QueuedIn40 or entRowObj.name = ETRow_QueuedOut40
		or entRowObj.name = ETRow_Free40 or entRowObj.name = ETRow_Projected40 or entRowObj.name = ETRow_PlannedIn40 or entRowObj.name = ETRow_PlannedOut40
		then
			selectedSizeRows.add(self.myEntTableDef.getEntTableRow(ETRow_40s));
		elseif entRowObj.name = ETRow_Total45 or entRowObj.name = ETRow_Used45 or entRowObj.name = ETRow_QueuedIn45 or entRowObj.name = ETRow_QueuedOut45
		or entRowObj.name = ETRow_Free45 or entRowObj.name = ETRow_Projected45 or entRowObj.name = ETRow_PlannedIn45 or entRowObj.name = ETRow_PlannedOut45
		then
			selectedSizeRows.add(self.myEntTableDef.getEntTableRow(ETRow_45s));
		elseif entRowObj.name = ETRow_Total53 or entRowObj.name = ETRow_Used53 or entRowObj.name = ETRow_QueuedIn53 or entRowObj.name = ETRow_QueuedOut53
		or entRowObj.name = ETRow_Free53 or entRowObj.name = ETRow_Projected53 or entRowObj.name = ETRow_PlannedIn53 or entRowObj.name = ETRow_PlannedOut53
		then
			selectedSizeRows.add(self.myEntTableDef.getEntTableRow(ETRow_53s));
		//cnwjo3 par 21189
		elseif entRowObj.name = ETRow_ColTotalFree or entRowObj.name = ETRow_ColTotalUsed or entRowObj.name = ETRow_ColTotalTotal or entRowObj.name = ETRow_ColTotalQIn
				or entRowObj.name = ETRow_ColTotalQOut or entRowObj.name = ETRow_ColTotalPlanIn or entRowObj.name = ETRow_ColTotalPlanOut or entRowObj.name = ETRow_ColTotalProjected then
			selectedSizeRows.add(self.myEntTableDef.getEntTableRow(ETRow_ColTotals));
		endif;	
		
		//if entRowObj.name = ETRow_Total20 or entRowObj.name = ETRow_Total30 or entRowObj.name = ETRow_Total40 or entRowObj.name = ETRow_Total45 or entRowObj.name = ETRow_Total53 then
		if entRowObj.name = ETRow_Total20 or entRowObj.name = ETRow_Total30 or entRowObj.name = ETRow_Total40 or entRowObj.name = ETRow_Total45 or entRowObj.name = ETRow_Total53 or entRowObj.name = ETRow_ColTotalTotal then
			selectedColRows.add(self.myEntTableDef.getEntTableRow(ETRow_TotalSpace));
		//elseif entRowObj.name = ETRow_Used20 or entRowObj.name = ETRow_Used30 or entRowObj.name = ETRow_Used40 or entRowObj.name = ETRow_Used45 or entRowObj.name = ETRow_Used53 then
		elseif entRowObj.name = ETRow_Used20 or entRowObj.name = ETRow_Used30 or entRowObj.name = ETRow_Used40 or entRowObj.name = ETRow_Used45 or entRowObj.name = ETRow_Used53 or entRowObj.name = ETRow_ColTotalUsed then
			selectedColRows.add(self.myEntTableDef.getEntTableRow(ETRow_UsedSpace));
		//elseif entRowObj.name = ETRow_QueuedIn20 or entRowObj.name = ETRow_QueuedIn30 or entRowObj.name = ETRow_QueuedIn40 or entRowObj.name = ETRow_QueuedIn45 or entRowObj.name = ETRow_QueuedIn53 then
		elseif entRowObj.name = ETRow_QueuedIn20 or entRowObj.name = ETRow_QueuedIn30 or entRowObj.name = ETRow_QueuedIn40 or entRowObj.name = ETRow_QueuedIn45 or entRowObj.name = ETRow_QueuedIn53 or entRowObj.name = ETRow_ColTotalQIn then
			selectedColRows.add(self.myEntTableDef.getEntTableRow(ETRow_QueuedIn));
		//elseif entRowObj.name = ETRow_QueuedOut20 or entRowObj.name = ETRow_QueuedOut30 or entRowObj.name = ETRow_QueuedOut40 or entRowObj.name = ETRow_QueuedOut45 or entRowObj.name = ETRow_QueuedOut53 then
		elseif entRowObj.name = ETRow_QueuedOut20 or entRowObj.name = ETRow_QueuedOut30 or entRowObj.name = ETRow_QueuedOut40 or entRowObj.name = ETRow_QueuedOut45 or entRowObj.name = ETRow_QueuedOut53 or entRowObj.name = ETRow_ColTotalQOut then
			selectedColRows.add(self.myEntTableDef.getEntTableRow(ETRow_QueuedOut));
		//elseif entRowObj.name = ETRow_Free20 or entRowObj.name = ETRow_Free30 or entRowObj.name = ETRow_Free40 or entRowObj.name = ETRow_Free45 or entRowObj.name = ETRow_Free53 then
		elseif entRowObj.name = ETRow_Free20 or entRowObj.name = ETRow_Free30 or entRowObj.name = ETRow_Free40 or entRowObj.name = ETRow_Free45 or entRowObj.name = ETRow_Free53 or entRowObj.name = ETRow_ColTotalFree then
			selectedColRows.add(self.myEntTableDef.getEntTableRow(ETRow_FreeSpace));
		//elseif entRowObj.name = ETRow_Projected20 or entRowObj.name = ETRow_Projected30 or entRowObj.name = ETRow_Projected40 or entRowObj.name = ETRow_Projected45 or entRowObj.name = ETRow_Projected53 then
		elseif entRowObj.name = ETRow_Projected20 or entRowObj.name = ETRow_Projected30 or entRowObj.name = ETRow_Projected40 or entRowObj.name = ETRow_Projected45 or entRowObj.name = ETRow_Projected53 or entRowObj.name = ETRow_ColTotalProjected then
			selectedColRows.add(self.myEntTableDef.getEntTableRow(ETRow_TotalProjected));
		//elseif entRowObj.name = ETRow_PlannedIn20 or entRowObj.name = ETRow_PlannedIn30 or entRowObj.name = ETRow_PlannedIn40 or entRowObj.name = ETRow_PlannedIn45 or entRowObj.name = ETRow_PlannedIn53 then
		elseif entRowObj.name = ETRow_PlannedIn20 or entRowObj.name = ETRow_PlannedIn30 or entRowObj.name = ETRow_PlannedIn40 or entRowObj.name = ETRow_PlannedIn45 or entRowObj.name = ETRow_PlannedIn53  or entRowObj.name = ETRow_ColTotalPlanIn then
			selectedColRows.add(self.myEntTableDef.getEntTableRow(ETRow_TotalPlanIn));
		//elseif entRowObj.name = ETRow_PlannedOut20 or entRowObj.name = ETRow_PlannedOut30 or entRowObj.name = ETRow_PlannedOut40 or entRowObj.name = ETRow_PlannedOut45 or entRowObj.name = ETRow_PlannedOut53 then
		elseif entRowObj.name = ETRow_PlannedOut20 or entRowObj.name = ETRow_PlannedOut30 or entRowObj.name = ETRow_PlannedOut40 or entRowObj.name = ETRow_PlannedOut45 or entRowObj.name = ETRow_PlannedOut53 or entRowObj.name = ETRow_ColTotalPlanOut then
			selectedColRows.add(self.myEntTableDef.getEntTableRow(ETRow_TotalPlanOut));
		endif;
		
		if entRowObj.name = ETRow_Stacking then
			selectedColRows.add(self.myEntTableDef.getEntTableRow(ETRow_Stacking));
		elseif entRowObj.name = ETRow_DeckingSequence then
			selectedColRows.add(self.myEntTableDef.getEntTableRow(ETRow_DeckingSequence));
		elseif entRowObj.name = ETRow_PriorityValue then
			selectedColRows.add(self.myEntTableDef.getEntTableRow(ETRow_PriorityValue));
		
		elseif entRowObj.name = ETRow_AllowOthers then //cnwjo3 par 20135
			selectedColRows.add(self.myEntTableDef.getEntTableRow(ETRow_AllowOthers));
		elseif entRowObj.name = ETRow_OverstowRule then //cnwjo3 par 20135
			selectedColRows.add(self.myEntTableDef.getEntTableRow(ETRow_OverstowRule));
		elseif entRowObj.name = ETRow_IfNoLocationFound then //cnwjo3 par 20135
			selectedColRows.add(self.myEntTableDef.getEntTableRow(ETRow_IfNoLocationFound));
		//04 Jan 2012	NDL	Par 28889
		elseif self.myDataTable.isGenFilterableYAMcolumn( entRowObj.name ) then
			selectedColRows.add(self.myEntTableDef.getEntTableRow(entRowObj.name));
		endif;
	endforeach;
	// Add the current visible columns.
	self.myEntTableDef.allEntTableRows.copy(self.allTblDataEntRows);
	
	self.mulColumns.setAvailable(self.allColumnRows, true);
	self.showSelectedTableRows(self.mulColumns, selectedColRows);
	self.mulSizes.setAvailable(self.allSizeRows, true);
	self.showSelectedTableRows(self.mulSizes, selectedSizeRows);
epilog
	delete selectedSizeRows;
	delete selectedColRows;
	delete allRowsObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showFilterSheet" id="5abf2b11-490e-49c9-85d7-a78614d73e23">
        <source>showFilterSheet();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation

*/

vars
	allSelectedCols : EntTableRowArray;
	col : EntTableRow;
	columnHeading : String;
	index : Integer;

begin

	self.btnResetJMT.visible := false;
	self.btnResetSys.visible := false;
	self.chkSystem.visible := false;
	
	self.frmFilterValues.visible := false;

	create allSelectedCols transient;
	self.mulColumns.getSelected(allSelectedCols);
	
	self.cmbColumnFilter.clear();
	
	if self.myDataTable.isKindOf( CM_YAMTable ) then
		foreach col in self.myDataTable.allTblDataEntRows do
			if self.myDataTable.isGenFilterableYAMcolumn( col.name )
			or col.name = ETRow_DeckingSequence
			or col.name = ETRow_AllowOthers
			or col.name = ETRow_IfNoLocationFound
			or col.name = ETRow_OverstowRule
			then
				columnHeading := displayMultiSelectAvailable(col);
				self.cmbColumnFilter.itemObject[ self.cmbColumnFilter.addItem( columnHeading ) ] := col;
			endif;
		endforeach;
	else
		foreach col in allSelectedCols do
			columnHeading := displayMultiSelectAvailable(col);
			self.cmbColumnFilter.itemObject[ self.cmbColumnFilter.addItem( columnHeading ) ] := col;
		endforeach;
	endif;
	
	self.refreshCmbFilterColour();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showSelectedTableRows" id="d7e492ae-7491-4acd-b412-0863ec566335">
        <source>showSelectedTableRows(_groupboxObj:CMUI_MultiSelectGroupBox input; _tableRows:EntTableRowArray) protected;
// --------------------------------------------------------------------------------
// Created:		11 February 2009 by cnwdad1
//
// Purpose:		Taking the Organiser's EntTableRow objects, these are translated
//				into the EnttableRow objects that are actually used by the data table,
//				and if those are visible, then the Organiser EntTableRow object is
//				moved to the selected list.
//
// Parameters:	_groupboxObj - The multi-select group box who's selected list to set.
//				_tableRows - A reference to an array of EntTableRow objects that are
//					relevant to the multi-select group box.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowObj			: EntTableRow;
	allSelected		: EntTableRowArray;
	allTableRows	: EntTableRowArray;
	
begin
	create allSelected transient;
	create allTableRows transient;
	
	foreach rowObj in _tableRows do
		self.translateRowFromOrgToTable(rowObj, allTableRows);
		
		if allTableRows.isEmpty() then
			continue;
		endif;
		
		if allTableRows.first().visible then
			allSelected.add(rowObj);
		endif;
	endforeach;
	
	_groupboxObj.setSelected(allSelected);
epilog
	delete allSelected;
	delete allTableRows;
end;</source>
        <access>protected</access>
        <Parameter name="_groupboxObj" type="CMUI_MultiSelectGroupBox" usage="input"/>
        <Parameter name="_tableRows" type="EntTableRowArray"/>
    </JadeMethod>
    <JadeMethod name="tblFilterValues_mouseDown" id="4bc9edcc-add3-4b62-83a0-31ac7e2b1a59">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFilterValues_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if table.column = 1 then
		if table.row &gt; table.fixedRows then
			if table.row &lt;= table.rows then
				self.selectFilterUpdated := true;
				self.enabledFilterButtons();
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3573ee83-53c0-41ef-9031-9bd8425296c0">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 February 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009757, locale);
//	btnClearAll.translateCaption(Xlat_0017294, locale);
//	btnExportCSVTV.translateCaption(Xlat_0017284, locale);
	btnPrintSetup.translateBubbleHelp(Xlat_0019395, locale);
	btnPrintSetup.translateCaption(Xlat_0019396, locale);
//	btnPrintTV.translateBubbleHelp(Xlat_0017291, locale);
//	btnPrintTV.translateCaption(Xlat_0017292, locale);
//	btnRemFilter.translateCaption(Xlat_0017287, locale);
	btnResetJMT.translateBubbleHelp(Xlat_0009758, locale);
	btnResetJMT.translateCaption(Xlat_0009759, locale);
	btnResetSys.translateBubbleHelp(Xlat_0009760, locale);
	btnResetSys.translateCaption(Xlat_0009761, locale);
//	btnSelectAll.translateCaption(Xlat_0017288, locale);
	btnShow.translateCaption(Xlat_0018012, locale);
//	btnUnselectAll.translateCaption(Xlat_0017285, locale);
//	btnUpdFilter.translateCaption(Xlat_0017289, locale);
	chkSystem.translateBubbleHelp(Xlat_0009762, locale);
	chkSystem.translateCaption(Xlat_0009763, locale);
//	lblFilters.translateCaption(Xlat_0017293, locale);
	lblShowFilter.translateCaption(Xlat_0018013, locale);
//	optTableData.translateCaption(Xlat_0017290, locale);
//	optUserData.translateCaption(Xlat_0017295, locale);
//	shtColumnFilter.translateCaption(Xlat_0017283, locale);
//	shtColumnMain.translateCaption(Xlat_0017286, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="translateRowFromOrgToTable" id="4031675d-5fe5-4c3a-b96e-9d359919220a">
        <source>translateRowFromOrgToTable(_orgRow:EntTableRow; _allTableRows:EntTableRowArray input) protected;
// --------------------------------------------------------------------------------
// Created:		11 February 2009 by cnwdad1
//
// Purpose:		Translates a Column Organiser EntTableRow object into an array of
//				matching CM_DataTable row objects.
//
// Parameters:	_orgRow - A reference to the table row to translate.
//				_allTableRows - A reference to an array of EntTableRows.
//
// Returns:		The populated array of matching EntTableRow objects.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableDefObj	: EntTableDef;
	
begin
	_allTableRows.clear();
	tableDefObj	:=	app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_YAMDataTbl);
	
	if tableDefObj = null then
		return;
	endif;
	
	if _orgRow.name = ETRow_TotalSpace then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Total20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Total30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Total40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Total45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Total53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalTotal));  //cnwjo3 par 21189
	elseif _orgRow.name = ETRow_UsedSpace then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Used20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Used30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Used40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Used45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Used53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalUsed)); //cnwjo3 par 21189
	elseif _orgRow.name = ETRow_QueuedIn then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedIn20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedIn30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedIn40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedIn45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedIn53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalQIn)); //cnwjo3 par 21189
		
	elseif _orgRow.name = ETRow_QueuedOut then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedOut20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedOut30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedOut40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedOut45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedOut53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalQOut)); //cnwjo3 par 21189
	elseif _orgRow.name = ETRow_FreeSpace then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Free20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Free30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Free40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Free45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Free53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalFree)); //cnwjo3 par 21189
	elseif _orgRow.name = ETRow_TotalProjected then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Projected20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Projected30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Projected40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Projected45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Projected53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalProjected)); //cnwjo3 par 21189

	elseif _orgRow.name = ETRow_TotalPlanIn then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedIn20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedIn30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedIn40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedIn45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedIn53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalPlanIn)); //cnwjo3 par 21189
	elseif _orgRow.name = ETRow_TotalPlanOut then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedOut20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedOut30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedOut40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedOut45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedOut53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalPlanOut)); //cnwjo3 par 21189
	elseif _orgRow.name = ETRow_Stacking then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Stacking));
	elseif _orgRow.name = ETRow_DeckingSequence then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_DeckingSequence));
	elseif _orgRow.name = ETRow_PriorityValue then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PriorityValue));
	
	elseif _orgRow.name = ETRow_AllowOthers then //cnwjo3 par 20135
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_AllowOthers));
	elseif _orgRow.name = ETRow_OverstowRule then //cnwjo3 par 20135
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_OverstowRule));
	elseif _orgRow.name = ETRow_IfNoLocationFound then //cnwjo3 par 20135
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_IfNoLocationFound));	

	elseif _orgRow.name = ETRow_20s then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Total20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Used20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedIn20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedOut20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Free20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Projected20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedIn20));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedOut20));
	elseif _orgRow.name = ETRow_30s then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Total30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Used30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedIn30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedOut30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Free30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Projected30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedIn30));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedOut30));
	elseif _orgRow.name = ETRow_40s then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Total40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Used40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedIn40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedOut40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Free40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Projected40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedIn40));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedOut40));
	elseif _orgRow.name = ETRow_45s then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Total45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Used45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedIn45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedOut45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Free45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Projected45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedIn45));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedOut45));
	elseif _orgRow.name = ETRow_53s then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Total53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Used53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedIn53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_QueuedOut53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Free53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_Projected53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedIn53));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_PlannedOut53));
	//cnwjo3 par 21189
	elseif _orgRow.name =  ETRow_ColTotals then
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalTotal));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalUsed));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalQIn));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalQOut));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalFree));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalProjected));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalPlanIn));
		_allTableRows.add(tableDefObj.getEntTableRow(ETRow_ColTotalPlanOut));
		
	//04 Jan 2012	NDL	Par 28889
	elseif self.myDataTable.isGenFilterableYAMcolumn( _orgRow.name ) then
		_allTableRows.add(tableDefObj.getEntTableRow(_orgRow.name));
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_orgRow" type="EntTableRow"/>
        <Parameter name="_allTableRows" type="EntTableRowArray" usage="input"/>
    </JadeMethod>
