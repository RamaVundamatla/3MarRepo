    <JadeMethod name="addToolbarControls" id="b8b919bd-2cde-48d7-b84f-7a9ab6c09e11">
        <updating/>
        <source>addToolbarControls() updating, protected;

vars
	frm				: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;

	inheritMethod();
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEditItem, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	frm := self.frmPropToolbar;
	frm.addButton(self.btnPropSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPropDelete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPropCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="918fe196-344a-436c-9426-67f8363ae63f">
        <source>addToolbarControlsQuery() protected;

vars
	queryToolbar			: CMUI_Toolbar;
begin

	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	queryToolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);

end;</source>
        <access>protected</access>
    </JadeMethod>
