    <JadeMethod name="cmbBillOfLadingGen_lostFocus" id="19fae872-8752-492b-91b9-83d4e45c00ff">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBillOfLadingGen_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/11/2023	navkc1 Bug 61004: LNX - New Invoice Creation screen is multi tabbed

*/

vars

begin
	self.tblInvProperties.setValueByControlName(combobox.name,combobox.text);
	
	self.setMyBOL(combobox.listObject.CM_BOL);
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
