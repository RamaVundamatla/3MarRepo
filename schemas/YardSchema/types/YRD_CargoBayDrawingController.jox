    <JadeMethod name="setTICollections" id="09004401-87ac-41ef-9c93-b036a146bef4">
        <source>setTICollections();
// ---------------------------------------------------------------------------
// Created:     01 September 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
begin
	inheritMethod();
	
	if self.myDrawingFrame = null then		// PAR 21532 CCMS SFW 1025
		return;
	endif;

	foreach theTI in self.myLocationsController.allTrackedItemOSBackEnds do
		if not self.allTIsA.includes(theTI) then
			self.allTIsA.add(theTI);
		endif;
		if not self.allTempTIs.includes(theTI) then
			self.allTempTIs.add(theTI);
		endif;
	endforeach;
	foreach theTI in self.myLocationsController.allTrackedItemOSBackEndsQd do
		if not self.allTIsQ.includes(theTI) then
			self.allTIsQ.add(theTI);
		endif;
		if not self.allTempTIs.includes(theTI) then
			self.allTempTIs.add(theTI);
		endif;
	endforeach;
	foreach theTI in self.myLocationsController.allTrackedItemOSBackEndsPd do
		if not self.allTIsP.includes(theTI) then
			self.allTIsP.add(theTI);
		endif;
		if not self.allTempTIs.includes(theTI) then
			self.allTempTIs.add(theTI);
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
