    <JadeMethod name="setSelectionBoundsForTA" id="f7883900-82d5-45d5-b7d8-453c2b3d105b">
        <source>setSelectionBoundsForTA(_ta : CM_TerminalArea;_taViewPos : CM_TerminalAreaViewPosition);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwer1	Initial creation

*/

vars
	topLeftLC		: CM_LocationsController;
	bottomRightLC	: CM_LocationsController;

	x1, y1, x2, y2	: Integer;
	int     		: Integer;
	row				: Object;
	label			: String;
begin
//	if not _ta.isKindOf(CM_GridArea) and not _ta.isKindOf(CM_BlockStack) then
	if not _ta.isKindOf(CM_GridArea) and not _ta.isKindOf(CM_BlockStack) and not _ta.isKindOf(CM_BulkArea) then	//19 Feb 2016	NDL	Par 37556
		return;
	endif;

	if _ta.findYABlock(null, topLeftLC, bottomRightLC, _taViewPos) then
		if not self.myDrawingFrame.getPointsForObject(topLeftLC, x1, y1, int, int) then
			if topLeftLC.CM_GridController.mySubBlockStack &lt;&gt; null then
				if not self.myDrawingFrame.getPointsForSubBlockStack(topLeftLC.CM_GridController.mySubBlockStack, x1, y1, int, int) then
					return;
				endif;
			endif;
		endif;
		if not self.myDrawingFrame.getPointsForObject(bottomRightLC, int, int, x2, y2) then
			if bottomRightLC.CM_GridController.mySubBlockStack &lt;&gt; null then
				if not self.myDrawingFrame.getPointsForSubBlockStack(bottomRightLC.CM_GridController.mySubBlockStack , int, int, x2, y2) then
					return;
				endif;
			endif;
		endif;
		self.normaliseRectanglePoints(x1, y1, x2, y2);
		self.selectionBoundsObjectsPutAtKey(x1, y1, x2, y2, _ta);
	endif;
end;
</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_taViewPos" type="CM_TerminalAreaViewPosition"/>
    </JadeMethod>
