    <JadeMethod name="outputFile" id="0f846c39-2ef6-4cb3-a362-471ea9dc81bf">
        <updating/>
        <source>outputFile(_protocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent; _camFile: CM_CamFile input; _runDateTime: TimeStamp; _camTaskHistory: CM_CamTaskHistory input; _unhSeqNumber: Integer io; _seqNumber: Integer; _terminal: CM_Terminal; _contextObj: Object; _transactions: CM_TITransactionSet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Sep 2025 navnk30 JIRA 35756: 8 - Create a new Cams protocol to handle Truck Departure events and generate "Ship Notice" Messages

*/

vars
	camVoyage	: CM_CamVoyage;
	camMessage	: CM_CamMessage;
	str,
	strMsg		: String;
begin
	foreach camVoyage in _camFile.camVoyages do
		foreach camMessage in camVoyage.camMessages do
			foreach str in camMessage.group3 do
				strMsg &amp;= str;
			endforeach;
		endforeach;
	endforeach;
	
	_camTaskHistory.setRawDataString(strMsg);
epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="processEvent" id="21e8f977-7cc0-4861-9010-dc4b1b1edb39">
        <updating/>
        <source>processEvent(_transaction: CM_EventTransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2025	navra1	Initial creation for //navra1 - MTN-34782 - 15th July 2025

*/

vars
	truckEvent 		: CMEVT_TruckEvent;	
	pxyRequest		: BGP_AgGatewayWSRequest;
	realRequest		: BGP_ExternalWSRequest;
begin
	app.createAlert("CAME TO THE PROCESSEVENT OF CAM AGGATEWAY", true);
	
	if _transaction.type &lt;&gt; EVT_TruckDeparture then
		return;
	endif;
	
	app.createAlert("Truck just departed, so creating ship notice message and activity history", true);
	
	truckEvent := _transaction.CMEVT_TruckEvent;
	
	if not app.isJMTUnitTest then
		self.createAndSendShipNotice(truckEvent.myVisit, _camProtocol, _camFile);
	endif;

epilog
	delete pxyRequest;	

end;</source>
        <Parameter name="_transaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sendShipNoticeMessage" id="0ce5915d-62d8-4759-afe4-5265c3393251">
        <source>sendShipNoticeMessage(_shipNoticeMessage : String; _responseCode : Integer io; _response : String io);			//navra1 - MTN-36083 - 19th Sep 2025
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Sep 2025 navnk30 JIRA 35756: 8 - Create a new Cams protocol to handle Truck Departure events and generate "Ship Notice" Messages

*/


vars
	wsAgent	: CM_AgGatewayConsumerWSAgent;
	
	agGatewayEWSDef					: CM_AgGatewayServiceDef;
	verb							: String;
	
	response						: String;
	maxRetries,
	responseCode					: Integer;
	baseEndpointLocal				: String;
	eachMessage						: String;
	messagePartNumber				: Integer;	
	messageParts					: CM_HugeStringArray;
	eachMessageContainer			: CM_HugeString;
	terminal						: CM_Terminal;
begin
	terminal := app.myPassport.myTerminal;
	if terminal = null then
		app.writeLog("Terminal not found", LogERROR);
		return;
	endif;
	
	agGatewayEWSDef := terminal.myAgGatewayServiceDef.CM_AgGatewayServiceDef;
	if agGatewayEWSDef = null then
		app.writeLog("AG Gateway ext service def not defined for terminal" &amp; terminal.code, LogERROR);
		return;
	endif;
	
	create wsAgent as CM_AgGatewayConsumerWSAgent;
	wsAgent.setupFromWebServiceDefinition(agGatewayEWSDef);
	wsAgent.setMyTerminal(terminal);
	
	maxRetries := 3;
	
	while maxRetries &gt; 0 do
		response := wsAgent.doSendHTTPRequest(agGatewayEWSDef.getShipNoticeEndPointStr(), JadeHTTPConnection.Verb_POST, wsAgent.getAdditionalHeadersForHTTP(), _shipNoticeMessage, responseCode);
		if responseCode = 200 then
			break;
		endif;
		maxRetries -= 1;
	endwhile;
	
	_response := response;							//navra1 - MTN-36083 - 19th Sep 2025
	_responseCode := responseCode;					//navra1 - MTN-36083 - 19th Sep 2025

epilog

end;</source>
        <Parameter name="_shipNoticeMessage" type="String"/>
        <Parameter name="_responseCode" type="Integer" usage="io"/>
        <Parameter name="_response" type="String" usage="io"/>
    </JadeMethod>
</Class>
