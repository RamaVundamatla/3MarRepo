    <JadeMethod name="btnJobTimesClick" id="179886f3-3dca-4e1f-9faa-6c06a583d960">
        <updating/>
        <source>btnJobTimesClick(btn: CMUI_ButtonForToolbar input) updating;
//----------------------------------------------------------------
//	Created:	06 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	aSheet : Sheet;
	idx : Integer;
begin
	
	if btn.value then
		self.mnuContextJobTimes.caption := MNU_TIMES_HIDE;
	else
		self.mnuContextJobTimes.caption := MNU_TIMES_SHOW;
	endif;
	aSheet := self.fldMain.topSheet;

	// ### PAR 13827
	if aSheet.userObject.isKindOf(CM_Crane) then
		idx := aSheet.index;
	endif;
	
	self.initTable();
	self.doRefresh();	

	// ### PAR 13827
	if not global.isValidObject(aSheet) then
		aSheet := self.shtCrane.getControl(idx);
		if aSheet = null then
			aSheet := self.shtMain;
		endif;
		
	endif;
	
	self.fldMain.topSheet := aSheet; // PAR 11646
	self.selectNewSheet(); // PAR 11646

end;</source>
