    <JadeMethod name="initialiseBOL" id="bf6cfe8d-92bf-4c71-a90e-67e14e3af053">
        <source>initialiseBOL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	tranMap : CM_TranMapBOL;
	tmctig : CMIF_TMCTranGroup;

begin
	
	foreach tranMap in self.myTMCController.myBank.allBOLTranMaps discreteLock do
		create tmctig;
		tmctig.myTranMapBOL := tranMap;
		tmctig.itemName := tmctig.getName();
		tmctig.extractName := tmctig.getCode();	

		tmctig.myGroup := self;
		tmctig.myTMCController := self.myTMCController;	
		tmctig.initialise(self.myGroup.CMIF_TMCRoot.groupCount);
	endforeach; 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initialiseCargoAlloc" id="8fda97e4-3187-488f-a4f7-e944af5e0e44">
        <source>initialiseCargoAlloc();
/*
Purpose:	 // PAR 35833		
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/

vars

	tranMap : CM_TranMapCargoAllocation;
	tmctig : CMIF_TMCTranGroup;

begin

	foreach tranMap in self.myTMCController.myBank.allCargoAllocTranMaps do
		create tmctig;
		tmctig.myCurrentMapTMCargoAllocation := tranMap;
		tmctig.itemName := tmctig.getName();
		tmctig.extractName := tmctig.getCode();
		tmctig.myGroup := self;
		tmctig.myTMCController := self.myTMCController;
		tmctig.initialise(self.myGroup.CMIF_TMCRoot.groupCount);
	endforeach;


end;</source>
    </JadeMethod>
    <JadeMethod name="initialiseEvent" id="f25972cc-68f6-4178-99cc-1d6876d1049b">
