<Class name="UT_Security" id="333952af-0a05-48f0-bada-022f8688a41a">
    <superclass name="UT_SystemAdmin"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="tAddStopsTasksToLevels" id="437e2036-74f1-421e-b4ac-41f8ddb80e6c">
        <source>tAddStopsTasksToLevels();

/*

Purpose:		Check that when adding Stops, Tasks that all levels
				above the selected on get the new item

Date			Who		Reason
03 February 2016	cnwmh5	Initial creation
27 Dec 2024			navah1	Change 33742: MTN - 22.0.24.12 - Unit Tests Review - [2]
*/
constants
	
	MyPassword						: String = "u^1tTest1";
	
vars
	
	securityRoleTerminal1			: CM_SecurityRoleTerminal;
	securityRoleTerminal2			: CM_SecurityRoleTerminal;
	securityRoleTerminal3			: CM_SecurityRoleTerminal;
	securityRoleTerminalParent		: CM_SecurityRoleTerminal;
	user							: CM_User;
	cargoType						: CM_CargoType;
	toDoTaskDesc					: CM_ToDoTaskDesc;
	userTerminal					: CM_UserTerminal;
	stop							: CM_StopsTable;
	opts							: CM_AssociationDict;
	
	selectedTypes					: CM_CargoBOLTypeSet;
	
	originalUserCode				: String;
	
begin

	originalUserCode := app.myPassport.myUser.code;

	// get the parent role
	securityRoleTerminalParent := CM_SecurityRoleTerminalRoot.firstInstance;
	
	// delete the terminal secrity roles from bottom up
	self.deleteSecurityRole("UTMDHSecL3");
	self.deleteSecurityRole("UTMDHSecL2");
	self.deleteSecurityRole("UTMDHSecL1");
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	self.assertNotNull(cargoType);
	
	create opts transient;
	
	create selectedTypes transient;
	selectedTypes.add(cargoType);

	// create the 3 levels for the security role terminal
	self.opts.purge();
	self.opts.addAssoc("ParentRole", securityRoleTerminalParent);
	securityRoleTerminal1 := self.addSecurityRole(false, "UTMDHSecL1").CM_SecurityRoleTerminal;
	self.assertNotNull(securityRoleTerminal1);
	
	securityRoleTerminalParent := securityRoleTerminal1;
	self.opts.purge();
	self.opts.addAssoc("ParentRole", securityRoleTerminalParent);
	securityRoleTerminal2 := self.addSecurityRole(false, "UTMDHSecL2").CM_SecurityRoleTerminal;
	self.assertNotNull(securityRoleTerminal2);
	
	securityRoleTerminalParent := securityRoleTerminal2;
	self.opts.purge();
	self.opts.addAssoc("ParentRole", securityRoleTerminalParent);
	securityRoleTerminal3 := self.addSecurityRole(false, "UTMDHSecL3").CM_SecurityRoleTerminal;
	self.assertNotNull(securityRoleTerminal3);

	// create user to use	
	self.opts.purge();
	self.opts.addAssoc("SysSecurityRole", CM_SecurityRoleSystemRoot.firstInstance);
	self.opts.addAssoc("UserPassword", MyPassword);
	user := self.addUser("UTMDH2", "UTMDH2");
	self.assertNotNull(user);
	
	self.opts.purge();
	self.opts.addAssoc("RequestedUser", user.code);
	self.opts.addAssoc("TermSecurityRole", securityRoleTerminal2);
	self.addUserTerminalToUser(cargoType);
	
	// add task created by user
	app.myPassport.setMyUserFromCode(user.code);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey("UTMDHSecCheck1");
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	toDoTaskDesc := self.createToDoTaskDesc("UTMDHSecCheck1");
	self.assertNotNull(toDoTaskDesc);
	
	self.deleteStopsTable(778);
	self.opts.purge();
	stop := self.addStopsTable(778, "UMSec", "UTMDHSec", selectedTypes, opts);
	self.assertNotNull(stop);
	
	// check the various terminal security roles to see that the taks has been added correctly
	securityRoleTerminalParent := CM_SecurityRoleTerminalRoot.firstInstance;
	self.assertTrue(securityRoleTerminalParent.allToDoTasksAddRemove.includes(toDoTaskDesc));
	self.assertTrue(securityRoleTerminalParent.allToDoTasksComplete.includes(toDoTaskDesc));
	self.assertTrue(securityRoleTerminal1.allToDoTasksAddRemove.includes(toDoTaskDesc));
	self.assertTrue(securityRoleTerminal1.allToDoTasksComplete.includes(toDoTaskDesc));
	self.assertTrue(securityRoleTerminal2.allToDoTasksAddRemove.includes(toDoTaskDesc));
	self.assertTrue(securityRoleTerminal2.allToDoTasksComplete.includes(toDoTaskDesc));
	self.assertFalse(securityRoleTerminal3.allToDoTasksAddRemove.includes(toDoTaskDesc));
	self.assertFalse(securityRoleTerminal3.allToDoTasksComplete.includes(toDoTaskDesc));
	
	self.assertTrue(securityRoleTerminalParent.allStopsCancel.includes(stop));
	self.assertTrue(securityRoleTerminalParent.allStopsMaint.includes(stop));
	self.assertTrue(securityRoleTerminalParent.allStopsView.includes(stop));
	self.assertTrue(securityRoleTerminal1.allStopsCancel.includes(stop));
	self.assertTrue(securityRoleTerminal1.allStopsMaint.includes(stop));
	self.assertTrue(securityRoleTerminal1.allStopsView.includes(stop));
	self.assertTrue(securityRoleTerminal2.allStopsCancel.includes(stop));
	self.assertTrue(securityRoleTerminal2.allStopsMaint.includes(stop));
	self.assertTrue(securityRoleTerminal2.allStopsView.includes(stop));
	self.assertFalse(securityRoleTerminal3.allStopsCancel.includes(stop));
	self.assertFalse(securityRoleTerminal3.allStopsMaint.includes(stop));
	self.assertFalse(securityRoleTerminal3.allStopsView.includes(stop));
	
	beginTransaction;
	foreach userTerminal in user.allUserTerminals discreteLock do
		delete userTerminal;
	endforeach;
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc("RequestedUser", user.code);
	self.opts.addAssoc("TermSecurityRole", securityRoleTerminal3);
	self.addUserTerminalToUser(cargoType);
	
	// add task created by user
	app.myPassport.setMyUserFromCode(user.code);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey("UTMDHSecCheck2");
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	toDoTaskDesc := self.createToDoTaskDesc("UTMDHSecCheck2");
	self.assertNotNull(toDoTaskDesc);
	
	self.deleteStopsTable(778);													//27.12.2024 navah1 #33742
	self.opts.purge();
	stop := self.addStopsTable(778, "UMSe1", "UTMDHSec1", selectedTypes, opts); //27.12.2024 navah1 #33742
	self.assertNotNull(stop);
	
	// check the various terminal security roles to see that the taks has been added correctly
	securityRoleTerminalParent := CM_SecurityRoleTerminalRoot.firstInstance;
	self.assertTrue(securityRoleTerminalParent.allToDoTasksAddRemove.includes(toDoTaskDesc));
	self.assertTrue(securityRoleTerminalParent.allToDoTasksComplete.includes(toDoTaskDesc));
	self.assertTrue(securityRoleTerminal1.allToDoTasksAddRemove.includes(toDoTaskDesc));
	self.assertTrue(securityRoleTerminal1.allToDoTasksComplete.includes(toDoTaskDesc));
	self.assertTrue(securityRoleTerminal2.allToDoTasksAddRemove.includes(toDoTaskDesc));
	self.assertTrue(securityRoleTerminal2.allToDoTasksComplete.includes(toDoTaskDesc));
	self.assertTrue(securityRoleTerminal3.allToDoTasksAddRemove.includes(toDoTaskDesc));
	self.assertTrue(securityRoleTerminal3.allToDoTasksComplete.includes(toDoTaskDesc));
	
	self.assertTrue(securityRoleTerminalParent.allStopsCancel.includes(stop));
	self.assertTrue(securityRoleTerminalParent.allStopsMaint.includes(stop));
	self.assertTrue(securityRoleTerminalParent.allStopsView.includes(stop));
	self.assertTrue(securityRoleTerminal1.allStopsCancel.includes(stop));
	self.assertTrue(securityRoleTerminal1.allStopsMaint.includes(stop));
	self.assertTrue(securityRoleTerminal1.allStopsView.includes(stop));
	self.assertTrue(securityRoleTerminal2.allStopsCancel.includes(stop));
	self.assertTrue(securityRoleTerminal2.allStopsMaint.includes(stop));
	self.assertTrue(securityRoleTerminal2.allStopsView.includes(stop));
	self.assertTrue(securityRoleTerminal3.allStopsCancel.includes(stop));
	self.assertTrue(securityRoleTerminal3.allStopsMaint.includes(stop));
	self.assertTrue(securityRoleTerminal3.allStopsView.includes(stop));
	
epilog

	app.myPassport.setMyUserFromCode(originalUserCode);

	delete selectedTypes;
	delete opts;
	
end;</source>
    </JadeMethod>
</Class>
