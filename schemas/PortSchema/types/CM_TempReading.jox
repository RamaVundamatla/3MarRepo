        <source>setMyTrackedItem(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     09 January 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if CM_Container.hasInstance(_ti) then
		self.myContainer	:= _ti.CM_Container;
	endif;
	self.myReeferProperties	:= _ti.myReeferProperties;
end;</source>
