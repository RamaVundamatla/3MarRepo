<Class name="CM_KPISpaceUtilisationAgent" id="914f1f6c-af2c-4c7e-b5a4-0810e095aa93">
    <superclass name="CM_Agent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myPassport" id="0a2bf7d5-e67a-45ea-97f2-3db639377901">
        <embedded/>
        <type name="CM_Passport"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myQueryAgent" id="30f20ec1-ef73-4225-9155-5c0a8e6998ed">
        <embedded/>
        <type name="CMIF_SpaceUtilisationQryAgent"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="doSave" id="bd9ce23e-0fdb-45cb-83a8-37c0cf405cd1">
        <source>doSave();
// ---------------------------------------------------------------------------
// Created:		16 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myQueryAgent.allKPITerminalAreas.isEmpty then
		return;
	endif;
	
	app.myTrxCA.trxCreateKPITerminalArea(self.myQueryAgent, app.myPassport);
end;</source>
    </JadeMethod>
    <JadeMethod name="initialise" id="e3d80886-659f-4162-ac7b-90afb8cac912">
        <updating/>
        <source>initialise(_terminal : CM_Terminal; _passport : CM_Passport input; _allTAs : CM_TerminalAreaMasterSet; _allCargoTypes : CM_CargoTypesByIdDict) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myPassport := _passport;
	self.myPassport.setMyCMIFMonitor(null);
	self.myPassport.clearErrorsWarnings();

	create self.myQueryAgent transient;
	self.myQueryAgent.myTerminal := _terminal;
	_allCargoTypes.copy(self.myQueryAgent.allQryCargoTypes);
	_allTAs.copy(self.myQueryAgent.allQryTerminalAreas);
	self.myQueryAgent.doChkSpace := true;
	self.myQueryAgent.doChkCargoType := true;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_allTAs" type="CM_TerminalAreaMasterSet"/>
        <Parameter name="_allCargoTypes" type="CM_CargoTypesByIdDict"/>
    </JadeMethod>
    <JadeMethod name="runProcess" id="826984aa-9a2c-4cac-b705-c0c7256cfe96">
        <source>runProcess();
// ---------------------------------------------------------------------------
// Created:		16 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.myQueryAgent.doQuery();
	
	self.doSave();

end;</source>
    </JadeMethod>
</Class>
