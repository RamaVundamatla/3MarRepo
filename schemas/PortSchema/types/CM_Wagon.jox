			//return ti.commodity;		// start navtnr20 02-05-2023 Bug : 57780
			if ti.commodity &lt;&gt; null then
				/*
				if data.pos(ti.commodity,1) = 0 then
					if data = null then
						data := ti.commodity;
					else
						data := data &amp; ", " &amp; ti.commodity;
					endif; // End navtnr20 02-05-2023 Bug : 57780
				endif;
				*/
				data.addStringToList(ti.commodity, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			endif;
		endforeach;
	endforeach;
	return data;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCustomStatus" id="4c4c533a-29e5-47f8-a4dd-152a143d5cda">
        <source>getCustomStatus() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60701: UI - Customs Status on Transport UI

*/

vars
	ti			: CM_TrackedItem;
	messStr,
	str			: String;
	tis			: CM_TIArray;
begin

	create tis transient;
	
	self.getAllTrackedItems(true, tis, true);
	self.getAllTrackedItems(true, tis, false);
	self.getAllTrackedItems(false, tis, true);
	self.getAllTrackedItems(false, tis, false);
	
	foreach ti in tis do
		
		str := ti.getCustomsStatus();
		
		if str = null then
			continue;
		endif;
		
		/*
		if messStr = null then
			messStr := str;
		elseif messStr.pos(str, 1) = 0 then
			messStr := messStr &amp; "," &amp; str;
		endif;
		*/
		
		messStr.addStringToList(str, ","); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return messStr;
epilog
	delete tis;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDamageCMIFController" id="6c41caca-0103-4802-966a-89ac27099a05">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_DamageDetails::getDamageCMIFController"/>
        </interfaceImplements>
        <source>getDamageCMIFController() : CMIF_Object;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwer1	Initial creation

*/

vars
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	rake : CM_RailLine;
	wagonPos : Integer;
	realWagon : CM_Wagon;
begin

	create wagonUpdateCtrl transient;
	
	realWagon := self.pxyGetRealObject.CM_Wagon;
	if realWagon &lt;&gt; null then
		rake := realWagon.myRailLine;
		if rake &lt;&gt; null then
			wagonPos := rake.allWagons.indexOf(realWagon);
		endif;
	endif;
	
	wagonUpdateCtrl.setBasicDetails(	CMIF_WagonUpdateController.Mode_Update,	//_mode : Integer;
										rake,	//_rake : CM_RailLine;
										realWagon.myTrainInwards,	//_train : CM_Train;
										wagonPos,	//_wagonPosition : Integer;
										true	//_trainMode : Boolean
										);
										
	wagonUpdateCtrl.expectedEditionWagon := realWagon.edition;									
	wagonUpdateCtrl.myProxyWagon := self;
	
	if realWagon &lt;&gt; null then
		wagonUpdateCtrl.populateFromExistingWagonAddTi( realWagon, null, 0 );
	endif;

	return wagonUpdateCtrl;
epilog

end;</source>
        <ReturnType type="CMIF_Object"/>
    </JadeMethod>
