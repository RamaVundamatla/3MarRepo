    <JadeMethod name="addEquivalentLineFromYACrit" id="91ebedf4-f853-4142-93fa-0c067cb2a8fc">
        <updating/>
        <source>addEquivalentLineFromYACrit( criteria : CM_YACriteria; className : String ):String updating;
/*

Purpose:			

Parameters:			Tries to add a Selector Query Line to a query using
					a Yard Allocation Criteria as the source.
					Some are one to one, others are NOT supported at all.

Return Value:		

Date		Who		Reason
12 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	yaData : CM_YAData;

begin

	yaData := criteria.myYAData;
	if yaData = null then
		return "No CM_YAData on YA Criteria Line";
	endif;
	
	return yaData.createTransientSelectorLine( self, criteria, className );

epilog

end;</source>
        <Parameter name="criteria" type="CM_YACriteria"/>
        <Parameter name="className" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="allowsSnapShotEdit" id="ec3e1d66-caec-4c96-878b-0e43aebf7aca">
        <source>allowsSnapShotEdit():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2021	navndl1	Initial creation	TFS 50835

*/

vars
	line : CM_SelectorCriteriaLine;
begin
	line := self.allCriteriaByPropertyName[CM_EventTransaction::myEventType.name, CM_EventTransaction.name];
	
	if line &lt;&gt; null then
		if line.myQueryOperator &lt;&gt; null then
			return line.myQueryOperator.allowsSnapShotEdit();
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="fe64a796-1bd4-4f50-8d1f-ca872c4cf68f">
        <source>cloneReferences(_transient : Boolean ; clonedSelf : SelfType input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 October 2019	jlger1	Initial creation TFS 47457

*/

vars
	criterLine,clonedCriteriaLine		: CM_SelectorCriteriaLine;
	invalidObj : Boolean;
begin
	on Exception do app.handleDeletedObject(exception,criterLine,invalidObj);
	
	foreach criterLine in self.allCriteriaLines discreteLock do
		clonedCriteriaLine:=criterLine.cloneSelf(_transient);
		if invalidObj then
			invalidObj:=false;
			continue;
		endif;
		if clonedCriteriaLine = null then
			continue;
		endif;
		clonedCriteriaLine.setMyCriteriaLineHolder(clonedSelf);
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <Parameter name="clonedSelf" type="SelfType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="collectionToSearch" id="688d2a29-81df-4f5c-a14f-ba59d560d59e">
        <methodInvocation>mapping</methodInvocation>
        <source>collectionToSearch(set: Boolean; _value: Collection io) mapping;
// -----------------------------------------------------------------------------
// Created:		09 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.collectionBelongsTo &lt;&gt; null then
			_value := self.collectionBelongsTo.getPropertyValue(self.collectionToSearchName).Collection;
		endif;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Collection" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createCriteriaLinesFromXML" id="d7ac92fc-1b2c-4e08-8d64-5bff284dacce">
        <updating/>
        <source>createCriteriaLinesFromXML(_xml : String; _qDef : CM_QueryDefinition input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	jlier1	Initial creation 53515
10 Sep 2024 navrv30 Bug 65984: EUP - Error 1090 when using Cargo review screen
*/
constants
	SelectionType = "selectionType";
	SeachValuesType = "searchValuesType";
vars
	parser : JadeXMLDocumentParser;
	doc : JadeXMLDocument;
	childElement : JadeXMLNode;
	critElement,propElement, valueElement,valueTypeElement, searchElement : JadeXMLElement;
	propName : String;
	operatorStr : String;
	critXMLElements,
	searchValues : JadeXMLElementArray;
	searchValuesType, valueType : Type;
	value, childValue : Any;
	coll : Collection;
	criteriaLine			: CM_SelectorCriteriaLine;
	clonedProp,
	existingProp		: CM_QueryProperty;
	clonedOp,
	existingOp			: CM_QueryOperator;
begin
	
	create parser transient;
	create doc transient;
	parser.parseDocumentString(doc,_xml);
	
	if doc.rootElement = null then
		return;
	endif;
	create critXMLElements transient;
	doc.rootElement.getAllElementsByTagName(CM_QueryCriteriaLineHolder::allCriteriaLines.name,critXMLElements);
	foreach critElement in critXMLElements do		
			propElement:= critElement.getElementByTagName(CM_SelectorCriteriaLine::propName.name);
			if propElement &lt;&gt; null then
				propName:=propElement.text;
			endif;
			
			propElement:= critElement.getElementByTagName(CM_QueryOperator::description.name);
			if propElement &lt;&gt; null then
				operatorStr:=propElement.text;
			endif;
			propElement:= critElement.getElementByTagName(SeachValuesType);
			if propElement &lt;&gt; null then
				searchValuesType:=propElement.text.asOid.Type;
			endif;
			delete searchValues;
			create searchValues transient;
			critElement.getAllElementsByTagName(CM_QueryStringOperators::searchValue.name,searchValues);
			if searchValuesType.isKindOf(CollClass) then
				delete coll;
				create coll as searchValuesType.CollClass transient;
				foreach childElement in searchValues do
					valueTypeElement:= childElement.JadeXMLElement.getElementByTagName(SelectionType);
					if valueTypeElement &lt;&gt; null then
						valueType:=valueTypeElement.text.asOid.Type;
					endif;
					valueElement:= childElement.JadeXMLElement.getElementByTagName(CM_QStringLookup::selectionValue.name);
					if valueElement = null then
						continue;
					endif;
					if valueType.isKindOf(PrimType) then
						childValue:=valueElement.text.asAnyOfType(valueType);
					else
						childValue:=valueElement.text.asOid;
					endif;
					if childValue &lt;&gt; null then
						coll.add(childValue);
					endif;
				endforeach;
				value:=coll;
			else
				valueElement := null; // ### TFS CR 55301 TASK 55553 30DEC2022 NAVAB1
				searchElement := searchValues.first.JadeXMLElement; // ### TFS CR 55301 TASK 55553 30DEC2022 NAVAB1
				if searchElement &lt;&gt; null then // ### TFS CR 55301 TASK 55553 30DEC2022 NAVAB1
					valueElement:= searchElement.getElementByTagName(CM_QStringLookup::selectionValue.name); // ### TFS CR 55301 TASK 55553 30DEC2022 NAVAB1
				endif;
				if valueElement = null then
					continue;
				endif;
				if searchValuesType.isKindOf(PrimType) then
					value:=valueElement.text.asAnyOfType(searchValuesType);
				else
					value:=valueElement.text.asOid;
				endif;

			endif;
		
			if propName &lt;&gt; null and operatorStr &lt;&gt; null then //value can be null
				
				existingProp := _qDef.allQueryProperties[propName];				
				if existingProp = null then			//10 Sep 2024 navrv30 Bug 65984
					continue;
				endif;
				existingOp := existingProp.allAllowedOperators[operatorStr];
				clonedProp := existingProp.cloneSelf(true);
				clonedOp := existingOp.cloneSelf(true);
				clonedOp.setSearchValue(value);
				
				create criteriaLine transient;
				criteriaLine.set(clonedProp, clonedOp, false);
				criteriaLine.setMyCriteriaLineHolder(self);
			endif;
	endforeach;
	
		
epilog
	delete searchValues;
	delete critXMLElements;
	delete coll;
	delete doc;
	delete parser;

end;</source>
        <Parameter name="_xml" type="String"/>
        <Parameter name="_qDef" type="CM_QueryDefinition" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="17bc1321-d11a-4741-9d12-39f1c16c84e8">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.allCriteriaByPropertyName.purge();

end;</source>
    </JadeMethod>
    <JadeMethod name="findCriteriaByName" id="a8421a62-7d4a-4ad4-af3b-e5e405f94209">
        <source>findCriteriaByName(_propName : String) : CM_SelectorCriteriaLine;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 October 2019	jlger1	Initial creation TFS 47457

*/

vars
	crit	: CM_SelectorCriteriaLine;
begin
	crit := self.allCriteriaByPropertyName.getAtKeyGeq(_propName,null);
	if crit &lt;&gt; null and crit.propName = _propName then
		return crit;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="CM_SelectorCriteriaLine"/>
    </JadeMethod>
    <JadeMethod name="getAllDependentCriteria" id="be71573c-294d-4025-b550-ef6d10b5b7c6">
        <source>getAllDependentCriteria(_critieria : CM_SelectorCriteriaLine input; _allCriterias : CM_SelectorCriteriaLineArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 October 2019	jlger1	Initial creation

*/

vars
	allDependentPropNames : StringArray;
	propName : String;
	crit : CM_SelectorCriteriaLine;
begin
	if _critieria = null or _allCriterias = null then
		return;
	endif;
	
	create allDependentPropNames transient;
	_critieria.myQueryProperty.getDependentProperties(allDependentPropNames);
	
	foreach propName in allDependentPropNames do
		crit:=self.findCriteriaByName(propName);
		if crit &lt;&gt; null and crit &lt;&gt; _critieria then
			if crit.getControlType = QueryControl_ComboBox then
				_allCriterias.add(crit);
			endif;
		endif;
	endforeach;
	
	
epilog
	delete allDependentPropNames;
end;</source>
        <Parameter name="_critieria" type="CM_SelectorCriteriaLine" usage="input"/>
        <Parameter name="_allCriterias" type="CM_SelectorCriteriaLineArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypes" id="be7cdbdb-ea4e-4f23-babe-daae11ecd12c">
        <source>getCargoTypes(_objectSet : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2019	jlger1	Initial creation  TFS 47132

*/

vars
	crit			: CM_SelectorCriteriaLine;
	value : Any;
	cargoType : CM_CargoType;
	cargoTypeID : Integer;
begin
	crit := self.findCriteriaByName(CM_TrackedItem::cargoType.name);
	
	
	if crit &lt;&gt; null then
		value:=crit.myQueryProperty.translateToSearchValue(crit.myQueryOperator.getSearchValue);
	endif;
	
	if value &lt;&gt; null then
		if value.isKindOf(IntegerArray) then
			foreach cargoTypeID in value.IntegerArray do
				cargoType:=app.myRoot.allCargoTypesById[cargoTypeID];
				if cargoType &lt;&gt; null then
					_objectSet.add(cargoType);
				endif;
			endforeach;
		elseif value.isKindOf(Integer) then
			cargoType:=app.myRoot.allCargoTypesById[value.Integer];
			if cargoType &lt;&gt; null then
				_objectSet.add(cargoType);
			endif;
			
		endif;
		
	endif;
epilog

end;</source>
        <Parameter name="_objectSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFullDescription" id="11b7041b-f72e-4d27-b0ce-7383a11e370a">
        <source>getFullDescription() : String;
// ---------------------------------------------------------------------------
// Created:     13 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	descr			: String;
	criteriaLine	: CM_SelectorCriteriaLine;	
begin
	foreach criteriaLine in self.allCriteriaLines do
		descr := descr &amp; criteriaLine.getDescriptionString &amp; CrLf;
	endforeach;

	return descr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLineWithAllocationAttr" id="6255fa3e-cf64-4978-9352-8ce4f579a4db">
        <source>getLineWithAllocationAttr( ya_Type : Integer ):CM_SelectorCriteriaLine;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	iter : Iterator;
	line : CM_SelectorCriteriaLine;

begin

	iter := self.allCriteriaLines.createIterator;
	while iter.next( line ) do
		if line.myQueryProperty.allocationAttribute = ya_Type then
			return line;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="ya_Type" type="Integer"/>
        <ReturnType type="CM_SelectorCriteriaLine"/>
    </JadeMethod>
    <JadeMethod name="getTerminals" id="7950a704-be5d-4187-b34e-d8013c51bf11">
        <source>getTerminals(_objectSet : ObjectSet input;
			_passport : CM_Passport );
/*

Date		Who		Reason
18 July 2014	cnwer1	Initial creation PAR

*/

vars
	iter : Iterator;
	crit			: CM_SelectorCriteriaLine;
	ut				: CM_UserTerminal;
begin
	if _objectSet = null then
		return;
	endif;
	
	iter:=self.allCriteriaByPropertyName.createIterator;
	self.allCriteriaByPropertyName.startKeyGeq(CM_TrackedItem::myTerminal.name,null,iter);
	while iter.next(crit) do
		if crit.propName &lt;&gt; CM_TrackedItem::myTerminal.name then
			break;
		endif;
		crit.myQueryOperator.getSearchValueAsObjectSet(_objectSet);
	endwhile;
		
	if _objectSet.isEmpty then
		foreach ut in _passport.myUser.allUserTerminals do
			_objectSet.add(ut.getMyTerminal);
		endforeach;
	endif;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_objectSet" type="ObjectSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getXMLStringForSave" id="f2018566-dd10-4797-a26e-cb2eaae23216">
        <source>getXMLStringForSave() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2022	jlier1	Initial creation 53515

*/
constants
	SelectionType = "selectionType";
	SeachValuesType = "searchValuesType";

vars
	jdoHolder,
	jdoCritLine,
	jdoSearchValue : JadeDynamicObject;
	jdoCritLines,

	jdoSearchValues : JadeDynamicObjectArray;
	transients 		: ObjectSet;
	json ,xmlStr		: String;
	critLine : CM_SelectorCriteriaLine;
	searchValues,
	searchValue : Any;
	obj : Object;
		jsonHelper		: CMIF_JsonHelper;
begin
	create jdoHolder transient;
	jdoHolder.addProperty(CM_QueryCriteriaLineHolder::allCriteriaLines.name,JadeDynamicObjectArray);
	
	create jdoCritLines transient;
	create transients transient;
	transients.add(jdoHolder);
	
	foreach critLine in self.allCriteriaLines discreteLock do
		searchValues:=null;
		create jdoCritLine transient;
		transients.add(jdoCritLine);
		
		jdoCritLine.addProperty(CM_SelectorCriteriaLine::propClassName.name,String);
		jdoCritLine.setPropertyValue(CM_SelectorCriteriaLine::propClassName.name,critLine.propClassName);
		jdoCritLine.addProperty(CM_SelectorCriteriaLine::propName.name,String);
		jdoCritLine.setPropertyValue(CM_SelectorCriteriaLine::propName.name,critLine.propName);
		if critLine.myQueryOperator &lt;&gt; null then
			jdoCritLine.addProperty(CM_SelectorCriteriaLine::myQueryOperator.name,String);
			jdoCritLine.setPropertyValue(CM_SelectorCriteriaLine::myQueryOperator.name,critLine.myQueryOperator.class.name);
			jdoCritLine.addProperty(CM_QueryOperator::description.name,String);
			jdoCritLine.setPropertyValue(CM_QueryOperator::description.name,critLine.myQueryOperator.description);
			
			searchValues:=critLine.myQueryOperator.getSearchValueRange(critLine.myQueryProperty);
			if searchValues = null then	
				searchValues:=critLine.myQueryOperator.getSearchValue;
			endif;
			
			if searchValues &lt;&gt; null then  // ### TFS CR 55301 TASK 55553 30DEC2022 NAVAB1
				jdoCritLine.addProperty(SeachValuesType,String);
				jdoCritLine.setPropertyValue(SeachValuesType,searchValues.getType.getOidAsString);
				jdoCritLine.addProperty(CM_QueryStringOperators::searchValue.name,JadeDynamicObjectArray);
				create jdoSearchValues transient;
				transients.add(jdoSearchValues);
				
				if searchValues.isKindOf(Collection) then
					foreach searchValue in searchValues.Collection do
						create jdoSearchValue transient;
						jdoSearchValue.addProperty(CM_QStringLookup::selectionValue.name,String);
						if searchValue.isKindOf(Object) then
							jdoSearchValue.setPropertyValue(CM_QStringLookup::selectionValue.name,searchValue.Object.getOidAsString);
						else
							jdoSearchValue.setPropertyValue(CM_QStringLookup::selectionValue.name,searchValue.asStringJMT);
						endif;
						jdoSearchValue.addProperty(SelectionType,String);	
						jdoSearchValue.setPropertyValue(SelectionType,searchValue.getType.getOidAsString);
						jdoSearchValues.add(jdoSearchValue);
						transients.add(jdoSearchValue);
					endforeach;
					if searchValues.Collection.isTransient and  not searchValues.Collection.isAnExclusiveObject then
						transients.add(searchValues.Collection);
					endif;
				else
					create jdoSearchValue transient;
					jdoSearchValue.addProperty(CM_QStringLookup::selectionValue.name,String);	
					if searchValues.isKindOf(Object) then
						jdoSearchValue.setPropertyValue(CM_QStringLookup::selectionValue.name,searchValues.Object.getOidAsString);
					else
						jdoSearchValue.setPropertyValue(CM_QStringLookup::selectionValue.name,searchValues.asStringJMT);
					endif;
					jdoSearchValue.addProperty(SelectionType,String);	
					jdoSearchValue.setPropertyValue(SelectionType,searchValues.getType.getOidAsString);
					jdoSearchValues.add(jdoSearchValue);
					transients.add(jdoSearchValue);
					
				endif;
				
				jdoCritLine.setPropertyValue(CM_QueryStringOperators::searchValue.name,jdoSearchValues);
			endif;

		endif;	
		jdoCritLines.add(jdoCritLine);
		
	endforeach;
	jdoHolder.setPropertyValue(CM_QueryCriteriaLineHolder::allCriteriaLines.name,jdoCritLines);
	
	jdoHolder.deserializeJSON(json);
	
	create jsonHelper transient;
	xmlStr := jsonHelper.convertJsonToXML(json);

	return xmlStr;
epilog
	delete jsonHelper;
	delete jdoCritLines;
	if transients &lt;&gt; null then
		transients.purge;
	endif;
	delete transients;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isEnqForCustDocCargoTrans" id="4143dc40-5240-4e5e-90d7-2899247e220c">
        <source>isEnqForCustDocCargoTrans() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	line : CM_SelectorCriteriaLine;
begin
	if 		self.allCriteriaByPropertyName[CM_TITransaction::getCustomDocAgentCodeForSel.name, CM_TITransaction.name] &lt;&gt; null
		or 	self.allCriteriaByPropertyName[CM_TITransaction::getCustomDocCodeForSel.name, CM_TITransaction.name] &lt;&gt; null
		or 	self.allCriteriaByPropertyName[CM_TITransaction::getCustomDocDateTimeForSel.name, CM_TITransaction.name] &lt;&gt; null
		or 	self.allCriteriaByPropertyName[CM_TITransaction::getCustomDocLicenseForSel.name, CM_TITransaction.name] &lt;&gt; null
		or 	self.allCriteriaByPropertyName[CM_TITransaction::getCustomDocTypeCodeForSel.name, CM_TITransaction.name] &lt;&gt; null
		or 	self.allCriteriaByPropertyName[CM_TITransaction::getCustomDocHSCodeForSel.name, CM_TITransaction.name] &lt;&gt; null
		then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEnquiryForCargoRelRecTrans" id="3dad443e-e1af-45c6-a375-95226478fa06">
        <source>isEnquiryForCargoRelRecTrans() : Boolean;
/*

Purpose:			TFS 40336

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2018	jlgab1	Initial creation

*/

vars
	line : CM_SelectorCriteriaLine;
begin
	line := self.allCriteriaByPropertyName["getTransactionType", "CM_TITransaction"];
	
	if line &lt;&gt; null then
		if line.myQueryOperator &lt;&gt; null then
			return line.myQueryOperator.isEnquiryForCargoRelRecTrans();
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForRT" id="094136a6-a4c9-4951-8789-81ff0ca7423a">
        <source>isValidForRT():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	iter : Iterator;
	criteriaLine : CM_SelectorCriteriaLine;

begin

	iter := self.allCriteriaLines.createIterator();
	
	while iter.next( criteriaLine ) do
	
		if not criteriaLine.isValidForRT() then
			return false;
		endif;
		
	endwhile;

	return true;

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeCritLine" id="1efd528a-fa7c-47a7-898c-949b27a188d1">
        <source>removeCritLine(_propName : String; _propClassName : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/04/2024	navkc1 CR63383 Task 63384: Jade - Improved invoice queries

*/

vars
	critLine		: CM_SelectorCriteriaLine;
begin
	
	critLine := self.allCriteriaByPropertyName[_propName, _propClassName];
	
	
	if critLine &lt;&gt; null and critLine.isTransient() then
		delete critLine;
	endif;
	
epilog

end;</source>
        <Parameter name="_propName" type="String"/>
