    <JadeMethod name="setBaseAttributes" id="3f2e289d-477e-470f-8ee9-7fe50e64aa99">
        <updating/>
        <source>setBaseAttributes(_ammended : Boolean; _dateTime : TimeStamp; _deleted, _noCharge : Boolean; _operatorCode : String;
				  _superceeded : Boolean; _type : Integer; _urNumber : String; _userGenerated : Boolean; _userId : String;
				  _ti : CM_TrackedItem; _terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/12/2012	cnwcs5 		CCMS SFW 1294 /par 30855
// ---------------------------------------------------------------------------
vars
	oldDeleted	: Boolean;

begin 
	oldDeleted := self.deleted;

	self.ammended		:= _ammended;
	self.dateTime		:= _dateTime;
	self.deleted		:= _deleted;
	self.noCharge		:= _noCharge;
	self.operatorCode	:= _operatorCode.trimBlanks;
	self.superseded		:= _superceeded;
	self.type			:= _type;
	self.urNumber		:= _urNumber;
	self.userGenerated	:= _userGenerated;
	self.userId			:= _userId.trimBlanks().toUpper();
	
	self.setMyTrackedItem(_ti,null);

	// now done in _passport.addTITransaction	
	if _deleted and (oldDeleted &lt;&gt; _deleted) then
		// par 30855 - create CAMS audit transaction 
		if _terminal.getConfig (CamsCreateTrxAudit).Boolean then
			self.createCAMSAuditTransaction (AuditDeleted, self, app.myPassport);
		endif;	
	endif;
end;</source>
        <Parameter name="_ammended" type="Boolean"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_deleted" type="Boolean"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_superceeded" type="Boolean"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_urNumber" type="String"/>
        <Parameter name="_userGenerated" type="Boolean"/>
        <Parameter name="_userId" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
