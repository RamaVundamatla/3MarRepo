    <JadeMethod name="doWizardStep4Processing" id="9c8fc5ad-e218-4a70-9000-41361e03efbf">
        <updating/>
        <source>doWizardStep4Processing() updating;

/*****************************************************
	Written by	:	cnwpra1		09 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	action		: Integer;

begin
	if myExcelDA = null then
		create myExcelDA;
	endif;
	
	myExcelDA.setMyWorkbookDefinition(myWorkbookDefinition);
	myExcelDA.setFileName(fileName);
	
	if blnNewWorkbook then
		action := ExcelDefnExcelDA.New_Workbook;
	elseif blnOpenExistingFile then
		action := ExcelDefnExcelDA.Open_File_New;
	elseif blnReplaceWorkbook then
		action := ExcelDefnExcelDA.Open_File_Replace;
	elseif blnUpdateWorkbook then
		action := ExcelDefnExcelDA.Update_Current_Workbook;
	endif;
	
	myExcelDA.initialise(action);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doWizardStep4ProcessingBack" id="1b188757-8f56-426c-a646-ff47c2ee8533">
        <updating/>
        <source>doWizardStep4ProcessingBack() updating;

/*****************************************************
	Written by	:	cnwpra1		12 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	
begin
	app.msgBox('The definition of the workbook has already been saved so changing Step 3 will have no effect',
							'Back Processing', MsgBox_OK_Only);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doWizardStep5Processing" id="4bf31e78-7a2a-40d9-84b8-4663ccaa331e">
        <updating/>
        <source>doWizardStep5Processing() updating;

/*****************************************************
	Written by	:	cnwpra1		09 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	processingErrorFound := myExcelDA.validateWorkbookAndDefinition;
	
	if myExcelDA.fatalError then
		doCancelled;
		processingErrorFound := false;	// so we drop out of the wizard
		return;
	elseif processingErrorFound then
		return;
	endif;
	
	if blnLoadTestData then
		processingErrorFound := not doGetDataFromHostApplication;
	endif;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doWizardStep5ProcessingBack" id="a0e26fa0-807d-496d-8c7f-35a72da2582b">
        <updating/>
        <source>doWizardStep5ProcessingBack() updating;

/*****************************************************
	Written by	:	cnwpra1		12 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	reply			: Integer;

begin
	if not myExcelDA.checkExcelOK then
		if myExcelDA.fatalError then
			doCancelled;
			backProcessingCancelled := false;	// so we drop out of the wizard
			return;
		endif;
	endif;
	
	reply := app.msgBox('Going back to Step 4 will cause the Excel to be closed so any unsaved updates will be lost' &amp; CrLf &amp; CrLf &amp;
										'Do you want to continue ?', 'Back Processing', MsgBox_Yes_No);
	
	if reply = MsgBox_Return_Yes then
		myExcelDA.closeExcel;
		myExcelDA.doCleanupProcessing;		
		myExcelDA := null;
	else
		backProcessingCancelled := true;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doWizardStep6Processing" id="fd93394c-34db-49a7-ae2f-2dbb5252b02e">
        <updating/>
        <source>doWizardStep6Processing() updating;

/*****************************************************
	Written by	:	cnwpra1		09 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if not myExcelDA.checkExcelOK then
		doCancelled;
		processingErrorFound := false;	// so we drop out of the wizard
		return;
	endif;
	
	if blnDiscardWorkbook then
		// the doCancelled shuts down Excel
	elseif blnSaveWorkbook then
		processingErrorFound := myExcelDA.validateWorkbookAndDefinition;
		
		if myExcelDA.fatalError then
			doCancelled;
			processingErrorFound := false;	// so we drop out of the wizard
			return;
		elseif processingErrorFound then
			return;
		endif;
		
		myExcelDA.saveWorkbookToDB;
	endif;
		//I need to tidy up the attributes of the DA as I am now finished with this workbook 
		
	doCancelled;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doWizardStep6ProcessingBack" id="e3447ea8-256d-4995-8676-caf1044378c6">
        <updating/>
        <source>doWizardStep6ProcessingBack() updating;

/*****************************************************
	Written by	:	cnwpra1		12 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	reply	: Integer;
	
begin
	if not myExcelDA.checkExcelOK then
		if myExcelDA.fatalError then
			doCancelled;
			backProcessingCancelled := false;	// so we drop out of the wizard
			return;
		endif;
	endif;
	
	if blnLoadTestData or myExcelDA.dataWorksheetUpdated then
		reply := app.msgBox('Going back to Step 5 will cause any test data to be removed from the ' &amp; 
										myWorkbookDefinition.dataWorksheet &amp; ' worksheet.' &amp; CrLf &amp; CrLf &amp;
										'Do you want to continue ?', 'Back Processing', MsgBox_Yes_No);
		
		if reply = MsgBox_Return_Yes then
			myExcelDA.clearWorksheetData;
		else
			backProcessingCancelled := true;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doWizardStepProcessing" id="c34174fd-99eb-4ff6-bd02-112b93d15548">
        <updating/>
        <source>doWizardStepProcessing() updating;

/*****************************************************
	Written by	:	cnwpra1		09 May 2004
	Description	:	This method is called after a 'Next' and is before the step is
					incremented so it can do the processing for the current step

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if intCurrentWizardStep = 1 then
		doWizardStep1Processing;
	elseif intCurrentWizardStep = 3 then	
		doWizardStep3Processing;
	elseif intCurrentWizardStep = 4 then
		doWizardStep4Processing;
	elseif intCurrentWizardStep = 5 then
		doWizardStep5Processing;
	elseif intCurrentWizardStep = 6 then
		doWizardStep6Processing;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doWizardStepProcessingBack" id="291ffdac-8f30-454c-9041-30dc24df145f">
        <updating/>
        <source>doWizardStepProcessingBack() updating;

/*****************************************************
	Written by	:	cnwpra1		09 May 2004
	Description	:	This method is called after a 'Back' and is before the step is
					decremented so it can undo the processing that took place to get
					to the current step

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if intCurrentWizardStep = 2 then
		doWizardStep2ProcessingBack;
	elseif intCurrentWizardStep = 3 then	
		doWizardStep3ProcessingBack;
	elseif intCurrentWizardStep = 4 then
		doWizardStep4ProcessingBack;
	elseif intCurrentWizardStep = 5 then
		doWizardStep5ProcessingBack;
	elseif intCurrentWizardStep = 6 then
		doWizardStep6ProcessingBack;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doWorkbookDefnWizardStep1" id="372d567c-f46c-4eaa-9274-c59bba7561a8">
        <updating/>
        <source>doWorkbookDefnWizardStep1()updating;

/*****************************************************
	Written by	:	cnwgrp1		04 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

constants
	Option_Load_Form = 1;
	Option_Activate_Form = 2;
	
vars
	excelDefWiz1	: ExcelDefnWizStep1Form;
	excelDataDA 	: ExcelDefnDataDA;
begin
	create excelDefWiz1;
	if myExcelDataDA = null then
		create excelDataDA;
		setMyExcelDataDA(excelDataDA);
		if myWorkbookDefinition &lt;&gt; null then
		excelDataDA.setValues(myWorkbookDefinition.workbookName,
								myWorkbookDefinition.workbookDescription,
								myWorkbookDefinition.dataWorksheet,
								myWorkbookDefinition.hideDataWorksheet,
								myWorkbookDefinition.topWorksheet);
		endif;
	endif;
	excelDefWiz1.setMyDA(self);
	excelDefWiz1.setCurrentStep(1);
	excelDefWiz1.setMyDataDA(myExcelDataDA);
	
	excelDefWiz1.loadForm;
	myControllingAppsDA.invokeMethod(myControllingAppsContext, myControllingAppsShowMethod, excelDefWiz1, Option_Load_Form);
	excelDefWiz1.show;
	//excelDefWiz1.showModal;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doWorkbookDefnWizardStep2" id="ce5ef129-e3ff-42e0-9837-a56c5f5d5f77">
