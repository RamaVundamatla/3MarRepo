    <JadeMethod name="resize" id="b2edc634-4166-46ff-a756-8262f74602ff">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		23 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnClose.move(((self.width - btnClose.width) - 18), ((self.height - btnClose.height) - 36), btnClose.width, btnClose.height);
	btnEdit.move(((btnClose.left - btnEdit.width) - 6), ((self.height - btnEdit.height) - 36), btnEdit.width, btnEdit.height);
	btnDelete.move(((btnEdit.left - btnDelete.width) - 6), ((self.height - btnDelete.height) - 36), btnDelete.width, btnDelete.height);
	btnNew.move(((btnDelete.left - btnNew.width) - 6), ((self.height - btnNew.height) - 36), btnNew.width, btnNew.height);
	btnFilter.move(btnFilter.left, ((self.height - btnFilter.height) - 36), btnFilter.width, btnFilter.height);
	tblObjects.move(tblObjects.left, tblObjects.top, (self.width - (tblObjects.left * 3) + 2), (btnClose.top - 46));
	tblObjects.positionScrollbar();
end;</source>
    </JadeMethod>
    <JadeMethod name="setIsBrowseOnly" id="e5006a64-fb77-4052-b9ca-8c53a017260a">
        <updating/>
        <source>setIsBrowseOnly(pValue: Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Sets a flag to indicate whether the class instances can only be
//				browsed, i.e. they can't be edited.
//
// Parameters:	pValue - True if the instances can only be browsed.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isBrowseOnly &lt;&gt; pValue then 
		self.isBrowseOnly := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyClass" id="dd103e91-da95-45a0-86b2-a27a561d4d0c">
        <updating/>
        <source>setMyClass(pValue: Class) updating;
// --------------------------------------------------------------------------------
// Created:		10 January 1999 by cnwdad1
//
// Purpose:		Sets a reference to the class who's instances are being browsed.
//
// Parameters:	pValue - The class who's instances will be browsed.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myClass &lt;&gt; pValue then 
		self.myClass := pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Class"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="c15a918d-90bc-4d02-8c84-3e1f0007db63">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		10 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.loadInstances(self.myClass);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblObjects_click" id="1b527581-a870-47ad-bdb5-d5df5f3f2264">
        <controlMethod name="CnEcDesignTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblObjects_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		10 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (tblObjects.row &gt; 1) and (not self.myClass.isSystemObject) then
		btnEdit.enabled		:=	true;
		btnDelete.enabled	:=	true;
	else
		table.clearAllSelected;
		btnEdit.enabled		:=	false;
		btnDelete.enabled	:=	false;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblObjects_dblClick" id="f4bac4f0-6836-4062-9a1d-a4b7aba8721c">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblObjects_dblClick(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		10 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (not self.myClass.isSystemObject) then
		btnEdit_click(btnEdit);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblObjects_displayEntry" id="3a497074-8d2e-4d4a-9ea5-55a94dde7def">
        <controlMethod name="CnEcDesignTable::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblObjects_displayEntry(table: CnEcDesignTable input; obj: Any; columnHeading: String input):String updating;
// --------------------------------------------------------------------------------
// Created:		10 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (columnHeading.trimBlanks.length &gt; 0) then
		if (columnHeading = "Object OID") then
			return obj.getOidString;
		elseif (self.myClass.findProperty(columnHeading).getType.name = "Binary") then
			return self.BINARY_LITERAL;
		else
			return obj.Object.getPropertyValue(columnHeading).String;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="CnEcDesignTable" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="columnHeading" type="String" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblObjects_excludeObject" id="99e19aa1-8434-4dbc-befb-e50b2e65a97c">
        <controlMethod name="CnEcDesignTable::excludeObject"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblObjects_excludeObject(obj: Object):Boolean updating;
// --------------------------------------------------------------------------------
// Purpose:	This method must NEVER be removed, as the source is set by the object
//			selection criteria mechanism.  When the selection criteria is to be
//			cleared, the source will be set to return a false value (ie. the source
//			you are reading now).
// --------------------------------------------------------------------------------
begin
	if self.selectionCriteriaArray.isEmpty() then
		return false;
	else
		return self.checkCriteria(obj);
	endif;
end;</source>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblObjects_mouseDown" id="1a9cd6de-bcb1-49e2-a042-c73e519908a4">
        <controlMethod name="CnEcDesignTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblObjects_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		12 July 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (table.row &gt; 1) and (table.row &lt;= table.rows) then
		if (table.column &gt; 0) and (table.column &lt;= table.columns) then
			if (table.cnEcGetCellObject(table.row, 1) &lt;&gt; null) then
				if (button = Window.MouseButton_Right) then
					popupMenu(mnuPopup, (x.Integer + table.left.Integer), (y.Integer + table.top.Integer));
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="unload" id="58722177-b578-4745-8bc5-9decbc42051d">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		10 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	jadeMethod	: JadeMethod;
	object		: Object;

begin
	self.statusMsg("Deleting transient objects...");
	self.selectionCriteriaArray.clear();

	foreach object in self.selectionCriteriaArray do
		if object &lt;&gt; null and object.isTransient() then
			delete object;
		endif;
	endforeach;
epilog
	endNotificationForSubscriber(self);
	self.statusMsg("");
end;</source>
    </JadeMethod>
</GUIClass>
