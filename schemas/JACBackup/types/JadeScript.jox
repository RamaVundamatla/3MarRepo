    <JadeMethod name="doWork" id="71f42b7c-6032-4c5e-9438-9cc2ffd17079">
        <source>doWork();
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	index:Integer;
	test:Test;
begin
	foreach index in 1 to 2000 do
		beginTransaction;
		create test;
		commitTransaction;
		beginTransaction;
		delete test;
		commitTransaction;
	endforeach;
	write 'Finished work.';
end;</source>
    </JadeMethod>
    <JadeMethod name="getMethodPosition" id="89cd2a56-992b-4e01-9ff8-ed376642047b">
        <source>getMethodPosition();
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

// This method gets the source of method 
// and outputs the line that includes the source position specified.
// It also outputs the previous 'Context' lines and a trailing line that points to
// the exact(?) position.

constants
	Context = 3;
vars
	clas: Class;
	prim: PrimType;
	methd: Method;
	srce: String;
	pointer: String;
	startPos: Integer;
	endPos: Integer;
	lineStart: Integer;
	lineCount: Integer;
	i: Integer;
begin

	// get the method's class
	// and the method where the error occurred
	clas := currentSchema.getClass("JACBackupController");
	methd := clas.getMethodInHTree("backupException");
	startPos := 1592;		//enter source position here
	clas := currentSchema.getClass("JACBackupSplitInfo");
	methd := clas.getMethodInHTree("backupFiles");
	startPos := 333;		//enter source position here

	//get the method's source
	srce  := methd.getSource;

	//get start of line and context
	foreach i in startPos to 1 step -1 do
		if srce[i] = Lf then

			if lineCount = 0 then
				lineStart := i + 1;
			endif;

			if lineCount = Context then
			 	break;
			 endif;

			lineCount := lineCount + 1;

		endif;
	endforeach;

	if (i = 0) or srce[i] = Lf then
		i := i + 1;
	endif;

	//get end of line
	endPos := srce.pos(CrLf, startPos);

	//output the lines in error
	write srce[i:endPos - i];

	// now point to the error
	pointer[startPos - lineStart + 2] := '^';

	foreach i in lineStart to startPos do
		// get the Tabs right
		if srce[i] = Tab then
			pointer[i - lineStart + 1] := Tab;
		endif;
	endforeach;

	write pointer &amp; " The error!";

end;</source>
    </JadeMethod>
    <JadeMethod name="getSecInfo" id="d5cda68d-4a00-4917-bcc9-653bfecf1b32">
        <source>getSecInfo();
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	jdba: JadeDatabaseAdmin;
	jdo: JadeDynamicObject;
	jdoArray: JadeDynamicObjectArray;
	secName: String; 
begin
	create jdba transient;
	create jdoArray transient;
	create jdo transient;
	jdba.sdsGetSecondaryProxies(jdoArray);
	secName := jdoArray[1].getAttributeValue("myName").String;
	jdoArray.inspectModal;
	write secName;
	jdba.sdsGetSecondaryInfo(secName,jdo);
	jdo.inspectModal;
epilog
	delete jdba;
	delete jdo;
	delete jdoArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="restartFirstSchedule" id="5f0c7484-1063-4d22-a8c8-cb48c49f1baf">
