    <JadeMethod name="canView" id="53fca4b3-2687-409d-9a10-04498472a623">
        <source>canView(_user : CM_User): Boolean;
/* ---------------------------------------------------------------------------
Created:     15 August 2008 by cnwrs2

Purpose:     PAR 16831 - check user has view permission
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	if _user = null then
		return false;
	endif;
	
	return _user.canViewStop(self.myTerminal, app.myRoot.allStopsTable[self.stopID]);

epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCCEventProperties" id="e988e5b5-d7d0-48af-aa8e-7a0a3e30d7dd">
        <source>getCCEventProperties(ccEvent: CMIF_CCEvent) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 45963

*/

vars

	stopType : String;
	vRequiredInfo : String;
	
begin

	stopType := self.getStopDescription;
	vRequiredInfo := self.requiredInfo;

	inheritMethod(ccEvent);
	
	ccEvent.addText( "stopType", stopType );
	ccEvent.addText( "requiredInfo", vRequiredInfo) ;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="ccEvent" type="CMIF_CCEvent"/>
    </JadeMethod>
