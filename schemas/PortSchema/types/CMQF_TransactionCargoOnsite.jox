    <JadeMethod name="filterObjects" id="3dbd9b97-fdd1-4a25-bca8-17091fb8d3b9">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		24 February 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// MES CCMS 1015 PAR22444 - cnwsh3. Messina Reports (Document - Teminal Ops BRS 2.1)
//----------------------------------------------------------------------
vars
	voyage 		: CM_Voyage;
	txnType 	: Integer;
	startTS,
	endTS		: TimeStamp;
	terminal 	: CM_Terminal;
	cargoType 	: Integer;
begin
	if self.getMyCargoType &lt;&gt; null then
		cargoType := self.getMyCargoType.id;
	endif;
	
	//Add edit txns as search option.
	self.initFields();
	
	//Set the time/date range.
	self.setDefaultStartEndDates(startTS, endTS);
	
	if self.getMyVoyage &lt;&gt; null then
		voyage := self.getMyVoyage;

		if not voyage.archived then
			foreach txnType in self.allTxnTypes do 
				voyage.getTITxnsByTypeFromTIs(txnType, 
											  false,
											  true,
											  false,
											  true,
											  startTS, 
											  endTS, 
											  CMQF_FilterReports::checkStatusIncludesObject.name, 
											  self, 
											  _collection);	
			endforeach;
		endif;
	else
		foreach terminal in self.allTerminals do : terminalLoop
			foreach txnType in self.allTxnTypes do
				terminal.getTITxnsByTypeFromOnsiteTIs(txnType, startTS, endTS, cargoType, CMQF_FilterReports::checkStatusIncludesObject.name, self, _collection);
				//terminal.getTITxnsForTypeAll(txnType, startTS, endTS, CMQF_FilterReports::checkStatusIncludesObject.name, self, _collection);
			endforeach;
		endforeach;
	endif;
		
epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="5c4e1117-ce15-4c3f-9414-bb8c5f0a9b47">
        <updating/>
        <source>includesObject(_trx: CM_TITransaction; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		24 February 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// MES CCMS 1015 PAR22444 - cnwsh3. Messina Reports (Document - Teminal Ops BRS 2.1)
//----------------------------------------------------------------------
vars
	rtnValue : Boolean;
begin
	rtnValue :=  inheritMethod(_trx, _passport, _breakOut);

	if rtnValue = false then
		return false;
	endif;
	
	if _trx.myTrackedItem = null then
		return false;
	endif;

	if self.getMyCargoType &lt;&gt; null and 
	   self.getMyCargoType &lt;&gt; _trx.myTrackedItem.myCargoType then
		return false;
	endif;
	
	return true;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_trx" type="CM_TITransaction"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFields" id="17a30bd6-bde4-4645-ba31-5a7be1b74e59">
        <updating/>
        <source>initFields() updating;
