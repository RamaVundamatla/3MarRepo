    <JadeMethod name="translateToDisplayValue" id="9b401565-7170-4217-a8e4-be45ad87448e">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin
	if _value &lt;&gt; null then
		return _value.CM_VehicleVisitRecord.visitNumber;
	endif;
	
	return null;

epilog

end;</source>
