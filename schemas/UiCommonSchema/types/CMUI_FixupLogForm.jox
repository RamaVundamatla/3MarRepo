    <JadeMethod name="userNotify" id="e688ce10-c117-4ddf-932b-8863e2779501">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2019	jlgndl1	Initial creation	TFS 47053

*/

vars

begin

	if eventType = EVENT_APP_LOG_LEVEL and theObject &lt;&gt; null and Process.hasInstance(theObject) and process = theObject.Process then
		self.setLogInfoLevels( true, userInfo.Integer );
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
