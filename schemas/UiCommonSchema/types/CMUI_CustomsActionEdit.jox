    <JadeMethod name="initSegmentCombo" id="ccae30d2-f771-4c49-935f-0301596ab1dd">
        <updating/>
        <source>initSegmentCombo() updating;
// ---------------------------------------------------------------------------
// Created:	30 September 2008 By Graeme Black cnwgb1
// Purpose: Key Segment combo (Non-AMS)	
// ---------------------------------------------------------------------------
// 30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops

vars
begin
	self.cmbFileSegment.clear;
	// 21/08/2009 	cnwsh3 		CCMS SFW1868 PAR20300 - CSI Inspection Stop revmoval via CUSRES
	// Put the value behind the item so we can get it from when loading the form with an EDI action selected.

	if self.ediFileType &lt;&gt; EDIFileType_XMLOneStopCust then
		self.cmbFileSegment.addItemWithData(EDIKeySegment_FTXDIN &amp; Tab &amp; ' - MAF Actions', EDIKeySegment_FTXDIN_Value);
		self.cmbFileSegment.addItemWithData(EDIKeySegment_FTXQIN &amp; Tab &amp; ' - Quarantine Instruction', EDIKeySegment_FTXQIN_Value);
		if self.ediFileType = EDIFileType_JMTInternal then // TFS 39133
			self.cmbFileSegment.addItemWithData(EDIKeyField_Clearance &amp; Tab &amp; ' - NZCS/MPI Clearance', EDIKeyField_Clearance_Value); // TFS 39133
			self.cmbFileSegment.addItemWithData(EDIKeySegment_MOT, EDIKeySegment_MOT_Value); // ### TFS 58834 (58836) 11July2023 NAVPW1
			// ### TFS 58831 (58833) 11July2023 NAVPW1
			self.height := 275;
			self.lblRoleCode.visible := true;
			self.cmbRoleCode.visible := true;
			// ### TFS 58831 (58833) 11July2023 NAVPW1
		else // TFS 39133
			self.cmbFileSegment.addItemWithData(EDIKeySegment_GIS &amp; Tab &amp; ' - Customs Clearance', EDIKeySegment_GIS_Value);
		endif; // TFS 39133
	endif;
	
	if self.ediFileType = EDIFileType_XMLOneStopCust then
		self.cmbFileSegment.addItemWithData(EDIKeySegment_CARST &amp; ' - AUS Customs', EDIKeySegment_CARST_Value);
		self.cmbFileSegment.addItemWithData(EDIKeySegment_CTORECR &amp; ' - AUS Customs', EDIKeySegment_CTORECR_Value);
		self.cmbFileSegment.addItemWithData(EDIKeySegment_SEAOUTR &amp; ' - AUS Customs', EDIKeySegment_SEAOUTR_Value);
		self.cmbFileSegment.addItemWithData(EDIKeySegment_AQISHOLD &amp; ' - AUS Customs', EDIKeySegment_AQISHOLD_Value);
		self.cmbFileSegment.addItemWithData(EDIKeySegment_XRAYADV &amp; ' - AUS Customs', EDIKeySegment_XRAYADV_Value);
		self.cmbFileSegment.addItemWithData(EDIKeySegment_CTOREMR &amp; ' - AUS Customs', EDIKeySegment_CTOREMR_Value);
		self.cmbFileSegment.addItemWithData(EDIKeySegment_UBMREQR  &amp; ' - AUS Customs', EDIKeySegment_UBMREQR_Value);
	endif;
	
	//Was up to 19/8/2009
	//self.cmbFileSegment.addItem(EDIKeySegment_FTXDIN &amp; Tab &amp; ' - MAF Actions');
	//self.cmbFileSegment.addItem(EDIKeySegment_FTXQIN &amp; Tab &amp; ' - Quarantine Instruction');
	//self.cmbFileSegment.addItem(EDIKeySegment_GIS &amp; Tab &amp; ' - General Indicator'); // cnwgb1 6-August-09 Prototype for CCMS 1868 POL
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="9477e832-fe1d-4c9c-9e71-7506e1bd2e68">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		26 February 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
//----------------------------------------------------------------------
vars

begin
	inheritMethod(keyCode, shift);
epilog
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadForm" id="d6643baa-3889-4b09-93eb-6066d78c90ea">
        <updating/>
        <source>loadForm() updating;
// ---------------------------------------------------------------------------
// Created:	11 September 2008 By Graeme Black cnwgb1
// Purpose:	CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
// 30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops
// 31/10/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing

vars
begin
	// Edit Action
	if self.myEDIAction &lt;&gt; null and self.myEDIAction.myEDIFileType.type = self.ediFileType then 
		if self.ediFileType = EDIFileTypeX12_350_4010
		or self.ediFileType = EDIFileTypeCAMIR_CustomsStatus then		//cnwmc5 - 10 July 2014 - CCMS 2353 PEN
			txtCode.text := self.myEDIAction.keyword;
			//PAR21435 - cnwsh3.  23/10/2009.  Allow name to be editable.
			txtName.text := self.myEDIAction.name;
			txtDescription.text := self.myEDIAction.description;
			self.setActionTypeCombo(self.myEDIAction.actionType);
			self.showAction( self.cmbActionType.text );
			self.setActionData( self.cmbActionType.text );
		elseif self.ediFileType = EDIFileType_CusRes or self.ediFileType = EDIFileType_XMLOneStopCust or self.ediFileType = EDIFileType_JMTInternal then // TFS 39133
			txtCode.text := self.myEDIAction.name;
			lblDescription.caption := app.getErrorString(Keyword);	//ChangeRequest 46721
			txtDescription.text := self.myEDIAction.keyword;
			self.setActionTypeCombo(self.myEDIAction.actionType);
			self.showAction( self.cmbActionType.text );
			self.setActionData( self.cmbActionType.text );
			self.setSegmentCombo(self.myEDIAction.keyFileSegment);
			self.doComboFileSegmentChange(self.cmbFileSegment);		// ### TFS 58834 20July2023 NAVPW1
			self.setActionRoleCodeCombo(self.myEDIAction.roleCode);	// ### TFS 58831 (58833) 05July2023 NAVPW1
		endif;
	else
	
		if self.ediFileType = EDIFileType_CusRes or self.ediFileType = EDIFileType_XMLOneStopCust or self.ediFileType = EDIFileType_JMTInternal then //09 Sep 2016	NDL	TFS 2278 / 2670 // TFS 39133
			lblDescription.caption := app.getErrorString(Keyword);	//ChangeRequest 46721
		
			// New Action
			txtCode.text := "";
			txtDescription.text := "";
			self.setActionTypeCombo(null);
			self.showAction( "" );
			self.setActionObject( null );
			self.txtData.text := "";
			self.setActionRoleCodeCombo(null);	// ### TFS 58831 (58833) 05July2023 NAVPW1
		endif;
	endif;
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="loadProxy" id="6f57a2e4-f83b-4467-ac03-ef97eadb39ea">
        <source>loadProxy(_pxyEDIAction : CM_EDIAction io) : Boolean;
// ---------------------------------------------------------------------------
// Created:	15 September 2008 By Graeme Black cnwgb1
// Purpose:	Loads the EDIAction Proxy with values from the CustomsActionEdit
//          Form. CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
// 30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops
// 31/10/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
// 03/07/2023	navpw1	TFS 58831 (58833) - Added roleCode
// 20/07/2023	navpw1	TFS 58834 - Fixed Mode of Transport Key File Segment

vars
	code 				: String;
	tmpName,
	description 		: String;
	action  			: String;
	keySeg				: String;
	objHold 			: Object;
	statusCode 			: Integer;
	statusText 			: String;
	ediFileTypeClass	: CM_EDIFileType;
	roleCode			: String;
	
begin
	code := self.txtCode.text;
	//PAR21435 - cnwsh3 23/10/2009.  Allow name to be editable.
	tmpName := self.txtName.text;
	description := self.txtDescription.text;
	action := self.cmbActionType.text;

	statusCode := 0;
	statusText := null;
	roleCode := self.cmbRoleCode.text;	// ### TFS 58831 (58833) 03July2023 NAVPW1
	
	// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	// Added Global Constants to describe EDI Actions for X12.
	if   action = EDIAction_PlaceHold//"Place Hold" 
	  or action = EDIAction_RemoveHolds//"Remove Hold" 
	  or action = EDIAction_Add//"Add"
	  or action = EDIAction_Complete//"Complete"
	  or action = EDIAction_Remove //"Remove" then
	  or action = EDIAction_PlaceContHold		//ChangeRequest 46721
	  or action = EDIAction_RemoveContHold		//ChangeRequest 46721
	  or action = EDIAction_AddToDoTask			//ChangeRequest 46721
//	  or action = EDIAction_CompleteToDoTask	//ChangeRequest 46721 NOT USED
	  or action = EDIAction_DeleteToDoTask then	//ChangeRequest 46721
	  objHold := self.cmbData.listObject;
	elseif action = "Set Status Code" then
		statusCode  := self.txtData.text.asNullInteger();
	elseif action = "Set Status Text" then
			statusText := self.txtData.text;
	endif;
	
	keySeg := self.cmbFileSegment.text[1:EDIKeySegment_MOT.length];	// ### TFS 58834 19July2023 NAVPW1
	if keySeg &lt;&gt; EDIKeySegment_MOT then								// ### TFS 58834 19July2023 NAVPW1
		keySeg := self.cmbFileSegment.text[1:EDIKeyField_Clearance.length]; // TFS 39133
		if keySeg &lt;&gt; EDIKeyField_Clearance then // TFS 39133
			keySeg :=  keySeg[1:7]; // TFS 39133 - here FTX+DIN, FTX+QIN or GIS
			if keySeg.pos(EDIKeySegment_GIS, 1) &gt; 0 then // TFS 39133 - 21/08/18 - fix GIS-related UI &amp; UT issues // TFS 39133 - 04/08/18 - bad index!
				keySeg := EDIKeySegment_GIS; // TFS 39133 - 21/08/18
			endif; // TFS 39133 - 21/08/18
			//keySeg.replaceChar(Tab, null); // 19/08/2009 	cnwsh3 		CCMS SFW1868 PAR20300 - CSI Inspection Stop revmoval via CUSRES // TFS 39133 - 21/08/18
		endif; // TFS 39133
	endif;		// ### TFS 58834 19July2023 NAVPW1
	
    ediFileTypeClass := app.myRoot.allEDIFileTypes.getAtKeyGeq( self.ediFileType, null);
    if ediFileTypeClass = null or ediFileTypeClass.type &lt;&gt; self.ediFileType then
        app.msgBox(app.getErrorString(EDI_File_config_not_correct),app.getErrorString(Customs_action), MsgBox_OK_Only );	//ChangeRequest 46721
		return false;
    endif;

	
	if self.ediFileType = EDIFileTypeX12_350_4010 then
		_pxyEDIAction.setProxy( 
			tmpName,
			code, 
			"X407", 
			action, 
			objHold.CM_Object,
			ediFileTypeClass,
			description, 
			statusText,
			statusCode,
			null);				// ### TFS 58831 (58833) 03July2023 NAVPW1
	//cnwmc5 - 10 July 2014 - CCMS 2353 PEN
	elseif self.ediFileType = EDIFileTypeCAMIR_CustomsStatus then
		_pxyEDIAction.setProxy( 
			tmpName,
			code, 
			"R02", 
			action, 
			objHold.CM_Object,
			ediFileTypeClass,
			description, 
			statusText,
			statusCode,
			null);				// ### TFS 58831 (58833) 03July2023 NAVPW1 
	elseif self.ediFileType = EDIFileType_CusRes or self.ediFileType = EDIFileType_JMTInternal then // TFS 39133
		_pxyEDIAction.setProxy( 
			code,
			description, 
			keySeg, 
			action, 
			objHold.CM_Object,
			ediFileTypeClass,
			description, 
			statusText,
			statusCode,
			roleCode);			// ### TFS 58831 (58833) 03July2023 NAVPW1 
	elseif self.ediFileType = EDIFileType_XMLOneStopCust then	//08 Sep 2016	NDL	TFS 2278 / 2670
		keySeg := app.getEDIKeyFileSegmentTypeStr(self.cmbFileSegment.itemData[ self.cmbFileSegment.listIndex ] );
		
		_pxyEDIAction.setProxy( 
			code,
			description, 
			keySeg, 
			action, 
			objHold.CM_Object,
			ediFileTypeClass,
			description, 
			statusText,
			statusCode,
			null);				// ### TFS 58831 (58833) 03July2023 NAVPW1
	endif;
	return true;
	
epilog
end;</source>
        <Parameter name="_pxyEDIAction" type="CM_EDIAction" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setActionData" id="f99c23f8-08c2-4e5d-90ff-1800c50dd496">
        <updating/>
        <source>setActionData(_selectedText : String) updating;
// ---------------------------------------------------------------------------
// Created:	18 September 2008 By Graeme Black cnwgb1
// Purpose:	Set the action object determined by the text
// ---------------------------------------------------------------------------
// 30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops
// 31/10/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
vars
begin
	self.setActionObject(null);
	self.setActionText("");
	if self.ediFileType = EDIFileTypeX12_350_4010
	or self.ediFileType = EDIFileTypeCAMIR_CustomsStatus then		//cnwmc5 - 10 July 2014 - CCMS 2353 PEN
		if _selectedText = "Set Status Code" then					//ChangeRequest 46721
			self.setActionNumber(  self.myEDIAction.actionNumber );	//ChangeRequest 46721			
		elseif _selectedText = "Set Status Text" then				//ChangeRequest 46721
			self.setActionText(  self.myEDIAction.actionText );		//ChangeRequest 46721
		else														//ChangeRequest 46721
			self.setActionObject( self.myEDIAction.myActionObject);	//ChangeRequest 46721
		endif;
	elseif self.ediFileType = EDIFileType_CusRes or self.ediFileType = EDIFileType_XMLOneStopCust or self.ediFileType = EDIFileType_JMTInternal then // TFS 39133
		if _selectedText &lt;&gt; null then
			self.setActionObject( self.myEDIAction.myActionObject);
		endif;
	endif;
epilog
end;</source>
        <Parameter name="_selectedText" type="String"/>
    </JadeMethod>
    <JadeMethod name="setActionNumber" id="5c8a3056-1169-48fb-a610-cb5e33944c6b">
        <source>setActionNumber( number : Integer);
// ---------------------------------------------------------------------------
// Created:	11 September 2008 By Graeme Black cnwgb1
// Purpose:	CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
vars
begin
	txtData.text := number.asStringJMT();
epilog
end;</source>
        <Parameter name="number" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setActionObject" id="4710079f-0c98-4a8d-83fa-87cde3783ad5">
        <source>setActionObject( _object : Object);
// ---------------------------------------------------------------------------
// Created:	11 September 2008 By Graeme Black cnwgb1
// Purpose:	CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
vars
begin
	if _object &lt;&gt; null then
	//	self.cmbData.listObject := _object;
		self.cmbData.listIndex := self.cmbData.findObject(_object);	//12 Sep 2016	NDL	TFS 2278 / 2670
	endif;
epilog
end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setActionRoleCodeCombo" id="8ab76d39-3b0d-4091-8f5d-266f40fd81cc">
        <source>setActionRoleCodeCombo(_roleCode : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 July 2023	navpw1	Initial creation TFS: 58831 (58833)

*/

vars
	idx : Integer;
	
begin
	if _roleCode = null then
		self.cmbRoleCode.setIndex(0);
		return;
	endif;
	
	foreach idx in 1 to self.cmbActionType.listCount do
		if self.cmbRoleCode.itemText[idx] = _roleCode then
			self.cmbRoleCode.setIndex(idx);
			return;
		endif;
	endforeach;
	
	self.cmbRoleCode.setIndex(0);
	
end;</source>
        <access>protected</access>
        <Parameter name="_roleCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setActionText" id="835adc87-974d-4ce0-a54c-4321b3a7008f">
        <source>setActionText( _text : String );
// ---------------------------------------------------------------------------
// Created:	11 September 2008 By Graeme Black cnwgb1
// Purpose:	CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
vars
begin
	txtData.text := _text;
epilog
end;</source>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="setActionTypeCombo" id="d9f0c59b-d493-45ff-aa36-e19e93105dcc">
        <source>setActionTypeCombo( _actionType : String )  protected;
// ---------------------------------------------------------------------------
// Created:	11 September 2008 By Graeme Black cnwgb1
// 31/10/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
// ---------------------------------------------------------------------------
vars
	idx: Integer;
begin
	if _actionType = null then			//ChangeRequest 46721
		self.cmbActionType.setIndex(1);	//ChangeRequest 46721
		return;							//ChangeRequest 46721
	endif;								//ChangeRequest 46721
	
	foreach idx in 1 to self.cmbActionType.listCount do
		if self.cmbActionType.itemText[idx] = _actionType then
			self.cmbActionType.setIndex(idx);
			return;						//ChangeRequest 46721
		endif;
	endforeach;
	
	self.cmbActionType.setIndex(0);		//ChangeRequest 46721

end;</source>
        <access>protected</access>
        <Parameter name="_actionType" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyEDIFileType" id="946b8c25-8bba-4464-8568-30cbf5feb7ee">
        <updating/>
        <source>setMyEDIFileType(_ediFileType : Integer) updating;
// ---------------------------------------------------------------------------
// Created:	23 September 2008 By Graeme Black cnwgb1
// Purpose:	Setup the kind of Action we are maintaining
// ---------------------------------------------------------------------------
vars
begin
	self.ediFileType := _ediFileType;
epilog
end;</source>
        <Parameter name="_ediFileType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setSegmentCombo" id="66bf3727-4c76-4e16-81b3-08c4debd44dc">
        <source>setSegmentCombo(_value : String);
// ---------------------------------------------------------------------------
// Created:	30 September 2008 By Graeme Black cnwgb1
// Purpose:	Select the correct key segment combo item
// 19/08/2009 	cnwsh3 		CCMS SFW1868 PAR20300 - CSI Inspection Stop revmoval via CUSRES
// ---------------------------------------------------------------------------
vars
	idx : Integer;
	itemDataValue : Integer;
begin
	// 19/08/2009	cnwsh3 CCMS SFW1868 PAR20300 - CSI Inspection Stop revmoval via CUSRES
	//self.cmbFileSegment.listIndex := app.getEDIKeyFileSegmentType(self.myEDIAction.keyFileSegment);
	
	//08 Sep 2016	NDL	TFS 2278 / 2670
	itemDataValue := app.getEDIKeyFileSegmentType(self.myEDIAction.keyFileSegment);
	foreach idx in 1 to self.cmbFileSegment.listCount do
		if self.cmbFileSegment.itemData[ idx ].Integer = itemDataValue then
			self.cmbFileSegment.listIndex := idx;
			break;
		endif;
	endforeach;

epilog
end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e97ec192-e517-4d86-b3ce-71458992d3bf">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:	10 September 2008 By Graeme Black cnwgb1
// Purpose:	CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
// 30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops
// 31/10/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
vars
	theCaption : String;
	
begin
	inheritMethod();
	self.txtCode.setFocus();
	self.initActionTypeCombo();
	self.height := 255;					// ### TFS 58831 (58833) 03July2023 NAVPW1
	self.lblRoleCode.visible := false;	// ### TFS 58831 (58833) 03July2023 NAVPW1
	self.cmbRoleCode.visible := false;	// ### TFS 58831 (58833) 03July2023 NAVPW1
//	self.initDataCombo();// Moved to loadForm	ChangeRequest 46721
	
	//PAR21435
	//self.txtDescription.maxLength := 60;
	self.txtDescription.scrollHorizontal := true;
	if self.ediFileType = EDIFileTypeX12_350_4010
	or self.ediFileType = EDIFileTypeCAMIR_CustomsStatus then		//cnwmc5 - 10 July 2014 - CCMS 2353 PEN
		//PAR21435 - cnwsh3. Allow the namne to be changed/saved by either the user or a csv load.
		self.txtName.visible := true;
		self.lblKeySegment.caption := app.getErrorString(Name);
		self.lblKeySegment.visible := true;
		self.cmbFileSegment.visible := false;
		
		self.txtName.tabIndex := self.txtCode.tabIndex + 1;
		
	elseif self.ediFileType = EDIFileType_CusRes or self.ediFileType = EDIFileType_XMLOneStopCust or self.ediFileType = EDIFileType_JMTInternal then // TFS 39133
		self.txtName.visible := false;
		self.initSegmentCombo();
	endif;
	
	if self.ediFileType = EDIFileType_JMTInternal then // TFS 39133
		self.cmbFileSegment.setIndex(1); // TFS 39133 - select the only choice in dropdown
		self.initRoleCodeCombo();	// ### TFS 58831 (58833) 03July2023 NAVPW1
	endif; // TFS 39133
	
	self.caption := app.getErrorString(CustomsActionsMaintain);
	self.loadForm();
	self.centreWindow();		// cnwdad1 10/08/2010 - PAR #23573.
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showAction" id="2105d6ef-902b-48d7-b839-4ff86039e255">
        <source>showAction( _selectedText : String);
// ---------------------------------------------------------------------------
// Created:	11 September 2008 By Graeme Black cnwgb1
// Purpose:	Display the correct fields for a particular action type
//			CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
// 30 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window - NZCS &amp; MPI stops
// 31/10/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing

vars
begin
	if self.ediFileType = EDIFileType_CusRes or self.ediFileType = EDIFileType_XMLOneStopCust or self.ediFileType = EDIFileType_JMTInternal then // TFS 39133
		if _selectedText &lt;&gt; EDIAction_None then
			lblActionData.caption := app.getErrorString(Data);
			cmbData.visible := true;
			self.initDataCombo(null);
			txtData.visible := false;
		else
			cmbData.visible := false;
			txtData.visible := false;
			lblActionData.caption := "";
		endif;
	elseif self.ediFileType = EDIFileTypeX12_350_4010
	or self.ediFileType = EDIFileTypeCAMIR_CustomsStatus then		//cnwmc5 - 10 July 2014 - CCMS 2353 PEN
		if _selectedText = EDIAction_PlaceHold or    // CCMS 1044 cnwgb1 7.9.09
		   _selectedText = EDIAction_RemoveHolds or 
		   _selectedText = EDIAction_PlaceContHold or 
 		   _selectedText =	EDIAction_RemoveContHold then // CCMS 1044 cnwgb1 7.9.09
			lblActionData.caption := app.getErrorString(HoldType);
			cmbData.visible := true;
			self.initDataCombo(_selectedText);
			txtData.visible := false;
		
		elseif _selectedText =	EDIAction_AddToDoTask or 
//			_selectedText =	EDIAction_CompleteToDoTask or //NOT USED
			_selectedText =	EDIAction_DeleteToDoTask then
			lblActionData.caption := app.getErrorString(Todo_task_type);
			self.initDataCombo(_selectedText);
			cmbData.visible := true;
			txtData.visible := false;
		
		
		elseif _selectedText = "Set Status Code" or _selectedText = "Set Status Text" then
			cmbData.visible := false;
			txtData.visible := true;
			if _selectedText = "Set Status Code" then
				lblActionData.caption := app.getErrorString(Code);
			else
				lblActionData.caption := app.getErrorString(Text_String);
			endif;
		else
			cmbData.visible := false;
			txtData.visible := false;
			lblActionData.caption := "";
		endif;
	endif;
epilog
end;</source>
        <Parameter name="_selectedText" type="String"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="da66d92f-1642-42f3-b562-e7c70f1e757f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 12 July 2023 08:43:36.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023838, locale);
	btnCancel.translateCaption(Xlat_0009764, locale);
	btnNext.translateCaption(Xlat_0009765, locale);
	btnSave.translateCaption(Xlat_0009766, locale);
	lblActionType.translateCaption(Xlat_0009767, locale);
	lblCode.translateCaption(Xlat_0009768, locale);
	lblDescription.translateCaption(Xlat_0009769, locale);
	lblKeySegment.translateCaption(Xlat_0009770, locale);
	lblRoleCode.translateCaption(Xlat_0026188, locale);
end;</source>
    </JadeMethod>
</GUIClass>
