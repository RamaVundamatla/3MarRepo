    <JadeMethod name="loadFormFromThinClientObj" id="efb223f5-2f75-45bd-9686-037697a2c961">
        <updating/>
        <source>loadFormFromThinClientObj(_obj:  MobileServerRTThin::DTO_EnquiryGradingTasks) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2008	concms1	Initial creation

*/

vars

begin 
	if _obj.containerID = txtContainer.text.trimRight then
		self.currentContainerId_forMove := _obj.containerID;

		lblLocation2.caption	:= _obj.currentLocationID;
		lblOperator2.caption 	:= _obj.operatorCode;
		lblISOType2.caption		:= _obj.isoType;			
		lblWeight2.caption		:= _obj.weight.String;
	else
		// found one but it does not match
		app.msgBox('Please enter a valid container ID','Errors occurred', MsgBox_Exclamation_Mark_Icon);
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="MobileServerRTThin::DTO_EnquiryGradingTasks"/>
    </JadeMethod>
    <JadeMethod name="loadReasonCombo" id="c61d3dc0-601c-40da-b7fa-e3a5874510cd">
        <source>loadReasonCombo() protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	app.myVehicleMountedRailGuiAgent.comboBoxPredefinedRemarks(self.cmbWrongReason);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTaskTable" id="1fa14eae-5ae3-4318-b20f-65238bc8557c">
        <updating/>
        <source>loadTaskTable() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theTable : Table;
	row : Integer;
begin
	theTable:=tblJobs;
	
	row:=theTable.fixedRows + 1;
	while row &lt;= theTable.rows do
		theTable.deleteRow(row);
	endwhile;
	
	app.myVehicleMountedRailGuiAgent.loadTable(theTable);

	//this just updates the colors
	self.updateTableElapsedTimes();	
	
	if theTable.rows &gt; theTable.fixedRows then
		if (not self.timerRefreshActive) then
			self.beginTimerForRefresh();
		endif;
	endif;
	

	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cdf6931b-f677-4cac-825a-a4f7bf6f240d">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date				Who		Reason
13 September 2006	cnwer1	Initial creation - PAR#xxxx
17 June 2008		concms1	PAR 17123 (CCMS 1671) DCT Gdansk - RDT Screen to relocate container

*/
vars
	errorStr : String;
begin
	inheritMethod();	
	if not app.isRunningOnCE then
		self.borderStyle := self.BorderStyle_Single;
		self.caption := 'Rail Dev mode (has control box)';
		self.height := self.height + 25;
	endif;	
	
	if not app.myVehicleMountedRailGuiAgent.myVehicleMountedAgent.canDoRTGContainerMove then	// PAR 17123
		shtMove.visible := false;																	// PAR 17123
	endif;																							// PAR 17123

	self.setupTable;
	self.setupTaskCaption;
	self.loadTaskTable();
	self.loadReasonCombo;
	self.clearMoveDetails;	// PAR 17123
	
	configElapsedTime:=app.myHandHeldGuiAgent.getTerminalConfig(HandHeldAgent.ConfigElapsedTimeExceeded).Integer;
	self.changeDefaultButtons(btnMsgOK,btnAccept);
	self.changeCancelButtons(btnMsgCancel,btnLogoff);
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupMsgFrameNew" id="9e55610f-62cc-43b8-ac01-e00c2f375bb1">
        <updating/>
        <source>setupMsgFrameNew(	_type : String;
					_containerId,
					_fromLoc, 
					_toLoc : String io;
					_ostow : Boolean;
					_canEditTo,
					_toIsVehicle:Boolean) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
constants
	Complete = "Complete";
	Overstow = "Overstow";
	MoveLabel = " move of ";
	From = " from ";
	To = " to ";
	Unknown = "...";
vars
	moveString : String;
begin
	//initalise 
	
	lblRow.caption:="Row";
	txtRow.visible:=_canEditTo;
	lblRow.visible:=_canEditTo;
	frmAccept.centreWindow();	
	
	fromLocationId:=_fromLoc;
	toLocationId:=_toLoc;
	if _ostow then	
		moveString:=Overstow;
	else
		moveString:=Complete;
	endif;
	
	if _canEditTo then
		txtRow.text:=toLocationId;
		if _toIsVehicle then
			lblRow.caption:="Vehicle";
		endif;
	endif;
	
	if not _ostow and self.mode = self.Mode_Rail then
		self.chkOnGround.visible:=true;
		self.chkOnGround.value := false;
	else
		self.chkOnGround.visible:=false;
	endif;
	
	self.clearErrors;
	currentContainerId :=_containerId;
	self.lblMsg.caption:=moveString &amp; MoveLabel &amp; _containerId &amp; From  &amp; _fromLoc &amp; To &amp; _toLoc;
	
	self.frmAccept.visible:=true;
	self.changeDefaultButtons(btnAccept,btnMsgOK);
	self.changeCancelButtons(btnLogoff,btnMsgCancel);
	self.txtRow.setFocus();
epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_containerId" type="String" usage="io"/>
        <Parameter name="_fromLoc" type="String" usage="io"/>
        <Parameter name="_toLoc" type="String" usage="io"/>
        <Parameter name="_ostow" type="Boolean"/>
        <Parameter name="_canEditTo" type="Boolean"/>
        <Parameter name="_toIsVehicle" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupTable" id="5578f2a3-087a-4eed-8afe-00572a2a6284">
        <updating/>
        <source>setupTable() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theTable : Table;
begin
	theTable := self.tblJobs;
	theTable.rows := 0;
	theTable.selectMode := Table.SelectMode_CurrentRow;
	theTable.alignment := Table.Alignment_Center_Top;

	if self.mode = Mode_Rail then
		colNoTime:=6;
		theTable.columns := 7;
		theTable.addItem(ColType &amp; Tab  &amp; ColJobNum &amp; Tab &amp; ColVehicle &amp; Tab &amp; ColId &amp; Tab &amp; ColWagonPos &amp; Tab &amp; ColTime &amp; Tab &amp; ColDoorDir);
		theTable.fixedRows := 1;
	else 
		colNoTime:=7;
		theTable.columns:=8;
		theTable.addItem(ColType &amp; Tab  &amp; ColJobNum &amp; Tab &amp; ColVehicle &amp; Tab &amp; ColId &amp; Tab &amp; ColSource &amp; Tab &amp; ColTarget &amp; Tab &amp; ColTime &amp; Tab &amp; ColDoorDir);
		theTable.fixedRows := 1;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTaskCaption" id="b4338fb5-fa84-4f00-9339-b88d0c540aa0">
        <source>setupTaskCaption();
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	shtJobs.caption:="Jobs - Lane " &amp; app.myVehicleMountedRailGuiAgent.getMyRTQueueLabel;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="44a7cfdd-2405-477b-a8e6-ee8beef7655e">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if eventTag = Timer_Refresh then
		self.timerRefreshActive := false;
		self.updateTableElapsedTimes();
		self.beginTimerForRefresh();
	endif;
	
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
