    <JadeMethod name="importFromXMLDocReference" id="ee1cc937-3143-4793-ae67-5b850f897596">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	childElement : JadeXMLElement;
begin

	if _property = CM_VesselTank::myVesselTankType then
		childElement:=_xmlElement.getElementByTagName(CM_VesselTankContentsType::code.name);	
		if childElement &lt;&gt; null then
			self.myVesselTankType:=app.myRoot.allVesselTankContentsTypes[childElement.textData];
		endif;
	else
		inheritMethod(_property, _xmlElement);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="55791ffe-072a-4ee3-8572-4d65345f6995">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
08 April 2011	cnwer1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	proxyVesselTank	: CM_VesselTank;
	completedOK		: Boolean;
begin
	proxyVesselTank := inheritMethod();
	proxyVesselTank.code := self.code;
	proxyVesselTank.description := self.description;
	proxyVesselTank.remarks := self.remarks;
	proxyVesselTank.volume := self.volume;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyVesselTank;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyVesselTank;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="55b2384f-5192-4db1-b698-172f5f186503">
        <updating/>
        <source>setForCreate(_proxyVesselTank: CM_VesselTank) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2011	cnwer1	Initial creation

*/

vars

begin
	_proxyVesselTank.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_proxyVesselTank);
epilog

end;</source>
        <Parameter name="_proxyVesselTank" type="CM_VesselTank"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b8401655-b23c-44a8-aafd-c7109d6711a4">
        <updating/>
        <source>setForUpdate(_proxyVesselTank : CM_VesselTank) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2011	cnwer1	Initial creation

*/

vars

begin
	
	self.code := _proxyVesselTank.code;
	self.description := _proxyVesselTank.description;
	self.remarks := _proxyVesselTank.remarks;
	self.volume := _proxyVesselTank.volume;
	self.myVesselTankType := _proxyVesselTank.myVesselTankType;

epilog

end;</source>
        <Parameter name="_proxyVesselTank" type="CM_VesselTank"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="c36a2394-695a-438a-a19d-7166396537c3">
        <updating/>
        <source>setProxy(	_code : String;
			_description : String;
			_remarks : String;
			_volume : Decimal;
			_myVesselTankType : CM_VesselTankContentsType) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2011	cnwer1	Initial creation

*/

vars

begin
	self.code:=_code;
	self.description:=_description;
	self.remarks:=_remarks;
	self.volume:=_volume;
	self.myVesselTankType:=_myVesselTankType;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_myVesselTankType" type="CM_VesselTankContentsType"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="bff963c2-4dff-4793-a358-1f11c6a47547">
