    <JadeMethod name="copyToRealWSObject" id="f9022f3a-3566-468b-bf78-9ed0b3916c7e">
        <source>copyToRealWSObject(_realRequest: IPN1_SendRealisasiTambat input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
	_realRequest.biaya := self.biaya;
	_realRequest.dermaga := self.dermaga;
	_realRequest.gtKapal := self.gtKapal;
	_realRequest.jamMulaiTambat := self.jamMulaiTambat;
	_realRequest.jamSelesaiTambat := self.jamSelesaiTambat;
	_realRequest.kadeAkhir := self.kadeAkhir;
	_realRequest.kadeAwal := self.kadeAwal;
	_realRequest.nomorPkk := self.nomorPkk;
	_realRequest.nomorPpk := self.nomorPpk;
	_realRequest.nomorPpkbTambat := self.nomorPpkbTambat;
	_realRequest.prosentase := self.prosentase;
	_realRequest.tanggalMulaiTambat := self.tanggalMulaiTambat;
	_realRequest.tanggalSelesaiTambat := self.tanggalSelesaiTambat;
	_realRequest.tarifTVariabel := self.tarifTVariabel;
	_realRequest.tarifTetap := self.tarifTetap;

epilog

end;</source>
