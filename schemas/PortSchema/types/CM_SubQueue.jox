    <JadeMethod name="setProxy" id="7a32c03f-8071-48e0-b5de-32be8ada119c">
        <updating/>
        <source>setProxy(	_theID 								: String;
			_parent								: CM_RadioTelemetryQueue;
			_isUni								: Boolean;
			_fromLCs, _toLCs 					: CM_LCArray;
			_fromTAs, _toTAs 					: CM_TAMasterByIdDict input; 
			_lookForFromAreaMove,
			_lookForToAreaMove					: Boolean;
			_allAllowedMachineTypeGroups		: IntegerArray input;
			_terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.id := _theID;
	self.myParentQueue:=_parent;
	self.isUnidirectional := _isUni;
	
	if _allAllowedMachineTypeGroups &lt;&gt; null then
		self.allAllowedMachineTypeGroups.clear();
		_allAllowedMachineTypeGroups.copy(self.allAllowedMachineTypeGroups);
	endif;
	
	self.lookForFromAreaMove	:= _lookForFromAreaMove;
	self.lookForToAreaMove		:= _lookForToAreaMove;
	
	self.moveFromLocnControllers.clear();
	if _fromLCs &lt;&gt; null then
		_fromLCs.copy(self.moveFromLocnControllers);
	endif;
	self.moveToLocnControllers.clear();
	if _toLCs &lt;&gt; null then
		_toLCs.copy(self.moveToLocnControllers);
	endif;
	
	self.allMoveFromTAMasters.clear();
	self.allMoveToTAMasters.clear();
	_toTAs.copy(self.allMoveToTAMasters);
	_fromTAs.copy(self.allMoveFromTAMasters);
	
	self.myTerminal := _terminal;
end;</source>
        <Parameter name="_theID" type="String"/>
        <Parameter name="_parent" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_isUni" type="Boolean"/>
        <Parameter name="_fromLCs" type="CM_LCArray"/>
        <Parameter name="_toLCs" type="CM_LCArray"/>
        <Parameter name="_fromTAs" type="CM_TAMasterByIdDict" usage="input"/>
        <Parameter name="_toTAs" type="CM_TAMasterByIdDict" usage="input"/>
        <Parameter name="_lookForFromAreaMove" type="Boolean"/>
        <Parameter name="_lookForToAreaMove" type="Boolean"/>
        <Parameter name="_allAllowedMachineTypeGroups" type="IntegerArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setProxyRTG" id="e9407ae6-a532-4537-8db3-0fc55b3c9108">
        <updating/>
        <source>setProxyRTG(_theID 								: String;
			_parentQueue : CM_RadioTelemetryQueue;
			_queueType : Integer;
			
			_fromTAs	: CM_TAMasterByIdDict input; 
			_terminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwer1	Initial creation

*/

vars

begin
	self.id:=_theID;
	self.myParentQueue:=_parentQueue;
	self.isUnidirectional :=false;
	self.queueType:=_queueType;
	self.moveFromLocnControllers.clear;
	self.moveToLocnControllers.clear();
	self.allMoveFromTAMasters.clear();
	self.allMoveToTAMasters.clear();
	_fromTAs.copy(self.allMoveFromTAMasters);
	
	self.allAllowedMachineTypeGroups.add(MACHINETYPEGRP_RTG);
	self.myTerminal := _terminal;
	
epilog

end;</source>
        <Parameter name="_theID" type="String"/>
        <Parameter name="_parentQueue" type="CM_RadioTelemetryQueue"/>
        <Parameter name="_queueType" type="Integer"/>
        <Parameter name="_fromTAs" type="CM_TAMasterByIdDict" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
