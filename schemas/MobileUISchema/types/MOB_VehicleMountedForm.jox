    <JadeMethod name="tblDirector_click" id="699dcfe6-bc32-4388-b44c-91060824d215">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDirector_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	cnwer1	Initial creation

*/

vars
	cargo 		: CM_TrackedItem;
	containerID : String;
	allSelectedRows : StringArray;
	dtoEntry,
	dtoTwinEntry: DTO_RTQueueEntry;
	dtoEntryArray 	: DTO_RTQueueEntryArray;
	singleDirector 	: Boolean;
	firstRTQTask,
	twinTask: CM_RTQueueTask;
	cargoSourceLoc : String;
begin
	self.addInfoDisplay(null);
	
	
	create dtoEntryArray transient;
	app.myVMAgent.findWorkingDTORTEntries(dtoEntryArray,self.tblTasks);
	
	if not dtoEntryArray.isEmpty then
		if dtoEntryArray.size &gt; 0 then
			dtoEntry:=dtoEntryArray[1];
		endif;
		if dtoEntryArray.size &gt; 1 then
			dtoTwinEntry:=dtoEntryArray[2];
		endif;
		
		if dtoEntryArray &lt;&gt; null and dtoEntry &lt;&gt; null then
			//we should have both..
			firstRTQTask:=dtoEntry.myRealQueueEntry.CM_RTQueueEntry.findTaskOfType(TASK_DIRECTOR,NULL_INTEGER);
			
			if dtoTwinEntry &lt;&gt; null then
				twinTask:=dtoTwinEntry.myRealQueueEntry.CM_RTQueueEntry.findTaskOfType(TASK_DIRECTOR,NULL_INTEGER);
			endif;
			
			if firstRTQTask = null or twinTask = null then
				singleDirector := true;
			else
				singleDirector := false;
			endif;
			
		else
			//else we are servicing one director task
			singleDirector := true;
		endif;
	endif;
		
	
	if self.btnRejectTwin.visible then
		//tandem picking so lets clear out one if we are unselecting
		allSelectedRows:=table.tag.getTokens();
			
		if allSelectedRows.includes(table.row.String) then	//this code should clear out the cargo ID if we are unselecting		
			cargo:=table.accessRow(table.row).itemObject.CM_TrackedItem;
			if cargo = null then
				return;
			endif;
			containerID:=cargo.id;
			if containerID &lt;&gt; null then
				//epr TFS 6863 14/9/17 so breakbulk works correctly
				if cargo.getOidString() =  self.getCargoID() then
					self.myMoveTableDetails.addCargoForEntRowName(ETRow_CargoID,null);
				else
					//epr par 34682 5/8/14
					if app.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen then		
						if cargo.getOidString()  =  self.getTandemCargoID then
							self.myMoveTableDetails.setDataColumn(5);
							self.myMoveTableDetails.addCargoForEntRowName(ETRow_CargoID,null);
						endif;
						self.myMoveTableDetails.setDataColumn(DataColumn);
					else
						if self.myMachine.isTandemLift and not singleDirector then
							if cargo.getOidString() =  self.getTandemCargoID  then
							self.myMoveTableDetails.addCargoForEntRowName(ETRow_TandemID,null);
							endif;
						else
							if cargo.getOidString() =  self.getTandemCargoID  then
							self.myMoveTableDetails.addCargoForEntRowName(ETRow_TwinID,null);
							endif;					
						endif;
					endif;
				endif;
			endif;
		endif;
	
		// now we select/deselect the row.
		self.displayVMTableRow(table,table.row,true);
		
		allSelectedRows:=table.tag.getTokens();
		
		if allSelectedRows.includes(table.row.String) then	// OK we have just selected this row.
		
			cargo:=table.accessRow(table.row).itemObject.CM_TrackedItem;
			if cargo = null then
				return;
			endif;
			containerID:=cargo.id;
			if containerID &lt;&gt; null then
				//epr par 34682 5/8/14
				if  self.getCargoID() = null then
					self.myMoveTableDetails.addCargoForEntRowName(ETRow_CargoID,cargo);
				else //self.myMoveTableDetails.getDataForEntRowName(ETRow_TandemID) = null then
					if app.myVMAgent.getMyRTVehicleConfig.canRemoveSplitScreen then
						self.myMoveTableDetails.setDataColumn(5);			
						self.myMoveTableDetails.addCargoForEntRowName(ETRow_CargoID,cargo);					
						self.myMoveTableDetails.setDataColumn(DataColumn);
					else
					
						if self.myMachine.isTandemLift and not singleDirector then
										
							self.myMoveTableDetails.addCargoForEntRowName(ETRow_TandemID,cargo);
						else
							self.myMoveTableDetails.addCargoForEntRowName(ETRow_TwinID,cargo);
						endif;
					endif;
				endif;
			endif;			
		endif;
			
	else
		self.displayVMTableRow(table,table.row,false);
		if table.row &gt; table.fixedRows then	
			cargo:=table.accessRow(table.row).itemObject.CM_TrackedItem;
			if cargo = null then
				return;
			endif;
			containerID:=cargo.id;
			if containerID &lt;&gt; null then
				self.myMoveTableDetails.addCargoForEntRowName(ETRow_CargoID,cargo);		
			endif;
			//04 Aug 2014	NDL	Par 34675
			if cargo.myPrimaryActualLocation &lt;&gt; null then
				cargoSourceLoc := cargo.myPrimaryActualLocation.getFullId;
				self.myMoveTableDetails.addDataForEntRowName(ETRow_SourceID,cargoSourceLoc);
			endif;
		endif;
	endif;
	
	

epilog
	delete dtoEntryArray;
	self.myMoveTableDetails.setDataColumn(DataColumn);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDirector_keyUp" id="a1e8373a-b346-4ab4-8a19-2d191564dc24">
