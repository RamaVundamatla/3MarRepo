    <JadeMethod name="getProtocols" id="d5269455-4fc5-46b5-977d-f4e0941e04f9">
        <source>getProtocols();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry

*/

vars
	rowIndex		: Integer;
