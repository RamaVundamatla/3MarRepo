<Class name="CM_TimeSlot" id="cc7388ca-a95b-4cf5-9619-09f130173163">
    <superclass name="CM_TimeSlotEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <PrimAttribute name="date" id="12917424-4ee2-4210-9acf-1f4fc60f28ad">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <ExplicitInverseRef name="myTerminal" id="4b6253fe-6ba0-41b5-b4d3-1ce23c7b5410">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <Inverse name="CM_Terminal::allTimeSlotByDate"/>
    </ExplicitInverseRef>
    <JadeMethod name="getMyTerminal" id="ba0e352b-0164-4c5b-84c8-344efb3227ee">
        <source>getMyTerminal(): CM_Terminal;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.myTerminal;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a1adc1ec-f470-4c22-a7e9-cb8c818b69a7">
        <updating/>
        <source>setForCreate(pProxyTimeSlot : CM_TimeSlot) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------

vars

begin
	pProxyTimeSlot.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.startTime 		:= pProxyTimeSlot.startTime;
	self.numOfSlot 		:= pProxyTimeSlot.numOfSlot;
	self.date 			:= pProxyTimeSlot.date;
	self.myTerminal		:= pProxyTimeSlot.myTerminal;
	self.causeEvent(self.myTerminal.getTerminalEvent(Event_TimeSlot_Add), false, null);
epilog

end;</source>
        <Parameter name="pProxyTimeSlot" type="CM_TimeSlot"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1178173e-0b0a-4922-9d87-605fb3d62549">
        <updating/>
        <source>setForUpdate(pProxyTimeSlot : CM_TimeSlot) updating;
// ---------------------------------------------------------------------------
// Created:     04 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
vars

begin
	pProxyTimeSlot.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	self.date 			:= pProxyTimeSlot.date;
	self.startTime 		:= pProxyTimeSlot.startTime;
	self.numOfSlot		:= pProxyTimeSlot.numOfSlot;
	self.myTerminal		:= pProxyTimeSlot.myTerminal;
	
	self.causeEvent(self.myTerminal.getTerminalEvent(Event_TimeSlot_Update), false, null);	


end;
</source>
        <Parameter name="pProxyTimeSlot" type="CM_TimeSlot"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="c242ab01-7394-4d8f-852e-2040f5d18d57">
        <updating/>
        <source>setProxy(pDate: Date; pStartTime: Time; pNumOfSlot: Integer; pTerminal: CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.date := pDate;
	self.startTime := pStartTime;
	self.numOfSlot := pNumOfSlot;
	self.myTerminal := pTerminal;
epilog

end;</source>
        <Parameter name="pDate" type="Date"/>
        <Parameter name="pStartTime" type="Time"/>
        <Parameter name="pNumOfSlot" type="Integer"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
    </JadeMethod>
