        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryWOTransactions" id="a1ed7513-62b6-432b-b32e-348a14d933ec">
        <updating/>
        <source>qryWOTransactions(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023 navhl20 Defect 57144: Send to Report showing Error

*/

vars

	numSelected	: Integer;
	jrwTrans 	: CM_JRWWOTransaction;
	woFilter 	: CMQF_WOTransactions;

begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);

	woFilter := _filter.CMQF_WOTransactions;
	jrwTrans := self.createJRWTransient(CM_JRWWOTransaction).CM_JRWWOTransaction;
	
	jrwTrans.allWOTransactions.purge();
	woFilter.filterObjects(jrwTrans.allWOTransactions, _passport);
	
	woFilter.allTerminals.copy(jrwTrans.allTerminals);
	
	woFilter.allTransTypes.copy(jrwTrans.allTransTypes);
	jrwTrans.fromDT.setDate(woFilter.startDate);
	jrwTrans.fromDT.setTime(woFilter.startTime);
	jrwTrans.toDT.setDate(woFilter.endDate);
	jrwTrans.toDT.setTime(woFilter.endTime);
	jrwTrans.needFilterUsers	:= woFilter.needFilterUsers;
	
	numSelected := jrwTrans.allWOTransactions.size;
	
epilog

	return numSelected;

end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryWorkOrder" id="3972fa09-3bc2-4c22-a267-59799c1b41a6">
        <updating/>
        <source>qryWorkOrder(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/

vars
	numSelected	: Integer;
	jrwTrans 	: CM_JRWWorkOrder;
	woFilter 	: CMQF_WorkOrder;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);

	woFilter := _filter.CMQF_WorkOrder;
	jrwTrans := self.createJRWTransient(CM_JRWWorkOrder).CM_JRWWorkOrder;
	
	jrwTrans.allWorkOrders.purge();
	woFilter.filterObjects(jrwTrans.allWorkOrders, _passport);
	
	woFilter.allTerminals.copy(jrwTrans.allTerminals);
	
	woFilter.allWOStatus.copy(jrwTrans.allWOStatus);
	woFilter.allWODetailTypes.copy(jrwTrans.allWOTypes);
	jrwTrans.fromReqDT := woFilter.fromReqDT.Date;
	jrwTrans.toReqDT := woFilter.toReqDT.Date;
	jrwTrans.needFilterUsers	:= woFilter.needFilterUsers;
	
	numSelected := jrwTrans.allWorkOrders.size;
	
epilog

	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryYardAudit" id="f5bfbd56-1858-4964-a581-5a11819ba902">
        <updating/>
        <source>qryYardAudit(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		22 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	numSelected 		: Integer;
	jrwTrans			: CM_JRWTrackedItems;
	tiFilter			: CMQF_YardAudit;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tiFilter := _filter.CMQF_YardAudit;
	jrwTrans := self.createJRWTransient(CM_JRWTrackedItems).CM_JRWTrackedItems;
	jrwTrans.allTrackedItems.clear();
	_filter.filterObjects(jrwTrans.allTrackedItems, _passport);
//	tiFilter.allTerminals.copy(jrwTrans.allTerminals);
	jrwTrans.setAllTerminals(tiFilter.allTerminals);
	jrwTrans.myOperator := tiFilter.myOperator;
	jrwTrans.qryStartDate := tiFilter.startDate;
	jrwTrans.qryEndDate := tiFilter.endDate;
	jrwTrans.myTerminalArea := tiFilter.getMyTerminalArea;
	jrwTrans.myVoyage := tiFilter.getMyVoyage;
	jrwTrans.myPort := tiFilter.getMyPort;
	if tiFilter.getMyCargoType &lt;&gt; null then
		jrwTrans.qryCargoType := tiFilter.getMyCargoType.description;
	else
		jrwTrans.qryCargoType := ("All Cargo Types");
	endif;
	numSelected := jrwTrans.allTrackedItems.size; 

epilog
	
	return numSelected;

end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xHandlerBreakOut" id="0474ea9c-0031-4883-b409-0c6d9e509926">
        <source>xHandlerBreakOut(_exception : CM_BreakOutException): Integer;
// -------------------------------------------
// Created 22 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	return Ex_Resume_Next;
end;</source>
        <Parameter name="_exception" type="CM_BreakOutException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
