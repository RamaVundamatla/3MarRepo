    <JadeMethod name="getYACriteria" id="179d7c80-4162-49c0-bab8-b27916d56f0d">
        <updating/>
        <source>getYACriteria() updating;

vars
	itemCode	: String;
	nullValue	: String;
	criteriaType: CM_YACriteriaType;
	criteria, proxyCriteria: CM_YACriteria;
	obj			: Object;
	oa			: ObjectArray;

begin
	self.allOperationalCriteria.purge();
	self.allTemplateCriteria.purge();
	create oa transient;
	
	if self.myYardAllocation = null then
		self.mySnapShotBroker.getYACriteriaTypes(self.mySnapShotBroker.allYACriteriaTypes, oa);
		foreach obj in oa do
			criteriaType := obj.CM_YACriteriaType;
			create proxyCriteria transient;
			itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length - 1);
			nullValue := "";
			if criteriaType.isBooleanType() then
				nullValue := CM_YADataBoolean.VALUE_FALSE.String;
			endif;
			proxyCriteria.setProxy(criteriaType, nullValue, itemCode);

			self.allOperationalCriteria.add( proxyCriteria.getTransient() );
		endforeach;
	endif;
			
	if self.myYardAllocation &lt;&gt; null then
		foreach criteria in self.myYardAllocation.allCriteria do
			create proxyCriteria transient;
			proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
			self.allOperationalCriteria.add( proxyCriteria.getTransient() );
		endforeach; 
	endif;

	self.populateCriteriaFrames(true);
	if self.isNew then
		self.clearCriteriaValues();
	else
		self.setDefaultCriteriaValues();
	endif;
	
epilog
	delete oa;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateCombos" id="65a72f23-f996-4fdc-8ebd-ada3950da10e">
        <updating/>
        <source>populateCombos() updating;

vars
	indx	: Integer;
	invLineDesc : CM_InvoiceLineDesc;
	field		: CM_XTABField;
	bank		: CM_Bank;
begin
	self.cmbInvoiceLine.clear;
	self.cmbInvoiceLine.sorted := true;
	
	// 35872 use the tran map bank
	bank := self.mySnapShotBroker.myTransactionMap.myBank;
	foreach invLineDesc in bank.invoiceLineDescriptors where not invLineDesc.isNotAvailableForEntry do
		indx := self.cmbInvoiceLine.addItemObject(invLineDesc.narration, invLineDesc);
	endforeach;	
	
	self.cmbQtyAttribute.clear;
	self.cmbQtyAttribute.sorted := true;
	
	foreach field in self.mySnapShotBroker.mySnapShotDefinition.allFields do
		indx := self.cmbQtyAttribute.addItemObject(field.heading, field);
	endforeach;	
end;
</source>
    </JadeMethod>
    <JadeMethod name="populateForm" id="e63faba4-f01c-4233-8539-454230e2f32a">
        <updating/>
        <source>populateForm() updating;

vars
	criteria : CM_YACriteria;

begin
	on Exception do self.handleBadCriteriaValue(exception);
	
	defaultYACodeChanged	:= false;
	self.populateOptions();
	
	if self.myYardAllocation &lt;&gt; null then
		self.populateCriteriaFrames(true);
	endif;

	if self.myProxyYA = null then
		return;
	endif;
	
	self.displayCriteriaDesc();
	
	self.txtYACode.text		:= self.myProxyYA.code;
	self.txtYADescription.text		:= self.myProxyYA.description;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateMappingDetails" id="4d9c83be-666b-4ee3-927f-28dcd0ed3506">
        <updating/>
        <source>populateMappingDetails() updating;
// show the current mapping details, and if editing, only leave the invoice line combo enabled for change
vars

begin
	self.cmbInvoiceLine.listIndex := self.cmbInvoiceLine.findObject(self.myInvoiceLineDesc);

	if self.myQuantityRangeMap &lt;&gt; null then
		self.cmbQtyAttribute.listIndex := self.cmbQtyAttribute.findObject(self.myQuantityRangeMap.myQuantityMap.mySnapShotQuantityType);
		self.txtQtyStart.text := self.myQuantityRangeMap.rangeStart.Integer.String;
		self.txtQtyEnd.text := self.myQuantityRangeMap.rangeEnd.Integer.String;
		self.chkMax.value := false;
		self.chkQtyZero.value := self.myQuantityRangeMap.myQuantityMap.chargeZero;
		self.optMapTypeSingle.value := (self.myQuantityRangeMap.myQuantityMap.mappingType = CM_QuantityMap.MapType_Single);
		self.optMapTypeEscalt.value := (self.myQuantityRangeMap.myQuantityMap.mappingType = CM_QuantityMap.MapType_Escalate);

		self.cmbQtyAttribute.enabled := self.isNew;
		self.txtQtyStart.enabled := self.isNew;
		self.txtQtyEnd.enabled := self.isNew;
		self.chkMax.enabled := self.isNew;
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="populateTable" id="18cc0e02-ef23-4cce-bf74-3823d6c4451e">
        <updating/>
        <source>populateTable(_fromNew : Boolean) updating;

vars
	fullTable	: Boolean;
	attr,
	savedRow,
	row,
	col		: Integer;
	allGroupProps : CM_QueryPropertyArray;
	queryProp	: CM_QueryProperty;
	ya			: CM_YardAllocation;
	invAlloc	: CM_InvoiceAllocation;
	yac			: CM_YACriteria;
	obj			: Object;
	selected,
 	selectedSorted	: ObjectArray;
	sa			: CnStringArray;		// membership size 260
begin
	create allGroupProps transient;
	self.mySnapShotBroker.mySnapShotDefinition.getGroupingProperties( allGroupProps );
	create selected transient;
	foreach queryProp in allGroupProps where queryProp.allocationAttribute &lt;&gt; 0 do
		if self.mySnapShotBroker.allYACriteriaTypes.includes(queryProp.allocationAttribute) then
			selected.add(queryProp);
		endif;
	endforeach;
	create selectedSorted transient;
	foreach attr in self.mySnapShotBroker.allYACriteriaTypes do
		foreach obj in selected do
			queryProp := obj.CM_QueryProperty;
			if queryProp.allocationAttribute = attr then
				selectedSorted.add(obj);
				break;
			endif;
		endforeach;
	endforeach;

	create sa transient;
	row := 1;
	col := 1;
	self.tblData.columns := selectedSorted.size + 2;		// properties plus range and invoice line
	self.tblData.rows := self.mySnapShotBroker.getChildrenSize() + 1;	// each item plus fixed header
	self.tblData.selectMode := CM_EntryTable.SelectMode_CurrentRow;
	foreach obj in selectedSorted do
		queryProp := obj.CM_QueryProperty;
		self.tblData.row := row;
		self.tblData.column := col;
		self.tblData.text := queryProp.niceName;
		col := col + 1;
	endforeach;
	self.tblData.column := col;
	self.tblData.text := app.getErrorString(Range);
	col := col + 1;
	self.tblData.column := col;
	self.tblData.text := app.getErrorString(Invoice_line);
	
	row := row + 1;
	// for new, show all existing invoice allocations but for edit, only show those with the same first criterion value as the current selection
	// but not once items have been removed - in this case show everything as the reference point can be lost.
	if self.hasRemoved then
		fullTable := true;
	elseif self.isNew then
		fullTable := true;
	else
		yac := self.myQuantityRangeMap.myQuantityMap.myInvoiceAllocation.allCriteria.first;
	endif;
	foreach ya in self.mySnapShotBroker.allInvoiceAllocations do
		invAlloc := ya.CM_InvoiceAllocation;
		if fullTable then
			self.populateTableAllocation(invAlloc, row, savedRow);
		elseif invAlloc.allCriteria.first.myYAData.isSameCriteria(yac.myYAData) then
			self.populateTableAllocation(invAlloc, row, savedRow);
		endif;
	endforeach;
	self.tblData.rows := row - 1;
	if not fullTable and savedRow &lt;&gt; 0 then
		self.tblData.row := savedRow;		// current inv alloc
	endif;
	if _fromNew then
		self.tblData.row := 1;	// don't leave the last entry highlighted
		self.btnRemove.enabled := false;
	else
		if self.hasRemoved then
			self.myYardAllocation := invAlloc;
		endif;
		self.setupFromCurrentItem();	// show the details from the current item
	endif;
	
epilog
	delete allGroupProps;
	delete selected;
	delete selectedSorted;
	delete sa;
end;

</source>
        <Parameter name="_fromNew" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateTableAllocation" id="5793a923-2720-462a-9dc6-e59274ddecf8">
        <source>populateTableAllocation(_ia : CM_InvoiceAllocation; _row : Integer io; _savedRow : Integer io) protected;

vars
	col		: Integer;
	str,
	range	: String;
	ild			: CM_InvoiceLineDesc;
	qm			: CM_QuantityMap;
	qrm			: CM_QuantityRangeMap;
	yac			: CM_YACriteria;
	invAlloc	: CM_InvoiceAllocation;
	sa			: CnStringArray;		// membership size 260
	mapping : CM_TranMapInvoiceLineMapping;
begin
	invAlloc := _ia;
	col := 1;
	create sa transient;
	foreach yac in invAlloc.allCriteria do
		sa.add(yac.getRawDescription);
	endforeach;
	qm := invAlloc.myQuantityMap;
	foreach qrm in qm.allQuantityRanges do
		range := qrm.rangeStart.Integer.String &amp; " - " &amp; qrm.rangeEnd.Integer.String;
		self.tblData.row := _row; 
		
		// TFS 40620 foreach ild in qrm.allInvoiceLinesUsed do
		foreach mapping in qrm.allTMInvoiceLineMappings do // TFS 40620
			ild := mapping.myTMInvoiceLineDesc; // TFS 40620
		
		
			col := 1;
			foreach str in sa do
				self.tblData.column := col;
				self.tblData.text := str;
				col := col + 1;
			endforeach;
			self.tblData.column := col;
			self.tblData.text := range;
			col := col + 1;
			self.tblData.column := col;
			self.tblData.text := ild.narration;
			self.tblData.accessRow(_row).itemObject := qrm;
			col := col + 1;
			if qrm = self.myQuantityRangeMap and
			   ild = self.myInvoiceLineDesc then
				_savedRow := _row;
			endif;
			_row := _row + 1;
		endforeach;
	endforeach;
	
epilog
	delete sa;
end;

</source>
        <access>protected</access>
        <Parameter name="_ia" type="CM_InvoiceAllocation"/>
        <Parameter name="_row" type="Integer" usage="io"/>
        <Parameter name="_savedRow" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="resizeForInvoice" id="9559c454-d7d8-47fb-95e0-542ad83093f5">
        <updating/>
        <source>resizeForInvoice() updating;
// 
vars

	criteriaFrame: CMUI_YACriteriaCntl;
	index	: Integer;
	topOfLastControl : Real;
	
begin

 // TFS 3509	self.fldYardAlloc.height := 90;	//08 Oct 2013	NDL	Par 32456
	
	self.frmMappings.top := self.fldYardAlloc.top + self.fldYardAlloc.height + 30;
	
 // TFS 3509	self.height := self.frmMappings.top + self.frmMappings.height + 70;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="saveData" id="3d08470b-4222-4adc-b180-c56839a0e138">
        <updating/>
        <source>saveData(_saveAs: Boolean) : Boolean updating;

/*

Purpose:		Standard method to perform a "Save" operation.

Parameters:		Not used here.	

Return Value:	True if the save ws successful, otherwise false.


Date			Who		Reason
05 August 2008	consw1	Initial creation

*/
vars
	terminalObj				: CM_Terminal;
	yardAllocationObj		: CM_InvoiceAllocation;
	proxyYAObj				: CM_InvoiceAllocation;
	proxyQM					: CM_QuantityMap;
	quantityRangeMap,
	proxyQRM				: CM_QuantityRangeMap;
	invLineDesc				: CM_InvoiceLineDesc;
	field					: CM_XTABField;
	fillOptionIn			: Integer;
	fillOptionOut			: Integer;
	yaCode					: String;
	yaDescription			: String;
	yaRemarks				: String;
	expiryType				: Integer;
	expiryDate				: Date;
	allowOthers				: Integer;
	noLocation				: Integer;
	priorityAdj				: Integer;
	isTestOverstowWeight	: Boolean;
	isDisabled				: Boolean;
	allTransientCriteriaObj	: CMIF_Array;
	yaColor					: Integer;
	overstowRule			: CM_YAOverstowRule;
	blockGroupsInColl		: CM_YABlockGroupArray;
	blockGroupsOutColl		: CM_YABlockGroupArray;
	result					: Integer;
	mode					: Integer;
	displayHatched			: Boolean;
	startRange,
	endRange				: Integer;
	mapType					: Integer;
	pxyMapping : CM_TranMapInvoiceLineMapping;
	bank : CM_Bank;
	mapTypeObj :CM_TranMapInvoiceLineGroupType;
begin
	if not self.validateInput then
		return false;
	endif;

	self.formatName(true);		// set up txtYACode.text from the criteria for use below

	create proxyYAObj transient;
	create proxyQM transient;
	create proxyQRM transient;
	create proxyQRM.allRegisteredMethods transient;

	while true do
	
		yardAllocationObj	:=	self.myYardAllocation.CM_InvoiceAllocation;
		
		// if this has been created during warning/error loop then purge and recreate below
		if allTransientCriteriaObj &lt;&gt; null then
			allTransientCriteriaObj.purge;
		else
			create allTransientCriteriaObj transient;
		endif;
		self.getCriteriaAllCMIF( allTransientCriteriaObj );
	
		field := self.cmbQtyAttribute.itemObject[self.cmbQtyAttribute.listIndex].CM_XTABField;
		// drop the 'N ' prefix from the un-used imex status
		if self.txtYACode.text.length &gt; 3 then
			yaCode := self.txtYACode.text[3:end];
		endif;
		yaCode := yaCode &amp; " " &amp; field.propertyName;
		yaDescription := yaCode;
	
		// Note: the null terminal parameter is deliberate, to keep these out of CM_Terminal.allYardAllocatonsByCode as the 'code' value
		//	may not be unique here
		proxyYAObj.setProxy(yaCode,
							yaDescription,
							yaRemarks,
							fillOptionIn,
							fillOptionOut,
							expiryType,
							expiryDate,
							yaColor,
							displayHatched,
							allowOthers,
							noLocation,
							overstowRule,
							priorityAdj,
							isTestOverstowWeight,
							isDisabled,
							blockGroupsInColl,
							blockGroupsOutColl,
							false,
							terminalObj);
		
		proxyYAObj.setQuantityMap(proxyQM);
		proxyYAObj.setServiceBroker(self.mySnapShotBroker);
		proxyQM.setAllocationDetails(proxyYAObj, field);
		proxyQM.setChargeZero(self.chkQtyZero.value);
		if self.optMapTypeSingle.value then
			mapType := CM_QuantityMap.MapType_Single;
		else
			mapType := CM_QuantityMap.MapType_Escalate;
		endif;	
		proxyQM.setMappingType(mapType);

		startRange := self.txtQtyStart.text.Integer;
		endRange := self.txtQtyEnd.text.Integer;
		if self.chkMax.value then
			endRange := CM_QuantityRangeMap.MAX_RANGE.Integer;
		endif;
		proxyQRM.setProxy(proxyQM, startRange, endRange,RANGETYPE_DEFAULT);
		invLineDesc := self.cmbInvoiceLine.itemObject[self.cmbInvoiceLine.listIndex].CM_InvoiceLineDesc;
		// update so the form refreshes with the new value
		self.myInvoiceLineDesc := invLineDesc;
// TFS 40620		proxyQRM.allInvoiceLineMaps.add(invLineDesc);
// TFS 40620		proxyQRM.allInvoiceLinesUsed.add(invLineDesc);
		create pxyMapping transient; // TFS 40620
		bank := invLineDesc.bank; // TFS 40620
		if bank &lt;&gt; null then // TFS 40620
			mapTypeObj := bank.getInvLineGroupAll(); // TFS 40620
		endif;
		pxyMapping.update(CM_QuantityRangeMap.DEFAULT_INVOICELINE_KEY, invLineDesc, proxyQRM, mapTypeObj, null, null, null, null, null); // TFS 40620

		app.myTrxUA.trxUpdateInvoiceAllocation(proxyYAObj, allTransientCriteriaObj, self.isNew, yardAllocationObj,  app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.myYardAllocation := yardAllocationObj;
			return true;
		else
			if app.myPassport.hasErrors then
				mode := ErrWarnMode_Update;  //do allow save if there are errors
			else
				mode := ErrWarnMode_Update+ErrWarnMode_CanAckWarnSkipErr;  //need a Save if only warnings
			endif;
			
			result := app.showErrorWarningDialog("Invoice Allocation", app.myPassport, mode);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged := true;
				continue;
			else
				return false;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
	endwhile;
	
	return true;
	
epilog
	if allTransientCriteriaObj &lt;&gt; null then
		allTransientCriteriaObj.purge;
	endif;
	delete allTransientCriteriaObj;
	delete proxyYAObj;
	if proxyQRM &lt;&gt; null then
		delete proxyQRM.allRegisteredMethods;
	endif;
	delete proxyQRM;
	delete proxyQM;
end;</source>
        <Parameter name="_saveAs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultCriteriaValues" id="7d2956d0-914c-44e2-9ce1-87499aa0de77">
        <updating/>
        <source>setDefaultCriteriaValues() updating;
// on a change, show null values as '(Default)', and disable them all
vars
	criteriaCtrl	: CMUI_YACriteriaCntl;
	i				: Integer;

begin
	while true do
		i := i + 1;
		criteriaCtrl := self.frmCriteria.getControl(i);
		if criteriaCtrl = null then
			break;
		endif;
		if criteriaCtrl.visible then
			if criteriaCtrl.txtCriteriaValue.text = null then
				criteriaCtrl.txtCriteriaValue.text := '(Default)';
			endif;
			criteriaCtrl.enabled := false;
		endif;
	endwhile;

end;
</source>
    </JadeMethod>
    <JadeMethod name="setReferences" id="38fd5f63-8498-4fa9-a44e-e4d321c93edf">
        <updating/>
        <source>setReferences(_new : Boolean; _ssb : CM_SnapShotServiceBroker; _qrm : CM_QuantityRangeMap; _ild : CM_InvoiceLineDesc) updating;

vars
	ya, proxyObj	: CM_InvoiceAllocation;
	qm				: CM_QuantityMap;
	blockGroupObj	: CM_YABlockGroup;

begin
	self.doClearCurrentYA();
	
	self.isNew := _new;
	self.mySnapShotBroker := _ssb;
	self.myQuantityRangeMap := _qrm;
	self.myInvoiceLineDesc := _ild;

	if _qrm &lt;&gt; null then
		qm := _qrm.myQuantityMap;
		ya := qm.myInvoiceAllocation;
		//  Also save off flag indicating if template criteria has been modified
		self.isTemplateModified := ya.isTemplateModified;
		self.myYardAllocation	:=	ya;
	endif;

epilog

end;</source>
        <Parameter name="_new" type="Boolean"/>
        <Parameter name="_ssb" type="CM_SnapShotServiceBroker"/>
        <Parameter name="_qrm" type="CM_QuantityRangeMap"/>
        <Parameter name="_ild" type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="654b3764-615d-4d8f-970f-f7e6d147a908">
        <updating/>
        <source>setupForm() updating;
vars

begin
	inheritMethod();
	
	self.grpTemplate.visible := false;
	self.cmbIMEX.visible := false;
	self.lblHeader.visible := false;
	self.chkDisableYA.visible := false;
	self.btnFindImex.visible := false;
	self.shtLocation.visible := false;
	self.shtOptions.visible := false;
	self.shtRemarks.visible := false;
	self.txtGroupName.visible := false;
	self.lblGroupName.visible := false;
	self.txtImex.visible := false;
	self.lblYAColour.visible := false;
	self.clrYAColour.visible := false;
	self.btnNext.visible := false;
	self.btnSave.visible := false;
	self.btnAdd.left := self.btnNext.left;
	self.btnAdd.top := self.btnRemove.top;
	self.btnNext.tag := "Next";	// anything but "SaveAs"
	
	if self.mySnapShotBroker = null then
		self.setCaption("Invoice Line Mapping");
	else
		self.setCaption(app.getErrorString1(Invoice_line_mapping, "'" &amp; self.mySnapShotBroker.mySnapShotDefinition.name &amp; "'"));
	endif;
	
	self.populateTable(self.isNew);
	self.populateCombos();
	if self.isNew then
		self.btnAdd.caption := app.getErrorString(AmpersandAdd);
		self.btnAdd.enabled := true;
		self.btnAdd.left := self.btnNext.left - 61;
		self.btnNext.visible := true;
		self.btnNext.caption := app.getErrorString(AmpersandNext);
	else
		self.btnAdd.caption := app.getErrorString(AmpersandUpdate);
		self.populateMappingDetails();
	endif;
	
	self.getYACriteria();

	self.minimumHeight := 495; // TFS 3509
	self.minimumWidth := 410; // TFS 3509
	self.frmMappings.parentAspect := Label.ParentAspect_StretchRight + Label.ParentAspect_AnchorBottom; // TFS 3509
	self.tblData.parentAspect := Label.ParentAspect_StretchRight; // TFS 3509
	self.fldYardAlloc.height := 90;	// TFS 3509
	self.borderStyle := Form.BorderStyle_Sizable; // TFS 3509

	self.resizeForInvoice();
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupFromCurrentItem" id="0712606a-fa0f-4f9e-940f-38432237a2a9">
        <updating/>
        <source>setupFromCurrentItem() updating;

vars
	status	: Boolean;
begin
	self.getYACriteria();
	self.populateMappingDetails();
	self.btnAdd.caption := app.getErrorString(AmpersandUpdate);
	self.btnNext.visible := false;
	self.btnAdd.left := self.btnNext.left;
	if self.myYardAllocation = null then
		status := false;
	else
		status := not self.myYardAllocation.CM_InvoiceAllocation.default;
	endif;
	self.btnRemove.enabled := status;

end;
</source>
    </JadeMethod>
    <JadeMethod name="tblData_rowColumnChg" id="64731454-7547-441b-b8cb-e9f3e593b59d">
