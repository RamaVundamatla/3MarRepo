    <JadeMethod name="mnuTaskAllocateMachine_click" id="0796c26f-6f3b-4913-a524-339abc5417a1">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuTaskAllocateMachine_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lMachine : CM_Machine;
	lObj 	: Object;
begin
	lMachine := menuItem.userObject.CM_Machine; //self.myTerminal.machines[menuItem.caption.trimBlanks];
	if lMachine &lt;&gt; null then
		self.allSelectedRTQEntries.clear();
		foreach lObj in self.tblQEntries.allSelectedObjects do
			if lObj.isKindOf(CM_RTQueueTask) then
				self.allSelectedRTQEntries.add(lObj.CM_RTQueueTask.myEntry);
			endif;
		endforeach;
		
		self.doAllocateMachineToTask(lMachine);
	endif;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
