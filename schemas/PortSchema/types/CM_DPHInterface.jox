<Class name="CM_DPHInterface" id="f48342a1-912c-4808-9e0d-6498e4242473">
    <superclass name="CM_ExtFinanceIO"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>

The external financial systems for DPH.

One file format for 2 external systems.

 ‘JD Edwards EnterpriseOne Financial Management’ produced by J.D. Edwards World Solution Company.
 ‘Dynamics GP’ produced by Stanley Stuart Yoffee &amp; Hendrix, Inc.

 
 


UNIT TEST - UT_Invoicing::uExternalInterfaceDPH</text>
    <DbClassMap file="invoice"/>
    <JadeMethod name="createDetailRecords" id="b9365479-b7f3-4f98-b275-a86783512872">
        <source>createDetailRecords(file : File io; inv : CM_Invoice; _newFile : Boolean);
/*
Purpose:	DPH financial export to CSV		
Date				Who			Reason
MAY 2013			CNWAB1		Initial creation
08/07/2022			jlizm1		PRP - UNIT Price Column in SalesLine Jade Interface file needs to have 4 decimal places instead of 2
13 September 2022	navpw1		TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
*/
constants
	DELIMITER = ",";
	
vars
 	isVoyageInvoice	: Boolean;
	str, itemNumber : String;
// PAR 31891		glSummaryDict 	: CM_GLSummaryByGLCodeDict;
	glSummaryDict 	: CM_GLSummaryByGLCodeRateDict;
	glSummary 		: CM_GLSummary;
	invoiceLine 	: CM_InvoiceLine;
	charge 			: CM_Charge;
	serv			: CM_Service;
	
begin
	//isVoyageInvoice := inv.invoiceType.isVoyageSpecific();
	isVoyageInvoice := inv.invoiceType.isVoyageSpecificDebtor(inv.debtor); // ### TFS 54565 (54384) 22Sep2022 NAVPW1
	create glSummaryDict transient;
	
	foreach	invoiceLine in inv.invoiceLines do
		foreach charge in invoiceLine.charges do
// PAR 31891			charge.getGLSummStatSumByGLCodeInvDes(glSummaryDict);
			charge.getGLRateSummaryStats(glSummaryDict);
			
		endforeach;
	endforeach;
	
	// PAR 31891
	if _newFile then
		str := "Document Number,Item Number, Quantity, Unit Price, Item Description";
		file.writeLine(str);
	endif;
	
	foreach glSummary in glSummaryDict do //We are including zero amount lines so export everthing.
		str := "";
		// PAR 31789
		serv := glSummary.getServiceObject(); // PAR 31789
		itemNumber := ""; // PAR 31789
		if serv &lt;&gt; null then // PAR 31789
			itemNumber := serv.remarks.trimBlankCharacters(); // PAR 31789
		else
			itemNumber := glSummary.serviceName;
		endif;
		
		str := inv.sequenceNum.String &amp; DELIMITER; // Document Number
// PAR 31789		str := str &amp; glSummary.serviceName &amp; DELIMITER; // Item Id
		str := str &amp; itemNumber &amp; DELIMITER; // Item Id
		str := str &amp; glSummary.quantity.String &amp; DELIMITER; // Quantity
		str := str &amp; glSummary.rate.asStringJMTWithPrecision(4,false) &amp; DELIMITER; // Rate
		str := str &amp; glSummary.myInvoiceLine.invoiceLineDesc.narration; // Narration
		
		file.writeLine(str);	
	endforeach;
	
epilog
	glSummaryDict.purge();
	delete glSummaryDict;
	
end;</source>
        <Parameter name="file" type="File" usage="io"/>
        <Parameter name="inv" type="CM_Invoice"/>
        <Parameter name="_newFile" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createGLRecords" id="ce3dbb69-7a53-48d9-92a1-2c0a0fc3b49e">
        <source>createGLRecords(file : File io; inv : CM_Invoice; _newFile : Boolean);
/*
Purpose:	DPH financial export to CSV		
Date				Who			Reason
MAY 2013			CNWAB1		Initial creation
13 September 2022	navpw1		TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
*/
constants
	DELIMITER = ",";
	TheA :String = #"C5";
	
vars
 	isVoyageInvoice	: Boolean;
	str, glAccount	: String;
	glSummaryDict	: CM_GLSummaryByGLCodeDict;
	glSummary		: CM_GLSummary;
	invoiceLine		: CM_InvoiceLine;
	charge			: CM_Charge;
//	lineTot			: Decimal[11,2];
//	docTot			: Decimal[11,2];
	pos				: Integer;
	lineTot			: Decimal[15,2];	//11 May 2018	NDL	TFS 38528
	docTot			: Decimal[15,2];	//11 May 2018	NDL	TFS 38528
	
begin
	//isVoyageInvoice := inv.invoiceType.isVoyageSpecific();
	isVoyageInvoice := inv.invoiceType.isVoyageSpecificDebtor(inv.debtor); // ### TFS 54565 (54384) 22Sep2022 NAVPW1
	create glSummaryDict transient;
	
	foreach	invoiceLine in inv.invoiceLines do
		foreach charge in invoiceLine.charges do
			charge.getGLSummStatSumByGLCodeInvDes(glSummaryDict);
		endforeach;
	endforeach;
	
	// PAR 31891
	if _newFile then
			str := "Document Number,Account Number, Distribution Type, Debit Amount, Credit Amount";
			file.writeLine(str);
	endif;
	
	foreach glSummary in glSummaryDict do 
		lineTot := glSummary.amount;
		pos := 1;
		glAccount := glSummary.glCode.scanUntil(TheA, pos);
		if glAccount.length &gt; 24 then
			glAccount := glAccount[1:24];
		endif;
		
		str := inv.sequenceNum.String &amp; DELIMITER; // Document Number
		str := str &amp; glAccount &amp; DELIMITER; // GL Code
// PAR 31789		str := str &amp; glSummary.quantity.String &amp; DELIMITER; // Quantity

/* WAS PAR 33262		
		if lineTot &lt; 0 then // PAR 31891 part 2
			str := str &amp; "2" &amp; DELIMITER &amp; lineTot.String &amp; DELIMITER &amp; DELIMITER; // Debit PAR 31891
		else
			str := str &amp; "1" &amp; DELIMITER &amp; DELIMITER &amp; lineTot.String &amp; DELIMITER; // Credit PAR 31891
		endif;
		NOW */
		str := str &amp; "1" &amp; DELIMITER &amp; DELIMITER &amp; lineTot.String &amp; DELIMITER; // PAR 33262 - credit or debit the line amount is always '1'
		
		docTot := docTot + lineTot;
		
		file.writeLine(str);	
	endforeach;
	
	// PAR 31891 PART 3
	str := inv.sequenceNum.String &amp; DELIMITER; // Document Number
	// ###  For each document number you specify in the distribution file you need a row for the 1210-0000 AR acct as a debit in order to create a balancing of debits equalling credits. 
	str := str &amp; "1210-0000" &amp; DELIMITER; // GL Code
/* WAS PAR 33262		
	if docTot &lt; 0 then // PAR 31891 part 2
		str := str &amp; "1" &amp; DELIMITER &amp; DELIMITER &amp; docTot.String &amp; DELIMITER; // Credit PAR 31891
	else
		str := str &amp; "2" &amp; DELIMITER &amp; docTot.String &amp; DELIMITER &amp; DELIMITER; // Debit PAR 31891
	endif;
	NOW */
	
	str := str &amp; "2" &amp; DELIMITER &amp; docTot.String &amp; DELIMITER &amp; DELIMITER;  // PAR 33262 - credit or debit the total amount is always '2'
	
	file.writeLine(str);
	
epilog
	glSummaryDict.purge();
	delete glSummaryDict;
	
end;</source>
        <Parameter name="file" type="File" usage="io"/>
        <Parameter name="inv" type="CM_Invoice"/>
        <Parameter name="_newFile" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createHeaderRecord" id="7d60b645-7887-4c81-aab1-dce1e7666a7a">
        <source>createHeaderRecord(file : File io; inv : CM_Invoice; _newFile : Boolean);
/*
Purpose:	DPH financial export to CSV		
Date				Who			Reason
MAY 2013		CNWAB1		Initial creation
21/07/2017 		cnwma1		TFS #5392:DPH - External File for Business Unit 025;
*/
constants
	DELIMITER = ",";
vars
	str : String;
	idx, pos 	: Integer;
begin
	// PAR 31891
	if _newFile then
		str := "Type,Type ID,Document Number, Date, Batch ID, Customer ID, Site ID, Comment Text, User Defined Text 1, User Defined Text 2, User Defined Text 3, User Defined Text 4, User Defined Text 5"; // PAR 31891 part 2 moved 'Comment Text'
		file.writeLine(str);
	endif;



	
	str := "3" &amp; DELIMITER;		//Record Type 1 = Quote; 2 = Order; 3 = Invoice; 4 = Return; 5 = Back Order; 6 = Fulfillment Order
	str := str &amp; "TOSINV" &amp; DELIMITER; // Type ID
	str := str &amp; inv.sequenceNum.String &amp; DELIMITER; 	// Invoice Number 
	// PAR 31789 str := str &amp; inv.postedDT.date.asStringJMT() &amp; DELIMITER; 			// Invoice date as using locale
	// PAR 33199 str := str &amp; inv.postedDT.date.format("MM/dd/yy") &amp; DELIMITER; 			// Invoice date using fix US format
	str := str &amp; inv.toDT.date.format("MM/dd/yy") &amp; DELIMITER; 	// PAR 33199 use END date not posted date
	
	
	str := str &amp; "TRX FROM TOS" &amp; DELIMITER; // Batch ID
	str := str &amp; inv.debtor.decfinName &amp; DELIMITER; 	// External Customer ID. PAR 31789
	//str := str &amp; self.getSiteId() &amp; DELIMITER; 	//Site ID.      //21.07.2017 cnwma1 TFS #5392
	str := str &amp; self.getSiteId(inv.bank) &amp; DELIMITER; 	//Site ID.  //21.07.2017 cnwma1 TFS #5392
	str := str &amp; DELIMITER; 	// Comment Text. 
	str := str &amp; DELIMITER; 	// User Defined Text 1
	str := str &amp; DELIMITER; 	// User Defined Text 2
	str := str &amp; DELIMITER; 	// User Defined Text 3
	str := str &amp; DELIMITER; 	// User Defined Text 4
	str := str &amp; DELIMITER; 	// User Defined Text 5
	
	//strip CrLf
	if str.length &lt;&gt; 0 then
		pos := str.pos(CrLf, 1);
		while pos &gt; 0 do
			if pos + 2 &gt; str.length then 
				str := str[1:pos - 1];
				break;
			endif;
			str := str[1:pos] &amp; ' ' &amp; str[pos+2:end];
			pos := str.pos(CrLf, 1);
		endwhile;
		str.replaceChar(Cr.Character, ' ');
		str.replaceChar(Lf.Character, ' ');
	endif;
	file.writeLine(str);
epilog
end;</source>
        <Parameter name="file" type="File" usage="io"/>
        <Parameter name="inv" type="CM_Invoice"/>
        <Parameter name="_newFile" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="export" id="42f0bf96-30ab-4690-bd1e-9dd626e0e177">
        <updating/>
        <source>export(invoice: CM_Invoice input) updating;
/*
Purpose:	DPH financial export to CSV		
Date				Who			Reason
MAY 2013		CNWAB1		Initial creation
27 Oct 2016		cnwrs1		TFS allow this directory to be assigned %MiscDir% insrtead of D:\qnsPjmt\server\c_misc
22 Jul 2019		cnwma1		ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
*/
constants
	ExportDirectory = "processed\";

	SLEEP = 3000;
	TRYS = 10;
vars
	fFolder		: FileFolder;
	file,
	tmpFile 	: File;
	path,
	exportDir 	: String; 

begin
	path := self.exportPath.normaliseDirectory().substituteDirectory();
	
	exportDir := path;
	if not app.isJMTUnitTest then	
		exportDir := path &amp; ExportDirectory;
		create fFolder transient;
		fFolder.fileName := exportDir;

		if not fFolder.isAvailable() then
			fFolder.make();
		endif;
	endif;
	
	
	create file;
	file.mode := File.Mode_Output;
	file.shareMode := File.Share_Exclusive;
	file.hidden := false;
	
	// ### SALES HEADER - INDIVIDUAL
	file.fileName := exportDir &amp; invoice.myTerminal.code &amp; invoice.sequenceNum.String &amp; "SalesHeader.csv"; 
	createHeaderRecord(file, invoice, true);
	file.close;

	// ### SALES LINES - INDIVIDUAL
	file.fileName := exportDir &amp; invoice.myTerminal.code &amp; invoice.sequenceNum.String &amp; "SalesLines.csv"; 
	createDetailRecords(file, invoice, true);
	file.close;

	// ### SALES DISTRIBUTION - INDIVIDUAL
	file.fileName := exportDir &amp; invoice.myTerminal.code &amp; invoice.sequenceNum.String &amp; "SalesDistribution.csv"; 
	createGLRecords(file, invoice, true);
	file.close;


	// ### SALES HEADER - MERGED
	self.exportMerge(file, path, "SalesHeader.csv","createHeaderRecord", invoice);

	// ### SALES LINES - MERGED
	self.exportMerge(file, path, "SalesLines.csv","createDetailRecords", invoice);

	// ### SALES DISTRIBUTION - MERGED
	self.exportMerge(file, path, "SalesDistribution.csv","createGLRecords", invoice);	

	invoice.incrementExportCount(false);	//22.07.2019 cnwma1 TFS #45577
	
epilog
	delete file;
	delete tmpFile;
	delete fFolder;
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportMerge" id="af1053a7-0644-468a-b1b2-e0e11cf63faf">
        <source>exportMerge(file : File io; _path : String; _fileName : String; _methodName : String; inv : CM_Invoice);
/*
Purpose:			
Date		Who		Reason
24 May 2013	cnwab1	Initial creation
*/
constants
	SLEEP = 3000;
	TRYS = 10;

vars
	idx : Integer;
	newFile : Boolean;
begin

	// ### SALES LINES - MERGED
	file.fileName := _path &amp; _fileName; 
	file.mode := File.Mode_Append;
	file.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	file.shareMode := File.Share_Exclusive;

	if not file.isAvailable() then
		newFile := true;
	endif;
	
	idx := 0;
	while true do
		if file.tryOpen() then
			self.sendMsgWithParams(_methodName, file, inv, newFile);
			break;
		else
		
			idx := idx + 1;
			if idx &gt; TRYS then
				app.raiseCMException2(Invoi_expor_not_occur_becau_fi, self.getNiceName(),file.fileName, null, null);
				break;
			endif;
			process.sleep(SLEEP);
		endif;
		
	endwhile;
	file.close;

epilog

end;</source>
        <Parameter name="file" type="File" usage="io"/>
        <Parameter name="_path" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="inv" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="exportToFile" id="2e254e40-6780-48db-ad90-48e3f99243eb">
        <source>exportToFile(invoice: CM_Invoice input; fileNameBase: String);
/*
Purpose:	DPH financial export to CSV		
Date				Who			Reason
MAY 2013		CNWAB1		Initial creation
22 July 2019	cnwma1		ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
*/
vars

	file 	   : File;
	fFolder    : FileFolder;
	filePrefix : String;
	fileDirStr : String;
	prefixIdx  : Integer;
	message    : String;
begin
	filePrefix := invoice.myTerminal.code &amp; invoice.sequenceNum.String;
	
	prefixIdx := fileNameBase.pos(filePrefix,1);
	if prefixIdx &lt;=0 then
		prefixIdx := fileNameBase.reversePos("\");
	endif;
	fileDirStr := fileNameBase[1:prefixIdx-1];


	create fFolder;
	fFolder.fileName := fileDirStr;
	if not fFolder.isAvailable then
		message := app.getErrorString2(Expor_path_does_not_exist_cann,fileDirStr,invoice.sequenceNum.String);
		app.msgBox(message,app.getErrorString(Export_error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	create file;
	file.allowReplace := true;
	file.mode := File.Mode_Output;	// 25/2/16 cnwmp6 PAR 36286 unicode version

	file.fileName := fileDirStr &amp;  filePrefix &amp; "SalesHeader.csv"; 
	createHeaderRecord(file, invoice, true);
	file.close;

	file.fileName := fileDirStr &amp; filePrefix &amp; "SalesLines.csv"; 
	createDetailRecords(file, invoice, true);
	file.close;

	file.fileName := fileDirStr &amp; filePrefix &amp; "SalesDistribution.csv"; 
	createGLRecords(file, invoice, true);
	file.close;

	invoice.incrementExportCount(false);		//22.07.2019 cnwma1 TFS #45577
epilog
	delete fFolder;
	delete file;
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="fileNameBase" type="String"/>
    </JadeMethod>
