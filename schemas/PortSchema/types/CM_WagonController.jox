    <JadeMethod name="getDrawingAttributes" id="efe12009-a8f0-49c5-9bb2-9b4c66568d2a">
        <source>getDrawingAttributes(pDisplay, pView : Integer;pHeight: Integer; pColour: Integer output; 
				pLetter : String output);
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lSize : Integer;
	array : CM_TIArray;
	loadStateSet : Boolean;
begin

	app.cmsBeginLoad(loadStateSet);
	sharedLock(self);

	inheritMethod(pDisplay, pView,pHeight, pColour, pLetter);	// this clears the array
	
	if pHeight &gt; 0 then
		create array;	
		self.getTIs(array, PLANNING_MODE, true);
		lSize := array.size;
		if lSize &gt; 0 and pHeight &lt;= lSize then
			if array[pHeight] &lt;&gt; null then
				pLetter := "P";
				if pColour = NULL_COLOURCODE then // this may have been set for restrictions in superclass so keep the restriction colour
					pColour := Gray;
				endif;
			endif;
		else
			self.getTIs(array, QUEUE_MODE, true);
			lSize := array.size;
			if lSize &gt; 0 and pHeight &lt;= lSize then
				if array[pHeight] &lt;&gt; null then
					pLetter := "Q";
					if pColour = NULL_COLOURCODE then
						pColour := Gray;
					endif;
				endif;
			else
				lSize := self.allTrackedItems.size;
				if lSize &gt; 0 and pHeight &lt;= lSize then
					if self.allTrackedItems[pHeight] &lt;&gt; null then
						pLetter := "A";
						if pColour = NULL_COLOURCODE then
							pColour := Gray;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;

epilog
	app.cmsEndLoad(loadStateSet);
	delete array;
end;</source>
        <Parameter name="pDisplay" type="Integer"/>
        <Parameter name="pView" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pColour" type="Integer" usage="output"/>
        <Parameter name="pLetter" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getFirstExistingItem" id="16a72d5d-5fda-4d35-8afb-ba08a67801f4">
        <source>getFirstExistingItem( control: CMIF_MoveController input; wle : CM_WorkListEntry output):CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2014	cnwndl1	Initial creation	//Par 35346 / CCMS 1408

*/

vars

	ti : CM_TrackedItem;
	req : CM_Request;
	str : String;
	obj : CM_Object;
	iter : Iterator;
	prospectTi : CM_TrackedItem;
	allTIs : CM_TIArray;
begin
	//epr par 37324 22/1/16
	create allTIs transient;
	self.getActualTIsForValidateMove(control,allTIs);
	
	if control &lt;&gt; null and control.moveMode = PLANNING_MODE then	//2 Mar 2015	NDL	Par 35748
		//in planning mode, 
		if not allTIs.isEmpty then
			//potentially when we are planning, there will be cargo in the position
			// that we wont be there when we come to load the wagon
			iter := self.allTrackedItems.createIterator;
			while iter.next( prospectTi ) do
				if not self.myWagon.allTIsReceived.includes( prospectTi ) then
					//it has been put on since the train arrived.
					ti := prospectTi;
					break;
				endif;
				if prospectTi.isROB then
					// it arrived on the train, but is staying there
					ti := prospectTi;
					break;
				endif;
			endwhile;
			delete iter;
		endif;
		
	else
		//Either NOT in planning mode, or we have no context (i.e. we don't know)
		if not allTIs.isEmpty then
			ti := allTIs.first;
		endif;
	
	endif;
	
	if ti = null and not self.allRailWLELoad.isEmpty then
		wle := self.allRailWLELoad.first;
		if wle &lt;&gt; null then
			ti := self.allRailWLELoad.first.myTrackedItem;
		endif;
	endif;
	
	if ti &lt;&gt; null then
		return ti;
	endif;
	
	if wle &lt;&gt; null then
		req := wle.myRequest;
		if req &lt;&gt; null then
			str := req.getISOType;
			if str &lt;&gt; null then
				obj := app.myRoot.allISOTypes.getAtKey(str);
			endif;
			if obj &lt;&gt; null then
				return obj;
			endif;
			str := req.getISOGroup;
			if str &lt;&gt; null then
				obj := app.myRoot.allISOTypeGroups.getAtKey(str);
			endif;
		endif;
	endif;
	
	return obj;

epilog

	delete iter;
	delete allTIs;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="wle" type="CM_WorkListEntry" usage="output"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getFirstTi" id="535eb72b-b738-429e-9c39-345daf551146">
        <source>getFirstTi():CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	ti : CM_TrackedItem;

begin

	if not self.allTrackedItems.isEmpty then
		ti := self.allTrackedItems.first;
	endif;
	
	if ti = null and not self.allRailWLELoad.isEmpty then
		ti := self.allRailWLELoad.first.myTrackedItem;
	endif;
	
	return ti;

epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getFullId" id="22f6da07-2c62-4696-a8c6-acaad1bdc59c">
        <source>getFullId(): String;
//--------------------------------------------------
// Created:	05 September 2003 By: cnwgd1
//--------------------------------------------------
/*
Date				Who		Reason
01 November 2023	navmd1	TFS 61063 - Unit Tests - Handle transient calls to this that haven't set myTerminal yet
*/
vars

begin

	if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig( RailDefaultWCIdFormat ).Integer = Rail_UPSP_Int then	//Par 35346 / CCMS 1408
		return self.getIdUPSPformat( null );
	
	else
		if self.myWagon &lt;&gt; null then
			return self.myWagon.getLocationId() &amp;  " " &amp; self.getLabel();
		endif;
	
	endif;
	
	return null;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullIdAndLevel" id="ca0d280a-4436-4e9f-a72d-3f0070552f5e">
        <source>getFullIdAndLevel(_ti: CM_TrackedItem; _mode: Integer; _isTarget: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2015	cnwndl1	Initial creation	Par 36169

*/

vars

begin

	if _ti &lt;&gt; null then
		return self.getFullIdTI( _ti );
	endif;
	
	return inheritMethod(_ti, _mode, _isTarget);
	
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
