<Class name="Schema">
    <JadeMethod name="getAllDriverSubschemaDescs" id="9370e8c7-2ea7-4b7f-92e8-e3cbe37c939d">
        <source>getAllDriverSubschemaDescs(drvScmDescDict : DriverSchemaDescriptorNameDict input);

// it is the caller's responsibility to clear drvScmDescDict if required

vars
	dsd : DriverSchemaDescriptor;
	scm : Schema;
	mth : Method;
	cls : Class;
	
begin
	if drvScmDescDict = null then
		return;
	endif;

	// first pass: add to the dictionary all of our immediate driver subschemas
	foreach scm in self.subschemas do
		cls := scm.jtdGetClasses["JtdContext"];
		if cls = null then
			// the schema is not a transaction driver schema
			continue;
		endif;
		
		mth := cls.jtdGetMethods["jtdAllProfileText"];
		if mth = null then
			// we cannot find the method that holds the profile text, which means
			// that the schema is not a transaction driver schema, is incomplete,
			// or has been modified
			continue;
		endif;

		create dsd transient;
		dsd.updateForCreate(scm, mth);
		drvScmDescDict.add(dsd);
	endforeach;
	
	// second pass: ask all of our immediate subschemas to return descriptors for
	// all of their driver subschemas
	foreach scm in self.subschemas do
		scm.getAllDriverSubschemaDescs(drvScmDescDict);
	endforeach;
end;</source>
        <Parameter name="drvScmDescDict" type="DriverSchemaDescriptorNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getProfileTextMethod" id="bf6391bd-6290-4705-b600-47c11565c25f">
        <source>getProfileTextMethod() : Method;

vars
	cls : Class;
	
begin
	cls := self.classes["JtdContext"];
	
	if cls = null then
		return null;
	endif;
	
	return cls.rootType.jtdGetMethods["jtdAllProfileText"];
end;</source>
        <ReturnType type="Method"/>
    </JadeMethod>
    <JadeMethod name="getTrxGenMethodProfiles" id="c496e99b-529a-4151-a525-28a5a9a70c76">
        <source>getTrxGenMethodProfiles(mpa : JtdMethodProfileArray input);

// It is the caller's responsibility to clear mpa first if required.
// It is also the caller's responsibility to delete the contents of
// mpa when finished.

vars
	trxGenCls : Class;
	
begin
	if mpa = null then
		return;
	endif;
	
	trxGenCls := self.classes[TrxGenClassName];
	
	if trxGenCls = null then
		// no transaction generator classes exist in this schema
		return;
	endif;

	if trxGenCls.superschemaType &lt;&gt; null then
		// this is a subschema copy - we deal only with root classes
		return;
	endif;

	trxGenCls.getMethodProfiles(mpa);
end;</source>
        <Parameter name="mpa" type="JtdMethodProfileArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="jtdGetClasses" id="26d774c1-9ca1-437d-86a0-ae3c6112f41d">
        <source>jtdGetClasses() : ClassNDict;

begin
	return self.classes;
end;</source>
        <ReturnType type="ClassNDict"/>
    </JadeMethod>
</Class>
