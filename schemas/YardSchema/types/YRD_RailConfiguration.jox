    <JadeMethod name="createYAConfig" id="47ab3a3f-d40c-49fb-b661-d877472c3086">
        <updating/>
        <source>createYAConfig():CM_YAConfig updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Sep 2009	cnwndl1	Initial creation 
25 Aug 2025	navdap1	MTN-35615 ENS | Bulk Creation of Yard Allocations
*/

vars
	configOpts : CMIF_YAConfig;
	proxyYAConfig : CM_YAConfig;
	realYAConfig : CM_YAConfig;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	create proxyYAConfig transient;
	proxyYAConfig.setProxy(self.myTerminal, null, null, null, null);	// MTN-35615
	
	create configOpts transient;
	configOpts.setFromTerminal(self.myTerminal);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateYAConfig(proxyYAConfig, realYAConfig, configOpts, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		self.unloadForm;
		break;
		
	endwhile;
	
	return realYAConfig;
	
epilog
	delete proxyYAConfig;
	delete configOpts;
end;</source>
        <ReturnType type="CM_YAConfig"/>
    </JadeMethod>
    <JadeMethod name="displayCriteria" id="ca846c32-8905-483c-be5c-9b935fa83be4">
