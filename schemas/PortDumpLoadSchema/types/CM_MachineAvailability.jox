<Class name="CM_MachineAvailability">
    <JadeMethod name="importPLXMLReference" id="4c6a5107-b31d-44b6-9ac6-e5c7f10adeb3">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_MachineAvailability::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
