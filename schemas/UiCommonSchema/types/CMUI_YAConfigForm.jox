    <JadeMethod name="getAPOverstowCombo" id="64777178-073d-4ea0-b604-08b7f0dfddbb">
        <source>getAPOverstowCombo() : Integer;
// --------------------------------------------------------------------------------
// Created:		15 February 2010 by cnwjo3
//
// Purpose:		par 22338
//
vars
	s : String;
begin

	return self.cmbAPOverstow.listIndex ;
/*
	if self.cmbAPOverstow.listIndex &gt; 0 then
		//epr par 27541 12/5/11
		return self.cmbAPOverstow.itemText[self.cmbAPOverstow.listIndex] =app.getErrorString(CMUI_YAConfigForm_YA);
