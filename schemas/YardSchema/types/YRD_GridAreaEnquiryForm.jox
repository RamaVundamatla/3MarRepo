    <JadeMethod name="initFromUserWindow" id="ad8cfaae-edf0-4e98-890a-ab194b3000cf">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	str		: String;
	pos		: Integer;
	tmpTA	: CM_TerminalArea;
	
begin
	inheritMethod(_userWindow);
	
	return;
	
	
	
	
	
	
	
	
	pos := 1;
	
	while true do
		str := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(XML_TA, pos);
		if pos &lt;= 0 then
			break;
		endif;
		
		tmpTA := self.myTerminal.allTerminalAreas[str];
		if tmpTA = null then
			continue;
		endif;

		self.myCurrentTerminalArea := tmpTA;
		self.allTerminalAreas.add(tmpTA);

	endwhile;

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
