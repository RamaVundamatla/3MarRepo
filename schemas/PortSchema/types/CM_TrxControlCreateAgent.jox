/*

Purpose:			Cash Module regular cash receipt processing (see trxCreateCashReceipts for the equivalent duty docs processing)

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	// Start the transaction
	beginTransaction;

	if _proxyCashReceipt &lt;&gt; null then	
		app.myUtilityCA.utlCreateCashReceiptPayments(_proxyCashReceipt, _newCashReceipt,
								_allPxyCashPays, _allRealCashPays, _comments, _passport ); 
	endif;
	
epilog
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
