epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getStatusDesc" id="537825c5-b532-4031-9a65-47df07d718c0">
        <options>4</options>
        <source>getStatusDesc(_status : Integer) : String typeMethod ;
/*
Purpose:	

Date		Who		Reason
19 July 2024	navab1	CR 64612 TASK 64659
*/

vars

begin
	if _status = CM_VoyageStage.STATUS_SUCCESS then
		return CM_VoyageStage.STATUS_SUCCESS_STR;
	elseif _status = CM_VoyageStage.STATUS_FAILED then
		return CM_VoyageStage.STATUS_FAILED_STR;
	elseif _status = CM_VoyageStage.STATUS_WAITING then
		return CM_VoyageStage.STATUS_WAITING_STR;
	endif;
	
	return CM_VoyageStage.STATUS_UNKNOWN_STR;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusDescription" id="cb6b0771-fa74-4fbc-ad21-4cd45898b9ca">
        <source>getStatusDescription(_status : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars

begin
	if _status = CM_VoyageStage.STATUS_SUCCESS then
		return CM_VoyageStage.STATUS_SUCCESS_STR;
	elseif _status = CM_VoyageStage.STATUS_FAILED then
		return CM_VoyageStage.STATUS_FAILED_STR;
	elseif _status = CM_VoyageStage.STATUS_WAITING then
		return CM_VoyageStage.STATUS_WAITING_STR;
	endif;
	
	return CM_VoyageStage.STATUS_UNKNOWN_STR;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypeDescription" id="242e7660-464b-4973-bf15-70ae0e70e9c9">
        <source>getTypeDescription() : String;
/*
Purpose - 	
Who - NAVAB1
Date - 19JUL2024
ADO - CR 64612 TASK 64659
*/

vars

begin
	if self.type = CM_VoyageStage.Type_Discharge then
		return app.getErrorString(Discharge);
	elseif self.type = CM_VoyageStage.Type_Load then
		return app.getErrorString(Load);

	endif;
	
	return "";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="retrieveVoyageStageDetails" id="23d14c21-90a5-46a0-ba92-b87cfedd57dd">
        <source>retrieveVoyageStageDetails(_stage : Integer io; _operatorCode : String io; _debtorCode : String io; _ediDataDesc : String io; _description : String io;_failureMessage : String io; _stageDescription :String io; _type : Integer io; _status : Integer io; _statusStr : String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2024	navra1	Initial creation for //navra1 - TFS 65380 - 7th Aug 2024

*/

vars

begin
	_stage := self.stage;
	_operatorCode := self.operatorCode;		
	_debtorCode := self.debtorCode;
	_ediDataDesc := self.ediDataDesc;
	_description := self.description;
	_failureMessage := self.failureMessage;
	_stageDescription := self.stageDescription;
	_type := self.type;
	_status :=self.status;
	_statusStr := self.statusStr;

epilog

end;</source>
        <Parameter name="_stage" type="Integer" usage="io"/>
        <Parameter name="_operatorCode" type="String" usage="io"/>
        <Parameter name="_debtorCode" type="String" usage="io"/>
        <Parameter name="_ediDataDesc" type="String" usage="io"/>
        <Parameter name="_description" type="String" usage="io"/>
        <Parameter name="_failureMessage" type="String" usage="io"/>
        <Parameter name="_stageDescription" type="String" usage="io"/>
        <Parameter name="_type" type="Integer" usage="io"/>
        <Parameter name="_status" type="Integer" usage="io"/>
        <Parameter name="_statusStr" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1cf8ed82-819e-416f-b2db-4ff08c319ce0">
        <updating/>
        <source>setForCreate(_pxyStage : CM_VoyageStage) updating; 
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars

begin
	self.myVoyageProgress :=  _pxyStage.myVoyageProgress;
	self.dateTime := app.actualTimeServer();

	self.setForUpdate(_pxyStage);
	
epilog

end;</source>
        <Parameter name="_pxyStage" type="CM_VoyageStage"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="aa3b8e5c-6934-4653-80f3-f68fe1a91c5a">
        <updating/>
        <source>setForUpdate(_pxyStage : CM_VoyageStage) updating; 
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars
	invoice : CM_Invoice;							//navra1 - CR 65374 - 26th July 2024
begin
	self.stage := _pxyStage.stage;	
	self.operatorCode := _pxyStage.operatorCode;	
	self.status := _pxyStage.status;
	self.stageDescription := app.getVoyageStageFromEnum(_pxyStage.stage);
	self.statusStr := self.getStatusDescription(_pxyStage.status);	
	self.type := _pxyStage.type;
	self.ediDataDesc :=  _pxyStage.ediDataDesc;
	self.myEDIData := _pxyStage.myEDIData;				//navra1 - MTN-34348 - 13th March 2025
	self.lastUpdateTime := _pxyStage.lastUpdateTime;
	//navra1 - CR 65374 - 26th July 2024 - start
	self.debtorCode := _pxyStage.debtorCode;
	if _pxyStage.allInvoices &lt;&gt; null then	
		foreach invoice in _pxyStage.allInvoices do
			self.allInvoices.tryAdd(invoice);			
		endforeach;	
	endif;
	//navra1 - CR 65374 - 26th July 2024 - end
	self.failureMessage := _pxyStage.failureMessage;
	self.description := _pxyStage.description;						//navra1 - CR 66185 - 18th Sep 2024
epilog

end;</source>
        <Parameter name="_pxyStage" type="CM_VoyageStage"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="220dfd19-236d-4f33-8a9d-af0c1d011079">
        <updating/>
        <source>setProxy(_stage : Integer; 
		_voyageProgress : CM_VoyageProgress; 
		_operatorCode : String; 
		_status : Integer; 
		_type : Integer; 
		_invoiceList : CM_InvoiceBySeqNumDict;			//navra1 - CR 65374 - 26th July 2024
		_debtorCode : String;					//navra1 - CR 65374 - 26th July 2024
		_ediData : CM_EDIData;					//navra1 - MTN-34348 - 13th March 2025
		_failureMessage : String;		
		_failureDescription : String) updating; 				//navra1 - CR 66185 - 18th Sep 2024
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars
	invoice : CM_Invoice;						//navra1 - CR 65374 - 26th July 2024
begin
	self.stage := _stage;	
	self.operatorCode := _operatorCode;	
	self.status := _status;
	self.myVoyageProgress :=  _voyageProgress;
	self.stageDescription := app.getVoyageStageFromEnum(_stage);
	self.statusStr := self.getStatusDescription(_status);	
	self.type := _type;
	self.lastUpdateTime := app.actualTimeServer();	
	self.myEDIData := _ediData;				//navra1 - MTN-34348 - 13th March 2025
	//navra1 - CR 65374 - 26th July 2024 - start
	self.debtorCode := _debtorCode;
	if _invoiceList &lt;&gt; null then	
		foreach invoice in _invoiceList do
			self.allInvoices.tryAdd(invoice);			
		endforeach;	
	endif;
	//navra1 - CR 65374 - 26th July 2024 - end
	self.failureMessage := _failureMessage;
	self.description := _failureDescription;				//navra1 - CR 66185 - 18th Sep 2024	
epilog

end;</source>
        <Parameter name="_stage" type="Integer"/>
        <Parameter name="_voyageProgress" type="CM_VoyageProgress"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_invoiceList" type="CM_InvoiceBySeqNumDict"/>
        <Parameter name="_debtorCode" type="String"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_failureMessage" type="String"/>
        <Parameter name="_failureDescription" type="String"/>
    </JadeMethod>
