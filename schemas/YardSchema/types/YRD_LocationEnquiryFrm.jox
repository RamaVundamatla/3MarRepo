    <JadeMethod name="initForTerminalArea" id="a376f587-eddf-4dca-9ef1-acc663f04fbf">
        <updating/>
        <source>initForTerminalArea(_notesOnly : Boolean)updating;
//--------------------------------------------------
// Created:	16 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	//epr TFS 47132 30/12/19
	if self.useSelectorTable then
		return;
	endif;
	
	self.setNotifications();	//14787

	if _notesOnly then
		return;
	endif;
	
	if self.myCurrentObject = null then
		return;
	endif;
	if self.myCurrentObject.isKindOf(CM_TerminalArea) then
		self.initFilterValuesForTA(self.myCurrentObject.CM_TerminalArea, null);
	elseif self.myCurrentObject.isKindOf(CM_LocationsController) then
		self.initFilterValuesForTA(self.myCurrentObject.CM_LocationsController.myTerminalArea, self.myCurrentObject.CM_LocationsController);	
	else
		return;
	endif;
	
		
end;</source>
        <Parameter name="_notesOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="816ade9b-c25a-4ff5-b51a-cd40b6994ec8">
        <updating/>
        <source>initForm() updating;
//--------------------------------------------------------------
//Created: 26 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	startupMode : Integer;
begin

	self.allowTblDataHide	:= false;

	self.useTxtHeader := true;
	self.useTxtThumb := true;
	
	inheritMethod();
	
	self.btnTranship.visible := false;
	self.bottomMargin := self.frmStatusLine.height.Integer;
	self.staMain.visible := false;
	self.frmStatusLine.initFrame();
	
	//epr TFS 47132 17/12/19
	if not self.useSelectorTable then
		if self.amInitialisingWithObject then
			self.initForTerminalArea(false);
		endif;
	endif;
	
	if self.myCurrentObject &lt;&gt; null then
		
		if self.myCurrentObject.isKindOf(CM_BulkArea) then
			self.btnAdjustStock.enabled := true;
		else
			self.btnAdjustStock.enabled := false;	
		endif;
		
	endif;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAdjustStock.enabled := false;	
	endif;


	if self.useTxtThumb then
		self.tblInputTop.visible := false;
		self.txtThumbnail.visible := false;
		self.tblExtraInfo.visible := true;
		self.tblExtraInfo.left := 0;
		self.tblExtraInfo.top := 0;
		self.tblExtraInfo.width := self.frmDetailsTop.width;
		self.tblExtraInfo.height := self.frmDetailsTop.clientHeight;

	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="0ee7ca64-8da6-4e4f-9593-93b731963f25">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:     06 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	str		: String;
	terminalPos		: Integer;
	tmpTA	: CM_TerminalArea;
	taType	: CM_TerminalAreaType;
	terminal : CM_Terminal;
	terminalXML : String;
	code		: String;
	terminalArea : String;
	xmlData			: String;
begin
	inheritMethod(_userWindow);
	
	self.useFloatingFilter := true;		// 24/08/2010 cnwar2 #25515
	
	xmlData		:= _userWindow.xmlInfo;
	terminalPos := 1; 
	
	while true do
		terminalXML := xmlData.cnEcGetNextTagValueOfName(self.TAG_Terminal, terminalPos);
		if terminalXML = null then
			break;
		endif;
		
		code := terminalXML.cnEcGetTagValueOfName(self.TAG_Code);
		if code = null then
			continue;
		endif;
		
		if not self.amInitialisingWithObject then
			if self.myTerminal.code = code then
				terminalArea := terminalXML.cnEcGetTagValueOfName(self.TAG_TerminalArea);
				if terminalArea &lt;&gt; null then
					tmpTA := self.myTerminal.allTerminalAreas[terminalArea];
					if tmpTA &lt;&gt; null then
						if self.useSelectorTable then
							self.myCurrentObject := tmpTA;
						endif;
							self.myStartupObject := tmpTA;
						return;
					endif;
				endif;	
			endif;
		endif;
	
		if terminalPos = 0 then
			break;
		endif;
	endwhile;
	/*
	str := xmlData.cnEcGetTagValueOfName(XML_TA);
	
	if str &lt;&gt; null then
		tmpTA := self.myTerminal.allTerminalAreas[str];
		if tmpTA &lt;&gt; null then
			self.myStartupObject := tmpTA;
			//self.filterTerminalArea := tmpTA;
			return;
		endif;
	endif;
		*/
	//self.filterTAType := ta;
	

	
	
	/*str := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TA);
	
	if str &lt;&gt; null then
		tmpTA := self.myTerminal.allTerminalAreas[str];
		if tmpTA &lt;&gt; null then
			self.myCurrentObject := tmpTA;
			self.amInitialisingWithObject := true;
		endif;
	endif;
*/
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="isContainerEnqForm" id="3d4afae5-1e96-426b-a221-49ae7e41d39d">
