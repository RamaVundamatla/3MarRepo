    <JadeMethod name="getWagonVisitClassToCreate" id="31f013d2-f4b6-4e8c-bd66-76461035bf46">
        <source>getWagonVisitClassToCreate( _wagonClass : CM_WagonClass; _term : CM_Terminal; _wagonId : String; _carrier : CM_Carrier ):Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	wagonClass : CM_WagonClass;
	wagonClassId : String;
	term : CM_Terminal;

begin

	if _wagonClass &lt;&gt; null then
		wagonClass := _wagonClass;
	
	else
		term := _term;
		if term = null and app.myPassport &lt;&gt; null then
			term := app.myPassport.myTerminal;
		endif;
		if term &lt;&gt; null and _wagonId.trimBlanks &lt;&gt; null then
			wagonClassId := app.myRoot.getWagonClassViaHookCode( _term, _wagonId, _carrier);
		endif;
		if wagonClassId &lt;&gt; null then
			wagonClass := app.myRoot.allWagonClasses[wagonClassId];
		endif;
	
	endif;
	
	if wagonClass = null then
		return CM_FlatcarVisit;
	endif;
	
	return wagonClass.getWagonVisitClassToCreate;

epilog

end;</source>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_wagonId" type="String"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getWeightForDefault" id="637cb857-c429-4f46-92d6-b7c3f5d0556a">
        <source>getWeightForDefault(_value : Decimal) : String;
/*
Purpose:			
Date				Who			Reason
13 September 2023 navmv20 Bug 60217: EUP - COO - Release Request - Message not displaying weight as per measurement type displayed
*/
vars
	measureType : CM_MeasurementType;

begin
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType = null then
		return _value.asStringWeightJMT;
	endif;
	return app.convertMeasurementForDisplay(measureType.shortName, _value);
epilog

end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWeightForDefaultDisplay" id="83470ada-96a1-419a-94b7-e30cef011598">
        <source>getWeightForDefaultDisplay(_value : Decimal) : String;
/*
Purpose:			
Date				Who			Reason
SEPT 2013		CNWAB1		Initial creation
*/
vars
	measureType : CM_MeasurementType;

begin
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType = null then
		return _value.asStringWeightJMT &amp; " Kg";
	endif;
	return app.convertMeasurementForDisplay(measureType.shortName, _value) &amp; " " &amp; measureType.shortName;
epilog

end;</source>
        <Parameter name="_value" type="Decimal"/>
        <ReturnType type="String"/>
    </JadeMethod>
