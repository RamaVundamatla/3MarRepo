<Class name="CM_QDecimalInRange" id="2e924fce-7d83-4eaf-b22a-fba2db1ffff6">
    <superclass name="CM_QueryDecimalOperator"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="lowerValue" id="fbf52f91-ff0a-4e52-9fbb-857aaa19c0ad">
        <precision>14</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="7a2da3b3-3f0c-4b82-ba38-7bcbd3ed7f86">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
// Purpose:		when this Operator is created, give it a description
vars

begin
	self.description := "in the range of";
end;</source>
    </JadeMethod>
    <JadeMethod name="doMatch" id="14e21090-6793-4b44-ad22-438414fd2473">
        <source>doMatch(_value: Any): Boolean;
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
// Purpose:		This should be where the matching is done
//
vars

begin
	return ((_value.Decimal &gt;= self.lowerValue) and (_value.Decimal &lt;= self.searchValue));

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLowerValue" id="e9966e12-515d-467f-8ff4-e11dcdf74430">
        <source>getLowerValue(_prop: CM_QueryProperty): String;
// ---------------------------------------------------------------------------
//	Created:	24 November 2009 cnwjo3
//
//	Purpose:	get the lower value
//
vars

begin
	return _prop.translateToDisplayValue(self.lowerValue);
end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueRange" id="7cf298b5-7e9e-4d31-bb6b-2d51bbe64660">
        <source>getSearchValueRange(_prop : CM_QueryProperty): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	jlier1	Initial creation 53515

*/

vars
	weightRange : CM_WeightRange;
	measure : CM_MeasurementType;
	measureStr 	: String;
	pos : Integer;
begin
	pos := _prop.propertyName.pos(CN_UNDERSCORE, 1);
	if pos = null then
		return null;
	endif;
	
	measureStr := _prop.propertyName[1:pos-1];
	measure:=app.myRoot.allMeasurementTypesByShortName[measureStr];
	if measure &lt;&gt; null then
		weightRange:=app.myRoot.allWeightRanges[measure,self.searchValue.Integer];
	endif;
	
	return weightRange;
	

epilog

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="c5be06fb-bd97-45d1-91b9-c349fddd8b05">
        <source>getSearchValueStr(_prop: CM_QueryProperty): String;
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
// Purpose:		set the search value of CM_QueryDecimalOperator
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 06/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	measure	: String;																						// PAR #31155

begin
	//return _prop.translateToDisplayValue(self.searchValue);
	//this may not be the right place for it but....
	//yep.  Weight is a Decimal but should always be displayed as an Integer.  Cool!
	if CM_QDecimalProperty.hasInstance(_prop) and _prop.CM_QDecimalProperty.myMeasurementType &lt;&gt; null then	// PAR #31155
		measure := _prop.CM_QDecimalProperty.myMeasurementType.shortName;									// PAR #31155
	endif;																									// PAR #31155
	if measure &lt;&gt; null then																					// PAR #31155
		return lowerValue.Integer.String &amp; "-" &amp; searchValue.Integer.String &amp; Space &amp; measure;				// PAR #31155
	else																									// PAR #31155
		return lowerValue.Integer.String &amp; "-" &amp; searchValue.Integer.String;
	endif;																									// PAR #31155
end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidForRT" id="51b9dc58-b99a-47cb-9a7d-29d4c6802785">
        <source>isValidForRT(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLowerValue" id="883e4896-e82c-49c0-9a26-0ad4122c1791">
        <updating/>
        <source>setLowerValue(_value: Any) updating;
// ---------------------------------------------------------------------------
// Created:		24 novemeber 2003 cnwjo3
//
// Purpose:     set the lower value for range
//
vars
	stringValue		: String;
	decimalValue	: Decimal[14,4];
begin
	if _value &lt;&gt; null then 
		stringValue := _value.String;
		if stringValue.isDecimal then
			decimalValue := stringValue.Decimal;
		else
			app.raiseCMException1(VB_INVALID_NUM, stringValue, null, null);
		endif;		
	endif;
	
	self.lowerValue := decimalValue;
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="72afb1c4-f735-4a76-99da-9e319eb378a3">
        <updating/>
        <source>setSearchValue(_value: Any) updating;
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
vars
	stringValue		: String;
	decimalValue	: Decimal[14,4];
begin
	if _value &lt;&gt; null then
		stringValue := _value.CM_WeightRange.value.String;
		if stringValue.isDecimal then
			decimalValue := stringValue.Decimal;
			self.lowerValue := _value.CM_WeightRange.lower; //epr TFS 47132 - avoid 1086 exception
		else
			app.raiseCMException1(VB_INVALID_NUM, stringValue, null, null);
		endif;		
	endif;
	
	self.searchValue := decimalValue;
	
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
