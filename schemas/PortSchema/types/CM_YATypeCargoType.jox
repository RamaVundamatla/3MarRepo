    <JadeMethod name="getObjects" id="b0280901-905d-4989-a46d-158c448e6f1e">
        <source>getObjects(objects: ObjectLongNameDict input);
//03 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
//14/10/2022 		navhl20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
vars
	cargoType: CM_CargoType;
	bolType : CM_BOLType;	// 14.10.2022 navhl20 TFS 53862
begin
	foreach cargoType in app.myRoot.allCargoTypesById do
		objects[cargoType.getYAIdentifier] := cargoType;
	endforeach;
	//Start 14.10.2022 navhl20 TFS 53862
	foreach bolType in app.myRoot.allBOLTypes do
		if not objects.includesKey(bolType.getYAIdentifier) then
			objects[bolType.getYAIdentifier] := bolType;
		endif;
	endforeach;
	//End 14.10.2022 navhl20 TFS 53862
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
