begin
	self.myEditForm	:=	pTheEditForm;
end;</source>
        <Parameter name="pTheEditForm" type="JSSLKEditLicenseForm"/>
    </JadeMethod>
    <JadeMethod name="setExternalInterface" id="64357bf9-33d0-4a78-9ffa-3a6d3a96f844">
        <updating/>
        <source>setExternalInterface(pTheExternalInterfaceObject:Object) updating;
// --------------------------------------------------------------------------------
// Created:		14 January 2003 by cnwdad1
//
// Purpose:		Sets a reference to the external interface object that was created
//				in the application schema to talk to this schema.
//
// Parameters:	pTheExternalInterfaceObject - The application schema's interface object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myExternalInterface &lt;&gt; pTheExternalInterfaceObject then
		self.myExternalInterface	:=	pTheExternalInterfaceObject;
	endif;
end;</source>
        <Parameter name="pTheExternalInterfaceObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setMaintenanceForm" id="dbe45410-2f8f-4299-887f-8431b5feae93">
        <updating/>
        <source>setMaintenanceForm(pTheMaintenanceForm:JSSLKLicenseMaintenanceForm) updating;
// --------------------------------------------------------------------------------
// Created:		26 March 2003 by cnwdad2
//
// Purpose:		Sets the current License Key maintenance form.  This form will be
//				unloaded if this interface is destroyed.
