    <JadeMethod name="b_back_click" id="6ab43134-44f1-4d23-bdab-1c1896a1c469">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>b_back_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	conkc1	Initial creation

*/

vars

begin
	v_objectNumber := v_objectNumber - 1;
	if v_objectNumber &lt; 0 then
		v_objectNumber := 0;
	endif;
	colourBackground;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
