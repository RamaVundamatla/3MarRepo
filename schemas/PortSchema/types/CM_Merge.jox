epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveAmount" id="ceeb3f80-1043-43c2-b997-a080d6e51dc3">
        <source>getMoveAmount() : String protected;
/*

for Breakbulk split/merge is by quantity for Bulk it is by weight


Date		Who		Reason
31 January 2014	cnwer1	Initial creation PAR

*/

vars
	moveQuantity : String;
	measure		: CM_MeasurementType;
	unit,moveAmount		: String;
	converted	: String;
	ct : CM_CargoType;
begin
	if self.action = self.ACTION_PARENT then
		if self.myTrackedItem &lt;&gt; null then
			ct:=self.myTrackedItem.myCargoType;
			if 	ct.isBulkMulti then
				if ct.isTrackByWeight then
					if ct.myWeightMeasurementType &lt;&gt; null then
						unit :=  ct.myWeightMeasurementType.shortName;
						moveAmount:=app.convertMeasurementForDisplay(unit, self.oldWeight - self.weight);
						moveQuantity:= moveAmount &amp; Space &amp; unit;
					endif;
				else
					if ct.myVolumeMeasurementType &lt;&gt; null then
						unit :=  ct.myVolumeMeasurementType.shortName;
						moveAmount:=app.convertMeasurementForDisplay(unit, self.oldVolume - self.volume);
						moveQuantity:= moveAmount &amp; Space &amp; unit;
					endif;
				endif;
				
			else
				moveQuantity:=(self.oldQuantity - self.quantity).asStringJMT;	
			endif;
		endif;
	elseif self.action = self.ACTION_CHILD then
		if self.myOtherTrackedItem &lt;&gt; null then
			ct:=self.myOtherTrackedItem.myCargoType;
			if ct.isBulkMulti then
				if ct.isTrackByWeight then
					if ct.myWeightMeasurementType &lt;&gt; null then
						unit :=  ct.myWeightMeasurementType.shortName;
						moveAmount:=app.convertMeasurementForDisplay(unit, self.weight - self.oldWeight);
						moveQuantity:= moveAmount &amp; Space &amp; unit;
					endif;
				else
					if ct.myVolumeMeasurementType &lt;&gt; null then
						unit :=  ct.myVolumeMeasurementType.shortName;
						moveAmount:=app.convertMeasurementForDisplay(unit, self.volume - self.oldVolume);
						moveQuantity:= moveAmount &amp; Space &amp; unit;
					endif;
				endif;
			else
				moveQuantity:= (self.quantity - self.oldQuantity).asStringJMT;
			endif;
		endif;
	endif;
	
	return moveQuantity;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNewAmount" id="225d33d8-ba81-49e9-974a-ed911e030a39">
        <source>getNewAmount() : String protected;
/*

Date		Who		Reason
21 March 2014	cnwer1	Initial creation PAR

*/

vars
	unit, newAmount : String;
	ct : CM_CargoType;
begin

	if self.myTrackedItem &lt;&gt; null then
		ct:=self.myTrackedItem.myCargoType;
		if ct.isBulkMulti then
			if ct.isTrackByWeight then
				if ct.myWeightMeasurementType &lt;&gt; null then
					unit :=  ct.myWeightMeasurementType.shortName;
					newAmount:=app.convertMeasurementForDisplay(unit, self.weight);
					return newAmount &amp; Space &amp; unit;
				endif;
			else
				if ct.myVolumeMeasurementType &lt;&gt; null then
					unit :=  ct.myVolumeMeasurementType.shortName;
					newAmount:=app.convertMeasurementForDisplay(unit, self.volume);
					return newAmount &amp; Space &amp; unit;
				endif;
			endif;
		endif;	
	endif;
	
	return self.quantity.asStringJMT;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOldAmount" id="34cfed8e-0946-425e-888a-45bcfdf0c374">
        <source>getOldAmount() : String protected;
/*

Date		Who		Reason
31 January 2014	cnwer1	Initial creation PAR

*/

vars
	unit, oldAmount : String;
	ct : CM_CargoType;
begin

	if self.myTrackedItem &lt;&gt; null then
		ct:=self.myTrackedItem.myCargoType;
		if ct.isBulkMulti then
			if ct.isTrackByWeight then
				if ct.myWeightMeasurementType &lt;&gt; null then
					unit :=  ct.myWeightMeasurementType.shortName;
					oldAmount:=app.convertMeasurementForDisplay(unit, self.oldWeight);
					return oldAmount &amp; Space &amp; unit;
				endif;
			else
				if ct.myVolumeMeasurementType &lt;&gt; null then
					unit :=  ct.myVolumeMeasurementType.shortName;
					oldAmount:=app.convertMeasurementForDisplay(unit, self.oldVolume);
					return oldAmount &amp; Space &amp; unit;
				endif;
			endif;
		endif;	
	endif;
	
	return self.oldQuantity.asStringJMT;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOtherMerge" id="17a2bc40-7881-4b0e-9f9e-6126d909cbfc">
        <source>getOtherMerge() : CM_Merge;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2013	cnwer1	Initial creation CCMS DPH 2274

*/

vars

begin
	if self.myChildMerge &lt;&gt; null then
		return self.myChildMerge;
	endif;
	
	if self.myParentMerge &lt;&gt; null then
		return self.myParentMerge;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Merge"/>
    </JadeMethod>
    <JadeMethod name="getOtherTrackedItem" id="d046d2f6-46ca-4caf-b1ad-dd3951a5b98b">
        <source>getOtherTrackedItem(): CM_TrackedItem;

// Created by cnwdvb1 on 01 November 2006
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	invalidTI		: Boolean;
	id				: String;
	otherTrackedItem	: CM_TrackedItem;
begin
	otherTrackedItem := self.myOtherTrackedItem;
	if otherTrackedItem &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, otherTrackedItem, invalidTI);
		// Dereference TI to check it is valid
		id := otherTrackedItem.id;
	endif;
	
	if invalidTI then
		return null;
	endif;

	return otherTrackedItem;
	
end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
