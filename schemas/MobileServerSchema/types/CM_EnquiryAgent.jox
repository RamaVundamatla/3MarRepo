<Class name="CM_EnquiryAgent" id="80867953-5d06-499a-a9ab-c914a8e0bd14">
    <superclass name="CM_Agent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="findAllAvailableQueues" id="4dd02ce6-95f1-4c31-92f0-b2ea63b1354b">
        <updating/>
        <source>findAllAvailableQueues(_queues : Collection input;
					   _mediator : CM_RadioTelemetryMediator input;
					   _passport : CM_Passport input) updating;

/*

Purpose:			Find all the queues for the machine associated to the passed in 
					mediator


Return Value:		_queues populated with the matches


Date		Who		Reason
11 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	
begin
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.initialiseTransaction();	
	
	app.myValRT.valFindAllAvailableQueues(_queues, _mediator);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	_passport.finaliseTransaction(TRXStatus_Committed);

	
epilog

end;</source>
        <Parameter name="_queues" type="Collection" usage="input"/>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findAllTrackedItems" id="3822faf0-0707-4109-a696-86816e68e1d3">
        <updating/>
        <source>findAllTrackedItems(_tiId : String;
				   _tiSet : CM_TISet input;
				   _lookOnsite,
				   _lookPrenotified : Boolean;
				   _reeferSearch : Boolean;				// CCMS 1007
				   _cargoType : Integer;	//02 Dec 2010	NDL Par 26417
				   _machine  : CM_Machine; // 6/1/14 epr par 31915
				   _passport : CM_Passport input) updating;

/*

Purpose:			Find all the containers matching the partial ID passed in


Return Value:		_tiSet populated with the matches


Date		Who		Reason
04 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
20 Nov 2009	cnwer1	CCCMS MES 1013 -needed to look at also prenoted cargo and sometimes just prenoted cargo
16 Dec 2009 cnwdap1	CCMS MES 1007 Allow for non-container reefers - new parameter to pass through to valFindAllTrackedItems
*/

vars
	
begin
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.initialiseTransaction();	
	
	//app.myValRT.valFindAllTrackedItems(_tiId, _tiSet,_lookOnsite,_lookPrenotified);				// CCMS 1007
	//app.myValRT.valFindAllTrackedItems(_tiId, _tiSet,_lookOnsite,_lookPrenotified, _reeferSearch);	// CCMS 1007
	app.myValRT.valFindAllTrackedItems(_tiId, _tiSet,_lookOnsite,_lookPrenotified, _reeferSearch, _cargoType,_machine); //02 Dec 2010	NDL Par 26417
	
	if _passport.hasErrors() then
		return;
	endif;
	
	_passport.finaliseTransaction(TRXStatus_Committed);

	
epilog

end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_lookOnsite" type="Boolean"/>
        <Parameter name="_lookPrenotified" type="Boolean"/>
        <Parameter name="_reeferSearch" type="Boolean"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getQueryDefinition" id="2cedb325-c866-41e1-a596-798b588575c3">
        <updating/>
        <source>getQueryDefinition( _dtoQueryDef: DTO_QueryDefinitionRT input; 
					_queryOid	: String; 
					_passport	: CM_Passport input ) updating;
// -------------------------------------------
// Created 02 May 2008 by cnwvu1
// -------------------------------------------

vars

begin

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.initialiseTransaction();	
	
	_dtoQueryDef.getQueryDefinition( _queryOid );
	
	if _passport.hasErrors() then
		return;
	endif;
	
	_passport.finaliseTransaction(TRXStatus_Committed);

end;
</source>
        <Parameter name="_dtoQueryDef" type="DTO_QueryDefinitionRT" usage="input"/>
        <Parameter name="_queryOid" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="queryRun" id="d1e2a470-55c4-4b22-a1e1-4c6c373e4ed4">
        <updating/>
        <source>queryRun(	_dtoQueryDef : DTO_QueryDefinitionRT; _dtoQueryResult : DTO_QueryResult input;
			_querySelectorOid : String; _passport : CM_Passport input ) updating;
// --------------------------------------------------------------------------------------------
// Created 08 May 2008 by cnwvu1
// --------------------------------------------------------------------------------------------

vars

begin

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.initialiseTransaction();	
	
	_dtoQueryResult.queryRun( _dtoQueryDef, _querySelectorOid );
	
	if _passport.hasErrors() then
		return;
	endif;
	
	_passport.finaliseTransaction(TRXStatus_Committed);

end;</source>
        <Parameter name="_dtoQueryDef" type="DTO_QueryDefinitionRT"/>
        <Parameter name="_dtoQueryResult" type="DTO_QueryResult" usage="input"/>
        <Parameter name="_querySelectorOid" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
