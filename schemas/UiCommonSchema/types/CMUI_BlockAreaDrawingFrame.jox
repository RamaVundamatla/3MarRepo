    <JadeMethod name="click" id="71711559-721b-41a0-9eea-c8894b50b88f">
        <updating/>
        <source>click(frame: Frame input) updating;
begin
	if self.myDrawer &lt;&gt; null then 

		self.myDrawer.doClick(self.firstMouseX, self.firstMouseY, self.isShift, self.isCtrl);
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dblClick" id="c80f318c-cbf3-4b46-83dc-378b2e308c2d">
        <controlMethod name="CMUI_GridAreaDrawingFrame::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dblClick(frame: Frame input) updating;
// Send the double click to the drawer for action
begin
	if self.myDrawer &lt;&gt; null then 
		self.myDrawer.doDblClick(self.firstMouseX, self.firstMouseY);
	endif;
end;
</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="dragDrop" id="561a8a23-feed-4e83-8dbc-0d7b81549bb6">
        <controlMethod name="Frame::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating, clientExecution;
// Something has been dropped on to this frame
begin
	if self.myDrawer &lt;&gt; null then 
		if frame = win and myDrawer.isSelectedLocationPixel(self.firstMouseX, self.firstMouseY) then
			// A location has been move in design mode
			self.myDrawer.doMove(self.firstMouseX, self.firstMouseY, x, y);
			self.endDrag();
		else
			self.myDrawer.doDragDrop(win, x, y);
		endif;
	endif;
end;
</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="b4e4aca1-c759-4db3-8475-4bee51bb1a8a">
        <updating/>
        <source>dragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
begin
	if state = Window.DragOver_Leave then
		self.endDrag();
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="endDrag" id="c88e531b-dc82-4946-8ef7-cf58bcf3736a">
        <updating/>
        <source>endDrag() protected, updating;
//19 June 2008	cnwdw1	
//
begin
	self.dragMode := DragMode_None;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getLabelContentsType" id="5fe2a425-0cbb-47df-8ff5-69ff38c81c9b">
        <source>getLabelContentsType():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2020	jlgndl1	Initial creation	TFS 49775

*/

vars

	form : Form;
	prop : Property;

begin

	if self.myScrollableFrame &lt;&gt; null then
		form := self.myScrollableFrame.form;
		if form &lt;&gt; null then
			prop := form.class.getPropertyInHTree("labelContents");
			if prop &lt;&gt; null and prop.type = Integer then
				return form.getPropertyValue("labelContents").Integer;
			endif;
		endif;
	endif;

	return 0;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isDrag" id="76de5508-ab8f-4165-929d-f40beced79f1">
        <source>isDrag() : Boolean protected;
//19 June 2008	cnwdw1	
// Are we in drag mode?
begin
	return self.dragMode = Window.DragMode_Drag;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="11015c40-75c0-405a-896e-3c019773756d">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
begin
	self.firstMouseX := x.Integer;
	self.firstMouseY := y.Integer;
	self.isShift := shift.bitAnd(1) &lt;&gt; 0;
	self.isCtrl := shift.bitAnd(2) &lt;&gt; 0;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="2ed9a03c-54b2-42a3-928f-a16e02625550">
        <updating/>
        <source>mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
begin
	if button = Window.MouseButton_Left and not self.isDrag() then
		if myDrawer &lt;&gt; null and myDrawer.isSelectedLocationPixel(x, y) then
			self.startDrag();
		endif;
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="165e72d3-9de5-45fd-8728-08e5862bab70">
        <updating/>
        <source>mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
vars
begin
	self.lastMouseX := x.Integer;
	self.lastMouseY := y.Integer;
	
	self.myDrawer.handleMouseUp(frame,button,shift, x,y);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="resize" id="4766f651-bbac-4e5c-b602-86aed21dc017">
        <updating/>
        <source>resize(x,  y : Integer) updating;
// Resize the drawing frame
begin
	if myScrollableFrame &lt;&gt; null then
		self.width := x;
		self.height := y;
		myScrollableFrame.resizeScrollingFrame(x, y);
		myScrollableFrame.repositionAfterResize();
		myScrollableFrame.repositionScrollBars();
	endif;
end;
</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setBlockAreaDrawer" id="0f4a14d9-0f54-445a-a20a-c05cdb3adcb2">
        <updating/>
        <source>setBlockAreaDrawer(blockAreaDrawer : CMUI_BlockAreaDrawer) updating;
// Inject the drawer so we can notify about interesting events
begin
	self.myDrawer := blockAreaDrawer;
end;
</source>
        <Parameter name="blockAreaDrawer" type="CMUI_BlockAreaDrawer"/>
    </JadeMethod>
    <JadeMethod name="setScrollableFrame" id="057c9d40-8a14-40d5-8b19-362dadd6ebab">
        <updating/>
        <source>setScrollableFrame(scrollableFrame : CMUI_BlockAreaScrollableFrame) updating;
begin
	self.myScrollableFrame := scrollableFrame;
end;
</source>
        <Parameter name="scrollableFrame" type="CMUI_BlockAreaScrollableFrame"/>
    </JadeMethod>
    <JadeMethod name="startDrag" id="8a70cec7-8342-47aa-85d8-91241e48d2f6">
        <updating/>
        <source>startDrag() protected, updating;
//19 June 2008	cnwdw1	
//
begin
	self.dragMode := DragMode_Drag;
	self.dragCursor :=  self.form.CM_BaseForm.picMvInstantCur.picture;
end;</source>
        <access>protected</access>
    </JadeMethod>
