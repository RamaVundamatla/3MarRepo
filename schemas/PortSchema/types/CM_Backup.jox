    <JadeMethod name="getDisplayStatus" id="a443e43e-e502-4b84-a173-04e793b2bd0b">
        <source>getDisplayStatus(_status : Integer) : String;
//
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
//
//26 Nov 2013	cnwrs1	Par 33072 backup fails after Jade major release
vars
	str : String;
begin
	if _status = BackupStatus_Completed then
		str := "Completed";
	elseif _status = BackupStatus_Idle then
		str := "Idle";
	elseif _status = BackupStatus_Processing then
		str := "Processing";
	elseif _status = BackupStatus_Abort then
		str := "Abort";
	elseif _status = BackupStatus_Actioned then
		str := "Actioned";
	elseif _status = BackupStatus_Unknown then
		str := "Unknown";
	elseif _status = BackupStatus_JournalNotFound then
		str := "Journal Not found";
	elseif _status = BackupStatus_Failed then
		str := "Failed";
	elseif _status = BackupStatus_Restarted then
		str := "Restarted";
	elseif _status = BackupStatus_JournalVersionErr then
			str := "Journal Wrong Version";
	else
		str := "Invalid";
	endif;
	return str;
end;
</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
