    <JadeMethod name="doNoteHandlingObject" id="58ca4ddb-bacc-4598-8b79-67e5f8fd15ac">
        <updating/>
        <source>doNoteHandlingObject(_object: CMIF_NotificationRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Apr 2025	navnk30	JIRA 34157: MTN | Rail Operations - Handle Notifications

*/

vars
	noteEvent	: Integer;
	noteObj		: CM_Object;
begin
	noteEvent := _object.eventType;
	noteObj := _object.myObject.CM_Object;
	
	if noteEvent = Object_Create_Event or
			noteEvent = Object_Update_Event or
			noteEvent = Object_Delete_Event or
			noteEvent = Any_System_Event then
		self.handleSysNotification(noteObj, noteEvent);
	else
		self.handleUserNotification(noteObj, noteEvent);
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CMIF_NotificationRecord"/>
    </JadeMethod>
