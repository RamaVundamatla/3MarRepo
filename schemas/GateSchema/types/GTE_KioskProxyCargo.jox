    <JadeMethod name="delete" id="31ba7d00-607a-4a34-928a-1aa5cd7fdafe">
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 September 2006 by cnwdad1:2
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myTIInterface &lt;&gt; null and global.isValidObject(self.myTIInterface) then
		delete self.myTIInterface;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getAllIds" id="94d703d0-4a0d-45f6-8541-1560c3bf1d74">
        <source>getAllIds():StringArray;
// --------------------------------------------------------------------------------
// Created:		22 August 2006 by cnwdad1
//
// Purpose:		Returns all of the receiver's Cargo Ids.
//
// Parameters:	None
//
// Returns:		An array of the Cargo Ids.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isBulkRelease() then
		return self.myTIInterface.CMIF_ReleaseByType.ids;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="id" id="3a01877d-0d74-4824-ac53-7eed038895b2">
        <source>id():String;
// --------------------------------------------------------------------------------
// Created:		14 August 2006 by cnwdad1
//
// Purpose:		Returns the receiver's Cargo Id.
//
// Parameters:	None
//
// Returns:		The Cargo Id.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isTrackedItem() then
		return self.myCargoItem.CM_TrackedItem.id;
	elseif self.isBulkRelease() then
		return self.myCargoItem.CM_BulkRelease.code;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isBulkRelease" id="6995295b-b383-4c2a-92ee-a92c3fa92f6a">
        <source>isBulkRelease():Boolean;
// --------------------------------------------------------------------------------
// Created:		22 August 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is for a
//				Bulk Release.
//
// Parameters:	None
//
// Returns:		True if the receiver is a Bulk Release, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myCargoItem.isKindOf(CM_BulkRelease);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isContainer" id="fcb71cab-9481-4a81-8fe8-02c0c5eea771">
        <source>isContainer():Boolean;
// --------------------------------------------------------------------------------
// Created:		22 August 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is for a
//				container.
//
// Parameters:	None
//
// Returns:		True if the receiver is for a container, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isTrackedItem() then
		return self.myCargoItem.isKindOf(CM_Container);
	else
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForReceival" id="80c022a5-2486-4ddc-9365-e4f831fda05e">
        <source>isForReceival():Boolean;
// --------------------------------------------------------------------------------
// Created:		26 September 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is for a
//				Receival.
//
// Parameters:	None
//
// Returns:		True if the receiver is for a Receival, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.myReceivalLoad &lt;&gt; null);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForRelease" id="a378f165-a10e-40af-b2c2-20c9753ddfb3">
        <source>isForRelease():Boolean;
// --------------------------------------------------------------------------------
// Created:		26 September 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is for a
//				Release.
//
// Parameters:	None
//
// Returns:		True if the receiver is for a Release, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.myReleaseLoad &lt;&gt; null);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTrackedItem" id="243c3e44-63c4-4947-b687-8ebe17436855">
        <source>isTrackedItem():Boolean;
// --------------------------------------------------------------------------------
// Created:		22 August 2006 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is for a
//				Tracked Item.
//
// Parameters:	None
//
// Returns:		True if the receiver is a Tracked Item, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myCargoItem.isKindOf(CM_TrackedItem);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCargoConfig" id="a1bd295c-cad7-417c-9351-ffa09c566285">
        <updating/>
        <source>setCargoConfig(_isDoorsBack:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		18 August 2006 by cnwdad1
//
// Purpose:		Sets the cargo location, and the position of the doors.
//
// Parameters:	_isDoorsBack - True if the cargo doors are at the rear.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isDoorsBack	:=	_isDoorsBack;
end;</source>
        <Parameter name="_isDoorsBack" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDoorsDirection" id="67c9cb4c-fd4b-4144-a945-55b88a33a594">
        <source>setDoorsDirection(_objReleaseReceival: CMIF_TIObject);
/* ---------------------------------------------------------------------------
Created:	13 October 2010	by cnwvu1

Purpose:	#25789. When bulk release, it needs doors direction to be set the same way 
			as releasing or receiving containers
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	tiInterfaceObj	: CMIF_TIObject;
	releaseById		: CMIF_ReleaseById;
	releaseByType	: CMIF_ReleaseByType;
	trackedItemObj	: CM_TrackedItem;
	receivalObj		: CMIF_Receival;
	releaseObj		: CMIF_ReleaseById;
	
begin

	//------------------------------------------------------------------------------------------------
	//										BULK RELEASE
	//------------------------------------------------------------------------------------------------
	if self.isBulkRelease() then
	
		tiInterfaceObj	:=	self.myTIInterface;
		
		if tiInterfaceObj.isKindOf(CMIF_ReleaseByType) then
		
			releaseByType := tiInterfaceObj.CMIF_ReleaseByType;
			if releaseByType.myCargoType.id &lt;&gt; TI_CargoType_Container then
				releaseByType.doorsDirection	:=	TI_DOORSDIRN_NULL;
			elseif self.isDoorsBack then
				releaseByType.doorsDirection	:=	TI_DOORSDIRN_AFT;
			else
				releaseByType.doorsDirection	:=	TI_DOORSDIRN_FWD;
			endif;
			
		elseif tiInterfaceObj.isKindOf(CMIF_ReleaseById) then
		
			releaseById := tiInterfaceObj.CMIF_ReleaseById;
			if releaseById.cargoType &lt;&gt; TI_CargoType_Container then
				releaseById.doorsDirection	:=	TI_DOORSDIRN_NULL;
			elseif self.isDoorsBack then
				releaseById.doorsDirection	:=	TI_DOORSDIRN_AFT;
			else
				releaseById.doorsDirection	:=	TI_DOORSDIRN_FWD;
			endif;

		endif;

	//------------------------------------------------------------------------------------------------
	//								CONTAINER - RELEASE OR RECEIVAL
	//------------------------------------------------------------------------------------------------
	else
	
		trackedItemObj := self.myCargoItem.CM_TrackedItem;


		if _objReleaseReceival.isKindOf(CMIF_Receival) then
			
			receivalObj := _objReleaseReceival.CMIF_Receival;
			if trackedItemObj.cargoType &lt;&gt; TI_CargoType_Container then
				receivalObj.doorsDirection	:=	TI_DOORSDIRN_NULL;
			elseif self.isDoorsBack then
				receivalObj.doorsDirection	:=	TI_DOORSDIRN_AFT;
			else
				receivalObj.doorsDirection	:=	TI_DOORSDIRN_FWD;
			endif;
			
		else
		
			releaseObj := _objReleaseReceival.CMIF_ReleaseById;
			if trackedItemObj.cargoType &lt;&gt; TI_CargoType_Container then
				releaseObj.doorsDirection := TI_DOORSDIRN_NULL;
			elseif self.isDoorsBack then
				releaseObj.doorsDirection := TI_DOORSDIRN_AFT;
			else
				releaseObj.doorsDirection := TI_DOORSDIRN_FWD;
			endif;
			
		endif;
	
	endif;	
			
			
end;</source>
        <Parameter name="_objReleaseReceival" type="CMIF_TIObject"/>
    </JadeMethod>
    <JadeMethod name="setIsConfirmed" id="4de1d17a-89f5-4818-b7d6-8b1ba885ee95">
        <updating/>
        <source>setIsConfirmed() updating;
// --------------------------------------------------------------------------------
// Created:		26 September 2006 by cnwdad1
//
// Purpose:		Updates the receiver "is confirmed" flag to true.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isConfirmed	:=	true;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateMe" id="1d95fcc4-e66b-4dbe-806f-6dcb9c73fa1a">
        <updating/>
        <source>updateMe(	_count:Integer;
			_cargoItemObj:CM_Object;
			_tiInterfaceObj:CMIF_TIObject;
			_proxyLoadObj:GTE_KioskProxyLoad;
			_totalWeight: Decimal;
			_isDoorsBack:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		11 August 2006 by cnwdad1
//
// Purpose:		Updates the receiver's property values.
//
// Parameters:	_count - The index of the receiver.
//				_cargoItemObj - A reference to the actual cargo item object.
//				_tiInterfaceObj - A reference to a TI Interface object (for Bulk Releases).
//				_proxyLoadObj - A reference to the receiver's proxy load object.
//				_totalWeight - The total weight of the cargo item - this may have
//					been amended by the driver.
//				_isDoorsBack - True if the cargo doors are at the rear.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30/11/2006	cnwdad1		PAR #13062 - added check for 40's for Bulk Releases.
//
// 25/07/2007	cnwdad1		CCMS #1493 - Added the weight of the cargo.
// --------------------------------------------------------------------------------
vars
	errorArrayObj	: CnEcArray;
	ti : CM_TrackedItem;
begin
	self.count			:=	_count;
	self.totalWeight	:=	_totalWeight;
	self.myCargoItem	:=	_cargoItemObj;
	
	if _cargoItemObj.isKindOf(CM_TrackedItem) then
		self.myConsignee	:=	_cargoItemObj.CM_TrackedItem.myConsignee;
		
		if _proxyLoadObj.isReceivalItem(_cargoItemObj.CM_TrackedItem) then
			self.myReceivalLoad	:=	_proxyLoadObj;
		elseif _proxyLoadObj.isReleaseItem(_cargoItemObj.CM_TrackedItem) then
			self.myReleaseLoad	:=	_proxyLoadObj;
		endif;
		
	elseif _cargoItemObj.isKindOf(CM_BulkRelease) then
		if self.myTIInterface &lt;&gt; null then
			delete self.myTIInterface;
		endif;
		self.myTIInterface	:=	_tiInterfaceObj;
		self.myReleaseLoad	:=	_proxyLoadObj;
	else
		create errorArrayObj transient;
		errorArrayObj.addString("Object: " &amp; _cargoItemObj.String);
		errorArrayObj.addString("Vehicle: " &amp; _proxyLoadObj.regoNumber);
		errorArrayObj.addString("Carrier: " &amp; _proxyLoadObj.myCarrier.code);
		errorArrayObj.addString("Pin #: " &amp; _proxyLoadObj.pinNumber);
		app.doRaiseAlertForKiosk("Kiosk error - Invalid cargo type for Kiosk (" &amp; _cargoItemObj.String &amp; ")", errorArrayObj);
	endif;
	
	self.isDoorsBack	:=	_isDoorsBack;
	
	if _cargoItemObj.isKindOf(CM_TrackedItem) then
		self.isForty	:=	_cargoItemObj.CM_TrackedItem.isAttributeTrue(TI_Attrib_IsForty);
	elseif _cargoItemObj.isKindOf(CM_BulkRelease) then
		if _tiInterfaceObj.isKindOf(CMIF_ReleaseByType) then  //cnwjo3 par 19613
			self.isForty	:= _tiInterfaceObj.CMIF_ReleaseByType.isForty();
		elseif _tiInterfaceObj.isKindOf(CMIF_ReleaseById) then  //cnwjo3 par 19613
			ti := _tiInterfaceObj.myTerminal.lookupTrackedItem(_tiInterfaceObj.CMIF_ReleaseById.id,_tiInterfaceObj.CMIF_ReleaseById.cargoType,null,null,null);
			if ti &lt;&gt; null then	//19 May 2020	NDL	TFS 49167
				self.isForty	:= ti.isForty();
			endif;
		else
			self.isForty	:=	_cargoItemObj.CM_BulkRelease.isForty();
		endif;
	else
		self.isForty	:=	false;
	endif;
epilog
	delete errorArrayObj;
end;</source>
        <Parameter name="_count" type="Integer"/>
        <Parameter name="_cargoItemObj" type="CM_Object"/>
        <Parameter name="_tiInterfaceObj" type="CMIF_TIObject"/>
        <Parameter name="_proxyLoadObj" type="GTE_KioskProxyLoad"/>
        <Parameter name="_totalWeight" type="Decimal"/>
        <Parameter name="_isDoorsBack" type="Boolean"/>
    </JadeMethod>
</Class>
