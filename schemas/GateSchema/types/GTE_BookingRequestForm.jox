    <JadeMethod name="sysNotify" id="545865d9-1f6d-478f-8581-85b6e8f3d648">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 February 2009	cnwrd1	Initial creation
24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/


vars

begin
//myCurrentBookingRef

		if eventType = Object_Update_Event and theObject = self.myCurrentBookingRef then
				if not hideUpdateMessage then
					app.msgBox('Booking Screen: Another user has updated the Booking you currently have selected.' &amp; CrLf &amp;
							'The Booking must now be re-loaded.', 'Booking updated', MsgBox_Exclamation_Mark_Icon);
				endif;
				
				self.loadBooking();
				self.loadBookingItemTable();
				if isRoll then
					self.unloadForm;
				endif;
		elseif eventType = Object_Delete_Event and theObject = self.myCurrentBookingRef then
			app.msgBox('Another user has deleted the Booking you are currently editing. The editing must now be cancelled','Booking deleted by another user.',MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			self.unloadForm();
		endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblBookingItemsDoubleClick" id="cc3983bc-b3f5-4a9f-b977-581c522a7e29">
        <updating/>
        <source>tblBookingItemsDoubleClick(table: Table input) updating;
//-----------------------------------------
//
// Created : by cnwaer1 01 September 2008
//-----------------------------------------
// 11/03/2010	cnwcs5	par 22605 - view permission
vars
	theRow	: Integer;
	//brItem : CM_BRefItemContainer;  //cnwjo3 19840
	brItem : CM_BookingRefItem;
begin
	if not self.btnEditDetail.enabled then	// 11/03/2010 cnwcs5 par 22605
		return;								// 11/03/2010 cnwcs5 par 22605
	endif;									// 11/03/2010 cnwcs5 par 22605
	
	theRow := table.row;
	
	if theRow &lt;= 0 then
		return;
	endif;
	
	if theRow = 1 then
		self.tblBookingItemsResort();
	else
		//brItem := self.tblBookingItems.accessRow(theRow).itemObject.CM_BRefItemContainer;  //cnwjo3 19840
		brItem := self.tblBookingItems.accessRow(theRow).itemObject.CM_BookingRefItem;
		self.doEditBookingRefItem(brItem,false);
	endif;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblBookingItemsResort" id="a4e9aa6f-8fd2-4cbc-8ca5-51d47e0a129d">
        <source>tblBookingItemsResort();
//-----------------------------------------
//
// Created : by cnwaer1 01 September 2008
//-----------------------------------------
vars
	idx,
	startRow,
	endRow,
	sortColNo	: Integer;
	sortColName	: String;
	descending	: Boolean;	
begin
//	tblBookingItems;

	sortColNo := self.tblBookingItems.column;
	
	if sortColNo &lt;= 0
	or sortColNo &gt; self.tblBookingItems.columns then
		return;
	endif;
	
	if self.tblBookingItems.allTblDataColPropertyNames.size &gt;= sortColNo then	
		// look in the data table collection
		sortColName := tblBookingItems.allTblDataColPropertyNames[sortColNo];
	endif;

	if sortColName = null then
		app.msgBox(app.getErrorString(Not_Able_To_Sort_By_Column), app.getErrorString(Info), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	self.tblBookingItems.resortTableByColumn(sortColNo);
	
	startRow := self.tblBookingItems.fixedRows + 1;
	endRow	:= self.tblBookingItems.rows;
	foreach idx in startRow to endRow do
		if (idx mod 2 = 0) then
			self.tblBookingItems.accessRow(idx).backColor := self.colorRow1;
		else
			self.tblBookingItems.accessRow(idx).backColor := self.colorRow2;
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="tblBookingItems_click" id="fb8729c4-9a57-4cc9-b1e7-10c5f4d767ce">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblBookingItems_click(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2009	cnwml2	Initial creation			//+cnwml2 PAR19782 CCMS SFW 1079
11/03/2010	cnwcs5	par 22605 - Booking Reserve permission
*/

vars

begin
	if tblBookingItems.allSelectedObjects.size &gt; 0 then													//+cnwml2 PAR20380
		if tblBookingItems.accessedRow.itemObject &lt;&gt; null then											//+cnwml2 PAR19848 CCMS SFW 1079
			if tblBookingItems.accessedRow.itemObject.CM_BookingRefItem.cargoType = 1 and
				tblBookingItems.accessedRow.itemObject.CM_BookingRefItem.getResDetailMaxToRelease &gt; 0  then	
				self.btnReserve.enabled := self.canReserve and
									self.canUpdate and	
									(self.canUpdateNonPendingBooking or
									(self.myCurrentBookingRef = null or
										self.myCurrentBookingRef.status = BOOKING_REF_PENDING));	// 11/03/2010 cnwcs5 par 22605
			else
				self.btnReserve.enabled := false;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
