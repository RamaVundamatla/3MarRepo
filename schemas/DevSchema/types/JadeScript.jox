begin
		app.initialize();
	app.myPassport.setMyUserFromCode("JLIER1");
	
	terminal:=CM_Root.firstInstance.allTerminals["JBL"];
	app.myPassport.setMyTerminal(terminal);
	
	wagon:="12082.265558".asOid.CM_Wagon;
	
	create tiA transient;
	wagon.getTIs(tiA,REAL_MODE);
	
	tiA.inspectModal;
	delete tiA;
	return;
	
	lc:="10370.1293352".asOid.CM_LocationsController;
	wagon :="12082.171452".asOid.CM_Wagon;
	foreach lc in wagon.allLocationsControllersArray do
		ti:=lc.allTrackedItems.first;
		if ti &lt;&gt; null and ti.myPrimaryActualLocation = lc then
			write lc.getFullIdTI(ti);
		else
			write lc.getFullId;
		endif;
	//	write ti;
		
		
	endforeach;
epilog

