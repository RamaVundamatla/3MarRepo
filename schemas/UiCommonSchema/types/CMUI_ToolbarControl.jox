    <JadeMethod name="getVisibleStatus" id="a30d1064-bbc6-4a43-8ca8-e3e7cd6276c3">
        <source>getVisibleStatus() : Boolean;
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.isHiddenForMoreToShow then
		// has been made invisible because no room
		return true;
	endif;

	return self.visible;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getWidth" id="4a366f5b-1cbd-4713-a985-fcbeb93b4aa5">
        <source>getWidth(_showCaptions : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:     20 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	return 0;

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideForMoreToShow" id="975b7e9f-8887-41b2-b0d3-e064b0a58a02">
        <updating/>
        <source>hideForMoreToShow() updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.visible then
		self.visible := false;
		// need to set this AFTER setting the above flag
		self.isHiddenForMoreToShow	:= true;
	endif;

end;</source>
    </JadeMethod>
