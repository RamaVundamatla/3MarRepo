    <JadeMethod name="createAlert" id="0fb5d4da-2a76-42aa-998c-8517a7bed10c">
        <source>createAlert(_severity : Integer;
			_details : String;
			_alertType : Integer; 
			_linkedTo : CM_Object): CM_SystemAlert;
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	caller responsible for app.commitAlert();

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	alert 		: CM_SystemAlert;
begin
	create alert transient;
	alert.setSeverity(_severity);
	alert.details:= _details;
	//epr tfs 1947 1/6/16
	if _details.containsOneOf(CrLf) then
		alert.addLogEntry(_details);
	endif;
	alert.setMySystemAlertType(app.myRoot.allSystemAlertTypes[_alertType]);
	alert.setLinkedTo(_linkedTo);
	alert.add;

	return alert;
end;


</source>
        <Parameter name="_severity" type="Integer"/>
        <Parameter name="_details" type="String"/>
        <Parameter name="_alertType" type="Integer"/>
        <Parameter name="_linkedTo" type="CM_Object"/>
        <ReturnType type="CM_SystemAlert"/>
    </JadeMethod>
    <JadeMethod name="createAlertsFromErrors" id="e3ad8aed-d49f-49db-b930-3fca6252046a">
        <source>createAlertsFromErrors(_alertType : Integer; _linkedTo : CM_Object);
/*
----------   ----------  --------------------------------------------------
Created:	06 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	error		: CM_Error;
begin
	
	foreach error in self.allErrors do	
		process.sleep(1);
		self.createAlert(SEVERE_ERROR, 
						error.errorCode.String &amp; ': ' &amp; error.text,
						_alertType,
						_linkedTo);
	endforeach;
	
	beginTransaction;
	app.commitAlert();
	commitTransaction;


end;





</source>
        <Parameter name="_alertType" type="Integer"/>
        <Parameter name="_linkedTo" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="createLogForStateChange" id="4aee185f-a6cd-4b54-80fc-2dbaaa97467e">
        <source>createLogForStateChange(_logType : String; _oId : String; _category : String; _oldValue : String io; _newValue : String io; _logLevel : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2025	naviv1	Initial creation

*/

vars
	testDesc : String;
begin
	testDesc	 := self.testDescription;

	app.writeLog('***'&amp; _logType &amp; '*** : '    &amp; ' TRX : '	  	 				&amp; testDesc
											   &amp; ' || Deferred Updates : '		&amp; self.useTIDictDeferUpdate.String
											   &amp; ' || Oid : '     		 		&amp; _oId
											   &amp; ' || Category : '     		 	&amp; _category
											   &amp; ' || Old : '					&amp; _oldValue 
											   &amp; ' || New : '	 				&amp; _newValue 
		, _logLevel);
		
	_oldValue := null;
	_newValue := null;
epilog

end;</source>
        <Parameter name="_logType" type="String"/>
        <Parameter name="_oId" type="String"/>
        <Parameter name="_category" type="String"/>
        <Parameter name="_oldValue" type="String" usage="io"/>
        <Parameter name="_newValue" type="String" usage="io"/>
        <Parameter name="_logLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="b05f45c8-534c-4ae0-847e-d5af5799993f">
        <updating/>
        <source>delete() updating;
/*
----------   ----------  --------------------------------------------------
Created:	12 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	delete self.myActivityCapture;
	delete self.allExtraInformation;
	delete self.myStateChangeController;	 //jlier1 TFS 61676 14/12/23
	self.allTrxPostActions.purge;
	self.allOpsViewRequests.purge;           //19.08.2020 cnwma1 TFS #49758
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteWarningsFor" id="527b2250-2ef0-4316-88f7-dfcd225eac3b">
        <updating/>
        <source>deleteWarningsFor( _warningsToIgnore : IntegerArray ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2011	cnwndl1	Initial creation	Par 28527

*/

vars

	error : CM_Error;
	warningsToDelete : CM_ErrorSet;

begin

	if _warningsToIgnore = null or _warningsToIgnore.isEmpty then
		// no warnings to ignore
		return;
	endif;
	
	if app.myPassport.allErrorWarnings.isEmpty then
		// no warnings in the passport
		return;
	endif;
	
	create warningsToDelete transient;
	foreach error in app.myPassport.allErrorWarnings do
		if error.warningOnly then
			if _warningsToIgnore.includes( error.errorCode ) then
				// this is one we want to ignore
				warningsToDelete.add( error );
			endif;
		endif;
	endforeach;

epilog

	if warningsToDelete &lt;&gt; null then
		if not warningsToDelete.isEmpty then
			warningsToDelete.purge;
		endif;
		delete warningsToDelete;
	endif;

end;</source>
        <Parameter name="_warningsToIgnore" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="doDeferredUpdates" id="675206d2-c356-4e3f-b04f-3d1256aa97cd">
        <updating/>
        <source>doDeferredUpdates() updating;
// ---------------------------------------------------------------------------
// Created:     27 June 2003 by cnwrs2
//
// Purpose:     Should be called just prior to the commit/epilog in
//				any trx's that use deferred updates.
//				This should be the only method that calls the deferred updates
//				methods so that they are always done in the same order to
//				avoid deadlocks.
// ---------------------------------------------------------------------------
//28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
//18 Oct 2024 navnk30	JIRA 19927: EUP - Error 1081 When using Rail Lander
vars

begin

	// ### TFS CR 63938 TASK 63942 02MAY2024 NAVAB1
	if self.noErrorsIgnored() then 
		self.updateEventTransForDeferUpd();
	endif;
	
	// ### TFS CR 64297 TASK 64298 28MAY2024 NAVAB1 - do TI locks first
	if self.noErrorsIgnored() then // PAR 17703
		self.updateTIsForDeferUpd();
	endif;
	
	if self.noErrorsIgnored() then // PAR 17703
		self.updateTITransForDeferUpd();
	endif;
	

	
	if self.noErrorsIgnored then				//28.05.2024 navma1 #64224
		self.updateFutureActorsForDeferUpd();
	endif;
	
	if self.noErrorsIgnored() then				//18.10.2024 navnk30 JIRA #19927
		self.updateWOTransForDeferUpd();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doLogoff" id="65efb7ea-6369-4afa-9916-f2b0368daef5">
        <updating/>
        <source>doLogoff() updating;
// ---------------------------------------------------------------------------
// Created:     09 October 2007 by cnwrs2
//
// Purpose:     
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 18/07/2025	navdap1		MTN-34430 MTN - Deferred Updates For Event Required For Login and Logout Trxs
// ---------------------------------------------------------------------------
vars
	localTrans	: Boolean;
begin

	if app.myTrxUA &lt;&gt; null then
		app.myTrxUA.trxUpdateLogoff(null,self);
	else
		// still want to record logoff transaction
		localTrans := (not process.isInTransactionState);
		if localTrans then
			beginTransaction;
		endif;
		self.recordLogoffEvent(null);		// MTN-34430
		if localTrans then
			commitTransaction;
		endif;
	endif;
epilog
	if localTrans and process.isInTransactionState then
		abortTransaction;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doPostUpdateAutoPlansFor" id="52ea096c-1556-4053-8001-87cf791a4175">
        <source>doPostUpdateAutoPlansFor( _ti : CM_TrackedItem input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2017	jlgndl1	Initial creation	TFS 7283

*/

vars

	edition : Integer;
	invalidObj : Boolean;

begin

	if _ti = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _ti, invalidObj );
	edition := _ti.edition;

	if self.allTisToAutoPlan.includes( _ti ) then
		self.allTisToAutoPlan.remove(_ti);
		if not invalidObj then
			_ti.createAutoMove(PLANNING_MODE);
		endif;
	endif;
	
	if self.allTisToAutoQueue.includes( _ti ) then
		self.allTisToAutoQueue.remove(_ti);
		if not invalidObj then
			_ti.createAutoMove(QUEUE_MODE);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTrxPostActions" id="5128d1d7-a660-4ab1-a19c-85dee2844a80">
        <updating/>
        <source>doTrxPostActions() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2018	jlger1	Initial creation 39166

*/

vars
	iter : Iterator;
	cmifPostTrx : CMIF_TrxPostAction;

begin
	
	self.isPostActionTrx:=true;
	iter:=self.allTrxPostActions.createIterator;
	while iter.next(cmifPostTrx) do
		cmifPostTrx.action(self);
	endwhile;
epilog
	delete iter;
	self.isPostActionTrx:=false;
	self.allTrxPostActions.purge;
end;</source>
    </JadeMethod>
    <JadeMethod name="dumpDetails" id="c95ef188-e9a4-49fa-8dd5-eecf35b8aab8">
        <source>dumpDetails(msg : String);
// ---------------------------------------------------------------------------
// Created:     04 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.writeStatement( 'CM_Passport Details - ' &amp; msg);
	app.writeStatement ('Status                = ' &amp; self.status.String);
	app.writeStatement ('allErrorWarnings.size = ' &amp; self.allErrorWarnings.size.String);
	app.writeStatement ('allErrors.size        = ' &amp; self.allErrors.size.String);
	app.writeStatement ('allWarnings.size      = ' &amp; self.allWarnings.size.String);
	app.writeStatement ('allSavedWarnings.size = ' &amp; self.allSavedWarnings.size.String);
	app.writeStatement ('numWarningsAtValid    = ' &amp; self.numWarningsAtValidationStage.String);
	app.writeStatement ('returnCode            = ' &amp; self.returnCode.String);
	app.writeStatement ('warningsAcknowledged  = ' &amp; self.warningsAcknowledged.String);
	app.writeStatement ('');

end;</source>
        <Parameter name="msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="dumpErrorWarnings" id="13a2b5fd-48b5-45b2-9ad9-11d526c36141">
        <source>dumpErrorWarnings();
// ---------------------------------------------------------------------------
// Created:     06 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	tmpErr	: CM_Error;
	
begin

	if self.allErrorWarnings.isEmpty then
		return;
	endif;
	
	app.writeStatement( '*** Dumping all error/warnings at ' &amp; app.actualTimeServer.String);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	foreach tmpErr in self.allErrorWarnings do
		if tmpErr.warningOnly then
			app.writeStatement( '    W-' &amp; tmpErr.errorCode.String &amp; '  &gt;&gt; ' &amp; tmpErr.text);
		else
			app.writeStatement('    E-' &amp; tmpErr.errorCode.String &amp; '  &gt;&gt; ' &amp; tmpErr.text);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="finaliseTransaction" id="a2496791-1afd-46ac-8ba2-904162608787">
        <updating/>
        <source>finaliseTransaction(_status : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/07/2020	jlgmd1		TFS 49690 STWR - Don't reset our deadlock priority if we're the process dealing with EDI Web Messages
// 07/12/2022 	navma1 		ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
// 07/03/2023	navmp20     Bug 56603: FR 53330/54104 | EUP - Unexpected warnings when changing Barges or Vessels
// 16/11/2023	navdap1		TFS 59458 EUP | EDI Specific Performance
// 09/04/2024	navdap1		TFS 63307 EUP | Performance - Cargo Enquiry Bulk Updates
// 28 May 2024  navma1		Bug 64224: MTN - DeadLocks Caused by Future Actors
// 18 Oct 2024	navnk30		JIRA 19927: EUP - Error 1081 When using Rail Lander
// 30 Oct 2024  navma1		MTN-14791 EUP | 53856 - New Scanning App - Unpack mode issue
// 17 Mar 2025  navma1 		MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
// ---------------------------------------------------------------------------
vars
	err	: CM_Error;	
begin

	err := self.allErrorWarnings.last;
	if err &lt;&gt; null then
		self.returnCode := err.errorCode;
	endif;

	if _status = TRXStatus_Committed then
		self.clearSavedWarnings();
	else
		self.saveWarnings();
	endif;

	if self.status = TRXStatus_InComplete then
		self.status := _status;
	endif;
	
	self.warningsAcknowledged := false;
	
	if self.warningsIgnored then	// PAR 23211 11/05/2010
		if (not app.isBackGroundApp) and (not app.isRTApp) then
			self.setWarningsIgnored(false);
		endif;
	endif;
	
	// if we are aborting these will not have been cleared out
	self.clearDeferUpdatesCollections();

	self.useTITransactionDeferUpdate 	:= false;
	self.useTIDictDeferUpdate 		 	:= false;
	self.useEventDeferUpdate 		 	:= false;  						 // ### TFS CR 63938 TASK 63942 02MAY2024 NAVAB1
	self.useOfflineFutureActorDeferUpd	:= false;						 //23.05.2024 navma1 #64224
	self.useOfflineFutureActorDeferDel	:= false;  						 //17.03.2025 navma1 #MTN-34120
	self.useWOTransactionDeferUpdate	:= false;						 //18.10.2024 navnk30 JIRA #19927
	
	app.myPassport.setPassportEdiMode(CM_Passport.EDI_MODE_NONE);		 //12.12.2022 navma1 #52499
	self.setIgnoreVesselChanges(false);      							 //07.03.2023 navmp20 TFS 56603
	self.allowProgressiveUpdates	    := false;						 // TFS 63307
	self.setContext(Context_Pass_Null);									 //30.10.2024 navma1 #MTN-14791
epilog
	// Reset our deadlock priority if we aren't a web app processing EDIs
	// TFS 59458 Also if we're not a BGP
	if not app.isWebApp and not app.isFromEDIviaWeb and not app.isBackGroundApp then
		process.setPersistentDeadlockPriority(0);
	endif;
end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllAccessibleUsers" id="339e658d-f71b-44b5-9906-fc8834c8b19b">
        <source>getAllAccessibleUsers(_allAccessibleUsers : CM_UserByCodeDict input);
// -------------------------------------------
// Created 14 December 2004 by cnwdvb1
// -------------------------------------------
vars

	dataController		: CM_DataAccessController;
	myOrganisation,
	organisation		: CM_Organisation;
	iter				: Iterator;
	user				: CM_User;
	foundOrganisation	: Boolean;

begin

	// Changed behaviour for Par 12113
	
	if _allAccessibleUsers = null then
		return;
	endif;
	
	user := app.myPassport.myUser;
	myOrganisation := user.myOrganisation;
	
	_allAccessibleUsers.clear();
	
	dataController := self.allDataAccessControllers[CM_Organisation.name];
	
	if dataController = null then
		//PAR14886.
		/*if myOrganisation &lt;&gt; null then
			myOrganisation.allUsers.copy(_allAccessibleUsers);
		else
			app.myRoot.allUsers.copy(_allAccessibleUsers);
		endif;*/
		app.myRoot.allUsers.copy(_allAccessibleUsers);
		return;
	endif;
	
	iter := dataController.allObjects.createIterator();
	
	while iter.next(organisation) do
		if organisation = myOrganisation then
			foundOrganisation := true;
		endif;
		organisation.allUsers.copy(_allAccessibleUsers);
	endwhile;
	
	if not foundOrganisation then
		myOrganisation.allUsers.copy(_allAccessibleUsers);
	endif;

epilog
	delete iter;	
end;</source>
        <Parameter name="_allAccessibleUsers" type="CM_UserByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllErrorsAndWarningsAsStr" id="724c2ba3-4eb8-4c79-860b-233df92b371a">
        <source>getAllErrorsAndWarningsAsStr():String;
// --------------------------------------------------------------------------------
// Created:		16 September 2008 by cnwdad1
//
// Purpose:		Returns a string of all errors and warnings, delimited by a CrLf.
//
// Parameters:	None
//
// Returns:		The CrLf delimited string, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorObj		: CM_Error;
	returnValue		: String;
	allErrorsObj	: CM_ErrorSet;
	
begin
	create allErrorsObj transient;
	
	if self.allErrors.cnEcIsNotEmpty() then
		self.allErrors.copy(allErrorsObj);
	endif;
	
	if self.allWarnings.cnEcIsNotEmpty() then
		self.allWarnings.copy(allErrorsObj);
	endif;
	
	if allErrorsObj.isEmpty() then
		return null;
	endif;
	
	foreach errorObj in allErrorsObj do
		if returnValue = null then
			returnValue	:=	errorObj.getDetailsAsString();
		else
			returnValue	:=	returnValue &amp; CrLf &amp; errorObj.getDetailsAsString();
		endif;
	endforeach;
	
	return returnValue;
epilog
	delete allErrorsObj;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllErrorsAndWarnsFullAsStr" id="07116fe9-bd36-4357-9d1d-057d8c99a3fb">
        <source>getAllErrorsAndWarnsFullAsStr():String;
vars
	errorObj		: CM_Error;
	returnValue		: String;
	allErrorsObj	: CM_ErrorSet;
	category	: ConstantCategory;
	constant	: Constant;	
begin
	create allErrorsObj transient;
	
	if self.allErrors.cnEcIsNotEmpty() then
		self.allErrors.copy(allErrorsObj);
	endif;
	
	if self.allWarnings.cnEcIsNotEmpty() then
		self.allWarnings.copy(allErrorsObj);
	endif;
	
	if allErrorsObj.isEmpty() then
		return null;
	endif;
	
	foreach errorObj in allErrorsObj do
		if returnValue = null then
			returnValue	:=	errorObj.getFullDetailsAsString();
		else
			returnValue	:=	returnValue &amp; CrLf &amp; errorObj.getFullDetailsAsString();
		endif;
	endforeach;
	
	// Add error code constant names
	category := currentSchema.getCategory(XLAT_Exceptions);		
	foreach errorObj in allErrorsObj do
		foreach constant in category.getConstants do
			if constant.valueAsInteger = errorObj.errorCode then
				returnValue := returnValue &amp; CrLf &amp; errorObj.errorCode.String &amp; " " &amp; constant.name;
			endif;
		endforeach;
	endforeach;
	
	return returnValue;
epilog
	delete allErrorsObj;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllErrorsWarningsAsString" id="309df4dc-bddc-4552-86f6-5e0dde9fbfc3">
        <source>getAllErrorsWarningsAsString() : String;
// ---------------------------------------------------------------------------
// Created:     22 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	error		: CM_Error;
	str			: String;
	errorSet	: CM_ErrorSet;
	
begin
	// I want to see errors first and if no errors I want some warnings.
	
	if not self.allErrors.isEmpty() then
		errorSet := self.allErrors;
	elseif not self.allWarnings.isEmpty() then
		errorSet := self.allWarnings;
	else
		return null;
	endif;
	
	foreach error in errorSet do
		if str = null then
			str := error.getDetailsAsString();
		else
			str := str &amp; CrLf &amp; error.getDetailsAsString();
		endif;
	endforeach;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultBOLType" id="b03b0f04-be43-4cec-b75e-cead429eb558">
        <source>getDefaultBOLType() : CM_BOLType;
// ---------------------------------------------------------------------------
// Created:     24 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	userTerminal			: CM_UserTerminal;
	term					: CM_Terminal;
	bolType					: CM_CargoBOLType;
begin
	term := self.myTerminal;
	if term &lt;&gt; null then
		if self.myUser &lt;&gt; null then
			userTerminal := self.myTerminal.allUserTerminals[self.myUser.code];
			if userTerminal &lt;&gt; null and userTerminal.myDefaultBOLType &lt;&gt; null then
				return userTerminal.myDefaultBOLType;
			endif;
		endif;
		
		foreach bolType in term.allCargoBOLTypes do
			if bolType.id = term.defaultBolType then
				return bolType.CM_BOLType;
			endif;
		endforeach;
	endif;
	
end;</source>
        <ReturnType type="CM_BOLType"/>
    </JadeMethod>
    <JadeMethod name="getDefaultCargoBOLType" id="473c261d-1c4a-4872-9c7b-907cce57d54f">
        <source>getDefaultCargoBOLType() : CM_CargoBOLType;
// ---------------------------------------------------------------------------
// Created:     24 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	userTerminal			: CM_UserTerminal;
	term					: CM_Terminal;
	bolType					: CM_CargoBOLType;
	
begin
	term := self.myTerminal;
	if term &lt;&gt; null then
		if self.myUser &lt;&gt; null then
			userTerminal := self.myTerminal.allUserTerminals[self.myUser.code];
			if userTerminal &lt;&gt; null and 
			   userTerminal.myDefaultCargoBOLType &lt;&gt; null then
				return userTerminal.myDefaultCargoBOLType;
			endif;
		endif;
		
		foreach bolType in term.allCargoBOLTypes do
			if bolType.id = term.defaultCargoBolType then
				return bolType.CM_CargoBOLType;
			endif;
		endforeach;
	//	return term.allCargoBOLTypes[term.defaultCargoBolType].CM_CargoBOLType;
	endif;

end;</source>
        <ReturnType type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="getDefaultCargoBOLTypeId" id="f27d6f55-5aae-4e4d-a6c8-1f750e0a1016">
        <source>getDefaultCargoBOLTypeId() : Integer;
// ---------------------------------------------------------------------------
// Created:     24 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	userTerminal			: CM_UserTerminal;
	term					: CM_Terminal;
	defCargoBOLType			: CM_CargoBOLType;

begin
	term := self.myTerminal;
	if term &lt;&gt; null then
		if self.myUser &lt;&gt; null then
			userTerminal := self.myTerminal.allUserTerminals[self.myUser.code];
			if userTerminal &lt;&gt; null then
				defCargoBOLType := userTerminal.myDefaultCargoBOLType;
			endif;
		endif;
		
		if defCargoBOLType = null then
			foreach defCargoBOLType in term.allCargoBOLTypes do
				if defCargoBOLType.id = term.defaultCargoBolType then
					break;
				endif;
				defCargoBOLType := null;
			endforeach;
//			defCargoBOLType:= term.allCargoBOLTypes[term.defaultCargoBolType].CM_CargoBOLType;
		endif;
	endif;
	
	if defCargoBOLType &lt;&gt; null then
		return defCargoBOLType.id;
	endif;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultCargoType" id="f34b91da-aded-412d-9e71-df76dc8ea34c">
        <source>getDefaultCargoType() : CM_CargoType;
// ---------------------------------------------------------------------------
// Created:     24 August 2004	cnwth2
//
// Purpose:     
//			 
