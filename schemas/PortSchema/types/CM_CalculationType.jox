    <JadeMethod name="setProxy" id="5290dfcf-8cd5-46fe-a4f6-69726a98b8d9">
        <updating/>
        <source>setProxy(_booleans : BooleanArray; _calculationType : Integer; _code : String; _description : String; 
			_hoursFree, _hoursMax, _hoursMin, _hoursBlock : Real; _integers : IntegerArray ; _notAvail : Boolean;
			_timeFrom, _timeTo : Time; _amountMin, _amountMax : Decimal; _calcTypeUnit : Integer;
			_quantityHookSource : String; _rateHookSource : String; _remarksHookSource: String; _userCode : String;			// 24024
			_isCargo, isVoyage, isEvent, _isWO : Boolean; _myCalendarType1, _myCalendarType2 : CM_Calendar; mesType : CM_MeasurementType;
			_rateType : Integer; _isBolType : Boolean; _isInventoryType : Boolean; _weightToUse : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
// ---------------------------------------------------------------------------

vars

begin
	self.booleanList.clear;
	self.integerRange1.clear;
	
	if _booleans &lt;&gt; null then
		_booleans.copy(self.booleanList);
	endif;
	if _integers &lt;&gt; null then
		_integers.copy(self.integerRange1);
	endif;
	self.myMeasurementType := mesType; // PAR 31615
	self.calculationType := _calculationType;
	self.code := _code.toUpper();
	self.description := _description;
	self.myCalendarType1 := _myCalendarType1; // PAR 30681
	self.myCalendarType2 := _myCalendarType2; // PAR 30681
	self.hoursBlock := _hoursBlock;
	self.hoursFree := _hoursFree;
	self.hoursMax := _hoursMax;
	self.hoursMin := _hoursMin;
	self.isNotAvailableForEntry := _notAvail;
	self.timeFrom := _timeFrom;
	self.timeTo := _timeTo;
	self.amountMax := _amountMax;
	self.amountMin := _amountMin;
	self.theCalcTypeUnit := _calcTypeUnit;
	self.isCargoCalcType := _isCargo;
	self.isEventCalcType := isEvent;
	self.isVoyageCalcType := isVoyage;
	self.isWorkOrderType := _isWO; // TFS 39198
	// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
	self.setProxyHookRate(_rateHookSource, _userCode);
	self.setProxyHookQuantity(_quantityHookSource, _userCode);
	self.setProxyHookRemarks(_remarksHookSource, _userCode);	// 22/2/18 MAP TFS37124
	self.rateType := _rateType;	//22 Mar 2019	NDL	TFS 43687
	self.isBolCalcType := _isBolType;	//30 Oct 2019	NDL	TFS 47100
	
	self.isInventoryType := _isInventoryType; // ### TFS 51219 25MAY2021 NAVAB1
	self.weightOptionToUse := _weightToUse; //02/10/2025	navkc1 JIRA 36149
end;</source>
        <Parameter name="_booleans" type="BooleanArray"/>
        <Parameter name="_calculationType" type="Integer"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_hoursFree" type="Real"/>
        <Parameter name="_hoursMax" type="Real"/>
        <Parameter name="_hoursMin" type="Real"/>
        <Parameter name="_hoursBlock" type="Real"/>
        <Parameter name="_integers" type="IntegerArray"/>
        <Parameter name="_notAvail" type="Boolean"/>
        <Parameter name="_timeFrom" type="Time"/>
        <Parameter name="_timeTo" type="Time"/>
        <Parameter name="_amountMin" type="Decimal"/>
        <Parameter name="_amountMax" type="Decimal"/>
        <Parameter name="_calcTypeUnit" type="Integer"/>
        <Parameter name="_quantityHookSource" type="String"/>
        <Parameter name="_rateHookSource" type="String"/>
        <Parameter name="_remarksHookSource" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_isCargo" type="Boolean"/>
        <Parameter name="isVoyage" type="Boolean"/>
        <Parameter name="isEvent" type="Boolean"/>
        <Parameter name="_isWO" type="Boolean"/>
        <Parameter name="_myCalendarType1" type="CM_Calendar"/>
        <Parameter name="_myCalendarType2" type="CM_Calendar"/>
        <Parameter name="mesType" type="CM_MeasurementType"/>
        <Parameter name="_rateType" type="Integer"/>
        <Parameter name="_isBolType" type="Boolean"/>
        <Parameter name="_isInventoryType" type="Boolean"/>
        <Parameter name="_weightToUse" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyHookQuantity" id="be8e5fd0-0542-4f32-8811-52d94c514559">
        <updating/>
        <source>setProxyHookQuantity(_quantityHookSource : String; _userCode : String) updating;
// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
vars
	qtyHook		: Integer;
begin
	// 34489 CCMS 1327 extended to HMS types
	if self.isVoyageCalcType then
		qtyHook := HookType_HMSInvoiceQuantity;
	else
		qtyHook := HookType_InvoiceQuantity;
	endif;
	if _quantityHookSource &lt;&gt; null then	
		if self.myHookCodeQuantity &lt;&gt; null then
			self.myHookCodeQuantity.setForProxy(self.code, app.myRoot.allHookTypes[qtyHook]);
			self.myHookCodeQuantity.setJadeCodeForProxy(_quantityHookSource, _userCode);
		else
			create self.myHookCodeQuantity transient;
			self.myHookCodeQuantity.setJadeCodeForProxy(_quantityHookSource, _userCode);
			self.myHookCodeQuantity.setForProxy(self.code, app.myRoot.allHookTypes[qtyHook]);
			self.myHookCodeQuantity.createProxyHookLinkForParent(qtyHook, self);
		endif;
	else
		if self.myHookCodeQuantity &lt;&gt; null then
			delete self.myHookCodeQuantity;
		endif;
	endif;
end;
</source>
        <Parameter name="_quantityHookSource" type="String"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
