    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="80da0b36-0858-4e7f-a315-67cde1d98785">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_MoveTransactionController; _passport: CM_Passport input) updating;
/*
Purpose:			

Date		Who		Reason
03 February 2022	navab1	TFS 51855
*/

vars
	crane : CM_Crane;
begin
	inheritMethod(_tiTransCntrl, _passport);

	
	if _tiTransCntrl.myWorkListEntry &lt;&gt; null then
		if _tiTransCntrl.myWorkListEntry.isKindOf(CM_VoyageWLE) then
			crane := _tiTransCntrl.myWorkListEntry.CM_VoyageWLE.getCrane();
			if crane &lt;&gt; null then
				self.craneId := crane.code;
				 // ### TFS 51855 15FEB2022 NAVAB1 self.targetLocn := crane.code;
			endif;
		endif;
	
	endif;
epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_MoveTransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="516d359d-7ced-47fb-ab6f-1be20f019642">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController) updating;
/*
Purpose:			

Date		Who		Reason
15 February 2022	navab1	TFS 51855
*/

vars
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	makeMove : Boolean;
begin
	inheritMethod(pTI, _tiTransCntrl);
	
	ti := self.myTrackedItem; // ### TFS 53369 28APR2022 NAVAB1
	
	 // ### TFS 51855 21DEC2021 NAVAB1
	if app.myPassport.isOpsViewEnabled(self.getMyTerminal()) then
		if _tiTransCntrl &lt;&gt; null then // ### TFS 51855 08FEB2022 NAVAB1
			wle :=  _tiTransCntrl.getWLE(); // ### TFS 51855 08FEB2022 NAVAB1
		endif;
			
		if ti.isContainer() then // ### TFS 53105 08JUN2022 NAVAB1
		
			if self.isRealMove then  // ### TFS 51855 03FEB2022 NAVAB1
			
				// VOYAGE INSTANT MOVE
				if ti.queueTask = null then  // ### TFS 51855 14FEB2022 NAVAB1 - not queued
					 // ### TFS 53369 28APR2022 NAVAB1self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_MOVE, self);  // ### TFS 51855 03FEB2022 NAVAB1
					makeMove := true;  // ### TFS 53369 28APR2022 NAVAB1
			
				else
					// QUEUED then INSTANT MOVED in Job Ops
					if ti.queueTask.machine = null then // ### TFS 52925 21FEB2022 NAVAB1
						 // ### TFS 53369 28APR2022 NAVAB1 self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_MOVE, self); // ### TFS 52925 21FEB2022 NAVAB1
						makeMove := true;  // ### TFS 53369 28APR2022 NAVAB1
					
					else
						// LOAD MOVE. Machine Rule ends in Lander App and IMV
						if ti.queueTask.machineTypeGroup = MACHINETYPEGRP_IMV 
						and wle &lt;&gt; null
						and not wle.isReceipt then // LOAD TO SHIP
							 // ### TFS 53369 28APR2022 NAVAB1 self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_MOVE, self);  // ### TFS 51855 03FEB2022 NAVAB1
							makeMove := true;  // ### TFS 53369 28APR2022 NAVAB1
						
						endif;
					endif;
				endif;
				
				if makeMove then // ### TFS 53369 28APR2022 NAVAB1
					self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_MOVE, self);  // ### TFS 53369 28APR2022 NAVAB1
					if ti &lt;&gt; null then // ### TFS 53369 28APR2022 NAVAB1
						ti.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM, ti);  // ### TFS 53369 28APR2022 NAVAB1
					endif;
				endif;
				
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
