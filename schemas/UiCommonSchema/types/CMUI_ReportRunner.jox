    <JadeMethod name="loadReportOptionCombos" id="f1934691-13b4-4b34-993d-39d760e4c056">
        <source>loadReportOptionCombos(_qryReport : CM_QryReport; _reportMenuItem :CM_MenuEntity );
// ---------------------------------------------------------------------------
// Created:     02 May 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 12/10/2020	jlgdap1		TFS 49898 PIBT Report Maintenance Window AvailableFormat setting issue
// 24/11/2020	jlgdap1		TFS 50413 SNO 14011 Error in system report
vars
	printerDef		: CM_PrinterDef;
	cmb				: CMUI_ComboBox;
	term	 		: CM_Terminal;
    entity          : CM_FTPEntity;
    reportRequest   : BGP_ReportRequest;
begin
	//Format options combo/////////////////////////////
	cmb := self.cmbFormat;
	cmb.clear();
	cmb.sorted := false;
	if _qryReport = null or _qryReport.reportFormats.includes(JadeReportWriterReport.PRINTER) or		// TFS 49898
	_qryReport.reportFormats.isEmpty then														// TFS 50413
		cmb.itemData[cmb.addItem(self.myReportAgent.FORMAT_OPTION_STANDARD)] := JadeReportWriterReport.PRINTER;
	endif;																								// TFS 49898
	
	if _qryReport &lt;&gt; null then
		if (_qryReport.isFormBasedReport) and (_qryReport.canCSV) then
			if _qryReport.reportFormats.includes(JadeReportWriterReport.CSV) then						// TFS 49898
				cmb.itemData[cmb.addItem(self.myReportAgent.FORMAT_OPTION_CSV)]		:= JadeReportWriterReport.CSV;
			endif;																						// TFS 49898
		elseif (not _qryReport.isFormBasedReport) then
			if _qryReport.reportFormats.includes(JadeReportWriterReport.CSV) then						// TFS 49898
				cmb.itemData[cmb.addItem(self.myReportAgent.FORMAT_OPTION_CSV)]		:= JadeReportWriterReport.CSV; 
			endif;																						// TFS 49898
			if _qryReport.reportFormats.includes(JadeReportWriterReport.HTML) then						// TFS 49898
				cmb.itemData[cmb.addItem(self.myReportAgent.FORMAT_OPTION_HTML)] 	:= JadeReportWriterReport.HTML;
			endif;																						// TFS 49898
			if _qryReport.reportFormats.includes(JadeReportWriterReport.RTF) then						// TFS 49898
				cmb.itemData[cmb.addItem(self.myReportAgent.FORMAT_OPTION_RTF)]		:= JadeReportWriterReport.RTF;
			endif;																						// TFS 49898
			if _qryReport.reportFormats.includes(JadeReportWriterReport.XML) then						// TFS 49898
				cmb.itemData[cmb.addItem(self.myReportAgent.FORMAT_OPTION_XML)]		:= JadeReportWriterReport.XML;
			endif;																						// TFS 49898
			if _qryReport.reportFormats.includes(JadeReportWriterReport.TEXT) then						// TFS 49898
				cmb.itemData[cmb.addItem(self.myReportAgent.FORMAT_OPTION_TEXT)]	:= JadeReportWriterReport.TEXT;		// 28218
			endif;																						// TFS 49898
			if _qryReport.reportFormats.includes(CM_QryReport.PDF_Format) then							// TFS 49898
				if _reportMenuItem &lt;&gt; null and _reportMenuItem.isKindOf( CM_MenuUserReport) and _reportMenuItem.CM_MenuUserReport.myReportTemplate &lt;&gt; null then	//01 Jul 2021	NDL	TFS 51405
					//We are a template and PDF is not valid for templates they have to use 'PRINTER' and select a printerDef' that is a PDF printer.
                    reportRequest := _reportMenuItem.CM_MenuUserReport.myReportTemplate.myReportRequest.BGP_ReportRequest;
                    if reportRequest &lt;&gt; null and reportRequest.outputType = BGP_ReportRequest.FTP_SFTP then                 //MTN-36668
                        cmb.itemData[cmb.addItem(CMUI_ReportAgent.FORMAT_OPTION_PDF)]		:= CM_QryReport.PDF_Format;     //MTN-36668
                    endif;                                                                                                  //MTN-36668
				else
					cmb.itemData[cmb.addItem(CMUI_ReportAgent.FORMAT_OPTION_PDF)]		:= CM_QryReport.PDF_Format;	// TFS 49898
				endif;
			endif;																						// TFS 49898
		endif;
	endif;
				
	if self.cmbFormat.listCount &gt; null then																		// TFS 49898
		self.cmbFormat.listIndex := 1;
		//self.tblPrintOptions.setValueByName(ETRow_FormatOption, self.myReportAgent.FORMAT_OPTION_STANDARD);	// TFS 49898
		self.tblPrintOptions.setValueByName(ETRow_FormatOption, self.cmbFormat.text);							// TFS 49898
	else																										// TFS 49898
		self.tblPrintOptions.setValueByName(ETRow_FormatOption, null);											// TFS 49898
	endif;																										// TFS 49898

	//Process options combo/////////////////////////////
	self.cmbProcess.clear();
	self.cmbProcess.addItem(self.PROCESS_FOREGROUND);
	self.cmbProcess.addItem(self.PROCESS_BACKGROUND);
	if self.canAccessTemplates then
		self.cmbProcess.addItem(self.PROCESS_TEMPLATE);
	endif;
	
	self.cmbProcess.listIndex := 1;
	self.tblPrintOptions.setValueByName(ETRow_ProcessOption, self.PROCESS_FOREGROUND);

	//Destination options combo/////////////////////////////
	self.cmbDestination.clear();
	self.cmbDestination.addItem(self.DESTINATION_SAVE);
	self.cmbDestination.addItem(self.DESTINATION_PRINTANDSAVE);
	self.cmbDestination.addItem(self.DESTINATION_PRINT);
    self.cmbDestination.addItem(self.DESTINATION_SFTP);     //MTN-36668
	
	self.cmbDestination.listIndex := 1;
	self.tblPrintOptions.setValueByName(ETRow_DestinationOption, self.DESTINATION_SAVE);
	
	//Load available printers//////////////////////////
	self.cmbPrinter.clear();
	if not app.myRoot.allPrinterDefsByLogicalName.isEmpty then
		foreach printerDef in app.myRoot.allPrinterDefsByLogicalName do
			self.cmbPrinter.itemObject[self.cmbPrinter.addItem(printerDef.logicalPrinterName)] := printerDef;
		endforeach;

		printerDef := app.myRoot.allPrinterDefsByLogicalName[ Printer_Default ];
		
		if printerDef = null then
			printerDef := app.myRoot.allPrinterDefsByLogicalName.first;
		endif;
		
		if printerDef &lt;&gt; null then
			self.cmbPrinter.text := printerDef.logicalPrinterName;
			self.tblPrintOptions.setValueByName(ETRow_ChoosePrinter, printerDef.logicalPrinterName);
		endif;
	endif;
	
	//load Terminals combos
	self.cmbTerminals.clear();
	foreach term in app.myRoot.allTerminals do
		self.cmbTerminals.addItemObject(term.code, term);
	endforeach;
	
	self.cmbTerminals1.clear();
	foreach term in app.myRoot.allTerminals do
		self.cmbTerminals1.addItemObject(term.code, term);
	endforeach;
		
	//Load FTP Entity Combo's                               //MTN-36668
    self.cmbFTPEntity.clear();                              //MTN-36668
    foreach entity in app.myRoot.allFTPEntities do          //MTN-36668
        if entity.isSFTP then                               //MTN-36668         -- Display Only SFTP entity.
            self.cmbFTPEntity.addItemObject(entity.id, entity); //MTN-36668
        endif;                                              //MTN-36668
    endforeach;                                             //MTN-36668
end;</source>
        <Parameter name="_qryReport" type="CM_QryReport"/>
        <Parameter name="_reportMenuItem" type="CM_MenuEntity"/>
    </JadeMethod>
    <JadeMethod name="loadReportTree" id="05b87065-ac40-4846-9032-4d77f3e5023b">
        <updating/>
        <source>loadReportTree() updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	userTerminal 	: CM_UserTerminal;
	user			: CM_User;
	menuEntity		: CM_MenuUserReport;
begin
	//self.lbReportTree.clear();
	user := app.getMyUser();
	
	if user &lt;&gt; null then
		userTerminal := user.getUserTerminal(self.myTerminal);
		if userTerminal = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Report menu root object has not been found for the current user.');
			return;
		endif;
	endif;
	
	self.lbReportTree.allMenuRoots.clear();
	self.lbReportTree.allMenuRoots.add(userTerminal.myReportMenuRoot);
	self.lbReportTree.allMenuRoots.add(user.myMenuRootBGRCurrent);
	self.lbReportTree.allMenuRoots.add(user.myMenuRootBGRSaved);
	
	if self.canAccessTemplates then
		self.lbReportTree.allMenuRoots.add(user.myMenuRootBGRTemplate);
	endif;
	
	self.lbReportTree.displayTree(false, null);
	
end;</source>
    </JadeMethod>
