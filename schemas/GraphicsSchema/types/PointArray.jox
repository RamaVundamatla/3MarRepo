		elseif minX &gt; point.x then
			minX := point.x;
		endif;
	endforeach;
	
	diffY := maxY - minY;
	diffX := maxX - minX;
	height := diffX;
	
	// Calculate starting points...
	point.set((minX/2).Integer, (minY/2).Integer);
	bestPlace.add(point);
	point.set((maxX/2).Integer, (maxY/2).Integer);
