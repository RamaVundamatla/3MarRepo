    <JadeMethod name="addBGPReportRow" id="00f23fec-2cd0-4784-a66e-afbf631e0f96">
        <source>addBGPReportRow(_menuEntity : CM_MenuEntity; _entDef : EntTableDef) protected;
// ---------------------------------------------------------------------------
// Created:     06 December 2002		cnwth2	
//
// Purpose:     EntDef passed in to saved de-referencing app for every time we display a line
//			 
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	entRow				: EntTableRow;
	str					: String;
	lineColour,
	idx					: Integer;
begin
	if not _menuEntity.isKindOf(CM_MenuUserReport) or _entDef = null then
		return;
	endif;
	
//	foreach entRow in _entDef.allEntTableRows do
	foreach entRow in self.tblBGPReports.allTblDataEntRows do
		str := str &amp; _menuEntity.getDisplayStringForAttribute(entRow.name, true) &amp; Tab;
	endforeach;
	lineColour := _menuEntity.CM_MenuUserReport.getLineColour;
	
	if lineColour = null then
		lineColour := self.tblBGPReports.backColor;
	endif;
	
	idx := self.tblBGPReports.addItem(str);
	self.tblBGPReports.accessRow(idx).itemObject := _menuEntity;
	self.tblBGPReports.accessedRow.backColor := lineColour;

end;</source>
        <access>protected</access>
        <Parameter name="_menuEntity" type="CM_MenuEntity"/>
        <Parameter name="_entDef" type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="armNotifications" id="d5db7719-921a-4b08-b1e3-0ce8c5912d08">
        <source>armNotifications() protected;
// ---------------------------------------------------------------------------
// Created:     04 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpUser	: CM_User;
	
begin
	tmpUser := app.getMyUser;
	self.endNotificationForSubscriber(self);
	self.beginNotification(tmpUser, EVENT_QRYREPORTUSER_CREATE, Response_Continuous, 1);
	self.beginNotification(tmpUser, EVENT_QRYREPORTUSER_UPDATE, Response_Continuous, 2);
	self.beginNotification(tmpUser, EVENT_QRYREPORTUSER_DELETE, Response_Continuous, 3);
	self.beginNotification(tmpUser, EVENT_QRYREPORTSYSTEM_UPDATE, Response_Continuous, 4);
	
	self.beginNotification(tmpUser, CM_User.BGP_REPORT_CREATED, Response_Continuous , 5);
	self.beginNotification(tmpUser, CM_User.BGP_REPORT_DELETED, Response_Continuous , 6);

end;</source>
        <access>protected</access>
    </JadeMethod>
