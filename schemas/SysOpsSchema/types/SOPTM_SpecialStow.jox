    <JadeMethod name="setControlsForAddEdit" id="d0592d56-bcf1-4d79-bfee-b9404669b3bf">
        <updating/>
        <source>setControlsForAddEdit() updating;
//-----------------------------------------
//
// Created : by cnwaer1 19 August 2008
//-----------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
  theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.disableRowByName(ETRow_Ports);
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_SpecialStow);
		// cannot update code		
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.disableRowByName(ETRow_Ports);
	endif;

	

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="e16e95c3-f4a9-4d19-93c1-677ea3adc893">
        <updating/>
        <source>setCtrlsForView() updating;
//-----------------------------------------
//
// Created : by cnwaer1 19 August 2008
//-----------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="244ceb0d-0de3-47af-845b-a79e47603681">
        <source>setupThumbnailDetails();
//-----------------------------------------
//
// Created : by cnwaer1 19 August 2008
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------------
// 20/05/2015	cnwdap1		PAR #36206 Graphical Representation of Special Stow
vars
	theForm : SOP_TableMaintForm;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	
	//theForm.setTblDataEntRows(ETDef_SpecialStowMaint);		// PAR #36206
	theForm.setTblDataEntRows(ETDef_SpecialStowTbl);			// PAR #36206

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_SpecialStowMaint);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="46b5f6c6-d759-4fdc-94c9-76e453886077">
        <updating/>
        <source>showThumbnail(pSpecialStow : CM_SpecialStow) updating;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 13/05/2015	cnwdap1		PAR #36206 TFS 324/334 Graphical Reresentation of Hazard Class
//
vars
	theForm : SOP_TableMaintForm;
	drawAttr : CM_DrawingAttribute;			// PAR #36206
	row : Integer;							// PAR #36206
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pSpecialStow.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pSpecialStow.description);
	drawAttr := pSpecialStow.myDrawingAttribute;										// PAR #36206
	if drawAttr &lt;&gt; null then															// PAR #36206
		theForm.tblInput1.setValueByName(ETRow_Font, drawAttr.fontName);				// PAR #36206
		theForm.cmbChar.fontName := drawAttr.fontName;									// PAR #36206
		if drawAttr.fontCharacter &gt;= 1 and drawAttr.fontCharacter &lt;= 255 then			// PAR #36206
			theForm.cmbChar.listIndex := drawAttr.fontCharacter;						// PAR #36206
		endif;																			// PAR #36206
		theForm.tblInput1.setValueByName(ETRow_Character, theForm.cmbChar.text);		// PAR #36206
		row := theForm.tblInput1.getRowByName(ETRow_Character);							// PAR #36206
		if row &lt;&gt; null then																// PAR #36206
			theForm.tblInput1.accessCell(row, theForm.tblInput1.ColumnValue).fontName := drawAttr.fontName;	// PAR #36206
		endif;																			// PAR #36206
	endif;																				// PAR #36206
end;</source>
        <Parameter name="pSpecialStow" type="CM_SpecialStow"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="13f1f6a6-8a7e-40ed-badd-21a33709f99d">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/05/2015	cnwdap1		Initial creation PAR #36206 TFS 324/334 Graphical Representation of Hazard Class and Special Stow
//
vars
	table : CM_DataTable;
	stow : CM_SpecialStow;
	cell : JadeTableCell;
	charColumn : Integer;
begin
	inheritMethod(_idxRow, _obj);
	
	if _idxRow &lt;&gt; 1 and _obj &lt;&gt; null then
		stow := _obj.CM_SpecialStow;
		if stow.myDrawingAttribute &lt;&gt; null then
			table := self.myForm.tblData;
			charColumn := table.getColumnByRowName(ETRow_Character);
			if charColumn &lt;&gt; null then
				cell := table.accessCell(_idxRow, charColumn);
				cell.fontName := stow.myDrawingAttribute.fontName;
				cell.text := stow.myDrawingAttribute.fontCharacter.Character;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
