    <JadeMethod name="delete" id="a1d9c917-a8a0-438d-a946-f7d84a8344ff">
        <updating/>
        <source>delete() updating;
/*
Date		Who		Reason
16 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
09/05/2012	cnwcs5	Complete auditing implementation for 8.1.1
//30 Apr 2014	cnwrs1	Par 34062 add useProxy to FTP Get/Put
*/
vars
	coll	:CM_EDIPartyBySenderCode;
	str		:String;
	party	:CM_EDIParty;
begin
	if not self.isTransient then
		if self.myTerminal &lt;&gt; null then
			coll := self.myTerminal.allEDIPartiesBySenderCode;
			
			foreach str in self.allUNEdifactSenderCodes do
				party := coll [str];
		
				if party = self then
					coll.removeKey (str); 
				else
					// Hmmm. Something has gone worng but we can't fix it here :-(
				endif;
			endforeach;
		endif;
	endif;
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="5e74429f-0a1f-40ca-a3a3-411b6155df8b">
        <source>getAuditText(): String;
/*
Date		Who		Reason
09 May 2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
*/
vars
	txt, str	: String;
	fileType	: CM_EDIFileType;
	rule		: CM_EDIPartyRules;
begin
	txt := inheritMethod();
	
	str := self.getSendersAsString;
	txt := txt &amp; 'Sender codes' &amp; AuditStringSeparator &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;
	
	foreach fileType in self.allEDIFileTypes do
		txt := txt &amp; fileType.getAuditText;
	endforeach;
		
	foreach rule in self.allEDIPartyRules do
		txt := txt &amp; rule.getAuditText;
	endforeach;
		
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="1d484582-92a4-44a0-a0ca-8e24b619a4b5">
        <source>getDisplayStringForAttribute(_name: String; _short: Boolean): String;
/*
Date		Who		Reason
17 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	if _name = ETRow_Senders then
		return self.getSendersAsString;
	endif;
	
	return inheritMethod(_name, _short);
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRulesForFileType" id="513475c1-edcf-4cdf-bad7-93ca720e9b6e">
        <source>getRulesForFileType(_type :Integer):CM_EDIPartyRules;
/*
Date		Who		Reason
22 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	iter	:Iterator;
	type	:CM_EDIFileType;
	result	:CM_EDIPartyRules;
begin
	iter := app.myRoot.allEDIFileTypes.createIterator;
	
	app.myRoot.allEDIFileTypes.startKeyGeq (_type, null, iter);
	
	while iter.next (type) do
		if type.type = _type then
			result := self.allEDIPartyRules [type]; 
			break;
		endif;
		break;
	endwhile;
	
	return result;
epilog
	delete iter;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_EDIPartyRules"/>
    </JadeMethod>
    <JadeMethod name="getSendersAsString" id="45314c85-9e4f-491d-aecd-bcba44948fe8">
        <source>getSendersAsString():String;
/*
Date		Who		Reason
17 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	str, result	:String;
	size, idx : Integer;
begin
	size:=self.allUNEdifactSenderCodes.size;
	idx:=1;
	foreach str in self.allUNEdifactSenderCodes do
		//jlier1 TFS 57187 21/3/23
		if idx = size and str = result then
			break;
		endif;
		if result = null then
			result := str;
		else
			result := result &amp; ' ' &amp; str;
		endif;
		idx:=idx +1;
	endforeach;
	
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTranslationOperator" id="239a1d75-46c1-4329-bae3-737d90f7d74d">
        <source>getTranslationOperator(_senderCode :String):CM_Operator;
/*
Purpose:	Find an operator to use for translations

Date		Who		Reason
29 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
03 Apr 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures

*/
vars
	operator		:CM_Operator;
	code			:String;
	gotException	:Boolean;
	test			:Integer;
	foundMatch		:Boolean;
begin
	// myTranslationOperator is not inversed as at the 792 hotfix in which this code was implemented
	// so we should check that it has not been deleted
	on Exception do app.handleDeletedObject (exception, operator, gotException);
	
	// if we have a translation operator defined for this EDI party then use that one
	operator := self.myTranslationOperator;
	
	if operator  &lt;&gt; null then
		test := operator.edition;
		
		if not gotException then
			return operator;
		endif;
		
		gotException := false;
	endif;
	
	// look up (the old way) based on the EDI sender code
	code		:= app.myRoot.getXlationSystemOperatorCode( null, _senderCode, foundMatch )[ 1 : CM_Operator::code.getLengthForString()];
	
	if code &lt;&gt; null then
		operator	:= app.myRoot.allOperators[ code ];
	endif;
		
	return operator;
epilog

end;</source>
        <Parameter name="_senderCode" type="String"/>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="9e7478dd-7f2f-4530-9789-1122f94f401e">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Date		Who		Reason
16/11/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	proxy 			: CM_EDIParty;
	rule, pxyRule	: CM_EDIPartyRules;
begin
	proxy := inheritMethod();
	
	proxy.myTranslationOperator	:= self.myTranslationOperator;
	proxy.myTerminal			:= self.myTerminal;
		
	foreach rule in self.allEDIPartyRules do
		pxyRule := rule.pxyCreateUpdateProxy;
		
		pxyRule.setMyEDIParty (proxy);
	endforeach;

	self.allEDIFileTypes.copy (proxy.allEDIFileTypes);	// not used as at 8.1.1 but here for completenes

	return proxy;
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="431be77b-7eb2-47e5-a03c-2863dc14eb9b">
        <updating/>
        <source>setForCreate(_proxy	:CM_EDIParty)updating;
/*
Date		Who		Reason
16/11/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	self.raiseExceptionIfTransient (method);
	
	self.setForUpdate (_proxy);
	
	self.myTerminal	:= _proxy.myTerminal;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDIParty"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d68c13d6-0561-4ea6-8c04-38ebaf3c843e">
        <updating/>
        <source>setForUpdate(_proxy :CM_EDIParty) updating;
/*
Date		Who		Reason
16/11/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	rule, pxyRule	:CM_EDIPartyRules;
begin
	self.raiseExceptionIfTransient (method);
	
	self.name					:= _proxy.name;
	self.description			:= _proxy.description;
	self.myTranslationOperator	:= _proxy.myTranslationOperator;
	self.onlyUseXlationOpForXlation	:=_proxy.onlyUseXlationOpForXlation; //jlier1	TFS 57187 22/3/23
	self.updateUNEdifactSenderCodes (_proxy);
	
	// add any new rules, update any existing rules.  rules can't be deleted except
	// when the party is deleted
	foreach pxyRule in _proxy.allEDIPartyRules do
		rule := pxyRule.pxyGetRealObject;
		
		if rule = null then
			create rule as pxyRule.class persistent;
			
			rule.setForCreate (pxyRule);
			
			rule.setMyEDIParty (self);
		else
			rule.setForUpdate (pxyRule);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDIParty"/>
    </JadeMethod>
    <JadeMethod name="setMyFTPEntity" id="7d7a9f6c-0519-4eb5-b191-9d7e126c94c9">
