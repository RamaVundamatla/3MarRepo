    <JadeMethod name="getValueForCargoCalcType" id="4c9f62d0-61e3-4b45-9151-33a95f554772">
        <source>getValueForCargoCalcType(_calcType : Integer) : Decimal;
/*

Purpose:	TFS 39236		

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlgab1	Initial creation

*/

vars
	value : Real;
	pxyCargoDetail : CM_WodCargoRequest;
begin
     
	foreach pxyCargoDetail in self.allCargoDetails discreteLock do

		value := value + pxyCargoDetail.getValueForCargoCalcType(_calcType);
	endforeach;

	return value;
	
epilog

end;</source>
        <Parameter name="_calcType" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
