<PrimType name="Integer">
    <JadeMethod name="asKilobytes" id="d0be8c75-1409-4052-999d-5131204fe3eb">
        <source>asKilobytes() : Real;

constants
	BytesPerKilobyte = 1024;
	
begin
	return self / BytesPerKilobyte;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="asMegabytes" id="9b00c3a1-1571-44b0-b668-985385535455">
        <source>asMegabytes() : Real;

constants
	BytesPerMegabyte = 1048576;
	
begin
	return self / BytesPerMegabyte;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
</PrimType>
