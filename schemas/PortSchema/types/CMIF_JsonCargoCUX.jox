    <JadeMethod name="delete" id="e37c6ea6-4a15-4ffb-ba0d-8c142c6df0d4">
        <updating/>
        <source>delete() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/04/2023	navdap1		Initial creation TFS 57362 CUX - Changes to Outgoing Message Formats
//
vars

begin
	self.customsReferenceInfo.purge;
	self.hazardous.purge;
	self.children.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getStatusFromTI" id="63e6c2a7-50b6-43ce-b02a-23181d95fcc2">
        <source>getStatusFromTI(_ti : CM_TrackedItem) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/04/2023	navdap1		Initial creation TFS 57362 CUX Changes to Outgoing Messaeg Formats
//
vars

begin
	if not _ti.releasedDT.isValid then
		// receivals
		if _ti.getTruckNumberReceival &lt;&gt; null then
			return self.ROADRECEIPT;
		elseif _ti.getMyTrainReceive &lt;&gt; null then
			return self.RAILRECEIPT;
		else
			return self.SHIPRECEIPT;	
		endif;
	else
		// releases
		if _ti.getTruckNumberRelease &lt;&gt; null then
			return self.ROADRELEASE;
		elseif _ti.getMyTrainRelease &lt;&gt; null then
			return self.RAILRELEASE;
		else
			//jlier1 TFS 63898 18/6/24
			if _ti.releasedTransportMode = TI_TRANSMODE_ROAD then
				return self.ROADRELEASE;
			else
				return self.SHIPRELEASE;
			endif;
		endif;
	endif;
	
	return self.CARGOENQUIRY;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromGTEReceival" id="15930150-7a45-4731-8ffc-ef6bf1dfd973">
        <updating/>
        <source>setFromGTEReceival(_receival : CMGTE_Receival) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/04/2023	navdap1		Initial creation TFS 57362 CUX Changes to Outgoing Message Formats
//
vars
	hazard : CM_Hazard;
	tiHazard : CM_TIHazard;
	haz : CMIF_JsonHazard;
	childTI : CMGTE_Entity;
	child : CMIF_JsonCargoCUX;

begin
	if _receival.myTrackedItem &lt;&gt; null then
		self.setFromTI(_receival.myTrackedItem, true);
		return;
	endif;
	
	self.alternativeId := _receival.alternativeId;
	if _receival.cargoType &lt;&gt; null then
		self.cargoType := app.myRoot.allCargoTypesById[_receival.cargoType].abbreviation;
	endif;
	if _receival.myProduct &lt;&gt; null then
		self.cargoSubType := _receival.myProduct.code;
	endif;
	self.carrier := _receival.carrier;
	self.commodity := _receival.commodity;
	self.consignee := _receival.consigneeCode;
	self.consignor := _receival.consignorCode;
	self.destinationPort := _receival.destinationPort;
	self.dischargePort := _receival.dischargePort;
	self.grossWeight := _receival.weightTotal.Integer;
	self.height := _receival.height.Integer;
	self.id := _receival.id;
	self.imexStatus := _receival.imExStatus.abbreviation;
	self.isotype := _receival.getIsoType();
	self.length := _receival.length.Integer;
	self.loadPort := _receival.loadPort;
	self.netWeight := _receival.weightTare.Integer;
	self.operator := _receival.operatorCode;
	self.receivalDateTime := null;
	self.receiveTruck := _receival.myVehicleVisitRecord.regNumber;
	self.releaseVoyage := _receival.voyageCode;
	self.remarks := _receival.remarks;
	self.status := self.ROADRECEIPT;
	self.tareWeight := _receival.weightTare.Integer;
	if _receival.getMyVoyageObject &lt;&gt; null then
		self.vesselCode := _receival.getMyVoyageObject.vesselCode;
	endif;
	self.volume := _receival.volumeTotal.Integer;
	self.width := _receival.width.Integer;
	
	// hazards
	foreach hazard in _receival.allTIHazards do
		tiHazard := hazard.CM_TIHazard;
		create haz transient;
		haz.acidBase := tiHazard.acidsBases;
		haz.flashpointTemperature := tiHazard.flashpointTemperature;
		haz.hazardCode := tiHazard.code;
		haz.limitedQuantity := tiHazard.limitedQuantity;
		haz.marinePollutant := app.isMarinePollutantEnumToString(tiHazard.isMarinePollutant);
		haz.packingGroup := tiHazard.packingGroup;
		haz.undgNumber := tiHazard.getUndgCodesAsString(false);
	endforeach;
	
	// children
	foreach childTI in _receival.allChildren do
		create child transient;
		self.setFromGTEReceival(childTI.CMGTE_Receival);
		
		self.children.add(child);
	endforeach;
epilog

end;</source>
        <Parameter name="_receival" type="CMGTE_Receival"/>
    </JadeMethod>
    <JadeMethod name="setFromGTERelease" id="9553e043-9f6f-4b78-b56f-4eb8640b2dcb">
        <updating/>
        <source>setFromGTERelease(_release : CMGTE_Release) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/04/2023	navdap1		Initial creation TFS 57362 CUX Changes to Outgoing Message Formats
//
vars
	hazard : CM_Hazard;
	tiHazard : CM_TIHazard;
	haz : CMIF_JsonHazard;
	childTI : CMGTE_Entity;
	child : CMIF_JsonCargoCUX;

begin
	if _release.myTrackedItem &lt;&gt; null then
		self.setFromTI(_release.myTrackedItem, false);
		return;
	endif;

	if _release.cargoType &lt;&gt; null then
		self.cargoType := app.myRoot.allCargoTypesById[_release.cargoType].abbreviation;
	endif;
	if _release.myProduct &lt;&gt; null then
		self.cargoSubType := _release.myProduct.code;
	endif;
	if _release.myBulkRelease &lt;&gt; null then
		self.carrier := _release.myBulkRelease.carrierId;
	elseif _release.myTrackedItem &lt;&gt; null then
		self.carrier := _release.myTrackedItem.carrier;
	endif;
	self.commodity := _release.commodity;
	self.consignee := _release.consigneeCode;
	if _release.myBulkRelease &lt;&gt; null then
		self.consignor := _release.myBulkRelease.consignorCode;
	elseif _release.myTrackedItem &lt;&gt; null then
		self.consignor := _release.myTrackedItem.consignor;
	endif;
	if _release.myBulkRelease &lt;&gt; null then
		self.destinationPort := _release.myBulkRelease.getDestinationCode;
		self.dischargePort := _release.myBulkRelease.getDischargePortCode;
		self.loadPort := _release.myBulkRelease.getLoadPortCode;
	elseif _release.myTrackedItem &lt;&gt; null then
		self.destinationPort := _release.myTrackedItem.destinationPort;
		self.dischargePort := _release.myTrackedItem.dischargePort;
		self.loadPort := _release.myTrackedItem.loadPort;
	endif;
	self.grossWeight := _release.weightRequested.Integer;
	self.height := _release.height.Integer;
	self.id := _release.id;
	self.imexStatus := app.myRoot.allImexStatuses[_release.imexStatus].abbreviation;
	self.isotype := _release.getIsoType();
	self.length := _release.length.Integer;
	self.operator := _release.operatorCode;
	self.receivalDateTime := null;
	self.receiveTruck := _release.myVehicleVisitRecord.regNumber;
	self.releaseVoyage := _release.voyageCode;
	self.remarks := _release.remarks;
	self.status := self.ROADRECEIPT;
	if _release.getMyVoyageObject &lt;&gt; null then
		self.vesselCode := _release.getMyVoyageObject.vesselCode;
	endif;
	self.volume := _release.volume.Integer;
	self.width := _release.width.Integer;
	
	// children
	foreach childTI in _release.allChildren do
		create child transient;
		self.setFromGTERelease(childTI.CMGTE_Release);
		
		self.children.add(child);
	endforeach;
epilog

end;</source>
        <Parameter name="_release" type="CMGTE_Release"/>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="e130aa6e-4a5f-4e5b-9ba5-26319691ef65">
        <updating/>
        <source>setFromTI(_ti : CM_TrackedItem; _isReceival : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/04/2023	navdap1		Initial creation TFS 57362 CUX Changes to Outgoing Message Formats
//
vars
	child : CMIF_JsonCargoCUX;
	hazard : CM_Hazard;
	tiHazard : CM_TIHazard;
	customsRef : CM_CustomsReference;
	haz : CMIF_JsonHazard;
	custRef : CMIF_JsonCustomsCUX;
	lc : CM_LocationsController;
	childTI : CM_TrackedItem;

begin
	self.alternativeId := _ti.alternativeId;
	self.cargoType := _ti.cargoTypeDescr;
	if _ti.myProduct &lt;&gt; null then
		self.cargoSubType := _ti.myProduct.description;
	endif;
	self.carrier := _ti.carrier;
	self.commodity := _ti.commodity;
	self.consignee := _ti.consignee;
	self.consignor := _ti.consignor;
	self.contentsStatus := _ti.contentsStatusCode;
	self.destinationPort := _ti.destinationPort;
	self.dischargePort := _ti.dischargePort;
	self.grossWeight := _ti.totalWeight.Integer;
	self.height := _ti.height.Integer;
	self.id := _ti.id;
	self.imexStatus := _ti.getImExStatusStringDesc(false);
	self.isotype := _ti.getISOType;
	self.length := _ti.length.Integer;
	self.loadPort := _ti.loadPort;
	self.locationid := _ti.locationId;
	self.netWeight := _ti.weightTare.Integer;
	self.operator := _ti.operatorCode;
	
	if _isReceival then
		self.receivalDateTime := _ti.receivedDT;
		self.receiveTrain := _ti.getInwardsTrainCode;
		self.receiveTruck := _ti.getTruckNumberReceival;
		if _ti.voyageInbound &lt;&gt; null then
			self.receiveVoyage := _ti.voyageInbound.code;
		endif;
		if _ti.getMyWagonReceive &lt;&gt; null then
			self.receiveWagon := _ti.getMyWagonReceive.id;
		endif;
		
	else
		self.releaseDateTime := _ti.releasedDT;
		self.releaseTrain := _ti.getOutwardsTrainCode;
		self.releaseTruck := _ti.getTruckNumberRelease;
		if _ti.voyageOutbound &lt;&gt; null then
			self.releaseVoyage := _ti.voyageOutbound.code;
		endif;
		if _ti.getMyWagonRelease &lt;&gt; null then
			self.releaseWagon := _ti.getMyWagonRelease.id;
		endif;
	endif;
	
	self.remarks := _ti.remarks;
	self.tareWeight := _ti.weightTare.Integer;
	self.vesselCode := _ti.vesselCode;
	self.volume := _ti.totalVolume.Integer;
	self.width := _ti.width.Integer;
	
	self.status := self.getStatusFromTI(_ti);
	
	// hazards
	foreach hazard in _ti.allTIHazards do
		tiHazard := hazard.CM_TIHazard;
		create haz transient;
		haz.acidBase := tiHazard.acidsBases;
		haz.flashpointTemperature := tiHazard.flashpointTemperature;
		haz.hazardCode := tiHazard.code;
		haz.limitedQuantity := tiHazard.limitedQuantity;
		haz.marinePollutant := app.isMarinePollutantEnumToString(tiHazard.isMarinePollutant);
		haz.packingGroup := tiHazard.packingGroup;
		haz.undgNumber := tiHazard.getUndgCodesAsString(false);
		
		self.hazardous.add(haz);
	endforeach;
	
	// customs reference info
	if _ti.allCustomsReferences &lt;&gt; null then
		foreach customsRef in _ti.allCustomsReferences do
			create custRef transient;
			custRef.customsControl := customsRef.customsContol;
			custRef.customsReferenceNumber := customsRef.referenceNumber;
			custRef.customsReferenceType := customsRef.referenceType;
			custRef.objectName := customsRef.objectName;
			custRef.packagesRemaining := customsRef.packagesRemaining;
			custRef.positionNumber := customsRef.positionNumber;
			custRef.status := customsRef.status;
			custRef.totalPackages := customsRef.packagesTotal;
			
			self.customsReferenceInfo.add(custRef);
		endforeach;
	endif;
	
	// children - either actual children, or cargo on board a MAFI
	if _ti.isMAFI then
		foreach lc in _ti.CM_TILC.allLCs do
			foreach childTI in lc.allTrackedItems do
				create child transient;
				child.setFromTI(childTI, _isReceival);
				
				self.children.add(child);
			endforeach;
		endforeach;
	else
		foreach childTI in _ti.allChildren do
			create child transient;
			child.setFromTI(childTI, _isReceival);
			
			self.children.add(child);
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_isReceival" type="Boolean"/>
    </JadeMethod>
</Class>
