    <JadeMethod name="setFromROROLaneDefn" id="7dbd53a8-d9ed-4acc-816b-71179ce5b9fa">
        <updating/>
        <source>setFromROROLaneDefn() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin

	self.ident:=self.myLanePositionDefn.code;
	self.ordinal:=self.myLanePositionDefn.ordinal;
	self.myDeck:=self.myLanePositionDefn.myDeck.CM_DeckVoyage;
	self.myVoyage:=self.myDeck.CM_DeckVoyage.getVoyage();
epilog

end;</source>
    </JadeMethod>
