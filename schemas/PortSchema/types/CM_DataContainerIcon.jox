    <JadeMethod name="isIcon" id="8bb81e30-0a73-496f-9800-4aebf544cc22">
        <source>isIcon(): Boolean;
// ---------------------------------------------------------------------------
// Created:      03 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateIcon" id="cdc77112-ed7d-4d85-b870-6c95ca272ff2">
        <updating/>
        <source>setForCreateIcon(_character: Character; _scaleFactor: Integer; _obj: Object;
		_font : String; _colour : Integer) updating;
// ---------------------------------------------------------------------------
// Created:      03 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	self.character := _character;
	self.setForCreate(null, DC_Icon, _scaleFactor, _obj);
	self.font := _font;
	self.colour := _colour;
end;</source>
        <Parameter name="_character" type="Character"/>
        <Parameter name="_scaleFactor" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_font" type="String"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
</Class>
