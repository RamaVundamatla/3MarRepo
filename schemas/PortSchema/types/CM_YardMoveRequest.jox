    <JadeMethod name="getTargetLocationID" id="44fe3c48-6815-46a3-b1dd-44937765e258">
        <source>getTargetLocationID() : String;
// -----------------------------------------------------------------------------
// Created:		24 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 24/07/2009	consw1		SFW1075 - To Do Task Scheduling
// -----------------------------------------------------------------------------

vars
	result : String;
begin
	if self.myTargetTA = null then
		return self.targetLocation; //cnwrd1 par 22987 8.3.2010
	endif;
	
	result := self.myTargetTA.getID();
	if result = null then
		result := self.myTargetTA.id;
	endif;
	
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
