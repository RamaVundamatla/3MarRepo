    <JadeMethod name="keyDown" id="f4f31276-13a3-43ab-b779-660d7a3b2455">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ydc : YRD_ContainerDrawingController;
	anObj : Object;
begin
	if keyCode = CMUI_Key_Esc then
		delete app.myMoveController;
		app.myDraggedTrackedItem := null;
		app.isDragging := false;
		self.dragMode := self.DragMode_None;
		
		foreach anObj in self.allDrawingControllers do
			ydc := anObj.YRD_ContainerDrawingController;
			ydc.doCancelDrag();
		endforeach;
		
//		self.sdf01.clearUpDragDrop();
		return;
		
	elseif keyCode = J_key_Delete then
		self.doDeleteKeyDown();
		
	endif;

	inheritMethod(keyCode, shift);
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="minimisedStateBegin" id="6d549867-b5d3-48d2-a550-6cf4ec15a0ff">
        <updating/>
        <source>minimisedStateBegin() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 May 2006 By cnwth2

Purpose:	Called when the grid area for becomes minimized. Doesn't bother redrawing while minimsed
			but sets 'needsRefresh' if receives a note while minimised.
			This significantly reduces 'spikes' caused by many grid area forms open on many machines
			and thin client 'hanging' while unnecessary redrawing took place after some bulk action
			(like adding a labour restriction to an area)

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	obj					: Object;
begin
	if self.currentlyMinimised then
		return;
	endif;
	
	foreach obj in self.allDrawingControllers do
		obj.CMUI_GridDrawingController.minimisedStateBegin();
	endforeach;
	self.currentlyMinimised := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="minimisedStateEnd" id="19bee8b6-b34e-4830-a225-90aa56ded955">
        <updating/>
        <source>minimisedStateEnd() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 May 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	obj			: Object;
begin
	if (not self.currentlyMinimised) then
		return;
	endif;

	foreach obj in self.allDrawingControllers do
		obj.CMUI_GridDrawingController.minimisedStateEnd();
	endforeach;
	self.currentlyMinimised := false;

end;</source>
        <access>protected</access>
    </JadeMethod>
