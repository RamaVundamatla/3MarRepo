    <JadeMethod name="setIsSenarioTesting" id="e3bb3bd7-76ca-419d-8205-a15630d4d886">
        <updating/>
        <source>setIsSenarioTesting(_singleMode : Boolean; _verboseLogging : Boolean) updating;
// -------------------------------------------
// Created 12 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if not _singleMode then
		if _verboseLogging then
			self.agentUsage := self.Scenario_Verbose;
		else
			self.agentUsage := self.Scenario;
		endif;
	else
		if _verboseLogging then
			self.agentUsage := self.TestSingleTI_Verbose;
		else
			self.agentUsage := self.TestSingleTI;
		endif;
	endif;
end;</source>
        <Parameter name="_singleMode" type="Boolean"/>
        <Parameter name="_verboseLogging" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setNumberOfFreeSpacesReq" id="991ff7dc-30a5-483e-bc00-0b7977ce30dc">
        <updating/>
        <source>setNumberOfFreeSpacesReq() updating;
// -------------------------------------------
// Created 16 September 2005 by cnwdvb1
// -------------------------------------------
vars

	rule	: CM_YAOverstowRule;
	imex	: CM_IMEXStatus;
	ti		: CM_TrackedItem;

begin

	// Normal autoplan.
	ti := self.getMyCurrentTrackedItem();
	
	if self.myCurrentAllocation &lt;&gt; null then
		// Don't have to specify a rule.
		if self.myCurrentAllocation.myYAOverstowRule &lt;&gt; null then
			rule := self.myCurrentAllocation.myYAOverstowRule;
		endif;
	else
	// Check out imex status default rule.
		if ti = null then
			return;
		endif;
		imex := ti.getImExStatusObject();
		if imex = null then
			return;
		endif;
		rule := imex.getYAOverstowRuleForTerminal(self.myCurrentTerminal);
	endif;
	
	if rule = null then
		return;
	endif;
	
	self.numberOfFreeSpacesRequired := rule.numberOfFreeTEUs;
	
	

end;</source>
    </JadeMethod>
    <JadeMethod name="setYAAutoPlan" id="c6a3a2ee-c6f7-4d75-9654-6e59df9d2867">
        <updating/>
        <source>setYAAutoPlan(_cmifYAAutoPlan : CMIF_YAAutoPlan) updating;
vars
	invalidCMIFAutoPlan : Boolean;
begin
	
	
	if self.myCMIFYAAutoPlan &lt;&gt; _cmifYAAutoPlan then
		
		on Exception do app.handleDeletedObject(exception, self.myCMIFYAAutoPlan, invalidCMIFAutoPlan); //cnwas3 par 26706
		
		if self.myCurrentCMIFYAAutoPlan = self.myCMIFYAAutoPlan then
			self.myCurrentCMIFYAAutoPlan := null;
		endif;
		delete self.myCMIFYAAutoPlan;
		self.myCMIFYAAutoPlan:=_cmifYAAutoPlan;
	endif;
epilog

end;</source>
        <Parameter name="_cmifYAAutoPlan" type="CMIF_YAAutoPlan"/>
    </JadeMethod>
