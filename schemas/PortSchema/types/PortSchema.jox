    <JadeMethod name="httpStatusCodeEnumToString" id="37882223-34fc-4405-947e-69b63b4a8541">
        <source>httpStatusCodeEnumToString(_responseCode : Integer) : String;
/*

Purpose:			Returns a String representation of what the HTTP Status code means

Parameters:			_responseCode	Integer	HTTP Status Code

Return Value:		String	Represents what the http status code means

Date		Who		Reason
31 March 2023	navpw1	Initial creation TFS: 57382

*/

begin
	if _responseCode = HttpResponseOK then
		return "OK";
	elseif _responseCode = HttpResponseCreated then
		return "Created";
	elseif _responseCode = HttpResponseNoContent then
		return "No Content";
	elseif _responseCode = HttpResponseClientError then
		return "Bad Request";
	elseif _responseCode = HttpResponseUnauthorized then
		return "Unauthorized";
	elseif _responseCode = HttpResponseForbidden then
		return "Forbidden";
	elseif _responseCode = HttpResponseNotFound then
		return "Not Found";
	elseif _responseCode = HttpResponseSystemError then
		return "Internal Server Error";
	endif;
	
	return null;
	
end;</source>
        <Parameter name="_responseCode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="iSOSizeToType" id="bd8cb592-b9e2-4944-b02a-e1b7a6ade3a4">
        <source>iSOSizeToType(pCargoType : Integer; iSOSize : Integer; height : Integer io; length : Integer io);
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwdwq1
// Purpose: 
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
	if pCargoType = TI_CargoType_Container then
		if iSOSize.bitAnd(ISO_HALF_HEIGHT) &lt;&gt; 0 then
			height := TI_HEIGHT_HALF;
		else
			height := TI_HEIGHT_FULL;
		endif;

		if (iSOSize.bitAnd(ISO_LEN_20) &lt;&gt; 0 ) then
			length := TI_LENGTH_20;
		else
			if iSOSize.bitAnd(ISO_LEN_40) &lt;&gt; 0 then
				length := TI_LENGTH_40;
			elseif iSOSize.bitAnd(ISO_LEN_45) &lt;&gt; 0 then
				length := TI_LENGTH_40;
			else
				length := TI_LENGTH_10;
			endif;
		endif;
	elseif pCargoType = TI_CargoType_Generator or 
				pCargoType = TI_CargoType_Tower or
				pCargoType = TI_CargoType_COU or
				pCargoType = TI_CargoType_Car then
		length := TI_LENGTH_10;
		height := TI_HEIGHT_FULL;

	elseif 	pCargoType = TI_CargoType_LCL then
		length := TI_LENGTH_10;
		height := TI_HEIGHT_HALF;
	else
		length := TI_LENGTH_20;
		height := TI_HEIGHT_FULL;
	endif;
end;</source>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="iSOSize" type="Integer"/>
        <Parameter name="height" type="Integer" usage="io"/>
        <Parameter name="length" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="ignoreObjectLockedExHandler" id="20d370aa-b2df-4d09-96cc-ca0e4bb61b99">
        <source>ignoreObjectLockedExHandler(exObj : Exception; obj : Object) : Integer;
// ---------------------------------------------------------------------------
// Created:     20 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
/*

Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #30027 - locking framework issues
	
*/

constants
	ObjectLocked	: Integer = 1027;

vars
	
begin
	if exObj.errorCode = ObjectLocked then
		return Ex_Resume_Next;			// PAR #30027 - was Ex_Continue
	endif;
	
	return Ex_Pass_Back;

end;</source>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="imexStatusEnumToString" id="b2b9c23e-bf0e-4c6c-a65d-7660b217adce">
        <source>imexStatusEnumToString(_imexStatus : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2023	navpw1	Initial creation TFS: 56851

*/

begin
	if _imexStatus = TI_IMEX_STATUS_EXPORT then
		return "EXP";
	elseif _imexStatus = TI_IMEX_STATUS_IMPORT  then
		return "IMP";
	elseif _imexStatus = TI_IMEX_STATUS_REMAINONBOARD then
		return "ROB";
	elseif _imexStatus = TI_IMEX_STATUS_STORAGE then
		return "STO";
	elseif _imexStatus = TI_IMEX_STATUS_TRANSHIP then
		return "TSH";
	endif;
	
	return null;
	
end;</source>
        <Parameter name="_imexStatus" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="imexStatusStringToEnum" id="bf52229c-f8b4-47e9-a265-708484e7eb86">
        <source>imexStatusStringToEnum(_imexStatus : String) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2023	navpw1	Initial creation TFS: 56851

*/

begin
	if _imexStatus = "EXP" then
		return TI_IMEX_STATUS_EXPORT;
	elseif _imexStatus = "IMP" then
		return TI_IMEX_STATUS_IMPORT;
	elseif _imexStatus = "ROB" then
		return TI_IMEX_STATUS_REMAINONBOARD;
	elseif _imexStatus = "STO" then
		return TI_IMEX_STATUS_STORAGE;
	elseif _imexStatus = "TSH" then
		return TI_IMEX_STATUS_TRANSHIP;
	endif;
	
	return null;
	
end;</source>
        <Parameter name="_imexStatus" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="importVesselDefnXMLCreateProxy" id="23f47e74-c79d-4d60-8387-af8d619d4157">
        <source>importVesselDefnXMLCreateProxy(_vessel : Boolean;
								_loloStructure : Boolean;
								_roroStructure : Boolean;
								_fileName : String output) : CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2013	cnwer1	Initial creation 31289

*/

vars
	fileXML : CMDFileOpen;
	theFileName : String;
	xmlDocumentParser : JadeXMLDocumentParser;
	xmlDocument : JadeXMLDocument;
	rootElement, childElement : JadeXMLElement;
	xmlAttribute : JadeXMLAttribute;
	classToCreate : Class;
	pxyObject 	: CM_Object;
begin
	
	on FileException do self.fileExceptionHandler(exception);
	create fileXML;
	fileXML.filter:="XML (*.xml)|*.xml";
	fileXML.fileName:=null;
	if fileXML.open &lt;&gt; 0 then
		return null;
	endif;
	
	theFileName:= fileXML.fileName;
	_fileName:=theFileName;
	if theFileName = null then
		return null;
	endif;
	
	on JadeXMLException do app.xmlExceptionHandler(exception);
	//parse xml into doc
	create xmlDocumentParser transient;
	create xmlDocument transient;
	xmlDocumentParser.parseDocumentFile(xmlDocument,theFileName);
	
	rootElement:=xmlDocument.rootElement;
	//get the class to create 
	xmlAttribute:=rootElement.getAttributeByName('type');
	if xmlAttribute = null then
		app.raiseCMException1(ERR_Parsing_XML,"The Root Element needs a type attribute",null,null);
	endif;
	
	classToCreate:=self.getClass(xmlAttribute.value);
	
	if classToCreate = CM_CellularVesselStructure and _loloStructure then
		create pxyObject as classToCreate transient;
		pxyObject.importFromXMLDoc(rootElement);
	elseif (classToCreate = CM_ROROVesselStructure or
		classToCreate = CM_DeckVessel) and  _roroStructure then
		
		create pxyObject as classToCreate transient;
		pxyObject.importFromXMLDoc(rootElement);
		
	elseif classToCreate = CM_Vessel and  _vessel then
		create pxyObject as CM_Vessel transient;	
		pxyObject.importFromXMLDoc(rootElement);
		
	elseif classToCreate = CM_Vessel and _loloStructure then
		// look at child tags
		childElement:=rootElement.getElementByTagName(CM_Vessel::myCellularVesselStructure.name);
		if childElement &lt;&gt; null then	
			create pxyObject as CM_CellularVesselStructure transient;
			pxyObject.importFromXMLDoc(childElement);
		endif;
	elseif classToCreate = CM_Vessel and _roroStructure then
		childElement:=rootElement.getElementByTagName(CM_Vessel::myROROVesselStructure.name);
		if childElement &lt;&gt; null then	
			create pxyObject as CM_ROROVesselStructure transient;
			pxyObject.importFromXMLDoc(childElement);
		endif;
	endif;
	
	return pxyObject;
epilog
	delete xmlDocument;
	delete xmlDocumentParser;
	delete fileXML;
end;</source>
        <Parameter name="_vessel" type="Boolean"/>
        <Parameter name="_loloStructure" type="Boolean"/>
        <Parameter name="_roroStructure" type="Boolean"/>
        <Parameter name="_fileName" type="String" usage="output"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="initAutoPrintRoadReceipt" id="ab8ed060-3bef-4fa5-86da-025c546513cb">
        <updating/>
        <source>initAutoPrintRoadReceipt()updating;
//--------------------------------------------------------------
//Created: January 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
//	app.initialize();
//	beginClassNotification(CM_RoadJob, false, EVENT_AUTO_PRINT_ROAD_RECEIPT, Response_Continuous, 0);

	// this was part of initializeAgents but has nothing to do with agents conflicts with create of root
	self.myRoot := CM_Root.firstInstance; // a crude method of knowing if getSingleton has created the first CM_Root
	if self.myRoot = null then
		self.myRoot := global.myCM_Root;
	endif;

	self.initializeAgents();
	self.cnActivateKarmaControl(Cn_Fat_Client, null, null);	//for dumps
//	on Exception do null global;	//Turn off the karma handler! VB does its own stuff.
//	on LockException do null global;	//AA 21/8/01: Also turn off karma lock exception handler
	
	app.myRoot := CM_Root.firstInstance;

	self.baseErrorNum := app.myRoot.baseErrorNum;

	app.initCnCntrlForJMT();
	/*
	//app.myCnCntrl.setKarmaControl(false);
	//app.myCnCntrl.setSuppressManagementDialogs(true);
	//app.myCnCntrl.setOmitBinaryVersionControlChk(true);

	if self.isDevelopmentSystem then
		app.myCnCntrl.setLogToScreen(true);
		app.myCnCntrl.setCheckTransientsOnShutDown(true);
	else
		app.myCnCntrl.setLogToScreen(false);
		app.myCnCntrl.setCheckTransientsOnShutDown(false);
	endif;
	app.myCnCntrl.setExceptionHandlerType(0);        // Jade only
	app.myCnCntrl.setExceptionDisplayModal(false);
	*/

end;</source>
    </JadeMethod>
    <JadeMethod name="initBackgroundNodeProcessing" id="c3261d45-e0f4-47c6-b978-75933eff837a">
        <source>initBackgroundNodeProcessing();
/*

Purpose:			Initialise the background processing for a node if required

Parameters:			None

Return Value:		None

Date		Who		Reason
03 Apr 2012	cnwkpd1	PAR #29384 - Diagnostic code for stable collection inconsistency checks

*/

constants
	DummyValue		= "Dummy";
	
vars
	logCollStr		: String;
	agent			: CM_BackgroundNodeAgent;
	lockedGlobal	: Boolean;
	portScmGlobal	: GPortSchema;
	
begin
	// First check that the ini file section and key is present at all.  If not, then do nothing
	logCollStr := app.getProfileStringServer(CM_BackgroundNodeAgent.IniFileSectionName,
											 CM_BackgroundNodeAgent.LogStableCollectionInfo,
											 DummyValue);
											 
	if logCollStr = DummyValue then
		app.writeLog(method.qualifiedName &amp; " [" &amp; CM_BackgroundNodeAgent.IniFileSectionName &amp; "] " &amp;
					   CM_BackgroundNodeAgent.LogStableCollectionInfo &amp; " key not found, exiting", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return;
	endif;
	
	// If we get to here, then we need to either create the background node agent, or just start a timer if
	// one already exists.  Need to single thread through this check
	portScmGlobal := GPortSchema.firstInstance();
	app.writeLog(method.qualifiedName &amp; " about to reserveLock " &amp; portScmGlobal.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	reserveLock(portScmGlobal);
	lockedGlobal := true;

	// Need to check for an existing agent for this node
	agent := CM_BackgroundNodeAgent.firstSharedTransientInstance();
	
	// If one exists, then just need to start its timer
	if agent &lt;&gt; null then
		agent.doStartTimer();
	else
		// We're the first process in the node, so we need to create the node agent (which will start the timer)
		beginTransientTransaction;
		create agent sharedTransient;
		commitTransientTransaction;
	endif;
	
epilog
	if lockedGlobal then
		app.writeLog(method.qualifiedName &amp; " about to unlock " &amp; portScmGlobal.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		unlock(portScmGlobal);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initCCMS1206" id="04e35e2f-72b6-41c1-b7f6-af4155ba05a4">
        <source>initCCMS1206();
