    </JadeMethod>
    <JadeMethod name="initDataTable" id="51cc031b-eba0-41ed-86a6-feaf12b11708">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:     09 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
begin
	self.setTblDataEntRows(ETDef_TermHdrData);

	self.zClearSortColumns();
	self.zAddSortColumn(ETRow_TermName, false);
	self.zAddSortColumn(ETRow_TermType, false);
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initEntryTable" id="220fb5a3-dd3a-4042-ac42-473cd6d6cbe4">
        <source>initEntryTable(_table : CM_EntryTable input; _entDefName : String) protected;
// ---------------------------------------------------------------------------
// Created:     09 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	entTableControl	: EntTableDef;
	
begin

	_table.rows := 0;
	_table.allEntRowTransients.purge();
	_table.optimiseRowHeight := true;	
	entTableControl := app.myController.getEntTableDef(_entDefName);
	_table.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');

	_table.top := self.VerticalSpacing;
	_table.left := self.HorizontalSpacing;
	_table.lockRight := true;
	_table.setDistanceFromRight(5);
	_table.stretchWidth := true;
	_table.optimiseHeadingColumn();
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_entDefName" type="String"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="0bbf8f5f-6d38-4ec0-a247-e73eebf3e652">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	self.allowSearch 			:= false;
	self.allowPrint 			:= false;
	self.allowExportCSV			:= false;
	self.allowPrintSelected 	:= false;
	self.allowMultiSelectDelete := false;
	self.allowMultiSelectEdit 	:= false;

	self.fldHdrEntry.useSheetBackColors := true;
	self.fldHdrEntry.setDefaultSheetBackColors();
	self.fldHdrEntry.initSheetBackColors();

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblTerminologyHdr" id="1998f57b-8284-42b7-93b4-0125690ba9ef">
        <updating/>
        <source>initTblTerminologyHdr() updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 August 2004	cnwth2
//
// Purpose:     Built only once - checkbox values only change

//				
//			 
// ----------   ----------  --------------------------------------------------
vars
	cargoBOLType			: CM_CargoBOLType;
	terminal				: CM_Terminal;
	cargoBOLTypeArray		: CM_CargoBOLTypeArray;
	terminalDict			: CM_TerminalByCodeDict;
	tbl						: CM_DataTable;
	row,
	numColumns,
	col						: Integer;
	failedDAC  :CM_DataAccessController;
begin
	tbl := self.tblTermHdr;
	tbl.clear();
	tbl.fontName := 'Arial';
	tbl.fontSize := 10;
	tbl.rows := 1;
	tbl.columns := 1;
	tbl.fixedRows := 1;
	tbl.fixedColumns := 1;
	tbl.inputType := Table.InputType_CheckBox;
	tbl.accessCell(1,1).text := 'CargoType/Terminal';
	tbl.accessedCell.fontBold := true;
	
	create cargoBOLTypeArray transient;
	create terminalDict transient;
	
	app.myRoot.allBOLTypes.copy(cargoBOLTypeArray);
	app.myRoot.allCargoTypesById.copy(cargoBOLTypeArray);
	app.myRoot.allTerminals.copy(terminalDict);
	
	row := tbl.addItem('If No Cargo Type');
	tbl.accessRow(row).itemObject := null;
	foreach cargoBOLType in cargoBOLTypeArray do
		row := tbl.addItem(cargoBOLType.description);
		tbl.accessRow(row).itemObject := cargoBOLType;
	endforeach;
	
	//add column for system default
	col := tbl.columns + 1;
	tbl.columns := col;
	tbl.accessColumn(col).itemObject := null;
	tbl.accessCell(1, col).text := 'If No Terminal';
	
	foreach terminal in terminalDict do
		col := tbl.columns + 1;
		tbl.columns := col;
		tbl.accessColumn(col).itemObject := terminal;
		tbl.accessCell(1, col).text := terminal.code;
	
		if not terminal.canUserAccessSelf(null, failedDAC, app.myPassport) then 
			tbl.accessColumn(col).visible := false;
			// make not visible as if not added to table and editing exsisting data
			// then will cause all previously selected items to be cleared. 
		endif; 
	endforeach;

epilog
	delete terminalDict;
	delete cargoBOLTypeArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTblTerminologyHdr" id="20c825e5-bc0a-4e5e-bdff-075ce286b9db">
        <updating/>
        <source>populateTblTerminologyHdr(_termHdr : CM_TerminologyDef) updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cargoBOLType				: CM_CargoBOLType;
	terminal					: CM_Terminal;
	ctTerminal					: CM_TerminologyHdr;
	numRows,
	numCols,
	row,
	col							: Integer;
	checked						: String;
	tbl							: CM_DataTable;
begin
	//populate cargoTypeTerminal table
	tbl := self.tblTermHdr;
	numRows := tbl.rows;
	numCols := tbl.columns;
	
	foreach row in 2 to numRows do
		cargoBOLType := tbl.accessRow(row).itemObject.CM_CargoBOLType;
		foreach col in 2 to numCols do
			terminal := tbl.accessColumn(col).itemObject.CM_Terminal;
			
			if _termHdr &lt;&gt; null and _termHdr.allTerminologyHdrs[cargoBOLType, terminal] &lt;&gt; null then
				checked := '1';			
			else
				checked := '0';
			endif;
			
			tbl.accessCell(row, col).text := checked;
		endforeach;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_termHdr" type="CM_TerminologyDef"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="dc8e73ea-8da8-4b2f-b986-5e1e36170c76">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     23 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	colorControl	: CM_ColorController;

begin

	create colorControl transient;
	inheritMethod(colorControl);

	self.setColorsForEntryTable(self.tblHdrEntry);
	self.setColorsForTable(self.tblTermHdr);	
	self.fldHdrEntry.backColor 		:= colorControl.formBackColor;

epilog
	delete colorControl;
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="be0ee815-3fd1-4c53-a2e2-4b8cf28fb908">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     16 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.mode = self.Mode_Add then
		self.tblHdrEntry.setValueByName(ETRow_TermHdrName, null);
		self.doCmbTermTypeClick();	
		self.tblHdrEntry.enableRowByName(ETRow_TermType);
		self.populateTblTerminologyHdr(null); //clears the table
	else
		self.tblHdrEntry.disableRowByName(ETRow_TermType);
	endif;

	self.tblHdrEntry.userInputEnabled := true;
	self.tblTermHdr.userInputEnabled := true;
	self.tblHdrEntry.goToRowByName(ETRow_TermHdrName);
	
	
end;</source>
    </JadeMethod>
