    <ExplicitInverseRef name="myClassInSchema" id="cf049e5a-8231-4d61-9fd9-117805161bce">
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="ClassInSchema"/>
        <access>protected</access>
        <Inverse name="ClassInSchema::allMethodsInClass"/>
    </ExplicitInverseRef>
    <PrimAttribute name="name" id="ff61f97f-f7ef-4324-8a21-ea1dc2120e41">
        <length>101</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
