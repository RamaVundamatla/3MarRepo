    <JadeMethod name="initRunnerForCashReceipt" id="afb75326-0765-4171-816f-79eb8033c010">
        <updating/>
        <source>initRunnerForCashReceipt(_cashReceipt : CM_CashReceipt) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2018	jlger1	Initial creation 42345

*/

vars

	jrwReport	: JadeReportWriterReport;
	reportName  : String;
	voyageProcess  : CM_VoyageProcess;
	reportParam			: WS_ReportParameter;
	incrementWONumPrints : Boolean;	//24 Aug 2018	NDL	TFS 40213
begin
	if _cashReceipt = null then
		return;
	endif;
	
	self.myCashReceipt:=_cashReceipt;
	self.myWorkOrder:=_cashReceipt.myWorkOrder;
	self.myContextObject :=_cashReceipt;
	self.allTerminals.clear;
	self.allTerminals.add(_cashReceipt.getTerminal);
	//jlier1 TFS 66233 23/9/24
	if _cashReceipt.myVoyage &lt;&gt; null then
		voyageProcess:=_cashReceipt.myVoyage.myVoyageProcess;
	else
		voyageProcess:=_cashReceipt.getTerminal.getDefaultVoyageProcess;
	endif;
	if voyageProcess = null then
		return;
	endif;

	reportName :=voyageProcess.reportInvoiceEstimate;
	
	jrwReport  := self.myJadeReportWriterManager.getReport(reportName);
	
	if jrwReport = null then
		return;
	endif;
	
	//24 Aug 2018	NDL	TFS 40213
	if incrementWONumPrints then
		app.myTrxUA.trxUpdWorkOrderNumPrint( self.myWorkOrder, app.myPassport );
	endif;
	
	self.myJRWReport:=jrwReport;
	self.reportFormat 		:= CM_QryReport.PDF_Format;
epilog

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="initRunnerForVoyageViewReport" id="2dadfbf7-4fc7-4c10-ba86-298d2cc958b9">
        <updating/>
        <source>initRunnerForVoyageViewReport(	_voyage 			 : CM_Voyage input;
								_voyageProcessReport : CM_VoyageProcessReport;
								_reportDefintion	 : String
								)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation	TFS 43240
12 Sep 2019	cnwma1	ChangeRequest 46507: PEL1 - Error : Timeout reached when running reports
*/

vars
	
	jrwReport   : JadeReportWriterReport;
	reportName  : String;
	reportParam : WS_ReportParameter;
	jrwVoyages  : CM_JRWVoyages;
begin

	if _voyage = null then
		return;
	endif;
	
	if _reportDefintion &lt;&gt; null then 						//12.09.2019 cnwma1 TFS #46507
		reportName   := _reportDefintion;				    //12.09.2019 cnwma1 TFS #46507
	else
		if _voyageProcessReport = null then
			return;
		endif;
		
		reportName := _voyageProcessReport.reportName;      //12.09.2019 cnwma1 TFS #46507
		self.myContextObject := _voyageProcessReport;
	endif;
	
	self.myVoyage := _voyage;	//19 Feb 2019	TFS 43240
	if self.myContextObject = null then
		self.myContextObject := _voyage;
	endif;
	jrwReport  := self.myJadeReportWriterManager.getReport(reportName);
	if jrwReport = null then
		return;
	endif;
	
	self.myJRWReport:=jrwReport;
	self.allTerminals.clear;
	self.allTerminals.add(_voyage.myTerminal);
	
	jrwVoyages := app.myQAFilter.createJRWTransient(CM_JRWVoyages).CM_JRWVoyages;
	jrwVoyages.allVoyages.add( _voyage );

	self.reportFormat := CM_QryReport.PDF_Format;
	
epilog
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_voyageProcessReport" type="CM_VoyageProcessReport"/>
        <Parameter name="_reportDefintion" type="String"/>
    </JadeMethod>
    <JadeMethod name="initRunnerForWorkOrder" id="a9085b5a-0228-4845-89b9-ce7ac7a49ef7">
        <updating/>
        <source>initRunnerForWorkOrder( _workOrder : CM_WorkOrder io ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlger1	Initial creation 38815 work order estimates
20 Jun 2018 cnwma1	ChangeRequest 38815: PEL1 - WP TI Work Order Changes
11 Mar 2019 cnwma1	Bug 43732: PEL1 - Container Services - Cancel Load (Export Return) showing up Report in WP after payment
17 Dec 2019	NDL		TFS 48058 - Remove line that gets parent of extension (was line 48)
*/

vars
	jrwReport	: JadeReportWriterReport;
	reportName  : String;
	voyageProcess  : CM_VoyageProcess;
	reportParam			: WS_ReportParameter;
begin
	if _workOrder = null then
		return;
	endif;
	
	self.myWorkOrder:=_workOrder;
	self.myContextObject :=_workOrder;
	self.allTerminals.clear;
	self.allTerminals.add(_workOrder.myTerminal);
	
	voyageProcess:=self.myWorkOrder.myTerminal.getDefaultVoyageProcess;

	if voyageProcess = null then
		return;
	endif;

	self.isRunWorkOrderReport := true;   							//20.6.2018 cnwma1 TFS #38815
	if _workOrder.allWoDtls.first.isKindOf(CM_WodReceive) then
		reportName :=voyageProcess.workOrderReceivalReport;								//24 Aug 2018	NDL	TFS 40213
	elseif _workOrder.allWoDtls.first.isKindOf(CM_WodRelease) then  //11 Mar 2019 cnwma1 #43732
		reportName :=voyageProcess.workOrderReleaseReport;
	elseif _workOrder.allWoDtls.first.isKindOf(CM_WodReleaseExtension) then	//12 Mar 2019	NDL	TFS 43405
		if not _workOrder.allWoDtls.first.CM_WodReleaseExtension.canPrintWOReportOnWeb then
			_workOrder := null; // so caller doesn't print
			return;
		else
			reportName :=voyageProcess.workOrderReleaseReport;
	//		_workOrder := _workOrder.allWoDtls.first.CM_WodReleaseExtension.myReleaseWorkOrder.getMyParent;
		endif;
	endif;
	
	jrwReport  := self.myJadeReportWriterManager.getReport(reportName);
	
	if jrwReport = null then
		return;
	endif;
	

	app.myTrxUA.trxUpdWorkOrderNumPrint( _workOrder, app.myPassport );
	
	
	self.myJRWReport:=jrwReport;
	self.reportFormat 		:= CM_QryReport.PDF_Format;
epilog

end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder" usage="io"/>
    </JadeMethod>
    <JadeMethod name="initRunnerFromVoyageInvoice" id="d67ab0b4-121a-4c2d-88c2-d2529039e0db">
        <updating/>
        <source>initRunnerFromVoyageInvoice( _invoice 			  : CM_Invoice;
							 _isPreInvoice 		  : Boolean;
							 _voyageProcessReport : CM_VoyageProcessReport;
							 _reportDefintion     : String) updating;
/*
Purpose:	TFS 41539		
Date				Who			Reason
OCTOBER 2018		CNWAB1		Initial creation
05 Nov 2018 		JLGER1		TFS 41539 - no longer set voyage status - it does not matter anymore
12 Sep 2019	cnwma1	ChangeRequest 46507: PEL1 - Error : Timeout reached when running reports
*/

vars
	
	jrwReport	   : JadeReportWriterReport;
	reportName     : String;
	voyageProcess  : CM_VoyageProcess;
	reportParam	   : WS_ReportParameter;
	voyage 		   : CM_Voyage;
begin
	if _invoice = null then
		return;
	endif;
	voyage:=_invoice.myVoyage;
	if voyage = null then
		return;
	endif;
	
	if _reportDefintion &lt;&gt; null then					//12.09.2019 cnwma1 TFS #46507
		reportName 			 := _reportDefintion;
		self.myInvoice		 := _invoice;
		self.myContextObject := _invoice;
	else
		voyageProcess := voyage.myVoyageProcess;
		if voyageProcess = null then
			return;
		endif;
		
		self.myInvoice		 := _invoice;
		self.myContextObject := _invoice;
		
		if _voyageProcessReport &lt;&gt; null then	//08 Feb 2019	NDL TFS 43240
			reportName := _voyageProcessReport.reportName;
			self.myContextObject := _voyageProcessReport;
		elseif _isPreInvoice then
			reportName := voyageProcess.reportInvoicePreinvoice;
		else
			reportName := voyageProcess.reportInvoiceTaxinvoice;
		endif;
	endif;
	jrwReport  := self.myJadeReportWriterManager.getReport(reportName);
	
	if jrwReport = null then
		return;
	endif;
	
	self.myJRWReport:=jrwReport;
	self.allTerminals.clear;
	self.allTerminals.add(voyage.getMyTerminal);

	create reportParam transient;
	reportParam.setValues(ETRow_MyVoyage,voyage.getOidAsString);
	if self.allWSReportParams[ETRow_MyVoyage] = null then
		self.allWSReportParams.add(reportParam);
	endif;
	self.reportFormat 		:= CM_QryReport.PDF_Format;
epilog
	
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_isPreInvoice" type="Boolean"/>
        <Parameter name="_voyageProcessReport" type="CM_VoyageProcessReport"/>
        <Parameter name="_reportDefintion" type="String"/>
    </JadeMethod>
    <JadeMethod name="isRowIncluded" id="70911bfc-5363-4611-886d-d39a548a23b6">
        <source>isRowIncluded(_rowName: String): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2008	cnwkao1	Initial creation

*/

vars

begin
	return self.allWSReportParams.getAtKey(_rowName) &lt;&gt; null;

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDefaultParameterByName" id="0399988f-5473-4db4-a88d-c68e3c79bca7">
        <updating/>
        <source>loadDefaultParameterByName(_defaultTemplate : CMQF_FilterReports; 
					_row : EntTableRow;
					_rowNameParameter : String;
					_defaultValueStr : String io;
					_defaultOID : String output) updating;
// ---------------------------------------------------------------------------
// Created:     30/04/2009 cnwdz2 par 19541
//
// Purpose:     retrive the default value for a report critiria
//			 
vars
	getCalculatedDate			: Boolean;
	rowName : String;
begin

	if _row &lt;&gt; null then
		rowName:=_row.name;
	endif;
	
	if rowName = null then
		rowName := _rowNameParameter;
	endif;
	
	getCalculatedDate := not (self.state = self.STATE_TEMPLATE_SAVE or self.state = self.STATE_TEMPLATE_EDIT);
	
	if _defaultTemplate &lt;&gt; null then
		_defaultValueStr := _defaultTemplate.getOIDAndDescForAttribute(rowName, getCalculatedDate, _defaultOID);//19/07/2010 cnwdz2 par24513
	endif;
end;</source>
        <Parameter name="_defaultTemplate" type="CMQF_FilterReports"/>
        <Parameter name="_row" type="EntTableRow"/>
        <Parameter name="_rowNameParameter" type="String"/>
        <Parameter name="_defaultValueStr" type="String" usage="io"/>
        <Parameter name="_defaultOID" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="runJRWReport" id="fe24b2e0-976e-4c41-92dc-de3fe6f43800">
        <updating/>
        <source>runJRWReport(_fileName : String;_formatOption : Integer; _noOutput : Boolean output ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlger1	Initial creation

*/

vars
	file : File;
	pxyJadeReport		: JadeReport;
	replacementFileTS : TimeStamp;
	clientStartTime   : TimeStamp;
	sleepTime : Integer;	//20 Feb 2019	NDL	TFS 43240
	sleepCount : Integer;	//20 Feb 2019	NDL	TFS 43240
	raiseError : Boolean;	//20 Feb 2019	NDL	TFS 43240
begin
	self.fileName			:= _fileName;
	self.printerName		:= null;
	self.printPreview		:= false;
	self.outputtingToFile	:=  (_formatOption &lt;&gt; JadeReportWriterReport.PRINTER);
	
	create file transient;
	file.mode := File.Mode_Output;
	file.fileName := self.fileName;	
	app.printer.abort();
	//if profile is specified then use it
	if self.profileName &lt;&gt; null then
		self.myJRWReport.setProfile(self.profileName.trimBlanks);
	endif;		

	create pxyJadeReport transient;
	pxyJadeReport.description := app.getErrorString(CM_Default);
	app.printer.printPreview := false;

	self.myJRWReport.setOutputFileTitle(self.fileName);
	app.printer.setReport(pxyJadeReport);
	self.setParameters(self.myJRWReport);			
	self.myJRWReport.setOutputDestination(_formatOption);
			
	app.printer.suppressDialog := true;
	
	self.myJRWReport.run;
		
	process.initiateTransientCompact();		// TFS 8294
			
	if file &lt;&gt; null and file.isOpen then
		file.close; //18 Dec 2017	NDL	TFS 8267 - Previously it didn't care.... now it does.
	endif;
	
	self.printReport(pxyJadeReport);
	
	if self.fileName &lt;&gt; null then
		app.getFileLastModified( self.fileName, replacementFileTS );
		// 33875 file was created on client using client PC time so compare using the client current time (was previously startTime from server)
		if not replacementFileTS.Date.isValid or replacementFileTS &lt; clientStartTime then
		
			//Some sort of timing hole while testing 20 Feb 2019 TFS 43240 NDL
			sleepTime := 500;
			raiseError := true;	
			while sleepCount &lt; 2000 do
				sleepCount := sleepCount + sleepTime;
				process.sleep(sleepTime);
				app.getFileLastModified( self.fileName, replacementFileTS );
				if not replacementFileTS.Date.isValid or replacementFileTS &lt; clientStartTime then
					//still can't find it.
					continue;
				else
					//found it now...
					raiseError := false;
					break;
				endif;
			endwhile;
			
			// No file, or file too old, indicate that they should NOT send it.
			if raiseError then 
				if self.myContextObject = null  then			
					app.raiseCMException(No_Print_Output,null, null);			
				else
					_noOutput := true;
				endif;
			endif;

		endif;
	endif;
	
epilog
	delete pxyJadeReport;	
	delete file;
end;	</source>
        <access>protected</access>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_formatOption" type="Integer"/>
        <Parameter name="_noOutput" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="runReportForWeb" id="9f5dbfbb-3eca-4a2a-acf6-a630361a96ab">
        <updating/>
        <source>runReportForWeb( _noOutput : Boolean output ):String updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Sep 2008	cnwkao1	Initial creation - based on WebSchema implementation
19 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	//self.myInformationString := null; - KO - appears to only be used for displaying errors
	self.reportBinary := null; //KO - used for PDF display
	if self.myReportData &lt;&gt; null then
		delete self.myReportData;
	endif;
	
	if self.isBackground then
		app.writeLog('Attempting to run report in background for session (Id) ' &amp; 
					 currentSession.getSessionId.String &amp;
					 ' ' &amp; process.String, LogINFO);
		self.runWebRptInBackground();
	else
		if currentSession &lt;&gt; null then
			app.writeLog('Attempting to run report in foreground for session (Id) ' &amp; 
					 currentSession.getSessionId.String &amp; 
					 ' ' &amp; process.String, LogINFO);
		 endif;
		self.runWebRptOnWebServer( _noOutput );
	endif;
	
	return null;
	
	
epilog

end;</source>
        <Parameter name="_noOutput" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="runVoyageProcessReport" id="49d296a3-3ae4-43c9-a251-dad9662ad4bd">
        <updating/>
        <source>runVoyageProcessReport(_fileName : String;_formatOption : Integer; _noOutput : Boolean output ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/05/2018	jlger1	Initial creation 38530
13/08/2019	jlgdap1	TFS 40030 PEL1 Multiple Estimates and Invoices
05/11/2019 	jlger1	TFS 41539 PEL1 deleted whole lot of code that never used now just prints from the set invoice
18 Jul 2019	NDL		TFS 42876 PEL! Remove extraneous lock keeper call, was causing 100010 errors
*/

vars
	status : Integer;
	voyage : CM_Voyage;
	cmifCashHeader : CMIF_CashReceiptHeader;
	jrwInvoice : CM_JRWInvoice;
	invoice 	: CM_Invoice;
	termDict 	: CM_TerminalByCodeDict;
	startTime		: TimeStamp;
//	endNoteSent		: Boolean;
	documentType :Integer;
	workOrder : CM_WorkOrderVoyageDtl;
	jrwVoyages : CM_JRWVoyages;	//19 Feb 2019	TFS 43240
begin
	if _formatOption &lt;&gt; JadeReportWriterReport.PRINTER and _fileName.trimBlanks = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Output file name is null');
		return;
	endif;	
	
//	endNoteSent := app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	if self.myInvoice = null and self.myVoyage = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invoice and Voyage are null');
		return;
	endif;
	documentType := app.printer.documentType;
	
	if self.myInvoice &lt;&gt; null then
		jrwInvoice := app.myQAFilter.createJRWTransient(CM_JRWInvoice).CM_JRWInvoice;
	
		create termDict transient;
		termDict.add(self.myInvoice.myTerminal);
		jrwInvoice.setAllTerminals(termDict);
		
		if self.myInvoice &lt;&gt; null  // TFS 41539 always show all invoices that are prepend, pending or posted
		and  self.myInvoice.status.isOneOf(invoice.INVOICE_PREPEND, invoice.INVOICE_PENDING, invoice.INVOICE_POSTED) then // TFS 41539
				jrwInvoice.allInvoices.add(self.myInvoice);	 // TFS 41539
	
		endif;
		
	elseif self.myVoyage &lt;&gt; null then	//19 Feb 2019	TFS 43240
		jrwVoyages := app.myQAFilter.createJRWTransient(CM_JRWVoyages).CM_JRWVoyages;
		
		create termDict transient;
		termDict.add(self.myVoyage.myTerminal);
		jrwVoyages.setAllTerminals(termDict);
		jrwVoyages.allVoyages.add(self.myVoyage);
		
	endif;
		
	self.runJRWReport(_fileName,_formatOption,_noOutput);
	
epilog
	delete termDict;
	delete self.myJRWReport;

	delete cmifCashHeader;
	app.printer.abort();
//	if (not endNoteSent) then
//		abortTransaction;	
//		app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
//	endif;
	app.printer.documentType:=documentType;
	app.writeLog('completed', LogINFO);
end;</source>
        <access>protected</access>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_formatOption" type="Integer"/>
        <Parameter name="_noOutput" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="runWebRptInBackground" id="bf5c1b07-acf4-451a-9ceb-cb38f1d2fd18">
        <updating/>
        <source>runWebRptInBackground() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwkao1	Initial creation - based on WebSchema implementation

*/
vars

	filterObject	: CMQF_FilterReports;
	terminal,
	reportName,
	profileName,
	reportDesc,
	heading,
	sender,
	ext				: String;
	formatOption1	: Integer;
	userSet			: CM_UserSet;
	user			: CM_User;
	email			: CM_EmailTemplate;
begin

	create userSet transient;
	
	formatOption1 := self.reportFormat;
	ext := app.getExtension(formatOption1);
	reportName	:= self.myQryReport.reportName;
	reportDesc	:= self.myQryReport.reportDescription &amp; ' (' &amp; ext &amp; ')';
	profileName := self.getValueByNameIfVisible(ETRow_ReportProfile).String;
	
	if self.myQryReport.isFormBasedReport then	
		formatOption1 := CM_QryReport.PDF_Format;
		self.reportFormat := formatOption1;
	endif;
	
	user := app.getMyUser();//currentSession.myUser;
//	self.printerName		:= 'DEFAULT';	// cnwrl1 11/11/2009
	self.printerName		:= Printer_Default;
	
/*	if formatOption1 = CM_QryReport.PDF_Format then
		if user = null or not user.canDo(null, PmPDFBackground) then
			//self.setInformationString($NoPDFPermission(terminal));
			app.raiseCMException1(Have_permiss_reports_termina,terminal,
							null, 
							null);
			
			return;
		endif;
	endif; */	// 07 Oct 2019	NDL	TFS 46169
	
	app.writeLog('Report - ' &amp; self.myQryReport.reportName &amp; ', User Id - ' &amp; user.code, LogINFO);
	
	
	filterObject := self.doGetQueryFilter();
	
	userSet.add(user);
	
	if self.isReportToBeEmailed then
		/* KO - different implementation
		emailAddresses  := self.myBasePage.getHttpValue(JMTBasePage.HTMLTag_EmailAddresses).replaceHTMLChars();
		self.emailAddresses := emailAddresses;
		*/
		heading := self.myQryReport.reportName &amp; ext;
		sender := app.myRoot.getConfig(AutoSendersEmailAddress).String;
		create email transient;
//	($Background_Report($Web) &amp; ' ' &amp; $User &amp; ' ' &amp; app.myPassport.getUserCode(), tmpEmailAddresses, sender, null, null, heading,
//												heading, null, binary, heading, EmailSource_Reports, null, app.myPassport);

		email.setProxy(	null,
						null,
						null,
						null,
						self.emailAddresses,
						//null,
						null,
						null,
						heading,
						heading,
						false);
	endif;	
	
	app.myTrxCA.trxCreateAndRunBackgroundRpt(	false,
												reportName,
												reportDesc,
												profileName,
												self.printerName,
												null,
												formatOption1,
												BGP_ReportRequest.Save,
												false,
												filterObject,
												self.myQryReport,
												null,
												email, //emailTemplate,
												user.code,
												userSet,
                                                null, //MTN-36668
												app.myPassport);

epilog
	delete userSet;
	delete email;
	delete filterObject;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="runWebRptOnWebServer" id="436a084e-2601-45b2-bdb9-0375fe585819">
        <updating/>
        <source>runWebRptOnWebServer( _noOutput : Boolean output ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Sep 2008	cnwkao1	Initial creation - based on WebSchema implementation
16 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
					Rework to remove load of file when not sending an email
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
20/06/2018   cnwma1		ChangeRequest 38815: PEL1 - WP TI Work Order Changes
*/

vars
	filterObject			: CMQF_FilterReports;
	formatOption1,
	formatOption2					: Integer;
	workFile				: File;
	binary				: Binary;
	fileName,
	partFileName,
	ext,
	fileURL,
	sender,
	heading,
	tmpEmailAddresses,
	terminalCode			: String;
	user					: CM_User;
	terminal				: CM_Terminal;
	startTs,
	endTs					: TimeStamp;
	diff					: Decimal[10,2];
	noDataEmail					: Boolean;
begin
	if self.isReportToBeEmailed then
		tmpEmailAddresses := self.emailAddresses;	
		if tmpEmailAddresses = null then
			app.raiseCMException(No_Email_address_supplied, null, null);
			return;
		endif;		
	endif;

	user := app.getMyUser();
	
	
	filterObject := self.myFilterObject;
	// Use the one we already have. If not, get it from the query report
	//if self.myQryReport &lt;&gt; null then
	if filterObject = null and self.myQryReport &lt;&gt; null then //11/07/2024	navkc1 CR 64837 Task 64852
		app.writeLog('Report - ' &amp; self.myQryReport.reportName &amp; ', User Id - ' &amp; user.code, LogINFO);
		filterObject := self.doGetQueryFilter();
	endif;
	
	if self.myJRWReport &lt;&gt; null then
		app.writeLog('Report - ' &amp; self.myJRWReport.name &amp; ', User Id - ' &amp; user.code, LogINFO);
		//self.reportFormat :=CM_QryReport.PDF_Format;
	
	endif;
	
	profileName := self.getValueByNameIfVisible(ETRow_ReportProfile).String;
	
	formatOption1 := self.reportFormat;
	if self.myQryReport &lt;&gt; null and self.myQryReport.isFormBasedReport then	
		formatOption1 := CM_QryReport.PDF_Format;
		self.reportFormat := formatOption1;
	endif;
	
	
	// Set up unique filename and resulting URL for this run
	ext := app.getExtension(formatOption1);
	partFileName := self.OUTPUT_FILE_PREFIX &amp; app.actualTimeServer.fileNameFormat &amp; "_" &amp; // 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
					app.relativeMachineMicros.String &amp; "_" &amp;
					self.getInstanceIdForObject64(process).String &amp; "_" &amp; 
					self.getInstanceIdForObject64(self).String &amp; ext;
					
	fileName := app.downloadFileDirectoryPath &amp; partFileName;
	fileURL := app.downloadFileDirectoryURL &amp; partFileName;
	
	if formatOption1 = CM_QryReport.PDF_Format then
		terminal := self.allTerminals.first;
	/*	if not user.canDo(terminal, PmPDFBackground) then
			if terminal &lt;&gt; null then
				terminalCode := terminal.code;
			endif;
			//self.setInformationString($NoPDFPermission(terminalCode));
			app.raiseCMException1( Have_permiss_reports_termina,terminalCode,null, null);
			return;
		endif;	*/	//07 Oct 2019	NDL	TFS 46169
		formatOption2 := JadeReportWriterReport.PRINTER;
	else
		formatOption2 := formatOption1;
	endif;

	startTs := app.actualTimeServer();
	app.writeLog('Starting to run report at - ' &amp; startTs.shortCurrentLocaleFormat(), LogINFO);
	
	// Need to change Process usercode so that Report Writer specifla field "User Id" works
	beginTransaction;
	process.changeUserCode(user.code);
	commitTransaction;
	
	//epr tfs 38530 17/5/18
	if self.myInvoice &lt;&gt; null
	or self.myVoyage &lt;&gt; null	//19 Feb 2019	TFS 43240
	then  //epr TFS 41539 5/11/18 
		self.runVoyageProcessReport( fileName,formatOption2,_noOutput );
		if _noOutput then
			return;
		endif;
	elseif self.myWorkOrder &lt;&gt; null then
		//self.runWorkOrderEstimate( fileName,formatOption2); //20.6.2018 cnwma1 TFS #38815
		//20.6.2018 cnwma1 TFS #38815
		if self.isRunWorkOrderReport then
			self.runWorkOrderReport(fileName,formatOption2);
		else
			self.runWorkOrderEstimate( fileName,formatOption2);
		endif;
	elseif self.myCashReceipt &lt;&gt; null then  //jlier1 TFS 66233 25/9/24
		self.runWorkOrderEstimate(fileName,formatOption2);
	else
		self.runForegroundReport(self.myQryReport,
								 filterObject,
								 null,
								 profileName,
								 formatOption2,
								 fileName,
								 null,
								 false, 
								 noDataEmail);						// 10/08/2010 cnwmh5 #25358
	endif;						
	endTs := app.actualTimeServer();
	diff := startTs.getDifference(endTs);
	
	app.writeLog('Report finished at - ' &amp; endTs.shortCurrentLocaleFormat() &amp; '. The run took ' &amp; (diff / 1000).String &amp; ' seconds',  LogINFO);

	create workFile transient;									
	workFile.fileName := fileName;
	if (not workFile.isAvailable) then
		app.writeLog('Could not locate file - ' &amp; fileName, LogINFO);
		app.raiseCMException1(ERR_CouldNotLocateFile, fileName, null, null);
		return;
	else
		app.writeLog('Report output file - ' &amp; fileName &amp; " created", LogINFO);
	endif;

	// Only read contents of file if it is to be emailed or we're using virtual directory copy
	if self.isReportToBeEmailed or app.downloadFileRemoteCopy then
	
		// Open and read the file if it is being emailed or copied
		workFile.kind := workFile.Kind_Binary;
		workFile.open();
		binary := workFile.readBinary(workFile.fileLength);
		workFile.close();
		//workFile.purge();
		
		if binary &lt;&gt; null then
			if self.isReportToBeEmailed then
				heading := self.myQryReport.reportName &amp; app.getExtension(formatOption1);
				sender := app.myRoot.getConfig(AutoSendersEmailAddress).String;
				app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString1(Background_Report, app.getErrorString(Web)) &amp; ' ' &amp; $User &amp; ' ' &amp; app.myPassport.getUserCode(), tmpEmailAddresses, sender, null, null, heading,
														heading, null, null, binary, heading, EmailSource_Reports, null, app.myPassport);
			endif;
			//27/07/2010 cnwdz2 24674
			if app.downloadFileRemoteCopy then
				self.reportBinary := binary;
			endif;
		endif;
	
	endif;

	// And pass back the URL to the file
	self.reportOutputFileName := fileName;
	self.reportOutputFileURL := fileURL;
		
epilog
	delete workFile;
	delete filterObject;

end;</source>
        <access>protected</access>
        <Parameter name="_noOutput" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="runWorkOrderEstimate" id="3faba2dc-3349-4712-86f4-8a0c82fc6bb0">
        <updating/>
        <source>runWorkOrderEstimate(_fileName : String;_formatOption : Integer) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlger1	Initial creation 38520
20/06/2018   cnwma1		ChangeRequest 38815: PEL1 - WP TI Work Order Changes renamed from runWorkOrderReport  &gt;&gt; runWorkOrderEstimate
13/09/20148	jlgdap1	TFS 40030 PEL1 Multiple Estimates and Invoices
18 Jul 2019	NDL		TFS 42876 PEL! Remove extraneous lock keeper call, was causing 100010 errors
25 Sep 2024 JLIER1	TFS 66233 FR 54207 - PDF document seems to be blank in both Draft and Final messages
*/

vars
	cmifCashHeader : CMIF_CashReceiptHeader;
	jrwInvoice : CM_JRWInvoice;
	startTime		: TimeStamp;
//	endNoteSent		: Boolean;
	documentType :Integer;
	termDict 	: CM_TerminalByCodeDict;
	noOutput : Boolean;	//20 Feb 2019	NDL	TFS 43240
	isQTS	 : Boolean; //06/12/2024	navkc1 JIRA Bug MTN-33566
begin
	if _formatOption &lt;&gt; JadeReportWriterReport.PRINTER and _fileName.trimBlanks = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Output file name is null');
		return;
	endif;
	
	isQTS := app.myRoot.isClientMilaha(); //06/12/2024	navkc1 JIRA Bug MTN-33566
	
//	endNoteSent := app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);

	documentType := app.printer.documentType;
	
	
	jrwInvoice := app.myQAFilter.createJRWTransient(CM_JRWInvoice).CM_JRWInvoice;

	create termDict transient;
	termDict.add(app.myPassport.myTerminal);
	jrwInvoice.setAllTerminals(termDict);
	//if self.myWorkOrder.myCashReceipt &lt;&gt; null then			// TFS 40030
	if self.myCashReceipt &lt;&gt; null then							// TFS 40030
		//create the header
		//cmifCashHeader :=self.myWorkOrder.myCashReceipt.createCashReceiptHeader(null); // 17.09.2018 cnwma1
		if isQTS then
			cmifCashHeader := self.myCashReceipt.createCashReceiptHeaderQTS(); //06/12/2024	navkc1 JIRA Bug MTN-33566
		else
			cmifCashHeader := self.myCashReceipt.createCashReceiptHeader(null);				 // 17.09.2018 cnwma1
		endif;
	endif;
	
	//create the jrw transient 
	if cmifCashHeader &lt;&gt; null then
		jrwInvoice.allCashReceiptReporting.add(cmifCashHeader);
		jrwInvoice.myDebtor:=cmifCashHeader.myDebtor;
	endif;
		
	self.runJRWReport(_fileName,_formatOption,noOutput);
	
epilog
	delete termDict;
	delete self.myJRWReport;
	delete cmifCashHeader;
	app.printer.abort();
//	if (not endNoteSent) then
//		abortTransaction;	
//		app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
//	endif;
	app.printer.documentType:=documentType;
	app.writeLog('completed', LogINFO);

end;</source>
        <access>protected</access>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_formatOption" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="runWorkOrderReport" id="b2e42c8d-519b-41e1-b74d-ab9ad6a4ff34">
        <updating/>
        <source>runWorkOrderReport(_fileName : String;_formatOption : Integer) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/06/2018  cnwma1	ChangeRequest 38815: PEL1 - WP TI Work Order Changes
18 Jul 2019	NDL		TFS 42876 PEL! Remove extraneous lock keeper call, was causing 100010 errors
*/

vars
	jrwTrans : CM_JRWTransaction;
	startTime		: TimeStamp;
//	endNoteSent		: Boolean;
	documentType :Integer;
	termDict 	: CM_TerminalByCodeDict;
	ti : CM_TrackedItem;
	trans : CM_TITransaction;
	allTIs : CM_TISet;
	noOutput : Boolean;	//20 Feb 2019	NDL	TFS 43240
begin
	if _formatOption &lt;&gt; JadeReportWriterReport.PRINTER and _fileName.trimBlanks = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Output file name is null');
		return;
	endif;
	
	
//	endNoteSent := app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);

	documentType := app.printer.documentType;
	
	if self.myWorkOrder = null then
		return;
	endif;

	jrwTrans := app.myQAFilter.createJRWTransient(CM_JRWTransaction).CM_JRWTransaction;

	create termDict transient;
	termDict.add(app.myPassport.myTerminal);
	jrwTrans.setAllTerminals(termDict);
	
	//create the jrw transient 
	create allTIs transient;		//27 Jun 2018	NDL	TFS 39246
	 self.myWorkOrder.getAllTIs(allTIs);
	foreach ti in allTIs do
		if ti&lt;&gt; null then
			foreach trans in ti.allTransactions do
				if trans.isKindOf(CM_WorkOrderReceival) 
					or trans.isKindOf(CM_WorkOrderRelease) 
					or trans.isKindOf(CM_WodExportReturn)  then
					jrwTrans.allTransactions.add(trans);
				endif;
			endforeach;
		
		endif;
	
	endforeach;

	self.runJRWReport(_fileName,_formatOption,noOutput);
	
epilog

	delete allTIs;
	delete termDict;
	delete self.myJRWReport;
	app.printer.abort();
//	if (not endNoteSent) then
//		abortTransaction;	
//		app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
//	endif;
	app.printer.documentType:=documentType;
	app.writeLog('completed', LogINFO);

end;</source>
        <access>protected</access>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_formatOption" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyCashReceipt" id="05f7b761-57d6-44d7-9290-c15111912647">
        <updating/>
        <source>setMyCashReceipt(_cashReceipt : CM_CashReceipt) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/09/2018	jlgdap1		Initial creation TFS 40030 PEL1 Multiple Estimates and Invoices
//
vars

begin
	self.myCashReceipt := _cashReceipt;
epilog

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
    </JadeMethod>
