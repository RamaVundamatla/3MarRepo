<Class name="CM_WOToDo_Voyage" id="7d95daae-b48c-49a3-920d-fc19145369c5">
    <superclass name="CM_WOTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getMyVoyageObject" id="2e53e275-bd62-40c9-9f10-d5b0593142a9">
        <source>getMyVoyageObject(): CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Mar 2023	navma1	Defect 57188: MTN - WO -Voyage is not correctly shown if there are multiple To Do Voyage tasks

*/

vars

begin
	
	if self.myWorkOrderDetail  = null then
		return null;
	endif;

	return self.myWorkOrderDetail.getMyVoyageObject();
epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="8648ac03-433b-430f-a312-af1834015c98">
        <source>getVoyageCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 January 2023	navhl20 ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
04 Aug 2023		navlw1	ChangeRequest 59284:[59660] EUP | FR - VAS Work Order Transactions - Fixing Duplicate Values 

*/

vars

begin
	if self.myWorkOrderDetail = null then
		return null;
	endif;

	if self.myWorkOrderDetail.CM_WodToDoVoyage.allVoyages.isEmpty() then
		return null;
	endif;
	
	return self.myWorkOrderDetail.CM_WodToDoVoyage.allVoyages.listString(Comma,CM_Voyage::code.name); // 04.08.2023 navlw1 tfs #59284:#59660
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
