		_controller.logEntry(" Initializing MTN Work Order Job Sheet") ;	
	endif;
	
	beginTransaction;
	
	foreach term in app.myRoot.allTerminals do 
		if term.myWOJobSheet = null then
			term.createJobSheets();
		endif;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Initializing MTN Work Order Job Sheet COMPLETE", LogINFO);
