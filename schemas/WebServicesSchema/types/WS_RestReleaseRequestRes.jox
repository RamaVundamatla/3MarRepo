    <JadeMethod name="setProxyFromObject" id="25a4f9bc-ce95-45a2-85fa-485cfa25d03d">
        <updating/>
        <source>setProxyFromObject(_releaseReq : CM_BulkRelease) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/06/2024	navdap1		Initial creation TFS 63107 CUX | GET /releaseRequest API to return release request line items
// 29/07/2024	navmd1		TFS 65433 Fix requestDateTime and estimatedRequiredDateTime returning local timestamps instead of UTC
// 30/07/2024	navlw1		TFS 65433 Fix issue with external voyage code
//
vars
	carrier				: CM_Carrier;
	consignee,
	consignor,
	freightForwarder	: CM_ConsigneeConsignor;
	bookingRef 			: CM_BookingRef;
	transferToTerminal 	: CM_Terminal;
	dischargePort 		: CM_Port;
	operator 			: CM_Operator;
	pinNbr 				: CM_PinNo;
	subTerminal 		: CM_SubTerminal;
	voyage 				: CM_Voyage;
	
begin
	carrier := _releaseReq.getCarrier();
	if carrier &lt;&gt; null then
		self.carrierId := carrier.code;
	endif;
	
	consignee := _releaseReq.getConsignee();
	if consignee &lt;&gt; null then
		self.consigneeId := consignee.code;
	endif;
	
	consignor := _releaseReq.getConsignor();
	if consignor &lt;&gt; null then
		self.consignorId := consignor.code;
	endif;
	
	freightForwarder := _releaseReq.getFreiForwarder();
	if freightForwarder &lt;&gt; null then
		self.freightForwarderId := freightForwarder.code;
	endif;
	
	bookingRef := _releaseReq.myBookingRefStock;
	if bookingRef &lt;&gt; null then
		self.bookingId := bookingRef.bookingReference;
	endif;
	
	self.deliveredToDate := _releaseReq.totalRequested - _releaseReq.quantityRemaining;
	
	transferToTerminal := _releaseReq.myTransferToTerminal;
	if transferToTerminal &lt;&gt; null then
		self.destinationTerminalId := transferToTerminal.code;
	endif;
	
	self.consignorVoyageId := _releaseReq.consignorVoyageCode;
	self.deliveryReleaseNumber	:= _releaseReq.deliveryReleaseNumber;					// 26/3/24 navsaa30 #62853
	self.allowCargoOnMultipleReleases	:= _releaseReq.allowCargoOnMultipleReleases;    // 26/3/24 navsaa30 #62853
	
	dischargePort := _releaseReq.myDischargePort;
	if dischargePort &lt;&gt; null then
		self.dischargePortId := dischargePort.code;
	endif;
	
	self.estimatedRequiredDateTime := _releaseReq.dateEstimatedRequired.localToUTCTime.asJSONFormat; 	// 11.04.24		navhn30		TFS #63474
	self.freightPayerCode := _releaseReq.freightPayerCode;
	self.fullRelease := _releaseReq.fullRelease;
	self.id := _releaseReq.code;

	operator := _releaseReq.myOperator;
	if operator &lt;&gt; null then
		self.operatorId := operator.code;
	endif;
	
	pinNbr := _releaseReq.myPinNo;
	if pinNbr &lt;&gt; null then
		self.pinNo := pinNbr.pinNo;
	endif;
	
	self.releaseByType := _releaseReq.releaseByType;
	self.remarks := _releaseReq.cargoRemarks;
	self.requestDateTime := _releaseReq.dateRequested.localToUTCTime.asJSONFormat;
	self.requestType := _releaseReq.getTypeDescription();
	self.status := _releaseReq.status;
	
	subTerminal := _releaseReq.mySubTerminal;
	if subTerminal &lt;&gt; null then
		self.subTerminalId := subTerminal.code;
	endif;

	self.deliveredToDate := _releaseReq.getTotalReleased();
	
	voyage := _releaseReq.myVoyage;
	if voyage &lt;&gt; null then
		self.voyageExternalId := voyage.voyageCodeExternal;
		self.voyageId := voyage.code;
	endif;

epilog

end;</source>
        <Parameter name="_releaseReq" type="CM_BulkRelease"/>
    </JadeMethod>
</Class>
