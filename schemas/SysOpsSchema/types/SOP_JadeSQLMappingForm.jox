    <JadeMethod name="initProxy" id="ce991fc7-8dd7-47b9-affd-ff2b6b46fbfd">
        <updating/>
        <source>initProxy(_pxyExtractClass : CM_DataDumpExtractClass) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	#cnwdz2	 24641

*/

vars
	pxyExtractClass : CM_DataDumpExtractClass;
begin
	if self.myProxyObject = null then
		create self.myProxyObject as CM_DataDumpExtractClass transient;
	endif;
	if _pxyExtractClass = null then
		return;
	endif;

	pxyExtractClass := self.myProxyObject.CM_DataDumpExtractClass;
	pxyExtractClass.setProxy(_pxyExtractClass.myDataDumpClass,_pxyExtractClass.allDataDumpFeatures,
								_pxyExtractClass.sqlTableName, 
								_pxyExtractClass.deleteAction,  _pxyExtractClass.deleteActionColumnName,  _pxyExtractClass.deleteActionColumnPos,
								_pxyExtractClass.lastOperation, _pxyExtractClass.lastOperationColumnName, _pxyExtractClass.lastOperationColumnPos,
								_pxyExtractClass.exportedTimestampColumnName, _pxyExtractClass.exportedTimestampColumnPos,
								_pxyExtractClass.oidColumnPos, _pxyExtractClass.extractedUpToDateTime);

	pxyExtractClass.allDataDumpSQLColumns.clear();
	_pxyExtractClass.allDataDumpSQLColumns.copy(pxyExtractClass.allDataDumpSQLColumns);
epilog

end;</source>
        <Parameter name="_pxyExtractClass" type="CM_DataDumpExtractClass"/>
    </JadeMethod>
