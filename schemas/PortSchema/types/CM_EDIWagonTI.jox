epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processAttributeDependencies" id="622453c7-cb96-4072-be53-dab232d8676e">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist : CMIF_EDIUserDefinedAssist input; _strIdentifier : String; _reset : Boolean; _xlationOperator :CM_Operator) updating;
//
// Date			Who		Reason
// 28 Apr 2011	cnwrs1	ccms 2044 - added strIdentifier
//20 Mar 2015	cnwrs1	Par 34702 - Add support for JMT XML with implied header
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//18 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//
vars

begin
	inheritMethod( _ediUserDefinedAssist,_strIdentifier, _reset, _xlationOperator);
	if _reset then
		if self.myEDIData.isKindOf(CM_EDIDataTrainConsist) then
			_ediUserDefinedAssist.currentWagonNumber := null;
		endif;
	else
		if self.myEDIData.isKindOf(CM_EDIDataTrainConsist) then
			_ediUserDefinedAssist.currentWagonNumber := self.wagonNumber;
			if self.trainCode = null then
				self.trainCode := _ediUserDefinedAssist.currentTrainCode;
				self.scheduledArrivalDT := _ediUserDefinedAssist.currentTrainSchedArrDT; //par 22668 cnwrs1 8 Feb 2010
			endif;
		endif;
	endif;
	if self.myEDIData.isKindOf(CM_EDIDataTrainConsist) and
	   self.myEDIData.CM_EDIDataTrainConsist.myTransportManifest &lt;&gt; null then
		if self.trainCode = null then
			self.trainCode := NULL_TRAIN_CODE;
			self.myEDIData.CM_EDIDataTrainConsist.setCurrentTrainCode(NULL_TRAIN_CODE);
		endif;	
	endif;
end;
</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ccef699f-3f09-4b30-a127-ce114c1863e3">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
// cnwrs1 sept 2009 CCMS Messina 1008
//
vars
	prop : Property;
	propDict : PropertyNDict;
begin
	inheritMethod(_proxyEDITI);
	
	propDict := self.class.getProperties;
	foreach prop in propDict do
		if self.canUserSet(prop.name) then
			// bypass all type integrity checking in the name of convenience!!!
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setWagonProxy" id="08c5ec89-9fb3-47f4-841b-cb3efef87329">
        <updating/>
        <source>setWagonProxy( _wagon : CM_Wagon io ) updating;
//
// cnwrs1 sept 2009 CCMS Messina 1008
//
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 02 Oct 2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
//
vars
	term    	 : CM_Terminal; 
	id 	    	 : String; 
	class   	 : CM_WagonClass;
	train   	 : CM_Train;
	outTrain	 : CM_Train;
	remark  	 : String;
	carrier 	 : CM_Carrier;
	recStevedore : CM_Stevedore;
	relStevedore : CM_Stevedore;
begin
	term		 :=	self.getMyTerminal; 
	id			 :=	self.wagonNumber; 
	class		 :=	app.myRoot.allWagonClasses.getAtKey(self.wagonClass);
	train		 :=	term.allTrainsOnTerminal.getAtKeyGeq(self.trainCode, self.scheduledArrivalDT); //par 22668 cnwrs1 8 Feb 2010
	recStevedore := self.getStevedore(self.receiveStevedore);  //02.10.2020 cnwma1 TFS #50112
	relStevedore := self.getStevedore(self.releaseStevedore);  //02.10.2020 cnwma1 TFS #50112
	
	if train &lt;&gt; null and train.code &lt;&gt; self.trainCode then
		train	:=	null;
	endif;
	
	outTrain	:=	train;
	remark		:=	null;
	
	if  carrierCode &lt;&gt; null then
		carrier	:=	app.myRoot.allCarriers.getAtKey(carrierCode);
	endif;
	
	_wagon.setProxy(term, 
					id, 
					class,
					train,
					outTrain,
					remark,
					maxCargoHeight,
					maxCargoWeight,
					tareWeight,
					carrier,
					recStevedore,   //02.10.2020 cnwma1 TFS #50112
					relStevedore);  //02.10.2020 cnwma1 TFS #50112 
end;
</source>
        <Parameter name="_wagon" type="CM_Wagon" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setWagonSeals" id="147d6310-d1ee-4cd7-b1ac-1c8de9248077">
        <updating/>
        <source>setWagonSeals(_value : String) updating;
//
/// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
//
vars

begin
	self.wagonSeals := _value;
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
</Class>
