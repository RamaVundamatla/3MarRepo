    <JadeMethod name="set" id="8cb30e98-53cf-4013-90af-930d1c1d67a7">
        <updating/>
        <source>set(_name: String; _description: String; _noLongerUsed: Boolean) updating;
//----------------------------------------------------------------
//	Created:	17 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.name := _name;
	self.noLongerUsed := _noLongerUsed;

	if not self.isSystemFormat then
		self.description := _description;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_noLongerUsed" type="Boolean"/>
    </JadeMethod>
