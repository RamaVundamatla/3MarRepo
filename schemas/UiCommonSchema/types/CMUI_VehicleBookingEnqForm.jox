    <JadeMethod name="createVbsDetailsCSV" id="cbfe4b52-5188-4e15-887c-eb283573f05a">
        <source>createVbsDetailsCSV(_selectedTimeslots : ObjectArray): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Nov 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications

*/

vars
	numDone,
	updateProgressAfter,
	totalParts,
	lastPos					: Integer;
	useAllRows				: Boolean;
	theXML, theXMLValue,
	keyValue, vbsDetails	: String;
	lastUpdated				: Decimal [20];
	obj						: Object;
	allEntTableRowsDict		: DynaDictionary;
	cmifMonitor				: CMIF_Monitor;
	passport				: CM_Passport;
	userWindow				: CM_UserWindow;
	entDefAll				: EntTableDef;
	row,
	entTableRow				: EntTableRow;
	selectedEntTableRows	: CM_ObjectArray;
	timeslot				: CM_VehicleBookingTimeSlot;
	
begin
	passport := app.myPassport;
	
	//Get the user window for the email configure rows
	userWindow := app.getUserWindow(CMUI_VBSEmailConfigure.name, false);
	
	if userWindow = null then
		//use all ent rows
		useAllRows := true;
	else
		theXML := userWindow.xmlInfo;
	endif;
	
	create allEntTableRowsDict transient;
	allEntTableRowsDict.setMembership(EntTableRow);
	allEntTableRowsDict.addMemberKey(EntTableRow::heading.name,false,false);
	allEntTableRowsDict.endKeys(false);
	
	allEntTableRowsDict.clear;
	
	//Get all ent table rows
	entDefAll := app.myController.getEntTableDef(ETDef_VBSEmail);
	
	//Copy all the ent table rows to the dictionary
	entDefAll.allEntTableRows.copy(allEntTableRowsDict);
	
	create selectedEntTableRows transient;
	
	if useAllRows then
		allEntTableRowsDict.copy(selectedEntTableRows);
	else
		theXMLValue := theXML.cnEcGetTagValueOfName((CMUI_MultiSelectGroupBox.XMLTag_ListTable &amp; CMUI_VBSEmailConfigure::mulSelectEmailLayout.name));
		if theXMLValue &lt;&gt; null then
			theXMLValue := theXMLValue.trimCharacters(CrLf);
		endif;
		
		//Get all selected rows into a object array
		while true do
			keyValue := theXMLValue.cnEcGetNextTagValueOfName(CMUI_MultiSelectGroupBox.XMLTag_SelectedValue, lastPos);
			
			if keyValue = null then
				break;
			endif;
			
			entTableRow := allEntTableRowsDict.getAtKey(keyValue).EntTableRow;
			if entTableRow &lt;&gt; null then
				vbsDetails &amp;= entTableRow.getHeading(null, null, app.myCurrentLocale) &amp; ",";
				selectedEntTableRows.add(entTableRow);
			endif;
			
			if lastPos = 0 then
				break;
			endif;	
		endwhile;
		vbsDetails := vbsDetails.stripTrailingChar(",");
		vbsDetails &amp;= CrLf;
	endif;
	
	if passport.myCMIFMonitor &lt;&gt; null then
		totalParts := _selectedTimeslots.size;
		cmifMonitor := passport.myCMIFMonitor;
		cmifMonitor.updateProgress(cmifMonitor.message, totalParts, 0);
		updateProgressAfter := (totalParts / 20).roundedUp; // update after every 5%
	endif;
	
	foreach obj in _selectedTimeslots do
		timeslot := obj.CM_VehicleBookingTimeSlot;
		
		if cmifMonitor &lt;&gt; null and
		(app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates 
		then
			cmifMonitor.updateProgress(cmifMonitor.message, cmifMonitor.partsInJob, numDone);
			lastUpdated := app.relativeMachineTime;
		endif;	
		
		foreach row in selectedEntTableRows as EntTableRow do
			vbsDetails &amp;= timeslot.getDisplayStringForAttribute(row.name, false) &amp; ",";
		endforeach;
		vbsDetails := vbsDetails.stripTrailingChar(",");
		vbsDetails &amp;= CrLf;
		
	endforeach;
	
	return vbsDetails;
	
epilog
	delete allEntTableRowsDict;
	delete selectedEntTableRows;
	
end;</source>
        <Parameter name="_selectedTimeslots" type="ObjectArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayExtraInfoForObj" id="31826a63-8484-4327-a943-9bf338e21dd7">
        <source>displayExtraInfoForObj(_vehicleBookingTimeSlot : CM_VehicleBookingTimeSlot);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen

*/

vars
	dataContainer : CM_DataContainer;
	invalid		  : Boolean;
	
begin
	on Exception do app.handleDeletedObject( exception, _vehicleBookingTimeSlot, invalid );
	
	if _vehicleBookingTimeSlot = null then
		return;
	endif;
	
	self.tblInfo.clear();
	self.tblInfo.rows := 0;
	
	_vehicleBookingTimeSlot.edition;
	
	if invalid then
		on Exception do null;
		return;
	endif;

	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
	
	_vehicleBookingTimeSlot.getExtraInfo(dataContainer);
	self.showExtraInformation(dataContainer, self.tblInfo, true, false, 4, 1, 1, 1, 1);
	self.doResizeColumnWidths(self.tblInfo, true);

	on Exception do null;
	
epilog
	if dataContainer &lt;&gt; null then
		delete dataContainer;
	endif;
	
end;</source>
        <Parameter name="_vehicleBookingTimeSlot" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
