    <JadeMethod name="qryVoyageOrderOfWork" id="d9179d9c-821a-4e3c-a717-f86589946b32">
        <updating/>
        <source>qryVoyageOrderOfWork(_filter : CMQF_VoyageOrderOfWork input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     22 July 2003		cnwth2	
//
// Purpose:     	
// cnwgb1 Added support for 30', 45' and 53' Containers	 
// ----------   ----------  --------------------------------------------------
vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWVoyageSummary;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	jrwTrans := self.createJRWTransient(CM_JRWVoyageSummary).CM_JRWVoyageSummary;
	jrwTrans.allCMIFJobTITotals.purge();
	jrwTrans.initLengthReportingOptions();
	_filter.filterObjects(jrwTrans.allCMIFJobTITotals, _passport);
	
//	_filter.allTerminals.copy(jrwTrans.allTerminals);
	jrwTrans.setAllTerminals(_filter.allTerminals);
	jrwTrans.myVoyage 					:= _filter.getMyVoyage;
	jrwTrans.jobTypeDescription 		:= _filter.getJobTypeDescription();
	jrwTrans.craneId					:= _filter.craneId;
	jrwTrans.showRemarks				:= _filter.showRemarks;
	
	
	jrwTrans.total20DischargeFull		:= _filter.total20DischargeFull;
	jrwTrans.total20DischargeMty		:= _filter.total20DischargeMty;
	jrwTrans.total20DischargeDLRFull	:= _filter.total20DischargeDLRFull;
	jrwTrans.total20DischargeDLRMty		:= _filter.total20DischargeDLRMty;
	
	jrwTrans.total20LoadingFull			:= _filter.total20LoadingFull;
	jrwTrans.total20LoadingMty			:= _filter.total20LoadingMty;
	jrwTrans.total20LoadingDLRFull		:= _filter.total20LoadingDLRFull;
	jrwTrans.total20LoadingDLRMty		:= _filter.total20LoadingDLRMty;
	
	if  jrwTrans.showLen30 then
		jrwTrans.total30DischargeFull		:= _filter.total30DischargeFull;
		jrwTrans.total30DischargeMty		:= _filter.total30DischargeMty;
		jrwTrans.total30DischargeDLRFull	:= _filter.total30DischargeDLRFull;
		jrwTrans.total30DischargeDLRMty		:= _filter.total30DischargeDLRMty;
		
		jrwTrans.total30LoadingFull			:= _filter.total30LoadingFull;
		jrwTrans.total30LoadingMty			:= _filter.total30LoadingMty;
		jrwTrans.total30LoadingDLRFull		:= _filter.total30LoadingDLRFull;
		jrwTrans.total30LoadingDLRMty		:= _filter.total30LoadingDLRMty;
	endif;
	
	jrwTrans.total40DischargeFull		:= _filter.total40DischargeFull;
	jrwTrans.total40DischargeMty		:= _filter.total40DischargeMty;
	jrwTrans.total40DischargeDLRFull	:= _filter.total40DischargeDLRFull;
	jrwTrans.total40DischargeDLRMty		:= _filter.total40DischargeDLRMty;
	
	jrwTrans.total40LoadingFull			:= _filter.total40LoadingFull;
	jrwTrans.total40LoadingMty			:= _filter.total40LoadingMty;
	jrwTrans.total40LoadingDLRFull		:= _filter.total40LoadingDLRFull;
	jrwTrans.total40LoadingDLRMty		:= _filter.total40LoadingDLRMty;
	
	if  jrwTrans.showLen45 then
		jrwTrans.total45DischargeFull		:= _filter.total45DischargeFull;
		jrwTrans.total45DischargeMty		:= _filter.total45DischargeMty;
		jrwTrans.total45DischargeDLRFull	:= _filter.total45DischargeDLRFull;
		jrwTrans.total45DischargeDLRMty		:= _filter.total45DischargeDLRMty;
		
		jrwTrans.total45LoadingFull			:= _filter.total45LoadingFull;
		jrwTrans.total45LoadingMty			:= _filter.total45LoadingMty;
		jrwTrans.total45LoadingDLRFull		:= _filter.total45LoadingDLRFull;
		jrwTrans.total45LoadingDLRMty		:= _filter.total45LoadingDLRMty;
	endif;

	if  jrwTrans.showLen53 then
		jrwTrans.total53DischargeFull		:= _filter.total53DischargeFull;
		jrwTrans.total53DischargeMty		:= _filter.total53DischargeMty;
		jrwTrans.total53DischargeDLRFull	:= _filter.total53DischargeDLRFull;
		jrwTrans.total53DischargeDLRMty		:= _filter.total53DischargeDLRMty;
		
		jrwTrans.total53LoadingFull			:= _filter.total53LoadingFull;
		jrwTrans.total53LoadingMty			:= _filter.total53LoadingMty;
		jrwTrans.total53LoadingDLRFull		:= _filter.total53LoadingDLRFull;
		jrwTrans.total53LoadingDLRMty		:= _filter.total53LoadingDLRMty;
	endif;
	
	if  jrwTrans.showLenOther then
		if jrwTrans.showLen30AsOther then
			jrwTrans.totalOtherDischargeFull		:= _filter.total30DischargeFull;
			jrwTrans.totalOtherDischargeMty			:= _filter.total30DischargeMty;
			jrwTrans.totalOtherDischargeDLRFull		:= _filter.total30DischargeDLRFull;
			jrwTrans.totalOtherDischargeDLRMty		:= _filter.total30DischargeDLRMty;
			
			jrwTrans.totalOtherLoadingFull			:= _filter.total30LoadingFull;
			jrwTrans.totalOtherLoadingMty			:= _filter.total30LoadingMty;
			jrwTrans.totalOtherLoadingDLRFull		:= _filter.total30LoadingDLRFull;
			jrwTrans.totalOtherLoadingDLRMty		:= _filter.total30LoadingDLRMty;
		endif;
		if jrwTrans.showLen45AsOther then
			jrwTrans.totalOtherDischargeFull		:= jrwTrans.totalOtherDischargeFull    + _filter.total45DischargeFull;
			jrwTrans.totalOtherDischargeMty			:= jrwTrans.totalOtherDischargeMty	   + _filter.total45DischargeMty;
			jrwTrans.totalOtherDischargeDLRFull		:= jrwTrans.totalOtherDischargeDLRFull + _filter.total45DischargeDLRFull;
			jrwTrans.totalOtherDischargeDLRMty		:= jrwTrans.totalOtherDischargeDLRMty  + _filter.total45DischargeDLRMty;
			
			jrwTrans.totalOtherLoadingFull			:= jrwTrans.totalOtherLoadingFull    + _filter.total45LoadingFull;
			jrwTrans.totalOtherLoadingMty			:= jrwTrans.totalOtherLoadingMty     + _filter.total45LoadingMty;
			jrwTrans.totalOtherLoadingDLRFull		:= jrwTrans.totalOtherLoadingDLRFull + _filter.total45LoadingDLRFull;
			jrwTrans.totalOtherLoadingDLRMty		:= jrwTrans.totalOtherLoadingDLRMty  + _filter.total45LoadingDLRMty;
		endif;
		if jrwTrans.showLen53AsOther then
			jrwTrans.totalOtherDischargeFull		:= jrwTrans.totalOtherDischargeFull    + _filter.total53DischargeFull;
			jrwTrans.totalOtherDischargeMty			:= jrwTrans.totalOtherDischargeMty	   + _filter.total53DischargeMty;
			jrwTrans.totalOtherDischargeDLRFull		:= jrwTrans.totalOtherDischargeDLRFull + _filter.total53DischargeDLRFull;
			jrwTrans.totalOtherDischargeDLRMty		:= jrwTrans.totalOtherDischargeDLRMty  + _filter.total53DischargeDLRMty;
			
			jrwTrans.totalOtherLoadingFull			:= jrwTrans.totalOtherLoadingFull    + _filter.total53LoadingFull;
			jrwTrans.totalOtherLoadingMty			:= jrwTrans.totalOtherLoadingMty     + _filter.total53LoadingMty;
			jrwTrans.totalOtherLoadingDLRFull		:= jrwTrans.totalOtherLoadingDLRFull + _filter.total53LoadingDLRFull;
			jrwTrans.totalOtherLoadingDLRMty		:= jrwTrans.totalOtherLoadingDLRMty  + _filter.total53LoadingDLRMty;
		endif;
	endif;
	
	jrwTrans.totalLoadingBreakBulk		:= _filter.totalLoadingBreakBulk;
	jrwTrans.totalLoadingBreakBulkDLR	:= _filter.totalLoadingBreakBulkDLR;
	jrwTrans.totalLoadingTimber			:= _filter.totalLoadingTimber;
	jrwTrans.totalLoadingTimberDLR		:= _filter.totalLoadingTimberDLR;
	jrwTrans.totalLoadingOther			:= _filter.totalLoadingOther;
	jrwTrans.totalLoadingOtherDLR		:= _filter.totalLoadingOtherDLR;
	
	jrwTrans.totalDischargeBreakBulk	:= _filter.totalDischargeBreakBulk;
	jrwTrans.totalDischargeBreakBulkDLR	:= _filter.totalDischargeBreakBulkDLR;
	jrwTrans.totalDischargeTimber		:= _filter.totalDischargeTimber;
	jrwTrans.totalDischargeTimberDLR	:= _filter.totalDischargeTimberDLR;
	jrwTrans.totalDischargeOther		:= _filter.totalDischargeOther;
	jrwTrans.totalDischargeOtherDLR		:= _filter.totalDischargeOtherDLR;
	
	jrwTrans.hatchLidJobRemarks			:= _filter.hatchLidJobRemarks;
	
	numSelected := jrwTrans.allCMIFJobTITotals.size;
	
epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_VoyageOrderOfWork" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
