    <JadeMethod name="testAgainstAttributePlan" id="2bee0a3a-e823-4857-a85d-416167423ff4">
        <source>testAgainstAttributePlan(obj: CMIF_AutoMovePlan input; attribPlan: CM_CargoTypeAttribPlan);
/*
 ------------------------------------------------------------------------
Created:			23 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	alternateISOG	: CM_ISOTypeGroup;

begin
	inheritMethod(obj, attribPlan);
	if obj.getController() = null then
		return;
	endif;
	//------------------
	//If this TI is a reefer with an attached COU, it will behave like
	//an integral. Call method to get an integral isoTypeGroup if it exists
	//------------------
	// CCMS 1110 DVB
	if attribPlan.isoTypeGroup = null then
		return;
	endif;
	alternateISOG := self.getAlternateISOTypeGroup();
	if alternateISOG &lt;&gt; null then
		if alternateISOG.code = attribPlan.isoTypeGroup.code then
			//------------
			//Its good!!! Return now!
			//------------
			return;
		endif;
		//obj.addLogEntry("Tracked Item is Reefer with COU, Special ISO Type group test failed. ( used ISO Group" &amp; alternateISOG.code &amp; "). Candidate's ISO Type group is : " &amp; self.isoTypeGroup &amp; ", Attrib Plan is :" &amp; attribPlan.isoTypeGroup.code.trimRight, IsForLogging); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString3(Track_item_reefe_with_speci_ty, alternateISOG.code, self.isoTypeGroup, attribPlan.isoTypeGroup.code.trimRight), IsForLogging, Track_item_reefe_with_speci_ty);
		obj.updateController(null);
		return;
	endif;	
	if self.isoTypeGroup &lt;&gt; attribPlan.isoTypeGroup.code then
		//obj.addLogEntry("Tracked Item ISO Type group test failed. Candidate's ISO Type group is : " &amp; self.isoTypeGroup &amp; ", Attrib Plan is :" &amp; attribPlan.isoTypeGroup.code.trimRight, IsForLogging); //- cnwmd1, Par 20524
		obj.addLogEntry(app.getErrorString2(Track_item_type_group_test_fai, self.isoTypeGroup, attribPlan.isoTypeGroup.code.trimRight), IsForLogging, Track_item_type_group_test_fai);
		obj.updateController(null);
		return;
	endif;
epilog
	if obj.getController = null then
		//obj.addVerboseLogEntry("FAILED tests for Attribute plan :" &amp; id.trimRight &amp; " Continuing to next plan.", IsForLogging); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString1(Faile_tests_attri_plan_conti_n, id.trimRight), IsForLogging, Faile_tests_attri_plan_conti_n);
	endif;
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="attribPlan" type="CM_CargoTypeAttribPlan"/>
    </JadeMethod>
    <JadeMethod name="testAgainstDeliveryRequest" id="8f9d6a55-a59b-4776-9679-c40f9b10200d">
        <source>testAgainstDeliveryRequest(reqToTest: CM_DeliveryRequest) protected;
/*
 ------------------------------------------------------------------------
Created:			30 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
----------		----------		-----------------------------------------
04/12/2014		cnwdap1			PAR #35081 Correct subterminal / interterminal to do task checks
---------------------------------------------------------------------------
*/
vars
	str : String;
// 	aStop : CM_Stops;
// 	theStopTable : CM_StopsTable;
	ajob	:	CM_Job;
//	extraMessage : String;// PAR 6531 
	strsObj	:	CM_Strings;
	isPackRelease : Boolean;
	bulkRelease	: CM_BulkRelease;
	targetSubT	: CM_SubTerminal;
	targetTerm	: CM_Terminal;					// PAR #35081
	toDoTask	: CM_ToDoTask;					// PAR #35081
begin

	inheritMethod(reqToTest);
	//-------------------------
	//Now test the CONTAINER specific stuff here
	//-------------------------
	//th2 - CM_ReserveDetail::isYardPack not referenced except for here (?!) - so ommneting out
	// But we still want to check if it is a pack though don't we??
	if reqToTest.myReserveDetail &lt;&gt; null then // PAR 10060
		//if reqToTest.myReserveDetail.isYardPack then // PAR 10060 //PAR15697 was raised as a result of doing this so has been backed out
			if reqToTest.myReserveDetail.myReserveHeader &lt;&gt; null then // PAR 10060
				isPackRelease := (reqToTest.myReserveDetail.myReserveHeader.type = BR_TYPE_PACKING); // PAR 10060
			endif;
		//endif;
	endif;
	
	//if not isPackRelease then // PAR 10060 - Only if Road or Rail release
	if not isPackRelease and self.isBulkReleaseForMTs(bulkRelease) then		// 17/12/2010 cnwmh5 #26586
		//epr 30/09/09 part of Flexi gate is you can do full releasee so check commodity is MT before giving warning
		if not self.isEmpty and reqToTest.commodity = self.myTerminal.getDefaultEmptyCommodity then 			//Delivery requests are ALWAYS MT.
			if app.isRTApp then
				app.raiseCMException3(TI_TestReqContentsStatus, self.id, self.contentsStatusDescription(), "Empty", null, null);
			else
				app.raiseCMWarning3(TI_TestReqContentsStatus, self.id, self.contentsStatusDescription(), "Empty", null, null, self);
			endif;
		endif;	
	
		if not self.isStorage then
			if app.isRTApp then
				app.raiseCMException3(TI_TestReqIMEX, self.id, self.getImExStatusStringDesc(true), "Storage", null, null);
			else
				app.raiseCMWarning3(TI_TestReqIMEX, self.id, self.getImExStatusStringDesc(true), "Storage", null, null, self);
			endif;
		endif;
	endif;	

	if self.hasReleaseJob() and self.releaseRequest &lt;&gt; null then
		if (self.jobRailRelease &lt;&gt; reqToTest.myJob) and
			(self.jobRoadRelease &lt;&gt; reqToTest.myJob) and
			(self.releaseRequest.myJob &lt;&gt; reqToTest.myJob) and		
			(self.getFirstAvailableLoadJob() &lt;&gt; reqToTest.myJob) then
//			 (self.jobShipRelease &lt;&gt; reqToTest.myJob) then
		//Need method to determin the relase type at some stage, give "unknown" now until we can sort it.
			if self.releaseRequest.deliveryNumber &lt;&gt; null then
				str := self.releaseRequest.deliveryNumber;
			else
				str := 'Unknown';
			endif;
			app.raiseCMException3(TI_TestReqOnOtherRelease, self.id, str, reqToTest.getId(), null, null);
		endif;
	endif;
	
	if self.getISOTypeObject = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Item '&amp; self.id &amp; ' has NO iso type');
		return;	
	endif;
	//------------------
	//If an integral, check for PTI.
	//------------------
	if self.isIntegral then
		if self.getPreTripDT = null then
			app.raiseCMWarning1(VB_INTEGRAL_INSPECED, self.id, null, null, self);
		endif;
	endif;
	//------------------------
	//ONLY test clean if NOT a general type TI
	//------------------------
	if not self.isGeneral then
		if reqToTest.clean  and not self.isClean then
			if app.isRTApp then
				app.raiseCMException3(VB_REQ_CLEAN_DIFF, self.id, 'not clean', 'clean', null, null);
			else
				app.raiseCMWarning3(VB_REQ_CLEAN_DIFF, self.id, 'not clean', 'clean', null, null, self);
			endif;
		endif;
	endif;
	
	if not reqToTest.isKindOf(CM_YardDeliveryRequest) then	//cnwrd par 28935 12.1.2012 - we want to only do the suitable for release test if we are not an internal move
		self.validateAvaGradeReleaseAsError( reqToTest );	// 16 Sep 2011	NDL	Par 28189
	endif;
	
 	if reqToTest.isoType.trimRight &lt;&gt; null then
 		//---------------------
 		//If there's an ISO type, test it.
 		//---------------------
 		if not self.isSimilarToISOType(reqToTest.isoType) then
			
			if reqToTest.isoGroup &lt;&gt; null then //cnwrd1 22.12.09 ++
			//cnwrd1 par 30414 25.9.2012
				if not reqToTest.testISOGroup(self.isoTypeGroup.trimRight, null) then
					app.raiseCMException3(TI_TestReqISOGroup, self.id, self.isoTypeGroupDesc, reqToTest.isoGroup, null, null);
				endif;
			/*	
				if self.isoTypeGroup.trimRight &lt;&gt; reqToTest.isoGroup then
					app.raiseCMException3(TI_TestReqISOGroup, self.id, self.isoTypeGroupDesc, reqToTest.isoGroup, null, null);
				endif;
				*/
			else
				app.raiseCMException3(TI_TestReqISO, self.id, self.isoType, reqToTest.isoType, null,self);
			endif;
		endif;
	else //check if we have ISO group (and no ISO type)//cnwrd1 11.01.2010
		if reqToTest.isoGroup &lt;&gt; null then 
			//cnwrd1 par 30414 25.9.2012
			if not reqToTest.testISOGroup(self.isoTypeGroup.trimRight, null) then
				app.raiseCMException3(TI_TestReqISOGroup, self.id, self.isoTypeGroupDesc, reqToTest.isoGroup, null, null);
			endif;
		/*
			if self.isoTypeGroup.trimRight &lt;&gt; reqToTest.isoGroup then
					app.raiseCMException3(TI_TestReqISOGroup, self.id, self.isoTypeGroupDesc, reqToTest.isoGroup, null, null);
			endif;			
			*/
		endif;
	endif;
	//------------------------
	//Check stops
	//------------------------
	self.checkStopsToBePrevented(StopPreventDeliveryRequest, null, false); //cnwrs1 May 2007 PAR13378 Stops

	if self.myTerminal.getConfig(CedoAllowPlanning).Boolean then
		//Raise warnings for planning
		self.checkStopsToBePrevented(StopPreventVoyagePlanning, null, false);			
	else
		self.checkStopsToBePrevented(StopPreventVoyagePlanning, null, true);			
	endif;

	//------------------------
	 //Test for Damage
	 //------------------
	 if self.damaged &lt;&gt; false then
		app.raiseCMWarning1(VB_IS_DAMAGED, self.id, null, null, self);
	 endif;
	//------------------
	 //Does the TI have a COU, if so, does the request WANT one?
	 //------------------
	 if self.hasCOU then
		if reqToTest.needCOU = false then
			if app.isRTApp then
				app.raiseCMException3(TI_TestReqCOU, self.id, 'has a', 'not for', null, null);
			else
				app.raiseCMWarning3(TI_TestReqCOU, self.id, 'has a', 'not for', null, null, self);
			endif;
		endif;
	else		//NFS 3162: Check if the request wants a COU...
		if reqToTest.needCOU then
			if app.isRTApp then
				app.raiseCMException3(TI_TestReqCOU, self.id, 'does not have a', 'is for', null, null);
			else
				app.raiseCMWarning3(TI_TestReqCOU, self.id, 'does not have a', 'is for', null, null, self);
			endif;
		endif;
	endif;
	
	//NFS 3162: Check that the TI meets requirements for a generator
	if self.getGenerator &lt;&gt; null then
		if reqToTest.needGenerator = false then
			if app.isRTApp then
				app.raiseCMException3(TI_TestReqGenerator, self.id, 'does', 'is not', null, null);
			else
				app.raiseCMWarning3(TI_TestReqGenerator, self.id, 'does', 'is not', null, null, self);
			endif;
		endif;
	else		//Check if the request wants a generator...
		if reqToTest.needGenerator = true then
			if app.isRTApp then
				app.raiseCMException3(TI_TestReqGenerator, self.id, 'does not', 'is', null, null);
			else
				app.raiseCMWarning3(TI_TestReqGenerator, self.id, 'does not', 'is', null, null, self);
			endif;
		endif;
	 endif;
	 //------------------
	 //Check toDo tasks
	 //------------------
	 	 
	//cnwrd1 par 28810 15.12.2011
	 if reqToTest.isKindOf(CM_YardDeliveryRequest) then
		targetSubT := reqToTest.CM_YardDeliveryRequest.myTargetSubTerminal;	
	elseif reqToTest.myTransferToTerminal &lt;&gt; null then								// PAR #35081
		targetTerm := reqToTest.myTransferToTerminal;								// PAR #35081
	 endif;
	 
	 
	if self.allToDoTasksToDo.isEmpty = false then
		if targetTerm = null then													// PAR #35081
			if targetSubT = null then
				if app.isRTApp then
					app.raiseCMException3(ERR_TODOTASKS, self.allToDoTasksToDo.size.String, app.getErrorString(Completed).toLower, self.id, null, null);
				else
					if app.myRoot.isClientPortOtago and reqToTest.myTransferToTerminal = null then	// 16 Sep 2011	NDL	Par 28189
						app.raiseCMException3(ERR_TODOTASKS, self.allToDoTasksToDo.size.String, app.getErrorString(Completed).toLower, self.id, null, null);
					else
						app.raiseCMWarning3(ERR_TODOTASKS, self.allToDoTasksToDo.size.String, app.getErrorString(Completed).toLower, self.id, null, null, self);
					endif;
				endif;
			else
				//new code checking in here for sub term release.
				self.validateSubTerminalChange(targetSubT);		//cnwrd1 par 28810 8.12.2011
			endif;
		else																						// PAR #35081
			foreach toDoTask in self.allToDoTasksToDo discreteLock do								// PAR #35081
				if not toDoTask.toDoTaskDesc.allAllowedReleaseTerms.includes(targetTerm) then		// PAR #35081
					if app.isRTApp then																// PAR #35081
						app.raiseCMException3(ERR_TODOTASKS, self.allToDoTasksToDo.size.String, app.getErrorString(Completed).toLower, self.id, null, null);			// PAR #35081
					else																			// PAR #35081
						if app.myRoot.isClientPortOtago and reqToTest.myTransferToTerminal = null then										// PAR #35081
							app.raiseCMException3(ERR_TODOTASKS, self.allToDoTasksToDo.size.String, app.getErrorString(Completed).toLower, self.id, null, null);		// PAR #35081
						else																		// PAR #35081
							app.raiseCMWarning3(ERR_TODOTASKS, self.allToDoTasksToDo.size.String, app.getErrorString(Completed).toLower, self.id, null, null, self);	// PAR #35081
						endif;																		// PAR #35081
					endif;																			// PAR #35081
				endif;																				// PAR #35081
			endforeach;																				// PAR #35081
		endif;																						// PAR #35081
	endif;
	//------------------
	//FINAL - Test for ID matching in the Request.
	//------------------
	if 	reqToTest.ids &lt;&gt; null then
		if not reqToTest.ids.compareIDStrings(self.id) then
			app.raiseCMWarning1(TI_TestReqIDMatch, self.id, null, null, self);
		endif;
	else
		if reqToTest.myJob = null then
			return;
		endif;  	
	  	ajob := reqToTest.myJob;
		//--------------
		//Get the appropriate ids reference
		//--------------
		if ajob.isKindOf(CM_RailJob) then
			strsObj := self.myOperator.notRailIds;
		elseif ajob.isKindOf(CM_RoadJob) then
			strsObj := self.myOperator.notRoadIds;
		else
			//--------------
			//Not a valid job type, no extra tests!
			//--------------
			return;
		endif;
		if strsObj &lt;&gt; null then
			if not strsObj.compareIDStrings(self.id) then
				app.raiseCMWarning1(TI_TestReqIDMatch, self.id, null, null, self);
			endif;
		endif;	
	endif;

 	//Test for heavy rating
	if reqToTest.heavyRated then
		if self.isHeavyDuty = false then 
			if app.isRTApp then
				app.raiseCMException3(TI_TestReqHeavy, self.id, 'is not', 'is', null, null);
			else
				app.raiseCMWarning3(TI_TestReqHeavy, self.id, 'is not', 'is', null, null, self);
			endif;
		endif;
	else
		if self.isHeavyDuty then
			//13 Mar 2012	NDL	Par 29171
			app.raiseCMWarning3(TI_TestReqHeavy, self.id, 'is', 'is not', null, null, self);
		
		//	if app.isRTApp then
		//		app.raiseCMException3(TI_TestReqHeavy, self.id, 'is', 'is not', null, null);
		//	else
		//		app.raiseCMWarning3(TI_TestReqHeavy, self.id, 'is', 'is not', null, null, self);
		//	endif;
		endif;
	endif;  	
	
end;</source>
        <access>protected</access>
        <Parameter name="reqToTest" type="CM_DeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="testAgainstSlotRequest" id="cc421a9a-b987-47bd-af5f-3e9fc671ab57">
        <source>testAgainstSlotRequest(reqToTest: CM_Request; _moveController : CMIF_MoveController);
/*
 ------------------------------------------------------------------------
Created:			08 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------	--------------	-------------------------------------------
30/07/2010		cnwdad1			PAR #24045 Added _moveController parameter.
07/12/2011		cnwdap1			PAR #26619 CCMS SFW 1260 Check over-dimensions
19/12/2011		cnwdap1			PAR #28881 Ignore EDI or discharge TIs when checking overdimensions
17/04/2012		cnwdap1			PAR #29448 Don't include container ID in location when warning of overheight underneath
28/08/2012		cnwmh5			PAR #30281 Change getting of iso type to variable so stop 1090 error
13/11/2019		jlgdap1			TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
30/10/2025		jlizm1			MTN 36255 Rotabox Assign Release To Vessel
---------------------------------------------------------------------------
*/
vars
	iso 		: CM_ISOType;
	moveMode	 :String;
	aString 	: String;
	theID 		: String;
	is40Footer 	: Boolean;
	isCrib 		: Boolean; 	//cnwas3 PAR 24273
	isEmpty 	: Boolean; //cnwas3 PAR 24273
	isFantainer : Boolean;	//cnwas3 PAR 24273
	isFlatRack 	: Boolean;	//cnwas3 PAR 24273 
	isHalfHeight: Boolean;	//cnwas3 PAR 24273
	is30		: Boolean;	//cnwas3 PAR 24273
	is45 		: Boolean;	//cnwas3 PAR 24273
	is53		: Boolean;	//cnwas3 PAR 24273
	isOpenTop	: Boolean; //cnwas3 PAR 24273
	isTank		: Boolean;	//cnwas3 PAR 24273
	isWC		: Boolean;	//cnwas3 PAR 24273
	bulkRelease	: CM_ReserveDetail;
	reserveSelection : CM_ReserveSelection;
	config		: Integer;				// 31/08/2010 cnwmh5 #23453
	useVoyageAllocation : Boolean;
	voyageController : CM_LocationsController;
	topTI		: CM_TrackedItem;		// PAR #26619
	underSlot	: CM_VoyageController;	// PAR #26619
	futureMove	: CM_FutureMove;		// PAR #28881
	ti			: CM_TrackedItem;		// PAR #28881
	locationID	: String;				// PAR #29448
	isoType		: CM_ISOType;				// 28/08/2012 cnwmh5 #30281
	isRota		: Boolean;
begin

	//03 Jul 2012	NDL	Par 29707
	voyageController:=reqToTest.getVoyageController;
	if not self.isTranshipItem and voyageController &lt;&gt; null then
		if not reqToTest.isReleaseType then
			//we are discharging from the slot request/RORO request, (and we are not a tranship)
			//so, who cares if we match where we were or not.
			return;
		endif;
	endif;

	inheritMethod(reqToTest, _moveController);
	//-------------------------
	//Now test the CONTAINER specific stuff here
	//-------------------------
	
//	voyageController:=reqToTest.getVoyageController;
	if voyageController &lt;&gt; null then
		theID := self.id &amp;  ' (' &amp; voyageController.getFullId() &amp; ') '; // PAR 29164 added back in the container ID
		locationID := voyageController.getFullId();						// PAR #29448 - par 29164 included self.id in the location id, take it back out again
	endif;
	iso := self.getISOTypeObject();

	//cnwjo3 par 26268
	if self.isTranshipItem then
		if self.myExportVoyage &lt;&gt; null then
			useVoyageAllocation := self.myExportVoyage.useVoyageAllocations;
		endif;
	else
		if self.myVoyage &lt;&gt; null then
			useVoyageAllocation := self.myVoyage.useVoyageAllocations;
		endif;	
	endif;
	
	//cnwjo3 par 26268.  If the slot request uses voyage allocation then we don't need to individually
	//validate the iso attributes (like open top, tank, etc) since this validation is done later in
	//CM_VoyageAllocation::testAgainstSlotRequest where warnings will be shown/displayed/thrown.
	
	if iso &lt;&gt; null and useVoyageAllocation = false then
		// #### CRIB
		isCrib := reqToTest.getAttrCrib(); 		//cnwas3 PAR 24273
		if isCrib &lt;&gt; iso.isCrib()  then		//cnwas3 PAR 24273
			if isCrib then					//cnwas3 PAR 24273
				app.raiseCMWarning5(TI_TestReqMessage, theID, 'is not a'," crib", "is", "crib.", null, null, self);
			else
				app.raiseCMWarning5(TI_TestReqMessage, theID, 'is a', "crib", "is not", "crib.", null, null, self);
			endif;
		endif;
		// #### TANK
		isTank := reqToTest.getAttrTank();		//cnwas3 PAR 24273 begin
		if isTank &lt;&gt; iso.isTank()  then
			if isTank then						//cnwas3 PAR 24273 end
				app.raiseCMWarning5(TI_TestReqMessage, theID, 'is not a'," tank", "is", "tank.", null, null, self);
			else
				app.raiseCMWarning5(TI_TestReqMessage, theID, 'is a', "tank", "is not", "tank.", null, null, self);
			endif;
		endif;
		// #### FLAT
		isFlatRack := reqToTest.getAttrFlatRack();		//cnwas3 PAR 24273
		if isFlatRack &lt;&gt; iso.isFlat()  then				//cnwas3 PAR 24273
			if isFlatRack then							//cnwas3 PAR 24273
				app.raiseCMWarning5(TI_TestReqMessage, theID, 'is not a'," flat", "is", "flat.", null, null, self);
			else
				app.raiseCMWarning5(TI_TestReqMessage, theID, 'is a', "flat", "is not", "flat.", null, null, self);
			endif;
		endif;
		// #### FANTAINER
		isFantainer := reqToTest.getAttrFantainer();		//cnwas3 PAR 24273
		if isFantainer &lt;&gt; iso.isFantainer()  then			//cnwas3 PAR 24273
			if isFantainer then								//cnwas3 PAR 24273
				app.raiseCMWarning5(TI_TestReqMessage, theID, 'is not a'," fantainer", "is", "fantainer.", null, null, self);
			else
				app.raiseCMWarning5(TI_TestReqMessage, theID, 'is a', "fantainer", "is not", "fantainer.", null, null, self);
			endif;
		endif;
		// #### OPENTOP
		isOpenTop := reqToTest.getAttrOpenTop();		//cnwas3 PAR 24273
		if isOpenTop &lt;&gt; iso.isOpenTop()  then		//cnwas3 PAR 24273
			if isOpenTop then							//cnwas3 PAR 24273
				app.raiseCMWarning5(TI_TestReqMessage, theID, 'is not an'," opentop", "is", "opentop.", null, null, self);
			else
				app.raiseCMWarning5(TI_TestReqMessage, theID, 'is an', "opentop", "is not", "opentop.", null, null, self);
			endif;
		endif;
		// #### ROTATABLE
		isRota := reqToTest.getIsRotatableContainer;
		if isRota &lt;&gt; iso.isRotatable then
			if isRota then
				app.raiseCMWarning5(TI_TestReqMessage, theID, 'is not',"rotatable", "is", "rotatable.", null, null, self);
			else
				app.raiseCMWarning5(TI_TestReqMessage, theID, 'is', "rotatable", "is not", "rotatable.", null, null, self);
			endif;
		endif;
	endif;
	
	if reqToTest.hasAnEmptyAttributeSet then	//13 Apr 2015	NDL	Par 36032
		isEmpty := reqToTest.getAttrEmpty();//cnwas3 PAR 24273
		if isEmpty &lt;&gt; self.isEmpty then		//cnwas3 PAR 24273
			if isEmpty then					//cnwas3 PAR 24273
				aString := "Empty";
			else
				aString := "Not Empty";
			endif;
			app.raiseCMWarning3(TI_TestReqContentsStatus, theID, self.contentsStatusDescription(), aString, null, null, self);
		endif;
	endif;

	isHalfHeight := reqToTest.getAttrHalfHeight();		//cnwas3 PAR 24273
	if isHalfHeight &lt;&gt; self.isAttributeTrue(TI_Attrib_IsHalfHeight) then		//cnwas3 PAR 24273
		if isHalfHeight then							//cnwas3 PAR 24273
			app.raiseCMWarning3(TI_TestReqHalfHeight, theID, 'is not a', "is", null, null, self);
		else
			app.raiseCMWarning3(TI_TestReqHalfHeight, theID, 'is a', "is not", null, null, self);
		endif;
	endif;

	// 31/08/2010 cnwmh5 #23453 - Start
	config := self.myTerminal.getConfig(HiCubePlanningWarning).Integer;
	if config &lt;&gt; HCPlanWarn_None then
		if reqToTest.getAttrHiCubed() then
			// slot request is for hi cubed
			if not self.isHighCube and (config = HCPlanWarn_HCFullCheck or config = HCPlanWarn_NonHCToHCSlot) then
				app.raiseCMWarning3(TI_TestReqHighCubed, self.id, 'is not a', "is", null, null, self);
			endif;
		else
			// slot request is not for hi cubed
			if self.isHighCube and (config = HCPlanWarn_HCFullCheck or config = HCPlanWarn_HCToNonHCSlot) then
				app.raiseCMWarning3(TI_TestReqHighCubed, self.id, 'is a', "is not", null, null, self); // PAR 22303
			endif;
		endif;
	endif;

	if not self.isEmpty then
		if reqToTest.getAttrPowerRequired() &lt;&gt; self.requiresPower then
			if self.requiresPower  then
				app.raiseCMWarning3(TI_TestReqPower, theID, 'does require', 'no', null, null, self);
			else
				app.raiseCMWarning3(TI_TestReqPower, theID, 'does not require', 'needing', null, null, self);
			endif;
		endif;
		//CCMS-1320 was not spec'ed to makes changes to slot requests so there is now an inconsistancy here
		isWC := reqToTest.getAttrWaterCooled();		//cnwas3 PAR 24273 begin
		if isWC &lt;&gt; (self.getCoolingType = ContainerWaterCooled) then //self.hasCoolingWaterConnection then
			if isWC then			//cnwas3 PAR 24273 end
				app.raiseCMWarning3(TI_TestReqWaterCooled, theID, 'is not', 'being', null, null, self);
			else
				app.raiseCMWarning3(TI_TestReqWaterCooled, theID, 'is', 'not', null, null, self);
			endif;
		endif;
	endif;
	
	 // PAR 21746 is40Footer := (reqToTest.getAttrIs40() or reqToTest.fortyBack);
	is40Footer := (reqToTest.getAttrIs40() or reqToTest.getAttrIsBackend());
	is30 := reqToTest.getAttrIs30();
	is45 := reqToTest.getAttrIs45();	// 10/05/2012 cnwar2 #29545
	is53 := reqToTest.getAttrIs53();
	if is40Footer then // PAR 18682
		if is40Footer &lt;&gt; self.is40 then
			if is40Footer then
				// PAR 29133 app.raiseCMWarning3(TI_TestReq40, theID, 'is not', 'being a', null, null, self);
				app.raiseCMException3(TI_TestReq40, theID, 'is not', 'being a', null, self);
			else
				// PAR 29133 app.raiseCMWarning3(TI_TestReq40, theID, 'is ', 'not being a', null, null, self);
				app.raiseCMException3(TI_TestReq40, theID, 'is ', 'not being a', null, self);
			endif;
		endif;
		
	//is45 := reqToTest.getAttrIs45();		// 10/05/2012 cnwar2 #29545 - move up with the others
	elseif is45 then
		if is45 &lt;&gt; self.is45 then
			if is45 then					//cnwas3 PAR 24273 end
				// PAR 29133 app.raiseCMWarning6(TI_TestReqLength, theID, 'is not', '45', '45', 'being a', '45', null, null, self);
				app.raiseCMException6(TI_TestReqLength, theID, 'is not', '45', '45', 'being a', '45', null,  self);
			else
				// PAR 29133 app.raiseCMWarning6(TI_TestReqLength, theID, 'is ', '45', '45', 'not being a', '45', null, null, self);
				app.raiseCMException6(TI_TestReqLength, theID, 'is ', '45', '45', 'not being a', '45', null,  self);
			endif;
		endif;
	
	elseif is30 then			//cnwas3 PAR 24273 begin
		if is30 &lt;&gt; self.is30 then
			if is30 then		//cnwas3 PAR 24273 end
				// PAR 29133 app.raiseCMWarning6(TI_TestReqLength, theID, 'is not', '30', '30', 'being a', '30', null, null, self);
				app.raiseCMException6(TI_TestReqLength, theID, 'is not', '30', '30', 'being a', '30', null,  self);
			else
				// PAR 29133 app.raiseCMWarning6(TI_TestReqLength, theID, 'is ', '30', '30', 'not being a', '30', null, null, self);
				app.raiseCMException6(TI_TestReqLength, theID, 'is ', '30', '30', 'not being a', '30', null, self);
			endif;
		endif;
	
	elseif is53 then	//cnwas3 PAR 24273 begin
		if is53 &lt;&gt; self.is53 then
			if is53 then		//cnwas3 PAR 24273 end
				// PAR 29133 app.raiseCMWarning6(TI_TestReqLength, theID, 'is not', '53', '53', 'being a', '53', null, null, self);
				app.raiseCMException6(TI_TestReqLength, theID, 'is not', '53', '53', 'being a', '53', null,  self);
			else
				// PAR 29133 app.raiseCMWarning6(TI_TestReqLength, theID, 'is ', '53', '53', 'not being a', '53', null, null, self);
				app.raiseCMException6(TI_TestReqLength, theID, 'is ', '53', '53', 'not being a', '53', null,  self);
			endif;
		endif;
	else // is 20  //05/05/2009 cnwdz2 par19570
		if not self.is20() then
			// PAR 29133 app.raiseCMWarning6(TI_TestReqLength, theID, 'is not', '20', '20', 'being a', '20', null, null, self);
			app.raiseCMException6(TI_TestReqLength, theID, 'is not', '20', '20', 'being a', '20', null, self);
		endif;
	endif;
	if reqToTest.isBulkRelease() then
		bulkRelease:=reqToTest.getBulkReleaseReserveDetail();
		bulkRelease.testCandidateTI(self);
		//01 Jul 2010	NDL Par 24687
		if bulkRelease.isKindOf(CM_ReserveSelection) then
			reserveSelection := bulkRelease.CM_ReserveSelection;
			if reserveSelection.allAvailabilityGrades.isEmpty = false then
				if not reserveSelection.allAvailabilityGrades.includes(self.availabilityGrade) then
					if app.isRTApp then
						app.raiseCMException3(TI_TestReqAvailable, self.id, self.availabilityGradeDescription, "Available for release", null, null);
					else
						app.raiseCMWarning3(TI_TestReqAvailable, self.id, self.availabilityGradeDescription, "Available for release", null, null, self);
					endif;
				endif;
			endif; 
			self.validateAvaGradeReleaseAsError( reqToTest );	// 12 Oct 2011	NDL	Par 28417
		endif;
	endif;
	
//	self.validateAvaGradeReleaseAsError( reqToTest );	// 16 Sep 2011	NDL	Par 28189
	// PAR #26619 Warn if we're planning/queuing/moving a container on top of another overheight container
	if voyageController &lt;&gt; null then
		if CM_SlotController.hasInstance(voyageController) then
			underSlot := voyageController.CM_SlotController.myUnderfootSlot;
		elseif CM_ROROSlotController.hasInstance(voyageController) then
			underSlot := voyageController.CM_ROROSlotController.getSlotUnderneathMe;
		endif;
		
		if underSlot &lt;&gt; null then
			// PAR #28881 changed the way we derive the TI to avoid picking up EDI moves or discharge TIs
			topTI := underSlot.getActualQueuedPlannedLoadTI();
			if topTI &lt;&gt; null then
				// in unit tests _moveController is null
				if _moveController &lt;&gt; null then
					moveMode := app.moveModeStatusEnumToString(_moveController.moveMode);
				endif;
				if topTI.isOverHeight then
					//app.raiseCMWarning2(Cannot_contain_underne_overhei, moveMode &amp; " " &amp; self.id, theID, theID, null, self);			// PAR #29448
					app.raiseCMWarning2(Cannot_contain_underne_overhei, moveMode &amp; " " &amp; self.id, locationID, locationID, null, self);	// PAR #29448
				endif;
				
				// also check whether we're putting this container on top of a flat
				isoType := topTI.getISOTypeObject();																					// 28/08/2012 cnwmh5 #30281
				if isoType &lt;&gt; null and isoType.isFlat then
					//app.raiseCMWarning3(Container_flat_platform, moveMode, self.id, theID, theID, null, self);						// PAR #29448
					app.raiseCMWarning3(Container_flat_platform, moveMode, self.id, locationID, locationID, null, self);				// PAR #29448
				endif;
			endif;
		endif;
	endif;
	// PAR #26619 end
	
	// TFS 46405 validate over-dimension planned moves
	if _moveController &lt;&gt; null and _moveController.moveMode = PLANNING_MODE and reqToTest.isSlotRequest then
		reqToTest.CM_SlotRequest.mySlotController.validateODMoveTo(_moveController);
	endif;
	// TFS 46405 end
	
end;</source>
        <Parameter name="reqToTest" type="CM_Request"/>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="testAgainstYardDeliveryRequest" id="ca4f7c3b-00e9-4a6f-9b3e-cd60e804cc04">
        <source>testAgainstYardDeliveryRequest(reqToTest: CM_YardDeliveryRequest) protected;
/*
 ------------------------------------------------------------------------
Created:			06 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	//grade 	: CM_MTGrade;
	//gradeReq 	: CM_MTGrade;
begin

//cnwrd1 par 26633 17.12.2010
	if reqToTest.allAvailabilityGrades.isEmpty = false then
		if not reqToTest.allAvailabilityGrades.includes(self.availabilityGrade) then
			// Par 11421
			if app.isRTApp then
				app.raiseCMException3(TI_TestReqAvailable, self.id, self.availabilityGradeDescription, "Available for release", null, null);
			else
				app.raiseCMWarning3(TI_TestReqAvailable, self.id, self.availabilityGradeDescription, "Available for release", null, null, self);
			endif;
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="reqToTest" type="CM_YardDeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="testAgainstYardMoveRequest" id="b55bb415-5476-4abb-a73c-31173ec4c321">
        <source>testAgainstYardMoveRequest(reqToTest: CM_YardMoveRequest) protected;
/*
 ------------------------------------------------------------------------
Created:			06 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	yiJob : CM_YardInternalJob;
begin
	//------------------------
	//Test the jobs collection of eligible tis if there are any there.
	//------------------------
	if not reqToTest.myJob.isKindOf(CM_YardInternalJob) then
		return;
	endif;
	yiJob := reqToTest.myJob.CM_YardInternalJob;
	if yiJob.selectedTIs.isEmpty then
		return;
	endif;
	if not yiJob.selectedTIs.includes(self) then
		app.raiseCMException2(Err_TIIsNotInReleaseList, self.id, reqToTest.mySourceLocation.getFullId, null, null);	
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="reqToTest" type="CM_YardMoveRequest"/>
    </JadeMethod>
    <JadeMethod name="testAutoPlanRequest" id="16c47165-e9f5-459a-a858-c3e9fdd1fd8b">
        <source>testAutoPlanRequest(obj: CMIF_AutoMovePlan input);
/*
 ------------------------------------------------------------------------
Created:			09 August 2002 by cnwdwq1
Purpose:			Request processing for ISO Release requests. We are trying to find
							a source location for suitable TI's. We have got this far
							OK, if we have got this far, on a request search, then we need to determine
							if this TI will match the request.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
27 Sep 2023		navma1 			ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
---------------------------------------------------------------------------
*/
vars
	term 	: CM_Terminal;
	iso 	: CM_ISOType;
	tiGrade	: CM_MTGrade;
	root	: CM_Root;
	
begin
	
	inheritMethod(obj);
	
	if obj.getController = null then
		//------------------------
		//qualified out at superclass level.
		//------------------------
		return;
	endif;	
	//First check that the TI is actually suitable to be released
	root	:= app.myRoot;
	
	tiGrade := root.allAvailabilityGrades[self.availabilityGrade];
	
	if tiGrade = null then
		obj.addVerboseLogEntry(app.getErrorString2(Unknown_availabili_grade,id, self.availabilityGrade.String), IsError, Unknown_availabili_grade);
		obj.updateController(null);
		return;
	endif;
	
	if tiGrade.isSuitableForRelease = false then
		obj.addVerboseLogEntry(app.getErrorString2(Availa_grade_that_suitab_relea,id, self.availabilityGrade.String), IsError, Availa_grade_that_suitab_relea);
		obj.updateController(null);
		return;
	endif;

	//Then check if it matches the request...
	iso := root.allISOTypes[self.isoType];
	if iso = null then
		obj.addLogEntry(app.getErrorString2(Does_have_valid_type, id, self.isoType), IsError, Does_have_valid_type);
		obj.updateController(null);
		return;
	endif;
	//------------------------
	//ONLY test clean if NOT a general type TI
	//------------------------
	if iso.isGeneral = false then
		//----------------
		//Is NOT a general box, test for clean status
		//----------------
		obj.addVerboseLogEntry(app.getErrorString1(General_type_testing_clean,id), IsForLogging, General_type_testing_clean);
		if self.isClean &lt;&gt; obj.request.clean then
			obj.updateController(null);
			return;
		endif;	
	else
		//obj.addVerboseLogEntry(id &amp; " is a General ISO Type.(ignoring Clean test)", IsForLogging); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString1(General_typeign_clean_test,id), IsForLogging, General_typeign_clean_test);
	endif;

	if self.isoType &lt;&gt; obj.request.isoType then
		//-------------
		//Do some extra work for iso type stuff
		//-------------
		term := self.myTerminal;
		//------------
		//Check isotype attributes
		//------------
		if not iso.isSimilarISOType(root.allISOTypes[obj.request.isoType]) then
		
		
			//if obj.request.doISOGroupCheck then 	//cnwrd1 22.12.09 --
			if obj.request.isoGroup &lt;&gt; null then	 //cnwrd1 22.12.09 ++
				//cnwrd1 par 30414 25.9.2012
				if not obj.request.testISOGroup(null,iso.myISOTypeGroup) then
					obj.addLogEntry(app.getErrorString1(Does_match_group_test, id), IsWarning, Does_match_group_test);
					obj.updateController(null);
					return;
				endif;
			else
				obj.addLogEntry(app.getErrorString1(Does_match_similar_type,id), IsWarning, Does_match_similar_type);
				obj.updateController(null);
				return;
			endif;
			
			
		endif;
	endif;	

  //NFS 3162: If we want a COU make sure that we have one attached
  if obj.request.isKindOf(CM_YardRequest) then
		if obj.request.needCOU and self.getCou = null then
			obj.addLogEntry(app.getErrorString1(Does_have_request_wants,id), IsError, Does_have_request_wants);
			obj.updateController(null);
			return;	
		endif;

		if obj.request.needGenerator and self.getGenerator=null then
			obj.addLogEntry(app.getErrorString1(Does_have_genera_reques_wants, id), IsError, Does_have_genera_reques_wants);
			obj.updateController(null);
			return;	
		endif;
	endif;
	if obj.request.isKindOf(CM_DeliveryRequest) and obj.request.allAvailabilityGrades.isNotEmpty then
		//NFS 3798 An undefined grade in the request means that all TI's comply
		if not obj.request.allAvailabilityGrades.includes(self.availabilityGrade) then
			obj.addVerboseLogEntry(app.getErrorString2(Avail_grade_that_does_match_re,id, self.availabilityGrade.String), IsForLogging, Avail_grade_that_does_match_re);
			obj.updateController(null);
			return;		
		endif;
	endif;
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testAutoPlanRequestYA" id="84311110-b9b4-4801-92ef-e4079a101be9">
        <source>testAutoPlanRequestYA(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------------------
// 09/07/2013	cnwdap1		PAR #31959 To Do Task checking now done in superclass method
// 3 Nov 2022 navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
vars
	term 		: CM_Terminal;
	index		: Integer;
	iso 		: CM_ISOType;
	tiGrade		: CM_MTGrade;
	cmifRequest	: CMIF_YARequest;
	
begin
	
	if not inheritMethod(_yaAgent) then
		return false;
	endif;

	cmifRequest := _yaAgent.myCurrentCMIFYAAutoPlan.CMIF_YARequest;
	
	if cmifRequest.hasAllocation then //cnwrd1 ccms 1303 14.11.2012
		return self.testAutoPlanRequestYAAlloc(_yaAgent);
	endif;

	//Then check if it matches the request...
	iso := app.myRoot.allISOTypes[self.isoType];
	if iso = null then
		_yaAgent.addLogEntry(AP_Log_YA_Default,id &amp; " does NOT have a VALID ISO TYPE!!!!: " &amp; self.isoType, true);
		return false;
	endif;
	//------------------------
	//ONLY test clean if NOT a general type TI
	//------------------------
	if iso.isGeneral = false then
		//----------------
		//Is NOT a general box, test for clean status
		//----------------
		_yaAgent.addLogEntry(AP_Log_YA_Default,id &amp; " is NOT a General ISO Type, now testing Clean.", true);
		if self.isClean &lt;&gt; cmifRequest.clean then
			_yaAgent.addLogEntry(AP_Log_YA_Default,id &amp; " does not match clean status. TI clean status = " &amp; isClean.getYesNo &amp; " Request wants " &amp; cmifRequest.clean.getYesNo, true);
			return false;
		endif;	
	else
		_yaAgent.addLogEntry(AP_Log_YA_Default,id &amp; " is a General ISO Type.(ignoring Clean test)", true);
	endif;

 	if cmifRequest.isoType.trimRight &lt;&gt; null then
 		//---------------------
 		//If there's an ISO type, test it.
 		//---------------------
 		if not self.isSimilarToISOType(cmifRequest.isoType) then
		
			if cmifRequest.isoGroup &lt;&gt; null then //cnwrd1 22.12.09 ++
				if cmifRequest.myDeliveryRequest &lt;&gt; null then //cnwrd1 par 30414 25.9.2012
					if not cmifRequest.myDeliveryRequest.testISOGroup( self.isoTypeGroup.trimRight , null ) then
						_yaAgent.addLogEntry(AP_Log_YA_Default, app.getErrorString3 ( TI_TestReqISOGroup, self.id, self.isoTypeGroupDesc,  cmifRequest.isoGroup) , true);
						return false;
					endif;
				else
					if self.isoTypeGroup.trimRight &lt;&gt; cmifRequest.isoGroup then
						_yaAgent.addLogEntry(AP_Log_YA_Default, app.getErrorString3 ( TI_TestReqISOGroup, self.id, self.isoTypeGroupDesc,  cmifRequest.isoGroup ) , true);
						return false;
					endif;
				endif;
			else
				///_yaAgent.addLogEntry( app.getErrorString2 ( TI_TestReqISO, self.id, self.isoType ) , true);
				_yaAgent.addLogEntry(AP_Log_YA_Default, app.getErrorString3 ( TI_TestReqISO, self.id, self.isoType, cmifRequest.isoType ) , true);	// 08/09/2010 cnmwh5 #25696
				return false;
			endif;
		endif;
	else //check if we have ISO group (and no ISO type)//cnwrd1 11.01.2010
		if cmifRequest.isoGroup &lt;&gt; null then 
			if cmifRequest.myDeliveryRequest &lt;&gt; null then //cnwrd1 par 30414 25.9.2012
				if not cmifRequest.myDeliveryRequest.testISOGroup( self.isoTypeGroup.trimRight , null ) then
					_yaAgent.addLogEntry(AP_Log_YA_Default, app.getErrorString3 ( TI_TestReqISOGroup, self.id, self.isoTypeGroupDesc,  cmifRequest.isoGroup) , true);
					return false;
				endif;
			else
				if self.isoTypeGroup.trimRight &lt;&gt; cmifRequest.isoGroup then
					_yaAgent.addLogEntry(AP_Log_YA_Default, app.getErrorString3 ( TI_TestReqISOGroup, self.id, self.isoTypeGroupDesc,  cmifRequest.isoGroup) , true);
					return false;
				endif;			
			endif;
		endif;
	endif;

  //NFS 3162: If we want a COU make sure that we have one attached
  if cmifRequest.isDeliveryRequest then
		if cmifRequest.myDeliveryRequest.needCOU and self.getCou = null then
			_yaAgent.addLogEntry(AP_Log_YA_Default,id &amp; " does not have a COU. The request wants one", true);
			return false;	
		endif;

		if cmifRequest.myDeliveryRequest.needGenerator and self.getGenerator=null then
			_yaAgent.addLogEntry(AP_Log_YA_Default,id &amp; " does not have a Generator. The request wants one", true);
			return false;	
		endif;
		
		if cmifRequest.myDeliveryRequest.heavyRated and not self.isHeavyDuty then
			_yaAgent.addLogEntry(AP_Log_YA_Default,id &amp; " is not heavy duty. The request wants one", true);
			return false;	
		endif;
		
	endif;
	if cmifRequest.allAvailabilityGrades.size &gt; 0 then
		//NFS 3798 An undefined grade in the request means that all TI's comply
		if not cmifRequest.allAvailabilityGrades.includes(self.availabilityGrade) then
			_yaAgent.addLogEntry(AP_Log_YA_Default,id &amp; " has an Availability Grade (" &amp; self.availabilityGrade.String &amp; ") that does not match the request.", true);
			return false;		
		endif;
	endif;
	
	//cnwrd1 par 31777 check todo tasks for autoplan reverse lookup	
	// PAR #31959 now done in superclass
	/*if self.allToDoTasksToDo.isEmpty = false then	
		_yaAgent.addLogEntry(AP_Log_YA_Default,id &amp; " has ToDo Tasks " &amp; self.getToDoTasksDisplay(self.allToDoTasksToDo, true) &amp; ".", true);
		return false;
	endif;*/
	
	//Start 3.11.2022	navsks20 TFS 52721
	if cmifRequest.checkIsAvailable() then // ### TFS 52721 15NOV2022 NAVAB1
		_yaAgent.addLogEntry(AP_Log_YA_Default,id &amp; " now testing Available.", true);
		if cmifRequest.isAvailable // ### TFS 52721 16NOV2022 NAVAB1 - if requested 'available' only
		and not self.isAvailable then // ### TFS 52721 16NOV2022 NAVAB1
			_yaAgent.addLogEntry(AP_Log_YA_Default,id &amp; " does not match Available status. TI Available status = " &amp; self.isAvailable.getYesNo &amp; " Request wants " &amp; cmifRequest.isAvailable.getYesNo, true);
			return false;
		endif;
	endif;
	//End 3.11.2022	navsks20 TFS 52721
	
	return true;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateContentsStatus" id="d154be31-079f-44b9-81fc-4aa8f0a79e62">
        <updating/>
        <source>updateContentsStatus() updating;
// ---------------------------------------------------------------------------
// Created:     01 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27/09/2017  cnwma1		TFS #7007 POL - Clear Weight Certified Details when Commodity Changed to MT
// ---------------------------------------------------------------------------
vars
	newStatus				: Integer;
	child					: CM_TrackedItem;
	mtCommodity				: String;
	tmpCommodity			: CM_Commodity;
	hasLCLChildren			: Boolean;
	
begin
	exclusiveLock(self);

 	// DVB return for Db purge;
	if self.myTerminal = null then
		return;
	endif;
	
	newStatus := TI_CONTENTS_STATUS_FCL;
	if self.commodity.trimBlanks = null then
		//jlier1 14/10/25 JIRA-36155
		if self.isRotatableContainer and self.getCargoTypeForContents() &lt;&gt; null then
			newStatus := TI_CONTENTS_STATUS_FCL;
		else
			newStatus := TI_CONTENTS_STATUS_EMPTY;
		endif;
	else
		tmpCommodity := self.getCommodityObject();
		if tmpCommodity &lt;&gt; null and tmpCommodity.isEmpty then
			newStatus := TI_CONTENTS_STATUS_EMPTY;
		endif;
    endif;

	//------------------
  	//check none of the children are LCL
	//------------------
//	isoType := self.getISOTypeObject();
	foreach child in self.allChildren do
		if child.cargoType = TI_CargoType_LCL or
			child.cargoType = TI_CargoType_BreakBulk or
			child.cargoType &gt; TI_CargoBOLType_Max then // contains atleast one break bulk so set status to LCL
			
		   	//newStatus := TI_CONTENTS_STATUS_LCL;  // 30/11/2010 cnwar2 #26454 - change to use boolean 
			hasLCLChildren := true;
       		break;
     	endif;
	endforeach;
	
	// 30/11/2010 cnwar2 #26454 - as below
	if hasLCLChildren then
		
		if self.isPackingComplete() then
			// have found a Pack Complete at this terminal, with no subsequent unpack.
			// set to default for terminal or LCL if no default set
			if self.myTerminal.getConfig(DefaultContentsStatus).String = app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FCL].abbreviation then
				newStatus := TI_CONTENTS_STATUS_FCL;
			else
				newStatus := TI_CONTENTS_STATUS_LCL;
			endif;
			
		//18 May 2011	NDL	Par 27344
		elseif self.hasUnpackAsLastPackActivity() then	
			// OK we have some child cargo, and our last trx was an unpack so we must be Less than a Container Load (LCL)
			newStatus := TI_CONTENTS_STATUS_LCL; 
		
		else
		
			// no pack complete at this terminal.  Might have been packed at another terminal so
			// if FCL leave as is, otherwise set to LCL
			if self.contentsStatus &lt;&gt; TI_CONTENTS_STATUS_FCL then
				newStatus := TI_CONTENTS_STATUS_LCL;
			endif;
		endif;
	endif;
	
	self.contentsStatus := newStatus;
	
	//par7831
	if self.commodity = null and self.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
		
		if not self.isRotatableContainer() then //08/10/2025	navkc1 JIRA 36144 - Dont do this for rotainer
			mtCommodity := self.myTerminal.getDefaultEmptyCommodity();
			self.setCommodity(mtCommodity);
		endif;
	endif;

	if newStatus = TI_CONTENTS_STATUS_EMPTY then
		self.updatedContenstStatusForEmpty();	//PAR 18718. When container is MT, then OD and Haz sould be set to null.
		
		if self.isWeightCertified then   //27.09.2017 cnwma1 TFS #7007
			self.isWeightCertified :=false;
			self.deleteVGMDetails();					
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="updateEDIAttributesForMerge" id="d93cfb68-fbd8-4acc-8bf0-7886cee5acc8">
        <updating/>
        <source>updateEDIAttributesForMerge(_ti: CM_Container; updateCtrl: CMIF_TIUpdateController io) updating;
//----------------------------------------------------------------
//	Created:	14 February 2005	by Jason Chapman  (cnwjc2)
// Changed		By		Reason
// ----------	-------	------------------------------------------
// 01/12/2009	cnwdap1	CCMS MES 1007 Reefer properties moved to CM_TrackedItem level
//----------------------------------------------------------------
vars
	
begin
	inheritMethod(_ti, updateCtrl);

	//careful with changing ISO type - don't want to trigger a change in size just yet
	if self.getISOTypeObject.isSimilarISOType(_ti.getISOTypeObject) then
		self.changeISOType(_ti.isoType, updateCtrl, app.myPassport);
	endif;
	
	self.setOverDimensionsOnly(_ti.overHeight, _ti.overLengthFront, _ti.overLengthRear, _ti.overWidthLeft, _ti.overWidthRight);											// 24/09/2012 cnwmh5 #30408
		
	//self.setTemperature(_ti.getTemperature);		// CCMS 1007
	
	//self.sealNum := _ti.sealNum;
	/*28 Sep 2010	NDL	Par 25608 - moved code up see call of inheritMethod.
	//16 Sep 2010	NDL	Par 25608 - Use/update new seals data structure
	if _ti.getSealNum.trimBlanks &lt;&gt; null then
		if self.isTransient then
			self.createProxySealTIsFromRawData(	_ti.getSealNum,	//_sealNum : String;
												null,	//_prevSealNum : String;
												null,	//_sealNumShippers : String;
												null,	//_sealNumVent : String;
												null,	//_sealNumCustoms : String;
												_ti.getSealDT	//_now : TimeStamp
												);
		else
			self.setSealNumOperators(_ti.getSealNum);
		endif;
	endif;
	*/

end;</source>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="updateCtrl" type="CMIF_TIUpdateController" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateHazardODWhenUnpack" id="1d162dd4-f487-4843-a8c4-7a1db3602ae0">
        <updating/>
        <source>updateHazardODWhenUnpack() updating;
/* ---------------------------------------------------------------------------
Created:	28 September 2009	by cnwvu1

Purpose:	PAR 18718. When I am Hazardous or OD and all children are detached (commodity = MT),
			or my commodity is changed to MT,
			I have to be set to non-hazardous and non-OD.
   
Change Date		Who		Reason
02/11/2009		cnwdap1	CCMS MES 1017 Clear new overdimension fields
------------------------------------------------------------------------------*/
vars

	tmpAllTIHazardsEmpty	: CM_HazardByCodeDict;
	localTareWeight : Decimal [14,4];
	
begin

	if not self.isOnSite() then	// when adding the child on Sipp or on Rail?
		return;
	endif;

	// ----------------------------------------------------------------------------------------
	//							setting OD and hazardous to null
	// ----------------------------------------------------------------------------------------
	
	
	//24 July 2013	NDL	Par 32023 - Remove the automatic reset of hazardous when unpacked...
/*	if self.allTIHazards &lt;&gt; null and self.allTIHazards.size &gt; 0 then
		self.allTIHazards.purge;
		self.hazard := null;

	endif; */
	
	// ------------------ OD ---------------
	if self.height &lt;&gt; null then
		self.setHeight(null);
	endif;
	if self.width &lt;&gt; null then
		self.setWidth(null);
	endif;
	if self.length &lt;&gt; null then
		self.setLength(null);
	endif;
	// CCMS 1017 start
	if self.overHeight &lt;&gt; null then
		self.overHeight := null;
	endif;
	if self.overLengthFront &lt;&gt; null then
		self.overLengthFront := null;
	endif;
	if self.overLengthRear &lt;&gt; null then
		self.overLengthRear := null;
	endif;
	if self.overWidthLeft &lt;&gt; null then
		self.overWidthLeft := null;
	endif;
	if self.overWidthRight &lt;&gt; null then
		self.overWidthRight := null;
	endif;
	// CCMS 1017 end
	
	//15 Mar 2012	NDL	Par 29250
	self.weightDeclared := 0;
	self.setWeightCargo(0);
	
	//5 Jul 2012	NDL	Par 29776
	localTareWeight := self.getTareWeight;
	if localTareWeight &lt;= 0 then
		app.raiseCMException1(Must_greater_than_zero, app.getErrorString(TareWeight),null,null);
		return;
	endif;
	
	self.setTotalWeightWithoutTrans(localTareWeight);
	//self.setTotalWeight(localTareWeight, null, app.myPassport);
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="updateMAFIForVoyageChange" id="abcc72ee-f443-4e22-a38e-8c6b523bbe03">
        <updating/>
        <source>updateMAFIForVoyageChange(_passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2024	jlier1	Initial creation 65290

*/

vars
	tilc : CM_TILC;	
	lc : CM_TILCController;
	hasOnboardCargo, queue : Boolean;
	ti		: CM_TrackedItem;
	params 	: CMIF_AutoplanParams;
	oldValue,
 	editDetails: String;
	editTrx  : CM_Edit;
	needMAFIEdit,
	needCargiEdit : Boolean;
begin
	tilc:=self.getCurrentTrailer;
	if tilc = null or not tilc.isMAFI then
		return;
	endif;
	if _passport.myStateChangeController &lt;&gt; null then
		_passport.myStateChangeController.initForObject(tilc); //jlier1 TFS 61676 14/12/23 
	endif;
	
	foreach lc in tilc.allLCs discreteLock do : outerLoop
		foreach ti in lc.allTrackedItems discreteLock do
			if ti &lt;&gt; self then
				hasOnboardCargo:=true;
				break outerLoop;
			endif;
		endforeach;
	endforeach;
	
	needMAFIEdit:=tilc.pxyGetRealObject = null;
	
	
	if self.myVoyage &lt;&gt; tilc.myVoyage then
		if hasOnboardCargo then
			queue:=true;
		else
			oldValue := app.getErrorString(Voyage) &amp; " - " &amp; tilc.voyageCode;
			tilc.changeVoyage(self.myVoyage,app.myPassport);	
			if needMAFIEdit then
				editDetails := app.formatForEditTransaction(CM_TrackedItem::myVoyage.name, oldValue, app.getErrorString(Voyage) &amp; " - " &amp;  tilc.voyageCode);
				editTrx := app.createEditTransaction(tilc, editDetails,null, _passport);
			endif;
			
		endif;
	endif;
	if self.dischargePort &lt;&gt; tilc.dischargePort then
		if hasOnboardCargo then
			queue:=true;
		else
			oldValue := tilc.dischargePort;
			tilc.setDischargePort(self.dischargePort);
			if needMAFIEdit then
				editDetails := app.formatForEditTransaction(CM_TrackedItem::dischargePort.name, oldValue, tilc.dischargePort);
				editTrx := app.createEditTransaction(tilc, editDetails,null, _passport);
			endif;
		endif;
	endif;
	
	if queue and not self.isQueuedToYard then
		create params transient;
		params.moveMode := QUEUE_MODE;
		params.showWarningWhenNoPlan := true;
		params.allTrackedItems.add(self);
		app.myUtilityUA.utlUpdateAutoplanTrackedItems(params, _passport);
	endif;
	
	

epilog
	delete params;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updatePreTripDT" id="4001f6ee-3b70-4663-bad5-af4a13b965af">
        <updating/>
        <source>updatePreTripDT() updating;
//Update the DT after transaction add/edit/delete
// 16/09/2010	cnwdap1		PAR #25754 This should have been moved up to CM_TrackedItem level as part
//							of reefer changes for CCMS 1116
vars
	trans	: CM_TITransaction;
	toDoTask : CM_ToDoTask;

begin
	inheritMethod();
	
	// what the code was before PSR #25754
	/*trans := self.getLastTransOfType(TRANS_TYPE_PRETRIP);

	if trans = null then
		setPreTripDT(null);
	else
		setPreTripDT(trans.dateTime);
	endif;
	
	toDoTask := self.getLastToDoTaskOfType(true, TRANS_TYPE_PRETRIP);
	
	if toDoTask &lt;&gt; null and toDoTask.dtLastUpdate &lt;&gt; trans.dateTime then
		toDoTask.updateLastUpdate(getPreTripDT);
	endif;*/	
end;</source>
    </JadeMethod>
    <JadeMethod name="updatedContenstStatusForEmpty" id="87c98248-85f2-48a4-9572-b19ef4b1be8b">
        <updating/>
        <source>updatedContenstStatusForEmpty() updating, protected;
/* ---------------------------------------------------------------------------
Created:	30 September 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
02/11/2009		cnwdap1	CCMS MES 1017 Clear new over dimension fields
29/08/2018		jlgrh7 		TFS #40020	STWR - Steinweg Rotterdam Over Dimension Tickbox Issue
------------------------------------------------------------------------------*/
vars
	tmpAllTIHazardsEmpty	: CM_HazardByCodeDict;
	
begin

	if self.isTransient then
		return;
	endif;
	
	//if not self.isOnSite() then											//when adding the child on Sipp or on Rail?	//-TFS40020	
	if not self.isOnSite() and not self.isOnShip() then	// +TFS40020	
		return;
	endif;

	if self.allTransactions.size = 0 then
		return;
	endif;

	if self.allChildren.size &gt; 0 then
		return;
	endif;
	
	if self.contentsStatus &lt;&gt; TI_CONTENTS_STATUS_EMPTY then
		return;
	endif;


	// ----------------------------------------------------------------------------------------
	//							setting OD and hazardous to null
	// ----------------------------------------------------------------------------------------

	
	// 09/02/2010 cnwar2 #22296 - remove hazardous clearing
	/*// ------------ HAZARDOUS ---------------
	if self.allTIHazards &lt;&gt; null and self.allTIHazards.size &gt; 0 then
		create tmpAllTIHazardsEmpty transient;	// created but is Empty
		self.setTIHazards(tmpAllTIHazardsEmpty);
	endif;*/
	// ------------------ OD ---------------
	if self.height &lt;&gt; null then
		self.setHeight(null);
	endif;
	if self.width &lt;&gt; null then
		self.setWidth(null);
	endif;
	if self.length &lt;&gt; null then
		self.setLength(null);
	endif;
	// CCMS 1017 start
	if self.overHeight &lt;&gt; null then
		self.overHeight := null;
	endif;
	if self.overLengthFront &lt;&gt; null then
		self.overLengthFront := null;
	endif;
	if self.overLengthRear &lt;&gt; null then
		self.overLengthRear := null;
	endif;
	if self.overWidthLeft &lt;&gt; null then
		self.overWidthLeft := null;
	endif;
	if self.overWidthRight &lt;&gt; null then
		self.overWidthRight := null;
	endif;
	//29/12/2010 cnwdz2 25973
	if self.isOverDimensions then
		self.isOverDimensions := false;
	endif;	
	// CCMS 1017 end
	
	
epilog
	if tmpAllTIHazardsEmpty &lt;&gt; null then
		delete tmpAllTIHazardsEmpty;
	endif;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="usesISOType" id="a7bf1f9b-e4b4-4757-ab79-0d21dc485108">
