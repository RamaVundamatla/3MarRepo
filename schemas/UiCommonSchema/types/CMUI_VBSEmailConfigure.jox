    <JadeMethod name="getXMLSettingsForSave" id="2e707c26-c132-4dd4-9fa2-2e212b5b2304">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Nov 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications
07 Mar 2023	navpw1	Defect 56991 - Fixed code below causing fields to n ot save when all fields selected

*/

vars
	attrNames : StringArray;
	xmlStr	: String;
	entDefAll : EntTableDef;
	row : EntTableRow;
begin
	create attrNames transient;
	attrNames.add(EntTableRow::heading.name);
	
	xmlStr := inheritMethod();
	
	//if self.mulSelectEmailLayout.myAvailableListBox.listCount &lt;&gt; 0 then 	// ### TFS 56991 07Mar2023 NAVPW1
	xmlStr := xmlStr &amp; self.mulSelectEmailLayout.getXMLStringForSelected(attrNames);
	//endif;																// ### TFS 56991 07Mar2023 NAVPW1
	
	return xmlStr;
epilog
	delete attrNames;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="079ba052-4c5a-4823-82bd-48226f122073">
        <source>getXMLSettingsForSetup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Nov 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications

*/

vars
	theXML, theXMLValue : String;
	keyValue : String;
	selected : ObjectArray;
	assoc : EntTableRow;
	assocDict : DynaDictionary;
	lastPos : Integer;
	userWindow	: CM_UserWindow;
	entDefAll : EntTableDef;
begin
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
	endif;
	
	theXML := userWindow.xmlInfo;
	
	create assocDict transient;
	assocDict.setMembership(EntTableRow);
	assocDict.addMemberKey(EntTableRow::heading.name,false,false);
	assocDict.endKeys(false);
	
	create selected transient;
	theXMLValue := theXML.cnEcGetTagValueOfName((CMUI_MultiSelectGroupBox.XMLTag_ListTable &amp; self.mulSelectEmailLayout.name));
	if theXMLValue &lt;&gt; null then
 		theXMLValue := theXMLValue.trimCharacters(CrLf);
		selected.clear;
		assocDict.clear;
		self.allAvailableEmailLayout.copy(assocDict);
		lastPos := 1;
		while true do
			keyValue := theXMLValue.cnEcGetNextTagValueOfName(CMUI_MultiSelectGroupBox.XMLTag_SelectedValue, lastPos);
			
			if keyValue = null then
				break;
			endif;
			
			assoc:=assocDict.getAtKey(keyValue).EntTableRow;
			if assoc &lt;&gt; null then
				selected.add(assoc);
			endif;
			
			if lastPos = 0 then
				break;
			endif;	
		endwhile;
		
		self.mulSelectEmailLayout.setSelected(selected);
	endif;
epilog
	delete selected;
	delete assocDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="initEmailLayout" id="e2675d15-c1d5-4291-bbd8-d2b3c0b54ef5">
        <updating/>
        <source>initEmailLayout() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Nov 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications

*/

constants
	GAP = 10;
	SMALLGAP	= 5;
vars
	control		: CMUI_MultiSelectGroupBox;
	entDefAll : EntTableDef;
begin
	control		:= self.mulSelectEmailLayout;
	
	control.formDisplayEntryMethodName := CMUI_VBSEmailConfigure::displayEntryEntRows.name;
	entDefAll := app.myController.getEntTableDef(ETDef_VBSEmail);
	control.setAvailable(self.allAvailableEmailLayout, true);
	
	control.availableHeading 		:= app.getErrorString (Available);
	control.selectedHeading  		:= app.getErrorString (Selected);
	control.userInputEnabled 		:= true;
	control.multiSelect				:= ListBox.MultiSelect_Extended;
	control.left					:= SMALLGAP;
	control.top						:= SMALLGAP;
	
	//control.setSorted(true);
	control.myAvailableListBox.sorted := true;
	control.mySelectedListBox.sorted := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setSelectedRow" id="9497a0bd-f497-4297-bb9e-eb10af2f26c7">
        <source>setSelectedRow();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Nov 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications

*/

vars
	rowPointer, rowCount	: Integer;
	listObject	: Object;
	listboxObj	: ListBox;
begin
	listboxObj	:=	self.mulSelectEmailLayout.mySelectedListBox;
	rowCount	:=	listboxObj.listCount();
	foreach rowPointer in 1 to rowCount do
		listObject	:=	listboxObj.itemObject[rowPointer];
		self.allSelectedEmailLayout.add(listObject.EntTableRow);
	endforeach;
	if self.myParentForm.isKindOf(CMUI_VehicleBookingEnqForm) then
		self.myParentForm.CMUI_VehicleBookingEnqForm.allSelectedRows.clear();
		self.allSelectedEmailLayout.copy(self.myParentForm.CMUI_VehicleBookingEnqForm.allSelectedRows);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9ef10fa3-e135-4ba6-8b4a-fe2ae58c1f35">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Nov 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications

*/

vars

begin
	inheritMethod();
	self.btnOk.caption := "Save";
	self.btnCancel.caption := "Close";
	self.mulSelectEmailLayout.myUpSelectedBtn.visible := true;
	self.mulSelectEmailLayout.myDownSelectedBtn.visible := true;
	self.mulSelectEmailLayout.myTopSelectedBtn.visible := true;
	self.mulSelectEmailLayout.myBottomSelectedBtn.visible := true;
	self.setupRows();
	self.initEmailLayout();
	self.getXMLSettingsForSetup();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupRows" id="3fd63d64-693e-4f17-a21b-c38a7a6ce07c">
        <source>setupRows() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Nov 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications

*/

vars
	entDefAll : EntTableDef;
	row : EntTableRow;
begin
	entDefAll := app.myController.getEntTableDef(ETDef_VBSEmail);
	
	foreach row in entDefAll.allEntTableRows do
		self.allAvailableEmailLayout.add(row);
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="de36ccf2-3a49-4db5-b302-78dd0a0dbdb7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 February 2023 14:11:13.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025573, locale);
end;</source>
    </JadeMethod>
</GUIClass>
