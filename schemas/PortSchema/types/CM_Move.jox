    <JadeMethod name="isChargeable" id="3c19e87c-b963-483d-be1d-d557689f3651">
        <source>isChargeable(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors

*/

vars

begin
	
	if app.myRoot.isClientEuroPorts then
		if self.mode = PLANNING_MODE or self.mode = QUEUE_MODE then
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
