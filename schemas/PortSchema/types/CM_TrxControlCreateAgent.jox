    <JadeMethod name="trxCreateAgentDebtor" id="c1d11e4e-5ea5-4145-8b92-e0f0ff67709b">
        <updating/>
        <source>trxCreateAgentDebtor(_cmif : CMIF_AgentDebtor; _realAgent : CM_Object output; _realDebtor : CM_Debtor output; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     20 February 2014 cnwjre1
//
// Purpose:     Create a consignee/consignor/freight forwarder/customs agent with an associated debtor, as cash-only
//				CCMS GLT 2342 par 33497
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/03/2015	cnwdap1		PAR #35895 CCMS PNL 2461 added isUsedForPacking attribute
// 03 Aug 2017	cnwma1		TFS #5209:PEN - Release Request Stop
// 09/08/2018	jlgdap1		TFS 40092 New parameter for CM_DebtorNode::setProxy
// 10/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// ---------------------------------------------------------------------------
vars
	proxyConsignee	: CM_ConsigneeConsignor;
	proxyCustomsAgent	: CM_CustomsAgent;
	proxyStevedore		: CM_Stevedore;					// TFS 44554
	proxyDebtorNode		: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	newDebtorNode			: CM_DebtorNode;
	newDebtor				: CM_Debtor;
	theBank : CM_Bank;
	rdg		: CM_RootDebtorGroup;
	term : CM_Terminal;
	debtorTermDetail : CMIF_DebtorTerminalDetail;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	// agent can be created withan existing debtor.  In this case, cmif.myDebtor is set.
	if _cmif.myDebtor &lt;&gt; null then
		newDebtor := _cmif.myDebtor;
	else
		create debtorNodeController transient;

		theBank := app.myRoot.myRootCompany;
		rdg := theBank.getRootDebtorGroup();
	
		debtorNodeController.myBank := theBank;
		debtorNodeController.myParentDebtorNode := rdg;
		create proxyDebtorNode as CM_Debtor transient;
		//proxyDebtorNode.setProxy(_cmif.debtorName);				// TFS 40092
		proxyDebtorNode.setProxy(_cmif.debtorName, null);			// TFS 40092
		debtorNodeController.myPxyDebtorNode := proxyDebtorNode;		// this is used to get the class to create, nothing else
		debtorNodeController.name := _cmif.debtorName;
		debtorNodeController.billingAddress := _cmif.debtorAddress;
		debtorNodeController.decfinName := _cmif.agentCode;
		
		// ### TFS 52237 02NOV2021 NAVAB1 add debtor terminal for all terminals
		foreach term in app.myRoot.allTerminals do
			create debtorTermDetail transient;
			
			debtorTermDetail.setMyTerminal(term);
			debtorTermDetail.setPaymentType(PaymentType_PostPay);
			
			if _cmif.isCashOnly then
				debtorTermDetail.setCashOnly(term.isCashOnlyEnabled());
			
			endif;
			debtorNodeController.allDebtorTerminalDetails.add(debtorTermDetail);
		endforeach;
		
		
		
	endif;

	app.setContinueCMExceptions(false);
	// create and populate the proxies and debtor cmif
	if _cmif.agentType = CUSTOMS_AGENT then
		create proxyCustomsAgent transient;
		proxyCustomsAgent.setProxy(_cmif.agentCode,
								   _cmif.agentDescription,
								   false,			// isNotAvailableForEntry
								   null);			// debtor, is set below
	
	// TFS 44554
	elseif _cmif.agentType = STEVEDORE then
		create proxyStevedore transient;
		proxyStevedore.setProxy(	_cmif.agentCode,			// code
									_cmif.agentDescription,		// description
									false,						// not available for entry
									null	);					// debtor, set below
	// TFS 44554
	
	else
		create proxyConsignee transient;
		proxyConsignee.setProxy(_cmif.agentCode,			// code
								_cmif.agentDescription,		// description
								false,					// not for entry
								false,					// secure exporter
								null,					// derogation number
								null,					// email address
								0,						// colour
								0,						// order
								null,					// consign group
								null,					// debtor, is set below
								false,					// show OOW remarks
								_cmif.isConsignee,
								_cmif.isConsignor,
								_cmif.isFreightForwarder,
								null,					// email PIN adresses
								null,					// license
								null,					// license expiry
								false,					// is used for packing			// PAR #35895
								false,
								false);					// 3.8.2017 cnwma1 TFS #5209
	endif;
	
	// Start the transaction
	beginTransaction;
	if debtorNodeController &lt;&gt; null then
		app.myUtilityCA.utlCreateDebtorNode(debtorNodeController, newDebtorNode, _passport);
		if not self.checkValidationWithPassport(_passport) then
			return;
		endif;
		newDebtor := newDebtorNode.CM_Debtor;
	endif;

	if _cmif.agentType = CUSTOMS_AGENT then
		proxyCustomsAgent.setDebtor(newDebtor);
		app.myUtilityCA.utlCreateCustomsAgent(proxyCustomsAgent, _realAgent, _passport);
	elseif _cmif.agentType = STEVEDORE then													// TFS 44554
		proxyStevedore.setDebtor(newDebtor);												// TFS 44554
		app.myUtilityCA.utlCreateStevedore(proxyStevedore, _realAgent, _passport);			// TFS 44554
	else
		proxyConsignee.setDebtor(newDebtor);
		app.myUtilityCA.utlCreateConsigneeConsignor(proxyConsignee, _realAgent, _passport);
	endif;
	_realDebtor := newDebtor;
	
epilog
	if debtorNodeController &lt;&gt; null then
		debtorNodeController.allDebtorTerminalDetails.purge(); // ### TFS 52237 27OCT2021 NAVAB1
	endif;
	
	
	delete debtorNodeController;
	delete proxyDebtorNode;
	delete proxyCustomsAgent;
	delete proxyConsignee;
	delete proxyStevedore;							// TFS 44554
	self.finaliseActivityWithPassport(_passport);
end;
</source>
        <Parameter name="_cmif" type="CMIF_AgentDebtor"/>
        <Parameter name="_realAgent" type="CM_Object" usage="output"/>
        <Parameter name="_realDebtor" type="CM_Debtor" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateAllFaultResponses" id="56dbee9b-29a5-48c7-8d1a-5d5be2ba152d">
        <updating/>
        <source>trxCreateAllFaultResponses(_allPxyFaultResponses : CM_FaultResponseArray input;  _terminal : CM_Terminal;  _passport : CM_Passport input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	faultResponse, newFaultResponse : CM_FaultResponse;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	// Start the transaction
	beginTransaction;

	app.myUtilityCA.utlCreateFaultResponses(_allPxyFaultResponses, _terminal, _passport);
	
	if _passport.hasErrors then
		_passport.dumpErrorWarnings();
	endif;
	

epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_allPxyFaultResponses" type="CM_FaultResponseArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateAndActionGateEntity" id="70df7be1-b8df-4c4b-b0de-6909840616aa">
        <updating/>
        <source>trxCreateAndActionGateEntity(_vvr : CM_VehicleVisitRecord input; _pxyGTE : CMGTE_Entity input; _receivalRequestInfo : CM_ReceivalInfo; _gte: CMGTE_Entity output; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     13 Aug 2009 cnwdw1
// Purpose:     Create a gate entity, and also action it to create the TI or Release
//19/6/2025   jlier1MTN-34221 refactoring validation so is before trx 
vars
	pxyTIs : CM_ObjectByStringDict;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	//19/6/2025   jlier1 MTN-34221 refactoring validation so is before trx 
	app.setContinueCMExceptions(true);
	create pxyTIs transient;
	app.myValCA.valGateEntity(_vvr,_pxyGTE,pxyTIs,_passport);
	
	if pxyTIs &lt;&gt; null then
		pxyTIs.purge;
		delete pxyTIs;
	endif;
	
	if app.myPassport.hasErrorsIgnored then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	_passport.useTITransactionDeferUpdate := true;	// PAR 18896, 09/03/2011
	_passport.useTIDictDeferUpdate := true;			// PAR 18896, 09/03/2011
	
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateInOutFlexiGateEntity(_vvr, _pxyGTE, _gte, _passport);

	if _passport.noErrors then
		app.myUtilityCA.utlCreateActionGateEntity(_vvr, _gte, false, _receivalRequestInfo, _passport);
	endif;
	
	//22 Feb 2010 NDL	CCMS 1867 - If the TI is being created in relation to a ReceivalRequestInfo, we need to tie the two together.
	if _receivalRequestInfo &lt;&gt; null and _passport.noErrors then
		if _gte.isKindOf( CMGTE_Receival ) then
			if _gte.CMGTE_Receival.myTrackedItem &lt;&gt; null then
				_receivalRequestInfo.addTrackedItem( _gte.CMGTE_Receival.myTrackedItem);
			endif;
		endif;
	endif;

	if _passport.noErrors then	// PAR 18896, 09/03/2011
		_passport.doDeferredUpdates();	
	endif;
	
epilog
	if pxyTIs &lt;&gt; null then
		pxyTIs.purge;
		delete pxyTIs;
	endif;

	self.finaliseActivityWithPassportEW(_passport, true);
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_pxyGTE" type="CMGTE_Entity" usage="input"/>
        <Parameter name="_receivalRequestInfo" type="CM_ReceivalInfo"/>
        <Parameter name="_gte" type="CMGTE_Entity" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
