<Class name="WS_RestReceivalDetailObject" id="0bd77a93-d77c-4a30-b422-a07c77b98587">
    <superclass name="WS_CargoObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <Constant name="Receival_Ship" id="5b748f80-c2df-4c88-ac46-8f2cb46db8b4">
        <source>"Ship"</source>
        <type name="String"/>
    </Constant>
    <Constant name="Receival_Train" id="6a08c6e2-f375-4060-a964-49172533c045">
        <source>"Train"</source>
        <type name="String"/>
    </Constant>
    <Constant name="Receival_Truck" id="f79a4af9-f7b7-40ff-8281-0bd5f17b728e">
        <source>"Truck"</source>
        <type name="String"/>
    </Constant>
    <Constant name="Receival_Wagon" id="5dfcb7b6-c10e-49be-8320-35583ec0297c">
        <source>"Wagon"</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="carrierId" id="335681fb-6440-4b55-80e6-6cbfc2c612cd">
        <length>11</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="dateTime" id="21cf5ff3-0f0a-4e7d-8c6f-edad3a069ace">
        <embedded/>
        <type name="TimeStampOffset"/>
    </PrimAttribute>
    <PrimAttribute name="id" id="b643fb8e-af0d-44ad-9796-7241a06efc52">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="type" id="c85bd1af-e296-44fc-aab2-87a356bb622c">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="validateRequest" id="ba7bebb7-c044-44fb-b841-de5d2ee1dacd">
        <source>validateRequest() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 June 2024		navmd1	Initial creation TFS 64176 Add some basic validation to Receival Details

*/

vars

begin
	app.writeLog(method.qualifiedName, LogTRACE);
	
	if self.id = null then
		// Its a bit dumb, but going from Nowhere to somewhere is a thing we allow
		//app.raiseCMException1(0 /* no id */, self.id, null, null);
		//return false;
	endif;
	
	if	(self.id &lt;&gt; null and self.type = null) or
		(self.type &lt;&gt; null and not self.type.isOneOf(Receival_Ship, Receival_Truck, Receival_Train, Receival_Wagon)) then
		app.raiseCMException1(Receive_Detail_Type_Invalid, self.type, null, null);
		return false;
	endif;
	
	// Validate Max lengths
	if self.type = WS_RestReceivalDetailObject.Receival_Ship and self.id.length &gt;= CM_Voyage::code.length then
		app.raiseCMException2(Field_Value_Too_Long, "receivalDetails/id", (CM_Voyage::code.length-1).String, null, null);
		return false;
	elseif self.type = WS_RestReceivalDetailObject.Receival_Truck and self.id.length &gt;= CM_Vehicle::regNumber.length then
		app.raiseCMException2(Field_Value_Too_Long, "receivalDetails/id", (CM_Vehicle::regNumber.length-1).String, null, null);
		return false;
	elseif self.type = WS_RestReceivalDetailObject.Receival_Train and self.id.length &gt;= CM_Train::code.length then
		app.raiseCMException2(Field_Value_Too_Long, "receivalDetails/id", (CM_Train::code.length-1).String, null, null);
		return false;
	elseif self.type = WS_RestReceivalDetailObject.Receival_Wagon and self.id.length &gt;= CM_Wagon::id.length then
		app.raiseCMException2(Field_Value_Too_Long, "receivalDetails/id", (CM_Wagon::id.length-1).String, null, null);
		return false;
	endif;
	
	return true;
			
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
