    <JadeMethod name="doDeleteJob" id="98f7ad9a-d2ab-48d9-9f05-43a81a0f9fe7">
        <updating/>
        <source>doDeleteJob(_job : CM_Job io) updating;
//-----------------------------------------
//Created: May 2003 By: cnwgd1
//-----------------------------------------

vars
	result : Integer;
begin

	if _job = null then
		return;	
	endif;

	app.mousePointer := MousePointer_HourGlass;	

	while true do
		app.myTrxDA.trxDeleteJob(_job, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog('Delete Voyage Job', app.myPassport,  ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog 
	app.mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="_job" type="CM_Job" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doDeselectOtherTables" id="8d100d00-3053-45fa-b70f-c94247b9b4a0">
        <source>doDeselectOtherTables(_includeInfo : Boolean);
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aWLETable,aTblInfo : CM_DataTable;
	anObject : Object;
	idx,tblIdx, numTables : Integer;
begin
	if self.myCurrentTableWLE = null then
		return;
	endif;

	foreach anObject in self.allClonedWLETables do
		aWLETable := anObject.CM_DataTable;
		idx := idx + 1;
		if self.myCurrentTableWLE = aWLETable then
			continue;
		endif;
		
		aWLETable.deselectAll();
	endforeach;
	
	
	if _includeInfo then
		self.tblInfo.rows := 0;
		numTables := self.allClonedWLETables.size;
		foreach idx in 1 to numTables + 1 do
			aTblInfo := self.tblInfo.getControl(idx).CM_DataTable;
			if aTblInfo &lt;&gt; null then //and aTblInfo &lt;&gt; self.myCurrentTableInfo then
				aTblInfo.rows := 0; //aTblInfo.fixedRows;
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="_includeInfo" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEdit" id="7a09a010-3129-49e5-821b-91e135213d01">
        <source>doEdit();
//--------------------------------------------------------------
//Created: 15 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	bol 	: CM_BOL;
	job 	: CM_Job;
begin
	if self.myCurrentWLE = null then
		app.msgBox('Please select an entry from the table to edit.','Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;	
	endif;
	
	job := self.myCurrentWLE.job;

	if self.myCurrentTrackedItem &lt;&gt; null then
		self.myAssistant.showCargoEnquiryForm(self.myCurrentTrackedItem, self.myMasterMenuAction, true, true);
	else
		app.msgBox('Job Entry ' &amp; job.jobId &amp; ' does not have an associated Cargo Item.','No Item to Edit.', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;	
	endif;
	
end;</source>
    </JadeMethod>
