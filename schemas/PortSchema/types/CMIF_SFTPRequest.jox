    <JadeMethod name="fin" id="358da31d-c7bf-468e-81b7-4e97932e4e9b">
        <source>fin();
//
// 24 Oct 2019	jlgrs1	TFS 46087 JMT implement SFTP.
//
vars
	timerOption,
	remainingTime		: Integer;
begin
	self.endNotification(self, SSH_CMD_EVENT_STDOUT);
	self.endNotification(self, SSH_CMD_EVENT_BOJ);
	self.endNotification(self, SSH_CMD_EVENT_EOJ);
	self.endNotification(self, SSH_CMD_EVENT_WARNING);
	self.endNotification(self, SSH_CMD_EVENT_ERROR);
	self.endNotification(self, SSH_CMD_EVENT_HALT);

	self.endNotification(self, SFTP_CMD_EVENT_BOJ);
	self.endNotification(self, SFTP_CMD_EVENT_STDOUT);
	self.endNotification(self, SFTP_CMD_EVENT_EOJ);
	
	self.endNotification(self, SFTP_READ_EVENT_BOJ);
	self.endNotification(self, SFTP_READ_EVENT_STDOUT);
	self.endNotification(self, SFTP_READ_EVENT_FILESIZE);
	self.endNotification(self, SFTP_READ_EVENT_PROGRESS);
	self.endNotification(self, SFTP_READ_EVENT_WARNING);
	self.endNotification(self, SFTP_READ_EVENT_ERROR);
	self.endNotification(self, SFTP_READ_EVENT_EOJ);	

	self.endNotification(self, SFTP_WRITE_EVENT_BOJ);
	self.endNotification(self, SFTP_WRITE_EVENT_STDOUT);
	self.endNotification(self, SFTP_WRITE_EVENT_FILESIZE);
	self.endNotification(self, SFTP_WRITE_EVENT_PROGRESS);	
	self.endNotification(self, SFTP_WRITE_EVENT_WARNING);
	self.endNotification(self, SFTP_WRITE_EVENT_ERROR);
	self.endNotification(self, SFTP_WRITE_EVENT_EOJ);
	
	// If our dirlist timeout timer still happens to be running, kill it before we go away
	if self.getTimerStatus(CMIF_SFTPRequest.EVENT_TIMEOUT, timerOption, remainingTime) then			// TFS 52179 navmd1 30/09/2022
		self.endTimer(CMIF_SFTPRequest.EVENT_TIMEOUT);												// TFS 52179 navmd1 30/09/2022
	endif;																							// TFS 52179 navmd1 30/09/2022
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCNWSSHLogLevel" id="c0881cd8-b7ae-4aa4-9ac8-0114e4d7443a">
        <source>getCNWSSHLogLevel():Integer protected;
/*

Purpose:	
	This method maps the current application log level to the corresponding logging verbosity level logged to cnwssh.log.
	
	MTN to CNWSSH mapping
	
	Master Terminal -&gt; CNWSSH :
	0 Info 			-&gt; N/A
	1 Fatal 		-&gt; 1 Warning
	2 Error 		-&gt; 2 Information
	3 Warn 			-&gt; 0 No Additional Logging    (as this is the default for both "systems")
	4 Debug 		-&gt; 3 Debug
	5 Trace 		-&gt; 4 Trace
Parameters:			

Return Value:		

Date		Who		Reason
05 September 2022	navsp1	Initial creation TFS#54620 - CNWSSH 1.0.0.17 Library update

*/

vars
	appLogLevel : Integer;
begin
	appLogLevel	:= app.logLevel;//MTN log level
	if appLogLevel = LogINFO then 
		return -1;//no logging
	elseif appLogLevel = LogFATAL then
		return 1;
	elseif appLogLevel = LogERROR then
		return 2;
	elseif appLogLevel = LogWARN then
		return 0;
	elseif appLogLevel = LogDEBUG then
		return 3;
	elseif appLogLevel = LogTRACE then
		return 4;
	else 
		return -1;//no logging
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTextFromDateOnwards" id="cb950b1e-9bf2-49b0-8003-cba08f596c67">
        <source>getTextFromDateOnwards( _inputStr : String ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2021	navndl1	Initial creation	TFS 51800 - Provide for different formated "response" from "emSFTP_ListDir"

*/

vars
	strDate : String;
	msg : String;
	posSpaceA : Integer;
	posSpaceB : Integer;
	
begin

	
	//New rules - It seems we don't actually know the exact format of what we might receive before the date, so don't really know where it starts.
	//The TFS 51800 examples start at pos 60, (not 43 or 44)
	//Lets just look for the first 3 character section that is a valid month, and start there.
	
	while true do
		if posSpaceA = 0 then
			//only need to set the first time thru, subsequent times it becomes what ever posSpaceB was last time plus one
			posSpaceA := _inputStr.pos( " ", 1 );
			if posSpaceA = 0 or posSpaceA &gt;= _inputStr.length then
				//No space character found
				break;
			endif;
		endif;
		
		//find the next space character after the one at posSpaceA
		posSpaceB := _inputStr.pos( " ", posSpaceA );
		if posSpaceB = 0 or posSpaceB &gt;= _inputStr.length then
			//No next space found or it was right at the end, so no room for rest of the data etc.
			break;
		elseif posSpaceA + 3 = posSpaceB then
			//We have a three character string between these two spaces, this might be the month portion of a date
			if self.convertMthNameToNumber( _inputStr[ posSpaceA:3] ) &gt; 0 then
				strDate := _inputStr.String[posSpaceA:end].cnEcRemoveSubstring(Lf).cnEcRemoveSubstring(Cr);
				break;
			endif;
		endif;
		
		//Not yet, so try again
		posSpaceA := posSpaceB + 1;
	
	endwhile;
	
	if strDate = null then
		msg := '068, strDate = ' &amp; strDate &amp; ',  _inputStr = ' &amp; _inputStr;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogINFO);
	endif;
	
	return strDate;
		
epilog

end;</source>
        <Parameter name="_inputStr" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="21e22b21-a769-41aa-8ea9-24c0940c0437">
        <source>init();
//
// 24 Oct 2019	jlgrs1	TFS 46087 JMT implement SFTP.
//
vars

begin
	self.beginNotification(self, SSH_CMD_EVENT_STDOUT, Response_Continuous, 0);	
	self.beginNotification(self, SSH_CMD_EVENT_BOJ, Response_Continuous, 0);
	self.beginNotification(self, SSH_CMD_EVENT_EOJ, Response_Continuous, 0);
	self.beginNotification(self, SSH_CMD_EVENT_WARNING, Response_Continuous, 0);
	self.beginNotification(self, SSH_CMD_EVENT_ERROR, Response_Continuous, 0);
	self.beginNotification(self, SSH_CMD_EVENT_HALT, Response_Continuous, 0);
	
	self.beginNotification(self, SFTP_CMD_EVENT_BOJ, Response_Continuous, 0);
	self.beginNotification(self, SFTP_CMD_EVENT_STDOUT, Response_Continuous, 0);
	self.beginNotification(self, SFTP_CMD_EVENT_EOJ, Response_Continuous, 0);
	
	self.beginNotification(self, SFTP_READ_EVENT_BOJ,	Response_Continuous, 0);
	self.beginNotification(self, SFTP_READ_EVENT_STDOUT, Response_Continuous, 0);
	self.beginNotification(self, SFTP_READ_EVENT_FILESIZE, Response_Continuous, 0);
	self.beginNotification(self, SFTP_READ_EVENT_PROGRESS, Response_Continuous, 0);
	self.beginNotification(self, SFTP_READ_EVENT_WARNING, Response_Continuous, 0);
	self.beginNotification(self, SFTP_READ_EVENT_ERROR, Response_Continuous, 0);
	self.beginNotification(self, SFTP_READ_EVENT_EOJ, Response_Continuous, 0);	

	self.beginNotification(self, SFTP_WRITE_EVENT_BOJ, Response_Continuous, 0);
	self.beginNotification(self, SFTP_WRITE_EVENT_STDOUT, Response_Continuous, 0);
	self.beginNotification(self, SFTP_WRITE_EVENT_FILESIZE, Response_Continuous, 0);
	self.beginNotification(self, SFTP_WRITE_EVENT_PROGRESS, Response_Continuous, 0);	
	self.beginNotification(self, SFTP_WRITE_EVENT_WARNING, Response_Continuous, 0);
	self.beginNotification(self, SFTP_WRITE_EVENT_ERROR, Response_Continuous, 0);
	self.beginNotification(self, SFTP_WRITE_EVENT_EOJ, Response_Continuous, 0);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadSelf" id="aa459c45-80bb-47da-a343-ee7b72ff0e5a">
        <updating/>
        <source>loadSelf(	_host,
			_userId,
			_password : String;
			_port : Integer;
			_sourceDirectory,
			_sourceFile,
			_destDirectory,
			_destFile,
			_publicKey,
			_privateKey,
			_passPhrase : String;
			_timeout,
			_functionType : Integer) updating;
//
// 24 Oct 2019	jlgrs1	TFS 46087 JMT implement SFTP.
//
vars

begin
	self.host := _host;
	self.userId := _userId;
	self.password := _password;
	self.port := _port;
	self.sourceDirectory := _sourceDirectory;
	self.sourceFile := _sourceFile;
	self.destinationDirectory := _destDirectory;
	self.destFile := _destFile;
	self.publicKey := _publicKey;
