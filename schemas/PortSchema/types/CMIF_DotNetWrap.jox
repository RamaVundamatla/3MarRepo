<Class name="CMIF_DotNetWrap" id="699c733a-2aae-416b-ba97-6f8394382b4e">
    <superclass name="CMIF_Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Superclass for a .NET wrapper class.  Has methods to catch and log any .NET calling exceptions that 
may occur.

Note that in the development environment, there is a local ini file option [JMTThinClient] DotNETUsePresentation
which can be set to true to actually create the .NET component on the thin client.
</text>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allHeaderData" id="ea04c346-59d1-43e5-b437-128aed510eda">
        <memberTypeInverse/>
        <type name="CMIF_DotNetHeaderByKey"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="usePresentationClient" id="f0891fe9-9319-44b6-adee-45ffa43e028a">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addHeaderData" id="d70d6d10-f32c-4b03-83d0-152c7ed1937a">
        <updating/>
        <source>addHeaderData(_key, _value : String) updating;
/*

Purpose:			Add the passed in key and value pair to the list to be passed to the
					.NET code on the next transformMessage call

Parameters:			key and value pair

Return Value:		None

Date		Who		Reason
10 Sep 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

vars
	headerData		: CMIF_DotNetHeaderData;
	
begin
	create headerData transient;
	headerData.key := _key;
	headerData.value := _value;
	
	self.allHeaderData.add(headerData);
	
epilog

end;</source>
        <Parameter name="_key" type="String"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="clearHeaderData" id="83763971-0ba5-4702-bb12-6731d852e45d">
        <updating/>
        <source>clearHeaderData() updating;
/*

Purpose:			Clear any previously added key and value pair headers

Parameters:			None

Return Value:		None

Date		Who		Reason
10 Sep 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

vars

begin
	self.allHeaderData.purge();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="d5a42cc9-d92f-4f8e-bed4-2d822abfc7c0">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Aug 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

constants
	SectionJMT		= "JMTThinClient";
	KeyIniPresent	= "DotNETUsePresentation";
	
vars
	hadException	: Boolean;
	fileName		: String;
	iniValue		: String;
	usePresentation	: Boolean;
	
begin
	app.sendHeartbeatIfRequired();		// 1/9/17 MAP TFS5551
	
	on Exception do self.handleExceptions(exception, hadException);
	
    usePresentation := false;
    
    // Check application ini file for usePresentationClient override (development only)
    executeWhen JMTDevelopmentEnvironment;
    fileName := app.getIniFileName();
    if fileName &lt;&gt; null then 
        iniValue := app.getProfileString(fileName, SectionJMT, KeyIniPresent, "false").toLower;
        usePresentation := iniValue.Boolean;
    endif;			
    endExecuteWhen;

    app.writeLog(method.qualifiedName &amp; " usePresentationClient=" &amp; usePresentation.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
    self.usePresentationClient := usePresentation;
		
end;
</source>
    </JadeMethod>
    <JadeMethod name="delete" id="4bb1c00a-14f0-4ce9-a6ec-73b83fbd08f1">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2015	cnwgb1	Initial creation

*/

vars

begin
    self.clearHeaderData();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getHeaderString" id="fdb976bb-2da7-49a0-8cb6-bf6608441f4a">
        <source>getHeaderString() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2015	cnwgb1	Initial creation

*/

vars
	xml	: JadeXMLDocument;
	headersElement : JadeXMLElement;
	itemElement : JadeXMLElement;
    headerData : CMIF_DotNetHeaderData;
begin
	create xml transient;
	headersElement := xml.addElement("Headers");
	
	foreach headerData in self.allHeaderData do
		itemElement := headersElement.addElement("Item");
		itemElement.addElement("Key").setText(headerData.key.asXML());
		itemElement.addElement("Value").setText(headerData.value.asXML());
	endforeach;
	
	return xml.writeToString();
epilog
    delete xml;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleExceptions" id="0af0e113-1cd8-4a86-9333-a234f04db655">
        <source>handleExceptions(_exc : Exception; _excOccurred : Boolean io) : Integer protected;
/*

Purpose:			Handle any kind of exception during the loading and execution of the
					external dlls by logging and resuming

Parameters:			

Return Value:		

Date		Who		Reason
08 Aug 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

vars
	stack	: ProcessStackArray;
begin
	if app.logLevel = LogTRACE then
		create stack;
		process.currentStack(stack);
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Calling Method: " &amp; stack[5].method.qualifiedName, LogTRACE);
	endif;
	
	app.writeLog(method.qualifiedName &amp; " " &amp; _exc.class.name &amp; " Error: " &amp; _exc.errorCode.String &amp; 
			   " Text: " &amp; _exc.text() &amp;
			   " Error Item: " &amp; _exc.errorItem &amp; " Extended Text: " &amp; _exc.extendedErrorText, LogERROR);	//25 Nov 2019	NDL	TFS 47053

	_excOccurred := true;
	
	if _exc.resumable then
		app.writeLog(method.qualifiedName &amp; " returning Ex_Resume_Next", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
				   
epilog
	if stack &lt;&gt; null then
		stack.purge();
		delete stack;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_excOccurred" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
