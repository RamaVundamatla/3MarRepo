    <JadeMethod name="tblMain_cellInputReady" id="5f0a7e3e-4bf0-4697-873d-a43b3209cc1d">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_cellInputReady(table: CM_EntryTable input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 Jun 2008	cnwkpd1		PAR #17183 - Allow for Bulk Edit changes to Customs
//							Entry numbers
// ---------------------------------------------------------------------------
vars
	tmpTable	: Table;
	tmpOperator	: CM_Operator;
	tmpVoyage	: CM_Voyage;
	tmpPort		: CM_Port;
	
	assistant	: GTE_Assistant;
	tmpConsignor : CM_ConsigneeConsignor;
	tmpConsignorCode : String;
	i	: Integer;
		
begin

	assistant := self.myAssistant.GTE_Assistant;
	
	tmpTable := table;
	
	if inputControl.name = 'cmbCarrier' then
	//	if cmbCarrier.listObject &lt;&gt; null then
	//		cmbCarrier.text := assistant.displayEntryCarrier(cmbCarrier.listObject.CM_Carrier);
	//	else
	//		if table.text &lt;&gt; null then
	//			cmbCarrier.text := table.text;
	//		endif;
	//	endif;

	elseif inputControl.name = 'cmbConsignee' then
		if cmbConsignee.listObject &lt;&gt; null then
			/* WAS PAR 1318. AKB August 2001
			cmbConsignee.text := assistant.displayEntryConsignor(cmbConsignee.listObject.CM_ConsigneeConsignor);
			NOW  PAR 1318 from here*/
			// The object in the combo is now a string object that has the code then a tab then the desc. So we strip of the code aand get the consignot object
			//tmpConsignorCode := cmbConsignee.listObject.String.scanUntil(Tab, i);
			//tmpConsignor := app.myRoot.allConsigneeConsignors[tmpConsignorCode];
			tmpConsignor := cmbConsignee.listObject.CM_ConsigneeConsignor;
			cmbConsignee.text := assistant.displayEntryConsignor(tmpConsignor);
			/* PAR 1318 to here */
		else
			if table.text &lt;&gt; null then
				cmbConsignee.text := table.text;
			endif;
		endif;

	elseif inputControl.name = 'cmbOperator' then
		if cmbOperator.listObject &lt;&gt; null then
			cmbOperator.text := assistant.displayEntryOperator(cmbOperator.listObject.CM_Operator);
		else
			if table.text &lt;&gt; null then
				cmbOperator.text := table.text;
			endif;
		endif;

	elseif inputControl.name = 'cmbTiType' then
		if table.text &lt;&gt; null then
			cmbTiType.text := table.text;
		endif;
	elseif inputControl = self.tblCustEntry then
//		if not self.doingMultiEdit then			// PAR #17183
			self.setCustEntryTable(table.CM_EntryTable.getValueByName(ETRow_CustomsEntryNumber).String);
			table.accessRow(table.row).height := 120;
//		endif;
	else
		
	endif;

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
