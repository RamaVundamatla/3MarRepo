    <JadeMethod name="validateMAFIVoyage" id="3a861860-e73f-4a93-a284-26e67961e2aa">
        <source>validateMAFIVoyage(_pxyMAFI : CM_TILC );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2024	jlier1	Initial creation

*/

vars
	lc : CM_LocationsController;
	onboardTI : CM_TrackedItem;
	realTILC : CM_TILC;
begin
	if not self.isMAFI then
		return;
	endif;
	realTILC:=self.pxyGetRealObject;
	if realTILC = null then
		return;
	endif;
	
	foreach lc in realTILC.allLCs discreteLock do : outerLoop
		foreach onboardTI in lc.allTrackedItems discreteLock do
			onboardTI.validateMAFIVoyage(self);	
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_pxyMAFI" type="CM_TILC"/>
    </JadeMethod>
    <JadeMethod name="validateMasterTI" id="5b2cdd91-b728-4dcd-aed9-afb41a8c9503">
        <updating/>
        <source>validateMasterTI(_master: CM_TIMaster; _passport: CM_Passport) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2009	cnwjk3	Initial creation

*/

vars
	masterTrailer 		: CM_TIMasterTILC;
	tiTrailerDesc,
	masterTrailerDesc	: String;
begin
	if _master = null then 
		return;
	endif;
	inheritMethod(_master, _passport);
	masterTrailer:= _master.CM_TIMasterTILC;
	if self.myTILCType &lt;&gt; masterTrailer.myTILCType then
		if self.myTILCType = null then
			tiTrailerDesc :=   app.getErrorString(Null);
		else
			tiTrailerDesc := self.myTILCType.code;
		endif;
		if masterTrailer.myTILCType = null then
			masterTrailerDesc :=  app.getErrorString(Null);
		else
			masterTrailerDesc := masterTrailer.myTILCType.code;
		endif;
		app.raiseCMWarning3(WARN_FLEETFILE_DISCREP,"Trailer Type for " &amp; self.id, tiTrailerDesc, masterTrailerDesc,"",null,self);		
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_master" type="CM_TIMaster"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateMove" id="ef86cb86-5ab3-46ec-8157-0400ddf3c341">
        <source>validateMove(_control: CMIF_MoveController input);
/*

Date		Who		Reason
14 August 2013	cnwer1	Initial creation PAR

*/

vars

begin
	if _control.myToPrimaryLocation &lt;&gt; null and _control.myToPrimaryLocation.isKindOf(CM_TILCController) then
		if self.allLCs.includes(_control.myToPrimaryLocation.CM_TILCController) then
			app.raiseCMException2(ERR_ALREADY_HERE,self.id,null,null,null);
		endif;
	endif;
	
	inheritMethod(_control);

epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateReceiptRelease" id="d8b24405-90eb-4168-8e99-c4b303227347">
        <updating/>
        <source>validateReceiptRelease(pControl: CMIF_TIUpdateController; _passport: CM_Passport input) updating, protected;
/* ---------------------------------------------------------------------------
Created:     03 March 2009 by cnwrs2

Purpose:     PAR 18352
        
Change Date	Who		Reason
19/12/2014  cnwma1  PAR #35323 Error 1090 : While Trying add Trailer using voyage Cargo Form
------------------------------------------------------------------------------*/
vars

begin
	inheritMethod(pControl, _passport);

	if pControl.mode = TI_UPDMODE_RECEIPT or
	   pControl.mode = TI_UPDMODE_BOLITEM  then  //19/12/2014 cnwma1 PAR #35323
		self.validateTrailerType();
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateTILCTotWeight" id="b1aeb6e0-297d-418a-91be-4a544adf0121">
        <updating/>
        <source>validateTILCTotWeight() updating;
/*

Purpose:			This method validates the total weight of the Trailer when the trailer type allows them to overwrite it

Parameters:			

Return Value:		

Date		Who		Reason
15/10/2025	navkc1 JIRA 36057 CUX | Total Weight Specification for Trailers - DB Changes / Form /Jade

*/

vars
	myType			: CM_TILCType;
	typeMaxWeight,
	typeTareWeight : Decimal[14,4];
	
begin
	if not self.canUpdateTotalWeight() then
		return;
	endif;
	
	myType := self.myTILCType; // 17/11/2025	navkc1	MTN JIRA 36651
	
	// 17/11/2025	navkc1	MTN JIRA 36651
	if myType &lt;&gt; null then
		typeMaxWeight := myType.maxWeight;
	endif;
	
	// 17/11/2025	navkc1	MTN JIRA 36651
	if typeMaxWeight &lt;&gt; null then
		if self.totalWeight &gt; typeMaxWeight then
			app.raiseCMWarning2(TotalWeightExceedTypeMax, self.totalWeight.asStringJMT(), typeMaxWeight.asStringJMT(), CM_TILC::totalWeight.name, null, self);
		endif;
	endif;
	
	typeTareWeight := self.getTareWeight();
	
	if self.totalWeight = null then
		
		// Option to continue so it just derives the weight from on board cargo
		app.raiseCMWarning1(TrailerTotalWeightZero, self.id, CM_TILC::totalWeight.name, null, self) ;
		
		// We are updating, good to just retrieve the on board cargo here
		// When creating, we might not have created the cargo on board yet, so accumulate the total weight at where it's creating it.
		if self.pxyGetRealObject() &lt;&gt; null then
			self.totalWeight += self.weightCargo + typeTareWeight;
		endif;
		
	elseif self.totalWeight &lt; typeTareWeight then
		// Hard stop as the total weight is entered and is less than the tareweight
		app.raiseCMException3(TrailerTotalWgtLessTypeTareWgt, self.id, self.totalWeight.asStringJMT(), typeTareWeight.asStringJMT(), CM_TILC::totalWeight.name, null) ;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateTrackedItem" id="76c59064-f61c-4fcf-858c-ec21c8049725">
        <updating/>
        <source>validateTrackedItem(pController: CMIF_TIUpdateController input; _passport: CM_Passport input) updating;
/*
Purpose:			

Date		Who		Reason
// ### TFS BUG 57408 14APR2023 NAVAB1
04/03/2024	jlizm1	TFS 62736 CUX - Gets lashing error when updating unrelated details
*/

vars
	currentContentStatus : Integer;
	
begin
	inheritMethod(pController, _passport);
	
	self.validateTILCTotWeight(); //15/10/2025	navkc1 JIRA 36057
	
	if pController.myRealTrackedItem &lt;&gt; null then
		// Changing to FULLY LASHED
		if self.contentsStatus = TI_CONTENTS_STATUS_FULLLASHED then
			currentContentStatus := pController.myRealTrackedItem.getContentsStatus();
			
			// but only if currently FULL or PART LOADED
			if not (   currentContentStatus = TI_CONTENTS_STATUS_FULLLASHED // not changed
					or currentContentStatus = TI_CONTENTS_STATUS_FCL
					or currentContentStatus = TI_CONTENTS_STATUS_PRTLOAD) then
				app.raiseCMException(Conte_statu_canno_fully_lashe_, null, null); 
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="pController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateTrailerType" id="8ac3a75d-89bf-48bf-b358-28e660c02328">
        <source>validateTrailerType() protected;
/* ---------------------------------------------------------------------------
Created:     03 March 2009 by cnwrs2

Purpose:     PAR 18352
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.myTILCType = null then 
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Trailer_Type), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Trailer_Type), null, null); // cnwdb2	PAR 35364
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="wasContainerReceived" id="c2e7cbe8-e003-45fd-83fa-d866643733c0">
        <source>wasContainerReceived(_camsDateTime : TimeStamp) : Boolean;
//
// 03 Jun 2014	cnwrs1	Par 34274 excluded Chassis Codeco if Container is attached
// 29 Jun 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
// 22 Apr 2024	jlirs1	TFS 63766 Cams issues with Jade deferred update
vars
	vvr : CM_VehicleVisitRecord;
	ti : CM_TrackedItem;
	tr : CM_TITransaction;
	result : Boolean;
	earliestTime : TimeStamp;
	latestTime : TimeStamp;
begin
	earliestTime := _camsDateTime.addHours(-1);
	latestTime := _camsDateTime.addMinutes(10);
	foreach vvr in self.allVisitRecords reversed do
		if vvr.allReceivedTrackedItems.includes(self) then
			foreach ti in vvr.allReceivedTrackedItems do
				if ti.cargoType = TI_CargoType_Container then
					foreach tr in ti.allTransactions do
						if tr.isCamsRoadReceiveType then
							if tr.camsTimeStamp &gt; earliestTime and		// 22 Apr 2024	jlirs1	TFS 63766 Cams issues with Jade deferred update
							   tr.camsTimeStamp &lt; latestTime then
								result := true;
								break;
							endif;
						endif;
					endforeach;
				endif;
			endforeach;
		endif;
	endforeach;
	return result;
end;</source>
        <Parameter name="_camsDateTime" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="wasContainerReleased" id="2830ede0-6cb2-4051-869f-0e17d31a2937">
        <source>wasContainerReleased(_camsDateTime : TimeStamp) : Boolean;
//
// 03 Jun 2014	cnwrs1	Par 34274 excluded Chassis Codeco if Container is attached
// 29 Jun 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
// 22 Apr 2024	jlirs1	TFS 63766 Cams issues with Jade deferred update
vars
	vvr : CM_VehicleVisitRecord;
	ti : CM_TrackedItem;
	tr : CM_TITransaction;
	result : Boolean;
	earliestTime : TimeStamp;
	latestTime : TimeStamp;
begin
	earliestTime := _camsDateTime.addHours(-1);
	latestTime := _camsDateTime.addMinutes(10);
	foreach vvr in self.allVisitRecords reversed do
		if vvr.allReleasedTrackedItems.includes(self) then
			foreach ti in vvr.allReleasedTrackedItems do
				if ti.cargoType = TI_CargoType_Container then
					foreach tr in ti.allTransactions do
						if tr.isCamsRoadReleaseType then
							if tr.camsTimeStamp &gt; earliestTime and		// 22 Apr 2024	jlirs1	TFS 63766 Cams issues with Jade deferred update
							   tr.camsTimeStamp &lt; latestTime then
								result := true;
								break;
							endif;
						endif;
					endforeach;
				endif;
			endforeach;
		endif;
	endforeach;
	return result;
end;
</source>
        <Parameter name="_camsDateTime" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="weightCargo" id="09d1fc1b-67c9-4177-9f00-7cd5b0931571">
        <methodInvocation>mapping</methodInvocation>
        <source>weightCargo(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2014	cnwndl1	Initial creation	Par 33561

*/

vars

	total : Decimal [12,4];
	onboardTIs : CM_TISet;
	ti : CM_TrackedItem;
	realTI : CM_TILC;
begin

	if not set then
	
		create onboardTIs transient;
		//jlier1 TFS 54703 28/9/22 - when ever you edit a trailer would get a total weight should not be zero error
		if self.pxyIsProxy then
			realTI:=self.pxyGetRealObject;
		else
			realTI:=self;
		endif;
		
		realTI.getAllOnboardTIs(onboardTIs);
		
		foreach ti in onboardTIs discreteLock do
			total := total + ti.totalWeight;
		endforeach;
		
		foreach ti in self.allChildren discreteLock do   // 36297
			total := total + ti.totalWeight;
		endforeach;

		_value := total;
	
	endif;

epilog

	delete onboardTIs;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="weightTare" id="6925d2d5-71a0-40ac-bcbc-da5b4610f432">
        <methodInvocation>mapping</methodInvocation>
        <source>weightTare(set : Boolean; _value : Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2014	cnwndl1	Initial creation Par 33561

*/

vars

begin

	if not set then
		if _value = 0 then
			_value := self.getTareWeight;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
