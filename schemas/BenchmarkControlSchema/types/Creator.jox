    <JadeMethod name="setInfo_tui" id="c5912a58-0d14-4bcf-8d79-5100344e1b14">
        <updating/>
        <source>setInfo_tui() updating;

vars
	i,j,mult,extra:Integer;
begin
	copies:=1;
	mult:=5;  // multiplied up to 5 times - normal setting for normal 420 user run
	//mult:=3;  // use this for 280 users
	//mult:=2;  // use this for 210 users
	extra:=mult+2;  // extra multiplier for unlimited profiles
	port:=myBmkControl.bmkBasePort.Integer+(appSequenceId mod 20);  // distribute amongst appServers
	
	i:=i+1;      			 	if i &gt; appSequenceId then profile:='BGPControl'; return; endif;  // max 1
	i:=i+2*mult;			if i &gt; appSequenceId then profile:='Idstr'; return; endif;			// max 10, nominal 10
	i:=i+2*mult;			if i &gt; appSequenceId then profile:='Ipobi'; return; endif;			// max 10, nominal 10
	i:=i+2*mult;			if i &gt; appSequenceId then profile:='Brprc'; return; endif;			// max 10, nominal 10
	i:=i+1*mult;			if i &gt; appSequenceId then profile:='Itror'; return; endif;			// max 5, nominal 5
	i:=i+1*mult;			if i &gt; appSequenceId then profile:='Pstat'; return; endif;			// max 5, nominal 5
	i:=i+6*extra;			if i &gt; appSequenceId then profile:='Ipbri'; return; endif;			// no limit
	i:=i+2*mult;			if i &gt; appSequenceId then profile:='Tranf'; return; endif;			// max 10
	i:=i+2*mult;			if i &gt; appSequenceId then profile:='Adjst'; return; endif;			// max 10
	i:=i+1*mult;			if i &gt; appSequenceId then profile:='Brcvd'; return; endif;			// no limit (but duplication after 10)
	i:=i+(1*mult).min(3);if i &gt; appSequenceId then profile:='Cstfx'; return; endif;			// max 3
	i:=i+1*mult;			if i &gt; appSequenceId then profile:='Iprod'; return; endif;			// duplication after 5
	i:=i+8*extra;			if i &gt; appSequenceId then profile:='Istsl'; return; endif;			// no limit (but gui heavy?)
	i:=i+16*extra;			if i &gt; appSequenceId then profile:='Itran'; return; endif;			// no limit
	i:=i+2*mult;			if i &gt; appSequenceId then profile:='Pord'; return; endif;			// max 10
	i:=i+3*extra;			if i &gt; appSequenceId then profile:='Prodm'; return; endif;		// no limit (but gui heavy?)
	i:=i+3*mult;			if i &gt; appSequenceId then profile:='Venrf'; return; endif;			// max 50
	i:=i+10*mult;			if i &gt; appSequenceId then profile:='Rford'; return; endif;			// max 50, nominal 50
	i:=i+5;					if i &gt; appSequenceId then profile:='Ordqt'; return; endif;			// max 5, nominal 5
	i:=i+2*mult;			if i &gt; appSequenceId then profile:='Order'; return; endif;			// max 10
	i:=i+(1*mult).min(3);if i &gt; appSequenceId then profile:='ReceiptsAdmin'; return; endif;	// max 3
	i:=i+(2*mult).min(7);if i &gt; appSequenceId then profile:='ReceiptsRfgun'; return; endif;	// max 7
	i:=i+6*extra;			if i &gt; appSequenceId then profile:='Ipbri'; return; endif;			// duplicated here to take up any slack // no limit
	
	//port:=port+(appSequenceId div 1);  // users per appServer
	//profType:=(appSequenceId div 5);
	/*profType:=(appSequenceId mod 20);
	
	if      appSequenceId = 0 then profile:='BGPControl';
	elseif profType = 1 then profile:='Ipbri';
	elseif profType = 2 then profile:='Adjst';
	elseif profType = 4 then profile:='Itran';
	elseif profType = 6 then profile:='Prodm';
	elseif profType = 8 then profile:='Pord';
	elseif profType = 10 then profile:='Venrf';
	elseif profType = 12 then profile:='Iprod';
	elseif profType = 14 then profile:='Tranf';
	elseif profType = 16 then profile:='Brcvd';
	elseif profType = 18 then if appSequenceId div 20 &lt; 6 then profile:='Cstfx'; else profile:='Itran'; endif;
	else                            profile:='Istsl';
	endif;/**/
	//profile:='Order';  // override profile

/* original code, saved off 20100127
	copies:=1;
	//port:=myBmkControl.bmkBasePort.Integer ;//+ appSequenceId mod 10;

	//port:=myBmkControl.bmkBasePort.Integer;
	port := '51570'.Integer;
	//profType:=(appSequenceId div 5)+0;

	profType:=(appSequenceId mod 19);
	//profType:=(9);

//	profType:=9;
//	port:=port+(appSequenceId div 4);  // users per appServer
//	if computerName &lt;&gt; 'cnwchcs136' then port:=port+1; endif;
//	port:=port+(appSequenceId div 1);  // users per appServer

	
	if     profType = 0 then profile:='Ipbri';
	elseif profType = 1 then profile:='Adjst';
	elseif profType = 2 then profile:='Itran';
	elseif profType = 3 then profile:='Prodm';
	elseif profType = 4 then profile:='Pord';
	elseif profType = 5 then profile:='Venrf';
	elseif profType = 6 then profile:='Iprod';
	elseif profType = 7 then profile:='Tranf';
	elseif profType = 8 and computerName &lt;&gt; "cnwchcs122" then profile:='Brcvd';
	elseif profType = 8 and computerName = "cnwchcs122" then profile:='Itran';
	elseif profType = 9 and computerName &lt;&gt; "cnwchcs122" and computerName &lt;&gt; "cnwchcs131" then profile:='Cstfx';
	elseif profType = 9 and computerName = "cnwchcs122" then profile:='Itran';
	elseif profType &gt;= 10 and profType &lt;= 19 then profile:='Istsl';
	//elseif profType &gt;= 20 then profile:='Reports';
	endif;/**/
	//profile:='Receipt';  // override profile
//epilog
//	delete profiles;
end;</source>
    </JadeMethod>
    <JadeMethod name="setSession" id="d20d7427-29d2-4c22-9a1e-66d2c8903e35">
        <updating/>
        <source>setSession(_session:Integer) updating;

begin
	session:=_session;
	if session &lt;&gt; 0 then
		myBmkControl:=global.allBmkControls[session];
	endif;
end;</source>
        <Parameter name="_session" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setup" id="602a48a5-aa81-4dd2-98dc-7c5f4f2efc46">
        <updating/>
        <source>setup() updating;

begin
	beginNotification(global, Bmk_Init, Response_Continuous,0);
	beginNotification(global, Bmk_Check_Thinbin, Response_Continuous,0);
	beginNotification(global, Bmk_Start_Spawner, Response_Continuous,0);
	beginNotification(global, Bmk_Start_App, Response_Continuous,0);
	beginNotification(global, Bmk_Stop_Creator, Response_Continuous,0);
	if app.name = "CreatorCreator" then
		beginNotification(global, Bmk0_Start_Creators, Response_Continuous,0);
		beginNotification(global, Bmk0_Show_Jade_Version, Response_Continuous,0);
		beginNotification(global, Bmk0_Fix_Environment_ID, Response_Continuous,0);
		beginNotification(global, Bmk0_Start_Rap, Response_Continuous,0);
		beginNotification(global, Bmk0_Start_Background_Monitor, Response_Continuous,0);
		beginNotification(global, Bmk0_Start_SingleUserAppServer, Response_Continuous,0);
		beginNotification(global, Bmk0_Start_SingleUser, Response_Continuous,0);
		beginNotification(global, Bmk0_Start_SingleUserJdbUtil, Response_Continuous,0);
		beginNotification(global, Bmk0_Start_PerfMonLog, Response_Continuous,0);
		beginNotification(global, Bmk0_Stop_PerfMonLog, Response_Continuous,0);
		beginNotification(global, Bmk0_Save_Log_Files, Response_Continuous,0);
		beginNotification(global, Bmk0_Stop_RapHost_CreatorCreator, Response_Continuous,0);
	endif;
	beginNotification(global, Bmk0_Sync_Thinbin, Response_Continuous,0);
	beginNotification(global, Bmk0_Stop_All_Mine, Response_Continuous,0);
	beginNotification(global, Bmk0_Stop_My_Children, Response_Continuous,0);
	beginNotification(global, Bmk_Start_Fat_Client, Response_Continuous,0);
	beginNotification(global, Any_System_Event, Response_Continuous,0);
	beginTransaction;
	process.userInfo := computerName.toLower;
	commitTransaction;
	setAutoDownLoad(app.getIniFileName);
end;</source>
    </JadeMethod>
    <JadeMethod name="showJadeVersion" id="de64bb73-a722-4a10-b115-fc44874979e5">
        <updating/>
        <source>showJadeVersion(sess:Integer) updating;

vars
	path,cmd,result:String;
	i,j,retCode:Integer;
	aa:Analysis;
begin
	myBmkControl:=global.allBmkControls[sess];
	if myBmkControl.rapHost = computerName and myBmkControl.owner = userCode then
		path:=myBmkControl.binFolder;
		cmd:=path&amp;'\jverinfo.exe';
		retCode:=node.createExternalProcess(path,cmd,null,null,true,true,j);
		result:=cmd&amp;" retCode="&amp;retCode.String&amp;" "&amp;process.userCode&amp;"@"&amp;process.userInfo;
		app.logMessage(result);
		global.causeEvent(Bmk_Result, true, result);
		
		create aa;
		aa.versionInfoRead(path&amp;'\');
	endif;
epilog
	delete aa;
end;</source>
        <Parameter name="sess" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startApp" id="fae66420-e7bd-48e5-8fe0-a31ab87e9e42">
        <updating/>
        <source>startApp() updating;

vars
	s,t,path,cmd,result,prod,tappserver:String;
	i,j,copy,profType,retCode,delay,driverWidth,driverHeight,autoPingInterval,queues,sstCopyInterval,appSeq:Integer;
	totalUsers,usersPerAppServer,numSearchVehicleWithAttr:Integer;
	tps:Real;
begin
	//tps:=6;  // achieves 6 tps or so (with autostart of mainform) with 1600 sst users and no contention
	//tps:=2.78;  // 1000 users
	//tps:=0.278;  // 100 users
	//sstCopyInterval:=(40000/tps).Integer;
	
	copies:=1;
	schemaName:=myBmkControl.schemaName;
	appName:=myBmkControl.appName;
	setAppSequenceId(process);
	setInfo;
	if copies &lt; 1 then
		return;
	endif;
	autoPingInterval:=10;

	path:='c:\thinbin\'&amp;myBmkControl.envid;

	if appName[1:7] = "Creator" then
		
		// delay between CreatorCreators when starting Creators
		// big delay may be required to control Creator appSequenceId's across multiple client machines
		
		prod:=global.allBmkControls[targetSession].product;
		if     prod = "JCC"			then process.sleep((appSequenceId mod 16)*10000);
		//elseif prod = "CMIS3"		then process.sleep((appSequenceId mod 12)*30000);
		//elseif prod = "CMIS3"		then process.sleep((appSequenceId mod 16)*1000);
		elseif prod = "CMIS3"		then process.sleep((appSequenceId mod 50)*10000);  // start all creators for one session before starting the next
		elseif prod = "CMIS4"		then process.sleep((appSequenceId mod 50)*1000);
		elseif prod[1:4] = "CMIS"	then process.sleep((appSequenceId mod 4)*30000);
		//elseif prod = "Jasper"		then process.sleep((appSequenceId mod 8)*10000);
		elseif prod = "Jasper"		then process.sleep((appSequenceId mod 8)*1000);
		elseif prod = "mtl"			then process.sleep((appSequenceId mod 12)*12000);
		elseif prod = "tpca"		then process.sleep((appSequenceId mod 100)*5000);
		//elseif prod = "tui"			then process.sleep((appSequenceId mod 10)*54000);
		//elseif prod = "tui"			then process.sleep((appSequenceId mod 10)*8000);
		elseif prod = "sms"			then process.sleep((appSequenceId mod 10)*24000);
		else							 process.sleep((appSequenceId mod 16)*1000);
		endif;
		
	else  
		// delay between Creators when starting driver apps
		// to control driver app appSequenceId's when copies = 1
		// may need big number for multiple copies
		
		prod:=global.allBmkControls[session].product;
//		app.logMessage(method.qualifiedName&amp;" calculating sleep time");
		if     prod = "JCC" 		then process.sleep((appSequenceId mod 16)*3000);
		//elseif prod = "CMIS3"	 	then process.sleep((appSequenceId mod 256)*3000);
		elseif prod = "CMIS3"	 	then process.sleep((appSequenceId mod 1000)*100);
		elseif prod = "CMIS4"	 	then process.sleep((appSequenceId mod 50)*5000);
		//elseif prod = "CMIS3"	 	then process.sleep((appSequenceId mod 1000)*1000);
		elseif prod[1:4] = "CMIS" 	then process.sleep((appSequenceId mod 60)*3000);
//		elseif prod = "skidemo" 	then process.sleep((appSequenceId mod 60)*(copies+1)*1000);
		elseif prod[1:2] = "sk" or prod[1:2] = "sl" 	then process.sleep((appSequenceId mod 60)*1000);
		elseif prod = "JadeStar" 	then process.sleep((appSequenceId mod 20)*3000);
		elseif prod = "Jasper" 		then process.sleep((appSequenceId mod 20)*3000);
		elseif prod = "mtl" 		then process.sleep((appSequenceId mod 100)*1000);
		elseif prod = "tpca" 		then process.sleep((appSequenceId mod 100)*100);
		elseif prod = "tui" 		then process.sleep((appSequenceId mod 100)*100);
		//elseif prod = "StartStopTest"  and global.allBmkControls[session].owner = "cnwjhp1"		then process.sleep((appSequenceId mod 100)*(sstCopyInterval div 40));
		else							 process.sleep((appSequenceId mod 100)*1000);
		endif;
	endif;
	
	driverWidth:=290;
	driverHeight:=196;
	foreach copy in 1 to copies do
		if session &lt;&gt; 0 and (global.allBmkControls[session].product = "CMIS4") then
			autoPingInterval:=100;
			if profile &lt;&gt; 'LightUser' then  // heavy users, one per appserver
				startApp_cmis4(copy, port, profile);
				// equal distribution, used for most runs up to 20110509
				/*totalUsers:=50;  // important to set this correctly
				numSearchVehicleWithAttr:=0;  // set to 0 if not using the new soft attributes profile
			
				appSeq:=appSequenceId * copies + copy - 1;
				port:=myBmkControl.bmkBasePort.Integer;
				usersPerAppServer:=totalUsers div myBmkControl.appServers;
				if totalUsers mod myBmkControl.appServers &lt;&gt; 0 then
					usersPerAppServer:=usersPerAppServer+1;
				endif;
				port:=port+(appSeq div usersPerAppServer);
				//port:=port+(appSeq mod myBmkControl.appServers);  //  spread evenly over appservers
				profType:=(appSeq mod 8);
				if      profType = 0 then profile:='AddCN';
				elseif profType = 1 then profile:='AddCompoundImageToCN';
				elseif profType = 2 then profile:='AddPersonToCN';
				elseif profType = 3 then profile:='SearchVehicle';         //port:=myBmkControl.bmkBasePort.Integer+4;
				elseif profType = 4 then profile:='AddSearchWarrant';
				elseif profType = 5 then profile:='AddVehicleToCN';
				elseif profType = 6 then profile:='SearchCN';
				elseif profType = 7 then profile:='multiSearchesAndAddToCN';
				endif;
				profile:='multiSearchesAndAddToCN';
				if appSeq &lt; numSearchVehicleWithAttr then profile:='searchVehicleWithAttr'; endif;/**/
			endif;
		endif;

		if session &lt;&gt; 0 and (global.allBmkControls[session].product[1:2] = "sk" or global.allBmkControls[session].product[1:2] = "sl") then
			profile:="All5";
/*			profType:=((copy-1) mod 5);  // use this to check user sequencing within appservers for repeatability
			if     profType = 0 then profile:='ADM22';
			elseif profType = 1 then profile:='CUS03';
			elseif profType = 2 then profile:='CUS04';
			elseif profType = 3 then profile:='INV53';
			elseif profType = 4 then profile:='MOR05';
			endif; /* */
		endif;

		if prod = 'mumbai' or prod = 'muu' then
			s:=host;
/*			if appName[1:7] &lt;&gt; "Creator" then
				if     computerName = 'cnwchcs131' then s := 'cnwchcs128';
				elseif computerName = 'cnwchcs128' then s := 'cnwchcs131';
				elseif computerName = 'cnwchcs131' then s := 'cnwchcs134';
				elseif computerName = 'cnwchcs134' then s := 'cnwchcs136';
				elseif computerName = 'cnwchcs136' then s := 'cnwchcs131';
				endif;
			endif; /**/
/*			if myBmkControl.owner[1:6] = 'cnwjbl'  then
				queues:=4;
			else
				queues:=24;
			endif;/**/
			queues:=4;
			cmd:=path&amp;'\jade.exe'
					&amp;' schema='&amp;schemaName
					&amp;' app='&amp;appName
//					&amp;' appserver='&amp;host
					&amp;' appserver='&amp;s
					&amp;' appserverport='&amp;port.String
					&amp;' endJade '
					&amp;(appSequenceId mod queues).String;
//					&amp;((copy - 1) mod 4).String;
					
/*		elseif prod = 'tui' and appName[1:7] &lt;&gt; "Creator"then //Temp cludge for TWL testing
			cmd:=path&amp;'\jade.exe'
					&amp;' schema='&amp;schemaName
					&amp;' app='&amp;appName
					&amp;' appserver=192.168.206.'&amp;(15+(appSequenceId mod 20)).String
					&amp;' appserverport='&amp;port.String
					&amp;' endJade '
					&amp;' '&amp;((appSequenceId mod 3)*196).String&amp;';'&amp;(((appSequenceId mod 9) div 3)*290).String&amp;';196;290;0;10;'&amp;profile&amp;';true;0;0;'; /**/
					
		else
			cmd:=path&amp;'\jade.exe'
					&amp;' schema='&amp;schemaName
					&amp;' app='&amp;appName
					&amp;' appserver='&amp;host
					&amp;' appserverport='&amp;port.String
					&amp;' endJade'
					//&amp;' '&amp;((appSequenceId mod 3)*driverHeight).String&amp;';'&amp;(((appSequenceId mod 9) div 3)*driverWidth).String&amp;';'&amp;driverHeight.String&amp;';'&amp;driverWidth.String&amp;';0;10;'&amp;profile&amp;';true;0;0;';
					&amp;' '&amp;((appSequenceId mod 3)*driverHeight).String&amp;';'&amp;(((appSequenceId mod 9) div 3)*driverWidth).String&amp;';'&amp;driverHeight.String&amp;';'&amp;driverWidth.String&amp;';0;'&amp;autoPingInterval.String&amp;';'&amp;profile&amp;';true;0;0;';
		endif;
		retCode:=node.createExternalProcess(null,cmd,null,null,true,false,j);
		result:=cmd&amp;" retCode="&amp;retCode.String&amp;" "&amp;process.userCode&amp;"@"&amp;process.userInfo;
		app.logMessage(result);
		global.causeEvent(Bmk_Result, true, result);
		if retCode &lt;&gt; 0 then
			result:="retCode="&amp;retCode.String&amp;" "&amp;process.userCode&amp;"@"&amp;process.userInfo;
			app.logMessage(result);
			global.causeEvent(Bmk_Result, true, result);
		endif;

		// delay between driver app copies in a Creator
		// ignore if copies = 1
		if copies &gt; 1 then
			if prod = "tpca" or prod = "mumbai" or prod = "muu" then
				process.sleep(100);
			elseif prod = "CMIS4" then
				process.sleep(200);
			elseif appName[1:7] = "Creator" then  // starting a Creatornn
				if     prod = "tui" then			process.sleep(100);
				//elseif prod = "CMIS3" then		process.sleep(1000);
				elseif prod = "CMIS3" then		process.sleep(100);
				elseif prod = "mtl" then			process.sleep(1000);
				elseif prod[1:2] = "sk" or prod[1:2] = "sl" then	process.sleep(1000);
				elseif prod = "StartStopTest" and process.getUserCode = "cnwjhp1" then	process.sleep(0);
				else									process.sleep(2000);
				endif;
			elseif session &lt;&gt; 0 and (global.allBmkControls[session].product[1:2] = "sk" or global.allBmkControls[session].product[1:2] = "sl") then
				process.sleep(1000);  // this is driver start stagger, not app start stagger
			elseif session &lt;&gt; 0 and global.allBmkControls[session].product = "tui" then
				process.sleep(1000);  // this is driver start stagger, not app start stagger
			/*elseif session &lt;&gt; 0 and global.allBmkControls[session].product = "StartStopTest" and global.allBmkControls[session].owner = "cnwjhp1" then
				process.sleep(sstCopyInterval);/**/
			else
				process.sleep(10000);
			endif;
		endif;
	endforeach;
	if appName[1:7] = "Creator" then
		global.causeEvent(Bmk0_Start_Creators*-1, true, session);
	else
		global.causeEvent(Bmk_Start_App*-1, true, session);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="startApp_cmis4" id="3eaabdce-aac8-4ddc-8beb-edec19fa43f9">
        <updating/>
        <source>startApp_cmis4(copy:Integer; port:Integer output; profile:String output) updating;

begin
	if      copy &lt;= 5 then profile:='SearchVehicle';
	elseif copy &lt;= 7 then profile:='SearchCN';
	elseif copy = 8   then profile:='AddSearchWarrant';
	endif;
	if      computerName='cnwchcs86' then
		port:=51700 + copy - 1;
		if copy = 9 then profile:='AddSearchWarrant'; endif;
	elseif computerName='cnwchcs120' then
		port:=51710 + copy - 1;
		if copy = 9 then profile:='multiSearchesAndAddToCN'; endif;
	elseif computerName='cnwchcs157' then
		port:=51720 + copy - 1;
		if copy = 9 then profile:='AddSearchWarrant'; endif;
	elseif computerName='cnwchcs300' then
		port:=51730 + copy - 1;
		if copy = 9 then profile:='AddCompoundImageToCN'; endif;
	elseif computerName='cnwchcs301' then
		port:=51740 + copy - 1;
		if copy = 9 then profile:='AddSearchWarrant'; endif;
	endif;/**/
	/* normal configuration
	if      computerName='cnwchcs86' then
		port:=51700 + copy - 1;
		if copy = 9 then profile:='AddSearchWarrant'; endif;
	elseif computerName='cnwchcs120' then
		port:=51710 + copy - 1;
		if copy = 9 then profile:='multiSearchesAndAddToCN'; endif;
	elseif computerName='cnwchcs157' then
		port:=51720 + copy - 1;
		if copy = 9 then profile:='AddSearchWarrant'; endif;
	elseif computerName='cnwchcs300' then
		port:=51730 + copy - 1;
		if copy = 9 then profile:='AddCompoundImageToCN'; endif;
	elseif computerName='cnwchcs301' then
		port:=51740 + copy - 1;
		if copy = 9 then profile:='AddSearchWarrant'; endif;
	endif;/**/
end;
</source>
        <Parameter name="copy" type="Integer"/>
        <Parameter name="port" type="Integer" usage="output"/>
        <Parameter name="profile" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="startBackgroundMonitor" id="8ed1e5ea-672d-4bd5-8472-20b31cfb70c8">
        <updating/>
        <source>startBackgroundMonitor(sess:Integer) updating;

vars
	path,cmd,result,prod,schemaname,appname:String;
	i,j,retCode:Integer;
begin
	setAppSequenceId(process);
	myBmkControl:=global.allBmkControls[sess];
	schemaname:='JadeMonitorSchema';
	appname:='JadeMonitorBackground';
	if myBmkControl.rapHost = computerName and myBmkControl.owner = userCode then
		path:=myBmkControl.binFolder;
		cmd:=path&amp;'\jade.exe'
				&amp;' path='&amp;myBmkControl.systemFolder
				&amp;' ini='&amp;myBmkControl.iniFileName
				&amp;' schema='&amp;schemaname&amp;' app='&amp;appname&amp;' server=multiuser'
				&amp;' endJade '
				&amp;(appSequenceId mod 4).String;
		retCode:=node.createExternalProcess(null,cmd,null,null,true,false,j);
		result:=cmd&amp;CrLf&amp;"retCode="&amp;retCode.String&amp;" "&amp;process.userCode&amp;"@"&amp;process.userInfo;
		app.logMessage(result);
		global.causeEvent(Bmk_Result, true, result);
	endif;
end;</source>
        <Parameter name="sess" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startCreators" id="ec58036f-cc43-4588-9e02-ed1ea528fa50">
        <updating/>
        <source>startCreators(sess:Integer) updating;

begin
	create myBmkControl transient;
	myBmkControl.setParams(app.getEnvid, app.computerNameAppServer.toLower, null, null, null, currentSchema.name, sess.asCreatorName
			,null, null, null, null, null, null);
	targetSession:=sess;
	startApp;
epilog
	delete myBmkControl;
end;</source>
        <Parameter name="sess" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="startFatClient" id="1d1e89f0-cdaf-4211-8020-9e735520f4b1">
        <updating/>
        <source>startFatClient(sess:Integer) updating;

vars
	path,cmd,result,prod,schemaname,appname:String;
	i,j,retCode:Integer;
begin
	setAppSequenceId(process);
	prod:=global.allBmkControls[sess].product;
//	if     prod = "tpca" then schemaname:='TPC_A';			appname:='TPC_App';		process.sleep((appSequenceId mod 100)*1000);
//	if     prod = "tpca" then schemaname:='TradeEmSchema';	appname:='Feeder';		process.sleep((appSequenceId mod 100)*1000);
	if     prod = "tpca" then schemaname:='TradeEmSchema';	appname:='Concentrator';process.sleep((appSequenceId mod 100)*1000);
	elseif prod = "tpca" then schemaname:='TradeEmSchema';	appname:='BrokerOrderEntryConc';	process.sleep((appSequenceId mod 100)*1000);
	elseif prod = "RecReplay" then schemaname:='RecReplayTestSchema';	appname:='RecReplayTestApp';	process.sleep((appSequenceId mod 100)*1000);
	else					  schemaname:='JadeSchema';		appname:='Jade';		process.sleep((appSequenceId mod 20)*1000);
	endif;
	if myBmkControl.rapHost = computerName and myBmkControl.owner = userCode then
		path:=myBmkControl.binFolder;
		cmd:=path&amp;'\jade.exe'
				&amp;' path='&amp;myBmkControl.systemFolder
				&amp;' ini='&amp;myBmkControl.iniFileName
				&amp;' schema='&amp;schemaname&amp;' app='&amp;appname&amp;' server=multiuser'
				&amp;' endJade '
				&amp;(appSequenceId mod 4).String;
		retCode:=node.createExternalProcess(null,cmd,null,null,true,false,j);
		result:=cmd&amp;CrLf&amp;"retCode="&amp;retCode.String&amp;" "&amp;process.userCode&amp;"@"&amp;process.userInfo;
		app.logMessage(result);
		global.causeEvent(Bmk_Result, true, result);
	endif;
end;</source>
        <Parameter name="sess" type="Integer"/>
    </JadeMethod>
