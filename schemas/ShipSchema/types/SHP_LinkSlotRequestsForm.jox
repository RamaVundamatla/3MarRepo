    <JadeMethod name="setCollection141" id="db0df091-af98-46b1-84ab-3fd40c1bfc95">
        <updating/>
        <source>setCollection141(_theLeftRequests: CM_RequestArray io) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 
// ---------------------------------------------------------------------------

vars
	aLeftRequest, aRightRequest : CM_Request;
	theRightRequests: CM_RequestArray;
	theLeftRequests: CM_RequestArray;
begin
	create theRightRequests transient;
	self.linkMode := self.Mode_141;
	
	create theLeftRequests transient;					// 11/07/2013 cnwmh5 #30938
	_theLeftRequests.copy(theLeftRequests);
	
	foreach aLeftRequest in theLeftRequests do
		aRightRequest := aLeftRequest.getDLRSOBRequestLink();
		if aRightRequest &lt;&gt; null then
			theRightRequests.add(aRightRequest);
		else												// 11/07/2013 cnwmh5 #31938
			_theLeftRequests.remove(aLeftRequest);
		endif;
	endforeach;
	
	// this will not happen, we check earlier that the left hand lot and all linked
	if _theLeftRequests.size &lt;&gt; theRightRequests.size then
		app.msgBox("Your selected requests are not all  linked, try again", "Request Link Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	else
		self.magRequests.setItemsOnLeftSide(_theLeftRequests, true);
		self.magRequests.setItemsOnRightSide(theRightRequests, true);
	endif;
	
	return true;
epilog
	delete theRightRequests;
	delete theLeftRequests;
end;</source>
        <Parameter name="_theLeftRequests" type="CM_RequestArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCollectionRORO141" id="b941b00e-f6f4-4968-a920-3141296e1106">
        <updating/>
        <source>setCollectionRORO141(_theLeftRequests: CM_RequestArray io) : Boolean updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/


vars
	aLeftRequest, aRightRequest : CM_Request;
	theRightRequests: CM_RequestArray;
	theLeftRequests: CM_RequestArray;
begin
	create theRightRequests transient;
	self.linkMode := self.Mode_141;
	
	create theLeftRequests transient;							// 11/07/2013 cnwmh5 #30938
	_theLeftRequests.copy(theLeftRequests);
	
	foreach aLeftRequest in theLeftRequests do
		aRightRequest := aLeftRequest.getDLRSOBRequestLink();
		if aRightRequest &lt;&gt; null then
			theRightRequests.add(aRightRequest);
		else													// 11/07/2013 cnwmh5 #31938
			_theLeftRequests.remove(aLeftRequest);
		endif;
	endforeach;
	
	// this will not happen, we check earlier that the left hand lot and all linked
	if _theLeftRequests.size &lt;&gt; theRightRequests.size then
		app.msgBox("Your selected requests are not all  linked, try again", "Request Link Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	else
		self.magRequests.setItemsOnLeftSide(_theLeftRequests, true);
		self.magRequests.setItemsOnRightSide(theRightRequests, true);
	endif;
	
	return true;
epilog
	delete theRightRequests;
	delete theLeftRequests;
end;</source>
        <Parameter name="_theLeftRequests" type="CM_RequestArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCollections" id="4ce31d19-ff09-4b27-9535-ebde65427273">
        <updating/>
        <source>setCollections(_theLeftRequests: CM_RequestArray io; _linkMode : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aLeftRequest, aRightRequest : CM_Request;
	theRightRequests: CM_RequestArray;
	theLeftRequests: CM_RequestArray;
	sobTotal,dlrTotal,grandTotal : Integer;
	doInclude : Boolean;
	theReq : CM_Request;
begin
	create theRightRequests transient;
	if _theLeftRequests.isEmpty then
		app.msgBox("Please select some slots, try again", "Request Link Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

//	self.allSlotControllers.clear;
	create theLeftRequests transient;								// 15/07/2013 cnwmh5 #31938
	_theLeftRequests.copy(theLeftRequests);

	// check that the selected requests are linked and that they are all SOB or all DLR
	foreach aLeftRequest in theLeftRequests do						// 15/07/2013 cnwmh5 #31938
		aRightRequest := aLeftRequest.getDLRSOBRequestLink();
		if aRightRequest &lt;&gt; null then
//			self.allSlotControllers.add(aRightRequest.getLC()); // the LINKED REQs Slot Controller
		endif;
		if _linkMode = self.Mode_141 then
			// only if it is linked
			doInclude := aRightRequest &lt;&gt; null;
		elseif _linkMode = self.Mode_12M then
			// only DLR or SOB requests that are not linked
			doInclude := aRightRequest = null;
			if not doInclude then								// 11/07/2013 cnwmh5 #31938
				_theLeftRequests.remove(aLeftRequest);
			endif;	 
		endif;
		
		if doInclude then
			grandTotal := grandTotal + 1;
			if aLeftRequest.isDLR() then // PAR 28968 isRehandle then
				dlrTotal := dlrTotal + 1;
			elseif aLeftRequest.isSOB then
				sobTotal := sobTotal + 1;
			endif;
		endif;
	endforeach;

	if sobTotal &gt; 0 and dlrTotal &gt; 0 then
		app.msgBox("Cannot mix DLR and SOB requests, try again", "Request Link Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	
	endif;
	if grandTotal =  0 then
		app.msgBox("Please select some linked requests, try again", "Request Link Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	
	endif;

	if _linkMode = self.Mode_141 then
		return self.setCollection141(_theLeftRequests);
	elseif _linkMode = self.Mode_12M then
		return self.setCollections12M(_theLeftRequests);
	else
		return false;	
	endif;
epilog
	delete theLeftRequests;
end;</source>
        <Parameter name="_theLeftRequests" type="CM_RequestArray" usage="io"/>
        <Parameter name="_linkMode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCollections12M" id="e7d3766e-2824-4aaa-bd11-cf8381273422">
        <updating/>
        <source>setCollections12M(_theLeftRequests: CM_RequestArray) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aLeftRequest, aRightRequest : CM_Request;
	theRightRequests: CM_RequestArray;
	sobTotal,dlrTotal,grandTotal,idx : Integer;
begin
	create theRightRequests transient;
	self.linkMode := self.Mode_12M;

	// if this is a discharge then get all the LOads, else if load get the discharges
// PAR 28968 	self.myVoyage.myCellularVoyageStructure.getAllUnLinkedRequests(theRightRequests,not _theLeftRequests.first.isDischarge,_theLeftRequests.first.moveType);
	// 29734 test RORO and Cellular structure non-null first
	if self.myVoyage.myROROStructure &lt;&gt; null then
		self.myVoyage.myROROStructure.getAllUnLinkedRequests(theRightRequests, _theLeftRequests.first.isReleaseType,_theLeftRequests.first.getMoveType(), true);
	endif;
	if self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		self.myVoyage.myCellularVoyageStructure.getAllUnLinkedRequests(theRightRequests,_theLeftRequests.first.isReleaseType,_theLeftRequests.first.getMoveType, false);
	endif;

	self.magRequests.setItemsOnLeftSide(_theLeftRequests, true);
	// set line colour in left AVAILABLE list box
	foreach aLeftRequest in _theLeftRequests do
		idx := self.magRequests.myAvailableListBox.findObject(aLeftRequest);
		if idx &gt; 0 then
			if aLeftRequest.getAttrDischargePort() &lt;&gt; null then
				self.magRequests.myAvailableListBox.itemBackColor[idx] := aLeftRequest.getAttrDischargePort().colour;
				self.magRequests.myAvailableListBox.itemForeColor[idx] := aLeftRequest.getAttrDischargePort().colour.getInverseColour;
			endif;
		endif;
	endforeach;
	if self.linkMode = self.Mode_141 then
		self.magRequests.setItemsOnRightSide(theRightRequests, true);
	else
		self.tblTIAvailable.rows := 0;
		foreach aRightRequest in theRightRequests do
			idx := self.tblTIAvailable.addItem(self.displayStuff(aRightRequest));
			self.tblTIAvailable.accessRow(idx).itemObject := aRightRequest;
			if self.doesMatch(aRightRequest,_theLeftRequests) then
				if aRightRequest.getAttrDischargePort() &lt;&gt; null then
					self.tblTIAvailable.accessedRow.backColor := aRightRequest.getAttrDischargePort().colour;
					self.tblTIAvailable.accessedRow.foreColor := aRightRequest.getAttrDischargePort().colour.getInverseColour;
				endif;
			endif;
		endforeach;
	endif;
	return true;
epilog
	delete theRightRequests;
end;</source>
        <Parameter name="_theLeftRequests" type="CM_RequestArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCollectionsRORO" id="eb34ce1d-8e75-4103-95a8-22e11cd06598">
        <updating/>
        <source>setCollectionsRORO(_theLeftRequests: CM_RequestArray io; _linkMode : Integer) : Boolean updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/


vars
	aLeftRequest, aRightRequest : CM_Request;
	sobTotal,dlrTotal,grandTotal : Integer;
	doInclude : Boolean;
	theLeftRequests : CM_RequestArray;
begin
	if _theLeftRequests.isEmpty then
		app.msgBox("Please select some slots, try again", "Request Link Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	self.allROROControllers.clear;
	self.isRORO := true;
	
	create theLeftRequests transient;							// 17/05/2013 cnwmh5 #31938
	_theLeftRequests.copy(theLeftRequests);
	
	// check that the selected requests are linked and that they are all SOB or all DLR
	foreach aLeftRequest in theLeftRequests do					// 17/05/2013 cnwmh5 #31938
		aRightRequest := aLeftRequest.getDLRSOBRequestLink();
//		if aRightRequest &lt;&gt; null then
// PAR 28968			self.allROROControllers.add(aRightRequest.getLC()); // the LINKED REQs Slot Controller
//		endif;
		if _linkMode = self.Mode_141 then
			// only if it is linked
			doInclude := aRightRequest &lt;&gt; null;
		elseif _linkMode = self.Mode_12M then
			// only DLR or SOB requests that are not linked
			doInclude := aRightRequest = null;
			if not doInclude then								// 11/07/2013 cnwmh5 #31938
				_theLeftRequests.remove(aLeftRequest);
			endif;	
		endif;
		
		if doInclude then
			grandTotal := grandTotal + 1;
			if aLeftRequest.isDLR() then // PAR 28968
				dlrTotal := dlrTotal + 1;
			elseif aLeftRequest.isSOB then
				sobTotal := sobTotal + 1;
			endif;
		endif;
	endforeach;

	if sobTotal &gt; 0 and dlrTotal &gt; 0 then
		app.msgBox("Cannot mix DLR and SOB requests, try again", "Request Link Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	
	endif;
	if grandTotal =  0 then
		app.msgBox("Please select some linked requests, try again", "Request Link Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	
	endif;

	if _linkMode = self.Mode_141 then
		return self.setCollectionRORO141(_theLeftRequests);
	elseif _linkMode = self.Mode_12M then
		return self.setCollectionsRORO12M(_theLeftRequests);
	else
		return false;	
	endif;
epilog
	delete theLeftRequests;
end;</source>
        <Parameter name="_theLeftRequests" type="CM_RequestArray" usage="io"/>
        <Parameter name="_linkMode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCollectionsRORO12M" id="7a870782-dddf-46be-b55e-8cf1d47354a6">
        <updating/>
        <source>setCollectionsRORO12M(_theLeftRequests: CM_RequestArray) : Boolean updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/


vars
	aLeftRequest, aRightRequest : CM_Request;
	theRightRequests: CM_RequestArray;
	sobTotal,dlrTotal,grandTotal,idx : Integer;
begin
	create theRightRequests transient;
	self.linkMode := self.Mode_12M;

	// if this is a discharge then get all the Loads, else if load get the discharges
	// 29734 test RORO and Cellular structure non-null first
	if self.myVoyage.myROROStructure &lt;&gt; null then
		self.myVoyage.myROROStructure.getAllUnLinkedRequests(theRightRequests, _theLeftRequests.first.isReleaseType,_theLeftRequests.first.getMoveType(), true);
	endif;
	if self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		self.myVoyage.myCellularVoyageStructure.getAllUnLinkedRequests(theRightRequests, _theLeftRequests.first.isReleaseType,_theLeftRequests.first.getMoveType(), false);
	endif;

	self.magRequests.setItemsOnLeftSide(_theLeftRequests, true);
	// set line colour in left AVAILABLE list box
	foreach aLeftRequest in _theLeftRequests do
		idx := self.magRequests.myAvailableListBox.findObject(aLeftRequest);
		if idx &gt; 0 then
			if aLeftRequest.getAttrDischargePort() &lt;&gt; null then
				self.magRequests.myAvailableListBox.itemBackColor[idx] := aLeftRequest.getAttrDischargePort().colour;
				self.magRequests.myAvailableListBox.itemForeColor[idx] := aLeftRequest.getAttrDischargePort().colour.getInverseColour;
			endif;
		endif;
	endforeach;
	if self.linkMode = self.Mode_141 then
		self.magRequests.setItemsOnRightSide(theRightRequests, true);
	else
		self.tblTIAvailable.rows := 0;
		foreach aRightRequest in theRightRequests do
			idx := self.tblTIAvailable.addItem(self.displayStuff(aRightRequest));
			self.tblTIAvailable.accessRow(idx).itemObject := aRightRequest;
			if self.doesMatchRORO(aRightRequest,_theLeftRequests) then
				if aRightRequest.getAttrDischargePort() &lt;&gt; null then
					self.tblTIAvailable.accessedRow.backColor := aRightRequest.getAttrDischargePort().colour;
					self.tblTIAvailable.accessedRow.foreColor := aRightRequest.getAttrDischargePort().colour.getInverseColour;
				endif;
			endif;
		endforeach;
	endif;
	return true;
epilog
	delete theRightRequests;
end;</source>
        <Parameter name="_theLeftRequests" type="CM_RequestArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="7c6a6f44-9118-41c7-a68f-173afbf05706">
