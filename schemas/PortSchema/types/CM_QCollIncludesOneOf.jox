    <JadeMethod name="doMatch" id="d00000cd-4227-40b6-a091-9587c564b8ac">
        <source>doMatch(_value: Any): Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2013	cnwpjs1	Initial creation  PAR # 31237
21 Nov 2016	cnwdap1	TFS 2844 STWR Hazardous Details Enhancements

*/

vars

	obj	: Object;
	tiHaz : CM_Hazard;						// TFS 2844

begin
	if self.allSelectionValues.isEmpty then //Haven't selected any items so assume it's ok.  
		return true;
	endif;
	
	if _value = null then
		return false;
	endif;
	
	foreach obj in allSelectionValues do
		if obj.isKindOf(CM_HazTempRange) then													// TFS 2844
			foreach tiHaz in _value.CM_HazardByCodeDict do										// TFS 2844
				//if tiHaz.CM_TIHazard.flashpointTemperature = obj.CM_HazTempRange.value then		// TFS 2844
				if obj.CM_HazTempRange.includesTemp(tiHaz.CM_TIHazard.flashpointTemperature) then	// TFS 3421 after 2844
					return true;																// TFS 2844
				endif;																			// TFS 2844
			endforeach;																			// TFS 2844
		elseif _value.Collection.isKindOf(CM_HazardByCodeDict) then								// TFS 2844
		//if _value.Collection.isKindOf(CM_HazardByCodeDict) then								// TFS 2844
			if _value.Collection.CM_HazardByCodeDict.includesHazard(obj) then
				return true;
			endif;
		elseif _value.Collection.includes(obj) then
			return true;
		endif;
	endforeach;
	
													
	return false;

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForRT" id="a34f46dd-67fa-4a34-b9cf-f1d601aa596b">
        <source>validateForRT(_queryName: String; _propName: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2017	cnwndl1	Initial creation	TFS 

*/

vars
	str	: String;
	obj	: Object;
	
begin
	
	foreach obj in self.allSelectionValues do
		if obj.isKindOf( CM_Object ) then
			str := str &amp; obj.CM_Object.auditIdDisplay() &amp; ', ';
		endif;
	endforeach;
	str := str[1 : str.length()-2];		// removing the last comma
	
	app.raiseCMWarning1( ERR_QueryForRTMustUseEqualTo, _queryName &amp;': "'&amp; _propName &amp;' '&amp; self.description &amp;' '&amp; str &amp;'"', null, null, null);
	
end;
</source>
        <Parameter name="_queryName" type="String"/>
        <Parameter name="_propName" type="String"/>
    </JadeMethod>
</Class>
