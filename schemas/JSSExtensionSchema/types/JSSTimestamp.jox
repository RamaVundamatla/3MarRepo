    <JadeMethod name="addDays" id="c7a3095d-b56a-4ad5-9fc6-5c0904d2bfca">
        <updating/>
        <source>addDays(pDays:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.timestampClient	:=	self.timestampClient.jssAddDays(pDays);
end;</source>
        <Parameter name="pDays" type="Integer"/>
    </JadeMethod>
