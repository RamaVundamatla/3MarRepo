    <JadeMethod name="initializeForActivity" id="ac83a1ca-cbb9-4022-8786-7625f9c87a79">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
03 December 2021	navab1	TFS 51853
*/

vars
	lc : CM_LocationsController;
begin
	inheritMethod(_any, _ewsOpsView);

	
	self.tableName		:= self.Xps_stackstatus;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey		:= self.generateFullGKey(_any, "");
		return;
	endif;
	
	
	if _any.isKindOf(CM_LocationsController) then
		lc := _any.CM_LocationsController;
		lc.initializeForActivity(_ewsOpsView, self);
	endif;
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
