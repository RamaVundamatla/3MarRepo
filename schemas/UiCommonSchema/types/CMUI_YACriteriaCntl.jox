    <JadeMethod name="setWidth" id="27fa9aa9-8e0b-4963-8941-2d6db2d6aa62">
        <source>setWidth(_width: Integer);
//28 July 2008	cnwdw1	
// Set the width of the control.
// 12 Jun 2013	cnwcs5	par 31712
vars
	left, top : Integer;
begin
	left 	:= 10;
	top 	:= 10;
	
	// start 10 pixels in
	self.lblCriteriaType.left 	:= left;
	self.lblCriteriaType.top 	:= top;
	
	// combo covers label
	self.cmbCriteriaType.left 	:= left;
	self.cmbCriteriaType.top 	:= top;
	
	// value starts 40% across control
	//left := (self.clientWidth * .5).Integer;
	left := (self.cmbCriteriaType.left + self.cmbCriteriaType.width + 10).Integer;
	
	self.txtCriteriaValue.left 	:= left;
	self.txtCriteriaValue.top 	:= top;
	
	// checkbox starts in same place
	self.chkCriteriaValue.left 	:= left;
	self.chkCriteriaValue.top 	:= top;
	
	// we use a label instead of a combo if we can't change the type
	self.lblCriteriaType.width 		:= self.txtCriteriaValue.left - self.lblCriteriaType.left - 2;
	self.lblCriteriaType.height 	:= self.txtCriteriaValue.height;
	self.lblCriteriaType.alignment 	:= Label.Alignment_Left_Middle;
		
	left := (_width - 20).Integer; // PAR 35325 changed from 10 to 20

	// 10 pixels between textbox and button
	self.btnValuePicker.left 	:= left - self.btnValuePicker.width;
	self.btnValuePicker.top 	:= top;

	self.txtCriteriaValue.width := self.btnValuePicker.left - self.txtCriteriaValue.left - 10; 
	
	
end;</source>
        <Parameter name="_width" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupChildControls" id="629c524d-f30c-4659-8a73-d51fb6cc115f">
        <updating/>
        <source>setupChildControls() updating, protected;
//28 July 2008	cnwdw1	
// Create the child controls
// 28/11/2023	navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues
vars
	isYAForm	: Boolean;
begin
	isYAForm := self.isInYACriteriaForm();
	
	create self.lblCriteriaType transient;
	self.lblCriteriaType.parent	:= self;
	self.lblCriteriaType.visible := false;
	self.lblCriteriaType.transparent := true;
	if isYAForm then
		self.lblCriteriaType.width := self.parent.width * 0.375;				// 28/11/2023	navkc1 Bug 60782
		self.lblCriteriaType.parentAspect := Control.ParentAspect_StretchRight; // 28/11/2023	navkc1 Bug 60782
	endif;
	self.form.addControl(self.lblCriteriaType);
	
	create self.cmbCriteriaType transient;
	self.cmbCriteriaType.parent := self;
	self.cmbCriteriaType.visible := not self.lblCriteriaType.visible;
	self.cmbCriteriaType.enabled := true;
	if isYAForm then
		self.cmbCriteriaType.width := self.parent.width * 0.375;				// 28/11/2023	navkc1 Bug 60782
		self.cmbCriteriaType.parentAspect := Control.ParentAspect_StretchRight; // 28/11/2023	navkc1 Bug 60782
	endif;
	self.cmbCriteriaType.setCriteriaControl(self);
	self.form.addControl(self.cmbCriteriaType);
	
	create self.txtCriteriaValue transient;
	self.txtCriteriaValue.parent :=	self;
	self.txtCriteriaValue.enabled := false;
	self.txtCriteriaValue.scrollHorizontal := true;
	self.txtCriteriaValue.case := TextBox.Case_Upper;
	self.txtCriteriaValue.selectionStyle := TextBox.SelectionStyle_SelectAll;
	if isYAForm then
		self.txtCriteriaValue.parentAspect := Control.ParentAspect_AnchorRight; // 28/11/2023	navkc1 Bug 60782
	endif;
	self.form.addControl(self.txtCriteriaValue);
	
	create self.chkCriteriaValue transient;
	self.chkCriteriaValue.parent :=	self;
	self.chkCriteriaValue.caption := null;
	self.chkCriteriaValue.enabled := true;
	if isYAForm then
		self.chkCriteriaValue.parentAspect := Control.ParentAspect_AnchorRight; // 28/11/2023	navkc1 Bug 60782
	endif;
	self.form.addControl(self.chkCriteriaValue);
	
	create self.btnValuePicker transient;
	self.btnValuePicker.parent := self;
	self.btnValuePicker.caption := "Find";
	self.btnValuePicker.width := 30;  //was 20;
	self.btnValuePicker.enabled := false;
	if isYAForm then
		self.btnValuePicker.parentAspect := Control.ParentAspect_AnchorRight; // 28/11/2023	navkc1 Bug 60782
	endif;
	self.form.addControl(self.btnValuePicker);
	
	self.setInitialValues();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateVoyages" id="31c0fff5-7eb9-4e9c-a37a-a496e962a4a0">
        <source>updateVoyages();

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
17 December 2008	consw1	Initial creation

*/

vars
	
begin
	if self.myVoyagesReference = null then
		return;
	endif;

	self.myVoyagesReference.clear;

	if self.hasValue then
		//self.getCriteriaType.resolvePattern( self.getValue.String, self.myVoyagesReference );
		//par 19879 cnwjo3.
		self.getCriteriaType.resolvePattern( self.getValue.String, self.myVoyagesReference, false);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="useDateRangeControls" id="efaf5a1a-2d94-4649-8ab5-6d39fc76db94">
        <source>useDateRangeControls() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27 May 2025	navdap1		Initial creation MTN-34981 MTN -Yard Allocations - Storing Cargo Based on a Date Range
//
vars
	startDate, endDate : CMUI_DateMaskYACriteriaCtrl;
	hyphen : CMUI_Label;

begin
	if self.chkCriteriaValue.userObject &lt;&gt; null then
		return;
	endif;
	
	create startDate transient;
	startDate.parent	:= self;
	startDate.top 		:= self.lblCriteriaType.top + 2;
	startDate.left 		:= self.chkCriteriaValue.left + 2;
	startDate.width		:= 75;
	startDate.enabled 	:= true;
	startDate.visible 	:= true;
	startDate.tabIndex	:= self.chkCriteriaValue.tabIndex + 1;
	startDate.parentAspect := Control.ParentAspect_AnchorRight;
	form.addControl(startDate);

	self.chkCriteriaValue.userObject := startDate;
	
	create hyphen transient;
	hyphen.parent		:= self;
	hyphen.top 			:= self.lblCriteriaType.top + 2;
	hyphen.left 		:= startDate.left + startDate.width + 3;
	hyphen.height		:= startDate.height;
	hyphen.width		:= 10;
	hyphen.enabled 		:= true;
	hyphen.visible 		:= true;
	hyphen.caption		:= Hyphen;
	hyphen.alignment 	:= Label.Alignment_Center_Middle;
	hyphen.parentAspect := Control.ParentAspect_AnchorRight;
	form.addControl(hyphen);
	
	create endDate transient;
	endDate.parent 	:= self;
	endDate.top 		:= startDate.top;
	endDate.left 		:= startDate.left + 92;
	endDate.width		:= startDate.width;
	endDate.enabled 	:= startDate.enabled;
	endDate.visible 	:= startDate.visible;
	endDate.tabIndex	:= startDate.tabIndex + 1;
	endDate.parentAspect := Control.ParentAspect_AnchorRight;
	form.addControl(endDate);

	startDate.userObject := endDate;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="useThreeStateBoolean" id="ca45227d-1ca8-44ad-bba3-f185c88ce521">
        <source>useThreeStateBoolean() : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2013	cnwjre1	Initial creation

*/

vars

begin

	if self.tag = null then
		return false;
	else
		return true;
	endif;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="useYesNoOptionButtons" id="315320d0-f174-4e8c-a9ad-862e53b07f11">
        <source>useYesNoOptionButtons() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
14 August 2008	consw1	Initial creation
28/11/2023		navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues
*/

vars
	cntlOptYes, cntlOptNo, cntlOptEither : CMUI_OptButtonYACriteriaCtrl;
	
begin
	if self.chkCriteriaValue.userObject &lt;&gt; null then
		return;
	endif;

	create cntlOptYes transient;
	cntlOptYes.parent 	:= self;
	cntlOptYes.caption 	:= "Yes";
	cntlOptYes.top 		:= self.lblCriteriaType.top + 2;
	cntlOptYes.left 	:= self.chkCriteriaValue.left + 2;
	cntlOptYes.enabled 	:= self.chkCriteriaValue.enabled;
	cntlOptYes.visible 	:= self.chkCriteriaValue.visible;
	cntlOptYes.value 	:= self.chkCriteriaValue.value;
	cntlOptYes.tabIndex	:= self.chkCriteriaValue.tabIndex + 1;
	cntlOptYes.parentAspect := Control.ParentAspect_AnchorRight;	// 28/11/2023	navkc1 Bug 60782
	form.addControl(cntlOptYes);

	self.chkCriteriaValue.userObject := cntlOptYes;
	
	create cntlOptNo transient;
	cntlOptNo.parent 	:= self;
	cntlOptNo.caption 	:= "No";
	cntlOptNo.top 		:= cntlOptYes.top;
	cntlOptNo.left 		:= cntlOptYes.left + 50;
	cntlOptNo.enabled 	:= cntlOptYes.enabled;
	cntlOptNo.visible 	:= cntlOptYes.visible;
	cntlOptNo.value 	:= not cntlOptYes.value;
	cntlOptNo.tabIndex	:= cntlOptYes.tabIndex + 1;
	cntlOptNo.parentAspect := Control.ParentAspect_AnchorRight;		// 28/11/2023	navkc1 Bug 60782
	form.addControl(cntlOptNo);

	cntlOptYes.userObject := cntlOptNo;

	if self.useThreeStateBoolean() then
		create cntlOptEither transient;
		cntlOptEither.parent 	:= self;
	//	cntlOptEither.caption 	:= "Either";
		cntlOptEither.caption 	:= app.getErrorString(NotApplicable);	//23 Mar 2015	NDL	Par 35886
		cntlOptEither.top 		:= cntlOptNo.top;
		cntlOptEither.left 		:= cntlOptNo.left + 50;
		cntlOptEither.enabled 	:= cntlOptNo.enabled;
		cntlOptEither.visible 	:= cntlOptNo.visible;
		cntlOptEither.value 	:= not cntlOptNo.value;
		cntlOptEither.tabIndex	:= cntlOptNo.tabIndex + 1;
		cntlOptEither.parentAspect := Control.ParentAspect_AnchorRight; // 28/11/2023	navkc1 Bug 60782
		form.addControl(cntlOptEither);

		cntlOptNo.userObject := cntlOptEither;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="1b7ebbf9-e4c4-49d6-891b-aa7d75844ac2">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
begin
	inheritMethod(cntrl, persistCntrl);
	self.setupChildControls();
end;</source>
