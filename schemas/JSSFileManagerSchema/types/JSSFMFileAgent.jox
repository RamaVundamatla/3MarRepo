    <JadeMethod name="deleteFile" id="8e42fe1d-3ed8-4fae-8aec-1e80ad67cbc4">
        <updating/>
        <source>deleteFile(pFileName:String; pNodeOptions:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		09 July 2002 by cnwdad2
//
// Purpose:		Deletes the specified file on the specified source node.
//
// Parameters:	pFileName - The path name of the file to delete.
//				pNodeOptions - Specifies the source JADE node.
//
// Returns:		True if the operation succeeded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sourceNode		: Integer;
	
begin
	on Exception do self.xHandler(exception);
	
	self.doFileErrorSet(0, null);
	
	if self.interpretSourceNodeOptions(pNodeOptions, sourceNode) then
	
		if sourceNode = JSSFMFileManagerService.NODE_SOURCE_CLIENT then
			return self.deleteDiskFileClient(pFileName);
		elseif sourceNode = JSSFMFileManagerService.NODE_SOURCE_APPSERVER then
			return self.deleteDiskFileAppServer(pFileName);
		elseif sourceNode = JSSFMFileManagerService.NODE_SOURCE_DBSERVER then
			return self.deleteDiskFileDbServer(pFileName);
		endif;
		
	endif;
epilog
	on Exception do null;
	
	self.doFileErrorCheck();
end;</source>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFileErrorCheck" id="2125097c-d1f4-4847-9acf-36e6e12b4fa0">
        <source>doFileErrorCheck() protected;
// --------------------------------------------------------------------------------
// Created:		22 July 2002 by cnwdad1
//
// Purpose:		Checks whether the file error code property has been set, and if so
//				raises an exception.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.errorCode &lt;&gt; 0 then
		self.myServiceManager.raiseJSSException2(	JSS_EX_00011,
													self.errorCode.String,
													self.errorMessage);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFileErrorSet" id="faff511a-89f8-4d80-8fb3-c7b829184231">
        <updating/>
        <source>doFileErrorSet(pErrorCode:Integer; pFileName:String) updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 July 2002 by cnwdad1
//
// Purpose:		Sets the file error code to the specified value.
//
// Parameters:	pErrorCode - The file error code value.
//				pFileName - The name of the file that caused the error code.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.errorCode		:=	pErrorCode;
	
	if pErrorCode = 0 then
		self.errorMessage	:=	null;
	else
		self.errorMessage	:=	self.getFileError(pErrorCode) &amp; CrLf &amp; "(" &amp; pFileName &amp; ")";
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pErrorCode" type="Integer"/>
        <Parameter name="pFileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileError" id="55a873ee-7416-4a78-9488-50e78b60f5d4">
        <source>getFileError(pErrorCode:Integer):String protected;
// --------------------------------------------------------------------------------
// Created:		09 July 2002 by cnwdad2
//
// Purpose:		Fetches a description for a file error code.
//
// Parameters:	pErrorCode - The file error code.
//
// Returns:		A description of the file error code.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorText	: String;
	
begin
	if pErrorCode = 2 then
		errorText	:=	"The system cannot find the file specified.";
	elseif pErrorCode = 3 then
		errorText	:=	"The system cannot find the path specified.";
	elseif pErrorCode = 4 then
		errorText	:=	"The system cannot open the file.";
	elseif pErrorCode = 5 then
		errorText	:=	"Access is denied.";
	elseif pErrorCode = 6 then
		errorText	:=	"The handle is invalid.";
	elseif pErrorCode = 7 then
		errorText	:=	"The storage control blocks were destroyed.";
	elseif pErrorCode = 8 then
		errorText	:=	"Not enough storage is available to process this command.";
	elseif pErrorCode = 9 then
		errorText	:=	"The storage control block address is invalid.";
	elseif pErrorCode = 10 then
		errorText	:=	"The environment is incorrect.";
	elseif pErrorCode = 11 then
		errorText	:=	"An attempt was made to load a program with an incorrect format.";
	elseif pErrorCode = 12 then
		errorText	:=	"The access code is invalid.";
	elseif pErrorCode = 13 then
		errorText	:=	"The data is invalid.";
	elseif pErrorCode = 14 then
		errorText	:=	"Not enough storage is available to complete this operation.";
	elseif pErrorCode = 15 then
		errorText	:=	"The system cannot find the drive specified.";
	elseif pErrorCode = 16 then
		errorText	:=	"The directory cannot be removed.";
	elseif pErrorCode = 17 then
		errorText	:=	"The system cannot move the file to a different disk drive.";
	elseif pErrorCode = 18 then
		errorText	:=	"There are no more files.";
	elseif pErrorCode = 19 then
		errorText	:=	"The media is write protected.";
	elseif pErrorCode = 20 then
		errorText	:=	"The system cannot find the device specified.";
	elseif pErrorCode = 21 then
		errorText	:=	"The device is not ready.";
	elseif pErrorCode = 22 then
		errorText	:=	"The device does not recognize the command.";
	elseif pErrorCode = 23 then
		errorText	:=	"Data error (cyclic redundancy check).";
	elseif pErrorCode = 24 then
		errorText	:=	"The program issued a command but the command length is incorrect.";
	elseif pErrorCode = 25 then
		errorText	:=	"The drive cannot locate a specific area or track on the disk.";
	elseif pErrorCode = 26 then
		errorText	:=	"The specified disk or diskette cannot be accessed.";
	elseif pErrorCode = 27 then
		errorText	:=	"The drive cannot find the sector requested.";
	elseif pErrorCode = 29 then
		errorText	:=	"The system cannot write to the specified device.";
	elseif pErrorCode = 30 then
		errorText	:=	"The system cannot read from the specified device.";
	elseif pErrorCode = 31 then
		errorText	:=	"A device attached to the system is not functioning.";
	elseif pErrorCode = 32 then
		errorText	:=	"The process cannot access the file because it is being used by another process.";
	elseif pErrorCode = 33 then
		errorText	:=	"The process cannot access the file because another process has locked a portion of the file.";
	elseif pErrorCode = 36 then
		errorText	:=	"Too many files opened for sharing.";
	elseif pErrorCode = 38 then
		errorText	:=	"Reached the end of the file.";
	elseif pErrorCode = 39 then
		errorText	:=	"The disk is full.";
	elseif pErrorCode = 50 then
		errorText	:=	"The request is not supported.";
	elseif pErrorCode = 51 then
		errorText	:=	"Windows cannot find the network path. Verify that the network path is correct and the destination computer is not busy or turned off. If Windows still cannot find the network path, contact your network administrator.";
	elseif pErrorCode = 55 then
		errorText	:=	"The specified network resource or device is no longer available.";
	elseif pErrorCode = 58 then
		errorText	:=	"The specified server cannot perform the requested operation.";
	elseif pErrorCode = 59 then
		errorText	:=	"An unexpected network error occurred.";
	elseif pErrorCode = 65 then
		errorText	:=	"Network access is denied.";
	elseif pErrorCode = 70 then
		errorText	:=	"The remote server has been paused or is in the process of being started.";
	elseif pErrorCode = 71 then
		errorText	:=	"No more connections can be made to this remote computer at this time because there are already as many connections as the computer can accept.";
	elseif pErrorCode = 72 then
		errorText	:=	"The specified printer or disk device has been paused.";
	elseif pErrorCode = 80 then
		errorText	:=	"The file exists.";
	elseif pErrorCode = 82 then
		errorText	:=	"The directory or file cannot be created.";
	elseif pErrorCode = 84 then
		errorText	:=	"Storage to process this request is not available.";
	elseif pErrorCode = 85 then
		errorText	:=	"The local device name is already in use.";
	elseif pErrorCode = 88 then
		errorText	:=	"A write fault occurred on the network.";
	elseif pErrorCode = 89 then
		errorText	:=	"The system cannot start another process at this time.";
	elseif pErrorCode = 108 then
		errorText	:=	"The disk is in use or locked by another process.";
	elseif pErrorCode = 110 then
		errorText	:=	"The system cannot open the device or file specified.";
	elseif pErrorCode = 111 then
		errorText	:=	"The file name is too long.";
	elseif pErrorCode = 112 then
		errorText	:=	"There is not enough space on the disk.";
	elseif pErrorCode = 113 then
		errorText	:=	"No more internal file identifiers available.";
	elseif pErrorCode = 114 then
		errorText	:=	"The target internal file identifier is incorrect.";
	elseif pErrorCode = 118 then
		errorText	:=	"The verify-on-write switch parameter value is not correct.";
	elseif pErrorCode = 119 then
		errorText	:=	"The system does not support the command requested.";
	elseif pErrorCode = 120 then
		errorText	:=	"This function is not supported on this system.";
	elseif pErrorCode = 122 then
		errorText	:=	"The data area passed to a system call is too small.";
	elseif pErrorCode = 123 then
		errorText	:=	"The filename, directory name, or volume label syntax is incorrect.";
	elseif pErrorCode = 124 then
		errorText	:=	"The system call level is not correct.";
	elseif pErrorCode = 125 then
		errorText	:=	"The disk has no volume label.";
	elseif pErrorCode = 130 then
		errorText	:=	"Attempt to use a file handle to an open disk partition for an operation other than raw disk I/O.";
	elseif pErrorCode = 131 then
		errorText	:=	"An attempt was made to move the file pointer before the beginning of the file.";
	elseif pErrorCode = 132 then
		errorText	:=	"The file pointer cannot be set on the specified device or file.";
	elseif pErrorCode = 133 then
		errorText	:=	"A JOIN or SUBST command cannot be used for a drive that contains previously joined drives.";
	elseif pErrorCode = 134 then
		errorText	:=	"An attempt was made to use a JOIN or SUBST command on a drive that has already been joined.";
	elseif pErrorCode = 135 then
		errorText	:=	"An attempt was made to use a JOIN or SUBST command on a drive that has already been substituted.";
	elseif pErrorCode = 136 then
		errorText	:=	"The system tried to delete the JOIN of a drive that is not joined.";
	elseif pErrorCode = 137 then
		errorText	:=	"The system tried to delete the substitution of a drive that is not substituted.";
	elseif pErrorCode = 138 then
		errorText	:=	"The system tried to join a drive to a directory on a joined drive.";
	elseif pErrorCode = 139 then
		errorText	:=	"The system tried to substitute a drive to a directory on a substituted drive.";
	elseif pErrorCode = 140 then
		errorText	:=	"The system tried to join a drive to a directory on a substituted drive.";
	elseif pErrorCode = 141 then
		errorText	:=	"The system tried to SUBST a drive to a directory on a joined drive.";
	elseif pErrorCode = 142 then
		errorText	:=	"The system cannot perform a JOIN or SUBST at this time.";
	elseif pErrorCode = 143 then
		errorText	:=	"The system cannot join or substitute a drive to or for a directory on the same drive.";
	elseif pErrorCode = 144 then
		errorText	:=	"The directory is not a subdirectory of the root directory.";
	elseif pErrorCode = 145 then
		errorText	:=	"The directory is not empty.";
	elseif pErrorCode = 146 then
		errorText	:=	"The path specified is being used in a substitute.";
	elseif pErrorCode = 147 then
		errorText	:=	"Not enough resources are available to process this command.";
	elseif pErrorCode = 148 then
		errorText	:=	"The path specified cannot be used at this time.";
	elseif pErrorCode = 149 then
		errorText	:=	"An attempt was made to join or substitute a drive for which a directory on the drive is the target of a previous substitute.";
	elseif pErrorCode = 154 then
		errorText	:=	"The volume label you entered exceeds the label character limit of the target file system.";
	elseif pErrorCode = 155 then
		errorText	:=	"Cannot create another thread.";
	elseif pErrorCode = 156 then
		errorText	:=	"The recipient process has refused the signal.";
	elseif pErrorCode = 157 then
		errorText	:=	"The segment is already discarded and cannot be locked.";
	elseif pErrorCode = 158 then
		errorText	:=	"The segment is already unlocked.";
	elseif pErrorCode = 159 then
		errorText	:=	"The address for the thread ID is not correct.";
	elseif pErrorCode = 161 then
		errorText	:=	"The specified path is invalid.";
	elseif pErrorCode = 164 then
		errorText	:=	"No more threads can be created in the system.";
	elseif pErrorCode = 167 then
		errorText	:=	"Unable to lock a region of a file.";
	elseif pErrorCode = 170 then
		errorText	:=	"The requested resource is in use.";
	elseif pErrorCode = 173 then
		errorText	:=	"A lock request was not outstanding for the supplied cancel region.";
	elseif pErrorCode = 180 then
		errorText	:=	"The system detected a segment number that was not correct.";
	elseif pErrorCode = 183 then
		errorText	:=	"Cannot create a file when that file already exists.";
	elseif pErrorCode = 206 then
		errorText	:=	"The filename or extension is too long.";
	elseif pErrorCode = 208 then
		errorText	:=	"The global filename characters, * or ?, are entered incorrectly or too many global filename characters are specified.";
	elseif pErrorCode = 212 then
		errorText	:=	"The segment is locked and cannot be reallocated.";
	elseif pErrorCode = 214 then
		errorText	:=	"Too many dynamic-link modules are attached to this program or dynamic-link module.";
	elseif pErrorCode = 240 then
		errorText	:=	"The session was canceled.";
	elseif pErrorCode = 266 then
		errorText	:=	"The copy functions cannot be used.";
	elseif pErrorCode = 267 then
		errorText	:=	"The directory name is invalid.";
	elseif pErrorCode = 276 then
		errorText	:=	"The extended attribute file on the mounted file system is corrupt.";
	elseif pErrorCode = 277 then
		errorText	:=	"The extended attribute table file is full.";
	elseif pErrorCode = 278 then
		errorText	:=	"The specified extended attribute handle is invalid.";
	elseif pErrorCode = 282 then
		errorText	:=	"The mounted file system does not support extended attributes.";
	elseif pErrorCode = 302 then
		errorText	:=	"The volume is too fragmented to complete this operation.";
	elseif pErrorCode = 303 then
		errorText	:=	"The file cannot be opened because it is in the process of being deleted.";
	elseif pErrorCode = 995 then
		errorText	:=	"The I/O operation has been aborted because of either a thread exit or an application request.";
	elseif pErrorCode = 996 then
		errorText	:=	"Overlapped I/O event is not in a signaled state.";
	elseif pErrorCode = 997 then
		errorText	:=	"Overlapped I/O operation is in progress.";
	elseif pErrorCode = 1001 then
		errorText	:=	"Recursion too deep; the stack overflowed.";
	elseif pErrorCode = 1003 then
		errorText	:=	"Cannot complete this function.";
	elseif pErrorCode = 1005 then
		errorText	:=	"The volume does not contain a recognized file system. Please make sure that all required file system drivers are loaded and that the volume is not corrupted.";
	elseif pErrorCode = 1006 then
		errorText	:=	"The volume for a file has been externally altered so that the opened file is no longer valid.";
	elseif pErrorCode = 1016 then
		errorText	:=	"An I/O operation initiated by the registry failed unrecoverably. The registry could not read in, or write out, or flush, one of the files that contain the system's image of the registry.";
	elseif pErrorCode = 1074 then
		errorText	:=	"The system is currently running with the last-known-good configuration.";
	elseif pErrorCode = 1076 then
		errorText	:=	"The current boot has already been accepted for use as the last-known-good control set.";
	elseif pErrorCode = 1111 then
		errorText	:=	"The I/O bus was reset.";
	elseif pErrorCode = 1113 then
		errorText	:=	"No mapping for the Unicode character exists in the target multi-byte code page.";
	elseif pErrorCode = 1115 then
		errorText	:=	"A system shutdown is in progress.";
	elseif pErrorCode = 1117 then
		errorText	:=	"The request could not be performed because of an I/O device error.";
	elseif pErrorCode = 1126 then
		errorText	:=	"While accessing the hard disk, a recalibrate operation failed, even after retries.";
	elseif pErrorCode = 1127 then
		errorText	:=	"While accessing the hard disk, a disk operation failed even after retries.";
	elseif pErrorCode = 1128 then
		errorText	:=	"While accessing the hard disk, a disk controller reset was needed, but even that failed.";
	elseif pErrorCode = 1130 then
		errorText	:=	"Not enough server storage is available to process this command.";
	elseif pErrorCode = 1131 then
		errorText	:=	"A potential deadlock condition has been detected.";
	elseif pErrorCode = 1132 then
		errorText	:=	"The base address or the file offset specified does not have the proper alignment.";
	elseif pErrorCode = 1142 then
		errorText	:=	"An attempt was made to create more links on a file than the file system supports.";
	elseif pErrorCode = 1155 then
		errorText	:=	"No application is associated with the specified file for this operation.";
	elseif pErrorCode = 1158 then
		errorText	:=	"The current process has used all of its system allowance of handles for Window Manager objects.";
	elseif pErrorCode = 1159 then
		errorText	:=	"The message can be used only with synchronous operations.";
	elseif pErrorCode = 1160 then
		errorText	:=	"The indicated source element has no media.";
	elseif pErrorCode = 1161 then
		errorText	:=	"The indicated destination element already contains media.";
	elseif pErrorCode = 1164 then
		errorText	:=	"The indicated device requires reinitialization due to hardware errors.";
	elseif pErrorCode = 1167 then
		errorText	:=	"The device is not connected.";
	elseif pErrorCode = 1173 then
		errorText	:=	"The Volume ID could not be found.";
	elseif pErrorCode = 1175 then
		errorText	:=	"Unable to remove the file to be replaced.";
	elseif pErrorCode = 1176 then
		errorText	:=	"Unable to move the replacement file to the file to be replaced. The file to be replaced has retained its original name.";
	elseif pErrorCode = 1177 then
		errorText	:=	"Unable to move the replacement file to the file to be replaced. The file to be replaced has been renamed using the backup name.";
	elseif pErrorCode = 1178 then
		errorText	:=	"The volume change journal is being deleted.";
	elseif pErrorCode = 1179 then
		errorText	:=	"The volume change journal is not active.";
	elseif pErrorCode = 1180 then
		errorText	:=	"A file was found, but it may not be the correct file.";
	elseif pErrorCode = 1208 then
		errorText	:=	"An extended error has occurred.";
	elseif pErrorCode = 1220 then
		errorText	:=	"An attempt was made to establish a session to a network server, but there are already too many sessions established to that server.";
	elseif pErrorCode = 1221 then
		errorText	:=	"The workgroup or domain name is already in use by another computer on the network.";
	elseif pErrorCode = 1223 then
		errorText	:=	"The operation was canceled by the user.";
	elseif pErrorCode = 1224 then
		errorText	:=	"The requested operation cannot be performed on a file with a user-mapped section open.";
	elseif pErrorCode = 1235 then
		errorText	:=	"The request was aborted.";
	elseif pErrorCode = 1237 then
		errorText	:=	"The operation could not be completed. A retry should be performed.";
	elseif pErrorCode = 1238 then
		errorText	:=	"A connection to the server could not be made because the limit on the number of concurrent connections for this account has been reached.";
	elseif pErrorCode = 1239 then
		errorText	:=	"Attempting to log in during an unauthorized time of day for this account.";
	elseif pErrorCode = 1240 then
		errorText	:=	"The account is not authorized to log in from this station.";
	elseif pErrorCode = 1241 then
		errorText	:=	"The network address could not be used for the operation requested.";
	elseif pErrorCode = 1244 then
		errorText	:=	"The operation being requested was not performed because the user has not been authenticated.";
	elseif pErrorCode = 1255 then
		errorText	:=	"The server machine is shutting down.";
	elseif pErrorCode = 1271 then
		errorText	:=	"The machine is locked and cannot be shut down without the force option.";
	elseif pErrorCode = 1359 then
		errorText	:=	"An internal error occurred.";
	elseif pErrorCode = 1392 then
		errorText	:=	"The file or directory is corrupted and unreadable.";
	elseif pErrorCode = 1393 then
		errorText	:=	"The disk structure is corrupted and unreadable.";
	elseif pErrorCode = 1460 then
		errorText	:=	"This operation returned because the timeout period expired.";
	elseif pErrorCode = 1626 then
		errorText	:=	"Function could not be executed.";
	elseif pErrorCode = 1627 then
		errorText	:=	"Function failed during execution.";
	elseif pErrorCode = 1785 then
		errorText	:=	"The disk media is not recognized. It may not be formatted.";
	elseif pErrorCode = 1816 then
		errorText	:=	"Not enough quota is available to process this command.";
	elseif pErrorCode = 1920 then
		errorText	:=	"The file cannot be accessed by the system.";
	elseif pErrorCode = 2003 then
		errorText	:=	"The requested metafile operation is not supported.";
	elseif pErrorCode = 4309 then
		errorText	:=	"A resource required for this operation is disabled.";
	elseif pErrorCode = 4316 then
		errorText	:=	"The resource required for this operation does not exist.";
	elseif pErrorCode = 4319 then
		errorText	:=	"The device is not ready for use.";
	elseif pErrorCode = 4321 then
		errorText	:=	"The drive identifier does not represent a valid drive.";
	elseif pErrorCode = 4325 then
		errorText	:=	"Unable to retrieve status about the drive.";
	elseif pErrorCode = 4330 then
		errorText	:=	"Unable to eject the media because it is in a drive.";
	elseif pErrorCode = 4337 then
		errorText	:=	"The volume contains system or paging files.";
	elseif pErrorCode = 4350 then
		errorText	:=	"The remote storage service was not able to recall the file.";
	elseif pErrorCode = 4352 then
		errorText	:=	"The remote storage service encountered a media error.";
	elseif pErrorCode = 4390 then
		errorText	:=	"The file or directory is not a reparse point.";
	elseif pErrorCode = 5014 then
		errorText	:=	"The operation could not be completed because the cluster group is not online.";
	elseif pErrorCode = 5019 then
		errorText	:=	"The operation could not be completed because the cluster resource is online.";
	elseif pErrorCode = 5033 then
		errorText	:=	"The minimum required disk space needed for logging is not available.";
	elseif pErrorCode = 5036 then
		errorText	:=	"A cluster node is not available for this operation.";
	elseif pErrorCode = 6009 then
		errorText	:=	"The specified file is read only.";
	elseif pErrorCode = 6014 then
		errorText	:=	"The disk partition does not support file encryption.";
	else
		errorText	:=	"Unknown error code!";
	endif;
epilog
	return errorText;
end;</source>
        <access>protected</access>
        <Parameter name="pErrorCode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPathAndFileNames" id="ea0de41f-093c-4186-abb4-f7e9e11cb10c">
        <source>getPathAndFileNames(pFullPath:String; pIsUnix:Boolean; pPathName:String output; pFileName:String output) protected;
// --------------------------------------------------------------------------------
// Created:		09 September 2002 by cnwdad3
//
// Purpose:		Return the path part of the fully qualified filename only (up to
//				and including the FINAL "\").
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	separatorPos	: Integer;
	fileSeparator	: String;

begin
	if pIsUnix then
		fileSeparator	:=	JSS_SEPARATOR_UNIX;
	else
		fileSeparator	:=	JSS_SEPARATOR_WIN;
	endif;
	
	separatorPos	:=	pFullPath.reversePos("\");
	
	if separatorPos = 0 then
		pPathName	:=	null;
		pFileName	:=	null;
	else
		pPathName	:=	pFullPath[1:separatorPos];
		pFileName	:=	pFullPath[(separatorPos + 1):end];
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pFullPath" type="String"/>
        <Parameter name="pIsUnix" type="Boolean"/>
        <Parameter name="pPathName" type="String" usage="output"/>
        <Parameter name="pFileName" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="interpretNodeOptions" id="6245384f-8119-4dd7-b3e3-63711ec071d7">
        <source>interpretNodeOptions(pNodeOptions:Integer; pSourceNode:Integer io; pTargetNode:Integer io):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		08 July 2002 by cnwdad2
//
// Purpose:		Splits the node options flags out into separate values.
//
// Parameters:	pNodeOptions - Specifies the source and target JADE nodes.
//				pSourceNode (IO) - The source JADE node.
//				pTargetNode (IO) - The target JADE node.
//
// Returns:		True if the node options are valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sourceClient	: Integer;
	sourceAppServer	: Integer;
	sourceDbServer	: Integer;
	targetClient	: Integer;
	targetAppServer	: Integer;
	targetDbServer	: Integer;
	
begin
	sourceClient	:=	JSSFMFileManagerService.NODE_SOURCE_CLIENT;
	sourceAppServer	:=	JSSFMFileManagerService.NODE_SOURCE_APPSERVER;
	sourceDbServer	:=	JSSFMFileManagerService.NODE_SOURCE_DBSERVER;
	targetClient	:=	JSSFMFileManagerService.NODE_TARGET_CLIENT;
	targetAppServer	:=	JSSFMFileManagerService.NODE_TARGET_APPSERVER;
	targetDbServer	:=	JSSFMFileManagerService.NODE_TARGET_DBSERVER;
	
	if (pNodeOptions - sourceClient) = targetClient then
		pSourceNode	:=	sourceClient;
		pTargetNode	:=	targetClient;
		return true;
		
	elseif (pNodeOptions - sourceClient) = targetAppServer then
		pSourceNode	:=	sourceClient;
		pTargetNode	:=	targetAppServer;
		return true;
		
	elseif (pNodeOptions - sourceClient) = targetDbServer then
		pSourceNode	:=	sourceClient;
		pTargetNode	:=	targetDbServer;
		return true;
		
	elseif (pNodeOptions - sourceAppServer) = targetClient then
		pSourceNode	:=	sourceAppServer;
		pTargetNode	:=	targetClient;
		return true;
		
	elseif (pNodeOptions - sourceAppServer) = targetAppServer then
		pSourceNode	:=	sourceAppServer;
		pTargetNode	:=	targetAppServer;
		return true;
		
	elseif (pNodeOptions - sourceAppServer) = targetDbServer then
		pSourceNode	:=	sourceAppServer;
		pTargetNode	:=	targetDbServer;
		return true;
		
	elseif (pNodeOptions - sourceDbServer) = targetClient then
		pSourceNode	:=	sourceDbServer;
		pTargetNode	:=	targetClient;
		return true;
		
	elseif (pNodeOptions - sourceDbServer) = targetAppServer then
		pSourceNode	:=	sourceDbServer;
		pTargetNode	:=	targetAppServer;
		return true;
		
	elseif (pNodeOptions - sourceDbServer) = targetDbServer then
		pSourceNode	:=	sourceDbServer;
		pTargetNode	:=	targetDbServer;
		return true;
		
	else
		self.myServiceManager.raiseJSSException1(JSS_EX_00010, pNodeOptions.String);
		return false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pNodeOptions" type="Integer"/>
        <Parameter name="pSourceNode" type="Integer" usage="io"/>
        <Parameter name="pTargetNode" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="interpretSourceNodeOptions" id="670e2044-9ef1-4375-8460-bd0d5b8e7dab">
        <source>interpretSourceNodeOptions(pNodeOptions:Integer; pSourceNode:Integer io):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		09 July 2002 by cnwdad2
//
// Purpose:		Validates the node options for a source JADE node.
//
// Parameters:	pNodeOptions - Specifies the source and target JADE nodes.
//				pSourceNode (IO) - The validated source node flag.
//
// Returns:		True if the node options are valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sourceClient	: Integer;
	sourceAppServer	: Integer;
	sourceDbServer	: Integer;
	
begin
	sourceClient	:=	JSSFMFileManagerService.NODE_SOURCE_CLIENT;
	sourceAppServer	:=	JSSFMFileManagerService.NODE_SOURCE_APPSERVER;
	sourceDbServer	:=	JSSFMFileManagerService.NODE_SOURCE_DBSERVER;
	
	if (pNodeOptions - sourceClient) = 0 then
		pSourceNode	:=	sourceClient;
		return true;
		
	elseif (pNodeOptions - sourceAppServer) = 0 then
		pSourceNode	:=	sourceAppServer;
		return true;
		
	elseif (pNodeOptions - sourceDbServer) = 0 then
		pSourceNode	:=	sourceDbServer;
		return true;
		
	else
		self.myServiceManager.raiseJSSException1(JSS_EX_00010, pNodeOptions.String);
		return false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pNodeOptions" type="Integer"/>
        <Parameter name="pSourceNode" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="interpretTargetNodeOptions" id="ec254503-ce42-4225-8591-7907a378af90">
        <source>interpretTargetNodeOptions(pNodeOptions:Integer; pSourceNode:Integer io):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		09 July 2002 by cnwdad2
//
// Purpose:		Validates the node options for a target JADE node.
//
// Parameters:	pNodeOptions - Specifies the source and target JADE nodes.
//				pTargetNode (IO) - The validated target node flag.
//
// Returns:		True if the node options are valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	targetClient	: Integer;
	targetAppServer	: Integer;
	targetDbServer	: Integer;
	
begin
	targetClient	:=	JSSFMFileManagerService.NODE_TARGET_CLIENT;
	targetAppServer	:=	JSSFMFileManagerService.NODE_TARGET_APPSERVER;
	targetDbServer	:=	JSSFMFileManagerService.NODE_TARGET_DBSERVER;
	
	if (pNodeOptions - targetClient) = 0 then
		pSourceNode	:=	targetClient;
		return true;
		
	elseif (pNodeOptions - targetAppServer) = 0 then
		pSourceNode	:=	targetAppServer;
		return true;
		
	elseif (pNodeOptions - targetDbServer) = 0 then
		pSourceNode	:=	targetDbServer;
		return true;
		
	else
		self.myServiceManager.raiseJSSException1(JSS_EX_00010, pNodeOptions.String);
		return false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pNodeOptions" type="Integer"/>
        <Parameter name="pSourceNode" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidDirectory" id="2bcb7942-33c7-47c2-b1ca-e0cd117fac9a">
        <updating/>
        <source>isValidDirectory(pDirectoryName:String; pNodeOptions:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad2
//
// Purpose:		Checks whether the specified directory is valid.
//
// Parameters:	pDirectoryName - The path name of the directory to validate.
//				pNodeOptions - Specifies the source JADE node.
//
// Returns:		True if the directory is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_DRIVE		: Boolean = false;
	IS_DIRECTORY	: Boolean = true;
	IS_FILE			: Boolean = false;
	
vars
	sourceNode	: Integer;
	
begin
	on Exception do self.xHandler(exception);
	
	self.doFileErrorSet(0, null);
	
	if self.interpretSourceNodeOptions(pNodeOptions, sourceNode) then
	
		if sourceNode = JSSFMFileManagerService.NODE_SOURCE_CLIENT then
			return self.isValidOnClient(pDirectoryName, IS_DRIVE, IS_DIRECTORY, IS_FILE);
			
		elseif sourceNode = JSSFMFileManagerService.NODE_SOURCE_APPSERVER then
			return self.isValidOnAppServer(pDirectoryName, IS_DRIVE, IS_DIRECTORY, IS_FILE);
			
		elseif sourceNode = JSSFMFileManagerService.NODE_SOURCE_DBSERVER then
			return self.isValidOnDbServer(pDirectoryName, IS_DRIVE, IS_DIRECTORY, IS_FILE);
			
		endif;
		
	endif;
epilog
	on Exception do null;
	
	self.doFileErrorCheck();
end;</source>
        <Parameter name="pDirectoryName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidDiskDirectory" id="1ee2deb5-c9ef-4079-af54-351886d70e80">
        <source>isValidDiskDirectory(pDirectoryName:String; pIsPresentationFileSystem:Boolean):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad2
//
// Purpose:		Checks whether the specified directory is valid.
//
// Parameters:	pDirectoryName - The path name of the directory to validate.
//				pIsPresentationFileSystem - For thin client nodes, this flag indicates
//					whether to use the thin client's own file system rather than the
//					Application Server node's file system.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	diskFolderObj	: FileFolder;
	
begin
	create diskFolderObj transient;
	diskFolderObj.usePresentationFileSystem	:=	pIsPresentationFileSystem;
	
	return diskFolderObj.isValidPathName(pDirectoryName);
epilog
	delete diskFolderObj;
end;</source>
        <access>protected</access>
        <Parameter name="pDirectoryName" type="String"/>
        <Parameter name="pIsPresentationFileSystem" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidDiskDrive" id="be3519e4-26e4-4ff6-9323-86f7d39bc232">
        <source>isValidDiskDrive(pDriveName:String; pIsPresentationFileSystem:Boolean):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad2
//
// Purpose:		Checks whether the specified disk drive is valid.
//
// Parameters:	pDriveName - The name of the disk drive to validate.
//				pIsPresentationFileSystem - For thin client nodes, this flag indicates
//					whether to use the thin client's own file system rather than the
//					Application Server node's file system.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	diskFolderObj	: FileFolder;
	
begin
	create diskFolderObj transient;
	diskFolderObj.usePresentationFileSystem	:=	pIsPresentationFileSystem;
	diskFolderObj.fileName	:=	pDriveName &amp; ":";
	
	if diskFolderObj.isAvailable() then
		return true;
	else
		return false;
	endif;
epilog
	delete diskFolderObj;
end;</source>
        <access>protected</access>
        <Parameter name="pDriveName" type="String"/>
        <Parameter name="pIsPresentationFileSystem" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidDiskFile" id="40d0d61f-e539-47d2-9443-7aa84fbf3540">
        <source>isValidDiskFile(pFileName:String; pIsPresentationFileSystem:Boolean):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad2
//
// Purpose:		Checks whether the specified file is valid.
//
// Parameters:	pFileName - The path name of the file to validate.
//				pIsPresentationFileSystem - For thin client nodes, this flag indicates
//					whether to use the thin client's own file system rather than the
//					Application Server node's file system.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theDiskFile	: FileFolder;
	
begin
	create theDiskFile transient;
	theDiskFile.usePresentationFileSystem	:=	pIsPresentationFileSystem;
	theDiskFile.fileName	:=	pFileName &amp; ":";
	
	if theDiskFile.isAvailable() then
		return true;
	else
		return false;
	endif;
epilog
	delete theDiskFile;
end;</source>
        <access>protected</access>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pIsPresentationFileSystem" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidDrive" id="3d0f3632-9ac9-4e0a-8ae6-0a4a4999d769">
        <updating/>
        <source>isValidDrive(pDriveName:String; pNodeOptions:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad2
//
// Purpose:		Checks whether the specified disk drive is valid.
//
// Parameters:	pDriveName - The name of the disk drive to validate.
//				pNodeOptions - Specifies the source JADE node.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_DRIVE		: Boolean = true;
	IS_DIRECTORY	: Boolean = false;
	IS_FILE			: Boolean = false;
	
vars
	sourceNode	: Integer;
	
begin
	on Exception do self.xHandler(exception);
	
	self.doFileErrorSet(0, null);
	
	if self.interpretSourceNodeOptions(pNodeOptions, sourceNode) then
	
		if sourceNode = JSSFMFileManagerService.NODE_SOURCE_CLIENT then
			return self.isValidOnClient(pDriveName, IS_DRIVE, IS_DIRECTORY, IS_FILE);
			
		elseif sourceNode = JSSFMFileManagerService.NODE_SOURCE_APPSERVER then
			return self.isValidOnAppServer(pDriveName, IS_DRIVE, IS_DIRECTORY, IS_FILE);
			
		elseif sourceNode = JSSFMFileManagerService.NODE_SOURCE_DBSERVER then
			return self.isValidOnDbServer(pDriveName, IS_DRIVE, IS_DIRECTORY, IS_FILE);
			
		endif;
		
	endif;
epilog
	on Exception do null;
	
	self.doFileErrorCheck();
end;</source>
        <Parameter name="pDriveName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidFile" id="f3134bdf-ff2f-4836-ac3f-d8413c4ba911">
        <updating/>
        <source>isValidFile(pFileName:String; pNodeOptions:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad2
//
// Purpose:		Checks whether the specified file is valid.
//
// Parameters:	pFileName - The path name of the file to validate.
//				pNodeOptions - Specifies the source JADE node.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_DRIVE		: Boolean = false;
	IS_DIRECTORY	: Boolean = false;
	IS_FILE			: Boolean = true;
	
vars
	sourceNode	: Integer;
	
begin
	on Exception do self.xHandler(exception);
	
	self.doFileErrorSet(0, null);
	
	if self.interpretSourceNodeOptions(pNodeOptions, sourceNode) then
	
		if sourceNode = JSSFMFileManagerService.NODE_SOURCE_CLIENT then
			return self.isValidOnClient(pFileName, IS_DRIVE, IS_DIRECTORY, IS_FILE);
			
		elseif sourceNode = JSSFMFileManagerService.NODE_SOURCE_APPSERVER then
			return self.isValidOnAppServer(pFileName, IS_DRIVE, IS_DIRECTORY, IS_FILE);
			
		elseif sourceNode = JSSFMFileManagerService.NODE_SOURCE_DBSERVER then
			return self.isValidOnDbServer(pFileName, IS_DRIVE, IS_DIRECTORY, IS_FILE);
			
		endif;
		
	endif;
epilog
	on Exception do null;
	
	self.doFileErrorCheck();
end;</source>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidOnAppServer" id="90eecbee-3653-4236-a58d-16532b5d867c">
        <executionLocation>client</executionLocation>
        <source>isValidOnAppServer(	pName:String;
					pIsDrive:Boolean;
					pIsDirectory:Boolean;
					pIsFile:Boolean):Boolean protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad2
//
// Purpose:		Validates a disk drive, directory or file on the Application Server
//				JADE node.
//
// Parameters:	pName - The name of the disk node to validate.
//				pIsDrive - True if the node is a disk drive.
//				pIsDirectory - True if the node is a disk directory.
//				pIsFile - True if the node is a disk file.
//
// Returns:		True if the node is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_PRESENTATION_FILE_SYSTEM	: Boolean = false;
	
begin
	if pIsDrive then
		return self.isValidDiskDrive(pName, IS_PRESENTATION_FILE_SYSTEM);
	elseif pIsDirectory then
		return self.isValidDiskDirectory(pName, IS_PRESENTATION_FILE_SYSTEM);
	elseif pIsFile then
		return self.isValidDiskFile(pName, IS_PRESENTATION_FILE_SYSTEM);
	else
		return false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pName" type="String"/>
        <Parameter name="pIsDrive" type="Boolean"/>
        <Parameter name="pIsDirectory" type="Boolean"/>
        <Parameter name="pIsFile" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidOnClient" id="5fb38fa9-5c19-4e70-9862-6eb912959e24">
        <executionLocation>client</executionLocation>
        <source>isValidOnClient(	pName:String;
					pIsDrive:Boolean;
					pIsDirectory:Boolean;
					pIsFile:Boolean):Boolean protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad2
//
// Purpose:		Validates a disk drive, directory or file on the client JADE node.
//
// Parameters:	pName - The name of the disk node to validate.
//				pIsDrive - True if the node is a disk drive.
//				pIsDirectory - True if the node is a disk directory.
//				pIsFile - True if the node is a disk file.
//
// Returns:		True if the node is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIsDrive then
		return self.isValidDiskDrive(pName, process.isUsingThinClient());
	elseif pIsDirectory then
		return self.isValidDiskDirectory(pName, process.isUsingThinClient());
	elseif pIsFile then
		return self.isValidDiskFile(pName, process.isUsingThinClient());
	else
		return false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pName" type="String"/>
        <Parameter name="pIsDrive" type="Boolean"/>
        <Parameter name="pIsDirectory" type="Boolean"/>
        <Parameter name="pIsFile" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidOnDbServer" id="0fbe44d6-643b-4afd-b897-73065a386823">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>isValidOnDbServer(	pName:String;
					pIsDrive:Boolean;
					pIsDirectory:Boolean;
					pIsFile:Boolean):Boolean updating, protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad2
//
// Purpose:		Validates a disk drive, directory or file on the Database Server
//				JADE node.
//
// Parameters:	pName - The name of the disk node to validate.
//				pIsDrive - True if the node is a disk drive.
//				pIsDirectory - True if the node is a disk directory.
//				pIsFile - True if the node is a disk file.
//
// Returns:		True if the node is valid, otherwise false.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	IS_PRESENTATION_FILE_SYSTEM	: Boolean = false;
	
begin
	on Exception do self.xHandlerServer(exception);
	
	if pIsDrive then
		return self.isValidDiskDrive(pName, IS_PRESENTATION_FILE_SYSTEM);
	elseif pIsDirectory then
		return self.isValidDiskDirectory(pName, IS_PRESENTATION_FILE_SYSTEM);
	elseif pIsFile then
		return self.isValidDiskFile(pName, IS_PRESENTATION_FILE_SYSTEM);
	else
		return false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pName" type="String"/>
        <Parameter name="pIsDrive" type="Boolean"/>
        <Parameter name="pIsDirectory" type="Boolean"/>
        <Parameter name="pIsFile" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="openDiskFile" id="6584f729-f741-479c-a708-3644263f8e3b">
        <updating/>
        <source>openDiskFile(	pFileName:String;
				pIsPresentationFileSystem:Boolean;
				pIsForUpdate:Boolean;
				pDiskFileObj:File output):Decimal updating, protected;
// --------------------------------------------------------------------------------
// Created:		27 June 2002 by cnwdad1
//
// Purpose:		Opens a disk file of the specified name.
//
//				**********************************************************************
//				* Note that it is the responsibility of the calling method to delete *
//				* the file object.                                                   *
//				**********************************************************************
//
// Parameters:	pFileName - The name of the file to open.
//				pIsPresentationFileSystem - If true, then the file is on the machine
//					that is running the Thin (prsentation) Client, as opposed to the
//					machine that is running the Application Server.  If false, then
//					the Application Server is assumed.
//				pIsForUpdate - If true, then the file is going to be updated, so
//					we'll open the file is Shared Exclusive.  If false, then we're
//					only going to read the file, so we'll open the file as Shared
//					Read-Write.
//				pDiskFileObj - The newly opened disk file.
//
// Returns:		The length of the file.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theDiskFile		: File;
	
begin
	create theDiskFile transient;
	
	if pIsForUpdate then
		theDiskFile.mode		:=	File.Mode_Output;
		theDiskFile.shareMode	:=	File.Share_Exclusive;
	else
		theDiskFile.mode		:=	File.Mode_Input;
		theDiskFile.shareMode	:=	File.Share_ReadWrite;
	endif;
	
	theDiskFile.usePresentationFileSystem	:=	pIsPresentationFileSystem;
	theDiskFile.kind						:=	File.Kind_Binary;
	theDiskFile.fileName					:=	pFileName;
	
	if theDiskFile.tryOpen() then
		pDiskFileObj	:=	theDiskFile;
		
		return theDiskFile.fileLengthDec();
	else
		self.doFileErrorSet(theDiskFile.errorCode(), pFileName);
		
		return 0;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pIsPresentationFileSystem" type="Boolean"/>
        <Parameter name="pIsForUpdate" type="Boolean"/>
        <Parameter name="pDiskFileObj" type="File" usage="output"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
