    <JadeMethod name="btnGraphic_click" id="5ba844b1-0555-4917-8958-d15e43829986">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnGraphic_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 Apr 2010	cnwer1	Initial creation
23 May 2012 cnwer1	Par 29611 
*/

vars
	lc 				: CM_LocationsController;
	strLocation 	: String;
	dtoEntry 		: DTO_RTQueueEntry;
	ti				: CM_TrackedItem;
	dtoEntryArray 		: DTO_RTQueueEntryArray;
begin
	self.addInfoDisplay(null);

	if not( self.frmTaskTable.visible or self.frmGetTask.visible) and 
	  (not self.isGFXViewVisible) and 
	  (  self.frmMoveTbl.visible or self.isDirectorViewVisible or self.isEnquiryMode) and 
	  self.canGFXDisplay(lc, strLocation, ti, true) then
	  
		self.doShowGFX(lc, ti, strLocation);
			
		//epr par 29611 23/5/12 
		//epr par 29611 23/5/12 
		if not self.isEnquiryMode and not app.myVMAgent.showingTaskList then
			create dtoEntryArray transient;
			self.myVMAgent.myMachQEntryTableSynchAgent.doFindWorkingDTOEntries(dtoEntryArray,false,null);
			self.setupFrmMoveFields(dtoEntryArray.first,null);
		endif;
	else
		if self.frmTaskTable.visible or self.frmGetTask.visible then
			self.doShowGFXForSelectedTask();
			self.frmMoveTbl.visible := false;	//26 Mar 2013	NDL	Par 31278
			return;
		endif;
		
		self.hideGFXFrames();
		self.resizeForNoGraphics();
		
		dtoEntry:=self.getWorkingDTOEntry();
		
		if dtoEntry &lt;&gt; null then
			if dtoEntry.isForDirectorTask then
				self.frmDirector.visible:=true;
			else
				if self.myVMAgent.getNextMoveState = VehicleMountedGenericAgent.ACCEPT_TASK then
					self.frmMoveTbl.visible:=false;
					self.frmGetTask.visible:=true;
				else
					self.frmMoveTbl.visible:=true;
				endif;
			endif;
		else
			if self.isShowOverstowCargo then
				if self.isSettingDown then
					self.frmMoveTbl.visible:=true;
				else
					self.frmDirector.visible:=true;
				endif;
			//epr par 25047 19/7/2010
			elseif self.isEnquiryMode then
				if self.btnAccept.caption &lt;&gt; app.getErrorString(Accept) then
					self.frmMoveTbl.visible:=true;
					self.frmMove.visible:=true;
				else
					self.frmMove.visible:=false;
					self.frmTaskTable.visible:=true;
				endif;
				
			else
				
				self.frmMove.visible:=false;
				//epr par 29611 22/5/12
				if app.myVMAgent.showingTaskList then
					self.frmTaskTable.visible:=true;
				else
					self.frmGetTask.visible:=true;
				endif;
			endif;
		endif;
		
		
	endif;
epilog
	delete dtoEntryArray;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
