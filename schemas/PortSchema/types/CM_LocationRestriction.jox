    <JadeMethod name="isBlockStack" id="76d4d012-4682-4bc4-a20a-403b9a819a2a">
        <methodInvocation>mapping</methodInvocation>
        <source>isBlockStack(set: Boolean; value: Boolean io) mapping;
vars
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	value := false;
	
	if self.myTerminalArea = null then
		return;
	endif;
	if self.myTerminalArea.type &lt;&gt; TA_TYPE_STRADDLE_STACK
	and self.myTerminalArea.type &lt;&gt; TA_TYPE_FORK_LIFT_STACK 
	and self.myTerminalArea.type &lt;&gt; TA_TYPE_RTG then
		value := true;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="operatorCodes" id="486447e4-0a86-4299-bcb1-67f3999d98e2">
        <methodInvocation>mapping</methodInvocation>
        <source>operatorCodes(set: Boolean; _value: String io) mapping;
//Just gets the operator codes and returns them as in line string
vars
   op : CM_Operator;
begin
 	if set then
  		app.raiseSetVirtualError(class.name, method.name);
		return;
 	endif;

	if self.allOperators.isEmpty then
		_value := null;
		return;
	endif;
	foreach op in self.allOperators do
		_value := _value &amp; op.code.trimRight &amp; ", ";
	endforeach;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="58528b36-bb98-40ca-ad57-ba3bf2826821">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	theProxy	: CM_LocationRestriction;
	completedOK		: Boolean;
	
begin
	theProxy := inheritMethod();

	self.allCommodityGroups.copy(theProxy.allCommodityGroups);
	self.allCargoTypes.copy(theProxy.allCargoTypes);
	self.allConsignees.copy(theProxy.allConsignees);
	self.allDischargePorts.copy(theProxy.allDischargePorts);
	self.allOperators.copy(theProxy.allOperators);
	self.allVoyages.copy(theProxy.allVoyages);
	self.allStopsToCheck.copy(theProxy.allStopsToCheck);

	theProxy.myTerminalArea	:= self.myTerminalArea;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return theProxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete theProxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeVoyage" id="bf8eb7e7-e42c-434a-a444-995b51e7efa8">
        <updating/>
        <source>removeVoyage(_voyage : CM_Voyage) updating;
/*
 ------------------------------------------------------------------------
Created:			12 November 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
begin
	if _voyage = null then
		return;
	endif;
	if not self.allVoyages.includes(_voyage) then
		return;
	endif;
	exclusiveLock(self);
	self.allVoyages.remove(_voyage);
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="56469454-072e-414a-8a81-41330a486b2e">
