    <JadeMethod name="setupForm" id="d3653438-a303-4870-83e6-98357c5695ec">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

	errMsg : String;

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	self.setupCmdButtons(3, app.getErrorString(Complete), app.getErrorString(Process_GC), app.getErrorString(Back), null, null );
	
	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	here := self.myMobileGenericAgent.myWorkPoint.getDefaultDischargeLane(false);
	if here = null then
		errMsg := app.getErrorString(Work_point_not_with_defau_disc);
		app.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only );
	endif;
	
	
	if app.myMobileCargoFindAgent.myTrackedItemToProcess &lt;&gt; null then
		//Returning from a search
		self.setMyTrackedItem(	app.myMobileCargoFindAgent.myTrackedItemToProcess );
	elseif self.getSessionAgent().mySelectedTI &lt;&gt; null then
		//returning from adding damage
		self.setMyTrackedItem(self.getSessionAgent().mySelectedTI );
	endif;
	
	inheritMethod();
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showDirtyButton" id="5219e853-144d-4454-af1f-82586b2f4d06">
        <source>showDirtyButton():Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

	iter : Iterator;
	tiTrx : CM_TITransaction;
	includesTrx : Boolean;
	extraData : Any;

begin

	if self.myTrackedItem = null then
		return false;
	endif;

	iter := self.myTrackedItem.allTransactions.createIterator;
	while iter.next( tiTrx) do
		if tiTrx.type &lt;&gt; TRANS_TYPE_NEEDSWASH then
			continue;
		endif;
		extraData := tiTrx.getExtraData(TrnsExtraDataContext);
		if extraData &lt;&gt; null and extraData.String = "MOB_HHVehicleLanderMove" then
			includesTrx := true;
			break;
		endif;	
	endwhile;
	
	return not includesTrx; // i.e. if we already have needs wash trx, don't show the button.

epilog

	delete iter;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3c763d77-5e96-4f5c-8de7-2c28465bffd6">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 May 2016.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021165, locale);
	btnDamage.translateCaption(Xlat_0021166, locale);
	btnDirty.translateCaption(Xlat_0021252, locale);
	btnLabel.translateCaption(Xlat_0021167, locale);
	lblCargoId.translateCaption(Xlat_0021168, locale);
	lblLocation.translateCaption(Xlat_0021169, locale);
	lblNoDamage.translateCaption(Xlat_0021170, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="0a54f8cf-8939-4b98-a8f6-f192cf4b2e47">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

begin

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := self.lblCargoId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="f4062097-e2fe-4b3c-a342-ea27bb355c84">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

begin

	//18 Aug 2016	NDL	2567
	if self.doTFS2567Rules() then
		//We will have found the correctly labelled cargo item
		//or found a single matching cargo item from the bar code
		//version and updated its alternate id to match the raw bar-code value. 
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := 0;
		return;
	endif;
	
	// If we are here we didn't find one using the new process, and need to do the old stuff so we throw the 
	// same old error messages, and or present the searcher.

//	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//05 Jul 2016	NDL	TFS 2275

	if self.txtCargoId.text.trimBlanks = null then
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	else
		if ( self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id &lt;&gt; self.txtCargoId.text )
		or ( self.myTrackedItem = null and self.txtCargoId.text &lt;&gt; self.lblCargoId.caption.toUpper )
		then
			self.selectCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;
	

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateComplete" id="731be78d-3b21-4590-9184-f69e85d96a98">
        <source>validateComplete(lc : CM_LocationsController output) : Boolean protected;
/*

Date		Who		Reason
08 February 2017	cnwer1	Initial creation TFS 3194

*/

vars
	errMsg : String;

begin
	if self.myTrackedItem = null then
		errMsg := app.getErrorString(Vehicle_selected);
		return false;
	endif;
	lc := self.myTrackedItem.myPrimaryQueuedLocation;
	if lc = null then
		lc := self.myTrackedItem.myPrimaryPlannedLocation;
	endif;
	if lc = null then
		errMsg := app.getErrorString1( Not_queued_anywhere, self.myTrackedItem.id);
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="lc" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
