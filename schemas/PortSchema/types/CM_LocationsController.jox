    <JadeMethod name="adjustStock" id="c1581880-6b0e-4099-9635-c452b15a19d6">
        <updating/>
        <source>adjustStock(_product : CM_Product; _date : Date;
			_type : Integer; _moveOut : Boolean; 
			_ti : CM_TrackedItem; _tiUpdCntrl : CMIF_TIUpdateController;
			_txn : CM_TITransaction input) updating;
// ---------------------------------------------------------------------------
// Created:     27 May 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSOHLocation	: CM_SOHLocation;
	
begin

	if _product = null then
		// Needed to allow deletion of items that have become corrupted CNWDW1
		executeWhen JMTDevelopmentEnvironment;
			return;
		endExecuteWhen;
		
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to adjust stock for null product');
		return;
	endif;

	// PAR 19968 - for fixups do not have a update controller
	//if _tiUpdCntrl = null then
	//	app.raiseUnexpectedProgramError(class.name, method.name, 'Null _tiUpdCntrl');
	//	return;
	//endif;

	tmpSOHLocation := self.getSOHLocationForProduct(_product);
	tmpSOHLocation.adjustStockOnHand(_date, _type, _moveOut, _ti, _tiUpdCntrl, _txn, true);

end;</source>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_moveOut" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiUpdCntrl" type="CMIF_TIUpdateController"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
