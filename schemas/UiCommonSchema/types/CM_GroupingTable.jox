    <JadeMethod name="getGroupingETRow" id="648442a3-cfd2-490f-b452-8c680991434b">
        <source>getGroupingETRow():EntTableRow protected;
// ---------------------------------------------------------------------------
// Created:     11 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str	:String;
	row	:EntTableRow;
begin
	if not self.allGroupingETRows.isEmpty then
		// right now we only have one
		return self.allGroupingETRows[1];
	endif;

	return null;
epilog

end;</source>
        <access>protected</access>
