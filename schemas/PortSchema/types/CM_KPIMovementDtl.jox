    <JadeMethod name="isGC" id="25b2d460-7701-483e-81e0-608071a80ae7">
        <source>isGC() : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2012	cnwdw1	Initial creation
*/
vars
	cargoType: CM_CargoType;
begin
	cargoType := app.myRoot.getCargoTypeFromAbbrev(self.cargoType);
	if cargoType = null then
		return false;
	endif;
	
	return cargoType.getTiBehaviourType = TIBehaviourType_BreakBulk;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInstantMove" id="425022d3-ac14-40b5-a2bf-4bb62414536f">
        <source>isInstantMove() : Boolean;

vars

begin
	if self.allMovementLegs.size = 1 and self.allMovementLegs.first.machineId = null then
		return true;
	endif;
	
	return false;

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
