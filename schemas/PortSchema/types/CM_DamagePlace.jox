    <JadeMethod name="validateForDelete" id="4c0a277b-343a-4fe8-854e-061357b055db">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if self.allDamageInstances.isNotEmpty then
		app.raiseCMException1(Cannot_Delete_DamagePlace, self.code, null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="428c7a65-27fa-49d3-a655-61c350988306">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	realDamagePlace,
	existingDamagePlace			: CM_DamagePlace;
begin
	if self.code = null then
		app.raiseCMException(Input_required_field_code, ETRow_Code, self);
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_desc, ETRow_Description, self); 
	endif;
	
	
	existingDamagePlace	:= self.myTerminal.allDamagePlaces[self.code];
	realDamagePlace		:= self.pxyGetRealObject();
	
	if existingDamagePlace &lt;&gt; null and
	   (realDamagePlace = null or //in which case we are trying add a new one that is duplicate
	   realDamagePlace &lt;&gt; existingDamagePlace) //in which case we are trying update one to be same as another
	   then
		app.raiseCMException1(DamagePlace_code_already_exist, self.code.String, null, null); 
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
