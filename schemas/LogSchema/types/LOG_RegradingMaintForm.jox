    <JadeMethod name="loadRegradeReasons" id="0c85ec13-d0fb-4421-8cfc-592fcecb60c1">
        <source>loadRegradeReasons() protected;
// ---------------------------------------------------------------------------
// Created:     28 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	regradeDict			: CM_LogRegradeCodeByCodeDict;
	regradeCode			: CM_LogRegradeCode;
begin

	regradeDict := app.myRoot.allLogRegradeCodes;
	if regradeDict.isEmpty then
		return;
	endif;
	
	foreach regradeCode in regradeDict do
		self.cmbRegrade.itemObject[self.cmbRegrade.addItem(regradeCode.code &amp; ' - ' &amp; regradeCode.description)] := regradeCode;
	endforeach;

	// Don't set listobject yet
	self.cmbRegrade.listIndex := -1;
//	self.tblActionData.setValueByName(ETRow_RegradeReason, self.cmbRegrade.text);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadRemainingCombos" id="c5c9bb04-d007-42f7-bf08-a0133f34af39">
        <source>loadRemainingCombos(_grade : CM_LogGrade; _tbl : CM_EntryTable input;
		_cmbType, _cmbTreat, _cmbLength : ComboBox input) protected;

vars

begin

	_cmbType.clear;
	_cmbTreat.clear;
	_cmbLength.clear;
	_cmbType.CMUI_ComboLogType.setObjectAndGrade(null,null);
	_cmbTreat.CMUI_ComboLogTreatment.setObjectAndGrade(null,null);
	_cmbLength.CMUI_ComboLogLength.setObjectAndGrade(null,null);
	_tbl.setValueByName(ETRow_Length, null);
	_tbl.setValueByName(ETRow_Treatment, null);
	_tbl.setValueByName(ETRow_Type, null);

//	if _grade &lt;&gt; null then
//		self.myAssistant.comboBoxAddCode(_cmbType,  _grade.allLogTypes, null, true);
//		self.myAssistant.comboBoxAddCode(_cmbTreat,  _grade.allLogTreatments, null, true);
//		self.myAssistant.comboBoxGeneral(_cmbLength,  _grade.allLogLengths);
//	endif;
	_cmbType.CMUI_ComboLogType.setObjectAndGrade(null,_grade);
	_cmbTreat.CMUI_ComboLogTreatment.setObjectAndGrade(null,_grade);
	_cmbLength.CMUI_ComboLogLength.setObjectAndGrade(null,_grade);
	

end;</source>
        <access>protected</access>
        <Parameter name="_grade" type="CM_LogGrade"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_cmbType" type="ComboBox" usage="input"/>
