    <JadeMethod name="grpPhotos_doTabOrder" id="d6ff77ab-69e6-4349-9869-cc7028ebf605">
        <controlMethod name="CMUI_FieldGeneric::doTabOrder"/>
        <methodInvocation>event</methodInvocation>
        <source>grpPhotos_doTabOrder(_startTab: Integer):Integer protected;
/*

Date		Who		Reason
24 October 2013	cnwer1	Initial creation PAR 31845

*/

vars
tabOrder	: Integer;

begin
	tabOrder 						:= _startTab;
	tabOrder 						:= tabOrder + 1;
	self.btnDamage.tabIndex	:= tabOrder;
	return tabOrder;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_startTab" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="grpVehicleBook_doAlignCtrls" id="7e47a73d-636f-4554-8ae7-a689203838a5">
        <controlMethod name="CMUI_FieldGeneric::doAlignCtrls"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>grpVehicleBook_doAlignCtrls(_fieldGeneric: CMUI_FieldGeneric input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	// put button on the right hand side, and stretch the label to fit 
	self.btnVehicleBook.move(_fieldGeneric.width - self.btnVehicleBook.width, 0, self.btnVehicleBook.width, _fieldGeneric.height);
	self.lblVehicleBook.move(self.grpVehicleBook.width - self.defaultControlWidth, 0, self.grpVehicleBook.width - self.defaultControlWidth - self.btnVehicleBook.width, _fieldGeneric.height);
	self.lblVehicleBook.borderStyle := self.lblVehicleBook.BorderStyle_None;

epilog

end;</source>
        <Parameter name="_fieldGeneric" type="CMUI_FieldGeneric" usage="input"/>
    </JadeMethod>
    <JadeMethod name="grpVehicleBook_doTabOrder" id="40bdd5e6-6fa1-4f37-aa1c-7033e9a6a541">
        <controlMethod name="CMUI_FieldGeneric::doTabOrder"/>
        <methodInvocation>event</methodInvocation>
        <source>grpVehicleBook_doTabOrder(_startTab: Integer):Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2013	cnwndl1	Initial creation

*/

vars
	tabOrder	: Integer;

begin
	tabOrder 						:= _startTab;
	tabOrder 						:= tabOrder + 1;
	self.btnVehicleBook.tabIndex	:= tabOrder;
	return tabOrder;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_startTab" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleException" id="96b1dc9b-c90c-491d-8b3a-2c31667aff93">
        <source>handleException(exc : Exception; exceptionFound : Boolean output) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 March 2010	cnwmh5	Initial creation

*/

vars

begin
	// total weight field exceed max length allowed
	if exc.errorCode = 14079 then
		exceptionFound := true;
		return Ex_Resume_Next;
	endif;
epilog

end;</source>
        <Parameter name="exc" type="Exception"/>
        <Parameter name="exceptionFound" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasAttachments" id="516eaa27-040f-446c-889c-75c23c8a6e21">
        <source>hasAttachments() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars

begin
	return not self.allAttachments.isEmpty;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasHSCode" id="e8ad929c-27b3-4ed7-8de5-bf7fcd9837d1">
        <source>hasHSCode() : Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 19 December 2022
TFS#		: 55584
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if app.myRoot.allHSCodesActive.isEmpty then		
		return false;	
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasPrenoteVolumeChanged" id="e1c62d13-abd5-4fd4-9aa4-4a31cec171be">
        <source>hasPrenoteVolumeChanged() : Boolean;
/*

Date		Who		Reason
05 April 2016	cnwer1	Initial creation TFS 1707

*/

vars
	formVolume,
	totalVolume,
	unitVolume : Decimal[14,4];
	 
begin
	if self.hasPreNote() and self.myTI.isBulkByQuantity then
		unitVolume:= self.myTI.totalVolume/self.myTI.totalQuantity;
		totalVolume:=unitVolume * self.txtNumItems.getInteger;
		formVolume:=self.tblTotalVolume.getConvertedValue;
		return totalVolume &lt;&gt; formVolume;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasPrenoteWeightChanged" id="0b289b81-eef1-49aa-85a2-44268105b677">
        <source>hasPrenoteWeightChanged() : Boolean protected;
/*

Date		Who		Reason
04 April 2016	cnwer1	Initial creation TFS 1707

*/

vars
	formWeight,
	totalWeight,
	unitWeight : Decimal[14,4];
	 
begin
	if self.hasPreNote() and self.myTI.isBulkByQuantity then
		unitWeight:= self.myTI.totalWeight/self.myTI.totalQuantity;
		totalWeight:=unitWeight * self.txtNumItems.getInteger;
		formWeight:=self.tblTotalWeight.getConvertedValue;
		return totalWeight &lt;&gt; formWeight;
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="haveProductAttributesChanged" id="2b1c5035-b005-41cd-a3a9-6052cc2c0807">
        <source>haveProductAttributesChanged(_existingSubCargo, _newSubCargo : CM_Product) : Boolean;
/*
Purpose:			Check whether attributes have changed between two products

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2009	cnwdap1	Initial creation
*/
vars

begin
	if _existingSubCargo = null or _newSubCargo = null then
		return true;
	endif;
	if _existingSubCargo = _newSubCargo then
		return false;
	endif;
	
	if _existingSubCargo.getMyWidth().getIsViewable() &lt;&gt; _newSubCargo.getMyWidth().getIsViewable() then
		return true;
	elseif _existingSubCargo.myWidthString.getIsViewable() &lt;&gt; _newSubCargo.myWidthString.getIsViewable() then
		return true;
	elseif _existingSubCargo.getMyLength().getIsViewable() &lt;&gt; _newSubCargo.getMyLength().getIsViewable() then
		return true;
	elseif _existingSubCargo.myLengthString.getIsViewable() &lt;&gt; _newSubCargo.myLengthString.getIsViewable() then
		return true;
	elseif _existingSubCargo.getMyHeight().getIsViewable() &lt;&gt; _newSubCargo.getMyHeight().getIsViewable() then
		return true;
	elseif _existingSubCargo.myHeightString.getIsViewable() &lt;&gt; _newSubCargo.myHeightString.getIsViewable() then
		return true;
	elseif _existingSubCargo.myQuantity.getIsViewable() &lt;&gt; _newSubCargo.myQuantity.getIsViewable() then
		return true;
	elseif _existingSubCargo.getMyWeight().getIsViewable() &lt;&gt; _newSubCargo.getMyWeight().getIsViewable() then
		return true;
	elseif _existingSubCargo.myVolume.getIsViewable() &lt;&gt; _newSubCargo.myVolume.getIsViewable() then
		return true;
	elseif _existingSubCargo.myType.getIsViewable() &lt;&gt; _newSubCargo.myType.getIsViewable() then
		return true;
	elseif _existingSubCargo.myDensityDec.getIsViewable() &lt;&gt; _newSubCargo.myDensityDec.getIsViewable() then		// ### TFS 52193 22Nov2021 NAVPW1
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_existingSubCargo" type="CM_Product"/>
        <Parameter name="_newSubCargo" type="CM_Product"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideROBforExportPN" id="dd608517-e244-4699-a20f-967b3a675972">
        <source>hideROBforExportPN( _robIndex : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2021	navndl1	Initial creation	TFS 51771

*/

vars

begin

	if not self.myTerminal.getConfig( GateHideROBforExportPN ).Boolean then
		return;
	endif;
	
	if not self.isFlexiGateForm then
		return;
	endif;
	
	if _robIndex &lt; 1 or _robIndex &gt; self.cmbImexStatus.listCount then
		return;
	endif;
	
	self.cmbImexStatus.setItemEnabled( _robIndex, false );
	
epilog

end;</source>
        <Parameter name="_robIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideSelectedControls" id="890795fa-8233-42e0-aee8-587820bd14b3">
        <updating/>
        <source>hideSelectedControls() updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#			Description
============================================================================
20/08/2009	cnwjk3					Initial creation
04/11/2009	cnwdap1	CCMS MES 1017 	new over dimension fields don't apply to this form so hide them
23/11/2009	cnwdap1	#21658 			For Trailer and Vehicle Cargo Types, show length/width/height dimensions fields
21/01/2010	cnwjre1	CCMS 1071 		BOL number and item replace booking ref and item for on-ship cargo
04/02/2010	cnwdap1	PAR #21867 		Treat "Track as Vehicle" cargo types the same as the system "CAR" Cargo Type
15/02/2010	cnwdap1	PAR #22088 		For system cargo type Timber, show length, width and height text boxes 
									(this is a system cargo type nad has no products, but still have a requirement to capture some dimensions details)
05/03/2010	cnwdap1	PAR #22655 		Default to Location being hidden, and then only show under the right conditions
15/03/2010	cnwdap1	PAR #23190 		Refactor product attribute showing/hiding
18/12/2012	cnwpjs	PAR #30787 		Voyage rationalisation
27/03/2013	cnwdap1	PAR #31155 
					CCMS SFW 1321 	Imperial Measurements
13/05/2013	cnwdap1	PAR #31472 		Create LCL Cargo - show height/length/width
12/09/2013	cnwdap1	PAR #32215 		New Car attributes, only show txtNumItems for break-bulk with "Duplicate ID Allowed"
08/04/2014	cnwdap1	PAR #33606 		CCMS SFW 1366 Bulk - don't show Mark, Mark Number or Colour for Bulk cargo types
20/08/2014	cnwma1	PAR #34749 		Creating cargo
09/06/2015	cnwdap1	PAR #36421 		Hide/show Is Hazardous field according to terminal config setting
12/10/2016	cnwma1	TFs #2636  		Query on Tranship to Port visibility Prenote / Gate Screens
20/02/2018 	cnwer1	TFS 7756   		removed redundant hiding of length width etc is done in doHideShowProductAttributes
22/03/2019	jlgka1	TFS 43816		Fixed Floating labels and text boxes on Add Cargo form.
19/12/2022	jlika1	TFS 55584  		HS Code Combobox Usage
10/08/2023	jlika1	TFS 59741 59148 POB | Port of Origin on Add New Cargo
01/10/2025	navdap1	MTN-36141 AAT | Rotabox Creation (EDI/API/Manual)
============================================================================*/
vars
	product		: CM_Product;
	cargoType	: CM_CargoType;
	entDef		: EntTableDef;					// PAR #36421
	entRow		: EntTableRow;					// PAR #36421
	isoType		: CM_ISOType;			// MTN-36141
begin
	inheritMethod();
	// hide sub terminal if this terminal doesn't have any
	self.cmbSubTerminal.isHidden := not self.myTerminal.isSubTerminalsOn;

	// CCMS 1071 show/hide BOL/booking fields if onship or otherwise
	// also hide other fields not used by on-ship
	if self.isOnshipForm then
		self.txtBookingRef.isHidden := true;
		self.cmbBRItem.isHidden := true;
		self.txtBOLNumber.isHidden := false;
		self.cmbBOLItem.isHidden := false;
		self.txtLocation.isHidden := true;
	
		self.cmbCargoLocation.isHidden := true;
		self.btnCargoId.visible := (self.updateMode = Mode_Add);		
	else
		//28 Sep 2011	NDL	Par 28285
		if ( self.isPreNoteForm or self.isFlexiGateForm ) then
			self.btnCargoId.visible := (self.updateMode = Mode_Add);
		endif;
	
		self.txtBookingRef.isHidden := false;
		self.cmbBRItem.isHidden := false;
		self.txtBOLNumber.isHidden := true;
		self.cmbBOLItem.isHidden := true;
		self.cmbCargoLocation.isHidden := true;
	endif;
	
	
	self.cmbLoadPort.isHidden := not self.isOnshipForm; // epr par  34945 20/10/14
	self.cmbTranship.isHidden := not self.myTerminal.getConfig(ShowPortOfCallTranship).Boolean;
	
	self.cmbPortOfOrigin.isHidden := not self.isOnshipForm;	// jlika1 TFS 59741		
	
	self.chkOOTL.isHidden:=not self.isOnshipForm;
	self.frmCoordinates.isHidden:=not self.isOnshipForm;
	
	if self.myVoyage &lt;&gt; null then
		if  self.myVoyage.myROROStructure &lt;&gt; null and not self.isAttachmentForm then // jlgka1 TFS 43816
			self.chkOOTL.visible:=  self.isOnshipForm;// epr par  34945 20/10/14
			self.frmCoordinates.visible:= self.isOnshipForm;// epr par  34945 20/10/14
		else
			self.chkOOTL.isHidden:= true;// epr par  34945 20/10/14
			self.frmCoordinates.isHidden:=true;// epr par  34945 20/10/14	
		endif;
	endif;
	
	// default to hiding Self Propelled, Radio and Trailer/Generator Type
	self.chkRadio.isHidden			:= true;
	self.chkSelfPropelled.isHidden	:= true;
	self.cmbTrailerType.isHidden	:= true;
	self.cmbGeneratorType.isHidden	:= true;
	
	// default to hiding all car-related attributes				// PAR #32215
	self.lstColour.isHidden			:= true;					// PAR #32215
	self.cmbVehicleMake.isHidden	:= true;					// PAR #32215
	self.cmbVehicleModel.isHidden	:= true;					// PAR #32215
	self.cmbVehicleType.isHidden	:= true;					// PAR #32215
	self.txtYear.isHidden			:= true;					// PAR #32215
	self.txtTracking1.isHidden		:= true;					// PAR #32215
	self.txtTracking2.isHidden		:= true;					// PAR #32215
	self.txtDocsReceived.isHidden	:= true;					// PAR #32215
	self.txtDocsSent.isHidden		:= true;					// PAR #32215
	self.txtDocsCleared.isHidden	:= true;					// PAR #32215
	self.txtDocsReturned.isHidden	:= true;					// PAR #32215
	self.txtDoors.isHidden			:= true;					// PAR #32215
	self.chkNew.isHidden			:= true;					// PAR #32215
	
	self.cmbISOType.isHidden			:= true;		//+cnwml2 PAR25323
	
	self.cmbContentsCargoType.isHidden := true;		// MTN-36141
	self.cmbProdType.isHidden := true;				// MTN-36141
	
	// PAR #23442 Default to hiding preSlung and Wet
	self.chkPreSlung.isHidden 		:= true;
	
	self.chkWet.isHidden			:= true;
	if self.hasHSCode() then
		self.cmbHSCode.isHidden := false; 
		self.btnHSCode.visible := true;
	else
		self.cmbHSCode.isHidden := true; 
		self.btnHSCode.visible := false;
	endif;
	
	cargoType := self.cmbType.getObject().CM_CargoType;
	if cargoType &lt;&gt; null then
		self.cmbSubCargo.isHidden := not cargoType.hasProductTypes ;
		self.cmbCommodity.isHidden := not cargoType.isCommodityRequired and not cargoType.id = TI_CargoType_Container;	
		
		//+cnwml2 PAR25323
		if cargoType.id = TI_CargoType_Container then
			self.cmbISOType.isHidden	:= false;
		endif;
		
		// show self propelled and radio if cargo type is a vehicle, or tracked as vehicle
		if  cargoType.productType = ProductType_Vehicle then	// PAR #21867
			self.chkRadio.isHidden			:= false;
			self.chkSelfPropelled.isHidden	:= false;		
			// show all new car-related attributes				// PAR #32215
			self.lstColour.isHidden			:= false;			// PAR #32215
			self.cmbVehicleMake.isHidden	:= false;			// PAR #32215
			self.cmbVehicleModel.isHidden	:= false;			// PAR #32215
			self.cmbVehicleType.isHidden	:= false;			// PAR #32215
			self.txtYear.isHidden			:= false;			// PAR #32215
			self.txtTracking1.isHidden		:= false;			// PAR #32215
			self.txtTracking2.isHidden		:= false;			// PAR #32215
			self.txtDocsReceived.isHidden	:= false;			// PAR #32215
			self.txtDocsSent.isHidden		:= false;			// PAR #32215
			self.txtDocsCleared.isHidden	:= false;			// PAR #32215
			self.txtDocsReturned.isHidden	:= false;			// PAR #32215
			self.txtDoors.isHidden			:= false;			// PAR #32215
			self.chkNew.isHidden			:= false;			// PAR #32215
		endif;
		// show trailer type if cargo type is a trailer
		self.cmbTrailerType.isHidden	:= not cargoType.productType = ProductType_Trailer;
	
		// show generator type if cargo type is a generator
		if cargoType.id = TI_CargoType_Generator then
			self.cmbGeneratorType.isHidden	:= false;
			self.cmbISOType.isHidden			:= false;					//+cnwml2 PAR25323
		endif;
		
		// Show ComboIso ISo CLip on UNIT type if cargo type is a ISO Clip on Unit 
		if cargoType.id = TI_CargoType_COU then
			self.cmbISOType.isHidden			:= false;					//+cnwml2 PAR25323
		endif;
		
		// PAR #23442 show PreSlung and Wet for Timber
		if cargoType.id = TI_CargoType_Timber then
			self.chkPreSlung.isHidden		:= false;
			self.chkWet.isHidden			:= false;
		endif;
		
		// PAR #23190
		self.doHideShowProductAttributes(cargoType);
		
		if cargoType.isBulkProduct then					// PAR #33606
			self.txtMark.isHidden := true;				// PAR #33606
			self.txtMarkNumber.isHidden := true;		// PAR #33606
			self.lstColour.isHidden := true;			// PAR #33606
		endif;											// PAR #33606
	endif;
	
	if self.isGeneralCargo() then
		product := self.cmbSubCargo.getObject().CM_Product;
		if product = null then 	
			// try the dummy product for the current cargoType
			if cargoType &lt;&gt; null then
				product := cargoType.mySystemProductType;
			endif;
		endif;
		
		self.doFilterProductAttributes(product);
		if self.isReceivalByType then 			// cnwjk3 PAR 22518 08/03/2010
			self.txtCargoID.isHidden := true;	// cnwjk3 PAR 22518 08/03/2010
		endif;									// cnwjk3 PAR 22518 08/03/2010
	endif;
	
	if self.isFlexiGateForm then
		self.cmbTransportMode.isHidden := true;
		if self.isEmptyContainer() then
			self.cmbCommodity.isHidden := true;
		endif;
		
		if (self.isEmptyContainer() or self.isFullContainer()) then
			if not self.isAttachmentForm() then
				self.cmbType.isHidden := true;
			endif;
			//18/02/2011 cnwdz2 par27057
			self.cmbType.setForObject(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
		endif;
	endif;
	
	// PAR #22655 Hide Location - will be shown later on if we are a flexi gate form and the correct config flag is set
	self.txtLocation.isHidden := true;			// PAR #22655
	if not self.isPreNoteForm and not self.isFlexiGateForm then  //epr tfs 2011			  
		self.dateExpArrival.isHidden := not self.isPreNoteForm;	// 19/02/2010 cnwar2 #21880
		self.timeExpArrival.isHidden := not self.isPreNoteForm;	// 19/02/2010 cnwar2 #21880
		//epr tfs 1882 18/5/16
		self.chkIsWeightCertified.isHidden :=true;
		self.txtWeightAuthorised.isHidden:=true;
		self.txtWeightCertifiedBy.isHidden:=true;
	else
		//epr tfs 1882 18/5/16
		if cargoType &lt;&gt; null and not cargoType.canWeightBeCertified then			
			self.chkIsWeightCertified.isHidden :=true;
			self.txtWeightAuthorised.isHidden:=true;
			self.txtWeightCertifiedBy.isHidden:=true;
		endif;
	endif;

	self.setNumItemsCaptionAndEnabled( cargoType );	//04 Mar 2014	NDL	Par 33596
	
	// hide attachments controls if this is an attachment form, or the editing of a child object
	if isAttachmentForm()
	or (self.myProxyTrackedItem &lt;&gt; null and self.myProxyTrackedItem.myParent &lt;&gt; null)
	then
		self.chkHasAttachment.isHidden := true;
	else
		self.chkHasAttachment.isHidden := false;
	endif;
	
	if self.myAssistant.getAutoCompleteStatus(self.myMainForm) //then
	and not self.isPreNoteForm then
		self.txtLocation.isHidden := false;
	endif;//cnwas3
	// default to hiding Wagon
	self.txtWagon.isHidden := true;
	self.txtWagonTrain.isHidden := true;	//04 Nov 2009	NDL Par 21519
	self.cmbWagonClass.isHidden := true;	//12 May 2014	NDL	Par 33615
	// show if transport mode is rail, and we're not a rail form
	
	if self.cmbTransportMode.getString = TI_TRANSMODE_RAIL_STR and not self.isRailPreNoteForm then
		self.txtWagon.isHidden := false;
		self.txtWagonTrain.isHidden := false;	//04 Nov 2009	NDL Par 21519
		self.cmbWagonClass.isHidden := false;	//12 May 2014	NDL	Par 33615
		self.txtWagonTrain.enabled := false; // non enterable value, always derived.
	endif;
	
	if self.isMakeLCLForm then		//09 Dec 2013	NDL	Par 32854
		self.setupForMakeLCLForm();
	endif;
	
	self.tblOverHeight.isHidden		:= true;			// PAR #31155
	self.tblOverFront.isHidden		:= true;			// PAR #31155
	self.tblOverRear.isHidden		:= true;			// PAR #31155
	self.tblOverLeft.isHidden		:= true;			// PAR #31155
	self.tblOverRight.isHidden		:= true;			// PAR #31155
	
	if self.transportMode = TI_TRANSMODE_SHIP_STR and self.cmbTransportMode.enabled then // par 22879 cnwrd1 11/3/2010 hack for create on ship cargo
		self.txtLocation.isHidden := false;
	endif;
	if self.isOnsiteForm then // TFS 2318
		self.txtLocation.isHidden := false; // TFS 2318
	endif; // TFS 2318
		
	self.txtOperatorSeal.isHidden	:= true;			//+cnwml2 PAR23715 SFW CCMS1131
	self.txtVentSeal.isHidden		:= true;	//28 Sep 2010	NDL Par 25608
	self.txtShippersSeal.isHidden	:= true;	//28 Sep 2010	NDL Par 25608
	self.txtCustomsSeal.isHidden	:= true;	//28 Sep 2010	NDL Par 25608
	self.txtUnknownSeal.isHidden	:= true;	//24 Oct 2019	NDL	TFS 47149
	self.txtTerminalOperatorSeal.isHidden	:= true;	//24 Oct 2019	NDL	TFS 47149
	
	//cnwmc5 - 1 Nov 2013 - PAR 32891
	self.doShowVehicleBookings();
	
	//PAr #30787 - Voyage Rationalisation
	if self.isOnshipForm then
		txtLocation.isHidden := false;
	endif;
	
	entDef := app.myRoot.myEntTableDataRoot.getEntTableDef(self.currentEntTableDef);	// PAR #36421
	entRow := entDef.myEntTableGroup.allEntTableRowsByName[ETRow_IsHazardous];			// PAR #36421
	if entDef &lt;&gt; null and entDef.allEntTableRows.includes(entRow) then					// PAR #36421
		if self.myTerminal.getConfig(UseDetailedHazEntry).Boolean then					// PAR #36421
			self.grpIsHazardous.visible := true;										// PAR #36421
			if not self.chkIsHazardous.value then										// PAR #36421
				self.btnIsHazardous.enabled := false;									// PAR #36421
			endif;																		// PAR #36421
			self.txtHazards.enabled := false;											// PAR #36421
		else																			// PAR #36421
			self.grpIsHazardous.visible := false;										// PAR #36421
			self.grpIsHazardous.isHidden := true;										// PAR #36421
		endif;																			// PAR #36421
	else																				// PAR #36421
		self.grpIsHazardous.visible := false;											// PAR #36421
		self.grpIsHazardous.isHidden := true;											// PAR #36421
	endif;																				// PAR #36421
	
	if self.cmbImexStatus.getObject &lt;&gt; null 											//12/10/2016 cnwma1 TFS #2636
	   and (self.cmbImexStatus.getObject.CM_IMEXStatus.code = TI_IMEX_STATUS_IMPORT 
			or self.cmbImexStatus.getObject.CM_IMEXStatus.code = TI_IMEX_STATUS_STORAGE
			or self.cmbImexStatus.getObject.CM_IMEXStatus.code = TI_IMEX_STATUS_REMAINONBOARD)  then
		self.cmbTranship.isHidden := true;
	else
		self.cmbTranship.isHidden := false;
	endif;
	
	self.txtCargoGroupID.isHidden:=not app.isCargoGroupEnabled; //jlier1 TFS 53515 25/5/22
	
	// MTN-36141 Show Contents Cargo Type and Cargo Sub Type fields if ISO Type is Rotatable
	if not self.cmbISOType.isHidden then
		isoType := self.cmbISOType.getObject().CM_ISOType;
		if isoType &lt;&gt; null and isoType.isRotatable() then
			self.cmbContentsCargoType.isHidden := false;
			self.cmbProdType.isHidden := false;
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
