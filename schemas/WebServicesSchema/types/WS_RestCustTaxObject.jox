<Class name="WS_RestCustTaxObject" id="1c38ed6a-f329-41ef-9063-ef4edbf81788">
    <superclass name="WS_CustomerObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="countryId" id="ec2f4a7c-6fac-4491-b3e7-6707f9a05b4f">
        <length>4</length>
        <embedded/>
        <type name="String"/>
        <text>ISO Country Code. Should match a valid country in Master Terminal</text>
    </PrimAttribute>
    <PrimAttribute name="number" id="1f7f4253-09b8-4530-b3e3-875aa1814e38">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
</Class>
