    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myTSWHelper" id="e239fc52-0f59-4e1d-b089-ce08fd33fc03">
        <embedded/>
        <type name="JMTTSWHelper"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="clientHasRaisedException" id="c6b15225-91c7-4162-a4df-54c9f94787b6">
        <source>clientHasRaisedException(firstMessageSection: String) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 August 2018	jlgsl4	TFS 39133 - Trade Single Window - TSW Client diagnostics

*/

vars

begin
	return firstMessageSection.pos(TSWClientExceptionMarker, 1);
epilog

end;</source>
        <Parameter name="firstMessageSection" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="4d5d5b0d-5873-4f96-9931-cdd6edb8dcfe">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2016	cnwkpd1	TFS 1832 - TSW Web Client

*/

vars
	hadException	: Boolean;
	fileName		: String;
	iniValue		: String;
	usePresentation	: Boolean;
	
begin
	on Exception do self.handleExceptions(exception, hadException);
	
	create self.myTSWHelper transient;
	if self.myTSWHelper &lt;&gt; null then
		self.myTSWHelper.usePresentationClient := self.usePresentationClient;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="936ccb8c-e593-4f2e-93d4-d660f26fde0e">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2016	cnwkpd1	TFS 1832 - TSW Web Client

*/

vars

begin
	delete self.myTSWHelper;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getNextPendingNotification" id="6c07ad48-70b1-41bd-b141-9c60c519cadb">
        <source>getNextPendingNotification(_submitter : String) : String;
/*

Purpose:			Get the next pending notification from the TSW Web Service for the 
					passed in submitter

Parameters:			Submitter code

Return Value:		XML response received from the TSW Web Service

Date		Who		Reason
02 Jun 2016	cnwkpd1	TFS 1832 - TSW Web Client
13 Aug 2018	jlgsl4	TFS 39133 - Trade Single Window - TSW Client diagnostics
20 Nov 2018	jlgsl4	TFS 39133 - Catch and handle TSW connection failure - reverting code to wmast state
*/

vars
	logFileName		: String;
	today			: Date;
	returnVal		: String;
	hadException	: Boolean; // TFS 39133 - 20/11/18
	
begin
	if self.myTSWHelper = null then
		return null;
	endif;
	
	today := app.actualTimeServer.Date;
	logFileName := self.class.name &amp; "_" &amp; today.formatAsYYYYMMDD &amp; "_" &amp; self.getInstanceIdForObject(process).String &amp; ".log";
	
	if self.usePresentationClient then
		logFileName := app.getTempDir &amp; logFileName;
	else
		if app.myCnCntrl &lt;&gt; null then
			logFileName := app.myCnCntrl.logPath &amp; "\" &amp; logFileName;
		else
			logFileName := app.getTempDirAppServer &amp; logFileName;
		endif;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " logging TSW diagnostics to " &amp; logFileName, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	app.writeLog(method.qualifiedName &amp; " calling TSW for submitter " &amp; _submitter, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	on Exception do self.handleExceptions(exception, hadException); // TFS 39133 - 20/11/18
	
	returnVal := self.myTSWHelper.getNextPendingNotification(_submitter.StringUtf8, logFileName.StringUtf8).String;
	//if clientHasRaisedException(returnVal[1:20]) = 1 then // TFS 39133 - TSW client's had some problem - 20/11/18
	//	raiseAlert(returnVal); // TFS 39133 - 20/11/18
	//endif; // TFS 39133 - 20/11/18
	
	if hadException then // TFS 39133 - 20/11/18 - TSW client broke, couldn't connect to TSW server etc.
		return null; // TFS 39133 - 20/11/18
	endif; // TFS 39133 - 20/11/18
	
	app.writeLog(method.qualifiedName &amp; " TSW call returned " &amp; returnVal, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	return returnVal;
	
epilog

end;</source>
        <Parameter name="_submitter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="raiseAlert" id="49a39db0-0873-40ba-a5b5-086fe6ec14d3">
        <source>raiseAlert(_detail : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 August 2018	jlgsl4	TFS 39133 - Trade Single Window - TSW Client diagnostics
*/

vars
	alert: CM_SystemAlert;
	setInTransState: Boolean;
	exceptionDetail : String;
	
begin
	if _detail = null then
		return;
	endif;
	
	if not process.isInTransactionState then
		setInTransState := true;
		beginTransaction;
	endif;
	exceptionDetail := '(JMTTSWClient .Net) - ' &amp; _detail;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' ' &amp; exceptionDetail, LogERROR);
	
	create alert;
	alert.details := exceptionDetail;
	alert.setSeverity(SEVERE_ERROR);
	//-----------
	//Tell alert to add itself to system
	//-----------
	alert.add;
epilog
	if setInTransState then
		app.cmsCommitTransaction(app.myPassport);
	endif;
end;
</source>
        <Parameter name="_detail" type="String"/>
    </JadeMethod>
</Class>
