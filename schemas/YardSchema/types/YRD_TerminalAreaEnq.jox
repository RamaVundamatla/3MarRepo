    <JadeMethod name="addToolbarControls" id="47a9c36e-19d9-4d45-a395-9030e3d0f8aa">
        <updating/>
        <source>addToolbarControls() updating, protected;
//-----------------------------------------------------------------------
//  Created by: cnwsh3
//	Date: 11 September 2003
//-----------------------------------------------------------------------
// 01/11/2012	cnwcs5	pat 30475 - removed btnRestriction
vars
	terminal	: CM_Terminal;
	toolbar		: CMUI_Toolbar;
	user		: CM_User;
begin
	inheritMethod();

	terminal	:= self.myTerminal;
	user 		:= app.getMyUser();
//	------------	
//	MAIN TOOLBAR
//	-------------	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnAreaTypes, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	
	if user.canDo(terminal, PmAdmSelectorView) then
		toolbar.addButton(self.btnSelector, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		
	if user.canDo(terminal, Mod_BulkCargo) then
		toolbar.addButton(self.btnAdjustStock, CMUI_Toolbar.Control_Alignment_Left);
	endif;

	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
//	--------------	
//	SEARCH TOOLBAR
//	--------------	
	toolbar 				:= self.frmToolbarSearch;
	toolbar.showCaptions 	:= false;
	
	toolbar.addButton(self.btnFind, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnAreaSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnAreasClear, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCloseSearch, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	
	toolbar.visible := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
