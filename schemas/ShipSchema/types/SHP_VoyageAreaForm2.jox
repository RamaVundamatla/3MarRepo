    <JadeMethod name="activate" id="0cf8a847-4a33-4661-b7e7-ab341d75bcd0">
        <controlMethod name="Form::activate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>activate() updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	doShow : Boolean;
begin
	inheritMethod();
	self.amActive := true;
	//cnwjo3 par 25114.  Don't need timer anymore
	//self.beginTimer(500 , Timer_OneShot, 1);
	
	doShow := (self.displayMode = ShpDisplayMode_ColCodeLoad or  self.displayMode = ShpDisplayMode_ColCodeDisch) and self.workingMode = self.WorkMode_None ; // PAR 23216 this is colour code mode only, not jobs, planning etc

	
	if self.myCurrentVoyage &lt;&gt; null and 
		global.isValidObject(self.myCurrentVoyage)  then	//cnwrs1 par27385 05 May 2011 could not get out of form with deletd voyage
		//self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,doShow);//cnwas3 par26840a	
		self.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,doShow);//cnwas3 par 27769
	endif;
	//self.showHideCC(doShow);


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="4c782ce8-59eb-4199-8d75-1c4cc67a6af0">
        <updating/>
        <source>addToolbarControls() protected, updating;
// ---------------------------------------------------------------------------
// Created:     27 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;

	showCaptions := toolbar.showCaptions;

	toolbar.addButton(self.btnSelectVoyage, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	if app.myPassport.myUser.canDo(self.myTerminal,PmShipVoyageEnquiryView) then
		toolbar.addButton(self.btnDefinition, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	toolbar.addButton(self.btnActual, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnProposed, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnColorCodeDish, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnColorCodeLoad, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnViewImport, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewExport, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnJobsMode, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSequenceMode, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPlanningMode, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnViewCommodity, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewConsignee, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewLoadPort, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewDischPort, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewISOGroup, CMUI_Toolbar.Control_Alignment_Left);
	if self.myTerminal.getConfig(ShipShowISOType).Boolean then
		self.btnViewISOGroup.bubbleHelp := "View by ISO Type";
	endif;

	toolbar.addButton(self.btnViewOperator, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewStatus, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewTemp, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewWeight, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnPenDischarge, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenLoad, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenRehandle, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenSOB, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenEraser, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCCScreen, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenEmpty, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenHiCube, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenHazard, CMUI_Toolbar.Control_Alignment_Left);
//PAR7496	toolbar.addButton(self.btnPenReefer, CMUI_Toolbar.Control_Alignment_Left);
//PAR7496	self.btnPenReefer.bubbleHelp := "Reefer Pen";
	toolbar.addButton(self.btnPenPower, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenWaterCool, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPen40, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPen45, CMUI_Toolbar.Control_Alignment_Left); // PAR 18682 CCMS 1055
	toolbar.addButton(self.btnPen30, CMUI_Toolbar.Control_Alignment_Left); // PAR 16415 CCMS 1029
	
	
	toolbar.addButton(self.btnPen53, CMUI_Toolbar.Control_Alignment_Left); // PAR 16415 CCMS 1029
	
	toolbar.addButton(self.btnPenHalfHeight, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenUnavail, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenOverDim, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnPenHeavy, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenVoltage, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenFlat, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenFantainer, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenOpentop, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenTank, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenCrib, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPenFrame, CMUI_Toolbar.Control_Alignment_Left);	//05 Feb 2018	NDL	TFS 36752

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	//make actual and auto discharge colour code buttons
	toolbar.addButton(self.btnMakeActual, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnAutoDischCC, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnImportTasks, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCustomsEDI, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnTranship,CMUI_Toolbar.Control_Alignment_Left);  //21/7/06 epr CCMS 1011
	
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	if self.bAllowSummaryDefn then
		// always make this button visible but the enabling will depend on the display mode being used.
		toolbar.addButton( self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left );
	endif;
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	toolbar.addButton(self.btnCapacity,CMUI_Toolbar.Control_Alignment_Left); // PAR 30895
	toolbar.addButton(self.btnCraneShifts,CMUI_Toolbar.Control_Alignment_Left); // TFS 3472
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnFlipHV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFlipPS, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnClearSelected, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveTopLeft, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveTopRight, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveBotLeft, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveBotRight, CMUI_Toolbar.Control_Alignment_Left);

	//============================================================
	// Now setup the second toolbar
	//============================================================
	toolbar := self.frmToolbar2;

	toolbar.showCaptions := showCaptions;
	//epr par 32911 8/11/13
	toolbar.addButton(self.btnOOWCreation, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPlanGuide, CMUI_Toolbar.Control_Alignment_Left);
	//epr 28371 11/10/11
	if app.myCurrentUserCan(self.myTerminal, Mod_VesselRORO) then
		toolbar.addButton(self.btnRoRoDeckDef, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	toolbar.addButton(self.btnNewWindow, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	//29 Sep 2020	NDL	TFS 49963
	toolbar.addButton(self.btnPrintScanPlan, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);

	self.seperatorSequence := toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addFrame(self.frmToolbarCombos, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmToolbarChk, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmToolbarSeqNum, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnTwinLiftCrane, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSeqDisP2ST2B, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSeqDisS2PT2B, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSeqDisT2BP2S, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSeqDisT2BS2P, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnSeqLoadP2SB2T, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSeqLoadS2PB2T, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSeqLoadB2TP2S, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSeqLoadB2TS2P, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addFrame(self.frmToolSeqApply, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.hideSeperator(self.seperatorSequence);
	//epr par 33028 20/11/13
	toolbar.addFrame(self.frmTBIgnoreWT, CMUI_Toolbar.Control_Alignment_Left);
 // ### TFS 50421 17SEP2021 NAVAB1 not needed	self.chkIgnoreWeightV.top	:=	(toolbar.height - self.chkIgnoreWeightV.height) div 2;	// cnwdad1 02/08/2010 - PAR #24045.
 // ### TFS 50421 17SEP2021 NAVAB1 not needed	toolbar.positionToolbarControls();
	//============================================================
	// Now setup the select voyage toolbay
	//============================================================
	toolbar := self.frmToolbarSelect;

	toolbar.showCaptions := showCaptions;
	
	toolbar.addButton(self.btnSelectVoyOK, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBaySelectOpt2, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSelectVoyCan, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;	
	//============================================================
	// Now setup the select BAYS toolbar
	//============================================================
	toolbar := self.frmToolbarBays;

	toolbar.showCaptions := false;
	
	toolbar.addFrame(self.frmSelBaysCombos, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSelBayTwin, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnBaySelectOpt, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSelBayClose, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;	

	//============================================================
	// Now setup the Positioning Frame toolbar
	//============================================================

	toolbar := self.frmPosToolbar;
	toolbar.showCaptions := false;
	
	toolbar.addButtonAt(self.btnFlipHVPos, 1, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperatorAt(2, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.positionToolbarControls();
	toolbar.visible := true;	

end;</source>
        <access>protected</access>
    </JadeMethod>
