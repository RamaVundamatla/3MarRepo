    <JadeMethod name="cleanUpPlanning" id="97928783-5d49-4ef6-b41b-151a47feb0a3">
        <source>cleanUpPlanning() protected;
// cnwrs1 ccms 1022 June 2006
// go thru all colour coding and remove any that is wrong
constants
	NoTI : Integer = 0;
	TINotDisch : Integer = 1;
	TIDischHere : Integer = 2;
vars
	aBayVoyage : CM_BayVoyage;	
	aSlotReq : CM_SlotRequest;
	iter01 : Iterator;
	currPortDestCode : String;
	ti : CM_TrackedItem;
	found : Integer;
begin
	currPortDestCode := self.myVoyage.myTerminal.getConfig(PortDestCode).String.trimBlanks();
	foreach aBayVoyage in self.myVoyage.myCellularVoyageStructure.allBayVoyagesByOrdinal do
		iter01 := aBayVoyage.allSlotRequestByMoveType.createIterator();
		while iter01.next(aSlotReq) do
			if aSlotReq.moveType = LOAD_COLOURCODE then
				found := NoTI;
				foreach ti in  aSlotReq.mySlotController.allTrackedItems do
					if found = NoTI then
						found := TIDischHere; // set first TI to be discharge here
					endif;
					if ti.dischargePort &lt;&gt; currPortDestCode then
						found := TINotDisch; // if any are not being discharge here set this
						break;
					endif;
				endforeach;
				if found = TINotDisch then // only delete load colour code if ALL are being discharged here
					//jlgzm1 tfs42177
					aSlotReq.setMoveType(NULL_MOVETYPE); //unPlanMyTIs wants this as moveType
					aSlotReq.unPlanMyTIs(aSlotReq.getTrackedItem, app.myPassport); //need to remove TI from job/wle
					aSlotReq.erase(NORMAL_ERASE);
				endif;
			elseif aSlotReq.moveType = DISCHARGE_COLOURCODE then
				if aSlotReq.getDischargePort() &lt;&gt; currPortDestCode then
					aSlotReq.erase(NORMAL_ERASE);
				endif;
			endif;
		endwhile;
		delete iter01;
	endforeach;
epilog
	delete iter01;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createNewActualBayPlan" id="717edca6-fc66-49ca-bc54-67028ee9ef34">
        <updating/>
        <source>createNewActualBayPlan(_passport : CM_Passport input) updating, protected;
/*
------------------------------------------------------------------------
Created:			26 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	fmIter : Iterator;
	fm : CM_FutureMovePlanned;
	moveController : CMIF_MoveController;
	primLocn : CM_LocationsController;
	now : TimeStamp;
	tiControl : CMIF_TIUpdateController;
	ediIndex	: Integer;
begin
	create moveController transient;
	moveController.setMoveMode(REAL_MODE);
	moveController.isSystemMove := true;
	ediIndex :=	self.getMyEDIIndex;

	fmIter := self.allPlannedFutureMoveEDIs.createIterator;

	tiControl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, null);
	tiControl.myVoyage := self.myVoyage;
	tiControl.transactionType := TRANS_TYPE_CREATED;
	//------------------
	//If the futureMove has a TrackedItem, then create and real-mode move to the 
	//location(s) the FM has for it.
	//------------------
	while fmIter.next(fm) do
		if fm.myTrackedItem = null then
			continue;
		endif;
		//----------------------
		//If this is the PRIMARY location for this TI, create and do the move
		//----------------------
		primLocn := fm.getPrimaryLocation;
		if (fm.myTrackedItem.isThisPrimaryLocation(primLocn, REAL_MODE)) then // this had a 'not' - removed AKB2003MAR
			continue;
		endif;
		moveController.setMyToPrimaryLocation(primLocn);
		moveController.setMyToSecondaryLocations(fm.allLocationsControllers);
		moveController.setIndexForEDIBayPlan(ediIndex);
		//----------------------
		//Create new (it should have NO REFERENCE that we 
		//are interested in (basically, ONLY its location)
		//----------------------

		self.createNewTIInActualBayPlan(fm.myTrackedItem, _passport, moveController, tiControl);
		if _passport.hasErrors then
			break;
		endif;

	endwhile;
	now := app.serverTimestampAtTrxStart;
	self.myVoyage.setRemarks(app.getErrorString2(EDIBPLoaded, self.description, now.String) , true);
	self.lastLoadToActualBayPlansDT := now;
epilog
	delete moveController;
	delete tiControl;
	delete fmIter;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createNewTIInActualBayPlan" id="ce6607f2-96e3-43e6-8c5d-e375cd93589e">
        <updating/>
        <source>createNewTIInActualBayPlan(_fromTI : CM_TrackedItem; _passport : CM_Passport input; _moveController : CMIF_MoveController input; 	_tiControl : CMIF_TIUpdateController input) updating, protected;
/*
------------------------------------------------------------------------
Created:			28 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	newProxyTI : CM_TrackedItem;
	newTI : CM_TrackedItem;

begin
	if _fromTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'donor tracked item', null, null);		
		return;
	endif;
	
	newProxyTI := _fromTI.pxyCreateUpdateProxy;
	
	//Make sure the voyage, Imex and state are updated
	newProxyTI.setImExStatus(TI_IMEX_STATUS_REMAINONBOARD);	//All boxes are by default Transit, they get converted to imports by the default cc.
	newProxyTI.setMyVoyage(self.myVoyage, _passport);
	newProxyTI.changeState(TI_STATE_ONSHIP, _passport);
	
	newTI := newProxyTI.myTerminal.createTrackedItem(newProxyTI, _passport);
	
	//Move the TI to the actual controller(s)
	_moveController.setMyTrackedItem(newTI);
	
	//testing this for quicker move jc 07/07/2004
	newTI.executeControlMove(_moveController, _passport);				
	//app.myUtilityUA.utlUpdateMoveTrackedItem(_moveController, _passport);		//was

epilog
	delete newProxyTI;
end;</source>
        <access>protected</access>
        <Parameter name="_fromTI" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_tiControl" type="CMIF_TIUpdateController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="erase" id="6815fb0b-2adf-4532-a2d4-9d20927827f8">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

// cnwdvb1 27 February 2003 

vars

	tiSet		: CM_TISet;
	iter		: Iterator;
	futureMove	: CM_FutureMovePlanned;

begin
	
	if self.myEdiData &lt;&gt; null then
		exclusiveLock(self.myEdiData);
		self.myEdiData.setStatus(CM_EDIFile.EDI_STATUS_INVALID);
	endif;
	
	// These TIs are CM_Container EDI TIs in that they have not been 'made actual' they have no location, 
	//			they have a special EDI future move to link them to a slot
	// When one of these bay plan controllers are made actual these TIs are used to create a new TI on the terminal
	// These TIs are left just on the EDI FM
	create tiSet transient;
	iter := self.allPlannedFutureMoveEDIs.createIterator;
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-self.allPlannedFutureMoveEDIs.size = ' &amp; self.allPlannedFutureMoveEDIs.size.String);
	while iter.next(futureMove) do
		exclusiveLock(futureMove);
		if futureMove.myTrackedItem &lt;&gt; null then
			tiSet.add(futureMove.myTrackedItem);
		endif;
	endwhile;
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-tiSet.size = ' &amp; tiSet.size.String);
	tiSet.purge;
	self.myEdiData := null;
	
	inheritMethod(_eraseLevel);
epilog
	delete iter;
	delete tiSet;
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
