    <JadeMethod name="isVoyage_Match" id="705175c4-adaf-48ec-99f3-dc9d5b66101c">
        <source>isVoyage_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

	voyage	: CM_Voyage;

begin
	
	// We don't have a voyage so take a look any way.
	if self.voyageCode = null then
		return true;
	endif;
	
	voyage := 	self.myTerminal.lookupVoyage (self.voyageCode, null, false);

	if voyage = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	// Check to see whether voyage matches priority selection.
	return _yaData.matches(voyage);

end;</source>
