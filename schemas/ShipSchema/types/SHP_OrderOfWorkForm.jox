vars

	theForm : SHP_SelectCranes;

begin
	app.mousePointer := Window.MousePointer_HourGlass;
	theForm := app.getForm(SHP_SelectCranes.name).SHP_SelectCranes;
	if theForm = null then
		create theForm as SHP_SelectCranes;
	endif;
		
	theForm.myTerminal := self.myTerminal;
	theForm.myCurrentVoyage := self.myCurrentVoyage;
	theForm.workPointJobSheetClassToCreate := CM_VoyageDeckJobSheet; // TFS 3646
	theForm.showModal();
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
