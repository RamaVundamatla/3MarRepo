    <JadeMethod name="getRTTaskFromTelegram" id="30b4e6a8-36be-429e-825b-e22d072d9037">
        <source>getRTTaskFromTelegram(_rtgTelegram : CM_RTGTelegram input) : CM_RTQueueTask;

vars
	telegramLC : CM_LocationsController;
	allRTTasksInTelegramLoc : CM_RTQueueTaskArray;
	rtQueueTask , theRTQueueTask: CM_RTQueueTask;
	
begin
	theRTQueueTask:=null;
	// get the telegrams location 
	telegramLC:=_rtgTelegram.getLocationController(_rtgTelegram.myMachine);
	self.writeLog("Telegram lc is " &amp; telegramLC.String);
	// get the tasks in that location 
	create allRTTasksInTelegramLoc transient;
	foreach rtQueueTask in self.myMachine.allCurrentQueueTasks discreteLock do
		if rtQueueTask.sourceLocation = telegramLC then
			if not allRTTasksInTelegramLoc.includes(rtQueueTask) then
				allRTTasksInTelegramLoc.add(rtQueueTask);
			endif;
		endif;
	endforeach;
	
	//self.writeLog("Number of tasks in location is " &amp; allRTTasksInTelegramLoc.size.String);
	if allRTTasksInTelegramLoc.size = 1 then
		theRTQueueTask:=allRTTasksInTelegramLoc.first;
	elseif allRTTasksInTelegramLoc.size = 0 then
		theRTQueueTask:=null;
		//return null;
	else
	//there are 2 in the RTG stack at same location so must be the top one
		if telegramLC.isKindOf(CM_RTGController) then
			foreach rtQueueTask in allRTTasksInTelegramLoc discreteLock do
				if rtQueueTask.ti = null then
					continue;
				endif;
				if theRTQueueTask = null then
					theRTQueueTask:=rtQueueTask;
				else
					if telegramLC.getIndexOfTiDisplay(REAL_MODE, rtQueueTask.ti).Integer &gt; telegramLC.getIndexOfTiDisplay(REAL_MODE, theRTQueueTask.ti).Integer then
						theRTQueueTask:=rtQueueTask;
					endif;
				endif;	
			endforeach;
	//there are 2 in same loc not in RTG stack i.e. on truck or imv so can decide automatically make user choose	
		else
			theRTQueueTask:=null;
			
			//return null;
		endif;
	//more than one rtQueue task in that location get the one thats height is greatest
	
	endif;
	
	self.writeLog("Returning task " &amp; theRTQueueTask.String);
	return theRTQueueTask;
	
	
	
epilog
	delete allRTTasksInTelegramLoc;
end;
</source>
        <Parameter name="_rtgTelegram" type="CM_RTGTelegram" usage="input"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getRelatedTask" id="24197d0e-6f1a-45f8-a9b6-c783d30fa6bc">
        <updating/>
        <source>getRelatedTask() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	task : CM_RTQueueTask;
	entry : CM_RTQueueEntry;
begin
	task := self.getCurrentTask;
	entry := task.myEntry;
	if entry &lt;&gt; null then
		self.myRelatedTask:=entry.getNextEntryFirstTask;
		if self.myRelatedTask = null then
			self.myRelatedTask:=entry.getPreviousEntryFirstTask;
		endif;
	endif;


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
