    <JadeMethod name="btnChangeBackColor_click" id="75a25f2f-89e3-4a47-84f1-9839bd13056a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnChangeBackColor_click(btn: Button input) updating;

vars
	theColor	: CMDColor;
	
begin
	create theColor;
	
	theColor.color := calendar1.backColor;
	if theColor.open = 0 then
		calendar1.backColor := theColor.color;
		calendar1.refresh();
	endif;
epilog
	delete theColor;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnChangeFont_click" id="fdf665f8-05c4-42cb-b8d8-93f0ab9847b0">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnChangeFont_click(btn: Button input) updating;

vars
	theFont : CMDFont;
	
begin
	create theFont;
	theFont.fontName := calendar1.fontName;
	theFont.fontSize := calendar1.fontSize;
	theFont.fontBold := calendar1.fontBold;
	theFont.fontItalic := calendar1.fontItalic;
	theFont.fontUnderline := calendar1.fontUnderline;
	theFont.fontStrikethru := calendar1.fontStrikethru;
	
	if theFont.open = 0 then
		calendar1.fontName := theFont.fontName;
		calendar1.fontSize := theFont.fontSize;
		calendar1.fontBold := theFont.fontBold;
		calendar1.fontItalic := theFont.fontItalic;
		calendar1.fontUnderline := theFont.fontUnderline;
		calendar1.fontStrikethru := theFont.fontStrikethru;
		calendar1.refresh();
	endif;
epilog
	delete theFont;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnChangeForeColor_click" id="7a9bff9b-caa7-4a16-814a-01df54fa00ff">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnChangeForeColor_click(btn: Button input) updating;

vars
	theColor : CMDColor;
	
begin
	create theColor;
	theColor.color := calendar1.foreColor;
	
	if theColor.open = 0 then
		calendar1.foreColor := theColor.color;
		calendar1.refresh();
	endif;
epilog
	delete theColor;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSetDate_click" id="5b5bed00-37f7-4a23-ba48-c433d47796e2">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSetDate_click(btn: Button input) updating;

begin
	if txtDate.text.Date.isValid then
		calendar1.date := txtDate.text.Date;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="calendar1_click" id="c3a8c568-a10c-493d-8c04-0453ed3f2daa">
        <controlMethod name="CnEcCalendar::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>calendar1_click(cntrl: CnEcCalendar input) updating;

begin
	lblDate.caption := cntrl.date.String;
end;</source>
        <Parameter name="cntrl" type="CnEcCalendar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lblDragDrop_mouseDown" id="fba77110-a0b5-4a30-8c33-e809983e9540">
        <controlMethod name="Label::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lblDragDrop_mouseDown(label: Label input; button: Integer; shift: Integer; x: Real; y: Real) updating;

begin
	label.dragMode := 1;
end;</source>
        <Parameter name="label" type="Label" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="load" id="62d1d9a3-f56a-4d4d-a7b7-794245aefb52">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	centreWindow();
	calendar1.dayNameLength := 2;
end;</source>
    </JadeMethod>
