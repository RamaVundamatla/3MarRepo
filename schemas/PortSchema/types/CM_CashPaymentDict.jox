    <JadeMethod name="countByStatus" id="0e41877c-b139-45c5-84b2-dfe34f7ba43a">
        <source>countByStatus(_status : Integer) : Integer;
/*
Purpose:			
Date		Who		Reason
31 March 2017	cnwab1	Initial creation

CM_InvoiceLine.STATUS_VOIDED
CM_InvoiceLine.STATUS_NORMAL

Changed On	By			Reason
----------	--------	-----------------------------------------------------
04/08/2017	jlgdap1		TFS 5657 Cash Collection Error
						When an invoice is voided, the invoice lines and cash payments associated with the invoice
						do NOT have their status set to VOID. But there is a mapping method "voided" on CM_CashPayment
						that indicates that the cash payment's invoice has been voided, and tehrefore this payment
						should be treated as voided as well.
						Changed this method to take account of this if looking for NORMAL status and VOID status,
						other statuses just continue as normal.
12/07/2019	jlgdi1		TFS 45301 Used the CM_CashPayment constants instead CM_InvoiceLine
*/

vars
	count : Integer;
    pay : CM_CashPayment;
begin
	if _status = CM_CashPayment.Status_Normal then // TFS 45301
		foreach pay in self discreteLock where pay.status = _status and not pay.voided do
			if pay.myCashPaymentForInvoice &lt;&gt; null then // TFS 8264 tax payment ignore
				continue;
			endif;
			count := count + 1;
		endforeach;
	elseif _status = CM_CashPayment.Status_Void then // TFS 45301
		foreach pay in self discreteLock where pay.status = _status or pay.voided do
			if pay.myCashPaymentForInvoice &lt;&gt; null then // TFS 8264 tax payment ignore
				continue;
			endif;
			count := count + 1;
		endforeach;
	else
		foreach pay in self discreteLock where pay.status = _status do
			if pay.myCashPaymentForInvoice &lt;&gt; null then // TFS 8264 tax payment ignore
				continue;
			endif;
			count := count + 1;
		endforeach;
	endif;
	
	return count;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getProformaPayment" id="4496b706-fac6-485b-95d9-727fd54f35b1">
        <source>getProformaPayment() : CM_CashPayment;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	cp : CM_CashPayment;
begin
	foreach cp in self reversed do		// from 34990 get the latest pro forma as it has any manual stuff
		if cp.voided then				// 35399 skip voided proforma payments
			continue;
		endif;
		if cp.myCashPaymentForInvoice &lt;&gt; null then // TFS 8264 tax payment ignore
			continue;
		endif;
		if cp.isProformaPayment then
			return cp;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_CashPayment"/>
    </JadeMethod>
</CollClass>
