    <JadeMethod name="translateForm" id="1ac2d0ca-17bf-468c-b69a-7b583a924767">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 October 2025 19:19:09.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026667, locale);
	btnAddCargoReleased.translateCaption(Xlat_0026670, locale);
	btnCancel.translateCaption(Xlat_0026668, locale);
	btnClose.translateCaption(Xlat_0026669, locale);
	btnMoveOnsite.translateCaption(Xlat_0027135, locale);
	btnSave.translateCaption(Xlat_0026673, locale);
	grpCargoOnsite.translateCaption(Xlat_0026674, locale);
	grpCurrentCargo.translateCaption(Xlat_0026675, locale);
	grpToLocation.translateCaption(Xlat_0027136, locale);
	grpVehicleVisit.translateCaption(Xlat_0026676, locale);
	lblCarrier.translateCaption(Xlat_0026680, locale);
	lblDriver.translateCaption(Xlat_0026681, locale);
	lblRegistration.translateCaption(Xlat_0026682, locale);
	lblSubArea.translateCaption(Xlat_0026683, locale);
	lblSubhaulier.translateCaption(Xlat_0026684, locale);
	lblTerminalArea.translateCaption(Xlat_0026685, locale);
	lblVehicleVisit.translateCaption(Xlat_0026686, locale);
	mnuTblColumnOrganiser.translateCaption(Xlat_0026687, locale);
	mnuTblContext.translateCaption(Xlat_0026688, locale);
	mnuTblRemoveTi.translateCaption(Xlat_0026689, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="e8c50b45-95cf-4afd-824a-27fede1b26da">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo

*/

vars
	invalid : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myPxyVehicleVisitRecord, invalid);

	if self.myPxyVehicleVisitRecord &lt;&gt; null then
		self.myPxyVehicleVisitRecord.edition;
		if not invalid then
			delete self.myPxyVehicleVisitRecord;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
