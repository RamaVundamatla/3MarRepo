    <JadeMethod name="getCriteriaPriority" id="b77aac86-6bb7-46b6-b0f9-719da2430043">
        <source>getCriteriaPriority() : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 October 2025		jlizm1	Initial creation MTN 35861 RTQueue configuration - cargo attribute criteria

*/

vars
	criteriaObj			: CM_YACriteria;
	priorityTotal		: Real;
	
begin
	foreach criteriaObj in self.allCriteria do
		priorityTotal := priorityTotal + criteriaObj.priorityValue;
	endforeach;
	
	return priorityTotal;

epilog

end;</source>
