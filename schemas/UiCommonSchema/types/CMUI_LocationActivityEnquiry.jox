    <JadeMethod name="handleYAInventoryTypeOK" id="354da4fa-b0ac-42e1-aaf5-41479824688e">
        <updating/>
        <source>handleYAInventoryTypeOK(_criteria : String) updating;
/*
Purpose:	Used by CMUI_YACriteriaCntl do not delete		

Date		Who		Reason
14 July 2021	navab1	TFS 51515
*/

vars
	etype : CM_EventType;
begin
	self.valueTranType := _criteria.toUpper();
	
	
	self.filterEventTypes.clear;
	
	etype := app.myRoot.allEventTypesByType[EVT_LocationMove];
	if self.valueTranType.pos(etype.name.toUpper(),1) &gt; 0 then
		self.filterEventTypes.add(etype);
	endif;
	
	etype := app.myRoot.allEventTypesByType[EVT_LocationBalance];
	if self.valueTranType.pos(etype.name.toUpper(),1) &gt; 0 then
		self.filterEventTypes.add(etype);
	endif;
	
	etype := app.myRoot.allEventTypesByType[EVT_LocationDiscrepDecrease];
	if self.valueTranType.pos(etype.name.toUpper(),1) &gt; 0 then
		self.filterEventTypes.add(etype);
	endif;
	
	etype := app.myRoot.allEventTypesByType[EVT_LocationDiscrepIncrease];
	if self.valueTranType.pos(etype.name.toUpper(),1) &gt; 0 then
		self.filterEventTypes.add(etype);
	endif;
	
epilog

end;</source>
        <Parameter name="_criteria" type="String"/>
    </JadeMethod>
