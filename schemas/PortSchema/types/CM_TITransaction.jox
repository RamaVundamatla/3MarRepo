    <JadeMethod name="displayOldStatus" id="004a4bcd-84a1-4788-aef6-ba85a85b39ca">
        <source>displayOldStatus():String;

constants
//	NO_STATUS = #00;
	EXPORT_MASK = #10;
	IMPORT_MASK = #20;
	STORAGE_MASK = #40;
	TRANSIT_MASK = #1400;
	DLR_MASK = #1100;
vars
	str: String;
begin
	if self.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
		str := str&amp;"EMPTY";
	elseif self.contentsStatus = TI_CONTENTS_STATUS_FCL then
		str := str&amp;"FCL";
	elseif self.contentsStatus = TI_CONTENTS_STATUS_LCL then
		str := str&amp;"LCL";
	elseif self.contentsStatus = TI_CONTENTS_STATUS_NULL then
		str := str&amp;"NULL";
	else
		str := str&amp;"notset";
	endif;
	str := str&amp;" ";
	if self.imExStatus = IMPORT_MASK then
		str := str&amp;"IMPORT";
	elseif self.imExStatus = EXPORT_MASK then
		str := str&amp;"EXPORT";
	elseif self.imExStatus = STORAGE_MASK then
		str := str&amp;"STORAGE";
	elseif self.imExStatus = DLR_MASK then
		str := str&amp;"DLR";
	elseif self.imExStatus = SOB_MASK then
		str := str&amp;"SOB";
	elseif self.imExStatus = TRANSIT_MASK then
		str := str&amp;"TRANSIT";
	else
		str := str&amp;"notset";
	endif;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayStatus" id="18020a5c-6333-4d9f-ba34-2a4885fe68a9">
        <source>displayStatus():String;
//
// Changed On	By			Reason
// ----------	--------	----------------------------------------------
// 19/05/2010	cnwdap1		CCMS 1116 Tranship changes
vars
	str: String;
begin
	if self.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
		str := str&amp;"EMPTY";
	elseif self.contentsStatus = TI_CONTENTS_STATUS_FCL then
		str := str&amp;"FCL";
	elseif self.contentsStatus = TI_CONTENTS_STATUS_LCL then
		str := str&amp;"LCL";
	elseif self.contentsStatus = TI_CONTENTS_STATUS_NULL then
		str := str&amp;"NULL";
	else
		str := str&amp;"notset";
	endif;
	str := str&amp;" ";
	if self.imExStatus = TI_IMEX_STATUS_IMPORT then
		str := str&amp;"IMPORT";
	elseif self.imExStatus = TI_IMEX_STATUS_EXPORT then
		str := str&amp;"EXPORT";
	elseif self.imExStatus = TI_IMEX_STATUS_TRANSHIP then		// PAR #233645 CCMS 1116
		str := str&amp;"TRANSHIP";									// PAR #233645 CCMS 1116
	elseif self.imExStatus = TI_IMEX_STATUS_STORAGE then
		str := str&amp;"STORAGE";
	elseif self.imExStatus = TI_IMEX_STATUS_NULL then
		str := str&amp;"NULL";
	else
		str := str&amp;"notset";
	endif;
	str := str&amp;' ';		
	if self.transitStatus = TI_TransitStatusDLR then
		str := str&amp;"DLR";
	elseif self.transitStatus = TI_TransitStatusSOB then
		str := str&amp;"SOB";
	elseif self.transitStatus = TI_TransitStatusNull then
		str := str&amp;"NULL";
	else
		str := str&amp;"notset";
	endif;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doCreateCharge" id="4abd96c1-f116-4a7d-8543-cb574f34e84c">
        <updating/>
        <source>doCreateCharge(_passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jul 2021	navndl1	Initial creation	TFS 51443
07 Dec 2022 navma1  ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
*/

vars

begin

	if app.myPassport.isInEdiVerifyMode then
		return true;
	endif;
	
	if self.noCharge or app.isUnitTestGarbageCollect then
		return true;
	endif;

	self.createCharge( _passport );
	return not _passport.hasErrorsOrWarnings();

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doGroupAndSendSAP" id="05709fad-98f6-4e06-8bf1-75068f9c6105">
        <source>doGroupAndSendSAP( _invLineSet : CM_InvoiceLineSet ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2019	jlgndl1	Initial creation	TFS 44248

*/

vars

	inv : CM_Invoice;
	invLineSet : CM_InvoiceLineSet;
	invLine : CM_InvoiceLine;
	invLineSorted : DynaDictionary;
	invoiceSet : CM_InvoiceSet;
	invoice : CM_Invoice;
	obj : Object;
	msg : String;

begin
	return;
	
	if _invLineSet.isEmpty then
		// nothing to process.
		return;
	endif;

	create invoiceSet transient;	// collection of unique invoices
	create invLineSet transient;	// wil be invlines per unique invoice
		
	// set up a dyna dict sorted by invoice
	create invLineSorted transient;	// all inv lines passed in that have an invoice, sorted by invoice
	invLineSorted.setMembership( CM_InvoiceLine );
	invLineSorted.addMemberKey( CM_InvoiceLine::invoice.name, false, false );
	invLineSorted.endKeys( true );
	
	
	foreach invLine in _invLineSet do
		if invLine.invoice &lt;&gt; null then
			invLineSorted.add( invLine );
			invoiceSet.addNoDuplicates( invLine.invoice, false);
		endif;
	endforeach;
	
	//Iterate through the invoices to be processed, gather up their respective unsent invoice lines.
	foreach invoice in invoiceSet do
	
		invLineSet.clear();
		
		foreach obj in invLineSorted do
			invLine := obj.CM_InvoiceLine;
			if invLine.invoice = invoice then
				invLineSet.add( invLine );
			endif;
		endforeach;
		
		//and send them to SAP.
		if not invLineSet.isEmpty then
			msg := method.qualifiedName &amp; " - about to call CM_Invoice.sendSAP";	//07 May 2019	NDL	TFS 44248
			app.writeLog(msg,LogINFO);	//07 May 2019	NDL	TFS 44248
			invoice.sendSAP( 0, CM_Invoice.INVOICE_SEND_WSDL112, invLineSet );
		endif;
		
	endforeach;

epilog

	delete invLineSet;
	delete invLineSorted;
	delete invoiceSet;

end;</source>
        <access>protected</access>
        <Parameter name="_invLineSet" type="CM_InvoiceLineSet"/>
    </JadeMethod>
    <JadeMethod name="doResyncInvoiceLines" id="6f8cf7b1-81b1-419d-89b1-5ac5927dee20">
        <source>doResyncInvoiceLines(_sbController : CMIF_ServiceBroker input; _controller:CMIF_TiTransactionResync);
// ---------------------------------------------------------------------------
// Created:		19 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		take out any invoiceline type that we have already charged for
//	1271	handle full escalating invoice lines (multiple lines from one open-ended quantity range) by
//			processing only the first but reusing the rest as part of this process
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 06/10/2015	cnwdap1		PAR #36909 Minimum Charges changes
// 03/11/2016   cnwma1		PAR #38387 JMT creating new stevedoring invoice when cash collection done
// 17/05/2017	cnwdap1		TFS 3042 SNO Empty Pool Party 
// 24/11/2018   cnwma1		ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction
// 05 Oct 2022  navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
// 25 Jun 2024 	jlier1		TFS 64775
// 23 Oct 2024 	navlw1		JIRA-33107: Invoice Logging Use Levels
// 31 Jan 2025	navlw1 		JIRA-33865: MTN | Logging only displays that financials aren't enabled in logging level is TRACE
// 25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
// ---------------------------------------------------------------------------
vars
	invLine			 : CM_InvoiceLine;
	invLineTypes 	 : CM_InvoiceLineDescArray;
	invLineDesc 	 : CM_InvoiceLineDesc;
	invoiceLines	 : ObjectArray;
	escalatingLines	 : ObjectArray;
	obj				 : Object;
	qrm				 : CM_QuantityRangeMap;
	isVoided		 : Boolean;
	reject 			 : Boolean;
	bu 				 : CM_Bank;
	invoice			 : CM_Invoice;
	debtorTypeCode 	 : String;						// TFS 3042
	canLogExtra	     : Boolean;
	term			 : CM_Terminal;
begin

	bu 				:= self.getBusinessUnitObject();
	canLogExtra		:= app.canLogExtraDetail();				//05.10.2022 navma1 #52967
	
	create invLineTypes transient;
	create invoiceLines transient;
	create escalatingLines transient;
	
	// Start navlw1 #JIRA-33865 31/01/2025
	term := self.myTerminal;
	if term = null then
		app.raiseUnexpectedProgramError(class.name, method.name, CM_TITransaction::myTerminal.name &amp; " is null.");
		return;
	endif;
	if self.noCharge then
		if canLogExtra then  //25.02.2025 navah1 #34141
			app.invLog("Transaction is not chargeable",LogINFO.String); // navlw1 #JIRA-33692
		endif;
		return;
	endif;
	if not term.getConfig(FinancialsEnabled).Boolean then
		if canLogExtra then  //25.02.2025 navah1 #34141
			app.invLog("Financials Are Not Enabled, No Charging Will Occur",LogTRACE.String); // navlw1 #JIRA-33692  // ### JIRA 35228 11JUL2025 NAVAB1
		endif;
		return;
	endif;
	if not app.myRoot.canDo(Mod_Invoicing) then
		if canLogExtra then  //25.02.2025 navah1 #34141
			app.invLog("Invoice Module is not licensed",LogINFO.String); // navlw1 #JIRA-33692
		endif;
		return;
	endif;
	// End navlw1 #JIRA-33865 31/01/2025
	
	foreach invLine in self.allInvoiceLines discreteLock where invLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED do
		// from TFS 2017 15/06/2016 just skip lines for posted invoices here
		invoice := invLine.invoice;
		
		if invoice &lt;&gt; null and not invoice.canUpdate then    // 24/11/2018   cnwma1	ChangeRequest 41945
			continue;
		endif;
		
		//13 Jan 2009	NDL CCMS MES 1006
		if invLine.isResourceUsageBased then
			//jlier1 TFS 64775 25/6/24
			if not _sbController.isInvoiceCargoAllocation then
				// handled separately, has to be identified using the resource.
				continue;
			endif;
			if invLine.myResourceTypeUsage &lt;&gt; _sbController.myResourceTypeUsage then
				continue;
			endif;
		endif;
		
		if invLine.escalatingCount &gt; 1 then		// part of an escalating storage set, save separately - process the first such only
			escalatingLines.add(invLine);
		else
			invoiceLines.add(invLine);
		endif;
	endforeach;
	
	foreach obj in invoiceLines do
		invLine := obj.CM_InvoiceLine;
		
		// PAR #36909 if this invoice line has an associated original invoice line, it's a minimum charge line
		// Just skip it here, otherwise we'll end up Voiding it below (because its invoice line type isn't 
		// really part of the invoice)
		if invLine.myInvoiceLineOriginal &lt;&gt; null then
			continue;
		endif;
		// TFS 1990 do updateFromTransactionResync only for split invoice lines to get the change of debtor, the rest of the processing is not needed
		if invLine.manual and  invLine.myTransactionTI &lt;&gt; null then
			invLine.updateFromTransactionResync(self);
			invLineTypes.clear;
			_sbController.allInvoiceLineTypes.copy(invLineTypes);
			foreach invLineDesc in invLineTypes do
				if invLine.invoiceLineDesc = invLineDesc then
					_sbController.allInvoiceLineTypes.remove(invLineDesc);
					break;
				endif;
			endforeach;
			continue;
		endif;
		// TFS 3042 do updateFromTransactionResync only for Empty Pool Party invoice lines to get the change of debtor
		// Don't want to recalculate quantity, otherwise we end up voiding any extra lines created as part of the 
		// empty Pool Party split
		if invLine.invoiceLineDesc &lt;&gt; null and invLine.invoiceLineDesc.myDebtorType &lt;&gt; null then
			debtorTypeCode := invLine.invoiceLineDesc.myDebtorType.code;
			if debtorTypeCode = CM_DebtorType.DT_EMPTY_POOL_PARTY then
				invLine.updateFromTransactionResync(self);
				invLineTypes.clear;
				_sbController.allInvoiceLineTypes.copy(invLineTypes);
				foreach invLineDesc in invLineTypes do
					if invLine.invoiceLineDesc = invLineDesc then
						_sbController.allInvoiceLineTypes.remove(invLineDesc);
						break;
					endif;
				endforeach;
				continue;
			endif;
		endif;
		// TFS 3042 end
		
		reject := true;
		
		// if the business unit has changed then void all the invoice lines
		// i.e. if the CM_Bank has changed we wont get in this bit...
		if bu = null or (_sbController.myBank = bu) then
			invLineTypes.clear;
			_sbController.allInvoiceLineTypes.copy(invLineTypes);
			foreach invLineDesc in invLineTypes discreteLock do
				if invLine.invoiceLineDesc = invLineDesc then
					// take out any invoiceline type that we have already charged correctly for
					isVoided := invLine.updateFromTransactionResync(self);
					// from 33885 testing don't remove if the invoice is voided/posted
					if isVoided then
						reject := false;
						continue;
					endif;
					_sbController.allInvoiceLineTypes.remove(invLineDesc);
					reject := false;
					if invLine.escalatingCount = 0 then
						if invLine.isVolumeBased() then // ### TFS CR 55653 TASK 55669 20JUN2023 NAVAB1
							invLine.updateFromVBContractResync();  // ### TFS CR 55653 TASK 55669 20JUN2023 NAVAB1
						else
							invLine.setFromQuantityRangeMap(_sbController.getQRMFromLineType(invLineDesc)); // PAR 27193
						endif;
					elseif bu &lt;&gt; null then
						qrm := _sbController.getQRMFromRange(invLine.quantityRangeStart);
						if qrm &lt;&gt; null then
							invLine.calculateQuantity();
							bu.createEscChargeLines(invLine, qrm, escalatingLines);
						endif;
					endif;
				endif;
			endforeach;
		endif;
		
		if reject then
			// should not have been charged so void it
			if canLogExtra then							// 05.10.2022 navmd1 #52967
				app.invLog("Invoice line " &amp; invLine.sequenceNum.String &amp; " of invoice " &amp; invLine.invoice.sequenceNum.String &amp; " voided", LogTRACE.String);
			endif;
			if _controller.force then   				 // PAR 31637
				invoice := invLine.invoice;
				if invoice &lt;&gt; null and
					invoice.isPostedOrReversal then		//04 Sep 2017	NDL	TFS 6759	
					continue;
				endif;
			endif;
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
		endif;
	endforeach;

epilog 

	delete invLineTypes;
	delete invoiceLines;
	delete escalatingLines;
	
end;</source>
        <Parameter name="_sbController" type="CMIF_ServiceBroker" usage="input"/>
        <Parameter name="_controller" type="CMIF_TiTransactionResync"/>
    </JadeMethod>
    <JadeMethod name="doesCommodityMatch" id="3d6fc9dc-8faa-468c-89d2-84c5c6a45d61">
        <source>doesCommodityMatch() : Boolean;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars
	ti				: CM_TrackedItem;
	gotException	: Boolean;
	result			: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, ti, gotException);
	
	result := false;
	ti := self.myTrackedItem;
	if ti &lt;&gt; null then
		if ti.commodity = self.commodity then
			result := true;
		endif;
	endif;
	
	return result;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
