    <JadeMethod name="tCargoReview1" id="b6198ea1-ae23-41ff-82ad-b1fa50d82e25">
        <source>tCargoReview1();
/*

Purpose:			

Parameters:			

Return Value:		
Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation
*/
constants
	VESSEL= "DSEQ5";
	VOYAGE= "DSEQ005";
	CARGOTYPEDESC = "UT_PULP";
	BOL = "UTBOLSTWO2";
vars

	term : CM_Terminal;
	pxyBOL : CM_BOLIn;
	//tis : CM_TIArray;
	qDef : CM_QueryDefinition;
	myEnqController : CM_EnqControllerTI;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	criteriaLine : CM_SelectorCriteriaLine;
	user : CM_User;
	startOfTest : TimeStamp;
	dateArray : DateArray;
	cargoReviewQueryObj : CMIF_CargoReviewQuery;
	entTableDef : EntTableDef;
	cargoId : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;	
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	restOfTIs : CM_TISet;
	opCode, cgId, cgId2 : String;
	vessel : CM_Vessel;
	dateTime : TimeStamp;
	additionalRows, groupingRows : EntTableRowArray;
	bol : CM_BOL;
	querySize : Integer;
	quantityTotal : String;
begin

	startOfTest := app.actualTimeServer();
	term := self.getTerminal();
	create cargoReviewQueryObj transient;
	create additionalRows transient;
	create groupingRows transient;
	
	
	self.deleteCargoType(CARGOTYPEDESC);
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();	
	cargoOp := self.getOperator(opCode);
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	
	self.deleteBOL(BOL, null);	
	bol := createBOLObject(BOL, VOYAGE);
	
	
	totalQuantity := 1;
	totalWeight := 500;
	totalVolume := 4;
	create tis transient;	
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);
		
	create restOfTIs transient;
	
	foreach idy in cgSuffix to cgSuffix + 19 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort, "COM2", totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1, bol.number);	
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");		
		restOfTIs.add(ti);
	endforeach;
	
	cgId2 := "KM2" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId2);
	cargoGroup2 := self.addCargoGroup(cgId2,tis);	
	foreach idy in cgSuffix to cgSuffix + 19 do
		cargoId := cargoType.abbreviation &amp; "+" &amp; idy.padLeadingWith("0",3);		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,"COM2", totalWeight.Integer, totalVolume, totalQuantity, cargoGroup2, bol.number);		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");		
		restOfTIs.add(ti);
	endforeach;
	
	
	create criteriaHolder transient;	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewAdditional);
	additionalRows.add(entTableDef.getEntTableRow(ETRow_TotalQuantity));
	additionalRows.add(entTableDef.getEntTableRow(ETRow_Reservations));	

	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewGrouping);
	groupingRows.add(entTableDef.getEntTableRow(ETRow_CargoTypeDescr));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_MyProduct));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_Commodity));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_CargoGroupId));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_BillOfLading));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_VoyageCode));
	
	cargoReviewQueryObj.reset(term,criteriaHolder,groupingRows,additionalRows);

	user := app.getMyUser();
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	cargoReviewQueryObj.myEnqController.myTerminal := term;
	cargoReviewQueryObj.myEnqController.myCriteriaLineHolder := criteriaHolder;
	//this terminal only
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, term);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, 87821);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, 3);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );

	cargoReviewQueryObj.myEnqController.myContext := self;
	
	cargoReviewQueryObj.reset(term, criteriaHolder, cargoReviewQueryObj.allGroupingRows, cargoReviewQueryObj.allAdditionalRows);
	
	restOfTIs.copy(cargoReviewQueryObj.myEnqController.allObjects);
	cargoReviewQueryObj.doSearch();
	
	querySize := cargoReviewQueryObj.allGroupings.size;
	quantityTotal := cargoReviewQueryObj.allGroupings.first.getPropertyValue(ETRow_TotalQuantity).String;
	self.assertTrueMsg( querySize = 2, "Wrong number of grouping rows found in the query.  Expected 1 got " &amp; querySize.String);	
	self.assertTrueMsg( quantityTotal = "20", "Wrong total quantity.  Expected 20 got " &amp; quantityTotal );
	
	//self.assertTrueMsg( querySize = 1, "Wrong number of BOL Transactions found in the query.  Expected 1 got " &amp; querySize.String);	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	self.deleteCargoGroup(cargoGroup2.id);

epilog
	self.resetDefaultTranMap();
	delete pxyBOL;	
	delete tis;
	delete dateArray;
	delete criteriaHolder;
	delete myEnqController;
	delete cargoReviewQueryObj;
	delete additionalRows;
	delete groupingRows;
	delete restOfTIs;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoReview2" id="4f8290c1-a8be-4ce3-93c7-5d5c60161991">
        <source>tCargoReview2();
/*

Purpose:			

Parameters:			

Return Value:		
Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation
*/
constants
	VESSEL= "DSEQ5";
	VOYAGE= "DSEQ005";
	CARGOTYPEDESC = "UT_PULP";
	ProductId = "UT_PULP_PROD";
	BOLID = "UTBOLSTWO2";
	
vars

	term : CM_Terminal;
	pxyBOL : CM_BOLIn;
	//tis : CM_TIArray;
	qDef : CM_QueryDefinition;
	myEnqController : CM_EnqControllerTI;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	criteriaLine : CM_SelectorCriteriaLine;
	user : CM_User;
	startOfTest : TimeStamp;
	dateArray : DateArray;
	cargoReviewQueryObj : CMIF_CargoReviewQuery;
	entTableDef : EntTableDef;
	cargoId : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1, cargoGroup2 : CM_CargoGroup;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;	
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	restOfTIs : CM_TISet;
	opCode, cgId, cgId2 : String;
	vessel : CM_Vessel;
	dateTime : TimeStamp;
	additionalRows, groupingRows : EntTableRowArray;
	bol : CM_BOL;
	querySize : Integer;
	quantityTotal, bolCode : String;
	commodity, comod : CM_Commodity;
	jdo : JadeDynamicObject;
	index : Integer;
	type : Type;
	value : Any;	
	tisInGrouping : CM_TIByCargoTypeIdDict;
	product : CM_Product;
	iso : CM_ISOType;
	operator : CM_Operator;
	allComodities : CM_CommodityByCodeDict;
	allCargoTypes	: ObjectArray;	
	bolTerminal	: CM_BOLTerminal;
begin

	startOfTest := app.actualTimeServer();
	term := self.getTerminal();
	create cargoReviewQueryObj transient;
	create additionalRows transient;
	create groupingRows transient;
	//create cargoReviewQueryObj.allGroupingRows transient;
	
	self.deleteCargoType(CARGOTYPEDESC);
	create allComodities transient;
	
	comod := self.addCommodity("COM2","Comodity One",allCargoTypes);	
	
	allComodities.add(comod);
	self.opts.purge();
	self.opts.addAssoc("Comodities", allComodities);
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();	
	operator := app.myRoot.allOperators[opCode];
	product := self.addProduct(ProductId, operator, cargoType);
	//self.assertTrueMsg(product &lt;&gt; null, CargoTypeDesc &amp; "/" &amp; ProductId &amp; " not created during setup.");
	
	cargoOp := self.getOperator(opCode);
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	
	self.deleteBOL(BOLID, null);	
	bol := createBOLObject(BOLID, VOYAGE);
	
	
	totalQuantity := 1;
	totalWeight := 500;
	totalVolume := 4;
	create tis transient;	
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis);
		
	create restOfTIs transient;
	
	foreach idy in cgSuffix to cgSuffix + 19 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort, "COM2", totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1, bol.number);
		beginTransaction;
		ti.setBOL(bol.number);
		ti.setBOLDtl(bol.allBOLDtls.first);
		commitTransaction;
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");		
		restOfTIs.add(ti);
	endforeach;
	
	cgId2 := "KM2" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId2);
	cargoGroup2 := self.addCargoGroup(cgId2,tis);	
	foreach idy in cgSuffix to cgSuffix + 19 do
		cargoId := cargoType.abbreviation &amp; "+" &amp; idy.padLeadingWith("0",3);		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,"COM2", totalWeight.Integer, totalVolume, totalQuantity, cargoGroup2, bol.number);
		beginTransaction;
		ti.setBOL(bol.number);
		ti.setBOLDtl(bol.allBOLDtls.first);
		commitTransaction;
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");		
		restOfTIs.add(ti);
	endforeach;
	beginTransaction;
	bolTerminal := bol.getBOLTerminal(term, true);
	bol.allTrackedItems.copy(bolTerminal.allTrackedItems);	
	commitTransaction;
	
	
	create criteriaHolder transient;	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewAdditional);
	additionalRows.add(entTableDef.getEntTableRow(ETRow_TotalQuantity));
	additionalRows.add(entTableDef.getEntTableRow(ETRow_Reservations));	

	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewGrouping);
	groupingRows.add(entTableDef.getEntTableRow(ETRow_CargoTypeDescr));
	//groupingRows.add(entTableDef.getEntTableRow(ETRow_MyProduct));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_Commodity));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_CargoGroupId));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_BillOfLading));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_VoyageCode));
	
	cargoReviewQueryObj.deleteGroupings();	
	cargoReviewQueryObj.reset(term,criteriaHolder,groupingRows,additionalRows);

	user := app.getMyUser();
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	cargoReviewQueryObj.myEnqController.myTerminal := term;
	cargoReviewQueryObj.myEnqController.myCriteriaLineHolder := criteriaHolder;
	//this terminal only
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, term);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, 87821);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, 3);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );

	cargoReviewQueryObj.myEnqController.myContext := self;
	
	cargoReviewQueryObj.reset(term, criteriaHolder, cargoReviewQueryObj.allGroupingRows, cargoReviewQueryObj.allAdditionalRows);
	
	restOfTIs.copy(cargoReviewQueryObj.myEnqController.allObjects);
	cargoReviewQueryObj.doSearch();
	
	querySize := cargoReviewQueryObj.allGroupings.size;
	quantityTotal := cargoReviewQueryObj.allGroupings.first.getPropertyValue(ETRow_TotalQuantity).String;
	self.assertTrueMsg( querySize = 2, "Wrong number of grouping rows found in the query.  Expected 1 got " &amp; querySize.String);	
	self.assertTrueMsg( quantityTotal = "20", "Wrong total quantity.  Expected 20 got " &amp; quantityTotal );
	
	//commodity := app.myRoot.allCommodities["COM2"];
	jdo := cargoReviewQueryObj.allGroupings.first;
	
	if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then		
			tisInGrouping := value.CM_TIByCargoTypeIdDict;
			ti := tisInGrouping.first;
			if ti &lt;&gt; null then
				cargoType := ti.myCargoType;
				product := ti.myProduct;
				if ti.isContainer then
					iso := ti.getISOTypeObject();
				endif;				
				if cargoReviewQueryObj.allGroupingRows.getEntRowNamed(ETRow_BillOfLading) &lt;&gt; null then					
					if bol = null and bolCode &lt;&gt; null then
						if ti.myVoyage &lt;&gt; null then
							bol := ti.myVoyage.getBOL(bolCode);
						endif;
					endif;				
					if ti.myBOLDtl &lt;&gt; null then
						bol := ti.myBOLDtl.myBOL.CM_BOLIn;
					endif;
				endif;				
				if jdo.getPropertyInfoByName(ETRow_CargoGroupId,index,type,value) then
					cargoGroup1 := ti.myCargoGroup;
				endif;				
				if cargoReviewQueryObj.allGroupingRows.getEntRowNamed(ETRow_Commodity) &lt;&gt; null then
					if jdo.getPropertyInfoByName(ETRow_Commodity,index,type,value) then
						commodity := ti.getCommodityObject();
					endif;
				endif;
			endif;
		endif;
	
	jdo.getPropertyInfoByName(ETRow_VoyageCode,index,type,value);
	voyage := term.allVoyagesByCode.getAtKeyGeq(value.String,null);
	if voyage &lt;&gt; null 
		and voyage.code &lt;&gt; value.String then
			voyage := null;
	endif;
	
		
	createReleaseRequest(cargoType, cargoOp, voyage, commodity, 5, cargoGroup1, bol, product, "Rel01");
	
	querySize := cargoReviewQueryObj.allGroupings.size;
	quantityTotal := cargoReviewQueryObj.allGroupings.first.getPropertyValue(ETRow_TotalQuantity).String;
	self.assertTrueMsg( querySize = 2, "Wrong number of grouping rows found in the query.  Expected 1 got " &amp; querySize.String);	
	self.assertTrueMsg( quantityTotal = "20", "Wrong total quantity.  Expected 20 got " &amp; quantityTotal );
	
	cargoReviewQueryObj.doSearch();
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	self.deleteCargoGroup(cargoGroup2.id);
	

epilog
	self.resetDefaultTranMap();
	delete pxyBOL;	
	delete tis;
	delete dateArray;
	delete criteriaHolder;
	delete myEnqController;
	delete cargoReviewQueryObj;
	delete additionalRows;
	delete groupingRows;
	delete restOfTIs;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoReview_35029" id="65d44b02-b51f-4547-8fa6-eddb72f5f26c">
        <source>tCargoReview_35029();
/*

Purpose:			

Parameters:			
Date		Who		 Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation
This use case handles the scenario where after an ownership change approval, when a new release 
request is created for the remaining TI, there was an exception from the validation method even though there are
available items. 
For use cases where the ownership change is done and the release request is gated out; those use cases will be
covered as part of the new solution.

*/
constants
	VESSEL= "VESSEL_A";
	VOYAGE= "VOYAGE_Q";
	CARGOTYPEDESC = "UT_PAPER";
	ProductId = "UT_PAPER_PROD";
	BOLID_1 = "UT_BOL_01";	
	CGX = "CG_X";	
	COM1 = "NEWS";
vars

	term : CM_Terminal;
	//tis : CM_TIArray;
	startOfTest : TimeStamp;
	cargoReviewQueryObj : CMIF_CargoReviewQuery;
	cargoId : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;	
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	opCode, cgId : String;
	vessel : CM_Vessel;
	dateTime : TimeStamp;
	additionalRows, groupingRows : EntTableRowArray;
	bol : CM_BOL;
	comod : CM_Commodity;
	product : CM_Product;
	operator : CM_Operator;
	allComodities : CM_CommodityByCodeDict;
	allCargoTypes	: ObjectArray;
	bolTerminal	: CM_BOLTerminal;
	criteriaHolder : CM_QueryCriteriaLineHolder;	
	entTableDef : EntTableDef;	
	user : CM_User;
	qDef : CM_QueryDefinition;
	myEnqController : CM_EnqControllerTI;
	criteriaLine : CM_SelectorCriteriaLine;
	dateArray : DateArray;
	querySize : Integer;
	quantityTotal : String;
	jdo : JadeDynamicObject;
	reservations, quantityReserved : String;
	pxyBOL : CM_BOLIn;
	releaseReq : CM_BulkRelease;
	pxyBulkRelease : CM_BulkRelease;
	myOperatorNew : CM_Operator;
	debtor1 : CM_Debtor;
begin

	startOfTest := app.actualTimeServer();
	term := self.getTerminal();	
	self.deleteCargoType(CARGOTYPEDESC);
	create allComodities transient;	
	comod := self.addCommodity(COM1,"Comodity One",allCargoTypes);		
	allComodities.add(comod);	
	
	self.opts.purge();
	self.opts.addAssoc("Comodities", allComodities);
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();	
	operator := app.myRoot.allOperators[opCode];
	product := self.addProduct(ProductId, operator, cargoType);
	
	cargoOp := self.getOperator(opCode);
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	myOperatorNew := self.addOperator("ABCO", "Ownership Change OperatorNew", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	beginTransaction;
		voyage.allOperators.add(myOperatorNew);
	commitTransaction;
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	
	self.deleteBOL(BOLID_1, null);	
	bol := createBOLObject(BOLID_1, VOYAGE);
	
	
	totalQuantity := 1;
	totalWeight := 500;
	totalVolume := 4;
	create tis transient;	
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(CGX);
	cargoGroup1 := self.addCargoGroup(CGX,tis);	
	
	foreach idy in cgSuffix to cgSuffix + 9 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort, COM1, totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1, bol.number);
		beginTransaction;
		ti.setBOL(bol.number);
		ti.setBOLDtl(bol.allBOLDtls.first);
		commitTransaction;
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");		
		self.restOfTIs.add(ti);
	endforeach;
	beginTransaction;
	bolTerminal := bol.getBOLTerminal(term, true);
	bol.allTrackedItems.copy(bolTerminal.allTrackedItems);	
	cargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, COM1);	
	commitTransaction;
	
	
	term := self.getTerminal();
	create cargoReviewQueryObj transient;
	create additionalRows transient;
	create groupingRows transient;
	create criteriaHolder transient;	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewAdditional);
	additionalRows.add(entTableDef.getEntTableRow(ETRow_TotalQuantity));
	additionalRows.add(entTableDef.getEntTableRow(ETRow_Reservations));	
	additionalRows.add(entTableDef.getEntTableRow(ETRow_QuantityReserved));		

	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewGrouping);
	groupingRows.add(entTableDef.getEntTableRow(ETRow_CargoTypeDescr));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_Commodity));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_CargoGroupId));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_BillOfLading));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_VoyageCode));
	
	cargoReviewQueryObj.deleteGroupings();	
	cargoReviewQueryObj.reset(term,criteriaHolder,groupingRows,additionalRows);

	user := app.getMyUser();
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	cargoReviewQueryObj.myEnqController.myTerminal := term;
	cargoReviewQueryObj.myEnqController.myCriteriaLineHolder := criteriaHolder;
	//this terminal only
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, term);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, 87821);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, 3);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );

	cargoReviewQueryObj.myEnqController.myContext := self;
	
	cargoReviewQueryObj.reset(term, criteriaHolder, cargoReviewQueryObj.allGroupingRows, cargoReviewQueryObj.allAdditionalRows);
	
	self.restOfTIs.copy(cargoReviewQueryObj.myEnqController.allObjects);
	cargoReviewQueryObj.doSearch();
	
	querySize := cargoReviewQueryObj.allGroupings.size;
	quantityTotal := cargoReviewQueryObj.allGroupings.at(1).getPropertyValue(ETRow_TotalQuantity).String;
	self.assertTrueMsg( querySize = 1, "Wrong number of grouping rows found in the query.  Expected 1 got " &amp; querySize.String);	
	self.assertTrueMsg( quantityTotal = "10", "Wrong total quantity.  Expected 10 got " &amp; quantityTotal );	
	
	//self.deleteOwnershipChange("ABC2");
	self.createOwnershipChange(operator.code, cargoGroup1);
	
	self.opts.purge();
	cargoReviewQueryObj.doSearch();	
	jdo := cargoReviewQueryObj.allGroupings.at(1);	
	releaseReq := createRelReqUsingJDO(jdo, cargoReviewQueryObj, 5, "REL01");
	cargoReviewQueryObj.doSearch();		
	
	jdo := cargoReviewQueryObj.allGroupings.at(1);
	querySize := cargoReviewQueryObj.allGroupings.size;
	quantityTotal := jdo.getPropertyValue(ETRow_TotalQuantity).String;		
	reservations := jdo.getPropertyValue(ETRow_Reservations).String;
	quantityReserved := jdo.getPropertyValue(ETRow_QuantityReserved).Integer.asStringJMT;
	self.assertTrueMsg( querySize = 1, "Wrong number of grouping rows found in the query.  Expected 1 got " &amp; querySize.String);	
	self.assertTrueMsg(quantityTotal = "10", "Wrong total quantity.  Expected 10 got " &amp; quantityTotal );
	self.assertTrueMsg(reservations = "REL01(5)", "Wrong Reservation.  Expected REL01(5) got " &amp; reservations);
	self.assertTrueMsg(quantityReserved = "5", "Wrong quantity reserved.  Expected 5 got " &amp; quantityReserved );		
		
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup("CG_X");
	self.deleteCargoGroup("CG_Y");
	cargoReviewQueryObj.deleteGroupings();	
	
epilog
	self.resetDefaultTranMap();
	delete pxyBOL;
	delete dateArray;
	delete criteriaHolder;
	delete myEnqController;
	delete cargoReviewQueryObj;
	delete additionalRows;
	delete groupingRows;
	delete tis;
	if self.restOfTIs &lt;&gt; null then
		self.restOfTIs.clear;
		self.restOfTIs.purge;
	endif;
	delete pxyBulkRelease;	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoReview_EditReleaseReq" id="8957ecdc-31ff-4ec8-be41-acaddc1514de">
        <source>tCargoReview_EditReleaseReq();
/*

Purpose:			

Parameters:			

Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation


*/
constants
	VESSEL= "VESSEL_A";
	VOYAGE= "VOYAGE_Q";
	CARGOTYPEDESC = "UT_PAPER";
	ProductId = "UT_PAPER_PROD";
	BOLID_1 = "UT_BOL_01";	
	CGX = "CG_X";	
	COM1 = "NEWS";
vars

	term : CM_Terminal;
	//tis : CM_TIArray;
	startOfTest : TimeStamp;
	cargoReviewQueryObj : CMIF_CargoReviewQuery;
	cargoId : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;	
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	opCode, cgId : String;
	vessel : CM_Vessel;
	dateTime : TimeStamp;
	additionalRows, groupingRows : EntTableRowArray;
	bol : CM_BOL;
	comod : CM_Commodity;
	product : CM_Product;
	operator : CM_Operator;
	allComodities : CM_CommodityByCodeDict;
	allCargoTypes	: ObjectArray;
	bolTerminal	: CM_BOLTerminal;
	criteriaHolder : CM_QueryCriteriaLineHolder;	
	entTableDef : EntTableDef;	
	user : CM_User;
	qDef : CM_QueryDefinition;
	myEnqController : CM_EnqControllerTI;
	criteriaLine : CM_SelectorCriteriaLine;
	dateArray : DateArray;
	querySize : Integer;
	quantityTotal : String;
	jdo : JadeDynamicObject;
	reservations, quantityReserved : String;
	pxyBOL : CM_BOLIn;
	releaseReq : CM_BulkRelease;
	pxyBulkRelease : CM_BulkRelease;
begin

	startOfTest := app.actualTimeServer();
	term := self.getTerminal();	
	self.deleteCargoType(CARGOTYPEDESC);
	create allComodities transient;	
	comod := self.addCommodity(COM1,"Comodity One",allCargoTypes);		
	allComodities.add(comod);	
	
	self.opts.purge();
	self.opts.addAssoc("Comodities", allComodities);
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();	
	operator := app.myRoot.allOperators[opCode];
	product := self.addProduct(ProductId, operator, cargoType);
	
	cargoOp := self.getOperator(opCode);
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
		
	self.deleteBOL(BOLID_1, null);
	bol := createBOLObject(BOLID_1, VOYAGE);
	
	
	totalQuantity := 1;
	totalWeight := 500;
	totalVolume := 4;
	create tis transient;	
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(CGX);
	cargoGroup1 := self.addCargoGroup(CGX,tis);	
	
	foreach idy in cgSuffix to cgSuffix + 9 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort, COM1, totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1, bol.number);
		beginTransaction;
		ti.setBOL(bol.number);
		ti.setBOLDtl(bol.allBOLDtls.first);
		commitTransaction;
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");		
		self.restOfTIs.add(ti);
	endforeach;
	beginTransaction;
	bolTerminal := bol.getBOLTerminal(term, true);
	bol.allTrackedItems.copy(bolTerminal.allTrackedItems);	
	cargoType.setPropertyValue(CM_CargoType::defaultCommodityCode.name, COM1);	
	commitTransaction;
	
	
	term := self.getTerminal();
	create cargoReviewQueryObj transient;
	create additionalRows transient;
	create groupingRows transient;
	create criteriaHolder transient;	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewAdditional);
	additionalRows.add(entTableDef.getEntTableRow(ETRow_TotalQuantity));
	additionalRows.add(entTableDef.getEntTableRow(ETRow_Reservations));	
	additionalRows.add(entTableDef.getEntTableRow(ETRow_QuantityReserved));		

	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewGrouping);
	groupingRows.add(entTableDef.getEntTableRow(ETRow_CargoTypeDescr));
	//groupingRows.add(entTableDef.getEntTableRow(ETRow_MyProduct));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_Commodity));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_CargoGroupId));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_BillOfLading));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_VoyageCode));
	
	cargoReviewQueryObj.deleteGroupings();	
	cargoReviewQueryObj.reset(term,criteriaHolder,groupingRows,additionalRows);

	user := app.getMyUser();
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	cargoReviewQueryObj.myEnqController.myTerminal := term;
	cargoReviewQueryObj.myEnqController.myCriteriaLineHolder := criteriaHolder;
	//this terminal only
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, term);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, 87821);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, 3);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );

	cargoReviewQueryObj.myEnqController.myContext := self;
	
	cargoReviewQueryObj.reset(term, criteriaHolder, cargoReviewQueryObj.allGroupingRows, cargoReviewQueryObj.allAdditionalRows);
	
	self.restOfTIs.copy(cargoReviewQueryObj.myEnqController.allObjects);
	cargoReviewQueryObj.doSearch();
	
	querySize := cargoReviewQueryObj.allGroupings.size;
	quantityTotal := cargoReviewQueryObj.allGroupings.at(1).getPropertyValue(ETRow_TotalQuantity).String;
	self.assertTrueMsg( querySize = 1, "Wrong number of grouping rows found in the query.  Expected 1 got " &amp; querySize.String);	
	self.assertTrueMsg( quantityTotal = "10", "Wrong total quantity.  Expected 10 got " &amp; quantityTotal );
	
	//commodity := app.myRoot.allCommodities["COM2"];
	jdo := cargoReviewQueryObj.allGroupings.at(1);	
	releaseReq := createRelReqUsingJDO(jdo, cargoReviewQueryObj, 5, "REL01");
	cargoReviewQueryObj.doSearch();	
	
	jdo := cargoReviewQueryObj.allGroupings.at(1);
	querySize := cargoReviewQueryObj.allGroupings.size;
	quantityTotal := jdo.getPropertyValue(ETRow_TotalQuantity).String;		
	reservations := jdo.getPropertyValue(ETRow_Reservations).String;
	quantityReserved := jdo.getPropertyValue(ETRow_QuantityReserved).Integer.asStringJMT;
	self.assertTrueMsg( querySize = 1, "Wrong number of grouping rows found in the query.  Expected 1 got " &amp; querySize.String);	
	self.assertTrueMsg(quantityTotal = "10", "Wrong total quantity.  Expected 10 got " &amp; quantityTotal );
	self.assertTrueMsg(reservations = "REL01(5)", "Wrong Reservation.  Expected REL01(5) got " &amp; reservations);
	self.assertTrueMsg(quantityReserved = "5", "Wrong quantity reserved.  Expected 5 got " &amp; quantityReserved );
	
	pxyBulkRelease := app.createUpdateProxy(releaseReq).CM_BulkRelease;
	pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.setTotalRequested(8);	
	app.myTrxUA.trxUpdateBulkRelease(pxyBulkRelease, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
		
	cargoReviewQueryObj.doSearch();	
	jdo := cargoReviewQueryObj.allGroupings.at(1);
	quantityReserved := jdo.getPropertyValue(ETRow_QuantityReserved).Integer.asStringJMT;
	self.assertTrueMsg(quantityReserved = "8", "Wrong quantity reserved.  Expected 8 got " &amp; quantityReserved );
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup("CG_X");
	self.deleteCargoGroup("CG_Y");
	cargoReviewQueryObj.deleteGroupings();	
	
epilog
	self.resetDefaultTranMap();
	delete pxyBOL;
	delete dateArray;
	delete criteriaHolder;
	delete myEnqController;
	delete cargoReviewQueryObj;
	delete additionalRows;
	delete groupingRows;
	delete tis;
	if self.restOfTIs &lt;&gt; null then
		self.restOfTIs.clear;
		self.restOfTIs.purge;
	endif;
	delete pxyBulkRelease;	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoReview_PartialRelEdit" id="228802f3-286f-49b3-b302-1e56ff670fa9">
        <source>tCargoReview_PartialRelEdit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2025	navrv30	Initial creation
23 September 2025	navrv30	MTN 36110 and MTN 35839
*/

constants
	VESSEL= "DSEQ5";
	VOYAGE= "DSEQ005";
	CARGOTYPEDESC = "UT_PULP";
	BOLID = "UTBOLSTWO2";
	TruckId : String = 'UTTRK1';
	ProductId = "UT_PAPER_PROD";
	BLOCKSTACK : String = "BSGateOut" ;
vars

	term : CM_Terminal;
	pxyBOL : CM_BOLIn;
	//tis : CM_TIArray;
	qDef : CM_QueryDefinition;
	myEnqController : CM_EnqControllerTI;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	criteriaLine : CM_SelectorCriteriaLine;
	user : CM_User;
	startOfTest : TimeStamp;
	dateArray : DateArray;
	cargoReviewQueryObj : CMIF_CargoReviewQuery;
	entTableDef : EntTableDef;
	cargoType : CM_CargoType;
	cargoGroup1 : CM_CargoGroup;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;	
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	opCode, cgId : String;
	vessel : CM_Vessel;
	dateTime : TimeStamp;
	additionalRows, groupingRows : EntTableRowArray;
	bol : CM_BOL;
	querySize : Integer;
	quantityTotal : String;
	vvr : CM_VehicleVisitRecord;
	jdo : JadeDynamicObject;
	releaseReq : CM_BulkRelease;
	vehicleName, 
	driverName			: String;	
	gate				: CM_Gate;
	driver				: CM_DriverDetails;
	terminalUTHelper	: UT_HelperAdmTerm;
	vehicle				: CM_Vehicle;
	product					: CM_Product;
	tI1,
	tI2,
	tI3,
	tI4,
	tI5					: CM_TrackedItem;
	blockStack, 
	targetBs				: CM_BlockStack;
	wle						: CM_WorkListEntry;
	tmpFoundLC				: CM_LocationsController;
	moveController			: CMIF_MoveController;
	pxyBulkRelease : CM_BulkRelease;
begin

	startOfTest := app.actualTimeServer();
	term := self.getTerminal();
	create cargoReviewQueryObj transient;
	create additionalRows transient;
	create groupingRows transient;
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteTerminalArea("UTBS2GateOut");
	
	// setup stuff 
	blockStack := self.addBlockStack(BLOCKSTACK, 10, null);
	targetBs := self.addBlockStack("UTBS2GateOut", 10, null);
	
	self.deleteCargoType(CARGOTYPEDESC);
	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();	
	cargoOp := self.getOperator(opCode);
	product := self.addProduct(ProductId, cargoOp, cargoType);
	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	
	self.deleteBOL(BOLID, null);	
	bol := createBOLObject(BOLID, VOYAGE);
	
	
	totalQuantity := 1;
	totalWeight := 500;
	totalVolume := 4;
	//create tis transient;	
	cgSuffix := 100;
	cgId := "RK" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,null);
		
	self.deleteCargo("UTBul01", cargoType);
	self.deleteCargo("UTBul02", cargoType);
	self.deleteCargo("UTBul03", cargoType);
	self.deleteCargo("UTBul04", cargoType);
	self.deleteCargo("UTBul05", cargoType);
	
	tI1 := self.addCargoBreakBulkAtLocation("UTBul01", cargoType, 1, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, cargoOp);
	
	tI2 := self.addCargoBreakBulkAtLocation("UTBul02", cargoType, 1, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, cargoOp);
	
	tI3 := self.addCargoBreakBulkAtLocation("UTBul03", cargoType, 1, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, cargoOp);
	
	tI4 := self.addCargoBreakBulkAtLocation("UTBul04", cargoType, 1, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, cargoOp);
	
	tI5 := self.addCargoBreakBulkAtLocation("UTBul05", cargoType, 1, blockStack.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, cargoOp);
	beginTransaction;
	tI1.setCargoGroup(cargoGroup1, cgId, app.myPassport);
	tI2.setCargoGroup(cargoGroup1, cgId, app.myPassport);
	tI3.setCargoGroup(cargoGroup1, cgId, app.myPassport);
	tI4.setCargoGroup(cargoGroup1, cgId, app.myPassport);
	tI5.setCargoGroup(cargoGroup1, cgId, app.myPassport);
	commitTransaction;

	restOfTIs.add(tI1);	
	restOfTIs.add(tI2);
	restOfTIs.add(tI3);
	restOfTIs.add(tI4);
	restOfTIs.add(tI5);
	
	
	create criteriaHolder transient;	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewAdditional);
	additionalRows.add(entTableDef.getEntTableRow(ETRow_TotalQuantity));
	additionalRows.add(entTableDef.getEntTableRow(ETRow_Reservations));	

	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewGrouping);
	groupingRows.add(entTableDef.getEntTableRow(ETRow_CargoTypeDescr));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_MyProduct));
	//groupingRows.add(entTableDef.getEntTableRow(ETRow_Commodity));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_CargoGroupId));
	//groupingRows.add(entTableDef.getEntTableRow(ETRow_BillOfLading));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_VoyageCode));
	
	cargoReviewQueryObj.reset(term,criteriaHolder,groupingRows,additionalRows);

	user := app.getMyUser();
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	cargoReviewQueryObj.myEnqController.myTerminal := term;
	cargoReviewQueryObj.myEnqController.myCriteriaLineHolder := criteriaHolder;
	//this terminal only
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, term);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, 87821);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, 3);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );

	cargoReviewQueryObj.myEnqController.myContext := self;
	
	cargoReviewQueryObj.reset(term, criteriaHolder, cargoReviewQueryObj.allGroupingRows, cargoReviewQueryObj.allAdditionalRows);
	
	self.restOfTIs.copy(cargoReviewQueryObj.myEnqController.allObjects);
	cargoReviewQueryObj.doSearch();
	
	jdo := cargoReviewQueryObj.allGroupings.at(1);	
	releaseReq := createRelReqUsingJDO(jdo, cargoReviewQueryObj, 5, "REL01");
	cargoReviewQueryObj.doSearch();	
	
	querySize := cargoReviewQueryObj.allGroupings.size;
	quantityTotal := cargoReviewQueryObj.allGroupings.first.getPropertyValue(ETRow_TotalQuantity).String;
	self.assertTrueMsg( querySize = 1, "Wrong number of grouping rows found in the query.  Expected 1 got " &amp; querySize.String);	
	self.assertTrueMsg( quantityTotal = "5", "Wrong total quantity.  Expected 5 got " &amp; quantityTotal );
	
	
	//========================gate out
	create terminalUTHelper transient;
	terminalUTHelper.setActiveProfile;
	terminalUTHelper.currentMethodBeingRun := UT_CargoReview::tCargoReview_PartialRelEdit;
	
	driverName := self.getDriverName();
	self.assertNotNullMsg(driverName, "driverName");
	vehicleName := TruckId;
	// Delete Vehicle		
	self.deleteVehicle(vehicleName);
	gate := self.getTerminal.getConfig(GateDefaultEntry).CM_Gate;
	self.assertNotNullMsg(gate, "Gate");
	
	// Create vehicle visit
	vvr := terminalUTHelper.xCreateVehicleVisitRecord(vehicleName, driverName, driverName, null, term, gate.name);
	self.assertNotNullMsg(vvr, "vvr");
	
	//Get Driver
	driver := term.allDriversByCode[driverName];
	self.assertNotNullMsg(driver, "driver");
	
	//Get Vehicle
	vehicle :=  term.vehicles.getAtKeyGeq(vehicleName, null);
	self.assertNotNullMsg(vehicle, "vehicle");
	
	
	terminalUTHelper.opts.addAssoc("ReleaseRequest", releaseReq);
	terminalUTHelper.opts.addAssoc(UTTI_CargoSubType, product);
	
	vvr := terminalUTHelper.xCreateGateEntityOutRelease(vvr, null, null,5,releaseReq);
	
	self.assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	terminalUTHelper.opts.purge();
	
	// self.opts.addAssoc("YardInterchangeArea", self.yic.id);
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(gate.name), 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.getPGate(gate.name), 1));
	
	terminalUTHelper.xMoveVehicleToYard(vvr.vehicle);
	
	// get the wle
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.allWorkListEntries.first;
	
	// get the location
	tmpFoundLC:= wle.getRoadReleaseLC();

	// create the move controllerwill take 10 mins
	create moveController transient;
	moveController.setMyWorkListEntry(wle);							
	moveController.setMyToPrimaryLocation(tmpFoundLC);
	moveController.setMyTrackedItem(tI1);
	moveController.setQuantity(1);
	
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	delete moveController;
	
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.myJob.getFirstWle();
	create moveController transient;
	moveController.setMyWorkListEntry(wle);							
	moveController.setMyToPrimaryLocation(tmpFoundLC);
	moveController.setMyTrackedItem(tI2);
	moveController.setQuantity(1);
	
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	
	delete moveController;
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.myJob.getFirstWle();
	create moveController transient;
	moveController.setMyWorkListEntry(wle);							
	moveController.setMyToPrimaryLocation(tmpFoundLC);
	moveController.setMyTrackedItem(tI3);
	moveController.setQuantity(1);
	
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	delete moveController;
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.myJob.getFirstWle();
	create moveController transient;
	moveController.setMyWorkListEntry(wle);							
	moveController.setMyToPrimaryLocation(tmpFoundLC);
	moveController.setMyTrackedItem(tI4);
	moveController.setQuantity(1);
	
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
	delete moveController;
	
	wle := vvr.allGateEntities.first.CMGTE_Release.myYardRequest.myJob.getFirstWle();
	self.deleteJobEntry(wle);
	
	self.roadExit(vvr);
	self.assertEqualMsg(releaseReq.status, BR_ACTIVE, "The release request has not been completed");
	
	pxyBulkRelease := app.createUpdateProxy(releaseReq).CM_BulkRelease;
	pxyBulkRelease.allReserveDetails.first.CM_ReserveSelection.setTotalRequested(4);	
	app.myTrxUA.trxUpdateBulkRelease(pxyBulkRelease, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	self.assertEqualMsg(releaseReq.status, BR_COMPLETE, "The release request has not been completed");
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);

epilog
	self.resetDefaultTranMap();
	delete pxyBOL;
	delete dateArray;
	delete criteriaHolder;
	delete myEnqController;
	delete cargoReviewQueryObj;
	delete additionalRows;
	delete groupingRows;
	if self.restOfTIs &lt;&gt; null then
		self.restOfTIs.clear;
		self.restOfTIs.purge;
	endif;
	//delete tiSet;
	delete terminalUTHelper;
	delete pxyBulkRelease;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoReview_Scenario01" id="ebe2608b-09b3-4886-81c5-f33fefe0208b">
        <source>tCargoReview_Scenario01();
/*

Purpose:			

Parameters:			

Return Value:	
SCENARIO-1	Grouping: Voyage, Cargo Type, Cargo Subtype, Commodity, Cargo Group, BOL							
								
Voyage		Cargo Type		Cargo Subtype		Commodity		Cargo Group		BOL		Total Qty	Qty Reserved	Reservations
VOYAGE_A	Paper			Reel				 NEWS				CG_Z		BOL_101		10			5				REL01 (5)
VOYAGE_A	Paper			Reel				 NEWS				CG_Y		BOL_101		15			7				REL02 (4), REL03 (3)
VOYAGE_A	Paper			Reel				 COPY				CG_X		BOL_102	 	25			12				REL04 (12)
VOYAGE_A	Paper			Reel				 COPY							BOL_103		20			8				REL05 (8)
Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation	

*/
constants	
	VOYAGE= "VOYAGE_Q";	
vars

	term : CM_Terminal;
	pxyBOL : CM_BOLIn;
	qDef : CM_QueryDefinition;
	myEnqController : CM_EnqControllerTI;
	criteriaHolder : CM_QueryCriteriaLineHolder;
	criteriaLine : CM_SelectorCriteriaLine;
	user : CM_User;
	dateArray : DateArray;
	cargoReviewQueryObj : CMIF_CargoReviewQuery;
	entTableDef : EntTableDef;
	additionalRows, groupingRows : EntTableRowArray;
	querySize : Integer;
	quantityTotal : String;
	jdo : JadeDynamicObject;
	reservations, quantityReserved : String;
begin

	createCargoReviewData();
	term := self.getTerminal();
	create cargoReviewQueryObj transient;
	create additionalRows transient;
	create groupingRows transient;
	create criteriaHolder transient;
	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewAdditional);
	additionalRows.add(entTableDef.getEntTableRow(ETRow_TotalQuantity));
	additionalRows.add(entTableDef.getEntTableRow(ETRow_Reservations));	
	additionalRows.add(entTableDef.getEntTableRow(ETRow_QuantityReserved));	
	

	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewGrouping);
	groupingRows.add(entTableDef.getEntTableRow(ETRow_CargoTypeDescr));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_MyProduct));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_Commodity));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_CargoGroupId));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_BillOfLading));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_VoyageCode));
	
	cargoReviewQueryObj.deleteGroupings();	
	cargoReviewQueryObj.reset(term,criteriaHolder,groupingRows,additionalRows);

	user := app.getMyUser();
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	cargoReviewQueryObj.myEnqController.myTerminal := term;
	cargoReviewQueryObj.myEnqController.myCriteriaLineHolder := criteriaHolder;
	//this terminal only
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, term);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, 87821);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, 3);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );

	cargoReviewQueryObj.myEnqController.myContext := self;
	
	cargoReviewQueryObj.reset(term, criteriaHolder, cargoReviewQueryObj.allGroupingRows, cargoReviewQueryObj.allAdditionalRows);
	
	restOfTIs.copy(cargoReviewQueryObj.myEnqController.allObjects);
	cargoReviewQueryObj.doSearch();
	
	querySize := cargoReviewQueryObj.allGroupings.size;
	quantityTotal := cargoReviewQueryObj.allGroupings.at(1).getPropertyValue(ETRow_TotalQuantity).String;
	self.assertTrueMsg( querySize = 4, "Wrong number of grouping rows found in the query.  Expected 1 got " &amp; querySize.String);	
	self.assertTrueMsg( quantityTotal = "10", "Wrong total quantity.  Expected 10 got " &amp; quantityTotal );
	
	jdo := cargoReviewQueryObj.allGroupings.at(1);	
	createRelReqUsingJDO(jdo, cargoReviewQueryObj, 5, "REL01");
	cargoReviewQueryObj.doSearch();
	
	jdo := cargoReviewQueryObj.allGroupings.at(2);	
	createRelReqUsingJDO(jdo, cargoReviewQueryObj, 4, "REL02");
	createRelReqUsingJDO(jdo, cargoReviewQueryObj, 3, "REL03");
	cargoReviewQueryObj.doSearch();
	
	jdo := cargoReviewQueryObj.allGroupings.at(3);	
	createRelReqUsingJDO(jdo, cargoReviewQueryObj, 12, "REL04");
	cargoReviewQueryObj.doSearch();
	
	jdo := cargoReviewQueryObj.allGroupings.at(4);	
	createRelReqUsingJDO(jdo, cargoReviewQueryObj, 8, "REL05");
	
	cargoReviewQueryObj.doSearch();
	
	jdo := cargoReviewQueryObj.allGroupings.at(1);
	querySize := cargoReviewQueryObj.allGroupings.size;
	quantityTotal := jdo.getPropertyValue(ETRow_TotalQuantity).String;		
	reservations := jdo.getPropertyValue(ETRow_Reservations).String;
	quantityReserved := jdo.getPropertyValue(ETRow_QuantityReserved).Integer.asStringJMT;
	self.assertTrueMsg( querySize = 4, "Wrong number of grouping rows found in the query.  Expected 4 got " &amp; querySize.String);	
	self.assertTrueMsg(quantityTotal = "10", "Wrong total quantity.  Expected 10 got " &amp; quantityTotal );
	self.assertTrueMsg(reservations = "REL01(5)", "Wrong Reservation.  Expected REL01(5) got " &amp; reservations);
	self.assertTrueMsg(quantityReserved = "5", "Wrong quantity reserved.  Expected 5 got " &amp; quantityReserved );	
	
	jdo := cargoReviewQueryObj.allGroupings.at(2);
	quantityTotal :=jdo.getPropertyValue(ETRow_TotalQuantity).String;
	reservations := jdo.getPropertyValue(ETRow_Reservations).String;
	quantityReserved := jdo.getPropertyValue(ETRow_QuantityReserved).Integer.asStringJMT;		
	self.assertTrueMsg(quantityTotal = "15", "Wrong total quantity.  Expected 15 got " &amp; quantityTotal );
	self.assertTrueMsg(reservations = "REL02(4),REL03(3)", "Wrong Reservation.  Expected REL02(4),REL03(3) got " &amp; reservations);
	self.assertTrueMsg(quantityReserved = "7", "Wrong quantity reserved.  Expected 7 got " &amp; quantityReserved );
	
	jdo := cargoReviewQueryObj.allGroupings.at(3);
	quantityTotal :=jdo.getPropertyValue(ETRow_TotalQuantity).String;
	reservations := jdo.getPropertyValue(ETRow_Reservations).String;
	quantityReserved := jdo.getPropertyValue(ETRow_QuantityReserved).Integer.asStringJMT;		
	self.assertTrueMsg(quantityTotal = "25", "Wrong total quantity.  Expected 25 got " &amp; quantityTotal );
	self.assertTrueMsg(reservations = "REL04(12)", "Wrong Reservation.  Expected REL04(12) got " &amp; reservations);
	self.assertTrueMsg(quantityReserved = "12", "Wrong quantity reserved.  Expected 12 got " &amp; quantityReserved );
	
	jdo := cargoReviewQueryObj.allGroupings.at(4);
	quantityTotal :=jdo.getPropertyValue(ETRow_TotalQuantity).String;
	reservations := jdo.getPropertyValue(ETRow_Reservations).String;
	quantityReserved := jdo.getPropertyValue(ETRow_QuantityReserved).Integer.asStringJMT;		
	self.assertTrueMsg(quantityTotal = "20", "Wrong total quantity.  Expected 20 got " &amp; quantityTotal );
	self.assertTrueMsg(reservations = "REL05(8)", "Wrong Reservation.  Expected REL05(8) got " &amp; reservations);
	self.assertTrueMsg(quantityReserved = "8", "Wrong quantity reserved.  Expected 8 got " &amp; quantityReserved );
	
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup("CG_X");
	self.deleteCargoGroup("CG_Y");
	cargoReviewQueryObj.deleteGroupings();	
	
	
epilog
	self.resetDefaultTranMap();
	delete pxyBOL;	
