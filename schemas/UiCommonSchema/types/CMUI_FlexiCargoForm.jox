    <JadeMethod name="onReleaseRefChanged" id="747d45eb-68fe-44d7-ab89-e8e6942abdae">
        <updating/>
        <source>onReleaseRefChanged(_id : String) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2009	cnwjk3	Initial creation

*/

vars
	bulkRelease	: CM_BulkRelease;
	reserve		: CM_ReserveDetail;
begin
	if _id &lt;&gt; null /*and not self.hasBulkRelease()*/ then
		//+cnwml2 PAR21161
		
		if self.myAssistant.getReserveDetailFromCode(_id, bulkRelease, reserve, false) then			
			self.myBulkRelease := bulkRelease;
			self.myReserveDetail := reserve;
		else
			self.myBulkRelease := null;
			self.myReserveDetail := null;
		endif;
	endif;
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="purgeTransientAttachments" id="11a567ae-4e41-4c2b-a974-c2ba8c686b7d">
        <source>purgeTransientAttachments();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 October 2012	cnwndl1	Initial creation	Par 30503

*/

vars

	localArray : ObjectArray;
	obj : Object;

begin

	if self.allAttachments.isEmpty then
		return;
	endif;
	
	create localArray transient;
	self.allAttachments.copy( localArray );

	foreach obj in localArray do
		if obj.isTransient then
			delete obj;
		endif;
	endforeach;
	
	self.allAttachments.clear();

epilog

	delete localArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="resetForm" id="a54a1a86-dcab-49a0-baca-28e7838967fd">
        <updating/>
        <source>resetForm() updating;
// -----------------------------------------------------------------------------
// Created:		04 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//	17/12/2009	cnwdap1		PAR #21827 Allow attachment to be edited directly from this form - correct setting of proxies
//	11/02/2011	cnwdap1		PAR #26929 Tidy up proxies if we have a receival by type 
//										This creates 3 proxies: CMGTE_ReceivalByType, CM_GTEReceivalInfo and CM_ReceivalRequestInfo
//										CMGTE_ReceivalByType are CM_GTEReceivalInfo parent/child so are OK, but we're left with a CM_ReceivalRequestInfo
// -----------------------------------------------------------------------------

vars

begin
	// don't delete the proxy GTE_Entity if we're doing attachments (parent form is the same kind as this form)
	if not self.myParentForm.isKindOf(CMUI_ReceiveCargoForm) then
		// PAR # 26929 tidy up references on self.myPxyGTEEntity 
		if CMGTE_ReceivalByType.hasInstance(self.myPxyGTEEntity) then
			if self.myPxyGTEEntity.CMGTE_ReceivalByType.myReceivalInfo &lt;&gt; null and self.myPxyGTEEntity.CMGTE_ReceivalByType.myReceivalInfo.myReceivalRequestInfo &lt;&gt; null then
				delete self.myPxyGTEEntity.CMGTE_ReceivalByType.myReceivalInfo.myReceivalRequestInfo;
				// self.myPxyGTEEntity.CMGTE_ReceivalByType.myReceivalInfo is a child of self.myPxyGTEEntity - will be deleted automatically
			endif;
		endif;
		// PAR #26929 end
		delete self.myPxyGTEEntity;
	endif;
	// delete the proxy tracked item unless we've come from the rail cargo form, in which case the proxy is the tracked item
	// PAR #21827 Also don't delete if we're an attachment form, the proxy will still be n use by the parent form
	if app.isValidObject(myProxyTrackedItem) and not self.isRailPreNoteForm and not self.myParentForm.isKindOf(CMUI_ReceiveCargoForm) then
		self.myProxyTrackedItem.erase(NORMAL_ERASE);
		self.myProxyTrackedItem := null;
	endif;

	self.updateMode := self.Mode_Add;

	self.myPxyGTEEntity := null;
	self.myRealGTEEntity := null;
	
	self.allAttachments.clear();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="restoreComboObject" id="79522d89-2363-471a-8b6e-2b3654af34fd">
        <source>restoreComboObject(_combo : CMUI_FieldComboBox input; _obj: Object; _overwrite : Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2009	cnwjk3	Initial creation

*/

vars

begin
	if not _overwrite and _combo.getObject &lt;&gt; null then
		return;
	endif;	
	if _obj &lt;&gt; null then
		_combo.setForObject(_obj);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_FieldComboBox" usage="input"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_overwrite" type="Boolean"/>
    </JadeMethod>
