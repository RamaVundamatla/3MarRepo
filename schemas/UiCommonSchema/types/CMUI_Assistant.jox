    <JadeMethod name="comboBoxRailIdFormat" id="400bd5cc-baf1-4425-b25b-8b185e8f5dc8">
        <source>comboBoxRailIdFormat(_cmb : ComboBox input; _int : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

	index : Integer;

begin

	_cmb.clear;

	index := _cmb.addItem("");
	_cmb.itemData[index] := 0;
	index := _cmb.addItem(Rail_JMT_Str);
	_cmb.itemData[index] := Rail_JMT_Int;
	index := _cmb.addItem(Rail_UPSP_Str);
	_cmb.itemData[index] := Rail_UPSP_Int;
	
	
	if _int &lt;&gt; null then
		foreach index in 1 to _cmb.listCount do
			if _cmb.itemData[index] = _int then
				_cmb.listIndex := _int;
				break;
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_int" type="Integer"/>
