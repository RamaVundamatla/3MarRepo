<GUIClass name="Button">
    <JadeMethod name="controlNamePrefix" id="5aed3ed7-df0f-450f-867b-4225d235b9b8">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		05 May 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "btn";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssSet" id="84547d10-4664-4cc8-aa5d-7489e41b8c1c">
        <updating/>
        <source>jssSet(pValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		13 August 2002 by cnwdad1
//
// Purpose:		Updates the receiver's caption with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.caption &lt;&gt; pValue then
		self.caption	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
</GUIClass>
