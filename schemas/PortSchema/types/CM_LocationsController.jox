    <JadeMethod name="testAutoPlan" id="7ce97e6f-8029-4acc-a302-5931c1cd0bf0">
        <source>testAutoPlan(obj : CMIF_AutoMovePlan input);
/* This is the MAIN routine called by each AttributePlan area, for each locationController
		in the list of lc's the users have specified to test. We ask each controller in turn to
		advise its suitability to accept the object in the obj parameter to this method.
		The calls to the sub-methods must be in the correct order, there is an element of
		precession for each method in turn. 
		If any of these methods encounters an issue that it considers will STOP the TI being
		moved to that LC, the targetLocation portion of the object is nulled.
		DWQ 08 April 1998
*/
vars
	anId	:	String;
begin

	//-------------
	//Default to OK from here, if the LC is no good, its cleared.
	//-------------
	obj.updateController(self);
	//-------------
	//Start the tests
	//-------------
	anId := self.getFullId;

	//obj.addVerboseLogEntry(anId &amp; " testing availability.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_availability, anId), IsForLogging, Testing_availability);
	self.testIsControllerAvailable(obj);
	if obj.getController = null then
		//obj.addVerboseLogEntry(anId &amp; " is unavailable.", IsForLogging); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString1(Unavailable,anId), IsForLogging, Unavailable);
  		return;
	endif;

	//obj.addVerboseLogEntry(anId &amp; " testing capacity.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_capacity,anId), IsForLogging, Testing_capacity);
	self.testIsControllerFull(obj);
	if obj.getController = null then
		//obj.addVerboseLogEntry(anId &amp; " is unsuitable due to capacity issues.", IsError); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString1(Unsuitable_capacity_issues,anId), IsError, Unsuitable_capacity_issues);
  		return;
	endif;

	//obj.addVerboseLogEntry(anId &amp; " testing restrictions.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_restrictions_param,anId), IsForLogging, Testing_restrictions_param);
	self.testIsControllerRestricted(obj);
	if obj.getController = null then
		//obj.addVerboseLogEntry(anId &amp; " is Restricted in some way (labour/Location).", IsError); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString1(Restricted_some_labourloca,anId), IsError, Restricted_some_labourloca);
  	return;
	endif;

	//obj.addVerboseLogEntry(anId &amp; " testing Voyage.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_voyage, anId), IsForLogging, Testing_voyage);
 	self.testIsDiffVoyage(obj);
 	if obj.getController = null then
		//obj.addVerboseLogEntry(anId &amp; " has objects of a different Voyage.", IsWarning); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString1(Objects_different_voyage,anId), IsWarning, Objects_different_voyage);
  	return;
 	endif;

	//obj.addVerboseLogEntry(anId &amp; " testing Commodity Group.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_commodity_group,anId), IsForLogging, Testing_commodity_group);
	self.testIsDiffCmdtyGroup(obj);
	if obj.getController = null then
		//obj.addVerboseLogEntry(anId &amp; " has objects of a different Commodity Group.", IsWarning); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString1(Objects_differe_commodi_group,anId), IsWarning, Objects_differe_commodi_group);
  	return;
	endif;

	//obj.addVerboseLogEntry(anId &amp; " testing Discharge Port.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_discharge_port,anId), IsForLogging, Testing_discharge_port);
	self.testIsDiffDischPort(obj);
	if obj.getController = null then
		//obj.addVerboseLogEntry(anId &amp; " has objects of a different Discharge Port.", IsWarning); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString1(Has_Objs_differe_dischar_port,anId), IsWarning, Has_Objs_differe_dischar_port);
  	return;
	endif;

	//obj.addVerboseLogEntry(anId &amp; " testing IMEX Status.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_imex_status,anId), IsForLogging, Testing_imex_status);
	self.testIsDiffIMEX(obj);
	if obj.getController = null then
		//obj.addVerboseLogEntry(anId &amp; " has objects of a different IMEX Staus.", IsWarning); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString1(Objects_differe_imex_staus,anId), IsWarning, Objects_differe_imex_staus);
  	return;
  endif;

	//obj.addVerboseLogEntry(anId &amp; " testing Overstow Weight.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_overstow_weight,anId), IsForLogging, Testing_overstow_weight);
	self.testOverstowWeight(obj);
  if obj.getController = null then
		//obj.addVerboseLogEntry(anId &amp; " has objects of incompatible weight.", IsWarning); //+ cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString1(Objects_incompatib_weight,anId), IsWarning, Objects_incompatib_weight);
  	return;
  endif;

	//obj.addVerboseLogEntry(anId &amp; " testing Overstow Planned/Queued status.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_oversto_planned_status,anId), IsForLogging, Testing_oversto_planned_status);
	self.testOverstowPlannedOrQueued(obj);
  if obj.getController = null then
		//obj.addVerboseLogEntry(anId &amp; " has objects that are planned/queued.", IsWarning); //- cnwmd1, Par 20524
		obj.addVerboseLogEntry(app.getErrorString1(Objects_that_plannedque,anId), IsWarning, Objects_that_plannedque);
  	return;
  endif;

	//------------------
	//From here, the "optional" tests apply..
	//------------------
	//obj.addVerboseLogEntry(anId &amp; " testing Power Requirement.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_power_requiremen,anId), IsForLogging, Testing_power_requiremen);
	if obj.myTrackedItem.isAttributeTrue(TI_Attrib_RequiresPower) then
		self.testIsRequirePower(obj);
		if obj.getController = null then
			//obj.addVerboseLogEntry(anId &amp; " has Power problem (as above).", IsWarning); //- cnwmd1, Par 20524
			obj.addVerboseLogEntry(app.getErrorString1(Power_problem_above,anId), IsWarning, Power_problem_above);
	 		return;
	 	endif;
	 	return;	//Needs power, no power!
	endif;

	//obj.addVerboseLogEntry(anId &amp; " testing Tower Requirement.", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Testing_tower_requiremen,anId), IsForLogging, Testing_tower_requiremen);
	testIsRequireTower(obj);
	if obj.getController = null then
 		return;
 	endif;

end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testAutoPlanRequest" id="c2793b97-1dfd-454a-a0ed-bc9b25bad31b">
        <source>testAutoPlanRequest(obj : CMIF_AutoMovePlan input);
/* This is the MAIN routine called by each AttributePlan area, for each locationController
		in the list of lc's the users have specified to test. We ask each controller in turn to
		advise if it has a TI in it that may satisfy the request passed in.
		The calls to the sub-methods must be in the correct order, there is an element of
		precession for each method in turn. 
		If any of these methods encounters an issue that it considers will STOP the lc being
		any use as a source of tis, the sourceLocation portion of the object is nulled.
		DWQ 19 May 1998
*/
vars
begin
	//---------------
	//Complain!!! Whatever we are, we are NO GOOD!
	//---------------
	obj.updateController(null);
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
