<Class name="JadeScript">
    <JadeMethod name="aBitOfAnalysis" id="fc7e2fa0-0a4d-45c0-bcff-01adf900a37a">
        <source>aBitOfAnalysis();

vars
	log : CM_Log;
	ediLogOut : CM_EDIBOLOutLogTI;
	ediBolOut : CM_EDIDataBOLOutLog;
	vvr : CM_VehicleVisitRecord;
	move : CM_Move;
	stateObject : CM_StateObject;
	stateData : CM_StateData;
	obj : Object;
	wharfage : CM_Wharfage;
	inspect : CM_Inspect;
	audit : CM_AuditObject;
	bol : CM_BOLIn;
	
	log4Count, 
	logNullCount, 
	logNullVoyageCount, 
	logNullVoyageObjectCount, 
	ediLogOutCount, 
	ediBolOutCount, 
	vvrPre2014Count, 
	vvrPre2014DetailCount,
	vvrPre2015Count, 
	vvrPre2015DetailCount,
	moveNoVoyage,
	moveInvalidVoyage,
	stateInvalid, 
	stateStringInvalid,
	stateStringNoParent,
	stateStringToCheck,
	keySame,
	wharfageCount,
	inspectCount,
	auditCount,
	invalidSubject : Integer;
	
	oid, key, str : String;
	
	nbr, 
	progress, 
	idx, 
	year,
	badStrings,
	stringsAttachedToObjects : Integer;
	
	twenty14, 
	date : Date;
	
	years, 
	numTIs : IntegerArray;
	
	file : File;
	
	handledEx,
	badString,
	found : Boolean;
	
	stringKeys : StringArray;
	jdo : JadeDynamicObject;
	jdoArray : JadeDynamicObjectArray;
	bolsToDelete : ObjectArray;

begin
	on Exception do aBitOfAnalysisExHandler(exception, handledEx);
	
	twenty14.setDate(1, 1, 2014);
	create years transient;
	create numTIs transient;
	create stringKeys transient;
	create file transient;
	file.openOutput("c:\temp\analysis.txt");
	write "==============================================================================";
	
	// Log objects - in map file logObjs
	//nbr := CM_Log.instances.size;
	//write nbr.String &amp; " logs to process";
	//file.writeLine(nbr.String &amp; " logs to process");
/*	create jdoArray transient;
	foreach log in CM_Log.instances discreteLock do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write progress.String &amp; " logs read";
		endif;
		
		date := null;
		str := null;
		// invalid voyage object
		if log.myVoyage &lt;&gt; null and not app.isValidObject(log.myVoyage) then
			log4Count := log4Count + 1;
			date := log.createdTime.Date;
			str := "Error 4";
		// null voyage object
		elseif log.myVoyage = null then
			logNullCount := logNullCount + 1;
			date := log.createdTime.Date;
			str := "No voyage";
		// log is on the NULL voyage
		elseif log.voyageCode &lt;&gt; null and log.voyageCode = "********************" then
			if CM_Voyage.hasInstance(log.myVoyage) then
				logNullVoyageCount := logNullVoyageCount + 1;
			elseif CM_NullVoyage.hasInstance(log.myVoyage) then
				logNullVoyageObjectCount := logNullVoyageObjectCount + 1;
			endif;				
			date := log.createdTime.Date;
			str := "Null voyage";
		endif;
		
		if date &lt;&gt; null then
			year := date.year;
			found := false;
			foreach jdo in jdoArray do
				if jdo.getPropertyValue("year").Integer = year and jdo.getPropertyValue("reason").String = str and jdo.getPropertyValue("site").Integer = log.site then
					nbr := jdo.getPropertyValue("count").Integer + 1;
					jdo.setPropertyValue("count", nbr);
					found := true;
					break;
				endif;
			endforeach;
			if not found then
				create jdo transient;
				jdo.addProperty("year", Integer);
				jdo.addProperty("reason", String);
				jdo.addProperty("site", Integer);
				jdo.addProperty("count", Integer);
				jdo.setPropertyValue("year", year);
				jdo.setPropertyValue("reason", str);
				jdo.setPropertyValue("site", log.site);
				jdo.setPropertyValue("count", 1);
				jdoArray.add(jdo);
			endif;
			/*idx := years.indexOf(year);
			if idx = null then
				years.add(year);
				idx := years.indexOf(year);
			endif;
			if numTIs.size &lt; idx then
				numTIs.add(0);
			endif;
			numTIs[idx] := numTIs[idx] + 1;
		endif;
		
	endforeach;
	foreach jdo in jdoArray do
		write jdo.getPropertyValue("year").Integer.String &amp; Tab &amp; jdo.getPropertyValue("reason").String &amp; Tab &amp; jdo.getPropertyValue("site").Integer.String &amp; Tab &amp; jdo.getPropertyValue("count").Integer.String;
	endforeach;
	file.writeLine(log4Count.String &amp; " logs have an invalid voyage, " &amp; CrLf &amp;
					logNullCount.String &amp; " logs have a null voyage, " &amp; CrLf &amp;
					logNullVoyageCount.String &amp; " logs have the NULL voyage" &amp; CrLf &amp;
					logNullVoyageObjectCount.String &amp; " logs have a CM_NullVoyage voyage");
*/	
	// EDI bol out logs and headers - in map file edi
/*	progress := null;
	nbr := CM_EDIDataBOLOutLog.instances.size;
	write nbr.String &amp; " EDI BOLs to process";
	//write CM_EDIBOLOutLogTI.instances.size.String &amp; " CM_EDIBOLOutLogTI instances to process";
	file.writeLine(nbr.String &amp; " EDI BOLs to process");
	foreach ediBolOut in CM_EDIDataBOLOutLog.instances do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write progress.String &amp; " EDI BOLs read";
		endif;
		
		ediLogOut := ediBolOut.allEDILogsByLotHatchPlace.first;
		if ediLogOut.myVoyageGlobal &lt;&gt; null and not app.isValidObject(ediLogOut.myVoyageGlobal) then
			ediBolOutCount := ediBolOutCount + 1;
			ediLogOutCount := ediLogOutCount + ediBolOut.allEDILogsByLotHatchPlace.size;
			
			if ediBolOut.loadStartDT &lt;&gt; null then
				year := ediBolOut.loadStartDT.Date.year;
			elseif ediBolOut.processDateTime &lt;&gt; null then
				year := ediBolOut.processDateTime.Date.year;
			else
				year := ediBolOut.creationTime.Date.year;
			endif;
			idx := years.indexOf(year);
			if idx = null then
				years.add(year);
				idx := years.indexOf(year);
			endif;
			if numTIs.size &lt; idx then
				numTIs.add(0);
			endif;
			numTIs[idx] := numTIs[idx] + 1;
		endif;
	endforeach;
	foreach idx in 1 to years.size do
		write years[idx].String &amp; Tab &amp; numTIs[idx].String;
	endforeach;
	file.writeLine(ediBolOutCount.String &amp; " EDI BOls with an invalid voyage, with " &amp; ediLogOutCount.String &amp; " EDI Logs");
	
	// vehicle visit and vehicle visit detail records - in map file terminal
/*	progress := null;
	nbr := CM_VehicleVisitRecord.instances.size; 
	write nbr.String &amp; " Vehicle Visits to process";
	write CM_VehicleVisitRecordDetail.instances.size.String &amp; " CM_VehicleVisitRecord instances to process";
	file.writeLine(nbr.String &amp; " Vehicle Visits to process");
	foreach vvr in CM_VehicleVisitRecord.instances do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write progress.String &amp; " vvrs read";
		endif;
		
		// prior to 1/1/2014?
		if vvr.createdTime.Date.year &lt; 2014 then
			vvrPre2014Count := vvrPre2014Count + 1;
			vvrPre2014DetailCount := vvrPre2014DetailCount + vvr.allVehicleVisitRecordDetails.size;
		endif;
		// prior to 1/1/2015?
		if vvr.createdTime.Date.year &lt; 2015 then
			vvrPre2015Count := vvrPre2015Count + 1;
			vvrPre2015DetailCount := vvrPre2015DetailCount + vvr.allVehicleVisitRecordDetails.size;
		endif;
	endforeach;
	file.writeLine(vvrPre2014Count.String &amp; " vehicle visit records prior to 2014, with " &amp; vvrPre2014DetailCount.String &amp; " detail records");
	file.writeLine(vvrPre2015Count.String &amp; " vehicle visit records prior to 2015, with " &amp; vvrPre2015DetailCount.String &amp; " detail records");
	
/*	progress := null;
	nbr := CM_Move.instances.size;
	write nbr.String &amp; " Move transactions to process";
	file.writeLine(nbr.String &amp; " Move transactions to process");
	foreach move in CM_Move.instances do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write progress.String &amp; " moves read";
		endif;
		
		// null voyage and null tracked item?
		if move.myTrackedItem = null and move.getMyVoyage = null and move.getVoyageDMP = null then
			moveNoVoyage := moveNoVoyage + 1;
		elseif not app.isValidObject(move.getVoyageDMP) then
			moveInvalidVoyage := moveInvalidVoyage + 1;
		endif;
	endforeach;
	file.writeLine(moveNoVoyage.String &amp; " move transactions with no TI or voyage, with " &amp; moveInvalidVoyage.String &amp; " move transactions with invalid voyage");
	progress := null;
	
	nbr := CM_StateObject.instances.size;
	write nbr.String &amp; " State Objects to process";
	file.writeLine(nbr.String &amp; " State Objects to process");
	year := null;
	foreach stateObject in CM_StateObject.instances do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write progress.String &amp; " state objects read";
		endif;
		
		// check strings are all valid
		badString := false;
		handledEx := false;
		badStrings := null;
		stringsAttachedToObjects := stringsAttachedToObjects + stateObject.allStateData.size;
		foreach stateData in stateObject.allStateData do
			handledEx := false;
			badString := false;
			idx := stateData.key.pos("-", 1);
			if idx &lt;&gt; null then
				oid := stateData.key[idx+1:stateData.key.length-idx];
				obj := oid.asObject;
				obj.creationTime;
				if handledEx then
					stateStringInvalid := stateStringInvalid + 1;
					if stateData.createdTime.date.year &gt; year then
						year := stateData.createdTime.date.year;
					endif;
					badString := true;
					badStrings := badStrings + 1;
				endif;
			endif;
		endforeach;
		//if badString then
		if badStrings = stateObject.allStateData.size then
			stateInvalid := stateInvalid + 1;
		endif;
	endforeach;
	write stateInvalid.String &amp; " State Objects with " &amp; stateStringInvalid.String &amp; " invalid strings";
	file.writeLine(stateInvalid.String &amp; " State Objects with " &amp; stateStringInvalid.String &amp; " invalid strings");
	write stringsAttachedToObjects.String &amp; " CM_StateString objects actually attached to a CM_StateObject instance";
	file.writeLine(stringsAttachedToObjects.String &amp; " CM_StateString objects actually attached to a CM_StateObject instance");
	write "Latest invalid state data string from State Objects was in " &amp; year.String;
	file.writeLine("latest invalid state data string from State Objects was in " &amp; year.String);
*/
	progress := null;
	year := null;
//	nbr := CM_StateString.instances.size;
//	write nbr.String &amp; " State Strings to process";
//	file.writeLine(nbr.String &amp; " State Strings to process");
	create stringKeys transient;
	foreach stateData in CM_StateString.instances do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write app.actualTimeServer.Time.format("HH:mm:ss") &amp; Tab &amp; progress.String &amp; " state objects read, " &amp; stateInvalid.String &amp; " strings with invalid myStateObject, " &amp; stateStringNoParent.String &amp; " strings with no parent, " &amp; stateStringInvalid.String &amp; " invalid string keys from " &amp; stateStringToCheck.String &amp; " strings to check";
			//if progress &gt; 10000000 then
			//	break;
			//endif;
		endif;
		
		// check strings are all valid
		if stateData.myStateObject &lt;&gt; null and not app.isValidObject(stateData.myStateObject) then
			stateInvalid := stateInvalid + 1;
			if stateData.createdTime.date.year &gt; year then
				year := stateData.createdTime.date.year;
			endif;
		elseif stateData.myStateObject = null and stateData.myTrackedItem = null and stateData.myBOL = null and stateData.myParent = null then
			stateStringNoParent := stateStringNoParent + 1;
			if stateData.createdTime.date.year &gt; year then
				year := stateData.createdTime.date.year;
			endif;
		elseif stateData.myTrackedItem = null and stateData.myBOL = null and stateData.myParent = null then
			stateStringToCheck := stateStringToCheck + 1;
			
			idx := stateData.key.pos("-", 1);
			if idx &lt;&gt; null then
				oid := stateData.key[idx+1:stateData.key.length-idx];
				key := stateData.key[1:idx-1];
				obj := oid.asObject;
				obj.creationTime;
				if handledEx then
					stateStringInvalid := stateStringInvalid + 1;
					if stateData.createdTime.date.year &gt; year then
						year := stateData.createdTime.date.year;
					endif;
					badStrings := badStrings + 1;
				endif;
				idx := stringKeys.indexOf(key);
				if idx = null then
					stringKeys.add(key);
					numTIs.add(0);
					idx := stringKeys.indexOf(key);
				endif;
				numTIs[idx] := numTIs[idx] + 1;
			endif;
		else
			if stateData.myBOL &lt;&gt; null then
				if stateData.key = "ActualPieceCountError" then
					continue;
				endif;
				if stateData.key = "OPID" then
					oid := "opid";
				else	
					oid := stateData.key;
				endif;
				key := stateData.myBOL.getPropertyValue(oid).String;
				if key = stateData.CM_StateString.value then
					keySame := keySame + 1;
					//if not stringKeys.includes(stateData.key) then
					//	stringKeys.add(stateData.key);
					//endif;
				endif;
			endif;					
		endif;
	endforeach;
	write stateStringInvalid.String &amp; " StateStrings with invalid parent and " &amp; stateStringNoParent.String &amp; " with no parent and " &amp; stateStringToCheck.String &amp; " state strings to check for valid keys";
	write keySame.String &amp; " StateStrings with value the same as the BOL attribute of the same name";
	file.writeLine(stateStringInvalid.String &amp; " StateStrings with invalid parent and " &amp; stateStringNoParent.String &amp; " with no parent and " &amp; stateStringToCheck.String &amp; " state strings to check for valid keys");
	file.writeLine(keySame.String &amp; " StateStrings with value the same as the BOL attribute of the same name");
	write "Latest invalid state data string from State Strings was in " &amp; year.String;
	file.writeLine("latest invalid state data string from State Strings was in " &amp; year.String);
	write badStrings.String &amp; Tab &amp; "badStrings";
	foreach idx in 1 to stringKeys.size do
		write stringKeys[idx] &amp; Tab &amp; numTIs[idx].String;
		file.writeLine(stringKeys[idx] &amp; Tab &amp; numTIs[idx].String);
	endforeach;

/*	progress := null;
	foreach wharfage in CM_Wharfage.instances do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write progress.String &amp; " wharfage transactions read";
		endif;
		
		if wharfage.myTrackedItem = null or not app.isValidObject(wharfage.myTrackedItem) then
			wharfageCount := wharfageCount + 1;
		elseif wharfage.myTrackedItem &lt;&gt; null and wharfage.myTrackedItem.myVoyage &lt;&gt; null and not app.isValidObject(wharfage.myTrackedItem.myVoyage) then
			wharfageCount := wharfageCount + 1;
		endif;
	endforeach;
	write wharfageCount.String &amp; " Wharfage transactions with no TI or TI for an invalid voyage";
	file.writeLine(wharfageCount.String &amp; " Wharfage transactions with no TI or TI for an invalid voyage");
	
	progress := null;
	foreach inspect in CM_Inspect.instances do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write progress.String &amp; " inspect transactions read";
		endif;
		
		if inspect.myTrackedItem = null or not app.isValidObject(inspect.myTrackedItem) then
			inspectCount := inspectCount + 1;
		elseif inspect.myTrackedItem &lt;&gt; null and inspect.myTrackedItem.myVoyage &lt;&gt; null and not app.isValidObject(inspect.myTrackedItem.myVoyage) then
			inspectCount := inspectCount + 1;
		endif;
	endforeach;
	write inspectCount.String &amp; " Inspect transactions with no TI or TI for an invalid voyage";
	file.writeLine(inspectCount.String &amp; " Inspect transactions with no TI or TI for an invalid voyage");

	progress := null;
	if years = null then
		create years transient;
	endif;
	years.clear;
	if numTIs = null then
		create numTIs transient;
	endif;
	numTIs.clear;
	if stringKeys = null then
		create stringKeys transient;
	endif;
	stringKeys.clear;
	create jdoArray transient;
	nbr := CM_AuditObject.instances.size;
	write nbr.String &amp; " CM_AuditObjects to read";
	file.writeLine(nbr.String &amp; " CM_AuditObjects to read");
	foreach audit in CM_AuditObject.instances do
		progress := progress + 1;
		if progress mod 200000 = 0 then
			write progress.String &amp; " audit objects read";
		endif;
		
		if audit.mySubject &lt;&gt; null then
			if not app.isValidObject(audit.mySubject) then
				invalidSubject := invalidSubject + 1;
			endif;
			continue;
		endif;
		
		date := audit.timestamp.Date;
		year := date.year;
		idx := years.indexOf(year);
		if idx = null then
			years.add(year);
			idx := years.indexOf(year);
		endif;
		if numTIs.size &lt; idx then
			numTIs.add(0);
		endif;
		numTIs[idx] := numTIs[idx] + 1;
		// what is this audit for?
		str := audit.getSubjectClassName;
		found := false;
		foreach jdo in jdoArray do
			if jdo.getPropertyValue("subjectClass").String = str and jdo.getPropertyValue("year").Integer = year then
				nbr := jdo.getPropertyValue("count").Integer + 1;
				jdo.setPropertyValue("count", nbr);
				found := true;
				break;
			endif;
		endforeach;
		if not found then 
			create jdo transient;
			jdo.addProperty("subjectClass", String);
			jdo.addProperty("year", Integer);
			jdo.addProperty("count", Integer);
			jdo.setPropertyValue("subjectClass", str);
			jdo.setPropertyValue("year", year);
			jdo.setPropertyValue("count", 1);
			jdoArray.add(jdo);
		endif;
		
	endforeach;
	write invalidSubject.String &amp; " Audit Objects with an invalid subject";
	file.writeLine(invalidSubject.String &amp; " Audit Objects with an invalid subject");
	foreach jdo in jdoArray do
		write jdo.getPropertyValue("subjectClass").String &amp; Tab &amp; jdo.getPropertyValue("year").Integer.String &amp; Tab &amp; jdo.getPropertyValue("count").Integer.String;
	endforeach;
*/		
epilog
	foreach idx in 1 to years.size do
		//write years[idx].String &amp; " has " &amp; numTIs[idx].String &amp; " errors";
		//file.writeLine(years[idx].String &amp; " has " &amp; numTIs[idx].String &amp; " errors");
		write years[idx].String &amp; " has " &amp; numTIs[idx].String &amp; " logs";
		file.writeLine(years[idx].String &amp; " has " &amp; numTIs[idx].String &amp; " logs");
	endforeach;
	delete years;
	delete numTIs;
	delete stringKeys;
	if jdoArray &lt;&gt; null then
		jdoArray.purge;
	endif;
	delete jdoArray;
	delete bolsToDelete;
	file.close;
	delete file;
end;
</source>
    </JadeMethod>
    <JadeMethod name="aBitOfAnalysisExHandler" id="18b6af68-0e56-4d79-b98f-c90af04159f0">
        <source>aBitOfAnalysisExHandler(ex : Exception; invalidObj : Boolean output) : Integer;

vars

begin
	if ex.errorCode = 4 then
		invalidObj := true;
		return Ex_Resume_Next;
	else
		write "pass back";
		return Ex_Pass_Back;
	endif;
end;
</source>
        <Parameter name="ex" type="Exception"/>
        <Parameter name="invalidObj" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="aBitOfAnalysisNick" id="459ec3db-9612-46dc-a2ec-3f4ee70e67c1">
        <source>aBitOfAnalysisNick();

