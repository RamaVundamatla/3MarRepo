    <JadeMethod name="deleteAdvancedData" id="0f757d1e-14c5-494f-9163-88afad866b65">
        <source>deleteAdvancedData( term : CM_Terminal )protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	//localOpts : CM_AssociationDict;

begin

	self.deleteAllThresholds( term );
	
	self.deleteVoyage("UTVOYAGE9");
	self.deleteVessel("UTSHIP");
	self.deleteReleaseRequest("UTRRSHIPTH");
