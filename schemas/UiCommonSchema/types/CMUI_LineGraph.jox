    <JadeMethod name="addGraphLegend" id="2f86eb1a-2736-460b-9769-cb1c76939ece">
        <updating/>
        <source>addGraphLegend(_str : String) updating;
/*
------------------------------------------------------------------------
Created:			06 April 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

begin

	if (not self.allGraphLegends.includes(_str)) then
		self.allGraphLegends.add(_str);
	endif;
end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="addLine" id="db449a21-27d9-4a8a-8aab-a9f55d63de1e">
        <updating/>
        <source>addLine(_label : String; _color : Integer) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 October 2003 by cnwrs2
//
// Purpose:     Creates a line and returns the line idx to be used when
//				passing in values
// ---------------------------------------------------------------------------
vars
	newLineArray	: IntegerArray;
	
begin

	create newLineArray transient;
	self.allLinesArray.add(newLineArray);
	self.allGraphLegends.add(_label);
	self.allGraphColors.add(_color);

	return self.allLinesArray.size;
	
end;</source>
        <access>protected</access>
        <Parameter name="_label" type="String"/>
        <Parameter name="_color" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addLineColors" id="f326a21c-d302-483d-a41b-7b5b60b5f393">
        <updating/>
        <source>addLineColors(_colors : IntegerArray) updating;
/*
------------------------------------------------------------------------
Created:			23 March 2004 by cnwdwq1
Purpose:			Called when operating in Y axis mode
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

begin
	self.allGraphColors.clear;
	_colors.copy(self.allGraphColors);
end;</source>
        <Parameter name="_colors" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="addLineWithValues" id="cb1ee06b-29ef-4de9-a837-6a9691fc122b">
        <updating/>
        <source>addLineWithValues(_label : String; _color : Integer; _values : IntegerArray) updating;
// ---------------------------------------------------------------------------
// Created:     16 October 2003 by cnwrs2
//
// Purpose:     Creates a line with the label and colour with the values
//				passed in
// 				Returns the line idx
// ---------------------------------------------------------------------------
vars
	newLineArray	: IntegerArray;
	val		: Integer;
	
begin

	create newLineArray transient;
	_values.copy(newLineArray);

	self.allLinesArray.add(newLineArray);
	self.allGraphLegends.add(_label);
	self.allGraphColors.add(_color);

end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_color" type="Integer"/>
        <Parameter name="_values" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="addValue" id="95501193-6237-479c-b4c9-54ffda8e9d1a">
        <updating/>
        <source>addValue(_lineIdx, _value : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     16 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	lineArray	: IntegerArray;
	numLines	: Integer;
	
begin

	numLines	:= self.allLinesArray.size();
	if _lineIdx &gt; numLines then
		app.raiseUnexpectedProgramError(class.name, method.name, 'You need to call addLine first');
		return;
	endif;	
	
	lineArray	:= self.allLinesArray[_lineIdx].IntegerArray;
	
	lineArray.add(_value);
	
end;</source>
        <Parameter name="_lineIdx" type="Integer"/>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addXLabels" id="047ac92c-1b1e-4215-bf44-e6521214f624">
        <updating/>
        <source>addXLabels(_labels1, _labels2 : StringArray) updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.allXAxisLabels.clear;
	self.allXAxisLabels2.clear;
	
	if _labels1 &lt;&gt; null then
		_labels1.copy(self.allXAxisLabels);
	endif;
	if _labels2 &lt;&gt; null then
		_labels2.copy(self.allXAxisLabels2);
	endif;

end;</source>
        <Parameter name="_labels1" type="StringArray"/>
        <Parameter name="_labels2" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="addYPoints" id="224e91ae-d313-4d6b-90fe-43ac3a3f4dc5">
        <updating/>
        <source>addYPoints( _label : String; _yPoints : IntegerArray) updating;
/*
---------------------------------------------------------------------------
Created:     19 March 2004 by cnwdwq1

Purpose:	Adds a point. 
			Each _point is a position for a separate line. on the y axis
 ---------------------------------------------------------------------------
*/
vars
	int : Integer;
	lineArray	: IntegerArray;
	numLines : Integer;
begin
	if self.allXAxisLabels.includes(_label) then
		app.raiseUnexpectedProgramError(class.name, method.name, "Duplicated X axis label "&amp;_label);
		return;
	endif;
	if self.allXAxisLabels.indexOf(_label) = null then
		self.allXAxisLabels.add(_label);
	endif;
	numLines	:= self.allLinesArray.size();
	if numLines = 0 and _yPoints.size &gt; 0 then
		foreach int in 1 to _yPoints.size do
			create lineArray transient;
			self.allLinesArray.add(lineArray);
		endforeach;
	endif;
	//------------------
	//Set the points
	//------------------
	foreach int in 1 to _yPoints.size do
		lineArray := self.allLinesArray[int].IntegerArray;
		lineArray.add(_yPoints[int]);
	endforeach;
end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_yPoints" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="calculateGraphSize" id="e9cddf82-a4d6-4ec7-8486-9c0e9fd1f12e">
        <updating/>
        <source>calculateGraphSize() updating, protected;

vars

	textHeight	: Real;
begin

	textHeight	:= self.graphLabelHeight;

	if self.isShowLineLegend then
		self.graphHeight := (self.height - (textHeight * 3)).Integer;
		self.graphWidth := (self.clientWidth - self.maxScaleLabelWidth - self.getLegendWidth() - 6 - self.GraphMargin).Integer;
	else
		self.graphHeight	:=	(self.clientHeight - (textHeight * 2)).Integer;
		self.graphWidth		:=	(self.clientWidth - self.maxScaleLabelWidth - 6).Integer;
	endif;
	
	if self.borderStyle &lt;&gt; 0 then
		self.graphHeight	:=	self.graphHeight - 2;
	endif;
	self.xAxisPos 	:= self.graphHeight + textHeight + self.GraphMargin;	// allow for top heading
	self.yAxisPos	:= self.maxScaleLabelWidth + self.GraphMargin;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="checkData" id="e594b7e4-4b29-485d-84f5-f9bb3ef885c6">
        <updating/>
        <source>checkData():String updating, protected;

vars
	returnValue		: String;
	numberOfLines 	: Integer;
	colorArray		: IntegerArray;
	position		: Integer;
	lineColor		: Integer;
	
begin
	numberOfLines := self.allLinesArray.size();
	
	if numberOfLines = 0 then
		if self.isShowTestData then
			self.clearGraph();
			self.setDefaultsInPainter();
			numberOfLines	:=	self.allLinesArray.size();
		else
			returnValue	:=	"No Data";
			return returnValue;
		endif;
	endif;
	
	if (numberOfLines * self.graphLabelHeight) &gt; self.graphWidth then
		returnValue	:=	"Too Much Data";
		return returnValue;			
	endif;
	
	if self.isShowLineLegend then
		if numberOfLines &gt; self.allGraphColors.size() then
			returnValue	:=	"Not enough colors set";
			return returnValue;
		endif;
	
		create colorArray transient;
	
		foreach position in 1 to numberOfLines do
			lineColor	:=	self.allGraphColors[position]; 
			
			if not colorArray.includes(lineColor) then
				colorArray.add(lineColor);
			else
				returnValue	:=	"Color used more than once";
				return returnValue;
			endif;	 
		endforeach;
	endif;  
	
	return returnValue;
epilog
	delete colorArray;	
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearGraph" id="7c93bbea-dbdb-4a1f-954e-86997f9031c4">
        <updating/>
        <source>clearGraph() updating;

begin
	inheritMethod();
	self.allXAxisLabels.purge();
	self.allXAxisLabels2.purge();
	self.allLinesArray.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="createLegendLabel" id="69792501-4bfe-4197-b606-44eabf509b46">
        <updating/>
        <source>createLegendLabel() updating, protected;

vars
	theLabel	: Label;
	
begin
	if self.isShowLineLegend then
		if self.myLegendLabel &lt;&gt; null then
			delete self.myLegendLabel;
		endif; 
			
		create theLabel transient;
		
		theLabel.name		:=	self.LEGEND_LABEL;
		theLabel.parent		:=	self;
		theLabel.left		:=	1;
		theLabel.visible	:=	true;
		theLabel.height		:=	self.graphLabelHeight;
		theLabel.top		:=	self.graphLabelHeight + self.graphHeight + self.graphLabelHeight;
		theLabel.width		:=	self.width - 2;
		theLabel.backColor	:=	self.backColor;
		theLabel.foreColor	:=	Black;
		theLabel.alignment	:=	Label.Alignment_Center_Middle;
		theLabel.transparent := true;
		self.form.addControl(theLabel);
		theLabel.caption	:=	"";
		self.myLegendLabel	:=	theLabel;
		
		self.setLegendLabel(0);
	else
	
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createLines" id="33267b64-9b85-4a60-8dce-94bc3ebe19cc">
        <updating/>
        <source>createLines(pPointGap : Integer; pNumberOfPoints : Integer; pTheLine : Object; pLineNumber : Integer) updating, protected;

vars
	startX						: Real; 
	startY						: Real; 
	endX						: Real; 
	endY						: Real; 
	lineColor					: Integer;
	unitValue					: Real;
	position					: Integer;
	lineValuesArray				: IntegerArray;
	numberOfPointsOnThisLine	: Integer;
	
begin
	position	:=	1;
	
	if pLineNumber &lt;= self.allGraphColors.size() then
		lineColor	:=	self.allGraphColors[pLineNumber];
	else
		lineColor	:=	Black;
	endif;

	if self.maxValue &lt;&gt; 0 then 
		unitValue		:=	self.graphHeight / self.maxValue;
	else 
		unitValue		:= 1;  // was getting division by 0 error so made value 1 if max value is zero.
	endif;
		
	self.drawWidth	:=	1;
	
	create lineValuesArray transient;
	pTheLine.IntegerArray.copy(lineValuesArray);
	numberOfPointsOnThisLine	:=	lineValuesArray.size();
	  
	if pNumberOfPoints &gt; 1 then
	
		foreach position in 1 to pNumberOfPoints where position &lt;= numberOfPointsOnThisLine do	

//			// If the line position value is zero, then defer drawing the line.
//			
//			if lineValuesArray[position] = 0 then
//				continue;
//			endif;
			
			//set up x and y
			endX	:=	((position - 1) * pPointGap) + self.maxScaleLabelWidth;
			endY	:=	(self.graphHeight - (lineValuesArray[position] * unitValue)) + self.graphLabelHeight;
		
			if position = 1 then
				startX	:=	endX;
				startY	:=	endY;
			endif;
			
			//draw the line here
			self.drawLine(startX, startY, endX, endY, lineColor);
		
			startX	:=	endX;
			startY	:=	endY;
			
		endforeach;
	endif;
epilog 
	delete lineValuesArray;	
end;</source>
        <access>protected</access>
        <Parameter name="pPointGap" type="Integer"/>
        <Parameter name="pNumberOfPoints" type="Integer"/>
        <Parameter name="pTheLine" type="Object"/>
        <Parameter name="pLineNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="15f2dff0-beb6-4a3d-be71-ea9fb8e1dc77">
        <updating/>
        <source>delete() updating;

begin
	self.allLinesArray.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeValue" id="5d134ab4-79f8-4161-a214-a7c0c1a65425">
        <source>doChangeValue(pValue:Integer; pLineNumber:Integer; pPosition:Integer ):Boolean;

vars
	lineArray	: IntegerArray;
	
begin
	if self.allLinesArray.size() &lt; pLineNumber then
		return false;
	endif;
	
	lineArray	:=	self.allLinesArray[pLineNumber].IntegerArray;
	
	if lineArray.size() &lt; pPosition then
		return false;
	endif;
		
	lineArray[pPosition]	:=	pValue;
	
	return true;
end;</source>
        <Parameter name="pValue" type="Integer"/>
        <Parameter name="pLineNumber" type="Integer"/>
        <Parameter name="pPosition" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawGraph" id="9aa6a552-f0bf-4dd3-b35d-6f9421160652">
        <updating/>
        <source>drawGraph() updating;

vars
	errorMessage	: String;
	
begin
	self.clearGraphics();
	inheritMethod();

	errorMessage := self.checkData();
	
	self.calculateGraphSize();

	if errorMessage = null then		
		self.autoRedraw	:=	true;
		self.setMaxScaleLength();
		self.drawYAxis();
		self.createLegendLabel();
		//self.setScale();
		self.drawLegend();
		self.setupForm();
	else
		self.doDataError(errorMessage);
	endif;
	
	if self.myLegend &lt;&gt; null then
		self.myLegend.drawGraph();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawLegend" id="19ba3544-d92c-460e-9c00-dd9a2c478928">
        <updating/>
        <source>drawLegend() updating, protected;
/*
------------------------------------------------------------------------
Created:			05 April 2004 by cnwdwq1
Purpose:			Hacked from CMUI_PointLineGraph
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	maxWidth,
	topPos,
	leftPos,
	linePos,
	offset,
	legendWidth	: Real;
	idx,
	tmpColor	: Integer;
	str			: String;

begin
	if (not self.isShowLineLegend) then
		return;
	endif;
	
	maxWidth := self.getMaxLegendWidth();
	
	topPos	:= self.xAxisPos - self.graphHeight + self.GraphLegendSpacing;
	leftPos := self.yAxisPos + self.graphWidth + self.GraphMargin + self.GraphLegendSpacing;

	linePos := topPos + self.graphLabelHeight;
	legendWidth := self.getLegendWidth();
	offset := (self.graphLabelHeight / 2);

	self.drawWidth := 2;
	
	foreach str in self.allGraphLegends do
		idx := idx + 1;
		if str = null then
			continue;
		endif;
		tmpColor := self.allGraphColors[idx];
		self.drawLine(leftPos, linePos + offset, leftPos + self.GraphLegendLineLength, linePos + offset, tmpColor);
		self.drawTextAt(str, leftPos + self.GraphLegendLineLength + self.GraphLegendSpacing, linePos, Black);
		
		linePos := linePos + self.graphLabelHeight;
	endforeach;
	
	leftPos := leftPos - self.GraphLegendSpacing;
	
	self.drawWidth := 1;
	self.drawRectangle(leftPos, topPos, leftPos + legendWidth, linePos, Black); 
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawXAxis" id="34db606c-794a-45ba-bfd0-4391ca2db2e3">
        <updating/>
        <source>drawXAxis(pPointGap : Integer; pNumberOfPoints : Integer; pLineNumber : Integer) updating, protected;

constants
	LabelSpacing	: Integer = 5;
	
vars
	labelHeight,
	pointPos,
	startX1,
	startX2,
	startY1,
	startY2				: Real; 
	lastEndPos1,
	lastEndPos2,
	textExtent			: Real;
	displayText1,
	displayText2		: String; 
	textColor			: Integer;
	idx					: Integer;
	numLabels1,
	numLabels2	: Integer;
	
begin

	numLabels1	:=	self.allXAxisLabels.size();
	numLabels2	:=	self.allXAxisLabels2.size();
	
	labelHeight := self.graphLabelHeight;

	startY1	:=	labelHeight + self.graphHeight;
	startY2	:=	startY1 + labelHeight;
	
	self.drawTextRotation	:=	0;
	
	foreach idx in 1 to pNumberOfPoints do
		
		if idx &lt;= numLabels1 then
			displayText1 := self.allXAxisLabels[idx];
		else
			displayText1 := null;
		endif;

		if idx &lt;= numLabels2 then
			displayText2 := self.allXAxisLabels2[idx];
		else
			displayText2 := null;
		endif;
		
		pointPos := ((idx - 1) * pPointGap) + self.maxScaleLabelWidth;
		if pointPos &lt; lastEndPos1 or pointPos &lt; lastEndPos2 then
			continue;
		endif;
		
		if displayText1 &lt;&gt; null then
			startX1 := pointPos - (self.getTextExtent(displayText1) / 2).Integer;				
			if startX1 &lt; lastEndPos1 then
				continue;
			endif;
		endif;
		
		if displayText2 &lt;&gt; null then
			startX2 := pointPos - (self.getTextExtent(displayText2) / 2).Integer;				
			if startX2 &lt; lastEndPos2 then
				continue;
			endif;
		endif;
				
		if displayText1 &lt;&gt; null and startX1 &gt;= lastEndPos1 then
			self.drawTextAt(displayText1, startX1, startY1, textColor);
			lastEndPos1 := startX1 + self.getTextExtent(displayText1) + LabelSpacing;
		endif;

		if displayText2 &lt;&gt; null and startX2 &gt;= lastEndPos2 then
			self.drawTextAt(displayText2, startX2, startY2, textColor);
			lastEndPos2 := startX2 + self.getTextExtent(displayText2) + LabelSpacing;
		endif;
			
	endforeach;

	if self.xAxisHeading &lt;&gt; null then
		textExtent := self.getTextExtent(self.xAxisHeading);
		if textExtent &gt; self.clientWidth then
			startX1 := 1;
		else
			startX1 := ((self.clientWidth - textExtent) / 2);
		endif;
		//if self.useXAxisLabelLine2 then
		//	self.drawTextAt(self.xAxisHeading, startX1, startY2 + labelHeight, textColor);
		//else
			self.drawTextAt(self.xAxisHeading, startX1, startY1 + labelHeight, textColor);
		//endif;
	endif;
	
	// now draw line across bottom
	self.drawLine(self.maxScaleLabelWidth,
				(self.graphHeight + self.graphLabelHeight),
				self.maxScaleLabelWidth + self.graphWidth,
				(self.graphHeight + self.graphLabelHeight),
				Black);		

/*
vars
	startX				: Real; 
	startY				: Real; 
	lineText			: String; 
	textColor			: Integer;
	position			: Integer;
	numberOfXAxisLabels	: Integer;
	txtHeight : Integer;	
begin
	position :=	1;
	textColor :=	Black;
	numberOfXAxisLabels := self.allXAxisLabels.size();
	self.drawTextRotation := 0;

	startY := self.graphLabelHeight + self.graphHeight; 
	
	if pNumberOfPoints &gt; 1 then
		foreach position in 1 to pNumberOfPoints where position &lt;= numberOfXAxisLabels do
			lineText	:=	self.allXAxisLabels[position];
			while self.getTextExtent(lineText) &gt; pPointGap and lineText.length &gt; 1 do
				lineText := lineText[1:(lineText.length - 1).Integer];
			endwhile;
			
			if lineText.length = 1 then
				if self.getTextExtent(lineText) &gt; pPointGap then
					lineText := "";
				endif;
			endif;
			startX := ((position - 1) * pPointGap) + self.maxScaleLabelWidth - 7;				

			//draw the text here
			self.drawTextAt(lineText, startX, startY, textColor);
		endforeach;
	endif;

	// now draw line across bottom
	self.drawLine(self.maxScaleLabelWidth,
				(self.graphHeight + self.graphLabelHeight),
				self.maxScaleLabelWidth + self.graphWidth,
				(self.graphHeight + self.graphLabelHeight),
				Black);		

*/
end;</source>
        <access>protected</access>
        <Parameter name="pPointGap" type="Integer"/>
        <Parameter name="pNumberOfPoints" type="Integer"/>
        <Parameter name="pLineNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawYAxis" id="5e9bbb78-6d20-460c-8e67-d594135f47fd">
        <updating/>
        <source>drawYAxis() updating, protected;
/*
------------------------------------------------------------------------
Created:			25 March 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	textHeightOffset,
	textExtent	: Real;
	yMaxValue,
	position	: Integer;
	startX,
	startY		: Real;
	displayText	: String;	
	
begin

	textHeightOffset := self.getTextHeight('1') / 2;
	
	displayText := self.yAxisHeading;
	self.drawWidth := 1;
	if displayText = null then
		startX := 1;
	else
		// draw the Y axis heading rotated.
		
		self.drawTextRotation := 90;
		self.drawTextCharRotation := 90;
		textExtent := self.getTextExtent(displayText);
		if textExtent &gt; self.graphHeight then
			startY := self.graphHeight + self.graphLabelHeight;
		else
			startY := ((self.graphHeight - textExtent) / 2) + self.graphLabelHeight + textExtent;
		endif;
		self.drawTextAt(displayText, 1, startY, Black);

		self.drawTextCharRotation := 0;

		startX := self.graphLabelHeight + 1;
	endif;

	self.drawTextRotation	:=	0;

	yMaxValue := self.maxValue;

	foreach position in 1 to 5 do
		if position = 1 then
			displayText	:=	yMaxValue.String;
			startY		:=	self.graphLabelHeight;
		elseif position = 2 then
			displayText	:=	(yMaxValue * 0.75).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.25).Integer;
		elseif position = 3 then
			displayText	:=	(yMaxValue * 0.5).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.50).Integer;
		elseif position = 4 then
			displayText	:=	(yMaxValue * 0.25).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.75).Integer;
		elseif position = 5 then
			displayText	:=	"0";
			startY		:=	(self.graphLabelHeight + self.graphHeight).Integer;
		endif;
		
		if self.maxValue &gt; 10 then
			displayText	:=	displayText.Integer.String;
		endif;
		
		self.drawTextAt(displayText, startX, startY - textHeightOffset, Black);	
		self.drawLine(self.maxScaleLabelWidth - 1, startY, self.maxScaleLabelWidth + 4, startY, Black);
	endforeach;

	// now draw line up left
	self.drawLine(self.maxScaleLabelWidth - 1,
				self.graphLabelHeight,
				self.maxScaleLabelWidth - 1,
				(self.graphLabelHeight + self.graphHeight + 1),
				Black);		

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="init" id="e7677e8c-1579-4a03-aea2-f45cb75e2651">
        <updating/>
        <source>init(_title, _xAxisHeading, _yAxisHeading : String) updating;
/*
------------------------------------------------------------------------
Created:			25 March 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	self.graphTitle := _title;
	self.xAxisHeading := _xAxisHeading;
	self.yAxisHeading := _yAxisHeading;
end;</source>
        <Parameter name="_title" type="String"/>
        <Parameter name="_xAxisHeading" type="String"/>
        <Parameter name="_yAxisHeading" type="String"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="215b7312-0270-432d-81fc-8f741e5c9d26">
        <updating/>
        <source>mouseUp(cntrl: BaseControl input; button: Integer; shift: Integer; x: Real; y: Real) updating;

begin
	inheritMethod(self, button, shift, x, y);
	
	if (not self.isInPainter()) and (not self.myLegendLabel = null) then
//if (not self.isInPainter()) then // 1090 if screen blank
		if self.isShowLineLegend then
			self.setLegendLabel(self.getPoint(x, y));
		endif;
	endif; 		
end;</source>
        <Parameter name="cntrl" type="BaseControl" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setDefaultsInPainter" id="67d78868-91c4-472c-8bd7-ecc4e2eebce9">
        <updating/>
        <source>setDefaultsInPainter() updating, protected;
vars
	idx	: Integer;
begin
	self.graphTitle	:=	self.name &amp; " - Sample data";
	
	idx := self.addLine('2000', Red);
	 
	self.addValue(idx, 10);
	self.addValue(idx, 20);
	self.addValue(idx, 50);
	self.addValue(idx, 30);
	self.addValue(idx, 40);

	idx := self.addLine('2001', Blue);
	
	self.addValue(idx, 20);
	self.addValue(idx, 0);
	self.addValue(idx, 0);
	self.addValue(idx, 25);
	self.addValue(idx, 30);

	idx := self.addLine('2001', Green);
	
	self.addValue(idx, 30);
	self.addValue(idx, 40);
	self.addValue(idx, 15);
	self.addValue(idx, 20);
	self.addValue(idx, 15);
	
	self.transparent := false;
	
	self.allXAxisLabels.add("January"); 
	self.allXAxisLabels.add("February");
	self.allXAxisLabels.add("March");
	self.allXAxisLabels.add("April");
	self.allXAxisLabels.add("May");
	
	if self.height &lt; 100 then
		self.height	:=	100;
	endif;
	
	if self.width &lt; 100 then
		self.width	:=	100;
	endif;				
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setLegendLabel" id="18b068c5-01be-43e9-981a-be9c689ad8dd">
        <updating/>
        <source>setLegendLabel(pColor:Integer) updating, protected;

vars
	lineIndex		: Integer;
	theControl		: Control;
	theLabel		: Label;
	valueString		: String;
	
begin
	lineIndex	:=	self.allGraphColors.indexOf(pColor);
	
	if self.isInPainter() then
		valueString := "Legend Label";
		self.myLegendLabel.foreColor	:=	Black; 
	else
		if lineIndex &lt;&gt; 0 then
			if lineIndex &lt;= self.allGraphLegends.size() then
				valueString := self.allGraphLegends[lineIndex].removeTabCrLfs(); 
			else
				valueString := self.xAxisHeading;
				if valueString = null then
					valueString := "No legend - "; 		
				endif;
			endif;
			
			self.myLegendLabel.foreColor	:=	pColor; 
		else
			if (not self.isShowLineLegend) then
				valueString := "Click on Line for Legends";
			endif;
			self.myLegendLabel.foreColor := Black; 
		endif;
	endif;	  
	
	self.myLegendLabel.caption	:=	valueString;		
end;</source>
        <access>protected</access>
        <Parameter name="pColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMaxScaleLength" id="8ccd335e-848f-483f-b945-7a1e22745295">
        <updating/>
        <source>setMaxScaleLength() updating, protected;

vars
	theLabel		: Label;
	theLine			: Object;
	lineValue		: Integer;
	tmpMaxValue,
	position		: Integer;
	numberOfLines	: Integer;
	
begin
	self.maxScaleLabelWidth	:=	0;
	numberOfLines			:=	self.allLinesArray.size();
	
	foreach position in 1 to numberOfLines do 
		theLine	:=	self.allLinesArray[position];
		
		foreach lineValue in theLine.IntegerArray do
			if lineValue &gt; tmpMaxValue then
				tmpMaxValue := lineValue;
			endif;
		endforeach;
	endforeach;
	
	// multiple by 1.1 to leave space at top of graph
	self.maxValue := (tmpMaxValue * 1.1).Integer;
	
	create theLabel transient;
	
	theLabel.caption		:=	lineValue.String;
	self.maxScaleLabelWidth	:=	theLabel.width.Integer;	
epilog
	delete theLabel;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setScale" id="57be4e3d-685b-4745-ab8d-5b2fe60e7f7c">
        <updating/>
        <source>setScale() updating, protected;

vars
	position	: Integer;
	startY, startX		: Integer;
	textValue	: String;	
	
begin
	self.drawTextRotation	:=	0;
	
	foreach position in 1 to 5 do
		if position = 1 then
			textValue	:=	self.maxValue.String;
			startY		:=	self.graphLabelHeight;
		elseif position = 2 then
			textValue	:=	(self.maxValue * 0.75).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.25).Integer - 2;
		elseif position = 3 then
			textValue	:=	(self.maxValue * 0.5).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.50).Integer - 4;
		elseif position = 4 then
			textValue	:=	(self.maxValue * 0.25).Real.String;
			startY		:=	self.graphLabelHeight + (self.graphHeight *.75).Integer - 6;
		elseif position = 5 then
			textValue	:=	"0";
			
			if self.isShowLineLegend then
				startY	:=	(self.graphLabelHeight + self.graphHeight - 8).Integer;
			else
				startY	:=	(self.graphLabelHeight + self.graphHeight - 10).Integer;
			endif;
		endif;
		
		if self.maxValue &gt; 10 then
			textValue	:=	textValue.Integer.String;
		endif;
		if self.yAxisHeading = null then
			startX := 10;
		else
			startX := self.graphLabelHeight + 10;
		endif;
		self.drawTextAt(textValue, startX, startY, Black);	
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cb2e9de1-2dcb-4985-b003-4c3cca55c629">
        <updating/>
        <source>setupForm() updating, protected;

vars
	numberOfLines		: Integer;
	pointCount			: Integer;
	maxNumberOfPoints	: Integer;
	pointGap			: Integer;
	theLine				: Object;
	position			: Integer;
	
begin
	numberOfLines	:=	self.allLinesArray.size();
	
	foreach position in 1 to numberOfLines do
		pointCount	:=	self.allLinesArray[position].IntegerArray.size();
		
		if pointCount &gt; maxNumberOfPoints then
			maxNumberOfPoints	:=	pointCount;
		endif;
	endforeach;

	if maxNumberOfPoints = 1 then	// R Barr 27/10/2006 Avoid divide by zero error
		pointGap := graphWidth;
	else
		pointGap := (self.graphWidth / (maxNumberOfPoints - 1)).Integer;
	endif;
	
	foreach position in 1 to numberOfLines do
		theLine	:=	self.allLinesArray[position];
		self.createLines(pointGap, maxNumberOfPoints, theLine, position);
	endforeach;
	
	self.drawXAxis(pointGap, maxNumberOfPoints, position);	
end;</source>
        <access>protected</access>
    </JadeMethod>
