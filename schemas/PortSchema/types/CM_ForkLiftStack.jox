    <JadeMethod name="setHeightOfStack" id="f3b6c4f9-fafc-407f-a070-8789992ed58e">
        <updating/>
        <source>setHeightOfStack(_height: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2012	cnwndl1	Initial creation	Par 29604
04/03/2015	cnwmh5	Tranisent Leak
*/

vars

	lcIter : Iterator;
	yaCont : CM_YardController;
	iter : Iterator;
	cell : CM_YALocationCell;
	cellsToDelete : CM_YALocationCellSet;

begin

	if _height &lt; self.heightOfStack then
		//we need to get rid of the cells related to positions above this height.
		if self.allLocationsControllers &lt;&gt; null and not self.allLocationsControllers.isEmpty then
			lcIter := self.allLocationsControllers.createIterator;
			while lcIter.next( yaCont ) do
				iter := yaCont.allYAYardLocationCells.createIterator;
				while iter.next( cell ) do
					if cell.height &gt; _height then
						if cellsToDelete = null then
							create cellsToDelete transient;
						endif;
						cellsToDelete.add( cell );
					endif;
				endwhile;
			endwhile;
		endif;
	endif;

	inheritMethod(_height);

epilog

	delete iter;
	delete lcIter;
	if cellsToDelete &lt;&gt; null then
		if not cellsToDelete.isEmpty then
			cellsToDelete.purge();
		endif;
		delete cellsToDelete;
	endif;
	
end;</source>
        <Parameter name="_height" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="867ba8c3-beb3-4072-8af6-fd3827ef4b92">
        <updating/>
        <source>setProxy(pID, pComment			: String; 
		 pType 					: Integer;
		 pRows 					: Integer;
		 pCols 					: Integer;
		 pHeight 				: Integer;
		 pTypeString 			: String;
		 pBack 					: Boolean;
		 pFront 				: Boolean;		 
		 pFull 					: Real;
		 pMT 					: Real;
		 pPower 				: Real;
		 pStagger 				: String;
		 pActAsReleasePoint 	: Boolean;
		 _terminal				: CM_Terminal;
		 _stockControlled		: Boolean;
		_hideFromOverView : Boolean;
		_deckingStartType : Integer;
		_noLeft, _noRight, _snapLeft, _goRight, _snapStrict : Boolean;
		_allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
		_defaultInterchangeArea: CM_InterchangeArea;
		_useSideAccessRules : Boolean;
		_use40ftIds			: Boolean;
		_leftlabel, 
		_rightLabel, 
		_topLabel, 
		_bottomLabel : String) updating;
// ---------------------------------------------------------------------------
// Created:     10 May 2001 Andrew Bishop
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/05/2010		cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
// 14/7/2010 	cnwer1		Par 24463 - allow set use 40 ft ids
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	setGridAreaProxy(pID, pComment, pType, pRows, pCols, pHeight, pActAsReleasePoint, _terminal, false,
					_stockControlled, _hideFromOverView,_deckingStartType,_noLeft, _noRight, _snapLeft,
					_goRight, _snapStrict, _allInterchangeAreas,_defaultInterchangeArea , _use40ftIds, _useSideAccessRules,
					null,null,null,null);
//	self.height := pHeight;
	self.accessBack := pBack;
	self.accessFront := pFront;
	self.maxHeightFull := pFull;
	self.maxHeightMT := pMT;
	self.maxHeightPower := pPower;
	setStaggerHeights(pStagger);
	self.pxySetLabels(	_leftlabel, 
						_rightLabel, 
						_topLabel, 
						_bottomLabel); 		//20/06/2011 cnwdz2 27732
end;</source>
        <Parameter name="pID" type="String"/>
        <Parameter name="pComment" type="String"/>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="pRows" type="Integer"/>
        <Parameter name="pCols" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pTypeString" type="String"/>
        <Parameter name="pBack" type="Boolean"/>
        <Parameter name="pFront" type="Boolean"/>
        <Parameter name="pFull" type="Real"/>
        <Parameter name="pMT" type="Real"/>
        <Parameter name="pPower" type="Real"/>
        <Parameter name="pStagger" type="String"/>
        <Parameter name="pActAsReleasePoint" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_deckingStartType" type="Integer"/>
        <Parameter name="_noLeft" type="Boolean"/>
        <Parameter name="_noRight" type="Boolean"/>
        <Parameter name="_snapLeft" type="Boolean"/>
        <Parameter name="_goRight" type="Boolean"/>
        <Parameter name="_snapStrict" type="Boolean"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
        <Parameter name="_useSideAccessRules" type="Boolean"/>
        <Parameter name="_use40ftIds" type="Boolean"/>
