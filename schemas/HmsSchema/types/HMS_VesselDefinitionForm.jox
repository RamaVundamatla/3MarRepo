    <JadeMethod name="doDelete" id="82fe1ddc-abc2-4219-9f2b-0e008ec6c323">
        <updating/>
        <source>doDelete()updating;
//--------------------------------------------------
// Created:	06 April 2005 By: cnwgd1
//--------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	theRealVoyage, theProxyVoyage : CM_Voyage;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	if self.myCurrentVessel = null then
		return;
	endif;
	
	if app.msgBox(app.getErrorString2(ConfirmDelete, 'Vessel', self.myCurrentVessel.name), 'Confirm Deletion', MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then	
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteVessel(self.myCurrentVessel, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Vessel Definition Delete', app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

	self.setMyCurrentVessel(null);
	global.beep;
	
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryUnload" id="df819bde-81dc-4970-be9d-91ae2bad4491">
        <updating/>
        <source>doQueryUnload(cancel: Integer io; reason: Integer) updating, protected;
//--------------------------------------------------
// Created:	07 April 2005 By: cnwgd1
//--------------------------------------------------
constants
	CANCEL_UNLOAD = 1;
vars
	result : Integer;
begin

	if self.mode = Mode_Add 
	or self.mode = Mode_Update then
		if reason = QueryUnload_User 
		or reason = QueryUnload_UnloadMethod
		or reason = QueryUnload_MdiChild then
			result := app.msgBox(app.getErrorString(EditChangedAndClosing), self.caption &amp; " Window Closing !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			if result = MsgBox_Return_No then
				cancel := CANCEL_UNLOAD;	//Do not close form
			endif;			
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
