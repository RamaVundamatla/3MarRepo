    <JadeMethod name="utlUpdateMachine" id="7e3e9f9c-46b8-45e4-82dc-175ff99c1ede">
        <source>utlUpdateMachine(pProxyMachine:CM_Machine; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 Sep 2020 cnwma1 		ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realMachine:CM_Machine;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pProxyMachine.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyMachine.pxyGetRealObjectAndEdition(realMachine, expectedEdition);
	
	if realMachine = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Machine.name, null, null);
		return;
	endif;

	app.myValUA.valMachine(realMachine, pProxyMachine);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realMachine);

	if _passport.noErrors and realMachine.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Machine', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMachine, true);
	endif;
	
	if _passport.noErrors then
		realMachine.setForUpdate(pProxyMachine, _passport);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realMachine, false);
	endif;
	
	//21.09.2020 cnwma1 TFS #49906
	if _passport.isOpsViewEnabled(realMachine.getMyTerminal()) then
		realMachine.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,
											BGP_OpsViewWSRequest.OPS_TYPE_MACHINE,
											realMachine);
	endif;
	//21.09.2020 cnwma1 TFS #49906

epilog
	
	
end;</source>
