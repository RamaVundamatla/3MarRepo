    <JadeMethod name="deselectVMTableRows" id="f61b9340-8182-439a-8454-d68426fda605">
        <source>deselectVMTableRows(_table: Table input) protected;
/*

Date		Who		Reason
12 August 2014	cnwer1	Initial creation PAR

*/

vars

	allSelectedRows : StringArray;
	selectedRow 	: String; 
begin
	
	if _table = null then
		return;
	endif;
	
	allSelectedRows:=_table.tag.getTokens();
	if allSelectedRows.size = 0 then
		return;
	endif;
	
	foreach selectedRow in allSelectedRows do
		self.displayVMTableRow(_table,selectedRow.Integer,true);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="disableAllControls" id="a0d6d3dd-c3e7-4081-a83a-e189959c15be">
        <source>disableAllControls();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 July 2010	cnwrd1	Initial creation

*/

vars
	intCntrl : Integer;
	cntrl : Control;
	txtBox : TextBox;
	cmbBox : ComboBox;
	chkBox : CheckBox;
	button : Button;
	table : Table;
	frame : Frame;
begin

	intCntrl := 1;

	while intCntrl &lt;= self.controlCount do
	
		cntrl := controls(intCntrl);		
		if cntrl.isKindOf( TextBox ) then
			txtBox := cntrl.TextBox;
			txtBox.readOnly := true;
		elseif cntrl.isKindOf( ComboBox ) then
			cmbBox := cntrl.ComboBox;
			cmbBox.enabled := false;
		elseif cntrl.isKindOf( CheckBox ) then			
			chkBox := cntrl.CheckBox;
			chkBox.enabled := false;
		elseif cntrl.isKindOf( Button ) then
			button := cntrl.Button;
			button.enabled := false;			
		elseif cntrl.isKindOf( Table ) then
			table := cntrl.Table;
			table.enabled := false;
		elseif cntrl.isKindOf( Frame ) then
			frame := cntrl.Frame;
			frame.enabled := false;			
		endif;
	intCntrl := intCntrl + 1;
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayVMTableRow" id="c97e945a-c9b4-4f3e-96ae-375ef4e98fa1">
        <source>displayVMTableRow(_table: Table input; _row: Integer;_isMultiSelect : Boolean)  protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation

*/
	
vars
	row       : JadeTableRow;
	maxSelectedRows,
	theLastSelectedRow : Integer;
	allSelectedRows : StringArray;
	selectedRow 	: String; 
begin
	
	if _row &lt; 1 or _row &gt; _table.rows then
		return;
	endif;
	_table.row:=_row;
	
	maxSelectedRows:=self.getVMTMaxSelectRows(_table);
	
	allSelectedRows:=_table.tag.getTokens();
	if allSelectedRows.size &gt; 0 then
		theLastSelectedRow:= allSelectedRows.last.Integer ;
	endif;
	
	if allSelectedRows.size &gt; 0  then
		if _isMultiSelect then
			if (_table.row &lt;= _table.rows and _table.row &gt; _table.fixedRows) then
			//only deselect if it was already selected
				if allSelectedRows.includes(_row.String) then
					row := _table.accessRow(_row.Integer);
					row.foreColor := app.myVMAgent.getMyScreenMode.tableForeColour;
					row.fontBold  := false;
					row.fontSize  := app.myVMAgent.getMyRTVehicleConfig.tableFontSize;
					allSelectedRows.remove(_row.String);
					_table.tag:=allSelectedRows.concatenate(Space);
					return;
				endif;
			endif;
		else
			foreach selectedRow in allSelectedRows where selectedRow.Integer  &lt;= _table.rows do
				row := _table.accessRow(selectedRow.Integer);
				row.foreColor := app.myVMAgent.getMyScreenMode.tableForeColour;
				row.fontBold  := false;
				row.fontSize  := app.myVMAgent.getMyRTVehicleConfig.tableFontSize;
			endforeach;
		endif;
	endif;
		
	if _isMultiSelect and allSelectedRows.size = maxSelectedRows then
		return;
	endif;
	
	if not (_table.row &lt;= _table.rows and _table.row &gt; _table.fixedRows) then
		return;
	endif;
		
	row :=  _table.accessRow(_table.row);
	row.fontSize  :=  app.myVMAgent.getMyRTVehicleConfig.tableSelectedFontSize;
	row.foreColor :=  app.myVMAgent.getMyScreenMode.tableSelectColour;
	row.fontBold  := true;
	if _isMultiSelect then
		allSelectedRows.add(_table.row.String);
		_table.tag  :=allSelectedRows.concatenate(Space);
	else
		_table.tag  :=  _table.row.String;
	endif;
	

epilog
	delete allSelectedRows;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_isMultiSelect" type="Boolean"/>
    </JadeMethod>
