    <JadeMethod name="populateCMIFfromBank" id="c4f794f5-b8a2-4f4d-a477-36d7a19805db">
        <updating/>
        <source>populateCMIFfromBank( _bank : CM_Bank ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010

*/

vars

begin

	self.myBank := _bank;
	if _bank &lt;&gt; null then
	
		self.cashInvoiceType := _bank.getConfig( CashInvoiceType ).CM_InvoiceDesc;
		self.cashRoundInvLineType := _bank.getConfig( CashRoundInvLineType ).CM_InvoiceLineDesc;
		self.cashRoundUpAmount := _bank.getConfig( CashRoundUpAmount ).Real;
		self.cashRoundingType := _bank.getConfig( CashRoundingType ).Integer;
		self.cashTaxInvLineType := _bank.getConfig( CashTaxInvLineType ).CM_InvoiceLineDesc;
		self.proXtraInvLineGrp := _bank.getConfig( ProXtraInvLineGrp ).CM_InvoiceLineDescGroup;	//28 Jan 2019	NDL	TFS 42940
	
	endif;

epilog

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="setBankFromCMIF" id="9ab61c54-f142-4556-8fb8-4ce2f5cc040b">
        <source>setBankFromCMIF();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010

*/

vars

begin

	
	
	self.myBank.setConfig( CashInvoiceType, self.cashInvoiceType );
	self.myBank.setConfig( CashRoundInvLineType, self.cashRoundInvLineType );
	self.myBank.setConfig( CashRoundUpAmount, self.cashRoundUpAmount );
	self.myBank.setConfig( CashRoundingType, self.cashRoundingType );
	self.myBank.setConfig( CashTaxInvLineType, self.cashTaxInvLineType );
	self.myBank.setConfig( ProXtraInvLineGrp, self.proXtraInvLineGrp );	//28 Jan 2019	NDL	TFS 42940

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateCashRoundup" id="06b1c799-3368-4ecb-8fbc-1650cc1f2010">
        <source>validateCashRoundup();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010 // migrated from CMIF_InvoiceCashModule

*/

vars

begin

	if self.cashRoundUpAmount &gt; 1 then
		app.raiseCMException1(XXX_less_than_one, app.getErrorString(Cash_roundup_nearest_amount), null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateConfig" id="085ee2b5-0112-4c23-bab5-afda85d3a406">
