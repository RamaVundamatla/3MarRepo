begin

	if self.myCargoType.isTrackByVolume then
		if self.myProduct &lt;&gt; null then
			measureType := self.myProduct.getDefaultMeasurementForType(Type_Volume);
		else
			measureType := self.myCargoType.getDefaultMeasurementForType(Type_Volume);
		endif;
		type := measureType.shortName;
		if self.volume &lt;&gt; 0 then
			returnVal := app.convertMeasurementForDisplay(type, (self.volume * self.factor ) ) &amp; " " &amp; type;
		endif;
	elseif self.myCargoType.isTrackByWeight then
		if self.myProduct &lt;&gt; null then
			measureType := self.myProduct.getDefaultMeasurementForType(Type_Weight);
		else
			measureType := self.myCargoType.getDefaultMeasurementForType(Type_Weight);
		endif;
		type := measureType.shortName;
		if self.weight &lt;&gt; 0 then
			returnVal := app.convertMeasurementForDisplay(type, (self.weight * self.factor ) ) &amp; " " &amp; type;
		endif;
	else
		if self.quantity &lt;&gt; 0 then
			returnVal := "x" &amp; ( self.quantity * self.factor ).Integer.asStringJMT;
		endif;
	endif;
	
	return returnVal;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRowHeadingString" id="1a5b6dd8-d7cc-4462-94a4-015e74fe653b">
        <options>4</options>
        <source>getRowHeadingString():String typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	headings : String;

begin

	headings := app.getErrorString(Cargo_cargo_type) &amp; Tab &amp;
				app.getErrorString(Amount_per_item) &amp; Tab &amp;
				app.getErrorString(Selected_input_items) &amp; Tab &amp;
				app.getErrorString(Total_amount_reqd) &amp; Tab &amp;
				app.getErrorString(Short_By);
				
	return headings;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRowString" id="0c4b59af-ecef-4b12-93f2-b95bf218a385">
        <source>getRowString( _colour : Integer output ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	underAmount : String;

begin

	_colour := Green;
	underAmount := null;
	
	if self.allTis.isEmpty then
		_colour := Black;
		underAmount := self.getAmountString( false ); // total amount required
	elseif self.insufficientComponent( underAmount ) then
		_colour := Red;
	endif;

	return	self.getCargoTypeProdString &amp; Tab &amp;
			self.getAmountString( true ) &amp; Tab &amp;  // per item value
			self.tiString() &amp; Tab &amp;
			self.getAmountString( false ) &amp; Tab &amp;  // total amount required for this blend job to create all of the output tis.
			underAmount;

epilog

end;</source>
        <Parameter name="_colour" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="insufficientComponent" id="3bc3b248-ea30-46b8-9b76-aba6f2f3ae6a">
        <source>insufficientComponent( _underAmountString : String output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	ti : CM_TrackedItem;
	totalVolume : Decimal[14,4];
	totalWeight : Decimal[14,4];
	totalQuantity : Integer;
	
	totalReqVolume : Decimal[14,4];
	totalReqWeight : Decimal[14,4];
	totalReqQuantity : Integer;
	
	measureType : CM_MeasurementType;
	type : String;
	underAmountDec : Decimal[14,4];

begin

	if self.myCargoType.isTrackByVolume then
		foreach ti in self.allTis do
			totalVolume := totalVolume + ti.totalVolume;
		endforeach;
		totalReqVolume := (self.volume * self.factor * self.outputCargoIdCount );
		
		if totalVolume &lt; totalReqVolume then
			if self.myProduct &lt;&gt; null then
				measureType := self.myProduct.getDefaultMeasurementForType(Type_Volume);
			else
				measureType := self.myCargoType.getDefaultMeasurementForType(Type_Volume);
			endif;
			type := measureType.shortName;
			underAmountDec := totalReqVolume - totalVolume;
			_underAmountString := app.convertMeasurementForDisplay(type, underAmountDec ) &amp; " " &amp; type;
			return true;
		else
			return false;
		endif;
		
		
	elseif self.myCargoType.isTrackByWeight then
		foreach ti in self.allTis do
			totalWeight := totalWeight + ti.totalWeight;
		endforeach;
		totalReqWeight := (self.weight * self.factor * self.outputCargoIdCount );
		
		if totalWeight &lt; totalReqWeight then
			if self.myProduct &lt;&gt; null then
				measureType := self.myProduct.getDefaultMeasurementForType(Type_Weight);
			else
				measureType := self.myCargoType.getDefaultMeasurementForType(Type_Weight);
			endif;
			type := measureType.shortName;
			underAmountDec := totalReqWeight - totalWeight;
			_underAmountString := app.convertMeasurementForDisplay(type, underAmountDec ) &amp; " " &amp; type;
			return true;
		else
			return false;
		endif;
		
	else
		foreach ti in self.allTis do
			totalQuantity := totalQuantity + ti.totalQuantity;
		endforeach;
		totalReqQuantity := (self.quantity * self.factor * self.outputCargoIdCount ).Integer;
		
		if totalQuantity &lt; totalReqQuantity then
			underAmountDec := totalReqQuantity - totalQuantity;
			_underAmountString := "x" &amp; underAmountDec.Integer.asStringJMT;
			return true;
		else
			return false;
		endif;
		
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_underAmountString" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateFromRecipeComp" id="5cad32c6-8cb7-4768-bc8b-4eff85bd683c">
        <updating/>
        <source>populateFromRecipeComp( _factor : Decimal; _recipeComponent : CM_RecipeComponent; _cargoIdCount : Integer ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	if _recipeComponent = null then
		return false;
	endif;
	
	if _factor = 0 then
		self.factor := 1;
	else
		self.factor := _factor.max(1);
	endif;
	self.myCargoType := _recipeComponent.myCargoType;
	self.myProduct := _recipeComponent.myProduct;
	self.myRecipeComponent := _recipeComponent;
	
	self.quantity := _recipeComponent.quantity;
	self.volume := _recipeComponent.volume;
	self.weight := _recipeComponent.weight;
	
	self.outputCargoIdCount :=  _cargoIdCount.max(1);
	
	return true;

epilog

end;</source>
        <Parameter name="_factor" type="Decimal"/>
        <Parameter name="_recipeComponent" type="CM_RecipeComponent"/>
        <Parameter name="_cargoIdCount" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFactor" id="4adb22a4-981e-465c-b8a4-167abb517286">
        <updating/>
        <source>setFactor( _factor : Decimal )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.factor := _factor;

epilog

end;</source>
        <Parameter name="_factor" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setManual" id="a4662b2f-26c1-483e-a6c1-4db0cb1929a0">
        <updating/>
        <source>setManual(	_myCargoType : CM_CargoType; 
			_myProduct : CM_Product;
			_quantity : Integer; 
			_volume : Decimal;
			_weight : Decimal;
			_cargoIdCount : Integer
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.myCargoType := _myCargoType;
	self.myProduct := _myProduct;
	self.quantity := _quantity;
	self.volume := _volume;
	self.weight := _weight;
	self.outputCargoIdCount := _cargoIdCount.max(1);
	
	self.factor := 1;
	self.myRecipeComponent := null;

epilog

end;</source>
        <Parameter name="_myCargoType" type="CM_CargoType"/>
        <Parameter name="_myProduct" type="CM_Product"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_cargoIdCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setOutputCargoIdCount" id="17d81a25-feb3-4e14-a825-b078e1735e53">
        <updating/>
        <source>setOutputCargoIdCount( _outputCargoIdCount : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin

	self.outputCargoIdCount := _outputCargoIdCount;

epilog

end;</source>
        <Parameter name="_outputCargoIdCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tiString" id="957fcaef-1d02-4615-9422-1f2b14a6daea">
        <source>tiString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	tiStr : String;
	ti : CM_TrackedItem;

begin

	foreach ti in self.allTis do
		if tiStr = null then
			tiStr := ti.id;
		else
			tiStr := tiStr &amp; ", " &amp; ti.id;
		endif;
	endforeach;
	
	return tiStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
