    <JadeMethod name="lstQueues_dragDrop" id="d691d8dc-2da5-4f02-8725-aecae9047419">
        <controlMethod name="ListBox::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstQueues_dragDrop(listbox: YRD_QueueListBox input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     05 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	// TFS 2198 CNWAB1
	// TFS 52945 NAVCS2 22/03/2022
	if not self.canMaintainRTQueue then
		return;
	endif;

	self.doLstQueuesDrapDrop(listbox, win, x, y);
	listbox.dragMode := DragMode_None;
epilog	
	self.lstQueues.enableEvent('mouseMove', true);
end;</source>
        <Parameter name="listbox" type="YRD_QueueListBox" usage="input"/>
