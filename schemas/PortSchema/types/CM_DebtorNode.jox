        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="ccms1604_init" id="bd091424-ca21-4243-8a6e-3c2116864243">
        <updating/>
        <source>ccms1604_init() updating;
// ---------------------------------------------------------------------------
// Created:     28 September 2007 by cnwrs2
//
// Purpose:     
