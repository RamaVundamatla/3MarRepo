    <DbClassMap file="basedvpr"/>
    <PrimAttribute name="timeClient" id="960fb8de-2610-44bc-bd91-9d78b1000101">
        <embedded/>
        <type name="Time"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="timeServer" id="77d01967-1696-4869-b051-76de24d99ff9">
        <embedded/>
        <type name="Time"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addHours" id="d9d73ad2-22b4-49e9-8609-731b53167c85">
        <updating/>
        <source>addHours(pHours:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number of hours to the receiver's time.
//
// Parameters:	pHours - A +ve or -ve number of hours.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.timeClient	:=	self.timeClient.cnEcAddHours(pHours);
end;</source>
        <Parameter name="pHours" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addMinutes" id="ac56c769-0c8c-4fc9-ad45-ed6d0d8b8128">
        <updating/>
        <source>addMinutes(pMinutes:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number of minutes to the receiver's time.
//
// Parameters:	pMinutes - A +ve or -ve number of minutes.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.timeClient	:=	self.timeClient.cnEcAddMinutes(pMinutes);
end;</source>
        <Parameter name="pMinutes" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addSeconds" id="678feab0-545e-403c-945d-aeb8d770e6b2">
        <updating/>
        <source>addSeconds(pSeconds:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number of seconds to the receiver's time.
//
// Parameters:	pSeconds - A +ve or -ve number of seconds.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.timeClient	:=	self.timeClient.cnEcAddSeconds(pSeconds);
end;</source>
        <Parameter name="pSeconds" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="4f61f9b6-366a-43f3-9b8f-ae6942ad5855">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setTimeClient();
	self.setTimeServer();
end;</source>
    </JadeMethod>
    <JadeMethod name="setTimeClient" id="f9a7eace-d3a0-4ebf-9e1d-18309125bf5b">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setTimeClient() updating, protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Sets the client node time.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTime	: Time;
	
begin
	self.timeClient	:=	currentTime;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTimeServer" id="05afe048-3fa4-4db6-ac87-92be64f96e1d">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>setTimeServer() updating, protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Sets the server node time.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTime	: Time;
	
begin
	self.timeServer	:=	currentTime;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateMe" id="8bd2d6bd-0341-495e-8ec6-6590be42b63a">
        <updating/>
        <source>updateMe(pTime:Time) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Sets the receiver's time value.
//
// Parameters:	pTime - The time value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.timeClient &lt;&gt; pTime then
		self.timeClient	:=	pTime;
	endif;
end;</source>
        <Parameter name="pTime" type="Time"/>
    </JadeMethod>
</Class>
