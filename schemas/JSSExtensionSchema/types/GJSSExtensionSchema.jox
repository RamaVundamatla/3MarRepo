    <DbClassMap file="jssxs_default"/>
    <JadeMethod name="jssConfirmAction" id="e1947b19-8666-4579-813a-f600a496bbf1">
        <source>jssConfirmAction(pActionName:String; pEntityName:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		25 July 2000 by cnwdad1
//
// Purpose:		Returns a flag after asking the User for confirmation of an action.
//
// Parameters:	pAction - A description of the action to be performed.
//				pEntityName - The name of the entity to be actioned.
//
// Returns:		True if the User has confirmed the action, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (app.msgBox($JSS_CONFIRM_ACTION(pActionName, pEntityName), $JSS_WARNING, MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes);
end;</source>
        <Parameter name="pActionName" type="String"/>
        <Parameter name="pEntityName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssConfirmDelete" id="b6a04d2c-5bf2-4f5a-b3ae-5ec38eabfeab">
        <source>jssConfirmDelete(pEntityName:String):Boolean;
// --------------------------------------------------------------------------------
// Created:		25 July 2000 by cnwdad1
//
// Purpose:		Returns a flag after asking the User for confirmation of a delete.
//
// Parameters:	pEntityName (String) - The name of the entity to be deleted.
//
// Returns:		True if the User has confirmed the delete, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (app.msgBox($JSS_CONFIRM_DELETE(pEntityName), $JSS_WARNING, MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes);
end;</source>
        <Parameter name="pEntityName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssFileException" id="bd1dff6b-b44a-4d1a-ab26-f5498ef82ee3">
        <source>jssFileException(pException:FileException):Integer;
// --------------------------------------------------------------------------------
// Created:		03 August 2000 by cnwdad2
//
// Purpose:		This is an exception handler specifically for File Exceptions.
//				This handler is intended to be for localized file operations only,
//				it is not meant to be armed globally.
//
// Parameters:	pException (FileException) - The raised exception object.
//
// Returns:		Passes back and "Abort Action" response.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 25/10/2000	cnwdad1		Changed to return a "Pass Back" value if the exception
//							occurred on the server node (message box dialogs cannot
//							be displayed on the server node, and there'd be no point
//							even if you could).
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	if node.isServerNode() then
		return Ex_Pass_Back;
	else
		errorMessage	:=	pException.text() &amp; CrLf &amp; CrLf &amp; "File: " &amp; pException.file().fileName;

		app.msgBox(errorMessage, $JSS_FILE_ERROR, MsgBox_Stop_Icon + MsgBox_OK_Only);
		return Ex_Abort_Action;
	endif;
end;</source>
        <Parameter name="pException" type="FileException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssGetAllFileNames" id="b1e430da-f054-4b39-a584-a15f43c9cb8a">
        <source>jssGetAllFileNames(pFolder:FileFolder input; pFileNameArray:JSSArray io; pIsIncludeSubdirectories:Boolean);
// --------------------------------------------------------------------------------
// Created:		11 October 2000 by cnwdad1
//
// Purpose:		This method will return a list of all file names in the directory
//				of the specified FileFolder (recursively if subdirectories are
//				to be included).
//
// Parameters:	pFolder (FileFolder) - The file directory to scan.
//				pFileNameArray (JSSArray) - The array of file names.
//				pIsIncludeSubdirectories (Boolean) - If true, then subdirecorties
//					will also be scanned.
//
// Returns:		The IO pFileNameArray parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFileNode	: FileNode;

begin
	foreach theFileNode in pFolder.files() do
		if theFileNode.isKindOf(File) then
			pFileNameArray.addString(theFileNode.File.fileName);
		elseif theFileNode.isKindOf(FileFolder) and pIsIncludeSubdirectories then
			self.jssGetAllFileNames(theFileNode.FileFolder, pFileNameArray, pIsIncludeSubdirectories);
		endif;
	endforeach;
end;</source>
        <Parameter name="pFolder" type="FileFolder" usage="input"/>
        <Parameter name="pFileNameArray" type="JSSArray" usage="io"/>
        <Parameter name="pIsIncludeSubdirectories" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssGetAllPrinters" id="478a1e34-9498-4c6d-9dea-7a283161d488">
        <executionLocation>client</executionLocation>
        <source>jssGetAllPrinters(pPrinterArray:StringArray io) clientExecution;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Populates the specified string array with a list of the printers
//				that are configured (visible to) the client.
//
// Parameters:	pPrinterArray (StringArray) - The array of prionter names.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	localPrinters	: StringArray;
	stringIndex		: Integer;
	arraySize		: Integer;

begin
	global.jssGetAllServerPrinters(pPrinterArray);

	create localPrinters transient;
	app.printer.getAllPrinters(localPrinters);

	arraySize	:=	localPrinters.size();
	stringIndex	:=	1;

	foreach stringIndex in 1 to arraySize do
		pPrinterArray.add(localPrinters[stringIndex]);
	endforeach;
epilog
	delete localPrinters;
end;</source>
        <Parameter name="pPrinterArray" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jssGetAllServerPrinters" id="f091f6bc-48e0-434a-936a-b0c27eda3fb0">
        <executionLocation>server</executionLocation>
        <source>jssGetAllServerPrinters(pPrinterArray:StringArray io) serverExecution;
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		Populates the specified string array with a list of the printers
//				that are configured (visible to) the database server.
//
// Parameters:	pPrinterArray (StringArray) - The array of prionter names.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (not pPrinterArray = null) then
		app.printer.getAllPrinters(pPrinterArray);
	endif;
end;</source>
        <Parameter name="pPrinterArray" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jssGetCommandLineParameter" id="e718217d-bb8a-46c7-86a0-d2c79e9f4aa6">
        <source>jssGetCommandLineParameter(pParameterName:String; pParameterValue:String io):Boolean;
// --------------------------------------------------------------------------------
// Created:		18 June 2000 by cnwdad1
//
// Purpose:		Returns the value of a JADE.EXE Command Line parameter.
//
// Parameters:	pParameterName - The name of the Parameter.
//				pParameterValue - The value of the requested parameter.
//
// Returns:		Boolean - True if the parameter name was found, false if not.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 21/01/2002	cnwdad1		Changed to check for Unicode and to call the appropriate
//							External Function.
// --------------------------------------------------------------------------------
vars
	parameterName	: String;
	isFound			: Boolean;
	commandLine		: String;
	parameterPos	: Integer;
	tokenPos		: Integer;

begin
	parameterName	:=	pParameterName.toLower();
	
	if app.isUnicode() then
		commandLine		:=	call jssGetCommandLineW.toLower();
	else
		commandLine		:=	call jssGetCommandLineA.toLower();
	endif;

	parameterPos	:=	commandLine.pos(pParameterName, 1);
	isFound			:=	(parameterPos &gt; 0);

	if isFound then
		tokenPos	:=	commandLine.pos("=", parameterPos);		// Get the position of the parameter's assignment.

		if tokenPos &gt; parameterPos and tokenPos &lt; commandLine.length() then
			tokenPos		:=	tokenPos + 1;					// We don't want to include the "=" in the returned value.
			pParameterValue	:=	commandLine.getNextToken(tokenPos).trimBlanks();
		else
			pParameterValue	:=	null;
		endif;
	endif;
epilog
	return isFound;
end;</source>
        <Parameter name="pParameterName" type="String"/>
        <Parameter name="pParameterValue" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssGetConstants" id="01dcdb4e-68d8-460a-9f87-9dca3dab356d">
        <source>jssGetConstants(pCategoryName:String; pConstantColl:ConstantNDict io):Boolean;
// --------------------------------------------------------------------------------
// Created:		01 February 2000 by cnwdad1
//
// Purpose:		Returns a collection of Global Constants for the requested Category.
//
// Parameters:	pCategoryName (String) - The name of the category whose constants to get.
//				pConstantColl (ConstantNDict) - The collection of constants.
//
// Returns:		True if the constant category is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCategory		: ConstantCategory;

begin
	theCategory	:=	currentSchema.getConstantCategory(pCategoryName);

	if theCategory = null then
		return false;
	else
		pConstantColl	:=	theCategory.getConstants();
		return true;
	endif;
end;</source>
        <Parameter name="pCategoryName" type="String"/>
        <Parameter name="pConstantColl" type="ConstantNDict" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssGetEnvironmentVariable" id="9988a493-c9a3-419c-af04-0174467bf94d">
        <source>jssGetEnvironmentVariable(pEnvironmentVariable:String):String;
// --------------------------------------------------------------------------------
// Created:		03 August 2000 by cnwdad2
//
// Purpose:		Returns the value for a Windows (DOS) Environment Variable (Refer
//				to the "DOS_Environment_Variables" category of Global Constants
//				for a list of pre-defined Enviroment Variables).  Note that this
//				method requires that the CardSchema's "karma.dll" library exists
//				in the JADE binaries directory.
//
// Parameters:	pEnvironmentVariable (String) - The name of the Environment Variable
//				whose value is being sought.
//
// Returns:		The value of the Environment Variable (this value will be null if
//				the Environment Variable name is not valid).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	environmentVariableValue	: String;

begin
	call cnGetEnvironmentVariable(pEnvironmentVariable, environmentVariableValue, JSS_DOSENV_MAX_RETURN_SIZE);
epilog
	return environmentVariableValue;
end;</source>
        <Parameter name="pEnvironmentVariable" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetFileSeparator" id="cc0db972-db78-478d-aa53-425d8f52f167">
        <source>jssGetFileSeparator():Character;
// --------------------------------------------------------------------------------
// Created:		02 September 2002 by cnwdad1
//
// Purpose:		Determines the platform of the operating system on which the calling
//				node is running, and return the appropriate file name separator,
//				i.e. a "\" (for Windows) or "/" (for Unix).
//
// Parameters:	None
//
// Returns:		The file name separator character.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.jssIsUnix() then
		return JSS_SEPARATOR_UNIX;
	else
		return JSS_SEPARATOR_WIN;
	endif;
end;</source>
        <ReturnType type="Character"/>
    </JadeMethod>
    <JadeMethod name="jssGetHttpBinary" id="57d101a9-faaf-4afa-bd19-34916b42bad2">
        <source>jssGetHttpBinary(	pBinaryUrl:String;
					pIsServerExecution:Boolean;
					pUsePresentationFileSystem:Boolean;
					pBinaryData:Binary io):String;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Fetches a binary file from an HTTP server.
//
// Parameters:	pBinaryUrl (String) - The URL from which to get the file.
//				pIsServerExecution (Boolean) - If true, then operation will be
//					performed on the server node.
//				pBinaryData (Binary) - The returned binary file.
//
// Returns:		Null if successful, otherwise returns an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 25/10/2000	cnwdad1		Added option for the fetching of the binary file to run
//							on the server node.  To guarantee the uniqueness of the
//							temporary (work) file name, also now sending the network
//							address of the requesting client to the operation.
//
// 14/05/2004	cnwdad1		Added the pUsePresentationFileSystem parameter.
// --------------------------------------------------------------------------------
vars
	workFileName	: String;
	
begin
	workFileName	:=	process.networkAddress();
	
	if workFileName = null then
		workFileName	:=	"\working.dat";
	else
		workFileName	:=	"\" &amp; workFileName &amp; ".dat";
	endif;

	if pIsServerExecution then
		return self.jssGetHttpBinaryServer(pBinaryUrl, workFileName, pBinaryData);
	else
		return self.jssGetHttpBinaryClient(pBinaryUrl, workFileName, pUsePresentationFileSystem, pBinaryData);
	endif;
end;</source>
        <Parameter name="pBinaryUrl" type="String"/>
        <Parameter name="pIsServerExecution" type="Boolean"/>
        <Parameter name="pUsePresentationFileSystem" type="Boolean"/>
        <Parameter name="pBinaryData" type="Binary" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetHttpBinaryClient" id="c357036c-8c1f-4aff-8f1b-513788a75cc3">
        <executionLocation>client</executionLocation>
        <source>jssGetHttpBinaryClient(	pBinaryUrl:String;
						pWorkFile:String;
						pUsePresentationFileSystem:Boolean;
						pBinaryData:Binary io):String protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		25 October 2000 by cnwdad1
//
// Purpose:		Refer to the "jssGetHttpBinary" method on this class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/05/2004	cnwdad1		Added the pUsePresentationFileSystem parameter.
// --------------------------------------------------------------------------------
begin
	return self.jssGetHttpBinaryFile(pBinaryUrl, pWorkFile, pUsePresentationFileSystem, pBinaryData);
end;</source>
        <access>protected</access>
        <Parameter name="pBinaryUrl" type="String"/>
        <Parameter name="pWorkFile" type="String"/>
        <Parameter name="pUsePresentationFileSystem" type="Boolean"/>
        <Parameter name="pBinaryData" type="Binary" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetHttpBinaryFile" id="b6c3a77e-cf3c-4b70-a6e6-6474ef9f9ec9">
        <source>jssGetHttpBinaryFile(	pBinaryUrl:String;
						pWorkFile:String;
						pUsePresentationFileSystem:Boolean;
						pBinaryData:Binary io):String protected;
// --------------------------------------------------------------------------------
// Created:		25 October 2000 by cnwdad1
//
// Purpose:		Refer to the "jssGetHttpBinary" method on this class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/05/2004	cnwdad1		Added the pUsePresentationFileSystem parameter.
// --------------------------------------------------------------------------------
vars
	requestResponse	: String;
	protocol		: String;
	webServer		: String;
	sourceFile		: String;
	targetFile		: String;
	tempFile		: File;
	theFolder		: FileFolder;
	workingFileName	: String;

begin
	on FileException do global.jssFileException(exception);

	// Extract the URL's constituent parts (we don't need the 'protocol' however).

	requestResponse	:=	pBinaryUrl.jssGetURLParts(protocol, webServer, sourceFile);

	if requestResponse &lt;&gt; null then
		return requestResponse;
	endif;

	// Get the Windows "temp" directory.
	workingFileName		:=	global.jssGetEnvironmentVariable(JSS_DOSENV_TEMP);

	if workingFileName = null then
		return $JSS_FILE_CANT_FIND_TEMP(JSS_DOSENV_TEMP);
	endif;

	// Check that the "Temp" directory is a valid file path...
	create theFolder transient;

	if not theFolder.isValidPathName(workingFileName) then
		return $JSS_FILE_TEMP_NOT_VALID(workingFileName);
	endif;

	// Check that the "Temp" directory is available...

	theFolder.fileName	:=	workingFileName;

	if not theFolder.isAvailable() then
		return $JSS_FILE_TEMP_NOT_AVAILABLE(workingFileName);
	endif;

	// Append the working file name to the "Temp" directory...

	workingFileName	:=	workingFileName &amp; pWorkFile;

	// Next, get the file from the URL...

	requestResponse	:=	global.jssGetHttpFile(webServer, sourceFile, workingFileName, node.isServerNode(), pUsePresentationFileSystem);

	// Now read the file in as a binary...

	if requestResponse &lt;&gt; null then
		return requestResponse;
	endif;

	create tempFile transient;
	tempFile.fileName	:=	workingFileName;
	tempFile.kind		:=	File.Kind_Binary;

	if tempFile.tryOpen() then
		pBinaryData		:=	tempFile.readBinary(tempFile.fileLength());
	else
		return $JSS_FILE_CANNOT_OPEN(tempFile.fileName);
	endif;

	tempFile.purge();

	return null;
epilog
	delete tempFile;
	delete theFolder;
end;</source>
        <access>protected</access>
        <Parameter name="pBinaryUrl" type="String"/>
        <Parameter name="pWorkFile" type="String"/>
        <Parameter name="pUsePresentationFileSystem" type="Boolean"/>
        <Parameter name="pBinaryData" type="Binary" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetHttpBinaryServer" id="9bee5a01-0d77-445e-9676-e94f26737ea6">
        <executionLocation>server</executionLocation>
        <source>jssGetHttpBinaryServer(pBinaryUrl:String; pWorkFile:String; pBinaryData:Binary io):String protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		25 October 2000 by cnwdad1
//
// Purpose:		Refer to the "jssGetHttpBinary" method on this class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.jssGetHttpBinaryFile(pBinaryUrl, pWorkFile, false, pBinaryData);
end;</source>
        <access>protected</access>
        <Parameter name="pBinaryUrl" type="String"/>
        <Parameter name="pWorkFile" type="String"/>
        <Parameter name="pBinaryData" type="Binary" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetHttpFile" id="1aad51e6-b296-4ac6-a360-199299963bd8">
        <source>jssGetHttpFile(	pWebServer:String;
				pFilePath:String;
				pTargetFile:String;
				pIsServerExecution:Boolean;
				pUsePresentationFileSystem:Boolean):String;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Fetches a file from an HTTP Web Server.
//
// Parameters:	pWebServer (String) - The name of the web server,
//									 e.g. "www.discoverjade.com".
//				pFilePath (String) - The path of the file (includeing the file name),
//									 e.g. "/Images/jadelogo.jpg" (note the preceding slash).
//				pTargetFile (String) - The file name (including path) to which the
//									 received file will be written, e.g. "c:\temp\logo.jpg".
//				pIsServerExecution (Boolean) - A flag to indicate whether the
//									 operation should should be executed on the server.
//				pUsePresentationFileSystem -A boolean flag to indicate whether the
//				presentation client's file system should be used (not applicable for
//				server execution).
//
// Returns:		String - Null if the operation was successsful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIsServerExecution then
		return self.jssGetHttpFileServer(pWebServer, pFilePath, pTargetFile);
	else
		return self.jssGetHttpFileClient(pWebServer, pFilePath, pTargetFile, pUsePresentationFileSystem);
	endif;
end;</source>
        <Parameter name="pWebServer" type="String"/>
        <Parameter name="pFilePath" type="String"/>
        <Parameter name="pTargetFile" type="String"/>
        <Parameter name="pIsServerExecution" type="Boolean"/>
        <Parameter name="pUsePresentationFileSystem" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetHttpFileClient" id="2069e4ce-d06c-40c1-a798-3162dacc2a37">
        <executionLocation>client</executionLocation>
        <source>jssGetHttpFileClient(pWebServer:String; pFilePath:String; pTargetFile:String; pUsePresentationFileSystem:Boolean):String protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Refer to the "jssGetHttpFile" method on this class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/05/2004	cnwdad1		Added the pUsePresentationFileSystem parameter.
// --------------------------------------------------------------------------------
begin
	return self.jssGetHttpFileName(pWebServer, pFilePath, pTargetFile, pUsePresentationFileSystem);
end;</source>
        <access>protected</access>
        <Parameter name="pWebServer" type="String"/>
        <Parameter name="pFilePath" type="String"/>
        <Parameter name="pTargetFile" type="String"/>
        <Parameter name="pUsePresentationFileSystem" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetHttpFileName" id="f28b8300-4da9-4819-8d33-46c3957a8584">
        <source>jssGetHttpFileName(pWebServer:String; pFilePath:String; pTargetFile:String; pUsePresentationFileSystem:Boolean):String protected;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Refer to the "jssGetHttpFile" method on this class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/05/2004	cnwdad1		Added the pUsePresentationFileSystem parameter.
// --------------------------------------------------------------------------------
vars
	httpConnect		: CnHttp;
	requestResult	: String;

begin
	create httpConnect transient;
	httpConnect.setServerName(pWebServer);
	requestResult	:=	httpConnect.cnConnect;

	if requestResult = CN_OK then
		requestResult	:=	httpConnect.cnGetFile(pFilePath, pTargetFile, pUsePresentationFileSystem);

		if requestResult = CN_OK then
			return null;
		endif;
	endif;

	return requestResult;
epilog
	delete httpConnect;
end;</source>
        <access>protected</access>
        <Parameter name="pWebServer" type="String"/>
        <Parameter name="pFilePath" type="String"/>
        <Parameter name="pTargetFile" type="String"/>
        <Parameter name="pUsePresentationFileSystem" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetHttpFileServer" id="3a9ce58c-6848-40f2-85a3-ff3cdb6a6485">
        <executionLocation>server</executionLocation>
        <source>jssGetHttpFileServer(pWebServer:String; pFilePath:String; pTargetFile:String):String protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		02 August 2000 by cnwdad1
//
// Purpose:		Refer to the "jssGetHttpFile" method on this class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.jssGetHttpFileName(pWebServer, pFilePath, pTargetFile, false);
end;</source>
        <access>protected</access>
        <Parameter name="pWebServer" type="String"/>
        <Parameter name="pFilePath" type="String"/>
        <Parameter name="pTargetFile" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetTempDirectory" id="5c5776c0-4b79-4241-8d45-abc532146272">
        <source>jssGetTempDirectory():String;
// --------------------------------------------------------------------------------
// Created:		03 August 2000 by cnwdad2
//
// Purpose:		Returns the Windows (DOS) "Temp" directory.  Note that this method
//				requires that the CardSchema's "karma.dll" library exists in the
//				JADE binaries directory.
//
// Parameters:	None
//
// Returns:		The name of the directory.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return global.jssGetEnvironmentVariable(JSS_DOSENV_TEMP);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssIsUnix" id="390c1848-8fce-440e-b527-11a7ba2d0c37">
        <source>jssIsUnix():Boolean;
// --------------------------------------------------------------------------------
// Created:		03 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	osPlatform		: Integer;
	osVersion		: String;
	osArchitecture	: Integer;
	
begin
	osPlatform		:=	node.getOSPlatform(osVersion, osArchitecture);
	
	return (osPlatform.bitAnd(Node.OSUnix) &lt;&gt; 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsValidHttpFile" id="cb3ef010-ae73-4248-98e7-bfebaf07180f">
        <source>jssIsValidHttpFile(pFilePathName:String; pIsIgnoreEmpty:Boolean; pErrorMessage:String output):Boolean;
// --------------------------------------------------------------------------------
// Created:		28 September 2000 by cnwdad2
//
// Purpose:		This method will validate a remote file on an HTTP server.
//
// Parameters:	pFilePathName (String) - The name and path of the file, and
//					optionally the protocol (e.g. HTTP://).
//				pIsIgnoreEmpty (Boolean) - If true, then an empty file will
//					not be reported as invalid.
//				pErrorMessage (String) - If the file is not valid, then this
//					parameter will return the error message, otherwise a null
//					value will be returned.
//
// Returns:		True if the file is value, otherwise false (in which case an error
//				message will also be returned in the output parameter).
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isValidFile		: Boolean;
	httpConnect		: CnHttp;
	requestResult	: String;
	protocol		: String;
	webServer		: String;
	sourceFile		: String;
	sourceFileSize	: Integer;

begin
	isValidFile		:=	true;
	pErrorMessage	:=	null;
	pFilePathName.jssGetURLParts(protocol, webServer, sourceFile);
	
	create httpConnect transient;
	httpConnect.setServerName(webServer);
	requestResult	:=	httpConnect.cnConnect;
	
	if requestResult = CN_OK then
		requestResult	:=	httpConnect.cnGetFileSize(sourceFile, sourceFileSize);
		
		if requestResult = CN_OK then
			if (not pIsIgnoreEmpty) and sourceFileSize = 0 then
				pErrorMessage	:=	$JSS_FILE_EMPTY(sourceFile);
				isValidFile		:=	false;
			endif;
		else
			pErrorMessage	:=	requestResult;
			isValidFile		:=	false;
		endif;
	else
		pErrorMessage	:=	requestResult;
		isValidFile		:=	false;
	endif;
epilog
	delete httpConnect;
	return isValidFile;
end;</source>
        <Parameter name="pFilePathName" type="String"/>
        <Parameter name="pIsIgnoreEmpty" type="Boolean"/>
        <Parameter name="pErrorMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsValidServerDirectory" id="c74c211e-a9bb-439d-bafe-4018c02e0f7d">
        <executionLocation>server</executionLocation>
        <source>jssIsValidServerDirectory(pDirectoryName:String):Boolean serverExecution;
// --------------------------------------------------------------------------------
// Created:		06 February 2001 by cnwdad1
//
// Purpose:		Validates a directory name relative to the JADE server node.
//
// Parameters:	pDirectoryName - The name of the directory to validate.
//
// Returns:		True if the directory is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFileFolder	: FileFolder;
	
begin
	create theFileFolder transient;
	theFileFolder.fileName	:=	pDirectoryName;
	
	return theFileFolder.isAvailable();
epilog
	delete theFileFolder;
end;</source>
        <Parameter name="pDirectoryName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssMessage_UnknownError" id="63fefa60-ed42-489a-8b88-8af1770e462a">
        <source>jssMessage_UnknownError(pErrorMessage:String);
// --------------------------------------------------------------------------------
// Created:		26 July 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	pMessageString	: String;

begin
	if pErrorMessage.trimBlanks().length() = 0 then
		pMessageString	:=	$JSS_FATAL_ERROR;
	else
		pMessageString	:=	pErrorMessage;
	endif;

	pMessageString	:=	pMessageString &amp; CrLf &amp; CrLf &amp; $JSS_CONTACT_ADMINISTRATOR;
	app.msgBox(pMessageString, $JSS_ERROR, MsgBox_Stop_Icon + MsgBox_OK_Only);
end;</source>
        <Parameter name="pErrorMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="jssReadBinaryFile" id="54ec63db-1590-47e4-b4ed-b9c6947a27cc">
        <source>jssReadBinaryFile(pFileName:String):Binary;
// --------------------------------------------------------------------------------
// Created:		19 November 2001 by cnwdad1
//
// Purpose:		Reads a file from disk as binary data.
//
// Parameters:	pFileName - The name (including the path) of the file to read.
//
// Returns:		The binary file data.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFile			: File;
	theBinaryFile	: Binary;
	
begin
	create theFile transient;
	theFile.kind	:=	File.Kind_Binary;
	theFile.openInput(pFileName);
	theBinaryFile	:=	theFile.readBinary(theFile.fileLength());
	
	return theBinaryFile;
epilog
	delete theFile;
end;</source>
        <Parameter name="pFileName" type="String"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="jssXHandlerDuplicate" id="b411c4c8-accc-4816-b30e-599d77bb9317">
        <source>jssXHandlerDuplicate(pTheException:Exception):Integer;
// --------------------------------------------------------------------------------
// Created:		31 May 2001 by cnwdad1
//
// Purpose:		Use this exception handler when adding a member to a collection where
//				a duplicate may arise.  Only use this method for situations where it
//				is acceptable for the application to ignore the duplicate and
//				continue without the need to handle this condition.
//
// Parameters:	pTheException - The exception object that was raised.
//
// Returns:		The pass-back value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	DUPLICATE_OBJECT	: Integer = 1309;
	DUPLICATE_KEY		: Integer = 1310;
	
begin
	if pTheException.errorCode = DUPLICATE_OBJECT
	or pTheException.errorCode = DUPLICATE_KEY
	then
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssXHandlerGetPropertyValue" id="28ff967b-def4-44d9-9daf-42571c870a00">
        <source>jssXHandlerGetPropertyValue(pException:Exception):Integer;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		If we're using the "getPropertyValue" method and wish to ignore an
//				exception if the requested property name was not valid, then we'll
//				using this handler to simply resume execution.
//
// Parameters:	pException (Exception) - The raised exception.
//
// Returns:		Resume Next if error 1011 is receiver, otherwise Pass Back to the
//				next handler in the stack.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ERROR_1011	: Integer = 1011;

begin
	if pException.errorCode = ERROR_1011 then
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <Parameter name="pException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssXHandlerNoCollectionEntry" id="67d5c5c1-02c9-4832-a2e1-543cfbe60dc9">
        <source>jssXHandlerNoCollectionEntry(pTheException:Exception):Integer;
// --------------------------------------------------------------------------------
// Created:		31 May 2001 by cnwdad1
//
// Purpose:		Use this exception handler when removing a member from a collection
//				where it is valid to ignore an error if the member is not actually
//				in the collection.
//
// Parameters:	pTheException - The exception object that was raised.
//
// Returns:		The pass-back value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ENTRY_NOT_FOUND	: Integer = 1301;
	
begin
	if pTheException.errorCode = ENTRY_NOT_FOUND then
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssXHandlerResumeNext" id="7b080d68-45f2-4179-a5ea-933f45fdbec2">
        <source>jssXHandlerResumeNext(	pTheExceptionObject : Exception;
						pErrorNumber : Integer output;
						pErrorText : String output) : Integer;
// --------------------------------------------------------------------------------
// Created:		27 November 2001 by cnwdad1
//
// Purpose:		Exception handler to pass control back to the method that armed
//				this handler.  Execution will resume from the next expression after
//				the evaluation of the method call or expression in which the
//				exception occurred.
//
// Parameters:	pTheExceptionObject - The exception instance.
//				pErrorNumber - The exception error code.
//				pErrorText - The exception error text.
//
// Returns:		The error number and error text (via the above output parameters),
//				and the exception's pass-back value (i.e. to "resume next").
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pErrorNumber	:=	pTheExceptionObject.errorCode;
	pErrorText		:=	pTheExceptionObject.text();
	
	return Ex_Resume_Next;
end;</source>
        <Parameter name="pTheExceptionObject" type="Exception"/>
        <Parameter name="pErrorNumber" type="Integer" usage="output"/>
        <Parameter name="pErrorText" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
