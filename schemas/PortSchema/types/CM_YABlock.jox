    </JadeMethod>
    <JadeMethod name="setForUpdate" id="642ef766-a142-4a80-ba7e-c4e644c7fc07">
        <updating/>
        <source>setForUpdate(pProxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		13 March 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	realDeckingOptions,
	pxyDeckingOptions	: CM_YADeckingOptionsBlock;

begin

	self.description	:=	pProxyObj.description;
	pxyDeckingOptions	:=	pProxyObj.myDeckingOptions;

	self.allYardControllers.clear;
	pProxyObj.allYardControllers.copy(self.allYardControllers);
	self.setGridObjects();

	self.myTerminalArea		:=	pProxyObj.myTerminalArea;
	self.status 			:=  pProxyObj.status;

	if pxyDeckingOptions &lt;&gt; null and self.myDeckingOptions = null then
		create realDeckingOptions persistent;

		realDeckingOptions.setForCreate(pxyDeckingOptions);

		realDeckingOptions.setMyBlock(self);
		realDeckingOptions.initialiseForDecking();

		//apply rules to YALocationCells
		realDeckingOptions.applyDeckingRulesToCellOrder();

	endif;

	self.updateDescriptionFromYAM();	
	// Build the location stat record
	self.buildLocationStatistics();
	
end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
