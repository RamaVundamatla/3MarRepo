<GUIClass name="TextBox">
    <JadeMethod name="controlNamePrefix" id="a2762d39-e4da-4f75-8caa-88af2ad8246c">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		05 May 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "txt";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssDate" id="81520c29-4952-4ad4-8101-0f8d78b13d9e">
        <source>jssDate():Date;
// --------------------------------------------------------------------------------
// Created:		20 December 2000 by cnwdad1
//
// Purpose:		Returns the text value of the receiver as a Date value.
//
// Parameters:	None
//
// Returns:		Date - the trimmed text cast to a Date value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.trimBlanks.Date;
end;</source>
        <text>___________________________________________________________________________

