    <JadeMethod name="adjustContainerLayout" id="3c5a0b56-cab3-45b6-af53-89a20592a2f7">
        <source>adjustContainerLayout(_allProxyCargoObj:GTE_KioskProxyCargoArray) protected;
// --------------------------------------------------------------------------------
// Created:		24 September 2006 by cnwdad1
//
// Purpose:		Adjusts the container layout depending upon how many containers
//				there are.
//
// Parameters:	_allProxyCargoObj - A referencee to an array of proxy cargo objects.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	editCargoObj		: GTE_KioskProxyCargo;
	proxyCargoObj		: GTE_KioskProxyCargo;
	containerObj		: CMUI_ContainerLoad;
	cargoCount			: Integer;
	fortyCount			: Integer;
	cargoWidth1			: Integer;
	cargoWidth2			: Integer;
	cargoWidth3			: Integer;
	cargoWidth4			: Integer;
	
begin

	//19 May 2020	NDL	TFS 49167
	if self.isAAAI then
		self.adjustGeneralCargoLayout();
		return;
	endif;
	
	editCargoObj	:=	self.aMyProxyLoad.findCargoForId(self.getCurrentCargoId(), self.aCargoCount);
	fortyCount		:=	_allProxyCargoObj.getFortyCount();
	cargoCount		:=	0;
	
	foreach proxyCargoObj in _allProxyCargoObj do
		cargoCount	:=	cargoCount + 1;
		
		if cargoCount = 1 then
			containerObj	:=	picLoad1;
		elseif cargoCount = 2 then
			containerObj	:=	picLoad2;
		elseif cargoCount = 3 then
			containerObj	:=	picLoad3;
		elseif cargoCount = 4 then
			containerObj	:=	picLoad4;
		else
			break;
		endif;
		
		containerObj.initializeMe(	proxyCargoObj.id(),
									proxyCargoObj.count,
									proxyCargoObj.isDoorsBack,
									proxyCargoObj.isEmpty,
									proxyCargoObj.isForty);
		
		if proxyCargoObj.id() &lt;&gt; editCargoObj.id()
		or proxyCargoObj.count &lt;&gt; self.aCargoCount
		then
			containerObj.setIsEmpty(true);
		endif;
	endforeach;
	
	if cargoCount &lt;= 2 and fortyCount = 0 then
		picLoad1.stretch	:=	Picture.Stretch_ControlTo;
		picLoad2.stretch	:=	Picture.Stretch_ControlTo;
		picLoad1.left		:=	228;
		picLoad2.left		:=	419;
		picLoad3.visible	:=	false;
		picLoad4.visible	:=	false;
		
		return;
	else
		picLoad1.stretch	:=	Picture.Stretch_ToControl;
		picLoad2.stretch	:=	Picture.Stretch_ToControl;
		picLoad3.stretch	:=	Picture.Stretch_ToControl;
		picLoad4.stretch	:=	Picture.Stretch_ToControl;
		picLoad1.left		:=	218;
	endif;
	
	cargoWidth1		:=	0;
	cargoWidth2		:=	0;
	cargoWidth3		:=	0;
	cargoWidth4		:=	0;
	
	_allProxyCargoObj.getWidths(cargoWidth1, cargoWidth2, cargoWidth3, cargoWidth4);
	
	if cargoWidth1 = 0 then
		picLoad1.visible	:=	false;
	else
		picLoad1.visible	:=	true;
		picLoad1.width		:=	cargoWidth1;
	endif;
	
	if cargoWidth2 = 0 then
		picLoad2.visible	:=	false;
	else
		picLoad2.visible	:=	true;
		picLoad2.move((picLoad1.left + picLoad1.width + 1), picLoad1.top, cargoWidth2, picLoad2.height);
	endif;
	
	if cargoWidth3 = 0 then
		picLoad3.visible	:=	false;
	else
		picLoad3.visible	:=	true;
		picLoad3.move((picLoad2.left + picLoad2.width + 1), picLoad2.top, cargoWidth3, picLoad3.height);
	endif;
	
	if cargoWidth4 = 0 then
		picLoad4.visible	:=	false;
	else
		picLoad4.visible	:=	true;
		picLoad4.move((picLoad3.left + picLoad3.width + 1), picLoad3.top, cargoWidth4, picLoad4.height);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_allProxyCargoObj" type="GTE_KioskProxyCargoArray"/>
    </JadeMethod>
    <JadeMethod name="adjustGeneralCargoLayout" id="06f2ee8b-e08d-45f1-82e9-56220f996002">
        <source>adjustGeneralCargoLayout();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2020	jlgndl1	Initial creation	TFS 49167

*/
vars

	proxyCargoObj : GTE_KioskProxyCargo;
	releaseIdStrs : String;
	bulkRel : CM_BulkRelease;
	bulkRels : CM_BulkReleaseSet;

begin

	if not self.isAAAI then
		return;
	endif;
	
	self.picLoad1.visible := false;
	self.picLoad2.visible := false;
	self.picLoad3.visible := false;
	self.picLoad4.visible := false;
	
	picLoad1.stretch :=	Picture.Stretch_ToControl;
	picLoad1.left := 212;
	picLoad1.width := 397;
	
	create bulkRels transient;

	foreach proxyCargoObj in self.aMyProxyLoad.allReleases do
		bulkRel := proxyCargoObj.myCargoItem.CM_BulkRelease;
		if bulkRel = null or bulkRel = self.aMyCargoItem.CM_BulkRelease then
			continue;
		endif;
		if not bulkRels.includes( bulkRel ) then
			bulkRels.add( bulkRel );
		endif;
	endforeach;
	
	foreach bulkRel in bulkRels do
		if releaseIdStrs = null then
			releaseIdStrs := app.getErrorString(Other_releases_selected) &amp; " : " &amp; bulkRel.code;
		else
			releaseIdStrs := releaseIdStrs &amp; ", " &amp; bulkRel.code;
		endif;
	endforeach;
	
	if releaseIdStrs &lt;&gt; null then
	
		self.picLoad1.visible := true;
		self.lblAAAIReles.caption := releaseIdStrs;
		self.lblAAAIReles.visible := true;
		self.lblAAAIReles.transparent := false;
		self.lblAAAIReles.parent := self.picLoad1;
		self.lblAAAIReles.fontSize := 12;
		self.lblAAAIReles.fontBold := true;
		
		self.lblAAAIReles.move( 5, 3, picLoad1.width - 10, picLoad1.height - 6 );
		
	endif;

epilog

	delete bulkRels;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="btnMoveLoad_click" id="4a6ff321-2d1a-4f98-8039-d55895b397c3">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnMoveLoad_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	proxyCargoObj		: GTE_KioskProxyCargo;
	allProxyCargosObj	: GTE_KioskProxyCargoArray;
	
begin
	app.mousePointer	:=	Busy;
	proxyCargoObj		:=	self.aMyProxyLoad.findCargoForId(self.getCurrentCargoId(), self.aCargoCount);
	allProxyCargosObj	:=	self.aMyProxyLoad.getProxyCargoArray(proxyCargoObj);
	
	self.aMyProxyLoad.moveLoad(proxyCargoObj);
	self.adjustContainerLayout(allProxyCargosObj);
	app.beep();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNo_click" id="c3820b4d-0bda-49b0-b94b-f49e739f51f3">
        <controlMethod name="JadeMask::click"/>
