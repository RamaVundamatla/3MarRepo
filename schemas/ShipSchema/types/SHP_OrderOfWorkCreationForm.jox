    <JadeMethod name="mnuWPOpHrs_click" id="62f070ec-3d09-4903-8d27-7234c29bc759">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuWPOpHrs_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	crane : CM_Crane;
	workPoint : CM_WorkPoint;

begin

	if self.mnuWPOpHrs.userObject &lt;&gt; null then
		if self.mnuWPOpHrs.userObject.isKindOf(CM_Crane) then
			crane := self.mnuWPOpHrs.userObject.CM_Crane;
		elseif self.mnuWPOpHrs.userObject.isKindOf(CM_WorkPoint) then
			workPoint := self.mnuWPOpHrs.userObject.CM_WorkPoint;
		endif;
	endif;

	self.myAssistant.showWorkPointHrsForm( self.myCurrentVoyage, null, crane, workPoint);

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setColours" id="e61c5dc9-9e8e-4303-be57-9160c2772bdb">
        <updating/>
        <source>setColours() updating;
// ---------------------------------------------------------------------------
// Created:		17 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.xmlColourBay = 0 then
		self.xmlColourBay := self.myTerminal.getConfig(ShipTransitBoxColor).Integer;
	endif;
	if self.xmlColourRow = 0 then
		self.xmlColourRow := self.ColourLightYellow;
	endif;
	if self.xmlColourCell = 0 then
		self.xmlColourCell := self.ColourBlueLight;
	endif;
	self.clrBay.ignoreSkin := true;
	self.clrCell.ignoreSkin := true;
	self.clrRow.ignoreSkin := true;
	self.clrBay.backColor :=  self.xmlColourBay;
	self.clrCell.backColor :=  self.xmlColourCell;
	self.clrRow.backColor :=  self.xmlColourRow;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="0b3f2119-0da6-4019-abe3-f4584d562ff5">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		21 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 25/09/2017	jlgdap1		TFS 7009 Fix display when showing large toolbar icons
vars
begin
	self.usesQueryFrame := false;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.staStatusBar.visible := true;
	self.staStatusBar.zOrder(1); //epr 29/8/11 for some reason status bar wasn't showing
	self.initCranesTable();
	self.useTableInfo := false;
	self.useTableSorting := false;
	inheritMethod();
	
	//epr CCMS 1033 5/9/11 changes to show RORO deck jobs
	self.fldJobs.width:=self.clientWidth;
	self.fldJobs.top:=self.frmHeading.top+self.frmHeading.clientHeight + 1;
	self.fldJobs.height:=self.clientHeight - (self.staStatusBar.clientHeight + self.fldJobs.top +8 );
	self.fldJobs.left:=0;
	self.fldJobs.parentAspect:=Control.ParentAspect_StretchBoth;
	
	self.tblData.parent:=self.shtBayJobs;
	self.tblData.move(0,0,self.shtBayJobs.clientWidth,self.shtBayJobs.clientHeight);
	self.tblData.parentAspect:=Control.ParentAspect_StretchBoth;
	self.tblData.scrollBars:=Table.ScrollBar_Vertical;
	self.tblRORO.scrollBars:=Table.ScrollBar_Vertical;
	self.fldJobs.zOrder(1);
	
	self.shtBayJobs.showMySheet;
	
	self.splMain.visible:=false;
	
	self.mnuColumnOrganiser.visible := false;
	
	self.cmbBerthage.addItem("Port");
	self.cmbBerthage.addItem("Starboard");
	self.cmbBerthage.listIndex := 1;
	self.mnuOOWShowBay.visible := true;	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.tblData.userInputEnabled := false;
		self.tblCranes.userInputEnabled := false;
		self.tblRORO.userInputEnabled := false;
		self.grpVoyage.enabled:= false;
		self.grpCranes.enabled:= false;
		self.btnReset.enabled:= false;
		self.btnAutoJobs.enabled:= false;
		self.btnOOW.enabled:= false;
		self.btnJobPriority.enabled:= false;
		self.btnAlloc.enabled:= false;
	endif;
	
	self.doMoveControlsForLargeCaptions();						// TFS 7009
end;</source>
    </JadeMethod>
    <JadeMethod name="showColourLegend" id="c360efc4-739f-4712-9aa4-af498d9a76db">
        <source>showColourLegend();
/* ---------------------------------------------------------------------------
// Created:		04 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
01 Aug 2011	cnwer1	CCMS 1033 - roro operations changed to be able to show workpoints aswell as cranes
*/
vars
	colLegend		: CMUI_ColourLegend;
	vjs				: CM_VoyageJobSheet;
	tmpColour		: Integer;
	workPointObject	: CM_Object;
begin
	create colLegend;
	self.setNavigatorHeading( colLegend.caption ); 
	colLegend.centreWindow;
	
	if self.myCurrentVoyage &lt;&gt; null then
		foreach vjs in self.myCurrentVoyage.allJobSheets do
			workPointObject:=vjs.getMyWorkPointObject;
			if workPointObject &lt;&gt; null then
				colLegend.addLegendItem(workPointObject.IF_VoyageWorkPoint.getTypeDescription &amp; " " &amp; workPointObject.IF_VoyageWorkPoint.getID, workPointObject.IF_VoyageWorkPoint.getColour.getInverseColour(), workPointObject.IF_VoyageWorkPoint.getColour, null, false);
			endif;
		endforeach;
	endif;		
	
	tmpColour := self.xmlColourBay;
	colLegend.addLegendItem("Non Twin Lift Bay", tmpColour.getInverseColour(), tmpColour,null, false);
	tmpColour := self.xmlColourCell;
	colLegend.addLegendItem("Moved Cell", tmpColour.getInverseColour(), tmpColour,null, false);
	tmpColour := self.xmlColourRow;
	colLegend.addLegendItem("Row Colour", tmpColour.getInverseColour(), tmpColour,null, false);
	
	colLegend.addLegendItem(app.getErrorString(CM_Totals),  White,986895, null, false);
	
	colLegend.showModal;
	
epilog
	delete colLegend;
	// cnwrl1 16/04/2009 PAR 19440
	// reset the navigation heading.
	if self.myCurrentVoyage = null then
		self.setNavigatorHeading( self.caption );
	else
		self.setNavigatorHeading( self.myCurrentVoyage.code );
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showCraneAllocater" id="bf30b771-048d-4ce4-b705-1a4ea520730b">
        <source>showCraneAllocater();
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theForm : SHP_SelectCranes;

begin
	if not self.doCheckVoyage(false) then
		return;
	endif;

	if not self.doCheckOOWJobs() then
		return;
	endif;
	app.mousePointer := Window.MousePointer_HourGlass;
	theForm := app.getForm(SHP_SelectCranes.name).SHP_SelectCranes;
	if theForm = null then
		create theForm as SHP_SelectCranes;
	endif;
	theForm.myTerminal := self.myTerminal;
	theForm.myCurrentVoyage := self.myCurrentVoyage;
	theForm.workPointJobSheetClassToCreate := CM_VoyageDeckJobSheet; // TFS 3646
	theForm.showModal();
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showUserColourFrame" id="cb380ff3-a9b0-4e97-b453-4f98db83bef0">
        <source>showUserColourFrame();
// ---------------------------------------------------------------------------
// Created:		04 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.frmUserColours.visible := not self.frmUserColours.visible;
	self.frmUserColours.left := 50;
	self.frmUserColours.top := 100;

	self.clrBay.setColor(xmlColourBay);
	self.clrCell.setColor(xmlColourCell);
	self.clrRow.setColor(xmlColourRow);
	self.frmUserColours.zOrder(1);

end;</source>
    </JadeMethod>
    <JadeMethod name="tblCranes_contextMenu" id="a71fc447-0f29-442d-9918-95c3b35b3657">
