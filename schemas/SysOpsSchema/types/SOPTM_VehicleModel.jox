    <JadeMethod name="setupThumbnailDetails" id="ea7a210e-3479-44e1-b7fd-22ce2b58bdea">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.myForm.useProxyObject := true;
	self.myForm.setTblDataEntRows(ETDef_VehicleModel);
	
	self.myForm.shtTblInput1.caption := 'Details';
	self.myForm.initTblInput(self.myForm.tblInput1, ETDef_VehicleModel);	
	self.myForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="0b48a8aa-cd6f-4f07-8730-0794f2c87902">
        <updating/>
        <source>showThumbnail(_vehicleModel : CM_VehicleModel) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.myForm.tblInput1.clearValues;

	self.myForm.tblInput1.setValueByName(ETRow_Model, _vehicleModel.model);

epilog

end;</source>
        <Parameter name="_vehicleModel" type="CM_VehicleModel"/>
    </JadeMethod>
