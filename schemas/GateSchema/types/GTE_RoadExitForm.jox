    <JadeMethod name="showThumbnailData" id="c44bacd0-d421-4266-add6-0d1513ae08e7">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
25 November 2024		jlizm1	MTN 33235 Delete current entry reverting already exported cargo

*/

vars
	job : CM_RoadJob;
begin
	if not global.isValidObject(obj) then
		clearThumbnailData();
		return;
	endif;

	job := obj.CM_RoadJob;

	tblThumb.rows := 0;
	
	self.showThumbnailForDef(ETDef_RoadExitThumb ,job);//obj.CM_Object
	
	if canCancelVisit then
		self.mnuCancelVisit.visible := true;
	else
		self.mnuCancelVisit.visible := false;
	endif;
	
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailForDef" id="9ab5dbba-d3e6-45a0-9cf3-a3f014eeca86">
        <source>showThumbnailForDef(pDefName : String; _obj : CM_Object);
// ---------------------------------------------------------------------------
// Created:     14 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	roadJob	: CM_RoadJob;
	opGroupDict	: CM_OperatorGroupByCodeDict;
	opGroup	: CM_OperatorGroup;
	request	: CM_Request;
	delRequest : CM_DeliveryRequest;
	opGroupStr	: String;
	rows,
	row : Integer;
	commodity : CM_Commodity;
	commodityStr : String;
begin

	inheritMethod(pDefName, _obj);

	roadJob := _obj.CM_RoadJob;

//	CCMS1304 - add Commodity field and Hazardous field to tblthumbnail	
	row := 1;
	rows := self.tblThumb.rows;
	foreach row in row to rows do
		if self.tblThumb.accessCell(row,1).text = "Commodity" then
			commodityStr :=	self.tblThumb.accessCell(row,2).text.trimBlanks;
			commodity := app.myRoot.allCommodities[commodityStr].CM_Commodity;
			if commodity &lt;&gt; null and
			   commodity.requiresPower then 
				self.tblThumb.accessCell(row,2).fontBold := true;	
				self.tblThumb.accessCell(row,2).foreColor := Blue;
			endif;

		endif;
	endforeach;

	create opGroupDict transient;
	//potentially a dynamic number of operator groups for one job - so build it:
	foreach request in roadJob.allRequests do
		if not CM_DeliveryRequest.hasInstance(request) then
			continue;
		endif;
		
		delRequest := request.CM_DeliveryRequest;
		if delRequest.myOperatorGroup = null then
			continue;
		endif;
		
		if not opGroupDict.includes(delRequest.myOperatorGroup) then
			opGroupDict.add(delRequest.myOperatorGroup);
		endif;
	endforeach;
	
	foreach opGroup in opGroupDict do
		opGroupStr := opGroupStr &amp; opGroup.code &amp; '  ';
	endforeach;
	
	self.tblThumb.addItem('Operator Group(s)' &amp; Tab &amp; opGroupStr);
	self.tblThumb.addItem('Job Remarks' &amp; Tab &amp; roadJob.remarks);
	

epilog
	delete opGroupDict;
end;</source>
        <Parameter name="pDefName" type="String"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="514428cd-6502-4d58-b31f-cd1dc985b5f2">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     30 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	tmpRoadJobReceive  : CM_RoadJob;
	tmpRoadJobRelease  : CM_RoadJob;
begin


	if theObject.isKindOf(CM_TrackedItem) then 
	
		tmpRoadJobReceive := theObject.CM_TrackedItem.jobRoadReceive;	
		if tmpRoadJobReceive &lt;&gt; null then 
			self.zTblDataSysNotifyUpdate(eventType, tmpRoadJobReceive , eventTag);
		endif;
		
		tmpRoadJobRelease := theObject.CM_TrackedItem.jobRoadRelease;
		if tmpRoadJobRelease &lt;&gt; null then 
			self.zTblDataSysNotifyUpdate(eventType, tmpRoadJobRelease , eventTag);
		endif;
		
		if tmpRoadJobReceive  =  null and tmpRoadJobRelease = null then 
		// no Road job associtated with ti. Must have been completed so end note
			self.endNotification(theObject, eventType);
		endif;
	
	else 
		if eventType = Object_Update_Event then
			self.zTblDataSysNotifyUpdate(eventType, theObject, eventTag);
		elseif eventType = Object_Create_Event then
			self.zTblDataSysNotifyCreate(eventType, theObject, eventTag);
		elseif eventType = Object_Delete_Event then
			self.zTblDataSysNotifyDelete(eventType, theObject, eventTag);
		endif;
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataDblClick" id="28e95c77-8637-48d6-913e-f597897bb1bf">
        <updating/>
        <source>tblDataDblClick(table: Table input) updating;
//----------------------------------------------------------------
//	Created:	15 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	theRow	: Integer;

begin

	theRow := table.row;
	
	if theRow &lt;= 0 then
		return;
	endif;
	
	if theRow = 1 then
		if self.mode = self.Mode_View
		and app.myPassport.myUser.canDo(self.myTerminal, PmGteSortRoadExit) then
			self.zTblDataResort();
		endif;
	else
	//	self.handleTblDataDblClick(theRow);//cnwrd1 32866
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="a1db8f89-dd5d-45e4-88c9-c5a01551c2b9">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//----------------------------------------------------------------
//	Created:	15 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	job : CM_RoadJob;
begin

	inheritMethod(_idxRow, _obj);


	if _obj.isKindOf(CM_RoadJob) then
		job := _obj.CM_RoadJob;
		if job.status = JOB_PART_COMPLETE then
			tblData.accessRow(_idxRow).backColor := LightYellow;
		elseif job.status = JOB_COMPLETE then
			tblData.accessRow(_idxRow).backColor := self.ColorGreenLight;
		else
			tblData.accessRow(_idxRow).backColor := LightRed;
		endif;
	endif;

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8c126934-7639-493a-9ee0-6d70c37c7065">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 September 2025 10:07:06.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005498, locale);
	btnFindExit.translateCaption(Xlat_0023216, locale);
	btnRetro.translateCaption(Xlat_0026734, locale);
	lblRetroDate.translateCaption(Xlat_0026735, locale);
	lblRetroTime.translateCaption(Xlat_0026736, locale);
	mnuCancelVisit.translateCaption(Xlat_0026060, locale);
	mnuCargoReview.translateCaption(Xlat_0026737, locale);
	mnuChangeInspectionStatus.translateCaption(Xlat_0025429, locale);
	mnuCheckSeals.translateCaption(Xlat_0025931, locale);
	mnuDisAssocBooking.translateCaption(Xlat_0026061, locale);
	mnuMaintainSeals.translateCaption(Xlat_0025932, locale);
	mnuOutCompleted.translateCaption(Xlat_0025430, locale);
	mnuOutFailed.translateCaption(Xlat_0025431, locale);
	mnuOutNA.translateCaption(Xlat_0025432, locale);
	mnuOutPending.translateCaption(Xlat_0025433, locale);
	mnuSendInspectionOut.translateCaption(Xlat_0025434, locale);
	mnuSendReport.translateCaption(Xlat_0027107, locale);
end;</source>
    </JadeMethod>
</GUIClass>
