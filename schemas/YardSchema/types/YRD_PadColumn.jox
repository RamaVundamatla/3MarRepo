<Class name="YRD_PadColumn" id="cdc6acd4-5fc2-41af-a3e7-eb2b45f4eb78">
    <superclass name="CMUI_GridColumn"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="Yard"/>
    <PrimAttribute name="maxWidth" id="be5704ae-f089-463c-9cd1-8cdbe1c53d38">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="drawSelf" id="9b1a5f2c-ae53-4a05-89d1-1a7453a870d7">
        <updating/>
        <source>drawSelf(pFrame: CMUI_Frame) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	TopTextMargin	: Integer = 10;
vars

	xPoint 		: Integer;
	textWidth 	: Integer;
	offset 		: Integer;
	pointWidth 	: Integer;
	caption 		: String;
begin

	if self.label[1:1] &lt;&gt; "_" then
		caption := self.label;
	endif;
	
	pointWidth := (x2 - x1).Integer;
	textWidth := pFrame.getTextExtent(self.label.trimBlanks);
	xPoint := (x1 + ((pointWidth - textWidth) / 2)).Integer;
	pFrame.drawTextAt(caption.trimBlanks, xPoint, TopTextMargin, Black);

end;</source>
        <Parameter name="pFrame" type="CMUI_Frame"/>
    </JadeMethod>
    <JadeMethod name="handleMouseDownEvent" id="5e7c55f7-77d9-44e9-a286-6f1589e9e6a5">
        <updating/>
        <source>handleMouseDownEvent(button: Integer; shift: Integer; x: Real; y: Real) updating;

begin

//	self.myGridArea.myGridAreaFrame.form.SOP_TerminalAreaDefForm.showGridFrameContextMenu(x.Integer, y.Integer, true);
	
end;</source>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="maxWidth" id="1afb7cc4-2928-4741-9b2b-50537b42010a">
        <methodInvocation>mapping</methodInvocation>
        <source>maxWidth(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpGridPoint	: CMUI_GridPoint;
	
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	foreach tmpGridPoint in self.allGridPointsByRow do
		_value := _value.max(tmpGridPoint.YRD_PadPoint.width.Integer);
	endforeach;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d5436301-74f9-44ac-8fd1-aa10e8aedc86">
        <updating/>
        <source>setForCreate(_label : String; _column : Integer; _yrdPadArea : YRD_PadArea; _gridCol : CM_GridColumn) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin


	self.label := _label;
	self.column := _column;
	self.myGridCol := _gridCol;
	self.myGridArea	:= _yrdPadArea;

end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_yrdPadArea" type="YRD_PadArea"/>
        <Parameter name="_gridCol" type="CM_GridColumn"/>
    </JadeMethod>
