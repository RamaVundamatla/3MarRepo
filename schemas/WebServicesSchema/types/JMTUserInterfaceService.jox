    <JadeWebServicesMethod name="getVoyageOrTowedVoyage" id="d632353c-23f8-4f39-ade2-baa2809a38d1">
        <source>getVoyageOrTowedVoyage( _voyageOid : String ):WS_VoyagesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2018	jlgndl1	Initial creation	TFS 41410

*/

vars
	response : WS_VoyagesResponse;
	voyage : CM_Voyage;
	terminal : CM_Terminal;
	iter : Iterator;
	tugVoyage : CM_Voyage;
	proxyVoyage : WS_Voyage;
	completedOK : Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	if _voyageOid &lt;&gt; null then
		voyage := app.myPassport.getObjectOfTypeFromOid(_voyageOid,CM_Voyage).CM_Voyage;
	endif;
	
	if voyage &lt;&gt; null then
		terminal := voyage.getMyTerminal();
		iter := terminal.allVoyagesByArrivalDTCode.createIterator;
		terminal.allVoyagesByArrivalDTCode.startKeyGeq( voyage.arrivedDT, null, iter );
		
		while iter.next( tugVoyage ) do
		
			if tugVoyage.arrivedDT &gt; voyage.departedDT then
				//Gone past our window of opportunity
				break;
			endif;
			if tugVoyage = voyage then
				//can't tow ourselves
				continue;
			endif;
			if not tugVoyage.isTug then
				continue;
			endif;
			if tugVoyage.myOperator &lt;&gt; voyage.myOperator then
				continue;
			endif;
			
		
			create proxyVoyage transient;
			proxyVoyage.setProxyFromObject(tugVoyage);
			response.allVoyages.add( proxyVoyage );

		endwhile;
		
	endif;
	
	completedOK:=true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	delete iter;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	cnEndTransaction;
end;</source>
        <Parameter name="_voyageOid" type="String"/>
        <ReturnType type="WS_VoyagesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyagePlanningCodes" id="27807f22-a606-4e4b-97a3-912fc673a8ab">
        <source>getVoyagePlanningCodes() : WS_CodeResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	response : WS_CodeResponse;
	term : CM_Terminal;
	completedOK : Boolean;
	planningCode : CM_VoyagePlanningCode;
	iter : Iterator;
	wsCode : WS_Code;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	term := app.myPassport.myTerminal;
	if term = null then
		completedOK := true;
		return response;
	endif;
	
	iter := term.allVoyagePlanningCodes.createIterator;
	while iter.next(planningCode) do
		create wsCode transient;
		wsCode.setProxyDetails(planningCode, planningCode.code, planningCode.description);
		response.allCodes.add(wsCode);
	endwhile;
	
	completedOK := true;
	return response;
	
epilog
	delete iter;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_CodeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyagePlanningVersion" id="5737d6b9-655c-4e49-a6bb-4e03d15ae62c">
        <source>getVoyagePlanningVersion(_voyageRequest : WS_VoyageRequest) :  WS_VoyageResponse webService;
/*
Purpose:	

Date		Who		Reason
28 April 2014	cnwer1	Initial creation PAR

*/

vars
	response 	: WS_VoyageResponse;
	wsVoyage 	: WS_Voyage;
	user			: CM_User;
	terminal	: CM_Terminal;
	voyage 		: CM_Voyage;
	completedOK : Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	// Populate list of Terminals
	user := app.getMyUser();
	terminal := app.myPassport.myTerminal;
	
	voyage:=terminal.lookupVoyage(_voyageRequest.voyageCode,_voyageRequest.arrivalDT.asTimeStampFromWebInterface,false);		//cnwmc5 - 13 Jan 2016 - PAR 37326
	
	if voyage = null then
		app.raiseCMException1(Voyage_not_found,_voyageRequest.voyageCode,null,null);
		completedOK := true;		// PAR #29758
		return response;
	endif;
	
	
	create wsVoyage transient;
	response.myVoyage:=wsVoyage;
	wsVoyage.setProxyFromObject(voyage);
	
	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	cnEndTransaction;
end;</source>
        <Parameter name="_voyageRequest" type="WS_VoyageRequest"/>
        <ReturnType type="WS_VoyageResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyageProcessDepot" id="fc5165c0-7ed7-4a8c-be91-d4b439cc7b43">
        <source>getVoyageProcessDepot() : WS_DepotVoyageResponse  webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Feb 2019	cnwma1	ChangeRequest 43244: PEL1 - Container Services - Segregation in WP for Depot and Terminal

*/

vars
	response		: WS_DepotVoyageResponse;
	completedOK		: Boolean;
	terminal        : CM_Terminal;
	processTerminal : CM_ProcessTerminal;
	voyageProcess   : CM_VoyageProcess;
begin
	/*
	Need to arm generic exception handlers locally to deal with all unexpected
	application exceptions and lock exceptions, because the standard global exception handlers
	are overridden to deal with XML parsing issues
	*/
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passDelayType for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;	
	
	terminal := app.myPassport.myTerminal;
	if terminal &lt;&gt; null then
	
		voyageProcess := terminal.getDefaultVoyageProcess();
		if voyageProcess &lt;&gt; null then
			processTerminal := voyageProcess.allProcessTerminals.getAtKey( voyageProcess, terminal );
			if processTerminal &lt;&gt; null then
				if processTerminal.myDepotVoyage &lt;&gt; null then
					response.depotVoyageCode := processTerminal.myDepotVoyage.code;
					response.depotVoyageOID  := processTerminal.myDepotVoyage.getOidString;
				endif;
			endif;
		endif;
	endif;

	
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_DepotVoyageResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyageProcessReports" id="802170ff-1718-48a6-820c-1d8c272dc55f">
        <source>getVoyageProcessReports(request : WS_VoyageProcessReportRequest) :WS_VoyageProcessReportResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Sep 2019	cnwma1	ChangeRequest 46507: PEL1 - Error : Timeout reached when running reports
*/

vars
	response	: WS_VoyageProcessReportResponse;
	completedOK : Boolean;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;

	response :=  request.getReportsToRun();
	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_VoyageProcessReportRequest"/>
        <ReturnType type="WS_VoyageProcessReportResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyageSlotsForJobLander" id="5c922da3-4372-4a95-8be0-092611f64d44">
        <source>getVoyageSlotsForJobLander(request : WS_VoyageSlotsRequest input) : WS_VoyageSlotsResponse webService;
/*

Date		Who		Reason
26/04/2017	cnwsc8	Initial creation
08/11/2018	jlgdap1	TFS 41300 PEL1 Unable to load to vessel from truck in Job Lander
27/03/2020	jlgdap1	TFS 48969 PEN - Web App Hand Held Problem
15/10/2021	navdap1	TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
08/12/2021	navdap1	TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
*/

vars
	response 	: WS_VoyageSlotsResponse;
	completedOK : Boolean;
	cargo 		: CM_TrackedItem;
	failedDAC	: CM_DataAccessController;
	wle 		: CM_WorkListEntry;
	slotArray 	: CM_LCArray;
	slot 		: CM_LocationsController;
	job  		: CM_VoyageJob;
	wsLC 		: WS_LocationsController;
	prenote 	: CM_TrackedItem;				// TFS 41300
	voyage 		: CM_Voyage;				// TFS 48969
	bulkRelease	: CM_BulkRelease;			// TFS 48969
	iterJob		: Iterator;					// TFS 48969
	voyJob		: CM_VoyageJob;				// TFS 48969
	voyWle		: CM_WorkListEntry;			// TFS 48969
	lc			: CM_LocationsController;	// TFS 48969
	ddChildWle 	: CM_WorkListEntry;				// TFS 51935
	directLoad	: Boolean;						// TFS 51935
begin

// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	//epr TFS 5535 4/8/17 
	cargo:=app.myPassport.getObjectOfTypeFromOid( request.cargoOid,CM_TrackedItem).CM_TrackedItem;	
	if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);//88972
		completedOK := true;
		return response;
	endif;
	
	wle := cargo.getVoyageWLEUnactioned(request.isDischarge = false);
	
	// TFS 41300 if no voyage wle found, see if we're split cargo from a prenote 				// TFS 41300
	if wle = null then																			// TFS 41300
		prenote := cargo.myTerminal.allNotifiedTIsByIdCargoType[cargo.id, cargo.cargoType];		// TFS 41300
		if prenote &lt;&gt; null then																	// TFS 41300
			wle := prenote.getVoyageWLEUnactioned(request.isDischarge = false);					// TFS 41300
		endif;																					// TFS 41300
	endif;																						// TFS 41300
	
	// TFS 48969 start - mimic the behaviour in the old handhelds is we're loading an empty container and UseRelReqAnyVoyLoad config is set
	if wle = null and cargo.myTerminal.getConfig(UseRelReqAnyVoyLoad).Boolean then
		if cargo.isContainer and cargo.CM_Container.isEmpty then
			bulkRelease := cargo.allBulkReleasesAssigned.first;
			if bulkRelease &lt;&gt; null and bulkRelease.isShipType then
				voyage := bulkRelease.myVoyage;
				if voyage &lt;&gt; null and voyage = cargo.myVoyage then
					//OK we got a voyage release request - rip thru the jobs
					iterJob := voyage.allVoyageJobs.createIterator;
					while iterJob.next( voyJob ) do
						if not voyJob.isVoyageJob and not voyJob.isVoyageROROJob then
							//Must be a LOLO load job or a RORO load job
							continue;
						endif;
						if voyJob.isDischargeOrSOB then
							//Only want load jobs
							continue;
						endif;
						if voyJob.status = JOB_COMPLETE then
							continue;
						endif;
						voyWle := voyJob.getNextFreeVoyageWLE;
						if voyWle &lt;&gt; null then
							if not voyWle.isTiAssignedToResDet( cargo ) then
								continue;
							endif;
							//Finally everything matches, use this one
							wle := voyWle;
							break;
						endif;
					endwhile;
					delete iterJob;
				endif;
			endif;
		endif;
	endif;
	// TFS 48969 end
	
	//directLoad := cargo.myTerminal.getConfig(DirectTruck2VesselMult).Boolean; 		// TFS 51935	// TFS 52293
	directLoad := wle &lt;&gt; null and wle.job &lt;&gt; null and wle.job.isDirectDeliveryJob; 		// TFS 51935	// TFS 52293
	if wle &lt;&gt; null then
		if cargo.myTerminal.getConfig(UseRelReqAnyVoyLoad).Boolean then		// TFS 48969
			lc := wle.getNextBulkReleaseLocation();							// TFS 48969
			if lc &lt;&gt; null then												// TFS 48969
				app.writeLog(method.qualifiedName &amp; Tab &amp; "lc is " &amp; lc.getFullId, LogDEBUG);
				create wsLC transient;										// TFS 48969
				wsLC.setProxyFromObject(lc.CM_LocationsController);			// TFS 48969
				response.allLocnControllers.add(wsLC);						// TFS 48969
			endif;															// TFS 48969
		endif;																// TFS 48969
		job := wle.job.CM_VoyageJob;
		if job &lt;&gt; null and job.allowOutOfOrderLoading then
			create slotArray transient;
			job.getEmptySlotLocIDInSequence(slotArray);
			foreach slot in slotArray do
				// ### TFS 52866 18May2022 NAVPW1 - Stops a duplicate location controller being added
				if lc &lt;&gt; null then
					if lc.getFullId = slot.CM_LocationsController.getFullId then
						continue;
					endif;
				endif;
				// ### TFS 52866 18May2022 NAVPW1 - Stops a duplicate location controller being added
				
				create wsLC transient;
				wsLC.setProxyFromObject(slot.CM_LocationsController);
				response.allLocnControllers.add(wsLC);
			endforeach;
		endif;
		// TFS 41300 special handling for a voyage hold job										// TFS 41300
		//if job &lt;&gt; null and job.isVoyageHoldJob then											// TFS 41300	// TFS 51935
		if job &lt;&gt; null and job.isVoyageHoldJob and not directLoad then							// TFS 41300	// TFS 51935
			create wsLC transient;																// TFS 41300
			wsLC.setProxyFromObject(wle.getTargetLocation);										// TFS 41300
			response.allLocnControllers.add(wsLC);												// TFS 41300
		endif;																					// TFS 41300
		
		// TFS 51935 special handling for voyage hold jobs with direct loading. 
		if directLoad then
			// The WLE we found earlier will be a child (voyage) WLE of a yard WLE
			// All the children of the Yard WLE are WLEs that we want
			if wle.myDirectDeliveryParentWLE &lt;&gt; null then
				foreach ddChildWle in wle.myDirectDeliveryParentWLE.allDirectDeliveryChildWLEs do
					if ddChildWle.isKindOf(CM_VoyageWLE) and not ddChildWle.isCompleteForJob() then
						create wsLC transient;
						wsLC.setProxyFromObject(ddChildWle.getTargetLocation);
						response.allLocnControllers.add(wsLC);
					endif;
				endforeach;
			endif;
		endif;
		// TFS 51935 end	
	endif;
	
	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	cnEndTransaction;
	delete slotArray;
end;</source>
        <Parameter name="request" type="WS_VoyageSlotsRequest" usage="input"/>
        <ReturnType type="WS_VoyageSlotsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyageWLEsForCargoItem" id="7af871fd-4980-4b03-89ab-38c1a1873637">
        <source>getVoyageWLEsForCargoItem(request : WS_VoyageWLEQueryRequest input) : WS_VoyageWLEResponse webService;
/*

Date		Who		Reason
28 November 2016	cnwer1	Initial creation TFS 2732
28 Jan 2020	jlgka1	TFS 45987 - JMT - Lander Apps WLE Picker
*/

vars
	response : WS_VoyageWLEResponse;
	completedOK : Boolean;
	cargo : CM_TrackedItem;
	failedDAC		: CM_DataAccessController;
	wle : CM_WorkListEntry;
	voyage : CM_Voyage;
	allWLEs : CM_WLEArray;
	wsVoyageWLE : WS_VoyageWLE;
begin

// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	//epr TFS 5535 4/8/17 
	cargo:= app.myPassport.getObjectOfTypeFromOid(request.cargoOid,CM_Cargo).CM_Cargo;	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	if cargo = null  then
		app.raiseCMException(Input_required_field_cargoItem,null,null);//88972
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17 	
	voyage :=app.myPassport.getObjectOfTypeFromOid( request.voyageOid,CM_Voyage).CM_Voyage;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	if voyage = null then
		app.raiseCMException1(Voyage_not_found,request.voyageOid,null,null);
		completedOK := true;		// PAR #29758
		return response;
	endif;
	
		
	create allWLEs transient;
	cargo.getVoyageWLEforLanderLoad(wle, null,voyage,allWLEs, null);
	
	foreach wle in allWLEs discreteLock do
		
		if request.checkRequiresJob then
			if request.isDischarge then
				if wle.getSourceLocation.isKindOf(CM_VoyageWLE) and  wle.getSourceLocation.requiresJob &lt;&gt; request.requiresJob then
					continue;
				endif;				
			else
				if wle.getTargetLocation = null then
					continue;
				endif;
				if  wle.getTargetLocation.requiresJob &lt;&gt; request.requiresJob then
					continue;
				endif;
			endif;
		endif;
		
		create wsVoyageWLE transient;
		wsVoyageWLE.setProxyFromObject(wle.CM_VoyageWLE);
		response.allVoyageWLEs.add(wsVoyageWLE);
	endforeach;
	
	
	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	cnEndTransaction;
	delete allWLEs;

end;</source>
        <Parameter name="request" type="WS_VoyageWLEQueryRequest" usage="input"/>
        <ReturnType type="WS_VoyageWLEResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyageWorkOrderTypes" id="34096d76-45d9-47f0-8f45-e5aeba9dc958">
        <source>getVoyageWorkOrderTypes(_voyage : String): WS_CodeResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 June 2018	jlger1	Initial creation 38561
25 July 2018	jlger1	Initial creation 38561 - show work orders types depending on the voyage if the voyage has departed then
												the voyage can only show cancelled or extension
15 Oct 2018		jlger1	TFS 41310 	- shift and extension now require a complete permit request before users can add them
04 Feb 2019		jlgdap1	TFS 43195 PEL1 Work Order Shift option being displayed before a permit is created
*/
vars
	response		: WS_CodeResponse;
	completedOK		: Boolean;
	proxyWorkOrderType : WS_Code;
	voyage 			: CM_Voyage;
	hasDeparted  : Boolean;
	cargoRequest : CM_WodVoyageCargoRequest;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passDelayType for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	if _voyage &lt;&gt; null then
		voyage:=app.myPassport.getObjectOfTypeFromOid(_voyage,CM_Voyage).CM_Voyage;
	endif;
	
	if voyage &lt;&gt; null and voyage.departedDT &lt;&gt; null then
		hasDeparted:= voyage.departedDT &lt;= app.actualTimeAppServer;
	endif;
	
	// Create the response
	create response transient;		
	
	if voyage = null then
		create proxyWorkOrderType transient;
		proxyWorkOrderType.setProxyDetails(null,WO_TASK_SHIFTMOVEMENT.String,app.getErrorString(Shift_movement));
		response.allCodes.add(proxyWorkOrderType);
		
		create proxyWorkOrderType transient;
		proxyWorkOrderType.setProxyDetails(null,WO_TASK_PERMIT.String,app.getErrorString(Permit_request) );
		response.allCodes.add(proxyWorkOrderType);
		
		create proxyWorkOrderType transient;
		proxyWorkOrderType.setProxyDetails(null,WO_TASK_CARGOINITIAL.String,app.getErrorString(VOYWO_Cargo_request));
		response.allCodes.add(proxyWorkOrderType);
		
		create proxyWorkOrderType transient;
		proxyWorkOrderType.setProxyDetails(null,WO_TASK_MARINEINITIAL.String,app.getErrorString(Voyage_initial_marine_service));
		response.allCodes.add(proxyWorkOrderType);
		
		create proxyWorkOrderType transient;
		proxyWorkOrderType.setProxyDetails(null,WO_TASK_MARINEDEPART.String,app.getErrorString(Voyage_departu_marine_service));
		response.allCodes.add(proxyWorkOrderType);
		
		create proxyWorkOrderType transient;
		proxyWorkOrderType.setProxyDetails(null,WO_TASK_TIMECHANGE.String,app.getErrorString(VOYWO_Time_change));
		response.allCodes.add(proxyWorkOrderType);
		
		create proxyWorkOrderType transient;
		proxyWorkOrderType.setProxyDetails(null,WO_TASK_WATER.String,app.getErrorString(VOYWO_Water_request));
		response.allCodes.add(proxyWorkOrderType);
		
		create proxyWorkOrderType transient;
		proxyWorkOrderType.setProxyDetails(null,WO_TASK_EXTENSION.String,app.getErrorString(VOYWO_Extension));
		response.allCodes.add(proxyWorkOrderType);
		
		create proxyWorkOrderType transient;
		proxyWorkOrderType.setProxyDetails(null,WO_TASK_HMSCANCEL.String,app.getErrorString(VOYWO_Cancel_request));
		response.allCodes.add(proxyWorkOrderType);
		
	else
		if not hasDeparted then
			
			//harbour:= voyage.myTerminal.myHarbour;									// TFS 43195
			//if harbour &lt;&gt; null then													// TFS 43195
			//	foreach berth in harbour.allBerths discreteLock do						// TFS 43195
			//		if berth.isLogicalBerth or not berth.requiresLengthOfTime then		// TFS 43195
			//			needCargoRequestOrPermit:=false;								// TFS 43195
			//			break;															// TFS 43195
			//		endif;																// TFS 43195
			//	endforeach;																// TFS 43195
			//endif;																	// TFS 43195
			//epr TFS 42159 26/11/18 
			cargoRequest:=voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL).CM_WodVoyageCargoRequest;
			// if they have a cargo request they can add with out a permit if they choose the same berth as the cargo request
			//only if it has the manual ETMAL
			//if not needCargoRequestOrPermit or cargoRequest &lt;&gt; null or  voyage.allWorkOrders.getWODPermitForDetailType(WO_TASK_VOY_SHIFTMOVEMENT,WO_STATUS_COMPLETE) &lt;&gt; null  then	// TFS 43195
			if cargoRequest &lt;&gt; null or voyage.allWorkOrders.getWODPermitForDetailType(WO_TASK_SHIFTMOVEMENT, WO_STATUS_COMPLETE) &lt;&gt; null  then										// TFS 43195
				
				create proxyWorkOrderType transient;
				proxyWorkOrderType.setProxyDetails(null,WO_TASK_SHIFTMOVEMENT.String,app.getErrorString(Shift_movement));
				response.allCodes.add(proxyWorkOrderType);
			endif;
			
			create proxyWorkOrderType transient;
			proxyWorkOrderType.setProxyDetails(null,WO_TASK_TIMECHANGE.String,app.getErrorString(VOYWO_Time_change));
			response.allCodes.add(proxyWorkOrderType);
			
			create proxyWorkOrderType transient;
			proxyWorkOrderType.setProxyDetails(null,WO_TASK_WATER.String,app.getErrorString(VOYWO_Water_request));
			response.allCodes.add(proxyWorkOrderType);
			
		endif;
		
		//only if it has the manual ETMAL
		if voyage.allWorkOrders.getWODPermitForDetailType(WO_TASK_EXTENSION,WO_STATUS_COMPLETE) &lt;&gt; null then
			create proxyWorkOrderType transient;
			proxyWorkOrderType.setProxyDetails(null,WO_TASK_EXTENSION.String,app.getErrorString(VOYWO_Extension));
			response.allCodes.add(proxyWorkOrderType);
		endif;
		
		create proxyWorkOrderType transient;
		proxyWorkOrderType.setProxyDetails(null,WO_TASK_HMSCANCEL.String,app.getErrorString(VOYWO_Cancel_request));
		response.allCodes.add(proxyWorkOrderType);
		
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_voyage" type="String"/>
        <ReturnType type="WS_CodeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyageWorkOrders" id="9e7c9c7f-5627-4b4e-aee2-d680a06cfa08">
        <source>getVoyageWorkOrders(_request : WS_GetVoyageWorkOrdersRequest) : WS_WorkOrdersResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2018	jlger1	Initial creation 38561 Voyage Work Orders
19 July 2018	jlger1	tfs 39810 can only change or cancel the selected voyages work orders
24 Sep 2018		jlgdap1	TFS 40543 PEL1 WP Time Change does not display all relevant work orders for the Voyage
*/

vars
	response		: WS_WorkOrdersResponse;
	completedOK		: Boolean;
	proxyWorkOrder : WS_WorkOrder;
	wo , voyageWO : CM_WorkOrder;
	voyage : CM_Voyage;
	currentWO : CM_WorkOrderDtl;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passDelayType for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;		
	
	app.checkCurrentUserHasAccess(PmWebWorkOrdersVoyView);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	voyage:=app.myPassport.getObjectOfTypeFromOid(_request.voyageOid,CM_Voyage).CM_Voyage;
	if voyage = null then
		completedOK := true;
		return response;
	endif;
	
	
	
	if _request.workOrderOid &lt;&gt; null then
		currentWO:=app.myPassport.getObjectOfTypeFromOid(_request.workOrderOid,CM_WorkOrderDtl).CM_WorkOrderDtl;
	endif;
	
	foreach wo in voyage.allWorkOrders  reversed , discreteLock  do
		//epr TFS 15/10/18 
		if wo.isKindOf(CM_WorkOrderVoyage) then
			if wo.allWoDtls.first = null then
				continue;
			endif;
			
			//don't show permits 
			if wo.allWoDtls.first.isKindOf(CM_WodPermitRequest) then
				continue;
			endif;
			
		endif;
		
	
		
		if currentWO &lt;&gt; null then
			if wo = currentWO.myParent then
				continue;
			endif;
			
		endif;
		if wo.taskStatus = WO_STATUS_CANCELLED then
			continue;
		endif;
		// TFS 40543 A COMPLETE "Cancel" work order shouldn't stop us looking for	// TFS 40543
		// other work orders that may be able to be cancelled / time changed		// TFS 40543
		if wo.isWorkOrderForCancel and wo.taskStatus = WO_STATUS_COMPLETE then		// TFS 40543
			continue;																// TFS 40543
		endif;																		// TFS 40543
		//epr tfs 40297 16/8/17
		if not wo.canCancel then
			break;
		endif;
		
		create proxyWorkOrder transient;
		proxyWorkOrder.setProxyFromObject(wo);
		response.allWorkOrders.add(proxyWorkOrder);
		break;
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_request" type="WS_GetVoyageWorkOrdersRequest"/>
        <ReturnType type="WS_WorkOrdersResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyages" id="acbb1208-0489-4014-9321-98b0f60ecfd2">
        <source>getVoyages(voyagesRequest : WS_VoyagesRequest) : WS_VoyagesResponse webService;

/*

Purpose:			Get the current Voyages the current user has access to.

Parameters:			

Return Value:		


Date		Who		Reason
22 Sep 2011	cnwer1	Initial creation CCMS MES 1026
11 Jul 2012 cnwer1	PAR 29962 - Work with LOLO now returning cranes aswell as workpoints
15 Feb 2016	cnwkpd1	PAR #35261 - Changes required for JADE 7.1 

*/

vars
	response		: WS_VoyagesResponse;
	completedOK		: Boolean;
	proxyVoyage		: WS_Voyage;
	iter			: Iterator;
	voy				: CM_Voyage;
	thePassport		: CM_Passport;
	failedDAC		: CM_DataAccessController;
	gracePeriod		: Integer;
	checkDT			: TimeStamp;
	includeNullVoyage,
	onlyRORO,
	onlyCellular,
 	includeBitmap,
	includeWorkPoints : Boolean;
	jobSheet : CM_VoyageJobSheet;
	workPointObject : CM_Object;
	workPointProxy : WS_WorkPoint;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	
	if voyagesRequest &lt;&gt; null then
		includeNullVoyage:=voyagesRequest.includeNullVoyage;
		onlyRORO	:=voyagesRequest.onlyROROVoyages;
		onlyCellular:=voyagesRequest.onlyCellularVoyges;
		includeBitmap:=voyagesRequest.includeBitmap;
		includeWorkPoints :=voyagesRequest.includeWorkPoints;
	endif;
	// Create the response
	create response transient;
	
	thePassport := app.myPassport;
			
	gracePeriod := thePassport.myTerminal.getConfig(VoyDepartedGracePeriod).Integer;
	if gracePeriod = null then
		gracePeriod := 24;
	endif;

	// get date to check against - now less the grace period
	checkDT := app.actualTimeServer();
	checkDT := checkDT.changeByXXHours(-gracePeriod);	
	
	iter := thePassport.myTerminal.allVoyagesByCode.createIterator();
	
	while iter.next(voy) do
		if voy.displayOption = VoyageDisplayNever then
			continue;
		endif;

		//epr  TFS 37314 1/3/17
		  //jlier1 TFS51963 5/10/21
		if voy.isCancelled or voy.status = Voyage_Status_Closed then 
			continue;
		endif;
		
		if voy.archived or voy.myTerminalArchived &lt;&gt; null then
			continue;
		endif;

		if not includeNullVoyage and
			voy.isNullVoyage then
			continue;
		endif;
		
		if onlyRORO then
			if not onlyCellular and  voy.myROROStructure = null then
				continue;
			endif;
		endif;
		
		
		if onlyCellular and voy.myCellularVoyageStructure = null then
				continue;
		endif;
		
		if (not voy.canUserAccessSelf(null, failedDAC, thePassport)) then
			continue;
		endif;
					
		//par 30078 25/7/12 do not appy Voyage Departed Grace Period to arrival time
		if not voy.arrivedDT.isValid then
			continue;
		endif;
		
		if  voy.arrivedDT &gt; app.actualTimeServer() then
			continue;
		endif;
			
		//epr TFS 2732 18/10/16
		if (not voy.isActiveDisplay(checkDT)) then			
			continue;
		endif;
				
		create proxyVoyage transient;
		proxyVoyage.setProxyFromObject(voy);
		if includeBitmap then
			proxyVoyage.voyageBitmap:=voy.bitmap;
		endif;
		
		if includeWorkPoints then
			foreach jobSheet in voy.allJobSheets do
				//epr par 29962 4/7/12
				workPointObject:=jobSheet.getMyWorkPointObject();
				if workPointObject = null then
					continue;
				endif;
				create workPointProxy transient;
				workPointProxy.setProxyFromObject(workPointObject);
				proxyVoyage.allWorkPoints.add(workPointProxy);
			endforeach;
		endif;
		
		
		response.allVoyages.add(proxyVoyage);

	endwhile;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up local transients
	delete iter;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <text>Get the current Voyages the current user has access to.</text>
        <Parameter name="voyagesRequest" type="WS_VoyagesRequest"/>
        <ReturnType type="WS_VoyagesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVoyagesForWorkOrderType" id="8e4e778a-f8b1-45df-8713-7d6cc78b0fb5">
        <source>getVoyagesForWorkOrderType(_workOrderType : Integer) : WS_VoyagesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 June 2018	jlger1	Initial creation 38561 Voyage Work Orders

*/
vars 
	response		: WS_VoyagesResponse;
	completedOK		: Boolean;
	proxyVoyage		: WS_Voyage;
	selectedVoyages	: CM_VoyageSet;
	voy				: CM_Voyage;		
	thePassport		: CM_Passport;	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create selectedVoyages transient;
	
	thePassport := app.myPassport;
	
	//epr TFS 41267 4/10/18 noticed when testing cancelling time change the voyage list here was different
	thePassport.myTerminal.getVoyageForVesselSchedule(selectedVoyages); // PAR 35795
	app.writeLog(method.qualifiedName &amp; Tab &amp; "selectedVoyages has " &amp; selectedVoyages.size.String &amp; " voyages", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	foreach voy in selectedVoyages discreteLock do // PAR 35795
		if not voy.isValidStatusForWorkOrder then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "voyage " &amp; voy.code &amp; " voy.isValidStatusForWorkOrder = false", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			continue;
		endif;
		
		if voy.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEINITIAL) = null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "voyage " &amp; voy.code &amp; " no WS_TASK_VOY_MARINEINITIAL work order", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			continue;
		endif;
		
		
	/*	if _workOrderType = WO_TASK_VOY_SHIFTMOVEMENT or 
			_workOrderType = WO_TASK_VOY_WATERREQUEST or
			_workOrderType = WO_TASK_VOY_TIMECHANGE then 
			if voy.myHMSVoyageData = null then
				continue;
			endif;
			
			if voy.myHMSVoyageData.allVoyageMovements.isEmpty then
				continue;
			endif;
			
			if _workOrderType = WO_TASK_VOY_TIMECHANGE then
				if not voy.myHMSVoyageData.hasHMSResourcesUsed then
					continue;
				endif;
			endif;
			
		elseif _workOrderType = WO_TASK_VOY_CARGOREQUEST then
			
			if voy.myGeneralCargoVoyage = null then
				continue;
			endif;
			
			if voy.myGeneralCargoVoyage.allLocationsByOrdinal.size = 0 then
				continue;
			endif;
		endif;
		*/
	
 		create proxyVoyage transient; // PAR 35795
		proxyVoyage.setProxyFromObject(voy); // PAR 35795
		response.allVoyages.add(proxyVoyage); // PAR 35795
	endforeach; // PAR 35795
	
		
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up local transients
	delete selectedVoyages;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_workOrderType" type="Integer"/>
        <ReturnType type="WS_VoyagesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getWagonCargo" id="efd6ce5d-6362-490c-92b1-3c5c06b31a95">
        <source>getWagonCargo(request : WS_WagonCargoRequest) :WS_WagonCargoResponse webService;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 Feb 2017	cnwsc8	TFS 2314 - Development of new MTM Web Service application 
17 Feb 2020 cnwma1	Bug 48595: JMT - Rail Lander Web app - missing Discharge button                   

*/

vars
	completedOK		: Boolean;
	response		: WS_WagonCargoResponse;
	wagonProxy	    : WS_Wagon;
	trackedItemProxy: WS_TrackedItem;
	wagon			: CM_Wagon;
	allTis 			: CM_TIArray;
	terminal		: CM_Terminal;
	ti 				: CM_TrackedItem;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	if request.wagonUid = "" then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	//epr TFS 5535 4/8/17
	wagon := app.myPassport.getObjectOfTypeFromOid(request.wagonUid,CM_Wagon).CM_Wagon;
	if wagon = null then
		completedOK := true;
		return response;
	endif;
	
	if wagon.getTerminal() &lt;&gt; terminal then
		completedOK := true;
		return response;
	endif;
	
	//if wagon.isFlatcar or wagon.isWellcarVisit  then            17.02.2020 cnwma1 #48595
		create allTis transient;
		wagon.getAllTrackedItems(request.inward, allTis, false);
	
		foreach ti in allTis do
			if ti.myPrimaryActualLocation = null or not ti.myPrimaryActualLocation.isWagon then
				continue;
			endif;
			
			create trackedItemProxy transient;
			trackedItemProxy.setProxyFromObject(ti);
			trackedItemProxy.setOidDetails(ti);
			response.allTrackedItems.add(trackedItemProxy);			
			
		endforeach;
	//endif;
	
	create wagonProxy transient;
	wagonProxy.setProxyFromObject(wagon);
	wagonProxy.setOidDetails(wagon);
	response.wagon := wagonProxy;

	// Got to here, everything is ok
	completedOK := true;
	return response;
epilog
	delete allTis;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_WagonCargoRequest"/>
        <ReturnType type="WS_WagonCargoResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getWagons" id="81d73e48-dcc0-44e2-bfc6-7a81febfab3b">
        <source>getWagons(request : WS_WagonsRequest) :WS_WagonsResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 Jan 2017	#cnwsc8	TFS 2532 - Development of new MTM Web Service application 
                   

*/

vars
	response		: WS_WagonsResponse;
	completedOK		: Boolean;
	train			: CM_Train;
	wagon			: CM_Wagon;
	wagons			: CM_WagonSet;
	wagonProxy	    : WS_Wagon;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	//epr TFS 5535 4/8/17 
	train := app.myPassport.getObjectOfTypeFromOid(request.trainUid,CM_Train).CM_Train;

	if train &lt;&gt; null then
		wagons := train.getWagons(request.discharge, request.load);
		foreach wagon in wagons do
			create wagonProxy transient;
			wagonProxy.setProxyFromObject(wagon);
			response.allWagons.add(wagonProxy);
		endforeach;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
epilog
	if wagons &lt;&gt; null then
		delete wagons;
	endif;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_WagonsRequest"/>
        <ReturnType type="WS_WagonsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getWagonsForReports" id="b87c3448-ece2-44c6-af54-a05a83c87ebf">
        <source>getWagonsForReports(_trainId : String) : WS_WagonsResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	response : WS_WagonsResponse;
	completedOK : Boolean;
	train, trn : CM_Train;
	wagon : CM_Wagon;
	wagons : CM_WagonSet;
	wagonProxy : WS_Wagon;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	//epr TFS 5535 4/8/17 
	train := app.myPassport.getObjectOfTypeFromOid(_trainId, CM_Train).CM_Train;
	if train = null then
		foreach trn in app.myPassport.myTerminal.allTrainsOnTerminal discreteLock do
			if trn.code = _trainId then
				train := trn;
				break;
			endif;
		endforeach;
	endif;

	if train &lt;&gt; null then
		wagons := train.getWagons(true, true);
		foreach wagon in wagons do
			create wagonProxy transient;
			wagonProxy.setProxyFromObject(wagon);
			response.allWagons.add(wagonProxy);
		endforeach;
	else
		foreach wagon in app.myPassport.myTerminal.allWagons discreteLock do
			create wagonProxy transient;
			wagonProxy.setProxyFromObject(wagon);
			response.allWagons.add(wagonProxy);
		endforeach;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
epilog
	if wagons &lt;&gt; null then
		delete wagons;
	endif;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_trainId" type="String"/>
        <ReturnType type="WS_WagonsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getWeightCertAuthorities" id="98827738-df97-430a-910b-e4834e29a59a">
        <source>getWeightCertAuthorities() : WS_CodeResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	response : WS_CodeResponse;
	completedOK : Boolean;
	weightAuth	: CM_WeighAuthority;
	iter : Iterator;
	wsCode : WS_Code;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	iter := app.myRoot.allWeighAuthorities.createIterator;
	while iter.next(weightAuth) do
		create wsCode transient;
		wsCode.setProxyDetails(weightAuth, weightAuth.certifiedName[1:10], weightAuth.certifiedName);
		response.allCodes.add(wsCode);
	endwhile;
	
	completedOK := true;
	return response;
	
epilog
	delete iter;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
