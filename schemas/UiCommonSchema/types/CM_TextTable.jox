        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>keyUp(table: CM_TextTable input; keyCode: Integer io; shift: Integer) updating, clientExecution;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	inheritMethod(table, keyCode, shift);

	if table.multiSelect &lt;&gt; MultiSelect_None and shift.bitAnd(2) = 0 then
		self.controlKeyDown := false;
	endif;
	
end;</source>
        <Parameter name="table" type="CM_TextTable" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
