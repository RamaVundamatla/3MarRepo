    <JadeMethod name="doOK" id="71d36f69-126d-4fe5-9443-4ce79d63e8c0">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2010	cnwer1	Initial creation

*/

vars
	
begin
	
	self.myTAViewInterface.renameView(self.myTAView,self.txtName.text);
	if app.myPassport.trxCompletedOK then
		inheritMethod();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getViewName" id="4e613ee9-da0d-4968-9721-75b01b386dcb">
        <source>getViewName() : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2010	cnwer1	Initial creation

*/

vars

begin
