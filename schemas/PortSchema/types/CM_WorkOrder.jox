    <JadeMethod name="getAuditText" id="16559b4c-d7a3-4d31-b264-42594bd1713c">
        <source>getAuditText(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwmd1	Initial creation

*/

vars
	wodtl 		: CM_WorkOrderDtl;
	email 		: CM_EmailEntity;
	auditStr,
	tmpStr 		: String;
	taskAuditStr: String;
	
begin
	auditStr[10000] := '*';
	auditStr := null;
	auditStr := inheritMethod();
	
	//26.6.2018 cnwma1 TFS #38635
	tmpStr := null;
	if self.taskStatus &lt;&gt; null then
		tmpStr := self.getStatusString;
		auditStr := auditStr &amp; 'Work Order Status' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	foreach email in self.allEmailAddresses discreteLock  do 
		if tmpStr = null then
			tmpStr := email.name;
		else
			tmpStr := tmpStr &amp; ', ' &amp; email.name;
		endif;
	endforeach;
	auditStr := auditStr &amp; 'Emails' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	auditStr := auditStr &amp; 'Tasks' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	//epr 30 Jan 2019 TFS  43546 lets do proper auditing on the tasks
	tmpStr := null;
	foreach wodtl in self.allWoDtls discreteLock do	
		tmpStr := tmpStr &amp; wodtl.getAuditText();
	endforeach;
	auditStr := auditStr &amp; tmpStr;
epilog
	return auditStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
