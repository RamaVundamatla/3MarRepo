    <JadeMethod name="trxCreateVoyageRequest" id="6a4eacd5-376a-4571-bad7-ba6cce3bdb00">
        <updating/>
        <source>trxCreateVoyageRequest(	_pxyVoyage : CM_Voyage input;
		                _vessel : CM_Vessel input;
						_voyageOperator,
						_loadOperator,
						_dischargeOperator : CM_Operator;
						_origin, _lastCall, _nextCall, _last : String;			// TFS 42024
						_hasCargo : Boolean;
						_remarks : String;
						_allDocuments	: ObjectArray input;
						_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/03/2018	jlger1	Initial creation tfs 37663 web portal create
20/11/2018	jlgdap1	TFS 42024 PEL1 Incorrect Ports in Voyage Request
08/11/2021 jlier1 TFS 52302
09/03/2022	jlizm1	TFS 52834 SAL file attachments filter by work order
*/

vars
	newVoyage : CM_Voyage;
	workorder : CM_WorkOrder;
	woDtl : CM_WodVoyageRequest;			// TFS 42024
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

			// Start the transaction
	beginTransaction;

	app.myUtilityCA.utlCreateVoyage(_pxyVoyage,newVoyage,_vessel,null,_pxyVoyage.myCellularVoyageStructure&lt;&gt; null,app.myPassport);
	
	if app.myPassport.hasErrors or newVoyage = null then
		return;
	endif;
	
	// TFS 40029
	woDtl := newVoyage.getWorkOrderForVoyageRequest();					// TFS 42024
	if woDtl &lt;&gt; null then												// TFS 42024
		workorder := woDtl.myParent;
		woDtl.setPortCodes(_origin, _lastCall, _nextCall, _last);		// TFS 42024
		woDtl.setGeneralRemarks(_remarks);
		woDtl.setHasCargo(_hasCargo);
		if workorder &lt;&gt; null then
			if _allDocuments &lt;&gt; null then
				app.myUtilityCA.utlCreateFiles(workorder, _allDocuments, _passport);	// TFS 52834
			endif;
			
			workorder.setOperatorsForWS(_voyageOperator,
						_loadOperator,
						_dischargeOperator);
		endif;																// TFS 42024
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
