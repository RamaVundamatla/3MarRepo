    <JadeMethod name="utlUpdateBGPBackupReset" id="0112fc37-180f-41bd-a013-1c0f0b60187a">
        <updating/>
        <source>utlUpdateBGPBackupReset(_backup : CM_Backup input; _bgpController : BGP_Controller input) updating;

vars
	backupHistory : CM_BackupHistory;
	request : BGP_Request;
begin
	if _backup = null then
		return;
	endif;
	_backup.setStatus(BackupStatus_Idle);
//	BGP_BackupDB.instances.purge;
	foreach request in BGP_BackupDB.instances do
		request.BGP_BackupDB.removeBackupClassNotify();	//cnwrs1 Par 28593 10 Nov 2011
//		request.endClassNotification(CM_Backup, false, Object_Update_Event);
//		if request.isProcessed then
			app.myUtilityDA.utlDeleteBGPRequest(null, request, true, app.myPassport);
//		endif;
	endforeach;
	if _bgpController = null then
		return;
	endif;
	_bgpController.setSDSSecondaryProcess(null);	// CCMS1150 cnwrs1 04 July 2011 
	_bgpController.setTerminateSDSProcess(false);
	backupHistory := app.myRoot.myBackup.allBackupDBs.last;
	if backupHistory &lt;&gt; null and
	   (backupHistory.status = BackupStatus_Actioned or 
	    backupHistory.status = BackupStatus_Processing or
		backupHistory.status = BackupStatus_Restarted) then
		backupHistory.setStatus(BackupStatus_Failed);
	endif;
end;
</source>
        <Parameter name="_backup" type="CM_Backup" usage="input"/>
        <Parameter name="_bgpController" type="BGP_Controller" usage="input"/>
    </JadeMethod>
