    <JadeMethod name="processExternal" id="b3a563b2-060c-4bbe-8d13-75418203cf85">
        <updating/>
        <source>processExternal(_parseAgent : CM_RemoteParseAgent io) : String updating;


begin

	if not self.getHeaderDtlExternal(_parseAgent) then
		return 'Error processing header details';
	endif;
	
	if self.myRadioTelemetryDevice = null then
		return 'Invalid device ID';
	endif;
	
	if not self.checkMessageId() then
		if not app.isDevelopmentSystem() then
			return 'Invalid message ID (' &amp; self.messageId &amp; ')';
		endif;
	endif;
	
	return null;
	
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processInternal" id="6fe76b52-9d09-4a7b-981f-269ca68ba0d6">
        <updating/>
        <source>processInternal(_cmif : CMIF_Remote; _passport : CM_Passport input) : Boolean updating;


begin

	self.raiseExceptionIfNotTransient(method);
	//self.messageId 		:= 'Internal';
	self.messageId		:= self.MessageIdInternal;	// PAR21218 23/02/2010
	self.messageType	:= _cmif.transactionType;
	self.myUser 		:= _passport.myUser;
	self.userId			:= _passport.userCode;
	self.myGUIUser		:= _passport.myUser;
	self.terminal		:= _cmif.terminal;
	self.time			:= _cmif.transactionTime;

	return true;
	
end;</source>
        <Parameter name="_cmif" type="CMIF_Remote"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runBackGroundProcess" id="e9fc5716-3eac-4a91-9175-798dab96cc5c">
        <source>runBackGroundProcess(_isBackGround : Boolean) : Boolean;

vars
	errorSet	: CM_ErrorSet;
	theTerminal	: CM_Terminal;

begin

	/*theTerminal := app.myRoot.allTerminals[self.terminal];
	if theTerminal = null then
		app.raiseCMException1(Err_InvalidTerminal, self.terminal, null, null);
	endif;
	app.myPassport.setMyTerminal(theTerminal);*/
	
	self.setPassportTerminal();
	
	if _isBackGround then
		app.myPassport.setMyUser(self.myUser);
	endif;
	app.myPassport.setIsBackgroundWarningsIgnored(_isBackGround);

	create errorSet transient;

	return self.runProcess(errorSet, _isBackGround);
	
epilog
	if errorSet &lt;&gt; null then
		errorSet.purge;
	endif;
	delete errorSet;
end;</source>
        <Parameter name="_isBackGround" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runProcess" id="63416df2-6754-40cc-9b60-439d5de71de5">
        <source>runProcess(_errorSet : CM_ErrorSet input; _isBackGround : Boolean) : Boolean;

vars

	theError 		: CM_Error;	
	remoteHdr		: CM_RemoteDataHdr;
	alert			: CM_SystemAlert;
	allAlertsCopy	: CM_SystemAlertByDateTime;

begin

	if _errorSet.size &gt; 0 then
		if _isBackGround then
			app.remoteErrorWarningToAlert(app.getErrorString(Background_Error_Right_Click), self, _errorSet, null, false, false);
		else
			app.myPassport.clearErrorsWarnings();
			foreach theError in _errorSet do
				if theError.warningOnly then
					//app.addWarningFullPassport(RemoteDataError, theError.text, null, null, app.myPassport);
					app.addWarningFullPassport(theError.errorCode, theError.text, null, null, app.myPassport);	//13 Sep 2012	NDL	30366
				else
					//app.addErrorFullPassport(RemoteDataError, theError.text, null, null, app.myPassport);
					app.addErrorFullPassport(theError.errorCode, theError.text, null, null, app.myPassport);	//13 Sep 2012	NDL	30366
				endif;
			endforeach;
		endif;
		return false;
	else
		remoteHdr := self;
		app.myTrxUA.trxUpdateRemoteState(remoteHdr, Remote_State_Processed, app.myPassport);
		create allAlertsCopy transient;
		self.allAlerts.copy(allAlertsCopy);
		app.myTrxDA.trxDeleteSystemAlert(allAlertsCopy,app.myPassport);
		return true;
	endif;
epilog
	delete allAlertsCopy;
end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
        <Parameter name="_isBackGround" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="08d09081-a8f7-4548-a3ee-13eb30eb264b">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns : Integer) updating;


begin

	self.terminal := _table.accessCell(2,_entryTableColumns).text;

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setError" id="8963172b-858f-4ce3-90da-d42b95c78b9d">
        <updating/>
        <source>setError(_err : Integer; _errText : String) updating;

vars

begin

	self.error 		:= _err;
	self.errorText	:= _errText;

end;</source>
        <Parameter name="_err" type="Integer"/>
