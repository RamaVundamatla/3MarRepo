    <JadeMethod name="validateMove" id="015f1d7a-b363-4fbb-be06-fee8716c4cc6">
        <source>validateMove();
// ---------------------------------------------------------------------------
// Created:     15 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	wagon : CM_Wagon;
begin
	foreach wagon in self.allWagons discreteLock do
		if self.myTargetRailLine.allWagonsById[wagon.id] &lt;&gt; null then
			app.raiseCMException2(Rake_alrea_wagon_with_pleas_ch,self.myTargetRailLine.getDisplayDetails(false), wagon.id , null, null);
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validatePlannedRailLineSpace" id="a494365b-9e9b-4133-830d-ea46a76cd691">
        <source>validatePlannedRailLineSpace();
/*

Purpose:			
		This method checks whether there is enough space in the rail line for planning wagon
Parameters:			

Return Value:		

Date		Who		Reason
01/05/2023	navkc1	Bug 57742: Wagon Track Planning - Capacity for Same Train
// 02/06/2023	navkc1	Bug 58384: FR 53740 | EUP - Wagon Track Planning (part II)
*/

vars
	availableSpace 		: Integer;
	neededSpace 		: Integer;
	maxSpace 			: Integer;
	numActualWagon		: Integer;
	numPlanWagon		: Integer;
	i 					: Integer;
	index				: Integer;
	isInward			: Boolean;
	wagon 				: CM_Wagon;
	train 				: CM_Train;
	railLine			: CM_RailLine;
	allTrains			: ObjectArray;
	numWagonForTrain	: IntegerArray;
	allWagonsToPlan		: CM_WagonArray;
	
begin
	
	// 02/06/2023	navkc1	Bug 58384 - if undoing move, don't need to validate;
	if self.isUndoMove then
		return;
	endif;
	
	create allTrains transient;
	create numWagonForTrain transient;
	create allWagonsToPlan transient;
	
	self.allWagons.copy(allWagonsToPlan);
	
	railLine := self.myTargetRailLine;
	
	isInward := self.isInwardTarget;
	
	// Count the number of train and number of wagon for each train we need to process.
	foreach wagon in allWagonsToPlan do
		if isInward then
			train := wagon.myTrainInwards;
		else
			train := wagon.myTrainOutwards;
		endif;
		
		// If the wagon we are planning is already physically there, remove it from the planning list.
		if railLine.allWagons.includes(wagon) then
			self.allWagons.remove(wagon);
			continue;
		endif;
		
		index := allTrains.indexOf(train);
		// If the train is already in the list, increase the counter of wagon
		if index &gt; 0 then
			numWagonForTrain[index] += 1;
		// If the train is not in the list, add it then increase the counter of wagon
		else
			allTrains.add(train);
			numWagonForTrain.add(1);
		endif;
	endforeach;
	
	// Max wagon the rail line can fit
	maxSpace := railLine.maximumWagons;
	
	index := 0;
	// For each train, calculate the number of space needed, number of space available. Raise warning if we don't have enough space.
	foreach train in allTrains as CM_Train do
		index += 1;
		
		neededSpace := numWagonForTrain[index];
		
		// Number of wagon that is already there for the train;
		numActualWagon := railLine.getNumOfActualWagonForTrain(train, isInward);
		// Number of wagon planned for the train;
		numPlanWagon := railLine.getNumOfPlannedWagonForTrain(train, isInward);
		
		availableSpace := maxSpace - numActualWagon - numPlanWagon;
		
		// If planning a wagon that is already there, increase the available space counter.
		foreach i in 1 to numActualWagon do
			wagon := railLine.allWagons[i];
			if wagon = null or self.allWagons.includes(wagon) then
				availableSpace := availableSpace + 1;
			endif;
		endforeach;
		
		// We have enough space for this train, next
		if neededSpace &lt;= availableSpace then
			continue;
		endif;
		
		// We don't have enough space for this train, raise warning		
		app.raiseCMWarning5(Warn_plan_wagon_move_space,
							train.code,
							numActualWagon.String,
							numPlanWagon.String,
							railLine.id,
							availableSpace.String,
							null,
							null,
							null
							);
	endforeach;				
epilog
	delete allTrains;
	delete numWagonForTrain;
	delete allWagonsToPlan;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateRailLineSpace" id="7b135dbe-9cde-4ca3-84f8-fbe92480f9cc">
        <updating/>
        <source>validateRailLineSpace() updating;

/*

Purpose:			Check there is available space on the rail line for the wagons being moved.
					if not, trim back the number of wagons and generate a warning.

Parameters:			

Return Value:		


Date		Who		Reason
11 Jun 2009	consw1	Initial creation
02/06/2023	navkc1	Bug 58384: FR 53740 | EUP - Wagon Track Planning (part II)
*/

vars
	availableSpace : Integer;
	neededSpace : Integer;
	i, max, pos : Integer;
	wagon : CM_Wagon;
	
begin
	
	// 02/06/2023	navkc1	Bug 58384 - If undoing move, don't need to validate;
	if self.isUndoMove then
		return;
	endif;
	
	neededSpace := self.allWagons.size;
	
	if neededSpace &lt; 2 then
		return;
	endif;
		
	pos := self.targetPosition;
	if pos = 0 then
		pos := max + 1;
	endif;
	
	if pos &gt; self.myTargetRailLine.maximumWagons then
		return;
	endif;

	max := self.myTargetRailLine.allWagons.size;

	if pos &gt; max then
		availableSpace := self.myTargetRailLine.maximumWagons - pos + 1;
	else
		availableSpace := self.myTargetRailLine.maximumWagons - max;
		foreach i in pos to max do
			wagon := self.myTargetRailLine.allWagons[i];
			if wagon = null or not wagon.confirmed or self.allWagons.includes(wagon) then
				availableSpace := availableSpace + 1;
				if neededSpace &lt;= availableSpace then
					return;
				endif;
			endif;
		endforeach;
	endif;

	if neededSpace &lt;= availableSpace or availableSpace = 0 then
		return;
	endif;
	
	//  Trim back wagons on move controller to space available

	while self.allWagons.size &gt; availableSpace do
		self.allWagons.removeAt(self.allWagons.size);
	endwhile;
	
	app.raiseCMWarning4(Warn_wagon_move_space_limited, availableSpace.asStringJMT(), neededSpace.asStringJMT(),
									self.targetPosition.asStringJMT(), self.myTargetRailLine.id, null, null, null);
									
									
	
epilog

end;</source>
    </JadeMethod>
</Class>
