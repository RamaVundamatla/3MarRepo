    <JadeMethod name="setupForm" id="9dde9265-8b42-4bd3-bc24-8bc6ca728928">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;

	inheritMethod();
		
	self.setupCmdButtons( 2, app.getErrorString(Rake_list), app.getErrorString(Back), null, null, null );
	
	self.setColours();
	
	self.setupDynaDicts();

	self.setupControls();
	
	self.beginClassNotification(CM_Wagon,false,Object_Delete_Event, Response_Continuous, 0);

epilog

end;</source>
