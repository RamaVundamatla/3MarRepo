	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="userCanModify" id="eab580ca-b569-4fe2-b77c-17a86876741b">
        <source>userCanModify(  _terminal : CM_Terminal ) : Boolean;
// ---------------------------------------------------------------------------
// Created:	20 January 2010 By Graeme Black cnwgb1
// Status: 	
// Purpose:	Does the user need and/or have permission to update a special required
//          field to remove a stop
// ---------------------------------------------------------------------------
vars
	user : CM_User;
	userTerm	: CM_UserTerminal;
begin
	user := app.getMyUser();
	if user = null then
		return false;
	endif;
		
	userTerm := user.getUserTerminal(_terminal);
	if userTerm = null then
		return false;
	endif;
	
	if userTerm.mySecurityRole = null then
		return false;
	endif;
	//epr refactoring for 
	if not userTerm.mySecurityRole .allStopsMaint.includes(self) then
		return false;
	endif;
	
	if not self.requiresInfo then
		return true;
	endif;
	
	if self.requiresInfoType = ImportReleasePIN then
		return app.getMyUser.canDo( _terminal, PmAdmOpImpReleasePinEdit );
	elseif self.requiresInfoType = ExportReleaseNumber  then
		return app.getMyUser.canDo( _terminal, PmAdmOpExpReleaseNumEdit );
	elseif self.requiresInfoType = DeliveryRelease then
		return app.getMyUser.canDo( _terminal, PmAdmDeliveryReleaseNumEdit );
	elseif self.requiresInfoType = SOLAS then
		return false; //epr TFS 1946 25/5/16
	endif;
	
	return true;
	
epilog
	
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="f01f9ff6-db77-4107-ac89-23f1b746537b">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if app.myRoot.allStopsTable[self.id] &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE,"ID"," Already in use.",null, null);
	endif;
	self.validateMe();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="23524343-3f10-4d83-824f-56277dab92e2">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aTI : CM_TrackedItem;
	aStop : CM_Stops;
	iter : Iterator;
	term : CM_Terminal;
	type : Integer;
	startObj : Object;
	allTypes : IntegerArray;
	bulk : CM_BulkRelease;
	resDet : CM_ReserveDetail;
	da : CM_DocumentActions;
	booking : CM_BookingRef;
	bookItem : CM_BookingRefItem;
	whereUsed : String;
begin

	//selector warning
	app.raiseCMWarning1(WARN_SELECTOR_PROPERTY, 'stop', 'stop', null, self);
	
	if self.allStops.size = 0 then //ok to delete
		if CM_BookingItemActions.instances.size = 0 and CM_ReserveDetailActions.instances.size = 0 then	//20 Mar 2017	NDL	TFS 3667
			return;
		endif;
	endif;
	
	foreach aStop in self.allStops do
		aTI := aStop.getMyTrackedItem;
		if aTI &lt;&gt; null then
			app.raiseCMException1(ERR_TI_EXISTS_FOR_STOPS_TABLE, " (" &amp; aTI.id &amp; " - " &amp; aTI.locationId &amp; ") ",null, null);
			break;	//don't raise an exception for each stop, just the first valid one
		endif;
	endforeach;
	
	create allTypes transient;
	allTypes.add(BR_TYPE_PACKING);
	allTypes.add(BR_TYPE_RAIL);
	allTypes.add(BR_TYPE_ROAD);
	allTypes.add(BR_TYPE_SHIP);
	
	foreach term in app.myRoot.allTerminals discreteLock do
		foreach type in allTypes do
			delete iter;
			iter := term.allBulkReleaseByTypeByStByCd.createIterator;
			startObj := term.allBulkReleaseByTypeByStByCd.getAtKeyGeq( type, BR_PENDING, null, null );
			if startObj = null then
				continue;
			endif;
			iter.startAtObject(startObj);
			while iter.next( bulk ) do
				if bulk.type &lt;&gt; type then
					break;
				endif;
				if bulk.status &lt;&gt; BR_PENDING and bulk.status &lt;&gt; BR_ACTIVE then
					break;
				endif;
				foreach resDet in bulk.allReserveDetails discreteLock do
					da := resDet.myReserveDetailActions;
					if da &lt;&gt; null and da.includesStopTable( self ) then
						app.raiseCMException1(Stop_table_documen_actions, "[" &amp; term.code &amp; "] " &amp; bulk.code, null, null);
						return;
					endif;
				endforeach;
				if bulk.type = BR_TYPE_PACKING then
					foreach resDet in bulk.allReservePackingChildren discreteLock do
						da := resDet.myReserveDetailActions;
						if da &lt;&gt; null and da.includesStopTable( self ) then
							app.raiseCMException1(Stop_table_documen_actions, "[" &amp; term.code &amp; "] " &amp; bulk.code, null, null);
							return;
						endif;
					endforeach;
				endif;
			endwhile;
		endforeach;
	endforeach;
	
	foreach term in app.myRoot.allTerminals discreteLock do
		
		delete iter;
		iter := term.allBookingRefsByStatusRef.createIterator;
		startObj := term.allBookingRefsByStatusRef.getAtKeyGeq( BOOKING_REF_PENDING, null );
		if startObj = null then
			continue;
		endif;
		iter.startAtObject(startObj);
		while iter.next( booking ) do
			
			if booking.status &lt;&gt; BOOKING_REF_PENDING and booking.status &lt;&gt; BOOKING_REF_ACTIVE then
				break;
			endif;
			foreach bookItem in booking.allBookingRefItems discreteLock do
				da := bookItem.myBookingRefItemActions;
				if da &lt;&gt; null and da.includesStopTable( self ) then
					app.raiseCMException1(Stop_table_documen_actions, "[" &amp; term.code &amp; "] " &amp; booking.bookingReference, null, null);	// ### TFS N/A 12Jul2024 NAVPW1 - FOund while running unit tests changed bulk.code to booking.bookingReference
					return;
				endif;
			endforeach;

		endwhile;
		
	endforeach;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;
	
	
epilog
	delete iter;
	delete allTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="f2acfee6-8918-40f3-9541-2709edea7d25">
        <source>validateForUpdate(_theRealStopTable : CM_StopsTable);
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
//
// ---------------------------------------------------------------------------

vars
	//aCargoType : CM_CargoBOLType;		//20 Jul 2022	navsj20	TFS 53862
	aCargoType : Object;				//20 Jul 2022	navsj20	TFS 53862
	aTI : CM_TrackedItem;
	aStop : CM_Stops;
	iter01 : Iterator;
	whereUsed : String;
	criteria : CM_YACriteria;			//27 Jul 2022	navsj20	TFS 53862
begin
	self.raiseExceptionIfNotTransient(method);
	self.validateMe();
	if self.requiresInfo and
	   self.requiresInfoType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Info Entry', ETRow_CustomsInfoEntry, null);
		app.raiseCMException(Input_required_field_infoEntry, ETRow_CustomsInfoEntry, null); // cnwdb2	PAR 35364
	endif;
	
	if _theRealStopTable.allStops.size = 0 then //ok to modify
		return;
	endif;

	if self.myStopCriteria &lt;&gt; null then																												//20 Jul 2022	navsj20	TFS 53862
		//foreach aCargoType in _theRealStopTable.allCargoTypesNew do																				//20 Jul 2022	navsj20	TFS 53862
		foreach criteria in self.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do			//27 Jul 2022	navsj20	TFS 53862
			foreach aCargoType in criteria.myYAData.CM_YADataObjects.allObjects where aCargoType.isKindOf(CM_CargoBOLType) do //20 Jul 2022	navsj20	TFS 53862
				//th2 - 25/09/06 collection not inversed - has invalid members - fixing to inverse later
				if (not app.isValidObject(aCargoType)) then
					continue;
				endif;
				
				// are we trying to remove a cargo type?
				//if not self.allCargoTypesNew.includes(aCargoType) then	//yes we are		//20 Jul 2022	navsj20	TFS 53862
				if not criteria.myYAData.CM_YADataObjects.allObjects.includes(aCargoType) then	//27 Jul 2022	navsj20	TFS 53862
						//see if any of my stops are for this cargo type
					foreach	aStop in _theRealStopTable.allStops do
						aTI := aStop.getMyTrackedItem;
						if aTI &lt;&gt; null then		
							//if aTI.myCargoType = aCargoType then						//20 Jul 2022	navsj20	TFS 53862
							if aTI.myCargoType = aCargoType.CM_CargoBOLType then		//20 Jul 2022	navsj20	TFS 53862
								//raise exception
								//app.raiseCMException2(ERR_STOPS_TABLE_HAS_TIS, " (" &amp; aTI.id &amp; " - " &amp; aTI.locationId &amp; ") ", " (" &amp; aCargoType.description &amp; ") ",null, null);	//20 Jul 2022	navsj20	TFS 53862
								app.raiseCMException2(ERR_STOPS_TABLE_HAS_TIS, " (" &amp; aTI.id &amp; " - " &amp; aTI.locationId &amp; ") ", " (" &amp; aCargoType.CM_CargoBOLType.description &amp; ") ",null, null);	//20 Jul 2022	navsj20	TFS 53862

		//						A Tracked Item %1 exists with the Cargo Type %2 that you are trying to remove from this Stop Type.
							endif;
						endif;
					endforeach;
				endif;
			endforeach;
		endforeach;		
	endif;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isNotAvailableForEntry then
		if self.isUsedinConfig( whereUsed ) then
			app.raiseCMException1(Not_make_not_availa_while, whereUsed, null, self);
		endif;
	endif;
	
end;</source>
        <Parameter name="_theRealStopTable" type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="c38876b1-1525-41a8-8982-a6c9075aa58b">
        <source>validateMe();
//
//15 May 2013	cnwrs1	par31549 tighning stop validation
//11 July 2022  navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
//02 Apr 2025	naviv1	MTN-34496 - Unit Test Stops can be Created with Id Above 999 Which is not Supported by MTN
vars
	stopTableTemplate : CM_StopTableTemplate;
begin
	// cnwrl1 01/07/2009 PAR 20100 - start of coding
	if self.id = null then
	//	app.raiseCMException1( REQUIRED_FIELD, 'StopTable ID', null, null );
		app.raiseCMException(Input_required_field_stopTabId, null, null ); // cnwdb2	PAR 35364
	else 
		if self.id &gt; StopIdMaximum then		//JIRA-34496
			app.raiseCMException(StopId_Exceeds_Limit, null, null );
		endif;
	endif;
	// cnwrl1 01/07/2009 PAR 20100 - end of coding
	
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'StopTable Code', null, null);
		app.raiseCMException(Input_required_field_stpTabCde, null, null); // cnwdb2	PAR 35364
	endif;
	if self.heading = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'StopTable Heading', null, null);
		app.raiseCMException(Input_required_field_stpTabHea, null, null); // cnwdb2	PAR 35364	
	endif;
	if self.shortHeading = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'StopTable Short Heading', null, null);
		app.raiseCMException(Input_required_field_shrtTabSH, null, null); // cnwdb2	PAR 35364
	endif;
	//Start 11 July 2022 navhl20 TFS 53862
	/*if self.allCargoTypesNew.size = 0 then
	//	app.raiseCMException1(REQUIRED_FIELD, 'StopTable Cargo Types', null, null);
		app.raiseCMException(Input_required_field_shrtTabCT, null, null); // cnwdb2	PAR 35364
	endif;*/
	//End 11 July 2022 navhl20 TFS 53862
	foreach stopTableTemplate in self.allStopTableTemplates do //ccms1824 cnwrs1 May 2009
		if stopTableTemplate.allProcessAreas.includes(StopProcessOpImpReleasePIN) and
		   stopTableTemplate.allProcessAreas.includes(StopProcessOpImpDeliverRel) then
			//app.raiseCMException1(REQUIRED_FIELD, 'StopTable must not include '&amp;StopProcessOpImpReleasePINStr&amp;' and '&amp;StopProcessOpImpDeliverRelStr&amp;' process action setting', null, null);
			app.raiseCMException(Stop_table_must_not_inclu_both, null, null);	// 10/07/2013 cnwar2 #31958
		endif;
	endforeach;
	if self.requiresInfo then //ccms 1824 cnwrs1 May 2009
		if self.requiresInfoType = CEDO then
			foreach stopTableTemplate in self.allStopTableTemplates do //ccms1824 cnwrs1 May 2009
				if not stopTableTemplate.isNotSet then
					if not stopTableTemplate.allApplyAreas.includes(StopApplyExport) then
						//app.raiseCMException1(REQUIRED_FIELD, 'Terminal '&amp;stopTableTemplate.myTerminal.code&amp;' '&amp;app.getErrorString(CM_CEDO)&amp;' StopTable must include '&amp;StopApplyExportStr&amp;' auto apply action setting', null, null);
						app.raiseCMException4(Stop_table_must_include, stopTableTemplate.myTerminal.code, app.getErrorString(CM_CEDO), StopApplyExportStr, app.getErrorString(Auto_apply), null, null);		// 10/07/2013 cnwar2 #31958
					endif;
					if not stopTableTemplate.allProcessAreas.includes(StopProcessEDICustomExport) then
						//app.raiseCMException1(REQUIRED_FIELD, 'Terminal '&amp;stopTableTemplate.myTerminal.code&amp;' '&amp;app.getErrorString(CM_CEDO)&amp;' StopTable must include '&amp;StopProcessEDICustomImportStr&amp;' process action setting', null, null);
						app.raiseCMException4(Stop_table_must_include, stopTableTemplate.myTerminal.code, app.getErrorString(CM_CEDO), StopProcessEDICustomImportStr, app.getErrorString(ProcessStr), null, null);		// 10/07/2013 cnwar2 #31958
					endif;
				endif;
			endforeach;
		elseif self.requiresInfoType = CustomsEntryNumber then
			foreach stopTableTemplate in self.allStopTableTemplates do //ccms 1824 cnwrs1 May 2009
				if not stopTableTemplate.isNotSet then
					if not stopTableTemplate.allApplyAreas.includes(StopApplyImport) then
						//app.raiseCMException1(REQUIRED_FIELD, 'Terminal '&amp;stopTableTemplate.myTerminal.code&amp;' '&amp;app.getErrorString(CM_Customs_Entry_Number)&amp;' StopTable must include '&amp;StopApplyImportStr&amp;' auto apply action setting', null, null);
						app.raiseCMException4(Stop_table_must_include, stopTableTemplate.myTerminal.code, app.getErrorString(CM_Customs_Entry_Number), StopApplyImportStr, app.getErrorString(Auto_apply), null, null);		// 10/07/2013 cnwar2 #31958
					endif;
					if not stopTableTemplate.allProcessAreas.includes(StopProcessEDICustomImport) then
						//app.raiseCMException1(REQUIRED_FIELD, 'Terminal '&amp;stopTableTemplate.myTerminal.code&amp;' '&amp;app.getErrorString(CM_Customs_Entry_Number)&amp;' StopTable must include '&amp;StopProcessEDICustomImportStr&amp;' process action setting', null, null);
						app.raiseCMException4(Stop_table_must_include, stopTableTemplate.myTerminal.code, app.getErrorString(CM_Customs_Entry_Number), StopProcessEDICustomImportStr, app.getErrorString(ProcessStr), null, null);		// 10/07/2013 cnwar2 #31958
					endif;
				endif;
			endforeach;
		elseif self.requiresInfoType = DeliveryRelease then
			foreach stopTableTemplate in self.allStopTableTemplates do //ccms 1824 cnwrs1 May 2009
				if not stopTableTemplate.isNotSet then
					if not stopTableTemplate.allApplyAreas.includes(StopApplyImport) then
						//app.raiseCMException1(REQUIRED_FIELD, 'Terminal '&amp;stopTableTemplate.myTerminal.code&amp;' '&amp;app.getErrorString(Delivery_Release_Number)&amp;' StopTable must include '&amp;StopApplyImportStr&amp;' auto apply action setting', null, null);
						app.raiseCMException4(Stop_table_must_include, stopTableTemplate.myTerminal.code, app.getErrorString(Delivery_Release_Number), StopApplyImportStr, app.getErrorString(Auto_apply), null, null);		// 10/07/2013 cnwar2 #31958
					endif;
					if not stopTableTemplate.allProcessAreas.includes(StopProcessOpImpDeliverRel) then
						//app.raiseCMException1(REQUIRED_FIELD, 'Terminal '&amp;stopTableTemplate.myTerminal.code&amp;' '&amp;app.getErrorString(Delivery_Release_Number)&amp;' StopTable must include '&amp;StopProcessOpImpDeliverRelStr&amp;' process action setting', null, null);
						app.raiseCMException4(Stop_table_must_include, stopTableTemplate.myTerminal.code, app.getErrorString(Delivery_Release_Number), StopProcessOpImpDeliverRelStr, app.getErrorString(ProcessStr), null, null);		// 10/07/2013 cnwar2 #31958
					endif;
				endif;
			endforeach;
		elseif self.requiresInfoType = ImportReleasePIN then
			foreach stopTableTemplate in self.allStopTableTemplates do //ccms 1824 cnwrs1 May 2009
				if not stopTableTemplate.isNotSet then
					if not stopTableTemplate.allApplyAreas.includes(StopApplyImport) then
						//app.raiseCMException1(REQUIRED_FIELD, 'Terminal '&amp;stopTableTemplate.myTerminal.code&amp;' '&amp;app.getErrorString(CM_Operator_Import_PIN)&amp;' StopTable must include '&amp;StopApplyImportStr&amp;' auto apply action setting', null, null);
						app.raiseCMException4(Stop_table_must_include, stopTableTemplate.myTerminal.code, app.getErrorString(CM_Operator_Import_PIN), StopApplyImportStr, app.getErrorString(Auto_apply), null, null);		// 10/07/2013 cnwar2 #31958
					endif;
					if not stopTableTemplate.allProcessAreas.includes(StopProcessOpImpReleasePIN) then
						//app.raiseCMException1(REQUIRED_FIELD, 'Terminal '&amp;stopTableTemplate.myTerminal.code&amp;' '&amp;app.getErrorString(CM_Operator_Import_PIN)&amp;' StopTable must include '&amp;StopProcessOpImpReleasePINStr&amp;' process action setting', null, null);
						app.raiseCMException4(Stop_table_must_include, stopTableTemplate.myTerminal.code, app.getErrorString(CM_Operator_Import_PIN), StopProcessOpImpReleasePINStr, app.getErrorString(ProcessStr), null, null);		// 10/07/2013 cnwar2 #31958
					endif;
				endif;
			endforeach;
		elseif self.requiresInfoType = ExportReleaseNumber then
			foreach stopTableTemplate in self.allStopTableTemplates do //ccms 1824 cnwrs1 May 2009
				if not stopTableTemplate.isNotSet then
					if not stopTableTemplate.allApplyAreas.includes(StopApplyExport) then
						//app.raiseCMException1(REQUIRED_FIELD, 'Terminal '&amp;stopTableTemplate.myTerminal.code&amp;' '&amp;app.getErrorString(CM_Operator_Export_Rel_Number)&amp;' StopTable must include '&amp;StopApplyExportStr&amp;' auto apply action setting', null, null);
						app.raiseCMException4(Stop_table_must_include, stopTableTemplate.myTerminal.code, app.getErrorString(CM_Operator_Export_Rel_Number), StopApplyExportStr, app.getErrorString(Auto_apply), null, null);		// 10/07/2013 cnwar2 #31958
					endif;
					if not stopTableTemplate.allProcessAreas.includes(StopProcessOpExpReleaseNo) then
						//app.raiseCMException1(REQUIRED_FIELD, 'Terminal '&amp;stopTableTemplate.myTerminal.code&amp;' '&amp;app.getErrorString(CM_Operator_Export_Rel_Number)&amp;' StopTable must include '&amp;StopProcessOpExpReleaseNoStr&amp;' process action setting', null, null);
						app.raiseCMException4(Stop_table_must_include, stopTableTemplate.myTerminal.code, app.getErrorString(CM_Operator_Export_Rel_Number), StopProcessOpExpReleaseNoStr, app.getErrorString(ProcessStr), null, null);		// 10/07/2013 cnwar2 #31958
					endif;
				endif;
			endforeach;
		endif;
	endif;
	foreach stopTableTemplate in self.allStopTableTemplates do //ccms 1824 cnwrs1 May 2009
		stopTableTemplate.validateMe();
	endforeach;
end;
</source>
    </JadeMethod>
</Class>
