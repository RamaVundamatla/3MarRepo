    <JadeMethod name="doResize" id="4a693ce8-8c59-4a80-8cf9-8484ba8ac84c">
        <updating/>
        <source>doResize() updating;
//11 February 2009	cnwdw1	
//
// 10 June 2013	cnwcs5	par 31712 - fixup forms
vars

begin
	self.clientHeight := (self.btnCancel.top + (self.btnCancel.height +15)).Integer;
end;</source>
