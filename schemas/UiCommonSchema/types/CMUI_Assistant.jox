    <JadeMethod name="showHSCodeSearchForm" id="d24d5ce6-026c-4002-b154-d21d4a9104c6">
        <source>showHSCodeSearchForm(_parentForm: CM_BaseForm; _showModal : Boolean) : CM_HarmonizedSystem;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
15 December 2022		jlizm1	Initial creation TFS 55582 HS Code Searcher

*/

vars

	form : CMUI_HSCodeSearch;
	
begin
	
	if _showModal then
		form := app.loadForm(CMUI_HSCodeSearchModal, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_HSCodeSearchModal;
	else
		form := app.loadForm(CMUI_HSCodeSearch, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_HSCodeSearch;
	endif;
	
	if form = null then
		return null;
	endif;
	
	form.setParentForm(_parentForm);
	
	if _showModal then
		form.showModal();
	else
		form.show();
	endif;
	
	if form.modalResult = IDOK then
		return form.getSelectedHSCode();
	endif;
	return null;
	
epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_showModal" type="Boolean"/>
        <ReturnType type="CM_HarmonizedSystem"/>
    </JadeMethod>
