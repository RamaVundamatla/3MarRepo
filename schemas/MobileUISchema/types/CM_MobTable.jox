    <JadeMethod name="fitTextToCell" id="4648c310-d887-4dd8-9b18-7d18644191ce">
        <source>fitTextToCell(pInputText : String; pOutputText : String output; pCellWidth : Integer; pCellHeight : Integer output);

/*
	Created on 01 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     Take the input text string, and insert Cr/Lf characters as necessary to fit the string in the 
//				cell width passed in.
//
// Parameters:  None
//
// Returns:     pOutputText updated with the string to place in the cell, and pCellHeight updated with the minimum
//				cell height required to display all the multi-line text
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	NewLine = CrLf;
	Space = ' ';

vars
 	currentPos, tempPos, i, j : Integer;
 	tempString, line, tempLine, token : String;

begin
	// Copy input string, and strip out any new line characters and tabs
	tempString := pInputText;
 	tempString := tempString.replaceString(NewLine, Space);
 	tempString := tempString.replaceString(Tab, Space);
 	tempString := tempString.eliminateContiguousSpaces();

	// If the resulting string will fit in the cell, then return
	if self.getTextExtent(tempString) &lt; pCellWidth then
		pOutputText := tempString;
		return;
	endif;

	// Build up a multi-line string 
	currentPos := 1;
	pOutputText := null;
	line := null;
	while currentPos &lt;= tempString.length do
		// First get the next token, not including its trailing space
		tempPos := tempString.pos(Space, currentPos);
		if tempPos = 0 then
			tempPos := tempString.length + 1;
		endif;
		token := tempString[currentPos:tempPos - currentPos];

		// now check if the current line will still fit in the cell
		if line = null then
			tempLine := token;
		else
			tempLine := line &amp; Space &amp; token;
		endif;

		// if the line so far fits in the cell, then move currentPos past this token
		if self.getTextExtent(tempLine) &lt; pCellWidth then
			line := tempLine;
			currentPos := tempPos + 1;

    	else
    		// current token puts current line over boundary
			if line &lt;&gt; null then
				if pOutputText = null then
					pOutputText := line;
				else
					pOutputText := pOutputText &amp; NewLine &amp; line;
				endif;
				line := null;
			else
				// current token is too big to fit in a cell, so we need to break
				//  it up
  				line := token;

/* 				i := 1;
         		while i &lt; token.length do
         			j := i;
         			while j &lt;= token.length and self.getTextExtent(token[i:j - i + 1]) &lt; pCellWidth do
         				j := j + 1;
         			endwhile;
         			line := token[i:j - i];

					if j &lt; token.length then
						if pOutputText = null then
							pOutputText := line;
						else
							pOutputText := pOutputText &amp; NewLine &amp; line;
						endif;
						line := null;
					endif;

					i := j;
         		endwhile;
*/
				currentPos := tempPos + 1;
         	endif;
		endif;

  	endwhile;

	if line &lt;&gt; null then
		if pOutputText = null then
			pOutputText := line;
		else
			pOutputText := pOutputText &amp; NewLine &amp; line;
		endif;
	endif;
epilog	
	pCellHeight := self.getTextHeight(pOutputText) + 5;
end;</source>
        <Parameter name="pInputText" type="String"/>
        <Parameter name="pOutputText" type="String" usage="output"/>
        <Parameter name="pCellWidth" type="Integer"/>
        <Parameter name="pCellHeight" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getAllSelectedObjects" id="63df8bab-1fc0-4a17-ac11-8ab4f8eb7f72">
        <updating/>
        <source>getAllSelectedObjects(_selectedObjects: ObjectArray input) updating;
/*
	Created on 19 May 2009
	
	by cnwdz2
	
	Purpose: ccms1801
*/

vars
	numRows,
	numCols,
	i, j	: Integer;
	obj		: Object;
begin
	numRows := self.rows;
	numCols := self.columns;

	foreach i in 1 to numRows do
		accessRow(i);
		if self.accessedRow.selected then
			obj := self.accessRow(i).itemObject;
			if obj &lt;&gt; null then
				_selectedObjects.add(obj);
			endif;
		endif;
	endforeach;		
epilog

end;
</source>
        <Parameter name="_selectedObjects" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllSelectedRows" id="bcb9e528-ad8f-4778-9042-681a707d6e7a">
        <updating/>
        <source>getAllSelectedRows(_selectedRows: IntegerArray input) updating;
/*
	Created on 19 May 2009
	
	by cnwdz2
	
	Purpose:ccms1801
*/

vars
	i,
	numRows : Integer;
begin
	numRows := self.rows;

	foreach i in 1 to numRows do
		accessRow(i);
		if self.accessedRow.selected then
			_selectedRows.add(i);
		endif;
	endforeach;		
epilog

end;
</source>
        <Parameter name="_selectedRows" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFirstSelectedObject" id="54a8144d-bdf6-47be-87e0-c683fe2c1558">
        <updating/>
        <source>getFirstSelectedObject():Object updating;
/*
	Created on 14 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	numRows,
	numCols,
	i, j	: Integer;
	obj		: Object;
begin
	numRows := self.rows;
	numCols := self.columns;

	foreach i in 1 to numRows do
		foreach j in 1 to numCols do
			accessCell(i,j);
			if self.accessedCell.selected then
				obj := self.accessRow(i).itemObject;
				if obj &lt;&gt; null then
					return obj;
				endif;
			endif;
		endforeach;
	endforeach;		
end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="rowColumnChg" id="2abda48a-a6c9-4f68-9d50-e4731bd191f7">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>rowColumnChg(table: Table input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		23 May 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	saveRow		: Integer;
	rowPointer	: Integer;
	startRow	: Integer;
	lastRow		: Integer;
	fore		: Integer;
	back		: Integer;
	
begin
	inheritMethod(table);
	
	if not self.useHighlightColours then
		return;
	endif;
	
	self.accessMode	:=	self.AccessMode_Row;
	saveRow		:=	self.row;
	startRow	:=	self.fixedRows + 1;
	lastRow		:=	self.rows;
	fore		:=	app.colorForeTables;
	back		:=	app.colorBackTables;
	
	foreach rowPointer in startRow to lastRow do
		self.row	:=	rowPointer;
		
		if rowPointer = saveRow then
			self.backColor	:=	Blue;	
			self.foreColor	:=	White;
		else
			self.backColor	:=	back;
			self.foreColor	:=	fore;
		endif;
	endforeach;
	
	self.row	:=	saveRow;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFixedColours" id="b7bb92e8-3e69-4820-a01c-4a6d32160f73">
        <source>setFixedColours();
// --------------------------------------------------------------------------------
// Created:		23 May 2008 by cnwdad1
//
// Purpose:		Sets the fore/back colors of the receiver's fixed rows and columns.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	columnObj	: JadeTableColumn;
	rowObj		: JadeTableRow;
	backColor	: Integer;
	foreColor	: Integer;
	pointer		: Integer;
	rowCount	: Integer;
	
begin
	tableObj	:=	self;
	backColor	:=	app.colorBackGeneral;
	foreColor	:=	app.colorForeGeneral;
	rowCount	:=	tableObj.fixedColumns;
	
	if rowCount &gt; 0 then
		foreach pointer in 1 to rowCount do
			columnObj	:=	tableObj.accessColumn(pointer);
			
			if columnObj = null then
				break;
			else
				columnObj.backColor	:=	backColor;
				columnObj.foreColor	:=	foreColor;
			endif;
		endforeach;
	endif;
	
	rowCount	:=	tableObj.fixedRows;
	
	if rowCount &gt; 0 then
		foreach pointer in 1 to rowCount do
			rowObj	:=	tableObj.accessRow(pointer);
			
			if rowObj = null then
				break;
			else
				rowObj.backColor	:=	backColor;
				rowObj.foreColor	:=	foreColor;
			endif;
		endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setMargins" id="794b3dbc-19c9-46ea-b0b3-d1f9f63ec933">
        <updating/>
        <source>setMargins()updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	i,
	numSheets	: Integer;
	tmpSheet	: JadeTableSheet;
begin
	numSheets := self.sheets;
	foreach i in 1 to numSheets do
		tmpSheet := self.accessSheet(i);
		tmpSheet.marginLeft := 2;
		tmpSheet.marginRight := 2;
		tmpSheet.marginTop := 1;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setUseHighlightColours" id="087cd6fa-b9b2-4ea0-8f94-26a9cad0a5f9">
        <updating/>
        <source>setUseHighlightColours(_value : Boolean) updating;
/*
	Created on 12 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	useHighlightColours := _value;
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="9c47f282-33cf-4873-88c4-1f61aed7a364">
        <controlMethod name="CM_Table::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		23 May 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	if not self.isInPainter() then
		self.selectMode	:=	Table.SelectMode_CurrentRow;
		self.setFixedColours();
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
