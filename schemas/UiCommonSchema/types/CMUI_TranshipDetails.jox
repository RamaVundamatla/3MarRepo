	self.frmToolbar.repositionAfterResize();

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="fabf6422-abc9-40f9-9966-56676e33f7ea">
        <updating/>
        <source>doSave() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 15/06/2010	cnwdap1		CCMS 1116 Tranship changes - allow change to non-tranship frmo this form as well
vars
	theReturn : Integer;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	if self.shtDetails.visible then
		// we are doing a change from normal to tranship
		return self.doSaveTranship();
		
	else
		// we are doing a change from tranship to non-tranship
		return self.doSaveNonTranship();
		
	endif;
	
	/* what it used to do - moved to doSaveTranship
	self.setControllerFromGUI();


	while true do
		app.myTrxCA.trxCreateTrackeditemsTranShip(self.myController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(SHP_Tranship_Update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
	return true;	*/
epilog
	//self.myController.clearProxies();
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveNonTranship" id="76866cfa-c01b-4168-a056-a1dbf6bb4fad">
        <updating/>
        <source>doSaveNonTranship() : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/06/2010	cnwdap1	Initial creation CCMS 1116 Tranship changes
*/
vars
	tis 	: CM_TIArray;
	ti 		: CM_TrackedItem;
	result	: Integer;
	pxyTI	: CM_TrackedItem;

begin
	create tis transient;
	
	while true do
		tis.purge;
		tis.clear;
		if self.allTrackedItems.size = 1 then
			pxyTI := self.allTrackedItems.first.CM_TrackedItem.pxyGetProxyObject();
			if pxyTI = null then
				pxyTI := app.createUpdateProxy(self.allTrackedItems.first).CM_TrackedItem;
			endif;
			//pxyTI.zSetPxyIsTranshipItem(false);
			//pxyTI.setNotTranship(false, null, app.myPassport);
			pxyTI.zSetPxyImexStatus(self.cmbIMEXStatus.listObject.CM_IMEXStatus.code);
			pxyTI.zSetPxyRemarks(self.txtNonRemarks.text);
			pxyTI.zSetImportVoyage(null); //cwnrd1 7.7.2010 need to clear the import voyage here.
			tis.add(pxyTI);
			app.myTrxUA.trxUpdateTINonTranship(	tis,
												TI_UPDMODE_NORMAL, 
												app.myPassport	);
		else
			foreach ti in self.allTrackedItems do
				pxyTI := ti.CM_TrackedItem.pxyGetProxyObject();
				if pxyTI = null then
					pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
				endif;
				//pxyTI.zSetPxyIsTranshipItem(false);
				//pxyTI.setNotTranship(false, null, app.myPassport);
				pxyTI.zSetPxyImexStatus(self.cmbIMEXStatus.listObject.CM_IMEXStatus.code);
				pxyTI.zSetPxyRemarks(self.txtNonRemarks.text);
				pxyTI.zSetImportVoyage(null); 					// 18/08/2011 cnwmh5 #28032
				tis.add(pxyTI);
			endforeach;
			app.myTrxUA.trxUpdateTINonTranship(	tis,
												TI_UPDMODE_NORMAL, 
												app.myPassport	);
		endif;			
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		return false;
	endwhile;
	
epilog
	if tis &lt;&gt; null then
		tis.purge;		// delete proxies
		delete tis;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveTranship" id="6dbd84fa-0184-4c5e-802f-1894d89e5385">
        <updating/>
        <source>doSaveTranship() : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/06/2010	cnwdap1	CCMS 1116 Tranship changes 
*/
vars
	theReturn	: Integer;

begin
	self.setControllerFromGUI();

	while true do
		app.myTrxCA.trxCreateTrackeditemsTranShip(self.myController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(SHP_Tranship_Update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControllerFromGUI" id="f13290a8-1529-4b6f-b1fb-e2a438d7b019">
        <source>setControllerFromGUI();
// ---------------------------------------------------------------------------
// Created:		20 June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 02/06/2010	cnwdap1		CCMS 1116 Tranship changes
vars
begin
	self.myController.clear();
	
	self.allTrackedItems.copy(self.myController.allTrackedItems);
	if self.shtDetails.visible then
		//self.myController.myExportCommodity := self.cmbCommodity.listObject.CM_Commodity;	// PAR #23889 CCMS 1116
		self.myController.myExportDestPort := self.cmbDestPort.listObject.CM_Port;
		self.myController.myExportDisPort := self.cmbDiscPort.listObject.CM_Port;
		//self.myController.myExportISOType := self.cmbISOType.listObject.CM_ISOType;		// PAR #23889 CCMS 1116
		self.myController.myExportVoyage := self.cmbExpVoyage.listObject.CM_Voyage;
		self.myController.remarks := self.txtRemarks.text;
		//self.myController.removeStops := self.chkRemStops.value;							// TFS 47222 jlgzm1 20/11/2019
		self.myController.bookingRef := self.txtBookRef.text;
		self.myController.billOfLading := self.txtBOL.text;
		self.myController.myTranshipToPort := self.cmbTShipPort.listObject.CM_Port;			// PAR #23889 CCMS 1116
		self.myController.interModal := self.chkInterModal.value;							// TFS 53084 jlizm1 20/04/2022
	else
		self.myController.remarks := self.txtNonRemarks.text;
		self.myController.imexStatus := self.cmbIMEXStatus.listObject.CM_IMEXStatus.code;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItems" id="6914c26f-c47a-43b7-b6c2-9f19cef01ffe">
        <updating/>
        <source>setMyTrackedItems(_tiArray : CM_TIArray input) updating;
// -------------------------------------------
// Created 14 June 2006 by cnwer1
// -------------------------------------------
vars

begin

	if _tiArray = null or _tiArray.isEmpty() then
		return;
	endif;
	
	if _tiArray.size &gt; 1 then
		self.isMultipleMove := true;
		//self.setMyCurrentTI(null); Done in self.initForm()
	else
		//self.setMyCurrentTI(_tiArray.first);Done in self.initForm()
	endif;
	
	self.allTrackedItems.clear();
	_tiArray.copy(self.allTrackedItems);

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f8843ba3-dbf2-4c81-bcfb-2fc81d7ff43c">
        <updating/>
        <source>setupForm() updating;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes, remoev toolbar and show OK/Cancel buttons
// 02/05/2022	jlizm1		TFS 53084 GPHA revceival/release of tranship cargo
//
vars
	exTI, firstTI : CM_TrackedItem;
	isoType : String;
	str : String;
begin
	inheritMethod();
	
	create myController transient;
	
	firstTI := allTrackedItems.first;
	
	if allTrackedItems.size &gt; 1 then
		self.setCaption("Bulk Tranship Edit");
	else
		self.setCaption(firstTI.id);
		//exTI := firstTI.myTranshipExport;					// PAR #23645 CCMS 1116
		exTI := firstTI;									// PAR #23645 CCMS 1116
	endif;
	//self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	// PAR #23645 CCMS 1116
	//self.showToolbar := true;								// PAR #23645 CCMS 1116
	//self.btnOk.visible := false;							// PAR #23645 CCMS 1116
	//self.btnCancel.visible := false;						// PAR #23645 CCMS 1116
	self.toolbarStyle := self.ToolbarStyle_None;			// PAR #23645 CCMS 1116
	self.showToolbar := false;								// PAR #23645 CCMS 1116
	self.btnOk.visible := true;								// PAR #23645 CCMS 1116
	self.btnCancel.visible := true;							// PAR #23645 CCMS 1116
	self.fldTranship.useSheetBackColors := true;
	self.fldTranship.setDefaultSheetBackColors();
 	self.fldTranship.initSheetBackColors();
  	self.cmbDestPort.myTerminal := self.myTerminal;
	self.cmbDestPort.myAssistant := self.myAssistant;
	self.cmbDiscPort.myTerminal := self.myTerminal;
	self.cmbDiscPort.myAssistant := self.myAssistant;
	self.cmbTShipPort.myTerminal := self.myTerminal;		// PAR #23645 CCMS 1116
	self.cmbTShipPort.myAssistant := self.myAssistant;		// PAR #23645 CCMS 1116
	
	self.myAssistant.comboBoxVoyageCurrent(	self.cmbExpVoyage,
											null,
											true,
											false,
											false,
											true,
											true,
											true,
											true,
											false,
											false);
	
	// PAR #23889 CCMS 1116 display tranship or non-tranship tab as appropriate
	//self.cmbISOType.initialise(false);					
	//self.cmbCommodity.initialise(false);
	if firstTI.isTranshipItem then
		self.shtDetails.visible 	:= false;
		self.shtNonDetails.visible	:= true;
		if firstTI.isTranshipExport then
			// on site, default imex status to import, otherwise default to export
			if firstTI.isOnSite then
				self.myAssistant.comboBoxIMEXStatus(self.cmbIMEXStatus, TI_IMEX_STATUS_IMPORT);
			else
				self.myAssistant.comboBoxIMEXStatus(self.cmbIMEXStatus, TI_IMEX_STATUS_EXPORT);
			endif;
			self.cmbIMEXStatus.removeObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP]);
			self.cmbIMEXStatus.removeObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_REMAINONBOARD]);
			self.cmbIMEXStatus.removeObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_NULL]);
			if firstTI.isOnShip then
				// ti is on the export ship - it must be an export
				self.cmbIMEXStatus.enabled := false;
			endif;
		elseif firstTI.isTranshipOnInboundVoyage then
			self.myAssistant.comboBoxIMEXStatus(self.cmbIMEXStatus, TI_IMEX_STATUS_REMAINONBOARD);
			self.cmbIMEXStatus.removeObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP]);
			self.cmbIMEXStatus.removeObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT]);
			self.cmbIMEXStatus.removeObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_NULL]);
			if firstTI.isOnShip then						// 19/08/2011 cnwmh5 #28032
				self.cmbIMEXStatus.enabled := false;
			endif;
		endif;
		self.height := 262;
		self.txtNonRemarks.height := 107;
	else
		self.shtDetails.visible 	:= true;
		self.shtNonDetails.visible	:= false;
		self.height := 390;
	endif;
	// PAR #23889 CCMS 1116 end of non-tranship/tranship checking
	
	self.chkInterModal.enabled := false;				// TFS 53084
	self.lblInterModal.enabled := false;				// TFS 53084
	
	if app.myRoot.allowTranshipInterModal then			// TFS 53084
		if firstTI &lt;&gt; null and (firstTI.isOnSite()	// TFS 53084
							or firstTI.isOnShip()) then // ### TFS BUG 61262 21NOV2023 NAVAB1
			self.chkInterModal.enabled := true;			// TFS 53084
			self.lblInterModal.enabled := true;			// TFS 53084
		endif;
	endif;
	
	/*	TFS 47222 jlgzm1 20/11/2019
	if firstTI &lt;&gt; null then
		self.chkRemStops.value := firstTI.hasStops;
	endif;
	*/
	
	if exTI &lt;&gt; null then
		self.txtBookRef.text := exTI.bookingReference;
		self.txtRemarks.text := exTI.remarksTranship;
		
		//cnwjo3 par 24781.  The cmbExpVoyage doesn't include archived or departed voyages
		//if the user attempts to set the TI to a Non-Tranship after the voyage has departed etc
		//added into the cmbExpVoyage control so exception doesn't occur
		if exTI.myVoyageTranshipExport &lt;&gt; null and self.cmbExpVoyage.findObject(exTI.myVoyageTranshipExport) &lt; 1  then
			str := exTI.myVoyageTranshipExport.code &amp; Tab &amp; exTI.myVoyageTranshipExport.description;
			self.cmbExpVoyage.itemObject[self.cmbExpVoyage.addItem(str)] := exTI.myVoyageTranshipExport;
			self.cmbExpVoyage.listObject := exTI.myVoyageTranshipExport;
		endif;
		
		self.cmbExpVoyage.listObject := exTI.myVoyageTranshipExport;		
		self.cmbDestPort.setObjectFromCode(exTI.destinationPort);	// PAR #23889 CCMS 1116
		self.cmbTShipPort.setObject(exTI.myTranshipToPort);			// PAR #23889 CCMS 1116
		self.txtRemarks.text := exTI.remarks;						// PAR #23889 CCMS 1116
	endif;
	
	self.cmbExpVoyage.setFocus();
	self.cmbIMEXStatus.setInitialised(true);
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="41e6eb04-18c1-4a20-ab25-59a7dbf4943a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 05 May 2022 08:08:26.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008216, locale);
	lblBOL.translateCaption(Xlat_0016232, locale);
	lblBookRef.translateCaption(Xlat_0001082, locale);
//	lblCommodity.translateCaption(Xlat_0001077, locale);
	lblDestPort.translateCaption(Xlat_0015084, locale);
	lblDiscPort.translateCaption(Xlat_0001080, locale);
	lblExpVoyage.translateCaption(Xlat_0001078, locale);
	lblIMEXStatus.translateCaption(Xlat_0016233, locale);
//	lblISOType.translateCaption(Xlat_0001083, locale);
	lblInterModal.translateCaption(Xlat_0024645, locale);
	lblNonRemarks.translateCaption(Xlat_0016234, locale);
 //	lblRemStops.translateCaption(Xlat_0001081, locale);
	lblRemarks.translateCaption(Xlat_0001084, locale);
	lblTShipPort.translateCaption(Xlat_0015085, locale);
	shtDetails.translateCaption(Xlat_0001085, locale);
	shtNonDetails.translateCaption(Xlat_0016235, locale);
end;</source>
    </JadeMethod>
