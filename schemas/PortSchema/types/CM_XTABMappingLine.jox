    <JadeMethod name="cloneSelf" id="06847427-3a74-4145-8f4e-65323fc8b1c1">
        <source>cloneSelf(_transient: Boolean): SelfType;
// ---------------------------------------------------------------------------
// Created:     16 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	clone	:SelfType;
begin
	clone := inheritMethod(_transient);
	
	if self.myQueryOperator &lt;&gt; null then
		clone.myQueryOperator := self.myQueryOperator.cloneSelf (_transient); //TFS 7528 only does primitives
		self.myQueryOperator.cloneReferences(clone.myQueryOperator); // TFS 7528
	endif;
	
	return clone;
epilog

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
