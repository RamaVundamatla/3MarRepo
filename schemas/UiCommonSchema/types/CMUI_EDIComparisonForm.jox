        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_mouseUp(table: CM_DataTable input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Date		Who		Reason
09 March 2017	cnwer1	Initial creation TFS

*/

vars
	col : Integer;
begin
	self.doTblData_mouseDown (table);
	
	if self.isEditMode then 
		col	:= table.getColumnByRowName(ETRow_HasChanged);
		if col &gt; 0 then
			table.accessCell(table.row, col).text := CMUI_EDIForm.HAS_CHANGED;			
		endif;	
	endif;
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
