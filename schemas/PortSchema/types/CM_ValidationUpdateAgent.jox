vars

begin

	self.raiseExceptionIfNull(_proxyCellDefn, 'CellDefn Proxy');
	self.raiseExceptionIfNull(_existingCellDefn, "CellDefn Existing");
	_proxyCellDefn.raiseExceptionIfNotProxy(method);
	if _existingCellDefn.id = _proxyCellDefn.id then
