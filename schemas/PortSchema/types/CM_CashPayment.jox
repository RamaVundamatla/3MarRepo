    <JadeMethod name="validateMe" id="93179083-84ff-4bc0-8c10-48c1aef67faf">
        <source>validateMe();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18/07/2012	cnwndl1	Initial creation
02/11/2015	cnwdap1	PAR #36909 CCMS ADP 2537 Minimum Charges
*/

vars

begin
	if self.cashValue = 0 and self.myCashPaymentForInvoice = null then		// 22/11/17 MAP TFS7357 zero cash payment for tax is permissable
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Cash_value), null, null); // cnwdb2	PAR 35364
	endif;
	if not self.dateTime.Date.isValid then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Transaction_date), null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myUser = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(User), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(User), null, null); // cnwdb2	PAR 35364
	endif;
	
	
	//if self.isProformaPayment and self.myTrackedItem = null then									// PAR #36909
	if self.isProformaPayment then // TFS 37454
		if not self.myProformaDetail &lt;&gt; null and //08/10/2024	navkc1	CR 33025
		not self.myProformaDetail.myInvoiceLineType.isVoyageCalcTypeForProforma() 
		and not self.isProformaForWorkOrder() then // TFS 39236
			if self.myTrackedItem = null and not self.isMinimumCharge then		// PAR #36909
			//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Cargo_ID), null, null);
				app.raiseCMException1(Input_required_field_Required, app.getErrorString(Cargo_ID), null, null);// cnwdb2	PAR 35364
			endif;
		endif;
	endif;
	
	if self.myDebtorTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Debtor_GC), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Debtor_GC), null, null); // cnwdb2	PAR 35364
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="voided" id="13d92007-4427-4084-9717-1ba878f532fb">
        <methodInvocation>mapping</methodInvocation>
        <source>voided(set : Boolean; _value : Boolean io) mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2012	cnwndl1	Initial creation	Par 29968
2/12/2014	cnwjre1	Use its own 'status' as well as the invoice status
12/07/2019	jlgdi1	TFS 45301 Used CM_CashPayments.Status_Void instead of CM_InvoiceLine.STATUS_VOIDED
					Returns true if the status is equal to Status_Merged
*/

begin
	if not set then
		if ((self.myInvoice &lt;&gt; null) and (self.myInvoice.isVoided)) or 
		   (self.status = CM_CashPayment.Status_Void) or 
		   (self.status = CM_CashPayment.Status_Merged) 
		then
			_value := true; // TFS 45301
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
</Class>
