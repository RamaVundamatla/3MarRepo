<Class name="CM_MessageUser" id="6a222da0-9942-417f-a2fd-ce7f787ee84a">
    <superclass name="CM_Message"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <PrimAttribute name="userCode" id="a355f67a-dd65-41cb-9bdf-bf96136dd5b5">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>
The userCode of the user who created the message</text>
    </PrimAttribute>
    <JadeMethod name="getInfoTableString" id="eae635a7-4b6d-4490-ba8d-a6beb7d39b9d">
        <source>getInfoTableString(): String;
//----------------------------------------------------------------
//	Created:	12 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	return self.createdDateTime.shortCurrentLocaleFormat &amp; Tab &amp; self.userCode &amp; Tab &amp; self.heading &amp; Tab &amp; self.text;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="115e23ba-f0d9-424f-a782-ba65dd80eee1">
        <updating/>
        <source>setForCreate(_heading: String; _text: String; _users: Collection; _deleteWhenAllRead: Boolean; _expiryDT: TimeStamp; _userCode: String) updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.userCode := _userCode;
	self.setForCreateSuperClass(_heading, _text, _users, _deleteWhenAllRead, _expiryDT);

end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_users" type="Collection"/>
        <Parameter name="_deleteWhenAllRead" type="Boolean"/>
        <Parameter name="_expiryDT" type="TimeStamp"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromProxy" id="b51dabbf-03a1-4550-8ad6-d58ec3534afd">
        <updating/>
        <source>setForCreateFromProxy(_pxyMessageUser: CM_MessageUser) updating;
//----------------------------------------------------------------
//	Created:	10 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin


	inheritMethod(_pxyMessageUser);
	
	self.userCode := _pxyMessageUser.userCode;
	
	self.myRoot := null;
	
end;</source>
        <Parameter name="_pxyMessageUser" type="CM_MessageUser"/>
    </JadeMethod>
</Class>
