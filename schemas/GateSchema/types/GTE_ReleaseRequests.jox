    <JadeMethod name="showHideSearcher" id="b27a6ee6-4ef9-4008-962f-84e31ff7dda2">
        <source>showHideSearcher();
/*
----------   ----------  --------------------------------------------------
Created:	31 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.frmSearch.visible then
		self.frmSearch.visible := false;
		self.frmMain.enabled := true;
		self.frmToolbar.enabled := true;
		self.btnSearch.default := false;
		self.lstTree.setFocus();
	else
		
		self.frmMain.enabled := false;
		self.frmSearch.visible := true;
		self.frmSearch.zOrder(1);
		self.frmToolbar.enabled := false;
		self.txtReleaseNo.setFocus();
		self.btnSearch.default := true;
	endif;
	

end;


</source>
    </JadeMethod>
    <JadeMethod name="showTISearcher" id="1f2637be-8ccd-4dc1-9123-faa0a7c02b85">
        <updating/>
        <source>showTISearcher() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 June 2007 By cnwth2

Purpose:	displays what was previously shown from the old release requests screen non-modal
			Even this is a lame searcher screen with limited options (and you can drag-drop 
			from anywhere else you like), the users requested it remain because it's small has
			exactly the search criteria the require.
			
			

/* Changes

Date		Name	TFS#			Description
============================================================================
16/12/2009	cnwmh5	PAR #21921  	Change checkISOGroup to myISOTypeGroup
01/04/2010	cnwdap1	PAR #23347 		set up availability grades if necessary
24/01/2019	jlgka1	TFS 41708		Populate myBOLIn with the Release Request
									myBOLIn.
============================================================================*/
vars
	
	tiFrm				: GTE_TrackedItems;
	isoType     		: CM_ISOType;
	operator    		: CM_Operator;
	operGroup			: CM_OperatorGroup;
	filterAvGrade 		: CM_MTGrade;
	br					: CM_BulkRelease;
	reserveDetail		: CM_ReserveDetail;
	lstObject			: Object;
	parentIdx 			: Integer;
begin
	/* th2 PAR 14758 - always display new
	tiFrm := app.getForm(GTE_TrackedItems.name).GTE_TrackedItems;
	if tiFrm &lt;&gt; null then
		tiFrm.zOrder(1);
		tiFrm.setFocus();
		return;
	endif;
	*/
	tiFrm := self.myAddItemsForm;
	if tiFrm = null or (not app.isValidObject(tiFrm)) then
		tiFrm := app.loadForm(GTE_TrackedItems,GTE_Assistant,false,false,false,
	                      self.myTerminal, self.myMasterMenuAction).GTE_TrackedItems;
	endif;
	
	if tiFrm = null then
		return;
	endif;
	
	tiFrm.myParentForm := self;
	self.myAddItemsForm := tiFrm;
	self.saveUserEntry();
	br := self.myMasterProxyObject.CM_BulkRelease;
	if br.releaseByType then
		//	reserveDetail := br.allReserveDetails.first;                  Par 16947 AER 21/07/2008
		if CM_ReserveSelection.hasInstance(self.lstTree.listObject) then
			reserveDetail := self.lstTree.listObject.CM_ReserveSelection;
		elseif CM_BulkRelease.hasInstance(self.lstTree.listObject) then
			if (br.allReserveDetails.size + br.allReservePackingChildren.size) &gt; 1 then
				app.msgBox(app.getErrorString(Select_Request_Line), app.getErrorString(ERR_RequestLineNotSelected), MsgBox_Exclamation_Mark_Icon);// AER 07/08/09
				return;
			elseif (br.allReserveDetails.size + br.allReservePackingChildren.size) = 0 then
				app.msgBox(app.getErrorString(No_Request_Line),app.getErrorString(NO_Request_Lines), MsgBox_Exclamation_Mark_Icon);// AER 07/08/09
				return;
			else // ther is at list one reserve, so use that
				if br.allReserveDetails.first &lt;&gt; null then
					reserveDetail := br.allReserveDetails.first;
				else
					reserveDetail := br.allReservePackingChildren.first;
				endif;
			endif;
		endif;
		if CM_ReserveSelection.hasInstance(reserveDetail) then
			tiFrm.myISOType  		:= reserveDetail.CM_ReserveSelection.myISOType;
			///tiFrm.checkISOGroup 	:= reserveDetail.CM_ReserveSelection.doISOGroupCheck;	// 16/12/2009 cnwmh5 #21921
			tiFrm.myISOGroup		:= reserveDetail.CM_ReserveSelection.getISOGroup;			// 16/12/2009 cnwmh5 #21921
			tiFrm.myCargoType 		:= reserveDetail.CM_ReserveSelection.myCargoType;
			tiFrm.filterMark		:= reserveDetail.CM_ReserveSelection.markSelection;	//28 Aug 2019	NDL	TFS 46118
		endif;
	else
		//epr par 35154 can now click + to add ti
		lstObject:= lstTree.listObject ;
		if lstObject = null then
			parentIdx:=lstTree.getParentRow(lstTree.listIndex);
			if parentIdx &gt; 0 then
				lstObject:=self.lstTree.itemObject[parentIdx];
			endif;
		endif;
			
		if lstObject &lt;&gt; null then
			if lstObject.isKindOf(CM_Product) then
				tiFrm.myCargoType:=lstObject.CM_Product.myCargoType;
			elseif lstObject.isKindOf(CM_CargoType) then
				tiFrm.myCargoType:=lstObject.CM_CargoType;
			elseif lstObject.isKindOf(CM_ReserveTI) then
				tiFrm.myCargoType:=lstObject.CM_ReserveTI.getCargoType;
			endif;
		endif;
	endif;
	tiFrm.isEmptyOnly 		:= not br.fullRelease;
	tiFrm.myOperator 		:= br.myOperator;
	tiFrm.isReleaseByType 	:= br.releaseByType;

	// PAR #23347 check availability grades are set up - if we've double-clicked on the release request
	// then lstMTGrade hasn't been set up
	if /*self.lstMTGrade.allSelectedObjects.isEmpty and*/ CM_ReserveSelection.hasInstance(reserveDetail) and not reserveDetail.CM_ReserveSelection.allAvailabilityGrades.isEmpty then
		// we've clicked on the bulk release line, we need to rebuild the availability grades list
		self.myAssistant.listTableMTGrade(self.lstMTGrade, br.myOperator, br.myOperatorGroup);
		self.myAssistant.setListTableMTGrade(self.lstMTGrade, reserveDetail.CM_ReserveSelection.allAvailabilityGrades);
	endif;
	// PAR #23347 end
	
	self.myAssistant.saveListTableMTGrades(self.lstMTGrade, tiFrm.allMTGrades);
	
	tiFrm.filterForCargo 	:= true;
	tiFrm.myVoyage 			:= br.myVoyage;
	tiFrm.myOperatorGroup 	:= br.myOperatorGroup;
	tiFrm.myFiltFreightFwdr := br.myFreightForwarder;
	tiFrm.myFiltConsignee	:= br.myConsignee;
	tiFrm.myBOLIn			:= br.myBOLIn; //jlgka1 TFS 417088
	
	tiFrm.allowReleaseAllocated := br.allowCargoOnMultipleReleases; //cnwrd1 par 22901 15.3.2010
	
	tiFrm.centreWindow;
	tiFrm.show;


end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showWeightOrRequested" id="b9760de2-35f5-47d6-96ca-7c7503d4e83f">
        <source>showWeightOrRequested();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
27 Feb 2025	navbs1	Bug MTN-34082: Invalid Required By Date exception when allocating the road job to gang

*/

vars
	byTypeByWeight 	: Boolean;
	table 			: CM_EntryTable;
begin
	table := self.tblEntry;
	
	if not table.isRowVisible(ETRow_ByTypeByWeight) then 		//27.02.2025 navbs1 #34082
		return;
	endif;
	
	byTypeByWeight	:= table.getValueByName(ETRow_ByTypeByWeight).Boolean;
	if 	byTypeByWeight	then
		table.hideRowByName(ETRow_TotalRequested, false);
		table.showRowByName(ETRow_WeightRequested, false);
		table.setValueByName(ETRow_DefaultAnyAmount, true);
		table.disableRowByName(ETRow_DefaultAnyAmount);
	else 
		table.showRowByName(ETRow_TotalRequested, false);
		table.hideRowByName(ETRow_WeightRequested, false);
		table.enableRowByName(ETRow_DefaultAnyAmount);
	endif;
epilog

end;</source>
    </JadeMethod>
