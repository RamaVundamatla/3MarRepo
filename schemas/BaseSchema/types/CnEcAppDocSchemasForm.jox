<GUIClass name="CnEcAppDocSchemasForm" id="24a21e63-758c-4b2f-8a2a-0c2935b1e013">
    <superclass name="CnEcAppDocForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="aAllSelectedSchemas" id="d7a17edc-1ea1-45ee-aa0a-0e94a02a82ea">
        <memberTypeInverse/>
        <type name="SchemaColl"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnCancel" id="5a8f5d86-d6eb-4567-afcd-1bc43d6d866b">
        <embedded/>
        <type name="CnEcMask"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnOk" id="34e21f7d-09d5-45bb-b08a-991b2cb2f9ed">
        <embedded/>
        <type name="CnEcMask"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="chkIncludeSubs" id="25cea01b-b01f-4355-b61d-725f8f55bbfe">
        <embedded/>
        <type name="CnEcCheckBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lstSchemas" id="33c917b8-fe1f-4004-8983-e5db4e7374aa">
        <embedded/>
        <type name="CnEcListBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnCancel_click" id="1a7e710c-0e3a-41b4-a747-1dac48975a58">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="fd76d8f7-88a7-4bc4-a21f-cdbf00c835fd">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.doFormUpdate() then
		self.modalResult	:=	self.CNEC_MODAL_SELECT;
		self.unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="6700d377-4c6a-47d5-a14a-45a171a7838e">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.centreWindow();
	self.listPopulateSchemas();
	self.modalResult	:=	self.CNEC_MODAL_CANCEL;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="38cb77fb-d7c4-4da2-9c73-af6f5955a111">
        <updating/>
        <source>doFormUpdate(): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj		: ListBox;
	rowPointer		: Integer;
	schemaObj		: Schema;
	allSubschemas	: SchemaColl;
	
begin
	if not self.doFormValidate() then
		return false;
	endif;
	
	listboxObj	:=	lstSchemas;
	rowPointer	:=	listboxObj.listIndex;
	schemaObj	:=	listboxObj.itemObject[rowPointer].Schema;
	self.aAllSelectedSchemas.add(schemaObj);
	
	if chkIncludeSubs.value then
		create allSubschemas transient;
		schemaObj.allSubschemas(allSubschemas);
		allSubschemas.copy(self.aAllSelectedSchemas);
	endif;
	
	return inheritMethod();
epilog
	delete allSubschemas;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFormValidate" id="5845e8ae-08e5-4f87-9b7a-65d3ec1cfee0">
        <updating/>
        <source>doFormValidate(): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj	: ListBox;
	rowPointer	: Integer;
	
begin
	listboxObj	:=	lstSchemas;
	rowPointer	:=	listboxObj.listIndex;
	
	if rowPointer = CNEC_NULL_INDEX then
		self.errorAdd("Please select a schema to add.");
		return false;
	endif;
	
	return inheritMethod();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listPopulateSchemas" id="4789066f-576e-4fc1-bd39-a5c4226c2f63">
        <source>listPopulateSchemas() protected;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Purpose:		Populates the listbox with an hierarchy of Schemas.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj			: ListBox;
	schemaObj			: Schema;
	allSubschemasObj	: SchemaNDict;
	rowPointer			: Integer;
	
begin
	listboxObj	:=	lstSchemas;
	create allSubschemasObj transient;
	rootSchema.getSubschemas(allSubschemasObj);// allSubschemas(allSubschemasObj);
	
	foreach schemaObj in allSubschemasObj do
		rowPointer	:=	listboxObj.addItem(schemaObj.name);
		listboxObj.itemObject[rowPointer]	:=	schemaObj;
		
		self.listPopulateSubSchemas(schemaObj, listboxObj, 2);
	endforeach;
epilog
	delete allSubschemasObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="listPopulateSubSchemas" id="53b09f45-dfc0-45b1-9de5-d22341e7d908">
        <source>listPopulateSubSchemas(pSchemaObj:Schema; pListboxObj:ListBox input; pLevel:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Purpose:		Populates the subschemas of the specified Schema into the listbox
//				hierarchy.
//
// Parameters:	pSchemaObj - A reference to the Schema who's subclasses to list.
//				pListboxObj - A reference to the listbox control to populate.
//				pLevel - The hierarchy level at which to populate the schemas.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	schemaObj			: Schema;
	allSubschemasObj	: SchemaNDict;
	rowPointer			: Integer;
	
begin
	create allSubschemasObj transient;
	pSchemaObj.getSubschemas(allSubschemasObj);
	
	foreach schemaObj in allSubschemasObj do
		rowPointer	:=	pListboxObj.addItem(schemaObj.name);
		pListboxObj.itemObject[rowPointer]	:=	schemaObj;
		pListboxObj.itemLevel[rowPointer]	:=	pLevel;
		
		self.listPopulateSubSchemas(schemaObj, pListboxObj, pLevel + 1);
	endforeach;
epilog
	delete allSubschemasObj;
end;</source>
        <access>protected</access>
        <Parameter name="pSchemaObj" type="Schema"/>
        <Parameter name="pListboxObj" type="ListBox" usage="input"/>
        <Parameter name="pLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lstSchemas_pictureClick" id="8317b13a-5f9c-4235-b68d-19d2e2e39ba2">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSchemas_pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		22 March 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	listbox.itemExpanded[picIndex]	:=	not listbox.itemExpanded[picIndex];
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
</GUIClass>
