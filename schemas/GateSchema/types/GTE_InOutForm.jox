    <JadeMethod name="txtBookingRef_lostFocus" id="24843631-cdf3-4652-8fff-1fe07b2efdc7">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtBookingRef_lostFocus(textbox: GTE_TextBox input) updating;
// ---------------------------------------------------------------------------
// Created:     26 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	30.6.2008	cnwrd1		par #17206
//	22.9.2016	cnwdap1		TFS 2651 - new parameters for getBookingRefFromCode method
// ---------------------------------------------------------------------------
vars
	txtStr				: String;
	tmpBookingRefItem	: CM_BookingRefItem;
	setItem 			: Boolean;
	sheet 				: GTE_Sheet;
	cmbItem             : CMUI_ComboBoxBookRefItem;
	comboProduct 		: CMUI_ComboProduct;
	comboOperator 		: CMUI_ComboOperator;
begin
	sheet := self.topSheet;
	txtStr := textbox.text;	
	if sheet = null then  // cnwrd1 30.6.2008 par #17206 
		return;
	endif;
	
	//6/11/2009 cnwdz2 par20850
	if sheet &lt;&gt; textbox.mySheet then
		return;
	endif;
	
	cmbItem := sheet.getControlByName(self.cmbBRItem.name).CMUI_ComboBoxBookRefItem;
	
	//epr par 19025 5/3/09 added to show this when no br item selected
	if (txtStr &lt;&gt; self.origValueStr or cmbItem.listIndex &lt; 0)  and txtStr &lt;&gt; null then
		// need to set values from booking ref if it exists
		//tmpBookingRefItem := self.myAssistant.getBookingRefFromCode(txtStr); // AER for Nelson 04/03/08	// TFS 2651
		tmpBookingRefItem := self.myAssistant.getBookingRefFromCode(txtStr, false).CM_BookingRefItem; 		// TFS 2651
		
		if tmpBookingRefItem &lt;&gt; null then									// AER for Nelson 04/03/08
			sheet.myMenuAction.myObject := tmpBookingRefItem;	// Par17524		14 July 2008
			//self.setValuesFromBookingRef(tmpBookingRef, textbox.mySheet);
			self.setDefaultsFromObject(textbox.mySheet, tmpBookingRefItem.CM_BookingRefItem); // AER for Nelson 04/03/08
			self.loadBookingRefItems(tmpBookingRefItem.myBookingReference, tmpBookingRefItem);	// AER for Nelson 04/03/08
			self.myAssistant.GTE_Assistant.mainExtraSetValue(tblMain, tblExtra, ETRow_MyBookingRefItem, tmpBookingRefItem.getShortDisplay);
		else
			cmbItem.clear;	// AER for Nelson 04/03/08
			cmbItem.lostFocus(cmbItem);
		endif;
	endif;
	
	//par 17383 cnwjo3
	comboProduct := self.getTopSheetControl(GTE_InOutForm::cmbProduct.name).CMUI_ComboProduct;  //cnwjo3
	comboOperator := self.getTopSheetControl(GTE_InOutForm::cmbOperator.name).CMUI_ComboOperator;
	if comboProduct &lt;&gt; null then
		comboProduct.setCargoType(textbox.mySheet.getCargoType()); //cnwjo3
		comboProduct.setOperator(comboOperator.listObject.CM_Operator); //cnwjo3
		comboProduct.setObject(comboProduct.listObject.CM_Product); //cnwjo3
	endif;
	
epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="textbox" type="GTE_TextBox" usage="input"/>
    </JadeMethod>
