        <source>setMyFilterObject(_filterObject : CMQF_FilterReports) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//11/07/2024	navkc1 CR 64837 Task 64852: Jade - Cash API Binary PDF

*/

vars

begin
	self.myFilterObject := _filterObject;
epilog

