    <JadeMethod name="setProxyFromObject" id="b11bd51e-a7fc-4149-b506-faf957d19cf3">
        <updating/>
        <source>setProxyFromObject(_object: CM_RTQueueTask) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
23 May 2017	cnwer1				Initial creation TFS
01 Jun 2018 cnwma1	Bug 37930 	SPT - FW: Job ID in Web Apps - Voyages
26 Apr 2019	jlgka1	44436		PNL - Vehicle App - Target Location Error.	
27 May 2019 cnwma1	Bug 44865: 	SNO - Vehicle RT Config screen onto web apps
26 Jun 2019	jlgdap1	TFS 44620	PNL - VMT to include final (queued) location column
09 Oct 2019	jlgka1 	TFS 46449	JMT - Loadrite for the Vehicle App
10 Oct 2019	jlgzm1	TFS 46418	POL - Show Matched containers in the Vehicle Apps
15 Oct 2019	jlgdap1	TFS 47058	JMT - Add To Do Tasks field to Primary/Secondary Task Fields
25 Oct 2019	jlgdap1	TFS 47079 	PRP Release Qty Issue
07 Jul 2021	navdap1	TFS 51409 	PNL Queued jobs in Driver Mode
============================================================================*/

vars
	ti 				: CM_TrackedItem;
	twinFlag 		: Integer;
	accessDirection : Integer;
	allOStowTIs 	: CM_TIArray;
	wle 			: CM_WorkListEntry;
	request  		: CM_Request;
	cargoType 		: CM_CargoType;
	subType 		: CM_Product;
	isoType 		: CM_ISOType;
	weightType		: CM_MeasurementType;
	setdownTask, 
 	pickupTask		: CM_RTQueueTask;
	overstowedTI 	: CM_TrackedItem;
	overstownTask 	: CM_RTQueueTask;
	bulkRelease		: CM_BulkRelease;	
	twinTI			: CM_TrackedItem; 	// TFS 46418
	rtVehicleConfig : CM_RTVehicleConfig;
	locationDisplayFormat : Integer;
	interchangeSourceDisplay,
	interchangeTargetDisplay : String;
begin
	inheritMethod(_object);
//	self.id :=_object.tiId;
	self.id :=_object.getTaskId;	//29 Aug 2019	NDL	TFS 46118
	self.sourceLocationId:=_object.getSourceLocationId; //jlier1 TFS 51580 7/9/21 - issue with director tasks not just showing area &amp; row/column
	
	rtVehicleConfig:=currentSession.getMyRTVehicleConfig;
	if rtVehicleConfig &lt;&gt; null  then
		locationDisplayFormat:=rtVehicleConfig.locationDisplayFormat;
	endif;
	
	
	
	self.status:=_object.statusString;
	if _object.isPickUp then
		if _object.isOverstowTaskAuto then
			setdownTask:=_object.myEntry.getDirectorOrSetDownTask; 
			//setdownTask:=_object.myEntry.findNonOverstowTaskOfType(TASK_PICKUP);
		else
			setdownTask:=_object.myEntry.getDirectorOrSetDownTask; 
			//epr 7681 8/11/17 - the auto plan on pickup jobs from Yard Operations only create pickup tasks to my disbelief
			if setdownTask &lt;&gt; null and setdownTask.isOverstowTaskAuto then
				setdownTask:=_object.myEntry.findNonOverstowTaskOfType(TASK_PICKUP);
			endif;
		endif;
		pickupTask:=_object;
	else
		setdownTask:=	_object;
		pickupTask := _object.myEntry.getDirectorOrPickupTask;
	endif;
	
	//epr 7681 8/11/17
	if setdownTask &lt;&gt; null and _object.isPickUp then // jlgka1 TFS 44436
		self.targetLocationId:=setdownTask.getTargetLocationExtra;
	
	else
		self.targetLocationId:=_object.targetLocationId;
		if _object.isMove then
			if _object.ti &lt;&gt; null and _object.ti.myPrimaryActualLocation = currentSession.myCurrentMachine.myMachineController then
				self.canIMVComplete:=currentSession.myCurrentMachine &lt;&gt; null and currentSession.myCurrentMachine.isIMV and
							_object.queue.getLoadMachinesMode = CM_VoyageCraneQueue.ActAsShipLander and
							(_object.targetLocation &lt;&gt; null and _object.targetLocation.isKindOf(CM_VoyageController)) ;
			endif;
		endif;
		
	endif;
	// jlier1 TFS 52160 5/11/21
	if locationDisplayFormat  &lt;&gt;  CM_RTVehicleConfig.LOCVIEW_ACTUAL then
		interchangeSourceDisplay:=_object.getSourceInterchangeDisplay;
		if not _object.isSetDown then
			interchangeTargetDisplay:=_object.getTargetInterchangeDisplay;
		endif;
		if locationDisplayFormat = CM_RTVehicleConfig.LOCVIEW_IC then
			if interchangeSourceDisplay &lt;&gt; null then
				self.sourceLocationId:=interchangeSourceDisplay;
			endif;
			if interchangeTargetDisplay &lt;&gt; null then
				self.targetLocationId:=interchangeTargetDisplay;
			endif;
		elseif locationDisplayFormat = CM_RTVehicleConfig.LOCVIEW_ACTUAL_IC then
			if interchangeSourceDisplay &lt;&gt; null and  self.sourceLocationId &lt;&gt; interchangeSourceDisplay then
				self.sourceLocationId:= self.sourceLocationId &amp; "&lt;br&gt;" &amp; interchangeSourceDisplay;
			endif;
			if interchangeTargetDisplay &lt;&gt;  null and  self.targetLocationId &lt;&gt; interchangeTargetDisplay  then
				self.targetLocationId:=self.targetLocationId  &amp; "&lt;br&gt;" &amp;  interchangeTargetDisplay;
			endif;
		elseif locationDisplayFormat = CM_RTVehicleConfig.LOCVIEW_IC_ACTUAL then
			if interchangeSourceDisplay &lt;&gt; null and  self.sourceLocationId &lt;&gt; interchangeSourceDisplay then
				self.sourceLocationId:=interchangeSourceDisplay  &amp; "&lt;br&gt;"  &amp;  self.sourceLocationId;
			endif;
			if interchangeTargetDisplay &lt;&gt; null  and  self.targetLocationId &lt;&gt; interchangeTargetDisplay then
				self.targetLocationId:= interchangeTargetDisplay  &amp; "&lt;br&gt;"  &amp;  self.targetLocationId ;
			endif;
		endif;
	endif;
	
	self.taskType :=_object.taskTypeId;
	self.isOverstowMove :=_object.isOverstowTask;
	if self.isOverstowMove then
		if 	 _object.isOverstowTaskAuto then
			overstownTask:=_object.myEntry.findNonOverstowTaskOfType(TASK_PICKUP);	
		elseif _object.myEntry.myOverstowOfEntry &lt;&gt; null then
			overstownTask:=_object.myEntry.myOverstowOfEntry.getTaskOfType(TASK_PICKUP,null);		
		endif;
		if overstownTask &lt;&gt; null then
			self.overstowOfTaskOid:=overstownTask.getOidAsString;
		endif;
	endif;
	self.queueId := _object.queueId;
	
	if _object.taskType = TASK_BREAKBULK or _object.isPickUp then
	
		self.moveAmount := _object.myEntry.getAmountLeftToMoveDisplay();
	else
		self.moveAmount :=  _object.myEntry.getAmountMovedDisplay(true);
	endif;	
	
	if self.moveAmount.Integer = 0 then
		self.moveAmount :="";
	endif;

	self.doorDirection :=_object.getDoorDirection();
	twinFlag:=_object.myEntry.getTwinCarryFlag;
	if twinFlag = CM_RTQueueEntry.TWIN_NEXT then
		self.twinLift:="Next";
	elseif  twinFlag = CM_RTQueueEntry.TWIN_PREV then
		self.twinLift:= "Prev"; 
	elseif  twinFlag = CM_RTQueueEntry.TWIN_BOTH then
		self.twinLift:= "Both";
	endif;
	self.rfidNumber:=_object.getRFIDNumber();
	self.carrier:=_object.getCarrier();	
	
	wle:=_object.myEntry.myWorkListEntry;
	if wle &lt;&gt; null then
		request :=wle.myRequest;
	endif;
	weightType := app.getDefaultMeasurementForType(Type_Weight);
	ti:= _object.ti;
	if ti &lt;&gt; null then
		self.isBreakBulkByQuantity:= ti.isBulkByQuantity ;
		self.isBulkTrackedByVolume:= ti.isBulkByVolume ;
		self.isBulkTrackedByWeight:= ti.isBulkByWeight ;
		self.cargoTypeDesc:=ti.cargoTypeDescr;
		self.cargoSubTypeDesc:=ti.getCargoSubTypeDescr();
		self.commodity:=ti.commodity;
		self.dischargePortDesc:=ti.dischargePort;
		if ti.canSetAvailabilityGrade then
			self.grade:= ti.getAvailabilityGradeDesc;
		endif;
		self.isChilled:=ti.isChilled or ti.isReefer;
		self.isControlAtmosphere:=ti.isControlledAtmosphere;
		self.isDamaged:=ti.damaged;
		self.isHazardous:=ti.isHazardous;
		create allOStowTIs transient;
		ti.getAllOverstowedTIs(allOStowTIs,false,accessDirection,currentSession.myCurrentMachine);	
		overstowedTICount:=allOStowTIs.size;
		self.isOverstowed:=overstowedTICount &gt; 0;
		self.isOverDimension:=ti.isOverDimensions;
		
		if ti.isKindOf(CM_Container) then
			self.isoTypeCode:=ti.getISOType();
			self.isoGroupCode:=ti.isoTypeGroup;
		endif;
		self.operatorCode:=ti.operatorCode;
		self.remarks:=ti.remarks;
		self.voyageCode:=ti.voyageCode;
		self.tempC := ti.getTemperature();
				
		if ti.displayTempFahrenheit then 
			self.tempF := ti.temperatureInFahrenheit;
		endif;	
		self.totalWeight :=  ti.getDefaultTotalWeightDisplay();
		self.colour := ti.getColour;	//29 Aug 2019	NDL	TFS 46118
		self.mark := ti.mark;	//29 Aug 2019	NDL	TFS 46118
		self.releaseId := ti.deliveryRelease;	//29 Aug 2019	NDL	TFS 46118
		//11 Sep 2019	NDL	TFS 46493
		if self.releaseId = null and not ti.allBulkReleasesAssigned.isEmpty then
			self.releaseId := ti.allBulkReleasesAssigned.first.code;
		endif;
		//jlgka1 TFS 46449 --&gt;
		cargoType :=  app.myRoot.getCargoTypeFromAbbrevOrDescr(ti.cargoTypeDescr);
		if cargoType &lt;&gt; null and cargoType.isWeighable and ti.hasToDoTasksWithTransClass(TRANS_TYPE_WEIGH, false) then
			self.isToBeWeighed := true;
		else
			self.isToBeWeighed := false;
		endif;
		//jlgka1 TFS 46449 &lt;--
		twinTI := ti.getTwinVoyageLoadTI();			// TFS 46418
		if twinTI &lt;&gt; null then						// TFS 46418
			self.twinLoadContainerId := twinTI.id;	// TFS 46418
		endif;
		
		self.toDoTasks := ti.getToDoTasksDisplay(ti.allToDoTasksToDo, false);		// TFS 47058
		
		self.dwellDays := ti.getDwellDays;							// TFS 51409
		self.preTripDT := ti.getPreTripDTLocalTZ().asStringJMT;		// TFS 51409
		//jlier TFS 52160 5/11/21
		if app.myPassport.myTerminal.myRTVehicleConfig &lt;&gt; null then
			self.modifiedISO:=app.myPassport.myTerminal.myRTVehicleConfig.getIsoTypeHookString(ti);
		endif;
		self.overDimensionDesc:=ti.getODDescription;
	else
		if request &lt;&gt; null then
			self.grade:=request.getAVGrade();
			self.isoTypeCode :=request.getISOType();
			self.isoGroupCode:=request.getISOGroup();
			self.operatorCode:= request.getOperatorCode();
			cargoType:= request.getCargoType;
			if cargoType &lt;&gt; null then
				self.cargoTypeDesc:= cargoType.description;
			endif;
			subType:= request.getCargoSubType;
			if subType &lt;&gt; null then
				self.cargoSubTypeDesc:= subType.description;
			endif;
			self.remarks := request.getRemarks();              //27.05.2019 cnwma1 #44865
			
			if request.isDeliveryRequest then
				self.colour := request.CM_DeliveryRequest.colour;	//29 Aug 2019	NDL	TFS 46118
				self.mark := request.CM_DeliveryRequest.mark;	//29 Aug 2019	NDL	TFS 46118
			endif;
			bulkRelease := request.myOriginatingBulkRelease;
			if bulkRelease &lt;&gt; null then
				self.releaseId := bulkRelease.code;	//29 Aug 2019	NDL	TFS 46118
			endif;
			self.isToBeWeighed := false;	//jlgka1 TFS 46449
		endif;
		
	endif;
	
	if self.isoTypeCode &lt;&gt; null then
		isoType:= app.myRoot.allISOTypes[isoTypeCode];
		if isoType &lt;&gt; null then
			if isoType.is20ftLong then
				self.info:="20'";
			elseif isoType.is30ftLong then
				self.info:="30'";
			elseif isoType.is40ftLong then
				self.info:="40'";
			elseif isoType.is45ftLong then
				self.info:="45'";
			elseif isoType.is53ftLong then
				self.info:="53'";
			endif;
		endif;
	endif;
	
	if _object.taskType = TASK_DIRECTOR and request &lt;&gt; null  then
		//epr TFS 6863 14/9/17 
		if cargoType &lt;&gt; null and  cargoType.allowDuplicates then
			self.outstandingTasks := _object.myEntry.getAmountLeftToMoveDisplay;
		else
			//self.outstandingTasks := request.myJob.getCountIncompleteWLE.String;		// TFS 47079
			self.outstandingTasks := request.myJob.getCountUnactionedWLE.String;		// TFS 47079
		endif;		
	endif;
	
	if _object.taskTypeId = "Bulk" or _object.taskTypeId = "Break-Bulk" then
		if _object.ti = null then
			self.info := "Director bulk";
		endif;
	endif;
	
	if _object.myEntry &lt;&gt; null then                      //01 Jun 2018 cnwma1	Bug 37930
		if _object.myEntry.myJob &lt;&gt; null then
			self.jobID := _object.myEntry.myJob.jobId;
		endif;
	endif;
	
	if wle &lt;&gt; null then												// TFS 44620
		self.finalTargetLocation := wle.getFinalTaskTargetLocId;	// TFS 44620
	endif;															// TFS 44620
	//jlier1 TFS 52160 5/11/21
	if app.myPassport.myTerminal.myRTVehicleConfig &lt;&gt; null then
		if pickupTask &lt;&gt; null then
			self.modifiedSource:=app.myPassport.myTerminal.myRTVehicleConfig.getLocationHookString(pickupTask,true);
		endif;
		if setdownTask &lt;&gt; null then
			self.modifiedTarget:=app.myPassport.myTerminal.myRTVehicleConfig.getLocationHookString(setdownTask,false);
		endif;
		self.modifiedDoorDir:=app.myPassport.myTerminal.myRTVehicleConfig.getDoorDirHookString(_object,_object.isPickUp);
	endif;
		
epilog
	delete allOStowTIs;
end;</source>
        <Parameter name="_object" type="CM_RTQueueTask"/>
    </JadeMethod>
</Class>
