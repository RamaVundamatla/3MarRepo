<GUIClass name="CMUI_MoveableRemarksFrame" id="16b012e8-4194-49f4-b406-699967eb765b">
    <superclass name="CMUI_MoveableFrame"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <Constant name="Close_Colour" id="1a684f64-ad6f-429c-89c2-a2d564c806e1">
        <constantUsages>
            <GlobalConstant name="DarkGray"/>
        </constantUsages>
        <source>DarkGray</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="Close_Length" id="b033ced6-79f8-44ae-a4a5-a958d93e8eef">
        <source>7</source>
        <type name="Integer"/>
    </Constant>
    <JadeMethod name="create" id="f4bc14ce-7076-4427-8ac2-82cf9d0a2839">
        <updating/>
        <source>create() updating;
/*
Date		Who		Reason
25 July 2012	cnwcs5	Initial creation - par 29124 - roro staowage advice remarks
*/
vars

begin
	self.boundaryWidth 	:= 0;
	self.borderStyle 	:= Frame.BorderStyle_Single;
	self.bevelInner 	:= Frame.Bevel_None;
	self.bevelOuter 	:= Frame.Bevel_None;	
	self.backColor		:= White;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setContents" id="690270d8-0746-4fbb-9009-8cdfa154de76">
        <updating/>
        <source>setContents(_heading, _text :String; _width, _padding :Integer)updating;
/*
Date		Who		Reason
21 Aug 2012	cnwcs5	Initial creation - par 29124:2
*/
vars
	
begin
	self.clearGraphics;
	
	self.autoRedraw	:= true;	
	self.wordWrap	:= true;
	self.width 		:= _width;
	self.height		:= self.getTextHeightForWidth(_text, _width) + 17 + _padding;
	
	self.drawFontBold		:= true;
	self.drawFontUnderline	:= true;
	
	self.drawTextIn (_heading, 1, 1, self.clientWidth, 17, self.foreColor);
	
	self.drawFontBold		:= false;
	self.drawFontUnderline	:= false;
	
	self.drawTextIn (_text, 1, 17, self.clientWidth, self.clientHeight, self.foreColor);
	
	
epilog

end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_padding" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="3514945b-63a2-46d8-999a-a1bc63c26866">
        <controlMethod name="CMUI_MoveableFrame::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
/*
Date		Who		Reason
25 Jul 2012	cnwcs5	Initial creation - par 29124
23 Aug 2012	cnwcs5	par 29124:2
*/
vars
	
begin
	inheritMethod(cntrl, persistCntrl);
	
	self.ignoreSkin	:= true;	// 29124:2
epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
