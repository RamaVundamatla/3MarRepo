    <JadeMethod name="createReport" id="7352b298-394d-44b2-9312-6e3b818e4c76">
        <updating/>
        <source>createReport(_schema : DEV_Schema; _reportType : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	ts 		: TimeStamp;
	schema	: DEV_Schema;
	
begin
	if self.myReport &lt;&gt; null and self.myReport.allSchemas.getAtKey(_schema.name) &lt;&gt; null then
		return;
	endif;

	if self.myReport = null then
		beginTransaction;
			self.myReport := create DEV_SourceCompareReport(ts, _reportType, process.getComputerName()) persistent;
			self.myReport.setRoot();
		commitTransaction;
	endif;
		
	if self.myReport.allSchemas.getAtKey(_schema.name) = null then
		beginTransaction;
			schema := create DEV_Schema(_schema.name, _schema.subSchema, _schema.otherData, _schema.documentationTextData) persistent;
			schema.setReport(self.myReport);
		commitTransaction;
	endif;
	
epilog

end;</source>
        <Parameter name="_schema" type="DEV_Schema"/>
        <Parameter name="_reportType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReport" id="4e5ce297-73db-4bc5-8210-36f00f7ddba8">
        <source>getReport() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2021	navpw1	Initial creation TFS: 52202

*/
	
begin
	if self.myReport = null then
		return "";
	endif;
	return self.myReport.getReport();
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
