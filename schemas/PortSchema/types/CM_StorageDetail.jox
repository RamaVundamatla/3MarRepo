    <JadeMethod name="setValues" id="2bf2434a-f663-4f59-9298-7f931830997b">
        <updating/>
        <source>setValues(	_chargedDaysType : Integer;
			_freeDaysType : Integer;
			_freeStorageDays : Integer;
			_config : CM_StorageConfig;
			_chargeDays : Integer;
			_priorityValue : Real;
			_stopFreeDays : Integer;
			_recievalDateRule : Integer;
			_noStorageIfNotFullyReceived : Boolean;
			_futureStorageStop : CM_StopsTable;
			_desc : String;
			_roadReceival : Integer;	// 29/05/2023	navkc1	CR 58011 Task 58012
			_shipReceival : Integer;	// 29/05/2023	navkc1	CR 58011 Task 58012
			_railReceival : Integer;	// 29/05/2023	navkc1	CR 58011 Task 58012
			_unpackReceival : Integer;	// 29/05/2023	navkc1	CR 58011 Task 58012
			_allAdditionalCalendars : CM_CalendarByCodeDict; // 30/05/2023	navkc1	CR 58013 Task 58014
			_cooFreeStorageDays : Integer;		//16/06/2023	navkc1	CR 58221 Task 58222
			_cooFreeDaysType : Integer; 	//16/06/2023	navkc1	CR 58221 Task 58222
			_includeFirstDay : Boolean;		//29/02/2023	navkc1 CR 61899 Task 61904
			_includeLastDay : Boolean		//29/02/2023	navkc1 CR 61899 Task 61904
			) updating;
// for the proxy
//21 Jul 2017	cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
// 29/05/2023	navkc1	CR 58011 Task 58012: UI - Storage Config - Storage Detail Receival Date
//30/05/2023	navkc1	CR 58013 Task 58014: UI - Storage Config - Storage Detail – Free Storage
//16/06/2023	navkc1	CR 58221 Task 58222: UI - Ownership Change Free Days
vars

begin
	self.chargedDaysType := _chargedDaysType;
	self.freeDaysType := _freeDaysType;
	self.freeStorageDays := _freeStorageDays;
	self.myStorageConfig := _config;
	self.chargeDays := _chargeDays; // PAR 36275 NEW
	self.priorityValue := _priorityValue;	//18 May 2016	NDL	TFS 1981
	self.stopCompletionFreeDays := _stopFreeDays;	// 24/08/2016 cnwjre1 TFS 2570 new option
	self.receivalDateRule :=_recievalDateRule; //epr TFS 2884 19/12/16
	self.noStorageIfNotFullyReceived:= _noStorageIfNotFullyReceived; //epr TFS 2884 19/12/16
	self.myFutureStorageStop :=_futureStorageStop; //21.07.2017 cnwma1 TFS #5409
	self.description := _desc[1:200]; // TFS 5225
	self.roadReceivalType := _roadReceival; // 29/05/2023	navkc1	CR 58011 Task 58012
	self.shipReceivalType := _shipReceival; // 29/05/2023	navkc1	CR 58011 Task 58012
	self.railReceivalType := _railReceival; // 29/05/2023	navkc1	CR 58011 Task 58012
	self.unpackReceivalType := _unpackReceival; // 29/05/2023	navkc1	CR 58011 Task 58012
	self.cooFreeDaysType := _cooFreeDaysType; //16/06/2023	navkc1	CR 58221 Task 58222
	self.cooFreeStorageDays := _cooFreeStorageDays; //16/06/2023	navkc1	CR 58221 Task 58222
	self.includeFirstDay := _includeFirstDay;	//29/02/2023	navkc1 CR 61899 Task 61904
	self.includeLastDay := _includeLastDay;	//29/02/2023	navkc1 CR 61899 Task 61904
	
	// 30/05/2023	navkc1	CR 58013 Task 58014
	if _allAdditionalCalendars &lt;&gt; null then
		_allAdditionalCalendars.copy(self.allAdditionalCalendars);
	endif;
end;
</source>
        <Parameter name="_chargedDaysType" type="Integer"/>
        <Parameter name="_freeDaysType" type="Integer"/>
        <Parameter name="_freeStorageDays" type="Integer"/>
        <Parameter name="_config" type="CM_StorageConfig"/>
        <Parameter name="_chargeDays" type="Integer"/>
        <Parameter name="_priorityValue" type="Real"/>
        <Parameter name="_stopFreeDays" type="Integer"/>
        <Parameter name="_recievalDateRule" type="Integer"/>
        <Parameter name="_noStorageIfNotFullyReceived" type="Boolean"/>
        <Parameter name="_futureStorageStop" type="CM_StopsTable"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_roadReceival" type="Integer"/>
        <Parameter name="_shipReceival" type="Integer"/>
        <Parameter name="_railReceival" type="Integer"/>
        <Parameter name="_unpackReceival" type="Integer"/>
        <Parameter name="_allAdditionalCalendars" type="CM_CalendarByCodeDict"/>
        <Parameter name="_cooFreeStorageDays" type="Integer"/>
        <Parameter name="_cooFreeDaysType" type="Integer"/>
        <Parameter name="_includeFirstDay" type="Boolean"/>
