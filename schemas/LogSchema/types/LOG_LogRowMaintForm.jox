    <JadeMethod name="tblInput1_change" id="f0f0a222-2b90-4488-be50-e45cb1bb5e76">
        <controlMethod name="CM_EntryTable::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblInput1_change(table: Table input) updating;

vars
	value1, value2 : Boolean;

begin

	value1:=	self.tblInput1.getValueByName(ETRow_MixedRow).Boolean;
	value2:=	self.tblInput1.getValueByName(ETRow_RowSplit).Boolean;

	if self.isMixedRow &lt;&gt; value1 then
		self.isMixedRow := value1;	
		if self.isMixedRow then
			setOperators();//26/08/2009 cnwdz2 PAR20519
			self.shtOne.visible := true;
			self.shtTwo.visible := true;
			self.shtThree.visible := true;
			self.shtFour.visible := true;
			self.shtFive.visible := true;
			self.shtSix.visible := true;
		else
			self.shtOne.visible := false;
			self.shtTwo.visible := false;
			self.shtThree.visible := false;
			self.shtFour.visible := false;
			self.shtFive.visible := false;
			self.shtSix.visible := false;
		endif;
		setSpecies();
		setSelected(self.myCurrentLogRestriction, false);	
		setTblInput1ViewForLogs();
	endif;
	
	if self.isRowSplit &lt;&gt; value2 then
		self.isRowSplit := value2;
		if self.myCurrentLogArea &lt;&gt; null then
			self.hideStartingLabels(self.myCurrentLogArea.isMarkedUp);
		endif;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a778bb3e-7dc0-4009-ba8d-fec4738d52fc">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006319, locale);
	btnArchive.translateBubbleHelp(Xlat_0002407, locale);
	btnArchive.translateCaption(Xlat_0002408, locale);
	shtTblInput1.translateCaption(Xlat_0002406, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateLogSpeciesSelection" id="434e00b4-acab-4b8c-a4da-6a2781393b43">
        <source>updateLogSpeciesSelection();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/08/2009	#cnwdz2	 20519
22/09/2014	cnwdap1	PAR #34908 Retain existing selection when adding a new operator
*/
vars
	coll	 : CM_CodesByCodeDict;
	code	 : CM_Code;
	codeSet	 : CM_CodeSet;
	tmpCodeGroup	: CM_CodesByCodeDict;
	logSpecies      : CM_Code;
	selectedSpecies   : CM_CodeSet;
	foundNewItem	: Boolean;
	selectedTypes	: CM_CodesByCodeDict;					// PAR #34908
begin
	create selectedSpecies transient;
	create coll transient;
	create tmpCodeGroup transient;
	create codeSet transient;
	
	foundNewItem := false;
	
	self.multiTwo.getSelected(selectedSpecies);
		
	if self.currentSelectedSpecies.size = selectedSpecies.size then
		foreach logSpecies in self.currentSelectedSpecies do
			if not selectedSpecies.includes(logSpecies) then
				foundNewItem := true;
				break;
			endif;
		endforeach;
		if not foundNewItem then
			return;	
		endif;
	endif;
		
	self.currentSelectedSpecies.clear();
	selectedSpecies.copy(self.currentSelectedSpecies);
	
	create selectedTypes transient;							// PAR #34908
	self.multiThree.getSelected(selectedTypes);				// PAR #34908
	foreach logSpecies in self.currentSelectedSpecies do
		coll.clear();
		logSpecies.CM_LogSpecies.allLogGrades.copy(coll);
		self.getAvailableCodesForRestrict(coll,codeSet);
		foreach code in coll do
			tmpCodeGroup.addNoDuplicates(code,false);
		endforeach;
	endforeach;				
	self.myViewer.setMultiGroupBox(self.multiThree, 'Grades', 'Log grades', tmpCodeGroup);
	self.multiThree.setSelected(selectedTypes);				// PAR #34908

epilog
	delete tmpCodeGroup;
	delete codeSet;
	delete coll;
	delete selectedSpecies;
	delete selectedTypes;									// PAR #34908
end;</source>
    </JadeMethod>
    <JadeMethod name="updateOperatorSelection" id="5ed67169-18e5-4bbe-a648-be915cbaabbd">
        <source>updateOperatorSelection();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/08/2009	#cnwdz2	20519
22/09/2014	cnwdap1	PAR #34908 Retain original specs if a new operator is being added
*/
vars
	operator : CM_Operator;
	coll	 : CM_CodesByCodeDict;
	code	 : CM_Code;
	codeSet	 : CM_CodeSet;
	tmpCodeGroup	: CM_CodesByCodeDict;
	selectedOperators : CM_OperatorByCodeDict;
	logSpecies      : CM_Code;
	foundNewItem	: Boolean;
	selectedSpecies		: CM_CodesByCodeDict;				// PAR #34908
	selectedTypes		: CM_CodesByCodeDict;				// PAR #34908
	selectedTreatments	: CM_CodesByCodeDict;				// PAR #34908
	selectedLengths		: CM_CodesByCodeDict;				// PAR #34908
	idx					: Integer;							// PAR #34908
begin
	create selectedOperators transient;
	create coll transient;
	create tmpCodeGroup transient;
	create codeSet transient;
	
	create selectedSpecies transient;						// PAR #34908
	create selectedTypes transient;						// PAR #34908
	create selectedTreatments transient;					// PAR #34908
	create selectedLengths transient;						// PAR #34908
	
	foundNewItem := false;
	
	self.multiOne.getSelected(selectedOperators);
		
	if self.currentSelectedOperators.size = selectedOperators.size then
		foreach operator in self.currentSelectedOperators do
			if not selectedOperators.includes(operator) then
				foundNewItem := true;
				break;
			endif;
		endforeach;
		if not foundNewItem then
			return;	
		endif;
	endif;
	
	self.currentSelectedOperators.clear();
	selectedOperators.copy(self.currentSelectedOperators);
	
	self.multiTwo.getSelected(selectedSpecies);				// PAR #34908
	foreach operator in self.currentSelectedOperators do
		// Get species for this operator.
		coll.clear();
		operator.getAllLogSpecies().copy(coll);
		self.getAvailableCodesForRestrict(coll,codeSet);
		foreach code in coll do
			tmpCodeGroup.addNoDuplicates(code,false);
		endforeach;
	endforeach;
	self.myViewer.setMultiGroupBox(self.multiTwo, 'Species', 'Log species', tmpCodeGroup);	
	self.multiTwo.setSelected(selectedSpecies);				// PAR #34908
	
	self.multiFour.getSelected(selectedTypes);				// PAR #34908
	tmpCodeGroup.clear();
	foreach operator in self.currentSelectedOperators do
		coll.clear();
		operator.getAllLogTypes().copy(coll);
		self.getAvailableCodesForRestrict(coll,codeSet);
			// check not available for entry for Types
		foreach code in coll do
			tmpCodeGroup.addNoDuplicates(code,false);
		endforeach;
	endforeach;	
	self.myViewer.setMultiGroupBox(self.multiFour, 'Types', 'Log types',tmpCodeGroup); 
	self.multiFour.setSelected(selectedTypes);				// PAR #34908
	
	self.multiFive.getSelected(selectedTreatments);			// PAR #34908
	tmpCodeGroup.clear();
	foreach operator in self.currentSelectedOperators do
		coll.clear();
		operator.getAllLogTreatments().copy(coll);
		self.getAvailableCodesForRestrict(coll,codeSet);
		// check not available for entry for Types
		foreach code in coll do
			tmpCodeGroup.addNoDuplicates(code,false);
		endforeach;
	endforeach;
	self.myViewer.setMultiGroupBox(self.multiFive, 'Treatments', 'Log treatments', tmpCodeGroup);
	self.multiFive.setSelected(selectedTreatments);			// PAR #34908
	
	self.multiSix.getSelected(selectedLengths);				// PAR #34908
	tmpCodeGroup.clear();
	foreach operator in self.currentSelectedOperators do
		coll.clear();
		operator.getAllLogLengths().copy(coll);
		self.getAvailableCodesForRestrict(coll,codeSet);
		// check not available for entry for Types
		foreach code in coll do
			tmpCodeGroup.addNoDuplicates(code,false);
		endforeach;
	endforeach;
	self.myViewer.setMultiGroupBox(self.multiSix, 'Lengths', 'Log lengths', tmpCodeGroup);
	self.multiSix.setSelected(selectedLengths);				// PAR #34908
		
epilog
	delete tmpCodeGroup;
	delete codeSet;
	delete coll;
	delete selectedOperators;
	delete selectedSpecies;									// PAR #34908
	delete selectedTypes;									// PAR #34908
	delete selectedTreatments;								// PAR #34908
	delete selectedLengths;									// PAR #34908
end;</source>
    </JadeMethod>
    <JadeMethod name="updateSheetsSelection" id="a4d70eef-e1a5-4edf-b4fb-33829f88c79c">
        <source>updateSheetsSelection();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	#cnwdz2	 20519

*/

vars
begin
	if self.fldInput.topSheet = self.shtOne then
		self.updateOperatorSelection();
	endif;	
	
	if self.fldInput.topSheet = self.shtTwo then
		self.updateLogSpeciesSelection();
	endif;

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="zDoSearch" id="979a3cdf-89aa-4b45-a10a-3633939b5761">
        <updating/>
        <source>zDoSearch() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2011	cnwndl1	Initial creation	Par 27176	/ CCMS 1117

*/

vars

begin

	inheritMethod();
	
	if self.tblData.rows &gt; self.tblData.fixedRows then
		self.zHideSearcher();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
