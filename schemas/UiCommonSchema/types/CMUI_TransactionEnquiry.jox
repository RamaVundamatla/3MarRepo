    <JadeMethod name="initFromUserWindow" id="8ef151aa-92d5-485d-ac00-8cbb17343a08">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars

	tmpTypeStr : String;
begin

	inheritMethod(_userWindow);
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblTrans.name);
	self.xmlStrTblTrans := tmpTypeStr.trimCharacters(CrLf);
