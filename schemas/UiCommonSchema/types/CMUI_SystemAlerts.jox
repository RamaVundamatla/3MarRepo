    <JadeMethod name="getXMLSettingsForSave" id="70610175-1e3f-45cc-b9b7-33c5b227097c">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:     16 December 2010 by cnwcs5 ccms mes 1112 / par 24464 (7.9.1 only)
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/03/2015	cnwmh5		Transient Leak
// ---------------------------------------------------------------------------
vars
	xml, str	:String;
	array		:StringArray;
	
begin
	xml :=  inheritMethod();

	create array transient;
