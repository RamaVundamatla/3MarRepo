    </JadeMethod>
    <JadeMethod name="getAllOperators" id="9c5f0da5-ba1e-4437-8e42-dc35059cc5bc">
        <source>getAllOperators(_operDict : CM_OperatorByCodeDict input);
//--------------------------------------------------
// Created:	12 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	debtor : CM_LineGroupDebtor;
begin
	if _operDict = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _operDict passed ot method');
		return;	
	endif;
	
	foreach debtor in self.lineGroupDebtors do
		if debtor.debtor &lt;&gt; null then
			debtor.debtor.getAllOperators(_operDict);
		endif;
	endforeach;
end;</source>
        <Parameter name="_operDict" type="CM_OperatorByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="8c2bada5-bb67-4998-8a40-50f54502b4ee">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	if _short then
		return self.code;
	else
		return '('&amp;self.code&amp;')  '&amp;self.description;
	endif;

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="identity" id="abf43326-e03b-4810-bd5b-f007295e332b">
