        <source>doOpenMoveCargoFromJobForm(menuItem : MenuItem input);
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		This method will open CMUI_SplitOrTransWorkCraneForm.
//				CCMS 1178 PAR 23366
//
