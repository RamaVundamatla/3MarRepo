<Class name="CMIF_HireTransController" id="accc5382-1b08-4fde-9f25-41919f78b402">
    <superclass name="CMIF_TITransactionController"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
