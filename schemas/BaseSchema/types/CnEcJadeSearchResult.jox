    <JadeMethod name="getOwnershipPath" id="268c0d00-3184-440a-85c1-47c88ff35d6e">
        <source>getOwnershipPath():String;
// --------------------------------------------------------------------------------
// Created:		23 April 2009 by cnwdad1
//
// Purpose:		Returns the path name of the receiver's ownership, e.g. if the object
//				is a property called "surname" on the class User, then this method
//				would return "User::surname".
//
// Parameters:	None
//
// Returns:		The receiver's path name.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	pathName	: String;
	theObject	: Object;
	typeObj		: Type;
	
begin
	theObject	:=	self.myObject;
	
	if theObject.isKindOf(Schema) then
		return theObject.getName();
		
	elseif theObject.isKindOf(Class) then
		return theObject.Class.schema.name &amp; "::" &amp; theObject.getName();
		
	elseif theObject.isKindOf(PrimType) then
		return theObject.PrimType.schema.name &amp; "::" &amp; theObject.getName();
		
	elseif theObject.isKindOf(Method) then
		typeObj	:=	theObject.Method.schemaType;
		return typeObj.schema.name &amp; "::" &amp; typeObj.name &amp; "::" &amp; theObject.getName();
		
	elseif theObject.isKindOf(Property) then
		typeObj	:=	theObject.Property.schemaType;
		return typeObj.schema.name &amp; "::" &amp; typeObj.name &amp; "::" &amp; theObject.getName();
		
	elseif theObject.isKindOf(Constant) then
		if theObject.isKindOf(GlobalConstant) then
			return theObject.GlobalConstant.getSchema().name &amp; "::" &amp; theObject.class.name &amp; "::" &amp; theObject.getName();
			
		elseif theObject.isKindOf(TranslatableString) then
			return theObject.TranslatableString.locale.cnEcGetSchema().name &amp; "::" &amp; theObject.class.name &amp; "::" &amp; theObject.getName();
		
		else
			typeObj	:=	theObject.Constant.schemaType;
			return typeObj.schema.name &amp; "::" &amp; typeObj.class.name &amp; "::" &amp; theObject.getName();
		endif;
	endif;
	
	return pathName;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="c1f83d1e-2ffa-4453-87ca-f2ea1e4e7dce">
        <updating/>
        <source>updateMe(pObject:Object; pResultPos:Integer; pIsText:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		Updates the receiver's properties.
//
// Parameters:	pObject - A reference to the object which yielded the search result.
//				pResultPos - The position at which the result was founf.
//				pIsText - True if the receiver's text is where the result was found.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myObject	:=	pObject;
	self.resultPos	:=	pResultPos;
	self.isText		:=	pIsText;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pResultPos" type="Integer"/>
        <Parameter name="pIsText" type="Boolean"/>
    </JadeMethod>
</Class>
