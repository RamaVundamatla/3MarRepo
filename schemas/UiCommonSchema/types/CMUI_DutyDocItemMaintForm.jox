    <JadeMethod name="populateCmbCurrency" id="20950b92-5f83-4f6b-a681-46386d0f8169">
        <source>populateCmbCurrency();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	exchange : CM_DutyDocExchangeRate;
	iter : Iterator;
	index : Integer;

begin

	self.cmbCurrency.clear();
	
	iter := app.myDutyDocRoot.allDutyDocExchangeRates.createIterator;
	while iter.next( exchange ) do
		index := self.cmbCurrency.addItem( exchange.code );
		self.cmbCurrency.itemObject[index] := exchange;
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbHSCode" id="d76162eb-1638-4bab-8a9f-32bc69122ec4">
        <source>populateCmbHSCode();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2013	cnwer1	Initial creation HAT 2189

*/

vars
	hsCode : CM_DutyDocHSCode;
	iter : Iterator;
begin
	self.cmbHSCodeCode.clear();
	
	iter := app.myDutyDocRoot.allDutyDocHSCodes.createIterator;
	while iter.next(hsCode ) do
		self.cmbHSCodeCode.addItemObject(hsCode.code.asStringJMT &amp; " - " &amp; hsCode.longDescription,hsCode );
	endwhile;

epilog

	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbOrigin" id="9dd1f1e9-163c-4f98-a8eb-ef5b5e9b8610">
        <source>populateCmbOrigin();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2013	cnwndl1	Initial creation	Par 32305

*/

vars

	country : CM_Country;
	iter : Iterator;
	index : Integer;

begin

	self.cmbOrigin.clear();
	
	iter := app.myRoot.allCountries.createIterator;
	while iter.next( country ) do
		index := self.cmbOrigin.addItem( country.isoCode3 &amp; " - " &amp; country.description );
		//index := self.cmbOrigin.addItem( country.getCodeISO3 );
		self.cmbOrigin.itemObject[index] := country;
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbPacking" id="482c18a5-661b-4796-b596-7a5ce0271779">
        <source>populateCmbPacking();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	index : Integer;
	item: String;
	agent: CM_DutyDocAgent;
	packingCodes: StringArray;
begin
	create agent transient;
	create packingCodes transient;
	agent.getAllPackingText(packingCodes);
	self.cmbPacking.clear();
	
	foreach item in packingCodes do
		index := self.cmbPacking.addItem( item );
	endforeach;

epilog
	delete agent;
	delete packingCodes;
end;</source>
    </JadeMethod>
