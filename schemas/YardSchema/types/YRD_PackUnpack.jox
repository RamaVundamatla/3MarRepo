    <JadeMethod name="disarmNotesForObject" id="09cd99b3-fea9-4524-a5bd-65f330d95a27">
        <source>disarmNotesForObject(_obj : Object) protected;

/*

Purpose:			Unregister for notes to the passed in object

Parameters:			Object to end notes for

Return Value:		None


Date		Who		Reason
06 Jul 2010	cnwkpd1	PAR #24795 - Tidy up notifications and performance of Pack/Unpack

*/

vars
	ti				: CM_TrackedItem;
	
begin
	// excp handler added Mar 2012 from 28474 testing
	on SystemException do app.handleEndNotification1066( exception );

	self.endNotification(_obj, Any_System_Event);
	if _obj.isKindOf(CM_TrackedItem) then
		ti := _obj.CM_TrackedItem;
		if self.allNotifiedTIs.includes(ti) then
			self.allNotifiedTIs.remove(ti);
		endif;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="disarmNotesForTableObjects" id="8cc8567a-8c83-4b2e-8120-9f6586f386bb">
        <source>disarmNotesForTableObjects( _tbl : CM_DataTable input) protected;

/*

Purpose:			Deregister for notes for all the objects in the passed in table
					(because we are about to clear it out)

Parameters:			Table containing notified objects

Return Value:		None


Date		Who		Reason
06 Jul 2010	cnwkpd1	PAR #24795 - Tidy up notifications and performance of Pack/Unpack

*/

vars
	row				: Integer;
	obj				: Object;
	
begin
	foreach row in _tbl.fixedRows + 1 to _tbl.rows do
		obj := _tbl.accessRow(row).itemObject;
		if obj &lt;&gt; null then
			self.disarmNotesForObject(obj);
		endif;
	endforeach;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayInitialisationTIs" id="58a59909-105b-4f4d-a853-cfa25e178f6d">
        <source>displayInitialisationTIs();
// -----------------------------------------------------------------------------
// Created:		24 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 24/07/2009	consw1		PAR 20335 - SFW1075 To Do Task Scheduling
// 14 Mar 2011	cnwkpd1	PAR #27142 - Correct handleDeletedObject exception arming
// -----------------------------------------------------------------------------

vars
	invalidTI	: Boolean;
	includeTI	: Boolean;
	reason		: String;
	ti : CM_TrackedItem;
	release		: CM_BulkRelease;
	reserve		: CM_ReserveDetail;
	
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidTI);

	// 37288 TFS 1199 optional filtering of to-be packed cargo
	if self.chbFilter.value then
		release := self.cmbBR.listObject.CM_BulkRelease;
	endif;
	self.allQryTis.clear();

	foreach ti in self.allInitialisationTIs do
		invalidTI := false;
		if ti.myParent = null then
			includeTI := true;
			if release &lt;&gt; null then				// 37288 TFS 1199 filtering of to-be packed cargo
				includeTI := false;
				foreach reserve in release.allReservePackingChildren do		// check child details
					if not reserve.isKindOf( CM_ReserveSelection ) then
						continue;
					endif;
					if release.allTrackedItemsReleased.includes(ti) then
						continue;
					endif;
					// see if this cargo matches any reserve selection, so would be a candidate for packing
					if ti.testAgainstReserveSelection( reserve.CM_ReserveSelection, reason, true, null ) then
						includeTI := true;
						break;
					endif;
				endforeach;
			endif;
			if includeTI then
				self.allQryTis.add(ti);
				self.addTblDataRow(null, ti, self.tblUnpacked);
			endif;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayPackedItems" id="255ad1cd-9949-42a5-aa26-53e01554fac8">
        <updating/>
        <source>displayPackedItems() updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
/*

Date		Who		Reason
06 Jul 2010	cnwkpd1	PAR #24795 - Tidy up notifications and performance of Pack/Unpack

*/

vars
	theTIs 			: CM_TIArray;
	theTI 			: CM_TrackedItem;
	idx 			: Integer;
//	theDataLine 	: String;
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	self.disarmNotesForTableObjects(self.tblPacked);	// PAR #24795
	self.tblPacked.rows := self.tblPacked.fixedRows;
	//create children transient;//PAR 22954
	//self.myTI.getAllChildren(children);//PAR 22954
	//foreach theTI in children do
	foreach theTI in self.myTI.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		//theDataLine := theTI.getAttributeStringForDefArray(self.tblUnpacked.allTblDataEntRows);
		//idx := self.tblPacked.addItem(theDataLine);
		//self.tblPacked.accessRow(idx).itemObject := theTI;
		self.addTblDataRow(null, theTI, self.tblPacked);
		self.allPackedItems.add(theTI);
	endforeach;

	self.resortDataTable(self.tblPacked);
epilog
	self.mousePointer := Window.MousePointer_Default;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="188b379d-9d3e-4d30-806c-1f4ac2d1487e">
        <updating/>
        <source>displaySelectorResults(_resultCollection : Collection; _mode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Jul 2010	cnwkpd1	PAR #24795 - Tidy up notifications and performance of Pack/Unpack

*/

vars
	ti				: CM_TrackedItem;
	theFilter		: CMQF_TrackedItem;
	
begin
	if _mode &gt; TI_CargoType_Max then
		app.msgBox('The Pack/Unpack screen cannot display item for the selected mode (' &amp; _mode.String &amp; ')', 'Invalid selector mode', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	theFilter := self.myFilterObject;

	// CCMS 1533
	//theFilter.allQryTIs.clear();
	if _resultCollection.isEmpty then
		return;
	endif;

	self.disarmNotesForTableObjects(self.tblUnpacked);		// PAR #24795
	self.tblUnpacked.rows := self.tblUnpacked.fixedRows;
	//theFilter.allQryTIs.clear();
	//_resultCollection.copy(theFilter.allQryTIs);
	self.allQryTis.clear();
	_resultCollection.copy(self.allQryTis);
	self.frmQuery.visible := false;
	
	//self.displayUnpackedItems();
//	self.endNotificationForSubscriber(self);
	//foreach ti in theFilter.allQryTIs do
	foreach ti in self.allQryTis do
		// PAR #24795 - Notes registration is handled in addTblDataRow
//		self.beginNotification(ti, Any_System_Event, Response_Continuous, 0);
		self.addTblDataRow(null, ti, self.tblUnpacked);
	endforeach;
	
	self.setState(self.STATE_ENABLED);
	
end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayTableBooking" id="1bcdf319-9f20-4068-ac8a-e14580bc0808">
        <updating/>
        <source>displayTableBooking(_booking : CM_BookingRef) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/08/2010	cnwdap1	Initial creation PAR #23925
22/07/2013	cnwdap1	PAR #31196 Don't default to Export IMEX status if we have a TI that's a Tranship
*/
vars
	tbl 			: CM_EntryTable;
	item			: CM_BookingRefItem;
	aPort			: CM_Port;
	aCommodity		: CM_Commodity;
	imexStatus		: CM_IMEXStatus;
	releaseString	: String;
	release			: CM_BulkRelease;

begin
	tbl := self.tblContainer;
	if _booking = null then
		return;
	endif;
	
	self.armNotesForObject(_booking);
	
	if tbl.getValueByName(ETRow_BookingReference) = null then				//+cnwml2 PAR25679 CCMS MSL 1076
		self.cmbBooking.setIndexFromObject(_booking);
		tbl.setValueByName(ETRow_BookingReference, _booking.bookingReference);
		
		if not _booking.allBookingRefItems.isEmpty then
			item := _booking.allBookingRefItems.first;
			self.loadBookingItems(item.myBookingReference, item);	
			tbl.setValueByName(ETRow_BookingItem, item.getShortDisplay);
		endif;
	endif;
	
	if _booking.myCargoType &lt;&gt; null and self.myTI = null then
		self.cmbCargoType.setIndexFromObject(_booking.myCargoType);
		tbl.setValueByName(ETRow_CargoTypeNonQuery, self.cmbCargoType.text);
	endif;
	
	if (_booking.myVoyage &lt;&gt; null) then
		if (self.cmbVoyageRight.findObject(_booking.myVoyage) &lt;&gt; -1) then
			self.cmbVoyageRight.listObject := _booking.myVoyage;
			tbl.setValueByControlName(self.cmbVoyageRight.name, self.cmbVoyageRight.text);
		endif;
	else
		self.cmbVoyageRight.listObject := null;
		tbl.setValueByControlName(self.cmbVoyageRight.name, null);		
	endif;
	
	self.cmbOperatorRight.setIndexFromObject(_booking.myOperator);
	tbl.setValueByName(ETRow_OperatorRight, self.cmbOperatorRight.text);

	aPort := app.myRoot.allPorts[_booking.dischargePort.trimBlanks()];
	self.cmbDisPortRight.setIndexFromObject(aPort);
	tbl.setValueByName(ETRow_DisPortRight, self.cmbDisPortRight.text);
	
	aPort := app.myRoot.allPorts[_booking.destinationPort.trimBlanks()];
	self.cmbDestPortRight.setIndexFromObject(aPort);
	tbl.setValueByName(ETRow_DestinationPortRight, self.cmbDestPortRight.text);
	
	aCommodity := app.myRoot.allCommodities[_booking.commodity.trimBlanks()];
	self.cmbCommodity.setObject(aCommodity);
	tbl.setValueByName(ETRow_Commodity, self.cmbCommodity.text);
	
	if self.myTI &lt;&gt; null and self.myTI.getImExStatus = TI_IMEX_STATUS_TRANSHIP then		// PAR #31196
	else																				// PAR #31196
		imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
		if imexStatus &lt;&gt; null then
			self.tblContainer.setValueByName(ETRow_ImexStatus, imexStatus.description);
			self.cmbImEx.listObject := imexStatus;	
		endif;
	endif;																				// PAR #31196
	
	self.cmbConsignee.setObject(_booking.myConsignee); 
	tbl.setValueByName(ETRow_Consignee, self.cmbConsignee.text);
	
	self.cmbConsignor.setObject(_booking.myConsignor); 
	tbl.setValueByName(ETRow_Consignor, self.cmbConsignor.text);
	
	self.doConsignorLostFocus();
	
	releaseString := tbl.getValueByName(ETRow_BulkRelease).String;
	if releaseString &lt;&gt; null then
		release := self.myTerminal.allBulkReleasesByCodeDate[releaseString, null];//find release object and populate delivery release no from release
		if release &lt;&gt; null then
			tbl.setValueByName(ETRow_DeliveryReleaseNo, release.deliveryReleaseNumber);
		endif;
	endif;
	
	self.resortDataTable(self.tblPacked);
epilog

end;</source>
        <Parameter name="_booking" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="displayTableTrackedItem" id="703e72d8-57ad-4ed6-9f30-19b3b569192e">
        <updating/>
        <source>displayTableTrackedItem(_newChildTIs :	CM_TISet) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/10/2009	cnwdad1		PAR #21432 - Sub-Terminal not set after container selected.
// 05/03/2010	cnwmh5		Par 22755 - Add sealNumVentCode
// 28/05/2010	cnwdap1		CCMS 1116 Tanship changes - don't allow tranship imex status to be changed
// 06 Jul 2010	cnwkpd1		PAR #24795 - Tidy up notifications and performance of Pack/Unpack
// 26 Aug 2010	cnwdap1		PAR #23925 CCMS MES 1072 Retain booking settings when changing container id
// 07 Sep 2010	cnwdap1		PAR #23925 CCMS MES 1072 Don't clear booking details if container has no booking
// 09 Apr 2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 20 June 2023 navhl20 	Bug 57388: EUP Testing | Container Weights not updated when Making New LCL
// 13 Apr 2024	navnk30 	Bug 63247: EUP Testing | Container Weights not updated when Making New LCL
// 03 Nov 2025 	navhl20 	Bug MTN-36206: IMT | Create LCL on Pack Unpack
// 20 Nov 2025	navah1		MTN-36555: STWO - Incorrect Total Weight Calculation for MAFI When Packing Multiple Cargo Items
// ---------------------------------------------------------------------------

vars
	tmpConsignor		: CM_ConsigneeConsignor;
	aPort 				: CM_Port;
	aCommodity 			: CM_Commodity;
	aContRange			: CM_ContRange;
	ti					: CM_TrackedItem;
	dataTbl				: CM_DataTable;
	tbl					: CM_EntryTable;
	childTI				: CM_TrackedItem;
	subTerminalObj		: CM_SubTerminal;
	imexStatus			: CM_IMEXStatus;
	release				: CM_BulkRelease;
	releaseString		: String;
	stock				: Boolean;		// PAR #23925
	sealType			: CM_SealType;
	sealTI 				: CM_SealTI;	//06 Dec 2010	NDL	Par 26506
	sealValue 			: String;	//06 Dec 2010	NDL	Par 26506
	contVol 			: Decimal [16,4]; //18 Jul 2011	NDL	Par 27868
	updatedTotalWeight,
	updatedCargoWeight,
	maxWeight 			: Decimal [16,4]; //09 Aug 2011	NDL	Par 27902
	contRange			: CM_ContRange;
	cargoType			: CM_CargoType;
	voyage				: CM_Voyage;
	myRoot				: CM_Root;	
	bookingRef			: CM_BookingRef;
	bookingRefItem		: CM_BookingRefItem;
	imexStatusInt		: Integer;
	cargoVolume			: Decimal[16,4];
	totalVolume			: Decimal[16,4];
	myReeferProps		: CM_TIReeferProperties;
begin
	tbl := self.tblContainer;
	ti := self.myTI;
	myRoot := app.myRoot;										//03.11.2025 navhl20 #36206
	
	if ti = null then											//03.11.2025 navhl20 #36206
		return;
	endif;
	
	self.armNotesForObject(ti);
	tbl.setValueByName(ETRow_ContainerID, ti.id);
	
	cargoType := ti.myCargoType;								//03.11.2025 navhl20 #36206
	if self.cmbCargoType.listObject = null then
		self.cmbCargoType.setIndexFromObject(cargoType);
		self.cmbCargoType.lostFocus(self.cmbCargoType);		
	endif;
	
	voyage := ti.myVoyage;										//03.11.2025 navhl20 #36206
	if (voyage &lt;&gt; null) then
		if (self.cmbVoyageRight.findObject(voyage) &lt;&gt; -1) then
			self.cmbVoyageRight.listObject := voyage;
			tbl.setValueByControlName(self.cmbVoyageRight.name, self.cmbVoyageRight.text);
		endif;
	else
		self.cmbVoyageRight.listObject := null;
		tbl.setValueByControlName(self.cmbVoyageRight.name, null);		
	endif;
	
	self.cmbOperatorRight.setIndexFromObject(ti.myOperator);
	tbl.setValueByName(ETRow_OperatorRight, self.cmbOperatorRight.text);
	
	aPort := myRoot.allPorts[ti.dischargePort.trimBlanks()];
	self.cmbDisPortRight.setIndexFromObject(aPort);
	tbl.setValueByName(ETRow_DisPortRight, self.cmbDisPortRight.text);
	
	//+cnwml2 PAR24740
	aPort := myRoot.allPorts[ti.destinationPort.trimBlanks()];
	self.cmbDestPortRight.setIndexFromObject(aPort);
	tbl.setValueByName(ETRow_DestinationPortRight, self.cmbDestPortRight.text);
	
	
	aCommodity := myRoot.allCommodities[ti.commodity.trimBlanks()];
	self.cmbCommodity.setObject(aCommodity);
	tbl.setValueByName(ETRow_Commodity, self.cmbCommodity.text);
	
	self.isReefer();			//+cnwml2 SFW CCMS 1063 PAR25852
	
	imexStatusInt := ti.getImExStatus();										//03.11.2025 navhl20 #36206
	
// cnwdad1 23/10/2009 - PAR #21432.
	if app.isSubTerminalsOn(self.myTerminal) then
		if ti.mySubTerminal = null then
			subTerminalObj	:=	self.myTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_TrackedItem,
																		0,	// cnwdad1 27/01/2010 - PAR #22205.
																		imexStatusInt,
																		self.cmbCommodity.text,
																		true);
			
			if subTerminalObj &lt;&gt; null then
				tbl.setValueByName(ETRow_MySubTerminal, subTerminalObj.code);
				self.cmbSubTerminal.cnEcSetTextIndex(subTerminalObj.code);		// cnwdad1 12/11/2009 - PAR #21566.
			endif;
		else
			tbl.setValueByName(ETRow_MySubTerminal, ti.mySubTerminal.code);
			self.cmbSubTerminal.cnEcSetTextIndex(ti.mySubTerminal.code);	// cnwdad1 12/11/2009 - PAR #21566.
		endif;
	endif;
	
	// PAR #23925 don't clear booking/booking items unless the container has a booking and it's different to this one
	// also not if the displayed booking is an Export booking with linked Stock bookings
	// PAR #23925 resubmit - if container has no booking, don't remove the booking details
	stock := self.cmbBooking.listObject &lt;&gt; null and self.cmbBooking.listObject.CM_BookingRef.allLinkedStockBookingItems.size &gt; 0;
	//+cnwml2 PAR25679 CCMS MSL 1076
	bookingRef 		:= ti.myBookingRef;											//03.11.2025 navhl20 #36206
	bookingRefItem 	:= ti.myBookingRefItem;										//03.11.2025 navhl20 #36206
	if bookingRef &lt;&gt; null then
		tbl.setValueByName(ETRow_BookingReference, ti.bookingReference);
		self.cmbBooking.setIndexFromObject(bookingRef);
		self.loadBookingItems(bookingRef, bookingRefItem);
	endif;
	
	if bookingRefItem &lt;&gt; null then
		tbl.setValueByName(ETRow_BookingItem, bookingRefItem.getShortDisplay);
		self.cmbBookingItem.setObject(bookingRefItem);
	endif;
	
	if ti.isKindOf(CM_Container) then
		self.setContentsImExStatus(ti.CM_Container.contentsStatus, imexStatusInt);
	else
		imexStatus := myRoot.allImexStatuses[imexStatusInt];
		if imexStatus &lt;&gt; null then
			self.tblContainer.setValueByName(ETRow_ImexStatus, imexStatus.description);
			self.cmbImEx.listObject := imexStatus;	
		endif;
	endif;
	
	if ti.isKindOf(CM_Container) then
		tbl.setValueByName(ETRow_IsoType, ti.CM_Container.isoType);
		tbl.setValueByName(ETRow_IsoGroup, ti.CM_Container.isoGroup);	// 27720 July 2011
	endif;
	
	self.cmbConsignee.setObject(ti.myConsignee); 
	tbl.setValueByName(ETRow_Consignee, self.cmbConsignee.text);
	
	tmpConsignor := myRoot.allConsigneeConsignors[ti.consignor];	
	// HJG CCMS 1235
	self.cmbConsignor.setObject(tmpConsignor); 
	tbl.setValueByName(ETRow_Consignor, self.cmbConsignor.text);
	
	self.doConsignorLostFocus();
	
	tbl.setValueByName(ETRow_CustomExportEntryNumber, ti.customExportEntryNumber);
	
	// 27868
	cargoVolume	:= ti.getMyCargoVolume;												//03.11.2025 navhl20 #36206
	if cargoVolume &gt; 0 then	
		tbl.setValueByName(ETRow_Volume, cargoVolume);	
	else
		tbl.setValueByName(ETRow_Volume, null.String);		
	endif;

	totalVolume := ti.getMyTotalVolume;												//03.11.2025 navhl20 #36206
	if totalVolume &gt; 0 then			// 27868
		tbl.setValueByName(ETRow_VolumeTotal, totalVolume);	
	else
		tbl.setValueByName(ETRow_VolumeTotal, null.String);		
	endif;

	 //18 Jul 2011	NDL	Par 27868
	tbl.accessCell(tbl.getRowByName(ETRow_ContainerVolume),2).enabled := false;	//18 Jul 2011	NDL	Par 27868
	if ti.myTiMaster &lt;&gt; null then
		contVol := ti.myTiMaster.volume;
	endif;
	if contVol &gt; 0 then	
		tbl.setValueByName(ETRow_ContainerVolume, contVol);	
	else
		tbl.setValueByName(ETRow_ContainerVolume, null.String);		
	endif;	
	
	tbl.setValueByName(ETRow_WeightTotal, ti.totalWeight.asStringWeightJMT());										//+cnwml2  MSL CCMS 1017
	tbl.setValueByName(ETRow_WeightTare, ti.weightTare.asStringWeightJMT());									//+cnwml2  MSL CCMS 1017
	tbl.setValueByName(ETRow_CargoWeight, ti.weightCargo.asStringWeightJMT());										//+cnwml2  MSL CCMS 1017
	tbl.setValueByName(ETRow_WeightMax, null.String);	// ** #25592 02/11/2010 - when there is no max weight for a container, it makes sense to set to null the current value and display blank row.
	self.setWeightByRow(ETRow_WeightTotal, ti.totalWeight); //20.11.2025 navah1 #MTN-36555
	self.setWeightByRow(ETRow_CargoWeight, ti.weightCargo); //20.11.2025 navah1 #MTN-36555
	
	//09 Aug 2011	NDL	Par 27902
	if ti.isContainer then
		maxWeight := ti.CM_Container.getMaxWeightFromTIMaster();	
		if maxWeight &gt; 0 then
			tbl.setValueByName(ETRow_WeightMax, maxWeight.asStringWeightJMT()); //cnwrd1 par 28451 13.10.2011
		else
			aContRange := myRoot.lookupContainerRange(ti.id);	
			if aContRange &lt;&gt; null then
				maxWeight := aContRange.maxKilos + aContRange.tareKilos;
				if maxWeight &gt; 0 then
					tbl.setValueByName(ETRow_WeightMax, maxWeight.asStringWeightJMT()); //cnwrd1 par 28451 13.10.2011
				endif;
			endif;
		endif;
	endif;
	
	if ti.isKindOf(CM_Container) then
		tbl.setValueByName(ETRow_VolumeMax, ti.CM_Container.getMaxVolume().asStringJMT().nullWhenZero());	// ** #25592 08/11/2010
	endif;
	
	//+cnwml2 PAR24347
	releaseString := tbl.getValueByName(ETRow_BulkRelease).String;
	if releaseString &lt;&gt; null then
		release := self.myTerminal.allBulkReleasesByCodeDate[releaseString, null];//find release object and populate delivery release no from release
		if release &lt;&gt; null then
			tbl.setValueByName(ETRow_DeliveryReleaseNo, release.deliveryReleaseNumber);
		endif;
	else
		tbl.setValueByName(ETRow_DeliveryReleaseNo, ti.deliveryRelease);
	endif;
	
	dataTbl := self.tblPacked;
	self.disarmNotesForTableObjects(dataTbl);		// PAR #24795
	dataTbl.rows := dataTbl.fixedRows;
	
	foreach childTI in ti.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		if (not self.allPackedItems.includes(childTI)) then
			self.allPackedItems.add(childTI);
		endif;
		
		self.addTblDataRow(null, childTI, dataTbl);
		
	endforeach;
	
	if _newChildTIs &lt;&gt; null then				//13.04.2024 navnk30 #63247
		foreach childTI in _newChildTIs do
			if (not self.allPackedItems.includes(childTI)) then
				self.allPackedItems.add(childTI);
			endif;
		endforeach;
	endif;

	//+cnwml2 PAR25328
	foreach childTI in self.allPackedItems do
		if not ti.allChildren.includes(childTI) then
			self.addTblDataRow(null, childTI, dataTbl);
		endif;
	endforeach;
	
	foreach childTI in self.allUnpackedItems do
		if ti.allChildren.includes(childTI) then
			dataTbl.removeItemObject(childTI);	
			self.allPackedItems.removeIfPresent(childTI); //epr par 34711 26/8/14
		endif;
	endforeach;
	
	// PAR #23645 CCMS 1116 Don't allow user to change Tranship IMEX status
	if ti.isTranshipItem then
		tbl.accessCell(tbl.getRowByName(ETRow_ImexStatus),2).enabled := false;
	else
		tbl.accessCell(tbl.getRowByName(ETRow_ImexStatus),2).enabled := true;
	endif;
	
	//+cnwml2 PAR23715 SFW CCMS1131
	foreach sealType in cargoType.allSealTypes do
		if not sealType.notAvailableForEntry then
			
			//06 Dec 2010	NDL	Par 26506
			sealValue := null;
			sealTI := ti.getSealTI(sealType);	
			if sealTI = null then
				sealTI := ti.getTransSealTiFromOldDataStruc(sealType);
				if sealTI &lt;&gt; null then
					sealValue := sealTI.getSealValueAsString;
					delete sealTI;	// get rid of this one, its a temporary transient.
				endif;
			else
				sealValue := sealTI.getSealValueAsString;
			endif;
			
			tbl.setValueByName("DtRow_" &amp; sealType.sealType, sealValue);	//06 Dec 2010	NDL	Par 26506
			
		endif;
	endforeach;
	
	//set Reefer Details
	//+cnwml2 SFW CCMS 1063 PAR25852
	myReeferProps := ti.myReeferProperties;										//03.11.2025 navhl20 #36206
	if ti.isReefer and myReeferProps &lt;&gt; null then
		tbl.setValueByName(ETRow_AllowableTimeOffPower, myReeferProps.allowableTimeOffPower.asNullDecimal());
		tbl.setValueByName(ETRow_CarriageTemp, ti.getDisplayTemperature(false, true));
		tbl.setValueByName(ETRow_PackDate, myReeferProps.packDate);
		tbl.setValueByName(ETRow_PackTime, myReeferProps.packTime);
		tbl.setValueByName(ETRow_PackTemp, myReeferProps.packTempC);
		tbl.setValueByName(ETRow_CO2, myReeferProps.getCarbonDioxide.asNullCarbonDioxide());
		tbl.setValueByName(ETRow_O2, myReeferProps.getOxygen.asNullOxygen());
		tbl.setValueByName(ETRow_CurtainsIn, myReeferProps.curtainsIn);
		tbl.setValueByName(ETRow_Humidity, myReeferProps.getHumidity.asNullHumidity());
		tbl.setValueByName(ETRow_Ventilation, myReeferProps.ventilation.asNullDecimal());		
		
		tbl.setValueByName(ETRow_CoolingType, app.coolingTypeENumToString(ti.getCoolingType, false));	
		tbl.setValueByName(ETRow_VoltageType, app.voltageTypeENumToString(ti.getVoltageType, false));	
	else
		tbl.setValueByName(ETRow_AllowableTimeOffPower, null);
		tbl.setValueByName(ETRow_CarriageTemp, ti.getDisplayTemperature(false, true));
		tbl.setValueByName(ETRow_PackDate, null);
		tbl.setValueByName(ETRow_PackTime, null);
		tbl.setValueByName(ETRow_PackTemp, null.String);
		tbl.setValueByName(ETRow_CO2, null);
		tbl.setValueByName(ETRow_O2, null);
		tbl.setValueByName(ETRow_CurtainsIn, null);
		tbl.setValueByName(ETRow_Humidity, null);
		tbl.setValueByName(ETRow_Ventilation, null);	
		
		tbl.setValueByName(ETRow_CoolingType, app.coolingTypeENumToString(null, false));	
		tbl.setValueByName(ETRow_VoltageType, app.voltageTypeENumToString(null, false));	
	endif;
	
	updatedCargoWeight := tbl.getMeasurementValueByName(ETRow_CargoWeight).Decimal;				//13.04.2024 navnk30 #63247
	updatedTotalWeight := tbl.getMeasurementValueByName(ETRow_WeightTotal).Decimal;				//13.04.2024 navnk30 #63247
	// PAR #31155 handle measurement rows
	self.resetMeasurementRows(self.tblContainer);																								// PAR #31155
	self.loadMeasurementTypes(self.tblContainer, self.tblContainer.myEntTableDef.name, self.tblContainer.myEntTableDef.allEntTableRows, true);	// PAR #31155
	// PAR #31155 end
	
	if updatedTotalWeight &gt; tbl.getMeasurementValueByName(ETRow_WeightTotal).Decimal then		//13.04.2024 navnk30 #63247
		self.setWeightByRow(ETRow_WeightTotal, updatedTotalWeight);
	endif;
	
	if updatedCargoWeight &gt; tbl.getMeasurementValueByName(ETRow_CargoWeight).Decimal then		//13.04.2024 navnk30 #63247
		self.setWeightByRow(ETRow_CargoWeight, updatedCargoWeight);
	endif;
	
	// 16/07/2014 cnwar2 #34025
	tbl.setValueByName(ETRow_AlternativeId, ti.alternativeId);
	tbl.setValueByName(ETRow_Remarks, ti.remarks);
	tbl.setValueByName(ETRow_Description, ti.description);
	
	self.resortDataTable(self.tblPacked);
	/*13.04.2024 navnk30 #63247 START
	if tbl.getMeasurementValueByName(ETRow_CargoWeight).Decimal = null then													//20.6.2023 navhl20 #57388
		foreach childTI in self.allPackedItems do
			contRange := app.myRoot.lookupContainerRange(childTI.id);
			self.assignContainerDetails(childTI, contRange);
		endforeach;
	endif;			13.04.2024 navnk30 #63247 END*/
	
	if _newChildTIs = null then					//13.04.2024 navnk30 #63247
		return;
	endif;
	foreach childTI in _newChildTIs do			//13.04.2024 navnk30 #63247
		self.assignContainerDetails(childTI, aContRange);
	endforeach;
epilog
	
end;</source>
        <Parameter name="_newChildTIs" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="displayUnpackedItems" id="5a1f24cc-17ac-4bf3-a227-a8b31e81b8ba">
        <source>displayUnpackedItems();
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTI 		: CM_TrackedItem;
begin
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="6d69f4d1-6dd1-41a2-a439-b31598bdad89">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 13 November 2003
//
//********************************************************************
vars
	found		: Boolean;
	row : Integer;
	changed : Boolean;
	child,
	ti : CM_TrackedItem;
begin
	inheritMethod();

	if self.isUsedForRepack and self.repackHasOccured then
		if app.msgBox(app.getString(CancelConfirmation), app.getString(Save_changes), MsgBox_Yes_No	) = MsgBox_Return_Yes then
			self.doSearch();
			self.clearTableContainerValues(false);
			self.repackHasOccured := false;	
			self.btnCancelBase.enabled := false;		// 28474 disable Cancel until change made
		endif;
	else
		//+cnwml2 PAR25678, revised 28474 Mar 2012
		//self.unloadForm;
		
		changed := self.tblContainer.hasChanged;
		if self.myTI &lt;&gt; null then
		if not changed then
			// packed
			foreach row in 2 to self.tblPacked.rows do
				ti := self.tblPacked.accessRow(row).itemObject.CM_TrackedItem;
				if not self.myTI.allChildren.includes(ti) then
					changed := true;
					break;
				endif;
			endforeach;
		endif;
		// unpacked, added for 28474 Mar 2012 enable Cancel only on change
		if not changed then
			foreach child in self.myTI.allChildren do
				found := false;
				foreach row in 2 to self.tblPacked.rows do
					ti := self.tblPacked.accessRow(row).itemObject.CM_TrackedItem;
					if ti = child then
						found := true;
						break;
					endif;
				endforeach;
				if not found then
					changed := true;
					break;
				endif;
			endforeach;
		endif;
		endif;
		
		if changed then
			if app.msgBox(app.getString(CancelConfirmation), app.getString(Save_changes), MsgBox_Yes_No	) = MsgBox_Return_Yes then
				self.allPackedItems.clear();
				//18 Oct 2012	NDL	Par 30520
				foreach ti in self.allUnpackedItems do
					self.tblUnpacked.findObjectInRow(ti,row);
					if row &gt; self.tblUnpacked.fixedRows and row &lt;= self.tblUnpacked.rows then
						tblUnpacked.removeItem(row);
					endif;
				endforeach;
				self.allUnpackedItems.clear();
				self.tblContainer.clearHasChanged();	// 28474 testing, reset the table change flag
				self.btnCancelBase.enabled := false;	// 28474 disable Cancel until change made
				self.doComboTrackedItemLostFocus(self.cmbTrackedItem);
			endif;
		else
			self.clearTableContainerValues(false);
			self.btnCancelBase.enabled := false;	
		endif;

	endif;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="c99eb82c-e9ca-4377-9689-e92e85792906">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Jul 2010	cnwkpd1	PAR #24795 - Tidy up notifications and performance of Pack/Unpack
08 Apr	2011	NDL	Par 20392 - Moved original code into new "doSave" method,
								and added loop to enable retying deadlocks
7/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt
03/11/2025 jlier1 	MTN-34531 - Deadlock retry refactor
*/

vars
	localCaption : String;
begin
	//set up the silent deadlock handler to attempt to retry
	app.myPassport.setupForDeadlockReplay(220, 3000);
	app.myPassport.silentDeadlockLimit := 10;	
	self.mousePointer := Window.MousePointer_HourGlass;
	localCaption:=self.caption;
	
	while true do
	
		self.mousePointer := Window.MousePointer_HourGlass;
		
		//call the code that was originally in this method
		self.doSave();	// original code that was "doBaseFormSave"
		
		if app.myPassport.noTrxReplayAllowed() then
			if app.myPassport.hadDeadlock then //had a deadlock and reached the limit show the deadlock error
				app.showErrorWarningDialog(app.getErrorString(PackUnpack), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			endif;
			break;
		endif;	
		self.updateCaptionDeadlockRetry(localCaption);
	endwhile;
	
epilog

	//set the silent deadlock handler back to the default values i.e. OFF
	app.myPassport.resetSilentDeadlockHandler;	//7/3/25 navsaa30 #14818
	self.caption:=localCaption;
	self.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseRepackSave" id="d987a1a0-6df4-4fc5-8574-b1aaef719130">
        <updating/>
        <source>doBaseRepackSave()updating, protected;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 25 November 2003
//
//********************************************************************
vars
	theMoveController 			: CMIF_MoveController;
	charged,
	loadState					: Boolean;
	result						: Integer;
	pxyTIToEmpty,
	pxyTIToRepack				: CM_TrackedItem;
	theChildSet					: CM_TISet;
	pxyChild					: CM_TrackedItem;
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	if not self.repackHasOccured then
		app.msgBox(app.getErrorString(RepackNotOcurred), app.getErrorString(RepackSelected), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;

	app.cmsBeginLoad(loadState);		

	//Make copies of the two TI's	
	pxyTIToEmpty := self.myTIToEmpty.pxyCreateUpdateProxy();
	pxyTIToRepack := self.myTI.pxyCreateUpdateProxy();
	
	pxyTIToRepack.setPxyFromEmptyToFull(self.myTIToEmpty);
	pxyTIToEmpty.setPxyToEmptyForRepack;
	
	create theChildSet transient;
	//pxyTIToEmpty.getAllChildren(theChildSet);//PAR 22954
	foreach pxyChild in pxyTIToEmpty.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		theChildSet.add(pxyChild);
	endforeach;
	
	pxyTIToEmpty.detachChildren();
	// attach these proxy children to the proxy TI	
	// NOTE this detaches all existing children first
	//pxyContainerToRepack.setChildrenForCreate(pxyContainerToRepack.allChildren, app.myPassport);	
	pxyTIToRepack.setChildrenForCreate(theChildSet, app.myPassport);


	//Pass repack to the transaction layer
	if self.cbIgnoreWarnings.enabled then
		app.myPassport.warningsAcknowledged := self.cbIgnoreWarnings.value;
	else
		app.myPassport.warningsAcknowledged := false;
	endif;

	while true do
		app.myTrxUA.trxUpdateRepack(pxyTIToEmpty, pxyTIToRepack, (not charged), app.myPassport);
		
		//08 Apr 2011	NDL	Par 20392 - now handled in 'doBaseFormSave'
		if app.myPassport.hadDeadlock = true then
			return;
		endif;
		
		if app.myPassport.trxCompletedOK then
			//do stuff like clear warnings from form and warnings window.  
			
			self.allPackedItems.clear();
			self.allUnpackedItems.clear();
			self.clearErrorWarnings();
			self.doDisplayTrackedItem(false);
			self.doSearch();
			
			//do this before nulling self.myContainer
			if self.myTerminal.getConfig(PromptForPackComplete).Boolean then
				//prompt for PackComplete transaction
				self.promptForPackComplete();
			endif;
			
			self.myTI := null;
			self.myTIToEmpty := null;
			break;
		else
			// par 26377 allow OK of warnings
			result := app.showErrorWarningDialog(app.getErrorString(PackUnpack), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			if app.myPassport.hasWarningsToAcknowledge then
				cbIgnoreWarnings.value := false;
				cbIgnoreWarnings.enabled := true;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			break;
		endif;
	endwhile;
	
	self.repackHasOccured := false;
	self.btnCancelBase.enabled := false;		// 28474 disable Cancel until change made

epilog
	self.mousePointer := Window.MousePointer_Default;
	
	app.cmsEndLoad(loadState);
	delete theMoveController;
	delete pxyTIToRepack;
	delete pxyTIToEmpty;	
	delete theChildSet;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCargoTypeClick" id="6fac58f1-8123-437b-91be-59740ace1643">
        <updating/>
        <source>doCargoTypeClick(_cargoType : CM_CargoType) updating;
// ---------------------------------------------------------------------------
// Created:     24 February 2003		cnwth2	
//
// Purpose:     		
//
// Changed On	By			Reason 
// ----------   ----------  --------------------------------------------------
// 07/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not appearing in System Admin
vars
	entDef 			: EntTableDef;
	entView			: EntTableView;
begin
	if _cargoType = null then
		return;
	endif;
	
	//if _cargoType.id &gt; TI_CargoBOLType_JMTMax then										// TFS 49252
	if _cargoType.id &gt; TI_CargoBOLType_JMTMax and not app.myRoot.isClientCentrePort then	// TFS 49252
		return;
	endif;

	entDef := self.getTblQueryDef;

	if _cargoType.id &gt; TI_CargoBOLType_Max then
		entView := entDef.allEntTableViews['UserCargoTypeView'];
	else
		entView := entDef.allEntTableViews['SystemCargoTypeView'];	
	endif;
	
	self.tblQuery.showHideRowsByView(entView, CM_EntryTable.ShowHideRows, null);
	self.tblQuery.adjustHeight(1000);
	self.doLoadCmbQryProduct(_cargoType);

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="doCmbBRBuild" id="a28e791c-4d04-4163-a557-30a5f10a5896">
        <source>doCmbBRBuild();
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	combo : CMUI_ComboBox;
	aBR,tmpBR : CM_BulkRelease;
	iter01 : Iterator;
	brSelected	: CM_BulkRelease;

begin
	combo := self.cmbBR;
	
	brSelected := combo.listObject.CM_BulkRelease;	//#26529 29/12/2010. Save brSelected on the screen.
	
	combo.clear;
	combo.sorted := true;
	
	iter01 := self.myTerminal.allBulkReleaseByTypeByStByCd.createIterator();

	self.myTerminal.allBulkReleaseByTypeByStByCd.startKeyGeq(BR_TYPE_PACKING,BR_ACTIVE,null,null,iter01);
	
	while iter01.next(aBR) do
		if aBR.type &lt;&gt; BR_TYPE_PACKING or aBR.status &lt;&gt; BR_ACTIVE then
			break;
		else
			tmpBR := self.myTerminal.getBulkReleaseFromCode(aBR.code);
			if tmpBR &lt;&gt; null then
				if tmpBR = aBR then
					combo.addItemObject(aBR.code,aBR);
				else
					combo.addItemObject(aBR.code &amp; Tab &amp; aBR.dateRequested.date.String,aBR);
				
				endif;
			else
				combo.addItemObject(aBR.code,aBR);
			endif;
		endif;
	endwhile;
/*
	foreach aBR in self.myTerminal.allBulkReleaseByTypeByStByCd
		where aBR.type = BR_TYPE_GENERAL
		and aBR.status = BR_ACTIVE do
			combo.addItemObject(aBR.code,aBR);
	endforeach;
*/	

	aBR := null;	//#26529 29/12/2010

	combo.sorted := false;
	combo.addItemAt("",1);
	
	if self.myTI &lt;&gt; null then
		// cnwdad1 28/05/2007 - PAR #14118.
		aBR := self.myTI.getBulkReleaseAssignedOfType(BR_TYPE_PACKING, BR_ACTIVE);	// PAR 16800

		if aBR = null then
			//aBR := self.myContainer.myBulkReleaseReleased;	// 20/05/2008 cnwar2 #16621
			aBR := self.myTI.allBulkReleasesReleased.getAtKeyGeq(BR_TYPE_PACKING, null, null, null);	// cnwrd1 26.5.09 ccms 1804
		endif;												// May be adding to parent which has already been packed
		
	endif;

	if aBR = null then	// #26529 29/12/2010. If release request is null for ti, it can be selected on the screen, the cmbBR combobox.
		aBR := brSelected;
	endif;												
	
	if aBR &lt;&gt; null then
		//epr par 16887 30/6/08
		if self.cmbBR.findObject(aBR) &gt; 0 then
			self.cmbBR.listObject := aBR;
		endif;
	else
		combo.listIndex := -1;
	endif;		
	
	combo.lostFocus(combo);
	
epilog
	delete iter01;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doComboTrackedItemLostFocus" id="93069590-4c63-40b9-a8c4-090803a824c3">
        <updating/>
        <source>doComboTrackedItemLostFocus(_combo : ComboBox) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 01 October 2004
//
//********************************************************************
// 06/08/2010	cnwdap1		PAR #23925 CCMS MES 1072 Restore booking/release on change of container
// 22/07/2013	cnwdap1		PAR #31196 Removed redundant parameter to comboBoxTrackedItemCmbPack method
vars
	release		: CM_BulkRelease;
	a : Integer;
begin
	self.doDisplayTrackedItem(true); //added for par 13111

	if not self.fromLastRow then
		self.tblContainer.setValueByControlName(_combo.name, _combo.text);
	endif;

	self.validateBookingTI();	// #26475 09/12/2010

	//+cnwml2 PAR25756 CCMS MSL 1076
	//filter bookings so that only tis that are linked to the selected booking or which have no links to any bookings are displayed
	if self.myTI &lt;&gt; null then			//+cnwml2 PAR26376
		if self.chbFilter.value then
			release := self.cmbBR.listObject.CM_BulkRelease;					// 37288	
		endif;
		//self.myAssistant.comboBoxTrackedItemCmbPack(self.cmbTrackedItem, self.cmbCargoType.listObject.CM_CargoType.id, TI_STATE_NORMAL, self.myTI, self.cmbBooking.listObject.CM_BookingRef);	// PAR #31196
		self.myAssistant.comboBoxTrackedItemCmbPack(self.cmbTrackedItem, self.cmbCargoType.listObject.CM_CargoType.id, self.myTI, self.cmbBooking.listObject.CM_BookingRef, release);					// PAR #31196
	endif;
	
	

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnCreateLCL.enabled:= false;
		self.btnMakeLCL.enabled:= false;
		self.btnMakeHaz.enabled:= false;
		self.mnuCreateAttachments.enabled:= false;
		self.mnuCreateCargoUnpack.enabled:= false;
		self.mnuEditContainer.enabled:= false;
	
		foreach a in 1 to self.tblContainer.rows do
			self.tblContainer.disableRow(a);
		endforeach;
		self.tblContainer.enableRowByName(ETRow_ContainerID);
		self.tblContainer.enableRowByName(ETRow_CargoTypeNonQuery);
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doConsignorLostFocus" id="20cb5ba3-3529-4ed8-8cb7-3457e20e5132">
        <updating/>
        <source>doConsignorLostFocus() protected, updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpConsignor 		: CM_ConsigneeConsignor;
	consignorCmb		: CMUI_ComboBox;
	derogationNumber 	: String;
	
begin

	consignorCmb := self.cmbConsignor;
	
	self.tblContainer.setValueByControlName(consignorCmb.name, consignorCmb.text);
	
	//JC prefill the custom Export Entry number	CCMS 1077
	tmpConsignor := self.cmbConsignor.myObject.CM_ConsigneeConsignor;
	if tmpConsignor &lt;&gt; null then
		derogationNumber := tmpConsignor.derogationNumber;
	endif;
	
    self.doLoadCmbCustomDetails();	
	self.tblContainer.setValueByName(ETRow_CustomExportEntryNumber, derogationNumber);
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCreateLCLButtonCLick" id="cace2aea-9184-4815-8ae9-fe3fe23bede2">
        <updating/>
        <source>doCreateLCLButtonCLick() protected, updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2003		cnwth2	
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	attachFrm		: CMUI_AttachBreakBulk;
	tmpLC			: CM_LocationsController;
begin

	if self.mnuEnhanced.checked then
		//06 Dec 2013	NDL	Par 32854
		tmpLC := self.cmbQryRow.listObject.CM_LocationsController;
		self.myAssistant.showMakeLCL(	self,	//_parentForm : CM_BaseForm;
										tmpLC,	//_relatedObj : Object;
										true,	//_modal : Boolean;
										3,	//_columns : Integer;
										160,	//_controlWidth : Integer
										true); // PAR 36239 28/5/15 want to be able to create containers from here
										       // PAR 36449 Actually not allowed to create containers unless the "Allow Creation as result of groupage is set" 
		return;
		
	else
	
		attachFrm := app.getForm(CMUI_AttachBreakBulk.name).CMUI_AttachBreakBulk;
		
		if attachFrm = null then
			// This line reinstated for PAR 16715 cnwgb1 13 May 2008
			attachFrm := app.loadForm(CMUI_AttachBreakBulk, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_AttachBreakBulk;
		endif;
		//th2 29/09/06 - added to stop warning comming up about expected quantity etc.
		attachFrm.aNumberOfItems := -1;
		
		if self.cmbQryTAType.listObject &lt;&gt; null then //default to currently queried TA type
			attachFrm.aTerminalAreaType := self.cmbQryTAType.listObject.CM_TerminalAreaType.type;
		else
			attachFrm.aTerminalAreaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_BLOCK_STACK].type;
		endif;
		
		attachFrm.aMyTerminalArea := self.cmbQryTermArea.listObject.CM_TerminalArea;
		attachFrm.aMyCargoType := app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk];
		attachFrm.aMyMasterTI := null;
	
		attachFrm.aMyLocationsController := self.cmbQryRow.listObject.CM_LocationsController;			//+cnwml2 PAR24785
	
		if self.cmbOperatorRight.listObject &lt;&gt; null then
			attachFrm.aMyOperator := self.cmbOperatorRight.listObject.CM_Operator;
		else
			attachFrm.aMyOperator := self.cmbQryOperator.listObject.CM_Operator; 
		endif;
		
		attachFrm.aIsForCreation := true;
		tmpLC := self.cmbQryRow.listObject.CM_LocationsController;
		if tmpLC &lt;&gt; null then
			self.beginNotification(tmpLC, Any_System_Event, Response_Continuous, 0);
		endif;
		attachFrm.show;
	
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCreatePackComplete" id="db9cb596-d230-4000-80d5-e3e03b8627f5">
        <updating/>
        <source>doCreatePackComplete() updating;
//----------------------------------------------------------------
//	Created:	29 September 2004	by Jason Chapman  (cnwjc2)
// 19 Mar 2024 navhl20 ChangeRequest 62863: EUP | Retrospective Operations - [54177.100] - Pack
// 13 Apr 2024 navnk30 Bug 63247: EUP Testing | Container Weights not updated when Making New LCL
//----------------------------------------------------------------
vars
	tiObj 		: CM_TrackedItem;
	operator	: CM_Operator;
	subterminal	: CM_SubTerminal;
	pxyTI		: CM_TrackedItem;
	result		: Integer;
	
begin
	if self.myTIForPackComplete &lt;&gt; null then
		tiObj	:=	self.myTIForPackComplete;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, ' current container is null');
		return;
	endif;

	operator	:=	self.cmbNewOperator.myObject.CM_Operator;
	pxyTI		:=	app.createUpdateProxy(tiObj).CM_TrackedItem;

	if operator &lt;&gt; pxyTI.myOperator then
		pxyTI.zSetPxyOperator(operator);
	endif;
	
	if app.isSubTerminalsOn(self.myTerminal) then
		subterminal	:=	self.cmbPSubTerminal.listObject.CM_SubTerminal;
		
		if subterminal &lt;&gt; pxyTI.mySubTerminal then
			pxyTI.zSetPxySubTerminal(subterminal);
		endif;
	endif;
	
	// set new sub-terminal on pxyTI here
	
	while true do
		app.myTrxUA.trxUpdateTIPackComplete(pxyTI, null, null, app.myPassport);		//19.03.2024 navhl20 #62863
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window
			self.myTI := self.myTIForPackComplete;
//			self.displayTableTrackedItem();				//13.04.2024 navnk30 #63247
			self.displayTableTrackedItem(null);			//13.04.2024 navnk30 #63247
			self.clearErrorWarnings();
			
			//hide the frame
			self.doPackComCancelClick();
			
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(PackUnpack), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			break;
		endif;
	endwhile;
epilog
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCreateUnpackComplete" id="7fb8ccdf-c166-403c-9b2d-569a06b9b8d1">
        <updating/>
        <source>doCreateUnpackComplete() updating;
//----------------------------------------------------------------
//	Created:	May 2007 cnwrs1
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 26/06/2012	cnwdap1		PAR #29735 New parameter for CM_TrackedItem::setBookingRefAndItem
// 13 Apr 2024	navnk30 	Bug 63247: EUP Testing | Container Weights not updated when Making New LCL
//----------------------------------------------------------------
vars
	tiObj			: CM_TrackedItem;
	operator		: CM_Operator;
	subterminal		: CM_SubTerminal;
	pxyTI			: CM_TrackedItem;
	result			: Integer;
	configOption	: Boolean;
	
begin
	if self.myTIForUnpackComplete &lt;&gt; null then
		tiObj	:=	self.myTIForUnpackComplete;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'current container is null');
		return;
	endif;

	operator	:=	self.cmbUnpckOperator.myObject.CM_Operator;
	pxyTI		:=	app.createUpdateProxy(tiObj).CM_TrackedItem;

	if operator &lt;&gt; pxyTI.myOperator then
		pxyTI.zSetPxyOperator(operator);
	endif;
	
	if app.isSubTerminalsOn(self.myTerminal) then
		subterminal	:=	self.cmbUSubTerminal.listObject.CM_SubTerminal;
		
		if subterminal &lt;&gt; pxyTI.mySubTerminal then
			pxyTI.zSetPxySubTerminal(subterminal);
		endif;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateTIUnpackComplete(pxyTI, app.myPassport, null);
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window
			self.myTI := self.myTIForUnpackComplete;
			//self.displayTableTrackedItem();			//13.04.2024 navnk30 #63247
			self.displayTableTrackedItem(null);			//13.04.2024 navnk30 #63247
			self.clearErrorWarnings();
			
			//hide the frame
			self.doUnpackCompleteCancelClick();
			
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(PackUnpack),
												app.myPassport,
												ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			break;
		endif;
	endwhile;
epilog
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDisplayTrackedItem" id="992c70e8-9623-4efc-8af6-950a868d739d">
        <updating/>
        <source>doDisplayTrackedItem(_showWarning : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     21 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

06 Jul 2010	cnwkpd1	PAR #24795 - Tidy up notifications and performance of Pack/Unpack
06 Aug 2010	cnwdap1	PAR #23925 CCMS MES 1072 If we have a booking selected, restore it once the tblContainer has been cleared
07 Sep 2010 cnwdap1	PAR #23925 resubmit - tighten checking around stock booking error message
13 Apr 2024	navnk30 Bug 63247: EUP Testing | Container Weights not updated when Making New LCL
*/

vars
	theTI				: CM_TrackedItem;
	ti					: CM_TrackedItem;
	numRows,
	row					: Integer;
	tbl					: CM_DataTable;
	cargoID				: String;
	release				: CM_BulkRelease;		// PAR #23925
	booking				: CM_BookingRef;		// PAR #23925
	bookingItem			: CM_BookingRefItem;	// PAR #23925
	previousTI			: CM_TrackedItem;
	sealTable 				: Control;
	sealType 			: String;
	seal 				: CM_SealTI;
	tmpStr : String;
begin
	self.repackHasOccured := false;
	self.allWarnings.clear();
	
	previousTI := self.myTI;	// saving old ti. #26529 27/12/2010
	theTI :=  self.cmbTrackedItem.listObject.CM_TrackedItem;
	
	if theTI = null then
		self.clearTableContainerValues(true);
		return;
	endif;
		
	cargoID := theTI.id;
		
	if not theTI.isOnSite  then
		app.msgBox('Cargo with an ID of ' &amp; cargoID &amp; ' could not be found on-site', 'Container not found', MsgBox_Exclamation_Mark_Icon);
		self.tblContainer.clearValues();
		self.tblContainer.goToRowByName(ETRow_ContainerID);
		return;
	endif;
	
	// PAR #23925 CCMS MES 1076 The container must be part of the booking we've selected
	booking := self.cmbBooking.listObject.CM_BookingRef;
	if booking &lt;&gt; null and theTI.bookingReference &lt;&gt; null and theTI.bookingReference &lt;&gt; booking.bookingReference then
		app.msgBox('Cargo Item ' &amp; cargoID &amp; ' is not associated with Booking ' &amp; booking.bookingReference, 'Booking Mismatch', MsgBox_Exclamation_Mark_Icon);
		self.clearTableContainerValues(true);
		self.tblContainer.goToRowByName(ETRow_ContainerID);
		return;
	endif;

	if (theTI &lt;&gt; previousTI) and (previousTI &lt;&gt; null) then	// #26529 29/12/2010. When to is the same (for example, when refreshing), then keep existing release request selected in cmbBR.
		self.cmbBR.listObject := null; 				//+cnwml2  PAR24347 
	endif;
		
	self.myTI := theTI;	//#26529 29/12/2010. It weas keeping old ti here. It should be changed for self.doCmbBRBuild()
	self.cmbBR.lostFocus(self.cmbBR);			//+cnwml2  PAR24347

	self.doCmbBRBuild(); //epr par 16887 30/6/08 this method does the below code anyway so bit redundant doing it twice

	/////////////////////////////////////////////
	//if packing/unpacking occured WITHOUR the user clicking save, 
	//then re-populate TIs into their appropriate tables
	tbl := self.tblUnpacked;
	foreach ti in self.allPackedItems do
		if ti.myParent &lt;&gt; null then
			continue;
		endif;
		
		self.addTblDataRow(null, ti, tbl);
	endforeach;
	
	// PAR #24795 - No need to do this if there are no "unpacked" items
	if not self.allUnpackedItems.isEmpty() then
		numRows := tbl.rows;
		foreach row in tbl.fixedRows to numRows do
			if row &gt; numRows then
				break;
			endif;
			
			ti := tbl.accessRow(row).itemObject.CM_TrackedItem;
			if ti = null then
				continue;
			endif;
			
			if (self.allUnpackedItems.includes(ti)) and (ti.myParent &lt;&gt; null) then
				self.disarmNotesForObject(ti);		// PAR #24795
				tbl.removeItem(row);
				numRows := numRows - 1;
			endif;
		endforeach;
	endif;
	
	// moved from cmbTrackedItem_lostFocus() back to here. cnwvu1 #26401 29/11/2010
	self.allPackedItems.clear();
	self.allUnpackedItems.clear();
	
	
	self.myTI := theTI;

	// PAR #23925 start - show error if container is not part of selected booking
	if self.cmbBooking.listIndex &gt; 0 and self.myTI &lt;&gt; null then
		booking := self.cmbBooking.listObject.CM_BookingRef;
		// PAR #23925 resubmit - only check bookings if the container has one
		//if not booking.isStockBookingRef and self.myTI.myBookingRef &lt;&gt; booking then
		if not booking.isStockBookingRef and self.myTI.myBookingRef &lt;&gt; null and self.myTI.myBookingRef &lt;&gt; booking then
			app.msgBox(app.getString(CargoNotPartExBook), app.getString(Wrong_booking), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	
	self.setCaption(app.getErrorString(Pack_) &amp; theTI.id);
	self.theTIimexStatus := self.myTI.getImExStatus;
	self.doLoadCmbContentsStatus();		//+cnwml2 PAR23045
//	self.displayTableTrackedItem();		//13.04.2024 navnk30 #63247
	self.displayTableTrackedItem(null);	//13.04.2024 navnk30 #63247
	if self.myTI &lt;&gt; null then
		// PAR #23925 restore release/booking/booking item if we had any
		release := self.cmbBR.listObject.CM_BulkRelease;					// PAR #23925
		booking := self.cmbBooking.listObject.CM_BookingRef;				// PAR #23925
		bookingItem := self.cmbBookingItem.listObject.CM_BookingRefItem;	// PAR #23925
		self.doModalMessageDisplay(self.myTI, _showWarning);
		self.doRestoreReleaseAndBooking(release, booking, bookingItem);		// PAR #23925
		self.displayTableBooking(booking);		// displays booking field values on the right table. #26475	7/12/2010
	endif;
		
	//jlier1 TFS 55164 15/11/22
	foreach sealTable in self.allSealTypeControls do
		sealType:=sealTable.name[9:end];
		sealTable.CM_Table.clear;
		if self.myTI &lt;&gt; null then
			seal:=self.myTI.allSeals[sealType];
			if seal &lt;&gt; null then
				row := sealTable.CM_Table.fixedRows;
				foreach tmpStr in seal.allSealNums do
					row := row + 1;
					sealTable.CM_Table.setCellText(row, 1, tmpStr);
				endforeach;
			endif;
		endif;
	endforeach;
	

end;</source>
        <access>protected</access>
        <Parameter name="_showWarning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEnquireTblContainer" id="7f1309fe-6194-40d8-891d-70bc5720792e">
        <source>doEnquireTblContainer(_edit : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     19 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if self.myTI = null then
		return;
	endif;
	
	//epr par 31372
	if self.tblContainer.allSelectedObjects.size &gt; 1 then
		self.myAssistant.showCargoEnquiryForTIs(self.myTI,self.tblContainer.allSelectedObjects,self.myMasterMenuAction,_edit);
		return;
	endif;
	
	self.myAssistant.showCargoEnquiryForm(self.myTI, self.myMasterMenuAction, true, _edit);

end;</source>
