    <JadeMethod name="initDataExtractFields_Default" id="4e984357-6d3d-4ec9-8328-032089c3e7bb">
        <source>initDataExtractFields_Default(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
25 May 2011 cnwdw1	Reviewed
26 May 2011 cnwsh3	Reviewed

*/

vars
	fieldName		: String;
	
begin
	fieldName := "id";
	self.initDataExtractField(_fields, CM_Container.name, "id", fieldName, STRING, "ID", "Unique identification number of Container", STRING, "4 letters + 7 digits");

	fieldName := "cargoType";
	self.initDataExtractField(_fields, CM_Container.name, "cargoType", fieldName, STRING, "Cargo Type", "Description from JMT Cargo Type", STRING, "ISO Container");

	//fieldName := "operatorCode";
	//self.initDataExtractField(_fields, CM_Container.name, "operatorCode", fieldName, STRING, "Operator", "Operator code", STRING, "Valid Operator code in JMT (4 characters maximum)");

	fieldName := "locationId";
	self.initDataExtractField(_fields, CM_Container.name, "locationId", fieldName, STRING, "Location ID", "JMT location string for current position", STRING, "Valid JMT Yard location string");

	fieldName := "isoType";
	self.initDataExtractField(_fields, CM_Container.name, "isoType", fieldName, STRING, "ISO Type", "JMT ISO Type code", STRING, "Valid JMT ISO Type (4 characters maximum)");

	fieldName := CM_Container::getImexStatusStrDesc.name;
	self.initDataExtractField(_fields, CM_Container.name, null, fieldName, STRING, "IMEX Status", "IMEX Status", STRING, "One of IMPORT/EXPORT/TRANSHIPMENT/STORAGE");

	fieldName := "myVoyage";
	self.initDataExtractField(_fields, CM_Container.name, "myVoyage", fieldName, STRING, "Voyage", "Voyage code", STRING, "Valid JMT Voyage code (20 characters maximum)");

//	fieldName := "customsEntryNumber";
//	self.initDataExtractField(_fields, CM_Container.name, "customsEntryNumber", fieldName, STRING, "Customs Entry Number", "**** fill in with field description ****", STRING, "**** fill in with possible values description ****");

	fieldName := "customsDSK";
	self.initDataExtractField(_fields, CM_Container.name, "customsDSK", fieldName, STRING, "DSK Number", "DSK Number", STRING, "Maximum 30 characters");

	fieldName := "customExportEntryNumber";
	self.initDataExtractField(_fields, CM_Container.name, "customExportEntryNumber", fieldName, STRING, "Customs Export Delivery Order", "Customs Export Delivery Order", STRING, "");

	fieldName := "commodity";
	self.initDataExtractField(_fields, CM_Container.name, "commodity", fieldName, STRING, "Commodity", "JMT Commodity code", STRING, "Valid JMT Commodity code (4 characters maximum)");

	fieldName := "commodityGroup";
	self.initDataExtractField(_fields, CM_Container.name, "commodityGroup", fieldName, STRING, "Commodity Group", "JMT Commodity Group code", STRING, "Valid JMT Commodity Group code (4 characters maximum)");

	fieldName := "transitStatus";
	self.initDataExtractField(_fields, CM_Container.name, "transitStatus", fieldName, STRING, "Transit Status", "The status of cargo that is staying on board, but may need to be moved", STRING, "Double Lift Restow, Shift On Board, Unknown Transit");

	fieldName := "isHazardous";
	self.initDataExtractField(_fields, CM_Container.name, "isHazardous", fieldName, BOOLEAN, "Is Hazardous", "Flag to indicate the cargo is Hazardous", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "isOverDimensions";
	self.initDataExtractField(_fields, CM_Container.name, "isOverDimensions", fieldName, BOOLEAN, "Is Over Dimensions", "Flag to indicate the cargo is Over Dimension", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "companyCode";
	self.initDataExtractField(_fields, CM_Container.name, "companyCode", fieldName, STRING, "Business Unit", "The Business Unit for invoicing purposes", STRING, "A valid Invoicing Business Unit");

	fieldName := "length";
	self.initDataExtractField(_fields, CM_Container.name, "length", fieldName, INTEGER, "Length", "Length of the container", INTEGER, INTEGER_POSSIBLEVAL);

	fieldName := "height";
	self.initDataExtractField(_fields, CM_Container.name, "height", fieldName, INTEGER, "Height", "Height of the container", INTEGER, INTEGER_POSSIBLEVAL);

	fieldName := "width";
	self.initDataExtractField(_fields, CM_Container.name, "width", fieldName, INTEGER, "Width", "Width of the container", INTEGER, INTEGER_POSSIBLEVAL);

	fieldName := "site";
	self.initDataExtractField(_fields, CM_Container.name, "site", fieldName, STRING, "Site (Current)", "The current site status of the container", STRING, "On site, Off site, TBA, On ship or Undefined");

	fieldName := "plannedSite";
	self.initDataExtractField(_fields, CM_Container.name, "plannedSite", fieldName, STRING, "Site (Planned)", "The next planned site of the container", STRING, "On site, Off site, TBA, On ship or Undefined");

	fieldName := "state";
	self.initDataExtractField(_fields, CM_Container.name, "state", fieldName, STRING, "State (current)", "The current state the container is registered as", STRING, "Undefined, Archived, Normal, Ghost, Prenotified, Off Site, On Ship, Deleted, EDI or TBA");
	
	fieldName := "plannedState";
	self.initDataExtractField(_fields, CM_Container.name, "plannedState", fieldName, STRING, "State (Planned)", "The containers next planned state", STRING, "Undefined, Archived, Normal, Ghost, Prenotified, Off Site, On Ship, Deleted, EDI or TBA");

	fieldName := "receiptTransportMode";
	self.initDataExtractField(_fields, CM_Container.name, "receiptTransportMode", fieldName, STRING, "Receipt Transport Mode", "How the container was received into the terminal", STRING, "Road, Rail, Ship");

	fieldName := "isSecureExport";
	self.initDataExtractField(_fields, CM_Container.name, "isSecureExport", fieldName, BOOLEAN, "Is Secure Export (SEP)", "True if the consignor is a secure export partner", BOOLEAN, BOOLEAN_POSSIBLEVAL);

	fieldName := "consignorVoyageCode";
	self.initDataExtractField(_fields, CM_Container.name, "consignorVoyageCode", fieldName, STRING, "Consignor Voyage Code", "Voyage code as entered by the consignor", STRING, "Maximum 20 characters");

	fieldName := "carrier";
	self.initDataExtractField(_fields, CM_Container.name, "carrier", fieldName, STRING, "Receipt Carrier", "The road carrier delivering the container to the terminal", STRING, "Maximum 10 characters");

	fieldName := "wagon";
	self.initDataExtractField(_fields, CM_Container.name, "wagon", fieldName, STRING, "Receipt Wagon", "The wagon id the container was delivered to the terminal on", STRING, "Maximum 20 characters");

	fieldName := "releasedDT";
	self.initDataExtractField(_fields, CM_Container.name, "releasedDT", fieldName, TIMESTAMP, "Released Date/Time", "Date and time this container was released", TIMESTAMP, TIMESTAMP_POSSIBLEVAL);

	fieldName := "releasedTransportMode";
	self.initDataExtractField(_fields, CM_Container.name, "releasedTransportMode", fieldName, STRING, "Released Transport Mode", "What transport the container left the terminal on", STRING, "Road, Rail, Ship");

	fieldName := "deliveryRelease";
	self.initDataExtractField(_fields, CM_Container.name, "deliveryRelease", fieldName, STRING, "Delivery Release", "A users request number for a container", STRING, "Maximum 25 characters");

	fieldName := "releaseCarrier";
	self.initDataExtractField(_fields, CM_Container.name, "releaseCarrier", fieldName, STRING, "Release Carrier", "The carrier code of the company picking up a container from a terminal", STRING, "Maximum 10 characters");

	fieldName := "releaseWagon";
	self.initDataExtractField(_fields, CM_Container.name, "releaseWagon", fieldName, STRING, "Release Wagon", "The wagon id the container was released from the terminal on", STRING, "Maximum 20 characters");

	fieldName := "myCustomsAgent";
	self.initDataExtractField(_fields, CM_Container.name, "myCustomsAgent", fieldName, STRING, "Customs Agent", "Customs Agent name related to the container", STRING, "Maximum 20 characters");

	fieldName := "alternativeId";
	self.initDataExtractField(_fields, CM_Container.name, "alternativeId", fieldName, STRING, "Alternative Id", "Container's alternative ID", STRING, "Maximum 30 characters");

	fieldName := "clientRef";
	self.initDataExtractField(_fields, CM_Container.name, "clientRef", fieldName, STRING, "Client Ref", "A free text field for a client reference numbers", STRING, "Maximum 30 characters");

	fieldName := "houseBillOfLading";
	self.initDataExtractField(_fields, CM_Container.name, "houseBillOfLading", fieldName, STRING, "House Bill of Lading", "Forwarders bill on lading", STRING, "Maximum 20 characters");

	fieldName := "isAvailable";
	self.initDataExtractField(_fields, CM_Container.name, "isAvailable", fieldName, BOOLEAN, "Is Available", "True if an onsite container has no stops or todo tasks", BOOLEAN, BOOLEAN_POSSIBLEVAL);


epilog

end;</source>
