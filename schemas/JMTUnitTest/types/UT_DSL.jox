    <JadeMethod name="getChildItem" id="cea98421-5b65-49da-b8bf-6e7bc9cc9e70">
        <source>getChildItem(_parent : CM_TrackedItem;  _id : String; _ct: Integer ) : CM_TrackedItem;
/*

Purpose:		 Find Child Cargo Item fon a tracked item

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2016	cnwgb1	Initial creation

*/

vars
    child : CM_TrackedItem;
begin
    if _parent = null then
        return null;
    endif;
    foreach child in  _parent.allChildren do
        if child.id = _id and child.cargoType = _ct then
            return child;
        endif;
    endforeach;
epilog

end;</source>
        <Parameter name="_parent" type="CM_TrackedItem"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_ct" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getClassMethodCreatedBy" id="21437bfa-4cdd-4aea-9390-2f71bfdb2c98">
        <source>getClassMethodCreatedBy() : String;

/*

Purpose:		Get the class and method that created the item

Date			Who		Reason
29/08/2012 		cnwmh5	Initial creation

*/

vars
	
	callStack		: ProcessStackArray;
	methCallDesc	: MethodCallDesc;
	klass			: Class;
	
	line			: String;
	className		: String;
	classMethodName	: String;
	posSpace		: Integer;
	posDoubleSemi	: Integer;
	posOpenBracket  : Integer;
	
begin
	
	// get the class to check the subclass in 
	klass := currentSchema.getClass("UT_DSL");
	if klass = null then
		return null;
	endif;
	
	create callStack transient;
	process.currentStack(callStack);
	foreach methCallDesc in callStack do
		
		line := methCallDesc.display;
		
		// have reached the call so we need to get out of here
		if line.cnContains("Object::sendMsg") then
			break;
		endif;
		
		// get the class name
		posSpace := line.pos(" ", 1);
		posDoubleSemi := line.pos("::", posSpace);
		if posSpace = 0 or posDoubleSemi = 0 then
			continue;
		endif;
		className := line[posSpace + 1 : (posDoubleSemi - 1) - posSpace];
		
		if klass.findLocalSubclass(className) = null then
			continue;
		endif;
		
		posOpenBracket := line.pos("(", posDoubleSemi);
		if posOpenBracket &gt; 0 then
			classMethodName := line[posSpace + 1 : (posOpenBracket - 1) - posSpace];
		endif;
		break;
		
	endforeach;
	
	return classMethodName;
	
epilog
	
	callStack.purge;
	delete callStack;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
