    <JadeMethod name="getProcessHarbour" id="07fdcb30-1312-4458-8610-470fecc9f3e5">
        <source>getProcessHarbour() : CM_ProcessHarbour;
/*

Purpose:			 // TFS 38524

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgab1	Initial creation

*/

vars
	voyage : CM_Voyage;
	vprocess : CM_VoyageProcess;
	harbour : HMS_Harbour;
	processHarbour : CM_ProcessHarbour;
begin

	voyage := self.getMyVoyageObject();
	
	if voyage = null then
		return null;
	endif;
	
	vprocess := voyage.myVoyageProcess;
	
	if vprocess = null then
		return null;
	endif;
	
	
	harbour := self.getHarbour();
	
	processHarbour :=  vprocess.allProcessHarbours[vprocess,harbour];
	
	return processHarbour;
epilog

end;</source>
        <ReturnType type="CM_ProcessHarbour"/>
    </JadeMethod>
