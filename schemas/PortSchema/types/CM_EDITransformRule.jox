<Class name="CM_EDITransformRule" id="0673951e-6816-4d3d-8121-cb15c4498ac7">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <Constant name="DefaultRemoveCharsExpression" id="c309badf-e5b7-4b54-b269-8bf42786770c">
        <source>"[^A-Za-z0-9]"</source>
        <type name="String"/>
    </Constant>
    <CompAttribute name="allIgnoredKeywords" id="9a5cdd50-93b7-44b2-b136-047f3579dd7f">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <PrimAttribute name="multipleSpacesTrimmed" id="cf419cc3-ceb4-40b0-8d31-56431300b37e">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myEDIPartyRule" id="0b4ab1a6-9999-4863-b7dd-65cee3650731">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_EDIPartyRules"/>
        <access>readonly</access>
        <Inverse name="CM_EDIPartyIFCSUMRules::myFTXTransform"/>
        <Inverse name="CM_EDIPartyIFCSUMRules::myNADTransform"/>
    </ExplicitInverseRef>
    <PrimAttribute name="nonAlphaNumericCharsRemoved" id="8854319d-5a22-4548-be98-fe824750e5f9">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="removedCharsExpression" id="36e28a0c-2eee-4c35-aa58-1719b260576d">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="handleRegexException" id="6b992994-16ad-4240-b479-efce359e8a5a">
        <source>handleRegexException(_exc : JadeRegexException; _hadException : Boolean io; _nativeError : String output ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2022	jlier1	Initial creation 56234

*/

vars
	returnVal : Integer;
begin
	returnVal := Ex_Pass_Back;
	if _exc.resumable then
			returnVal := Ex_Resume_Next;
	endif;
	_nativeError:=_exc.nativeErrorMessage;
	_hadException:=true;
	
	return returnVal;
epilog

end;</source>
        <Parameter name="_exc" type="JadeRegexException"/>
        <Parameter name="_hadException" type="Boolean" usage="io"/>
        <Parameter name="_nativeError" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="956e40da-fafd-40d7-8e7c-74ed436f72f5">
        <updating/>
        <source>setForUpdate(_proxy : CM_EDITransformRule) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2022	jlier1	Initial creation 56234

*/

vars
	 pattern : JadeRegexPattern;
	 patternCompileException : Boolean;
	 patternExceptionMessage : String;
begin
	self.nonAlphaNumericCharsRemoved:=_proxy.nonAlphaNumericCharsRemoved;
	self.multipleSpacesTrimmed:=_proxy.multipleSpacesTrimmed;
	self.allIgnoredKeywords.clear;
	_proxy.allIgnoredKeywords.copy(self.allIgnoredKeywords);
	self.removedCharsExpression:=_proxy.removedCharsExpression;
	if self.removedCharsExpression = null then
		self.removedCharsExpression:=DefaultRemoveCharsExpression;
	endif;
	
	on JadeRegexException do self.handleRegexException(exception,patternCompileException,patternExceptionMessage);
	
	if self.removedCharsExpression &lt;&gt; null then
		create pattern transient;
		pattern.setAnchored(true).compile(self.removedCharsExpression);
		if not pattern.isCompiled then	
			app.raiseCMException1(Regex_pattern_error,patternExceptionMessage,null,null);
		endif;
	endif;
	
epilog
	delete pattern;
end;</source>
        <Parameter name="_proxy" type="CM_EDITransformRule"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="070d2c99-376e-46e2-986a-1329f2fe7d10">
        <updating/>
        <source>setProxy( 	_multipleSpacesTrimmed : Boolean;
			_nonAlphaNumericCharsRemoved : Boolean;
			_removedCharsExpression : String;
			_allIgnoredKeywords : StringArray input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2022	jlier1	Initial creation 56234

*/

vars

begin
	self.multipleSpacesTrimmed:=_multipleSpacesTrimmed;
	self.nonAlphaNumericCharsRemoved:=_nonAlphaNumericCharsRemoved;
	self.removedCharsExpression := _removedCharsExpression;
	self.allIgnoredKeywords.clear;
	_allIgnoredKeywords.copy(self.allIgnoredKeywords);
	
epilog

end;</source>
        <Parameter name="_multipleSpacesTrimmed" type="Boolean"/>
        <Parameter name="_nonAlphaNumericCharsRemoved" type="Boolean"/>
        <Parameter name="_removedCharsExpression" type="String"/>
        <Parameter name="_allIgnoredKeywords" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="transformText" id="13529aab-bb43-4ae5-bf5d-cd9eb9954f2e">
        <source>transformText(_text : String input) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2022	jlier1	Initial creation 56234

*/

vars
	result,
	resultKeywords:  String;
	ignoredKeyword : String;
	matches : JadeRegexResult;
	 match : JadeRegexMatch;
	 removedKeywords : Boolean;
	 i 	: Integer;
begin
	if _text = null then
		return null;
	endif;
	result:=_text;
	
	if self.nonAlphaNumericCharsRemoved then
		//should store the regex pattern
		result := JadeRegex@replaceAll(result, " ",self.removedCharsExpression, true);
	endif;
	
	//jlier1 TFS 57604 20/4/23 - problems with removing overlapping keywords like ORDER OF &amp; TO THE ORDER &amp; ORDER OF
	resultKeywords:=result;		
	foreach ignoredKeyword in self.allIgnoredKeywords do	
		JadeRegex@findAll(result,'(\b' &amp; ignoredKeyword &amp; '\b)',true, false, matches) ;
		foreach i in 1 to matches.numMatches do
			removedKeywords:=true;
			match := matches.at(i);
			resultKeywords[match.position:match.length]:=' ';
		endforeach;
		delete matches;
	endforeach;
	if removedKeywords then	
		result:=resultKeywords;
	endif;
	
	if self.multipleSpacesTrimmed or removedKeywords then
		result:= JadeRegex@replaceAll(result," ","\s{2,}",true); //this expression finds all spaces with 2 or more characters and replaces with single space
	endif;
	
	return result.trimBlanks;
epilog
	delete matches;
end;</source>
        <Parameter name="_text" type="String" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
