    <JadeMethod name="hideControl" id="729a38b7-37fb-4578-9503-71973e2a9295">
        <source>hideControl(pControl : Control input);
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if pControl = null then
		return;
	endif;
	
	pControl.visible := false;
end;</source>
        <Parameter name="pControl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="labels" id="a91dff55-7a81-4ef6-8b71-6d9f40768131">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>labels(set: Boolean; _value: Integer io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     Uses the same constant values as for Scroll Bars
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if (not set) then
		_value := self.labels;
		return;
	endif;
	
	self.labels := _value;
	
	if _value = ScrollBars_None then
		self.hideControl(self.myHLabels);
		self.hideControl(self.myVLabels);
		
	elseif _value = ScrollBars_Horizontal then
		self.showControl(self.myHLabels);
		self.hideControl(self.myVLabels);

	elseif _value = ScrollBars_Vertical then
		self.hideControl(self.myHLabels);
		self.showControl(self.myVLabels);

	elseif _value = ScrollBars_Both then
		self.showControl(self.myHLabels);
		self.showControl(self.myVLabels);
		self.showControl(self.myTopLeftFillerFrame);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="positionHScrollBar" id="0c5311b3-dfda-42fe-b271-f5d3c1ffa147">
        <source>positionHScrollBar() protected;
// ---------------------------------------------------------------------------
// Created:     15 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	verticalScrollBar		: Integer;
	tmpWidth				: Real;
begin
	if self.scrollsVertically() then
		verticalScrollBar := ScrollBarWidth;
	endif;
	tmpWidth := self.clientWidth;

	if self.myHScroll &lt;&gt; null then
		self.myHScroll.move(0, self.clientHeight - ScrollBarWidth, self.width - verticalScrollBar, ScrollBarWidth);

//		self.myHScroll.move(0, 
//							(self.clientHeight - ScrollBarWidth),
//							tmpWidth - verticalScrollBar,
//							ScrollBarWidth);
		self.myHScroll.zOrder(1);								
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="positionVScrollBar" id="5027fc04-cc63-47bf-bc14-e06771f06c89">
        <source>positionVScrollBar() protected;
// ---------------------------------------------------------------------------
// Created:     15 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	horizontalScrollBar		: Integer;
	tmpHeight				: Real;
begin
	if self.scrollsHorizontally() then
		horizontalScrollBar := ScrollBarWidth;
	endif;
	
	tmpHeight := self.clientHeight;

	if self.myVScroll &lt;&gt; null  then
		self.myVScroll.move((self.clientWidth - ScrollBarWidth),
							0,
							ScrollBarWidth,
							(tmpHeight - horizontalScrollBar));
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="purgeAllGridAreas" id="9da1b1a4-f6ee-452c-bda4-51cbb128c0ab">
        <executionLocation>client</executionLocation>
        <source>purgeAllGridAreas() clientExecution;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aGA : CMUI_GridArea;
begin
//	self.allGridAreasByColumnRow.purge;

	foreach aGA in self.allGridAreasByColumnRow reversed do
		delete aGA;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="102ca0f0-39d1-4e4a-b760-bf6ce3e716b9">
        <updating/>
        <source>repositionAfterResize() updating;
// ---------------------------------------------------------------------------
// Created:     30 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	inheritMethod();
	
	if self.myHLabels &lt;&gt; null then
		self.myHLabels.repositionAfterResize();
	endif;
	if self.myVLabels &lt;&gt; null then
		self.myVLabels.repositionAfterResize();
	endif;
	
	self.positionHScrollBar();
	self.positionVScrollBar();
	
	if self.myBottomRightFillerFrame &lt;&gt; null then
		self.myBottomRightFillerFrame.repositionAfterResize();
		self.myTopLeftFillerFrame.repositionAfterResize();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="repositionScrollBars" id="5c8de29a-1adb-4274-a95b-90f00a15f9d2">
        <source>repositionScrollBars();
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/7/2006	RBarr		PAR 11526 Changed scroll bar minimum from 1 to zero because
//							graphical content at the top was being lost when scrolling up
// ---------------------------------------------------------------------------
vars
	newTop,
	newLeft	: Integer;
	hScrollMax : Integer;
begin

// ######### AKB2002NOV - make the scrollers relative to what is on screen
   	self.myHScroll.min		:= 0;	// 1;
	self.myHScroll.max		:= self.myDrawingFrame.width.Integer;
   	self.myHScroll.smallChange	:= (self.width / 3).Integer;
   	self.myHScroll.largeChange 	:= self.width.Integer - 20;

   	self.myVScroll.min		:= 0;	// 1;
	self.myVScroll.max		:= self.myDrawingFrame.height.Integer;
   	self.myVScroll.smallChange	:= (self.height / 3).Integer;
   	self.myVScroll.largeChange 	:= self.height.Integer - 20;

// #########
	
	if self.scrollsHorizontally() then
		self.positionHScrollBar();
		self.myHScroll.visible := true;
		self.myHScroll.max := (self.myDrawingFrame.clientWidth - self.clientWidth + self.myVLabels.clientWidth).Integer;
		newLeft := self.myHScroll.value;
	else
		self.hideControl(self.myHScroll);
		newLeft := 0;
	endif;

	if self.scrollsVertically() then
		self.positionVScrollBar();
		self.myVScroll.max := (self.myDrawingFrame.height - self.clientHeight + self.myHLabels.height).Integer;
		self.myVScroll.visible := true;
		newTop := self.myVScroll.value;
	else
		self.hideControl(self.myVScroll);
		newTop := 0;
	endif;

	if self.myHScroll.visible
	and self.myVScroll.visible
	then
		self.myHScroll.max := self.myHScroll.max + ScrollBarWidth;
		self.myVScroll.max := self.myVScroll.max + ScrollBarWidth;
	   	self.myBottomRightFillerFrame.repositionAfterResize();
	   	self.myBottomRightFillerFrame.visible := true;
	else
	   	self.myBottomRightFillerFrame.visible := false;
	endif;

	if newTop &lt;&gt;self.myDrawingFrame.top or 
	   newLeft &lt;&gt; self.myDrawingFrame.left then
		self.scrollControl(ScrollBar_Horizontal, newLeft);
		self.scrollControl(ScrollBar_Vertical, newTop);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeAndRepositionChildFrames" id="530e1e01-cccf-4e33-ab65-78a053a00bee">
        <updating/>
        <source>resizeAndRepositionChildFrames() updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gridArea	: CMUI_GridArea;
	frame : CMUI_GridAreaFrame;
	oldRow,
	row,
	col			: Integer;
	x1,	y1,	x2,	y2,
	tmpPos,
	maxX2, rowHeight, lastRowY2		: Real;
		
begin

	oldRow := 0;
	
	foreach gridArea in self.allGridAreasByRowColumn do
		row := gridArea.row;
		col := gridArea.column;
		frame := gridArea.myGridAreaFrame;
		if col = 1 then
			x1 := 0;
		else
			x1 := self.allColumnEndPositions[col-1];
		endif;
		x2 := self.allColumnEndPositions[col];
		
		if row &lt;&gt; oldRow then
			y1 := y2;
			y2 := self.allRowEndPositions[row];
			lastRowY2 := y2;

			// draw row labels
//			gridArea.drawRowLabel(y1);
	
			oldRow := row;
		endif;
		if row &gt; 1 then
			rowHeight := y2 - self.allRowEndPositions[row - 1];
		else
			rowHeight := y2;
			
			// draw column labels
//			gridArea.drawColumnLabel(col.stringWithLeadingZeros(2), x1);
		endif;
		frame.move(x1, y1, (x2 - x1), rowHeight);
		maxX2 := maxX2.max(x2);
	endforeach;
	self.resizeDrawingFrame(maxX2, y2);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resizeDrawingFrame" id="b7109941-17fd-4201-877f-efcbba9795e0">
        <source>resizeDrawingFrame(pWidth, pHeight : Real);
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newTop,
	newLeft	: Integer;
	hScrollMax : Integer;
begin
	self.myDrawingFrame.width := pWidth;
	self.myDrawingFrame.height := pHeight;
	self.myHLabels.width := pWidth;
	self.myVLabels.height := pHeight;

	self.repositionScrollBars();

end;</source>
        <Parameter name="pWidth" type="Real"/>
        <Parameter name="pHeight" type="Real"/>
    </JadeMethod>
    <JadeMethod name="saveAllUsedProducts" id="25aaaa29-142b-4f8c-93d7-4e4a51080548">
        <source>saveAllUsedProducts(pAllProductsObj:CM_ProductByCodeDict);
// --------------------------------------------------------------------------------
// Created:		01 December 2005 by cnwdad1
//
// Purpose:		Updates a collection of Products that are currently "in use" within
//				a Grid Area.  This collection will be refreshed whenever a new area
//				is selected.
//
// Parameters:	pAllProductsObj - A reference to a collection of Products.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myDrawingAttrController.saveAllUsedProducts(pAllProductsObj);
end;</source>
        <Parameter name="pAllProductsObj" type="CM_ProductByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="scrollBars" id="1a38346d-d96e-4408-9226-7d8a26075c36">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>scrollBars(set: Boolean; _value: Integer io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if (not set) then
		_value := self.scrollBars;
		return;
	endif;
	
	self.scrollBars := _value;
	
	if _value = ScrollBars_None then
		self.hideControl(self.myHScroll);
		self.hideControl(self.myVScroll);
		
	elseif _value = ScrollBars_Horizontal then
		self.showControl(self.myHScroll);
		self.hideControl(self.myVScroll);

	elseif _value = ScrollBars_Vertical then
		self.hideControl(self.myHScroll);
		self.showControl(self.myVScroll);

	elseif _value = ScrollBars_Both then
		self.showControl(self.myHScroll);
		self.showControl(self.myVScroll);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="scrollControl" id="a6a3673f-2498-4337-b6f7-bc1857d630c4">
        <source>scrollControl(pDirection : Integer; pValue : Integer);
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	offsetY1, tmpValue	: Integer;

begin
	on Exception do self.handleInvalidMethodCall(exception);

	if pDirection = ScrollBar_Horizontal then
		if self.myVLabels.visible then
			tmpValue := self.myVLabels.width.Integer;
		endif;
		tmpValue := tmpValue - pValue;
		self.myDrawingFrame.left := tmpValue;
		if self.myHLabels &lt;&gt; null then
			self.myHLabels.left := tmpValue;
		endif;
	else
		if self.myHLabels.visible then
			tmpValue := self.myHLabels.height.Integer;
		endif;
		
		// 
		if self.myParentForm &lt;&gt; null then
			// This is initially only used by the RORO Planning Screen
			offsetY1 :=	self.myParentForm.sendMsgWithParams("doGetYOffset", pValue).Integer;
			if offsetY1 &lt;&gt; 0 then
				offsetY1 := (offsetY1 * self.scaleFactor).Integer;
				offsetY1 := offsetY1 -10;
	//			offsetY1 := (offsetY1 - self.myHLabels.height).Integer;
			endif;
		endif;
		
		tmpValue := tmpValue - pValue - offsetY1;
		self.myDrawingFrame.top := tmpValue;
		if self.myVLabels &lt;&gt; null then
			self.myVLabels.top := tmpValue;
		endif;
	endif;
	
	self.myDrawingFrame.scrollControl(pDirection, pValue);
	
	// if I have a twin then scroll them as well
	if self.mySDF &lt;&gt; null then
		self.mySDF.scrollControl(pDirection,pValue);
		
	endif;
end;</source>
        <Parameter name="pDirection" type="Integer"/>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="scrollsHorizontally" id="5596fa1e-33d5-4b0a-bbb8-7312a25ad3eb">
        <source>scrollsHorizontally() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theWidth : Integer;
begin


	if self.myDrawingFrame &lt;&gt; null then
		theWidth := self.myDrawingFrame.clientWidth + self.myVLabels.clientWidth;

		if (self.scrollBars = ScrollBars_Horizontal or self.scrollBars = ScrollBars_Both) 
		and  self.clientWidth &lt; theWidth then
			return true;
		endif;
	endif;	
	return false;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="scrollsVertically" id="80a84c2a-7b61-4965-97fc-c3c12989e9e5">
        <source>scrollsVertically() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theHeight : Integer;

begin
	if self.myDrawingFrame &lt;&gt; null then
		theHeight := self.myDrawingFrame.clientHeight + self.myHLabels.clientHeight;
		
		if (self.scrollBars = ScrollBars_Vertical
		or self.scrollBars = ScrollBars_Both)
		and self.clientHeight &lt; theHeight
		then
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectPointsWithinXYs" id="b1ff39cc-d656-4d4a-87b1-3edba4fd260b">
        <source>selectPointsWithinXYs(_x1,_y1,_x2,_y2 : Integer);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDrawingFrame" id="94271a95-6993-44f7-b640-b40e5e952822">
        <updating/>
        <source>setDrawingFrame(_frame : CMUI_DrawingFrame input) updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _frame = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'frame', null, null);
		return;
	endif;

	if self.myDrawingFrame = _frame then
		return;
	endif;

	if self.myDrawingFrame &lt;&gt; null then
		delete self.myDrawingFrame;
	endif;
	
	self.myDrawingFrame := _frame;

   	_frame.move(0, 0, _frame.width, _frame.height);
	_frame.visible := true;
	self.setFrameDefaults(_frame);
	_frame.borderStyle := BorderStyle_None;
	_frame.parent 	:= self;
	_frame.zOrder(0);		// send to the back
	
end;</source>
        <Parameter name="_frame" type="CMUI_DrawingFrame" usage="input"/>
