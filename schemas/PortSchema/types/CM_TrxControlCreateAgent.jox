	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateAS400FileLoad(id, docketFile, logFile, terminal, _newFileLoad, _root, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
