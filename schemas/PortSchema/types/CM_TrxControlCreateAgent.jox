    <JadeMethod name="trxCreateSealsCheckOnGTE" id="c2ca8c1f-9df7-4bfd-91bf-3ab713809067">
        <updating/>
        <source>trxCreateSealsCheckOnGTE(	_proxySealCheckTrx : CM_SealCheck input;
							_gte : CMGTE_Receival io;
							_toDoTaskDescToAdd : CM_ToDoTaskDesc;
							_allSealsToUpdate : CM_SealTIBySealTypeDict;
							_passport : CM_Passport input)
							updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2014	cnwndl1	Initial creation	Par 34076

*/

//Just add a copy of the proxy seal checks details ontto the GTE
//proxy Seal Check on the transaction has a collection of these.
		
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	
	// Start the transaction
	beginTransaction;
	
	if _toDoTaskDescToAdd &lt;&gt; null then
		_gte.addToDoTask( _toDoTaskDescToAdd, _passport );
	endif;
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _proxySealCheckTrx &lt;&gt; null then
		_gte.replaceSealCheckDetails( _proxySealCheckTrx.allSealCheckDetails );
	endif;
	
	//14 Jun 2017	NDL	TFS 4656
	if _allSealsToUpdate &lt;&gt; null and not _allSealsToUpdate.isEmpty then
		_gte.setUpdatedSeals( _allSealsToUpdate);
	endif;
	
	
epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_proxySealCheckTrx" type="CM_SealCheck" usage="input"/>
        <Parameter name="_gte" type="CMGTE_Receival" usage="io"/>
        <Parameter name="_toDoTaskDescToAdd" type="CM_ToDoTaskDesc"/>
        <Parameter name="_allSealsToUpdate" type="CM_SealTIBySealTypeDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateSealsCheckTransaction" id="6ce24eec-4acd-49a2-9840-d57ec5efbd35">
        <updating/>
        <source>trxCreateSealsCheckTransaction(	_tiTransactionController : CMIF_TITransactionController input;
								_theTIProxy 			 : CM_TrackedItem io;
								_tiUpdateRequired 		 : Boolean;
								_getReceival			 : CMGTE_Receival;	//20 Nov 2019	NDL	TFS 47568
								_newTITransaction 		 : CM_TITransaction output;
								_editFieldsValues 		 : HugeStringArray;
								_passport 				 : CM_Passport input)
								updating;

/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#				Description
============================================================================
10 Sep 2010	cnwndl1	Par 25608 
					/ SFW CCMS 1131		Initial creation	
24 Nov 2015	cnwkpd1	PAR #36805 			Performance and locking issues
										Change this transaction to use deferred updates to prevent deadlocks
29 Mar 2019 jlgka1	TFS 44020			Change StringArray to HugeStringArray.
============================================================================*/
vars

	theTransactionController	: CMIF_TITransactionController;
	txnControllerDict 			: CMIF_TITxnContrlrByTypeDTDict;
	realTi 						: CM_TrackedItem;
	userStr 					: String;
	trans 						: CM_Edit;
	str 						: String;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	_passport.useTIDictDeferUpdate	:= true;			// PAR #36805
	_passport.useTITransactionDeferUpdate := true;
	
	realTi := _theTIProxy.pxyGetRealObject;
	create txnControllerDict transient;
	create theTransactionController transient;
	
	// Start the transaction
	beginTransaction;
	
	// Create the seal checks transaction
	app.myUtilityCA.utlCreateTITransaction(_tiTransactionController, _newTITransaction, _passport);
	
	if _passport.noErrors and _tiUpdateRequired then
		
		if _editFieldsValues &lt;&gt; null and not _editFieldsValues.isEmpty then
			// create the 'CM_Edit' transaction for the seals changes.
			if _passport.userCode = null then
				userStr := app.getErrorString(UnknownUser);
			else
				userStr := _passport.userCode;
			endif;
			theTransactionController.userId := userStr;
			theTransactionController.dateTime := app.serverTimestampAtTrxStart;
			theTransactionController.myTrackedItem := realTi;
			theTransactionController.myOtherTrackedItem := null;
			theTransactionController.noCharge := false; //TFS 3844 changed to false
			theTransactionController.type := TRANS_TYPE_EDIT;
			trans := realTi.createTransaction(theTransactionController, _passport).CM_Edit;	
			foreach str in _editFieldsValues do
				trans.fieldsValues.add(str);
			endforeach;
			
		endif;
		
		// update the seals information and to do task already put on the ti proxy if required.
		app.myUtilityUA.utlUpdateTrackedItem(_theTIProxy, null, TI_UPDMODE_NORMAL, txnControllerDict, null, null, _passport);
		
		//20 Nov 2019	NDL	TFS 47568 - moved from the form.
		if _passport.noErrors then
			if _getReceival &lt;&gt; null and realTi &lt;&gt; null then
				_getReceival.setUpdatedSeals( realTi.allSeals );
			endif;
		endif; 
		
	endif;
	
	if _passport.noErrors then					// PAR #36805
		_passport.doDeferredUpdates();	
	endif;
	
epilog
	delete theTransactionController;
	delete txnControllerDict;
	self.finaliseActivityWithPassport(_passport);	
end;</source>
        <Parameter name="_tiTransactionController" type="CMIF_TITransactionController" usage="input"/>
        <Parameter name="_theTIProxy" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_tiUpdateRequired" type="Boolean"/>
        <Parameter name="_getReceival" type="CMGTE_Receival"/>
        <Parameter name="_newTITransaction" type="CM_TITransaction" usage="output"/>
        <Parameter name="_editFieldsValues" type="HugeStringArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
