        <updating/>
        <source>actionEventRequestStops(_bgpEmailDict : BGP_EmailReqByUserAddressDict input; _eventReqEmail : CM_EventRequestEmail; _passport : CM_Passport input)updating, protected;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	iter : Iterator;
begin
	
	iter := self.allEventRequestsStops.createIterator();
	self.allEventRequestsStops.startKeyGeq(EventRequestMatched, null, iter);
	self.actionEventRequestSend(_bgpEmailDict, _eventReqEmail, iter, _passport);

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_bgpEmailDict" type="BGP_EmailReqByUserAddressDict" usage="input"/>
        <Parameter name="_eventReqEmail" type="CM_EventRequestEmail"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addReportToUserTerminalSecRole" id="514f6896-54c5-469f-b3a7-b4ace2b80e09">
        <source>addReportToUserTerminalSecRole(_qryReport : CM_QryReportUser);
// -------------------------------------------
// Created 17 September 2004 by cnwdvb1
// -------------------------------------------
vars

	userTerminal,
	userTerminalOther	: CM_UserTerminal;
	set					: ObjectSet;
	role				: Object;
	numParts,
	numDone				: Integer;
	securityRole		: CM_SecurityRole;

begin

	create set transient;
	foreach userTerminal in self.allUserTerminals do
		if (not set.includes(userTerminal.mySecurityRole)) then
			set.add(userTerminal.mySecurityRole);
			securityRole := userTerminal.mySecurityRole.myParentRole;
			if  securityRole &lt;&gt; null and not set.includes(securityRole) then
				set.add(securityRole);
			endif;
		endif;
	endforeach;
	
	foreach role in set do
		//we now have all roles to be updated - no longer need to call this to find out how many
		//role.CM_SecurityRole.getNoOfUserTermsRecursive(numParts);
		numParts := numParts + role.CM_SecurityRole.allUserTerminals.size;
	endforeach;
	
	foreach role in set do
		role.CM_SecurityRole.addRptResetRptMenus(_qryReport, numParts, numDone);
	endforeach;
	
epilog
	delete set;
end;</source>
        <Parameter name="_qryReport" type="CM_QryReportUser"/>
    </JadeMethod>
