    <JadeMethod name="pxyCreateUpdateProxy" id="2563f509-947e-42f3-8113-3e23b1f732e4">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 14 June 2023 navmv20 CR 58215 Task 58217: UI - Invoice Process Email

*/

vars

	pxyProcess : CM_InvoiceProcess;
	pxyEmailTemplate : CM_EmailTemplate;
	completedOK : Boolean;

begin
	pxyProcess := inheritMethod();
	
	if self.myEmailTemplate &lt;&gt; null then
		pxyEmailTemplate := self.myEmailTemplate.pxyCreateUpdateProxy();
		pxyEmailTemplate.setMyParent(pxyProcess);
	endif;
	
	completedOK := true;
	return pxyProcess;

epilog
	if not completedOK then
		delete pxyProcess;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="641b1512-4c48-4608-8234-ca39c58fa877">
        <updating/>
        <source>setForCreate(_pxyProcess : SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Jan 2019	jlgsl4	TFS 39618 - LNX - Invoice Approved Status

*/

vars

begin
	self.setForUpdate(_pxyProcess);
	
	self.myRoot := app.myRoot;
epilog

end;</source>
        <Parameter name="_pxyProcess" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ae584348-25f4-4377-8dc8-16523e53b9e5">
        <updating/>
        <source>setForUpdate(_pxyProcess : SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Oct 2018	jlgsl4	TFS 39618 - LNX - Invoice Approved Status
14 June 2023 navmv20 CR 58215 Task 58217: UI - Invoice Process Email
*/

vars
	template : CM_EmailTemplate; //14/06/2023 navmv20 CR 58215 Task 58217	
begin
	self.code := _pxyProcess.code;
	self.description := _pxyProcess.description;
	self.pinEmailOffset := _pxyProcess.pinEmailOffset;
	
	//14/06/2023 navmv20 CR 58215 Task 58217 - START
	if self.myEmailTemplate = null and _pxyProcess.myEmailTemplate &lt;&gt; null then
		create template persistent;
		template.setMyParent(self);
		template.setForUpdate(_pxyProcess.myEmailTemplate);
	endif;
	if self.myEmailTemplate &lt;&gt; null then
			self.myEmailTemplate.setForUpdate(_pxyProcess.myEmailTemplate);
	endif;
	//14/06/2023 navmv20 CR 58215 Task 58217 - END
epilog

end;</source>
        <Parameter name="_pxyProcess" type="SelfType"/>
    </JadeMethod>
