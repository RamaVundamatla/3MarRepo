    <JadeMethod name="create" id="fc235c05-8aaf-49c0-80c9-c6874a4b2c37">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 October 2010	cnwndl1	Initial creation	Par 25530

*/

vars

begin

	self.permissionView	:= PmGteVehSchView;
	self.permissionMaint := PmGteVehSchMaint;

	// NAVAB1 23NOV2021 Dmast Wmast Differences
	if not app.getMyUser.canDoSomewhere( PmGteVehSchView ) then
		self.permissionView	:= PmGteVehSchWeb;
		self.permissionMaint := PmGteVehSchWeb;
	endif;
	

epilog

end;</source>
