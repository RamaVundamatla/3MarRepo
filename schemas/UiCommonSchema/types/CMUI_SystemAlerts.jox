        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAll_click(btn: Button input) updating;
/*
------------------------------------------------------------------------
Created:			10 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

begin
	self.currentButton := BTN_ALL;
	self.displayAlerts();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
