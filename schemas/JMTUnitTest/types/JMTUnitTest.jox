    <JadeMethod name="extractResultSummForTesting" id="49d1dc6a-e2f4-4eea-ab96-064bf691cf57">
        <source>extractResultSummForTesting();
/*

Purpose:			To extract the run details for a specific date
					This is used by Testing to get the details of a 
					specific run based on the date passed into it

Parameters:			

Return Value:		

Date		Who		Reason
09/08/2024	navmh5	Initial creation

*/

vars
	
	file							: File;	
	root							: UM_Root;
	testRun							: UM_UnitTestRun;
	
	iter							: Iterator;
	
	paramNames						: StringArray512;
	paramValues						: StringArray512;
	paramArray						: StringArray512;

	pos								: Integer;
	commandLineStr					: String;
	posEqual						: Integer;
	posEqual2						: Integer;
	tempStr							: String;
	posSpace						: Integer;
	timeToLeave						: Boolean;
	
	receivedDate					: String;
	date							: Date;
	fileName						: String;
	searchTS						: TimeStamp;
	
begin

	app.initialize();
	
	commandLineStr := self.getThinClientCommandLine();
	//commandLineStr := "Date=09/08/2024";
	write "commandLineStr: " &amp; commandLineStr;
	create paramArray transient;
	pos := commandLineStr.toLower().pos("endjade", 1);
	if pos &lt;&gt; 0 then
		commandLineStr := commandLineStr[pos + 7:end];
	endif;

	while (true) do
	
		// Get the 1st =
		posEqual := commandLineStr.pos("=", 1);
		if posEqual = 0 then
			break;
		endif;
		write commandLineStr &amp; Tab &amp; posEqual.String;
		
		// get the next =
		posEqual2 := commandLineStr.pos("=", posEqual + 1);
		write "posEqual2: " &amp; posEqual2.String;
		
		// work out what the string is
		if posEqual2 &gt; 0 then
			posSpace := commandLineStr.reversePosIndex(" ", posEqual2);
			tempStr := commandLineStr[1:posSpace].trimBlanks();
			commandLineStr := commandLineStr[posSpace:end].trimBlanks();
		else
			tempStr := commandLineStr;
			timeToLeave := true;
		endif;
						
		// get the parameters
		paramArray.clear();
		tempStr.getTokensForDelimiter("=", paramArray);
		write "paramArray: " &amp; paramArray[1] &amp; Tab &amp; paramArray[2];
		if paramArray[1] = "Date" then
			receivedDate := paramArray[2];
		endif;	
		
		// break out as no more items on the line
		if timeToLeave then
			break;
		endif;
	
	endwhile;
	
	
	date := receivedDate.asDate();
	
	write "date: " &amp; date.String;
	
	searchTS := app.cnGetServerTime();
	searchTS.setDate(date);
	searchTS.setTime("23:59:59".Time);
	write "searchTS: " &amp; searchTS.String;
	
	root := UM_Root.firstInstance;
	if root = null then
		app.msgBox("Unable to find instance of UM_Root.  Exiting Jadescript...", "UM_Root Error", 
			MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	iter := root.allUnitTestRuns.createIterator;
	root.allUnitTestRuns.startKeyLeq(searchTS, iter);
	while iter.next(testRun) do
		break;
	endwhile;
	
	write "TestRun Details: Run: " &amp; testRun.numRun.asStringJMT() &amp;
		"    Passed: " &amp; testRun.numPassed.asStringJMT() &amp;
		"    Failed: " &amp; testRun.numFailed.asStringJMT();
		
	
	fileName := "DetailForRunDated_" &amp; date.year.String &amp; date.month.padLeadingWith("0", 2).String &amp; 
		date.day.padLeadingWith("0", 2).String &amp; ".txt";
	create file transient;
	file.fileName := "c:\temp\" &amp; fileName;
	file.usePresentationFileSystem := true;
	file.mode := File.Mode_Output;
	
	write "file.fileName: " &amp; file.fileName;
	
	file.writeString("No Run,Passed,Failed" &amp; CrLf &amp; testRun.numRun.asStringJMT() &amp; 
		"," &amp; testRun.numPassed.asStringJMT() &amp; "," &amp; testRun.numFailed.asStringJMT());
	file.close(); 

epilog

	delete file;
	delete paramNames;
	delete paramValues;
	delete paramArray;
	
	app.finalize();
	terminate;
	
end;</source>
    </JadeMethod>
