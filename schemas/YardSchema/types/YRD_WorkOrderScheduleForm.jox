    <JadeMethod name="addRowToSchedule" id="878536df-26ea-4761-805b-1a84d02692a2">
        <updating/>
        <source>addRowToSchedule(_dateTime: TimeStamp; _col1Value: String; _col2Value: String; _col3Value: String; _atRow : Integer) updating;
// -----------------------------------------------------------------------------
// Created:		17 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// -----------------------------------------------------------------------------

vars
	col, row : Integer;
	localDateTime : TimeStamp;
begin
	row := _atRow;
	//27 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	localDateTime := self.systemToLocalTime(_dateTime);
	if row = 0 then
		row := self.tblSchedule.addItem( localDateTime.asStringJMT() );
	else
		self.tblSchedule.addItemAt( localDateTime.asStringJMT(), row);
	endif;
	
	self.tblSchedule.accessColumn(1).visible := false;
	//self.tblSchedule.accessCell(row,1).  itemObject := localDateTime;
	self.tblSchedule.accessCell(row,1).gridRight := false;	
	self.tblSchedule.accessCell(row,2).gridRight := false;
	//self.tblSchedule.accessCell(row,3).gridRight := false;	
	
	if _col1Value &lt;&gt; null then
		self.tblSchedule.accessCell(row,2).text := _col1Value &amp; CrLf &amp; _col2Value;	
	else
		self.tblSchedule.accessCell(row,2).text :=  _col2Value;	
	endif;
	
//	self.tblSchedule.accessCell(row,2).text := _col1Value;
	//self.tblSchedule.accessCell(row,3).text := _col2Value;
	self.tblSchedule.accessCell(row,3).text := _col3Value;
	
	if localDateTime &gt; self.currentTS then
		if localDateTime.date.day mod 2 = 1 then
			self.tblSchedule.accessCell(row, 1).backColor := self.colorRow1;
			self.tblSchedule.accessCell(row, 2).backColor := self.colorRow1;
			self.tblSchedule.accessCell(row, 3).backColor := self.colorRow1;
			self.tblSchedule.accessCell(row, 4).backColor := self.colorRow1;
		else
			self.tblSchedule.accessCell(row, 1).backColor := self.colorRow2;
			self.tblSchedule.accessCell(row, 2).backColor := self.colorRow2;
			self.tblSchedule.accessCell(row, 3).backColor := self.colorRow2;
			self.tblSchedule.accessCell(row, 4).backColor := self.colorRow2;
		endif;
		
	
	/*
		self.tblSchedule.accessCell(row, 1).backColor := self.colorHeadingColumn;
		self.tblSchedule.accessCell(row, 2).backColor := self.colorHeadingColumn;
		self.tblSchedule.accessCell(row, 3).backColor := self.colorHeadingColumn;
		self.tblSchedule.accessCell(row, 4).backColor := self.colorHeadingColumn;
		*/
		col := self.tblSchedule.fixedColumns + 1;
		while col &lt; self.tblSchedule.columns do
			self.tblSchedule.accessCell(row,col).inputType := Table.InputType_TextNumeric;
			self.tblSchedule.accessCell(row,col).cellControl := self.txtEditable;
			self.tblSchedule.accessedCell.backColor := self.colorValueColumn;
			col := col + self.TaskColumns;			
		endwhile;
	else
		col := self.tblSchedule.fixedColumns + 1;
		self.tblSchedule.accessCell(row,col).inputType := Table.InputType_TextNumeric;
		self.tblSchedule.accessCell(row,col).cellControl := self.txtReadOnly;
		

	endif;

epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_col1Value" type="String"/>
        <Parameter name="_col2Value" type="String"/>
        <Parameter name="_col3Value" type="String"/>
        <Parameter name="_atRow" type="Integer"/>
    </JadeMethod>
