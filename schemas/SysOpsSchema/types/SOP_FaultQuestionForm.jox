    <JadeMethod name="setupForm" id="6e182aad-44a6-44ea-ac21-4cff607b86b1">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 September 2007	cnwer1	Initial creation - CCMS 1071 

*/
vars
	faultQuestion : CM_FaultQuestion;
	faultType : CM_FaultType;
	failure : String;
begin
	self.showToolbar := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.txtQuestion.configureFor_Text;
	inheritMethod();
	self.caption:='Fault Question Maintenance';
	if self.myFaultQuestion  &lt;&gt; null then
		faultType:=self.myFaultQuestion.myFaultType;
		failure :=self.myFaultQuestion.failureCondition;
		self.txtQuestion.text:=self.myFaultQuestion.description;
	else
		faultType:=null;
		failure:=null;
		self.txtQuestion.text:=null;
	endif;
	self.myAssistant.comboBoxFaultType(cmbFaultType,faultType,true);
	self.myAssistant.comboBoxFaultFailureCondition(self.cmbFailure,failure);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b5f4ac74-65b7-42dd-8cac-1f4880ccfb57">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 July 2018 15:58:20.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022862, locale);
	btnNext.translateBubbleHelp(Xlat_0007027, locale);
	btnNext.translateCaption(Xlat_0007028, locale);
	lblFailure.translateCaption(Xlat_0007029, locale);
	lblFaultType.translateCaption(Xlat_0007030, locale);
	lblQuestion.translateCaption(Xlat_0007031, locale);
	mnuContext.translateCaption(Xlat_0007032, locale);
	mnuCopy.translateCaption(Xlat_0007033, locale);
	mnuCur.translateCaption(Xlat_0007034, locale);
	mnuPaste.translateCaption(Xlat_0007035, locale);
	mnuRedo.translateCaption(Xlat_0007036, locale);
	mnuSelectAll.translateCaption(Xlat_0007037, locale);
	mnuUndo.translateCaption(Xlat_0007038, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtQuestion_contextMenu" id="0b7cfcf0-d92e-4ffb-9732-76f476e93fd5">
        <controlMethod name="JadeTextEdit::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtQuestion_contextMenu(textedit: JadeTextEdit input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 October 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	xLeft,yTop : Real;
	
begin
	xLeft := x;
	yTop := y;
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	mnuContext.userObject:=textedit;
	self.popupMenu(mnuContext,xLeft.Integer, yTop.Integer);
	
	return true;
epilog

end;</source>
        <Parameter name="textedit" type="JadeTextEdit" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
