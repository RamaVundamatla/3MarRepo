    <JadeMethod name="create" id="fd6e098f-0241-4fa6-bf2e-2d1a06aed838">
        <updating/>
        <source>create() updating;

begin
	// these are required for booking refs
	createInputFile(operatorFile, "Operators.txt");
	createInputFile(isoTypeFile, "ISOTypes.txt");

	createInputFile(userFile, "UserIds.txt");
	createInputFile(userListFile, "UserIdList.txt");
	createInputFile(bookingRefFile, "BookingRefs.txt");
	createInputFile(bookingRefListFile, "BookingRefList.txt");
	createInputFile(rfidTagFile, "rfidTags.txt");
	createInputFile(rfidTagListFile, "rfidTagList.txt");
	
	createInputFile(baplieTemplateFile, "BaplieTemplate.txt");
	createInputFile(baplieFile, "Baplie_"&amp;app.sequenceId.String&amp;".txt");
	
	carrierIterator:=app.myRoot.allCarriers.createIterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="createBookingRef" id="e905bdca-acd3-456b-8cd2-b375feabfc48">
        <source>createBookingRef(_bookingRefId:String):CM_BookingRef;

vars
	newBookingRef,
	pxyBookingRef		: CM_BookingRef;
	tmpHazards			: ObjectArray;
	disPorts			: StringArray;
begin
	create pxyBookingRef transient;
	create disPorts transient;
	create tmpHazards transient;
	/*pxyBookingRef.setProxy(_bookingRefId,
							null,
							TI_CargoType_Container,
							false,
							app.myPassport.myTerminal.getConfig(EmptyCommodity).String.trimBlanks,
							null,
							"Cargo for JMT Benchmarking",
							'AUBNE',//destination brisbane
							'AUBNE',//also the discharge port
							disPorts,//optional discharge ports stringarray (empty)
							tmpHazards, //hazards
							null, //humidity
							false, //inspected
							selectRandomISOType, //20ft, 40ft etc container type
							app.myRoot.allConsigneeConsignors.first, //consignor
							app.myRoot.allConsigneeConsignors.first, //consignee
							app.myRoot.allOperators[selectRandomOperator],
							app.myPassport.myTerminal.getNullVoyage,
							null,
							"Booking Ref for JMT Benchmarking",
							null,//remarks
						//	null,//status
							null,//temperature
							null,
							null,//height
							null,//length
							null,//width
							null, //height string
							null, // length string
							null, // width string
							null,//type
							null,//density
							null,//volume
							null,//product quantity
							null,//weight
							null,//cubic meters
							app.myPassport.myTerminal,
							null, //product
							false,
							false,
							null, null,
							null, // shippingRef
							null, null, null, null,
							null, null, null, null, 
							null, null, null, null, null, null
							);/**/
	app.myPassport.warningsAcknowledged := true;
	app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateBookingRef(pxyBookingRef, app.myPassport, null, newBookingRef);				
	
	if (not app.myPassport.trxCompletedOK) then
		app.msgBox('Booking reference creation failed for "' &amp; _bookingRefId &amp; '". Here comes the inspect of the errors...','Booking reference creation failure', MsgBox_Exclamation_Mark_Icon);
		
		app.myPassport.allErrorWarnings.inspectModal;
		return null;
	endif;
	
	return newBookingRef;
	
epilog
	delete pxyBookingRef;
	delete disPorts;
	delete tmpHazards;
end;</source>
        <Parameter name="_bookingRefId" type="String"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="createInputFile" id="4731cca2-1d91-45b0-a900-7f7cb8871695">
        <source>createInputFile(f:File io; fileName:String);

begin
	create f;
	f.mode:=File.Mode_Input;
	f.kind := File.Kind_Unknown_Text;	// 2/3/16 cnwmp6 PAR 36286 unicode version
	
	if fileName[1:7] = "Baplie_" then  // new baplie file is kept on thin client machine
		f.usePresentationFileSystem:=true;
		f.fileName:=app.getJadeInstallDir&amp;"\"&amp;fileName;
	else
		f.usePresentationFileSystem:=false;
		f.fileName:=app.dbPath.toLower.replace("c_system","c_misc\jtd\")&amp;fileName;
	endif;
end;</source>
        <Parameter name="f" type="File" usage="io"/>
        <Parameter name="fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="createRandomFiles" id="921cb6af-5d18-42e2-b603-05f5462f0e18">
        <source>createRandomFiles();
//	When setting up for a new database, these are also required:
//		get a suitable baplie file (\server\c_misc\jtd\BaplieTemplate.txt)
//		select a suitable vessel, shipping line and trade in vp004_saveVoyageDef
//		select a suitable terminal and hard code it in JtdDriverSchemaApp::initialize
//		also terminal area - see vp002_createWorkingSet
vars
	user:CM_User; userTerminal:CM_UserTerminal; op:CM_Operator;
	bookingRef:CM_BookingRef;
	rfidTag:CM_RFIDTag;
	s,t,u:String;  i,j,k:Integer;
begin
	// prepare operators
	beginTransaction;
	foreach op in app.myRoot.allOperators do
		op.setPropertyValue('requiresBookingReference', false);
		op.setPropertyValue('requiresCVC', false);
		op.setPropertyValue('requiresDeliveryRelease', false);
		op.setPropertyValue('requiresHumidity', false);
		op.setPropertyValue('requiresRequestNumber', false);
		op.setPropertyValue('requiresVentilation', false);
		op.setPropertyValue('requiresVoyage', false);
		op.setPropertyValue('isNotAvailableForEntry', false);
	endforeach;
	commitTransaction;

	// do operator file
	operatorFile.mode:=File.Mode_Output;
	operatorFile.writeString(",MSK,MSK,MSK,MSK,MSK,MSK,MSK,MSK,PON,CSA,COL,ANZ,NYK,MOL,MSK,MSK,MSK,MSK,MSK,MSK,MSK,MSK,MSK,MSK,MSK,MSK,MSK,MSK,PON,CSA,COL,ANZ,NYK,MOL,MSK,MSK,MSK,MSK,MSK,MSK,"&amp;"".padBlanks(94));
	operatorFile.close;
	operatorFile.mode:=File.Mode_Input;
	operatorFile.kind := File.Kind_Unknown_Text;	// 2/3/16 cnwmp6 PAR 36286 unicode version
	write "operators written"; /* */

	// do isoType file
	isoTypeFile.mode:=File.Mode_Output;
	//th2 changed 12/02/2007 - too much 40ft weighting
	isoTypeFile.writeString(",2200,4200,2232,4330,2255,4350,2200,4200,2232,4330,2255,4350,2200,4200,2232,2200,2255,4350,2200,4200,2232,4330,2255,2200,"&amp;"".padBlanks(92));
	isoTypeFile.close;
	isoTypeFile.mode:=File.Mode_Input;
	isoTypeFile.kind := File.Kind_Unknown_Text;	// 2/3/16 cnwmp6 PAR 36286 unicode version
	write "isoTypes written"; /* */

	// do user file
	userFile.mode:=File.Mode_Output;
	userFile.writeString(",");

	i:=0;
	foreach user in app.myRoot.allUsers do :userLoop
		//exlude superuser from the mix as he's treated differently throughout the code
		s:=user.code.toUpper;
		if s.pos('CNW', 1) &lt; 1 or (not CM_SecurityRoleSystemRoot.hasInstance(user.mySystemSecurityRole)) then
			continue;
		endif;
		
		foreach userTerminal in user.allUserTerminals do : userTerminalLoop
			if (not CM_SecurityRoleTerminalRoot.hasInstance(userTerminal.mySecurityRole)) then
				continue userLoop;
			endif;
		endforeach;
		
		setupUser(user);  // set password, etc
		
		//user has top level security at system and terminal levels
		if user.code.cnContains(',')=false and user.code.length &gt; 0 then
			userFile.writeString(user.code&amp;',');
			i:=i+1;
		endif;
	endforeach;
	userFile.writeString(''.padBlanks(91));  // ensure all usercodes are used - selectRandom reads 100 bytes
	write "total users written to file: "&amp;i.String; /* */

	// do booking ref file (requires operator file and iso type file)
	bookingRefFile.mode:=File.Mode_Output;
	bookingRefFile.writeString(",");

	beginTransaction;
	CM_BookingRef.instances.purge();
	commitTransaction;
	
	foreach i in 1 to 100 do
		s := "JBLBOOKING" &amp; i.String;
		bookingRef := app.myPassport.myTerminal.allBookingRefsByRef[s];
		if bookingRef = null then
			bookingRef := createBookingRef(s);
		endif;
		bookingRefFile.writeString(s&amp;',');
	endforeach;
	write "total booking refs written: "&amp;(i-1).String; /* */

	// do rfid tag file
	rfidTagFile.mode:=File.Mode_Output;
	rfidTagFile.writeString(",");
	
	i:=0;
	foreach rfidTag in app.myPassport.myTerminal.allRFIDTagsBySerialNo where rfidTag.myRoadJob = null do
		beginTransaction;
		rfidTag.setPropertyValue('isAvailableForEntry', true);
		commitTransaction;
		rfidTagFile.writeString(rfidTag.serialNumber&amp;',');
		i:=i+1;
	endforeach;
	rfidTagFile.writeString(''.padBlanks(99));  // ensure all usercodes are used - selectRandom reads 100 bytes
	write "total rfid tags written: "&amp;(i-1).String; /* */
end;</source>
    </JadeMethod>
    <JadeMethod name="createRandomListFiles" id="c3fdbeca-2db2-4d0a-8c60-9d4c7b3afb5c">
        <source>createRandomListFiles();

vars
	s,t,u:String;  i,j,k:Integer;  sa:StringArray;
begin
	k:=200;
	create sa transient;

	userListFile.mode:=File.Mode_Output;
	foreach i in 1 to k do
		s:=selectRandomUser.code;
		if not sa.includes(s) then
			userListFile.writeLine(s);
			sa.add(s);
		endif;
	endforeach;

	bookingRefListFile.mode:=File.Mode_Output;
	foreach i in 1 to k do
		bookingRefListFile.writeLine(selectRandomBookingRef);
	endforeach;

	sa.clear;
	rfidTagListFile.mode:=File.Mode_Output;
	foreach i in 1 to k do
		s:=selectRandomRFIDTag.serialNumber;
		if not sa.includes(s) then
			rfidTagListFile.writeLine(s);
			sa.add(s);
		endif;
	endforeach;

epilog
	delete sa;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="4a8deaf2-8337-4d4c-9cd1-b0b839c14425">
        <updating/>
        <source>delete() updating;

begin
	delete userFile;
	delete userListFile;
	delete operatorFile;
	delete isoTypeFile;
	delete bookingRefFile;
	delete bookingRefListFile;
	delete rfidTagFile;
	delete rfidTagListFile;

	delete baplieTemplateFile;
/*	if baplieFile &lt;&gt; null and baplieFile.isAvailable then
		baplieFile.purge();  // only one file per planner, so leave them in place in case debugging is required
	endif; /* */
	
	delete baplieFile;
	
	delete carrierIterator;
end;</source>
    </JadeMethod>
    <JadeMethod name="getNextBaplieFile" id="973d1bf2-0e1d-4ef1-95ec-51b213bd1b52">
        <updating/>
        <source>getNextBaplieFile(voyageCode:String) updating;

vars
	i,seqnum:Integer;
	s,destPort:String;
begin
	destPort:=app.getMyTerminalConfig(PortDestCode).String;
	baplieFile.close;
	baplieFile.mode:=File.Mode_Output;  // will overwrite any existing file
	baplieTemplateFile.kind := File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
	baplieTemplateFile.seek(0);
	while not baplieTemplateFile.endOfFile do
		s:=baplieTemplateFile.readLine;
		s:=s.replace('PTN000001', voyageCode).replace('NZPOE', destPort);
		if s[1:7] = 'EQD+CN+' then
			i:=8;
			i:=s.pos('+',i);  // position of + after container id
			seqnum:=seqnum+1;
			s:='EQD+CN+'&amp;voyageCode&amp;seqnum.pad(4)&amp;s[i:end];
		endif;
		baplieFile.writeLine(s);
	endwhile;
	baplieFile.close;
	app.logMessage("generated "&amp;baplieFile.fileName&amp;" for voyage "&amp;voyageCode);
end;
</source>
        <Parameter name="voyageCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="selectForm" id="bf971767-d25d-4897-873f-c7e32fa1c8e8">
        <source>selectForm(class:Class):Form;

vars
	i:Integer;
	form:Form;
begin
	if app.formsCount &gt; 1 then
		foreach i in 1 to app.formsCount do
			form := app.forms(i);
			if form.isKindOf(class) then
				return form;
			endif;
		endforeach;
	endif;
    return null;
end;</source>
        <Parameter name="class" type="Class"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="selectRandom" id="e2c0a88e-8898-43ec-a3e4-4aff8964b28b">
        <source>selectRandom(f:File):String;
//	grab a random token from the specified file
vars
	i,j,offset:Integer;
	s,t:String;
begin
	offset:=app.random(f.fileLength-99);
	f.seek(offset);
	s:=f.readString(100);
	j:=1;
	// probably in the middle of a token, so look for next full one
	t:=s.scanUntil(',',j);
	j:=j+1;
	t:=s.scanUntil(',',j);
	return t;
end;</source>
        <Parameter name="f" type="File"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="selectRandomBookingRef" id="653861dd-6a64-42de-b067-72ae37cfa0b9">
        <source>selectRandomBookingRef():String;

vars
	i,j:Integer; s,t:String;
begin
	if repeatable then
		if bookingRefListFile.endOfFile then
			app.logMessage("---------------------------------------");
			app.logMessage("restarting at top of bookingRefListFile");
			app.logMessage("---------------------------------------");
			bookingRefListFile.seek(0);
		endif;
		return bookingRefListFile.readLine;  // for repeatable random results

	else	
		while s = null do  // for full random
			s:=selectRandom(bookingRefFile);
			i:=i+1;
			if i &gt; 1 then i:=14 div 0; endif;  // ask for help
		endwhile;
		return s;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="selectRandomCarrier" id="490b5737-6572-4c81-916a-fecb6a75be5a">
        <source>selectRandomCarrier():CM_Carrier;

vars
	carrier:CM_Carrier;
begin
	carrierIterator.next(carrier);
	if carrier = null then
//		app.logMessage("-----------------------------");
//		app.logMessage("restarting with first carrier");
//		app.logMessage("-----------------------------");
		carrierIterator.reset;
		carrierIterator.next(carrier);
	endif;
	
	return carrier;
end;</source>
        <ReturnType type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="selectRandomISOType" id="ff790e05-cfae-42a6-b409-8da4abc79253">
        <source>selectRandomISOType():String;
//	not used during benchmark - only during file generation
vars
	i,j:Integer; s,t:String;
begin
	while s = null do  // for full random
		s:=selectRandom(isoTypeFile);
		i:=i+1;
		if i &gt; 1 then i:=14 div 0; endif;  // ask for help
	endwhile;
	return s;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="selectRandomOperator" id="f3c8c28f-9511-422d-8033-30eb955753a4">
        <source>selectRandomOperator():String;
//	not used during benchmark - only during file generation
vars
	i,j:Integer; s,t:String;
begin
	while s = null do  // for full random
		s:=selectRandom(operatorFile);
		i:=i+1;
		if i &gt; 1 then i:=14 div 0; endif;  // ask for help
	endwhile;
	return s;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="selectRandomRFIDTag" id="8b2c63a0-def2-4723-802a-265dc4ca8461">
        <source>selectRandomRFIDTag():CM_RFIDTag;

vars
	i,j:Integer; s,t:String;
	rfidTag:CM_RFIDTag;
begin
	while rfidTag = null or not rfidTag.isAvailable or rfidTag.myRoadJob &lt;&gt; null do
		if repeatable then
			if rfidTagListFile.endOfFile then
				app.logMessage("------------------------------------");
				app.logMessage("restarting at top of rfidTagListFile");
				app.logMessage("------------------------------------");
				rfidTagListFile.seek(0);
			endif;
			rfidTag:=app.myPassport.myTerminal.allRFIDTagsBySerialNo[rfidTagListFile.readLine];  // for repeatable random results
	
		else	
			while rfidTag = null do  // for full random
				rfidTag:=app.myPassport.myTerminal.allRFIDTagsBySerialNo[selectRandom(rfidTagFile)];
				i:=i+1;
				if i &gt; 3 then i:=14 div 0; endif;  // ask for help
			endwhile;
		endif;
		app.logMessage(method.qualifiedName&amp;" rfidTag="&amp;rfidTag.code&amp;" ("&amp;rfidTag.serialNumber&amp;") "&amp;rfidTag.isAvailable.String&amp;" "&amp;rfidTag.myRoadJob.String);
	endwhile;
	return rfidTag;
end;</source>
        <ReturnType type="CM_RFIDTag"/>
    </JadeMethod>
    <JadeMethod name="selectRandomUser" id="26457dd4-78a0-4f09-b4b9-891ce7e041d7">
        <source>selectRandomUser():CM_User;

vars
	i,j:Integer;
	user:CM_User;
begin
	if repeatable then
		if userListFile.endOfFile then
			app.logMessage("---------------------------------");
			app.logMessage("restarting at top of userListFile");
			app.logMessage("---------------------------------");
			userListFile.seek(0);
		endif;
		user:=app.myRoot.allUsers[userListFile.readLine.toUpper];  // for repeatable random results

	else	
		while user = null do  // for full random
			user:=app.myRoot.allUsers[selectRandom(userFile).toUpper];
			i:=i+1;
			if i &gt; 1 then i:=14 div 0; endif;  // ask for help
		endwhile;
	endif;

	// handle password expiry, etc
	setupUser(user);
	
	return user;
end;</source>
        <ReturnType type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="setupUser" id="e4c3c834-77cb-4e87-a466-0f52d4417bc3">
        <source>setupUser(user:CM_User input);

vars
	userWindow:CM_UserWindowForOpen;
begin
	beginTransaction;
	user.recentPasswords.purge;
	user.updateNumberLogonAttempts(null);
	user.setPropertyValue('status', EnabledNormalUser);

	//'userWindow' objects serve to 'remember' the users last open windows and their state
	//here we are getting rid of everything except the main form (which is required)
	user.allUserWindows.purge;
	user.allUserWindowsForStartup.purge;
	
	foreach userWindow in user.allUserWindowsForOpen do
		if userWindow.windowClassName &lt;&gt; 'CMUI_SuperAppForm2' then
			userWindow.erase(NORMAL_ERASE);
		endif;
	endforeach;
	commitTransaction;
	
end;
</source>
        <Parameter name="user" type="CM_User" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupUsers" id="a806d93a-1901-48f5-ac8a-2eaf794e576a">
        <updating/>
        <source>setupUsers() updating;

vars
	user:CM_User; userTerminal:CM_UserTerminal;
begin
	foreach user in app.myRoot.allUsers do :userLoop
		//exlude superuser from the mix as he's treated differently throughout the code
		if user.code.toUpper.pos('CNW', 1) &lt; 1 or (not CM_SecurityRoleSystemRoot.hasInstance(user.mySystemSecurityRole)) then
			continue;
		endif;
		
		foreach userTerminal in user.allUserTerminals do : userTerminalLoop
			if (not CM_SecurityRoleTerminalRoot.hasInstance(userTerminal.mySecurityRole)) then
				continue userLoop;
			endif;
		endforeach;
		
		setupUser(user);  // set password, etc
	endforeach;
end;
</source>
    </JadeMethod>
</Class>
