	self.importExportStorage2(true, storageConfig);
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete triggers;
	self.deleteStorageConfig( true );
end;</source>
    </JadeMethod>
    <JadeMethod name="tTest9x" id="b1daca61-c9f3-420e-aff6-93e83cba1d45">
        <updating/>
        <source>tTest9x() updating;
// cnwns1

/*

Purpose:			Test using storage config with use last days only and with 2 free storage days for exports, 3 for imports


Parameters:			

Return Value:		


Date		Who		Reason
11 October 2012	cnwjre1	Initial creation

*/

vars

	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	chargedDaysWorking	: Boolean;
	freeDaysWorking		: Boolean;
begin

	self.deleteStorageConfig( false );

	calendar := self.setupCalendar2();
	create triggers transient;
	// set the options
	includeFirstDay := false;
	includeLastDay := true;
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking, deriveDebtorFrom, triggers, true, 3, 2, 0);	// TFS 2570

	self.importExportStorage2(false, storageConfig);
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete triggers;
	self.deleteStorageConfig( true );
end;</source>
    </JadeMethod>
    <JadeMethod name="uCheck31932" id="59b7b344-c02e-4bff-be71-136775a53def">
        <source>uCheck31932();
// cnwjre1
// Copied from UT_VoyageOps::tLanderNonWorked to check Port Nelson contact 31932, to do the same activity, which is to receive ship on 20/6/2013, release road 27/6/2013 at an earlier time than the receipt
// storage config for 7 days free, tran map 'Storage' to ILD with 'Days since receival'

constants
	VoyageName = 'UTVOYROR2';
	ShipName = 'UTROR2';
	TestOperator = 'UTOP';
	CraneTransferAreaId	= "UTC1T2";
	IMV1 = "UTI2";
vars
	cta: CM_CraneTransferArea;
	bs: CM_BlockStack;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	queue: CM_VoyageQueue;
	rampQueue: CM_VoyageCraneQueue;
	cargo1,
	cargo2	: CM_TrackedItem;
	tas: StringArray;
	crane: CM_Machine;
	imv: CM_Machine;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
	forkLift: CM_Machine;
	task: CM_RTQueueTask;
	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	bank			: CM_Bank;
	tran			: CM_TITransaction;
	invLine			: CM_InvoiceLine;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	chargedDaysWorking	: Boolean;
	freeDaysWorking		: Boolean;
	tranDate		: Date;
	tranTime		: Time;
	time			: Time;
	tranTS			: TimeStamp;
	vvr 			: CM_VehicleVisitRecord;
	singleGate		: CM_Gate;
	msg				: String;

begin
	// set days onsite time at to 00:00 to match Port Nelson (unitTestBeforeClass sets it to 17:00)
	time := "00:00".Time;
	bank := self.myBank;
	if bank.onsiteStorageChargeTime &lt;&gt; time then
		beginTransaction;
			bank.onsiteStorageChargeTime := time;
		commitTransaction;
	endif;
	

	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar2();
	create triggers transient;
	// set the options to match the Port Nelson values (both true)
	includeFirstDay := true;		// the value is SHOULD be to match their processing rules
	includeFirstDay := false;		// for testing
	includeLastDay := true;
	// import days = 7, export days (not used here) = 10
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking,
						deriveDebtorFrom, triggers, true, 7, 10, 0);	// TFS 2570

	// set up the yard allocation to force to UBS1 for somewhere to go
	self.disableAllYA(true);
	bs:= self.addBlockStack("UBS1", 100, null);
	self.addYACatchAll("UTYA", bs);
	
	cta := self.addCraneTransferArea(CraneTransferAreaId);

	create tas transient;
	tas.add(cta.id);
	tas.add(bs.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	crane := self.addCrane("UTRP", null, tas, null);
	
	self.addMachineRule (cta, bs, RTMoveMethod_7);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	vessel := self.addVesselLOLOholdsRORO(ShipName, self.getOperator(TestOperator));
	voyage	:= self.addVoyageWithConRORO(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													null, 10, false, true);
	queue := self.addVoyageQueue(voyage);
	rampQueue := self.addVoyageCraneQueue(voyage, queue, crane);
	
	// set up all required invoicing, storage transactions using UT_ILTFSD4, Days onsite at
	self.loadTranMapDaysSinceReceival();
	
	// add two import general containers on-ship
	cargo1 := self.addContainerAtLocnDisch("MRKU0910410", "2200", "GENL", TI_IMEX_STATUS_IMPORT, voyage.myShipBlockStack, app.myRoot.allPorts["NZPOE"], voyage);
	cargo2 := self.addContainerAtLocnDisch("MRKU0910420", "2200", "GENL", TI_IMEX_STATUS_IMPORT, voyage.myShipBlockStack, app.myRoot.allPorts["NZPOE"], voyage);

	imv := self.addIMV(IMV1, 93, tas, rampQueue.id);
	forkLift := self.addForkLift("UTFL", 94, tas, rampQueue.id);
	
	// move first box
	self.doQueueUnplannedUnworkedCargo(cargo1, job, wle );
	self.assertNotNullMsg(wle, "Failed to queue cargo 1");
	
	// Lander puts cargo on IMV
	app.myTrxUA.trxUpdateShipMoveImport(imv, cargo1, wle, job,null,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIForTxnOfType(cargo1, TRANS_TYPE_REC_SHIP);
	self.checkTIForTxnOfType(cargo1, TRANS_TYPE_WHARFAGE);
	
	// Forklift sets down into yard
	self.machineLogon(forkLift);
	task := self.machineTaskRequest(forkLift);
	self.machineAcceptTask(forkLift, wle.allRTQueueEntries.last.allTasks.first);
	self.machinePickup(forkLift);
	self.machineSetdown(forkLift, cargo1, bs.id);
	self.machineLogOff(forkLift);
	
	// Make sure temp voyage job is deleted
	self.assertEqual(voyage.allVoyageJobs.size, 0);
	
	// move second box
	self.doQueueUnplannedUnworkedCargo(cargo2, job, wle );
	self.assertNotNullMsg(wle, "Failed to queue cargo 2");
	
	// Lander puts cargo on IMV
	app.myTrxUA.trxUpdateShipMoveImport(imv, cargo2, wle, job,null,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIForTxnOfType(cargo2, TRANS_TYPE_REC_SHIP);
	self.checkTIForTxnOfType(cargo2, TRANS_TYPE_WHARFAGE);
	
	// Forklift sets down into yard
	self.machineLogon(forkLift);
	task := self.machineTaskRequest(forkLift);
	self.machineAcceptTask(forkLift, wle.allRTQueueEntries.last.allTasks.first);
	self.machinePickup(forkLift);
	self.machineSetdown(forkLift, cargo2, bs.id);
	self.machineLogOff(forkLift);
	
	self.assertEqual(voyage.allVoyageJobs.size, 0);

	// back-date cargo1 transactions to 7 days ago and the times all plus 1 hour (the container left earlier in the day than the arrival)
	// back-date cargo2 transactions to 7 days ago and the times all minus 1 hour (the container left later in the day than the arrival)
	write tranDate.String;
	tranDate := tranDate - 7;
	write tranDate.String;
	
	tranTS.setDate(tranDate);
	foreach tran in cargo1.allTransactions do
		tranTime := tran.dateTime.time.addHours(-1);
		tranTS.setDate(tranDate);
		tranTS.setTime(tranTime);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	foreach tran in cargo2.allTransactions do
		tranTime := tran.dateTime.time.addHours(1);
		tranTS.setDate(tranDate);
		tranTS.setTime(tranTime);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	// do a road release
	// Remove all automatic stops
	self.deleteStops(cargo1);
	self.deleteStops(cargo2);

	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	self.opts.addAssoc("deliveryNumber", "999");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo1.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo2.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// check the storage transaction and invoicing
	write "Days onsite at,  include first day=" &amp; includeFirstDay.String;
	write cargo1.id;
	foreach tran in cargo1.allTransactions do
		if tran.isKindOf(CM_Receive) or tran.isKindOf(CM_Release) then
			msg := msg &amp; " " &amp; tran.class.name &amp; " " &amp; tran.dateTime.String;
		endif;
		if tran.isKindOf(CM_Storage) then
			write "Storage " &amp; tran.dateTime.String &amp; " noCharge=" &amp; tran.noCharge.String &amp; " " &amp; tran.getDisplayStringForAttribute(ETRow_Storage, false);
			foreach invLine in tran.allInvoiceLines do
				write "Invoice line quantity " &amp; invLine.quantity.String &amp; " ild=" &amp; invLine.invoiceLineDesc.narration;
			endforeach;
		endif;
	endforeach;
	write msg;
	
	msg := "";
	write "";write cargo2.id;
	foreach tran in cargo2.allTransactions do
		if tran.isKindOf(CM_Receive) or tran.isKindOf(CM_Release) then
			msg := msg &amp; " " &amp; tran.class.name &amp; " " &amp; tran.dateTime.String;
		endif;
		if tran.isKindOf(CM_Storage) then
			write "Storage " &amp; tran.dateTime.String &amp; " noCharge=" &amp; tran.noCharge.String &amp; " " &amp; tran.getDisplayStringForAttribute(ETRow_Storage, false);
			foreach invLine in tran.allInvoiceLines do
				write "Invoice line quantity " &amp; invLine.quantity.String &amp; " ild=" &amp; invLine.invoiceLineDesc.narration;
			endforeach;
		endif;
	endforeach;
	write msg;
	
	/* original code
	MRKU0910410
	Storage 16 July 2013, 12:39:02 noCharge=true Stored for 9 days, no charge. 
	Storage 16 July 2013, 13:39:03 noCharge=false Stored for 1 days 
	Invoice line quantity 1 ild=UT_ILTFSD4

	MRKU0910420
	Storage 16 July 2013, 13:39:03 noCharge=true Stored for 9 days, no charge.
 	*/
	
	/* witn NEW code, includeFirstDay set true
	MRKU0910410
	Storage 23 July 2013, 23:59:59 noCharge=true Stored for 6 days, no charge. 
	Storage 25 July 2013, 17:16:19 noCharge=false Stored for 2 days 
	Invoice line quantity 2 ild=UT_ILTFSD5

	MRKU0910420
	Storage 23 July 2013, 23:59:59 noCharge=true Stored for 6 days, no charge. 
	Storage 25 July 2013, 17:16:19 noCharge=false Stored for 2 days 
	Invoice line quantity 2 ild=UT_ILTFSD5
	*/
	/* and with includeFirstDay set to false
	MRKU0910410
	Storage 24 July 2013, 23:59:59 noCharge=true Stored for 6 days, no charge. 
	Storage 25 July 2013, 17:18:53 noCharge=false Stored for 1 days 
	Invoice line quantity 1 ild=UT_ILTFSD5

	MRKU0910420
	Storage 24 July 2013, 23:59:59 noCharge=true Stored for 6 days, no charge. 
	Storage 25 July 2013, 17:18:53 noCharge=false Stored for 1 days 
	Invoice line quantity 1 ild=UT_ILTFSD5
	*/
	/*
	02 August 2013
	26 July 2013
	Days onsite at,  include first day=true
	MRKU0910410
	Storage 31 July 2013, 23:59:59 noCharge=true Stored for 6 days, no charge. 
	Storage 02 August 2013, 15:36:24 noCharge=false Stored for 2 days 
	Invoice line quantity 2 ild=UT_ILTFSD5
	 CM_Create 26 July 2013, 14:36:22 CM_ReceiveShip 26 July 2013, 14:36:23 CM_ReleaseRoad 02 August 2013, 15:36:24

	MRKU0910420
	Storage 31 July 2013, 23:59:59 noCharge=true Stored for 6 days, no charge. 
	Storage 02 August 2013, 15:36:24 noCharge=false Stored for 2 days 
	Invoice line quantity 2 ild=UT_ILTFSD5
	 CM_Create 26 July 2013, 16:36:22 CM_ReceiveShip 26 July 2013, 16:36:23 CM_ReleaseRoad 02 August 2013, 15:36:24
	
	02 August 2013
	26 July 2013
	Days onsite at,  include first day=false
	MRKU0910410
	Storage 01 August 2013, 23:59:59 noCharge=true Stored for 7 days, no charge. 
	Storage 02 August 2013, 15:36:43 noCharge=false Stored for 1 days 
	Invoice line quantity 1 ild=UT_ILTFSD5
	 CM_Create 26 July 2013, 14:36:41 CM_ReceiveShip 26 July 2013, 14:36:42 CM_ReleaseRoad 02 August 2013, 15:36:43

	MRKU0910420
	Storage 01 August 2013, 23:59:59 noCharge=true Stored for 7 days, no charge. 
	Storage 02 August 2013, 15:36:43 noCharge=false Stored for 1 days 
	Invoice line quantity 1 ild=UT_ILTFSD5
	 CM_Create 26 July 2013, 16:36:41 CM_ReceiveShip 26 July 2013, 16:36:42 CM_ReleaseRoad 02 August 2013, 15:36:43
*/
epilog
	time := "17:00".Time;
	bank := self.myBank;
	if bank.onsiteStorageChargeTime &lt;&gt; time then
		beginTransaction;
			bank.onsiteStorageChargeTime := time;
		commitTransaction;
	endif;

	self.disableAllYA(false);
	self.resetDefaultTranMap();	
	delete tas;
	delete triggers;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCheck31932A" id="a78ff5a7-b9df-47db-ab47-bbac7e9d4117">
        <source>uCheck31932A();
// cnwjre1
// Copied from UT_VoyageOps::tLanderNonWorked to check Port Nelson contact 31932, to do the same activity, which is to receive ship on 20/6/2013, release road 27/6/2013 at an earlier time than the receipt
// storage config for 7 days free, tran map 'Storage' to ILD with 'Days onsite at' calculation type, bank time 00:00

constants
	VoyageName = 'UTVOYROR2';
	ShipName = 'UTROR2';
	TestOperator = 'UTOP';
	CraneTransferAreaId	= "UTC1T2";
	IMV1 = "UTI2";
vars
	cta: CM_CraneTransferArea;
	bs: CM_BlockStack;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	queue: CM_VoyageQueue;
	rampQueue: CM_VoyageCraneQueue;
	cargo1,
	cargo2	: CM_TrackedItem;
	tas: StringArray;
	crane: CM_Machine;
	imv: CM_Machine;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
	forkLift: CM_Machine;
	task: CM_RTQueueTask;
	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	bank			: CM_Bank;
	tran			: CM_TITransaction;
	invLine			: CM_InvoiceLine;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	chargedDaysWorking	: Boolean;
	freeDaysWorking		: Boolean;
	tranDate		: Date;
	tranTime		: Time;
	time			: Time;
	tranTS			: TimeStamp;
	vvr 			: CM_VehicleVisitRecord;
	singleGate		: CM_Gate;
	msg				: String;

begin
	// set days onsite time at to 00:00 to match Port Nelson (unitTestBeforeClass sets it to 17:00)
	time := "00:00".Time;
	bank := self.myBank;
	if bank.onsiteStorageChargeTime &lt;&gt; time then
		beginTransaction;
			bank.onsiteStorageChargeTime := time;
		commitTransaction;
	endif;
	

	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar2();
	create triggers transient;
	// set the options to match the Port Nelson values (both true)
	includeFirstDay := true;		// the value is SHOULD be to match their processing rules
	//includeFirstDay := false;		// for testing
	includeLastDay := true;
	// import days = 7, export days (not used here) = 10
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking,
						deriveDebtorFrom, triggers, true, 7, 10, 0);	// TFS 2570

	// set up the yard allocation to force to UBS1 for somewhere to go
	self.disableAllYA(true);
	bs:= self.addBlockStack("UBS1", 100, null);
	self.addYACatchAll("UTYA", bs);
	
	cta := self.addCraneTransferArea(CraneTransferAreaId);

	create tas transient;
	tas.add(cta.id);
	tas.add(bs.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	crane := self.addCrane("UTRP", null, tas, null);
	
	self.addMachineRule (cta, bs, RTMoveMethod_7);
	
	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	vessel := self.addVesselLOLOholdsRORO(ShipName, self.getOperator(TestOperator));
	voyage	:= self.addVoyageWithConRORO(VoyageName,
													ShipName,
													TestOperator, 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													null, 10, false, true);
	queue := self.addVoyageQueue(voyage);
	rampQueue := self.addVoyageCraneQueue(voyage, queue, crane);
	
	// set up all required invoicing, storage transactions using UT_ILTFSD4, Days onsite at
	self.loadTranMapDaysOnsiteAt();
	
	// add two import general containers on-ship
	cargo1 := self.addContainerAtLocnDisch("MRKU0910410", "2200", "GENL", TI_IMEX_STATUS_IMPORT, voyage.myShipBlockStack, app.myRoot.allPorts["NZPOE"], voyage);
	cargo2 := self.addContainerAtLocnDisch("MRKU0910420", "2200", "GENL", TI_IMEX_STATUS_IMPORT, voyage.myShipBlockStack, app.myRoot.allPorts["NZPOE"], voyage);

	imv := self.addIMV(IMV1, 93, tas, rampQueue.id);
	forkLift := self.addForkLift("UTFL", 94, tas, rampQueue.id);
	
	// move first box
	self.doQueueUnplannedUnworkedCargo(cargo1, job, wle );
	self.assertNotNullMsg(wle, "Failed to queue cargo 1");
	
	// Lander puts cargo on IMV
	app.myTrxUA.trxUpdateShipMoveImport(imv, cargo1, wle, job,null,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIForTxnOfType(cargo1, TRANS_TYPE_REC_SHIP);
	self.checkTIForTxnOfType(cargo1, TRANS_TYPE_WHARFAGE);
	
	// Forklift sets down into yard
	self.machineLogon(forkLift);
	task := self.machineTaskRequest(forkLift);
	self.machineAcceptTask(forkLift, wle.allRTQueueEntries.last.allTasks.first);
	self.machinePickup(forkLift);
	self.machineSetdown(forkLift, cargo1, bs.id);
	self.machineLogOff(forkLift);
	
	// Make sure temp voyage job is deleted
	self.assertEqual(voyage.allVoyageJobs.size, 0);
	
	// move second box
	self.doQueueUnplannedUnworkedCargo(cargo2, job, wle );
	self.assertNotNullMsg(wle, "Failed to queue cargo 2");
	
	// Lander puts cargo on IMV
	app.myTrxUA.trxUpdateShipMoveImport(imv, cargo2, wle, job,null,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.checkTIForTxnOfType(cargo2, TRANS_TYPE_REC_SHIP);
	self.checkTIForTxnOfType(cargo2, TRANS_TYPE_WHARFAGE);
	
	// Forklift sets down into yard
	self.machineLogon(forkLift);
	task := self.machineTaskRequest(forkLift);
	self.machineAcceptTask(forkLift, wle.allRTQueueEntries.last.allTasks.first);
	self.machinePickup(forkLift);
	self.machineSetdown(forkLift, cargo2, bs.id);
	self.machineLogOff(forkLift);
	
	self.assertEqual(voyage.allVoyageJobs.size, 0);

	// back-date cargo1 transactions to 7 days ago and the times all plus 1 hour (the container left earlier in the day than the arrival)
	// back-date cargo2 transactions to 7 days ago and the times all minus 1 hour (the container left later in the day than the arrival)
	write tranDate.String;
	tranDate := tranDate - 7;
	write tranDate.String;
	
	tranTS.setDate(tranDate);
	foreach tran in cargo1.allTransactions do
		tranTime := tran.dateTime.time.addHours(-1);
		tranTS.setDate(tranDate);
		tranTS.setTime(tranTime);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	foreach tran in cargo2.allTransactions do
		tranTime := tran.dateTime.time.addHours(1);
		tranTS.setDate(tranDate);
		tranTS.setTime(tranTime);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	// do a road release
	// Remove all automatic stops
	self.deleteStops(cargo1);
	self.deleteStops(cargo2);

	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	self.opts.addAssoc("deliveryNumber", "999");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo1.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo2.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// check the storage transaction and invoicing
	write "Days onsite at,  include first day=" &amp; includeFirstDay.String;
	write cargo1.id;
	foreach tran in cargo1.allTransactions do
		if tran.isKindOf(CM_Receive) or tran.isKindOf(CM_Release) then
			msg := msg &amp; " " &amp; tran.class.name &amp; " " &amp; tran.dateTime.String;
		endif;
		if tran.isKindOf(CM_Storage) then
			write "Storage " &amp; tran.dateTime.String &amp; " noCharge=" &amp; tran.noCharge.String &amp; " " &amp; tran.getDisplayStringForAttribute(ETRow_Storage, false);
			foreach invLine in tran.allInvoiceLines do
				write "Invoice line quantity " &amp; invLine.quantity.String &amp; " ild=" &amp; invLine.invoiceLineDesc.narration;
			endforeach;
		endif;
	endforeach;
	write msg;
	
	msg := "";
	write "";write cargo2.id;
	foreach tran in cargo2.allTransactions do
		if tran.isKindOf(CM_Receive) or tran.isKindOf(CM_Release) then
			msg := msg &amp; " " &amp; tran.class.name &amp; " " &amp; tran.dateTime.String;
		endif;
		if tran.isKindOf(CM_Storage) then
			write "Storage " &amp; tran.dateTime.String &amp; " noCharge=" &amp; tran.noCharge.String &amp; " " &amp; tran.getDisplayStringForAttribute(ETRow_Storage, false);
			foreach invLine in tran.allInvoiceLines do
				write "Invoice line quantity " &amp; invLine.quantity.String &amp; " ild=" &amp; invLine.invoiceLineDesc.narration;
			endforeach;
		endif;
	endforeach;
	write msg;
	
	/* original code
	MRKU0910410
	Storage 16 July 2013, 12:39:02 noCharge=true Stored for 9 days, no charge. 
	Storage 16 July 2013, 13:39:03 noCharge=false Stored for 1 days 
	Invoice line quantity 1 ild=UT_ILTFSD4

	MRKU0910420
	Storage 16 July 2013, 13:39:03 noCharge=true Stored for 9 days, no charge.
 	*/
	
	/* with NEW code, includeFirstDay set true
	06 August 2013
	30 July 2013
	Days onsite at,  include first day=true
	MRKU0910410
	Storage 05 August 2013, 23:59:59 noCharge=true Stored for 7 days, no charge. 
	Storage 06 August 2013, 08:28:34 noCharge=false Stored for 2 days SHOULD BE 1 DAY
	Invoice line quantity 2 ild=UT_ILTFSD4
	 CM_Create 30 July 2013, 07:28:30 CM_ReceiveShip 30 July 2013, 07:28:32 CM_ReleaseRoad 06 August 2013, 08:28:34

	MRKU0910420
	Storage 05 August 2013, 23:59:59 noCharge=true Stored for 7 days, no charge. 
	Storage 06 August 2013, 08:28:34 noCharge=false Stored for 2 days SHOULD BE 1 DAY
	Invoice line quantity 2 ild=UT_ILTFSD4
	 CM_Create 30 July 2013, 09:28:31 CM_ReceiveShip 30 July 2013, 09:28:32 CM_ReleaseRoad 06 August 2013, 08:28:34
	*/
	/* and with includeFirstDay set to false
	06 August 2013
	30 July 2013
	Days onsite at,  include first day=false
	MRKU0910410
	Storage 06 August 2013, 08:36:07 noCharge=true Stored for 7 days, no charge. 
	 CM_Create 30 July 2013, 07:36:04 CM_ReceiveShip 30 July 2013, 07:36:05 CM_ReleaseRoad 06 August 2013, 08:36:07

	MRKU0910420
	Storage 06 August 2013, 08:36:07 noCharge=true Stored for 7 days, no charge. 
	 CM_Create 30 July 2013, 09:36:05 CM_ReceiveShip 30 July 2013, 09:36:06 CM_ReleaseRoad 06 August 2013, 08:36:07
	*/
epilog
	time := "17:00".Time;
	bank := self.myBank;
	if bank.onsiteStorageChargeTime &lt;&gt; time then
		beginTransaction;
			bank.onsiteStorageChargeTime := time;
		commitTransaction;
	endif;

	self.disableAllYA(false);
	self.resetDefaultTranMap();	
	delete tas;
	delete triggers;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateOfflineActor1" id="2cf44215-94ae-4131-a095-84e2496033eb">
        <source>uCreateOfflineActor1();

vars
	root	: CM_Root;
	term	: CM_Terminal;
	ti		: CM_TrackedItem;
	actor	: CM_FreeStorageExpiryStopCreate;
	now		: TimeStamp;
	now1, now2	: TimeStamp;
	count	: Integer;
begin
	now1 := now.addMinutes(30);
	now2 := now.addMinutes(90);

	root := CM_Root.firstInstance;
	term := root.allTerminals["JT1"];
	beginTransaction;
	foreach ti in term.allOnsiteTIsByCargoTypeId do
		create actor persistent;
		actor.setMyTrackedItem(ti);
		actor.setParentObject(ti);
		actor.setActionTimeStamp(now1);
		actor.setRoot(root);

		create actor persistent;
		actor.setMyTrackedItem(ti);
		actor.setParentObject(ti);
		actor.setActionTimeStamp(now2);
		actor.setRoot(root);
		
		count := count + 2;
	endforeach;
	commitTransaction;
	
	write count.String &amp; " CM_FreeStorageExpiryStopCreate instances created";
end;
</source>
    </JadeMethod>
    <JadeMethod name="uStorageBillingByTAGroup1" id="2313a822-9be5-42ce-aa11-029c14a60c71">
        <source>uStorageBillingByTAGroup1();
/*

Purpose:		TFS 41427	

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2018	NAVAB1	Initial creation

*/
constants
	// inside
	BlockStackId1		: String = "UTPELBS1";
	BlockStackId2		: String = "UTPELBS2";
	// outside
	BlockStackId3		: String = "UTPELBS3";
	BlockStackId4		: String = "UTPELBS4";
	
	// inside
	TAGroup1			: String = "TAGROUPPEL1";
	// outside
	TAGroup2			: String = "TAGROUPPEL2";
	

vars
	root : CM_Root;
	bank		: CM_Bank;
	bs1, bs2,
	bs3, bs4, autorel	: CM_BlockStack;
	ti,
	ti1, ti2, ti3, ti4, ti5	: CM_TrackedItem;
	termAreas		: CM_TerminalAreaArray;
	tasg,
	tasg1, tasg2	: CM_TerminalAreaStorageGroup;
	invType : CM_InvoiceDesc;
	debtorType : CM_DebtorType;
	triggers		: CM_StorageTriggerByType;
	pxyStorageTrigger : CM_StorageTrigger;
	realAlloc :CM_InvoiceCargoAllocation;
	opCriteriaColl : CM_YACriteriaTypeArray;
	aCode,aDesc : String;
	pxyTM,realTM : CM_TranMapCargoAllocation;
	pxyYAConfig, realYAConfig : CM_InvoiceAllocationConfig;
	voyage : CM_Voyage;
	receiveTxn, moveTxn, storeTxn : CM_TITransaction;
	trans : CM_TransactionSet;
	
begin
	root := app.myRoot;
	bank := self.myBank;
	
	// TERMINAL AREAS
	bs1 := self.addBlockStack(BlockStackId1, 99, null);
	assertNotNullMsg(bs1, BlockStackId1);
	bs2 := self.addBlockStack(BlockStackId2, 99, null);
	assertNotNullMsg(bs2, BlockStackId2);
	bs3 := self.addBlockStack(BlockStackId3, 99, null);
	assertNotNullMsg(bs3, BlockStackId3);
	bs4 := self.addBlockStack(BlockStackId4, 99, null);
//	autorel := self.addReleaseTransAreaAuto("AUTOREL").CM_BlockStack;
	
	// TERMINAL AREA GROUPS
	self.deleteTerminalAreaStorageGroup(TAGroup1);
	self.deleteTerminalAreaStorageGroup(TAGroup2);
	
	create termAreas transient;
	termAreas.add(bs1);
	termAreas.add(bs2);
	
	tasg1 := self.addTerminalAreaStorageGroup(TAGroup1, "YARD", termAreas);
	
	termAreas.clear();
	termAreas.add(bs3);
	termAreas.add(bs4);
	tasg2 := self.addTerminalAreaStorageGroup(TAGroup2, "WHSE", termAreas);

	// INVOICE TYPE
	self.deleteInvoiceTypeOnly("UT_PELStorage");
	invType := self.createInvoiceType("UT_PELStorage", InvoiceTypeGeneral);

	// SERVICE, RATES, INVOICE LINE TYPES
	self.createInvoiceLineAndRate(invType, "UT_PELStorageWHSE01to05", "UT_PELStorageWHSE01to05", "CCT06", "SDT1", 300.00);
	self.createInvoiceLineAndRate(invType, "UT_PELStorageWHSE06to10", "UT_PELStorageWHSE06to10", "CCT06", "SDT1", 300.00);
	self.createInvoiceLineAndRate(invType, "UT_PELStorageWHSE11to99", "UT_PELStorageWHSE11to99", "CCT06", "SDT1", 600.00);
	
	self.createInvoiceLineAndRate(invType, "UT_PELStorageYARD01to05", "UT_PELStorageYARD01to05", "CCT06", "SDT1", 200.00);
	self.createInvoiceLineAndRate(invType, "UT_PELStorageYARD06to10", "UT_PELStorageYARD06to10", "CCT06", "SDT1", 200.00);
	self.createInvoiceLineAndRate(invType, "UT_PELStorageYARD11to99", "UT_PELStorageYARD11to99", "CCT06", "SDT1", 400.00);
	
	// STORAGE TRIGGERS
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( StorageTAGroup, false, null);
	triggers.add(pxyStorageTrigger);

	// STORAGE CONFIG
	debtorType := app.myRoot.allDebtorTypes["SDT1"];	
	self.setupStorageConfig5(null,true,true,0,0,false,false,debtorType,triggers,true);
	
	// INVOICE CARGO INVOICE TRANSACTION MAP
	create opCriteriaColl transient;
	
	bank := self.getTerminal().getDefaultCompanyBank();
	aCode := "UTPELStorage";
	aDesc := "UT PEL Invoice Allocation";
	
	// ### TRANSACTION MAP
	foreach realTM in bank.allCargoAllocTranMaps where realTM.name &lt;&gt; aCode do
		app.myTrxUA.trxUpdateBankTMCAActive(realTM); 
		break;
	endforeach;
//	assertTrueMsg(bank.myCurrentTranMapCargoAlloc = null, "Did not deactivate tran map");
	realTM := bank.allCargoAllocTranMaps[aCode];
	if realTM &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMapCA(realTM);
		self.assertTrueTrxOKShowPassport("Delete Tran Map - " &amp; aDesc);
	endif;

	create pxyTM transient;
	pxyTM.setProxy(bank, aCode, aDesc);
		
	app.myTrxCA.trxCreateInvoiceTranMapCAlloc(pxyTM,realTM);
	self.assertTrueTrxOKShowPassport("Create TM");
	
	app.myTrxUA.trxUpdateBankTMCAActive(realTM); 
	
	// ### TRAN MAP ALLOC CONFIG
	realYAConfig := realTM.myInvoiceAllocationConfig;
	self.assertTrueMsg(realYAConfig &lt;&gt; null, "Invoice Allocation Config is NUll");
	
	pxyYAConfig := app.createUpdateProxy(realYAConfig).CM_InvoiceAllocationConfig;
	
	// cargo type, inbound and outbound ship operators
	opCriteriaColl.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	opCriteriaColl.add(app.myRoot.allYACriteriaTypes[YACriteriaType_SrcTermArea]);
	
	pxyYAConfig.setProxyInvoiceAllocation(opCriteriaColl, null, realTM, null);
	
	app.myTrxUA.trxUpdateYAIMEXConfig(pxyYAConfig, app.myPassport);	

	// MAP INVOICE LINES TO MAP
	realAlloc := self.addInvoiceCargoAllocation(realTM, TI_CargoType_Container, null, TRANS_TYPE_STORAGE, "", "", "UTICA1", "UT_PEL Storage WHSE", BlockStackId3, BlockStackId4);
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT06","VOID","",0,5, false);
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT06","UT_PELStorageWHSE06to10","",6,10, true);
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT06","UT_PELStorageWHSE11to99","",11,CM_QuantityRangeMap.MAX_RANGE.Integer, true);

	realAlloc := self.addInvoiceCargoAllocation(realTM, TI_CargoType_Container, null, TRANS_TYPE_STORAGE, "", "", "UTICA1", "UT_PEL Storage YARD", BlockStackId1, BlockStackId2);
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT06","VOID","",0,5, false);
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT06","UT_PELStorageYARD06to10","",6,10, true);
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT06","UT_PELStorageYARD11to99","",11,CM_QuantityRangeMap.MAX_RANGE.Integer, true);

	
	// CARGO
	self.addVesselVoyage();
	voyage := self.getVoyage("PEL10001");
		
	self.addOnshipCargoForId("PELU1810171", voyage.myShipBlockStack, voyage);
	self.addOnshipCargoForId("PELU1810172", voyage.myShipBlockStack, voyage);
	self.addOnshipCargoForId("PELU1810173", voyage.myShipBlockStack, voyage);
	self.addOnshipCargoForId("PELU1810174", voyage.myShipBlockStack, voyage);
	
	
	self.opts.addAssoc('IsForcedMove', false);
	// MOVE CARGO - TFS 41301 SCENARIO 1
	
	ti1 := getTrackedItemAtLocation("PELU1810171", voyage.myShipBlockStack);
	self.moveBreakBulk(ti1, bs1, 0);
	
	receiveTxn:=ti1.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	
	beginTransaction;
	receiveTxn.updateDateTime(receiveTxn.dateTime.addDays(-17));	
	commitTransaction;
	
	self.moveOffsite(ti1);

	// MOVE CARGO - TFS 41301 SCENARIO 2

	ti2 := getTrackedItemAtLocation("PELU1810172", voyage.myShipBlockStack);
	self.moveBreakBulk(ti2, bs3, 0);
	
	receiveTxn:=ti2.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	
	beginTransaction;
	receiveTxn.updateDateTime(receiveTxn.dateTime.addDays(-17));	
	commitTransaction;
	
	self.moveOffsite(ti2);

	// MOVE CARGO - TFS 41301 SCENARIO 3
	ti3 := getTrackedItemAtLocation("PELU1810173", voyage.myShipBlockStack);
	self.moveBreakBulk(ti3, bs1, 0);
	receiveTxn:=ti3.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	
	self.resetTransactionDate(ti3,receiveTxn.dateTime.addDays(-20));

	self.moveBreakBulk(ti3, bs3, 0);

	storeTxn:=ti3.getLastTransOfType(	TRANS_TYPE_STORAGE);
	moveTxn:=ti3.getLastTransOfType(	TRANS_TYPE_MOVE);
	beginTransaction;
	moveTxn.updateDateTime(receiveTxn.dateTime.addDays(13));
	storeTxn.updateDateTime(moveTxn.dateTime.addSeconds(1));
	commitTransaction;
	
	create trans transient;
	trans.add(storeTxn);
	self.updateTransactionResync(trans,ti3,null);
	delete trans;
	self.moveOffsite(ti3);

	// MOVE CARGO - TFS 41301 SCENARIO 4
	ti4 := getTrackedItemAtLocation("PELU1810174", voyage.myShipBlockStack);
	self.moveBreakBulk(ti4, bs1, 0);
	receiveTxn:=ti4.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	
	self.resetTransactionDate(ti4,receiveTxn.dateTime.addDays(-20));

	self.moveBreakBulk(ti4, bs3, 0);

	storeTxn:=ti4.getLastTransOfType(	TRANS_TYPE_STORAGE);
	moveTxn:=ti4.getLastTransOfType(	TRANS_TYPE_MOVE);
	beginTransaction;
	moveTxn.updateDateTime(receiveTxn.dateTime.addDays(3));
	storeTxn.updateDateTime(moveTxn.dateTime.addSeconds(1));
	commitTransaction;
	
	create trans transient;
	trans.add(storeTxn);
	self.updateTransactionResync(trans,ti4,null);
	trans.clear();
	self.moveOffsite(ti4);
	delete trans;

	
	
	// CHECK INVOICE LINES
	
	
	
epilog
	delete pxyTM;
	delete pxyYAConfig;
	delete termAreas;
	delete triggers;
	delete opCriteriaColl;
	delete trans;
end;</source>
    </JadeMethod>
    <JadeMethod name="uStorageBillingByTAGroup2" id="a94e9c50-7d47-44f2-9c37-5d3803212f3f">
        <source>uStorageBillingByTAGroup2();
/*

Purpose:		TFS 41427	

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2018	NAVAB1	Initial creation

*/
constants
	// inside
	BlockStackId1		: String = "UTPELBS1";
	BlockStackId2		: String = "UTPELBS2";
	// outside
	BlockStackId3		: String = "UTPELBS3";
	BlockStackId4		: String = "UTPELBS4";
	
	// inside
	TAGroup1			: String = "TAGROUPPEL1";
	// outside
	TAGroup2			: String = "TAGROUPPEL2";
	

vars
	root : CM_Root;
	bank		: CM_Bank;
	bs1, bs2,
	bs3, bs4, autorel	: CM_BlockStack;
	ti,
	ti1, ti2, ti3, ti4, ti5	: CM_TrackedItem;
	termAreas		: CM_TerminalAreaArray;
	tasg,
	tasg1, tasg2	: CM_TerminalAreaStorageGroup;
	invType : CM_InvoiceDesc;
	debtorType : CM_DebtorType;
	triggers		: CM_StorageTriggerByType;
	pxyStorageTrigger : CM_StorageTrigger;
	realAlloc :CM_InvoiceCargoAllocation;
	opCriteriaColl : CM_YACriteriaTypeArray;
	aCode,aDesc : String;
	pxyTM,realTM : CM_TranMapCargoAllocation;
	pxyYAConfig, realYAConfig : CM_InvoiceAllocationConfig;
	voyage : CM_Voyage;
	receiveTxn, moveTxn, storeTxn : CM_TITransaction;
	trans : CM_TransactionSet;
	
begin
	root := app.myRoot;
	bank := self.myBank;
	
	// TERMINAL AREAS
	bs1 := self.addBlockStack(BlockStackId1, 99, null);
	assertNotNullMsg(bs1, BlockStackId1);
	bs2 := self.addBlockStack(BlockStackId2, 99, null);
	assertNotNullMsg(bs2, BlockStackId2);
	bs3 := self.addBlockStack(BlockStackId3, 99, null);
	assertNotNullMsg(bs3, BlockStackId3);
	bs4 := self.addBlockStack(BlockStackId4, 99, null);
//	autorel := self.addReleaseTransAreaAuto("AUTOREL").CM_BlockStack;
	
	// TERMINAL AREA GROUPS
	self.deleteTerminalAreaStorageGroup(TAGroup1);
	self.deleteTerminalAreaStorageGroup(TAGroup2);
	
	create termAreas transient;
	termAreas.add(bs1);
	termAreas.add(bs2);
	
	tasg1 := self.addTerminalAreaStorageGroup(TAGroup1, "YARD", termAreas);
	
	termAreas.clear();
	termAreas.add(bs3);
	termAreas.add(bs4);
	tasg2 := self.addTerminalAreaStorageGroup(TAGroup2, "WHSE", termAreas);

	// INVOICE TYPE
	self.deleteInvoiceTypeOnly("UT_PELStorage");
	invType := self.createInvoiceType("UT_PELStorage", InvoiceTypeGeneral);

	// SERVICE, RATES, INVOICE LINE TYPES
	self.createInvoiceLineAndRate(invType, "UT_PELStorageWHSE01to03", "UT_PELStorageWHSE01to03", "CCT06", "SDT1", 300.00);
	self.createInvoiceLineAndRate(invType, "UT_PELStorageWHSE04to07", "UT_PELStorageWHSE04to07", "CCT06", "SDT1", 300.00);
	self.createInvoiceLineAndRate(invType, "UT_PELStorageWHSE08to99", "UT_PELStorageWHSE08to99", "CCT06", "SDT1", 600.00);
	
	self.createInvoiceLineAndRate(invType, "UT_PELStorageYARD01to03", "UT_PELStorageYARD01to03", "CCT06", "SDT1", 200.00);
	self.createInvoiceLineAndRate(invType, "UT_PELStorageYARD04to07", "UT_PELStorageYARD04to07", "CCT06", "SDT1", 200.00);
	self.createInvoiceLineAndRate(invType, "UT_PELStorageYARD08to99", "UT_PELStorageYARD08to99", "CCT06", "SDT1", 400.00);
	
	// STORAGE TRIGGERS
	create triggers transient;
	create pxyStorageTrigger transient;
	pxyStorageTrigger.setProxy( StorageTAGroup, false, null);
	triggers.add(pxyStorageTrigger);

	// STORAGE CONFIG
	debtorType := app.myRoot.allDebtorTypes["SDT1"];	
	self.setupStorageConfig5(null,true,true,0,0,false,false,debtorType,triggers,true);
	
	// INVOICE CARGO INVOICE TRANSACTION MAP
	create opCriteriaColl transient;
	
	bank := self.getTerminal().getDefaultCompanyBank();
	aCode := "UTPELStorage";
	aDesc := "UT PEL Invoice Allocation";
	
	// ### TRANSACTION MAP
	foreach realTM in bank.allCargoAllocTranMaps where realTM.name &lt;&gt; aCode do
		app.myTrxUA.trxUpdateBankTMCAActive(realTM); 
		break;
	endforeach;
//	assertTrueMsg(bank.myCurrentTranMapCargoAlloc = null, "Did not deactivate tran map");
	realTM := bank.allCargoAllocTranMaps[aCode];
	if realTM &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMapCA(realTM);
		self.assertTrueTrxOKShowPassport("Delete Tran Map - " &amp; aDesc);
	endif;

	create pxyTM transient;
	pxyTM.setProxy(bank, aCode, aDesc);
		
	app.myTrxCA.trxCreateInvoiceTranMapCAlloc(pxyTM,realTM);
	self.assertTrueTrxOKShowPassport("Create TM");
	
	app.myTrxUA.trxUpdateBankTMCAActive(realTM); 
	
	// ### TRAN MAP ALLOC CONFIG
	realYAConfig := realTM.myInvoiceAllocationConfig;
	self.assertTrueMsg(realYAConfig &lt;&gt; null, "Invoice Allocation Config is NUll");
	
	pxyYAConfig := app.createUpdateProxy(realYAConfig).CM_InvoiceAllocationConfig;
	
	// cargo type, inbound and outbound ship operators
	opCriteriaColl.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	opCriteriaColl.add(app.myRoot.allYACriteriaTypes[YACriteriaType_SrcTermArea]);
	
	pxyYAConfig.setProxyInvoiceAllocation(opCriteriaColl, null, realTM, null);
	
	app.myTrxUA.trxUpdateYAIMEXConfig(pxyYAConfig, app.myPassport);	

	// MAP INVOICE LINES TO MAP
	realAlloc := self.addInvoiceCargoAllocation(realTM, TI_CargoType_Container, null, TRANS_TYPE_STORAGE, "", "", "UTICA1", "UT_PEL Storage WHSE", BlockStackId3, BlockStackId4);
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT06","VOID","",0,3, false);
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT06","UT_PELStorageWHSE04to07","",4,7, true);
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT06","UT_PELStorageWHSE08to99","",8,CM_QuantityRangeMap.MAX_RANGE.Integer, true);

	realAlloc := self.addInvoiceCargoAllocation(realTM, TI_CargoType_Container, null, TRANS_TYPE_STORAGE, "", "", "UTICA1", "UT_PEL Storage YARD", BlockStackId1, BlockStackId2);
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT06","VOID","",0,3, false);
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT06","UT_PELStorageYARD04to07","",4,7, true);
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT06","UT_PELStorageYARD08to99","",8,CM_QuantityRangeMap.MAX_RANGE.Integer, true);

	
	// CARGO
	self.addVesselVoyage();
	voyage := self.getVoyage("PEL10001");
		
	self.addOnshipCargoForId("PELU1810175", voyage.myShipBlockStack, voyage);
	
	
	self.opts.addAssoc('IsForcedMove', false);


	// MOVE CARGO - TFS 41427 SCENARIO 5
	ti5 := getTrackedItemAtLocation("PELU1810175", voyage.myShipBlockStack);
	self.moveBreakBulk(ti5, bs1, 0);
	receiveTxn:=ti5.getLastTransOfType(	TRANS_TYPE_REC_SHIP);
	self.assertNotNull(receiveTxn);	
	self.resetTransactionDate(ti5,receiveTxn.dateTime.addDays(-18));

	self.moveBreakBulk(ti5, bs3, 0);

	storeTxn:=ti5.getLastTransOfType(	TRANS_TYPE_STORAGE);
	moveTxn:=ti5.getLastTransOfType(	TRANS_TYPE_MOVE);
	beginTransaction;
	moveTxn.updateDateTime(receiveTxn.dateTime.addDays(13));
	storeTxn.updateDateTime(moveTxn.dateTime.addSeconds(1));
	commitTransaction;
	
	create trans transient;
	trans.add(storeTxn);
	self.updateTransactionResync(trans,ti5,null);
	trans.clear();
	self.moveOffsite(ti5);
	delete trans;


//	self.assertNull(cargo.getLastTransOfType(	TRANS_TYPE_STORAGE));
// 		
	
	
	// CHECK INVOICE LINES
	
	
	
epilog
	delete pxyTM;
	delete pxyYAConfig;
	delete termAreas;
	delete triggers;
	delete opCriteriaColl;
	delete trans;
end;</source>
    </JadeMethod>
    <JadeMethod name="uStorageCheckWithConfig" id="3c6a13ba-db42-41bf-8611-28d2b73ccd02">
        <source>uStorageCheckWithConfig();
// cnwjre1
// Check (revised) storage configuration code, free days 0 and 1, receipt same day to 3 days after free days

constants
	VoyageName = 'UTVOYROR2';
	ShipName = 'UTROR2';
	TestOperator = 'UTOP';
	CraneTransferAreaId	= "UTC1T2";
	IMV1 = "UTI2";
vars
	cta: CM_CraneTransferArea;
	bs: CM_BlockStack;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	queue: CM_VoyageQueue;
	rampQueue: CM_VoyageCraneQueue;
	cargo1,
	cargo2	: CM_TrackedItem;
	tas: StringArray;
	crane: CM_Machine;
	imv: CM_Machine;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
	forkLift: CM_Machine;
	task: CM_RTQueueTask;
	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	bank			: CM_Bank;
	tran			: CM_TITransaction;
	invLine			: CM_InvoiceLine;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	chargedDaysWorking	: Boolean;
	freeDaysWorking		: Boolean;
	tranDate		: Date;
	tranTime		: Time;
	time			: Time;
	tranTS			: TimeStamp;
	vvr 			: CM_VehicleVisitRecord;
	singleGate		: CM_Gate;
	
	freeDays		: Integer;
	releaseDays		: Integer;

begin
	

	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar2();
	create triggers transient;
	// set the options to match the Port Nelson values (both true)
	includeFirstDay := true;		// the value it SHOULD be to match their processing rules
	includeFirstDay := false;		// for testing
	includeLastDay := true;
write "NO free days, include first day=" &amp; includeFirstDay.String &amp; " include last day=" &amp; includeLastDay.String;	
	// import days = 0, export days (not used here) = 10
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking,
						deriveDebtorFrom, triggers, true, 0, 10, 0);	// TFS 2570

	time := "00:00".Time;
	bank := self.getTerminal().getDefaultCompanyBank();
	if bank.onsiteStorageChargeTime &lt;&gt; time then
		beginTransaction;
			bank.onsiteStorageChargeTime := time;
		commitTransaction;
	endif;

	// set up the yard allocation to force to UBS1 for somewhere to go
	self.disableAllYA(true);
	bs:= self.addBlockStack("UBS1", 100, null);
	self.addYACatchAll("UTYA", bs);
	
	cta := self.addCraneTransferArea(CraneTransferAreaId);

	create tas transient;
	tas.add(cta.id);
	tas.add(bs.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	crane := self.addCrane("UTRP", null, tas, null);
	
	self.addMachineRule (cta, bs, RTMoveMethod_7);
	
	// set up all required invoicing, storage transactions using days onsite at/days since receival
	
	self.loadTranMapDaysOnsiteAt();
	//self.loadTranMapDaysSinceReceival();
	
	foreach freeDays in 0 to 1 do
		foreach releaseDays in 0 to freeDays + 3 do
			self.xStorageCheckWithConfig(crane, tas, bs, freeDays, releaseDays);
		endforeach;
	endforeach;
epilog
	time := "17:00".Time;
	bank := self.getTerminal().getDefaultCompanyBank();
	if bank.onsiteStorageChargeTime &lt;&gt; time then
		beginTransaction;
			bank.onsiteStorageChargeTime := time;
		commitTransaction;
	endif;

	self.disableAllYA(false);
	self.resetDefaultTranMap();	
	delete tas;
	delete triggers;
end;</source>
    </JadeMethod>
    <JadeMethod name="unitTestBeforeClass" id="f7d8eb46-4e0c-4d7b-9564-d3881ec51756">
        <updating/>
        <source>unitTestBeforeClass() updating, protected;
// cnwjre1
//
// Set up invoice line descs for the transaction map load tests and any common invoice objects used across tests
vars
	time	: Time;
	bank	: CM_Bank;
	commod	: CM_Commodity;
	commodGroup	: CM_CommodityGroup;
	invType : CM_InvoiceDesc;	
	glCode	: CM_GLCode;
	term	: CM_Terminal;
	calendar	: CM_Calendar;
	dayType		: CM_DayType;
begin

	inheritMethod();
	// bank onsiteStorageChargeTime
	time := "17:00".Time;
	bank := self.myBank;
	if bank.onsiteStorageChargeTime &lt;&gt; time then
		beginTransaction;
			bank.onsiteStorageChargeTime := time;
		commitTransaction;
	endif;
	glCode := bank.glCodes["UT_GL"];				// created in the super-class method
	invType := self.getInvoiceType("UT_InvTypeStore");			// is a storage-type invoice type
	if invType = null then
		invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	endif;
	
	self.addIfNewServiceILD("UT_ServiceFSD1", "CCT35", "UT_ILTFSD1", glCode, invType);	// receival teu
	self.addIfNewServiceILD("UT_ServiceFSD2", "CCT109", "UT_ILTFSD2", glCode, invType);	// ship_en
	self.addIfNewServiceILD("UT_ServiceFSD3", "CCT108", "UT_ILTFSD3", glCode, invType);	// ship_st
	self.addIfNewServiceILD("UT_ServiceFSD4", "CCT07", "UT_ILTFSD4", glCode, invType);	// onsite_at
	self.addIfNewServiceILD("UT_ServiceFSD5", "CCT06", "UT_ILTFSD5", glCode, invType);	// receival
	self.addIfNewServiceILD("UT_ServiceFSD6", "CCT106", "UT_ILTFSD6", glCode, invType);	// volume days
	self.addIfNewServiceILD("UT_ServiceFSD7", "CCT105", "UT_ILTFSD7", glCode, invType);	// weight days
	self.addIfNewServiceILD("UT_ServiceFSD8", "CCT09", "UT_ILTFSD8", glCode, invType);	// connected

	if app.myRoot.allCommodities["*UTA"] = null then
		self.addCommodity("*UTA", "Unit Test *A - DO NOT REMOVE", null);
	endif;
	commod := app.myRoot.allCommodities["*UTA"];
	if commod.myCommodityGroup = null then
		commodGroup := app.myRoot.allCommodityGroups["GEN"];
		beginTransaction;
		commod.setMyCommodityGroup(commodGroup);
		commitTransaction;
	endif;
	if app.myRoot.allCommodities["UT_A"] = null then
		self.addCommodity("UT_A", "Unit Test A - DO NOT REMOVE", null);
	endif;
	if app.myRoot.allCommodities["UT_B"] = null then
		self.addCommodity("UT_B", "Unit Test B - DO NOT REMOVE", null);
	endif;
	if app.myRoot.allCommodities["UT_C"] = null then
		self.addCommodity("UT_C", "Unit Test C - DO NOT REMOVE", null);
	endif;
	if app.myRoot.allCommodities["UT_D"] = null then
		self.addCommodity("UT_D", "Unit Test D - DO NOT REMOVE", null);
	endif;
	if app.myRoot.allCommodities["UT_E"] = null then
		self.addCommodity("UT_E", "Unit Test E - DO NOT REMOVE", null);
	endif;
	if app.myRoot.allCommodities["UT_F"] = null then
		self.addCommodity("UT_F", "Unit Test F - DO NOT REMOVE", null);
	endif;
	if app.myRoot.allCommodities["UT_G"] = null then
		self.addCommodity("UT_G", "Unit Test G - DO NOT REMOVE", null);
	endif;
	if app.myRoot.allCommodities["UT_H"] = null then
		self.addCommodity("UT_H", "Unit Test H - DO NOT REMOVE", null);
	endif;
	
	// remove calendar 'UTSC' from any user schema so can delete and add it here
	foreach term in app.myRoot.allTerminals do
		calendar := term.allCalendars['UTSC'];
		if calendar &lt;&gt; null then
			beginTransaction;
			calendar.allTerminals.clear();
			commitTransaction;
			app.myTrxDA.trxDeleteCalendar(calendar, app.myPassport);
		endif;
	endforeach;
	// delete UTDAY day type once any other UTSC calendars are gone
	dayType := app.myRoot.allDayTypes['UTDAY'];
	if dayType &lt;&gt; null then
		app.myTrxDA.trxDeleteDayType(dayType, app.myPassport);
	endif;

epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateCargo" id="ff50cabe-2239-4232-9010-24a9530fa553">
        <source>validateCargo(_msg : String; _storagePerTI : IntegerArray; _linesPerStorage : IntegerArray; _qtyPerLine : IntegerArray; _trackedItems : CM_TIArray) protected;
// generic voyage import/export storage invoice validation - pass in message for errors ('Import'/'Export' etc), list of expected number of CM_Storage per tracked item,
//	 list of expected invoice lines per CM_Storage, the expected quantity of each line, collection of tracked items (voyage.allImportTIs/allExportTIs)
//11/09/2017	cnwma1  TFS #6897 JMT - Calculation Type Label Refactor
vars
	tiCount,
	perTiCount,
	invCount	: Integer;
	index1,
	index2,
	index3		: Integer;
	expectedTrans	: Integer;		// storage transaction count
	expectedLines	: Integer;		// invoice line count
	expectedQuantity	: Real;		// invoice line quantity
	
	id		: String;
	calcStr	: String;
	ti		: CM_TrackedItem;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
	calcType	: CM_CalculationType;
///msg : String;	
begin

	foreach ti in _trackedItems do
		tiCount := tiCount + 1;
		index1 := index1 + 1;
		if index1 &gt; _storagePerTI.size then
			self.assertEqualMsg(index1, _storagePerTI.size, _msg &amp; " expected storages");
			return;
		endif;
///msg := _msg &amp; " " &amp; ti.id &amp; " " &amp; ti.commodity;
		expectedTrans := _storagePerTI[index1];

		perTiCount := 0;
		id := tiCount.String &amp; " " &amp; ti.id;

		foreach trans in ti.allTransactions do
		//	app.writeLog ('Transaction: ' &amp; Tab &amp; ti.id &amp; Tab &amp; trans.String &amp; Tab &amp; trans.id &amp; Tab &amp; 'createdTime: ' &amp; trans.createdTime.String &amp; Tab &amp; 
		//		'dateTime: ' &amp; trans.dateTime.String &amp; Tab &amp; 'allInvoiceLines.size: ' &amp; trans.allInvoiceLines.size.String &amp; Tab &amp; 
		//		'creationTime: ' &amp; trans.creationTime.String, LogINFO);
			if trans.isKindOf(CM_Storage) then
				perTiCount := perTiCount + 1;
				index2 := index2 + 1;
				if index2 &gt; _linesPerStorage.size then
					self.assertEqualMsg(index2, _linesPerStorage.size, _msg &amp; " expected invoice lines");
					return;
				endif;
				expectedLines := _linesPerStorage[index2];


				id := tiCount.String &amp; " " &amp; ti.id &amp; " " &amp; perTiCount.String;
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					calcType := invLine.getCalcType();
					if calcType = null then
						calcStr := " no calc type ";
					else
						//calcStr := " " &amp; calcType.calculationType.String &amp;"=" &amp; calcType.getCalcTypeDesc() &amp; " "; //11/09/2017 cnwma1 TFS #6897
						calcStr := " " &amp; calcType.calculationType.String &amp;"=" &amp; calcType.description &amp; " ";   //11/09/2017 cnwma1 TFS #6897
					endif;
					index3 := index3 + 1;
					if index3 &gt; _qtyPerLine.size then
						self.assertEqualMsg(index3, _qtyPerLine.size, _msg &amp; " expected quantities");
						return;
					endif;

					
					expectedQuantity := _qtyPerLine[index3].Real;	// cast to Real for match with invoice line quantity which is also Real, although has integer values here

			//		app.writeLog('Inv Line: ' &amp; Tab &amp; ti.id &amp; Tab &amp; invLine.String &amp; Tab &amp; 'calcStr:' &amp; calcStr &amp; Tab &amp; 'exp q: ' &amp; expectedQuantity.String &amp; Tab &amp; 
			//			'creationTime: ' &amp; invLine.creationTime.String, LogINFO);
					self.assertEqualMsg(invLine.quantity, expectedQuantity, id &amp; calcStr &amp; _msg &amp; " quantity");
										
				endforeach;
			//	app.writeLog('Inv Line2: ' &amp; Tab &amp; ti.id &amp; Tab &amp; invLine.String &amp; Tab &amp; 'id: ' &amp; id &amp; Tab &amp; 'exp lines: ' &amp; expectedLines.String &amp; Tab &amp; 'inv count: ' &amp; invCount.String, LogINFO);
				self.assertEqualMsg(invCount, expectedLines, id &amp; _msg &amp; " invoice lines");
			endif;
		endforeach;
		self.assertEqualMsg(perTiCount, expectedTrans, id &amp; _msg &amp; " storage transactions");
	endforeach;

	self.assertEqualMsg(tiCount, _storagePerTI.size, _msg &amp; " tracked items");
end;
</source>
        <access>protected</access>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_storagePerTI" type="IntegerArray"/>
        <Parameter name="_linesPerStorage" type="IntegerArray"/>
        <Parameter name="_qtyPerLine" type="IntegerArray"/>
        <Parameter name="_trackedItems" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="validateCargoStorage" id="bfc8fc4c-495a-4522-8f4a-8270d043179b">
        <source>validateCargoStorage(_msg : String; _cargo : CM_TrackedItem; _transCount  :Integer; _firstTransCharged : Boolean; _firstTransDesc : String; 
					 _tranDate1 : Date; _tranDate2 : Date; _invLineQty : Integer) protected;
// called from importCargo to validate each cargo item
vars
	tran	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
	transCount	: Integer;
	invLineCount	: Integer;
	msg		: String;
begin
	transCount := 0;
	msg := _msg &amp; " Cargo " &amp; _cargo.id;
	foreach tran in _cargo.allTransactions do
		if tran.isKindOf(CM_Storage) then
			transCount := transCount + 1;
			if transCount = 1 then
				if not _firstTransCharged then
					self.assertEqualMsg(tran.noCharge, true, msg &amp; " first storage is noCharge" );
				endif;
				self.assertEqualMsg(tran.dateTime.date, _tranDate1, msg &amp; " first storage date" );
				if _firstTransDesc &lt;&gt; null then
					self.assertEqualMsg(tran.getDisplayStringForAttribute(ETRow_Storage, false), _firstTransDesc, msg &amp; " first storage display" );
				endif;
			elseif transCount = 2 then
				self.assertEqualMsg(tran.noCharge,false, msg &amp; " second storage is charged" );
				self.assertEqualMsg(tran.dateTime.date, _tranDate2, msg &amp; " second storage date" );
			endif;
			invLineCount := 0;
			foreach invLine in tran.allInvoiceLines do
				self.assertEqualMsg(invLine.quantity.Integer, _invLineQty, msg &amp; " charged storage invoice line quantity");
				invLineCount := invLineCount + 1;
			endforeach;
			if _firstTransCharged then
				if transCount = 1 then
					self.assertEqualMsg(invLineCount, 1, msg &amp; " first storage has 1 invoice line");
				endif;
			else
				if transCount &gt; 1 then
					self.assertEqualMsg(invLineCount, 1, msg &amp; " second storage has 1 invoice line");
				endif;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(transCount, _transCount, msg &amp; " has " &amp; _transCount.String &amp; " storage transactions");

end;
</source>
        <access>protected</access>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_transCount" type="Integer"/>
        <Parameter name="_firstTransCharged" type="Boolean"/>
        <Parameter name="_firstTransDesc" type="String"/>
        <Parameter name="_tranDate1" type="Date"/>
        <Parameter name="_tranDate2" type="Date"/>
        <Parameter name="_invLineQty" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateFSDExports1" id="786affc3-1b35-40ee-ad9d-efd6e66c87a1">
        <source>validateFSDExports1(_voyage : CM_Voyage; _include : Boolean) protected;
// Each tracked item should have two storage transactions, the first no-charge and the second with one invoice line only.

vars
	transCount,
	perTiCount,
	tiCount,
	invCount	: Integer;
	id		: String;
	ti		: CM_TrackedItem;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach ti in _voyage.allExportTIs do
		perTiCount := 0;
		tiCount := tiCount + 1;
		foreach trans in ti.allTransactions do
			id := tiCount.String &amp; " " &amp; ti.id &amp; " " &amp; perTiCount.String;
			if trans.isKindOf(CM_Storage) then
				transCount := transCount + 1;
				perTiCount := perTiCount + 1;
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					if invCount = 1 then
						if _include then
							self.assertEqualMsg(invLine.quantity, 11.Real, transCount.String &amp; id &amp; " Export quantity");
						else
							self.assertEqualMsg(invLine.quantity, 10.Real, transCount.String &amp; id &amp; " Export quantity");
						endif;
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeLastLoad", "Export ILD");
					endif;
				endforeach;
				if perTiCount = 1 then
					self.assertEqualMsg(invCount, 0, id &amp; " Export invoice line(s)");
				else
					self.assertEqualMsg(invCount, 1, id &amp; " Export invoice line(s)");
				endif;
			endif;
		endforeach;
	endforeach;

	self.assertEqualMsg(transCount, 8, "Export storage transactions");
end;
</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_include" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateFSDImports1" id="3b0cf598-b9a9-462a-8908-92025c3068fe">
        <source>validateFSDImports1(_voyage : CM_Voyage; _include : Boolean) protected;
// The first three imported TIs have two storage transactions, to test escalating storage handling, of 9 days and 2 days (exclusive)
//  or 10 and 2 inclusive.  Each tracked item should have two storage transactions, the first no-charge and the second with one invoice line only.
// Import cargo has 3 free days
vars
	tiCount,
	transCount,
	perTiCount,
	invCount	: Integer;
	id		: String;
	ti		: CM_TrackedItem;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
	tiId : String;
begin
	foreach ti in _voyage.allImportTIs do
	
		tiCount := tiCount + 1;
		perTiCount := 0;
		foreach trans in ti.allTransactions do
			if trans.isKindOf(CM_Storage) then
				transCount := transCount + 1;
				perTiCount := perTiCount + 1;
				id := tiCount.String &amp; " " &amp; ti.id &amp; " " &amp; perTiCount.String;
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					if _include then
						if tiCount &gt; 3 then
							self.assertEqualMsg(invLine.quantity, 9.Real, id &amp; " Import quantity");
						else
							if perTiCount = 2 then
								self.assertEqualMsg(invLine.quantity, 7.Real, id &amp; " Import quantity");
							else
								self.assertEqualMsg(invLine.quantity, 2.Real, id &amp; " Import quantity");
							endif;
						endif;
					else
						if tiCount &gt; 3 then
							self.assertEqualMsg(invLine.quantity, 8.Real, id &amp; " Import quantity");
						else
							if perTiCount = 2 then
								self.assertEqualMsg(invLine.quantity, 6.Real, id &amp; " Import quantity");
							else
								self.assertEqualMsg(invLine.quantity, 2.Real, id &amp; " Import quantity");
							endif;
						endif;
					endif;
					self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeFirstDischarge", id &amp; " Import ILD");
				endforeach;
				if perTiCount = 1 then
					self.assertEqualMsg(invCount, 0, id &amp; " Import invoice line(s)");
				else
					self.assertEqualMsg(invCount, 1, id &amp; " Import invoice line(s)");
				endif;
			endif;
		endforeach;
	endforeach;
	// first three TIs have 3 storage, the rest have 2.  Should be 24 TIs, so 51 transactions.
	self.assertEqualMsg(transCount, 51, "Import storage transactions");
end;
</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_include" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateFreeStorageImports1" id="3494ffe3-7ab4-4b3b-aae8-a81bbb004afe">
        <source>validateFreeStorageImports1(_voyage : CM_Voyage; _config : CM_StorageConfig) protected;
// Each cargo item has a no-charge storage transaction then at least one charged one.
// The first three imported TIs have two charged storage transactions, to test escalating storage handling, of 9 days and 2 days (exclusive)
//  or 10 and 2 exclusive.  Each charged storage transaction should have one invoice line only.
//11/09/2017	cnwma1  TFS #6897 JMT - Calculation Type Label Refactor
vars
	tiCount,
	transCount,
	perTiCount,
	invCount	: Integer;
	id		: String;
	ti		: CM_TrackedItem;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
	calcType	: CM_CalculationType;
	calcStr	: String;
begin
return;
write "IMPORTS";
	foreach ti in _voyage.allImportTIs do
		write ti.id &amp; " " &amp; ti.commodity;
		tiCount := tiCount + 1;
		id := tiCount.String &amp; " " &amp; ti.id;
		perTiCount := 0;
		foreach trans in ti.allTransactions do
			if trans.isKindOf(CM_Storage) then
				write " storage "&amp;trans.dateTime.String;
				transCount := transCount + 1;
				perTiCount := perTiCount + 1;
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					calcType := invLine.getCalcType();
					if calcType = null then
						calcStr := "no calc type";
					else
						//calcStr := calcType.calculationType.String &amp;" " &amp; calcType.getCalcTypeDesc();  //11/09/2017 cnwma1 TFS #6897
						calcStr := calcType.calculationType.String &amp;" " &amp; calcType.description;    //11/09/2017 cnwma1 TFS #6897
					endif;
					write " invoice line quantity " &amp; invLine.quantity.String&amp; " calc type " &amp; calcStr;
					//if _include then
						if tiCount &gt; 3 then
							//self.assertEqualMsg(invLine.quantity, 12.Real, id &amp; " Import quantity");
						else
							if perTiCount = 2 then
								//self.assertEqualMsg(invLine.quantity, 10.Real, id &amp; " Import quantity");
							elseif perTiCount = 3 then
								//self.assertEqualMsg(invLine.quantity, 2.Real, id &amp; " Import quantity");
							endif;
						endif;
					//else
						if tiCount &gt; 3 then
							//self.assertEqualMsg(invLine.quantity, 11.Real, id &amp; " Import quantity");
						else
							if perTiCount = 2 then
								//self.assertEqualMsg(invLine.quantity, 9.Real, id &amp; " Import quantity");
							elseif perTiCount = 3 then
								//self.assertEqualMsg(invLine.quantity, 2.Real, id &amp; " Import quantity");
							endif;
						endif;
					//endif;
					//self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeFirstDischarge", id &amp; " Import ILD");
				endforeach;
				if perTiCount = 1 then
					//self.assertEqualMsg(invCount, 0, id &amp; " Import invoice line(s) " &amp; perTiCount.String);
				else
					//self.assertEqualMsg(invCount, 1, id &amp; " Import invoice line(s) " &amp; perTiCount.String);
				endif;
			endif;
		endforeach;
	endforeach;
	// first three TIs have 3 storage, the rest have 2.  Should be 24 TIs, so 51 transactions.
	write "Import transCount="&amp;transCount.String;
	//self.assertEqualMsg(transCount, 51, "Import storage transactions");
end;
</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_config" type="CM_StorageConfig"/>
    </JadeMethod>
    <JadeMethod name="validateFutureStorage1" id="66d18d99-403c-490f-8957-8319dddebaaa">
        <source>validateFutureStorage1(_tis : CM_TIArray; _phase : Integer) protected;
// Each tracked item should have one future storage transaction in phase 1
//	two future storage transactions in phase 2
vars
	transCount,
	perTiCount,
	tiCount,
	invCount	: Integer;
	id		: String;
	ti		: CM_TrackedItem;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach ti in _tis do
		perTiCount := 0;
		tiCount := tiCount + 1;
		foreach trans in ti.allTransactions do
			if trans.isKindOf(CM_FutureStorage) then
				perTiCount := perTiCount + 1;
				id := " Phase " &amp; _phase.String &amp; " ti " &amp; tiCount.String &amp; " " &amp; ti.id &amp; " trans " &amp; perTiCount.String;
				if tiCount = 1 then
					if perTiCount = 1 then
						self.assertEqualMsg(trans.CM_FutureStorage.daysCharged, 30, id &amp; " daysCharged 1st");	// MAP changed 36 to 30
					elseif perTiCount = 2 then
						self.assertEqualMsg(trans.CM_FutureStorage.daysCharged, 30, id &amp; " daysCharged 2nd");
					endif;
				elseif tiCount = 2 then
					if perTiCount = 1 then
						self.assertEqualMsg(trans.CM_FutureStorage.daysCharged, 30, id &amp; " daysCharged 1st");	// MAP changed 31 to 30
					elseif perTiCount = 2 then
						self.assertEqualMsg(trans.CM_FutureStorage.daysCharged, 30, id &amp; " daysCharged 2nd");
					endif;
				elseif tiCount = 3 then
					if perTiCount = 1 then
						self.assertEqualMsg(trans.CM_FutureStorage.daysCharged, 30, id &amp; " daysCharged 1st");	// MAP changed 31 to 30
					elseif perTiCount = 2 then
						self.assertEqualMsg(trans.CM_FutureStorage.daysCharged, 30, id &amp; " daysCharged 2nd");
					endif;
				endif;
				transCount := transCount + 1;
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					if tiCount = 1 then
						if perTiCount = 1 then
							self.assertEqualMsg(invLine.quantity, 30.Real, transCount.String &amp; id &amp; " invoice quantity 1st");	// MAP changed 36 to 30
						elseif perTiCount = 2 then
							self.assertEqualMsg(invLine.quantity, 30.Real, transCount.String &amp; id &amp; " invoice quantity 2nd");
						endif;
					elseif tiCount = 2 then
						if perTiCount = 1 then
							self.assertEqualMsg(invLine.quantity, 30.Real, transCount.String &amp; id &amp; " invoice quantity 1st");	// MAP changed 31 to 30
						elseif perTiCount = 2 then
							self.assertEqualMsg(invLine.quantity, 30.Real, transCount.String &amp; id &amp; " invoice quantity 2nd");
						endif;
					endif;
				endforeach;
				// one invoice line per storage transaction for the first 2 items, no line for the third transaction
				if tiCount &lt; 3 then
					self.assertEqualMsg(invCount, 1, id &amp; " Future storage invoice line(s)");
				endif;
			endif;
		endforeach;
	endforeach;
	if _phase = 1 then
		self.assertEqualMsg(transCount, 3, " Phase 1 future storage transactions");	// 15/6/17 MAP Check for 3 transactions not 4, 4th TI shouldn't have a future storage transaction as its commodity isn't covered by future storage
	elseif _phase = 2 then
		self.assertEqualMsg(transCount, 6, "Phase 2 future storage transactions");
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_tis" type="CM_TIArray"/>
        <Parameter name="_phase" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateFutureStorage2" id="8e4bfdf2-b72b-49e1-b2ad-7a191b381eca">
        <source>validateFutureStorage2(_tis : CM_TIArray) protected;
// Each tracked item should have one future storage transaction and one invoice line
vars
	transCount,
tiCount,
	invCount	: Integer;
	id		: String;
	ti		: CM_TrackedItem;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach ti in _tis do
		tiCount := tiCount + 1;
		foreach trans in ti.allTransactions do
			if trans.isKindOf(CM_FutureStorage) then
				id := " Ti " &amp; tiCount.String &amp; " " &amp; ti.id;
				if tiCount = 1 then
					self.assertEqualMsg(trans.CM_FutureStorage.daysCharged, 30, id &amp; " daysCharged 1st");	// MAP changed 36 to 30
				elseif tiCount = 2 then
					self.assertEqualMsg(trans.CM_FutureStorage.daysCharged, 30, id &amp; " daysCharged 1st");	// MAP changed 31 to 30
				endif;
				transCount := transCount + 1;
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					if tiCount = 1 then
						self.assertEqualMsg(invLine.quantity, 30.Real, transCount.String &amp; id &amp; " invoice quantity 1st");	// MAP changed 36 to 30
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILTFSD9", transCount.String &amp; id &amp; " invoice ILD 1st");	// MAP changed UT_ILTFSD10 to UT_ILTFSD9
					elseif tiCount = 2 then
						self.assertEqualMsg(invLine.quantity, 30.Real, transCount.String &amp; id &amp; " invoice quantity 1st");	// MAP changed 31 to 30
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILTFSD9", transCount.String &amp; id &amp; " invoice ILD 2nd");
					endif;
				endforeach;
				// one invoice line per storage transaction for the first 2 items, no line for the third transaction
				if tiCount &lt; 3 then
					self.assertEqualMsg(invCount, 1, id &amp; " Future storage invoice line(s)");
				endif;
			endif;
		endforeach;
	endforeach;
	self.assertEqualMsg(transCount, 2, " Future storage transactions");
end;
</source>
        <access>protected</access>
        <Parameter name="_tis" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="validateIES0" id="fa74ec51-927a-4361-9240-7946f2d4971f">
        <source>validateIES0(_voyage : CM_Voyage) protected;
/*

Purpose:			From importExportStorage3 with no storage config - the base values

Parameters:			

Return Value:		


Date		Who		Reason
12 October 2012	cnwjre1	Initial creation
9/08/2016	cnwjre1	Revised for fewer containers being used in the tests
*/

vars
	int				: Integer;
	msg				: String;
	storagePerTI	: IntegerArray;
	linesPerStorage	: IntegerArray;
	qtyPerLine		: IntegerArray;
	trackedItems	: CM_TIArray;

begin

	create storagePerTI transient;
	create linesPerStorage transient;
	create qtyPerLine transient;
	create trackedItems transient;
	
	// Import storage transaction expected values
	// storage transactions per cargo item
	foreach int in 1 to 14 do
		storagePerTI.add(1);
	endforeach;
	
	// invoice lines per storage transaction
	foreach int in 1 to 14 do
		linesPerStorage.add(1);
	endforeach;
	
	// 'quantity' value of each invoice line
	qtyPerLine.add(11);
	qtyPerLine.add(11);
	qtyPerLine.add(12);
	qtyPerLine.add(11);
	qtyPerLine.add(0);
	qtyPerLine.add(44000);
	qtyPerLine.add(1);
	qtyPerLine.add(20);
	qtyPerLine.add(11);
	qtyPerLine.add(11);
	qtyPerLine.add(10);
	qtyPerLine.add(11);
	qtyPerLine.add(1);
	qtyPerLine.add(1);
	
	_voyage.allImportTIs.copy(trackedItems);
	msg := "Imports";
	self.validateCargo(msg, storagePerTI, linesPerStorage, qtyPerLine, trackedItems);
	
	// Export storage transaction expected values
	storagePerTI.clear();
	linesPerStorage.clear();
	qtyPerLine.clear();
	trackedItems.clear();
	// storage transactions per cargo item
	foreach int in 1 to 19 do
		storagePerTI.add(1);
	endforeach;
	
	// invoice lines per storage transaction
	foreach int in 1 to 19 do
		linesPerStorage.add(1);
	endforeach;
	
	// 'quantity' value of each invoice line
	qtyPerLine.add(11);
	qtyPerLine.add(12);
	qtyPerLine.add(12);
	qtyPerLine.add(11);
	qtyPerLine.add(0);
	qtyPerLine.add(44000);
	qtyPerLine.add(1);
	qtyPerLine.add(22);
	qtyPerLine.add(12);
	qtyPerLine.add(13);
	qtyPerLine.add(12);
	qtyPerLine.add(0);
	qtyPerLine.add(48000);
	qtyPerLine.add(1);
	qtyPerLine.add(24);
	qtyPerLine.add(12);
	qtyPerLine.add(13);
	qtyPerLine.add(1);
	qtyPerLine.add(1);

	_voyage.allExportTIs.copy(trackedItems);
	msg := "Exports";
	self.validateCargo(msg, storagePerTI, linesPerStorage, qtyPerLine, trackedItems);
epilog
	delete storagePerTI;
	delete linesPerStorage;
	delete qtyPerLine;
	delete trackedItems;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="validateIES1" id="cec7245b-637c-471f-a6c2-5a0b965810d1">
        <source>validateIES1(_voyage : CM_Voyage) protected;
/*

Purpose:			From importExportStorage3 all default storage config
					should be basically one day less than the base values
Parameters:			

Return Value:		


Date		Who		Reason
12 October 2012	cnwjre1	Initial creation
9/08/2016	cnwjre1	Values revised for fewer containers being used
*/

vars
	int				: Integer;
	msg				: String;
	storagePerTI	: IntegerArray;
	linesPerStorage	: IntegerArray;
	qtyPerLine		: IntegerArray;
	trackedItems	: CM_TIArray;

begin
	create storagePerTI transient;
	create linesPerStorage transient;
	create qtyPerLine transient;
	create trackedItems transient;
	
	// IMPORT storage transaction expected values
	// storage transactions per cargo item (14 items, one storage transaction each, one invoice line)
	foreach int in 1 to 14 do
		storagePerTI.add(1);
	endforeach;
	
	// invoice lines per storage transaction
	foreach int in 1 to 14 do
		linesPerStorage.add(1);
	endforeach;
	
	// 'quantity' value of each invoice line
	qtyPerLine.add(10);
	qtyPerLine.add(10);
	qtyPerLine.add(10);
	qtyPerLine.add(10);
	qtyPerLine.add(0);
	qtyPerLine.add(40000);
	qtyPerLine.add(1);
	qtyPerLine.add(18);
	qtyPerLine.add(10);
	qtyPerLine.add(9);
	qtyPerLine.add(9);
	qtyPerLine.add(10);
	qtyPerLine.add(1);
	qtyPerLine.add(1);
	
	_voyage.allImportTIs.copy(trackedItems);
	msg := "Imports";
	self.validateCargo(msg, storagePerTI, linesPerStorage, qtyPerLine, trackedItems);
	
	// EXPORT storage transaction expected values, 19 containers
	storagePerTI.clear();
	linesPerStorage.clear();
	qtyPerLine.clear();
	trackedItems.clear();
	// storage transactions per cargo item
	foreach int in 1 to 19 do
		storagePerTI.add(1);
	endforeach;
	
	// invoice lines per storage transaction
	foreach int in 1 to 19 do
		linesPerStorage.add(1);
	endforeach;
	
	// 'quantity' value of each invoice line
	qtyPerLine.add(10);
	qtyPerLine.add(12);
	qtyPerLine.add(10);
	qtyPerLine.add(10);
	qtyPerLine.add(0);
	qtyPerLine.add(40000);
	qtyPerLine.add(1);
	qtyPerLine.add(20);
	qtyPerLine.add(12);
	qtyPerLine.add(11);
	qtyPerLine.add(11);
	qtyPerLine.add(0);
	qtyPerLine.add(44000);
	qtyPerLine.add(1);
	qtyPerLine.add(22);
	qtyPerLine.add(12);
	qtyPerLine.add(11);
	qtyPerLine.add(1);
	qtyPerLine.add(1);

	_voyage.allExportTIs.copy(trackedItems);
	msg := "Exports";
	self.validateCargo(msg, storagePerTI, linesPerStorage, qtyPerLine, trackedItems);
epilog
	delete storagePerTI;
	delete linesPerStorage;
	delete qtyPerLine;
	delete trackedItems;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="validateIES2" id="a43d8ec9-60c9-40d0-b6ba-c92d831c97b4">
        <source>validateIES2(_voyage : CM_Voyage) protected;
/*

Purpose:			From importExportStorage3 with storage config include first days set, all other options default and no free storage days
					should be the same as the base values
Parameters:			

Return Value:		


Date		Who		Reason
12 October 2012	cnwjre1	Initial creation
9/08/2016	cnwjre1	Revised for fewer containers being used in the tests
*/

vars
	int				: Integer;
	msg				: String;
	storagePerTI	: IntegerArray;
	linesPerStorage	: IntegerArray;
	qtyPerLine		: IntegerArray;
	trackedItems	: CM_TIArray;

begin

	create storagePerTI transient;
	create linesPerStorage transient;
	create qtyPerLine transient;
	create trackedItems transient;
	
	// Import storage transaction expected values
	// storage transactions per cargo item
	foreach int in 1 to 14 do
		storagePerTI.add(1);
	endforeach;
	
	// invoice lines per storage transaction
	foreach int in 1 to 14 do
		linesPerStorage.add(1);
	endforeach;
	
	// 'quantity' value of each invoice line
	qtyPerLine.add(11);						// Days Since Receival TEU 
	qtyPerLine.add(11);						// Days Since First Discharge 
	qtyPerLine.add(11);						// Days Onsite At 17:00:00 
	qtyPerLine.add(11);						// Days Since Receival 
	qtyPerLine.add(0);						// Days Onsite By Volume 
	qtyPerLine.add(44000);					// Days Onsite By Weight Kilos 
	qtyPerLine.add(1);						// Days Connected 
	qtyPerLine.add(20);						// Days Since Receival TEU
	qtyPerLine.add(11);						// Days Since First Discharge 
	qtyPerLine.add(10);						// Days Onsite At 17:00:00 
	qtyPerLine.add(10);						// Days Since Receival 
	qtyPerLine.add(11);						// Days Since First Discharge 
	qtyPerLine.add(1);						// Days Connected 
	qtyPerLine.add(1);
	
	_voyage.allImportTIs.copy(trackedItems);
	msg := "Imports";
	self.validateCargo(msg, storagePerTI, linesPerStorage, qtyPerLine, trackedItems);
	
	// Export storage transaction expected values
	storagePerTI.clear();
	linesPerStorage.clear();
	qtyPerLine.clear();
	trackedItems.clear();
	// storage transactions per cargo item
	foreach int in 1 to 19 do
		storagePerTI.add(1);
	endforeach;
	
	// invoice lines per storage transaction
	foreach int in 1 to 19 do
		linesPerStorage.add(1);
	endforeach;
	
	// 'quantity' value of each invoice line
	qtyPerLine.add(11);						// Days Since Receival TEU
	qtyPerLine.add(13);						// Days Since Last Load
	qtyPerLine.add(11);						// Days Onsite At 00:00:00
	qtyPerLine.add(11);						// Days Since Receival
	qtyPerLine.add(0);						// Days Onsite By Volume
	qtyPerLine.add(44000);					// Onsite By Weight Kilos
	qtyPerLine.add(1); 						// Days Connected
	qtyPerLine.add(22);						// Days Since Receival TEU
	qtyPerLine.add(13);						// Days Since Last Load
	qtyPerLine.add(12);						// Days Onsite At 00:00:00
	qtyPerLine.add(12);						// Days Since Receival
	qtyPerLine.add(0);						// Days Onsite By Volume
	qtyPerLine.add(48000);					// Days Onsite By Weight Kilos
	qtyPerLine.add(1);						// Days Connected
	qtyPerLine.add(24);						// Days Since Receival TEU
	qtyPerLine.add(13);						// Days Since Last Load
	qtyPerLine.add(12);					// Days Onsite At 00:00:00
	qtyPerLine.add(1);						// Days Connected
	qtyPerLine.add(1);						// Days Connected

	_voyage.allExportTIs.copy(trackedItems);
	msg := "Exports";
	self.validateCargo(msg, storagePerTI, linesPerStorage, qtyPerLine, trackedItems);
epilog
	delete storagePerTI;
	delete linesPerStorage;
	delete qtyPerLine;
	delete trackedItems;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="validateIES3" id="0f05411a-bf19-4345-95fc-abb2fa1f5010">
        <source>validateIES3(_voyage : CM_Voyage) protected;
/*

Purpose:			From importExportStorage3 with storage config with include last days set, all other options default and no free storage days
					Should be the same as the base values
Parameters:			

Return Value:		


Date		Who		Reason
12 October 2012	cnwjre1	Initial creation
9/08/2016	cnwjre1	Revised for fewer containers being used in the tests
*/

vars
	int				: Integer;
	msg				: String;
	storagePerTI	: IntegerArray;
	linesPerStorage	: IntegerArray;
	qtyPerLine		: IntegerArray;
	trackedItems	: CM_TIArray;

begin

	create storagePerTI transient;
	create linesPerStorage transient;
	create qtyPerLine transient;
	create trackedItems transient;
	
	// Import storage transaction expected values
	// storage transactions per cargo item
	foreach int in 1 to 14 do
		storagePerTI.add(1);
	endforeach;
	
	// invoice lines per storage transaction
	foreach int in 1 to 14 do
		linesPerStorage.add(1);
	endforeach;
	
	// 'quantity' value of each invoice line
	qtyPerLine.add(11);				// Days Since Receival TEU
	qtyPerLine.add(11);				// Days Since First Discharge
	qtyPerLine.add(11);				// Days Onsite At 00:00:00
	qtyPerLine.add(11);				// Days Since Receival
	qtyPerLine.add(0);				// Days Onsite By Volume
	qtyPerLine.add(44000);			// Days Onsite By Weight Kilos
	qtyPerLine.add(1);				// Days Connected
	qtyPerLine.add(20);				// Days Since Receival TEU
	qtyPerLine.add(11);				// Days Since First Discharge
	qtyPerLine.add(10);				// Days Onsite At 00:00:00
	qtyPerLine.add(10);				// Days Since Receival
	qtyPerLine.add(11);				// Days Since First Discharge
	qtyPerLine.add(1);				// Days Connected
	qtyPerLine.add(1);				// Days Connected
	
	_voyage.allImportTIs.copy(trackedItems);
	msg := "Imports";
	self.validateCargo(msg, storagePerTI, linesPerStorage, qtyPerLine, trackedItems);
	
	// Export storage transaction expected values
	storagePerTI.clear();
	linesPerStorage.clear();
	qtyPerLine.clear();
	trackedItems.clear();
	// storage transactions per cargo item
	foreach int in 1 to 19 do
		storagePerTI.add(1);
	endforeach;
	
	// invoice lines per storage transaction
	foreach int in 1 to 24 do
		linesPerStorage.add(1);
	endforeach;
	
	// 'quantity' value of each invoice line
	qtyPerLine.add(11);
	qtyPerLine.add(12);
	qtyPerLine.add(11);
	qtyPerLine.add(11);
	qtyPerLine.add(0);
	qtyPerLine.add(44000);
	qtyPerLine.add(1);
	qtyPerLine.add(22);
	qtyPerLine.add(12);
	qtyPerLine.add(12);
	qtyPerLine.add(12);
	qtyPerLine.add(0);
	qtyPerLine.add(48000);
	qtyPerLine.add(1);
	qtyPerLine.add(24);
	qtyPerLine.add(12);
	qtyPerLine.add(12);
	qtyPerLine.add(1);
	qtyPerLine.add(1);

	_voyage.allExportTIs.copy(trackedItems);
	msg := "Exports";
	self.validateCargo(msg, storagePerTI, linesPerStorage, qtyPerLine, trackedItems);
epilog
	delete storagePerTI;
	delete linesPerStorage;
	delete qtyPerLine;
	delete trackedItems;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="validateIES4" id="e03521a9-64ec-4b02-baee-ff3852f67c5b">
        <source>validateIES4(_voyage : CM_Voyage) protected;
/*

Purpose:			From importExportStorage3 with storage config with include both first day and last day but all other options default and no free storage days
					Should all be one day more than the base values
Parameters:			

Return Value:		


Date		Who		Reason
12 October 2012	cnwjre1	Initial creation
9/08/2016	cnwjre1	Values revised for fewer containers being used

*/

vars
	int				: Integer;
	msg				: String;
	storagePerTI	: IntegerArray;
	linesPerStorage	: IntegerArray;
	qtyPerLine		: IntegerArray;
	trackedItems	: CM_TIArray;

begin

	create storagePerTI transient;
	create linesPerStorage transient;
	create qtyPerLine transient;
	create trackedItems transient;
	
	// Import storage transaction expected values
	// storage transactions per cargo item
	foreach int in 1 to 14 do
		storagePerTI.add(1);
	endforeach;
	
	// invoice lines per storage transaction
	foreach int in 1 to 14 do
		linesPerStorage.add(1);
	endforeach;
	
	// 'quantity' value of each invoice line
	qtyPerLine.add(12);						// Days Since Receival TEU 
	qtyPerLine.add(12);						// Days Since First Discharge 
	qtyPerLine.add(12);						// Days Onsite At 17:00:00 
	qtyPerLine.add(12);						// Days Since Receival 
	qtyPerLine.add(0);						// Days Onsite By Volume 
	qtyPerLine.add(48000);					// Days Onsite By Weight Kilos 
	qtyPerLine.add(1);						// Days Connected
	qtyPerLine.add(22);						// Days Since Receival TEU
	qtyPerLine.add(12);						// Days Since First Discharge 
	qtyPerLine.add(11);						// Days Onsite At 17:00:00 
	qtyPerLine.add(11);						// Days Since Receival 
	qtyPerLine.add(12);						// Days Since First Discharge 
	qtyPerLine.add(1);						// Days Connected
	qtyPerLine.add(1);
	
	_voyage.allImportTIs.copy(trackedItems);
	msg := "Imports";
	self.validateCargo(msg, storagePerTI, linesPerStorage, qtyPerLine, trackedItems);
	
	// Export storage transaction expected values
	storagePerTI.clear();
	linesPerStorage.clear();
	qtyPerLine.clear();
	trackedItems.clear();
	// storage transactions per cargo item
	foreach int in 1 to 19 do
		storagePerTI.add(1);
	endforeach;
	
	// invoice lines per storage transaction
	foreach int in 1 to 19 do
		linesPerStorage.add(1);
	endforeach;
	
	// 'quantity' value of each invoice line
	qtyPerLine.add(12);						// Days Since Receival TEU 
	qtyPerLine.add(13);						// Days Since Last Load 
	qtyPerLine.add(12);						// Days Onsite At 17:00:00 
	qtyPerLine.add(12);						// Days Since Receival 
	qtyPerLine.add(0);						// Days Onsite By Volume 
	qtyPerLine.add(48000);					// Days Onsite By Weight Kilos 
	qtyPerLine.add(1);						// Days Connected
	qtyPerLine.add(24);						// Days Since Receival TEU
	qtyPerLine.add(13);						// Days Since Last Load 
	qtyPerLine.add(13);						// Days Onsite At 17:00:00 
	qtyPerLine.add(13);						// Days Since Receival
	qtyPerLine.add(0);						// Days Onsite By Volume 
	qtyPerLine.add(52000);					// Days Onsite By Weight Kilos 
	qtyPerLine.add(1);						// Days Connected
	qtyPerLine.add(26);						// Days Since Receival TEU 
	qtyPerLine.add(13);						// Days Since Last Load 
	qtyPerLine.add(13);						// Days Onsite At
	qtyPerLine.add(1);						// Days Connected
	qtyPerLine.add(1);						// Days Connected 

	_voyage.allExportTIs.copy(trackedItems);
	msg := "Exports";
	self.validateCargo(msg, storagePerTI, linesPerStorage, qtyPerLine, trackedItems);
epilog
	delete storagePerTI;
	delete linesPerStorage;
	delete qtyPerLine;
	delete trackedItems;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="validateImportExportStorage" id="3cb31084-63f9-4ffc-ac2b-30cc68461854">
        <source>validateImportExportStorage(_voyage : CM_Voyage; _storageConfig : CM_StorageConfig) protected;
/*

Purpose:			Called from importExportStorage3
					Validate voyage import and export cargo based on the storage config options
Parameters:			

Return Value:		


Date		Who		Reason
12 October 2012	cnwjre1	Initial creation

*/

vars

begin
	// no storage config - base values
	if _storageConfig = null then
		self.validateIES0(_voyage);
		return;
	endif;
	// storage config with no options set
	if not _storageConfig.includeFirstDay and
	   not _storageConfig.includeLastDay and
	   _storageConfig.shipReceivalType = CM_StorageConfig.ShipReceivalActualDischarge and
	   _storageConfig.shipReleaseType = CM_StorageConfig.ShipReleaseActualLoad then
		self.validateIES1(_voyage);
		return;
	endif;
	// storage config with first day only, all else default
	if _storageConfig.includeFirstDay and
	   not _storageConfig.includeLastDay and
	   _storageConfig.shipReceivalType = CM_StorageConfig.ShipReceivalActualDischarge and
	   _storageConfig.shipReleaseType = CM_StorageConfig.ShipReleaseActualLoad then
		self.validateIES2(_voyage);
		return;
	endif;
	// storage config with last day only, all else default
	if not _storageConfig.includeFirstDay and
	   _storageConfig.includeLastDay and
	   _storageConfig.shipReceivalType = CM_StorageConfig.ShipReceivalActualDischarge and
	   _storageConfig.shipReleaseType = CM_StorageConfig.ShipReleaseActualLoad then
		self.validateIES3(_voyage);
		return;
	endif;
	// storage config with first and last day only, all else default
	if _storageConfig.includeFirstDay and
	   _storageConfig.includeLastDay and
	   _storageConfig.shipReceivalType = CM_StorageConfig.ShipReceivalActualDischarge and
	   _storageConfig.shipReleaseType = CM_StorageConfig.ShipReleaseActualLoad then
		self.validateIES4(_voyage);
		return;
	endif;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_storageConfig" type="CM_StorageConfig"/>
    </JadeMethod>
    <JadeMethod name="validateImportStorage" id="5f988e34-eebb-433b-bc66-c645a1351860">
        <source>validateImportStorage(_msg : String; _cargo : CM_TrackedItem; _tranDate1 : Date; _tranDate2 : Date; _invLineQty : Integer) protected;
// called from importStorage to validate each cargo item
vars
	tran	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
	transCount	: Integer;
	invLineCount	: Integer;
	msg		: String;
begin
	transCount := 0;
	msg := _msg &amp; " Cargo " &amp; _cargo.id;
	foreach tran in _cargo.allTransactions do
		if tran.isKindOf(CM_Storage) then
			transCount := transCount + 1;
			if transCount = 1 then
				self.assertEqualMsg(tran.noCharge, true, msg &amp; " first storage is noCharge" );
				self.assertEqualMsg(tran.dateTime.date, _tranDate1, msg &amp; " first storage date" );
				self.assertEqualMsg(tran.getDisplayStringForAttribute(ETRow_Storage, false), "Stored for 7 free days, no charge. ", msg &amp; " first storage display" );
			elseif transCount = 2 then
				self.assertEqualMsg(tran.noCharge,false, msg &amp; " second storage is charged" );
				self.assertEqualMsg(tran.dateTime.date, _tranDate2, msg &amp; " second storage date" );
			endif;
			invLineCount := 0;
			foreach invLine in tran.allInvoiceLines do
				self.assertEqualMsg(invLine.quantity.Integer, _invLineQty, msg &amp; " second storage invoice line quantity");
				invLineCount := invLineCount + 1;
			endforeach;
			if transCount = 2 then
				self.assertEqualMsg(invLineCount, 1, msg &amp; " second storage has 1 invoice line");
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 2, msg &amp; " has 2 storage transactions");

end;
</source>
        <access>protected</access>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_tranDate1" type="Date"/>
        <Parameter name="_tranDate2" type="Date"/>
        <Parameter name="_invLineQty" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyStorageTI" id="2e3645ad-cdec-4233-9a8c-3352a584f1fc">
        <source>verifyStorageTI(_ti : CM_TrackedItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods

*/

vars

begin
	write _ti.getFreeStorageDays();
	write _ti.getAdditionalStorageDays();
	write _ti.getFreeStorageExpiry();
	write _ti.getFreeStorageDaysRemaining();
	write _ti.getFreeStorageChangeReason();
	write _ti.getFreeDaysType();
	write _ti.getChargedDaysType();
	write _ti.getFreeDaysType();
	write _ti.getFutureStorageAnniversary();
	write "-------------- ";
epilog

end;</source>
