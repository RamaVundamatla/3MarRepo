    <JadeMethod name="doTblPilotLaunchMnuClick" id="970caff2-a063-4a84-ace1-1c71e37ed573">
        <updating/>
        <source>doTblPilotLaunchMnuClick(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	xLeft 	: Real;
	yTop	: Real;
	obj : Object;
begin
	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	self.mnuPilotLaunchDelete.userObject := table.accessRow(table.row).itemObject;	

	self.mnuPilotLaunchDelete.visible := true;
	if not self.aCanUpdateFull then
		if not self.aCanUpdatePartial then
			// View Only
			self.mnuPilotLaunchAdd.visible := false;
			self.mnuPilotLaunchDelete.visible := false;
			self.mnuPilotLaunchDelete.userObject := null;				
		endif;
	endif;
	self.popupMenu(self.mnuPilotLaunchContext, xLeft.Integer, yTop.Integer);	
	return true;	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="dotblResourcesContextMnuClick" id="27769989-8e98-4be4-a702-1cfb7446ccc8">
        <updating/>
        <source>dotblResourcesContextMnuClick(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//  Created 01/09/2006 Shane

vars
	xLeft 	: Real;
	yTop	: Real;
	obj : Object;
begin

//	if self.aMode &lt;&gt; self.Mode_Update then
//		return false;
//	endif;
	
	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	self.mnuResourceDelete.userObject := table.accessRow(table.row).itemObject;	

	// ### PAR 10579 CCMS 1350
	self.mnuResourceDelete.visible := true;
	if not self.aCanUpdateFull then
		if not self.aCanUpdatePartial then
			// View Only
			self.mnuResourceAdd.visible := false;
			self.mnuResourceDelete.visible := false;
			self.mnuResourceDelete.userObject := null;				
		else
			// Partial Only - no deleting contract lines
			obj := table.accessRow(table.row).itemObject;
			if obj.isKindOf(HMS_ResourceUsed) then
				if obj.HMS_ResourceUsed.partOfContract then
					self.mnuResourceDelete.visible := false;
					self.mnuResourceDelete.userObject := null;				
				endif;
			endif;
		endif;
	endif;



	self.popupMenu(self.mnuResContext, xLeft.Integer, yTop.Integer);
	
	return true;	
	
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableMovementCancelBtns" id="ddb62a54-fba0-4090-8725-91b47bb0bb49">
        <source>enableMovementCancelBtns();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

	voyage : CM_Voyage;

begin

	self.btnViewCancelMove.enabled := false;

	if self.aMode = self.Mode_Update then
		return;
	endif;	

	if self.aMySelectedMovement &lt;&gt; null  then
		if aMySelectedMovement.myCancelledMovement &lt;&gt; null then
			self.btnViewCancelMove.enabled := true;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
