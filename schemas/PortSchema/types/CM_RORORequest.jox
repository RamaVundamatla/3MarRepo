    <JadeMethod name="createAllocationFromLoadCC" id="6367c05f-9061-43c4-8bb5-6d99125c0418">
        <updating/>
        <source>createAllocationFromLoadCC(_loadCC : CMIF_LoadColorCode; _moveType : Integer; _slotC : CM_VoyageROROController input) : CM_VoyageAllocation updating;
/*
Purpose:			
Date				Who			Reason
NOVEMBER 2011		CNWAB1		Initial creation
*/

vars
	workedDT : TimeStamp;
	aComm : CM_Commodity;
	aPortCode, tmpAllocDesc : String;
	voy : CM_Voyage;
	useAllocations : Boolean;
	existingAlloc, newAlloc : CM_VoyageAllocation;
	cargoType : CM_CargoType;
begin

	voy := _slotC.myVoyage;

	create newAlloc transient;
	if _moveType = LOAD_MOVETYPE then
		newAlloc.setFromLoadCC(_loadCC,TI_IMEX_STATUS_EXPORT, _moveType, self.getWeightRangeFromWeight(0));
	else
		newAlloc.setFromLoadCC(_loadCC,TI_IMEX_STATUS_IMPORT, _moveType, self.getWeightRangeFromWeight(0));
	endif;
	newAlloc.removeNonconfigCriteria(voy);
	
	tmpAllocDesc := newAlloc.getDefaultDescription(); // allocation.setFromTI() will build the criteria, so this will result in a meaningful description;
	newAlloc.setProxy(	tmpAllocDesc,
						tmpAllocDesc,
						null,
						YAFillOption_InOrder,
						YAFillOption_InOrder,
						YAExpiryType_Never,
						null,
						newAlloc.getDefaultColour,// allocation.setFromTI() should have set the dishargePort so this call should set a good colour
						null,  //cnwjo3 par 24145
						YAOverlap_Never,//allow others
						YANoLocation_Continue,
						null,
						0, //priority adjustment
						false,
						false,
						null,
						null,
						true,
						self.myTerminal);
	existingAlloc := voy.getAllocationWithSameCriteria(newAlloc);
	
	if existingAlloc = null then
		app.myUtilityUA.utlUpdateVoyageAlloc(false,voy, newAlloc,existingAlloc,app.myPassport);
		existingAlloc := voy.getAllocationWithSameCriteria(newAlloc);
	else
		app.myEventManager.createSingleObjInfoNoteEvt(voy,self.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE),existingAlloc);
	endif;
	
	self.allAllocations.add(existingAlloc);
	
	return existingAlloc;

epilog
	delete newAlloc; // not needed
end;</source>
        <Parameter name="_loadCC" type="CMIF_LoadColorCode"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_slotC" type="CM_VoyageROROController" usage="input"/>
        <ReturnType type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="884b46b8-08a8-413b-a444-ab0142f8d77e">
        <updating/>
        <source>createWLEs() updating;
/*
Purpose:			
Date				Who			Reason
JANUARY 2012		CNWAB1		Initial creation
05 July 2019		jlgzm1		TFS 42863 MSL - Direct Release Between RORO Voyages and Rail - Break Bulk
*/

vars
	wle		: CM_WorkListEntry;
	aTI 	: CM_TrackedItem;
	tbaTI	: CM_TrackedItem;		// PAR #26426
	idx, qty , wleQuantity : Integer;
	cargoType : CM_CargoType;	// tfs42863
begin

	
	if self.allWorkListEntries.isEmpty then
		if self.isDischarge then
			if self.myROROController &lt;&gt; null then
				foreach aTI in self.myROROController.allTrackedItems do
					create wle as CM_VoyageWLE;
					wle.setForCreate(self.myJob, self);
					wle.setMyTrackedItem(aTI);
					wle.setQuantity(aTI.totalQuantity.max(1));
				endforeach;
			endif;
		else
			qty := self.quantity.Integer;
			if qty &lt;1 then
				qty := 1;
			endif;
			cargoType := self.getAttrCargoType();
			if cargoType &lt;&gt; null and cargoType.isAllowDuplicates then	//09 Jan 2019	NDL	- found in unit test UT_BtreakBulk::tBreakBulkROROGCJobsWorked 
				create wle as CM_VoyageWLE;
				wle.setForCreate(self.myJob, self);
				wle.setQuantity(qty);
			else
				foreach idx in 1 to qty do
					create wle as CM_VoyageWLE;
					wle.setForCreate(self.myJob, self);
				endforeach;
			endif;
		
		endif;
	else
		cargoType := self.getAttrCargoType();
		wleQuantity:=self.getWLEQuantity;
		if self.quantity &gt; wleQuantity then
			qty := self.quantity.Integer;
			if qty &lt; 1 then
				qty := 1;
			endif;
			qty := qty - wleQuantity; // Qty To Add
			if qty &gt; 0 then
				// tfs42863
				// if splittable, create 1 wle with the specified qty
				if cargoType &lt;&gt; null and cargoType.isAllowDuplicates then
					wle := self.allWorkListEntries.first;
					wle.setQuantity(self.quantity.Integer);
				else
					foreach idx in 1 to qty do
						create wle as CM_VoyageWLE;
						wle.setForCreate(self.myJob, self);
					endforeach;
				endif;
			endif;
		else
			qty := self.quantity.Integer;
			if qty &lt; 1 then
				qty := 1;
			endif;
			qty := wleQuantity - qty; // Qty To Remove
			if qty &gt; 0 then
				foreach wle in self.allWorkListEntries reversed do
					//cnwmc5 - 28/01/2013 - PAR #31084
					if wle.myTrackedItem = null then
						self.removeWLE(wle.CM_VoyageWLE, null);
						idx := idx + 1;
					endif;
					if idx = qty then
						break;
					endif;
				endforeach;
			endif;
		endif;
		
		foreach wle in self.allWorkListEntries do //cnwrd1 ccmw 1310 par 30807 need to tidy up the tba containers, here for some reason (copying slotrequest)
			if self.isBulkRelease() then
				//wle.setLocations(self.getBulkReleaseReserveDetail().getLocation(), self.);
				self.myOriginatingBulkRelease := null;		
				wle.setMyTrackedItem(null);		
			endif;		
		endforeach;
	endif;

	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="erase" id="a5d73dc0-1cba-4c6e-992b-2cfb66e81ca6">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
Purpose:			
Date		Who		Reason
31 August 2011	cnwab1	Initial creation
26 Nov 2012	NDL	Par 30754
*/

vars

	slotController : CM_VoyageROROController;
	voy : CM_Voyage;
	voyAlloc : CM_VoyageAllocation;
begin
	slotController := self.myROROController; // PAR 30905
	
//Par 30754	slotController := self.myROROController;

//Par 30754	if slotController &lt;&gt; null then
//Par 30754		voy := slotController.myVoyage;
		voyAlloc := self.allAllocations.first.CM_VoyageAllocation;
		if voyAlloc &lt;&gt; null then
			voy := voyAlloc.myVoyage;
			app.myEventManager.createSingleObjInfoNoteEvt(voy,voy.myTerminal.getTerminalEvent(EVENT_VOY_ALLOC_UPDATE),voyAlloc);
		endif;
//	Par 30754	slotController.removeSlotRequest(self);
//Par 30754	endif;

	self.myLayout.sendDeleteNotes();

	// PAR 30905
	if slotController &lt;&gt; null then
		slotController.removeSlotRequest(self);
	endif; 
		
		
	if voy &lt;&gt; null then // PAR 32732
		app.myEventManager.createSingleObjInfoNoteEvt(voy,voy.myTerminal.getTerminalEvent(Event_SlotRequest_Delete),self);	// PAR 32732
	endif;
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAftLCFor40" id="4d4a3de4-abe8-4f7c-aac6-76e391cc5453">
        <source>getAftLCFor40(_mode : Integer) : CM_DeckItem;
/*
Purpose:			
Date		Who		Reason
23 August 2011	cnwab1	Initial creation
*/

vars
	theDefn : CM_DeckItem;
begin
	if self.myROROController = null then
		return null;
	endif;
	
	theDefn := self.myROROController.getDefn();
	if theDefn = null then
		return null;
	endif;
	
	return theDefn.getAftLCFor40(_mode);

epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_DeckItem"/>
    </JadeMethod>
