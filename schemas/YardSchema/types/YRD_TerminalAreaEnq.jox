    <JadeMethod name="showExtraInfo" id="84a9bbc2-3978-4860-abad-57ee3d02ee66">
        <source>showExtraInfo(_obj : CM_Object);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	dataContainer 	: CM_DataContainer;
	numberOfColumns	: Integer;
	table			: CM_DataTable;
begin
	table			:= self.tblExtraInfo;
	table.rows 		:= 0;
	numberOfColumns := 4; //self.getNumberOfColumns();
	
	if _obj = null then
		return;
	endif;

	table.alignment := Table.Alignment_Left_Top;
	
	//######################
	// DISPLAY INFO
	create dataContainer transient;
	
	dataContainer.headerColour 	:= self.colorHeadingColumn;
	dataContainer.valueColour 	:= self.colorValueColumn;
	dataContainer.displayMode 	:= REAL_MODE;
	
	_obj.getExtraInfo(dataContainer);
	
	table.userObject := _obj; // this is used to redraw this info
	
	self.showExtraInformation(dataContainer, table, false, false, numberOfColumns, 1, 4, 1, 1);

	self.doResizeColumnWidths(table, true);

epilog
	if dataContainer &lt;&gt; null then
		delete dataContainer;
	endif;


end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
