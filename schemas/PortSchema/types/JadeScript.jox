    <JadeMethod name="adpOvertime" id="caa9b26a-8f5b-4a54-bd72-dda147bfde43">
        <source>adpOvertime(_cmif : CMIF_CalcTypeQuantityHook) : Real;
constants
	CALENDAR_HOLIDAY		= 'AKB';		// Calendar code (holiday).
	CALENDAR_FRIDAY			= 'AKB';		// Calendar code (Friday).
	CALENDAR_RAMA			= 'AKB';		// Calendat code (Ramadan).
	
	RESOURCE 				= 'ADPNT';		// To Do Resource code (resource to look for on the transaction).
	
	OVERTIME_START 			= '12:00';		// 12PM
	OVERTIME_FINISH			= '13:00';		// 1PM
	OVERTIME_START_2		= '16:00';		// 4PM
	OVERTIME_FINISH_2		= '07:00';		// 7AM next day. Must be sometime the following day.
	
	RAMA_OVERTIME_START 	= '13:00';		// 1PM
	RAMA_OVERTIME_FINISH 	= '07:00';		// 7AM next day. Must be sometime the following day.
	
	MAXTIME					= '23:59';		// Do Not Change.
	MINTIME					= '00:00';		// Do Not Change.
	EXTRA_MINS				= 1;			// Do Not Change.
	
vars
	terminal				: CM_Terminal;
	calendar,
	calendar2,
	calendar3				: CM_Calendar;
	toDoUsage,
	tempToDoUsage 			: CM_ResourceTypeUsage;
	
	fromDateTime,
	toDateTime				: TimeStamp;
	
	minTime,
	maxTime,
	fromTime,
	toTime					: Time;
	
	daysDifference,
	minsDifference 			: Integer;
	totalHours				: Real;
	
	hasRamaFromCalendarDay,
	hasRamaToCalendarDay,
	hasFromCalendarDay,
	hasToCalendarDay,
	hasHolCalendarDay,
	hasRamaCalendarDay 		: Boolean;
	
begin
	// Setup (get termnial and calendar).
	terminal := _cmif.myTransaction.CM_TITransaction.myTerminal;
	calendar := terminal.allCalendars[CALENDAR_HOLIDAY];
	calendar2 := terminal.allCalendars[CALENDAR_FRIDAY];
	calendar3 := terminal.allCalendars[CALENDAR_RAMA];
	toDoUsage := _cmif.myResourceTypeUsage;
	
	// If I can't find the To Do Resource, then theres nothing to do here.
	if toDoUsage = null or toDoUsage.myResourceType.code &lt;&gt; RESOURCE then
		return _cmif.origQty;
	endif;
	
	// Get the TimeStamps from the To Do Resource Usage.
	fromDateTime := toDoUsage.fromDateTime;
	toDateTime := toDoUsage.toDateTime;
	fromTime := fromDateTime.time;
	toTime := toDateTime.time;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	if calendar3.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null then
		hasRamaFromCalendarDay := true;
	endif;
	if calendar3.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null then
		hasRamaToCalendarDay := true;
	endif;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	if calendar.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null 
	or calendar2.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null then
		hasFromCalendarDay := true;
	endif;
	if calendar.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null
	or calendar2.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null then
		hasToCalendarDay := true;
	endif;
	
	// Calculate the difference in days between the first and last.
	daysDifference := toDateTime.date - fromDateTime.date;
	
	// Check start day for holiday.
	if hasFromCalendarDay then
		// Do nothing - holiday.
	elseif hasRamaFromCalendarDay then
		// Check for 00:00 to 07:00.
		if fromTime &lt; RAMA_OVERTIME_FINISH.Time then
			if toTime &lt; RAMA_OVERTIME_FINISH.Time then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(RAMA_OVERTIME_FINISH.Time);
			endif;
		endif;
		
		// Check for 13:00 to 23:59.
		if fromTime &gt;= RAMA_OVERTIME_START.Time then
			if toDateTime.date = fromDateTime.date then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		elseif fromTime &lt; RAMA_OVERTIME_START.Time then
			if toDateTime.date = fromDateTime.date then
				if toTime &gt; RAMA_OVERTIME_START.Time then
					minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(toTime);
				endif;
			else
				minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		endif;
	else
		// Check for 00:00 to 07:00.
		if fromTime &lt; OVERTIME_FINISH_2.Time then
			if toTime &lt; OVERTIME_FINISH_2.Time then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(OVERTIME_FINISH_2.Time);
			endif;
		endif;
		
		// Check for 12:00 to 13:00.
		if fromTime &gt;= OVERTIME_START.Time and fromTime &lt; OVERTIME_FINISH.Time then
			if toDateTime.date = fromDateTime.date and toTime &lt; OVERTIME_FINISH.Time then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(OVERTIME_FINISH.Time);
			endif;
		elseif fromTime &lt; OVERTIME_START.Time then
			if toDateTime.date = fromDateTime.date then
				if toTime &lt; OVERTIME_FINISH.Time and toTime &gt; OVERTIME_START.Time then 
					minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(toTime);
				elseif toTime &gt; OVERTIME_FINISH.Time then
					minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(OVERTIME_FINISH.Time);
				endif;
			else
				minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(OVERTIME_FINISH.Time);
			endif;
		endif;
		
		// Check for 16:00 to 23:59.
		if fromTime &gt;= OVERTIME_START_2.Time then
			if toDateTime.date = fromDateTime.date then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		elseif fromTime &lt; OVERTIME_START_2.Time then
			if toDateTime.date = fromDateTime.date then
				if toTime &gt; OVERTIME_START_2.Time then
					minsDifference := minsDifference + OVERTIME_START_2.Time.cnMinutesDifference(toTime);
				endif;
			else
				minsDifference := minsDifference + OVERTIME_START_2.Time.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		endif;
	endif;
	
	// Calculate middle days.
	if toDateTime.date &lt;&gt; fromDateTime.date then
		if daysDifference &gt; 1 then
			daysDifference := daysDifference - 1;
			while daysDifference &gt; 0 do
				hasHolCalendarDay := false;
				hasRamaCalendarDay := false;
				if calendar.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null 
				or calendar2.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null then
					hasHolCalendarDay := true;
				endif;
				if calendar3.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null then
					hasRamaCalendarDay := true;
				endif;
	
				if hasHolCalendarDay then
					// Do nothing - holiday.
				elseif hasRamaCalendarDay then
					minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(RAMA_OVERTIME_FINISH.Time);
					minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
				else
					// Normal day - whole overtime for that day.
					minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(OVERTIME_FINISH_2.Time);
					minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(OVERTIME_FINISH.Time);
					minsDifference := minsDifference + OVERTIME_START_2.Time.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
				endif;
				daysDifference := daysDifference - 1;
			endwhile;
		endif;
		
		// Check last day for holiday.
		if hasToCalendarDay then
			// Do nothing - holiday.
		elseif hasRamaToCalendarDay then
			// Check for 00:00 to 07:00.
			if toTime &gt; RAMA_OVERTIME_FINISH.Time then
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(RAMA_OVERTIME_FINISH.Time);
			else
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(toTime);
			endif;
			
			// Check for 16:00 to 23:59.
			if toTime &gt; RAMA_OVERTIME_START.Time then
				minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(toTime);
			endif;
		else
			// Check for 00:00 to 07:00.
			if toTime &gt; OVERTIME_FINISH_2.Time then
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(OVERTIME_FINISH_2.Time);
			else
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(toTime);
			endif;
			
			// Check for 12:00 to 13:00.
			if toTime &gt;= OVERTIME_START.Time and toTime &lt; OVERTIME_FINISH.Time then
				minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(toTime);
			elseif toTime &gt; OVERTIME_FINISH.Time then
				minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(OVERTIME_FINISH.Time);
			endif;
			
			// Check for 16:00 to 23:59.
			if toTime &gt; OVERTIME_START_2.Time then
				minsDifference := minsDifference + OVERTIME_START_2.Time.cnMinutesDifference(toTime);
			endif;
		endif;
	endif;
	
	// Calculate the total hours worked.
	totalHours := minsDifference / 60;
	if totalHours mod 1 &gt; 0 then
		totalHours := totalHours.Integer + 1;
	endif;
	
	// Return the total number of hours for the for all resources used.
	return _cmif.origQty * totalHours;
end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="adpOvertimeFull" id="ad82cd6c-183a-4864-b7fb-13505961295f">
        <source>adpOvertimeFull(_cmif : CMIF_CalcTypeQuantityHook) : Real;
constants
	CALENDAR_HOLIDAY		= 'AKB';		// Calendar code (holiday).
	CALENDAR_FRIDAY			= 'AKB';		// Calendar code (Friday).
	CALENDAR_RAMA			= 'AKB';		// Calendat code (Ramadan).
	
	RESOURCE 				= 'ADPNT';		// To Do Resource code (resource to look for on the transaction).
	
	OVERTIME_START 			= '12:00';		// 12PM
	OVERTIME_FINISH			= '13:00';		// 1PM
	OVERTIME_START_2		= '16:00';		// 4PM
	OVERTIME_FINISH_2		= '07:00';		// 7AM next day. Must be sometime the following day.
	
	RAMA_OVERTIME_START 	= '13:00';		// 1PM
	RAMA_OVERTIME_FINISH 	= '07:00';		// 7AM next day. Must be sometime the following day.
	
	MAXTIME					= '23:59';		// Do Not Change.
	MINTIME					= '00:00';		// Do Not Change.
	EXTRA_MINS				= 1;			// Do Not Change.
	
vars
	terminal				: CM_Terminal;
	calendar,
	calendar2,
	calendar3				: CM_Calendar;
	toDoUsage,
	tempToDoUsage 			: CM_ResourceTypeUsage;
	
	fromDateTime,
	toDateTime				: TimeStamp;
	
	minTime,
	maxTime,
	fromTime,
	toTime					: Time;
	
	daysDifference,
	minsDifference 			: Integer;
	totalHours				: Real;
	
	hasRamaFromCalendarDay,
	hasRamaToCalendarDay,
	hasFromCalendarDay,
	hasToCalendarDay,
	hasHolCalendarDay,
	hasRamaCalendarDay 		: Boolean;
	
	fromDayCalendar,
	toDayCalendar,
	holiday					: CM_CalendarDate;
	
begin
	// Setup (get termnial and calendar).
	terminal := _cmif.myTransaction.CM_TITransaction.myTerminal;
	calendar := terminal.allCalendars[CALENDAR_HOLIDAY];
	calendar2 := terminal.allCalendars[CALENDAR_FRIDAY];
	calendar3 := terminal.allCalendars[CALENDAR_RAMA];
	toDoUsage := _cmif.myResourceTypeUsage;
	
	// If I can't find the To Do Resource, then theres nothing to do here.
	if toDoUsage = null or toDoUsage.myResourceType.code &lt;&gt; RESOURCE then
		return _cmif.origQty;
	endif;
	
	// Get the TimeStamps from the To Do Resource Usage.
	fromDateTime := toDoUsage.fromDateTime;
	toDateTime := toDoUsage.toDateTime;
	fromTime := fromDateTime.time;
	toTime := toDateTime.time;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	if calendar3.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null then
		hasRamaFromCalendarDay := true;
	endif;
	if calendar3.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null then
		hasRamaToCalendarDay := true;
	endif;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	if calendar.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null 
	or calendar2.getFirstCalendarDateForDay(fromDateTime.date) &lt;&gt; null then
		hasFromCalendarDay := true;
	endif;
	if calendar.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null
	or calendar2.getFirstCalendarDateForDay(toDateTime.date) &lt;&gt; null then
		hasToCalendarDay := true;
	endif;
	
	// Get start and finish days off Calendar (check to see if they are holidays).
	fromDayCalendar := calendar.getFirstCalendarDateForDay(fromDateTime.date);
	if fromDayCalendar = null then
		fromDayCalendar := calendar2.getFirstCalendarDateForDay(fromDateTime.date);
	endif;
	toDayCalendar := calendar.getFirstCalendarDateForDay(toDateTime.date);
	if toDayCalendar = null then
		toDayCalendar := calendar2.getFirstCalendarDateForDay(toDateTime.date);
	endif;
	
	// Calculate the difference in days between the first and last.
	daysDifference := toDateTime.date - fromDateTime.date;
	
	// Check start day for holiday.
	if hasFromCalendarDay then
		// Calculate day as overtime.
		minTime := fromDayCalendar.startTime;
		if minTime = null then
			minTime := MINTIME.Time;
		endif;
		maxTime := fromDayCalendar.endTime;
		if maxTime = null then
			maxTime := MAXTIME.Time;
		endif;
		
		if fromTime &gt; minTime then
			minTime := fromTime;
		endif;
		
		if fromDateTime.date = toDateTime.date and toTime &lt; maxTime then
			maxTime := toTime;
		else
			minsDifference := minsDifference + EXTRA_MINS;
		endif;
		minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime);
	elseif hasRamaFromCalendarDay then
		// Check for 00:00 to 07:00.
		if fromTime &lt; RAMA_OVERTIME_FINISH.Time then
			if toTime &lt; RAMA_OVERTIME_FINISH.Time then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(RAMA_OVERTIME_FINISH.Time);
			endif;
		endif;
		
		// Check for 13:00 to 23:59.
		if fromTime &gt;= RAMA_OVERTIME_START.Time then
			if toDateTime.date = fromDateTime.date then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		elseif fromTime &lt; RAMA_OVERTIME_START.Time then
			if toDateTime.date = fromDateTime.date then
				if toTime &gt; RAMA_OVERTIME_START.Time then
					minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(toTime);
				endif;
			else
				minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		endif;
	else
		// Check for 00:00 to 07:00.
		if fromTime &lt; OVERTIME_FINISH_2.Time then
			if toTime &lt; OVERTIME_FINISH_2.Time then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(OVERTIME_FINISH_2.Time);
			endif;
		endif;
		
		// Check for 12:00 to 13:00.
		if fromTime &gt;= OVERTIME_START.Time and fromTime &lt; OVERTIME_FINISH.Time then
			if toDateTime.date = fromDateTime.date and toTime &lt; OVERTIME_FINISH.Time then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(OVERTIME_FINISH.Time);
			endif;
		elseif fromTime &lt; OVERTIME_START.Time then
			if toDateTime.date = fromDateTime.date then
				if toTime &lt; OVERTIME_FINISH.Time and toTime &gt; OVERTIME_START.Time then 
					minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(toTime);
				elseif toTime &gt; OVERTIME_FINISH.Time then
					minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(OVERTIME_FINISH.Time);
				endif;
			else
				minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(OVERTIME_FINISH.Time);
			endif;
		endif;
		
		// Check for 16:00 to 23:59.
		if fromTime &gt;= OVERTIME_START_2.Time then
			if toDateTime.date = fromDateTime.date then
				minsDifference := minsDifference + fromTime.cnMinutesDifference(toTime);
			else
				minsDifference := minsDifference + fromTime.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		elseif fromTime &lt; OVERTIME_START_2.Time then
			if toDateTime.date = fromDateTime.date then
				if toTime &gt; OVERTIME_START_2.Time then
					minsDifference := minsDifference + OVERTIME_START_2.Time.cnMinutesDifference(toTime);
				endif;
			else
				minsDifference := minsDifference + OVERTIME_START_2.Time.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
			endif;
		endif;
	endif;
	
	// Calculate middle days.
	if toDateTime.date &lt;&gt; fromDateTime.date then
		if daysDifference &gt; 1 then
			daysDifference := daysDifference - 1;
			while daysDifference &gt; 0 do
				hasHolCalendarDay := false;
				hasRamaCalendarDay := false;
				
				holiday := calendar.getFirstCalendarDateForDay(fromDateTime.date + daysDifference);
				if holiday = null then
					holiday := calendar2.getFirstCalendarDateForDay(fromDateTime.date + daysDifference);
				endif;
				if calendar.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null 
				or calendar2.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null then
					hasHolCalendarDay := true;
				endif;
				if calendar3.getFirstCalendarDateForDay(fromDateTime.date + daysDifference) &lt;&gt; null then
					hasRamaCalendarDay := true;
				endif;
	
				if hasHolCalendarDay then
					// Holiday - whole day (or hours specified).
					minTime := holiday.startTime;
					if minTime = null then
						minTime := MINTIME.Time;
					endif;
					maxTime := holiday.endTime;
					if maxTime = null then
						maxTime := MAXTIME.Time;
					endif;
					minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime) + EXTRA_MINS;
				elseif hasRamaCalendarDay then
					minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(RAMA_OVERTIME_FINISH.Time);
					minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
				else
					// Normal day - whole overtime for that day.
					minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(OVERTIME_FINISH_2.Time);
					minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(OVERTIME_FINISH.Time);
					minsDifference := minsDifference + OVERTIME_START_2.Time.cnMinutesDifference(MAXTIME.Time) + EXTRA_MINS;
				endif;
				daysDifference := daysDifference - 1;
			endwhile;
		endif;
		
		// Check last day for holiday.
		if hasToCalendarDay then
			//Calculate holiday hours
			minTime := toDayCalendar.startTime;
			if minTime = null then
				minTime := MINTIME.Time;
			endif;
			maxTime := toDayCalendar.endTime;
			if maxTime = null then
				maxTime := MAXTIME.Time;
			endif;
			
			if toTime &lt; maxTime then
				maxTime := toTime;
			else 
				minsDifference := minsDifference + EXTRA_MINS;
			endif;
			minsDifference := minsDifference + minTime.cnMinutesDifference(maxTime);
		elseif hasRamaToCalendarDay then
			// Check for 00:00 to 07:00.
			if toTime &gt; RAMA_OVERTIME_FINISH.Time then
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(RAMA_OVERTIME_FINISH.Time);
			else
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(toTime);
			endif;
			
			// Check for 16:00 to 23:59.
			if toTime &gt; RAMA_OVERTIME_START.Time then
				minsDifference := minsDifference + RAMA_OVERTIME_START.Time.cnMinutesDifference(toTime);
			endif;
		else
			// Check for 00:00 to 07:00.
			if toTime &gt; OVERTIME_FINISH_2.Time then
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(OVERTIME_FINISH_2.Time);
			else
				minsDifference := minsDifference + MINTIME.Time.cnMinutesDifference(toTime);
			endif;
			
			// Check for 12:00 to 13:00.
			if toTime &gt;= OVERTIME_START.Time and toTime &lt; OVERTIME_FINISH.Time then
				minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(toTime);
			elseif toTime &gt; OVERTIME_FINISH.Time then
				minsDifference := minsDifference + OVERTIME_START.Time.cnMinutesDifference(OVERTIME_FINISH.Time);
			endif;
			
			// Check for 16:00 to 23:59.
			if toTime &gt; OVERTIME_START_2.Time then
				minsDifference := minsDifference + OVERTIME_START_2.Time.cnMinutesDifference(toTime);
			endif;
		endif;
	endif;
	
	// Calculate the total hours worked.
	totalHours := minsDifference / 60;
	if totalHours mod 1 &gt; 0 then
		totalHours := totalHours.Integer + 1;
	endif;
	
	// Return the total number of hours for the for all resources used.
	return _cmif.origQty * totalHours;
end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="adpUpgradeCalcHookCodeNew" id="ac6da605-9b5b-4caa-85f8-c4d225af7f03">
        <source>adpUpgradeCalcHookCodeNew();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2015	cnwmc5	Initial creation

*/

vars
	pxyCalc,
	calcType			: CM_CalculationType;
	currentRateCode,
 	currentQuantCode,
	currentRemarksCode	: String;
	newRateCode,
	newQuantCode		: String;
	
	loadState 			: Boolean;
	line 				: String;
	pos 				: Integer;
	
	realQtyRange,
	pxyQtyRange			: CM_QuantityRange;
	
begin
	
	app.initialize();
	app.myPassport.setMyUserFromCode('SUPERUSER');
	
	// Loop through all CM_CalculationType's and update the Hook Code objects 
	// to work with the new signature.
	foreach calcType in CM_CalculationType.instances do
		if calcType.myHookCodeQuantity = null and calcType.myHookCodeRate = null then
			continue;
		endif;
		
		newQuantCode := null;
		newRateCode := null;
		currentRemarksCode := calcType.myHookCodeRemarks.getCurrentJadeCode();
		
		// Update the Hook Code for Quantity
		if calcType.myHookCodeQuantity &lt;&gt; null then
			currentQuantCode := calcType.myHookCodeQuantity.getCurrentJadeCode();
			
			// Modifiy the current code
			if currentQuantCode &lt;&gt; null then
				pos := 1;
				line := currentQuantCode.cnEcGetNextLine(pos);
				newQuantCode := "amendQuantity(_cmif : CMIF_CalcTypeQuantityHook) : Real;";
				while pos &lt;&gt; 0 do
					line := currentQuantCode.cnEcGetNextLine(pos);
					line.cnReplaceString("_tran", "_cmif.myTransaction");
					line.cnReplaceString("_origQty", "_cmif.origQty");
					newQuantCode := newQuantCode &amp; CrLf &amp; line;
				endwhile;
			endif;
		endif;
		
		// Update the Hook Code for Rates
		if calcType.myHookCodeRate &lt;&gt; null then
			currentRateCode := calcType.myHookCodeRate.getCurrentJadeCode();
			
			// Modifiy the current code
			if currentRateCode &lt;&gt; null then
				pos := 1;
				line := currentRateCode.cnEcGetNextLine(pos);
				newRateCode := "amendRate(_cmif : CMIF_CalcTypeRateHook) : Real;";
				while pos &lt;&gt; 0 do
					line := currentRateCode.cnEcGetNextLine(pos);
					line.cnReplaceString("_tran", "_cmif.myTransaction");
					line.cnReplaceString("_origRate", "_cmif.origRate");
					line.cnReplaceString("_invoiceLine", "_cmif.myInvoiceLine");
					newRateCode := newRateCode &amp; CrLf &amp; line;
				endwhile;
			endif;
		endif;
		
		app.cmsBeginLoad(loadState);
		pxyCalc := calcType.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadState);
		
		foreach realQtyRange in calcType.allQuantityRanges do
			create pxyQtyRange transient;
			pxyQtyRange.setup(	realQtyRange.formula, 
								pxyCalc, 
								realQtyRange.daysIncrement, 
								realQtyRange.percentage, 
								realQtyRange.rangeStart, 
								realQtyRange.rangeEnd,
								realQtyRange.rangeType);
		endforeach;
		
		pxyCalc.setProxy(	calcType.booleanList,
							calcType.calculationType,
							calcType.code,
							calcType.description,
							calcType.hoursFree,
							calcType.hoursMax,
							calcType.hoursMin,
							calcType.hoursBlock,
							calcType.integerRange1,
							calcType.isNotAvailableForEntry,
							calcType.timeFrom,
							calcType.timeTo,
							calcType.amountMin,
							calcType.amountMax,
							calcType.theCalcTypeUnit,
							newQuantCode,
							newRateCode,
							currentRemarksCode,
							app.myPassport.getUserCode(),
							calcType.isCargoCalcType,
							calcType.isVoyageCalcType,
							calcType.isEventCalcType,
							calcType.isWorkOrderType, // TFS 39198
							calcType.myCalendarType1,
							calcType.myCalendarType2,
							calcType.myMeasurementType,
							calcType.rateType,	//22 Mar 2019	NDL	TFS 43687
							calcType.isBolCalcType,	//30 Oct 2019	NDL	TFS 47100
							false, // ### TFS 51219 25MAY2021 NAVAB1
							calcType.weightOptionToUse //02/10/2025	navkc1 JIRA 36149
							);
		
		app.myTrxUA.trxUpdateCalculationType(pxyCalc, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			// SOMETHING WENT WRONG
			write app.myPassport.getErrorsAndWarningsAsString();
			break;
		endif;
		
		delete pxyCalc;
	endforeach;
	
epilog
	delete pxyCalc;
	
	app.cmsEndLoad(loadState);
end;</source>
    </JadeMethod>
