Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssIsBetween" id="c7d52b48-3613-44ae-b2a4-502b4e8605f9">
        <source>jssIsBetween(pStartDate:Date; pEndDate:Date):Boolean;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Check to see whether the receiver is within the range of the dates
//				passed in.  A null receiver is treated as always in the range.
//
// Parameters:	pStartDate (Date) - The starting (lower range) date.
//				pEndDate (Date) - The ending (upper range) date.
//
// Returns:		True if the receiver is between the specified dates, otherwise false.
//				NOTE: False is returned if the receiver is null or not a valid date.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self = null then
		return false;
	elseif not self.isValid then
		return false;
	endif;

	if pStartDate &lt;&gt; null then
		if pStartDate &gt; self then
			return false;
		endif;
	endif;

	if pEndDate &lt;&gt; null then
		if pEndDate &lt; self then
			return false;
		endif;
	endif;

	return true;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pStartDate" type="Date"/>
        <Parameter name="pEndDate" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsInFuture" id="e2363889-46a8-44e9-9ac9-b3dba0f13751">
        <source>jssIsInFuture():Boolean;
// If given a valid date that is in the future will return true.
// If invalid date format, or date has passed, returns false.
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	testDate	: String;					// Date given
	today		: String;					// Today

begin
	// If Invalid Date or Date format, return false and break.
	
	if self.Date = null
	or not self.Date.isValid
	then
		return null;
	endif;

	testDate	:= self.format("dd-MM-yyyy");   
	today		:= app.actualTimeServer.Date.format("dd-MM-yyyy");// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	if testDate[7:4] &gt; today[7:4] then		// Year is in the future, return true and break.
		return true;
	endif;

	// Current Year and Month is in the future, return true and break.
	
	if testDate[7:4] = today[7:4]
	and testDate[4:2] &gt; today[4:2]
	then
		return true;
	endif;

	// If Current Year and Current Month and day is in the future, return true and break.
	
	if testDate[7:4] = today[7:4]
	and testDate[4:2] = today[4:2]
	and testDate[1:2] &gt; today[1:2]
	then
		return true;
	endif;

	return false;
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
reproduced, used or disclosed except upon prior written permission of Jade
Software Corporation Limited.

  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsWeekDay" id="807f4dd9-6ecc-4aa3-814c-45ffaca02d5d">
        <source>jssIsWeekDay():Boolean;
// --------------------------------------------------------------------------------
// Created:		31 August 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is a week
//				day.
//
// Parameters:	None
//
// Returns:		True if the receiver is a week day, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.dayOfWeek &gt; 5);
end;</source>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

