    <JadeMethod name="createEntry" id="e1c10868-61ed-40b6-9259-3f2d9ea692f7">
        <lockReceiver/>
        <updating/>
        <source>createEntry():JSSArrayElement updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 by cnwdad1
//
// Purpose:		Private method to create a new JSSArrayElement instance for a new
//				element in the array.
//
// Parameters:	None
// Returns:		JSSArrayObject - The newly created instance of JSSArrayElement.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayElement	: JSSArrayElement;

begin
	if self.isTransient() then
		create arrayElement transient;
	else
		create arrayElement;
	endif;
epilog
	return arrayElement;
end;</source>
        <access>protected</access>
        <ReturnType type="JSSArrayElement"/>
    </JadeMethod>
    <JadeMethod name="delete" id="180acfef-adf6-49cf-807e-55f0a9ba1ae2">
        <lockReceiver/>
        <updating/>
        <source>delete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 by cnwdad1
//
// Purpose:		Private method to purge the JSSArrayElement instances of the array.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.purge();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getBinaryAt" id="c39ab8ea-aad5-4af8-8754-2682ce1d867c">
        <source>getBinaryAt(pIndex:Integer):Binary;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 by cnwdad1
//
// Purpose:		Returns the binary value of a specified array element.
//
// Parameters:	pIndex (Integer) - The index of the array element whose value to return.
// Returns:		Binary - The binary value of the specified array element.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if pIndex &gt; self.size() then
		return null;
	else
		return self[pIndex].getBinaryValue();
	endif;
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getStringAt" id="7cb03a5a-aa29-4918-b7b1-2fb388791e33">
        <source>getStringAt(pIndex:Integer):String;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 by cnwdad1
//
// Purpose:		Returns the string value of a specified array element.
//
// Parameters:	pIndex (Integer) - The index of the array element whose value to return.
// Returns:		String - The string value of the specified array element.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if pIndex &gt; self.size() then
		return null;
	else
		return self[pIndex].getStringValue();
	endif;
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
