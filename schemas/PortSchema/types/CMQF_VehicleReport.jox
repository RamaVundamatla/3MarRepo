    <JadeMethod name="filterObjects" id="111573d7-aa05-43f4-acfb-dbd9524174f5">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
/*

Date		Who		Reason
16 Feb 2015	cnwkpd1	PAR #35697 - Use start and end dates as keys to allVehicleVisits, and don't 
					hold locks while filtering
25/05/2022  navhl20 TFS 53430  EUP - Sub Carrier registration in MTN	
*/

vars
	terminal 		: CM_Terminal;
	vv 				: CM_VehicleVisitRecord;
	tsFrom,
	tsTo			: TimeStamp;
	iter			: Iterator;
	
begin
	if self.dateFrom = null then
		//user has enter nothing for the dateFrom
		self.dateFrom := "1/1/0000".asDateJMT();
	endif;
	if self.dateTo = null then
		//user has enter nothing for the dateTo
		self.dateTo := "1/1/9999".asDateJMT();
	endif;
	
	// PAR #35697 - Set up start and end timestamps
	tsFrom := null;
	tsFrom.setDate(self.dateFrom);
	
	tsTo := null;
	tsTo.setDate(dateTo + 1);
	
	foreach terminal in self.allTerminals do
	
		// PAR #35697 - Use dictionary keys
		delete iter;
		iter := terminal.allVehicleVisits.createIterator();
		terminal.allVehicleVisits.startKeyGeq(tsFrom, iter);
		
		while iter.next(vv) do
			if vv.timeIn &gt;= tsTo then			// stop when we've passed dateTo
				break;
			endif;
			
			if not _collection.includes(vv) then
				if self.selectedGatePass &lt;&gt; Any_String then
					if vv.visitNumber &lt;&gt; self.selectedGatePass then
						continue;
					endif;
				endif;
				
				if self.selectedCarrierCode &lt;&gt; Any_String then
					if vv.carrierCode &lt;&gt; self.selectedCarrierCode then
						continue;
					endif;
				endif;
				
				//Start 25/05/2022 navhl20 TFS 53430
				if self.selectedSubCarrierCode &lt;&gt; Any_String then
					if vv.subCarrierCode &lt;&gt; self.selectedSubCarrierCode then
						continue;
					endif;
				endif;
				//End 25/05/2022 navhl20 TFS 53430 
				
				_collection.add(vv);
				
			endif;
		endwhile;
	endforeach;
	
epilog
	delete iter;
	
end;
</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f1aea149-89b3-45e0-bdfd-3fc81be07a1a">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 16 February 2009
//
// Implemented version:
// 
//----------------------------------------------------------------------
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
vars
	runDate : Date;
	oid 	: String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
/*
	runDate := app.actualTimeServer().date;
	
	if _attrName = ETRow_GatePass then
		return self.selectedGatePass;
	elseif _attrName = ETRow_CarrierCode then
		return self.selectedCarrierCode;
	elseif _attrName = ETRow_FilterDateIn then
		if _getCalculatedDate then
			//return self.dateFrom.asStringJMT();
			return self.setDateFromTemplate(self.dateFromType, self.dateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.dateFromType, self.dateFromFactor);
		endif;
	elseif _attrName = ETRow_FilterDateOut  then
		//return self.dateTo.asStringJMT();
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.dateToType, self.dateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.dateToType, self.dateToFactor);
		endif;

	endif;
	
	inheritMethod(_attrName, _getCalculatedDate);
	*/
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="bc1843cc-fb06-479f-ae07-b37897db27d8">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid : String output): String;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 16 February 2009
//
// Implemented version:
// 
//----------------------------------------------------------------------
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
//18/07/2018 	JLGNS1	Bug 39368: STWO - Report Profile Issue
//25/05/2022 navhl20 TFS 53430  EUP - Sub Carrier registration in MTN

vars
	runDate : Date;
begin
	runDate := app.actualTimeServer().Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support
	
	if _attrName = ETRow_GatePass then
		return self.selectedGatePass;
	elseif _attrName = ETRow_CarrierCode then
		return self.selectedCarrierCode;
	//Start 25/05/2022 navhl20 TFS 53430 
	elseif _attrName = ETRow_SubCarrierCode then									 
		return self.selectedSubCarrierCode;
	//End 25/05/2022 navhl20 TFS 53430 
	elseif _attrName = ETRow_FilterDateIn then
		if _getCalculatedDate then
			//return self.dateFrom.asStringJMT();
			return self.setDateFromTemplate(self.dateFromType, self.dateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.dateFromType, self.dateFromFactor);
		endif;
	elseif _attrName = ETRow_FilterDateOut  then
		//return self.dateTo.asStringJMT();
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.dateToType, self.dateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.dateToType, self.dateToFactor);
		endif;

	endif;
	
	return	inheritMethod(_attrName, _getCalculatedDate, _oid);	//	Bug 39368
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDatesForTemplateRun" id="2f3ea1df-4a53-4752-80d5-8eb62896219f">
        <updating/>
        <source>setDatesForTemplateRun(_runDate: Date) updating;

vars

begin
	inheritMethod(_runDate);
	self.dateFrom := self.setDateFromTemplate(self.dateFromType, self.dateFromFactor, _runDate);
	self.dateTo := self.setDateFromTemplate(self.dateToType, self.dateToFactor, _runDate);
end;
</source>
        <Parameter name="_runDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="efe021dd-c0e1-4013-a010-811d6b702d05">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;

vars

begin
	inheritMethod(_obj, _runDate, _allEventData);
	self.dateTo := self.setDateFromTemplate(self.dateToType, self.dateToFactor, _runDate);
	self.dateFrom := self.setDateFromTemplate(self.dateFromType, self.dateFromFactor, _runDate);
	
end;
</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
</Class>
