<Class name="SOPTM_SortingMethod" id="e3b3b284-1881-4801-969c-9c455161db8f">
    <superclass name="SOP_TableMaintItem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <JadeMethod name="create" id="b15892cc-b52f-4a91-a960-822838cb85f5">
        <updating/>
        <source>create() updating;
/*

Purpose:			Creation of the Sys Ops Item

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	self.name := SOP_TableMaintForm.Table_SortingMethod;
	self.permissionView	 := PmAdmAvailabilitygradeView;
	self.permissionMaint := PmAdmAvailabilitygradeMaint;
	self.myDataClass := CM_SortingMethod;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="e3b7de13-17b3-4171-b7ed-7f686e78cdf2">
        <updating/>
        <source>doDelete(pObj: Object io) updating;
/*

Purpose:			Deletes a sorting method

Parameters:			pObj	Object	Sorting Method to be deleted

Return Value:		NONE

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	app.myTrxDA.trxDeleteSortingMethod(pObj.CM_SortingMethod, app.myPassport);
	
end;</source>
        <Parameter name="pObj" type="Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="9e90e7c4-243e-442c-8f00-7a8ebe4e88ab">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			Saves a sorting method

Parameters:			NONE

Return Value:		Boolean	Representing whether it suceeded or failed

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

vars
	theForm				: SOP_TableMaintForm;
	tbl					: CM_EntryTable;
	pxySortingMethod	: CM_SortingMethod;
	
begin
	theForm := self.myForm;
	tbl 	:= theForm.tblInput1;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_SortingMethod transient;
		endif;
		if theForm.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	pxySortingMethod := theForm.myProxyObject.CM_SortingMethod;
	pxySortingMethod.setProxy(tbl.getValueByName(ETRow_Code).String,
						tbl.getValueByName(ETRow_Description).String,
						tbl.getValueByName(ETRow_IsNotAvailableForEntry).Boolean
						);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateSortingMethod(pxySortingMethod, theForm.myCurrentObject, app.myPassport);
	else
		app.myTrxUA.trxUpdateSortingMethod(pxySortingMethod, app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="95c755fc-6caa-46ff-89ff-6c1b3b68eda0">
        <source>getCollection(): Collection;
/*

Purpose:			Gets the collection to be used by the table

Parameters:			NONE

Return Value:		Collection	The collection to be returned

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	return app.myRoot.allSortingMethods;
	
end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getEntTableDef" id="8be29068-2f52-44d2-b165-074e1b82c3c4">
        <source>getEntTableDef(): String;
/*

Purpose:			Gets the Ent Table definition to be used by the table

Parameters:			NONE

Return Value:		String	Represents which Ent Table Definition to use

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	return ETDef_SortingMethodMaintTbl;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="f8e15cc4-5bd8-45e4-88b3-fba5e8afc7de">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
/*

Purpose:			Determines whether or not the object should be included in the table

Parameters:			_obj		Object		The obejct to check and verify
					_passport	CM_Passport	The passport to use whenm checking

Return Value:		Boolean	Represents whether or not the object should be shown

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_SortingMethod.isNotAvailableForEntry;
	endif;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isNotAvailableForEntryUsed" id="ea278266-4508-4e6d-bef3-4b752643428c">
        <source>isNotAvailableForEntryUsed(): Boolean;
/*

Purpose:			Determines whether isNotAvaiabaleForEntry should be used on this item

Parameters:			NONE

Return Value:		Boolean	Represents that isNotAvaiabaleForEntry should be used on this item

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSystemItem" id="ee176e6a-0a53-4808-908f-89115369d22e">
        <source>isSystemItem(): Boolean;
/*

Purpose:			Determines whether this item is a system item or terminal item

Parameters:			NONE

Return Value:		Boolean	Represents that this item is a system level item

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

begin
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="91cb6e36-41b0-4521-b590-a3f3d170f084">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			Sets the controls for Add and Edit Mode on the form

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
07 June 2023	navpw1	Initial creation TFS: 57813 (58438)

*/

vars
	theForm 	: SOP_TableMaintForm;
	entTableRow	: EntTableRow;
	entTableDef	: EntTableDef;
	
begin
	theForm		:= self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	entTableDef	:= app.myController.getEntTableDef(ETDef_SortingMethodMaintTbl);
	
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.enableRowByName(entTableRow.name);
	endforeach;
	
	if theForm.mode = theForm.Mode_Add then 
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
	else
		self.showThumbnail(theForm.myCurrentObject.CM_SortingMethod);
	endif;
    theForm.tblInput1.cnEcResizeContents;
	
end;</source>
    </JadeMethod>
</Class>
