    </JadeMethod>
    <JadeMethod name="jadeSkinUnload" id="3252edbc-1445-4f00-9752-c1836052e48c">
        <source>jadeSkinUnload();
// ---------------------------------------------------------------------------
// Created:     08 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	js	: JadeSkin;
	f	: File;
	dir	: String;
	propCol	: PropertyColl;
	prop	: Property;
	jadeSkinsColl	:  JadeSkinsColl;
	skinName		: String;
begin

	skinName := 'PortTecBlue';
	dir := 'c:\temp\c_temp\PortTecBlue';

	jadeSkinsColl := app.getSkinCollection();
	
	foreach js in jadeSkinsColl do
		if js.name = skinName then
			break;
		endif;
	endforeach;
	
	if js = null or js.name &lt;&gt; skinName then
		app.writeStatement( 'JadeSkin is null or not found');
		return;
	endif;
	
	create f transient;
	f.mode := File.Mode_Output;
	f.kind := File.Kind_Binary;
	
	propCol := JadeSkin.allProperties();
	
	foreach prop in propCol do
		if prop.name[1:3] = 'img' then
			f.fileName := dir &amp; '\' &amp; prop.name &amp; '.png';
	
			f.open; 
	 
			f.writeBinary(js.getPropertyValue(prop.name).Binary);
	
			f.close;
		endif;
	endforeach;
	
epilog
	delete f;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="jreCheckEntTables" id="1466a6cb-754a-4768-b69e-1dfcfa20d2eb">
        <source>jreCheckEntTables();
// 
vars
	tabName	: String;
	entDef: EntTableDef;
begin
	app.initialize();
	app.createMyController(CMUI_Controller);

	tabName := "ReceiveData";
	entDef := app.myController.getEntTableDef(tabName);
	write tabName &amp; " " &amp; entDef.myEntTableGroup.name;
	tabName := "DefaultCargoEnt";
	entDef := app.myController.getEntTableDef(tabName);
	write tabName &amp; " " &amp; entDef.myEntTableGroup.name;
	tabName := "TimberCargoEnt";
	entDef := app.myController.getEntTableDef(tabName);
	write tabName &amp; " " &amp; entDef.myEntTableGroup.name;
	tabName := "TrailorData";
	entDef := app.myController.getEntTableDef(tabName);
	write tabName &amp; " " &amp; entDef.myEntTableGroup.name;
	tabName := "BreakBulkEnt";
	entDef := app.myController.getEntTableDef(tabName);
	write tabName &amp; " " &amp; entDef.myEntTableGroup.name;

end;
</source>
    </JadeMethod>
    <JadeMethod name="lnxReport" id="c05f7a40-ada8-42d0-b855-4bf09c37ba91">
        <updating/>
        <source>lnxReport()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/03/2017	cnwma1	Initial creation
22/11/2017	jlgdap1	TFS 7948 LNX Activity report showing wrong volume
*/
vars
	dyna : DynaDictionary;
	voyActivity,oldActivity,tt : CMIF_VoyageActivity;
	tit : CM_TITransaction;
	jobSheet :CM_VoyageJobSheet;
	delay : CM_Delay;
	event : CM_EventTransaction;
	objArr,groupedArr : CMIF_VoyageActivityArray;
	wPoint :String;
	oldQty :Integer;
		oldWt :Decimal [14,4];
	oldVol: Decimal [16,4];
	oldType,
	oldName,
	oldJob,
	oldCargoType,
	oldCrane : String;
	voy : CM_Voyage;
	                lFile        : File;
begin 
	voy := "4480.623".asOid.CM_Voyage;
	create dyna transient;
	dyna.setMembership(CMIF_VoyageActivity);  
	dyna.addMemberKey(CMIF_VoyageActivity::dateTime.name, true, true);   // activityDate
	dyna.addMemberKey(CMIF_VoyageActivity::activityType.name,false,true);  
	dyna.endKeys(true);
	
	foreach jobSheet in voy.allJobSheetsInOrder do
		if jobSheet &lt;&gt; null then
			foreach tit in jobSheet.allShipReceivals do 
				create  voyActivity transient;
				voyActivity.dateTime :=tit.dateTime;
				voyActivity.qty :=tit.totalQuantity;
				//voyActivity.volume :=tit.totalVolume;											// TFS 7948
				if tit.myTrackedItem &lt;&gt; null and tit.myTrackedItem.getDensity &lt;&gt; null then		// TFS 7948
					voyActivity.volume := tit.totalWeight / tit.myTrackedItem.getDensity;		// TFS 7948
				else																			// TFS 7948
					voyActivity.volume :=tit.totalVolume;										// TFS 7948
				endif;																			// TFS 7948
				voyActivity.weight :=tit.totalWeight;
				voyActivity.activityType :="Transaction";
				voyActivity.activityName := "Discharge";
				if tit.CM_ReceiveShip.getJob &lt;&gt; null then
					voyActivity.jobId:=tit.CM_ReceiveShip.getJob.id;
					voyActivity.myJob :=tit.CM_ReceiveShip.getJob.CM_VoyageJob;
				endif;
				if tit.CM_ReceiveShip.getCrane &lt;&gt; null then
					voyActivity.craneId :=tit.CM_ReceiveShip.getCrane.id;
				endif;
				voyActivity.cargoType :=tit.myTrackedItem.cargoTypeDescr;
				if jobSheet.myWorkPoint &lt;&gt; null then
					wPoint := jobSheet.myWorkPoint.code;
					voyActivity.workPointId := wPoint;
				endif;
				voyActivity.shiftCode := tit.CM_ReceiveShip.shiftCode;
				voyActivity.shiftStart := tit.CM_ReceiveShip.shiftStart;
				voyActivity.shiftEnd := tit.CM_ReceiveShip.shiftEnd;
				voyActivity.userCode := tit.userId;
				dyna.add(voyActivity);
			endforeach;
		endif;
	endforeach;
	
	foreach jobSheet in voy.allJobSheetsInOrder do
		if jobSheet &lt;&gt; null then
			foreach tit in jobSheet.allShipReleases do 
				create  voyActivity transient;
				voyActivity.dateTime :=tit.dateTime;
				voyActivity.qty :=tit.totalQuantity;
				//voyActivity.volume :=tit.totalVolume;											// TFS 7948
				if tit.myTrackedItem &lt;&gt; null and tit.myTrackedItem.getDensity &lt;&gt; null then		// TFS 7948
					voyActivity.volume := tit.totalWeight / tit.myTrackedItem.getDensity;		// TFS 7948
				else																			// TFS 7948
					voyActivity.volume :=tit.totalVolume;										// TFS 7948
				endif;																			// TFS 7948
				voyActivity.weight :=tit.totalWeight;
				voyActivity.activityType :="Transaction";
				voyActivity.activityName := "Load";
				if tit.CM_ReleaseShip.getJob &lt;&gt; null then
					voyActivity.jobId:=tit.CM_ReleaseShip.getJob.id;
					voyActivity.myJob :=tit.CM_ReleaseShip.getJob.CM_VoyageJob;
				endif;
				if tit.CM_ReleaseShip.getCrane &lt;&gt; null then
					voyActivity.craneId :=tit.CM_ReleaseShip.getCrane.id;
				endif;
				voyActivity.cargoType :=tit.myTrackedItem.cargoTypeDescr;
				if jobSheet.myWorkPoint &lt;&gt; null then
					wPoint := jobSheet.myWorkPoint.code;
					voyActivity.workPointId := wPoint;
				endif;
				voyActivity.shiftCode := tit.CM_ReleaseShip.shiftCode;
				voyActivity.shiftStart := tit.CM_ReleaseShip.shiftStart;
				voyActivity.shiftEnd := tit.CM_ReleaseShip.shiftEnd;
				voyActivity.userCode := tit.userId;
				dyna.add(voyActivity);
			endforeach;
		endif;
	endforeach;
	
	foreach event in voy.allEventTransactionsByDateTime do
		if event  &lt;&gt; null   then
			create  voyActivity transient;
			
			voyActivity.activityType :="Event";
			voyActivity.activityName := event.myEventType.name;
			voyActivity.eventAmount := event.amount;
			
			if event.isKindOf(CMEVT_VoyageEvent) then
				voyActivity.remarks :=event.CMEVT_VoyageEvent.remarks;
				if event.CMEVT_VoyageEvent.shiftCode &lt;&gt; null then
					voyActivity.dateTime := event.CMEVT_VoyageEvent.shiftStart;
					voyActivity.shiftStart := event.CMEVT_VoyageEvent.shiftStart;
					voyActivity.shiftEnd := event.CMEVT_VoyageEvent.shiftEnd;
					voyActivity.shiftCode := event.CMEVT_VoyageEvent.shiftCode;
				else
					voyActivity.dateTime :=event.dateTime;
				endif;
			else
				voyActivity.dateTime :=event.dateTime;
			endif;
			voyActivity.userCode := event.userCode;
			if event.myEventType &lt;&gt; null then
				voyActivity.myEventType := event.myEventType;
			endif;
			dyna.add(voyActivity);
		endif;
	endforeach;
	
	foreach delay in voy.allDelays do
		create  voyActivity transient;
		if delay &lt;&gt; null then
			if delay.myWorkPoint &lt;&gt; null then
				wPoint := delay.myWorkPoint.code;
				voyActivity.workPointId := wPoint;
			endif;
			voyActivity.dateTime :=delay.startDT;
			voyActivity.activityType :="Delay";
			voyActivity.activityName := delay.myDelayType.description;
			voyActivity.remarks :=delay.remarks;
			if delay.myEventStart &lt;&gt; null then
				voyActivity.userCode := delay.myEventStart.userCode;
			endif;
			dyna.add(voyActivity);
		endif;
		
	endforeach;
	
	
	create objArr transient;
	create groupedArr transient;
	dyna.copy(objArr);
	
	foreach voyActivity in objArr do
		if voyActivity.activityType ="Transaction" then
			if oldJob = voyActivity.jobId 
				and oldCrane = voyActivity.craneId 
				and oldName = voyActivity.activityName 
				and oldType = voyActivity.activityType 
				and oldCargoType = voyActivity.cargoType then
				oldQty :=0;
				oldWt := 0;
				oldVol := 0;
				oldQty:=oldActivity.qty;
				oldWt := oldActivity.weight;
				oldVol := oldActivity.volume;
				voyActivity.dateTime :=oldActivity.dateTime;
				voyActivity.qty :=  oldQty+ voyActivity.qty;
				voyActivity.weight :=  oldWt+ voyActivity.weight;
				voyActivity.volume :=  oldVol+ voyActivity.volume;
				groupedArr.remove(oldActivity);
			endif;
			groupedArr.add(voyActivity);
		else
			groupedArr.add(voyActivity);
		endif;
			oldType := voyActivity.activityType;
			oldName := voyActivity.activityName;
			oldCrane := voyActivity.craneId;
			oldJob := voyActivity.jobId;
			oldActivity := voyActivity;
			oldCargoType := voyActivity.cargoType;
			
	endforeach;
	     create lFile transient;
    lFile.fileName := "C:\TEMP\LNX283.csv";
    lFile.open;

	foreach  tt in groupedArr do 
	lFile.writeLine( tt.activityType &amp;","&amp; tt.activityName &amp; "," &amp; tt.dateTime.asStringJMT &amp; "," &amp; tt.cargoType &amp; "," &amp;tt.qty.asStringJMT &amp; "," &amp;tt.jobId&amp; "," &amp;tt.craneId &amp;"," &amp;tt.weight.asStringJMT
					&amp;","&amp; tt.shiftCode &amp;","&amp; tt.shiftStart.asStringJMT&amp;","&amp;tt.shiftEnd.asStringJMT &amp;","&amp; tt.remarks);
	endforeach;
	   lFile.close;
    delete lFile;

epilog
delete objArr;
delete dyna;

end;
	</source>
    </JadeMethod>
    <JadeMethod name="lnxReport2" id="61c43464-1b83-4ce9-8bd2-22623ba5c6f0">
        <source>lnxReport2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/03/2017	cnwma1	Initial creation
22/11/2017	jlgdap1	TFS 7948 LNX Activity report showing wrong volume
*/


vars
	dyna : DynaDictionary;
	voyActivity,oldActivity,tt : CMIF_VoyageActivity;
	tit : CM_TITransaction;
	jobSheet :CM_VoyageJobSheet;
	delay : CM_Delay;
	event : CM_EventTransaction;
	objArr,groupedArr : CMIF_VoyageActivityArray;
	wPoint :String;
	oldQty :Integer;
	oldWt :Decimal [14,4];
	oldVol: Decimal [16,4];
	oldType,
	oldName,
	oldJob,
	oldCargoType,
	oldCrane : String;
	voy : CM_Voyage;
	                lFile        : File;
begin 
	voy := "4480.863645".asOid.CM_Voyage;
	create dyna transient;
	dyna.setMembership(CMIF_VoyageActivity);  
	dyna.addMemberKey(CMIF_VoyageActivity::dateTime.name, true, true);   // activityDate
	dyna.addMemberKey(CMIF_VoyageActivity::activityType.name,false,true);  
	dyna.endKeys(true);
	
	foreach jobSheet in voy.allJobSheetsInOrder do
		if jobSheet &lt;&gt; null then
			foreach tit in jobSheet.allShipReceivals do 
				create  voyActivity transient;
				voyActivity.dateTime :=tit.dateTime;
				voyActivity.qty :=tit.totalQuantity;
				//voyActivity.volume :=tit.totalVolume;											// TFS 7948
				if tit.myTrackedItem &lt;&gt; null and tit.myTrackedItem.getDensity &lt;&gt; null then		// TFS 7948
					voyActivity.volume := tit.totalWeight / tit.myTrackedItem.getDensity;		// TFS 7948
				else																			// TFS 7948
					voyActivity.volume :=tit.totalVolume;										// TFS 7948
				endif;																			// TFS 7948
				voyActivity.weight :=tit.totalWeight;
				voyActivity.activityType :="Transaction";
				voyActivity.activityName := "Discharge";
				if tit.CM_ReceiveShip.getJob &lt;&gt; null then
					voyActivity.jobId:=tit.CM_ReceiveShip.getJob.id;
					if tit.CM_ReceiveShip.getJob &lt;&gt; null then
						voyActivity.myJob :=tit.CM_ReceiveShip.getJob.CM_VoyageJob;
					endif;
				endif;
				if tit.CM_ReceiveShip.getCrane &lt;&gt; null then
					voyActivity.craneId :=tit.CM_ReceiveShip.getCrane.id;
				endif;
				voyActivity.cargoType :=tit.myTrackedItem.cargoTypeDescr;
				if jobSheet.myWorkPoint &lt;&gt; null then
					wPoint := jobSheet.myWorkPoint.code;
					voyActivity.workPointId := wPoint;
				endif;
				
				dyna.add(voyActivity);
			endforeach;
		endif;
	endforeach;
	
	foreach jobSheet in voy.allJobSheetsInOrder do
		if jobSheet &lt;&gt; null then
			foreach tit in jobSheet.allShipReleases do 
				create  voyActivity transient;
				voyActivity.dateTime :=tit.dateTime;
				voyActivity.qty :=tit.totalQuantity;
				//voyActivity.volume :=tit.totalVolume;											// TFS 7948
				if tit.myTrackedItem &lt;&gt; null and tit.myTrackedItem.getDensity &lt;&gt; null then		// TFS 7948
					voyActivity.volume := tit.totalWeight / tit.myTrackedItem.getDensity;		// TFS 7948
				else																			// TFS 7948
					voyActivity.volume :=tit.totalVolume;										// TFS 7948
				endif;																			// TFS 7948
				voyActivity.weight :=tit.totalWeight;
				voyActivity.activityType :="Transaction";
				voyActivity.activityName := "Load";
				if tit.CM_ReleaseShip.getJob &lt;&gt; null then
					voyActivity.jobId:=tit.CM_ReleaseShip.getJob.id;
					voyActivity.myJob :=tit.CM_ReleaseShip.getJob.CM_VoyageJob;
				endif;
				if tit.CM_ReleaseShip.getCrane &lt;&gt; null then
					voyActivity.craneId :=tit.CM_ReleaseShip.getCrane.id;
				endif;
				voyActivity.cargoType :=tit.myTrackedItem.cargoTypeDescr;
				if jobSheet.myWorkPoint &lt;&gt; null then
					wPoint := jobSheet.myWorkPoint.code;
					voyActivity.workPointId := wPoint;
				endif;
				dyna.add(voyActivity);
			endforeach;
		endif;
	endforeach;
	
	foreach event in voy.allEventTransactionsByDateTime do
		if event  &lt;&gt; null   then
			create  voyActivity transient;
			voyActivity.dateTime :=event.dateTime;
			voyActivity.activityType :="Event";
			voyActivity.activityName := event.myEventType.name;
			dyna.add(voyActivity);
		endif;
	endforeach;
	
	foreach delay in voy.allDelays do
		create  voyActivity transient;
		if delay &lt;&gt; null then
			if delay.myWorkPoint &lt;&gt; null then
				wPoint := delay.myWorkPoint.code;
				voyActivity.workPointId := wPoint;
			endif;
			voyActivity.dateTime :=delay.startDT;
			voyActivity.activityType :="Delay";
			voyActivity.activityName := delay.myDelayType.description;
			
			dyna.add(voyActivity);
		endif;
		
	endforeach;
	
	
	create objArr transient;
	create groupedArr transient;
	dyna.copy(objArr);
	
	foreach voyActivity in objArr do
		if voyActivity.activityType ="Transaction" then
		
			if oldJob = voyActivity.jobId 
				and oldCrane = voyActivity.craneId 
				and oldName = voyActivity.activityName 
				and oldType = voyActivity.activityType 
				and oldCargoType = voyActivity.cargoType then
				oldQty :=0;
				oldQty:=oldActivity.qty;
				voyActivity.qty :=  oldQty+ voyActivity.qty;
				groupedArr.remove(oldActivity);
			endif;
			groupedArr.add(voyActivity);
		else
			groupedArr.add(voyActivity);
		endif;
			oldType := voyActivity.activityType;
			oldName := voyActivity.activityName;
			oldCrane := voyActivity.craneId;
			oldJob := voyActivity.jobId;
			oldActivity := voyActivity;
			oldCargoType := voyActivity.cargoType;
			
	endforeach;
	     create lFile transient;
    lFile.fileName := "C:\TEMP\LNX.csv";
    lFile.open;

	foreach  tt in groupedArr do 
 write	tt.activityType &amp;Tab&amp; tt.activityName &amp; Tab &amp; tt.dateTime.asStringJMT &amp; Tab &amp; tt.cargoType &amp; Tab &amp;tt.qty.asStringJMT &amp; Tab &amp;tt.jobId&amp; Tab &amp;tt.craneId;
	endforeach;
	   lFile.close;
    delete lFile;

epilog
delete objArr;
delete dyna;

end;
	
	</source>
    </JadeMethod>
    <JadeMethod name="lnxReport3" id="b8ea329e-6ad3-4fde-888b-a166bea1764d">
        <source>lnxReport3();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/04/2017	cnwma1	Initial creation
22/11/2017	jlgdap1	TFS 7948 KNX Activity report showing wrong volume
*/


vars
	dyna : DynaDictionary;
	voyActivity,oldActivity ,lastAct,oldLast,tt: CMIF_VoyageActivity;
	tit : CM_TITransaction;
	jobSheet :CM_VoyageJobSheet;
	delay : CM_Delay;
	event : CM_EventTransaction;
	objArr,groupedArr ,lastGroupedArr: CMIF_VoyageActivityArray;
	wPoint :String;
	oldQty :Integer;
	oldWt :Decimal [14,4];
	oldVol: Decimal [16,4];
	oldType,
	oldName,
	oldJob,
	oldCargoType,
	oldProduct,
	oldCommodity,
	oldCrane : String;
	oldDateTime,transStartTime : TimeStamp;
	voy : CM_Voyage;
    lFile        : File;
	oldEvent : CM_EventTransaction;	
begin 
//	voy := "4480.127".asOid.CM_Voyage;
	voy := "4480.2099".asOid.CM_Voyage;
	create dyna transient;
	dyna.setMembership(CMIF_VoyageActivity);  
	dyna.addMemberKey(CMIF_VoyageActivity::dateTime.name, false, true);   // activityDate
	dyna.addMemberKey(CMIF_VoyageActivity::activityType.name,false,true);  
	dyna.endKeys(true);
	
	foreach jobSheet in voy.allJobSheetsInOrder do
		if jobSheet &lt;&gt; null then
			foreach tit in jobSheet.allShipReceivals do 
				create  voyActivity transient;
				voyActivity.dateTime :=tit.dateTime;
				voyActivity.qty :=tit.totalQuantity;
				//voyActivity.volume :=tit.totalVolume;											// TFS 7948
				if tit.myTrackedItem &lt;&gt; null and tit.myTrackedItem.getDensity &lt;&gt; null then		// TFS 7948
					voyActivity.volume := tit.totalWeight / tit.myTrackedItem.getDensity;		// TFS 7948
				else																			// TFS 7948
					voyActivity.volume :=tit.totalVolume;										// TFS 7948
				endif;																			// TFS 7948
				voyActivity.weight :=tit.totalWeight;
				voyActivity.activityType :="Transaction";
				voyActivity.activityName := "Discharge";

				if tit.CM_ReceiveShip.myTrackedItem &lt;&gt; null then
					voyActivity.cargoType :=tit.CM_ReceiveShip.myTrackedItem.cargoTypeDescr;
					voyActivity.commodity := tit.CM_ReceiveShip.myTrackedItem.commodity;
					if tit.CM_ReceiveShip.myTrackedItem.myProduct &lt;&gt; null then
						voyActivity.product :=tit.CM_ReceiveShip.myTrackedItem.myProduct.description;
					endif;
				endif;
				
				if tit.CM_ReceiveShip.getJob &lt;&gt; null then
					voyActivity.jobId:=tit.CM_ReceiveShip.getJob.id;
					voyActivity.myJob :=tit.CM_ReceiveShip.getJob.CM_VoyageJob;
				endif;
				if tit.CM_ReceiveShip.getCrane &lt;&gt; null then
					voyActivity.craneId :=tit.CM_ReceiveShip.getCrane.id;
				endif;
				if jobSheet.myWorkPoint &lt;&gt; null then
					wPoint := jobSheet.myWorkPoint.code;
					voyActivity.workPointId := wPoint;
				endif;
				voyActivity.shiftCode := tit.CM_ReceiveShip.shiftCode;
				voyActivity.shiftStart := tit.CM_ReceiveShip.shiftStart;
				//voyActivity.shiftEnd := tit.CM_ReceiveShip.shiftEnd;
				voyActivity.shiftEnd := tit.CM_ReceiveShip.dateTime;
				voyActivity.userCode := tit.userId;
				dyna.add(voyActivity);
			endforeach;
		endif;
	endforeach;
	
	foreach jobSheet in voy.allJobSheetsInOrder do
		if jobSheet &lt;&gt; null then
			foreach tit in jobSheet.allShipReleases do 
				create  voyActivity transient;
				voyActivity.dateTime :=tit.dateTime;
				voyActivity.qty :=tit.totalQuantity;
				//voyActivity.volume :=tit.totalVolume;											// TFS 7948
				if tit.myTrackedItem &lt;&gt; null and tit.myTrackedItem.getDensity &lt;&gt; null then		// TFS 7948
					voyActivity.volume := tit.totalWeight / tit.myTrackedItem.getDensity;		// TFS 7948
				else																			// TFS 7948
					voyActivity.volume :=tit.totalVolume;										// TFS 7948
				endif;																			// TFS 7948
				voyActivity.weight :=tit.totalWeight;
				voyActivity.activityType :="Transaction";
				voyActivity.activityName := "Load";
				
				if tit.CM_ReleaseShip.myTrackedItem &lt;&gt; null then
					voyActivity.cargoType :=tit.CM_ReleaseShip.myTrackedItem.cargoTypeDescr;
					voyActivity.commodity := tit.CM_ReleaseShip.myTrackedItem.commodity;
					if tit.CM_ReleaseShip.myTrackedItem.myProduct &lt;&gt; null then
						voyActivity.product :=tit.CM_ReleaseShip.myTrackedItem.myProduct.description;
					endif;
				endif;
				
				if tit.CM_ReleaseShip.getJob &lt;&gt; null then
					voyActivity.jobId:=tit.CM_ReleaseShip.getJob.id;
					voyActivity.myJob :=tit.CM_ReleaseShip.getJob.CM_VoyageJob;
				endif;
				if tit.CM_ReleaseShip.getCrane &lt;&gt; null then
					voyActivity.craneId :=tit.CM_ReleaseShip.getCrane.id;
				endif;

				if jobSheet.myWorkPoint &lt;&gt; null then
					wPoint := jobSheet.myWorkPoint.code;
					voyActivity.workPointId := wPoint;
				endif;
				voyActivity.shiftCode := tit.CM_ReleaseShip.shiftCode;
				voyActivity.shiftStart := tit.CM_ReleaseShip.shiftStart;
				//voyActivity.shiftEnd := tit.CM_ReceiveShip.shiftEnd;
				voyActivity.shiftEnd := tit.CM_ReleaseShip.dateTime;
				voyActivity.userCode := tit.userId;
				dyna.add(voyActivity);
			endforeach;
		endif;
	endforeach;
	

		foreach event in voy.allEventTransactionsByDateTime do
		if event  &lt;&gt; null   then
			create  voyActivity transient;
			
			voyActivity.activityType :="Event";
			voyActivity.activityName := event.myEventType.name;
			voyActivity.eventAmount := event.amount;
			voyActivity.dateTime :=event.dateTime;
			voyActivity.userCode := event.userCode;
			if event.isKindOf(CMEVT_VoyageEvent) then
				voyActivity.remarks	   := event.CMEVT_VoyageEvent.remarks;
				voyActivity.shiftStart := event.CMEVT_VoyageEvent.dateTime;
				voyActivity.shiftEnd   := event.CMEVT_VoyageEvent.dateTimeEnd;
				voyActivity.shiftCode  := event.CMEVT_VoyageEvent.shiftCode;
				if event.CMEVT_VoyageEvent.myJobSheet &lt;&gt; null then //26/04/2017 cnwma1
					if event.CMEVT_VoyageEvent.myJobSheet.myWorkPoint &lt;&gt; null then
						voyActivity.workPointId :=event.CMEVT_VoyageEvent.myJobSheet.myWorkPoint.code;
					endif;
				endif;
				if event.CMEVT_VoyageEvent.myJob &lt;&gt; null then
					voyActivity.myJob := event.CMEVT_VoyageEvent.myJob;
					voyActivity.jobId := event.CMEVT_VoyageEvent.myJob.id;
				endif;
			endif;
			if event.myEventType &lt;&gt; null then
				voyActivity.myEventType := event.myEventType;
			endif;
			dyna.add(voyActivity);
		endif;
	endforeach;
	
	foreach delay in voy.allDelays do
		create  voyActivity transient;
		if delay &lt;&gt; null then
			if delay.myWorkPoint &lt;&gt; null then
				wPoint := delay.myWorkPoint.code;
				voyActivity.workPointId := wPoint;
			endif;
			voyActivity.dateTime :=delay.startDT;
			voyActivity.activityType :="Delay";
			voyActivity.activityName := delay.myDelayType.description;
			voyActivity.remarks :=delay.remarks;
			if delay.myEventStart &lt;&gt; null then
				voyActivity.userCode := delay.myEventStart.userCode;
			endif;
			dyna.add(voyActivity);
		endif;
		
	endforeach;
	
	
	create objArr transient;
	create groupedArr transient;
	dyna.copy(objArr);
	
	//Grouping transactions together
	foreach voyActivity in objArr do
		if voyActivity.activityType ="Transaction" then
			if oldJob = voyActivity.jobId 
				and oldCrane = voyActivity.craneId 
				and oldName = voyActivity.activityName 
				and oldType = voyActivity.activityType 
				and oldCargoType = voyActivity.cargoType
				and oldProduct = voyActivity.product
				and oldCommodity = voyActivity.commodity then
				oldQty :=0;
				oldWt := 0;
				oldVol := 0;
				oldQty:=oldActivity.qty;
				oldWt := oldActivity.weight;
				oldVol := oldActivity.volume;
				voyActivity.dateTime :=oldActivity.dateTime;
				voyActivity.qty :=  oldQty+ voyActivity.qty;
				voyActivity.weight :=  oldWt+ voyActivity.weight;
				voyActivity.volume :=  oldVol+ voyActivity.volume;
				
				groupedArr.remove(oldActivity);
			endif;

			groupedArr.add(voyActivity);
		else
			
			groupedArr.add(voyActivity);
			
		endif;
			oldType := voyActivity.activityType;
			oldName := voyActivity.activityName;
			oldCrane := voyActivity.craneId;
			oldJob := voyActivity.jobId;
			oldActivity := voyActivity;
			oldCargoType := voyActivity.cargoType;
			oldProduct := voyActivity.product;
			oldCommodity := voyActivity.commodity;
			
	endforeach;
	/*
	create lastAct transient;
	create lastGroupedArr transient;
	
	foreach lastAct in groupedArr reversed do
	if voyActivity.activityType ="Transaction" then
	
			if transStartTime.isValid then
				lastAct.shiftStart := transStartTime;
				//lastAct.shiftEnd :=oldActivity.dateTime;
				transStartTime := null;
			endif;
			lastGroupedArr.add(lastAct);
	else
	
				
		if lastAct.activityType ="Event" then
			if lastAct.shiftEnd.isValid &lt;&gt; null then
				oldLast := lastAct;
				transStartTime := oldLast.shiftEnd;
			endif;
		endif;
	
	endif;
	
	
	endforeach;*/
	create lFile transient;
    lFile.fileName := "C:\TEMP\PEL51118.csv";
    lFile.open;
	lFile.writeLine("Shift Code" &amp;","&amp; "WorkPoint" &amp;","&amp; "Gang" &amp;","&amp; "Activity" &amp;","&amp; "ActivityType" &amp;","&amp; "ActivityTime" &amp;","&amp; "CMD" &amp;","&amp; "CargoType" &amp;","&amp; "CargoSub" &amp;","&amp; "Qty" &amp;","&amp; "Weight" &amp;","&amp; "Vol" &amp;","&amp; "ActivityStart" &amp;","&amp; "ActivityEnd");
	foreach  tt in groupedArr reversed do 

	lFile.writeLine( tt.shiftCode &amp;","&amp; tt.workPointId  &amp;","&amp; tt.jobId &amp;","&amp; tt.activityName &amp;","&amp; tt.activityType &amp;","&amp; tt.dateTime.asStringJMT &amp;","&amp; tt.commodity &amp;","&amp; tt.cargoType &amp;","&amp; tt.product &amp;","&amp; tt.qty.asStringJMT &amp;","&amp; tt.weight.asStringJMT  &amp;","&amp; tt.volume.asStringJMT &amp;","&amp; tt.shiftStart.asStringJMT &amp;","&amp;  tt.shiftEnd.asStringJMT );  

	endforeach;
	   lFile.close;
    delete lFile;
epilog
delete objArr;
delete dyna;
delete lastAct;

end;
	</source>
    </JadeMethod>
    <JadeMethod name="lnxReport3517" id="55f29492-f3ec-4f11-b0ef-65b09e526083">
        <source>lnxReport3517();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/05/2017	cnwma1	Initial creation
22/11/2017	jlgdap1	TFS 7948 LNX Activity report showing wrong volume
*/



vars
	dyna : DynaDictionary;
	voyActivity,oldActivity,tt : CMIF_VoyageActivity;
	tit : CM_TITransaction;
	jobSheet :CM_VoyageJobSheet;
	delay : CM_Delay;
	event : CM_EventTransaction;
	objArr,groupedArr : CMIF_VoyageActivityArray;
	wPoint :String;
	oldQty :Integer;
	oldWt :Decimal [14,4];
	oldVol: Decimal [16,4];
	oldType,
	oldName,
	oldJob,
	oldCargoType,
	oldProduct,
	oldCommodity,
	oldCrane : String;
	jobIds : StringArray;
	jobId : String;
	lastActivity,oldLastActivity : CMIF_VoyageActivity;
	lastGroupedArr : CMIF_VoyageActivityArray;
	eventLastEndTime : TimeStamp;
	voy : CM_Voyage;
	lFile        : File;
	transLastEndTime: TimeStamp;
	oldLastTransActivity : CMIF_VoyageActivity;
begin 
//	voy := "4480.623".asOid.CM_Voyage;
	voy := "4480.2179".asOid.CM_Voyage;
create dyna transient;
	dyna.setMembership(CMIF_VoyageActivity);  
	dyna.addMemberKey(CMIF_VoyageActivity::dateTime.name, true, true);   // activityDate
	dyna.addMemberKey(CMIF_VoyageActivity::activityType.name,false,true);  
	dyna.endKeys(true);
	
	foreach jobSheet in voy.allJobSheetsInOrder do
		if jobSheet &lt;&gt; null then
			foreach tit in jobSheet.allShipReceivals do 
				create  voyActivity transient;
				voyActivity.myTerminal := voy.myTerminal;   //05/05/2017 cnwma1 TFS #4346
				voyActivity.dateTime :=tit.dateTime;
				voyActivity.qty :=tit.totalQuantity;
				//voyActivity.volume :=tit.totalVolume;											// TFS 7948
				if tit.myTrackedItem &lt;&gt; null and tit.myTrackedItem.getDensity &lt;&gt; null then		// TFS 7948
					voyActivity.volume := tit.totalWeight / tit.myTrackedItem.getDensity;		// TFS 7948
				else																			// TFS 7948
					voyActivity.volume :=tit.totalVolume;										// TFS 7948
				endif;																			// TFS 7948
				voyActivity.weight :=tit.totalWeight;
				voyActivity.activityType :="Transaction";
				voyActivity.activityName := "Discharge";
				voyActivity.dischargePort := tit.dischargePort;	//01 Aug 2017	NDL	TFS 5226
				voyActivity.loadPort := tit.loadPort;	//01 Aug 2017	NDL	TFS 5226

				if tit.CM_ReceiveShip.myTrackedItem &lt;&gt; null then
					voyActivity.cargoType :=tit.CM_ReceiveShip.myTrackedItem.cargoTypeDescr;
					voyActivity.commodity := tit.CM_ReceiveShip.myTrackedItem.commodity;
					if tit.CM_ReceiveShip.myTrackedItem.myProduct &lt;&gt; null then
						voyActivity.product :=tit.CM_ReceiveShip.myTrackedItem.myProduct.description;
					endif;
				endif;
				
			//	if tit.CM_ReceiveShip.getJob &lt;&gt; null then
			//		voyActivity.jobId:=tit.CM_ReceiveShip.getJob.id;
			//		voyActivity.myJob :=tit.CM_ReceiveShip.getJob.CM_VoyageJob;
			//	endif;
				voyActivity.setMyJobAndLocations( tit.CM_ReceiveShip.myTrackedItem, tit.CM_ReceiveShip.getJob );	//01 Aug 2017	NDL	TFS 5226
				
				if tit.CM_ReceiveShip.getCrane &lt;&gt; null then
					voyActivity.craneId :=tit.CM_ReceiveShip.getCrane.id;
				endif;
				if jobSheet.myWorkPoint &lt;&gt; null then
					wPoint := jobSheet.myWorkPoint.code;
					voyActivity.workPointId := wPoint;
				endif;
				voyActivity.shiftCode := tit.CM_ReceiveShip.shiftCode;
				voyActivity.shiftStart := tit.CM_ReceiveShip.shiftStart;
				//voyActivity.shiftEnd := tit.CM_ReceiveShip.shiftEnd;  //27/04/2017 cnwma1
				voyActivity.shiftEnd := tit.CM_ReceiveShip.dateTime;    //27/04/2017 cnwma1
				voyActivity.userCode := tit.userId;
				dyna.add(voyActivity);
			endforeach;
		endif;
	endforeach;
	
	foreach jobSheet in voy.allJobSheetsInOrder do
		if jobSheet &lt;&gt; null then
			foreach tit in jobSheet.allShipReleases do 
				create  voyActivity transient;
				voyActivity.myTerminal := voy.myTerminal;   //05/05/2017 cnwma1 TFS #4346
				voyActivity.dateTime :=tit.dateTime;
				voyActivity.qty :=tit.totalQuantity;
				//voyActivity.volume :=tit.totalVolume;											// TFS 7948
				if tit.myTrackedItem &lt;&gt; null and tit.myTrackedItem.getDensity &lt;&gt; null then		// TFS 7948
					voyActivity.volume := tit.totalWeight / tit.myTrackedItem.getDensity;		// TFS 7948
				else																			// TFS 7948
					voyActivity.volume :=tit.totalVolume;										// TFS 7948
				endif;																			// TFS 7948
				voyActivity.weight :=tit.totalWeight;
				voyActivity.activityType :="Transaction";
				voyActivity.activityName := "Load";
				voyActivity.dischargePort := tit.dischargePort;	//01 Aug 2017	NDL	TFS 5226
				voyActivity.loadPort := tit.loadPort;	//01 Aug 2017	NDL	TFS 5226
				
				if tit.CM_ReleaseShip.myTrackedItem &lt;&gt; null then
					voyActivity.cargoType :=tit.CM_ReleaseShip.myTrackedItem.cargoTypeDescr;
					voyActivity.commodity := tit.CM_ReleaseShip.myTrackedItem.commodity;
					if tit.CM_ReleaseShip.myTrackedItem.myProduct &lt;&gt; null then
						voyActivity.product :=tit.CM_ReleaseShip.myTrackedItem.myProduct.description;
					endif;
				endif;
				
		//		if tit.CM_ReleaseShip.getJob &lt;&gt; null then
		//			voyActivity.jobId:=tit.CM_ReleaseShip.getJob.id;
		//			voyActivity.myJob :=tit.CM_ReleaseShip.getJob.CM_VoyageJob;
		//		endif;
				voyActivity.setMyJobAndLocations( tit.CM_ReleaseShip.myTrackedItem, tit.CM_ReleaseShip.getJob );	//01 Aug 2017	NDL	TFS 5226
				
				if tit.CM_ReleaseShip.getCrane &lt;&gt; null then
					voyActivity.craneId :=tit.CM_ReleaseShip.getCrane.id;
				endif;

				if jobSheet.myWorkPoint &lt;&gt; null then
					wPoint := jobSheet.myWorkPoint.code;
					voyActivity.workPointId := wPoint;
				endif;
				voyActivity.shiftCode := tit.CM_ReleaseShip.shiftCode;
				voyActivity.shiftStart := tit.CM_ReleaseShip.shiftStart;
				//voyActivity.shiftEnd := tit.CM_ReleaseShip.shiftEnd; //27/04/2017 cnwma1
				voyActivity.shiftEnd := tit.CM_ReleaseShip.dateTime;  //cnwma1 27/04/2017
				voyActivity.userCode := tit.userId;
				dyna.add(voyActivity);
			endforeach;
		endif;
	endforeach;

	foreach event in voy.allEventTransactionsByDateTime do
		if event  &lt;&gt; null   then
			create  voyActivity transient;
			voyActivity.myTerminal := voy.myTerminal;   //05/05/2017 cnwma1 TFS #4346
			voyActivity.activityType :="Event";
			voyActivity.activityName := event.myEventType.name;
			voyActivity.eventAmount := event.amount;
			voyActivity.dateTime :=event.dateTime;
			voyActivity.userCode := event.userCode;
			if event.isKindOf(CMEVT_VoyageEvent) then
				voyActivity.remarks	   := event.CMEVT_VoyageEvent.remarks;
				//voyActivity.shiftStart := event.CMEVT_VoyageEvent.shiftStart; //27/04/2017 cnwma1
				voyActivity.shiftStart := event.CMEVT_VoyageEvent.dateTime;     //27/04/2017 cnwma1
				voyActivity.shiftEnd   := event.CMEVT_VoyageEvent.dateTimeEnd;
				voyActivity.shiftCode  := event.CMEVT_VoyageEvent.shiftCode;
				if event.CMEVT_VoyageEvent.myJobSheet &lt;&gt; null then //26/04/2017 cnwma1 TFS #4216
					if event.CMEVT_VoyageEvent.myJobSheet.myWorkPoint &lt;&gt; null then
						voyActivity.workPointId :=event.CMEVT_VoyageEvent.myJobSheet.myWorkPoint.code;
					endif;
				endif;
		//		if event.CMEVT_VoyageEvent.myJob &lt;&gt; null then  //26/04/2017 cnwma1 TFS #4216
		//			voyActivity.myJob := event.CMEVT_VoyageEvent.myJob;
		//			voyActivity.jobId := event.CMEVT_VoyageEvent.myJob.id;
		//		endif;
				voyActivity.setMyJobAndLocations( null, event.CMEVT_VoyageEvent.myJob );	//01 Aug 2017	NDL	TFS 5226
				
			endif;
			if event.myEventType &lt;&gt; null then
				voyActivity.myEventType := event.myEventType;
			endif;
		
			dyna.add(voyActivity);
		endif;
	endforeach;
	
	foreach delay in voy.allDelays do
		create  voyActivity transient;
		voyActivity.myTerminal := voy.myTerminal;   //05/05/2017 cnwma1 TFS #4346
		if delay &lt;&gt; null then
			if delay.myWorkPoint &lt;&gt; null then
				wPoint := delay.myWorkPoint.code;
				voyActivity.workPointId := wPoint;
			endif;
			voyActivity.dateTime :=delay.startDT;
			voyActivity.activityType :="Delay";
			voyActivity.activityName := delay.myDelayType.description;
			voyActivity.remarks :=delay.remarks;
			if delay.myEventStart &lt;&gt; null then
				voyActivity.userCode := delay.myEventStart.userCode;
			endif;
			dyna.add(voyActivity);
		endif;
		
	endforeach;
	
	
	create objArr transient;
	create groupedArr transient;
	create jobIds transient;
	dyna.copy(objArr);
	
	//Grouping transactions together
	foreach voyActivity in objArr do
		if voyActivity.activityType ="Transaction" then
			if oldJob = voyActivity.jobId 
				and oldCrane = voyActivity.craneId 
				and oldName = voyActivity.activityName 
				and oldType = voyActivity.activityType 
				and oldCargoType = voyActivity.cargoType
				and oldProduct = voyActivity.product
				and oldCommodity = voyActivity.commodity then
				oldQty :=0;
				oldWt := 0;
				oldVol := 0;
				oldQty:=oldActivity.qty;
				oldWt := oldActivity.weight;
				oldVol := oldActivity.volume;
				voyActivity.dateTime :=oldActivity.dateTime;
				voyActivity.qty :=  oldQty+ voyActivity.qty;
				voyActivity.weight :=  oldWt+ voyActivity.weight;
				voyActivity.volume :=  oldVol+ voyActivity.volume;
				groupedArr.remove(oldActivity);
			endif;
			groupedArr.add(voyActivity);
		else
			groupedArr.add(voyActivity);
		endif;
			oldType := voyActivity.activityType;
			oldName := voyActivity.activityName;
			oldCrane := voyActivity.craneId;
			oldJob := voyActivity.jobId;
			oldActivity := voyActivity;
			oldCargoType := voyActivity.cargoType;
			oldProduct := voyActivity.product;
			oldCommodity := voyActivity.commodity;
			
			if not jobIds.includes(voyActivity.jobId) then  //27/04/2017 cnwma1
				jobIds.add(voyActivity.jobId);
			endif;
	endforeach;
	
	//27/04/2017 cnwma1
	//create lastActivity transient;															// TFS 7948
	create lastGroupedArr transient;
	foreach jobId in jobIds  do
		foreach lastActivity in groupedArr reversed where lastActivity.jobId = jobId do
			if lastActivity.activityType="Transaction" then
			
				/*if eventLastEndTime.isValid then  				//03/05/2017 cnwma1 TFS #4314
					lastActivity.shiftStart := eventLastEndTime;
					lastActivity.shiftEnd := lastActivity.dateTime;
					lastGroupedArr.add(lastActivity);
					eventLastEndTime := null;
				endif;*/
				if eventLastEndTime.isValid then    			//03/05/2017 cnwma1 TFS #4314
					lastActivity.shiftStart := eventLastEndTime;
					//eventLastEndTime := null;                 //24/05/2017 cnwma1 TFS #4526
				elseif transLastEndTime.isValid then
					lastActivity.shiftStart := transLastEndTime;
					transLastEndTime := null;
				else
				endif;
				lastActivity.shiftEnd := lastActivity.dateTime;
				lastGroupedArr.add(lastActivity);
				oldLastTransActivity :=lastActivity;
				transLastEndTime :=oldLastTransActivity.dateTime;  //03/05/2017 cnwma1 TFS #4314
			else
				if lastActivity.activityType="Event" then
					if	lastActivity.shiftEnd.isValid then
						oldLastActivity :=lastActivity;
						eventLastEndTime := oldLastActivity.shiftEnd;
					endif;
					lastGroupedArr.add(lastActivity);
				endif;	
			endif;
		endforeach;
	endforeach;
	//return groupedArr; //27/04/2017 cnwma1
	

	create lFile transient;
    lFile.fileName := "C:\TEMP\PEL301018-1.csv";
    lFile.open;
	lFile.writeLine("Shift Code" &amp;","&amp; "WorkPoint" &amp;","&amp; "Gang" &amp;","&amp; "Activity" &amp;","&amp; "ActivityType" &amp;","&amp; "ActivityTime" &amp;","&amp; "CMD" &amp;","&amp; "CargoType" &amp;","&amp; "CargoSub" &amp;","&amp; "Qty" &amp;","&amp; "Weight" &amp;","&amp; "Vol" &amp;","&amp; "ActivityStart" &amp;","&amp; "ActivityEnd");
	foreach  tt in lastGroupedArr reversed do 

	lFile.writeLine( tt.shiftCode &amp;","&amp; tt.workPointId  &amp;","&amp; tt.jobId &amp;","&amp; tt.activityName &amp;","&amp; tt.activityType &amp;","&amp; tt.dateTime.asStringJMT &amp;","&amp; tt.commodity &amp;","&amp; tt.cargoType &amp;","&amp; tt.product &amp;","&amp; tt.qty.asStringJMT &amp;","&amp; tt.weight.asStringJMT  &amp;","&amp; tt.volume.asStringJMT &amp;","&amp; tt.shiftStart.asStringJMT &amp;","&amp;  tt.shiftEnd.asStringJMT );  

	endforeach;
	   lFile.close;
    delete lFile;
	
	
epilog
delete objArr;
delete dyna;
delete jobIds ;
delete lastActivity;
delete groupedArr;
end;
</source>
    </JadeMethod>
    <JadeMethod name="maPol3626" id="53b9ee37-d41f-409e-8252-391fae2e1ce7">
        <source>maPol3626();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2017	cnwma1	Initial creation

*/

vars
	voyWle : CM_VoyageWLE;
	 i : Integer;
	 file : File;
	 	currentLocation : CM_LocationsController;
begin
create file transient;
	file.fileName := "C:\TEMP\POL28317-3.csv";
	file.open;
	 foreach voyWle in CM_VoyageWLE.instances do
		if voyWle.myTrackedItem &lt;&gt; null and voyWle.myTrackedItem.myPrimaryActualLocation &lt;&gt; null then
				currentLocation := voyWle.myTrackedItem.getPrimaryLocation(REAL_MODE);
				if  currentLocation.isCraneLaneController()  then
					continue;
				endif;
				if  currentLocation.isWorkPointLaneController()  then 
					continue;
				endif;
					if voyWle.isCompleteForJob and voyWle.myFutureMove = null   then
						file.writeLine(voyWle.myTrackedItem.id &amp;","&amp; voyWle.myTrackedItem.getStateDisplay &amp; "," &amp; voyWle.myTrackedItem.myTerminal.code);
					endif;
				endif;
		
	endforeach;
	file.close;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="maVVr" id="b096eecb-2938-4f2e-8b99-d5222a7edda1">
        <source>maVVr();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2016	cnwma1	Initial creation

*/

vars
	vvr : CM_VehicleVisitRecord;
	now : TimeStamp;
begin
		app.initialize;
		now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		vvr := "3100.428110".asOid.CM_VehicleVisitRecord;
		if vvr &lt;&gt; null then
		
			beginTransaction;
			 // vvr.setTimeIn("11/09/2016".asDateJMT,"00:00:00".asTimeJMT); //.setDateTime(2016,09,11,15,00,00,00);
			vvr.setTimeIn((now.date)-1, now.time);
			//vvr.setVisitNumber("2");
			commitTransaction;
		endif;
epilog

end;</source>
    </JadeMethod>
