    <JadeMethod name="addForkLiftStack" id="bc87cb56-49a7-409d-8b5f-eee75ab62e11">
        <source>addForkLiftStack(_name: String; _rows,_columns,_height: Integer): CM_ForkLiftStack;
/*

Purpose:		aka Gridded Block Stack	

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwer1	Initial creation

*/


//
vars

	pxyForkStack: CM_ForkLiftStack;
	pxyGridCol: CM_GridColumn;
	pxyGridRow: CM_GridRow;
	pxyStackCntrl: CM_StackController;
	column, row: Integer;
	label: String;
	pDO: CM_YADeckingOptionsTA;
	realTA 	: CM_TerminalAreaMaster;
	
	pxyTA				: CM_TerminalAreaMaster;
	pxyCMIFTerminalArea	: CMIF_GridArea;
	use40ftIds			: Boolean;
	power				: Boolean;
	
begin
	self.deleteTerminalArea(_name);
	
	use40ftIds := self.opts.bool("use40ftIds");			// 26/08/2011 cnwmh5
	power := self.opts.bool("WithPower");				// 21/07/2015 cnwmh5
		
	create pxyForkStack transient;

	pxyForkStack.setProxy(_name, 
					"",
					TA_TYPE_FORK_LIFT_STACK, 
					_rows, 
					_columns, 
					_height,
					"Gridded Block Stack",
					true,  //back
					true, //front
					HEIGHT_FULL_HIGH_CUBE*_height, //full height //
					HEIGHT_FULL_HIGH_CUBE*_height, //MT height
					HEIGHT_FULL_HIGH_CUBE*_height, //power height
					null,
					false, //release point
					self.getTerminal,
					false, //stock
					false, // hide ove
					0, //deck start type
					false, false, false, false, false, null,null, true, use40ftIds,				// 26/08/2011 cnwmh5
					"West", "East", "North", "Sourth");
	
	create pDO transient;
	pDO.setProxy(false, true, pxyForkStack);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	foreach row in 1 to _rows do
		label := row.stringWithLeadingZeros(2);
		create pxyGridRow transient;
		pxyGridRow.setForProxy(row, label, pxyForkStack);
		foreach column in 1 to _columns do
			label := column.stringWithLeadingZeros(4);
			pxyGridCol := pxyForkStack.allGridColumns[column].CM_GridColumn;
			if pxyGridCol = null then
				create pxyGridCol transient;
				pxyGridCol.setForProxy(column, label, pxyForkStack);
			endif;
			
			create pxyStackCntrl transient;
			pxyStackCntrl.setForProxy(PAD_AVAILABLE, 
							NORMAL_USE, 
							pxyGridRow.row, 
							pxyGridCol.column,
							pxyGridRow.label &amp; pxyGridCol.label,
							2,
							power,											// 21/07/2015 cnwmh5
							false,
							null,
							pxyForkStack, false,null, false, null, false, null);
	

			pxyStackCntrl.setForProxyGridController(pxyGridRow.label &amp; pxyGridCol.label, 
								pxyGridCol,
								pxyGridRow,
								2);

		endforeach;
	endforeach;

	// 26/08/2011 cnwmh5
	pxyTA := pxyForkStack;
	// only do this if use40ftIds is set as returns correct location but slightly different format
	if use40ftIds then
		create pxyCMIFTerminalArea transient;
		pxyCMIFTerminalArea.numRows :=  _rows;
		pxyCMIFTerminalArea.numColumns := _columns;
		pxyCMIFTerminalArea.myPxyTerminalAreaMaster := pxyForkStack;
		pxyCMIFTerminalArea.startNumColumn := 1;
		pxyCMIFTerminalArea.startNumRow := 1;
		pxyCMIFTerminalArea.labelLengthCol := 4;
		pxyCMIFTerminalArea.labelLengthRow := 4;
		pxyCMIFTerminalArea.use40ftIds := use40ftIds;
		pxyCMIFTerminalArea.createProxyStructure();
		pxyTA := pxyCMIFTerminalArea.myPxyTerminalAreaMaster;
	endif;
		
	app.myTrxCA.trxCreateTerminalArea(pxyTA, realTA, app.myPassport);				// 26/08/2011 cnwmh5
	self.assertNoTrxErrorsOrWarnings();

	return realTA.CM_ForkLiftStack;
epilog
	delete pxyForkStack;
	delete pxyCMIFTerminalArea;
	if app.isValidObject(pDO) then
		delete pDO;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <ReturnType type="CM_ForkLiftStack"/>
    </JadeMethod>
    <JadeMethod name="addFutureStorageMapping" id="20b196a0-21ef-462e-8105-23b6929a976f">
        <source>addFutureStorageMapping(_tasg : CM_TerminalAreaStorageGroup; _ild : CM_InvoiceLineDesc; _storageDetail : CM_StorageDetail) : CM_FutureStorageMapping;

vars
	proxyFSM	: CM_FutureStorageMapping;
	futureStoreMapping	: CM_FutureStorageMapping;
begin
	create proxyFSM transient;
	
	proxyFSM.setProxy(_tasg, _ild, _storageDetail, null);
	
	app.myTrxCA.trxCreateFutureStorageMapping(proxyFSM, futureStoreMapping, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return futureStoreMapping;
	
epilog
	delete proxyFSM;
end;
</source>
        <Parameter name="_tasg" type="CM_TerminalAreaStorageGroup"/>
        <Parameter name="_ild" type="CM_InvoiceLineDesc"/>
        <Parameter name="_storageDetail" type="CM_StorageDetail"/>
        <ReturnType type="CM_FutureStorageMapping"/>
    </JadeMethod>
    <JadeMethod name="addFutureStorageMapping2" id="504ea6bd-3943-4298-859a-59b03e7acd16">
        <source>addFutureStorageMapping2(_bank : CM_Bank; _storageGroup : CM_TerminalAreaStorageGroup; _storageDetail : CM_StorageDetail; _calcType : CM_CalculationType; _currentQRM : CM_QuantityRangeMap;
						 _mapType : Integer; _groupType : Integer; _chargeZero : Boolean; _rangeFrom : Integer; _rangeTo : Integer; _invLineDescs : CM_InvoiceLineDescArray input) : CM_FutureStorageMapping;

// recoded after 36257/37434, a copy of CMUI_InvoiceFutureStorageMaps::do Save
vars
	count	: Integer;
	updateMode	: Boolean;
	isVoid	: Boolean;
	ild		: CM_InvoiceLineDesc;
	qm, pxyQM, realqm : CM_QuantityMap;
	qrm,
	pxyQRM : CM_QuantityRangeMap;
	theReturn, mapType : Integer;
	map,
	fsm	: CM_FutureStorageMapping;
	gt : CM_TranMapInvoiceLineGroupType;

begin
	if _currentQRM &lt;&gt; null then
		qm := _currentQRM.myQuantityMap;
		fsm := qm.myFutureStorageMap;
		updateMode := true;
	endif;
	
	if fsm = null then
		foreach map in _storageGroup.allFutureStorageMappings do
			if map.myStorageDetail = _storageDetail then		
				fsm := map;
				break;
			endif;
		endforeach;
		if fsm = null then
			foreach map in _storageGroup.allFutureStorageMappings do
				if map.myStorageDetail = null then		// the default one created with a new storage group
					fsm := map;
					break;
				endif;
			endforeach;
		endif;
		if fsm &lt;&gt; null then
			qm := fsm.myQuantityMap;
		endif;
	endif;
	
	if updateMode then
		beginLoad;
		pxyQM := qm.pxyCreateUpdateProxy().CM_QuantityMap;
		if _currentQRM &lt;&gt; null then
			pxyQRM := _currentQRM.pxyCreateUpdateProxy().CM_QuantityRangeMap;
		endif;
		endLoad;
	else
		if qm &lt;&gt; null then
			beginLoad;
			pxyQM := qm.pxyCreateUpdateProxy().CM_QuantityMap;
			endLoad;
		else
			create pxyQM transient;
			pxyQM.setMyCalculationType(_calcType);
		endif;
		// if the default mapping is found with a 0-max VOID range map, use this as the current quantity map and overwrite the details
		//   to avoid creating a second quantity map with the same range and getting a duplicate key exception
		if fsm &lt;&gt; null and
		   fsm.myStorageDetail = null then
			foreach qrm in fsm.myQuantityMap.allQuantityRanges do
				count := count + 1;
			endforeach;
			if count = 1 and
			   qrm.rangeStart = 0 and
			   qrm.rangeEnd = CM_QuantityRangeMap.MAX_RANGE then
				beginLoad;
				pxyQRM := qrm.pxyCreateUpdateProxy();
				endLoad;
				updateMode := true;
			endif;
		endif;
		if pxyQRM = null then
			create pxyQRM transient;
		endif;
		if fsm = null then
			create fsm transient;
			fsm.setProxy(_storageGroup, null, _storageDetail, null);
		endif;
	endif;
	if pxyQRM = null then
		create pxyQRM transient;
	endif;
	
	mapType := _mapType;
	gt := _bank.getInvLineGroupByType(_groupType);
	
	if fsm.isTransient then
		pxyQM.setProxy(null, _chargeZero, mapType, _calcType, null);
	else
		pxyQM.setProxy(null, _chargeZero, mapType, _calcType, fsm);
	endif;
	if qm &lt;&gt; null then
		pxyQRM.setProxy(qm, _rangeFrom, _rangeTo, 0);
	else
		pxyQRM.setProxy(pxyQM, _rangeFrom, _rangeTo, 0);
	endif;
	pxyQRM.setProxyInvoiceLineTypesFS(_invLineDescs, gt);
	
	map := app.myTrxUA.trxUpdateInvoiceFutureStorage(updateMode, pxyQM,realqm, pxyQRM, fsm, _storageDetail); // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1 - realqm
 
	return map;
	

epilog
	if global.isValidObject(pxyQRM) then
		delete pxyQRM;
	endif;
	if global.isValidObject(pxyQM) then
		delete pxyQM;
	endif;
	if fsm.isTransient then
		delete fsm;
	endif;
end;
</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_storageGroup" type="CM_TerminalAreaStorageGroup"/>
        <Parameter name="_storageDetail" type="CM_StorageDetail"/>
        <Parameter name="_calcType" type="CM_CalculationType"/>
        <Parameter name="_currentQRM" type="CM_QuantityRangeMap"/>
        <Parameter name="_mapType" type="Integer"/>
        <Parameter name="_groupType" type="Integer"/>
        <Parameter name="_chargeZero" type="Boolean"/>
        <Parameter name="_rangeFrom" type="Integer"/>
        <Parameter name="_rangeTo" type="Integer"/>
        <Parameter name="_invLineDescs" type="CM_InvoiceLineDescArray" usage="input"/>
        <ReturnType type="CM_FutureStorageMapping"/>
    </JadeMethod>
    <JadeMethod name="addGCAllocRowArea" id="dad636f1-adb4-42bb-a205-54f09f8d4e97">
        <source>addGCAllocRowArea( gcallocId : String ):CM_GeneralCargoAllocRowArea;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2021	navndl1	Initial creation	TFS	49912 

*/

vars

	realTA : CM_TerminalAreaMaster;
	pxyGcAllocRowArea : CM_GeneralCargoAllocRowArea;	
	areaLength : Integer;
	areaWidth : Integer;
	columns : String;
	dividers : String;
	colArray : StringArray;
	divArray : StringArray;
	selectedInterchanges : CM_InterchangeAreaArray;
	pDO: CM_YADeckingOptionsTA;

begin

	self.deleteTerminalArea( gcallocId );
	
	create pxyGcAllocRowArea transient;
	
	areaLength := 80;
	areaWidth := 10;
	columns := "A,B,C,D,E,F,G,H";
	dividers := "C,D,F";
	
	create colArray transient;
	create divArray transient;
	columns.getTokensForDelimiter(Comma, colArray);
	dividers.getTokensForDelimiter(Comma, divArray);
	
	create selectedInterchanges transient;
	
	if pxyGcAllocRowArea.myLayoutGraphic = null then
		pxyGcAllocRowArea.initDefaultLayout();
	endif;

	pxyGcAllocRowArea.myLayoutGraphic.setProxyColour(Red, White);
	pxyGcAllocRowArea.setIsEmpty(true);	
	
	pxyGcAllocRowArea.setProxy(gcallocId, null, TA_TYPE_GEN_CARGO_ALLOC_ROW, areaLength, areaWidth, false, self.getTerminal, false, false, null, false, false, false, null, null);
	pxyGcAllocRowArea.createProxyLCsAndGroups(colArray, divArray);
	
	create pDO transient;
	pDO.setProxy(false, true, pxyGcAllocRowArea);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	app.myTrxCA.trxCreateTerminalArea( pxyGcAllocRowArea, realTA, app.myPassport );
	
	if realTA &lt;&gt; null then
		return realTA.CM_GeneralCargoAllocRowArea;
	else
		return null;
	endif;
				
epilog

	delete colArray;
	delete divArray;
	delete selectedInterchanges;
	delete pxyGcAllocRowArea;
	if app.isValidObject(pDO) then
		delete pDO;
	endif;

end;</source>
        <Parameter name="gcallocId" type="String"/>
        <ReturnType type="CM_GeneralCargoAllocRowArea"/>
    </JadeMethod>
    <JadeMethod name="addGCHoldDefn" id="e1f94b0b-4ddd-4170-9033-094bac4d7bbb">
        <source>addGCHoldDefn(	_gcVesselStruct: CM_GeneralCargoVesselStructure;
				_holdNum: Integer;
				_placeNum: Integer;
				_isOnDeck : Boolean;							// PAR #36766
				_maxWeight : Integer;							// PAR #36766
				_maxVolume: Decimal;
				_maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
				_onShipCrane: Integer;
				_locName: String
				):CM_GCHoldLocationDefn;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/07/2013	cnwndl1	Initial creation	Par 31965
27/08/2015	cnwdap1	PAR #36766 CCMS SFW 1334 Bulk Graphical Representation - new parameters
*/

vars
	
	proxy : CM_GCHoldLocationDefn;
	gcHoldLocnDefn : CM_GCHoldLocationDefn;

begin

	create proxy transient;
	proxy.setProxy(	_holdNum,	//_hatch : Integer;
					_locName,	//_name : String;
					_placeNum,	//_place : Integer;
					_isOnDeck,	//_isOnDeck : Boolean;			// PAR #36766
					_maxWeight,	//_maxWeight : Integer;			// PAR #36766
					_maxVolume,	//_maxVolume: Decimal;
					_maxHeight,	// _maxHeight: Decimal;	//07 Feb 2017	NDL	TFS 3216
					_onShipCrane,// onShipCrane : Integer
					_gcVesselStruct	//_myGCVesselStructure : CM_GeneralCargoVesselStructure
					);
	
	app.myPassport.setWarningsIgnored(true);					// 11/09/2015 cnwmh5	
	
	app.myTrxCA.trxCreateGCHoldLocnDefn(proxy, gcHoldLocnDefn, app.myPassport);
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "GC Hold Defn not created : " &amp; app.myPassport.getAllErrorsAndWarningsAsStr );
	
	return gcHoldLocnDefn;
	
epilog

	app.myPassport.setWarningsIgnored(false);					// 11/09/2015 cnwmh5

	delete proxy;

end;</source>
        <Parameter name="_gcVesselStruct" type="CM_GeneralCargoVesselStructure"/>
        <Parameter name="_holdNum" type="Integer"/>
        <Parameter name="_placeNum" type="Integer"/>
        <Parameter name="_isOnDeck" type="Boolean"/>
        <Parameter name="_maxWeight" type="Integer"/>
        <Parameter name="_maxVolume" type="Decimal"/>
        <Parameter name="_maxHeight" type="Decimal"/>
        <Parameter name="_onShipCrane" type="Integer"/>
        <Parameter name="_locName" type="String"/>
        <ReturnType type="CM_GCHoldLocationDefn"/>
    </JadeMethod>
    <JadeMethod name="addGCRackOrGround" id="4f6d2e41-ae90-46a6-ac24-43741410113f">
        <source>addGCRackOrGround(realGeneralCargoArea : CM_IrregularBlockArea input; _x1, _y1, _x2, _y2 : Integer; _id : String) : CM_IrregularBlockController;

/*

Purpose:		Add a General Cargo Area

Date			Who		Reason
06/12/2011		cnwmh5	Initial creation

*/

vars
	locationProxy,blockLocation 				: CM_IrregularBlockController;
	region 						: PointArray;
	topLeft,
	bottomRight					: Point;
	
	locationType				: Integer;
	capacity					: Integer;
	maxWeight					: Real;
	colour						: Integer;
	myICArea : CM_InterchangeArea;
begin
	
	create region transient;
	create locationProxy transient;
	topLeft.set(_x1,_y1);
	region.add(topLeft);
	bottomRight.set(_x2,_y2);
	region.add(bottomRight);
	
	locationType := GC_RackLocation;						// 17/11/2015 cnwmh5
	if self.opts.includesKey("LocationType") then
		locationType := self.opts.int("LocationType");
	endif;
	capacity := self.opts.int("Capacity");
	maxWeight := self.opts.real("MaxWeight");
	colour := self.opts.int("Colour");
	
	// ### TFS CR 58499 TASK 61456 29DEC2023 NAVAB1
	if self.opts.includesKey("ICArea") then
		myICArea := self.opts.obj("ICArea").CM_InterchangeArea;
	endif;
	
	locationProxy.setProxy(realGeneralCargoArea, _id, region,
									colour, 			//0,	//_colour : Integer;
									capacity, 		//0,	//_defaultCapacity : Integer;
									locationType, 		// GC_RackLocation,	//_locationType : Integer;			
									maxWeight, 		//0,	//_maximumWeight : Real;
									myICArea	//_myICArea : CM_InterchangeArea
									);
	

	beginTransaction;
		// location added
		create blockLocation;
		blockLocation.setForCreate(locationProxy.CM_IrregularBlockController, realGeneralCargoArea);
	commitTransaction;
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return blockLocation;

epilog
delete locationProxy;
	delete region;
end;</source>
        <Parameter name="realGeneralCargoArea" type="CM_IrregularBlockArea" usage="input"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_IrregularBlockController"/>
    </JadeMethod>
    <JadeMethod name="addGCShelf" id="c7551bbb-b4df-4f12-ab29-d86883e66db3">
        <source>addGCShelf(_rack : CM_IrregularBlockController; _index : Integer; _shelfId : String; _defaultCapacity : Integer; _maxWeight : Real; _ica : CM_InterchangeArea) : CM_RackShelfController;
/*
Purpose:			
Date		Who		Reason
20 September 2013	NAVAB1	Initial creation
*/

vars

	lastCurrentSub : CM_RackShelfController;
	shelfProxy : CM_RackShelfController;
	newIndex : Integer;
	msg : String;
	realShelf : CM_RackShelfController;
begin

	
	create shelfProxy transient;
	shelfProxy.setDefaultProxy( _index, _rack, null );

	shelfProxy.setProxy(	null,	//blockAreaProxy : CM_IrregularBlockArea;
					_shelfId,	//id: String;
					shelfProxy.region,	//region: PointArray;
					Blue,	//_colour : Integer;
					_defaultCapacity,	//_defaultCapacity : Integer;
					GC_ShelfLocation,	//_locationType : Integer;
					_maxWeight,	//_maximumWeight : Real;
					_ica	//_myICArea : CM_InterchangeArea
					);
	beginTransaction;
		create realShelf as CM_RackShelfController persistent;
		realShelf.setForCreate( shelfProxy, null );
		realShelf.setMyLocation(_rack);
		realShelf.setForUpdateICA(_ica);
	commitTransaction;
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	return realShelf;
epilog
	delete shelfProxy;
end;</source>
        <Parameter name="_rack" type="CM_IrregularBlockController"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_shelfId" type="String"/>
        <Parameter name="_defaultCapacity" type="Integer"/>
        <Parameter name="_maxWeight" type="Real"/>
        <Parameter name="_ica" type="CM_InterchangeArea"/>
        <ReturnType type="CM_RackShelfController"/>
    </JadeMethod>
    <JadeMethod name="addGCStructureDefn" id="699e5929-1ffe-437f-9566-2c203cd6ed56">
        <source>addGCStructureDefn(_gcVessel: CM_Vessel input):CM_GeneralCargoVesselStructure;
/*
Purpose:			
Date				Who			Reason
JANUARY 2014		NAVAB1		Initial creation
*/


vars
	

	gcStructureDefn : CM_GeneralCargoVesselStructure;

begin

	self.assertTrueMsg(_gcVessel &lt;&gt; null, "Vessel is null!");
	
	app.myTrxCA.trxCreateVesselGCStructure(_gcVessel, gcStructureDefn, app.myPassport);
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "GC Structure not created : " &amp; app.myPassport.getAllErrorsAndWarningsAsStr );
	
	return gcStructureDefn;
	
epilog

	

end;</source>
        <Parameter name="_gcVessel" type="CM_Vessel" usage="input"/>
        <ReturnType type="CM_GeneralCargoVesselStructure"/>
    </JadeMethod>
    <JadeMethod name="addGate" id="2c6ec73c-a06e-41c1-b7d6-931f05acc7c3">
        <source>addGate(_gateId : String; _dual, _in, _out, _promptRFID : Boolean; _icArea : CM_InterchangeArea; _gateAreas : StringArray) : CM_Gate;

/*

Purpose:		Add a Gate	

Parameters		_gateAreas : Format for this is &lt;Area Name&gt;;&lt;Comment&gt;;&lt;Area Type&gt;;&lt;In&gt;;&lt;Out&gt;;&lt;Lanes&gt;;

Date			Who		Reason
05/12/2011		cnwmh5	Initial creation

*/

vars

	pxyGate							: CM_Gate;
	gate							: CM_Gate;
	gateUsage						: CM_GateAreaUsage;
	obj								: Object;
	
	gadArray						: StringArray;
	objArray						: ObjectArray;
	
	str								: String;
	
begin

	self.deleteGate(_gateId);

	create pxyGate transient;
			
	pxyGate.setProxy(_gateId,				// Id / Code
					 _dual,					// Dual
					 _in, 					// In
					 _out,					// out
					 _promptRFID,			// Prompt for RFID
					 _icArea,					// Interchange area
					 self.getTerminal());	// Terminal
						  
	// create gate areas
	foreach str in _gateAreas do
		gadArray := str.cnGetTokens(";");
		pxyGate.pxyAddNewGateArea(gadArray[1], gadArray[2], gadArray[3].Integer, gadArray[4].Boolean,
			gadArray[5].Boolean);
		delete gadArray;
	endforeach;
	
	app.myTrxCA.trxCreateGate(pxyGate, gate, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return gate;
	
epilog
	create objArray transient;
	pxyGate.allGateAreas_IN.copy(objArray);
	pxyGate.allGateAreas_OUT.copy(objArray);
	foreach obj in objArray do
		obj.CM_GateAreaUsage.erase(NORMAL_ERASE);
	endforeach;
	delete objArray;
	delete gadArray;
	delete pxyGate;
end;</source>
        <Parameter name="_gateId" type="String"/>
        <Parameter name="_dual" type="Boolean"/>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_out" type="Boolean"/>
        <Parameter name="_promptRFID" type="Boolean"/>
        <Parameter name="_icArea" type="CM_InterchangeArea"/>
        <Parameter name="_gateAreas" type="StringArray"/>
        <ReturnType type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="addGeneralCargoArea" id="186476ad-9a6e-4df9-8f72-a2a8070d01ff">
        <source>addGeneralCargoArea(_gcId, _gcComment: String; _rows, _columns : Integer; _units : Integer; _allInterchangeAreas : CM_InterchangeAreaArray;
		_defaultInterchangeArea : CM_InterchangeArea) : CM_IrregularBlockArea;

/*

Purpose:		Add a General Cargo Area

Date			Who		Reason
06/12/2011		cnwmh5	Initial creation

*/

vars

	pxyGeneralCargoArea			: CM_IrregularBlockArea;
	generalCargoArea			: CM_TerminalAreaMaster;
	locationProxy 				: CM_IrregularBlockController;
	region 						: PointArray;
	topLeft,
	bottomRight					: Point;
	pDO : CM_YADeckingOptionsTA;
	autoRestrictions : Boolean;
begin

	self.deleteTerminalArea(_gcId);
	
	autoRestrictions := false;
	if self.opts.includesKey("AutoRestrictions") then
		autoRestrictions := self.opts.bool("AutoRestrictions");
	endif;

	create pxyGeneralCargoArea transient;
	
	pxyGeneralCargoArea.setProxy(_gcId, 
								 _gcComment,			// Comment
								 TA_TYPE_IRREGULAR_BLOCK_AREA,					// Type
								 _rows,					// rows
								 _columns, 				// columns
								 _units,					// Units
								 null, 					// row labels
								 null,					// Column Labels
								 autoRestrictions, 				// autoRestrictions
								false,					// stockControlled
								self.getTerminal(),		// Terminal
								_allInterchangeAreas,	// All Interchange Areas
								_defaultInterchangeArea); // Default Interchange Area
								
	create pDO transient;
	pDO.setProxy(false, true, pxyGeneralCargoArea);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	app.myTrxCA.trxCreateTerminalArea(pxyGeneralCargoArea, generalCargoArea, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return generalCargoArea.CM_IrregularBlockArea;

epilog
	delete pDO; // This is deleted by pxyGeneralCargoArea delete so this delete must be first.
	delete pxyGeneralCargoArea;
end;</source>
        <Parameter name="_gcId" type="String"/>
        <Parameter name="_gcComment" type="String"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_units" type="Integer"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
        <ReturnType type="CM_IrregularBlockArea"/>
    </JadeMethod>
    <JadeMethod name="addGenerator" id="21866962-f731-4980-adff-3cb9323e6b27">
        <source>addGenerator(_id: String; _operator:CM_Operator) : CM_TrackedItem;
//
// 19 May 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
//
vars
	pxyTI: CM_TrackedItem;
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
	id : String;
begin
	id := _id;
	self.deleteTrackedItem(id, false);
	pxyTI := self.createGenerator(_id, _operator, true);
	//pxyTI.setWeight(2000, null, null);					//-cnwml2 MSL CCMS 1017
//	pxyTI.setTotalWeight(2000, null, null);				//+cnwml2 MSL CCMS 1017
//	pxyTI.setWeightTare(400);
//	pxyTI.zSetPxyImexStatus(_imexStatus);
//	pxyTI.setVolume(6.666);	// #25592. Need some volume to test. 08/11/2010
//	pxyTI.zSetPxyTotalVolume(6.666);	//03 Jun 2011	NDL Par 26504

//	if self.opts.includesKey("quantity") then							// 24/09/2012 cnmwh5 #30120/#29876
//		pxyTI.zSetPxyQuantity(self.opts.int('quantity'));
//	endif;
	
	// PAr # 31237
//	if self.opts.includesKey(UTTI_SpecialLifts) then							
//		pxyTI.zSetPxySpecialLifts(self.opts.obj(UTTI_SpecialLifts).CM_SpecialLiftByCodeDict);
//	endif;
	
	if self.opts.includesKey(UTTI_VoyageCode) then
		voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq(self.opts.str(UTTI_VoyageCode), null);
		pxyTI.setMyVoyage(voyage, app.myPassport);
	endif;
	if self.opts.includesKey(UTTI_DischargePort) then
		pxyTI.setDischargePort(self.opts.str(UTTI_DischargePort));
	endif;
	
//	if _commodity = "REEF" then
//		pxyTI.setTemperature(4);
//	endif;
		pxyTI.CM_Generator.setMyGeneratorType(app.myRoot.allGeneratorTypes.first);
	
	return self.addContainerFromProxy(pxyTI);
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addGeneratorAtLocation" id="ffbce5e4-9bfa-4eb4-b55b-a5ecbbb3fef2">
        <source>addGeneratorAtLocation(id: String; _operator:CM_Operator; _location : Any) : CM_Generator;
//
// 19 May 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
//
vars
	generator : CM_Generator;
	operatorObj : CM_Operator;

begin
	if _operator = null then
		operatorObj	:=	self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	else
		operatorObj	:=	_operator;
	endif;
	
	generator := self.addGenerator(id, operatorObj).CM_Generator;
	self.move(generator, self.getLocationsController(_location));
	
	return generator;
epilog
end;</source>
        <Parameter name="id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="Any"/>
        <ReturnType type="CM_Generator"/>
    </JadeMethod>
    <JadeMethod name="addGeneratorType" id="a2d5fe85-9c25-43aa-bce5-3aa6078b8791">
        <source>addGeneratorType(_generatorTypeID, _generatorTypeDesc : String) : CM_GeneratorType;
/*

Purpose:			

Parameters:			

Return Value:		

Date								Who						Reason
12 July 2016				cnwrh7					Initial creation

*/

vars
	pxyGeneratorType					: CM_GeneratorType;
	generatorType							: CM_GeneratorType;
	defaultWeight							: Decimal[6,2];
	type												 : String;
begin
	defaultWeight := 1234.12;
	type := "Stand-alone";
	self.deleteGeneratorType(_generatorTypeID);

	create pxyGeneratorType transient;
	
	pxyGeneratorType.setProxy(_generatorTypeID,				// Id / Code
							 _generatorTypeDesc,				// Description
						    type,
							defaultWeight			// Default Weight
							 );
												  
	app.myTrxCA.trxCreateGeneratorType(pxyGeneratorType, generatorType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return generatorType;

epilog
	delete pxyGeneratorType;
end;
</source>
        <Parameter name="_generatorTypeID" type="String"/>
        <Parameter name="_generatorTypeDesc" type="String"/>
        <ReturnType type="CM_GeneratorType"/>
    </JadeMethod>
    <JadeMethod name="addHMSResourceBasic" id="5c973b84-d3d5-43d3-83c2-1b952bd8bb02">
        <source>addHMSResourceBasic( _harbour : HMS_Harbour; _resourceTypeCode : String; _howMany : Integer ):HMS_Resource;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2019	jlgndl1	Initial creation	TFS 44773

*/

vars

	pxyResource : HMS_Resource;
	resource : HMS_Resource;
	count : Integer;
	index : Integer;
	
	code : String; 			
	description : String;
	endPosnAlongWharf : Integer;
	startPosnAlongWharf : Integer;
	resourceType : HMS_ResourceType;
	myCalculationTypeQuantity : CM_CalculationType;
	myWharf : HMS_Wharf;
	
	vsID : Integer;
	voyageStatus : CM_VoyageStatus;

begin

	resourceType := app.myRoot.allResourceTypes[_resourceTypeCode.toUpper];
	if resourceType = null then
		return null;
	endif;
	if _howMany &gt; 9 then
		assertTrueMsg(false,"Too many resources for " &amp; method.qualifiedName &amp; " to create");
		return null;
	elseif _howMany &lt; 1 then
		count := 1;
	else
		count := _howMany;
	endif;
	
	code := resourceType.code;
	description := "Unit Testing - " &amp; code;
	
	if self.opts.includesKey(HMS_Resource::code.name) then
		code := self.opts.str(HMS_Resource::code.name);
	endif;
	if self.opts.includesKey(HMS_Resource::description.name) then
		description := self.opts.str(HMS_Resource::description.name);
	endif;
	if self.opts.includesKey(HMS_Resource::endPosnAlongWharf.name) then
		endPosnAlongWharf := self.opts.int(HMS_Resource::endPosnAlongWharf.name);
	endif;
	if self.opts.includesKey(HMS_Resource::startPosnAlongWharf.name) then
		startPosnAlongWharf := self.opts.int(HMS_Resource::startPosnAlongWharf.name);
	endif;
	
	if self.opts.includesKey(HMS_Resource::myWharf.name) then
		myWharf := self.opts.obj(HMS_Resource::myWharf.name).HMS_Wharf;
	endif;
	if self.opts.includesKey(HMS_Resource::myCalculationTypeQuantity.name) then
		myCalculationTypeQuantity := self.opts.obj(HMS_Resource::myCalculationTypeQuantity.name).CM_CalculationType;
	endif;
	if self.opts.includesKey(HMS_Resource::allVoyageStatuses.name) then
		vsID := self.opts.int(HMS_Resource::allVoyageStatuses.name);
		voyageStatus := app.myRoot.allVoyageStatuses.getAtKey( vsID );
	endif;
	
	foreach index in 1 to count do
		
		create pxyResource transient;
		
		pxyResource.setProxy( _harbour, myWharf, myCalculationTypeQuantity );
		
		if count = 1 then
			pxyResource.setPropertyValue( HMS_Resource::code.name, code.toUpper ); 			
			pxyResource.setPropertyValue( HMS_Resource::description.name, description );
		else
			pxyResource.setPropertyValue( HMS_Resource::code.name, code.toUpper.trimBlanks[1:9] &amp; index.String ); 			
			pxyResource.setPropertyValue( HMS_Resource::description.name, description[1:49] &amp; index.String );
		endif;
		pxyResource.setPropertyValue( HMS_Resource::endPosnAlongWharf.name, endPosnAlongWharf );
		pxyResource.setPropertyValue( HMS_Resource::startPosnAlongWharf.name, startPosnAlongWharf );
		pxyResource.setPropertyValue( HMS_Resource::myResourceType.name, resourceType );
		
		app.myTrxCA.trxCreateHMSResource(pxyResource, resource, app.myPassport);
		
		if app.myPassport.hasErrorsOrWarnings then
			return null;
		endif;
		
		if voyageStatus &lt;&gt; null then
			beginTransaction;
			voyageStatus.allHMSResourcesAllowed.addNoDuplicates( resource, false );
			voyageStatus.allHMSResourcesApproval.addNoDuplicates( resource, false );
			commitTransaction;
		endif;
		
		delete pxyResource;
		pxyResource := null;
	
	endforeach;
	
	return resource;

epilog

	abortTransaction;
	delete pxyResource;

end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_resourceTypeCode" type="String"/>
        <Parameter name="_howMany" type="Integer"/>
        <ReturnType type="HMS_Resource"/>
    </JadeMethod>
    <JadeMethod name="addHMSResourceToMovement" id="f3dcb2ff-e141-45d1-a428-03f92ff6e149">
        <source>addHMSResourceToMovement(_resourceType : HMS_ResourceType; _resource : HMS_Resource; _pxyVTMISTrans : HMS_VTMISTransaction;
						 _fromDateTime, _toDateTime : TimeStamp; _unitsUsed : Real; _poc : Boolean; _movement : HMS_VoyageMovement input);
// add an HMS resource used for the given resource, type and movement
vars
	pxyResourceUsed : HMS_ResourceUsed;
	proxyMovement	: HMS_VoyageMovement;
begin

	create pxyResourceUsed transient;
	pxyResourceUsed.setProxy(_movement.myHarbour, _resourceType, _resource, _pxyVTMISTrans, _fromDateTime, _toDateTime, _unitsUsed, _poc,null,null);
	create proxyMovement transient;
	pxyResourceUsed.setPropertyValue("myVoyageMovement", proxyMovement);	// just to keep the validation happy

	app.myTrxUA.trxAddHMSResourceUsed(pxyResourceUsed, _movement, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	delete pxyResourceUsed;
	delete proxyMovement;
end;</source>
        <Parameter name="_resourceType" type="HMS_ResourceType"/>
        <Parameter name="_resource" type="HMS_Resource"/>
        <Parameter name="_pxyVTMISTrans" type="HMS_VTMISTransaction"/>
        <Parameter name="_fromDateTime" type="TimeStamp"/>
        <Parameter name="_toDateTime" type="TimeStamp"/>
        <Parameter name="_unitsUsed" type="Real"/>
        <Parameter name="_poc" type="Boolean"/>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addHMSResourceType" id="5175753b-3059-48e5-b4e2-003969c7ea4d">
        <source>addHMSResourceType(_resourceTypeCode, _resourceTypeDesc, _units : String; _numberDecPlaces : Integer; _isQuantityRequired, _requiresActionDateTime, 
		_requiresFromToDateTime, _notAvailable, _isMarineService, _iconVisibleOnView : Boolean) : HMS_ResourceType;

/*

Purpose:		Create a HMS Resource	

Date			Who		Reason
31/01/2012		cnwmh5	Initial creation

*/

vars

	pxyHMSResourceType 			: HMS_ResourceType;
	resourceType				: HMS_ResourceType;

begin

	self.deleteHMSResourceType(_resourceTypeCode);

	create pxyHMSResourceType transient;
	pxyHMSResourceType.setProxy(app.myRoot);
	
	pxyHMSResourceType.setPropertyValue("code", _resourceTypeCode);
	pxyHMSResourceType.setPropertyValue("description", _resourceTypeDesc);
	pxyHMSResourceType.setPropertyValue("isQuantityRequired", _isQuantityRequired);
	pxyHMSResourceType.setPropertyValue("quantityUnits", _units);
	pxyHMSResourceType.setPropertyValue("numDecimalPlaces", _numberDecPlaces);
	pxyHMSResourceType.setPropertyValue("isActionDateTimeRequired", _requiresActionDateTime);
	pxyHMSResourceType.setPropertyValue("isFromToDateTimeRequired",_requiresFromToDateTime);
	pxyHMSResourceType.setPropertyValue("isNotAvailableForEntry", _notAvailable);
	pxyHMSResourceType.setPropertyValue("isMarineService", _isMarineService);
	pxyHMSResourceType.setPropertyValue("iconVisibleOnView", _iconVisibleOnView);

	app.myTrxCA.trxCreateHMSResourceType(pxyHMSResourceType, resourceType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return resourceType;
		
epilog

	delete pxyHMSResourceType;
	
end;</source>
        <Parameter name="_resourceTypeCode" type="String"/>
        <Parameter name="_resourceTypeDesc" type="String"/>
        <Parameter name="_units" type="String"/>
        <Parameter name="_numberDecPlaces" type="Integer"/>
        <Parameter name="_isQuantityRequired" type="Boolean"/>
        <Parameter name="_requiresActionDateTime" type="Boolean"/>
        <Parameter name="_requiresFromToDateTime" type="Boolean"/>
        <Parameter name="_notAvailable" type="Boolean"/>
        <Parameter name="_isMarineService" type="Boolean"/>
        <Parameter name="_iconVisibleOnView" type="Boolean"/>
        <ReturnType type="HMS_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="addHMSResourceTypeBasic" id="e74da56c-10ab-4747-a5c1-8d6ce37a5d56">
        <source>addHMSResourceTypeBasic( _resourceTypeCode : String ):HMS_ResourceType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2019	jlgndl1	Initial creation	TFS 44773

*/

vars

	pxyResourceType : HMS_ResourceType;
	resourceType : HMS_ResourceType;
	
	description : String;
	isQuantityRequired : Boolean;
	quantityUnits : String;
	numDecimalPlaces : Integer;
	isActionDateTimeRequired : Boolean;
	isFromToDateTimeRequired : Boolean;	
	isMarineService : Boolean;

begin

	description := _resourceTypeCode;
	
	if self.opts.includesKey(HMS_ResourceType::description.name) then
		description := self.opts.str(HMS_ResourceType::description.name);
	endif;	
	if self.opts.includesKey(HMS_ResourceType::isQuantityRequired.name) then
		isQuantityRequired := self.opts.bool(HMS_ResourceType::isQuantityRequired.name);
	endif;
	if self.opts.includesKey(HMS_ResourceType::quantityUnits.name) then
		quantityUnits := self.opts.str(HMS_ResourceType::quantityUnits.name);
	endif;
	if self.opts.includesKey(HMS_ResourceType::numDecimalPlaces.name) then
		numDecimalPlaces := self.opts.int(HMS_ResourceType::numDecimalPlaces.name);
	endif;
	if self.opts.includesKey(HMS_ResourceType::isActionDateTimeRequired.name) then
		isActionDateTimeRequired := self.opts.bool(HMS_ResourceType::isActionDateTimeRequired.name);
	endif;
	if self.opts.includesKey(HMS_ResourceType::isFromToDateTimeRequired.name) then
		isFromToDateTimeRequired := self.opts.bool(HMS_ResourceType::isFromToDateTimeRequired.name);
	endif;
	if self.opts.includesKey(HMS_ResourceType::isMarineService.name) then
		isMarineService := self.opts.bool(HMS_ResourceType::isMarineService.name);
	endif;

	create pxyResourceType transient;
	pxyResourceType.setProxy(app.myRoot);

	pxyResourceType.setPropertyValue( HMS_ResourceType::code.name, _resourceTypeCode );
	pxyResourceType.setPropertyValue( HMS_ResourceType::description.name, description );
	pxyResourceType.setPropertyValue( HMS_ResourceType::isQuantityRequired.name, isQuantityRequired );
	pxyResourceType.setPropertyValue( HMS_ResourceType::quantityUnits.name, quantityUnits );
	pxyResourceType.setPropertyValue( HMS_ResourceType::numDecimalPlaces.name, numDecimalPlaces );
	pxyResourceType.setPropertyValue( HMS_ResourceType::isActionDateTimeRequired.name, isActionDateTimeRequired );
	pxyResourceType.setPropertyValue( HMS_ResourceType::isFromToDateTimeRequired.name,isFromToDateTimeRequired );	
	pxyResourceType.setPropertyValue( HMS_ResourceType::isMarineService.name, isMarineService );
	
	app.myTrxCA.trxCreateHMSResourceType(pxyResourceType, resourceType, app.myPassport);
	
	return resourceType;
		
epilog

	delete pxyResourceType;
	
end;</source>
        <Parameter name="_resourceTypeCode" type="String"/>
        <ReturnType type="HMS_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="addHMSTug" id="3bc7256e-aa74-44ff-b7aa-b74dcf443c3f">
        <source>addHMSTug(_tugCode, _tugDesc : String; _harbour : HMS_Harbour) : HMS_Tug;

/*

Purpose:		Create a HMS Tug	

Date			Who		Reason
31/01/2012		cnwmh5	Initial creation

*/

vars

	pxyHMSTug 	: HMS_Tug;
	hmsObject	: HMS_Object;
	tug			: HMS_Tug;

begin

	self.deleteHMSTug(_tugCode);

	create pxyHMSTug transient;
	pxyHMSTug.setProxy(app.myRoot);
	
	pxyHMSTug.setPropertyValue("code", _tugCode);
	pxyHMSTug.setPropertyValue("description", _tugDesc);
	pxyHMSTug.setPropertyValue("myCurrentHarbour", _harbour);

	app.myTrxCA.trxCreateHMSObject(pxyHMSTug, hmsObject, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	tug := hmsObject.HMS_Tug;
	return tug;
		
epilog

	delete pxyHMSTug;
	
end;</source>
        <Parameter name="_tugCode" type="String"/>
        <Parameter name="_tugDesc" type="String"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <ReturnType type="HMS_Tug"/>
    </JadeMethod>
