    <JadeMethod name="backupExceptionHandler" id="ca136dec-f25c-4427-8d9f-311dd6defc1b">
        <updating/>
        <source>backupExceptionHandler(_ex:Exception) :Integer updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// ---------------------------------------------------------------------------
vars
	msg : String;
begin
	if _ex.errorCode = 3036 then
		msg := "3036 exception : db file not found";
		self.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.doDumpStack(_ex);
		self.setFailedNotify( "[" &amp; method.qualifiedName &amp; "] " &amp; msg );
		return Ex_Resume_Next;
	elseif _ex.errorCode = 3051 then		// Operation aborted by user request
		msg := "3051 exception : backup aborted by user";
		self.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.doDumpStack(_ex);
		self.setAbortNotify();
		return Ex_Pass_Back;
	elseif _ex.errorCode = 1066 then
		msg := "1066 exception : Notification not set for this OID";
		self.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.doDumpStack(_ex);
//		self.setFailedNotify();
		return Ex_Resume_Next;
	elseif _ex.errorCode = 1227 then
		msg := "1227 exception : backup notification receiver lost";
		self.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.doDumpStack(_ex);
//		self.setFailedNotify();
		return Ex_Resume_Next;
	elseif _ex.errorCode = 1400 then
		msg := "1400 exception : The receiver has already registered a timer with the specified tag";
		self.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.doDumpStack(_ex);
//		self.setFailedNotify();
		return Ex_Resume_Next;
	elseif _ex.errorCode = 1205 then
		msg := "1205 exception : Method aborted";
		self.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.doDumpStack(_ex);
		self.setFailedNotify("[" &amp; method.qualifiedName &amp; "] " &amp; msg);
		return Ex_Resume_Next;
	else
		if self.myBackupHistory &lt;&gt; null then
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
		endif;
		app.writeLog(_ex.errorCode.String&amp;' '&amp;_ex.extendedErrorText, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.doDumpStack(_ex);
		self.setFailedNotify("[" &amp; method.qualifiedName &amp; "] " &amp; _ex.errorCode.String&amp;' '&amp;_ex.extendedErrorText);
		if _ex.resumable then
			return Ex_Resume_Next;
		else
			return Ex_Abort_Action;
		endif;//		return Ex_Pass_Back;
	endif;
	if _ex.resumable then
		return Ex_Resume_Next;
	else
		self.setFailedNotify("[" &amp; method.qualifiedName &amp; "] " &amp; _ex.errorCode.String&amp;' '&amp;_ex.extendedErrorText);
		return Ex_Abort_Action;
	endif;//		return Ex_Pass_Back;
end;</source>
        <Parameter name="_ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="9cab3723-54ae-4a25-bce1-f8aa22a0996e">
        <updating/>
        <source>create() updating;
//
// CCMS1150 cnwrs1 04 July 2011
//
vars

begin
	app.writeLog(method.qualifiedName &amp; ' ' &amp; self.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	create self.myCnBackup transient;
end;
</source>
    </JadeMethod>
    <JadeMethod name="delete" id="fb66f9c1-dfb0-4f1e-a642-beea4b1caaf5">
        <updating/>
        <source>delete() updating;
//
//cnwrs1 ccms1150 04 July 2011
//
//06 Nov 2012	cnwrs1		Par 28355 - Notification exceptions
vars
	msg : String;
	isInvalid : Boolean;
begin
	app.writeLog(method.qualifiedName &amp; ' ' &amp; self.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	if self.myKCBackupProcess &lt;&gt; null then	//31 Oct 2012	cnwrs1	Par28355
		on Exception do app.handleDeletedObject(exception, self.myKCBackupProcess, isInvalid);
		msg := self.myKCBackupProcess.signOnTime.String;
		if not isInvalid then
			self.endNotificationForSubscriber(self.myKCBackupProcess);
		endif;
	endif;
	self.endNotificationForSubscriber(self);
	delete self.myCnBackup;
	app.myBackupAgentDB := null;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doBackup" id="3c643486-6b9e-4bfe-8d3f-eb1e090a7c5c">
        <updating/>
        <source>doBackup(_backupHistory : CM_BackupHistory; _firstTime : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// ---------------------------------------------------------------------------
// 
// This is called by the BGP Request to do the backup it is only caned on the platform that will do the actual backup
// the _firstTime parameter is set if this agent has just been created it is not set if the agent already exists sometimes the notification of CM_Backup.status to Actioned is lost and is picked up second time around
// NOTE: these methods run on both the SDS Primary and the SDS Secondary
//
//06 Nov 2012	cnwrs1		Par 28355 - add Destination to log Message
vars
	allDroppedFiles: DbFileArray;
	messageTitle: String;
	taskMessage: String;
	dbFileObj: DbFile;
	completed: Boolean;
	allFiles: DbFileArray;
	dbf: DbFile;
	header : String;
	msg: String;
	backup: CM_Backup;
	errorNumber : Integer;
	errorText 	: String;
	isInvalid : Boolean;
begin
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	if self.myKCBackupProcess &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, self.myKCBackupProcess, isInvalid);	// CCMS1150 cnwrs1 04 July 2011
		msg := self.myKCBackupProcess.signOnTime.String;
		if isInvalid then
			self.myKCBackupProcess := null;
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' backup was running but will reset it.', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		else
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' backup already running will leave it running.', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			return;
		endif;
	endif;
	if _firstTime then
		on Exception do self.backupExceptionHandler(exception) global;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' beginTimer EVENT_Backup_TimerCheck', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.beginTimer(6000, Timer_OneShot, EVENT_Backup_TimerCheck);
	endif;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' beginNotifications', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	self.beginNotification(system, NotifyBackupAbort, Response_Continuous, 0);
	self.beginNotification(system, NotifyBackupComplete, Response_Continuous, 0);
	self.beginNotification(system, NotifyBackupFailed, Response_Continuous, 0);
	self.beginNotification(system, NotifyBackupStartup, Response_Continuous, 0);
	self.beginNotification(system, NotifyCreateRaiseAlert, Response_Continuous, 0);
	self.beginNotification(system, NotifyBackupSetHistoryStatus, Response_Continuous, 0);
	self.beginNotification(system, NotifyBackupSetStatus, Response_Continuous, 0);
	self.beginNotification(system, NotifyBackupTerminated, Response_Continuous, 0);
	self.beginNotification(system, NotifyBackupRestarted, Response_Continuous, 0);
	backup := app.myRoot.myBackup;
	self.startTime := app.actualTimeServer;
	if _backupHistory &lt;&gt; null then
		self.myBackupHistory := _backupHistory;
	endif;
	
	
	
	if not self.isValidToBackup then
		msg := "Database backup started at "&amp;self.startTime.String&amp;" has failed. Backup not licenced.";
		header := "Database Backup Failed";
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;' '&amp;header&amp;' '&amp;msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.raiseAlertNotify(header, msg, SEVERE_ERROR);
		self.setFailedNotify( "[" &amp; method.qualifiedName &amp; "] " &amp; msg );
		return;
	endif;
	// if backup is not setup dont do anything
	if app.myRoot.myBackup = null then
		msg := "Database backup started at "&amp;self.startTime.String&amp;" has failed. Backup not setup.";
		header := "Database Backup Failed";
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;' '&amp;header&amp;' '&amp;msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.raiseAlertNotify(header, msg, SEVERE_ERROR);
		self.setFailedNotify( "[" &amp; method.qualifiedName &amp; "] " &amp; msg );
		return;
	endif;
	
	//12 Jan 2016	NDL	Par 37296
	if not verifyNoWorkingFileCreateHtm() then
		//either checks and finds its good to go and creates a file warning others off
		// or bails and logs an appropriate message etc.
		return;
	endif;
	
	if backup.status &lt;&gt; BackupStatus_Idle and 
	   backup.status &lt;&gt; BackupStatus_Actioned and 
	   backup.status &lt;&gt; BackupStatus_Processing and
	   backup.status &lt;&gt; BackupStatus_Restarted then	// must be in restart mode
		msg := "Database backup started at "&amp;self.startTime.String&amp;" has failed. Backup is currently busy.";
		header := "Database Backup Failed";
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;' '&amp;header&amp;' '&amp;msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.raiseAlertNotify(header, msg, SEVERE_ERROR);
		self.setFailedNotify( "[" &amp; method.qualifiedName &amp; "] " &amp; msg );
		return;
	endif;
	if self.myKCBackupProcess &lt;&gt; null then
		msg := "Database backup started at "&amp;self.startTime.String&amp;" is currently busy.";
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;' '&amp;header&amp;' '&amp;msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return;
	endif;
	if (backup.sdsSecondaryBackup and app.isSDSSecondaryDB) or
	   (not backup.sdsSecondaryBackup and not app.isSDSSecondaryDB) then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;' setOffKCBackupM to '&amp;backup.dbBackupPath, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		create self.myFolder transient;
		self.myFolder.fileName := backup.dbBackupPath;
		if not self.myFolder.isAvailable then
			self.myFolder.make;
		endif;
		self.setOffKCBackupM();
	endif;
epilog
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' epilog', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	delete self.myFolder;
end;</source>
        <Parameter name="_backupHistory" type="CM_BackupHistory"/>
        <Parameter name="_firstTime" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="ehNullOrInvalidObjectRefAbort" id="9bb32505-52a1-455c-bade-5001f1ad72f9">
        <source>ehNullOrInvalidObjectRefAbort(_exObj : Exception; _obj : Object; _error : Boolean output) : Integer;
//
// CCMS1150 cnwrs1 04 July 2011
//
vars

begin
	if _obj = null then
		if _exObj.errorCode = Cn_ObjectNotFound or							// 4
		   _exObj.errorCode = Cn_AttemptedAccessViaNullRef  then			// value 1090
			_error := true;
			abortTransaction;
			abortTransientTransaction;
			return Ex_Resume_Next;
		endif;
	
		return Ex_Pass_Back;
	endif;
	
	// if pObj specified, we're only interested if we've got a 4 or 1090 on the specified object
	if (_exObj.errorCode = Cn_ObjectNotFound  or _exObj.errorCode = Cn_AttemptedAccessViaNullRef) and	// 4 or 1090
		_exObj.errorObject() = _obj then
		_error := true;
		abortTransaction;
		abortTransientTransaction;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;
end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_error" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eventTypeToDisplay" id="0c9a34ad-5037-45ce-8b1c-1e6e36334405">
        <source>eventTypeToDisplay(_eventType : Integer) : String;
//
// this is just for reported the eventType as a string rather than a number
//
vars

begin
	if _eventType = NotifyBackupAbort then
		return " NotifyBackupAbort";
	elseif _eventType = NotifyBackupComplete then
		return " NotifyBackupComplete";
	elseif _eventType = NotifyBackupFailed then
		return " NotifyBackupFailed";
	elseif _eventType = NotifyBackupRestarted then
		return "NotifyBackupRestarted";
	elseif _eventType = NotifyBackupSetHistoryStatus then
		return " NotifyBackupSetHistoryStatus";
	elseif _eventType = NotifyBackupSetStatus then
		return " NotifyBackupSetStatus";
	elseif _eventType = NotifyBackupStartup then
		return " NotifyBackupStartup";
	elseif _eventType = NotifyBackupTerminated then
		return " NotifyBackupTerminated";
	elseif _eventType = NotifyCreateRaiseAlert then
		return " NotifyCreateRaiseAlert";
	else
		return _eventType.String;
	endif;
end;
</source>
        <Parameter name="_eventType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidToBackup" id="cdd78b9f-03bc-46d1-a5df-232aa0e555cb">
        <source>isValidToBackup():Boolean protected;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

// this looks to be redundant

vars
	result: Boolean;
begin
	result := false;
	if not inheritMethod() then
		return result;
	endif;
	//par 24446 cnwrs1 16 June 2010 JMTbackup does not need to check SDS settings
/*	if not self.myDBA.sdsIsInitialized then
		result := true;
		return result;
	endif;
	if not self.myDBA.sdsIsRunning then
		result := true;
		return result;
	endif;
//sds is up and running only backup if you are the secondary
	if self.myDBA.sdsGetDatabaseRole = SDS_PrimaryType then
		result := false;
		return result;
	endif;*/
	result := true;
epilog
	return result;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="purgeSDSJournals" id="64af6982-3091-491e-b673-33ddae883e56">
        <updating/>
        <source>purgeSDSJournals(_status : Integer io) updating;
//
// this will purge the SDS journals as necassary. The Journal purge is normally run by the Journal Backup but that doesnot run on the SDS Secondary so that job is done by the SDS Secondary backup when needed.
// NOTE: if there is a SDS SEcondary and the backup is done on the primary this cant delete the old secondary journals
//
//14 Mar 2014	cnwrs1	Par 30577 cleanup acn files in remote backup directories
vars
	msg : String;
	backup : CM_Backup;
begin
	backup := app.myRoot.myBackup;
	create self.myFolder transient;
	if (backup.sdsSecondaryBackup and app.isSDSSecondaryDB) or
	   (not backup.sdsSecondaryBackup and not app.isSDSSecondaryDB) then
		self.myFolder.fileName := backup.dbBackupPath;
		if backup.dbRemoteBackupPath &lt;&gt; null then
			if not self.myFolder.copy(backup.dbRemoteBackupPath, false, true, false) then
				msg :=  "Remote database backup copy to "&amp;backup.dbRemoteBackupPath&amp;" failed."; 
				_status := BackupStatus_Failed;
			endif;
		endif;
	endif;
	if app.isSDSSecondaryDB then
		if backup.purgeRemoteJournals then
			msg := ' Purging SDS journal files older than ('&amp;backup.purgeJournalDays.String&amp;')';
			self.writeLog(class.name&amp;'::'&amp;method.name&amp;" "&amp;msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			if self.myDBA = null then
				create self.myDBA transient;
			endif;
			self.myFolder.fileName := self.myDBA.getCurrentJournalDirectory;
			self.myFolder.mask := "*.log";						//Just the journal files !
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' purging '&amp;self.myFolder.mask&amp;' from '&amp;self.myFolder.fileName, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			self.purgeFolderJournalFiles("SDS journal file");	
			self.myFolder.mask := "*.scan";						//Just the journal verify files !
			self.purgeFolderJournalFiles("SDS database journal verify file");	
		endif;
	endif;
epilog
	delete self.myFolder;
end;
</source>
        <Parameter name="_status" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="raiseAlertNotify" id="425f8b4f-5d93-43e1-9c05-d4e79072ba27">
        <source>raiseAlertNotify(_shortMsg, _longMsg: String; _severity: Integer);
//
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
//
vars
	alert: CM_SystemAlert;
	msg : String;
begin
	msg := 'Backup Alert - '&amp;_shortMsg&amp;' ('&amp;_longMsg&amp;')';
	self.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	create alert transient;
	alert.details := _shortMsg;
	alert.setSeverity(_severity);
//	alert.addLogEntry(_shortMsg);
	alert.addLogEntry(_longMsg);
//	alert.add;
	if app.isSDSSecondaryDB then // CCMS1150 cnwrs1 16 June 2011
		system.sdsCauseEvent(NotifyCreateRaiseAlert, true, alert);
	else
		system.causeEvent(NotifyCreateRaiseAlert, true, alert);
	endif;
	
end;
</source>
        <Parameter name="_shortMsg" type="String"/>
        <Parameter name="_longMsg" type="String"/>
        <Parameter name="_severity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setAbortNotify" id="b4b2f295-bb76-44a5-a528-c8c627376f28">
        <updating/>
        <source>setAbortNotify() updating;
//
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
//
vars

begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;NotifyBackupAbort.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	if app.isSDSSecondaryDB then // CCMS1150 cnwrs1 16 June 2011
		system.sdsCauseEvent(NotifyBackupAbort, true, null);
		system.causeEvent(NotifyBackupAbort, true, null);
//		self.wrapUpBackup(BackupStatus_Abort, app.myRoot.myBackup);
	else
		system.causeEvent(NotifyBackupAbort, true, null);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setCompleteNotify" id="43d8ed1a-00ac-4254-95d7-d5509c903711">
        <updating/>
        <source>setCompleteNotify() updating;
//
// 04 July 2011	cmwrs1		CCMS1150 - when the backup has been complete do an intail wrapup
//
vars
	status : Integer;
begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;NotifyBackupComplete.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	if app.isSDSSecondaryDB then // CCMS1150 cnwrs1 16 June 2011
/*		if self.myBGPBackupRequest &lt;&gt; null then
			// if we find the Primary has an incorrect secondary process then update it
			if self.myBGPBackupRequest.myProcessingController &lt;&gt; null and 
			   process &lt;&gt; self.myBGPBackupRequest.myProcessingController.mySDSSecondaryProcess then
				self.myBGPBackupRequest.myProcessingController.sdsCauseEvent(BGP_Object.BGP_SDSSecondaryProcess, true, process);	// 11 July 2011	cmwrs1		CCMS1150 - backup sds notification
			endif;
		endif;*/
		status := BackupStatus_Completed;
		self.purgeSDSJournals(status);
		system.sdsCauseEvent(NotifyBackupComplete, true, null);
		self.wrapUpBackup(status, app.myRoot.myBackup, null);
	else
		system.causeEvent(NotifyBackupComplete, true, null);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setFailedNotify" id="c04b6f7a-d604-47dd-a401-07e103bfd99a">
        <updating/>
        <source>setFailedNotify( _extraInfo : String ) updating;
//
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// 13 Jan 2016	NDL	Par 37296- Added _extraInfo
//
vars

begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;NotifyBackupFailed.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	if app.isSDSSecondaryDB then // CCMS1150 cnwrs1 16 June 2011
		system.sdsCauseEvent(NotifyBackupFailed, true, _extraInfo);
		system.causeEvent(NotifyBackupFailed, true, _extraInfo);
//		self.wrapUpBackup(BackupStatus_Failed, app.myRoot.myBackup);
	else
		system.causeEvent(NotifyBackupFailed, true, _extraInfo);
	endif;
end;</source>
        <Parameter name="_extraInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="setHistoryStatusNotify" id="e05d2ccd-404b-4594-9ded-4ae748fde67c">
        <source>setHistoryStatusNotify(_status : Integer);
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23 Jule 2011	cmwrs1		CCMS1150 - backup sds notification
// ---------------------------------------------------------------------------

vars
//	str : String;
begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_status.String&amp;' '&amp;NotifyBackupSetHistoryStatus.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	if app.isSDSSecondaryDB then // CCMS1150 cnwrs1 16 June 2011
		system.sdsCauseEvent(NotifyBackupSetHistoryStatus, true, _status);
	else
		system.causeEvent(NotifyBackupSetHistoryStatus, true, _status);
	endif;
end;

</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setOffKCBackupM" id="ab26ba91-d2b4-4890-8875-f4e4faad551a">
        <updating/>
        <source>setOffKCBackupM() protected, updating;
//
// cnwrs1 ccms1150 04 July 2011 run KCBackupMulti see also BackupTest Schema in CardSchema sample
// navkc1 TFS #52310 07/10/2022 Set "DisableBackupNotification=false" in the ini file.
vars
//	exceededLicence: Boolean;
//	badObject : Boolean;
//	proc : Process;
//	x : Integer;
	hsa	: HugeStringArray;
	cnBackup	: CnBackup;
	tsNow		: TimeStamp;
	iniFileName,	
	disableBackupNotify	: String;
	
begin
	app.writeLog(class.name&amp;'::'&amp;method.name, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	self.setStartupNotify();
	create cnBackup transient;
	self.myCnBackup := cnBackup;
	beginNotification(system, Cn_Backup_Progress_Update, Response_Continuous, 0);	// wait continuous for progress updates
	beginNotification(system, Cn_Backup_Status_Change,   Response_Continuous, 0);	// wait continuous for status change
	beginTransientTransaction;
	create hsa sharedTransient;
	hsa.add("environmentId="&amp;app.myCnKarmaCntrl.environmentId);
	hsa.add("backupDirectory="&amp;app.myRoot.myBackup.dbBackupPath);
	hsa.add("backupWorkers="&amp;app.myRoot.myBackup.databaseWorkers.String);
	hsa.add("compressFiles="&amp;app.myRoot.myBackup.dbCompress.String);	// CCMS1150 cnwrs1 16 June 2011
	hsa.add("quiesce=false");
	commitTransientTransaction;
	
	// 07/10/2022	navkc1	#52310 starts
	if not app.isInternalEnvironment(false) then
		iniFileName			:= app.getIniFileNameAppServer();
		disableBackupNotify	:= app.getProfileStringAppServer(iniFileName, CN_KCDATABASEBACKUP, CN_DISABLEBACKUPNOTIFICATIONS, null);
		
		// If this is true, that means we are not sending notifications when the backup status is changed.
		// We need the notifications otherwise we won't know what's the progress of the backup or if the backup is completed
		if disableBackupNotify = true.String then
			disableBackupNotify := false.String;
			app.setProfileStringAppServer(iniFileName, CN_KCDATABASEBACKUP, CN_DISABLEBACKUPNOTIFICATIONS, disableBackupNotify);
		endif;
	endif;
	// 07/10/2022	navkc1	#52310 ends
	
	self.myKCBackupProcess := app.startApplicationWithParameter("CardSchema", "KCDatabaseBackupMulti", hsa);
	if self.myKCBackupProcess = null then
		self.setFailedNotify("[" &amp; method.qualifiedName &amp; "] KCDatabaseBackupMulti failed to start");
	endif;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setStartupNotify" id="35e498aa-810c-47a3-94a3-249a606e23f9">
        <source>setStartupNotify();
//
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
//
vars

begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;NotifyBackupStartup.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	if app.isSDSSecondaryDB then // CCMS1150 cnwrs1 16 June 2011
		if self.myBGPBackupRequest &lt;&gt; null then
			// if we find the Primary has an incorrect secondary process then update it
			if self.myBGPBackupRequest.myProcessingController &lt;&gt; null and 
			   process &lt;&gt; self.myBGPBackupRequest.myProcessingController.mySDSSecondaryProcess then
				self.myBGPBackupRequest.myProcessingController.sdsCauseEvent(BGP_Object.BGP_SDSSecondaryProcess, true, process);	// 11 July 2011	cmwrs1		CCMS1150 - backup sds notification
			endif;
		endif;
		system.sdsCauseEvent(NotifyBackupStartup, true, null);
	else
		system.causeEvent(NotifyBackupStartup, true, null);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setStatusNotify" id="c76d4730-bdff-4e96-a4d5-f820d593ce6a">
        <source>setStatusNotify(_status : Integer);
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification
// ---------------------------------------------------------------------------

vars

begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;NotifyBackupSetStatus.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
//	str := "backup status notify was="&amp;self.displayStatus;
	if app.isSDSSecondaryDB then // CCMS1150 cnwrs1 16 June 2011
		system.sdsCauseEvent(NotifyBackupSetStatus, true, _status);
	else
		system.causeEvent(NotifyBackupSetStatus, true, _status);
	endif;
end;
</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="944980f0-7f9d-423e-be3b-580694938cbb">
        <updating/>
        <source>timerEvent(_eventTag: Integer) updating;
//
// cnwrs1 ccms1150 04 July 2011 we use this to see if KCBackup is still running
//
vars
	dateTime : TimeStamp;
	restartTime : Integer;
	timeStamp : TimeStamp;
	header : String;
	msg : String;
	isInvalid : Boolean;
begin
	restartTime := 120000;	//2 mins
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' eventTag='&amp;_eventTag.String, 0);	//25 Nov 2019	NDL	TFS 47053

	on Exception do backupExceptionHandler(exception);
	// this is called if the doBackup has been called twice 
	if _eventTag = EVENT_Backup_TimerCheck then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' EVENT_Backup_TimerCheck', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

		if app.myRoot.myBackup.status = BackupStatus_Abort then
			self.setAbortNotify();
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' BackupStatus_Abort '&amp;app.isSDSSecondaryDB.String&amp;' '&amp;app.myRoot.myBackup.sdsSecondaryBackup.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			return;
		endif;	
		if self.myKCBackupProcess &lt;&gt; null then 
			on Exception do app.handleDeletedObject(exception, self.myKCBackupProcess, isInvalid);
			dateTime := self.myKCBackupProcess.signOnTime;
			if isInvalid then
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;' myKCBackupProcess is invalid '&amp;self.myBGPBackupRequest.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
				if (app.isSDSSecondaryDB and app.myRoot.myBackup.sdsSecondaryBackup) or
				   (not app.isSDSSecondaryDB and not app.myRoot.myBackup.sdsSecondaryBackup) then
					self.setFailedNotify( "[" &amp; method.qualifiedName &amp; "] myKCBackupProcess has been deleted" );
				endif;
				return;
			endif;
		endif;
		if self.myBGPBackupRequest &lt;&gt; null then 
			on Exception do app.handleDeletedObject(exception, self.myBGPBackupRequest, isInvalid);
			dateTime := self.myBGPBackupRequest.processingStartTime;
			if isInvalid then
				app.writeLog(class.name&amp;'::'&amp;method.name&amp;' myBGPBackupRequest is invalid '&amp;self.myBGPBackupRequest.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
				if (app.isSDSSecondaryDB and app.myRoot.myBackup.sdsSecondaryBackup) or
				   (not app.isSDSSecondaryDB and not app.myRoot.myBackup.sdsSecondaryBackup) then
					self.setAbortNotify();
				endif;
				return;
			endif;
		endif;
		if self.myBGPBackupRequest = null and	// we are in abit of a mess the timer should have been terminated under these conditions, this may not work as it may be wrapUpBackup that has failed.
		   self.myKCBackupProcess = null and
		   app.myRoot.myBackup.status = BackupStatus_Idle and
		   not app.isSDSSecondaryDB then
			abortTransaction;
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' all seems to be finished but timer still running '&amp;app.isSDSSecondaryDB.String&amp;' '&amp; app.myRoot.myBackup.sdsSecondaryBackup.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			self.setFailedNotify( "[" &amp; method.qualifiedName &amp; "] Status Idle, but backup running!" );
			return;
		endif;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' beginTimer EVENT_Backup_TimerCheck', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.beginTimer(restartTime, Timer_OneShot, EVENT_Backup_TimerCheck);
	// this timer is only called if wrapup fails to reset the system
	elseif _eventTag = EVENT_Backup_TimerReset then
		on Exception do app.handleDeletedObject(exception, self.myBGPBackupRequest, isInvalid);	// CCMS1150 cnwrs1 04 July 2011
		msg := self.myBGPBackupRequest.createdDateTime.String;
		if not isInvalid and
		   self.myBGPBackupRequest &lt;&gt; null and
		   self.myBGPBackupRequest.myProcessingController &lt;&gt; null then
			self.aborted := true;
			app.myTrxUA.trxUpdateBGPBackupReset(app.myRoot.myBackup, self.myBGPBackupRequest.myProcessingController);
		endif;
	endif;
end;
</source>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unMarkOurTerritory" id="0bddb3d5-1d56-48e2-99d6-d962821ef5e1">
        <source>unMarkOurTerritory();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2016	cnwndl1	Initial creation	Par 37296

								If we set up a file to warn others off, then we need to clean it up...  So they can have their turn.

*/

vars

	miscPath : String;
	ourBackupFile:File;
	checkValue : String;
	length : Integer;
	
	firstLine : String;

begin

	miscPath := app.cnGetServerMiscPath;
	
	//If we get to here there is nothing in the way of us backing up, so create a file to warn off others...
	
	create ourBackupFile transient;
	ourBackupFile.usePresentationFileSystem := false;
	ourBackupFile.fileName := miscPath &amp; "\" &amp; BackupInProgress;
	ourBackupFile.mode := File.Mode_Input;
	ourBackupFile.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	
	if ourBackupFile.tryOpen then
		firstLine := ourBackupFile.readLine();
		checkValue := self.String &amp; " " &amp; self.startTime.String;
		length := checkValue.length;
		if firstLine.length &gt;= length and firstLine[1:length] = checkValue then
			//its our file
			ourBackupFile.purge;
		else
			ourBackupFile.close;
		endif;
		
	endif;
	

epilog

	delete ourBackupFile;

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="bc3a5489-36ec-418f-8fbc-e220ae3b2b1e">
        <updating/>
        <source>userNotification(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;
//
// CCMS1150 cnwrs1 04 July 2011
//
vars

begin
	if _eventType &gt;= NotifyMin and _eventType &lt;= NotifyMax then
		// these are the notifications for control of the BGP control processes
		self.userNotificationControl(_eventType, _theObject, _eventTag, _userInfo);
	elseif _eventType &gt; Cn_Joss_Emergency_Alert and _eventType &lt; Cn_Unhandled_Exception then
		// these are the notifications for KCBackupMulti
		self.userNotificationCnBackup(_eventType, _theObject, _eventTag, _userInfo);
	else
	endif;
epilog

end;

</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationCnBackup" id="2a1f820c-72c2-4447-8371-7c7beb7afe77">
        <updating/>
        <source>userNotificationCnBackup(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;
// 23 Jule 2011	cmwrs1		CCMS1150 - backup sds notification

vars
//	cc : CnCntrl;
	cnBackup : CnBackup;
	notFound : Boolean;
	nonDbFileNameArray	: CnStringArray;
	nonDbFileSizeArray	: Integer64Array;
	str : String;
	phase : String;
	fileName : String;
	errorText : String;
	statusText : String;
	adviceType : String;
	mapFileName : String;
	droppedFile : String;
	header : String;
	msg : String;
	tsNow : TimeStamp;
	timeStamp : TimeStamp;
	fileSize : Integer64;
	totalSize : Integer64;
	int : Integer;
	indx : Integer;
	startLog : Integer;
	endLog : Integer;
	workerId : Integer;
	progress : Integer;
//	rowIndex,
	statusTag : Integer;

begin

	cnBackup := self.myCnBackup;
//	cc := app.myCnCntrl;
	self.receivedAdvice := true;
	on SystemException do self.ehNullOrInvalidObjectRefAbort(exception, cnBackup, notFound);
	cnBackup.edition();
	if notFound then
		return;
	endif;
	create nonDbFileNameArray transient;
	create nonDbFileSizeArray transient;
	cnBackup.interpretBackupInfo(	_eventType,			// the event type parsed into this userNotify method, just pass it on
									_userInfo.Binary,	// the userInfo parsed into this userNotify method, just pass it on
									adviceType,			// the returned adviceType, we use this determine the status of the backup worker threads
									timeStamp,			// the returned timestamp of when the update was recieved
									fileName,			// the returned filename the current worker is backing up, also used for non-db file backups 
									fileSize,			// the returned filesize of the current file being backed up
									totalSize,			// the returned totalSize to be backed up value - note this is the db totalsize. when the backup completes this param will contain the totalsize of the entire backup.
									progress,			// the returned progress value for use in progress bars, logging etc.
									errorText,			// the returned string of any errors that occurred during the backup process
									startLog,			// the returned integer of the first journal to be backed up
									endLog,				// the returned integer of the last journal to be backed up - note all journals between startLog and endLog as backed up also 
									workerId,			// the returned process id of the current backup worker thread
									phase,				// the returned phase the backup worker is in
									
									// ##############################################################################################################################
									// ## the following params are for non-database files only, i.e.: anything outside what we would normally refer to as 'system' ##
									// ##																														   ##	
									// ## 				 note that nonDbFileNameArray and nonDbFileSizeArray needed to be created as transients					   ##	
									// ##############################################################################################################################
									
									nonDbFileNameArray,	// non-db backup notifications are staggered to avoid extensive notifications, this returned array contains filenames backed up during that period since the last notification
									nonDbFileSizeArray, // non-db backup notifications are staggered to avoid extensive notifications, this returned array contains filesizes for each filename in the previous array
									statusTag,			// the returned statusTag, we use this to determine the status of the non-db files backup
									statusText);		// the returned statusText, we use this to display information about the non-db files backup status
	
	if _eventType = Cn_Backup_Progress_Update then
		// ### BACKUP IS ACTIVE ###
		if adviceType = CnMessage.Advice_Type_Backup_Starting then
			foreach mapFileName in cnBackup.mapFileNames do
				int := int + 1;
			endforeach;
			return;
		// ### BACKUP HAS FAILED ###
		elseif adviceType = CnMessage.Advice_Type_Backup_Failed then
			self.setFailedNotify( "[" &amp; method.qualifiedName &amp; "] " &amp; errorText );
		// ## BACKUP HAS COMPLETED SUCCESSFULLY ###
		elseif adviceType = CnMessage.Advice_Type_Backup_CompletedOK then
			self.setCompleteNotify();
		elseif adviceType = CnMessage.Advice_Type_Backup_Cancel_OK then
			self.setAbortNotify();
			return;
		endif;

		if phase = "S" then																					// backup worker is starting to backup a new mapfile
			phase := "starting";
//			self.setStartupNotify();
		elseif phase = "B" then
			phase := "backup";
		elseif phase = "V" then
			phase := "verify";
		elseif phase = "C" then																					// current filename has finished backing up
			phase := "completed";
		elseif phase = "T" then																					// backup worker has terminated
			phase := "finished";
		endif;
																											// update the table to reflect each workers progress
	elseif _eventType = Cn_Backup_Status_Change then
// these eventTypes are only raised during the non-db file backup stage
		if statusTag = Cn_Backup_Workers_Complete then
		elseif statusTag = Cn_Backup_Journal_Start then
			foreach str in nonDbFileNameArray do
			endforeach;
		elseif statusTag = Cn_Backup_NonDbFile_Start then
			foreach str in nonDbFileNameArray do
				indx := indx + 1;
			endforeach;
		elseif statusTag = Cn_Backup_Complete then
			self.setCompleteNotify;
			return;
		elseif statusTag = Cn_Backup_Failed then
			self.setFailedNotify( "[" &amp; method.qualifiedName &amp; "] " &amp; errorText );
			return;
		elseif statusTag = Cn_Backup_Inclusions then
			foreach str in nonDbFileNameArray do
			endforeach;
		endif;
	elseif _eventType = NotifyBackupTerminated then
		self.setAbortNotify;
		return;
	endif;
epilog
	delete nonDbFileNameArray;
	delete nonDbFileSizeArray;
end;
</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="userNotificationControl" id="b8383242-162f-4f0d-ae3f-af94b1092b10">
        <updating/>
        <source>userNotificationControl(_eventType: Integer; _theObject: Object; _eventTag: Integer; _userInfo: Any) updating;
// 04 July 2011	cmwrs1		CCMS1150 - backup sds notification

vars
	backup : CM_Backup;
	alert : CM_SystemAlert;
	timeStamp : TimeStamp;
	header : String;
	msg : String;
	extraInfo : String;
begin
	if _eventType = NotifyBackupFailed and _userInfo &lt;&gt; null and _userInfo.isKindOf(String) then	//13 Jan 2016	NDL	Par 37296
		extraInfo := _userInfo.String.trimBlanks;
	endif;
	backup := app.myRoot.myBackup;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' eventType='&amp;_eventType.String&amp;self.eventTypeToDisplay(_eventType)&amp;' userInfo='&amp;_userInfo.String&amp;' backup='&amp;backup.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	if _eventType = NotifyBackupSetStatus then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;'Setting status to '&amp;_userInfo.String&amp;' for '&amp;backup.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		if backup &lt;&gt; null and
		   global.isValidObject(backup) then
			app.myTrxUA.trxUpdateBGPBackupStatus(backup, _userInfo.Integer);
		else
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;" Received a "&amp;_eventType.String&amp;" event for a backup entry that no longer exists. "&amp;backup.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		endif;
		return;
	elseif _eventType = NotifyBackupSetHistoryStatus then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;'Setting history status to '&amp;_userInfo.String&amp;' for '&amp;self.myBackupHistory.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		if self.myBackupHistory &lt;&gt; null and
		   global.isValidObject(backup) then
			app.myTrxUA.trxUpdateBGPBackupHistStatus(self.myBackupHistory, _userInfo.Integer);
		else
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;" Received a "&amp;_eventType.String&amp;" event for a backup history entry that no longer exists. "&amp;self.myBackupHistory.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		endif;
		return;
	elseif _eventType = NotifyBackupFailed then
		self.wrapUpBackup(BackupStatus_Failed, backup, extraInfo);
		return;
	elseif _eventType = NotifyBackupRestarted then
		self.wrapUpBackup(BackupStatus_Restarted, backup, null);
		return;
	elseif _eventType = NotifyBackupAbort then
		self.wrapUpBackup(BackupStatus_Abort, backup, null);
		return;
	elseif _eventType = NotifyCreateRaiseAlert then
		alert := _userInfo.CM_SystemAlert;	//not working as yet _userinfo has been deletd
		if global.isValidObject(alert) then
			alert.add;
			app.commitAlert();
		else
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp; " NotifyCreateRaiseAlert alert invalid "&amp;alert.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		endif;
	elseif _eventType = NotifyBackupComplete then
		self.wrapUpBackup(BackupStatus_Completed, backup, null);
	elseif _eventType = NotifyBackupStartup then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;'do startup notify '&amp;self.myBackupHistory.String&amp;' '&amp;backup.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		app.myTrxUA.trxUpdateBGPBackupStatus(backup, BackupStatus_Processing);
		app.myTrxUA.trxUpdateBGPBackupHistStatus(self.myBackupHistory, BackupStatus_Processing);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp; " Unknown eventType "&amp;_userInfo.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	endif;
end;
</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="verifyNoWorkingFileCreateHtm" id="56fe4b71-ebf7-4e9d-ac58-43edbb970d73">
        <updating/>
        <source>verifyNoWorkingFileCreateHtm():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/01/2016	cnwndl1	Initial creation	Par 37296

						Don't want to run over the top of a Central OPS deploy and/or backups.

						Either checks and finds its good to go and creates a file warning others off
						Or bails and logs an appropriate message etc.
08/03/2016	cnwdap1	PAR #37597 If the misc folder doesn't exist, create it
*/

vars

	miscPath : String;
	deployFile : File;
	otherBackupFile : File;
	ourBackupFile:File;
	
	msg : String;
	header : String;
	firstLine : String;
	length : Integer;
	
	miscFolder : FileFolder;							// PAR #37597

begin

	miscPath := app.cnGetServerMiscPath;
	// PAR #37597 Does the misc directory exist?
	create miscFolder transient;
	miscFolder.usePresentationFileSystem := false;
	if miscFolder.isValidPathName(miscPath) then
		miscFolder.fileName := miscPath;
		if not miscFolder.isAvailable then
			miscFolder.make();
		endif;
		if not miscFolder.isAvailable then
			msg := "Misc folder " &amp; miscPath &amp; " unable to be created - no backup sentinel file created.";
			header := "Database Backup Sentinal File " &amp; BackupInProgress &amp; " Not Created";
			app.writeLog(class.name &amp; "::" &amp; method.name &amp; Space &amp; header &amp; Space &amp; msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			// still allow backup to continue......
			return true;
		endif;
	else
		msg := "Misc folder " &amp; miscPath &amp; " is not a valid folder name";
		header := "Database Backup - Misc Folder Invalid";
		app.writeLog(class.name &amp; "::" &amp; method.name &amp; Space &amp; header &amp; Space &amp; msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		// still allow backup to continue......
		return true;
	endif;
	// End of PAR #37597
	
	create deployFile transient;
	deployFile.usePresentationFileSystem := false;
	deployFile.fileName := miscPath &amp; "\" &amp; DeployInProgress;
	deployFile.mode := File.Mode_Input;
	deployFile.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	
	if deployFile.isAvailable then
		deployFile.close;
		msg := "Database backup started at "&amp;self.startTime.String&amp;" has failed, because a deploy is currently running.";
		header := "Database Backup Failed";
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;' '&amp;header&amp;' '&amp;msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.raiseAlertNotify(header, msg, SEVERE_ERROR);
		self.setFailedNotify( "[" &amp; method.qualifiedName &amp; "] " &amp; msg );
		return false;
	endif;
	
	
	create otherBackupFile transient;
	otherBackupFile.usePresentationFileSystem := false;
	otherBackupFile.fileName := miscPath &amp; "\" &amp; BackupInProgress;
	otherBackupFile.mode := File.Mode_Input;
	otherBackupFile.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	
	if otherBackupFile.isAvailable then
		
		msg := "Database backup started at "&amp;self.startTime.String&amp;" has failed, because a 'deploy related backup' is currently running.";
		header := "Database Backup Failed";
		
		if otherBackupFile.tryOpen then
			firstLine := otherBackupFile.readLine();
			if firstLine.length &gt; 9 and firstLine[1:9] = "CM_Backup" then
				msg := "Database backup started at "&amp;self.startTime.String&amp;" has failed, because a 'JMT backup' is already running.";
			endif;
		endif;
		otherBackupFile.close;
		
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;' '&amp;header&amp;' '&amp;msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.raiseAlertNotify(header, msg, SEVERE_ERROR);
		self.setFailedNotify( "[" &amp; method.qualifiedName &amp; "] " &amp; msg );
		return false;
		
	endif;
	
	//If we get to here there should be nothing in the way of us doing a back up, so create a file to warn off others...
	
	create ourBackupFile transient;
	ourBackupFile.usePresentationFileSystem := false;
	ourBackupFile.openOutput(miscPath &amp; "\" &amp; BackupInProgress);
	ourBackupFile.writeLine( self.String &amp; " " &amp; self.startTime.String );
	ourBackupFile.close();
	
	return true;

epilog

	if deployFile &lt;&gt; null then
		delete deployFile;
	endif;
	if otherBackupFile &lt;&gt; null then
		delete otherBackupFile;
	endif;
	if ourBackupFile &lt;&gt; null then
		delete ourBackupFile;
	endif;
	if miscFolder &lt;&gt; null then						// PAR #37597
		delete miscFolder;							// PAR #37597
	endif;											// PAR #37597

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="wrapUpBackup" id="95f7a5d3-f406-47a2-8b09-6f2bb3865b89">
        <updating/>
        <source>wrapUpBackup(_status : Integer; _backup  : CM_Backup input; _extraInfo : String) updating;
// CCMS1150 cnwrs1 16 June 2011
//
// this is where we finish the backup process and delete ourself 
// this is called either bacuase the backup completed failed or was aborted
// if this method crashes we create a  EVENT_Backup_TimerReset event to reset the backup process 
//
//06 Nov 2012	cnwrs1		Par 28355 - Handle invalid myBGPBackupRequest
//16 Aug 2013	cnwrs1	Par 31212 update completion date time for backups
vars
	header : String;
	msg : String;
	isInvalid : Boolean;
	backupStatus : Integer;
	historyStatus : Integer;
	backup : CM_Backup;
	crashed : Boolean;
begin
	crashed := true;
	historyStatus := _status;
	backupStatus := BackupStatus_Idle;
	backup := app.myRoot.myBackup;
	if _status = BackupStatus_Abort then
		header := "Database Backup Aborted";
		msg := "Database backup started at "&amp;self.startTime.String&amp;" has been Aborted.";
		if self.myKCBackupProcess &lt;&gt; null then
			system.forceOffUser(myKCBackupProcess.node, myKCBackupProcess);//09 Sep 2013	cnwrs1	Par Fix completed DT during backup
		endif;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;" initailize cleanup of CM_Backup status and BGP_BackupDB", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		if backup.sdsSecondaryBackup then
			self.setHistoryStatusNotify(_status);
		endif;
	elseif _status = BackupStatus_Failed then
		header := "Database Backup has failed.";
		msg := "Database backup started at "&amp;self.startTime.String&amp;" has failed please check the backup log file cn_backup_nn.log.";
		if self.myKCBackupProcess &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, self.myKCBackupProcess, isInvalid);//09 Sep 2013	cnwrs1	Par Fix completed DT during backup 
			msg := self.myKCBackupProcess.number.String;
			if not isInvalid then
				system.forceOffUser(self.myKCBackupProcess.node, self.myKCBackupProcess);//09 Sep 2013	cnwrs1	Par Fix completed DT during backup
			endif;
		endif;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;" initailize cleanup of CM_Backup status and BGP_BackupDB", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		if backup.sdsSecondaryBackup then
			self.setHistoryStatusNotify(_status);
		endif;
	elseif _status = BackupStatus_Completed then
		header := "Database Backup Successful.";
		msg := "Database backup started at "&amp;self.startTime.String&amp;" has been successful.";
	elseif _status = BackupStatus_Restarted then
		header := "Database Backup is being Restarted.";
		msg := "Database  Backup was restarted at "&amp;self.startTime.String&amp;".";
		backupStatus := historyStatus;
	endif;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' status='&amp;historyStatus.String&amp;' '&amp;header&amp;' '&amp;msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

	if not app.isSDSSecondaryDB then
		if self.myBackupHistory &lt;&gt; null then
			app.myTrxUA.trxUpdateBGPBackupHistStatus(self.myBackupHistory, historyStatus);
			//13 Jan 2016	NDL	Par 37296
			if _status = BackupStatus_Failed and _extraInfo &lt;&gt; null then	
				app.myTrxUA.trxUpdateBGPBackupHistExtra(self.myBackupHistory, _extraInfo);
			endif;
		endif;
		app.myTrxUA.trxUpdateBGPBackupStatus(_backup, backupStatus);
	endif;
	self.myBackupHistory := null;
	delete self.myCnBackup;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' end notification for self '&amp;self.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	self.endNotificationForSubscriber(self);
	if self.myBGPBackupRequest &lt;&gt; null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' end notification for self.myBGPBackupRequest '&amp;self.myBGPBackupRequest.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
//		self.myBGPBackupRequest.endClassNotification(CM_Backup, false, Object_Update_Event);	//this must be done before myBGPBackupRequest is deleted 
		isInvalid := false;
		on Exception do app.handleDeletedObject(exception, self.myBGPBackupRequest, isInvalid);	//06 Nov 2012	cnwrs1		Par 28355 - 
		msg := self.myBGPBackupRequest.processingStartTime.String;
		if not isInvalid then
			if _status = BackupStatus_Completed then	//16 Aug 2013	cnwrs1
				app.myTrxUA.trxUpdateBGPControllerPost(self.myBGPBackupRequest.myProcessingController, app.myPassport);	//16 Aug 2013	cnwrs1	
			endif;
			self.myBGPBackupRequest.BGP_BackupDB.removeBackupClassNotify();	// cnwrs1 Par 28593 10 Nov 2011
			if app.isSDSSecondaryDB then
				self.myBGPBackupRequest.myProcessingController.sdsCauseEvent(BGP_Object.BGP_DeleteBGPBackupDB, true, self.myBGPBackupRequest);	// 11 July 2011	cmwrs1		CCMS1150 - backup sds notification
			elseif not backup.sdsSecondaryBackup then
				self.myBGPBackupRequest.myProcessingController.causeEvent(BGP_Object.BGP_DeleteBGPBackupDB, true, self.myBGPBackupRequest);	// 11 July 2011	cmwrs1		CCMS1150 - backup sds notification
			endif;
		endif;
	endif;
	self.myBGPBackupRequest.causeEvent(BGP_Object.BGP_DisplayUpdate, false, null);
	if _extraInfo.trimBlanks &lt;&gt; null then	//13 Jan 2016	NDL	Par 37296
		self.raiseAlert(header, msg &amp; CrLf &amp; _extraInfo, SEVERE_WARNING);
	else
		self.raiseAlert(header, msg, SEVERE_WARNING);
	endif;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;' pre epilog', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	crashed := false;
epilog
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;' epilog', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	self.unMarkOurTerritory();	//12 Jan 2016	NDL	Par 37296
	
	if crashed and 
	   not self.aborted and
	   not app.isSDSSecondaryDB then
	   // we have had a crash here we want to try and reset the backup process but dont not get into a nested exception loop
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' beginTimer EVENT_Backup_TimerReset', LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		self.beginTimer(0, Timer_OneShot, EVENT_Backup_TimerReset);
	endif;
	delete self.myFolder;
	on Exception do null global;
	delete self;
end;
</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_backup" type="CM_Backup" usage="input"/>
        <Parameter name="_extraInfo" type="String"/>
    </JadeMethod>
</Class>
