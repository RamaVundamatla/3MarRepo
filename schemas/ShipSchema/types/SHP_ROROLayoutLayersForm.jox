    <JadeMethod name="unload" id="147edc75-2475-4602-973d-9329a40a918a">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/

vars

begin
	// 28785 Jan 2012 handle closing window from 'x' close which doesn't call lostFocus by calling each one here
	//  this adds minimum overhead which is accceptable to avoid missing updates
	self.tblDimensions_queryRowColChg(self.tblDimensions, self.tblDimensions.sheet, self.tblDimensions.row, self.tblDimensions.column);
	self.tblDimensions_rowColumnChg(self.tblDimensions);
	self.txtItemCode_lostFocus(self.txtItemCode);
	self.txtItemDesc_lostFocus(self.txtItemDesc);
	self.txtItemRemarks_lostFocus(self.txtItemRemarks);
	self.txtLayerCode_lostFocus(self.txtLayerCode);
	self.txtLayerDesc_lostFocus(self.txtLayerDesc);
	self.txtLayerRemarks_lostFocus(self.txtLayerRemarks);
	
	if self.myParentForm &lt;&gt; null then
		self.myParentForm.setPropertyValue("myLayerFrame",null);
		self.myParentForm.setPropertyValue("myUIStylesFrame",null);// PAR 27595
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="9e2c4b22-12ec-4274-b69d-210b52390cb9">
