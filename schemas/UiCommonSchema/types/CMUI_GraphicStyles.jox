    <JadeMethod name="addToolbarControls" id="96a366ac-03fc-46a2-a841-ed75a53524a6">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
Date		    Who			Reason
06 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars
	deckToolbar,fillToolbar, lineToolbar : CMUI_Toolbar;
begin
	inheritMethod();
	deckToolbar := self.frmToolbar;
	fillToolbar := self.toolbarFillStyle;
	lineToolbar := self.toolbarLineStyle;
	
	inheritMethod();		
	
	deckToolbar.transparent := true;
	deckToolbar.stretchWidth := false;
	deckToolbar.width := 15;
	deckToolbar.bevelInner := 0;
	deckToolbar.bevelOuter := 0;
	//deckToolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	//deckToolbar.positionToolbarControls();
	
	fillToolbar.addButton(self.btnColoursFill, CMUI_Toolbar.Control_Alignment_Left);		
	
	lineToolbar.addButton(self.btnColoursLines,CMUI_Toolbar.Control_Alignment_Left);
	
	self.doSetupToolbarFrames();
	
	fillToolbar.addFrame(self.frmColourButtons,CMUI_Toolbar.Control_Alignment_Left);
	fillToolbar.positionToolbarControls();	
			
	lineToolbar.addFrame(self.frmLineColour, CMUI_Toolbar.Control_Alignment_Left);
	lineToolbar.positionToolbarControls();	
	
	toolbarLineWidth.addFrame(self.frmLineWidth, CMUI_Toolbar.Control_Alignment_Left);
	toolbarLineWidth.positionToolbarControls();		
	toolbarLineWidth.visible := true;
	
	self.setToolbars();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
