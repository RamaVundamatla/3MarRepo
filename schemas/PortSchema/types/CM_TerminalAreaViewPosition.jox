    <JadeMethod name="flipHorizontally" id="1ef4a215-ffa0-40e9-96e2-31cb96fad4ed">
        <updating/>
        <source>flipHorizontally() updating;

/*

Purpose:		Flip horizontally.

Parameters:			

Return Value:		


Date				Who		Reason
03 September 2008	consw1	Initial creation

*/

vars

begin
	self.horizontalFlip := not horizontalFlip;
epilog

end;</source>
    </JadeMethod>
