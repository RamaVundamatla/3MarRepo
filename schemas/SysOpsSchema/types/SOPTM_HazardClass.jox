    <JadeMethod name="setupThumbnailDetails" id="32e68649-cb04-4f87-9fc3-c1843c5245d6">
        <updating/>
        <source>setupThumbnailDetails() updating;

vars
	theForm : SOP_TableMaintForm;
    row     : Integer;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_HazardClassTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_HazardClassMaint);
	theForm.shtTblInput1.visible := true;


	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;

	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);			
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="ab0bb08e-2855-4422-a855-10a411f64614">
        <updating/>
        <source>showThumbnail(pHazardClass : CM_HazardClass) updating;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 13/05/2015	cnwdap1		PAR #36206 TFS 324/334 Graphical Reresentation of Hazard Class
// 15/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
//
vars
	theForm : SOP_TableMaintForm;
	drawAttr : CM_DrawingAttribute;			// PAR #36206
	row : Integer;							// PAR #36206

begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Code, pHazardClass.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pHazardClass.description);
	theForm.tblInput1.setValueByName(ETRow_Colour, pHazardClass.colour.String);
	theForm.tblInput1.setValueByName(ETRow_AlternateCode, pHazardClass.alternateCode);
	drawAttr := pHazardClass.myDrawingAttribute;										// PAR #36206
	if drawAttr &lt;&gt; null then															// PAR #36206
		theForm.tblInput1.setValueByName(ETRow_Font, drawAttr.fontName);				// PAR #36206
		theForm.cmbChar.fontName := drawAttr.fontName;									// PAR #36206
		if drawAttr.fontCharacter &gt;= 1 and drawAttr.fontCharacter &lt;= 255 then			// PAR #36206
			theForm.cmbChar.listIndex := drawAttr.fontCharacter;						// PAR #36206
		endif;																			// PAR #36206
		theForm.tblInput1.setValueByName(ETRow_Character, theForm.cmbChar.text);		// PAR #36206
		row := theForm.tblInput1.getRowByName(ETRow_Character);							// PAR #36206
		if row &lt;&gt; null then																// PAR #36206
			theForm.tblInput1.accessCell(row, theForm.tblInput1.ColumnValue).fontName := drawAttr.fontName;	// PAR #36206
		endif;																			// PAR #36206
	endif;																				// PAR #36206
	theForm.tblInput1.setValueByName(ETRow_Symbols, app.getErrorString(Dbl_Click_To_Add_Update));			// PAR #36421
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pHazardClass.isNotAvailableForEntry);
end;</source>
        <Parameter name="pHazardClass" type="CM_HazardClass"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="c04a36cc-201d-42b1-aac1-02d7c2f43ba8">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//--------------------------------------------------
// Created:	25 November 2003 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------
// 20/05/2015	cnwdap1		PAR #36206 Graphical Representation of Hazard Class
vars
	lHazardClass : CM_HazardClass;
	cell : JadeTableCell;
	table : CM_DataTable;				// PAR #36206
	charColumn : Integer;				// PAR #36206
	
begin
	lHazardClass := _obj.CM_HazardClass;
	if(_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then	
			cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;			
			cell.backColor := lHazardClass.colour;
		endif;
	endif;
	
	if _idxRow &lt;&gt; 1 and lHazardClass &lt;&gt; null then											// PAR #36206
		if lHazardClass.myDrawingAttribute &lt;&gt; null then										// PAR #36206
			table := self.myForm.tblData;													// PAR #36206
			charColumn := table.getColumnByRowName(ETRow_Character);						// PAR #36206
			if charColumn &lt;&gt; null then														// PAR #36206
				cell := table.accessCell(_idxRow, charColumn);								// PAR #36206
				cell.fontName := lHazardClass.myDrawingAttribute.fontName;					// PAR #36206
				cell.text := lHazardClass.myDrawingAttribute.fontCharacter.Character;		// PAR #36206
			endif;																			// PAR #36206
		endif;																				// PAR #36206
	endif;																					// PAR #36206
end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
