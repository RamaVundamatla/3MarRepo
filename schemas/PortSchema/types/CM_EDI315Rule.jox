        <source>setForUpdate( _proxy : CM_EDI315Rule) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2015	cnwrd1	Initial creation

*/

vars

begin
	self.raiseExceptionIfTransient (method);
	
	self.function	:= _proxy.function;
	self.item		:= _proxy.item;
	self.value		:= _proxy.value;
	self.stopTable 	:= _proxy.stopTable;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDI315Rule"/>
