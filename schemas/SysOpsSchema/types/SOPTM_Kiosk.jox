    <JadeMethod name="initShtMultiSelect" id="8fbb8bab-4e0e-4cfa-a4d9-adc44b080ede">
        <source>initShtMultiSelect();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 August 2023		jlizm1	Initial creation TFS 59548 Kiosk maintenance locales
18 August 2023		jlizm1	TFS 59550 Kiosk PPE Questions
27 August 2023		jlizm1	TFS 59551 Kiosk Additional Question

*/

vars
	theForm	: SOP_TableMaintForm;
	
begin
	inheritMethod();
	
	theForm := self.myForm;
	
	
	theForm.mulSelect1.setVisibleButtons(false, false, true);
	self.setupMultiSelect1(app.getErrorString(Locales), app.myRoot.allLocales, SOP_TableMaintForm::displayEntryLocale.name);
	theForm.mulSelect1.myBaseForm := theForm;
	theForm.mulSelect1.mySelectedListBox.sorted := false;
	theForm.chkAnyTriggField.visible := false;
	
	theForm.shtSingleSelect1.visible := true;
	theForm.shtSingleSelect1.caption := app.getErrorString(PPE_Questions);
	theForm.lstSingleSelect1.visible := true;	
	
	theForm.btnSingle1Up.visible:=true;
	theForm.btnSingle1Down.visible:=true;
	theForm.frmTBSingle.setToolbarControlsEnabled(true);

	theForm.shtSingleSelect3.visible := true;
	theForm.shtSingleSelect3.caption := app.getErrorString(Additional_questions);
	theForm.lstSingleSelect3.visible := true;	
	
	theForm.btnSingle3Up.visible:=true;
	theForm.btnSingle3Down.visible:=true;
	theForm.frmTBSingle3.setToolbarControlsEnabled(true);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initShtTranslations" id="4d4f08d1-e6a0-4f39-9a1c-03cfae9dc976">
        <source>initShtTranslations();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 August 2023		jlizm1	Initial creation TFS 59549 Kiosk maintenance terms and conditions

*/

constants
	LeftMargin		: Integer = 10;
	TopMargin		: Integer = 10;
	Spacing			: Integer = 5;
	BtnWidth		: Integer = 75;
	BtnHeight		: Integer = 20;
	
vars
	theForm 	: SOP_TableMaintForm;
	currentTop 	: Integer;
	
begin
	inheritMethod();
	
	theForm := self.myForm;
	
	theForm.shtTranslations.visible := true;
	theForm.shtTranslations.caption := app.getErrorString(Terms_conditions);
	
	theForm.btnXlatSave.visible := true;
	theForm.btnXlatCancel.visible := true;
	theForm.btnXlatDelete.visible := true;
	theForm.cmbLocale2.visible := true;
	theForm.lblLocale.visible := true;
	theForm.txtTranslation.visible := true;
	
	currentTop := TopMargin;
	
	theForm.lblLocale.move(LeftMargin, currentTop + 3, 90, 20);
	theForm.cmbLocale2.move(LeftMargin + 80, currentTop, 200, 20);
	
	currentTop := currentTop + 20 + Spacing;
	
	theForm.txtTranslation.move(LeftMargin, currentTop, 90, 20);
	theForm.txtTranslation.stretchHeight := true;
	theForm.txtTranslation.stretchWidth := true;
	theForm.txtTranslation.distanceFromRight := LeftMargin;
	theForm.txtTranslation.distanceFromBottom := TopMargin + 30 ;
	theForm.txtTranslation.scrollVertical := true;
	theForm.txtTranslation.scrollBars := 2;
	
	currentTop := currentTop + theForm.txtTranslation.height.Integer + Spacing;

	theForm.btnXlatCancel.lockRight := true;
	theForm.btnXlatCancel.lockBottom := true;
	theForm.btnXlatCancel.distanceFromRight := LeftMargin;
	theForm.btnXlatCancel.distanceFromBottom := TopMargin;
	theForm.btnXlatCancel.width := BtnWidth;
	theForm.btnXlatCancel.height := BtnHeight;
	
	theForm.btnXlatDelete.lockRight := true;
	theForm.btnXlatDelete.lockBottom := true;
	theForm.btnXlatDelete.distanceFromRight := theForm.btnXlatCancel.distanceFromRight + BtnWidth + Spacing;
	theForm.btnXlatDelete.distanceFromBottom := TopMargin;
	theForm.btnXlatDelete.width := BtnWidth;
	theForm.btnXlatDelete.height := BtnHeight;
	
	theForm.btnXlatSave.lockRight := true;
	theForm.btnXlatSave.lockBottom := true;
	theForm.btnXlatSave.distanceFromRight := theForm.btnXlatDelete.distanceFromRight  + BtnWidth + Spacing;
	theForm.btnXlatSave.distanceFromBottom := TopMargin;
	theForm.btnXlatSave.width := BtnWidth;
	theForm.btnXlatSave.height := BtnHeight;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateLocaleCombo" id="e567bef0-63a9-4df7-93d4-aafc82001d74">
        <updating/>
        <source>populateLocaleCombo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 August 2023		jlizm1	Initial creation TFS 59549 Kiosk maintenance terms and conditions

*/

vars
	theForm 	: SOP_TableMaintForm;
	kiosk :CM_Kiosk;
	primaryLocale : CM_Locale;

begin
	theForm := self.myForm;
	primaryLocale := theForm.cmbLocale.listObject.CM_Locale;
	self.selectedLocale := null;
	
	self.allSelectedLocales.clear();
	theForm.mulSelect1.getSelected(self.allSelectedLocales);

	if primaryLocale &lt;&gt; null and not self.allSelectedLocales.includes(primaryLocale) then
		self.allSelectedLocales.add(primaryLocale);
	endif;
	
	theForm.cmbLocale2.listCollection(self.allSelectedLocales, false, 0);
	
	self.displayTermsAndConditions();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="5806e656-0fc2-476c-a960-aaecd9004dd1">
        <updating/>
        <source>setControlsForAddEdit() updating;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation
07 August 2023	jlizm1	TFS 59548 Kiosk maintenance locales
11 August 2023	jlizm1	TFS 59549 Kiosk maintenance terms and conditions
14 August 2023	jlizm1	TFS 59550 Kiosk PPE Questions
28 August 2023	jlizm1	TFS 59551 Kiosk Additional Question

*/
vars
	theForm 	: SOP_TableMaintForm;
	entTableRow	: EntTableRow;
	entTableDef	: EntTableDef;

begin
   	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	entTableDef := app.myController.getEntTableDef(ETDef_Kiosk);
	
	foreach entTableRow in entTableDef.allEntTableRows do
		theForm.tblInput1.enableRowByName(entTableRow.name);
	endforeach;
	
	if theForm.mode = theForm.Mode_Add then 
		theForm.tblInput1.clearValues;
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
	else
		self.showThumbnail(theForm.myCurrentObject.CM_Kiosk);
		theForm.cmbLocale.setObject(theForm.myCurrentObject.CM_Kiosk.myPrimaryLocale);
		self.selectedLocale := theForm.myCurrentObject.CM_Kiosk.myPrimaryLocale;
	endif;
    theForm.tblInput1.cnEcResizeContents;
	
	theForm.btnXlatCancel.enabled := true;
	theForm.btnXlatDelete.enabled := true;
	theForm.btnXlatSave.enabled := true;
	theForm.txtTranslation.enabled := true;
	
	theForm.shtSingleSelect1.visible := false;
	theForm.shtSingleSelect3.visible := false;
	
end;</source>
    </JadeMethod>
