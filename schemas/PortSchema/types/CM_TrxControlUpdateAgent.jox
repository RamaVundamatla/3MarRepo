    <JadeMethod name="trxSapWSDL111Update" id="3e6847af-98f9-4428-80c6-97ed1bd11131">
        <updating/>
        <source>trxSapWSDL111Update(	_invoice : CM_Invoice input;
						_resultString : String;
						_cashReceipt : CM_CashReceipt input;
						_crPaymentStatus : Integer;
						_wsdlType : String;
						_passport : CM_Passport input
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2019	jlgndl1	Initial creation	TFS 45330

*/

vars

	msgArray : String200Array;
	msg : String;
	baseMsg : String;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
//	on LockException do agtPassportLockExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //Silent lock exception handler for retries...

	create msgArray transient;
	baseMsg :=  method.qualifiedName &amp; ' ' &amp; _wsdlType &amp; " ";
		
	beginTransaction;

	if _resultString = 'X' then
		//If it was successfull update Invoice 'Payment Status' to 'Payment cancelled'
		app.myUtilityUA.updRealInvoicePaymentStat( _invoice, CM_Invoice.INVOICE_PAYMENT_CANCEL, _wsdlType, msgArray, _passport);
	endif;
	
	if _passport.noErrors and _cashReceipt &lt;&gt; null then
		//Update Cash Receipt(s) Payment Status (will either be 'cancel pending' or 'cancel approved')
		app.myUtilityUA.utlUpdateRealCashRecPayStatus( _cashReceipt, _crPaymentStatus, _passport );
		if _passport.noErrors then
			msg := baseMsg &amp; " Updated Payment Status to " &amp; _crPaymentStatus.String &amp; " for CashReceipt :" &amp; _cashReceipt.externalInvoiceNumber;
		endif;
	endif;
	
	if _passport.noErrors then
		foreach msg in msgArray do
			app.writeLog(msg ,LogINFO);
		endforeach;
	else
		msg := baseMsg &amp; _passport.getErrorsAndWarningsAsString();
		app.writeLog(msg ,LogINFO);
	endif;

epilog

	delete msgArray;

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_resultString" type="String"/>
        <Parameter name="_cashReceipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_crPaymentStatus" type="Integer"/>
        <Parameter name="_wsdlType" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSapWSDL112Success" id="d42a6b65-2a19-49f4-86dd-513778f0f96d">
        <updating/>
        <source>trxSapWSDL112Success( 	_invoice : CM_Invoice input;
						_invLines : CM_InvoiceLineSet;
						_passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2019	jlgndl1	Initial creation	TFS 45330

*/

vars

	msgArray : String200Array;
	msg : String;
	baseMsg : String;
	invLine : CM_InvoiceLine;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
//	on LockException do agtPassportLockExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //Silent lock exception handler for retries...

	create msgArray transient;
	baseMsg :=  method.qualifiedName &amp; ' ' &amp; BGP_SAPWSRequest.WSDL112 &amp; " "; 
		
	beginTransaction;
	
	if _invoice &lt;&gt; null then
		_invoice.sendSAPKinerja();
	endif;
	
	if not _invLines.isEmpty() then
		foreach invLine in _invLines do
			app.myUtilityUA.utlUpdPEL1PrepaySAPDate( invLine, _passport );
			if _passport.hasErrors then
				break;
			endif;
		endforeach;
	endif;
	
	if _passport.noErrors then
		foreach msg in msgArray do
			app.writeLog(msg ,LogINFO);
		endforeach;
	else
		msg := baseMsg &amp; _passport.getErrorsAndWarningsAsString();
		app.writeLog(msg ,LogINFO);
	endif;
	
epilog

	delete msgArray;

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_invLines" type="CM_InvoiceLineSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSapWSDL11_14_16Update" id="67ee3f3e-005d-4a7a-b9f5-9df0d9936a00">
        <updating/>
        <source>trxSapWSDL11_14_16Update(	_cashReceipt : CM_CashReceipt input; 
							_workOrder : CM_WorkOrder input; 
							_wsdlType : String;
							_cashRecNewStatus : Integer; // Cash Receipt payment status
							_woNewStatus : Integer;
							_doApprove : Boolean;
							_responseStatusStr : String;
							_passport : CM_Passport input
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2019	jlgndl1	Initial creation	TFS 45330

*/

vars

	msgArray : String200Array;
	msg : String;
	baseMsg : String;
	cashRec : CM_CashReceipt;
	isAllCashApproved : Boolean;
	isIMSR : Boolean;
	woNewStatus : Integer;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
//	on LockException do agtPassportLockExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //Silent lock exception handler for retries...

	create msgArray transient;
	baseMsg :=  method.qualifiedName &amp; ' ' &amp; _wsdlType &amp; " ";
		
	beginTransaction;
	
	//update the Cash receipts payment status
	app.myUtilityUA.utlUpdateRealCashRecPayStatus( _cashReceipt, _cashRecNewStatus, _passport );
	
	if app.myPassport.noErrors then
		msg := baseMsg &amp; "Updated Payment Status CashReceipt :" &amp; _cashReceipt.externalInvoiceNumber;
		msgArray.add( msg );
	endif;
	
	if _passport.noErrors and _workOrder &lt;&gt; null then
		//Update WO Status
		woNewStatus := _woNewStatus;
		if _doApprove then
			foreach cashRec in _workOrder.allCashReceipts do
				if cashRec.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED then
					isAllCashApproved := true;
					continue;
				endif;
				isAllCashApproved := false;
			endforeach;					
			if isAllCashApproved then
				woNewStatus := WO_STATUS_APPROVED;
			endif;
		endif;
		
		if _responseStatusStr = "X" then	
			if _workOrder.isWorkOrderForIMSR then
				isIMSR := true;
			endif;	
			if isIMSR then
				woNewStatus := WO_STATUS_PENDING;
			endif;
		endif;
		
		app.myUtilityUA.utlSapEstimateResponse( _workOrder, woNewStatus, _doApprove, _passport );
		
		if app.myPassport.noErrors then
			msg := baseMsg &amp; "Updated Status Work Order : " &amp; _workOrder.id;
			msgArray.add( msg );
		endif;
		
	endif;
	
	if _passport.noErrors then
		foreach msg in msgArray do
			app.writeLog(msg ,LogINFO);
		endforeach;
	else
		msg := baseMsg &amp; _passport.getErrorsAndWarningsAsString();
		app.writeLog(msg ,LogINFO);
	endif;

epilog

	delete msgArray;

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_workOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_wsdlType" type="String"/>
        <Parameter name="_cashRecNewStatus" type="Integer"/>
        <Parameter name="_woNewStatus" type="Integer"/>
        <Parameter name="_doApprove" type="Boolean"/>
        <Parameter name="_responseStatusStr" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSapWSDL12Success" id="21a99866-254e-4f00-8e82-640a7a976108">
        <updating/>
        <source>trxSapWSDL12Success( invoice : CM_Invoice input; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2019	jlgndl1	Initial creation	TFS 45312

*/

vars

	msgArray : String200Array;
	msg : String;
	baseMsg : String;
	cmifStatus : CMIF_InvoiceStatus;
	pxyInvoice: CM_Invoice;

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
//	on LockException do agtPassportLockExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //Silent lock exception handler for retries...

	create msgArray transient;
	baseMsg :=  method.qualifiedName &amp; ' ' &amp; BGP_SAPWSRequest.WSDL12 &amp; " "; 
		
	beginTransaction;
	
	//Update Invoice 'Payment Status' to 'Paid'
	app.myUtilityUA.updRealInvoicePaymentStat( invoice, CM_Invoice.INVOICE_PAYMENT_PAID, BGP_SAPWSRequest.WSDL12, msgArray, _passport) ;
	
	if _passport.noErrors then
		//Update Cash Receipt(s) Payment Status to Paid
		invoice.updateCashRecSAPDirect( CM_CashReceipt.PAID, BGP_SAPWSRequest.WSDL12, msgArray, _passport );
	endif;
	
	if _passport.noErrors then
		//Tax number and Invoice Date generation for Auto-collection Invoice
		msg :=  baseMsg &amp; ' ' &amp; "Update Invoice Tax Details" &amp;
			' ' &amp; "Invoice :"   &amp; invoice.exportCurrencyCode ;
		msgArray.add( msg );
		invoice.generateTax();
	endif;
	
	if _passport.noErrors then
		//Invoice 'Status' from "Pending" to "Posted"
		pxyInvoice := app.createUpdateProxy( invoice ).CM_Invoice;
		
		create cmifStatus transient;
		cmifStatus.myInvoice := pxyInvoice;
		cmifStatus.newStatus := CM_Invoice.INVOICE_POSTED;
		pxyInvoice.toDT := app.actualTimeServer;
		
		app.myValUA.valInvoiceStatus( invoice, cmifStatus );
		
		if _passport.noErrors then
			app.myUtilityUA.utlUpdateInvoiceStatus( cmifStatus, _passport);
		endif;
		
	endif;
	
	if _passport.noErrors then
		foreach msg in msgArray do
			app.writeLog(msg ,LogINFO);
		endforeach;
	else
		msg := baseMsg &amp; _passport.getErrorsAndWarningsAsString();
		app.writeLog(msg ,LogINFO);
	endif;
	
epilog

	delete pxyInvoice;
	delete cmifStatus;
	delete msgArray;

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxSapWSDL13Success" id="6dfe784e-16ce-4e38-af28-570fe4cc3e02">
