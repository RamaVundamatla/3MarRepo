    <JadeMethod name="validateMe" id="10549c40-f6c9-4cef-bef2-cbd06329a77c">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

	real : CM_ServicePayTypeMapping;
	existing : CM_ServicePayTypeMapping;

begin

	if self.myBank = null then
		app.raiseCMException( Bank_selected, null, null );
	endif;
	
	if self.myService = null then
		app.raiseCMException( Service_selected, null, null );
	endif;

	
	if self.myDebtor = null then
		app.raiseCMException( Debtor_not_found, null, null );
	endif;
	
	if self.isTransient then
		real := self.pxyGetRealObject();
	else
		real := self;
	endif;
	
	if self.myBank = null or self.myService = null or  self.myDebtor = null then
		return;
	endif;
	
	existing := self.myBank.getServicePayTypeMapping( self.myService, self.myDebtor, false );	// the specific one for this debtor only.
	if existing &lt;&gt; null and existing &lt;&gt; real then
		app.raiseCMException3( Servic_paymen_type_alread_exis, self.myBank.code, self.myService.name, self.myDebtor.code, null, null );
	endif;


epilog

end;</source>
    </JadeMethod>
</Class>
