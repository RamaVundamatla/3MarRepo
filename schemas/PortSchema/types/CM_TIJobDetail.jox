    <JadeMethod name="setJobActionDetails" id="05cb3185-5465-422e-b7ca-b985716ed3d1">
        <updating/>
        <source>setJobActionDetails(_job: CM_Job; _isStart: Boolean; _ts : TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62897: Jade - Job Create Transactions and Events

*/

vars
	jobSheet	: CM_JobSheet;
begin
	self.jobDesc := _job.getJobTypeDescription();
	self.jobType := _job.getJobClassNiceString();
	self.jobId := _job.id;
	
	if _isStart then
		self.jobStart := _ts;
	else
		self.jobEnd := _ts;
	endif;	
	
	jobSheet := _job.myJobSheet;
	if jobSheet &lt;&gt; null then
		self.jobSheetCode := jobSheet.externalName;
	endif;

epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_isStart" type="Boolean"/>
        <Parameter name="_ts" type="TimeStamp"/>
    </JadeMethod>
</Class>
