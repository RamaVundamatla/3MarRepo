    <JadeMethod name="xHandlerCMExceptionUserObject" id="dc54775e-f6c8-4e33-9eba-44296c99dba8">
        <source>xHandlerCMExceptionUserObject(_exception :CM_Exception input; _context :Object):Integer;
/*
Date		Who		Reason
22/05/2012	cnwcs5	Initial creation - par 29583 - setting context for EDI errors
*/
vars

begin 
	if _context = null then
		// nothing to do
		return Ex_Pass_Back;
	endif;
	// change the myUserObject property on the error 
	_exception.setUserObject (_context);
	
	return Ex_Pass_Back;
epilog

end;</source>
        <Parameter name="_exception" type="CM_Exception" usage="input"/>
        <Parameter name="_context" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
