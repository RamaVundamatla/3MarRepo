    <JadeMethod name="comboBoxEDIActionItem" id="2ad6d0b0-23fd-474b-96cc-9392323a7331">
        <source>comboBoxEDIActionItem(_cmb : ComboBox input; _ediActionObject : CM_Object);
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	obj		: CM_Object;
	objSet	: CM_ObjectSetActual;
	idx		: Integer;
begin
	create objSet transient;
	
	_cmb.clear;
	
	// DVB CCMS 1235
	app.myRoot.allStopsTable.copy(objSet);
	app.myRoot.allToDoTaskDescriptions.copy(objSet);
	
	foreach obj in objSet do
		idx := _cmb.addItem(obj.getEDIActionName);
		_cmb.itemObject[idx] := obj;
	endforeach;
	
	if _ediActionObject &lt;&gt; null then
		_cmb.listObject := _ediActionObject;
	endif;
	
epilog
	delete objSet;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_ediActionObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="comboBoxEDIFileType" id="77200625-848f-4c6d-ac56-5f56ee10327b">
        <source>comboBoxEDIFileType(_cmb : ComboBox input; _ediFileType : CM_EDIFileType; _checkAllowEDIActions: Boolean);
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ediFileType	: CM_EDIFileType;
	idx			: Integer;
begin

	_cmb.clear;
	foreach ediFileType in app.myRoot.allEDIFileTypes do
		if (_checkAllowEDIActions and ediFileType.allowEDIActions)
		or (not _checkAllowEDIActions) then
			idx := _cmb.addItem(ediFileType.name);
			_cmb.itemObject[idx] := ediFileType;
		endif;
	endforeach;
	
	if _ediFileType &lt;&gt; null then
		_cmb.text := _ediFileType.name;
		_cmb.listObject := _ediFileType;
	endif;

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_ediFileType" type="CM_EDIFileType"/>
        <Parameter name="_checkAllowEDIActions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxEDIStatus" id="21cb8336-aecd-476b-8aeb-da18c7e70fe3">
        <source>comboBoxEDIStatus( _cmb : ComboBox input; _status : Integer constant; _ediConfig : CM_EDIConfig input );
//
//	ccms1906
//
vars
	const : Constant;
	tConst : Constant;
	idx	: Integer;
	constDict : ConstantNDict;
	tClass : Class;
	str : String;
	ediControllerAgent	: CM_EDIControllerAgent;					// cnwrl1 31/03/2010 PAR 23432
	compareLength		: Integer;									// cnwrl1 31/03/2010 PAR 23432
	
begin
	_cmb.clear;
	_cmb.sorted	:= true;											// cnwrl1 31/03/2010 PAR 23432
	tClass := currentSchema.getClass( CM_EDIFile.name );
	create constDict transient;
	create ediControllerAgent transient;
	tClass.getConstants( constDict );
	compareLength			:= CM_EDIFile.StatusHeader.length;
	idx						:= _cmb.addItem( null );				// This is the "All" statuses entry.
	_cmb.itemData[ idx ]	:= 999;									// This is the "All" statuses entry.
	foreach const in constDict do : constant_loop
		// only want to load into the EDI Ops Filter Status combo statuses starting with 'EDI_STATUS'
		if const.name[ 1 : compareLength ] &lt;&gt; CM_EDIFile.StatusHeader then		// currently 1:10
			continue constant_loop;
		endif;
//		str := _ediConfig.displayStatus(const.valueAsInteger);	// cnwrl1 31/03/2010 PAR 23432 - what it was
		str := ediControllerAgent.displayStatus( const.valueAsInteger );
		if str = null then
			continue constant_loop;
		endif;
		idx := _cmb.addItem( str );
		_cmb.itemData[ idx ] := const.valueAsInteger;
		if _status = const.valueAsInteger then
			tConst := const;
		endif;
	endforeach constant_loop;
	
	if tConst &lt;&gt; null then
//		_cmb.text := _ediConfig.displayStatus(tConst.valueAsInteger);	// cnwrl1 31/03/2010 PAR 23432 - what it was
		_cmb.text := ediControllerAgent.displayStatus( tConst.valueAsInteger );
	endif;
	
epilog
	delete constDict;
	delete ediControllerAgent;
	
end;
</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxEDITypeCategories" id="f2c3768d-fc97-489d-af58-ae1b389ed2c1">
        <source>comboBoxEDITypeCategories(_cmb: CMUI_ComboBox input; _userDefined : Boolean; _defType: Integer);
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//15/9/2008 	PAR17931 	cwnsh3 	Removed data classes that were intended for use with U.S changes but they were not required.
// 28/08/2009	cnwrl1		PAR 20320 - MES 1011 New Messina Messages
// 7.9.09 cnwgb1	MES 1011 get rid of ordering dependence, and sort
// 22/02/2010	cnwrl1		PAR 21725 = CCMS 1068 (CR005) - EDI file load of Consignor/Consignee
// 22/04/2010	cnwcs5		par 23580 - ccms sfw 1118 - enhanced edi form
//							changed to use method on CM_EDIControllerAgent instead of CMUI_Assistant as it's more efficient
//							Changed self.getEDIDisplayStrForType to agent.getEDIDisplayStrForType so no comments in code
vars
	agent	:CM_EDIControllerAgent;// 22/04/2010 cnwcs5 par 23580
	coll	:IntegerArray;
	int		:Integer;
begin
	_cmb.clear;
	_cmb.sorted := true;
	
	create agent transient;	// 22/04/2010 cnwcs5 par 23580
	create coll transient;	// 27/04/2010 cnwcs5 par 23580
	
	agent.getAllEDIDataTypeValues (coll, _userDefined);		// 27/04/2010 cnwcs5 par 23580
	
	foreach int in coll do								// 27/04/2010 cnwcs5 par 23580
		if _userDefined then	//13 Aug 2015	NDL	Par - fixed format XML for Steinwegs Cargo Group Assignment message.  I.e. NOT translatable.
			if int = EDIDataType_CargoGroupAssign
			or int = EDIDataType_MultiMoveGroup	//17 Sep 2015	NDL	Par 36906
			or int = EDIDataType_OneStopPre		//07 Apr 2017	NDL	TFS 3950
			or int = EDIDataType_OneStopCust	//07 Apr 2017	NDL	TFS 3950
			or int = EDIDataType_OneStopEIDO	//07 Apr 2017	NDL	TFS 3950
			then
				continue;
			endif;
		endif;
		_cmb.itemData[_cmb.addItem(agent.getEDIDisplayStrForType(int))] := int;// 27/04/2010 cnwcs5 par 23580
	endforeach;											// 27/04/2010 cnwcs5 par 23580
	
	if _defType &gt; 0 then								// 27/04/2010 cnwcs5 par 23580
		_cmb.listIndex := _cmb.findItemData(_defType);	// 27/04/2010 cnwcs5 par 23580
	endif;												// 27/04/2010 cnwcs5 par 23580
	
epilog
	delete agent;	// 22/04/2010 cnwcs5 par 235800
	delete coll;	// 27/04/2010 cnwcs5 par 235800
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_userDefined" type="Boolean"/>
        <Parameter name="_defType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxEDIXlationTypes" id="cd4c9f85-20f4-454d-9f43-62f4c53e67e1">
        <source>comboBoxEDIXlationTypes(_combo :CMUI_ComboBox input; _includeSystem, _includeAll :Boolean; _selection :Integer);
/*
Date		Who		Reason
11 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259 
//15 Jul 2014	Par 34567	CCMS 2346 add EDI Xlation for Cargo Type and Cargo Sub Type
20 mar 2017	cnwdap1	TFS 3734 AAT Add "Vehicle Make" translation type
22 Nob 2018 jlger1	TFS 42095 PEL Work Points which is terminal level xlation
07 Jun 2023	jlika1	TFS 58320 58319 | Jade work for Translations
07 Jun 2023 navpw1	TFS: 57813 (58438) - Added Sorting Method Xlation Type to Combo Box
12 Jun 2023	jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type
08 Nov 2023	jlika1	TFS 61129 61013 CUX | Cargo Priority - EDI Translation
29 Aug 2024 navsp1  TFS ChangeRequest 63842: NSW | OnePort Integration Dev
*/
vars
	
begin
	_combo.sorted	:= false;
	// ALL
	if _includeAll then
		_combo.addItemWithData ("*** All Operator Codes ***", self.ItemData_All_Operator);
	endif;
	
	// OPERATOR translations
	_combo.addItemWithData (app.getErrorString (Availability_Grades), XLATION_TYPE_MTGRADE_BYOP);
	_combo.addItemWithData (app.getErrorString (CustomerPriority), XLATION_TYPE_CUSTPRIORITY_BYOP);
	_combo.addItemWithData (app.getErrorString (CargoTypes), XLATION_TYPE_CARGOTYPE_BYOP);
	_combo.addItemWithData (app.getErrorString (Cargo_subtypes), XLATION_TYPE_CARGOSUBTYPE_BYOP);
	_combo.addItemWithData (app.getErrorString (Carriers), XLATION_TYPE_CARRIER_BYOP);
	_combo.addItemWithData (app.getErrorString (Commodities), XLATION_TYPE_COMMODITY_BYOP);
	_combo.addItemWithData (app.getErrorString (Consignee_Consignors), XLATION_TYPE_CONSIGNEE_BYOP);
	_combo.addItemWithData( app.getErrorString (Country), XLATION_TYPE_COUNTRYTERMINAL); //jlier1 TFS 54846 30/9/22
	_combo.addItemWithData (app.getErrorString (Instruction_types), XLATION_TYPE_INSTRUCTTERMINAL);
	_combo.addItemWithData (app.getErrorString (ISOTypes), XLATION_TYPE_ISOTYPE_BYOP);
	_combo.addItemWithData (app.getErrorString (Operators), XLATION_TYPE_OPERATOR_BYOP);
	_combo.addItemWithData (app.getErrorString (Ports), XLATION_TYPE_PORT_BYOP);
	_combo.addItemWithData (app.getErrorString (Shipping_Agent), XLATION_TYPE_SHIPINGAGENT_BYOP);
	_combo.addItemWithData (app.getErrorString (Shipping_Line), XLATION_TYPE_SHIPPINGLINE_BYOP);
	_combo.addItemWithData (app.getErrorString (SortingMethod), XLATION_TYPE_SORTINGMETHD_BYOP);	// ### TFS 57813 (58438) 07Jun2023 NAVPW1
	_combo.addItemWithData (app.getErrorString (Terminals), XLATION_TYPE_TERMINAL_BYOP);
	_combo.addItemWithData (app.getErrorString (VesselType), XLATION_TYPE_VESSEL_TYPE);	//11 Sep 2018	NDL	TFS 40778
	_combo.addItemWithData (app.getErrorString (Vessels), XLATION_TYPE_VESSEL_BYOP);
	_combo.addItemWithData (app.getErrorString (Voyages), XLATION_TYPE_VOYAGETERMINAL);	
	_combo.addItemWithData (app.getErrorString (Operators) &amp; " - " &amp; app.getErrorString (Terminal), XLATION_TYPE_OPERATOR_BYTERM);		//TFS 63842
	
	// SYSTEM translations
	if _includeAll then
		_combo.addItemWithData("*** All Terminal Codes ***",self.ItemData_All_System);
		_combo.addItemWithData(app.getErrorString(Terminal) &amp; " - " &amp; app.getErrorString (Work_points), XLATION_TYPE_WORKPOINT);
		_combo.addItemWithData ("*** All System Codes ***", self.ItemData_All_System);
	else
		if _includeSystem then
			_combo.addItemWithData(app.getErrorString(Terminal) &amp; " - " &amp; app.getErrorString (Work_points), XLATION_TYPE_WORKPOINT);
		endif;
	endif;
	
	if _includeSystem then
		_combo.addItemWithData(app.getErrorString1 (System_Hyphen, app.getErrorString (Customs_Agents)), XLATION_TYPE_CUSTOMSAGENT);
		_combo.addItemWithData(app.getErrorString1 (System_Hyphen, app.getErrorString (Operators)), XLATION_TYPE_OPERATOR);
		_combo.addItemWithData(app.getErrorString1 (System_Hyphen, app.getErrorString (Shipping_lines)), XLATION_TYPE_SHIPPINGLINE);
		_combo.addItemWithData(app.getErrorString1 (System_Hyphen, app.getErrorString (Trailer_Type)), XLATION_TYPE_TRAILER_TYPE);
		_combo.addItemWithData(app.getErrorString1 (System_Hyphen, app.getErrorString (Vessels)), XLATION_TYPE_VESSEL);	
		_combo.addItemWithData(app.getErrorString1 (System_Hyphen, app.getErrorString (Vehicle_Makes)), XLATION_TYPE_VEHICLE_MAKE);		// TFS 3734
		
	endif;
	
	if _selection &lt;&gt; null then
		_combo.setIndexForItemData (_selection);
	endif;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_includeSystem" type="Boolean"/>
        <Parameter name="_includeAll" type="Boolean"/>
        <Parameter name="_selection" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxEmailAddress" id="38e6db0c-fd1b-493b-b213-f1478a756c9c">
        <source>comboBoxEmailAddress(pCmb : ComboBox input; pEmailAddress : CM_EmailEntity);
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	pCmb.listCollection(app.myRoot.allEmailEntities, true, 0);	
	if pEmailAddress &lt;&gt; null then
		pCmb.text := self.displayEntryEmailAddress(pEmailAddress);
		pCmb.listObject := pEmailAddress;
