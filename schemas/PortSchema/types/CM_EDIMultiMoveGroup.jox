    <JadeMethod name="loadDB" id="ae404d61-9183-4e0b-83af-a09554f7194d">
        <source>loadDB(_validateOnly: Boolean; _passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2015	cnwndl1	Initial creation	Par 36608

*/

vars
	realMultiMoveGroup,
	pxyMultiMoveGroup : CM_MultiMoveGroup;
	term : CM_Terminal;
begin

	term := self.getMyTerminal;
	self.verifySelf();
	
	if _validateOnly then
		return;
	endif;

	pxyMultiMoveGroup := self.createProxy();
	app.myUtilityCA.utlCreateMultiMoveGrp( pxyMultiMoveGroup, realMultiMoveGroup, _passport);
	
	
epilog

	delete pxyMultiMoveGroup;

end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCargoIdsFromString" id="c29daddc-a0dd-4e86-8530-d3a9b764e988">
        <updating/>
        <source>setCargoIdsFromString( _str : String )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2015	cnwndl1	Initial creation	Par 36906

*/

vars

	strArray : StringArray;

begin

	self.allCargoIds.clear();

	strArray := _str.getTokens();
	if strArray &lt;&gt; null and not strArray.isEmpty then
		strArray.copy( self.allCargoIds );
	endif;

epilog

	delete strArray;

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="07a6357e-4e11-407d-bb7d-8e93e6d6f59b">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2015	cnwndl1	Initial creation	Par 36906

*/

vars

begin
	inheritMethod(_proxyEDITI);
	
	self.allCargoIds.clear();
	if not _proxyEDITI.allCargoIds.isEmpty then
		_proxyEDITI.allCargoIds.copy( self.allCargoIds );
	endif;

epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="3e58c738-568f-4b9e-8386-94ba7fc40995">
        <source>verifySelf();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2015	cnwndl1	Initial creation	Par 36906

*/

vars

begin

	if messageMode &lt;&gt; CM_EDICargoGroupAssign.EDI_ACTION_ADD then
		app.raiseCMException1( EDI_Action_Is_Invalid, messageMode, null, null );
		return;
	endif;
	
	if self.allCargoIds.isEmpty then
		app.raiseCMException( No_Cargo_selected, null, null );
		return;
	endif;
	
	


epilog

end;</source>
    </JadeMethod>
</Class>
