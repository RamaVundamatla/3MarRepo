    <DbClassMap file="basemap"/>
    <JadeMethod name="canAccessSchemaEntity" id="3653cb1a-379d-4c5e-ae86-dd18148e6043">
        <source>canAccessSchemaEntity(schemaEntity: SchemaEntity; errorMessage: String output): Boolean;
// --------------------------------------------------------------------------------
// Created:		16 May 2005 by cnwdad1
//
// Purpose:		Refer to the superclass in Jade Help.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
/*
	if schemaEntity.isKindOf(Class) then
		if schemaEntity.name = CnEcBaseRoot.name then
			errorMessage	:=	"Access to the Base Root class is not allowed.";
			return false;
		endif;
		
	elseif schemaEntity.isKindOf(Method) then
		if schemaEntity.name = CnEcBaseRoot::setLastBackedUpLog.name then
			errorMessage	:=	"Access to setting of the last backed up log is not allowed.";
			return false;
		endif;
		
	endif;
*/
	
	return inheritMethod(schemaEntity, errorMessage);
end;</source>
        <Parameter name="schemaEntity" type="SchemaEntity"/>
        <Parameter name="errorMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canAccessStatement" id="e3c64b05-e3b0-4833-99f3-fe2284d21b69">
        <source>canAccessStatement(statement: String; errorMessage: String output): Boolean;
// --------------------------------------------------------------------------------
// Created:		16 May 2005 by cnwdad1
//
// Purpose:		Refer to the superclass in Jade Help.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
/*
	if statement = Statement_BeginTransaction then
		errorMessage	:=	"Transactions are not allowed.";
		return false;
	endif;
*/
	
	return inheritMethod(statement, errorMessage);
end;</source>
        <Parameter name="statement" type="String"/>
        <Parameter name="errorMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
