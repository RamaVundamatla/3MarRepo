<Class name="CM_ITSInterfaceController" id="8f0ae168-fd43-4afb-8673-828d1b046f7f">
    <superclass name="CM_InterfaceController"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>CCMS MES 1014 - RDT ITS Interface (Narrowband Radio solution provided International Terminal Solutions).

This class implements the master initiation application for the ITS Interface and manages the TCP/IP connection with the ITS Server.</text>
    <DbClassMap file="mobileServer"/>
    <Constant name="MessageDelim" id="4890aa3e-2fb2-47a0-bd28-10a05b1d1f96">
