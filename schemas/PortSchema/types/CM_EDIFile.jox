    </JadeMethod>
    <JadeMethod name="getName" id="afa06ed2-e50f-4806-889e-e61509f23a91">
        <source>getName() : String;
// -------------------------------------------
// Created 10 May 2004 by cnwdvb1
// -------------------------------------------
vars
	returnStr			: String;
	ediControllerAgent	: CM_EDIControllerAgent;
	
begin
	create ediControllerAgent transient;
	
	returnStr	:=	inheritMethod() &amp; Tab &amp;
					self.creationTime.cnEcShortFullFormat &amp; Tab &amp;
					self.ediClientRef.display &amp; Tab &amp;
					self.ediMessageType.display &amp; Tab &amp;
					self.fileName.padBlanks( 30 ) &amp; Tab &amp;
					'fileStatus ' &amp; self.fileStatus.display &amp; Space &amp;	// self.displayStatus.padBlanks( 30 );	// cnwrl1 31/03/2010 PAR 23432 - what it was
					ediControllerAgent.displayStatus( self.fileStatus );
	
	if self.ediData &lt;&gt; null then
		returnStr	:=	returnStr &amp; Tab &amp;
						'ediDataType ' &amp; self.ediData.ediDataType.display &amp; Tab &amp;
						'ediData status ' &amp; self.ediData.status.display &amp; Space &amp;	// self.displayStatus.padBlanks( 30 );	// cnwrl1 31/03/2010 PAR 23432 - what it was
						ediControllerAgent.displayStatus( self.ediData.status );
	endif;
	
	return returnStr;
	
epilog
	delete ediControllerAgent;
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOriginalFileDataString" id="c46ecc4c-1510-421e-b00a-8038bf9f55f5">
