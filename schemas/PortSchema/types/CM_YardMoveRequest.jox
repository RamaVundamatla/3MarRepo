    <JadeMethod name="createWLEs" id="96f1fd9c-1fd3-40fb-aa91-534e49455e97">
        <source>createWLEs();

vars
	i,
	numReq	:	Integer;
	aWLE	:	CM_YardWLE;
	
begin
	//------------
	//Create the appropriate WLEs
	//------------
	numReq := self.totalRequested;
	i := 1;		
	while true do
		create aWLE;
		aWLE.setForCreate(self.myJob, self);
		aWLE.causeEvent(aWLE.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, aWLE);				  	
		i := i+1;		
		if i &gt; numReq then
			//If total requested = 0 then we always create 1
			break;
		endif;
	endwhile;

end;</source>
    </JadeMethod>
    <JadeMethod name="getId" id="42307113-b9f4-47c2-8ea8-14aae5e40bf6">
        <source>getId() : String;

vars

begin
	return "Intrnl Move";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNominatedTA" id="50d82e48-a7a2-4a96-a8ad-1c2790641e7b">
        <source>getNominatedTA(): CM_TerminalArea;
// 23098
vars
	ta	: CM_TerminalArea;
begin
	if self.mySourceLocation &lt;&gt; null and
	   self.mySourceLocation.isGridLocation then
		ta := self.mySourceLocation.myTerminalArea;
	endif;
	return ta;
end;
</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
