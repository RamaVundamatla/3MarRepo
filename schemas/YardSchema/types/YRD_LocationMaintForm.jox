        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFlipH" id="18b3c440-4447-422c-98ce-fb676f4ea6c2">
        <updating/>
        <source>doFlipH() updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theGridArea : CMUI_GridArea;
	theFrame : CMUI_GridAreaFrame;
	flipString : String;
	theGridFrame : CMUI_GridAreaFrame;

begin

	theFrame := self.frmGridArea;
	theGridArea := theFrame.myGridArea;
	theGridArea.setFlips(self.xmlFlipH,self.xmlFlipV);
	theGridArea.doFlipH();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFlipV" id="4d7c8a78-e433-4411-9e9a-012e07895b39">
        <updating/>
        <source>doFlipV() updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theGridArea : CMUI_GridArea;
