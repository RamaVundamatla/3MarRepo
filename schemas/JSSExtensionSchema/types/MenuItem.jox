<GUIClass name="MenuItem">
    <Constant name="JSS_MENU_SEPARATOR" id="c152dbe7-052e-4f0f-9162-1b7ce2239c05">
        <source>"-"</source>
        <type name="String"/>
    </Constant>
    <JadeMethod name="jssHasSubmenu" id="2527c909-7c9e-474e-852f-39d54c36a54b">
        <source>jssHasSubmenu():Boolean;
// --------------------------------------------------------------------------------
// Created:		18 August 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver has any
//				submenu items.
//
// Parameters:	None
//
// Returns:		True if the receiver has submenus, otherwise false;
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.hasSubMenu;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsSeparator" id="bce211ed-d9ef-4898-9e5f-160ed08188af">
        <source>jssIsSeparator():Boolean;
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is a menu
//				separator.
//
// Parameters:	None
//
// Returns:		True if the Menu Item is a menu separator, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.caption = self.JSS_MENU_SEPARATOR);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
