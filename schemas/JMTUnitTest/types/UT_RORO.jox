    <JadeMethod name="tROROOOTLRotationsProposed" id="b8d9dad0-6d95-43d8-a780-6cf7204184e5">
        <updating/>
        <source>tROROOOTLRotationsProposed() updating;
/*
Purpose:		Test that the OOTL Rotation to the correct positionsw	

/* Changes

Date		Name	TFS#		Description
============================================================================
22 Jan 2013	cnwrs1	Initial creation
12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/

constants
	VoyageName1 = 'VOYSHIP30951_8';
	VoyageName2 = 'VOYSHIP30951_9';
	ShipName = 'JROSO';	//JROSO
	TestOperator = 'MSL';
	UserDefinedDeckPlan	= 'Unit Test Deck Plan';
	UserDefinedStowAdvice = 'Unit Test RORO Stow Advice';
	UserDefinedDeckPlanNoBOL	= 'Unit Test Deck Plan No BOL';
	ContainerId00 = "OOTL4307370";
	ContainerId01 = "OOTL4307371";
	ContainerId02 = "OOTL4307372";
	ContainerId03 = "OOTL4307373";
	ContainerId04 = "OOTL4307374";
	ContainerId05 = "OOTL4307375";
	ContainerId06 = "OOTL4307376";
	ContainerId07 = "OOTL4307377";
	ContainerId08 = "OOTL4307378";
	ContainerId09 = "OOTL4307379";
	ContainerId10 = "OOTL4309510";
	ContainerId11 = "OOTL4309511";
	ContainerId12 = "OOTL4309512";
	ContainerId13 = "OOTL4309513";
	ContainerId14 = "OOTL4309514";
	ContainerId15 = "OOTL4309515";
	ContainerId16 = "OOTL4309516";
	ContainerId17 = "OOTL4309517";
	ContainerId18 = "OOTL4309518";
	ContainerId19 = "OOTL4309519";
	ContainerId20 = "OOTL4307390";
	ContainerId21 = "OOTL4307391";
	ContainerId22 = "OOTL4307392";
	ContainerId23 = "OOTL4307393";
	ContainerId24 = "OOTL4307394";
	ContainerId25 = "OOTL4307395";
	ContainerId26 = "OOTL4307396";
	ContainerId27 = "OOTL4307397";
	ContainerId28 = "OOTL4307398";
	ContainerId29 = "OOTL4307399";
	ContainerId30 = "OOTL4307400";
	ContainerId31 = "OOTL4307401";
	ContainerId32 = "OOTL4307402";
	ContainerId33 = "OOTL4307403";
vars
	theLines : HugeStringArray;
	bSynchronous : Boolean;
	xmlBlock : String;
	clientRef : String;
//	clientRefDeckStowAdvice : String;
	messageType : String;
	ediText : String;
	tempStr : String;
	fileTypeUser : CM_EDIFileTypeUser;
	pxyFileTypeUser : CM_EDIFileTypeUser;
//	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile : CM_EDIFile;
	ediData : CM_EDIData;
	ediDataActual : CM_EDIData;
	ediDataProposed : CM_EDIData;
	binaryMsg : Binary;
	ediFileType : CM_EDIFileType;
	ediControllerAgent : CM_EDIControllerAgent;
	operator : CM_Operator;
	ediDataParams : CMIF_EDIDataDetails;
	ediTI : CM_EDITrackedItem;
	clientRefNum : Integer;
	found : Boolean;
	allTIs : CM_TIArray;
	theLCs : CM_LCArray;
	realAlloc : CM_YardAllocation;
	container : CM_Container;
	lc : CM_ROROSlotController;
	voyageDeck : CM_DeckVoyage;
	voyageJob : CM_VoyageJob;
	cargoType : CM_CargoType;
	workPoint: CM_WorkPoint;
	cargoTypeID : Integer;
	blockStack : CM_BlockStack;
	unloadArray : StringArray512;
	idx : Integer;
begin

	operator := app.myRoot.allOperators[TestOperator];

	// delete the voyages and recreate
	self.deleteVoyage(VoyageName1);
	voyage := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage);
	voyage := self.addVoyageWithConRORO(VoyageName1, ShipName, TestOperator, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VoyageName1);
	self.assertNotNull(voyage);

	// delete the voyages and recreate
	self.deleteVoyage(VoyageName2);
	voyage := self.getVoyage(VoyageName2);
	self.assertIsDeleted(voyage);
	voyage := self.addVoyageWithConRORO(VoyageName2, ShipName, TestOperator, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VoyageName2);
	self.assertNotNull(voyage);

	// create the OOTL and rotate
	create ediControllerAgent transient;
	create pxyFileTypeUser transient;
	create ediDataParams transient;
	create allTIs transient;
	create theLCs transient;
	create unloadArray transient;
	
	ediControllerAgent.setTerminal(self.getTerminal);	// cnwrl1 24/05/2010 PAR 24276
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_DeckPlan(UserDefinedDeckPlan);
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedDeckPlan].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedDeckPlan).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedDeckPlan &amp; ' is missing');

	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_DeckPlanNoBOL(UserDefinedDeckPlanNoBOL);
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedDeckPlanNoBOL].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedDeckPlanNoBOL).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedDeckPlanNoBOL &amp; ' is missing');

	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_ROROStowAdvice(UserDefinedStowAdvice);
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefinedStowAdvice].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefinedStowAdvice).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefinedStowAdvice &amp; ' is missing');

	self.deleteVoyage(VoyageName1);
	voyage := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage);

	operator := app.myRoot.allOperators[TestOperator];
	
	// now set up cleanly

	voyage := self.addVoyageWithConRORO(VoyageName1, ShipName, TestOperator, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
													
	self.assertNotNullMsg( voyage, 'Add voyage failed' );
	voyage := self.getVoyage(VoyageName1);
	self.assertNotNull(voyage);

	// make sure all of the objects are deleted and created correctly.
	found := false;
	clientRefNum := 0;
	while found = false do
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
		if ediFile &lt;&gt; null then
			beginTransaction;
			if ediFile.ediData = null then
				delete ediFile;
			else
				ediData := ediFile.ediData;
				delete ediData;
			endif;
			commitTransaction;
		else
			found := true;
		endif;
	endwhile;
	clientRefNum := 0;
/*
	//  now add the ship manifest via EDI
	ediControllerAgent.setTerminal(self.getTerminal);	// cnwrl1 24/05/2010 PAR 24276
	// setup the add ship manifest here
	ediText := //self.uRORODeckPlan(VoyageName, ShipName, TestOperator);
"V,A,"&amp;VoyageName1&amp;","&amp;ShipName&amp;"
L,D1400O,S
P,D1400O,1,51.0,-1.22
P,D1400O,2,57.0,-1.22
P,D1400O,3,57.0,1.23
P,D1400O,4,51.0,1.23
P,D1400O,5,51.0,-1.22
L,D1400O,S,,Yes,1X1

L,D1401O,S
P,D1401O,1,54.0,-1.22
P,D1401O,2,60.0,-1.22
P,D1401O,3,60.0,1.23
P,D1401O,4,54.0,1.23
P,D1401O,5,54.0,-1.22
L,D1401O,S,,Yes,1X1

L,D1402O,S
P,D1402O,1,85.0,-1.22
P,D1402O,2,91.0,-1.22
P,D1402O,3,91.0,1.23
P,D1402O,4,85.0,1.23
P,D1402O,5,85.0,-1.22
L,D1402O,S,,Yes,1X1

L,D1403O,S
P,D1403O,1,94.0,-1.22
P,D1403O,2,100.0,-1.22
P,D1403O,3,100.0,1.23
P,D1403O,4,94.0,1.23
P,D1403O,5,94.0,-1.22
L,D1403O,S,,Yes,1X1

C,A,,,,,CONT,,,GENL,,,,,,,,,NZPOE,D1400OR,,,,"&amp;ContainerId00&amp;",1,4262,,,,,,,,"&amp;TestOperator&amp;",,,,,,,,,,,,,12589,,,,,"&amp;VoyageName1&amp;"
C,A,,,,,CONT,,,GENL,,,,,,,,,NZPOE,D1401OR,,,,"&amp;ContainerId01&amp;",1,4262,,,,,,,,"&amp;TestOperator&amp;",,,,,,,,,,,,,12589,,,,,"&amp;VoyageName1&amp;"
C,A,,,,,CONT,,,GENL,,,,,,,,,NZPOE,D1402OR,,,,"&amp;ContainerId02&amp;",1,2200,,,,,,,,"&amp;TestOperator&amp;",,,,,,,,,,,,,12589,,,,,"&amp;VoyageName1&amp;"
C,A,,,,,CONT,,,GENL,,,,,,,,,NZPOE,D1403OR,,,,"&amp;ContainerId03&amp;",1,2200,,,,,,,,"&amp;TestOperator&amp;",,,,,,,,,,,,,12589,,,,,"&amp;VoyageName1;
	// take the edi Data string make it binary and set up the required EDI Message Type.
	
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedDeckPlan[1 : fileTypeUser.name.maxLength];  // ie 63
	clientRefNum := clientRefNum + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);

//L,D1200O,S,,Yes,1X1

	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg);
		tempStr	:= 'Failed to load edi data ';
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg);
		tempStr	:= 'Failed to queue edi data ';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
//	self.assertEqualMsg(ediControllerAgent.ediStatusCode, null, tempStr &amp; ' pos 1');
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertNotNull(ediFile);

	// uncomment when #30863 1) has been fixed.
	//self.xRemoveCargoFromSlot(voyage, "D1401OR");
	//self.xRemoveCargoFromSlot(voyage, "D1403OR");
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	
	// Now check the actual data has been loaded correctly.
*/

	
	
	
	
	clientRef := null;

	// now add RORO Stow advice
	ediControllerAgent.setTerminal(self.getTerminal);	// cnwrl1 24/05/2010 PAR 24276
	
	// setup the add stowage advice here
	ediText := self.uROROStowAdvice30863(VoyageName1, ShipName, TestOperator);
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefinedStowAdvice[1 : fileTypeUser.name.maxLength];  // ie 63
	clientRefNum := clientRefNum + 1;
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load edi data ';
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue edi data ';
	endif;
	tempStr	:= tempStr &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertNotNull(ediFile);
	
	// now extract the details
	ediFileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedStowAdvice];
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		ediData := ediControllerAgent.loadDeckStowageAdvice(voyage, clientRef, voyage.myOperator, ediFileType);
		ediDataParams.operator := voyage.myOperator;
		ediFile := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediData.number, ediDataParams);
	endif;
	self.deleteWorkPoint("UT_30728");
	workPoint := self.addWorkPoint("UT_30728", true);
	blockStack := self.addBlockStack("DIAM", 10000, null);	
	voyageDeck := voyage.myROROStructure.allDecksByCode["1"];
	
	allTIs.clear();
	theLCs.clear();
	container := self.addContainerForExport(ContainerId20,
									operator,
									"2200",					// ISOType is not needed
									"GENL",					// commodity is not needed
									TI_IMEX_STATUS_EXPORT,	// import not export
									"PAR30360",					// booking id
									voyage.code,
									"DEBRV",					// dischargePort
									null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerId01.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	allTIs.add(container);
	lc := voyage.myROROStructure.findSlotController("D1901O", 1);
	theLCs.add(lc);
	// add the voyage job and plan the containers
	container := self.addContainerForExport(ContainerId21,
									operator,
									"2200",					// ISOType is not needed
									"GENL",					// commodity is not needed
									TI_IMEX_STATUS_EXPORT,	// import not export
									"PAR30360",					// booking id
									voyage.code,
									"DEBRV",					// dischargePort
									null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerId11.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	allTIs.add(container);
	lc := voyage.myROROStructure.findSlotController("D1003", 1);
	theLCs.add(lc);
	container := self.addContainerForExport(ContainerId22,
									operator,
									"2200",					// ISOType is not needed
									"GENL",					// commodity is not needed
									TI_IMEX_STATUS_EXPORT,	// import not export
									"PAR30360",					// booking id
									voyage.code,
									"DEBRV",					// dischargePort
									null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerId12.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	allTIs.add(container);
	lc := voyage.myROROStructure.findSlotController("D1042", 1);
	theLCs.add(lc);
	container := self.addContainerForExport(ContainerId23,
									operator,
									"2200",					// ISOType is not needed
									"GENL",					// commodity is not needed
									TI_IMEX_STATUS_EXPORT,	// import not export
									"PAR30360",					// booking id
									voyage.code,
									"DEBRV",					// dischargePort
									null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerId11.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	allTIs.add(container);
	lc := voyage.myROROStructure.findSlotController("D1301OR", 1);
	theLCs.add(lc);

	// add the voyage job and plan the containers
	voyageDeck := voyage.myROROStructure.allDecksByCode['1'];
	voyageJob := self.addVoyageROROJob(voyage, voyageDeck, "UT_30728", theLCs, false);
	assertTrue(voyageJob &lt;&gt; null);
	realAlloc := theLCs.first.getRequest(true).getVoyageAllocations().first;

	self.planTIsRORO(allTIs, theLCs, realAlloc.CM_VoyageAllocation.allRequests.first.CM_RORORequest); //realAlloc.allRequests.first.CM_RORORequest);

	allTIs.clear();
	theLCs.clear();
	container := self.addContainerForExport(ContainerId27,
									operator,
									"2200",					// ISOType is not needed
									"GENL",					// commodity is not needed
									TI_IMEX_STATUS_EXPORT,	// import not export
									"PAR30360",					// booking id
									voyage.code,
									"DEBRV",					// dischargePort
									null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerId01.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	allTIs.add(container);
	lc := voyage.myROROStructure.findSlotController("D2100O", 1);
	theLCs.add(lc);

	container := self.addContainerForExport(ContainerId28,
									operator,
									"2200",					// ISOType is not needed
									"GENL",					// commodity is not needed
									TI_IMEX_STATUS_EXPORT,	// import not export
									"PAR30360",					// booking id
									voyage.code,
									"DEBRV",					// dischargePort
									null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerId01.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	allTIs.add(container);
	lc := voyage.myROROStructure.findSlotController("D2101O", 1);
	theLCs.add(lc);
	// add the voyage job and plan the containers
//	voyageDeck := voyage.myROROStructure.allDecksByCode['2'];
//	voyageJob := self.addVoyageROROJob(voyage, voyageDeck, "UT_307282", theLCs, false);
//	assertTrue(voyageJob &lt;&gt; null);
//	realAlloc := theLCs.first.getRequest(true).getVoyageAllocations().first;

//	self.planTIsRORO(allTIs, theLCs, realAlloc.CM_VoyageAllocation.allReques//ts.first.CM_RORORequest); //realAlloc.allRequests.first.CM_RORORequest);

//	allTIs.clear();
//	theLCs.clear();
	container := self.addContainerForExport(ContainerId29,
									operator,
									"4262",					// ISOType is not needed
									"GENL",					// commodity is not needed
									TI_IMEX_STATUS_EXPORT,	// import not export
									"PAR30360",					// booking id
									voyage.code,
									"DEBRV",					// dischargePort
									null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerId01.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	allTIs.add(container);
	lc := voyage.myROROStructure.findSlotController("D2101O", 2);
	theLCs.add(lc);
	// add the voyage job and plan the containers
	voyageDeck := voyage.myROROStructure.allDecksByCode['2'];
	voyageJob := self.addVoyageROROJob(voyage, voyageDeck, "UT_307283", theLCs, false);
	assertTrue(voyageJob &lt;&gt; null);
	realAlloc := theLCs.first.getRequest(true).getVoyageAllocations().first;

	self.planTIsRORO(allTIs, theLCs, realAlloc.CM_VoyageAllocation.allRequests.first.CM_RORORequest); //realAlloc.allRequests.first.CM_RORORequest);

	ediControllerAgent.setTerminal(self.getTerminal);
	ediFileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedDeckPlanNoBOL];
	ediDataParams.operator := voyage.myOperator;
	//now extract the actual and proposed deck plan and compare them - they should be different
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		ediData := ediControllerAgent.loadDeckPlanTIs(voyage, ACTUAL_BAYPLANS, clientRef, voyage.myOperator, ediFileType);
		ediDataActual := ediData;
		ediFile := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediData.number, ediDataParams);
		// now check the data lines
		unloadArray.clear();
//		write "*************** Actual ******************";
		unloadArray.add("V,A,VOYSHIP30951_8,Jolly Rosso");
		
		unloadArray.add("L,D1400O,S,0.0000,false,");
		unloadArray.add("P,D1400O,1,51.00,-1.20");
		unloadArray.add("P,D1400O,2,57.00,-1.20");
		unloadArray.add("P,D1400O,3,57.00,1.20");
		unloadArray.add("P,D1400O,4,51.00,1.20");
		unloadArray.add("P,D1400O,5,51.00,-1.20");
		unloadArray.add("L,D1400O,,0.0000,true,1X1");
	
		// remove when #30863 1) has been done
		unloadArray.add("L,D1401O,S,0.0000,false,");
		unloadArray.add("P,D1401O,1,54.00,-1.20");
		unloadArray.add("P,D1401O,2,60.00,-1.20");
		unloadArray.add("P,D1401O,3,60.00,1.20");
		unloadArray.add("P,D1401O,4,54.00,1.20");
		unloadArray.add("P,D1401O,5,54.00,-1.20");
		unloadArray.add("L,D1401O,,0.0000,true,1X1");

		
		unloadArray.add("L,D1402O,S,0.0000,false,");
		unloadArray.add("P,D1402O,1,85.00,-1.20");
		unloadArray.add("P,D1402O,2,91.00,-1.20");
		unloadArray.add("P,D1402O,3,91.00,1.20");
		unloadArray.add("P,D1402O,4,85.00,1.20");
		unloadArray.add("P,D1402O,5,85.00,-1.20");
		unloadArray.add("L,D1402O,,0.0000,true,1X1");
		
		// remove when #30863 1) has been done
		unloadArray.add("L,D1403O,S,0.0000,false,");
		unloadArray.add("P,D1403O,1,94.00,-1.20");
		unloadArray.add("P,D1403O,2,100.00,-1.20");
		unloadArray.add("P,D1403O,3,100.00,1.20");
		unloadArray.add("P,D1403O,4,94.00,1.20");
		unloadArray.add("P,D1403O,5,94.00,-1.20");
		unloadArray.add("L,D1403O,,0.0000,true,1X1");

		unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D1400OR,,0.0000,,OOTL4307370,Import,4262,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,VOYSHIP30951_8,,,0.0000,,,");
		unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D1401OR,,0.0000,,OOTL4307371,Import,4262,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,VOYSHIP30951_8,,,0.0000,,,");
		unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D1402OR,,0.0000,,OOTL4307372,Import,2200,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,VOYSHIP30951_8,,,0.0000,,,");
		unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D1403OR,,0.0000,,OOTL4307373,Import,2200,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,VOYSHIP30951_8,,,0.0000,,,");
		idx := 0;
		create theLines transient;
		ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
		foreach ediText in theLines do
			idx := idx + 1;
//			write ediText;
			self.assertEqualMsg(ediText, unloadArray[idx], "line "&amp;idx.String&amp;" error.");
		endforeach;
	endif;
	ediFileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedDeckPlan];
	ediDataParams.operator := voyage.myOperator;
	//now extract the actual and proposed deck plan and compare them - they should be different
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		ediData := ediControllerAgent.loadDeckPlanTIs(voyage, ACTUAL_BAYPLANS, clientRef, voyage.myOperator, ediFileType);
		ediDataActual := ediData;
		ediFile := ediData.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediData.number, ediDataParams);
	endif;

	if ediFileType &lt;&gt; null then
		self.deleteVoyage(VoyageName2);
		voyage := self.getVoyage(VoyageName2);
		self.assertIsDeleted(voyage);
		voyage := self.addVoyageWithConRORO(VoyageName2, ShipName, TestOperator, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
		self.assertNotNullMsg( voyage, 'Add voyage failed' );
		voyage := self.getVoyage(VoyageName2);
		self.assertNotNull(voyage);
		foreach ediTI in ediDataActual.allEDITrackedItems do
			if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
				beginTransaction;
				ediTI.setVoyageCode(VoyageName2);
				commitTransaction;
			elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
				beginTransaction;
				ediTI.setVoyageCode(VoyageName2);
				ediTI.setId(ediTI.id.replace('OOTL4', 'OOTL6'));
				commitTransaction;
			endif;
		endforeach;
		beginTransaction;
		ediDataActual.setStatus(CM_EDIFile.EDI_STATUS_VERIFYING);
		commitTransaction;
		self.ediDBLoad(ediDataActual.ediFileArray.last);
		tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
		self.assertEqualMsg(ediDataActual.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
		ediControllerAgent.setTerminal(self.getTerminal);
		ediFileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedDeckPlanNoBOL];
		ediDataParams.operator := voyage.myOperator;
		//now extract the actual and proposed deck plan and compare them - they should be different
		if ediFileType &lt;&gt; null then
			clientRefNum := clientRefNum + 1;
			clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
			ediControllerAgent.setEdiClientRef(clientRef);
			ediData := ediControllerAgent.loadDeckPlanTIs(voyage, ACTUAL_BAYPLANS, clientRef, voyage.myOperator, ediFileType);
			ediDataActual := ediData;
			ediFile := ediData.ediFileArray.last;//should be the one we just created 
			ediControllerAgent.extractFile(ediFile, ediData.number, ediDataParams);
			// now check the data lines
			unloadArray.clear();
//			write "*************** Actual ******************";
			unloadArray.add("V,A,VOYSHIP30951_9,Jolly Rosso");
			
			unloadArray.add("L,D1400O,S,0.0000,false,");
			unloadArray.add("P,D1400O,1,51.00,-1.20");
			unloadArray.add("P,D1400O,2,57.00,-1.20");
			unloadArray.add("P,D1400O,3,57.00,1.20");
			unloadArray.add("P,D1400O,4,51.00,1.20");
			unloadArray.add("P,D1400O,5,51.00,-1.20");
			unloadArray.add("L,D1400O,,0.0000,true,1X1");
		
			// remove when #30863 1) has been done
			unloadArray.add("L,D1401O,S,0.0000,false,");
			unloadArray.add("P,D1401O,1,54.00,-1.20");
			unloadArray.add("P,D1401O,2,60.00,-1.20");
			unloadArray.add("P,D1401O,3,60.00,1.20");
			unloadArray.add("P,D1401O,4,54.00,1.20");
			unloadArray.add("P,D1401O,5,54.00,-1.20");
			unloadArray.add("L,D1401O,,0.0000,true,1X1");
			
			unloadArray.add("L,D1402O,S,0.0000,false,");
			unloadArray.add("P,D1402O,1,85.00,-1.20");
			unloadArray.add("P,D1402O,2,91.00,-1.20");
			unloadArray.add("P,D1402O,3,91.00,1.20");
			unloadArray.add("P,D1402O,4,85.00,1.20");
			unloadArray.add("P,D1402O,5,85.00,-1.20");
			unloadArray.add("L,D1402O,,0.0000,true,1X1");
			
			// remove when #30863 1) has been done
			unloadArray.add("L,D1403O,S,0.0000,false,");
			unloadArray.add("P,D1403O,1,94.00,-1.20");
			unloadArray.add("P,D1403O,2,100.00,-1.20");
			unloadArray.add("P,D1403O,3,100.00,1.20");
			unloadArray.add("P,D1403O,4,94.00,1.20");
			unloadArray.add("P,D1403O,5,94.00,-1.20");
			unloadArray.add("L,D1403O,,0.0000,true,1X1");
	
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D1400OR,,0.0000,,OOTL6307370,Import,4262,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,VOYSHIP30951_9,,,0.0000,,,");
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D1401OR,,0.0000,,OOTL6307371,Import,4262,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,VOYSHIP30951_9,,,0.0000,,,");
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D1402OR,,0.0000,,OOTL6307372,Import,2200,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,VOYSHIP30951_9,,,0.0000,,,");
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D1403OR,,0.0000,,OOTL6307373,Import,2200,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00,,,,,12589,,,,0.000,VOYSHIP30951_9,,,0.0000,,,");
			idx := 0;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach ediText in theLines do
				idx := idx + 1;
//				write ediText;
				self.assertEqualMsg(ediText, unloadArray[idx], "line "&amp;idx.String&amp;" error.");
			endforeach;
		endif;
	endif;
	
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
	delete allTIs;
	delete theLCs;
	delete unloadArray;
	delete theLines;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Michael_PAR31258&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
