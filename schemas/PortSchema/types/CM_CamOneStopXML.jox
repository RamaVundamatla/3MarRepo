    <JadeMethod name="makeWeightCertIPSubSectXML" id="d406e5d9-e78e-4b46-ae12-8dd2736bf237">
        <source>makeWeightCertIPSubSectXML( _ti: CM_TrackedItem; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/08/2016	cnwndl1	Initial creation	TFS 2561 / 2277
19/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;
	pos, cityPos : Integer;						// TFS 4492
	street, city, country : String;				// TFS 4492
	container : CM_Container;					// TFS 4492
	vgmMail : String;							// TFS 4492

begin

	rootElem := _parentElem.addElement('WeightCertificateIssuingParty');
	
	if _ti = null then
		return;
	endif;
	
	if _ti.isKindOf(CM_Container) and _ti.CM_Container.myVGMDetails &lt;&gt; null then	// TFS 4492
		container := _ti.CM_Container;												// TFS 4492
		xmlElem := rootElem.addElement('NameOfIssuingParty');						// TFS 4492
		xmlElem.setText( container.myVGMDetails.weightCertifiedReference );			// TFS 4492
																					// TFS 4492
		vgmMail := container.myVGMDetails.vgmMail;									// TFS 4492
/*		pos := vgmMail.reversePos(Space);											// TFS 4492
		if pos &lt;&gt; null then															// TFS 4492
			country := vgmMail[pos+1:end];											// TFS 4492
			cityPos := vgmMail.reversePosIndex(Space, pos-1);						// TFS 4492
			if cityPos &lt;&gt; null then													// TFS 4492
				city := vgmMail[cityPos+1:pos-cityPos];								// TFS 4492
				if cityPos &lt;&gt; null then												// TFS 4492
					street := vgmMail[1:cityPos-1];									// TFS 4492
				endif;																// TFS 4492
			endif;																	// TFS 4492
		endif;																		// TFS 4492	*/
		
		vgmMail.getAddressValues( street, city, country );	//15 Nov 2017	NDL	TFS 7779
		
		xmlElem := rootElem.addElement('Street');									// TFS 4492
		if street &lt;&gt; null then														// TFS 4492
			xmlElem.setText( street );												// TFS 4492
		else																		// TFS 4492
			xmlElem.setText( null );												// TFS 4492
		endif;																		// TFS 4492
																					// TFS 4492
		xmlElem := rootElem.addElement('City');										// TFS 4492
		if city &lt;&gt; null then														// TFS 4492
			xmlElem.setText( city );												// TFS 4492
		else																		// TFS 4492
			xmlElem.setText( null );												// TFS 4492
		endif;																		// TFS 4492
																					// TFS 4492
		xmlElem := rootElem.addElement('Country');									// TFS 4492
		if country &lt;&gt; null then														// TFS 4492
			xmlElem.setText( country );												// TFS 4492
		else																		// TFS 4492
			xmlElem.setText( null );												// TFS 4492
		endif;																		// TFS 4492
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_parentElem" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="outputFile" id="a99c7444-e1fa-4bfa-a343-54134b8e845e">
        <updating/>
        <source>outputFile(_protocol: CM_CamProtocol input; _camAgent: CM_CamControllerAgent; _camFile: CM_CamFile input; _runDateTime: TimeStamp; _camTaskHistory: CM_CamTaskHistory input; _unhSeqNumber: Integer io; _seqNumber: Integer; _terminal: CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Aug 2016	cnwndl1	Initial creation	TFS 2561 / 2277
03 Mar 2017 cnwgb1  TFS 3643
09 Jan 2020	jlgdap1	TFS 48016 SNO Deletion CODECO - new _transactions parameter

*/

vars
	camVoyage 		: CM_CamVoyage;
	camMessage 		: CM_CamMessage;
	str, outputStr 		: String;
	messageType 	: String;
	singleQuote	:Character;
	strLine : String;
begin

	singleQuote	:= _protocol.segmentTerminator;
	
	app.writeLog("===================================", LogWARN);
	
	if _camFile.camVoyages.size &gt; 0 then
        _camFile.incrementMessageCount(); // TFS 3643 cnwgb1 3 Mar 2017
		foreach camVoyage in _camFile.camVoyages do
			foreach camMessage in camVoyage.camMessages do
				
				foreach str in camMessage.group3 do
				
					if str[str.length:1] = singleQuote then
						outputStr := outputStr &amp; str;
						strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, outputStr, null);
						outputStr := null; //reset this now
					else
						//we dont end with a segment terminator so lets just collect data						
						outputStr := outputStr &amp; str;
					endif;
									
				endforeach;
				
				
			endforeach;
		endforeach;
	endif;

	app.writeLog("===================================", LogWARN);
	_camTaskHistory.setRawDataString(outputStr);
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="outputFileMessage" id="bf391ec1-6c34-474d-8cca-adcab3041244">
        <updating/>
        <source>outputFileMessage(_camTaskHistory: CM_CamTaskHistory input; _message: String; _coll: HugeStringArray input): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars
    str : String;
begin
	
	str := _message;
	
	if _coll &lt;&gt; null then
		if str.length &gt; 511 then
			str := str [1:511];
		endif;
		
		_coll.add (str);
	endif;
	
	return str;
end;</source>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processEvent" id="939c4b63-5b58-4aac-98d7-1706df3effce">
        <updating/>
        <source>processEvent(_transaction: CM_EventTransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277

*/

vars

	xmlDoc : JadeXMLDocument;
	messHdrEventType : String;
	messTypeDesc : String; 
	strMsg : String;
	camMessage : CM_CamMessage;
	voyage : CM_Voyage;
	voyageCode : String;
	vesselName : String;

begin

	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.getDescription);
	
	//setup the type details for the 
	self.getMessHdrTypeFromTrx( _transaction, null, messHdrEventType, messTypeDesc );
	
	create xmlDoc transient;
    xmlDoc.outputDeclaration := true;
	
	
	self.getFullXMLForEvent( _camProtocol, _transaction, messHdrEventType, messTypeDesc, xmlDoc );
	
	strMsg := xmlDoc.writeToString();
	
	voyage := _transaction.CMEVT_VoyageEvent.myVoyage;
	if voyage &lt;&gt; null then
		voyageCode := voyage.code;
		if voyage.myVessel &lt;&gt; null then
			vesselName := voyage.myVessel.name;
		endif;
	endif;
	
	camMessage := self.getCamMessage(_camFile, voyageCode, vesselName, 0, _camProtocol.singleContainerPerBGM); 
	self.addMessage(camMessage.group3, strMsg);

epilog

	delete xmlDoc;

end;</source>
        <Parameter name="_transaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="6ec2d78e-3291-4a89-abf1-141197244112">
        <updating/>
        <source>processTransaction(_transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2016	cnwndl1	Initial creation	TFS 2561 / 2277
//20 dec 2016	cnwrs1	TFS 3158 Cams Exclusion report does not include the rehandles and sobs
*/

vars

	ti : CM_TrackedItem;
	xmlDoc : JadeXMLDocument;
	messHdrEventType : String;
	messTypeDesc : String; 
	strMsg : String;
	camMessage : CM_CamMessage;
	str : String;

begin

	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.getCamsDisplayDetails);
	
	ti := _transaction.myTrackedItem;
	if ti = null then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'There is no Cargo Item associated with the TI Transaction');
		endif;
		return;
	endif;
	
	//setup the type details for the 
	self.getMessHdrTypeFromTrx( _transaction, ti, messHdrEventType, messTypeDesc );
	
	create xmlDoc transient;
    xmlDoc.outputDeclaration := true;
	
	self.getFullXMLForTiTrx( _camProtocol, ti,  _transaction, messHdrEventType, messTypeDesc, xmlDoc );
	
	strMsg := xmlDoc.writeToString();
	
	camMessage := self.getCamMessage(_camFile, "", null, 0, _camProtocol.singleContainerPerBGM); 
	
	self.addMessage(camMessage.group3, strMsg);
	self.addXMLLinesToGroup4(camMessage.group4, strMsg);
	
	
	camMessage.tiId := ti.id.trimRight;
	camMessage.setupCAMSInfoDetails(_camProtocol, camMessage.group3.size, camMessage.group4.size, camMessage.group5.size, _transaction);
	foreach str in camMessage.group4 do
		camMessage.setupCAMSInfoDetailsStr (_camProtocol, str, _transaction); 
	endforeach;
	

epilog

	delete xmlDoc;

end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
