    <JadeMethod name="isDefaultCargoIcon" id="6325c5d9-3281-42ab-a171-e15aecc57cb1">
        <source>isDefaultCargoIcon(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/01/2018	jlgmp6	Initial creation	TFS36749
04/11/2019	jlgdap1	TFS 46405 AAT Flat rack and OOG in LOLO Planning Screen
*/

vars
	code: String;
begin
	code := self.code;

	return code = PicTIInTransit
		or code = PicTIReadyToShip
		or code = PicTICustomHold
		or code = PicTIHazard
		or code = PicSpecialStow
		or code = PicTITBA
		or code = PicTIQueued
		or code = PicTIPlanned
		or code = PicTI40Footer
		or code = PicTI45Footer
		or code = PicTI30Footer
		or code = PicTI53Footer
		or code = PicTIWaterCooled
		or code = PicTIControlledAtmos
		or code = PicTIConnected
		or code = PicTIReefer
		or code = PicTICOU
		or code = PicTIEmpty
		or code = PicTIFlat
		or code = PicTICrib
		or code = PicTIFrame //05 Feb 2018	NDL	TFS 36752
		or code = PicTIOpentop
		or code = PicTIFantainer
		or code = PicTITank
		or code = PicTIHiCube
		or code = PicTI_OD_HLW
		or code = PicTI_OD_HL
		or code = PicTI_OD_HW
		or code = PicTI_OD_H
		or code = PicTI_OD_WL
		or code = PicTI_OD_L
		or code = PicTI_OD_W
		or code = PicTIBreakBulk
		or code = PicTITimber
		or code = PicTIFlatRackEndsDown		// TFS 46405
		or code = PicTIFlatRackEndsUp;		// TFS 46405
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e8553ddc-cbc8-4dd2-ba8a-3928cf876ffe">
        <updating/>
        <source>setForCreate(_theProxyAttribute : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/10/2017   cnwma1		TFS #7431	JMT - Refactoring - Drawing Attributes Labels
// ---------------------------------------------------------------------------

vars

begin
	self.colour := _theProxyAttribute.colour;
	self.fontCharacter := _theProxyAttribute.fontCharacter;
	self.fontName := _theProxyAttribute.fontName;
	self.myRoot := _theProxyAttribute.myRoot;
	self.code := _theProxyAttribute.code;

	if _theProxyAttribute.getLabel&lt;&gt; null then    //31/10/2017 cnwma1	 TFS #7431
		self.label := _theProxyAttribute.getLabel;
	else
		self.label := _theProxyAttribute.code;
	endif;
	
end;</source>
        <Parameter name="_theProxyAttribute" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b3562f74-b38d-4eb2-bd7e-8614b559df32">
        <updating/>
        <source>setForUpdate(_theProxyAttribute : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/10/2017   cnwma1		TFS #7431	JMT - Refactoring - Drawing Attributes Labels
// ---------------------------------------------------------------------------

vars

begin
	self.colour := _theProxyAttribute.colour;
	self.fontCharacter := _theProxyAttribute.fontCharacter;
	self.fontName := _theProxyAttribute.fontName;
	self.code := _theProxyAttribute.code;
	
	if _theProxyAttribute.getLabel&lt;&gt; null then    //31/10/2017 cnwma1	 TFS #7431
		self.label := _theProxyAttribute.getLabel;
	else
		self.label := _theProxyAttribute.code;
	endif;
end;</source>
        <Parameter name="_theProxyAttribute" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdatePriority" id="d2f3d884-f362-4ece-a338-299c1e8e5656">
        <updating/>
        <source>setForUpdatePriority(_priority : Integer)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2017	jlgma1	Initial creation

*/

vars
	
begin
	if self.priority &lt;&gt; _priority then
		self.priority :=_priority;
	endif;
epilog

end;</source>
        <Parameter name="_priority" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="75680a69-f8a3-42bd-888c-2caad29caf45">
        <updating/>
        <source>setProxy(_theCode : String;_theFontName : String;_theFontCharacter : Integer; _theColour : Integer;_myRoot : CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.myRoot := _myRoot;
	self.code :=  _theCode;
	self.fontName := _theFontName;
	self.fontCharacter := _theFontCharacter;
	self.colour :=  _theColour ;
end;</source>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_theFontName" type="String"/>
        <Parameter name="_theFontCharacter" type="Integer"/>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_myRoot" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="2141620c-6149-4d00-b660-1c2ebd264d31">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if app.myRoot.allDrawingAttributes[self.code] &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE,"Code",self.code &amp; " is already In Use. Choose a Different Code",null,null);
	endif;
	
	self.validateForUpdate();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="ac294e79-8ae7-4872-bbff-9d3e823ea84b">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.code = null then
		app.raiseCMException2(ERR_INVALID_VALUE,"Code","A Code Must Be Entered.",null,null);
	endif;
	if self.colour &lt; 0 then
		app.raiseCMException2(ERR_INVALID_VALUE,"Colour","A Colour Must Be Entered.",null,null);
	endif;
	if self.fontName = null then
		app.raiseCMException2(ERR_INVALID_VALUE,"Font Name","A Font Name Must Be Entered.",null,null);
	endif;
	if self.fontCharacter  &lt; 1 or self.fontCharacter &gt; 255 then
		app.raiseCMException2(ERR_INVALID_VALUE,"Character","A Character Must Be Entered Between 1 and 255. " &amp; self.code &amp; " " &amp; self.fontCharacter.String,null,null);
	endif;

end;</source>
    </JadeMethod>
</Class>
