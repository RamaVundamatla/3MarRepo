    <JadeMethod name="setWeighbridgeSerial" id="a36ce46b-7599-4032-9ccb-240d2d9a6e2f">
        <updating/>
        <source>setWeighbridgeSerial(_weighBridge : CM_WeighBridgeObj) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2017	cnwns1	Initial creation

*/

vars
	ld	:CM_LDWeighBridge;
	ldReal : CM_LDWeighBridge;
begin

	
	ldReal := self.getLaneDevice_WeighBridge();
	
	if _weighBridge = null then
		if ldReal &lt;&gt; null then
			delete ldReal;
		endif;
		return;
	endif;
	
	if ldReal = null then
		create ld transient;
		ld.setMyLaneController (self);
		ld.setWeighBridge(_weighBridge);
		create ldReal persistent;
	
		ldReal.setForCreate(ld,self);
	else
		ldReal.setWeighBridge(_weighBridge);
	endif;
		
	
epilog
	delete ld;
end;</source>
        <Parameter name="_weighBridge" type="CM_WeighBridgeObj"/>
    </JadeMethod>
