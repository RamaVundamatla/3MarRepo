    <JadeMethod name="setForCreate" id="ab3bec8f-1857-4025-8dfe-55e924e0f705">
        <updating/>
        <source>setForCreate( _proxyStopOverriddenReason	: CM_StopOverridenReason input ) updating;

/*
Purpose:	Create a real from the supplied proxy.

Date			Who		Reason
20 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	
begin
	_proxyStopOverriddenReason.raiseExceptionIfNotTransient( method );
	
	self.setForUpdate( _proxyStopOverriddenReason );
	self.myRoot	:= app.myRoot;
	
epilog
	
end;
</source>
        <Parameter name="_proxyStopOverriddenReason" type="CM_StopOverridenReason" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3ff4c5a2-47ee-4720-8b1a-5f58bf2ea376">
        <updating/>
        <source>setForUpdate( _proxyStopOverriddenReason : CM_StopOverridenReason input ) updating;

/*
Purpose:	Update the real object from the supplied proxy object.

Date			Who		Reason
20 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	
begin
	self.code			:= _proxyStopOverriddenReason.code;
	self.description	:= _proxyStopOverriddenReason.description;
	
epilog
	
end;
</source>
        <Parameter name="_proxyStopOverriddenReason" type="CM_StopOverridenReason" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="a47ddc83-edc9-4684-9257-0b5f3471626d">
        <updating/>
        <source>setProxy( _code : String; _description : String ) updating;

/*
Date			Who		Reason
20 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	maxLength	: Integer;
	
begin
	self.raiseExceptionIfNotTransient( method );
	
	maxLength			:= CM_StopOverridenReason::code.getLengthForString();
	self.code			:= _code[ 1 : maxLength ].trimBlanks;
	maxLength			:= CM_StopOverridenReason::description.getLengthForString();
	self.description	:= _description[ 1 : maxLength ].trimBlanks;
	self.myRoot 		:= app.myRoot;
	
epilog
	
end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="e0432396-87c3-49d7-aa0a-3fac2605e1ee">
        <source>validateForCreate();

/*
Purpose:	Do any validation that is specified to creation only.

Date			Who		Reason
20 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	
begin
	if app.myRoot.allStopOverridenReasonsByCode[ self.code ] &lt;&gt; null then
		app.raiseCMException1( VB_DUPLICATED_ITEM, self.code, ETRow_Code, null );
	endif;
	
	self.validateMe();			// now do the general validation
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="5a7c31fb-e9f5-4380-bfee-97bbd9f6a4ae">
        <source>validateForDelete();

/*
Purpose:	Check if it is valid to delete this object.

Date			Who		Reason
20 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	stopOverride	: CM_StopOverride;
	stopUpdate		: CM_StopUpdate;
	
begin
	// Note because self.continueCMExceptions has been set to false - we only get the first error to save time.
	foreach stopOverride in CM_StopOverride.instances discreteLock do : cond_loop
		if stopOverride.myStopOverrideReason &lt;&gt; null and stopOverride.myStopOverrideReason = self then
			app.raiseCMException2( StopOverriddenReason_Delete, self.code, stopOverride.id.display, null, null );
			break;		// though this is done because self.continueCMExceptions is false!
		endif;
	endforeach cond_loop;
	
	foreach stopUpdate in CM_StopUpdate.instances discreteLock do : cond_loop
		if stopUpdate.myStopOverrideReason &lt;&gt; null and stopUpdate.myStopOverrideReason = self then
			app.raiseCMException2( StopOverriddenReason_Delete, self.code, stopUpdate.id.display, null, null );
			break;		// though this is done because self.continueCMExceptions is false!
		endif;
	endforeach cond_loop;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="d2dbc16d-cf0d-4169-b5dc-3524c8c54400">
        <source>validateForUpdate();

/*
Purpose:	Do any validation that is specified to updating only.

Date			Who		Reason
20 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	
begin
	self.validateMe();			// now do the general validation
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="0927a152-60f8-4787-ab5a-249ca216f821">
        <source>validateMe() protected;

/*
Purpose:	Do any validation that is applicable to both creation and updating.

Date			Who		Reason
20 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	
begin
	if self.code = null then
	//	app.raiseCMException1( REQUIRED_FIELD, ETRow_Code, ETRow_Code, null );
		app.raiseCMException1( Input_required_field_Required, ETRow_Code, ETRow_Code, null ); // cnwdb2	PAR 35364


	endif;
	
	if self.description = null then
	//	app.raiseCMException1( REQUIRED_FIELD, ETRow_Description, ETRow_Description, null );
		app.raiseCMException1( Input_required_field_Required, ETRow_Description, ETRow_Description, null ); // cnwdb2	PAR 35364


	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
</Class>
