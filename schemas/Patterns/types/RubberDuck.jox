<Class name="RubberDuck" id="9a0a10fd-4f93-49b4-9697-0f278135c217">
    <superclass name="Duck"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <JadeMethod name="create" id="8b7241fb-b7ac-41c4-8529-dca25d728485">
        <updating/>
        <source>create() updating;
//25 August 2009	cnwdw1	
//
vars
begin
	write "I am a Rubber Ducky";
	create self.flyer as FlyNoWay transient;
	self.flyBehaviour := flyer.FlyNoWay;
	create self.quackBehaviour as Squeak transient;
end;</source>
    </JadeMethod>
