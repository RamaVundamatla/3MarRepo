    <JadeMethod name="displayEntryRoadBulkRelease" id="28b791c7-d03a-433f-be38-d40cecaaf0b9">
        <source>displayEntryRoadBulkRelease(pRelease : CM_BulkRelease) : String;
// ---------------------------------------------------------------------------
// Created:     10 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpBR	 : CM_BulkRelease;
begin



	if pRelease &lt;&gt; null then
//			return pRelease.code;
	
		if pRelease.type &lt;&gt; BR_TYPE_ROAD then 
			return null;
		endif;
	
		if pRelease.status &lt;&gt; BR_ACTIVE then
			return null;
		endif;
	
		tmpBR := pRelease.myTerminal.getBulkReleaseFromCode(pRelease.code); // ### AKB2005MAY - cope with duplicate codes.
	
		if tmpBR = pRelease then
			return pRelease.code;
		else
			return pRelease.code &amp; Tab &amp; pRelease.dateRequested.date.String; // ### AKB2005MAY - cope with duplicate codes.
			
		endif;
	else
		return null;
	endif;
	

	
end;</source>
        <Parameter name="pRelease" type="CM_BulkRelease"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayEntryRowArea" id="f9e0e570-a6eb-46e3-a5ad-6c098521e8aa">
        <source>displayEntryRowArea(_terminal : CM_Terminal; _row : CM_RowController) :String;
// ---------------------------------------------------------------------------
// Created:     13 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _terminal = null or _row = null then
		return null;
	endif;
	
	if _row.myTerminal &lt;&gt; _terminal then
		return null;
	endif;

	return _row.id;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_row" type="CM_RowController"/>
        <ReturnType type="String"/>
    </JadeMethod>
