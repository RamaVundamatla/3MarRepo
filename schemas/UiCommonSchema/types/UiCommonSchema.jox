    <JadeMethod name="doLicense" id="8651eba2-226e-48fb-a1ad-b8e9c4ccb1e6">
        <source>doLicense(_obj : CM_Object; _isSpecial : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:     01 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

// isSpecial - new parameter, PAR12809
// purpose - to call the License Installing screen, when user starts JMTerminal
// and the license is deleted before

vars
	form : CMUI_LicenseForm;	

begin

	if _obj = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null license object');
		return false;
	endif;

	if _isSpecial then		//PAR12809
		create form transient;
		form.createMyAssistant(CMUI_Assistant);
		app.mousePointer := Window.MousePointer_Default;
	else
		form := app.loadForm(CMUI_LicenseForm, CMUI_Assistant, false, false, true, null, null).CMUI_LicenseForm;
	endif;
	
	if form = null then
		// user must not have permission to view
		return false;
	endif;

	if (not form.init(_obj)) then
		return false;
	endif;

	form.showModal();
	
	if form.modalResult = MsgBox_Return_OK then
		return true;
	endif;

	if _isSpecial then	//PAR12809 - to avoid terminating JMTerminal application
		return true;
	endif;

	return false;

epilog
	delete form;

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_isSpecial" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLock" id="ed7ecdb4-cec2-478f-92d6-3037bab6ec73">
        <updating/>
        <source>doLock(_userName : String): Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	05 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	lock 	: CMS_Lock;
	lockOK 	:Boolean;
	user	: CM_User;
	
begin
	user := app.myRoot.allUsers.getAtKey(_userName.toUpper);
	lockOK := false;
	create lock;
	
	if user &lt;&gt; null then
		lock.userObject := user;
		lock.userID.text := user.code;
		lock.lblSysTitle.caption :=   "This Master Terminal has been locked by " &amp;user.code &amp; " (" &amp; user.userName &amp; ")";
		
	else
		lock.userObject := self;
	endif;
	lock.showModal;
	
	if lock.modalResult = 0 then
		lockOK := true;
	else
		app.writeLog('Login failed - terminating', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
	endif;

	
epilog
	if lock &lt;&gt; null then
		delete lock;
	endif;
	return lockOK;	
end;
</source>
        <Parameter name="_userName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLogin" id="476b02fe-e32a-4496-8c2f-8f88338c77b5">
        <updating/>
        <source>doLogin() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	login		: CMS_Logon;
	loginOK		: Boolean;
	user			:CM_User;

begin

	user := app.myRoot.allUsers.getAtKey(app.userName.toUpper);

	loginOK := false;
	
	create login;
	if user &lt;&gt; null 
	and not user.isNotAvailableForEntry then // CNWAB1A AUG2014
		login.userObject := user;
		login.userID.text := user.code;
	else
		login.userObject := self;
	endif;
	login.showModal;            

	if login.modalResult = 0 then
		loginOK := true;
		app.setLocale(app.getMyUser().getLocale());
	else
		app.writeLog('Login failed - terminating', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
	endif;

	
epilog
	if login &lt;&gt; null then
		delete login;
	endif;
	return loginOK;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLogout" id="e7e22235-d0e8-4acb-8ca1-56b0e9a95bdf">
        <updating/>
        <source>doLogout(_isLock : Boolean; _isLogoutLogin: Boolean) :String updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
01 Jul 2008	cnwkpd1	PAR #16757 - After saving window settings, tidy up any app references, so 
					they're not carried over to the next session in a logout/login situation
10 Mar 2023 navmd1	TFS 52824 SSO - If explicitly logging out, rather than just closing the app, then always remove the SSO cache
					
*/

vars
	userCode	: String;
	user		: CM_User;
	
begin
	user := self.getMyUser();
	//if self.getMyUser() &lt;&gt; null then
	if user &lt;&gt; null then
		self.doSaveSettingsOnExit(user, _isLock or app.saveSettingsOnExit);
	endif;
	app.unloadAllForms();

	self.doResetForLogout();			// PAR #16757
	
	userCode := app.myPassport.userCode;

	//20.07.2022 navam1 #52824
	if (app.mySSOAgent &lt;&gt; null and app.mySSOAgent.isLoggedInUsingSSO) then
		app.mySSOAgent.logout(_isLogoutLogin);
	endif;

	app.myPassport.doLogoff();
	/*
	//th2 added 30/07/2007
	beginTransaction;
	tmpEVTLogout := app.createEvent(EVT_UserLogout, app.actualTimeServer(), null, userCode, false).CMEVT_Logout;
	if app.myPassport.myEventLogin &lt;&gt; null and
	   app.myPassport.myEventLogin.userCode = userCode then
		tmpEVTLogout.setEventLogin(app.myPassport.myEventLogin);
	endif;
	commitTransaction;
	*/
	
	delete app.myPassport;
	delete self.myController;
	
/*	if self.myErrorWarningForm &lt;&gt; null then
		if global.isValidObject(self.myErrorWarningForm) then
			self.myErrorWarningForm.unloadForm;
		endif;
		self.myErrorWarningForm := null;
	endif;*/
	
	return userCode;
end;</source>
        <Parameter name="_isLock" type="Boolean"/>
        <Parameter name="_isLogoutLogin" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doMeasureTableCellInputReady" id="968271ae-1854-47c9-816b-46edaef5973f">
        <updating/>
        <source>doMeasureTableCellInputReady(_table : Table; _inputControl : Control input) updating;
/*
Purpose:			Set up any CM_MeasurementTable controls for input in any tables

Parameters:			_table - the parent table
					_inputControl - the CM_MeasurementTable control

Return Value:		

Date		Who		Reason
05/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars
	tbl			: CM_EntryTable;
	measTable	: CMUI_MeasurementTable;
	measure		: CM_MeasurementType;
	str			: String;
	measurement	: Decimal [23,10];
	colourCont	: CM_ColorController;

begin
	create colourCont transient;
	tbl := _table.CM_EntryTable;
	measTable := _inputControl.CMUI_MeasurementTable;
	measTable.change(measTable);
	measTable.accessCell(1, measTable.ColumnSpacer).text := null;
	measTable.accessedCell.backColor := colourCont.valueColumnColor;
	if tbl.accessCell(_table.row, tbl.ColumnValue).cellControl.isKindOf(CMUI_MeasurementTable) then
		tbl.accessRow(_table.row).height := 25;
	endif;

epilog
	delete colourCont;
end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_inputControl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResetForLogout" id="a1c26553-6899-488b-a4e6-b03c1dcdfbec">
        <updating/>
        <source>doResetForLogout() updating;

/*

Purpose:			Clear/reset any properties prior to a logout, to ensure nothing is carried over
					to a new session in a logout/login situation

Parameters:			None

Return Value:		None


Date		Who		Reason
01 Jul 2008	cnwkpd1	PAR #16757 - Prevent logout exceptions

*/

vars

begin
	inheritMethod();
	
	self.allUserWindows.purge;
	self.myCurrentCargoType := null;
	self.myCurrentConsignee := null;
	self.myCurrentOperator := null;
	self.myDraggedTrackedItem := null;
	self.myYardAllocationMaintForm := null;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveSettingsOnExit" id="842cdc62-35a2-40e8-af3f-c07cd7abc5d8">
        <source>doSaveSettingsOnExit(_user : CM_User; pSaveActuals : Boolean);
// ---------------------------------------------------------------------------
// Created:     08 May 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
//16/09/2019 	JLGNS1	Bug 46569: POL - [Fwd: ##RE-12686## : JMT Window setup not retaining settings]
//02/03/2025    NAVRV30	JIRA 33944 MTN | Clear Individual Form XML settings
//23/07/2025	jlizm1	MTN 35282 Retain navigator search toolbar on exit
vars
	mdiForm			: CMUI_SuperAppForm2;
	tmpForm			: Form;
	tmpBaseForm		: CM_BaseForm;
	idx				: Integer;
	user			: CM_User;
	xtoolbarHidden,
	saveSettings,
	useAnimation,
	useNavigator,
	showWelcomeScreen : Boolean;	// par 17903
	transUserWindow : CM_UserWindowForOpen;
	menuUserDtl		: CM_MenuUserDtl;
	pxyUserWin		: CM_UserWindowForStartup;
	tmpUserWinSet	: CM_UserWindowForStartupSet;
	str 			: String;
	welcomeForm		: CMUI_WelcomeForm; // par17903
	xml				: String;
	navForm			: CMUI_Navigator;
begin
	if app.isSDSSecondaryDB() then	//cnwrs1 nov 2005 make JMTTerminal work on SDSsecondary
		return;
	endif;
	
	//user := app.getMyUser();
	user := _user;
	if user = null then
		return;
	endif;

	// need to set height / width / position of MDI Frame
	// need to possibly save if toolbar hidden or no
	// need to save animation
	// need to save "Save Settings On Exit"

	xtoolbarHidden 	:= app.toolbarHidden;
	if app.mainForm.isKindOf(CMUI_SuperAppForm2) then
		mdiForm := app.mainForm.CMUI_SuperAppForm2;
	endif;
	
//	if pSaveActuals and app.mainForm.isKindOf(CMUI_SuperAppForm2) then
	if pSaveActuals and mdiForm &lt;&gt; null then
		saveSettings	:= self.saveSettingsOnExit;
		useAnimation	:= mdiForm.useAnimation;
	else
		// set defaults
		saveSettings	:= self.saveSettingsOnExit;
		useAnimation	:= false;
	endif;
	
	// Save window positions and sizes	
	if pSaveActuals then
		create tmpUserWinSet transient;
	
		foreach idx in 1 to app.formsCount do
			tmpForm := app.forms(idx);
			
			if (not tmpForm.visible) then
				continue;
			endif;
			
			if (not CM_BaseForm.hasInstance(tmpForm)) then
				continue;
			endif;
			
			tmpBaseForm := tmpForm.CM_BaseForm;			
			
			if tmpBaseForm.class = CMUI_Navigator then
				useNavigator := true;
				continue;
			endif;
			
			if (not tmpBaseForm.isAllowedForSaveOnExit()) then
				continue;
			endif;
			//02/03/2025    NAVRV30	JIRA 33944
			/*if tmpBaseForm.clearSavedSettingsForCurr then
				continue;
			endif;*/

			if tmpBaseForm.myMasterMenuAction &lt;&gt; null then
				menuUserDtl := tmpBaseForm.myMasterMenuAction.myMenuUserDtl;
				
				if (not global.isValidObject(menuUserDtl)) then
					continue;
				endif;
			endif;
			
			create pxyUserWin transient;
			tmpUserWinSet.add(pxyUserWin);
			
//if app.isDevelopmentSystem()
//and app.computerName().toUpper() = "CNWRS1A"
//then

//endif;

			transUserWindow := app.getUserWindow(tmpBaseForm.name, true);	// get realUserWindow  not proxy
			if tmpBaseForm.isContainerEnqForm then							//Bug 46569
				xml := transUserWindow.xmlInfo;		// 6/11/18 MAP TFS41143	Container Enquiry screen updates its user window's xml each time Column Organiser is used, to avoid changed xml getting overwritten by another instance
			else
				xml := tmpBaseForm.getXMLSettingsForExit();
			endif;

			pxyUserWin.setProxy(user,
								tmpBaseForm.name,
								xml,
								tmpBaseForm.top,
								tmpBaseForm.left,
								tmpBaseForm.width,
								tmpBaseForm.height,
								tmpBaseForm.windowState,
								menuUserDtl);
			// par 11163 rs1 jan 2006 update the UserWindowOpen setting for all windows that are open
			// at shut down  

			transUserWindow.setProxy(user,
								tmpBaseForm.name,
								xml,
								tmpBaseForm.top,
								tmpBaseForm.left,
								tmpBaseForm.width,
								tmpBaseForm.height,
								tmpBaseForm.windowState);
		endforeach;

	else
		useNavigator := (app.getForm(CMUI_Navigator.name).CMUI_Navigator &lt;&gt; null);
	endif;
	
	if useNavigator then
		navForm := app.getForm(CMUI_Navigator.name).CMUI_Navigator;
		if navForm &lt;&gt; null then
			str := navForm.getXMLSettingsForExit();
			transUserWindow := self.allUserWindows[navForm.name].CM_UserWindowForOpen;
		
			if transUserWindow &lt;&gt; null then
				transUserWindow.setProxy(user, navForm.name, str, navForm.top, navForm.left, navForm.width, navForm.height, navForm.windowState);
			endif;
		endif;
	endif;

	// Save settings for the mdi form.
	if mdiForm &lt;&gt; null then
		 //Maybe we want to get the printer paper and printer name at this point so we can restore the settings when we log back on.
		 str := mdiForm.getXMLSettingsForSave();
		
		transUserWindow := self.allUserWindows[mdiForm.name].CM_UserWindowForOpen;
		
		if transUserWindow &lt;&gt; null then
			transUserWindow.setProxy(user, mdiForm.name, str, mdiForm.top, mdiForm.left, mdiForm.width, mdiForm.height, mdiForm.windowState);
		endif;
	endif;

// par 17903 - start
	showWelcomeScreen := user.getShowWelcomeScreen;	
	
	if user.hasWelcomeForm then
		// only update if they have one
		welcomeForm := app.getForm(CMUI_WelcomeForm.name).CMUI_WelcomeForm;
		
		if welcomeForm &lt;&gt; null then //Par 18021
			showWelcomeScreen := not welcomeForm.chkDoNotShow.value;
		elseif user.getShowWelcomeScreen() then	// we have to check the flag "Show Welcome Screen" on for a user
			showWelcomeScreen := true;
		else
			showWelcomeScreen := false;
		endif;
		if useNavigator then	// if Navigator is active, we should hide it when Welcome screen is active
			useNavigator := not showWelcomeScreen;	// to hide Navigator when Welcome screen is active
		endif;
	endif;
// par 17903 - end	

	app.myTrxUA.trxUpdateUserSettingsOnExit(user, app.allUserWindows, tmpUserWinSet,
						ConfigGrp_Gate, saveSettings, xtoolbarHidden, 
						useAnimation, useNavigator, showWelcomeScreen, app.myPassport);	// par 17903
epilog
	if tmpUserWinSet &lt;&gt; null then
		tmpUserWinSet.purge();
		delete tmpUserWinSet;
	endif;
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="pSaveActuals" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTileWindows" id="1d86d2e3-4538-4089-87b4-4ab32545ee1d">
        <updating/>
        <source>doTileWindows() updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	navForm		: CMUI_Navigator;
	mdiForm		: CMUI_SuperAppForm2;
	form		: Form;
	tmpClientHeight,
	formLeft,
	formWidth,
	formHeight	: Real;
	idx,
	numForms	: Integer;
		
begin

	if (not app.mainForm.isKindOf(CMUI_SuperAppForm2)) then
		return;
	endif;
	
	mdiForm := app.mainForm.CMUI_SuperAppForm2;

	navForm := app.getForm(CMUI_Navigator.name).CMUI_Navigator;
	
	tmpClientHeight := mdiForm.clientWindowHeight;

	if navForm &lt;&gt; null then
		navForm.doDockTopLeft(true);
		formLeft := navForm.width;
	endif;
	
	
	formLeft 	:= formLeft + 1;
	formWidth 	:= mdiForm.clientWidth - formLeft;
	formHeight 	:= tmpClientHeight;
	
	numForms := self.formsCount;
	foreach idx in 1 to numForms do
		form := self.forms(idx);
		if form = mdiForm or
		   form = navForm then
		   	continue;
		endif;
		form.move(formLeft, 0, formWidth, formHeight);
		form.resize();
	endforeach;
	
	self.tiledFormLeftPos := formLeft;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="dragDetected" id="03e63e34-12c2-4169-8d9e-fd84d2703aa1">
        <source>dragDetected(x, y, origX, origY : Real) : Boolean;
// ---------------------------------------------------------------------------
// Created:     05 October 2001 by cnwrs2
//
// Purpose:     This function returns TRUE if users have dragged our stated distance since
//				the original mouse co-ords were captured in the mousedown event. This should
//				be called in the MOUSEMOVE event.
//				Note that this is here and not on Window so that it can be accessed from the
//				forms in subschemas when called from superschemas
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	DRAG_THRESHOLD 			: Integer = 7;		// pixels
	SMALL_DRAG_THRESHOLD	: Integer = 7;		// pixels

vars
	numXTwips,
	numYTwips	: Real;
	rtnValue	: Boolean;

begin
	if origX &lt;= 0 or origY &lt;= 0 then
		return false;
	endif;
/*
  '------------
  'Check to see what current values of x/y are.
  'If &gt; or &lt; threshold, then DRAG MAN!!
  'If the smallchange flag is set, then drag if 5 pixels
  '------------
  With screen
    numXTwips = IIf(smallChange, SMALL_DRAG_THRESHOLD * .TwipsPerPixelX, DRAG_THRESHOLD * .TwipsPerPixelX)
    numYTwips = IIf(smallChange, SMALL_DRAG_THRESHOLD * .TwipsPerPixelY, DRAG_THRESHOLD * .TwipsPerPixelY)
  End With
*/
	if ((origX - x).abs &gt; DRAG_THRESHOLD)
	or ((origY - y).abs &gt; DRAG_THRESHOLD)
	then
		return true;
	endif;

	return false;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="origX" type="Real"/>
        <Parameter name="origY" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
