<Class name="CM_CamACOSDesc" id="8bbc7a2d-509b-452b-a551-1913535b315b">
    <superclass name="CM_CamProtocolDesc"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="cams"/>
    <JadeMethod name="availableTransactions" id="d97fbe31-6fdd-48d5-ad28-c5fb5b8bdf9e">
        <source>availableTransactions(_classColl: ClassColl input);
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed parameter usage from io to input
vars

begin
	_classColl.add(CM_ReceiveRail);
	_classColl.add(CM_ReceiveRoad);
	_classColl.add(CM_ReleaseRail);
	_classColl.add(CM_ReleaseRoad);
end;
</source>
        <Parameter name="_classColl" type="ClassColl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="eff1ea8b-da67-489c-9194-5aabd43a126b">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	03 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.name := "Maersk ACOS";
	self.type := EDIFileTypeCams_MaerskACOS;

end;</source>
    </JadeMethod>
    <JadeMethod name="fullEmptyStatus" id="ec718bb2-11d0-4346-9ab3-5544ea3a4af3">
        <source>fullEmptyStatus(_imexStatus : Integer; _contentsStatus : Integer): String;
/*
	Changed On	By			Reason
	----------	--------	----------------------------------------------
	18/05/2010	cnwdap1		CCMS 1116 Tranship changes
*/
vars
	fullEmptyString:String;
begin
	if _contentsStatus = TI_CONTENTS_STATUS_EMPTY then
		fullEmptyString := "E";
	else
		if _imexStatus =TI_IMEX_STATUS_EXPORT then
			fullEmptyString := "F"; //was X
		elseif _imexStatus = TI_IMEX_STATUS_IMPORT then
			fullEmptyString := "F";  //was I
		elseif _imexStatus = TI_IMEX_STATUS_TRANSHIP then	// PAR #23645 CCMS 1116
			fullEmptyString := "F";							// PAR #23645 CCMS 1116
		endif;
	endif;

	return fullEmptyString;
end;</source>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_contentsStatus" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIBundle" id="7714b305-d54e-455b-8d4a-91c38e6e2fab">
        <source>getEDIBundle(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/12/2024	navkc1 JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/

vars

begin
	
	return CM_EDIFileType.EDI_Bundle_CUSTOM;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMessageTypeString" id="80013a93-de63-4e2b-8231-4281538f317a">
        <source>getMessageTypeString(_messageType : Integer) : String;

vars

begin

	if _messageType = CODECO_GATEIN then
		return "ACOS Gate In";
	elseif _messageType = CODECO_GATEOUT then
		return "ACOS Gate Out";
	else
		return "Unknown ACOS Message!";
	endif;
end;</source>
        <Parameter name="_messageType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputFile" id="65f4c269-0f4b-4bf4-b44b-d56b2993048b">
        <updating/>
        <source>outputFile(_protocol : CM_CamProtocol input; _camAgent : CM_CamControllerAgent; _camFile : CM_CamFile input; _runDateTime : TimeStamp; _camTaskHistory : CM_CamTaskHistory input;
		   _unhSeqNumber : Integer io; _seqNumber : Integer; _terminal : CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camFile/_camTaskHistory parameter usage from io to input
// 18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 30 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 19 Dec 2012	cnwcs5	CCMS SFW 1294 /par 30855
// 25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
// 09 Jan 2020 	jlgdap1	TFS 48016 SNO Deletion CODECO - new _transactions parameter
vars
	camVoyage 		: CM_CamVoyage;
	camMessage 		: CM_CamMessage;
	code, str 		: String;
	termPortCode 	: String;
	messageType 	: String;
	i 				: Integer;
	strLine : String;
begin
	app.writeLog("===================================", LogWARN);
	
	if _camFile.camVoyages.size &gt; 0 then
		foreach camVoyage in _camFile.camVoyages do
			foreach camMessage in camVoyage.camMessages do
				
				//BGM header
				if camMessage.activity = CODECO_GATEIN then
					messageType := "TREC";
					camMessage.segmentCount :=  1;
				elseif camMessage.activity = CODECO_GATEOUT then
					messageType := "TDEL";
					camMessage.segmentCount :=  1;
				endif;
				
				code 			:= _terminal.getConfig(PortDestCode).String;
				termPortCode 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _terminal);

				//00 header
				strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, 
										"00" &amp; messageType.padBlanks(4) &amp; termPortCode.padBlanks(6)[1:6] &amp; camVoyage.voyageOid.vesselCode.padBlanks(6)[1:6] &amp; 
										camVoyage.getSanitisedVoyageCode().padBlanks(6)[1:6] &amp; "1",
										camMessage.header);
				
				i := 1;
				
				while i &lt;= camMessage.group3.size do
					str := camMessage.group3[i].String;
					strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, str, null);
					
					str := camMessage.group4[i].String;
					strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, str, null);
					
					str := camMessage.group5[i].String;
					strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, str, null);
					
					camMessage.segmentCount := camMessage.segmentCount + 1;
					i := i + 1;
				endwhile;

				//99 trailer same as 00 header but has number of records  rather than the version number
				camMessage.segmentCount := camMessage.segmentCount + 1; // allow for this trailer
				
				strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, "99" &amp;
									messageType.padBlanks(4) &amp;
									"NZPOE".padBlanks(6) &amp;
									camVoyage.voyageOid.vesselCode.padBlanks(6)[1:6] &amp;
									camVoyage.getSanitisedVoyageCode().padBlanks(6)[1:6] &amp;
									camMessage.segmentCount.String.padZeros(6)[1:6],
									camMessage.trailer);

			endforeach;
		endforeach;
	endif;

	app.writeLog("===================================", LogWARN);
	_camTaskHistory.setRawDataString(strLine);
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="83acd8af-fa72-43aa-b0db-ad40be25ed5a">
        <updating/>
        <source>processTransaction(_transaction : CM_TITransaction; _camProtocol : CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile : CM_CamFile input) updating;
// 12/05/2010	cnwcs5	par 23967 - change _camFile paremeter to be input not io so as to correctly reflect its usage
// 14/07/2010	cnwdap1	PAR 25021 - change use of isImport/isExport for tranships
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
//20 dec 2016	cnwrs1	TFS 3158 Cams Exclusion report does not include the rehandles and sobs
vars
	camMessage : CM_CamMessage;
	fCode : String;
	code : String;
	messageCount : Integer;
	commodity : String;
	emptyFullIndicator : String;
	temperaturePart : String;
	dischargePortPart : String;
	destinationPortPart : String;
	carrierPart : String;
	roadRailPart : String;
	wagonPart : String;
	messagePart : String;
	outwardMovementPart : String;
	tonnage : Real;
	theTI : CM_TrackedItem;
	vesselName : String;
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.getCamsDisplayDetails);

	theTI := _transaction.myTrackedItem;

	//get the voyage code
	//if theTI.isExport then								// PAR #25021
	if theTI.isExport or theTI.isTranshipOutbound then		// PAR #25021
		code := theTI.myVoyage.code;
	//elseif theTI.isImport then							// PAR #25021
	elseif theTI.isImport or theTI.isTranshipInbound then	// PAR #25021
		code := theTI.myVoyage.inwardCode;
	elseif theTI.isStorage then
		code := theTI.myVoyage.inwardCode;
	else
		code := theTI.myVoyage.code;
	endif;
	
	if code = null then	//inward may be blank - in which case...
		code := theTI.myVoyage.code;
	endif;
	vesselName := theTI.myVoyage.vesselName; //par18987 cnwrs1 Mar 2009
	//translate the voyage Code
	fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_VOYAGETERMINAL, _camProtocol.terminal);

	if theTI.voyageCode.trimRight = "HOLD"
	or theTI.voyageCode.trimRight = "********" then
		app.writeLog("Error : Container " &amp; theTI.id.trimRight &amp; " has an invalid voyage of " &amp; fCode &amp; ".", LogINFO);
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "Transaction is for no voyage so is excluded.");
		endif;
		camMessage := null;
	else
		if _transaction.isCamsRoadReceiveType()
		or _transaction.isCamsRailReceiveType() then
			camMessage := self.getCamMessage(_camFile, fCode, vesselName, CODECO_GATEIN, _camProtocol.singleContainerPerBGM); //ccms1747 cnwrs1 aug 2008 
		elseif _transaction.isCamsRoadReleaseType()
		or _transaction.isCamsRailReleaseType() then
			camMessage := self.getCamMessage(_camFile, fCode, vesselName, CODECO_GATEOUT, _camProtocol.singleContainerPerBGM); //ccms1747 cnwrs1 aug 2008 
		else
			//do nothing
			if _camAgent.logExcludedTransactions then
					_camAgent.logReasonForExclusion(_transaction, "Transaction not a road/rail receive/release.");
			endif;
			camMessage := null;
		endif;
	endif;

	if camMessage &lt;&gt; null then
		camMessage.camVoyage.voyageOid := theTI.myVoyage;

	//                  containerIdPart := transaction.trackedItem.id.padLeftBlanks(12);
	//                  isoTypePart := transaction.trackedItem.isoType.padLeftBlanks(4);
		code := "     ";
		if theTI.CM_Container.getTemperature &lt;&gt; NULL_TEMPERATURE then
			if theTI.CM_Container.getTemperature &gt; -10
			and theTI.CM_Container.getTemperature &lt; 10 then
				if theTI.CM_Container.getTemperature = 0 then
					code := "0" &amp; theTI.CM_Container.getTemperature.asStringJMTWithPrecision($CM_CamACOSTemp.decimalPlaces, false) &amp; "+";
				else
					code := "0" &amp; theTI.CM_Container.getTemperature.asStringJMTWithPrecision($CM_CamACOSTemp.decimalPlaces, false);
				endif;
			else
				code := theTI.CM_Container.getTemperature.asStringJMTWithPrecision($CM_CamACOSTemp.decimalPlaces, false);
			endif;
		endif;
		temperaturePart := code[1:2] &amp; code[4:2];

		if _transaction.isCamsRoadReceiveType()
		or _transaction.isCamsRailReceiveType() then
			code := theTI.destinationPort.trimRight;
			if code = "" then
				destinationPortPart := "";
			else
				destinationPortPart := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _camProtocol.terminal);
			endif;

			code := theTI.dischargePort.trimRight;
			if code = "" then
				dischargePortPart := "";
			else
				dischargePortPart := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _camProtocol.terminal);
			endif;
			carrierPart := _transaction.myTrackedItem.carrier;
		endif;
		if _transaction.isCamsRoadReleaseType()
		or _transaction.isCamsRailReleaseType() then
			//get the port code
			if theTI.deliveryReleaseReason &lt;&gt; 0 then
				code := theTI.loadPort;
			else
				code := theTI.dischargePort;
			endif;
			dischargePortPart := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _camProtocol.terminal).padLeftBlanks(5);
			carrierPart := theTI.releaseCarrier;

		endif;
		if _transaction.isCamsRoadReceiveType() then
			wagonPart := theTI.vehicle;
		endif;
		if _transaction.isCamsRoadReleaseType() then
			wagonPart := theTI.releaseVehicle;
		endif;
		if _transaction.isCamsRoadReceiveType()
		or _transaction.isCamsRoadReleaseType() then
			roadRailPart := "R";
		endif;
		if _transaction.isCamsRailReceiveType()
		or _transaction.isCamsRailReleaseType() then
			roadRailPart := "T";
			wagonPart := theTI.wagon;
		endif;

		emptyFullIndicator := self.fullEmptyStatus(theTI.getImExStatus, _transaction.contentsStatus).trimBlanks;
		if emptyFullIndicator &lt;&gt; "E" then
			commodity := theTI.commodity;    //commodity description
			outwardMovementPart := "55";
		else
			commodity := "";
			outwardMovementPart := "53";
		endif;

		tonnage := theTI.totalWeight.Real/1000;
		code := " ";

		// now create the message in one statement
		messagePart := "01" &amp;
		theTI.id.padBlanks(12)[1:12] &amp;
		_transaction.dateTime.date.shortYearEDI()[1:6] &amp;
		_transaction.dateTime.time.shortFormatEDI()[1:4] &amp;
		"MSK" &amp; // container operator
		"AV" &amp;    //container condition indicator
		emptyFullIndicator.padBlanks(1)[1:1] &amp;
		theTI.CM_Container.isoType.padBlanks(4)[1:4] &amp;
		//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
		theTI.CM_Container.getSealNumShipper.padBlanks(12)[1:12] &amp;
	//                  transaction.trackedItem.totalWeight.String.padZeros(4) &amp;
		tonnage.asStringJMTWithPrecision($CM_CamACOSTemp.decimalPlaces, false).padZeros(4)[1:2] &amp;
		tonnage.asStringJMTWithPrecision($CM_CamACOSTemp.decimalPlaces, false).padZeros(4)[4:1] &amp;
		code.padBlanks(1)[1:1] &amp;    //clean/dirty Indicator
		roadRailPart.padBlanks(1)[1:1] &amp;
		carrierPart.padBlanks(5)[1:5] &amp; //carrier name
		wagonPart.padBlanks(10)[1:9] &amp;  //truck/wagon registraction number //note write out 9 charcters to get 10 ??
		dischargePortPart.padBlanks(5)[1:5] &amp;   // discharge port
		destinationPortPart.padBlanks(5)[1:5] &amp; //final destination
		code.padBlanks(14)[1:14] &amp;  //ECN
		"MAERSK".padBlanks(12)[1:14] &amp;  // shippers name
		theTI.bookingReference.padBlanks(8)[1:8] &amp;    //shipper line reference
		commodity.padBlanks(4)[1:4] &amp;    //commodity description
		temperaturePart[1:4] &amp;
		code.padBlanks(4)[1:4] &amp;    // IMDG Class
		code.padBlanks(4)[1:4];      // IMDG UN Number
	//                      "~";                //for testing only to show end of record
		if _transaction.isCamsRailReleaseType() or
		   _transaction.isCamsRoadReleaseType() then
			messagePart := messagePart &amp; outwardMovementPart.padBlanks(2)[1:2];
		endif;
		app.writeLog("Message Length " &amp; messagePart.length.String &amp; ".", LogWARN);

		// this is a bit grubby by splitting the message up into segments to store
		// in the string array which can only be 62 chars long.
		// If works fine as long as the decoding is the same. ACOS should only exist till mid 1999
		camMessage.group3.add(messagePart);
//		camMessage.group4.add(messagePart[62:61]);
//		camMessage.group5.add(messagePart[123:9]);
		camMessage.eqdCount := camMessage.eqdCount + 1;
		if messageCount = 0 then
			messageCount := messageCount + 1;
		endif;
	else
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "CAM Message is null " &amp; _transaction.String &amp; ".");
		endif;
	endif;
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
</Class>
