    <JadeMethod name="doBaseFormSave" id="f2f0480a-d1ce-4b17-b39d-6792283b3eed">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	05 September 2006 By cnwth2

Purpose:	saves user added email address

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
27 Jan 2009	 cnwkpd1	 PAR #17554 - Development of new RIA Web Service application
						 Changed code to use transaction layer to update emails I can see
08/04/2011	 cnwmh5		 PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars
	errObj					: CM_Error;
	ignoreWarnings,
	rtnValue				: Boolean;
	
	existingEmail,
	pxyEmailAddress			: CM_EmailAddress2;
	lEmailAddress, lTitle	: String; 
	user					: CM_User;
begin

  	user := app.myPassport.myUser;
	lEmailAddress := self.tblAddAddress.getValueByName(ETRow_EmailAddress).String.trimWhiteSpace.toLower;
	
	existingEmail := app.myRoot.allEmailAddressesByAddress[lEmailAddress];
	if existingEmail &lt;&gt; null then
		if user.allEmailsICanSee.includes(existingEmail) then
			app.msgBox('An email with this address is already present in the emails you see listed. You cannot change its details from this screen','Email address aleady exists.', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		elseif app.msgBox('An email with this address already exists in the system. Do you want to add it to the emails you can see?','Email address aleady exists.',MsgBox_OK_Cancel + MsgBox_Information_Icon) &lt;&gt; MsgBox_Return_OK then
			return;
		endif;
		
		// Update the email so I can see it
		beginLoad;
		pxyEmailAddress := existingEmail.pxyCreateUpdateProxy();		// PAR #17554
		endLoad;
		
		app.myTrxUA.trxUpdateEmailAddress2(pxyEmailAddress, app.myPassport);		// PAR #17554
		
		if app.myPassport.trxCompletedOK then
			self.doShowHideAddAddress(false);
		endif;
		return;
		
	endif;
	
	create pxyEmailAddress as CM_EmailAddress2 transient;
	
	lTitle := self.tblAddAddress.getValueByName(ETRow_Title).String;
	self.tblAddAddress.setObjectFromTable(pxyEmailAddress, null, false);
	pxyEmailAddress.setProxyForEmailAddress(lTitle, lEmailAddress, self.cmbAutoReply.getCurrentItemData);
	
	app.myTrxCA.trxCreateEmailAddress2(pxyEmailAddress, existingEmail, app.myPassport);
	
	if app.myPassport.trxCompletedOK then
		self.doShowHideAddAddress(false);
	endif;
	

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxyEmailAddress;		// PAR #17554
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="79d24f40-190d-4667-bd5c-a71d10ca5cf8">
        <updating/>
        <source>doOK() updating;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	lstCnt,
	cnt : Integer;
	lstBox : CMUI_ListBox;
	emailEntity : CM_EmailEntity;
	tmpDict : CM_EmailEntityByTypeNameDict;
begin
	if self.myEmailController = null then
		//This should have been set by the calling form
		inheritMethod();
		return;
	endif;
	
	//Get Bcc addreses
	tmpDict := self.myEmailController.allBccAddresses;
	tmpDict.clear();
	lstBox := self.lstBoxBcc;
	cnt := 1;
	lstCnt := lstBox.listCount;
	while cnt &lt;= lstCnt do
		emailEntity := lstBox.itemObject[cnt].CM_EmailEntity;
		if emailEntity &lt;&gt; null then
			if (not tmpDict.includes(emailEntity)) then
				tmpDict.add(emailEntity);		
			endif;
		endif;
		cnt := cnt+1;		
	endwhile;

	//Get Cc addreses
	tmpDict := self.myEmailController.allCcAddresses;
	tmpDict.clear();
	lstBox := self.lstBoxCc;
	cnt := 1;
	lstCnt := lstBox.listCount;
	while cnt &lt;= lstCnt do
		emailEntity := lstBox.itemObject[cnt].CM_EmailEntity;
		if emailEntity &lt;&gt; null then
			if (not tmpDict.includes(emailEntity)) then
				tmpDict.add(emailEntity);		
			endif;
		endif;
		cnt := cnt+1;		
	endwhile;

	//Get To addreses
	tmpDict := self.myEmailController.allToAddresses;
	tmpDict.clear();
	lstBox := self.lstBoxTo;
	cnt := 1;
	lstCnt := lstBox.listCount;
	while cnt &lt;= lstCnt do
		emailEntity := lstBox.itemObject[cnt].CM_EmailEntity;
		if emailEntity &lt;&gt; null then
			if (not tmpDict.includes(emailEntity)) then
				tmpDict.add(emailEntity);		
			endif;
		endif;
		cnt := cnt+1;		
	endwhile;		
	
	inheritMethod();
		
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="468082fa-949b-479a-95cb-f8c2010b691e">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	24 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.btnAddNewAddress.top := self.btnOk.top;
	self.btnAddNewAddress.height := self.btnOk.height;
	self.tblContacts.move(self.tblContacts.left, self.tblContacts.top, self.frmRecipients.left - self.tblContacts.left*2, self.btnCancel.top - self.lblContacts.top);

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowHideAddAddress" id="7eaa5fea-cba5-4e06-8fdb-3b4902b7ebf2">
        <source>doShowHideAddAddress(_show : Boolean) protected;
/*
----------   ----------  --------------------------------------------------
Created:	05 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	frm			: CMUI_MoveableFrame;
begin
	
	frm := self.frmAddAddress;
	
	if _show then
		frm.top := 50;
		frm.parent := self;
		frm.zOrder(1);
		frm.left := (self.width/2) - (frm.width /2);//centre
		frm.visible := _show;
		
		self.tblContacts.enabled	:= false;
		self.btnAddNewAddress.enabled := false;
		self.btnBcc.enabled			:= false;
		self.btnCancel.enabled		:= false;
		self.btnCc.enabled			:= false;
		self.btnOk.enabled			:= false;
		self.btnTo.enabled			:= false;
		self.lstBoxBcc.enabled		:= false;
		self.lstBoxCc.enabled		:= false;
		self.lstBoxTo.enabled		:= false;
		
		self.tblAddAddress.clearValues();
		self.tblAddAddress.userInputEnabled := true;
	else
		frm.visible := false;
		self.tblContacts.enabled	:= true;
		self.btnAddNewAddress.enabled := true;
		self.setupButtonAccess();
		self.btnCancel.enabled		:= true;
		self.btnOk.enabled			:= true;
		if self.disableBCC then
			self.lstBoxBcc.enabled		:= false;
			self.btnBcc.enabled := false;
		else
			self.lstBoxBcc.enabled		:= true;
		
		endif;
		if self.disableCC then
			self.btnCc.enabled := false;
			self.lstBoxCc.enabled		:= false;
		else
			self.lstBoxCc.enabled		:= true;
		endif;
		
		//22 May 2018	NDL	TFS 38767
//		self.lstBoxTo.enabled		:= true;
		if self.disableBCC then
			self.lstBoxTo.enabled		:= false;
			self.btnTo.enabled := false;
		else
			self.lstBoxTo.enabled		:= true;
		
		endif;
		
		
		self.tblAddAddress.userInputEnabled := false;
		self.loadTblContacts();
	endif;
	

end;


</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findEmail" id="70a31aba-f6a9-4f0f-9e54-94b6544cf7db">
        <source>findEmail(_name : String; _findExact : Boolean) : CM_EmailEntity protected;
// created by cnwvu1	29/01/2007
// purpose: when typing a letter, to organize going down to the first row having that letter.

vars
	entity,
	entity2,
	entity3	: CM_EmailEntity;
	dict	: CM_EmailEntityByTypeNameDict;
	name	: String;

begin
	// 32759 Jan 2014 use the appropriate dictionary to find the emails - was just using the root dictionary and not always finding user entries
	if self.optViewUser.value then
		dict := app.myPassport.myUser.allEmailsICanSee;
	else
		dict := app.myRoot.allEmailEntities;
	endif;

	name := _name.trimBlanks();
	// Find the exact name
	if _findExact then
		// Check groups and then addresses
		entity := dict[Email_Group, name];
		if entity = null then
			entity := dict[Email_Address, name];
		endif;
	else
		// Get closest approximation to string as possible for both.
		entity2 := dict.getAtKeyGeq(Email_Group, name);
		entity3 := dict.getAtKeyGeq(Email_Address, name);
		// We have both so compare and see which one is lower case or smallest.
		if entity2 &lt;&gt; null and entity3 &lt;&gt; null then
			if entity2.name &lt; entity3.name then
				entity := entity2;
			else
				entity := entity3;
			endif;
		elseif entity2 &lt;&gt; null then
			entity := entity2;
		else
			entity := entity3;
		endif;
	endif;

	return entity;

end;
</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_findExact" type="Boolean"/>
        <ReturnType type="CM_EmailEntity"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="016ed0ee-7414-422c-975c-9a4952c6267a">
