    <JadeMethod name="activate" id="dbdbb689-0140-49e2-8978-dc5dd00f8451">
        <controlMethod name="Form::activate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>activate() updating;
/*
----------   ----------  --------------------------------------------------
Created:	26 May 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod();
	//don't know window state here so end minimised just incase form 
	//was minimised (no work done if it wasn't)
	self.minimisedStateEnd();
end;</source>
    </JadeMethod>
    <JadeMethod name="addParameters" id="d5d2ec11-9d87-42a0-bb4f-eb9cbb4ffa2a">
        <updating/>
        <source>addParameters( _area : CM_GridArea; _minRow, _maxRow, _minColumn, _maxColumn : Integer; _viewMode, _extraStackHeight : Integer ) updating;

/*

Purpose:			This method is invoked from CMUI_Assistant::showYardGridAreasForm to specify
					parameters for the form prior to being displayed.

Parameters:			

Return Value:		


Date				Who		Reason
18 November 2008	consw1	Initial creation

*/

vars
	params : CMIF_GridArea;
	
begin
	create params transient;
	params.myTerminalAreaMaster	:= _area;
	params.startNumRow 		:= _minRow;
	params.numRows 			:= _maxRow;
	params.startNumColumn 	:= _minColumn;
	params.numColumns 		:= _maxColumn;
	params.colour			:= _viewMode;
	params.extraStackHeight	:= _extraStackHeight;	// PAR 21532 CCMS SFW 1025
	
	self.allParameters.add(params);
	
epilog

end;</source>
        <Parameter name="_area" type="CM_GridArea"/>
        <Parameter name="_minRow" type="Integer"/>
        <Parameter name="_maxRow" type="Integer"/>
        <Parameter name="_minColumn" type="Integer"/>
        <Parameter name="_maxColumn" type="Integer"/>
        <Parameter name="_viewMode" type="Integer"/>
        <Parameter name="_extraStackHeight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="ca8c71e8-8567-410b-b5ba-36623a4732da">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags
// 12/02/2009	cnwrl1		Add Summaise All (CCMS SFW 1047 - Totals Only Lists)
// 15/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 10/03/2011	cnwcs5		CCMS CPL 2017/PAR 27126 - new toolbar button
// 19 May 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();

	toolbar := self.frmToolbar;

	toolbar.addButton(self.btnSelectTAs, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnViewDwellDays, CMUI_Toolbar.Control_Alignment_Left);	//28 Jul 2011	NDL	Par 27890
	toolbar.addButton(self.btnViewVoyage, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewTrain, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewCommodity, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewConsignee, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewShippingLine, CMUI_Toolbar.Control_Alignment_Left);	//19-may-2022 navtnr20 53204
	
	toolbar.addButton(self.btnViewDischarge, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewDest,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewISOGroup, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewOperator, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewStatus, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewTempRange, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewMTGrade, CMUI_Toolbar.Control_Alignment_Left);	//29 Jul 2011	NDL	Par 27890
	toolbar.addButton(self.btnViewCarrierIn, CMUI_Toolbar.Control_Alignment_Left);	// 9/6/17 MAP TFS4209
	toolbar.addButton(self.btnViewCarrierOut, CMUI_Toolbar.Control_Alignment_Left);	// 9/6/17 MAP TFS4209
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnViewYardAlloc, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnViewYardAllEd, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnReverseStack, CMUI_Toolbar.Control_Alignment_Left);
//	self.btnReverseStack.caption := "Reverse Decking";

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnMoveTopLeft, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveTopRight, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveBotLeft, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveBotRight, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	self.btnAutoMask.style := Button.Style_Auto2State;
	toolbar.addButton(self.btnAutoMask, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	self.btnShowOSGrid.style := Button.Style_Auto2State;
	toolbar.addButton(self.btnShowOSGrid, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addButton(self.btnFlipH, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnFlipV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSwitchView, CMUI_Toolbar.Control_Alignment_Left);
	
	// 03/03/2011 cnwcs5 CCMS CPL 2017/PAR 27126 - start
	if app.getMyUser.canDo (self.myTerminal, PmAdmAuditTALocationView) then
		toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
		toolbar.addButton( self.btnTALocnAudit, CMUI_Toolbar.Control_Alignment_Left );
	endif;
	// 03/03/2011 cnwcs5 CCMS CPL 2017/PAR 27126 - end
	
	// cnwrl1 12/02/2009 Add Summaise All (CCMS SFW 1047 - Totals Only Lists)
	if self.allowSummaryDefn then
		// always make this button visible but the enabling will depend on the display mode being used.
		toolbar.addSeperator( CMUI_Toolbar.Control_Alignment_Left );
		toolbar.addButton( self.btnSummariseAll, CMUI_Toolbar.Control_Alignment_Left );
	endif;
	// cnwrl1 12/02/2009 Add Summaise All (CCMS SFW 1047 - Totals Only Lists)
	
	//23 oct 2008 cnwdz2 par 18301
	//if app.isDevelopmentSystem then
	//	toolbar.addButton(self.btnView3DView, CMUI_Toolbar.Control_Alignment_Left);
	//endif;
	
	toolbar := self.frmToolBarPopup;
	toolbar.addButton(self.btnPopupClose, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPopupPrint, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnPopupEnq, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="allowsTableFilters" id="0355b678-7930-4e11-93af-dbf26445ab98">
        <source>allowsTableFilters(_table: Table): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	return _table = self.tblYAM;

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="applyColumnFilter" id="5fa5a494-02cb-427c-b913-af6dad9045af">
        <updating/>
        <source>applyColumnFilter(_table: CM_DataTable io):Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

	visibleCount : Integer;

begin

	if _table &lt;&gt; null then
		if _table.allowsColumnFilters then
			visibleCount := _table.applyColumnFilter( self.allColumnFilters );
		endif;
	endif;
	
	return visibleCount;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
