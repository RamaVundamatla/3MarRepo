    <JadeMethod name="doClickFindCont" id="5f36384f-cfb8-4863-8a70-8ef393288efd">
        <source>doClickFindCont();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2016	cnwndl1	Initial creation	TFS 3034 / 2549

*/

vars

	text : String;
	mess : String;
	menuButton : MOB_Button;
	ti : CM_TrackedItem;
	index : Integer;

begin

	text := self.txtContFind.text.trimBlanks.toUpper;
	if text = null or text = self.lblContFind.caption.toUpper.trimBlanks then
		return;
	endif;
	
	if self.allSelectedConts.includes( ti ) then
		mess := app.getErrorString1(Container_already_selected,text);
		return;
	endif;
	
	mess := app.getErrorString1(Conta_not_found_onsit_not_curr,text);
	
	if self.availButtonCount &lt; 1 then	
		return;
	endif;
	
	foreach index in 1 to self.availButtonCount do
		menuButton := self.btnAvailTemp.getControl( index ).MOB_Button;
		if menuButton &lt;&gt; null then
			ti := menuButton.userObject.CM_TrackedItem;
			if ti &lt;&gt; null then
				if ti.id = text then
					// This is the one.
					mess := null;
					self.txtContFind.text := self.lblContFind.caption.toUpper;
					menuButton.click(menuButton);
					return;
				endif;
			endif;
		endif;
	endforeach;

epilog

	if mess &lt;&gt; null then
		app.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doComplete" id="eb142030-0e0f-4abd-9d36-a5cd22ecf093">
        <updating/>
        <source>doComplete( _ti : CM_Container input )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2016	cnwndl1	Initial creation

*/

vars

	pxyTI : CM_Container;
	msg : String;
	autoQueue : Boolean;
	result : Integer;

begin

	if _ti = null then
		msg := app.getErrorString(NO_Container_selected);
		self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	if not _ti.allChildren.isEmpty then
		msg := app.getErrorString1( WARN_TI_NOT_EMPTY, _ti.id);
		if self.msgBox( msg, app.getErrorString(Warning), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
	endif;

	pxyTI := app.createUpdateProxy( _ti ).CM_Container;

	while true do
	
		app.myTrxUA.trxUpdateTIUnpackComplete(pxyTI, app.myPassport, null);
		if app.myPassport.trxCompletedOK() then
			break;
			
		else
			result := app.showErrorWarningDialog(app.getErrorString(PackUnpack),
												app.myPassport,
												ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			return;
		endif;
	endwhile;
	
	msg := app.getErrorString1( Want_auto_queue, _ti.id );
	autoQueue := self.msgBox( msg, app.getErrorString(Confirmation), MsgBox_Yes_No, false) = MsgBox_Return_Yes;
	
	if autoQueue then
		msg := null;
		self.myMobileGenericAgent.rePlanTi( _ti, null, 0 );
	endif;
		
epilog

	delete pxyTI;

end;</source>
        <Parameter name="_ti" type="CM_Container" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="c196ab17-1d35-4bfe-ba8b-280df3c7d650">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2016	cnwndl1	Initial creation	TFS 2811 / 2549

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	//Left hand side
	cTop := self.resizedMargin;
	cLeft := self.resizedMargin;
	//cWidth := ( stdWidth / 3 ) - self.resizedMargin;
	cWidth := ( ( stdWidth * 2 ) / 5 ) - self.resizedMargin;
	cHeight := stdHeight * 3;
	tabIndex := 4000;
	
	if _initialSetup then
		self.lblBookings.setAndIncrementTabIndex( tabIndex );
		self.lblBookings.visible := true;
	endif;
	self.lblBookings.move( 	cLeft,
							cTop,
							cWidth,
							cHeight );
							
	cTop := cTop + self.lblBookings.height + self.resizedMargin;
	cHeight:= ( self.clientHeight - cTop - self.getCMDButtonsHeight() - ( self.resizedMargin * 2 ) );
	
	//03 Mar 2017	NDL	TFS 3299
	if _initialSetup then
		self.btnDocActions1.setAndIncrementTabIndex( tabIndex );
	endif;
	self.btnDocActions1.visible := false;
	self.btnDocActions1.move( 	self.resizedMargin,
								( cTop + cHeight ) - ( self.btnOne.height + self.resizedMargin ),
								self.btnOne.width,
								self.btnOne.height );
	if self.allSelectedConts.includesTiThatHasDocActions() then
		self.btnDocActions1.visible := true;
		cHeight := cHeight - ( self.btnOne.height + self.resizedMargin ); 
	endif;
	
	if _initialSetup then
		self.fldContainers.setAndIncrementTabIndex( tabIndex );
		self.fldContainers.visible := true;
	endif;
	self.fldContainers.move(cLeft, 
							cTop, 
							cWidth, 
							cHeight);
							
	//03 Mar 2017	NDL	TFS 3299
	if self.btnDocActions1.visible then
		cTop := cTop + self.fldContainers.height + self.resizedMargin;
		self.btnDocActions1.move( 	self.resizedMargin,
									cTop,
									self.btnOne.width,
									self.btnOne.height );
	endif;
							
	//01 Dec 2016	NDL	TFS 3034 / 2549 
	if _initialSetup then
		self.txtContFind.setAndIncrementTabIndex( tabIndex );
		self.txtContFind.parent := self.shtContSel;
		self.txtContFind.visible := true;
		self.btnContFind.setAndIncrementTabIndex( tabIndex );
		self.btnContFind.parent := self.shtContSel;
		self.btnContFind.visible := true;
	endif;
	
	self.setupFldContainers( _initialSetup, tabIndex );
	
	// Right hand side.
	cTop := self.resizedMargin * 2;
	cLeft := cLeft + cWidth + self.resizedMargin;
	cWidth := self.clientWidth - cLeft - self.resizedMargin - self.resizedMargin;
	
	if _initialSetup then
		self.chkByCont.setAndIncrementTabIndex( tabIndex );
		self.chkByCont.visible := true;
	endif;
	self.chkByCont.move( 	cLeft,
							cTop,
							cWidth,
							stdHeight );
							
	cTop := cTop + self.chkByCont.height + self.resizedMargin * 2;
	if _initialSetup then
		self.cmbSortBy.setAndIncrementTabIndex( tabIndex );
		self.cmbSortBy.visible := true;
	endif;
	self.cmbSortBy.move( 	cLeft,
							cTop,
							cWidth,
							stdHeight );
							
	cTop := self.fldContainers.top;
	cHeight:= (self.clientHeight - cTop - self.getCMDButtonsHeight() - ( self.resizedMargin * 2 ) );					 
	if _initialSetup then
		self.fldChildren.setAndIncrementTabIndex( tabIndex );
		self.fldChildren.visible := true;
	endif;
	self.fldChildren.move(cLeft, 
							cTop, 
							cWidth, 
							cHeight);
							
	//03 Mar 2017	NDL	TFS 3299
	if _initialSetup then
		self.btnDocActions2.setAndIncrementTabIndex( tabIndex );
	endif;
	self.btnDocActions2.visible := false;
	self.btnDocActions2.move( 	cLeft,
								self.btnDocActions1.top,
								self.btnOne.width,
								self.btnOne.height );
								
	self.localTabIndex := tabIndex;						
	self.setupFldChildren( _initialSetup );
							
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="d8bd8e6c-0d2a-439e-abc4-55a573c090ce">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2016	cnwndl1	Initial creation

*/

vars

	topSheet : MOB_Sheet;
	cont : CM_Container;
	msg : String;
	int : Integer;

begin

	topSheet := self.fldChildren.topSheet.MOB_Sheet;
	if topSheet = null then
		msg := app.getErrorString(NO_Container_selected);
		return;
	endif;
	
	if self.allSelectedConts.isEmpty then
		msg := app.getErrorString(NO_Container_selected);
		return;
		
	elseif self.allSelectedConts.size = 1 then
		// there is only one use it
		cont := self.allSelectedConts[1].CM_Container; 		
		
	elseif topSheet = self.shtExChild then
		// there is more than one displayed and they are not showing a sheet that identifies it
		msg := app.getErrorString(Please_select_specifi_contain);
		return;
		
	elseif not self.allSelectedConts.isEmpty then
		
		if self.chkByCont.value then
			//10 Feb 2017	NDL TFS 3297 - This bit wont be used now that we have been asked to disable the 
			// complete button unless there is only one item in selected.  This code used to check which 
			// child folder was being used and derive teh parent container from that.
			// Leave the code here for when sanity prevails or implementation learn how to read, and we are allowed
			// to re-instate it.
			foreach int in 1 to self.allSelectedConts.size do
				if self.shtChildTemp.getControl(int) = topSheet then
					// use the one associated with the specific sheet displayed
					cont := self.allSelectedConts[int].CM_Container;
					break;
				endif;
			endforeach;
		else
			// multiples, and displaying all on one tab
			msg := app.getErrorString(Please_select_specifi_contain);
			return;
		endif;

	endif;
	
	if cont = null then
		msg := app.getErrorString(NO_Container_selected);
		return;
	endif;

	self.doComplete( cont );
	
	self.populateContainers();
	self.doResizeControls(false);	//03 Mar 2017	NDL	TFS 3299

epilog

	if msg &lt;&gt; null then
		self.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only, true);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
