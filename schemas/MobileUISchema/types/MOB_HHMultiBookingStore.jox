    <JadeMethod name="populateLblBookings" id="e9440ab7-a44f-48d1-b4fa-20cd44d8d59b">
        <source>populateLblBookings()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2016	cnwndl1	Initial creation

*/

vars

	bookingRef : CM_BookingRef;
	str : String;

begin

	self.lblBookings.caption := null;
	self.lblBookings.wordWrap := true;

	foreach bookingRef in self.myMobileGenericAgent.allSelectedBookings do
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; bookingRef.bookingReference;
	endforeach;
	
	if str = null then
		str := app.getErrorString(Bookings_selected_process);
	endif;
	
	self.lblBookings.caption := str;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resizeAllScrollButtons" id="c8341b91-9bf1-42d7-a019-3ba757f327c2">
        <updating/>
        <source>resizeAllScrollButtons() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 October 2016	cnwndl1	Initial creation

*/

vars
	
	buttonHeight : Integer;
	buttonWidth : Real;
	buttonTop : Integer;
	index : Integer;
	menuButton : MOB_Button;

begin

	self.setResizeableMarginAndFontSize();
						
	buttonHeight := self.getScrollingButtonHeight();
	if self.compTempButtonCount &gt; 0 then
		buttonWidth := getButtonWidthSetScrollBar( self.compTempButtonCount, self.frmToComplete, self.btnToCompTemp.height, self.scrToComplete );
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.compTempButtonCount do
			menuButton := self.btnToCompTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnToCompTemp.fontSize;	
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
	else
		buttonWidth := getButtonWidthSetScrollBar( self.compTempButtonCount, self.frmToComplete, self.btnToCompTemp.height, self.scrToComplete );
	endif;
	
	if self.storedButtonCount &gt; 0 then
		buttonWidth := getButtonWidthSetScrollBar( self.storedButtonCount, self.frmStored, self.btnStoredTemp.height, self.scrStored );
		buttonTop := self.resizedMargin - 1;
		foreach index in 1 to self.storedButtonCount do
			menuButton := self.btnStoredTemp.getControl( index ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.width := buttonWidth;
				menuButton.height := buttonHeight;
				menuButton.top := buttonTop;
				menuButton.fontSize := self.btnStoredTemp.fontSize;	
				buttonTop := buttonTop + buttonHeight + self.resizedMargin;
			endif;
		endforeach;
	else
		buttonWidth := getButtonWidthSetScrollBar( self.storedButtonCount, self.frmStored, self.btnStoredTemp.height, self.scrStored );
	endif;


epilog

end;</source>
    </JadeMethod>
