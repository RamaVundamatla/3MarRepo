    <JadeMethod name="btnStart_click" id="d586233b-98fc-4880-a764-7f2dd5d21be5">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStart_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	interface		: CM_TCPInterfaceDefinition;
	
begin
	interface := self.cmbDefinition.listObject.CM_TCPInterfaceDefinition;
	if interface &lt;&gt; null then
		app.initTCPListenerWorkerApp(interface);
		
		self.cmbTerminal.enabled := false;
		self.cmbDefinition.enabled := false;
		
		self.btnStart.enabled := false;
		
		self.lblRunning.caption := "Application is running, close this form to terminate";
		
	endif;
	
		
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbDefinition_click" id="655e5d35-eecf-4cd4-9538-80ee472b9f45">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbDefinition_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars

begin
	self.doInterfaceDisplay();
	

epilog

end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbTerminal_click" id="5d53f6ca-c307-4f75-b47b-e93a6390fdb1">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTerminal_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	terminal		: CM_Terminal;
	interface		: CM_InterfaceDefinition;
	
begin
	self.cmbDefinition.clear;
	
	terminal := self.cmbTerminal.listObject.CM_Terminal;
	if terminal &lt;&gt; null then
		foreach interface in terminal.allInterfaceDefinitions do
			self.cmbDefinition.itemObject[self.cmbDefinition.addItem(interface.name)] := interface;
		endforeach;
	endif;

	self.doInterfaceDisplay;
	

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doInterfaceDisplay" id="86d64a06-6a3c-41e3-ac84-a68b658dc730">
        <source>doInterfaceDisplay() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 September 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	interface		: CM_TCPInterfaceDefinition;
	table			: Table;
	
begin
	interface := self.cmbDefinition.listObject.CM_TCPInterfaceDefinition;
	
	table := self.tblInteDetails;
	table.rows := 0;
	
	if interface = null then
		self.btnStart.enabled := false;
	else
		self.btnStart.enabled := true;
		table.addItem("Local Address:" &amp; Tab &amp; interface.localAddress);
		table.addItem("Local Port:" &amp; Tab &amp; interface.localPortNumber.String);
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="96499079-12bc-4466-8e61-6b85956ee7c9">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	root			: CM_Root;
	terminal		: CM_Terminal;
	
begin
	root := CM_Root.firstInstance;
	foreach terminal in root.allTerminals do
		self.cmbTerminal.itemObject[self.cmbTerminal.addItem(terminal.code &amp; " " &amp; terminal.name)] := terminal;
	endforeach;
	
	self.doInterfaceDisplay();
	

epilog

end;</source>
    </JadeMethod>
</GUIClass>
