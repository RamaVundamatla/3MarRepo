    <JadeMethod name="arrivalTimeAtFromRegion" id="64aad0cf-f222-4734-94e3-9f6fefa4c88b">
        <methodInvocation>mapping</methodInvocation>
        <source>arrivalTimeAtFromRegion(set : Boolean; _value : TimeStamp io) mapping;
// --------------------------------------------------------------------------------
// Created:		20 November 2007 by cnwdad1
//
// Purpose:		
// --------------------------------------------------------------------------------
vars
	prevMove	: HMS_Movement;
begin
	if set then
		// do nothing
		app.raiseSetVirtualError(class.name, method.name);	
	else
		prevMove := self.myPreviousMovement;
		if prevMove &lt;&gt; null then
			if self.isFirstMovementForGlobalVoyage then
				_value := prevMove.arrivalTimeAtFromRegion;
			else
				_value := prevMove.arrivalTimeAtToRegion;
			endif;
		else
			//_value := null;
			// This situation can arise for the first movement of a voyage
			_value := self.arrivalTimeAtToRegion.cnEcAddMinutes(-self.steamingTime);
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="TimeStamp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="arrivalTimeAtToRegion" id="82e055b6-4d0d-4a81-bfb5-ead2f0487877">
        <methodInvocation>mapping</methodInvocation>
        <source>arrivalTimeAtToRegion(set: Boolean; _value: TimeStamp io) mapping;
// ---------------------------------------------------------------------------
// Created:     30 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.occursOnDTNEW.isValid then
			if self.moveType = HMSMovementTypeArrival or
			   self.moveType = HMSMovementTypePassage then
				_value := self.occursOnDTNEW; 
			elseif self.moveType = HMSMovementTypeShift then
				_value := self.occursOnDTNEW; 
			elseif self.moveType = HMSMovementTypeDeparture then
				_value := self.occursOnDTNEW.cnEcAddMinutes(self.steamingTime); 
			elseif self.isCancelled() then	//19 Nov 2018	NDL	TFS 42034
				_value := self.occursOnDTNEW;
			else
				_value := null;
				app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled moveType (' &amp; self.moveType &amp; ')');
			endif;
		else
			_value := null;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="TimeStamp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="causeHMSEvent" id="17cc4cf7-cfaf-40ef-b967-570b8cc3d348">
        <source>causeHMSEvent(_eventMode: Integer);
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 January 2008	cnwer1	Initial creation - PAR#15618

*/
vars

begin
	if _eventMode = self.EventMode_Delete 
		or _eventMode = self.EventMode_Update 
		or _eventMode = self.EventMode_Create then
		if self.myVoyageGlobal &lt;&gt; null then
			self.myVoyageGlobal.causeEvent(HMSObject_Update_Event,false, self);
		endif;
	else
		inheritMethod(_eventMode);

	endif;
epilog

end;</source>
        <Parameter name="_eventMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="changeMyBerth" id="03f94ed5-2e51-4367-bd3a-fb7f264a9421">
        <updating/>
        <source>changeMyBerth(_berth : HMS_Berth) updating;
//-----------------------------------------------------------------------
//	Created:	06 March 2007 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	if self.getMyBerth() &lt;&gt; _berth then
		self.setMyBerth(_berth);
	endif;
epilog

end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="countDeleted" id="11383728-0922-4a91-9513-f3c480bd1072">
        <source>countDeleted():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

begin

	if self.myCancelledMovement = null then
		return 0;
	else
		return self.myCancelledMovement.countDeleted() + 1;
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createPropertyChanges" id="4d9e3e31-d129-48b5-9f87-0f5a40f80c86">
        <source>createPropertyChanges(_transaction : HMS_Transaction; _fromMovement : CMIF_HMS_WorkingMovement input);
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
	oldStr,
	newStr:						String;
	propertyChange:				HMS_PropertyChange;
    moveForDetails:				HMS_VoyageMovement;
    tug:						HMS_Tug;
    tugsUsedHasChanged:			Boolean;
    addMode:					Boolean;
    orientationChanged:			Boolean;
    propertyChanged:			Boolean;
    positionHasChanged:			Boolean;
    timePilot:					Integer;
    timeTugs:					Integer;
    timeLines:					Integer;
    launchLocation:				Integer;
    tugsLocation:				Integer;
    defContact:					CM_EmailAddress2;
    defAgent:					CM_ShippingAgent;
    defShippingLine:			CM_ShippingLine;
    agentIsDefault:				Boolean;

begin
	// NOTE: new values come from '_fromMovement', old values come from 'self' - these
	// transaction methods are called before he _fromMovement properties are copied
	// to self - therefore self is an image of the old data at this stage.

	// This method creates a transaction for all the changes that take place when the 
	// permanent movement is updated (ie either ADD or EDIT changes)
	// NOTE: A single transaction may cover changes to one or more properties

	if _fromMovement = null then
		return;
	endif;
	
 	// Get action type - ADD or EDIT for perm move updates
	if _transaction.type = TRANS_TYPE_AddMovement then
		// ADD mode 
		addMode:=true;
	elseif _transaction.type = TRANS_TYPE_EditMovement then
		// EDIT mode
		addMode:=false;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid transaction type (' &amp; _transaction.type.String &amp; ')');
		return;
	endif;

	// ************************************************************************
	//								TIDAL INFORMATION
	// ************************************************************************

	// Move Tidal Class
	propertyChanged:=false;
	if addMode=true then
		if _fromMovement.init_MoveTidalClass&lt;&gt;_fromMovement.myMoveTidalClass then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif myTidalClass&lt;&gt;_fromMovement.myMoveTidalClass then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if myTidalClass&lt;&gt;null then
			oldStr:=myTidalClass.description;
		else
			oldStr:="Not Specified";
		endif;	
		if _fromMovement.myMoveTidalClass&lt;&gt;null then
			newStr:=_fromMovement.myMoveTidalClass.description;
		else
			newStr:="Not Specified";
		endif;	
   		propertyChange.set(_transaction, "Movement Tidal Class", oldStr, newStr);
	endif;


end;</source>
        <Parameter name="_transaction" type="HMS_Transaction"/>
        <Parameter name="_fromMovement" type="CMIF_HMS_WorkingMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPropertyChangesFromProxy" id="1fe82bd2-a543-4478-83c3-7b6a290f8d8a">
        <source>createPropertyChangesFromProxy(_transaction : HMS_Transaction; _pxyMovement : HMS_Movement input);
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
	oldStr,
	newStr:						String;
	propertyChange:				HMS_PropertyChange;
    tug:						HMS_Tug;
    tugsUsedHasChanged:			Boolean;
    addMode:					Boolean;
    orientationChanged:			Boolean;
    propertyChanged:			Boolean;
    positionHasChanged:			Boolean;
    timePilot:					Integer;
    timeTugs:					Integer;
    timeLines:					Integer;
    launchLocation:				Integer;
    tugsLocation:				Integer;
    agentIsDefault:				Boolean;

begin
	// NOTE: new values come from '_pxyMovement', old values come from 'self' - these
	// transaction methods are called before he _pxyMovement properties are copied
	// to self - therefore self is an image of the old data at this stage.

	// This method creates a transaction for all the changes that take place when the 
	// permanent movement is updated (ie either ADD or EDIT changes)
	// NOTE: A single transaction may cover changes to one or more properties

	if _pxyMovement = null then
		return;
	endif;
	
 	// Get action type - ADD or EDIT for perm move updates
	if _transaction.type = TRANS_TYPE_AddMovement then
		// ADD mode 
		addMode := true;
	elseif _transaction.type = TRANS_TYPE_EditMovement then
		// EDIT mode
		addMode := false;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid transaction type (' &amp; _transaction.type.String &amp; ')');
		return;
	endif;
	
	if _pxyMovement.moveStatusNEW &lt;&gt; self.moveStatusNEW then
		create propertyChange;
   		propertyChange.set(_transaction, "Move Status", app.movementStatusNumToString(self.moveStatusNEW), app.movementStatusNumToString(_pxyMovement.moveStatusNEW));			
		//Note: move status have own trans class see self.createTrans_AdjustMoveTime(); why? I don't know
	endif;

	// ************************************************************************
	//								TIDAL INFORMATION
	// ************************************************************************

	// Move Tidal Class
	propertyChanged:=false;
	if addMode=true then
		if _pxyMovement.init_MoveTidalClass &lt;&gt; _pxyMovement.myTidalClass then
			// Property has changed
			propertyChanged:=true;
		else
			// Property same
			propertyChanged:=false;
		endif;
	elseif myTidalClass&lt;&gt;_pxyMovement.myTidalClass then
		// Property has changed
		propertyChanged:=true;
	endif;
	if propertyChanged=true then
		// Property has changed
		create propertyChange;
   		if myTidalClass&lt;&gt;null then
			oldStr:=myTidalClass.description;
		else
			oldStr:="Not Specified";
		endif;	
		if _pxyMovement.myTidalClass&lt;&gt;null then
			newStr:=_pxyMovement.myTidalClass.description;
		else
			newStr:="Not Specified";
		endif;	
   		propertyChange.set(_transaction, "Movement Tidal Class", oldStr, newStr);
	endif;


end;</source>
        <Parameter name="_transaction" type="HMS_Transaction"/>
        <Parameter name="_pxyMovement" type="HMS_Movement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="departureTimeFromFromRegion" id="07406b57-882f-4ce6-8523-a6aa2854aca4">
        <methodInvocation>mapping</methodInvocation>
        <source>departureTimeFromFromRegion(set: Boolean; _value: TimeStamp io) mapping;
// ---------------------------------------------------------------------------
// Created:     30 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 03/04/2019	jlgdap1		TFS 44119 PEL1 Restriction on when shift movements can happen
// 29/11/2023	navdap1		TFS 61530 POB - QSHIPS - Error When Voyage Movements Updated
vars
	prevMove	: HMS_Movement;
	pxyMove		: HMS_Movement;		// TFS 61530

begin
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := null;
		if self.moveType = HMSMovementTypeDeparture then
			_value := self.occursOnDTNEW; 
		else
			prevMove := self.myPreviousMovement;
			// TFS 61530 Do we have a transient one that's already been correctly updated
			if prevMove &lt;&gt; null and self.isTransient and not prevMove.isTransient then
				pxyMove := app.myProxyManager.getProxyObject(prevMove).HMS_Movement;
				if pxyMove &lt;&gt; null then
					prevMove := pxyMove;
				endif;
			endif;
			// TFS 61530 end
			
			if prevMove &lt;&gt; null and
			   self.isFirstMovementForGlobalVoyage then
				_value := prevMove.departureTimeFromFromRegion;
			//else
				//_value := self.arrivalTimeAtToRegion.cnEcAddMinutes(-self.steamingTime);
				
			elseif self.occursOnDTNEW.isValid then
				if self.moveType = HMSMovementTypeArrival or
				   self.moveType = HMSMovementTypePassage then
					_value := self.occursOnDTNEW.cnEcAddMinutes(-self.steamingTime); 
				elseif self.moveType = HMSMovementTypeShift then
					if prevMove &lt;&gt; null then							// TFS 44119
						_value := prevMove.occursOnDTNEW;				// TFS 44119
					else												// TFS 44119
						_value := self.occursOnDTNEW.cnEcAddMinutes(-self.steamingTime); 
					endif;												// TFS 44119
				elseif self.isCancelled() then	//19 Nov 2018	NDL	TFS 42043
					//All good...
				else
					app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled moveType (' &amp; self.moveType &amp; ')');
				endif;
			endif;
		endif;
		
/*		
		if self.occursOnDTNEW.isValid then
			if self.moveType = HMSMovementTypeArrival or
			   self.moveType = HMSMovementTypePassage then
				_value := self.occursOnDTNEW.cnEcAddMinutes(-self.steamingTime); 
			elseif self.moveType = HMSMovementTypeShift then
				_value := self.occursOnDTNEW.cnEcAddMinutes(-self.steamingTime); 
			elseif self.moveType = HMSMovementTypeDeparture then
				_value := self.occursOnDTNEW; 
			else
				_value := null;
				app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled moveType (' &amp; self.moveType &amp; ')');
			endif;
		else
			_value := null;
		endif;
*/
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="TimeStamp" usage="io"/>
    </JadeMethod>
    <JadeMethod name="display" id="64b3d545-6a43-4bc4-9b93-3e45e49cac9e">
