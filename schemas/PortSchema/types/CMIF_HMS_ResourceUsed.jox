    <JadeMethod name="getDisplayStringForAttribute" id="f8c26076-7bfb-4fde-b6c8-e8c6b032ec9b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	24 February 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/10/2017	jlgdap1		TFS 7204 STWR Correct real handling for non-standard locales
vars

begin

	if _attrName = ETRow_QuantityUnits then
		if self.myResourceType &lt;&gt; null then
			return self.myResourceType.quantityUnits;
		endif;	
		return null;		

	elseif _attrName = ETRow_MyResourceType then
		if self.myResourceType &lt;&gt; null then
			return self.myResourceType.description;		
		elseif self.myResource &lt;&gt; null then
			return self.myResource.myResourceType.description;
		endif;
		return null;
	
	elseif _attrName = ETRow_MyResource then
		if self.myResource &lt;&gt; null then
			return self.myResource.description;
		endif;	
		return null;
				
	elseif _attrName = ETRow_MyVTMISTransaction then
		if self.myPersistentResourceUsed &lt;&gt; null then
			return self.myPersistentResourceUsed.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
	elseif _attrName = ETRow_FromDate
	or _attrName = ETRow_ActionDate then
		if self.fromDateTime.isValid then
			return self.fromDateTime.date.shortFormatJMT();		
		else
			return null;
		endif;
	elseif _attrName = ETRow_FromTime 
	or _attrName = ETRow_ActionTime then	
		if self.fromDateTime.isValid then
			return self.fromDateTime.time.currentLocaleFormatJMT();
		else
			return null;
		endif;
	elseif _attrName = ETRow_ToDate then
		if self.toDateTime.isValid then
			return self.toDateTime.date.shortFormatJMT();		
		else
			return null;
		endif;
	elseif _attrName = ETRow_ToTime then
		if self.toDateTime.isValid then
			return self.toDateTime.time.currentLocaleFormatJMT();
		else
			return null;
		endif;
	elseif _attrName = ETRow_PartOfContract then
		return self.isPartOfContract.getYesNo();
	elseif _attrName = ETRow_CreateCharge then
		return self.isCharged.getYesNo();		
		
	elseif _attrName = ETRow_UnitsUsed then				// TFS 7204
		return self.unitsUsed.asStringJMT;				// TFS 7204
		
	else
		return inheritMethod(_attrName, _short);
	endif;		

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCharging" id="e3e273de-b6df-40c1-95b4-2c1c985f98e2">
        <source>validateForCharging(_passport : CM_Passport input) : Boolean;
//--------------------------------------------------
// Created:	28 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	msgStr : String;
	tmpVoyage : CM_Voyage;
	tmpResourceType : HMS_ResourceType;
	realObj : HMS_ResourceUsed;
begin
	if (not self.isCharged) then
		//They are not trying to charge it
		return true;
	endif;
	
	if self.myPersistentResourceUsed &lt;&gt; null then
		if self.myPersistentResourceUsed.myVTMISTransaction &lt;&gt; null then
			//Already charged therefore they can't update it and is ignored
			return true;
		endif;
	endif;
	
	tmpVoyage := self.myWorkingMovement.getMyPersistantVoyage();
	if tmpVoyage = null then
		//Voyage has not ben created therefore debot will not be set
		app.raiseCMException3(ERR_RESOURCE_REQUIRES_INFO, null, 'Debtor for Voyage', null, null, null);					
	elseif tmpVoyage.myDebtor = null then
		app.raiseCMException3(ERR_RESOURCE_REQUIRES_INFO, null, 'Debtor for Voyage', null, null, null);					
	endif;

	tmpResourceType := self.myResourceType;

	if tmpResourceType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Resource Type', null, null);
		app.raiseCMException(Input_required_field_resorceTy, null, null); // cnwdb2	PAR 35364
	endif;
	
	if _passport.hasErrors() then
		return false;
	endif;

	msgStr := 'Resource Type ' &amp; tmpResourceType.description;	

	//Resource must be set when creating charge
	if self.myResource = null then
		//The resource has not been set yet
		app.raiseCMException3(ERR_RESOURCE_REQUIRES_INFO, msgStr, 'Resource', null, null, null);
	endif;

	if tmpResourceType.isFromToDateTimeRequired then
		if (not self.fromDateTime.isValid) then
	//		app.raiseCMException1(REQUIRED_FIELD, msgStr &amp; ' From Date', null, null);		
			app.raiseCMException1(Input_required_field_frmDate, msgStr , null, null); // cnwdb2	PAR 35364
		endif;
		if (not self.toDateTime.isValid) then
		//	app.raiseCMException1(REQUIRED_FIELD, msgStr &amp; ' To Date', null, null);		
			app.raiseCMException1(Input_required_field_toDate, msgStr &amp; ' ', null, null); // cnwdb2	PAR 35364
		endif;
		if _passport.noErrors() then
 			if self.fromDateTime &gt; self.toDateTime then
				app.raiseCMException1(AutoScheduleDateError, msgStr &amp; ' to date/time must be after the from date/time', null, null);
			endif;		
		endif;		
	elseif tmpResourceType.isActionDateTimeRequired then
		if (not self.fromDateTime.isValid) then
		//	app.raiseCMException1(REQUIRED_FIELD, msgStr &amp; ' From Date', null, null);
			app.raiseCMException1(Input_required_field_frmDate, msgStr, null, null); // cnwdb2	PAR 35364
		endif;	
	endif;	

	if tmpResourceType.isQuantityRequired then
		if self.unitsUsed &lt;= 0 then
//			app.raiseCMException1(REQUIRED_FIELD, msgStr &amp; ' Units Used', null, null);		
			app.raiseCMException1(Input_required_field_untsUsed, msgStr , null, null); // cnwdb2	PAR 35364
		endif;	
	endif;
	
	return (not _passport.hasErrors());
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
