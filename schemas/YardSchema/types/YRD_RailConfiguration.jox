    <JadeMethod name="btnNDLTest_contextMenu" id="87e97021-f2f3-468c-9b68-5b2b6cd17de2">
        <controlMethod name="Button::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNDLTest_contextMenu(btn: Button input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 November 2016	cnwns1	Initial creation

*/

vars
	schema : Schema;
	formClass : Class;
	assistClass : Class;
	form : CM_BaseForm;
		assist : CMUI_Assistant;
begin
schema := currentSchema.getSchema("GateSchema");
	formClass := schema.getClass("GTE_BulkGateForm_Out");
	assistClass := schema.getClass("GTE_Assistant");
	create form as formClass transient;
	form.myTerminal := self.myTerminal;
	create assist as assistClass;
	assist.myTerminal := self.myTerminal;
	form.myAssistant := assist;
	//form.sendMsgWithParams("setMyTrackedItem","4022.15545".asOid.CM_TrackedItem);
	
	
		form.show;
		return true;
epilog

end;</source>
