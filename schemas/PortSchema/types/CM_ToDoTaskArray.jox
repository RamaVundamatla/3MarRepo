    <JadeMethod name="includes" id="9c5ff130-3eb2-486c-9104-44167d13f767">
        <source>includes(value: MemberType): Boolean;
/////////////////////////////////
//
//	cnwyl1 - 05092006
//  Reason: it is to tell if there is the tasks with the same ToDoTaskCode in the array
//	
//  navcs2	- TFS53038
//  05/07/2022	 
/////////////////////////////////
vars
	taskToDo, 
	taskToDoInArray : Object;
	taskToDoCode : Integer;
begin
	taskToDo := value.CM_TiToDoTask;	//navsp1 22DEC2022 TFS 55861
	// TFS53038 05/07/2022 navcs2
	if not taskToDo.isKindOf(CM_TiToDoTask) then
		return false;
	endif;
	
	//taskToDo := value.CM_TiToDoTask;  //navsp1 22DEC2022 TFS 55861
	
	foreach taskToDoInArray in self do
		if taskToDo.CM_TiToDoTask.toDoTaskDescCode = taskToDoInArray.CM_TiToDoTask.toDoTaskDescCode then
			return true;
		endif;
	endforeach;
	return false;
end;</source>
        <Parameter name="value" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesToDoDesc" id="be943602-2e48-4b5d-8689-c5bca2d08f5d">
        <source>includesToDoDesc(_code : Integer) : Boolean;

// Created by cnwdvb1 on 10 September 2007

vars

	toDo : CM_ToDoTask;

begin
	
	foreach toDo in self do
		if toDo.toDoTaskDescCode = _code then
			return true;
		endif;
	endforeach;
	
	return false;

end;</source>
        <Parameter name="_code" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
