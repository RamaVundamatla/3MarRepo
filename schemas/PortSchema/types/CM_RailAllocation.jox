    <JadeMethod name="getOriginPort" id="4a7e94a6-b4b0-4073-8faa-a7e2b3b76b5a">
        <source>getOriginPort() : CM_Port;
/*
Purpose:			

Date		Who		Reason
06JAN2022	NAVAB1	TFS 51855
*/

vars
	criteria			: CM_YACriteria;
begin
	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType.type = YACriteriaType_LoadPort then
			return criteria.myYAData.CM_YADataObjects.getFirstObject().CM_Port;
		endif;
	endforeach;

end;


</source>
        <ReturnType type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="getReleaseRequest" id="430bd6e4-533d-48b5-8859-fe2e2385ad81">
        <source>getReleaseRequest() : CM_BulkRelease;
/*
----------   ----------  --------------------------------------------------
Created:	15 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	criteria			: CM_YACriteria;
begin
	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType.type = YACriteriaType_RailReleaseReq then
			return criteria.myYAData.CM_YADataObjects.getFirstObject().CM_BulkRelease;
		endif;
	endforeach;

end;


</source>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getWagonString" id="16f439da-d63b-41fc-8d76-38205d48fd33">
        <source>getWagonString() : String;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.allWagonControllers.isEmpty() then
		return null;
		
	endif;
	
	return self.allWagonControllers.first.myWagon.id;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
