    <JadeMethod name="canBeReprocessedByBGP" id="48e757b6-df1b-49f9-ab4b-0419293c94e9">
        <source>canBeReprocessedByBGP(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2023	navsp1	Initial creation TFS 61165

*/

vars
	result		:Boolean;
	status		:Integer;
	purgeDate	:Date;
	createTS	:TimeStamp;
begin
	result := inheritMethod();
	
	if not result then
		status := self.status;
		
		if status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or 
			status = CM_EDIFile.EDI_STATUS_VERIFIED or 
	        status = CM_EDIFile.EDI_STATUS_LOCKERROR or
			status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
			
			if self.canBePartiallyLoaded then					
				result := true;
			else
				app.writeLog("Train_canBeReprocessedByBGP - Can't be partially loaded", LogDEBUG);
			endif;
		endif;
	endif;
	
	if result then
		if self.getEDIAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
			result := false;
		endif;
	endif;
	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesCargoForExptDateExist" id="e7c728f8-c713-4c57-9edf-c6c79a6cd1f9">
        <source>doesCargoForExptDateExist(_eta : Date): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2023	navra1	Initial creation for 57263

*/

vars
	ediTI: CM_EDITrackedItem;
begin
	foreach ediTI in self.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIPrenoteTI) and ediTI.CM_EDIPrenoteTI.expectedArrivalDate &lt;&gt; null then
			if _eta = ediTI.CM_EDIPrenoteTI.expectedArrivalDate then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_eta" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doesReceiptTransportModeExist" id="08d5c35c-b9ea-421d-931f-1e78a555b35e">
        <source>doesReceiptTransportModeExist(_receiptTransportMode: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
6 April 2023	navra1	Initial creation for 57263

*/

vars
	ediTi: CM_EDITrackedItem;
begin
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDIPrenoteTI) then
			if ediTi.CM_EDIPrenoteTI.transportMode.toUpper().compareEql(_receiptTransportMode.toUpper(), true, false, null) then
				return true;
			endif;
		endif;
	endforeach;

	return false;
epilog

end;</source>
        <Parameter name="_receiptTransportMode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
