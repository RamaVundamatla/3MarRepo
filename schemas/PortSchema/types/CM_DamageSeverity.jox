    <JadeMethod name="validateForUpdate" id="fc1a1f8a-5ee8-464a-9761-0be6e6cc87ee">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	realDamageSeverity,
	realDamageSeverityLevel,
	existingDamageSeverity,
	existingDamageSeverityLevel		: CM_DamageSeverity;
begin
	if self.code = null then
		app.raiseCMException(Input_required_field_code, ETRow_Code, self);
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_desc, ETRow_Description, self); 
	endif;
	
	if self.level = null then
		app.raiseCMException(Input_require_field_level, ETRow_Severity, self); 
	endif;
	
	// ### TFS 55249 01NOV2022 NAVAB1
	if self.level &lt; 1 or self.level &gt; 9999 then
		app.raiseCMException(Damage_severi_must_betwee_9999, ETRow_Severity, self); 
	endif;
	
	existingDamageSeverity	:= self.myTerminal.allDamageSeverities[self.code];
	realDamageSeverity		:= self.pxyGetRealObject();
	
	if existingDamageSeverity &lt;&gt; null and
	   (realDamageSeverity = null or //in which case we are trying add a new one that is duplicate
	   existingDamageSeverity &lt;&gt; realDamageSeverity) //in which case we are trying update one to be same as another
	   then
		app.raiseCMException1(Damage_defini_code_alread_exis, self.code, null, null); 
	endif;	
	
	existingDamageSeverityLevel	:= self.myTerminal.allDamageSeverities[self.level.String];
	realDamageSeverityLevel		:= self.pxyGetRealObject();
	
	if existingDamageSeverityLevel &lt;&gt; null and
	   (realDamageSeverityLevel = null or //in which case we are trying add a new one that is duplicate
	   existingDamageSeverityLevel &lt;&gt; realDamageSeverity) //in which case we are trying update one to be same as another
	   then
		app.raiseCMException1(DamageSeverity_already_exist, self.level.String, null, null); 
	endif;

end;


</source>
    </JadeMethod>
</Class>
