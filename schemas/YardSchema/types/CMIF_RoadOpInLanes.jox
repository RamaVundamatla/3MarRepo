    <JadeMethod name="getTableObjects" id="186a8365-cb84-4324-b214-d389b2c5fe25">
        <source>getTableObjects(_obj : CM_Object;_objectArray : ObjectArray input);
/*
Date		Who		Reason
21 Aug 2006	cnwer1	Initial creation - PAR#xxxx
23 Oct 2012	cnwcs5	par 29653  use includeObject method for filtering
*/
vars
	vehicle 		: CM_Vehicle;
	controller		: CMIF_RoadOpController;
	job 			: CM_Job;
	wle 			: CM_WorkListEntry;
	wleWasFiltered 	: Boolean;
begin
	if _obj = null then
		return;
	endif;
	
	_objectArray.clear;
	
	//epr par 35702 2/3/15 CCMS 2457
	if not _obj.isKindOf(CM_Vehicle) then
		return;
	endif;
	
	//its a vehicle or nothing
	vehicle		:= _obj.CM_Vehicle;
	controller	:= self.myRoadOpController;
	
	foreach job in vehicle.allRoadJobs discreteLock do
		foreach wle in job.CM_RoadJob.workListEntries discreteLock do
			if not wle.isReceipt then
				continue;
			endif;
			
			if not self.includeObject (wle, controller) then
				wleWasFiltered := true;
				continue;
			endif;
			
			_objectArray.add(wle);
		endforeach;			
	endforeach;
	
	
	if _objectArray.size = null and not wleWasFiltered then
		_objectArray.add(vehicle);
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_objectArray" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getYardMenuCaption" id="aeeed7c7-60a2-4317-9cc0-ca006ecdf7ae">
