    <JadeMethod name="getLeftTop" id="e7302e46-06ff-40ac-a648-d0a42c296e4d">
        <source>getLeftTop(_left: Integer output; _top : Integer output);
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		remove after all V6 terminals are updated to V7. And have resaved their Terminal Area Positions
// ---------------------------------------------------------------------------
vars

begin
	_left := (self.left / TWIPsPerPixel).Integer; // divide by V6 VB Twips
	_top := (self.top / TWIPsPerPixel).Integer;
end;</source>
        <Parameter name="_left" type="Integer" usage="output"/>
        <Parameter name="_top" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getRailLines" id="83f503c8-1247-4b4a-8a1e-153d24a30f0e">
        <source>getRailLines(_theLines : PointArray input);
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theSegmentor : CMIF_RectangleSegments;
	theTopPoints, theBotPoints : PointArray;
	aPoint, bPoint : Point;
	diffX, diffY,segments, idx, startPoint : Integer;
begin
	if not self.myTerminalArea.isKindOf(CM_Rail) then 
		return;
	endif;
	
	_theLines.clear;
	create theSegmentor transient;
	create theTopPoints transient;
	create theBotPoints transient;
	segments := self.myTerminalArea.CM_Rail.allRailLines.size + 1;

	aPoint := self.pointsPolygon[2];
	bPoint := self.pointsPolygon[3];
	theSegmentor.getPointsOnLine(segments,aPoint.x,aPoint.y,bPoint.x,bPoint.y,theTopPoints);
	if self.pointsPolygon.size &lt; 5 then
		aPoint := self.pointsPolygon[1];
	else
		aPoint := self.pointsPolygon[5];
	endif;
	bPoint := self.pointsPolygon[4];
	theSegmentor.getPointsOnLine(segments,aPoint.x,aPoint.y,bPoint.x,bPoint.y,theBotPoints);
	
	foreach idx in 2 to theTopPoints.size - 1 do
		aPoint := theTopPoints[idx];
		_theLines.add(aPoint);
		aPoint := theBotPoints[idx];
		_theLines.add(aPoint);
	endforeach;
epilog
	delete theSegmentor;
	delete theTopPoints;
	delete theBotPoints;
end;</source>
        <Parameter name="_theLines" type="PointArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="937a4380-2f34-41d2-9e78-250a58ef0aa8">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------

vars
	likeMe : SelfType;
	completedOK		: Boolean;
begin
	likeMe :=  inheritMethod();

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return likeMe;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete likeMe;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
