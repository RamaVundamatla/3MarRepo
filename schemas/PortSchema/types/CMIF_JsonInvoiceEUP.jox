<Class name="CMIF_JsonInvoiceEUP" id="d4ddc081-1c14-4764-8099-3c0c001e4d45">
    <superclass name="CMIF_JsonTransform"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <ImplicitInverseRef name="header" id="07777100-1ecb-4409-b6a8-4614b59f3d98">
        <embedded/>
        <type name="CMIF_JsonInvoiceHeaderEUP"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="sale" id="7a019ae6-08d8-468c-a15c-c5f885de7b3c">
        <embedded/>
        <type name="CMIF_JsonInvoiceSaleEUP"/>
    </ImplicitInverseRef>
    <JadeMethod name="setFromInvoice" id="b5930f7f-ce44-4627-aa38-d7abe830fdb6">
        <updating/>
        <source>setFromInvoice(_invoice: CM_Invoice) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/06/2023	navcs2	ChangeRequest 58433: [58454]: EUP | TAS Invoicing - Invoice Posting Confirmation Message

*/
constants
	StatusSuccess		: String = "SUCCESS";
	StatusFailure		: String = "FAILURE";
	TypeReturn			: String = "RETURN";
	Receiver			: String = "TAS";
	Sender				: String = "MTN";
	InvType				: String = "INV";
	CNType				: String = "CN";
vars
	bank			: CM_Bank;
	invoiceType		: CM_InvoiceDesc;
	header			: CMIF_JsonInvoiceHeaderEUP;
	sale			: CMIF_JsonInvoiceSaleEUP;
	terminal 		: CM_Terminal;
	debtorTerminal	: CM_DebtorTerminal;
	debtor			: CM_Debtor;
begin
	invoiceType := _invoice.invoiceType;
	
	if not invoiceType.useForApiCn and not invoiceType.useForApiInv then
		app.raiseCMException(This_not_web_invoice, "Invoice Type", invoiceType);
		return;
	endif;
	
	terminal := _invoice.myTerminal;

	bank := terminal.getDefaultCompanyBank();
	
	create header transient;
	create sale transient;
	
	// Set the header details from the invoice
	header.date				:= _invoice.dueDate;
	header.id 				:= _invoice.exportCurrencyCode;
	header.type 			:= TypeReturn;
	header.status			:= StatusSuccess;
	header.receiver			:= Receiver;
	header.sender			:= Sender;
	
	// Get the debtor details
	debtor 					:= _invoice.debtor;
	debtorTerminal		 	:= debtor.allDebtorTerminals[terminal];
	
	// Set the sale fields from the invoice
	sale.department			:= debtorTerminal.orgCode;
	sale.eBSFinancialRef 	:= _invoice.debtor.code;
	sale.docNumber		 	:= _invoice.exportCurrencyCode;
	
	if _invoice.category = InvoiceCategory_Invoice then
		sale.docType := InvType;
	else
		sale.docType := CNType;
	endif;
	
	self.sale := sale;
	self.header := header;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
</Class>
