    <JadeWebServicesMethod name="getCranesForVoyage" id="2831e9c7-1d2a-45ba-8f71-b02c3799346f">
        <usesRPC>default</usesRPC>
        <source>getCranesForVoyage(voyageId : String) : WS_MachineResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwkao1	Initial creation
15 Oct   2015   cnwma1  PAR #36606 Web Service Methods need to validate Terminal/DataAccess on OIDs
*/

vars
	voyage		: CM_Voyage;
	obj			: Object;
	jobSheet	: CM_VoyageJobSheet;
	terminal	: CM_Terminal;
	crane		: CM_Machine;
	pxyCrane	: WS_Machine;
	response	: WS_MachineResponse;
	completedOK	: Boolean;
	failedDAC 	: CM_DataAccessController;	
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// ### BY OID
	//epr TFS 5535 10/8/17 
	voyage :=app.myPassport.getObjectOfTypeFromOid(voyageId,CM_Voyage).CM_Voyage;	
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	terminal := app.myPassport.myTerminal;
	
	// ### BY CODE
	if voyage = null then
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(voyageId,null);
		if voyage &lt;&gt; null and voyage.code &lt;&gt; voyageId then
			voyage := null;
		endif;
		//epr TFS 5535 10/8/17 
		if voyage &lt;&gt; null and not voyage.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			voyage := null;
		endif;
		
	endif;
	
	if voyage &lt;&gt; null then
		foreach jobSheet in voyage.allJobSheets discreteLock do
			crane := terminal.machines.getAtKey(jobSheet.crane.trimBlanks()); //really trimblanks?
			if crane &lt;&gt; null then
				create pxyCrane transient;
				pxyCrane.setProxyFromObject(crane);
				response.allMachines.add(pxyCrane);
			endif;
		endforeach;
	endif;
	
	completedOK := true;
	return response;
	
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <wsdlName>getCranesForVoyage</wsdlName>
        <Parameter name="voyageId" type="String"/>
        <ReturnType type="WS_MachineResponse"/>
    </JadeWebServicesMethod>
