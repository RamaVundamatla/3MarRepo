    <JadeMethod name="startApp" id="95582dd9-d366-4731-8033-9d5146c49227">
        <updating/>
        <source>startApp(envid,host,controlPort,schemaName,appName:String):String updating;

vars
	path,cmd,appserverhost:String;
	i,j,retCode,result:Integer;
begin
	if computerName='cnwchcs73' then
		path:='c:\thinbin_host\'&amp;envid;
	else
		path:='c:\thinbin\'&amp;envid;
	endif;

	if computerName[1:7]='cnwchcs' and host='cnwchcc46' then
		appserverhost:='cnwchcs46';
	else
		appserverhost:=host;
	endif;
	cmd:=path&amp;'\jade.exe'
			&amp;' schema='&amp;schemaName
			&amp;' app='&amp;appName
			&amp;' appserver='&amp;appserverhost
			&amp;' appserverport='&amp;controlPort;

	if appName = "StartAppServer" then
//		cmd:=cmd&amp;" endjade "&amp;txtAppServers.text&amp;";"&amp;txtBmkBasePort.text&amp;";1;";
		cmd:=cmd&amp;" endjade "&amp;myBmkControl.appServers.String&amp;";"&amp;myBmkControl.bmkBasePort.String&amp;";1;";
	endif;
	result:=node.createExternalProcess(null,cmd,null,null,true,false,retCode);
	if result = 0 then
		return cmd&amp;" result="&amp;result.String;
	else
		return cmd&amp;CrLf&amp;"result="&amp;result.String;
	endif;
end;</source>
        <Parameter name="envid" type="String"/>
        <Parameter name="host" type="String"/>
        <Parameter name="controlPort" type="String"/>
        <Parameter name="schemaName" type="String"/>
        <Parameter name="appName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="startAppOnServer" id="515de685-07fe-421d-87a6-5137b93af6e7">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>startAppOnServer() updating, serverExecution;

vars
	path,templatePath,logPath,cmd,altHostName,result:String;
	i,j,retCode:Integer;
	cre:Creator;
	sysAdmin:SysAdmin;
begin
	path:=app.dbPath.replace('c_system', 'c_misc\thinbin\'&amp;myBmkControl.envid);
	templatePath:=app.dbPath.replace('c_system', 'c_misc\thinbin\template ');
	logPath:=app.dbPath.replace('c_system', 'c_misc\thinbin\logs\cmd.log');
	create cre;
	if app.name = "DoCommand" then
		cre.doCmd('xcopy '&amp;templatePath&amp;path&amp;' /I /Y', ' &gt;&gt; '&amp;logPath);
	else
		cre.doCmd('if not exist '&amp;path&amp;' xcopy '&amp;templatePath&amp;path&amp;' /I /Y', ' &gt;&gt; '&amp;logPath);
	endif;
	app.doWindowEvents(6000);
	cre.setAutoDownLoad(path&amp;'\jade.ini');
	create sysAdmin;
	/*if sysAdmin.isUnicode(myBmkControl.product) then
		app.setProfileString(path&amp;'\jade.ini', "JadeLog", "LogDirectory",  "logs_uni");
	endif;/**/
	app.setProfileString(path&amp;'\jade.ini', "JadeLog", "LogFile",  "jommsg_"&amp;myBmkControl.product);
	
	syncMasterThinbinFiles;

	altHostName:=myBmkControl.appServerHost;
	if altHostName = "cnwchcc46" then
		altHostName:="cnwchcs46";
	endif;
	cmd:=path&amp;'\jade.exe'
			&amp;' schema=NodeControlSchema'
			&amp;' app=StartAppServer'
			&amp;' appserver='&amp;altHostName
			&amp;' appserverport='&amp;myBmkControl.controlPort
			&amp;' Jade.UnattendedMode=true'  // suppress msgbox dialog if cannot connect
			&amp;" endjade 0;0; &lt;&lt;&lt;sync master thinbin&gt;&gt;&gt;";

	addResults(cmd);
	app.logMessage(cmd);
	retCode:=node.createExternalProcess(null,cmd,null,null,true,true,j);
	app.doWindowEvents(2000);
	if retCode = 4 or j &lt;&gt; 0 then
		result:="done (but the app may still be replacing files for a few seconds) retCode="&amp;retCode.String;
	else
		result:="failed, retCode="&amp;retCode.String&amp;" result="&amp;j.String;
	endif;
	addResults(result);
	app.logMessage(result);
epilog
	delete cre;
	delete sysAdmin;
end;</source>
    </JadeMethod>
    <JadeMethod name="startAppOnServerOrig" id="6371d901-154c-4daa-bdbd-b6c625f585b4">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>startAppOnServerOrig() updating, serverExecution;

vars
	path,templatePath,logPath,cmd,altHostName,result:String;
	i,j,retCode:Integer;
	cre:Creator;
begin
	path:=app.dbPath.replace('c_system', 'c_misc\thinbin\'&amp;myBmkControl.envid);
	templatePath:=app.dbPath.replace('c_system', 'c_misc\thinbin\template ');
	logPath:=app.dbPath.replace('c_system', 'c_misc\thinbin\logs\cmd.log');
	create cre;
	if app.name = "DoCommand" then
		cre.doCmd('xcopy '&amp;templatePath&amp;path&amp;' /I /Y', ' &gt;&gt; '&amp;logPath);
	else
		cre.doCmd('if not exist '&amp;path&amp;' xcopy '&amp;templatePath&amp;path&amp;' /I /Y', ' &gt;&gt; '&amp;logPath);
	endif;
	app.doWindowEvents(1000);
	cre.setAutoDownLoad(path&amp;'\jade.ini');
	if myBmkControl.product.toLower.cnContains("cmi") then
		app.setProfileString(path&amp;'\jade.ini', "JadeLog", "LogDirectory",  "logs_uni");
	endif;
	
	syncMasterThinbinFiles;

	altHostName:=myBmkControl.appServerHost;
	if altHostName = "cnwchcc46" then
		altHostName:="cnwchcs46";
	endif;
	cmd:=path&amp;'\jade.exe'
			&amp;' schema=NodeControlSchema'
			&amp;' app=StartAppServer'
			&amp;' appserver='&amp;altHostName
			&amp;' appserverport='&amp;myBmkControl.controlPort
			&amp;" endjade 0;0; &lt;&lt;&lt;sync master thinbin&gt;&gt;&gt;";

	addResults(cmd);
	app.logMessage(cmd);
	retCode:=node.createExternalProcess(null,cmd,null,null,true,true,j);
	app.doWindowEvents(2000);
	if retCode = 4 or j &lt;&gt; 0 then
		result:="done (but the app may still be replacing files for a few seconds) retCode="&amp;retCode.String;
	else
		result:="failed, retCode="&amp;retCode.String&amp;" result="&amp;j.String;
	endif;
	addResults(result);
	app.logMessage(result);
epilog
	delete cre;
end;</source>
    </JadeMethod>
