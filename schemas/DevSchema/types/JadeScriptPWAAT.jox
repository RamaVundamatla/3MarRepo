<Class name="JadeScriptPWAAT" id="5d480754-c764-4ced-87f9-1a9326bbc46d">
    <superclass name="JadeScriptPW"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmsmap"/>
    <JadeMethod name="getUnclosedWebSessGrouped" id="3c82fe7f-7e9c-44ca-aa99-cf7c8ef2fc38">
        <source>getUnclosedWebSessGrouped();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2025	navpw1	Initial creation

*/

vars
	schema : Schema;
	class : Class;
	//logon : SWebServiceSchema;
	objSet : CM_ObjectSet;
	exportHeaders,
	exportData : String;
	iter : Iterator;
	obj : Object;
	userCode,
	display,
	startDtStr,
	lastAccessDtStr: String;
	startIdx : Integer;
	ts : TimeStamp;
	date : Date;
	time : Time;
	lFile      		: File;
	dynaDict : DynaDictionary;
	count : Integer;
	stringObj : CM_String;
	
begin
	schema := rootSchema.getSchema("WebServicesSchema");
	class := schema.getClass("SWebServiceSchema");
	
	create objSet transient;
	
	create dynaDict transient;
	dynaDict.setMembership(CM_String);
	dynaDict.addExternalKey(String, 10, false, false); //User Code
	dynaDict.endKeys(true);
	
	class.instances.copy(objSet);
	
	iter := objSet.createIterator;
	
	while iter.next(obj) do
		if obj.getPropertyValue("myUser") &lt;&gt; null then
			userCode := obj.getPropertyValue("myUser").CM_User.getPropertyValue("code").String;
		else
			userCode := null;
		endif;
		
		if dynaDict[userCode] = null then
			create stringObj transient;
			stringObj.string := 1.String;
			dynaDict.putAtKey(userCode, stringObj);
		else
			stringObj := dynaDict[userCode].CM_String;
			count := stringObj.string.Integer;
			count +=1;
			stringObj.string := count.String;
		endif;
		
	endwhile;
	delete iter;
	
	exportHeaders := "user,count";
	
	create lFile transient;
	lFile.fileName := "C:\TEMP\aat\session_info_user_group_mtn.csv";
    lFile.open;
	lFile.writeLine(exportHeaders);
	
	iter := dynaDict.createIterator;
	
	while iter.next(stringObj) do
		iter.getCurrentKeys(userCode);
		
		exportData := userCode &amp; Comma &amp; stringObj.string;
		
		lFile.writeLine(exportData);
		
	endwhile;
	
	lFile.close;
	
epilog
	delete objSet;
	delete lFile;
	dynaDict.purge;
	delete dynaDict;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getUnclosedWebSessions" id="9adc7c9c-586d-466b-98ea-a850c23a1123">
        <source>getUnclosedWebSessions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2025	navpw1	Initial creation

*/

vars
	schema : Schema;
	class : Class;
	//logon : SWebServiceSchema;
	objSet : CM_ObjectSet;
	exportHeaders,
	exportData : String;
	iter : Iterator;
	obj : Object;
	userCode,
	display,
	startDtStr,
	lastAccessDtStr: String;
	startIdx : Integer;
	ts : TimeStamp;
	date : Date;
	time : Time;
	lFile      		: File;
	
begin
	schema := rootSchema.getSchema("WebServicesSchema");
	class := schema.getClass("SWebServiceSchema");
	
	create objSet transient;
	
	class.instances.copy(objSet);
	
	exportHeaders := "session_id,start_time,last_access_time,user,oid";
	
	create lFile transient;
	lFile.fileName := "C:\TEMP\aat\session_info_mtn.csv";
    lFile.open;
	lFile.writeLine(exportHeaders);
	
	iter := objSet.createIterator;
	
	while iter.next(obj) do
		if obj.getPropertyValue("myUser") &lt;&gt; null then
			userCode := obj.getPropertyValue("myUser").CM_User.getPropertyValue("code").String;
		else
			userCode := null;
		endif;
		
		display := obj.sendMsg("display").String;
		
		startIdx := display.pos("=", 1)+1;
		
		display := display.scanUntil(CrLf, startIdx);
		
		ts := obj.getPropertyValue("startTime").TimeStamp;
		date := ts.date;
		time := ts.time;
		
		startDtStr := date.format('yyyy-MM-dd');
		startDtStr &amp;= Space &amp; time.format('HH:mm:ss') &amp; "." &amp; time.milliSecond.String.padLeadingZeros(3);
		
		ts := obj.getPropertyValue("lastAccessTime").TimeStamp;
		lastAccessDtStr := date.format('yyyy-MM-dd');
		lastAccessDtStr &amp;= Space &amp; time.format('HH:mm:ss') &amp; "." &amp; time.milliSecond.String.padLeadingZeros(3);
		
		exportData := display &amp; Comma &amp; startDtStr &amp; Comma &amp; lastAccessDtStr &amp; Comma &amp; userCode &amp; Comma &amp; obj.getOidAsString();
		lFile.writeLine(exportData);
		
	endwhile;
	
	lFile.close;
	
epilog
	delete objSet;
	delete lFile;
	
end;</source>
    </JadeMethod>
</Class>
