    <JadeMethod name="doMnuGridReverseClick" id="43b9f256-ae60-4be5-b178-a29dd9be6720">
        <updating/>
        <source>doMnuGridReverseClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theRequest,pxySR : CM_SlotRequest;
	theMotorDir,
	theDoorDir,
	theDirection : Integer;
	obj : Object;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	
	//Mohammad CCMS1060
	foreach obj in self.myBayDrawingController.allSelectedObjects do
	
		theRequest := obj.CM_SlotController.mySlotRequestLoad;
		if theRequest = null then
			continue;
		endif;	
		
		// epr TFS 7006 29/9/17 
		if self.mnuGridReverse.helpKeyword = "MOTOR" then
			if menuItem = self.mnuGridRevDoorsAft then
				theDirection:=TI_DOORSDIRN_FWD;
			else
				theDirection:=TI_DOORSDIRN_AFT;
			endif;
				
		else
			if menuItem = self.mnuGridRevDoorsAft then
				theDirection:=TI_DOORSDIRN_AFT;
			else
				theDirection:=TI_DOORSDIRN_FWD;
			endif;
		endif;		

		
		pxySR := app.createUpdateProxy(theRequest).CM_SlotRequest;
		pxySR.setProxyForDoorDirection(theDirection);
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateSlotRequestDirection(pxySR, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(self.mnuGridReverse.caption, app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
		delete pxySR;
	endforeach;
epilog
	delete pxySR;
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
