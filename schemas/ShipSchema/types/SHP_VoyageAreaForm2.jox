        <source>doBtnToolbarGetPxyBackends(_theController : CMIF_SlotRequestController input) ;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	if not _theController.allLinkedProxySlotRequests.isEmpty then
		if _theController.allLinkedProxySlotRequests.size &lt;&gt; _theController.allProxySlotRequests.size then
		
