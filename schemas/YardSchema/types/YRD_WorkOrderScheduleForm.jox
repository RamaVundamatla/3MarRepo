    <JadeMethod name="timerClear" id="9ab7b7eb-824e-437f-8b49-6a29c4fb8537">
        <updating/>
        <source>timerClear() updating;
// -----------------------------------------------------------------------------
// Created:		19 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if self.timerTS &lt;&gt; null then
		self.endTimer(self.TimerDT);
		self.timerTS := null;
	endif;
	
epilog

end;</source>
