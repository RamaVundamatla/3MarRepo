    </JadeMethod>
    <JadeMethod name="unloadForm" id="cf79fc1c-36c6-4b32-883a-d22c82ebe776">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>unloadForm(): Boolean updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group

*/

vars

begin
	self.allCargoGroupDetails.purge();
	return inheritMethod();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateProgressForBulkMove" id="2aecfdcb-5252-4c29-95d9-b55dd4572430">
        <source>updateProgressForBulkMove(_cmifMonitor : CMIF_Monitor input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Apr 2024 navhl20 ChangeRequest 63302: EUP - Bulk Moves in Retrospective Screen
*/
vars

begin
	self.pbProgressBar.partsInJob := _cmifMonitor.partsInJob;	
	self.pbProgressBar.partsDone := _cmifMonitor.partsDone;
	self.lblModalInfo.caption := app.getErrorString(Move_cargo) &amp; Space &amp; '[' &amp; _cmifMonitor.partsDone.String &amp; '/' &amp; _cmifMonitor.partsInJob.String &amp; ']';
	
	self.frmModalDialog.refreshNow();
	self.frmModalDialog.doWindowEvents(0);
	self.btnModalDefault.doWindowEvents(0);
	
	if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
		_cmifMonitor.monitorReturnValue := _cmifMonitor.MonitorReturnValue_Cancel;
	endif;

end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate" id="554b4a00-5409-468a-8e9a-30ea9027641b">
        <source>validate(_ta : CM_TerminalArea; _targetLocation : CM_LocationsController; _isPack : Boolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations
12 Mar 2024 navhl20 ChangeRequest 62734: EUP | Ship Operations in DD - [54176.060] - [Release] Retrospective Operations
22 Jul 2024 navbs1 ChangeRequest 64884: EUP - Retrospective Jobs Grouped by Cargo Group
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
03 Dec 2024 navbs1  Bug MTN-33570: MTN - Ship WorkOrder Enhancements
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.
*/

vars
	tiSet : CM_TISet;
	job	  : CM_Job;	
begin
	
	job := self.myJob;
	
	if job = null then																				//27.03.2025 navhl20 #34493
		if app.msgBox(app.getErrorString(Input_required_field_jobID), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
			return false;
		endif;
	endif;
	
	if not job.isWOPackJob and not job.isWOUnpackJob then
		if not job.isRelease then
			if _ta = null then
				if app.msgBox(app.getErrorString(Input_required_field_termArea), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
					return false;
				endif;
			endif;
			
			if self.cmbSubArea.listCount &gt; 0 and _targetLocation = null then
				if app.msgBox(app.getErrorString(Input_require_area_field), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
					return false;
				endif;
			endif;
		elseif self.grpLocation.visible then																	//12.03.2024 navhl20 #62734
			if _targetLocation = null then
				if app.msgBox(app.getErrorString(Input_requir_voyage_hold_field), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
					return false;
				endif;
			endif;
		endif;
	endif;
	
	if _isPack then																							//27.03.2025 navhl20 #34493
		if job.isWOPackJob then
			if self.tblParent.allSelectedObjects.isEmpty() or self.tblChild.allSelectedObjects.isEmpty() then
				if app.msgBox(app.getErrorString(Please_select_cargo_item_pack), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
					return false;
				endif;
			endif;
		else
			if self.tblChild.allSelectedObjects.isEmpty() then
				if app.msgBox(app.getErrorString(Please_select_cargo_item_unpac), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
					return false;
				endif;
			endif;
		endif;
	else
		create tiSet transient;																				//03.12.2024  navbs1  #33570
		self.getSelectedObjects(self.tblAvailCargo,tiSet);													//03.12.2024  navbs1  #33570
		
		if tiSet.isEmpty()  then																																							//03.12.2024  navbs1  #33570
			if app.msgBox(app.getErrorString(Please_Select_Cargo_Items), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
				return false;
			endif;
		endif;
	endif;
	
	return true;
epilog
	delete tiSet;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_isPack" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCargoToPack" id="61631aec-8d7d-4713-b8e2-45f1b3c11444">
        <source>validateCargoToPack(_parentCargo, _packCargo : CM_TrackedItem; _bulkRelease : CM_BulkRelease; _reserveDetail : CM_ReserveDetail io; _setParentFromChild : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	quantity		: Integer;
	cmifLoader 		: CMIF_MobileGenericAgent;
	reason 			: String;
	job 			: CM_Job;
	req				: CM_Request;
begin
	if not _setParentFromChild then
		_parentCargo.validateCargoToPack(_packCargo);
	endif;

	create cmifLoader transient;
	cmifLoader.setMyTerminal(app.myPassport.myTerminal);
	cmifLoader.setMyBulkRelease(_bulkRelease);
	_reserveDetail := cmifLoader.getReserveDetailCargoMatches(_packCargo,quantity, null,reason);
	
	if _reserveDetail = null then
		job := self.myJob;
		if job &lt;&gt; null then
			req := job.allRequests.first;
		endif;
		if req &lt;&gt; null then
			_reserveDetail := req.myReserveDetail;
		endif;
	endif;
	
	if app.myPassport.noErrors and _reserveDetail &lt;&gt; null then
		_reserveDetail.validateForPack(_reserveDetail, _packCargo, quantity, null);
	endif;
epilog
	delete cmifLoader;
end;</source>
        <Parameter name="_parentCargo" type="CM_TrackedItem"/>
        <Parameter name="_packCargo" type="CM_TrackedItem"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="io"/>
        <Parameter name="_setParentFromChild" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateDateTime" id="9f372279-a954-4184-91d9-85f33b38f47a">
        <source>validateDateTime(_effectiveDate : TimeStamp):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Sep 2024 navhl20	ChangeRequest 14712: EUP - FR | 54176 - Ship operations in Delivery Dispatch screen (retrospective) - 1
14 Nov 2024 navma1	MTN-19903 EUP - Validation of the Effective Date field
29 Nov 2024	navhl20 Bug MTN-33551: MTN - Effective date validation issue
12 Mar 2025	navhl20 Bug MTN-34121: MTN | Bulk Discharge fails with "Effective Date..." error
*/

vars
	jobSheet 	: CM_WorkPointJobSheet;
	shift		: CM_Shift;
	startTS,
	endTs		: TimeStamp;
	job			: CM_Job;
begin
	job		 := self.myJob;
	jobSheet := job.myJobSheetForWorkPoint;
	
	if jobSheet &lt;&gt; null then
		shift := jobSheet.myShift;
	endif;
	
	startTS := jobSheet.startDateTime;				//14.11.2024 navma1 #MTN-19903
	
	if shift &lt;&gt; null then
		endTs := shift.endDateTime;
	endif;
	
	if job.isVoyageWorkpointJob then
		startTS := job.CM_VoyageWorkPointJob.actualStartTs;
		endTs   := job.CM_VoyageWorkPointJob.actualEndTs;
	endif;
	
	if not _effectiveDate.isValid or not startTS.isValid or not endTs.isValid then
		if app.msgBox(app.getErrorString(Invalid_effecti_date_time), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then	//29.11.2024 navhl20 #33551
			return false;
		endif;
	endif;
	
	if _effectiveDate &lt; startTS or _effectiveDate &gt; endTs then
		if app.msgBox(app.getErrorString(Effec_date_time_shoul_withi_ra), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
			return false;
		endif;
	endif;
	
	if _effectiveDate&gt; app.actualTimeAppServer() then		//12.03.2025 navhl20 #34121
		if app.msgBox(app.getErrorString(Effec_date_time_must_prese_pas), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_effectiveDate" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTruckLoad" id="9897eef3-ad31-4cc3-838d-63dd4f006344">
        <source>validateTruckLoad(_quantity : Integer; _weight : Decimal; _resDetl : CM_ReserveDetail):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Mar 2025	navhl20 CR MTN-34493: MTN - Removing unnecessary codes from Work Order complete job screen methods.

*/

vars
	wle 		: CM_WorkListEntry;
	count 		: Integer;
	weightCount	: Decimal[12,4];
begin
	foreach wle in self.myJob.workListEntries discreteLock where wle.status &lt;&gt; WLE_COMPLETED do
		if _quantity &lt;&gt; 0 then
			count := count + wle.quantity.max(1);
		else
			weightCount := weightCount + wle.weight;
		endif;
	endforeach;
	
	if _resDetl &lt;&gt; null and weightCount = null then
		weightCount := _resDetl.weightRequested - _resDetl.getWeightLoaded();
	endif;
	
	if count &gt; 0 and _quantity &gt; count then
		if app.msgBox(app.getErrorString(Select_cargos_exceed_requir_qu), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
			return false;
		endif;
	elseif _weight &gt; 0 and _weight &gt; weightCount then
		if app.msgBox(app.getErrorString(Select_cargos_exceed_requir_we), app.getErrorString(Error) , MsgBox_Question_Mark_Icon + MsgBox_OK_Only) = MsgBox_Return_OK then
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_resDetl" type="CM_ReserveDetail"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
