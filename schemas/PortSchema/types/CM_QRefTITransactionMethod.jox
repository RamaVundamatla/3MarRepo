    <JadeMethod name="setComboValues" id="5f8e9bb5-a8f7-4402-9f21-aced27c88e73">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars
	op		: CM_TransactionType;
	coll	: CM_TransactionTypeByType;
	qrl		: CM_QReferenceLookup;
begin
	_combo.clear();
	
	coll := app.myRoot.allTransactionTypes;
	
	foreach op in coll do
		_combo.itemObject[_combo.addItem( op.description )] := op;
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="60634926-b40f-40bb-86f4-e173c81535b4">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QReferenceIsOneOf; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36228

*/

vars
	selectionValue : Integer;
	type : CM_TransactionType;
	idx : Integer;
begin
	_tbl.clear;
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2; // TFS 7821


	foreach type in app.myRoot.allTransactionTypes do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(type) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; type.description);
		_tbl.accessRow(idx).itemObject := type;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="c3080546-8c1e-4ee5-924c-7c5c2d447da1">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars
	str : String;
	numRows,
	idx	 : Integer;
	typeSet : CM_ObjectSet;
	type : CM_TransactionType;
begin

	create typeSet transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			type := _tbl.accessRow(idx).itemObject.CM_TransactionType;
			typeSet.add(type);
		endif;
	endforeach;
	
	_op.setSearchValue(typeSet);
	
epilog
	delete typeSet;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="ef81337b-7ec6-4f6b-a720-9dc712e04504">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin 
	if _value.isKindOf(CM_TransactionType) then
		if _value &lt;&gt; null then
			return _value.CM_TransactionType.description;
		else
			return null;
		endif;
	elseif _value.isKindOf( CM_TITransactionByDateOrdDict ) then	//28 Aug 2018	NDL TFS 40400
		return _value.CM_TITransactionByDateOrdDict.listAllTypes();
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="297d3db7-57e5-4812-b51e-2d83c063aa57">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	taType : CM_TransactionType;
		
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_TransactionType) then
			return _value.CM_TransactionType;
		endif;
	endif;
	
	if _value.isKindOf(Integer) then
		return app.myRoot.allTransactionTypes[_value.Integer];
	else
		return app.myRoot.allTransactionTypesByDesc[_value.String];
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="897ca076-f862-471e-a799-48fcf7225623">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	objSet : ObjectSet;
	obj : Object;
	transType : CM_TransactionType;
	result : String;
	collStr : String;
	coll : CM_TransactionTypeByDesc;
	strArray : StringArray;
	str : String;

begin
	if _value.isKindOf(ObjectSet) then
		objSet := _value.ObjectSet;
		foreach obj in objSet do
			transType := obj.CM_TransactionType;
			result := result &amp; transType.description &amp; CNEC_COMMA &amp; Space;
		endforeach;
		if result &lt;&gt; null then
			result := result[1:result.length-2];
		endif;
		return result;
		
	elseif _value.isKindOf(String) and _value.String.cnContains("|") then
		collStr := _value.String;
		create strArray transient;
		create coll transient;
		collStr.getTokensForDelimiter("|", strArray);
		foreach str in strArray do
			transType := app.myRoot.allTransactionTypesByDesc[str];
			if transType &lt;&gt; null then
				coll.addNoDuplicates(transType, false);
			endif;
		endforeach;
		return coll;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
