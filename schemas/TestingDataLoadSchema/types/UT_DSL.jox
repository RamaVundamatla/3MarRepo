    <JadeMethod name="deleteTask" id="52247ddd-16d8-4897-84e1-25884b4b78ee">
        <source>deleteTask(_entry : CM_RTQueueEntry);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 December 2011	cnwdw1	Initial creation
*/
vars
	lMoveControl	: CMIF_MoveController;
	wleArray,
	wlesWithWarnings	: CM_WLEArray;
begin

	if _entry.myWorkListEntry.myTrackedItem &lt;&gt; null then
		create lMoveControl transient;
		if _entry.isPlanOnPickupNoTarget then 
			lMoveControl.setMoveMode(QUEUE_PLAN_ON_PICKUP);
		else
			lMoveControl.setMoveMode(QUEUE_MODE);
		endif;
		lMoveControl.setMyTrackedItem(_entry.myWorkListEntry.myTrackedItem);
		lMoveControl.setMyWorkListEntry(_entry.myWorkListEntry);
		lMoveControl.isForcedMove := true;
		app.myTrxUA.trxUpdateMoveTIUndo(lMoveControl, app.myPassport);
	else
		create wleArray transient;
		create wlesWithWarnings transient;
		wleArray.add(_entry.myWorkListEntry);
		app.myTrxUA.trxUpdateWLEsUnqueue(wleArray, wlesWithWarnings, app.myPassport);
	endif;
	
	self.assertNoTrxErrorsOrWarnings();
			
epilog
	delete lMoveControl;
	delete wleArray;
	delete wlesWithWarnings;
end;</source>
        <Parameter name="_entry" type="CM_RTQueueEntry"/>
    </JadeMethod>
