    <JadeMethod name="trxUpdateChargesManual" id="ca12ab9a-9f81-4d20-bdfd-d48bdf3bc19a">
        <updating/>
        <source>trxUpdateChargesManual(_theAQC : CMIF_ChargesController; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	pxyCharge : CM_Charge;
	colSize : Integer;
	theInvLine : CM_InvoiceLine;
	realCharge : CM_Charge;
	invLines : CM_InvoiceLineSet;
	invoices : CM_InvoiceSet;
	theInvoice : CM_Invoice;
	lastUpdate		: Decimal [20];
	chunk : Integer;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	beginTransaction;

// ### JIRA 33479 27NOV2024 NAVAB1	create invoices transient;// ### TFS DEFECT 63946 02MAY2024 NAVAB1
	
	// ### TFS BUG 62926 02APR2024 NAVAB1
	create invLines transient;
	colSize := _theAQC.allCharges.size; 
	lastUpdate := app.relativeMachineTime; // ### TFS BUG 64505 03JUL2024 NAVAB1
	
	foreach pxyCharge in _theAQC.allCharges do
		
		app.myUtilityUA.utlUpdateChargesManual(pxyCharge,_passport);
		if _passport.hasErrors then
			return;
		endif;
		
		// ### TFS BUG 62926 02APR2024 NAVAB1
		realCharge := pxyCharge.pxyGetRealObject().CM_Charge;
		theInvLine := realCharge.invoiceLine;
		invLines.addNoDuplicates(theInvLine,false);
		
		// ### TFS DEFECT 63946 02MAY2024 NAVAB1
		/*// ### JIRA 33479 27NOV2024 NAVAB1
		theInvoice := theInvLine.invoice;
		if theInvoice &lt;&gt; null then
			if invoices.tryAddIfNotNull(theInvoice) then
				self.reserveLock(theInvoice); // ### TFS BUG 64505 06JUNE024 NAVAB1
			endif;
		endif;
		*/
		
		// ### TFS BUG 64505 03JUL2024 NAVAB1 - do chunking
		if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then			
			chunk := chunk + 1;
			
			if _passport.hasErrors() then
				if not process.isInTransactionState() then
					beginTransaction;
				endif;
			
				continue;
			endif;			
			
			commitTransaction;
			process.sleep(200);			
			lastUpdate := app.relativeMachineTime;
			beginTransaction;
		endif;		
	endforeach;

	// ### TFS BUG 64505 06JUNE024 NAVAB1
	if _passport.hasErrors then
		return;
	endif;

	
	// ### TFS BUG 62926 02APR2024 NAVAB1
	if colSize &lt; 1000 then
		foreach theInvLine in invLines discreteLock do
			theInvLine.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceLineUpdate), true, theInvLine);
		endforeach;
	endif;
	// ### TFS DEFECT 63946 02MAY2024 NAVAB1
	/* // ### JIRA 33479 27NOV2024 NAVAB1
	foreach theInvoice in invoices do

		theInvoice.setAmountDetailsToNull();
		// ### TFS BUG 64505 06JUNE024 NAVAB1
		if _passport.hasErrors then
			return;
		endif;
		foreach theInvLine in theInvoice.invoiceLines discreteLock do
			theInvLine.setTotalAmount();

			// ### TFS BUG 64505 06JUNE024 NAVAB1
			if _passport.hasErrors then
				return;
			endif;
		endforeach;
	endforeach;
	*/
	// ### JIRA 33479 27NOV2024 NAVAB1 - change to adjust the invoice line for tax and line amount and adjust the invoice for just that invoice line.
	foreach theInvLine in invLines discreteLock do
		theInvLine.setTotalAndTaxForResync();
	endforeach;
	
	
epilog
	delete invoices;// ### TFS DEFECT 63946 02MAY2024 NAVAB1

	delete invLines;// ### TFS BUG 62926 02APR2024 NAVAB1
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theAQC" type="CMIF_ChargesController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateChargesTaxManual" id="8af3eaea-f85b-41fe-a0d2-0e3eddd2a156">
        <updating/>
        <source>trxUpdateChargesTaxManual(_theAQC : CMIF_ChargesController; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars
	pxyCharge, realCharge : CM_Charge;
	invLine : CM_InvoiceLine;
	inv : CM_Invoice;
	invset : CM_InvoiceSet;
	colSize : Integer;
	invLines : CM_InvoiceLineSet;
	lastUpdate		: Decimal [20];
	chunk : Integer;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	create invset transient;
	create invLines transient;

	colSize :=  _theAQC.allChargesByTax.size; // ### TFS BUG 62926 02APR2024 NAVAB1
	lastUpdate := app.relativeMachineTime; // ### TFS BUG 64505 03JUL2024 NAVAB1
	 
	app.setContinueCMExceptions(false);
	beginTransaction;

	foreach pxyCharge in _theAQC.allChargesByTax do
		
		app.myUtilityUA.utlUpdateChargesTaxManual(pxyCharge,_passport);
		if _passport.hasErrors then
			return;
		endif;
		
		// ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1
		realCharge := pxyCharge.pxyGetRealObject().CM_Charge;
		invLine := realCharge.invoiceLine;
		inv := invLine.invoice;
		if invset.addNoDuplicates(inv, false) then
			self.reserveLock(inv); // ### TFS BUG 64505 06JUNE024 NAVAB1
		endif;
		
		
		// ### TFS BUG 62926 02APR2024 NAVAB1
		invLines.addNoDuplicates(invLine,false);
		
		// ### TFS BUG 64505 03JUL2024 NAVAB1 - do chunking
		if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then			
			chunk := chunk + 1;
			
			if _passport.hasErrors() then
				if not process.isInTransactionState() then
					beginTransaction;
				endif;
			
				continue;
			endif;			
			
			commitTransaction;
			process.sleep(200);			
			lastUpdate := app.relativeMachineTime;
			beginTransaction;
		endif;		
	endforeach;
	
	// ### TFS BUG 64505 06JUNE024 NAVAB1 - recalc the details on the charges and lines
	foreach invLine in invLines discreteLock do
		invLine.setTaxDetails(); 
		invLine.setTotalAmount(); 
	endforeach;
	
	
	// ### TFS BUG 62926 02APR2024 NAVAB1
	if colSize &lt; 1000 then
		foreach invLine in invLines discreteLock do
			invLine.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceLineUpdate), true, invLine);
		endforeach;
	endif;
		
		
		
	// ### TFS BUG 64505 06JUNE024 NAVAB1
	if _passport.hasErrors then
		return;
	endif;
	
	// ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1
	foreach inv in invset do

		inv.setTaxDetailsFromLines();
		
		// ### TFS BUG 64505 06JUNE024 NAVAB1
		if _passport.hasErrors then
			return;
		endif;
		inv.setTotalAmountFromLines(); // ### TFS CR 63369 TASK 63371 08APR2024 NAVAB1
		
		// ### TFS BUG 64505 06JUNE024 NAVAB1
		if _passport.hasErrors then
			return;
		endif;
	endforeach;

epilog
	delete invset;
	delete invLines;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theAQC" type="CMIF_ChargesController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
