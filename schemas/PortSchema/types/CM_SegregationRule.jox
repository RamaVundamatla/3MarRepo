    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <ImplicitInverseRef name="myConstituentEntity1" id="84d7653e-d1f6-4075-9b32-697db6089098">
        <embedded/>
        <type name="CM_Object"/>
        <access>readonly</access>
    </ImplicitInverseRef>
