        <updating/>
        <source>setForKioskAAAI( _bulkRelease : CM_BulkRelease; _vvr : CM_VehicleVisitRecord ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2020	jlgndl1	Initial creation	TFS 49167

*/

vars

	cargoType : CM_CargoType;

begin

	self.cargoType := 1;
	self.deliveryReleaseNumber := _bulkRelease.code;
	self.doorsDirection := 4;
	self.setIsAnyId( true ); //forestryStop
	self.isReleaseById := true;
	self.setIsAnyAmount( true );//mafStop
	self.myBulkRelease := _bulkRelease;
	self.numItems := 1;
	self.jobType := 8;
	self.jobTypeString := "Release General Cargo";
	self.myTerminal := _bulkRelease.myTerminal;
	self.myVehicleVisitRecord := _vvr;
	if _bulkRelease.myOperator &lt;&gt; null then
		self.operatorCode := _bulkRelease.myOperator.code;
	endif;
	self.totalQuantity := 1;
	
	self.mySubTerminalSource := _bulkRelease.mySubTerminal;	//18 Mar 2021	NDL	TFS 50942

epilog

end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7ba4343b-647e-40c1-a7d8-59ed331ffd3c">
        <updating/>
        <source>setForUpdate(_pxyGTEEntity: CMGTE_Release; _realVVR : CM_VehicleVisitRecord ) updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 27 Feb 2018		cnwma1  		ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
// 02 Oct 2020 		cnwma1   		ChangeRequest 50112: ASPA - GCI Stevedores
// 22 Apr 2024		jlizm1			TFS 62856 Shipment Number field
// 19 Jul 2024		navpw1			TFS: 61525 (61527) - Added vbsti field so it is saved to the database
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_pxyGTEEntity, _realVVR);
	
	self.importReleasePIN   := _pxyGTEEntity.importReleasePIN;
	self.numItems 		    := _pxyGTEEntity.numItems;
	self.colour 		    := _pxyGTEEntity.colour;
	self.yardInstructions   := _pxyGTEEntity.yardInstructions;
	self.remarks 			:= _pxyGTEEntity.remarks;
	self.doorsDirection 	:= _pxyGTEEntity.doorsDirection;//cnwas3
	self.cargoType		 	:= _pxyGTEEntity.cargoType;
	self.mtOnly 			:= _pxyGTEEntity.mtOnly;

	self.mySubTerminalSource 	:= _pxyGTEEntity.mySubTerminalSource;
	self.deliveryReleaseNumber  := _pxyGTEEntity.deliveryReleaseNumber;
	self.isReleaseById 			:= _pxyGTEEntity.isReleaseById;
	if self.isReleaseById then
		self.myTrackedItem		:= _pxyGTEEntity.myTrackedItem;
	endif;
	
	
	self.bookingReference 	  := _pxyGTEEntity.bookingReference;	
	self.deliveryReason 	  := _pxyGTEEntity.deliveryReason;
	self.consignorVoyageCode  := _pxyGTEEntity.consignorVoyageCode;
	self.consigneeCode 		  := _pxyGTEEntity.consigneeCode;
	self.eirNumber 			  := _pxyGTEEntity.eirNumber;
	self.myTransferToTerminal := _pxyGTEEntity.myTransferToTerminal;
	self.customEntryNumber    := _pxyGTEEntity.customEntryNumber;
	self.updateConsigneeCode  := _pxyGTEEntity.updateConsigneeCode;
	self.stevedoreCode        := _pxyGTEEntity.stevedoreCode;       //02.10.2020 cnwma1 TFS #50112

	self.myCargoType 	   :=  _pxyGTEEntity.myCargoType;
	self.myTILCType 	   := _pxyGTEEntity.myTILCType;
	self.doISOGroupCheck   := _pxyGTEEntity.doISOGroupCheck;
	self.clean 			   := _pxyGTEEntity.clean;
	self.heavyRated        := _pxyGTEEntity.heavyRated;
	self.operatorGroupCode := _pxyGTEEntity.operatorGroupCode;
	self.isoType 		   := _pxyGTEEntity.isoType;
	self.isoGroup 		   := _pxyGTEEntity.isoGroup;
	self.imexStatus 	   := _pxyGTEEntity.imexStatus;
	self.commodity 		   := _pxyGTEEntity.commodity;
	self.billOfLading 	   := _pxyGTEEntity.billOfLading;	
	self.myBOLDtl 		   := _pxyGTEEntity.myBOLDtl;			//08 Oct 2020	NDL	TFS 49189
	self.idMask 		   := _pxyGTEEntity.idMask;
	self.myBulkRelease     := _pxyGTEEntity.myBulkRelease;
	self.myReserveDetail   := _pxyGTEEntity.myReserveDetail;
	self.density 		   := _pxyGTEEntity.density;
	self.setBestPick(_pxyGTEEntity.getBestPick());				// CCMS 1101
	self.isFIFO 	   	   := _pxyGTEEntity.isFIFO; 			//cnwrd1 par 24169 9/6/2010
	self.canBeHiLoCube 	   := _pxyGTEEntity.canBeHiLoCube;		// May 2011 cnwjre1 27097 POL CCMS 2043
	self.totalQuantity 	   := _pxyGTEEntity.totalQuantity; 		//cnwrd1 ccsm 2274
	self.setIsAnyId( _pxyGTEEntity.getIsAnyId );				//01 Aug 2014	NDL	Par 34675
	self.setIsAnyAmount( _pxyGTEEntity.getIsAnyAmount );		//21 mar 2017	NDL	TFS 3813
	self.weightRequested:=_pxyGTEEntity.weightRequested; //jlier1 TFS  53678 20/6/22
	self.releaseWeight		:= _pxyGTEEntity.releaseWeight;		//13.Dec.2023 navsp1 TFS 61547
	self.releaseQuantity	:= _pxyGTEEntity.releaseQuantity;	//13.Dec.2023 navsp1 TFS 61547
	self.shipmentNumber		:= _pxyGTEEntity.shipmentNumber;	// TFS 62856
	self.allAvailabilityGrades.clear();
	_pxyGTEEntity.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	//self.myParent:= _pxyGTEEntity.myParent;  //27.02.2018 cnwma1 ChangeRequest #36813
	self.myVbsti			:= _pxyGTEEntity.myVbsti;			// ### TFS 61525 (61527) 19Jul2024 NAVPW1
	
	
epilog

end;</source>
        <Parameter name="_pxyGTEEntity" type="CMGTE_Release"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setFromROB_GTE_Receival" id="d984fed7-2e38-4fdc-b35a-70069a7080a2">
        <updating/>
        <source>setFromROB_GTE_Receival( _receivalContainer : CMGTE_Receival input;
							_realVVR : CM_VehicleVisitRecord) updating;
/*

Date		Who		Reason
14 July 2014	cnwer1	Initial creation PAR 
27 Nov  2014	cnwma1  PAR #35299 Cannot set Non Container Cargo to Remain on Board in Gate
*/

vars

begin
	if _receivalContainer = null then
		return;
	endif;
	
	
	self.setIsReleaseById(true);
	self.id:=_receivalContainer.id;
	self.myTerminal:=_receivalContainer.myTerminal;
	self.description := _receivalContainer.description;
	self.voyageCode :=_receivalContainer.voyageCode;
	self.operatorCode:=_receivalContainer.operatorCode;
	//self.myCargoType:=_receivalContainer.myCargoType;
	self.cargoType:=_receivalContainer.cargoType;
	self.imexStatus := TI_IMEX_STATUS_REMAINONBOARD;
	self.numItems:=1;
	self.consigneeCode		 		:= _receivalContainer.consigneeCode;
	if _receivalContainer.isKindOf(CMGTE_Container) then
		self.commodity:=_receivalContainer.CMGTE_Container.commodity;	
		self.isoType 				:= _receivalContainer.CMGTE_Container.isoType;
		if _receivalContainer.jobType = self.JobType_EmptyIN then	
			self.jobType:=self.JobType_EmptyOUT;
				self.mtOnly 				:= true;
		else
			self.jobType:=self.JobType_FullOUT;
		endif;
	elseif  _receivalContainer.isKindOf(CMGTE_TILC) then
		self.myTILCType:=_receivalContainer.CMGTE_TILC.myTILCType;
		self.jobType:=self.JobType_ChassisOut;
		self.isChassisOut:=true;
		self.jobQueueNum:=2;
	else 											// 27/11/2014 cnwma1 PAR#35299
		if _receivalContainer.myProduct &lt;&gt; null then
			self.myProduct := _receivalContainer.myProduct;
		endif;
		self.jobType:=self.JobType_GeneralOUT;
	endif;
	
	
	self.date 				:= app.serverTimestampAtTrxStart.date;
	self.status 			:= CMGTE_Entity.Status_Unverified;
	self.myVehicleVisitRecord := _realVVR;
	
epilog

end;</source>
        <Parameter name="_receivalContainer" type="CMGTE_Receival" usage="input"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setImportReleasePIN" id="682a1ea7-ee85-4ad1-8f89-7944a81b024a">
