    <JadeMethod name="getMatchingEmptyResUsed" id="cf5cafdf-fb85-4eb0-962f-c11dd844d80e">
        <source>getMatchingEmptyResUsed(_res : HMS_Resource) : HMS_ResourceUsed;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		Empty means that it does not have a resource set. It also must be part of contract
//				However if there is only 1 resource for a resource type, the resource may be set.
//				So if it matches resource, or null, resource type IS part of contract and has no transaction we match
//				Basically in vessel maint they can specify 'default' resource types, 1 of each.
//				These are the resources that are part of the contract. Seperately, for each movement type, they can
//				specify on a pilot, launch, tug, line co and wharf what resources to charge when the voyage is closed.
//				They do not have to do any of this, but if they do when the voyage is closed we must check whether the 
//				pilot, launch etc resource is part of the contract, if so we use the contract resource used, else we create a new one.
//
// ---------------------------------------------------------------------------

vars
	resType : HMS_ResourceType;
	aResUsed : HMS_ResourceUsed;
begin
	resType := _res.myResourceType;
	
	foreach aResUsed in self.allResourceUsed
		where aResUsed.partOfContract
		and (aResUsed.myResource = null  or aResUsed.myResource = _res)
		and aResUsed.myResourceType = resType 
		and aResUsed.myVTMISTransaction = null do // Not Charged yet

		return aResUsed;
		
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_res" type="HMS_Resource"/>
        <ReturnType type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="getMatchingINContractResUsed" id="986bc77a-62cf-4e31-aac2-227b1d88697e">
        <source>getMatchingINContractResUsed(_res : HMS_Resource) : HMS_ResourceUsed;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		Empty means that it does not have a resource set. It also must be part of contract
//				However if there is only 1 resource for a resource type, the resource may be set.
//				So if it matches resource, or null, resource type IS part of contract and has no transaction we match
//				Basically in vessel maint they can specify 'default' resource types, 1 of each.
//				These are the resources that are part of the contract. Seperately, for each movement type, they can
//				specify on a pilot, launch, tug, line co and wharf what resources to charge when the voyage is closed.
//				They do not have to do any of this, but if they do when the voyage is closed we must check whether the 
//				pilot, launch etc resource is part of the contract, if so we use the contract resource used, else we create a new one.
//
// ---------------------------------------------------------------------------

vars
	resType : HMS_ResourceType;
	aResUsed : HMS_ResourceUsed;
begin
	resType := _res.myResourceType;
	
	foreach aResUsed in self.allResourceUsed
		where aResUsed.partOfContract
		and (aResUsed.myResource = null  or aResUsed.myResource = _res)
		and aResUsed.myResourceType = resType 
		and aResUsed.myVTMISTransaction = null do // Not Charged yet

		return aResUsed;
		
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_res" type="HMS_Resource"/>
        <ReturnType type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="getMatchingUsedResUsed" id="317630d8-46ce-46a4-adcf-7e99779bb8b9">
        <source>getMatchingUsedResUsed(_res : HMS_Resource; _obj : HMS_Object;_poc : Boolean) : HMS_ResourceUsed;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
//				Trying to match to res used, make sure it is for the same tug, pilot etc.
// ---------------------------------------------------------------------------

vars
	aResUsed : HMS_ResourceUsed;
begin
	
	foreach aResUsed in self.allResourceUsed
		where aResUsed.partOfContract = _poc
		and aResUsed.myResource = _res  do

		if _obj &lt;&gt; null 
		and aResUsed.myHMSObject &lt;&gt; _obj then
			continue;
		endif;
		
		return aResUsed;
		
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_res" type="HMS_Resource"/>
        <Parameter name="_obj" type="HMS_Object"/>
        <Parameter name="_poc" type="Boolean"/>
        <ReturnType type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="getMovementPreviousChargeable" id="d3a1ee13-1337-4e42-8746-23e536de05ab">
        <source>getMovementPreviousChargeable():HMS_VoyageMovement;
// ---------------------------------------------------------------------------
// Created:		JUNE 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	aWharf : HMS_Wharf;
	aRes : HMS_Resource;
	move : HMS_VoyageMovement;
	iter : Iterator;
begin
	iter := self.myHMSVoyageData.allVoyageMovements.createIterator();
	iter.startAtObject(self);

	while iter.back(move) do
		if move = self then
			continue;
		endif;	
		
		aWharf := move.getMyBerth().myWharf;
		aRes := aWharf.getResourceForHarbourMovement(move.moveType,HMS_Wharf.First_Resource);
		if aRes = null then
			continue; // not chargeable
		endif;
		
		return move;
	endwhile;
	
	return null;
	
epilog
	delete iter;		// PAR #26678
	
end;</source>
        <ReturnType type="HMS_VoyageMovement"/>
    </JadeMethod>
    <JadeMethod name="getMyCancelledMovements" id="1f6abf85-714b-491b-8e81-e6fe09a4390e">
        <source>getMyCancelledMovements( _cancelledMovements : HMS_VoyageMovementArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

begin

	if self.myCancelledMovement = null or not self.myCancelledMovement.isKindOf(HMS_VoyageMovement) then
		return;
	else
		
		if not _cancelledMovements.includes( self.myCancelledMovement.HMS_VoyageMovement ) then
			_cancelledMovements.add( self.myCancelledMovement.HMS_VoyageMovement );
		endif;
		
		self.myCancelledMovement.HMS_VoyageMovement.getMyCancelledMovements( _cancelledMovements );
		
	endif;
	
	

epilog

end;</source>
        <Parameter name="_cancelledMovements" type="HMS_VoyageMovementArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyHMSVesselData" id="87abba1e-5a48-43d2-a5c5-f7afbb85d468">
        <source>getMyHMSVesselData() : HMS_VesselData;
//--------------------------------------------------
// Created:	24 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpVessel : CM_Vessel;
begin
	tmpVessel := self.getMyVessel();
	if tmpVessel &lt;&gt; null then
		return tmpVessel.myHMSVesselData;
	endif;
	return null;
end;</source>
        <ReturnType type="HMS_VesselData"/>
    </JadeMethod>
    <JadeMethod name="getMyHMSVoyageData" id="5a4d5bf2-883d-45ba-af95-5be4ac8b79d1">
        <source>getMyHMSVoyageData():HMS_VoyageData;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2018	jlgndl1	Initial creation	TFS 42043

				Cancelled movements that are not yet linked to a replacement don't have a 'myHMSVoyageData'....

*/

vars
	iter : Iterator;
	hmsTrx : HMS_Transaction;

begin
	if self.myHMSVoyageData &lt;&gt; null then
		return self.myHMSVoyageData;

	else
		iter := self.allHMSTransactions.createIterator;
		while iter.next( hmsTrx ) do
			if hmsTrx.myHMSVoyageData &lt;&gt; null then
				return hmsTrx.myHMSVoyageData;
			endif;
		endwhile;
		
	endif;
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="HMS_VoyageData"/>
    </JadeMethod>
