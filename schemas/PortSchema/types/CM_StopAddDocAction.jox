    <JadeMethod name="getDisplayStringForAttribute" id="e4d57067-e00e-4775-9eb7-908d8fdb1946">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	returnStr	: String;

begin

	if _attrName = ETRow_Details then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			//returnStr := app.getErrorString( TransType_184 ) &amp; ColonAndSpace &amp; self.stopDescription &amp; " (x" &amp; self.amount.String &amp; ")";
			//09 Nov 2016	NDL	TFS 2928
			returnStr := app.getErrorString( TransType_184 ) &amp; ColonAndSpace &amp; self.stopDescription &amp; " (x" &amp; self.amount.String &amp; ") - " &amp; self.parentDocId &amp; ", " &amp; self.documentId;
	
			returnStr := returnStr &amp; Period &amp; Space &amp; self.remarks;
			return returnStr;
		endif;
		
	elseif _attrName = ETRow_TransactionType then
		return inheritMethod(ETRow_Type, _short);
		
		
	elseif _attrName = ETRow_Amount then	//28 Sep 2016	NDL	TFS 2649 / 2001
		return amount.String;
		
	endif;	
		
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
