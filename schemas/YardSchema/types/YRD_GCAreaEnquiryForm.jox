    <JadeMethod name="doMnuHideSelectorPanel" id="ec6edac3-a9ae-4c1a-b495-a5040e247eef">
        <updating/>
        <source>doMnuHideSelectorPanel() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	saveWidth	: Real;

begin

	self.mnuHideSelectorPanel.enabled := true;

	if self.myTerminal.getConfig(GridAreaSelectorSet) = null then
		self.dkbSelectorPane.visible := false;
		self.mnuHideSelectorPanel.caption := self.MNU_SELECTOR_SHOW;
		self.mnuHideSelectorPanel.enabled := false;
		
	elseif self.mnuHideSelectorPanel.caption = self.MNU_SELECTOR_SHOW then
		// save and reset the width as if showing for thw first time
		// then Jade appears to get some odd width 
		saveWidth := self.dkbSelectorPane.width;
		self.dkbSelectorPane.visible := true;
		self.dkbSelectorPane.width := saveWidth;
		self.mnuHideSelectorPanel.caption := self.MNU_SELECTOR_HIDE;
		
	else
		self.dkbSelectorPane.visible := false;
		self.mnuHideSelectorPanel.caption := self.MNU_SELECTOR_SHOW;
		
	endif;
	
	self.xmlSelector := self.mnuHideSelectorPanel.caption = self.MNU_SELECTOR_SHOW;
	
	self.doShowHideSubMainCol();
	
	self.doResize();
	
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="doMnuYardAllocBuild" id="f6d6a46d-3b66-431a-babf-d53de8dd5332">
        <updating/>
        <source>doMnuYardAllocBuild(_menuItem : MenuItem input) updating;
/*
Purpose:			
Date				Who			Reason
SEPT 2013		CNWAB1		Initial creation
*/

vars
	index :Integer;
	mnuChild,mnuMaster,
	tmpMenu	: MenuItem;
	ta		: CM_TerminalArea;
	yalloc : CM_YardAllocation;
	include : Boolean;	//23 Jul 2020	NDL	TFS 49775
	hasAtLeastOne : Boolean; //23 Jul 2020	NDL	TFS 49775
	yc : CM_YardController; //23 Jul 2020	NDL	TFS 49775
	obj : Object; //23 Jul 2020	NDL	TFS 49775
begin

	_menuItem.visible := true;
	mnuMaster := _menuItem;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.userObject := null;
	mnuMaster.helpKeyword := "MAIN"; // DO NOT TRANSLATE

	// TFS 2734 CNWAB1
	if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuYardAllocAdjust.caption := app.getErrorString(GCEnqAllocationAdjust); // "&amp;New Allocation...";
		self.mnuYardAllocAdjust.visible := true;
		self.mnuYardAllocAdjust.enabled := true;
		self.mnuYardAllocAdjust.helpKeyword := "YAChild"; // DO NOT TRANSLATE
		self.mnuYardAllocAdjust.userObject := null;
		
		self.mnuYardAllocNew.caption := app.getErrorString(GCEnqAllocationNew); // "&amp;New Allocation...";
		self.mnuYardAllocNew.visible := true;
		self.mnuYardAllocNew.enabled := true;
		self.mnuYardAllocNew.helpKeyword := "YAChild"; // DO NOT TRANSLATE
		self.mnuYardAllocNew.userObject := null;

		self.mnuYardAllocRemove.caption := app.getErrorString(GCEnqAllocationRemove); // "&amp;Remove Allocation...";
		self.mnuYardAllocRemove.visible := false; // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; not showing as removing an LC means updating the YA Blocks as well, so not showing at the moment
		self.mnuYardAllocRemove.enabled := true;
		self.mnuYardAllocRemove.helpKeyword := "YAChild"; // DO NOT TRANSLATE
		self.mnuYardAllocRemove.userObject := null;
	endif;

	


	foreach index in 1 to 50 do
		tmpMenu := null;
		mnuChild := mnuMaster.getMenuItem(index);
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
	endforeach;
	
	ta := self.myCurrentTerminalArea;

	index := 1;
	foreach yalloc in ta.allYardAllocations where yalloc.includeInYardDisplays() do
	
		//23 Jul 2020	NDL	TFS 49775 - Don't show the allocations that don't include the locations we are looking at.
		include := false;
		foreach yc in yalloc.allYardControllers do
			if self.myCurrentDrawingController.allGridObjects.includes(yc) then
				include := true;
				break;
			endif;
		endforeach;
		if not include then
			continue;
		endif;
		
		mnuChild := mnuMaster.loadSubMenu(index);
		mnuChild.caption := yalloc.code &amp; "...";
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := "YAChild"; // DO NOT TRANSLATE
		mnuChild.userObject := yalloc;
		tmpMenu := mnuChild;
		index := index + 1;
	endforeach; 
	
	//23 Jul 2020	NDL	TFS 49775 - Don't allow adjustment if we have no allocations.
	foreach obj in myCurrentDrawingController.allSelectedObjects do
		if obj.isKindOf( CM_YardController ) then
			yc := obj.CM_YardController;
			if not yc.allYardAllocations.isEmpty then
				hasAtLeastOne := true;
				break;
			endif;
		endif;
	endforeach;
	if not hasAtLeastOne then
		self.mnuYardAllocAdjust.enabled := false;
	endif;
	
	// TFS 2734 CNWAB1
	if index = 1 
	and not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		mnuMaster.visible := false;
	endif;
end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNotesForLegend" id="81c2f5c4-c667-406e-b379-257c965a691a">
        <source>doNotesForLegend(_startNote : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	idx, numRows : Integer;
	theTable : Table;
begin
	theTable := self.frmColLegendTIs.myLegendTable;
	numRows := theTable.rows;
	foreach idx in 2 to numRows do
		anObject := theTable.accessRow(idx).itemObject;
		if anObject &lt;&gt; null then
			if _startNote then
				self.beginNotification(anObject, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			else
				self.endNotification(anObject, EVENT_CODE_COLOUR_CHANGE);
			endif;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_startNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNotesForLegendStartStop" id="17470834-3d85-43fe-9141-20d8abefebf7">
        <updating/>
        <source>doNotesForLegendStartStop(_theIndex : Integer; _ydc : YRD_GCRackDrawingController) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin

	self.doNotesForLegend(false);
	if (not self.frmColLegendTIs.displayCodesForMode(_ydc.viewMode, _ydc.myDrawingAttrController)) then
		// could not find any codes/colours in controller so display them all
		self.frmColLegendTIs.doChangeViewMode(_theIndex);
	endif;
	self.doNotesForLegend(true);

end;</source>
        <Parameter name="_theIndex" type="Integer"/>
        <Parameter name="_ydc" type="YRD_GCRackDrawingController"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="58729b83-1994-4c0c-862f-9eb52b013eee">
        <updating/>
        <source>doQuery(_viewMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	numDB : Integer;
	cdc : YRD_GCRackDrawingController;
	ydb : YRD_ContainerGridAreaDockBar;
	tmpScrollableFrame	: CMUI_ScrollableFrame;
	tmpController	: YRD_GCRackDrawingController;
	tmpDkbGridArea	: CMUI_GridAreaDockBar;
	breakOut : Boolean;
	aTA : Object;
	obj : Object;
	aTI : CM_TrackedItem;
begin

	self.dkbGridArea.visible := false;
	self.dkcGridArea.visible := true;
	self.tblGridAreaInfo.rows := 0;
	self.dkbGridArea.isForGCRacks := true;
	
	// PAR 26858
	ydb := self.allDockBars.first().YRD_ContainerGridAreaDockBar;

	if ydb = null then

		// NOTE. the create of YDB creates the frames etc.
		ydb := self.dkbGridArea.cloneSelf(true);
		self.allDockBars.add(ydb);

		self.addControl(ydb);
		ydb.parent := self.dkcGridArea;
		ydb.visible := true;
		ydb.postCreate();
		ydb.left := 1;
	endif;
	
	self.myDrawingFrame := ydb.myDrawingFrame; 
	self.myDrawingFrame.isEnquiry := true;
	
	self.myDrawingFrame.doAutoScrolling := true;
	cdc := ydb.myDrawingController.YRD_GCRackDrawingController;
	self.setMyCurrentDrawingController(cdc, true);
	cdc.showDrawingFrame(false);
	cdc.allSelectorTIs.clear(); // PAR 26858


	self.myDrawingFrame.changeBackColor(self.defYardBackColSelected);

	ydb.setScrolledCallbackMethod('handleGridAreaScrolledEvent');

	ydb.setHLabelDetails(0, false);
	ydb.setVLabelDetails(0, false);
	// when able add labels as virtual to CMUI_GridAreaDockBar and
	// make dkbGridArea.myScrollableFrame protected
	tmpScrollableFrame := ydb.myScrollableFrame;
	tmpScrollableFrame.labels := ScrollBars_Both;

	cdc.allSelectorTIs.clear;
	
	if self.mySelectorEnquiryController &lt;&gt; null then
		self.useSelector := true;
		
		foreach obj in self.allTIs do
			aTI := obj.CM_TrackedItem;
			if self.mySelectorEnquiryController.includesObject(aTI, breakOut, app.myPassport) then
			
				cdc.allSelectorTIs.add(aTI);
			endif;
		endforeach;
//		self.allTIs.copy(cdc.allSelectorTIs);
		cdc.mySelectorEnquiryController := self.mySelectorEnquiryController;
	endif;
	
	cdc.setFlip(self.xmlFlipH,self.xmlFlipV);
	cdc.setScale(self.xmlZoomFactor, true, true); //CMUI_GridDrawingController.ScaleFactor_2);
	cdc.moveMode := self.moveModeForm;
	cdc.onlySelectSelectorTIs := self.onlySelectSelectorTIs;
	
	cdc.init(self.myCurrentTerminalArea,self.allGridRows);
	self.viewForMode(_viewMode, false);
	cdc.setViewMode(_viewMode);
	
	//cnwjo3 par 25479.  Don't need this since it will be done in setDisplayMode
	//cdc.drawSelf(true); // ### &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;

	cdc.notableObjectsClear();
	cdc.notableObjectAdd(self.myCurrentTerminalArea);
	cdc.changeBackColor(self.defYardBackColSelected);
	ydb.cnEcResizeContents();

	self.myCurrentDrawingController.setScale(self.xmlZoomFactor, true, true);
	self.myDrawingFrame.myDragSelectFrame.visible := true;
	self.myDrawingFrame.myDragSelectFrame.zOrder(1);
	ydb.myScrollableFrame.myHLabels.height := 0;
	ydb.myScrollableFrame.myHLabels.backColor := Red;
	ydb.myScrollableFrame.myScrollingFrame.top := 0;
	ydb.myScrollableFrame.myTopLeftFillerFrame.visible := false;
	self.setDisplayMode(DISPLAY_MODE_ACTUAL);

end;</source>
        <Parameter name="_viewMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="da45d381-ea34-415b-8f99-8120e04020e2">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpController	: YRD_GCRackDrawingController;
	anObj : Object;
	tmpVM : Integer;
	wasYALOC : Boolean;
begin
	inheritMethod();
	tmpController := self.myCurrentDrawingController;
	
	tmpVM := tmpController.viewMode;
	
	if tmpVM &lt;&gt; 0 then
		tmpController.setViewMode(tmpVM);
	else
		tmpController.setViewMode(VIEW_VOYAGE);
	endif;
	tmpController.drawSelf(true);
	if wasYALOC then
		tmpController.setViewMode(VIEW_YARD_ALLOC);
	endif;
//		tmpController.getYardAllocationPoints(false); // draw on viewing frame
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="bd4451e1-c70a-4f31-b2fe-cd5b1da4c730">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	anObj : Object;
	cdb : YRD_ContainerGridAreaDockBar;
begin

	

	inheritMethod();
	
	self.frmSelectorPane.cnEcResizeContents;	//28 July 2011	NDL	Par 27890
	
	foreach anObj in self.allDockBars do
		cdb := anObj.YRD_ContainerGridAreaDockBar;
		cdb.cnEcResizeContents();
	endforeach;

	self.frmStatusLine.doResize();
	self.setLastColumnMaxWidth(self.tblGridAreaInfo);
	self.doResizeColumnWidths(self.tblGridAreaInfo, true);
	
	
	

end;</source>
    </JadeMethod>
