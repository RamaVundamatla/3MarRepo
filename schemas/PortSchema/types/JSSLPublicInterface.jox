// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myServiceObject.sendMsgWithParams(method.name, pCustomerName, pProductCode).Date;
end;</source>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <ReturnType type="Date"/>
