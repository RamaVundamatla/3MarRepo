    <JadeMethod name="checkForIllegalCharacters" id="5375ac0f-818a-491f-82ab-2220c0f6e43d">
        <source>checkForIllegalCharacters(pPhoneNumber:String; pErrorMessage:String io):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the phone number is free
//				of illegal characeters.
//
// Parameters:	None
//
// Returns:		True if the phone number is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentPos		: Integer;
	workString		: String;
	workChar		: Character;
	stringLength	: Integer;

begin
	stringLength		:=	pPhoneNumber.length;
	currentPos			:=	1;
	workString			:=	null;

	foreach currentPos in 1 to stringLength do
		workChar	:=	pPhoneNumber[currentPos:1].Character;
		
		if workChar.isAlpha = false
		and workChar.isNumeric = false
		and workChar.String &lt;&gt; " "
		then
			// Create a space delimited list of all illegal characters found.
			workString := workString &amp; " " &amp; workChar.String;
		endif;
	endforeach;

	if workString &lt;&gt; "" then
		pErrorMessage :=  "Error - Input contains illegal characters or illegal delimiters for a phone number. - '" &amp; workString &amp; " '.";
		return false;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pPhoneNumber" type="String"/>
        <Parameter name="pErrorMessage" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkForValidStdCodes" id="8d8692d0-bbf7-4699-befb-909fe2ff46fe">
        <source>checkForValidStdCodes(pPhoneNumber:String io; pErrorMessage:String io):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Check for valid STD codes.
//
// Parameters:	pPhoneNumber - The phone number to check and update if valid.
//				pErrorMessage - An error message if the STD code is invalid.
//
// Returns:		If the STD code is valid then the updated phone number will be
//				returned in the IO parameter and the method will return true.  If
//				the STD code is not valid, an error message will be returned in the
//				IO parameter and the method will return false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	updatedInputString	: String;
	warnings			: String;
	
begin
	updatedInputString	:=	pPhoneNumber;
	
    if updatedInputString[1:1] = "0" then
		if updatedInputString[2:1] = "0" then
	        pErrorMessage :=  "Error - '00' is not a valid STD code in NZ.";
			return false;
	 	endif;

		if updatedInputString[2:1] = "1" then
		    pErrorMessage :=  "Error - '01' is not a valid STD code in NZ.";
			return false;
		endif;

		if updatedInputString[2:1] = "2" then
			if updatedInputString[3:1] &lt;&gt; "1"
			and updatedInputString[3:1] &lt;&gt; "5"
			and updatedInputString[3:1] &lt;&gt; "6"
			and updatedInputString[3:1] &lt;&gt; "7"
			and updatedInputString[3:1] &lt;&gt; "9"
			then
			   	pErrorMessage :=  "Error - '021', '025', &amp; '026', '027' &amp; '029' are the only valid '02' STD codes in NZ.";
				return false;
			endif;

			if updatedInputString[3:1] = "6" then
	  	     	warnings := warnings &amp; " 026 is a pager number in NZ. ";
			endif;
		endif;

		if updatedInputString[2:1] = "5" and  updatedInputString[3:2] &lt;&gt; "08" then
			pErrorMessage :=  "Error - '0508' is the only valid '05' STD code in NZ.";
			return false;
		endif;

		if updatedInputString[2:1] = "8" and  updatedInputString[3:2] &lt;&gt; "00" then
			pErrorMessage :=  "Error - '0800' is the only valid '08' STD code in NZ.";
			return false;
		endif;
	endif;   

	pPhoneNumber	:=	updatedInputString.trimBlanks;
	pErrorMessage	:=	warnings.trimBlanks;
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pPhoneNumber" type="String" usage="io"/>
        <Parameter name="pErrorMessage" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkLengthOfNumber" id="8a9eb637-841d-4943-913e-43d55ae654b3">
        <source>checkLengthOfNumber(pPhoneNumber:String io; pErrorMessage:String io):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Ensure that the phone number is long enough, but not too long.
//
// Parameters:	pPhoneNumber - The phone number to check and update if valid.
//				pErrorMessage - An error message if the length is invalid.
//
// Returns:		If the length is valid then the updated phone number will be returned
//				in the IO parameter and the method will return true.  If the length
//				is not valid, an error message will be returned in the IO parameter
//				and the method will return false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	updatedInputString	: String;
	warnings			: String;
	
begin
	updatedInputString	:=	pPhoneNumber;
	
	if updatedInputString.length &lt; 9 then
		pErrorMessage :=  "Error - Phone number too short - Requires at least 9 digits in NZ.";
		return false;
	endif;

	if updatedInputString[1:2] &lt;&gt; "02"
	and updatedInputString[1:4] &lt;&gt; "0508"
	and updatedInputString[1:4] &lt;&gt; "0800"
	and updatedInputString[1:4] &lt;&gt; "0900"
	and updatedInputString.length &gt; 9
	then
	   	pErrorMessage	:=	"Error - Phone number too long - Maximum of 9 digits for a normal phone number in NZ.";
		return false;
	endif;

	// Truncate 0800, 0508 &amp; 0900 numbers.
	
	if updatedInputString[1:4] = "0508"
	or updatedInputString[1:4] = "0800"
	or updatedInputString[1:4] = "0900"
	then				// to 10 digits.
		if updatedInputString.length &gt; 10 then
			warnings			:=	warnings &amp; updatedInputString[1:4] &amp; " number truncated. ";
			updatedInputString	:=	updatedInputString[1:10];
		endif;

		if updatedInputString.length &lt; 10 then				// check for enough characters in 0800 etc.
			pErrorMessage	:=	"Error - Phone number too short - Requires at least 6 digits after the " &amp; updatedInputString[1:4] &amp; ".";
			return false;
		endif;
	endif;

	if updatedInputString[1:2] = "02"
	and updatedInputString.length &gt; 10
	then
		pErrorMessage :=  "Error - Cell Phone/Pager number too long - Maximum of 10 digits in NZ.";
		return false;
	endif;
    
	pPhoneNumber	:=	updatedInputString.trimBlanks;
	pErrorMessage	:=	warnings;
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pPhoneNumber" type="String" usage="io"/>
        <Parameter name="pErrorMessage" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="convertAlphaToNumeric" id="7cc10ac4-101c-4e37-923f-bf52bac117aa">
        <source>convertAlphaToNumeric(pPhoneNumber:String io; pErrorMessage:String io) protected;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Convert any Alpha phone numbers to numeric. (i.e. 0800 DIAL ZM ).
//
// Parameters:	pPhoneNumber - The phone number to check and update if valid.
//				pErrorMessage - An error message if the number is invalid.
//
// Returns:		If the number is valid then the updated phone number will be returned
//				in the IO parameter and the method will return true.  If the number
//				is not valid, an error message will be returned in the IO parameter
//				and the method will return false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	updatedInputString	: String;
	workString			: String;
	warnings			: String;
	
begin
	updatedInputString	:=	pPhoneNumber;
	workString			:=	updatedInputString;

	updatedInputString.replaceChar("A", "2");
	updatedInputString.replaceChar("B", "2");
	updatedInputString.replaceChar("C", "2");
	updatedInputString.replaceChar("D", "3");
	updatedInputString.replaceChar("E", "3");
	updatedInputString.replaceChar("F", "3");
	updatedInputString.replaceChar("G", "4");
	updatedInputString.replaceChar("H", "4");
	updatedInputString.replaceChar("I", "4");
	updatedInputString.replaceChar("J", "5");
	updatedInputString.replaceChar("K", "5");
	updatedInputString.replaceChar("L", "5");
	updatedInputString.replaceChar("M", "6");
	updatedInputString.replaceChar("N", "6");
	updatedInputString.replaceChar("O", "6");
	updatedInputString.replaceChar("P", "7");
	updatedInputString.replaceChar("Q", "1");
	updatedInputString.replaceChar("R", "7");
	updatedInputString.replaceChar("S", "7");
	updatedInputString.replaceChar("T", "8");
	updatedInputString.replaceChar("U", "8");
	updatedInputString.replaceChar("V", "8");
	updatedInputString.replaceChar("W", "9");
	updatedInputString.replaceChar("X", "9");
	updatedInputString.replaceChar("Y", "9");
	updatedInputString.replaceChar("Z", "1");		

	if updatedInputString &lt;&gt; workString then
		warnings := warnings &amp; "Alpha characters replaced with Numerics in input. ";
	endif;
	
	pPhoneNumber	:=	updatedInputString.trimBlanks;
	pErrorMessage	:=	warnings.trimBlanks;
end;</source>
        <access>protected</access>
        <Parameter name="pPhoneNumber" type="String" usage="io"/>
        <Parameter name="pErrorMessage" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getNZFormatted" id="1f9489be-75e2-4b7c-8493-79616ab0b671">
        <source>getNZFormatted():String;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Using the phoneNumber property as input, returns the phone number in
//				an appropriate phone number format for New Zealand. If not recognised
//				as a valid NZ phone number, just return the number as it was received.
//
// Parameters:	None
//
// Returns:		The formatted telephone number.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	inputString		: String;
	outputString	: String;
	errorMsg		: String;

begin
	inputString	:=	self.phoneNumber;

	if inputString.cnEcValidateNZPhoneNumber(errorMsg) = false then
		return inputString;
	endif;	

	if inputString.length = 9 and inputString[2:1] &lt;&gt; "2" then		// normal 2 digit Std code
		outputString[1:1]	:=	"(";			//  format (0n) 123 4567
		outputString[2:2]	:=	inputString[1:2];
		outputString[4:2]	:=	") "; 			
		outputString[6:3]	:=	inputString[3:3];
		outputString[9:1]	:=	" "; 			
		outputString[10:4]	:=	inputString[6:4];
	endif;	

	if inputString.length = 9 and inputString[2:1] = "2" then		// 6 digit cell phone or pager
		outputString[1:1]	:=	"(";			//  format (02n) 123 456
		outputString[2:3]	:=	inputString[1:3];
		outputString[5:2]	:=	") "; 			
		outputString[7:3]	:=	inputString[4:3];
		outputString[10:1]	:=	" "; 			
		outputString[11:3]	:=	inputString[7:3];
	endif;	 

	if inputString.length = 10 and inputString[2:1] = "2" then		// 7 digit cell phone or pager
		outputString[1:1]	:=	"(";			//  format (02n) 123 4567
		outputString[2:3]	:=	inputString[1:3];
		outputString[5:2]	:=	") "; 			
		outputString[7:3]	:=	inputString[4:3];
		outputString[10:1]	:=	" "; 			
		outputString[11:4]	:=	inputString[7:4];
	endif;	

	if inputString.length = 10 and inputString[2:1] &lt;&gt; "2" then		// 0508 or 0800 or 0900 phone number
		outputString[1:4]	:=	inputString[1:4];	//  format 0800 123 456
		outputString[5:1]	:=	" "; 			
		outputString[6:3]	:=	inputString[5:3];
		outputString[9:1]	:=	" "; 			
		outputString[10:3]	:=	inputString[8:3];
	endif;

	if outputString = "" then			// if nothing else just return the same 
		outputString	:=	inputString;
	endif;	

	return outputString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="removeAllSpaces" id="4a793302-dc42-4788-81e2-2b3878ae6c5b">
        <source>removeAllSpaces(pPhoneNumber:String io) protected;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Strip all spaces from the phone number.
//
// Parameters:	pPhoneNumber - The number to strip the spaces from.
//
// Returns:		pThe stripped number as an IO parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	updatedInputString	: String;
	currentPos			: Integer;
	workString			: String;
	stringLength		: Integer;
	
begin
	updatedInputString	:=	pPhoneNumber;
	currentPos			:=	1;
	workString			:=	null;

	while currentPos &lt;= updatedInputString.length do
		if updatedInputString[currentPos:1] &lt;&gt; " " then
			workString := workString &amp; updatedInputString[currentPos:1];	
		endif;
		currentPos := currentPos + 1;
	endwhile;
	
	pPhoneNumber	:=	updatedInputString;
end;</source>
        <access>protected</access>
        <Parameter name="pPhoneNumber" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="removePhonePrefixes" id="c24df32b-deeb-4514-9917-38d7c0d3f564">
        <source>removePhonePrefixes(pPhoneNumber:String io; pErrorMessage:String io) protected;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Check for string starting with 'Phone', 'ph' or 'fax' and remove.
//
// Parameters:	pPhoneNumber - The phone number to remove the prefixes from.
//				pErrorMessage - An error message if the number is invalid.
//
// Returns:		If the number is valid then the updated phone number will be returned
//				in the IO parameter and the method will return true.  If the number
//				is not valid, an error message will be returned in the IO parameter
//				and the method will return false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	updatedInputString	: String;
	workString			: String;
	warnings			: String;
	
begin
	updatedInputString	:=	pPhoneNumber;
	workString			:=	null;

	if updatedInputString[1:5] = "PHONE" then
		workString			:=	updatedInputString[6:updatedInputString.length - 5];
		updatedInputString	:=	workString;
		warnings			:=	warnings &amp; "'Phone' removed from input. ";	
	endif;
	
	if updatedInputString[1:2] = "PH" then
		workString			:=	updatedInputString[3:updatedInputString.length - 2];
		updatedInputString	:=	workString;
		warnings			:=	warnings &amp; "'Ph' removed from input. ";	
	endif;
	
	if updatedInputString[1:3] = "FAX" then
		workString			:=	updatedInputString[4:updatedInputString.length - 3];
		updatedInputString	:=	workString;
		warnings			:=	warnings &amp; "'Fax' removed from input. ";	
	endif;
	
	pPhoneNumber	:=	updatedInputString.trimBlanks;
	pErrorMessage	:=	warnings.trimBlanks;
end;</source>
        <access>protected</access>
        <Parameter name="pPhoneNumber" type="String" usage="io"/>
        <Parameter name="pErrorMessage" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="replaceDelimiters" id="68b495bf-003e-4b67-ba94-de759a9c6a16">
        <source>replaceDelimiters(pPhoneNumber:String io; pErrorMessage:String io) protected;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Replaces delimiters in the phone number.
//
// Parameters:	pPhoneNumber - The phone number to replace delimiters in.
//				pErrorMessage - An error message if the number is invalid.
//
// Returns:		If the number is valid then the updated phone number will be returned
//				in the IO parameter and the method will return true.  If the number
//				is not valid, an error message will be returned in the IO parameter
//				and the method will return false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	workString			: String;
	updatedInputString	: String;
	warnings			: String;
	
begin
	updatedInputString	:=	pPhoneNumber;
	
	// Replace Standard delimiters with spaces.

	updatedInputString.replaceChar("(", " ");
	updatedInputString.replaceChar(")", " ");

	workString	:=	updatedInputString;		// Set up for before and after check.

	// Replace non-Standard delimiters with spaces.

	updatedInputString.replaceChar("+", " ");
	updatedInputString.replaceChar("#", " ");
	updatedInputString.replaceChar("*", " ");
	updatedInputString.replaceChar("-", " ");
	updatedInputString.replaceChar("[", " ");
	updatedInputString.replaceChar("]", " ");
	updatedInputString.replaceChar("{", " ");
	updatedInputString.replaceChar("}", " ");
	updatedInputString.replaceChar("&lt;", " ");
	updatedInputString.replaceChar("&gt;", " ");
	updatedInputString.replaceChar(".", " ");
	updatedInputString.replaceChar(",", " ");

	if workString &lt;&gt; updatedInputString then
		warnings	:=	warnings &amp; "Non-standard delimiters removed from input. ";
	endif;
	
	pPhoneNumber	:=	updatedInputString.trimBlanks;
	pErrorMessage	:=	warnings.trimBlanks;
end;</source>
        <access>protected</access>
        <Parameter name="pPhoneNumber" type="String" usage="io"/>
        <Parameter name="pErrorMessage" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="5b13a9f6-125b-4bb0-b28a-9127bfb167ab">
        <updating/>
        <source>updateMe(pPhoneNumber:String) updating;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Updates the receiver's phone number.
//
// Parameters:	pPhoneNumber - The phone number.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.phoneNumber &lt;&gt; pPhoneNumber then
		self.phoneNumber	:=	pPhoneNumber;
	endif;
end;</source>
        <Parameter name="pPhoneNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForNZ" id="c0413440-01ca-4070-ba46-cc248afc392a">
        <updating/>
        <source>validateForNZ(pErrorMessage:String output):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Having converted any alpha in the input to it's numeric equivalent
//				if necessary and removed all delimiters check that the resultant
//				phone number seems reasonable for New Zealand. If the resultant
//				number seems O.K. update self with the resultant number, and return
//				true listing any Warnings for changes made in errorMessage.
//
//				If the resultant number seems to be in error, return false, putting
//				the reason in errorMessage and leaving the the original input in self.
//
// Parameters:	pErrorMessage (String) - Message describing any formatting errors.
//
// Returns:		True if the telephone number is valid for New Zealand, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/11/2001	cnwdad1		Added a check to report the phone number as valid if
//							it's null.
// --------------------------------------------------------------------------------
vars
      workChar:				Character;		// Work space for character checking
      updatedInputString:	String;			// Contains the copy of self that we manipulate 
      workString:			String;			// Work area
      warnings:				String;         // Holds the Warning messages if required
      currentPos:			Integer;

begin
	if self.phoneNumber = null then
		return true;
	endif;

	if self.myLocaleInfo.defaultCountryCode &lt;&gt; 64 then
		pErrorMessage	:=	"The computer's current Locale is not New Zealand.";
		return false;
	endif;
	
	updatedInputString	:=	self.phoneNumber.toUpper;

	self.replaceDelimiters(updatedInputString, warnings);

	if not self.checkForIllegalCharacters(updatedInputString, pErrorMessage) then
		return false;
	endif;

	self.removeAllSpaces(updatedInputString);
	self.removePhonePrefixes(updatedInputString, warnings);
	self.convertAlphaToNumeric(updatedInputString, pErrorMessage);

	if updatedInputString &lt;&gt; workString then
		warnings	:=	warnings &amp; "Alpha characters replaced with Numerics in input. ";
	endif;   

	// Ensure number starts with a zero

    if updatedInputString[1:1] &lt;&gt; "0" then
       pErrorMessage :=  "Error - Phone number must start with an STD code, i.e. start with a zero.";
       return false;
    endif;

	if not self.checkForValidStdCodes(updatedInputString, pErrorMessage) then
		return false;
	endif;

	if not self.checkLengthOfNumber(updatedInputString, pErrorMessage) then
		return false;
	endif;
	
	// Ensure first digit of local number not zero

	if updatedInputString[1:4] &lt;&gt; "0508"
	and updatedInputString[1:4] &lt;&gt; "0800"
	and updatedInputString[1:4] &lt;&gt; "0900"
	and updatedInputString[3:1] = "0"
	then
		pErrorMessage	:=	"Error - '0' invalid number imediately after the STD code in NZ phone number.";
		return false;
	endif;

	// Got through all the checking, return any warnings after updating self and end.

	self.phoneNumber	:=	updatedInputString;

	if warnings &lt;&gt; null then	
    	warnings		:=	"Warning: " &amp; warnings;
     	pErrorMessage	:=	warnings.trimBlanks;
    endif;

    return true;  							
end;</source>
        <Parameter name="pErrorMessage" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
