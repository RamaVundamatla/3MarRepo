    <JadeMethod name="checkAccelerator" id="3fde6db2-4de6-448e-996d-c167362cca9f">
        <source>checkAccelerator(_buttonObj: MOB_Button; _searchFor: Integer): Boolean protected;

vars
	charPos	: Integer;
	
begin
    if not _buttonObj.visible or _buttonObj.caption = null or _searchFor = 0 then
    	return false;
    else
    	charPos	:=	_buttonObj.caption.pos("&amp;",1);
    	return charPos &lt;&gt; null and charPos &lt; _buttonObj.caption.length and _buttonObj.caption[charPos+1:1].toUpper = _searchFor.Character;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_buttonObj" type="MOB_Button"/>
        <Parameter name="_searchFor" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="b88dedce-eb3a-403d-affd-acb5feeedf73">
        <updating/>
        <source>doResize() updating, protected;

constants
	Width = 308;
	Height = 150;
	Dummy = "Dummy";
vars
	
begin
	self.height:=frm_Main.top + Height  +  frmButtons.height +35;
	self.width:=Width;	
	self.frm_Main.height:=Height;


end;
</source>
        <access>protected</access>
