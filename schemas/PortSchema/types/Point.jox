<PrimType name="Point">
    <JadeMethod name="above" id="6afe1e80-7cce-45dc-b486-b7e57b6ff0c4">
        <source>above(point : Point) : Boolean;
// Return true if self is above point
begin
	return self.y &lt; point.y;
end;
</source>
        <Parameter name="point" type="Point"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="add" id="a912a12c-52f2-4965-a171-3f47d2a3ab69">
        <source>add(x, y: Integer) : Point;
// Add x and y and return a new point
vars
	newPoint: Point;
begin
	newPoint.setX(self.x + x);
	newPoint.setY(self.y + y);
	return newPoint;
end;
</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Point"/>
    </JadeMethod>
    <JadeMethod name="asStringJMT" id="9bb49d02-9f16-4a2a-9954-7eedc31ca438">
