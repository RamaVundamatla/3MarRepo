<Class name="CMEVT_NonOperationalEvent" id="4dc07d79-a18b-4400-8a8f-63a0cc3c0a48">
    <superclass name="CM_EventTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="myOperator" id="72069946-55ab-4767-9961-1cb51ec2454a">
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_Operator"/>
        <access>readonly</access>
        <Inverse name="CM_Operator::allEventTransactions"/>
    </ExplicitInverseRef>
    <JadeMethod name="hasTaskThatIsComplete" id="ff94b2d8-1a80-4d99-9cfd-bd4a4bc0c327">
        <source>hasTaskThatIsComplete(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2023  navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks

*/

vars
	taskDesc : CM_ToDoTaskDesc;
	task : CM_ToDoTask;
	myWodToDo : CM_WodToDo;
begin

	if self.myToDoTask = null then
		return false;
	endif;
	
	return self.myDebtor.allToDoTasksCompleted.includes(self.myToDoTask);
	
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromCMIF" id="ea826942-16b8-4a5e-9a32-6d60a6d11eac">
        <updating/>
        <source>setDetailsFromCMIF(_eventType: CM_EventType; _cmifEventTrx: CMIF_NonOperationalCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars
	wod				: CM_WorkOrderDtl;
	resourceUsage 	: CM_ResourceTypeUsageSet;
begin
	
	if _cmifEventTrx.allResourceUsages.isNotEmpty() &lt;&gt; null then
		create resourceUsage transient;
		_cmifEventTrx.allResourceUsages.copy(resourceUsage);
	endif;
	
	self.setMyDebtor(_cmifEventTrx.myDebtor);
	self.setToDoTask(_cmifEventTrx.myToDoTask);
	self.addResourcesFromProxys(resourceUsage);
	
	wod := _cmifEventTrx.myWorkOrderDetail;
	
	if wod = null then
		self.getWorkOrderDetail();
	endif;
	
	if wod &lt;&gt; null then
		self.setContractId(wod.contractId);
		self.setNoCharge(wod.getNoCharge());
	endif;
	
	inheritMethod(_eventType, _cmifEventTrx);

epilog
	delete resourceUsage;
end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_cmifEventTrx" type="CMIF_NonOperationalCtrl"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7ca1a31a-c3b3-4e38-88d0-9a5abee62878">
