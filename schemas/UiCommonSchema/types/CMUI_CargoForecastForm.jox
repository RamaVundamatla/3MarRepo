    <JadeMethod name="clearCmbData" id="4216c1ce-2959-4dfc-9abe-536a9d7bb592">
        <updating/>
        <source>clearCmbData()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2022	navak20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars

begin
	self.cmbMode.listIndex := self.cmbMode.findString(1, app.getErrorString(Discharge));
	self.cmbCargoType.text := null;
	self.cmbCommodity.text := null;
	self.cmbOperator.text := null;
	self.txtQuantity.text := null;
	self.txtCargoVolume.text := null;
	self.txtCargoWeight.text := null;
	self.btnSave.enabled := false;
	self.btnRemove.enabled := false;
	self.btnAudits.enabled := false;
	self.isNewBtnClicked := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbCargoType_click" id="44bd6a64-335f-481f-b7c2-0caae74a6bd9">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoType_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2022	navak20	Initial creation
06 June 2022    navds20  53728 EUP - Cargo Forecast Issues
*/

vars
	defaultedCargoType : CM_CargoType;
	weightMeasurement, volumeMeasurement : CM_MeasurementType;
begin
	defaultedCargoType := self.cmbCargoType.itemObject[self.cmbCargoType.listIndex].CM_CargoType;

	weightMeasurement := defaultedCargoType.getMeasurementTypeFor(Type_Weight, true);	//13.05.2022 navsrk20 53142
	volumeMeasurement := defaultedCargoType.getMeasurementTypeFor(Type_Volume, true);	//13.05.2022 navsrk20 53142
	self.txtCargoVolume.setValues('' &amp; Space &amp; volumeMeasurement.shortName);	//13.05.2022 navsrk20 53142
	self.txtCargoWeight.setValues('' &amp; Space &amp; weightMeasurement.shortName);	//13.05.2022 navsrk20 53142
    if defaultedCargoType &lt;&gt; null then
		if defaultedCargoType.allCommodities.size &gt; 0 then
			cmbCommodity.listCollection(defaultedCargoType.allCommodities, true, 0);
		else 
			cmbCommodity.clear;
		endif;
    else
        cmbCommodity.listCollection(app.myRoot.allCommodities, true, 0);
    endif;
epilog
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCargoType_displayEntry" id="18a48359-cc72-4567-9078-08339d43e231">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoType_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2022	navhl20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars
    cargo : CM_CargoType;
	str		  : String;
begin
	cargo := obj.CM_CargoType;
	
	if cargo.isNotAvailableForEntry then
		return null;
	endif;
	
	str := 	cargo.description;

	return str;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
