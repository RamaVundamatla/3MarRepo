    <JadeMethod name="doAdd" id="fc7f555f-9984-48ce-9754-d8f51d52acf0">
        <updating/>
        <source>doAdd() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2010	cnwer1	Initial creation

*/

vars
	form : YRD_SatDefinitionAdd;
	newName : String;
	isSystem : Boolean;
begin

	create form transient;
	form.setMyTAViewInterface(self.myTAViewInterface);
	form.showModal;
	if form.modalResult = IDOK then
		self.unloadForm;
	endif;
epilog
	delete form;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCopy" id="5c76407b-5878-4516-999d-87cb4affc2df">
        <updating/>
        <source>doCopy() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwer1	Initial creation

*/

vars
	form : YRD_SatDefinitionCopy;
	newName : String;
	isSystem : Boolean;
	selectedTAView : CM_TerminalAreaView;
begin

	selectedTAView:=self.lstTAViews.listObject.CM_TerminalAreaView;
	if selectedTAView = null then
		return;
	endif;
	create form transient;
	form.initializeSelf(self.myTAViewInterface,selectedTAView);
	form.showModal;
	if form.modalResult = IDOK then
		self.unloadForm;
	endif;
epilog
	delete form;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="6113b19b-1c75-41de-a25d-79e8a47066bc">
        <updating/>
        <source>doDelete() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2010	cnwer1	Initial creation
19 September 2011	cnwdap1	Clear myTAView reference
*/

vars
	taView : CM_TerminalAreaView;
begin

	if self.lstTAViews.listIndex &gt; 0 then
		taView:=self.lstTAViews.listObject.CM_TerminalAreaView;
	endif;

	if taView &lt;&gt; null then
		
		if app.msgBox(app.getErrorString1(Lit_Confirm_Delete, taView.name), app.getErrorString(Confirm_Delete), MsgBox_Yes_No) = MsgBox_Return_Yes then
			self.myTAViewInterface.deleteView(taView);
		else
			return;
		endif;
	endif;
	
	self.myTAView := null;		// PAR #27814
	self.loadTerminalViews();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEdit" id="b955e81c-ade9-4a85-aa18-a09dc25e1014">
        <updating/>
        <source>doEdit() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwer1	Initial creation

*/

vars
	selectedView : CM_TerminalAreaView;
begin
	
	selectedView:=self.lstTAViews.listObject.CM_TerminalAreaView;
