    <JadeMethod name="btnClose_click" id="c69f6dd4-7de1-4cf1-baf5-b452230c5c5f">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClose_click(btn: Button input) updating;

begin
	unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnExcludedInclud_click" id="f85577d5-17e2-4031-8d7c-64ad6b802535">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExcludedInclud_click(btn: Button input) updating;

vars
	object	: Object;
	myIndex	: Integer;
	changes	: Boolean;
begin
	foreach myIndex in 1 to lstForms_excluded.listCount do
		if lstForms_excluded.itemSelected[myIndex] then
			object := lstForms_excluded.itemObject[myIndex];
			
			if object &lt;&gt; null then
				changes := true;
				aAllExcludedForms.remove(object);
				aAllIncludedForms.add(object);
			endif;
		endif;
	endforeach;

	if changes then
		self.populateHelpLists();
		btnSaveChanges.enabled	:= true;
		btnGetForms.enabled		:= false;
	endif;
	
	self.setButtons(null);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnExcludedRemove_click" id="612bc22b-e8e5-4504-8b5b-a35a0436318c">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExcludedRemove_click(btn: Button input) updating;

vars
	object	: Object;
	myIndex	: Integer;
	changes	: Boolean;
begin
	foreach myIndex in 1 to lstForms_excluded.listCount do
		if lstForms_excluded.itemSelected[myIndex] then
			object := lstForms_excluded.itemObject[myIndex];
			if object &lt;&gt; null then
				changes := true;
				aAllExcludedForms.remove(object);
			endif;
		endif;
	endforeach;

	if changes then
		self.populateHelpLists();
		btnSaveChanges.enabled := true;
		btnGetForms.enabled := false;
	endif;
	
	self.setButtons(null);
