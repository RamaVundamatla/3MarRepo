    <JadeMethod name="validate" id="6571989a-2932-4cf0-aa45-7f31e2b7b4b1">
        <source>validate(_passport :CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     23 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/09/2009	cnscw5		ccms1061 - validation of rfid tag readers was only checking within one gate area
//							changed to check all gate areas and work correctly
// ---------------------------------------------------------------------------
vars
	gate				: CM_Gate;
	pxyUsage			: CM_GateAreaUsage;
	hasA, hasP, hasT	: Boolean;
	obj					: Object;
	
begin
	// Note: The raiseUnexpectedProgramError method is used where we expect the GUI to
	// prevent the error in question.
	gate	:= self.pxyGetRealObject;
	
	if self.name = null then
		app.raiseCMException (Gate_Error1, "Name", null);
	endif;
	
	if gate = null or self.name &lt;&gt; gate.name then
		// new name - check for duplicates
		if self.myTerminal.allGates[self.name] &lt;&gt; null then
			app.raiseCMException1 (Gate_Error2, self.name, "Name", null);
		endif;
	endif;
	
	if self.myDefaultInterchangeArea = null then
		app.raiseCMException (Gate_Error3, "Default Interchange Area", null);
	endif;
	
	if self.myTerminal = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Terminal must be set');
	endif;
	
	if not self.isInGate and not self.isOutGate then
		app.raiseCMException (Gate_Error4, "Entry/Exit", null);
	endif;
	
	if gate &lt;&gt; null then
		if gate.isTerminalDefault_IN and not self.isInGate then
			app.raiseCMException1 (Gate_Error12, self.name, "Entry", null);
		endif;
		if gate.isTerminalDefault_OUT and not self.isOutGate then
			app.raiseCMException1 (Gate_Error13, self.name, "Exit", null);
		endif;
	endif;
	
	if self.isInGate and self.allGateAreas_IN.isEmpty then
		app.raiseCMException (Gate_Error5, "Entry", null);
	elseif self.isInGate then
		pxyUsage := self.allGateAreas_IN.first;
		
		if pxyUsage = null or not pxyUsage.isAGate then
			app.raiseUnexpectedProgramError ('Gate', method.name, 'first inward gate area must be the a-gate');
		endif;
	endif;
	
	foreach pxyUsage in self.allGateAreas_IN do
		self.validateUpdate_GateUsage (pxyUsage, _passport);
		
		if pxyUsage.isAGate then
			if hasA then
				app.raiseUnexpectedProgramError ('Gate', method.name, 'cannot have &gt; 1 inward a-gate area');
			endif;
			hasA := true;
		endif;
		if pxyUsage.isTrouble then
			if hasT then
				app.raiseUnexpectedProgramError ('Gate', method.name, 'cannot have &gt; 1 inward  trouble gate area');
			endif;
			hasT := true;
		endif;
	endforeach;
	
	if self.isInGate and not hasA then
		app.raiseUnexpectedProgramError ('Gate', method.name, 'must have an inward a-gate area');
	endif;
	
	if not self.allGateAreas_OUT.isEmpty then
		pxyUsage := self.allGateAreas_OUT.first;
		
		if not pxyUsage.isPGate then
			app.raiseUnexpectedProgramError ('Gate', method.name, 'first outward gate area must be the p-gate');
		endif;
	endif;
	
	hasP := false;
	hasT := false;
	
	foreach pxyUsage in self.allGateAreas_OUT do
		if not self.hasGateArea_IN (pxyUsage.myGateArea) then
			// we have not already done validate for the inward gate area
			self.validateUpdate_GateUsage (pxyUsage, _passport);
		endif;
		
		if not pxyUsage.isPGate and not pxyUsage.isTrouble then
			app.raiseUnexpectedProgramError ('Gate', method.name, 'outward gate areas can only be p-gates or trouble');
		endif;
		if pxyUsage.isTrouble then
			if hasT then
				app.raiseUnexpectedProgramError ('Gate', method.name, 'cannot have &gt; 1 outward  trouble gate area');
			endif;
			hasT := true;
		endif;
	endforeach;
	
	// now check that an rfid tag reader has not been used more than once on the proxy.
	self.validateRFIDTagReaders;
	
	if self.pxyIsProxy then
		self.validateUpdate_DeleteWarnings (self.pxyGetRealObject.CM_Gate);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="539a560a-097c-4f65-9609-f7d3e3977363">
        <source>validateCreate(_passport :CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     12 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin	
	self.validate (_passport);
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="d255ee30-d0f3-40c9-879f-28eb915a10b5">
        <source>validateDelete(_passport :CM_Passport);
// ---------------------------------------------------------------------------
// Created:     12 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	usage		:CM_GateAreaUsage;
	gateArea	:CM_GateArea;
	icArea		:CM_InterchangeArea;
	whereUsed : String;
begin
	if not self.allInterchangeAreasDefault.isEmpty then
		// there are interchange areas that use this gate as their default out gate
		icArea := self.allInterchangeAreasDefault.first.CM_InterchangeArea;
		
		app.raiseCMException1 (Gate_Error6, icArea.id, "Gate", null);
	endif;

	foreach usage in self.allGateAreas_IN do
		gateArea := usage.myGateArea;
		
		if gateArea.isUsedByOtherGates (self) then
			continue;
		endif;
		
		gateArea.validateForDelete ();
		
		app.raiseCMWarning1 (Gate_Warning1, gateArea.id, "Gate Area", null, null);
	endforeach;	
	
	foreach usage in self.allGateAreas_OUT do
		gateArea := usage.myGateArea;
		
		if self.hasGateArea_IN (gateArea) then
			// we have already validated this one
			continue;
		endif;
		
		if gateArea.isUsedByOtherGates (self) then
			// used by other gates, won't get deleted
			continue;
		endif;
		
		gateArea.validateForDelete ();
		
		app.raiseCMWarning1 (Gate_Warning1, gateArea.id, "Gate Area", null, null);
	endforeach;	
	
	//10 Nov 2020	NDL	TFS 50279
	if not app.isGarbageCollectionProcess and self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.name, whereUsed, null, self);
	endif;
	

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateRFIDTagReaders" id="2a3f84dd-6dc4-4897-9f5f-11a561553206">
        <source>validateRFIDTagReaders():Boolean protected;
// ---------------------------------------------------------------------------
// Created:     11 September 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes 
//				Checks an rfid tag reader isnot used twice on the proxy 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gateAreas	:CM_ObjectSet;
	gateLanes	:CM_ObjectArray;
	obj			:Object;
	gateArea	:CM_GateArea;
	lane		:CM_GateAreaLaneController;
	readers		:CM_RFIDTagReaderByCodeDict;
	result		:Boolean;
begin
	self.raiseExceptionIfNotTransient (method);
	
	create gateAreas transient;
	create gateLanes transient;
	create readers transient;
	
	// get all the gate areas
	self.getAllGateAreas (gateAreas);
	
	foreach obj in gateAreas do
		gateArea := obj.CM_GateArea;
		// get lanes for the gate area
		gateArea.getAllLaneControllers (gateLanes);
	endforeach;
	
	// now gateLanes contains every lane for every gate area that is part of the gate proxy
	foreach obj in gateLanes do
		lane := obj.CM_GateAreaLaneController;
	
		if not lane.validateRFIDTagReaderUsage (readers) then
			// we got one that has ben used more than once
			result := false;
		endif;
	endforeach;
	return result;
epilog
	delete gateAreas;
	delete gateLanes;
	delete readers;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="8f0239ba-284b-44ef-be6b-966dec6612f9">
        <source>validateUpdate(_passport :CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     12 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	self.raiseExceptionIfNotProxy (method);
	
	self.validate (_passport);
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate_DeleteWarnings" id="178c02ba-d092-48ca-89e7-af27cf8ca67a">
        <source>validateUpdate_DeleteWarnings(_gate :CM_Gate) protected;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	coll			:CM_ObjectSet;
	usage, pxyUsage	:CM_GateAreaUsage;
	obj				:Object;
	gateArea		:CM_GateArea;
begin
	// Note: proxy is the receiver
	create coll transient;
	
	foreach usage in _gate.allGateAreas_IN do
		gateArea := usage.myGateArea;
		
		if gateArea.isUsedByOtherGates (_gate) then
			continue;
		endif;
		
		coll.addNoDuplicates (usage.myGateArea, false);
	endforeach;	
	
	foreach usage in _gate.allGateAreas_OUT do
		gateArea := usage.myGateArea;
		
		if gateArea.isUsedByOtherGates (_gate) then
			continue;
		endif;
		
		coll.addNoDuplicates (usage.myGateArea, false);
	endforeach;	
	
	// we now have the gate areas from the persistent obejct
	foreach pxyUsage in self.allGateAreas_IN do
		gateArea := pxyUsage.myGateArea.pxyGetRealObject;
		
		if gateArea = null then
			continue;
		endif;
		coll.removeIfPresent (gateArea);
	endforeach;	
	
	foreach pxyUsage in self.allGateAreas_OUT do
		gateArea := pxyUsage.myGateArea.pxyGetRealObject;
		
		if gateArea = null then
			continue;
		endif;
		coll.removeIfPresent (gateArea);
	endforeach;	
	
	// coll contains gate areas that are only used by the receiver
	// and won't be once updating is completed	
	// anything left in coll will be deleted so give the user a warning
	foreach obj in coll do 
		gateArea := obj.CM_GateArea;
		
		gateArea.validateForDelete;
		
		app.raiseCMWarning1 (Gate_Warning1, gateArea.id, "Gate Area", null, null);
	endforeach;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_gate" type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate_GateUsage" id="5f9686a5-e90f-47db-a619-542771d0e4b3">
        <source>validateUpdate_GateUsage(_proxy :CM_GateAreaUsage; _passport :CM_Passport input)protected;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gateArea, pxyGateArea	:CM_GateArea;
	usage					:CM_GateAreaUsage;
begin
	usage 		:= _proxy.pxyGetRealObject;
	
	if usage = null then
		_proxy.validateCreate (_passport);
	else
		_proxy.validateUpdate (_passport);
	endif;
	
	pxyGateArea := _proxy.myGateArea;
	gateArea	:= pxyGateArea.pxyGetRealObject;
	
	if gateArea = null then
		pxyGateArea.validateForCreate ();
	else
		pxyGateArea.validateForUpdate (gateArea);
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_GateAreaUsage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
