    <JadeMethod name="addTi" id="38dfcffc-175d-4e35-a958-348b31d8c32f">
        <updating/>
        <source>addTi(_ti : CM_Log; _doAccessCheck : Boolean) updating;

vars
	failedDAC	: CM_DataAccessController;
begin

	if _ti = null then
		return;
	endif;
	
	if _doAccessCheck then
		if (not _ti.canUserViewMe(null, app.myPassport, true, false, false, false, false, failedDAC)) then
			return;
		endif;
	endif;

	self.allTi.add(_ti);
	self.numberOfLogs := self.numberOfLogs + 1;
	self.volume := self.volume + _ti.getMyTotalVolume;
	self.weightTonnes := self.weightTonnes + _ti.weightTonnes;
	self.sedAverage := global.calcAverageSEDMean(_ti.logLength, self.volume, self.numberOfLogs).roundedTo(2);		

end;</source>
        <Parameter name="_ti" type="CM_Log"/>
        <Parameter name="_doAccessCheck" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyTis" id="029d6937-597f-4180-a2ff-325c6d2e085b">
        <updating/>
        <source>copyTis(_col : Collection;  _doAccessCheck : Boolean) updating;

vars
	obj	: Object;
	ti 	: CM_TrackedItem;
	iter	: Iterator;
begin

	iter := _col.createIterator;
	while iter.next(obj) do
		self.addTi(obj.CM_Log, _doAccessCheck);
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_col" type="Collection"/>
        <Parameter name="_doAccessCheck" type="Boolean"/>
    </JadeMethod>
