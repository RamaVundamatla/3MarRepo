<CollClass name="ObjectArray">
    <JadeMethod name="cnEcGetMemberClass" id="1d5242f1-c233-4605-978f-00ec7544d4c3">
        <source>cnEcGetMemberClass():Class;
// --------------------------------------------------------------------------------
// Created:		15 March 2001 by cnwdad1
//
// Purpose:		Returns the Class of the receiver's membership.
//
// Parameters:	None
//
// Returns:		The Class of the receiver's membership.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.cnEcGetMemberType().Class;
end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsPrimitiveArray" id="6a5d7f22-0ba9-4978-a89d-265b2910b5e8">
        <source>cnEcIsPrimitiveArray(): Boolean;
// --------------------------------------------------------------------------------
// Created:		03 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcSort" id="feb6d7c7-ad44-464e-add1-cb6cc8296b6e">
        <lockReceiver/>
        <updating/>
        <source>cnEcSort(pIsDescending: Boolean) updating, lockReceiver;
// --------------------------------------------------------------------------------
// Created:		13 March 2001 by cnwdad1
//
// Purpose:		Overrides the superclass implementation since the CnEcSorter only
//				handles primitive arrays.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <Parameter name="pIsDescending" type="Boolean"/>
    </JadeMethod>
</CollClass>
