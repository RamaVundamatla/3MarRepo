    <JadeMethod name="rel842_par36958" id="3044698d-bd0c-4827-b551-b496ba27f4da">
        <source>rel842_par36958();
/*

Date		Who		Reason
24 September 2015	cnwer1	Initial creation PAR

*/

vars
	newPerms : IntegerArray;
	pxySecurityRole,						
	terminalRole : CM_SecurityRole;
	termRole	: CM_SecurityRoleTerminalRoot;
	sysRole		: CM_SecurityRoleSystemRoot;
	permissionAgent	: CM_PermissionAgent;
	canUpdateInvoiceLines  : Boolean;
begin	
	app.initialize;
	
	
	create newPerms transient;
// TFS 39618  	newPerms.add(PmAdmInvoiceStatusPost);	//terminal based
// TFS 39618  	newPerms.add(PmAdmInvoiceStatusVoid);
// TFS 39618  	newPerms.add(PmAdmInvoiceLineStatusVoid);
// TFS 39618  	newPerms.add(PmAdmInvoiceLineStatusNormal);
	
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	/*beginTransaction;
		termRole.setPermissionsFromIntArray(newPerms,true);
		sysRole.setPermissionsFromIntArray(newPerms,false);
	commitTransaction;
*/

	create permissionAgent transient;
	foreach terminalRole in termRole.allChildRoles do
		canUpdateInvoiceLines:=terminalRole.canDo(PmAdmInvoicelistMaint);
		delete pxySecurityRole;
		beginLoad;
			pxySecurityRole := terminalRole.pxyCreateUpdateProxy();
		endLoad;
// TFS 39618 	pxySecurityRole.permissions[PmAdmInvoiceStatusPost]:=canUpdateInvoiceLines;
// TFS 39618 		pxySecurityRole.permissions[PmAdmInvoiceStatusVoid]:=canUpdateInvoiceLines;
// TFS 39618	pxySecurityRole.permissions[PmAdmInvoiceLineStatusVoid]:=canUpdateInvoiceLines;
// TFS 39618  		pxySecurityRole.permissions[PmAdmInvoiceLineStatusNormal]:=canUpdateInvoiceLines;
		app.myTrxUA.trxUpdateSecurityRole(pxySecurityRole, permissionAgent, app.myPassport);
	endforeach;

epilog
	delete newPerms;
	delete permissionAgent;
	delete pxySecurityRole;
end;</source>
    </JadeMethod>
    <JadeMethod name="rel842_par36965" id="b9d60581-45b5-4902-b55b-bc253b2a9234">
