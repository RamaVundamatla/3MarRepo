    <JadeMethod name="translateForm" id="c3102e9d-2009-4d02-970c-ccc1ca6e825c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 03 April 2024 10:08:57.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025186, locale);
	btnAdd.translateCaption(Xlat_0026805, locale);
	btnNew.translateCaption(Xlat_0026806, locale);
	btnRemove.translateCaption(Xlat_0026807, locale);
	btnUpdate.translateCaption(Xlat_0026808, locale);
	lblCustomsControl.translateCaption(Xlat_0026809, locale);
	lblObjectName.translateCaption(Xlat_0026810, locale);
	lblPositionNum.translateCaption(Xlat_0026811, locale);
	lblRefNum.translateCaption(Xlat_0026812, locale);
	lblRefType.translateCaption(Xlat_0026813, locale);
	lblRemPackages.translateCaption(Xlat_0026814, locale);
	lblRentPeriod.translateCaption(Xlat_0026815, locale);
	lblStatus.translateCaption(Xlat_0026816, locale);
	lblTotalPackages.translateCaption(Xlat_0026817, locale);
end;</source>
    </JadeMethod>
