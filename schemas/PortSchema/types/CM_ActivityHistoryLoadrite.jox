    <JadeMethod name="setForCreate" id="9194bcb3-9eab-4c66-bfe1-93c97433f1dc">
        <updating/>
        <source>setForCreate(_proxy: CM_ActivityHistoryLoadrite) updating;

// Created by cnwdvb1 on 03 October 2006

vars

begin
	inheritMethod(_proxy);
	self.driver			:= _proxy.driver;
	self.loadriteMsg	:= _proxy.loadriteMsg;
	self.machine		:= _proxy.machine;
	self.isSuccessful	:= _proxy.isSuccessful;

end;</source>
        <Parameter name="_proxy" type="CM_ActivityHistoryLoadrite"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="03ac9dea-16e6-45e5-a0e0-ae727140f6d4">
        <updating/>
        <source>setForUpdate(_proxy: CM_ActivityHistoryLoadrite) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2018	jlger1	Initial creation

*/

vars

begin
	inheritMethod(_proxy);
	self.driver			:= _proxy.driver;
	self.loadriteMsg	:= _proxy.loadriteMsg;
	self.machine		:= _proxy.machine;
	self.isSuccessful	:= _proxy.isSuccessful;
epilog

