<Class name="CMIF_DumpLoadAgent" id="b39d0975-4a63-49ae-83e5-370cd177454a">
    <superclass name="CMIF_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="PortLoading"/>
    <JadeMethod name="exportConfigConstants" id="94b45eca-8073-4a79-9aea-5df01632a0be">
        <source>exportConfigConstants(_file : File);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2025	naviv1	Initial creation

*/

vars
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;
	passport	: CM_Passport;
begin

	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory(ConfigConstants);
	constDict := category.getConstants();
	passport := app.myPassport;

	foreach const in constDict do
		_file.writeLine('&lt;'&amp;const.getName()&amp;"&gt;"&amp;app.myRoot.getConfig(const.getName()).String&amp;'&lt;/'&amp;const.getName()&amp;"&gt;");
	endforeach;
end;</source>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="exportObjects" id="d264e52e-6263-4c83-84db-e6731317dae6">
        <source>exportObjects(_class:Class; _exportReferences, _exportCollections:Boolean; _maxNumber:Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2025	naviv1	Initial creation

*/
vars
	obj: Object;
	passInArray: ObjectArray;
	file: File;
	cnt, numberToProcess: Integer;
	dirName,fileName: String;
	resultStr: String;
	objArray: ObjectArray;
	ifConfig: CMIF_Config;
	tmpTerminal: CM_Terminal;
	tmpOperator: CM_Operator;
	fileFolder: FileFolder;
begin
	write "Extracting "&amp;_class.name;	
	
	create objArray transient;
	if _class = CMIF_ConfigRoot then
		create ifConfig as _class;
		ifConfig.setFromPersistentData(app.myRoot);
		ifConfig.myObject := app.myRoot;
		objArray.add(ifConfig);
	elseif _class = CMIF_ConfigTerminal then
		foreach tmpTerminal in CM_Terminal.instances do
			create ifConfig as _class;
			ifConfig.setFromPersistentData(tmpTerminal);
			ifConfig.myObject := tmpTerminal;
			objArray.add(ifConfig);
		endforeach;
	elseif _class = CMIF_ConfigOperator then
		foreach tmpOperator in CM_Operator.instances do
			create ifConfig as _class;
			ifConfig.setFromPersistentData(tmpOperator);
			ifConfig.myObject := tmpOperator;
			objArray.add(ifConfig);
		endforeach;
	else
		_class.allInstances(objArray, 0, false);
	endif;
	numberToProcess := objArray.size;
	if numberToProcess = 0 then 
		return null;
	endif;
	dirName := "C:\temp\";
	create fileFolder transient;
	fileFolder.fileName := dirName;
	if not fileFolder.isAvailable then
		fileFolder.make();
	endif;
	if not fileFolder.isAvailable then
		write "cannot create folder requested";
	endif;
	fileName := dirName &amp; _class.name &amp; '.xml';
	
	create file transient;
	file.openOutput(fileName);
	
	create passInArray transient;
	app.writeLog('Started outputing instances of ' &amp; _class.name &amp; ' at ' &amp; app.actualTimeServer.String, LogINFO);
	cnt := 0;
	file.writeLine("&lt;" &amp; _class.name &amp; "_file&gt;");		
	if _class = Constant then
		self.exportConfigConstants(file);
	else	
		foreach obj in objArray do
			obj.exportPDXML(file, passInArray, _exportReferences, _exportCollections);
			cnt := cnt + 1;
			if _maxNumber &gt; 0 then
				if cnt &gt;= _maxNumber then
					break;
					app.writeLog('Processed ' &amp; cnt.String &amp; ' instances of ' &amp; _class.name &amp; ' at ' &amp; app.actualTimeServer.String, LogINFO);
				endif;
			endif;
		endforeach;
	endif;
	file.writeLine("&lt;/" &amp; _class.name &amp; "_file&gt;");			
	

    if file.isAvailable then
        file.close;
    endif;

   
    create file transient;
    file.openInput(fileName);
    if file.isAvailable then
        file.seek(0);
        resultStr := file.readString(file.fileLength).asStringRESTFUL;
        file.close;
    else
        resultStr := "Could not open file for reading";
    endif;
	
	app.writeLog('Finished outputing instances of ' &amp; _class.name &amp; ' at ' &amp; app.actualTimeServer.String, LogINFO);
	app.writeLog('Total instances of class ' &amp; _class.name &amp; ' output to file : ' &amp; numberToProcess.String, LogINFO);
	app.writeLog('Total objects output to file : ' &amp; cnt.String, LogINFO);
	
	return resultStr;
	
epilog

	delete file;
	delete passInArray;
	delete objArray;
end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_exportReferences" type="Boolean"/>
        <Parameter name="_exportCollections" type="Boolean"/>
        <Parameter name="_maxNumber" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="importObjects" id="863d4c6b-62d7-4500-bb3d-cfbef3ee45ce">
        <source>importObjects(_classNew: Class; _data: String; _phase: Integer; _deleteAll : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2025	naviv1	Initial creation

*/

vars
	attributeBlock,
	classTag,
	classTagEnd,
	classBlock,
	lineStr: String;
	newObj: Object;
	cnt: Integer;
	result: Boolean;	
	objArray: ObjectArray;
	object: Object;
	countError, countOK: Integer;
	classXMLName: String;
	methodName: String;
	agent : DEV_LoadAgent;
	xmlData : String;
	file: File;
	dirName,fileName: String;
	fileFolder: FileFolder;
begin
	result := false;
	classXMLName := _classNew.name;
	xmlData := _data.base64Decode().String;
	create agent transient;
   
	
	if classXMLName = null then
		app.raiseUnexpectedProgramError(classXMLName, method.name, 'Class name passed in is null');
		return;
	endif;
	write classXMLName&amp;" to "&amp;_classNew.name;
	
	if _classNew = null then
		app.raiseUnexpectedProgramError(_classNew.name, method.name, 'Class with name "'&amp;_classNew.name&amp;'" could not be found');
		return;
	endif;
	
	create objArray transient;
	if _phase = 0 then //only do this once per run
		_classNew.allInstances(objArray, 0, false);
		if _deleteAll then
			beginTransaction;
			foreach object in objArray do
				delete object;
			endforeach;
			commitTransaction;
		endif;
	endif;

	classTag := '&lt;'&amp;classXMLName&amp;'&gt;';
	classTagEnd := '&lt;/'&amp;classXMLName&amp;'&gt;';
	app.writeLog('Started importing instances of '&amp;classXMLName&amp;' at '&amp;app.actualTimeServer.String, LogINFO);
	countError := 0;
	countOK := 0;
	
	dirName := "C:\temp\";
	create fileFolder transient;
	fileFolder.fileName := dirName;
	if not fileFolder.isAvailable then
		fileFolder.make();
	endif;
	if not fileFolder.isAvailable then
		write "cannot create folder requested";
	endif;
	fileName := dirName &amp; _classNew.name &amp; '.xml';
	
	create file transient;
	file.openOutput(fileName);
	file.writeString(xmlData);
	file.close;

    file.openInput(fileName);
	file.seek(0);
	
	while not file.endOfFile do
		lineStr := file.readLine();
		
		if lineStr = classTag then
			classBlock := classTag&amp;CrLf;
		else
			classBlock := classBlock&amp;lineStr&amp;CrLf;
		endif;
//write lineStr&amp;' '&amp;classTagEnd;		
		if lineStr = classTagEnd then
			
			attributeBlock := classBlock.cnEcGetTagValueOfName(classXMLName&amp;'Attributes');
			
			cnt := cnt + 1;
			create newObj as _classNew transient;
			newObj.importPLXML(classXMLName, classBlock);
			if _classNew.name[1:3] = "CM_" then
				methodName := "load"&amp;_classNew.name[4:_classNew.name.length];
			elseif _classNew.name[1:4] = "HMS_" then
				methodName := "load"&amp;_classNew.name[5:_classNew.name.length];
			elseif _classNew.name[1:5] = "CMIF_" then
				methodName := "load"&amp;_classNew.name[6:_classNew.name.length];
			else
				methodName := "loadObject";
			endif;
			result := agent.sendMsgWithParams(methodName, newObj).Boolean;
			if result then
				countOK := countOK + 1;
			else
				countError := countError + 1;
			endif;
			if cnt mod 200 = 0 then
				app.writeLog('Imported '&amp;cnt.String&amp;' instances of '&amp;_classNew.name&amp;' at '&amp;app.actualTimeServer.String, LogINFO);
			endif;
		endif;
	endwhile;
	file.close;
	
	app.writeLog('Finished importing instances of '&amp;_classNew.name&amp;' at '&amp;app.actualTimeServer.String, LogINFO);
	app.writeLog('Total instances of class '&amp;_classNew.name&amp;' input from file : '&amp;cnt.String, LogINFO);
	app.writeLog('  '&amp;_classNew.name &amp;' OK count='&amp;countOK.String&amp;' Error count='&amp;countError.String, LogINFO);
	write _classNew.name &amp;' OK count='&amp;countOK.String&amp;' Error count='&amp;countError.String;
	if countError &gt; 0 then
		write "***************************************************";
	endif;
epilog
	abortTransaction;
	delete file;
	delete objArray;
	delete agent;	
end;</source>
        <Parameter name="_classNew" type="Class"/>
        <Parameter name="_data" type="String"/>
        <Parameter name="_phase" type="Integer"/>
        <Parameter name="_deleteAll" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="splitLines" id="5e4cd73e-1a19-4453-9890-98f628dde289">
        <source>splitLines(str : String) : StringArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2025	naviv1	Initial creation

*/

vars
    lines : StringArray;
    currLine, ch : String;
    i : Integer;
begin
    create lines transient;
    currLine := "";
    i := 1;

    while i &lt;= str.length do
        ch := str[i:i];

        if ch = Cr then
            // CR found: check if next char is LF (CRLF)
            if i &lt; str.length and str[i+1:i+1] = Lf then
                i := i + 1;  // skip LF in CRLF
            endif;
            lines.add(currLine);
            currLine := "";
        elseif ch = Lf then
            // LF-only newline
            lines.add(currLine);
            currLine := "";
        else
            currLine := currLine &amp; ch;
        endif;

        i := i + 1;
    endwhile;

    // add last line if any (like readLine)
    if currLine &lt;&gt; "" or str.endsWith(Cr) or str.endsWith(Lf) then
        lines.add(currLine);
    endif;

    return lines;
end;</source>
        <Parameter name="str" type="String"/>
        <ReturnType type="StringArray"/>
    </JadeMethod>
</Class>
