    <JadeMethod name="doTblDataContextMenu" id="7dc5ca06-8bea-450b-9ff2-86465babce6e">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars
	x1, y1	: Real;
	hasBank	: Boolean;
	hasInvoices	: Boolean;
	obj : Object;
	cloneCount : Integer;
	clonedItem : MenuItem;
	snapshotData : CM_SnapshotData;
	dos			: CM_DynamicObject_Snapshot;
begin

	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	

	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;	
	self.mnuDelSnapShot.visible := not self.tblData.allSelectedObjects.isEmpty;
	
	snapshotData := self.tblData.accessRow(self.tblData.row).itemObject.CM_SnapshotData;
	self.mnuShowSnapShot.userObject := snapshotData;
	self.mnuShowSnapShot.visible := false;
	self.mnuSummarise2.visible := false;
	if snapshotData &lt;&gt; null then
		if snapshotData.myOutputFormat_SS &lt;&gt; null and
		   snapshotData.myOutputFormat_SS.myBankToCharge &lt;&gt; null then
			hasBank := true;
			foreach dos in snapshotData.allSnapshotData do
				if dos.allInvoiceLines.size &gt; 0 then
					hasInvoices := true;
					break;
				endif;
			endforeach;
		endif;
		self.mnuShowSnapShot.visible := true;
		self.mnuSummarise2.visible := true;
		self.mnuCharge.visible := hasBank and app.getMyUser().canDo(self.myTerminal, PmAdmInvoiceSSGenMaint);
		self.mnuResync.visible := hasBank and app.getMyUser().canDo(self.myTerminal, PmAdmInvoiceSSGenMaint); 
		// remove these two following lines once permissions reset has been run
		self.mnuCharge.visible := hasBank;
		self.mnuResync.visible := hasBank;
		self.mnuInvoiceLines.visible := hasInvoices;
	endif;
	
	cloneCount := 1;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuInspectObject, false, cloneCount);
	cloneCount := 2;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuColumnOrganiser, false, cloneCount);
	cloneCount := 3;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuDeleteSep2, false, cloneCount);
	cloneCount := 4;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuDelSnapShot, false, cloneCount);
	cloneCount := 5;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuDeleteSep, false, cloneCount);
	cloneCount := 6;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuResync, false, cloneCount);
	cloneCount := 7;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuInvoiceLines, false, cloneCount);
	cloneCount := 8;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuCharge, false, cloneCount);
	cloneCount := 9;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuSummarise2, false, cloneCount);
	cloneCount := 10;
	clonedItem := self.zCloneMenu(self.mnuCloneItem, self.mnuShowSnapShot, false, cloneCount);
	
	self.popupMenu(mnuLocalContext, x1.Integer, y1.Integer);

	return false;

epilog

end;

</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
