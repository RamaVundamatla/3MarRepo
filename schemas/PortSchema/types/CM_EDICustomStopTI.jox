    <JadeMethod name="setStatus" id="d3ab7af5-b3ce-49e0-becb-23803a0c8e09">
        <updating/>
        <source>setStatus(_newStatus: Integer) updating;
//----------------------------------------------------------------
//	Created:	10 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	eventType	: Integer;
	terminal	: CM_Terminal;
begin	

	inheritMethod(_newStatus);

	if _newStatus &lt;&gt; CM_EDIFile.EDI_STATUS_UNPROCESSED then
		if _newStatus = CM_EDIFile.EDI_STATUS_DBLOADED then
			//remove from unprocessed
			self.myUnprocEDIData := null;
		endif;	
		terminal := self.getMyTerminal();
		if terminal &lt;&gt; null then
			terminal.causeEvent(terminal.getTerminalEvent(EVENT_EDI_EDITI_UPDATE), false, self);
		endif;
	else
		if self.myUnprocEDIData = null then
			self.myUnprocEDIData := self.myEDIData.CM_EDIDataCustomStop;
		endif;
	endif;
	
end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
