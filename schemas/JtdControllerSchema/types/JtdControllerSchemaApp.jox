    <JadeMethod name="getInstanceId" id="dffdf9bc-267a-4d84-a19d-897fb11532bc">
        <source>getInstanceId(o:Object):Integer;

vars
	s:String;
	posn,i:Integer;
begin
	posn:=1;
	s:=getOidStringForObject(o);
	posn:=s.reversePos(".")+1;
	return s[posn:end].Integer;
end;</source>
        <Parameter name="o" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getJadeVersionNumbers" id="57e55deb-c244-4d0b-847b-a4e28b614826">
        <source>getJadeVersionNumbers(verRelease, verMajor, verMinor : Integer output);

vars
	len, dotPos1, dotPos2 : Integer;
	s : String;
	
begin
	verRelease := 0;
	verMajor := 0;
	verMinor := 0;
	
	s := self.getSystemVersion; // from RootSchema::Application

	len := s.length;
	
	if len &lt; 1 then
		return;
	endif;

	dotPos1 := s.pos('.', 1);
	
	if dotPos1 &lt; 2 or dotPos1 &gt; len then
		return;
	endif;

	verRelease := s[1 : dotPos1 - 1].Integer;

	if dotPos1 = len then
		return;
	endif;
	
	dotPos2 := s.pos('.', dotPos1 + 1);
	
	if dotPos2 &lt; (dotPos1 + 2) or dotPos2 &gt; len then
		return;
	endif;
	
	verMajor := s[dotPos1 + 1 : (dotPos2 - dotPos1) - 1].Integer;
	
	if dotPos2 = len then
		return;
	endif;
	
	verMinor := s[dotPos2 + 1 : end].Integer;
end;</source>
        <Parameter name="verRelease" type="Integer" usage="output"/>
        <Parameter name="verMajor" type="Integer" usage="output"/>
        <Parameter name="verMinor" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getUserCmdLine" id="89086c1e-a51e-4d8a-9a97-80126b7b1ee6">
        <updating/>
        <source>getUserCmdLine():String updating;

vars
	s,t:String;
	i,j:Integer;
begin
	if app.isUnicode then
		s:=(call getCommandLineW);
	else
		s:=(call getCommandLine);
	endif;
	logMessage("&lt;"&amp;s&amp;"&gt;");
	i:=s.toLower.pos(" endjade ",1);
	if i=0 then return null; endif;  // No endJade token
	return s[i+8:end].trimBlanks;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVersionString" id="c5505712-a072-454e-abd7-6986a8591f52">
        <source>getVersionString() : String;

begin
	return VersionMajor.String &amp; '.' &amp; VersionMinor.String &amp; '.' &amp; VersionPatch.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initController" id="35a4d06a-cf4d-4716-816d-c18af7340059">
        <updating/>
        <source>initController() updating;

begin
	if getProfileString(getIniFileNameAppServer,"JBL","TradeQueues","0").Integer &gt; 0 then
		app.startApplication("TradeEmSchema", "StockTicker");
	endif;
	create self.mySession transient;
end;</source>
    </JadeMethod>
