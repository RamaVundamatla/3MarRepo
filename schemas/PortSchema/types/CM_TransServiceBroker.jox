    <JadeMethod name="copyFrom" id="4627a5bd-744c-4feb-9ce8-d73d30276b2e">
        <updating/>
        <source>copyFrom(_map: CM_TransServiceBroker; _tranType : CM_TransactionType; _parent : CM_CommodityMap) updating;
// 32311 set up self from the parameter plus the new transaction type, copy all of the parameter map children under self.
vars
	resourceBroker	: CM_TransResourceServiceBroker;
	newChild		: CM_TransResourceServiceBroker;
	newQuantityMap	: CM_QuantityMap;
	debtorMap		: CM_DebtorMap;
	newDebtorMap	: CM_DebtorMap;
begin
	self.myTransactionType := _tranType;
	if _tranType &lt;&gt; null then
		self.className := _tranType.classNameToCreate;
	endif;
	if _parent = null then
		self.commodityMap := _map.commodityMap;
	else
		self.commodityMap := _parent;
	endif;
	create newQuantityMap persistent;
	newQuantityMap.copyFrom(_map.myChildQuantityMap, self);
	foreach resourceBroker in _map.allResourceBrokers do
		create newChild persistent;
		newChild.setResourceTypeAndBroker(resourceBroker.myResourceType, self);
		newChild.setProxyTSB(resourceBroker.className, self.commodityMap, resourceBroker.myTransactionType);		// 33959 populate the rest of the instance
		create newQuantityMap persistent;
		newQuantityMap.copyFrom(resourceBroker.myChildQuantityMap, newChild);
	endforeach;
	
	foreach debtorMap in _map.allDebtorMapsByDebtor do
		create newDebtorMap persistent;
		newDebtorMap.copyFrom(debtorMap, debtorMap.myDebtorNode, debtorMap.myDebtorType, self);
	endforeach;
end;
</source>
        <Parameter name="_map" type="CM_TransServiceBroker"/>
        <Parameter name="_tranType" type="CM_TransactionType"/>
        <Parameter name="_parent" type="CM_CommodityMap"/>
    </JadeMethod>
    <JadeMethod name="getAllPaths" id="18bae58e-325d-4dea-8114-33ccec351dbf">
        <source>getAllPaths(_child : CM_FinancialObject; _paths : HugeStringArray input; _items : ObjectArray input);
// 32311 return the path text and tran map item for each tran map entry, other than the entered one in _child, at the same level
vars
	debtorMap	: CM_DebtorMap;
begin
	if _child.isKindOf(CM_TransServiceBroker) then
		_paths.add(self.getPath());
		_items.add(self);
		return;
	endif;

	foreach debtorMap in self.allDebtorMapsByDebtor do
		debtorMap.getAllPaths(_child, _paths, _items);
	endforeach;

end;</source>
        <Parameter name="_child" type="CM_FinancialObject"/>
        <Parameter name="_paths" type="HugeStringArray" usage="input"/>
        <Parameter name="_items" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllPaths2" id="2e2b5bc1-8c9a-48eb-b33b-c42ae650546c">
