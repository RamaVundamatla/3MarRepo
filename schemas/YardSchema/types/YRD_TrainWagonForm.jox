Return Value:		

Date		Who		Reason
19 March 2024	navpw1	Initial creation TFS: 62857 (62858)

*/

vars
	isRetroMode	: Boolean;
	ts			: TimeStamp;
	
begin
	isRetroMode := self.btnRetrospective.value;
	
	if isRetroMode then
		self.frmRetroDt.width := 271;
		self.doResize();
	else
		self.frmRetroDt.width := 10;
		self.doResize();
	endif;
	self.frmRetroDt.visible := isRetroMode;
	self.txtRetroDate.setDate(ts.date);
	self.txtRetroTime.setTime(ts.time);
	
end;</source>
