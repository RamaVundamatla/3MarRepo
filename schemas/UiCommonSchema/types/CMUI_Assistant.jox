    <JadeMethod name="showEventEnquiry" id="89fd33f5-fa16-4006-8302-5680235a396b">
        <source>showEventEnquiry(_masterMenuAction : CMUI_MenuAction);
/*
----------   ----------  --------------------------------------------------
Created:	19 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	frm			: CMUI_EventEnquiryForm;
	pic			: CMUI_ToolbarPicture;
	mainForm	: CMUI_SuperAppForm2;
begin
	if app.name &lt;&gt; JMTerminal then
		return;
	endif;
	
	mainForm := app.mainForm.CMUI_SuperAppForm2;
	
	frm := app.getForm(CMUI_EventEnquiryForm.name).CMUI_EventEnquiryForm;
	if frm = null then
		frm := app.loadForm(CMUI_EventEnquiryForm, CMUI_Assistant, false, false, false, null, _masterMenuAction).CMUI_EventEnquiryForm;
		if frm = null then
			return;
		endif;
	endif;
	
	frm.show();

end;





</source>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showEventEnquiryQuickSearch" id="74072426-7e68-4de7-b3d8-6251603b6dd9">
        <source>showEventEnquiryQuickSearch(_minutesPrevious : Integer; _masterMenuAction : CMUI_MenuAction);
/*
----------   ----------  --------------------------------------------------
Created:	19 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	frm			: CMUI_EventEnquiryForm;
	pic			: CMUI_ToolbarPicture;
	mainForm	: CMUI_SuperAppForm2;
begin
	if app.name &lt;&gt; JMTerminal then
		return;
	endif;
	
	mainForm := app.mainForm.CMUI_SuperAppForm2;
	
	pic := mainForm.btnEventAlarm.myToolbarButton.getMyPicture();
	pic.picture := mainForm.picEventOff.picture;
	mainForm.btnEventAlarm.visible := false;
	mainForm.endTimer(CMUI_SuperAppForm2.TIMER_EVENTALARM);
	
	frm := app.getForm(CMUI_EventEnquiryForm.name).CMUI_EventEnquiryForm;
	if frm = null then
		frm := app.loadForm(CMUI_EventEnquiryForm, CMUI_Assistant, false, false, false, null, _masterMenuAction).CMUI_EventEnquiryForm;
		if frm = null then
			return;
		endif;
	endif;
	
	frm.showForQuickSearch(_minutesPrevious);

end;





</source>
        <Parameter name="_minutesPrevious" type="Integer"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
