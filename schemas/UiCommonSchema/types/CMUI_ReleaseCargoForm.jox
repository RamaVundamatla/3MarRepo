    <JadeMethod name="txtCargoID_hasGotFocus" id="a4512655-9d59-44bd-b96e-275f6af91d6d">
        <controlMethod name="CMUI_FieldFrame::hasGotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoID_hasGotFocus(_fieldFrame: CMUI_FieldFrame input) updating;
// -----------------------------------------------------------------------------
// Created:		07 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 04/09/2013	cnwdap1		PAR #32379 Make Cargo ID list box wider to show break bulk info
// 13/09/2103	cnwdap1		PAR #32487 If Cargo ID box is on the right-hand side of the screen,
//							move it to the left so the extra details still have room to show
// -----------------------------------------------------------------------------

vars
	ti : CM_TrackedItem;
	displayRows : Integer;
	tmpHeight, tmpWidth : Real;
	tmpX, tmpY : Real;

begin
	if self.lstCargoIDvalues.allSelectedObjects.isEmpty() and
	   self.txtCargoIDvalue.text.trimBlanks() &lt;&gt; null then
	//	return;
	endif;
	
	if self.myReserveDetail &lt;&gt; self.lstCargoIDvalues.userObject then
		self.lstCargoIDvalues.userObject := self.myReserveDetail;
	endif;

	self.lstCargoIDvalues.height := 150;
	self.lstCargoIDvalues.displayCollection(self.allSearchTIs, false, Table.DisplayCollection_Forward, null);
	
	if self.lstCargoIDvalues.rows = 0 then
		return;
	endif;
	
	// adjust height of list table and place it under the textbox
	
	tmpX := self.txtCargoIDvalue.getFormLeft;
	tmpY := self.txtCargoIDvalue.getFormTop + self.txtCargoIDvalue.height;
	tmpWidth := self.txtCargoIDvalue.width;  //self.defaultControlWidth;
	displayRows := self.lstCargoIDvalues.rows.min(6);
	tmpHeight := displayRows * self.lstCargoIDvalues.rowHeight[1] + 10;
	
	self.lblCargoIDfiller.backColor := self.txtCargoID.parent.backColor;
	self.lblCargoIDfiller.move(tmpX, tmpY, self.defaultControlWidth, tmpHeight + 5);
	
	self.lblCargoIDfiller.visible := true;
	self.lblCargoIDfiller.parent := self;
	
	if tmpX &gt; self.clientWidth / 2 then											// PAR #32487
		tmpX := tmpX - 80;														// PAR #32487
	endif;																		// PAR #32487
	//self.lstCargoIDvalues.move(tmpX, tmpY, tmpWidth, tmpHeight);				// PAR #32379
	self.lstCargoIDvalues.move(tmpX, tmpY, tmpWidth + 80, tmpHeight);			// PAR #32379
	self.lstCargoIDvalues.visible := true;
	self.lstCargoIDvalues.parent := self;

	self.txtCargoIDvalue.text := null;
	
	if not self.lstCargoIDvalues.allSelectedObjects.isEmpty() then
		self.lstCargoIDvalues.setFocus();
	endif;
	
epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoID_hasLostFocus" id="9f7b1584-821a-4eda-88ef-6a3739c2207e">
        <controlMethod name="CMUI_FieldFrame::hasLostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoID_hasLostFocus(_fieldFrame: CMUI_FieldFrame input) updating;
// -----------------------------------------------------------------------------
// Created:		07 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	str 	: String;
	ti		: CM_TrackedItem;

begin
	if not self.lstCargoIDvalues.visible then
		return;
	endif;
	
	// trigger container id change method for first selected container
	
	ti := self.lstCargoIDvalues.allSelectedObjects.first.CM_TrackedItem;
	if ti = null then
		self.onContainerIdChange(null, null);
	else
		//self.onContainerIdChange(ti.id, null);
		self.onContainerIdChange(ti.id, ti);//cnwas3 par 21204
	endif;
	
	// get codes from list box, display in text box and disappear the list box
	//epr par 32445 17/10/13
	if self.lstCargoIDvalues.allSelectedObjects.size = 1 and ti.canSplitTotalQuantity then
		str:=ti.id  &amp; " " &amp; ti.getPrimaryLocationId(REAL_MODE) ;
	else
		
		str := self.lstCargoIDvalues.getSelectedString(CM_TrackedItem::id.name);
	endif;		
	
	str := self.truncateDisplayString(str, 22);
	self.txtCargoIDvalue.text := str;

	self.lstCargoIDvalues.visible := false;
	self.lblCargoIDfiller.visible := false;
	self.lstCargoIDvalues.parent := _fieldFrame;
	self.lblCargoIDfiller.parent := _fieldFrame;
	
	//+cnwml2 PAR23874
	if self.lstCargoIDvalues.allSelectedObjects.size &gt; 0 then
		self.cmbType.enabled := false;
	else
		self.cmbType.enabled := true;
	endif;

epilog

end;</source>
        <Parameter name="_fieldFrame" type="CMUI_FieldFrame" usage="input"/>
    </JadeMethod>
