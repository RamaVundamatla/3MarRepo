    <JadeMethod name="setTrackedItem" id="d7eb1a76-bde6-418a-b3b6-91f3b9042a41">
        <updating/>
        <source>setTrackedItem(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     26 February 2001 by cnwrs2
//
// Purpose: 	Tracked Item is now read only. Therefore you must use this method to set it.    
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	7/6/01			AA		Handle the release request property in one place
// 21/09/2015	cnwma1      PAR #36473 Consignee appears to be cleared from cargo details
// ---------------------------------------------------------------------------
vars
	invalid : Boolean;
	str : String;
begin
	on Exception do app.handleDeletedObject(exception, _ti, invalid);
	str := _ti.id;
	if invalid then
		return;
	endif;
	self.trackedItem := _ti;
	if self.myOriginatingBulkRelease = null then   // 21/09/2015 cnwma1 PAR #36473
		if self.trackedItem &lt;&gt; null then
			if self.consignee = null then
				self.consignee :=_ti.consignee;
			endif;
		endif;
	endif;

	if _ti &lt;&gt; null and _ti.canMergeBreakBulk then   // PAR 32380
		return;
	endif;
	//jlier1 TFS 59732 6/9/23
	if self.pxyIsProxy then
		return;
	endif;
	if (not self.isReceipt) then
		if self.bulkRelease = null then		//dont set for bulk release requests
			if self.myTrackedItemIfRelease &lt;&gt; null then
				self.myTrackedItemIfRelease := null;
			endif;
			self.myTrackedItemIfRelease := _ti;
		endif;
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="transfer" id="68b121e1-da54-48a5-a9dc-2ff3ec9f2dc2">
        <updating/>
        <source>transfer(source: CM_TrackedItem; target: CM_TrackedItem) updating;
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars

begin

	exclusiveLock(self);

	if self.trackedItem &lt;&gt; null and source = self.trackedItem then
		self.setTrackedItem(target);
		self.updateObjectEdition (self.myJob);	// par 30292
	endif;

end;</source>
        <Parameter name="source" type="CM_TrackedItem"/>
        <Parameter name="target" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validate" id="864cd1cf-1dc4-49d0-9f29-e38ec433a141">
        <source>validate(pUserObject : Object);
// ---------------------------------------------------------------------------
// Created:     16 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/02/2018	jlgdap1		TFS 37198 NXL Unable to Plane Prenoted Container to Train
// ---------------------------------------------------------------------------
// 12/07/2022    navgm20    Bug 54076: CUX - Swapping Release Cargo and Road Exit Issues
//  ----------------------------------------------------------------------------------
vars
	tiProxy	: CM_TrackedItem;
	realTIRequest : CM_TIRequest;
begin

	inheritMethod(pUserObject);

	if self.trackedItem = null then
		app.raiseCMException1(ErrorOnStore_NullTIForRequest, self.String, null, pUserObject);
		return;
	endif;
	
	if self.bulkRelease &lt;&gt; null then
		//self.trackedItem.validateForBulkRelease(self.bulkRelease.code);	// 06/12/2010 cnwmh5 #26400
		self.trackedItem.validateForBulkRelease(self.bulkRelease.getDeliveryReleaseNumber());
	endif;
	//jlier1 TFS 59732 6/9/23 
	realTIRequest:=self;
	if self.isTransient then
		realTIRequest:=self.pxyGetRealObject;
	endif;
	
	if self.myOriginatingBulkRelease &lt;&gt; null then
		//self.trackedItem.validateForBulkRelease(self.myOriginatingBulkRelease.code);	// 06/12/2010 cnwmh5 #26400
		self.trackedItem.validateForBulkRelease(self.myOriginatingBulkRelease.getDeliveryReleaseNumber());
		self.myOriginatingBulkRelease.testCandidateTI(self.trackedItem);
	else
		if self.trackedItem.directDelivery then	//08 Feb 2013	NDL	Par 31102
			//don't care....
		elseif self.trackedItem.canMergeBreakBulk then // PAR 32380
		    // don't care
		//elseif self.trackedItem.releaseRequest &lt;&gt; null then		//13453								//12/07/2022 navgm20 TFS 54076 
		elseif self.trackedItem.releaseRequest &lt;&gt; null and self.trackedItem.releaseRequest &lt;&gt; realTIRequest then //12/07/2022 navgm20 TFS 54076 
			if self.trackedItem.myTrainAssigned &lt;&gt; null 								// TFS 37198
			and self.trackedItem.myPrimaryPlannedLocation.isWagon 						// TFS 37198
			and self.trackedItem.myPrimaryActualLocation.isVehicle then					// TFS 37198
				// this is OK - this is a road receival prenote planned to a wagon		// TFS 37198
			else																		// TFS 37198
				app.raiseCMException2(ERR_TI_ALREADY_ALLOCATED, self.trackedItem.id, self.trackedItem.releaseRequest.myJob.jobId, null, null);
				return;	
			endif;																		// TFS 37198
		endif;
	endif;
	
	if self.myJob &lt;&gt; null then // AKB2004NOV MT RAIL Rel Reqs CCMS1282
		if self.myTrackedItemIfRelease &lt;&gt; null then
			tiProxy := app.myProxyManager.getProxyObject(self.myTrackedItemIfRelease).CM_TrackedItem;
			if tiProxy &lt;&gt; null then
				tiProxy.checkStopsToBePrevented(StopPreventReleaseRequest, self.myTrackedItemIfRelease, false);
			else
				self.myTrackedItemIfRelease.checkStopsToBePrevented(StopPreventReleaseRequest, null, false);
			endif;
		endif;
	endif;	
end;</source>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateForReturnJob" id="970c4ce6-79f7-41f4-8dac-552f36461e11">
        <source>validateForReturnJob();
//-----------------------------------------
//Changed: April 2003 By: cnwgd1
//-----------------------------------------
vars
	wle : CM_WorkListEntry;
	request : CM_Request;
begin

	//-------------------------------------------------------
	// This type of request only has one wle&lt;--&gt;trackedItem
	// relation. Just check to see if it has been worked and
	// if it hasn't then ok to return it to build priority
	//-------------------------------------------------------
	sharedLock(self);

	if self.allWorkListEntries.size &gt; 1 then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_WRONG_REQTYPE, null, null);
	endif;
	
	wle := self.allWorkListEntries.first;
	if wle = null then
		return;
	endif;

	if wle.status &lt;&gt; WLE_UNACTIONED then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(VB_NOT_UNACTND, wle.job.getTreeDescription(), null, null);
	endif;	
	
end;</source>
    </JadeMethod>
