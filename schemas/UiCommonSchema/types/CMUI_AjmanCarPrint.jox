<GUIClass name="CMUI_AjmanCarPrint" id="95a857d8-757f-4e53-baa9-615ebd7d41d3">
    <superclass name="CMUI_DotMatrixBaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
