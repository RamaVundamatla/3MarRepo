    <PrimAttribute name="aChunkSize" id="d4fbbfcd-19e4-43fe-b97f-c6a91cc8a616">
        <precision>23</precision>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="btnCancel" id="f70ac5a1-8c31-4a8d-8447-64178a866917">
        <embedded/>
        <type name="JadeMask"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnOk" id="3afc744b-f7d3-440c-96cb-b1aeb81b9a99">
        <embedded/>
        <type name="JadeMask"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblChunkSize" id="c174b7d1-46d4-4874-926e-f88af9e31ba3">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblDescription" id="39a0c548-c118-433f-a92e-a842756bcc99">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="txtChunkSize" id="b7422033-851b-47ce-8260-3e8e9f4f1b9c">
        <embedded/>
        <type name="TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnCancel_click" id="09d98e8b-1898-4ca9-8f1a-76a8ebc70d40">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		13 July 2002 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	modalResult	:=	self.JSS_MODAL_CANCEL;
	unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="6bf43eb9-38c3-4b24-a3cd-bc3633ff9c5e">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		13 July 2002 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.doFormUpdate(false) then
		modalResult	:=	self.JSS_MODAL_UPDATE;
		unloadForm;
	endif;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormInitialize" id="aa8aacc1-eb4b-4cff-a182-e1fcf257ddb4">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 July 2002 by cnwdad2
//
// Purpose:		The standard JSS CoreSchema form initialization event method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	txtChunkSize.text	:=	self.aChunkSize.String;
	modalResult			:=	self.JSS_MODAL_CANCEL;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="81c36537-2f7c-4e86-83ad-3a7814322738">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 July 2002 by cnwdad2
//
// Purpose:		The standard JSS CoreSchema form update method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	chunkSize	: Decimal[23];
	
begin
	chunkSize	:=	txtChunkSize.text.trimBlanks().Decimal;
	
	self.aMyServiceObject.setFileChunkSize(chunkSize);
epilog
	return inheritMethod(pIsDelete);
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setChunkSize" id="e1901373-2391-4b8c-95c7-c10c1b861272">
        <updating/>
        <source>setChunkSize(pChunkSize:Decimal) updating;
// --------------------------------------------------------------------------------
// Created:		13 July 2002 by cnwdad2
//
// Purpose:		Updates the local chunk size setting property.
//
// Parameters:	pChunkSize - The chunk size value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aChunkSize	:=	pChunkSize;
end;</source>
        <Parameter name="pChunkSize" type="Decimal"/>
    </JadeMethod>
</GUIClass>
