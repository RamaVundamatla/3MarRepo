    <JadeMethod name="valDeleteFile" id="5f065263-8281-48f1-bbf8-1aafe6c15297">
        <source>valDeleteFile(_parent : CM_Object; _fileData : CM_FileData);
// ---------------------------------------------------------------------------
// Created:     24 January 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
// need to get better error messages
	if _parent = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_parent', null, null);
	endif;
	
	if _fileData = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_fileData', null, null);
	endif;
	
	
end;
</source>
