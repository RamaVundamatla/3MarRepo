    <JadeMethod name="addInvTypeSurchargeExempt" id="82a64a17-8924-4321-ad99-b4d66d91128a">
        <source>addInvTypeSurchargeExempt(	_invType : CM_InvoiceDesc input;
							_minimumCharge : Real; // Optional
							_minChgInvLineType : CM_InvoiceLineDesc;	// Optional
							_myCurrencyType : CM_CurrencyType	//Optional
							):CM_InvoiceTypeSurchargeExempt;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37818, 37819, 37821, 37822

*/

vars

	real : CM_InvoiceTypeSurchargeExempt;
	proxy : CM_InvoiceTypeSurchargeExempt;

begin

	create proxy transient;
	
	proxy.setProxy(	_minimumCharge, //_minimumChargeAmount : Real;
					_invType,	//_myInvoiceType : CM_InvoiceDesc;
					_minChgInvLineType,	//_myMinimumChargeInvoiceLineType : CM_InvoiceLineDesc;
					_myCurrencyType,	//_myCurrencyType : CM_CurrencyType;
					null	//_taxExemptInvLineType : CM_InvoiceLineDesc
					);
					
	app.myTrxCA.trxCreateInvTypeSurExempt( proxy, real, app.myPassport );
	
	return real;

epilog

	delete proxy;

end;</source>
        <Parameter name="_invType" type="CM_InvoiceDesc" usage="input"/>
        <Parameter name="_minimumCharge" type="Real"/>
        <Parameter name="_minChgInvLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_myCurrencyType" type="CM_CurrencyType"/>
        <ReturnType type="CM_InvoiceTypeSurchargeExempt"/>
    </JadeMethod>
    <JadeMethod name="addInvoiceCargoAllocationLines" id="e9d063ef-7590-43d8-93f0-fc06a6c54664">
        <source>addInvoiceCargoAllocationLines(_realAlloc: CM_InvoiceCargoAllocation; _ctCode: String; _ild1: String; _ild2: String; _from: Integer; _tooo: Integer; _newrange: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2020	jlgndl1	Initial creation	TFS 50113 - moved up from UT_Invoicing

*/

vars
	sb : CM_CargoAllocServiceBroker;
	bu : CM_Bank;
	pxyQM :CM_QuantityMap;
	pxyQRM, realQRM :CM_QuantityRangeMap;
	ild : CM_InvoiceLineDesc;
	lines : CM_InvoiceLineDescSet;
	ct : CM_CalculationType;
	mapType	: CM_TranMapInvoiceLineGroupType;
begin
	sb := _realAlloc.myServiceBroker.CM_CargoAllocServiceBroker;
	bu := sb.getBank();
	ct := app.myRoot.allCalculationTypesByCode[_ctCode];

	
	beginLoad;
	pxyQM := sb.myChildQuantityMap.pxyCreateUpdateProxy().CM_QuantityMap;
	endLoad;
	
	if _newrange then
		create pxyQRM transient;
		mapType := bu.getInvLineGroupAll();
		
	else
		realQRM := sb.myChildQuantityMap.allQuantityRanges.first;
		beginLoad;
		pxyQRM := realQRM.pxyCreateUpdateProxy().CM_QuantityRangeMap;
		endLoad;
		mapType := realQRM.allTMInvoiceLineMappings.first.CM_TranMapInvoiceLineMapping.myTMInvoiceLineGroupType;
	endif;
	
	pxyQM.setProxy(sb,true, 1,ct, null);

	create lines transient;
	if _ild1 &lt;&gt; "" then
		ild := bu.invoiceLineDescriptors[_ild1];
		lines.add(ild);
	endif;
	if _ild2 &lt;&gt; "" then
		ild := bu.invoiceLineDescriptors[_ild2];
		lines.add(ild);
	endif;
	
	pxyQRM.setProxyInvoiceLineTypes(lines,mapType);
	pxyQRM.setProxy(sb.myChildQuantityMap,_from,_tooo,0);
	
	app.myTrxUA.trxUpdateInvoiceCargoAllocMap(not _newrange, pxyQM,pxyQRM, sb);
	self.assertTrueTrxOKShowPassport("Mapping Invoice Lines 1 " &amp; _realAlloc.description);
epilog
	delete pxyQM;
	delete pxyQRM;
	delete lines;

end;</source>
        <Parameter name="_realAlloc" type="CM_InvoiceCargoAllocation"/>
        <Parameter name="_ctCode" type="String"/>
        <Parameter name="_ild1" type="String"/>
        <Parameter name="_ild2" type="String"/>
        <Parameter name="_from" type="Integer"/>
        <Parameter name="_tooo" type="Integer"/>
        <Parameter name="_newrange" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addInvoiceRateEntry" id="07f232aa-9a2f-4850-8ae9-b4acac776122">
        <source>addInvoiceRateEntry(_rate : CM_Rate; _start : TimeStamp; _expiry : TimeStamp; _ignoreEntry : Boolean; _costs : DecimalArray;
			_adjustToBase : Decimal;
			_percentOfBase : Decimal;
			_parentRate : CM_Rate;
			_tidalClassRates : CM_RateByTidalClass ) : CM_RateEntry;

vars
	pxyRE, realRE : CM_RateEntry;
	cpu : Real;
	user : String; 
	tidalClassRate : CM_TidalClassRate;
	pxyTidalClassRate : CM_TidalClassRate;
begin
	if _costs.size &gt;= 1 then
		cpu := _costs[1];
	endif;
	
	user := app.myPassport.myUser.code; 
	create pxyRE transient;

	pxyRE.setProxy(_costs, cpu, _rate, user, _start, _expiry, _ignoreEntry, _adjustToBase, _percentOfBase, _parentRate );
	
	//24 Jul 2018	NDL	TFS 39338
	if _tidalClassRates &lt;&gt; null then
		foreach tidalClassRate in _tidalClassRates do
			create pxyTidalClassRate transient;
			pxyTidalClassRate.setDetails(	tidalClassRate.costPerUnit,	//_costPerUnit : Decimal;
											tidalClassRate.myTidalClass,	//_myTidalClass : HMS_TidalClass;
											pxyRE	//_myRateEntry : CM_RateEntry
											);
		endforeach;
	endif;
	
	app.myTrxCA.trxCreateRateEntry(pxyRE, realRE, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	return realRE;
epilog
	delete pxyRE;
end;
</source>
        <Parameter name="_rate" type="CM_Rate"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_expiry" type="TimeStamp"/>
        <Parameter name="_ignoreEntry" type="Boolean"/>
        <Parameter name="_costs" type="DecimalArray"/>
        <Parameter name="_adjustToBase" type="Decimal"/>
        <Parameter name="_percentOfBase" type="Decimal"/>
        <Parameter name="_parentRate" type="CM_Rate"/>
        <Parameter name="_tidalClassRates" type="CM_RateByTidalClass"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="addInvoiceRateEntryPercentage" id="3e38fc92-fa81-4f98-b115-80022a05ffec">
        <source>addInvoiceRateEntryPercentage(_rate : CM_Rate; _start : TimeStamp; _expiry : TimeStamp; _ignoreEntry : Boolean; _costs : DecimalArray; _isPercentage : Boolean; _isAmount : Boolean) : CM_RateEntry;

vars
	pxyRE, realRE : CM_RateEntry;
	cpu : Real;
	user : String; 
begin
	if _costs.size &gt;= 1 then
		cpu := _costs[1];
	endif;
	
	user := app.myPassport.myUser.code; 
	create pxyRE transient;
	pxyRE.setProxyWithPercentage(_costs, cpu, _rate, user, _start, _expiry, _ignoreEntry,_isPercentage,_isAmount);
	
	app.myTrxCA.trxCreateRateEntry(pxyRE, realRE, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	return realRE;
epilog
	delete pxyRE;
end;
</source>
        <Parameter name="_rate" type="CM_Rate"/>
