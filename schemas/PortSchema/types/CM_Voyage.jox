    <JadeMethod name="isCurrentOnPort" id="da15de72-01f9-490a-91d6-9e858c74edda">
        <source>isCurrentOnPort():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 

*/

vars
	arrDT ,
	depDT    : TimeStamp;
	now		 : TimeStamp;
begin
	
	now   := app.actualTimeServer;
	arrDT := self.arrivedDT;
	depDT := self.departedDT;
	
	if self.arrivedDT.isValid and self.departedDT.isValid then
		
		if arrivedDT &lt;= now and depDT &gt;= now then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
