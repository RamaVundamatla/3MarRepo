        <source>isChargeLineSelectedForPaying( _row : Integer ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 November 2013	cnwndl1	Initial creation	Par 32940

*/

vars

begin

	return ( self.tblCharges.getCellText( _row, ColumnInclude ).Integer = 1 ).Boolean;

