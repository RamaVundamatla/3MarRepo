<Class name="JtdDefaultDriverProfile" id="262236d6-0d37-4bfd-8b74-f39b94ec6dd1">
    <superclass name="JtdDriverProfile"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>************************************************************************

