    <JadeMethod name="comboBoxStockOrderGeneric" id="c2761e4d-62ec-4d96-91b0-733d669bbf83">
        <source>comboBoxStockOrderGeneric(_cmb : CMUI_ComboBox input;
							_terminal 		: CM_Terminal;
							_op 			: CM_Operator;
							_processOption,
							_fulfilledStatus	: Integer;
							_orderId 		: String);
// ---------------------------------------------------------------------------
// Created:     29 April 2004	cnwth2
//
// Purpose:     
// 14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  				 
// ----------   ----------  --------------------------------------------------
vars
	iter			: Iterator;
	termDict		: CM_StkOrdByProcessFulfillStat;
	orderNoKey		: String;
	fulfilledKey,
	processKey		: Integer;
	stockOrder		: CM_StockOrderHeader;
	found			: Boolean;
begin
	_cmb.clear();
	
	if _op &lt;&gt; null then
		termDict := _op.allStkOrdByProcessFulfillStat;
	elseif _terminal &lt;&gt; null then
		termDict := _terminal.allStkOrdByProcessFulfillStat;
	else
		return;
	endif;
	
	iter := termDict.createIterator;
	termDict.startKeyGeq(_processOption, _fulfilledStatus, null, iter);
	
	while iter.next(stockOrder) do
		iter.getCurrentKeys(processKey, fulfilledKey, orderNoKey);  //MTN-35226
		
		if _processOption &lt;&gt; null and
		   processKey &lt;&gt; _processOption then
			break;
		endif;
		
		if fulfilledKey = OrderStatus_Fulfilled then
			continue;
		endif;
		
		_cmb.itemObject[_cmb.addItem(orderNoKey)] := stockOrder;
		if orderNoKey = _orderId then
			found := true;
		endif;
	endwhile;

	if found then
		_cmb.text := _orderId;
	endif;
	
epilog
	delete iter;

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_op" type="CM_Operator"/>
        <Parameter name="_processOption" type="Integer"/>
        <Parameter name="_fulfilledStatus" type="Integer"/>
        <Parameter name="_orderId" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxStockOrderHeader" id="ef82b34b-1f9b-4f07-abf0-cc3f5d7ce916">
