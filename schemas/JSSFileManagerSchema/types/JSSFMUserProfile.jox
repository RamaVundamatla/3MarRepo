    <DbClassMap file="jssfm_userprofile"/>
    <PrimAttribute name="computerName" id="4715bdef-6045-41f1-a864-6d6bde4f870c">
        <length>61</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myRoot" id="7f707a57-081b-4377-b0b5-3f79bc4cdebb">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="JSSFMRoot"/>
