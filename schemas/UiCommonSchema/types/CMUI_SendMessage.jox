    <JadeMethod name="addToolbarControls" id="ce20d9fa-4eab-431f-8d73-7b55723559fb">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*
------------------------------------------------------------------------
Created:			26 November 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	self.btnSaveBase.bubbleHelp := "Send Message (Alt-S)";
	self.btnSaveBase.caption := "&amp;Send";
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
end;</source>
        <access>protected</access>
    </JadeMethod>
