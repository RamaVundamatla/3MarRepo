<Class name="CM_BlockStack" id="f77ad500-168e-4010-bc6a-3a868d68785f">
    <superclass name="CM_TerminalArea"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Is responsible for modelling a stand alone type block stack (NOT
one that appears within a straddle block). These areas act as
lists, in that tracked items may be removed from either end ONLY.
Retrictions are also applied at this level.</text>
    <DbClassMap file="location"/>
