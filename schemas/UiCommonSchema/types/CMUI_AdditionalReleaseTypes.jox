    <JadeMethod name="loadCombos" id="ae6a5f9d-67e6-407d-b921-cb9c9d61b10e">
        <source>loadCombos() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwjk3	Initial creation

*/

vars
	product : CM_Product;
begin
	if self.mySubCargoType &lt;&gt; null then 
		if self.mySubCargoType.myType &lt;&gt; null then
			cmbDimType.listCollection(self.mySubCargoType.myType.allCodes, true, ComboBox.DisplayCollection_Forward);
			//cmbDimType.setForObject(self.mySubCargoType.myType);
		endif;
	elseif self.myCargoType &lt;&gt; null then
		product := self.myCargoType.mySystemProductType;	
		if product &lt;&gt; null then			
			// Cargo type has no real products associated with it, so uses a dummy product...
			// populate dimensions type combo
			if product.myType &lt;&gt; null then
				cmbDimType.listCollection(product.myType.allCodes, true, ComboBox.DisplayCollection_Forward);
				//cmbDimType.setForObject(product.myType);
			endif;
		endif;
	endif;
	cmbDimType.setForObject(self.myProductAttributeCode);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDetailsFromParentForm" id="421d49c6-a08b-41b3-83c4-80afdcb72168">
        <updating/>
        <source>setDetailsFromParentForm( _description, _remarks,
						  _weight, _length, _volume, _width, _height, 
						  _quantity, _colour, _markNumber, _yardInstructions,
						  _widthText, _heightText, _lenText, _density : String;
						  _productAttributeCode : CM_ProductAttributeCode;
						  _cargoType : CM_CargoType; _subCargoType : CM_Product
						 ) updating;

/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/08/2009	cnwjk3	Initial creation
14/05/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
23/08/2103	cnwdap1	PAR #32331 Description and Colour moved to main Release form
*/

vars

begin
	self.tblLength.setup(Type_Length, self.backColor);
	self.tblWidth.setup(Type_Width, self.backColor);
	self.tblHeight.setup(Type_Height, self.backColor);
	
	self.tblTotalWeight.setup(Type_Weight, self.backColor);
	self.tblDensity.setup(Type_Density, self.backColor);
	self.tblVolume.setup(Type_Volume, self.backColor);
	
	self.myCargoType := _cargoType;
	self.mySubCargoType := _subCargoType;
	self.myProductAttributeCode := _productAttributeCode;
	//self.txtDescription.setValue(_description);					// PAR #32331
	self.txtRemarks.setValue(_remarks);
	self.tblTotalWeight.setValueDefault(_weight);					// PAR #31155
	self.tblLength.setValueDefault(_length);						// PAR #31155
	self.tblVolume.setValueDefault(_volume);						// PAR #31155
	self.tblWidth.setValueDefault(_width);							// PAR #31155
	self.tblHeight.setValueDefault(_height);						// PAR #31155
	self.txtQuantity.setValue(_quantity);
	//self.txtColour.setValue(_colour);								// PAR #32331
	self.txtMarkNumber.setValue(_markNumber);
	self.txtYardInstruct.setValue(_yardInstructions);
	self.txtWidthText.setValue(_widthText);
	self.txtHeightText.setValue(_heightText);
	self.txtLengthText.setValue(_lenText);
	self.tblDensity.setValueDefault(_density);						// PAR #31155
epilog

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_weight" type="String"/>
        <Parameter name="_length" type="String"/>
        <Parameter name="_volume" type="String"/>
        <Parameter name="_width" type="String"/>
        <Parameter name="_height" type="String"/>
        <Parameter name="_quantity" type="String"/>
        <Parameter name="_colour" type="String"/>
        <Parameter name="_markNumber" type="String"/>
        <Parameter name="_yardInstructions" type="String"/>
        <Parameter name="_widthText" type="String"/>
        <Parameter name="_heightText" type="String"/>
        <Parameter name="_lenText" type="String"/>
        <Parameter name="_density" type="String"/>
        <Parameter name="_productAttributeCode" type="CM_ProductAttributeCode"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_subCargoType" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="dcd092fe-87cb-4343-8b13-4c7b3a068b70">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2009	cnwjk3	Initial creation

*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	captionString	: String;

begin
	inheritMethod();
	self.handleMenusForModalDisplay();
	
	self.initFieldsForEntDefName(ETDef_AdditionalReleaseTypes, true);
	// turn off resize, and disappear min/max buttons
	self.borderStyle	:= self.BorderStyle_Double;
	self.maxButton		:= false;
	self.minButton		:= false;
	
	// no Next button
	btnNext.visible := false;
	
	captionString := app.getFormCaptionsString(Xlat_0012183);
	self.setCaption(captionString);
	self.loadCombos();

	if not self.isUpdatable() then
		self.enableAllControls(false);
	endif;
	
	self.btnCancel.enabled := true;
	
epilog

end;</source>
    </JadeMethod>
