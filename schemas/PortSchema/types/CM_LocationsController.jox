    <JadeMethod name="delete" id="36d04f98-0218-4af5-bd36-a84b7fda7c8a">
        <updating/>
        <source>delete() updating;
/*
------------------------------------------------------------------------
Created:			11 September 2003 by cnwdwq1
Purpose:			Forces a cleanup of any tracked items still here. There are 3 refs
							on cm_ti that arent looked after with an inverse we need to clear.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	ti 		: CM_TrackedItem;
	tis 	: CM_TIArray;
	prodMinMax : CM_TerminalAreaProductMinMax;
	
	
begin
	create tis transient;
	foreach ti in self.allTrackedItemsById do
		ti.destructorForPrimaryLocn(REAL_MODE, self);
	endforeach;
	self.getAllPlannedTrackedItems(tis, true, false);
	foreach ti in tis do
		ti.destructorForPrimaryLocn(PLANNING_MODE, self);
	endforeach;
	tis.clear;
	self.getAllQueuedTrackedItems(tis, true);
	foreach ti in tis do
		ti.destructorForPrimaryLocn(QUEUE_MODE, self);
	endforeach;
	
	// 10/09/2009 cnwar2 CCMS-1107/#20627
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152 
	
	//07 Apr 2021	NDL	TFS 49912
	foreach prodMinMax in self.allProductMinMax do
		delete prodMinMax;
	endforeach;
epilog
	delete tis;
end;</source>
    </JadeMethod>
