    <JadeMethod name="setPxyFromFieldValue" id="2b2df75a-7c40-4890-a858-c6bb242c2bb4">
        <updating/>
        <source>setPxyFromFieldValue( _fieldName : String; _fieldValue : String; _errLinkObj : Object; _passportObj : CM_Passport input ) updating;

/*
Purpose:		Refer to superclass implementation.

Date			Who		Reason
29 July 2010	cnwrl1	Initial creation as part of PAR 23526 - CCMS 1075 - EDI Cargo Field Update needs additional fields.
07 March 2018	jlgrh7 TFS37374 MSL - Cargo field update with MAFI ML
*/
	
vars
	upperFieldName	: String;
	trailerType		: CM_TILCType;
//	tiUpdateCntrl 	: CMIF_TIUpdateController;
	
begin
	self.raiseExceptionIfNotProxy(method);
//	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passportObj.userCode, null);

	upperFieldName	:= _fieldName.toUpper;
	
	if not self.validateFieldValueLength( _fieldName, _fieldValue, _errLinkObj ) then
		return;
	endif;
	
	if upperFieldName = CM_EDICargoFieldUpdateTI.F_TrailerType.toUpper then
		trailerType	:= app.myRoot.allTILCTypes[ null, _fieldValue.toUpper ];
		if trailerType = null then
			app.raiseCMException1( ERR_INVALID_TRAILER_TYPE, _fieldValue.toUpper, _fieldName, _errLinkObj );
		else
			self.setMyType( trailerType );
		endif;
	elseif upperFieldName = CM_EDICargoFieldUpdateTI.F_AvailabilityGrade.toUpper then									//+TFS37374 for availabilityGrade attribute
		self.availabilityGrade 		:= _fieldValue.Integer;
	else
		inheritMethod( _fieldName, _fieldValue, _errLinkObj, _passportObj );
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_fieldValue" type="String"/>
        <Parameter name="_errLinkObj" type="Object"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setUserDefinedTI" id="344ef0cf-6ca7-46fb-9cdf-714101371491">
        <updating/>
        <source>setUserDefinedTI(_ediTi: CM_EDICargoTI; _site: Integer; _terminal: CM_Terminal; _updateController: CMIF_TIUpdateController input; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	26 February 2010 By Graeme Black cnwgb1 PAR22476
// Purpose:	Setup values from EDI Cargo Load
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod(_ediTi, _site, _terminal, _updateController, _passport);
	self.myTILCType := app.myRoot.allTILCTypes[ null, _ediTi.trailerType ];
	
	//15/10/2025	navkc1 JIRA 36057
	if self.myTILCType &lt;&gt; null and self.myTILCType.allowUpdateTotalWeight then
		self.updateTILCTotalWeightConfig(true);
	endif;
	
	
	if _ediTi.availabilityGrade = null then
		self.availabilityGrade	:= self.myTerminal.getConfig( DefAvailabilityGrade ).Integer;
	else
		self.availabilityGrade	:= _ediTi.availabilityGrade;
	endif;

epilog
end;</source>
        <Parameter name="_ediTi" type="CM_EDICargoTI"/>
        <Parameter name="_site" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setUserDefinedTIForModify" id="056724d4-a1fe-4a67-a4ad-89c0630f318b">
        <updating/>
        <source>setUserDefinedTIForModify(_ediTi: CM_EDICargoTI; _terminal: CM_Terminal; _updateController: CMIF_TIUpdateController input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2014	cnwmc5	Initial creation	CCMS 2352

*/

vars

begin
	inheritMethod(_ediTi, _terminal, _updateController, _passport);
	
	if _ediTi.trailerType &lt;&gt; null then
		self.myTILCType := app.myRoot.allTILCTypes[ null, _ediTi.trailerType ];
	endif;
	
	//15/10/2025	navkc1 JIRA 36057
	if self.myTILCType &lt;&gt; null and self.myTILCType.allowUpdateTotalWeight then
		self.updateTILCTotalWeightConfig(true);
	endif;
	
	
	if _ediTi.availabilityGrade &lt;&gt; null then
		self.availabilityGrade	:= _ediTi.availabilityGrade;
	endif;
	
epilog

end;</source>
        <Parameter name="_ediTi" type="CM_EDICargoTI"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testAutoPlanRequestYA" id="edc31436-054a-49a4-aa48-e6c256e6eff2">
        <source>testAutoPlanRequestYA(_yaAgent: CM_YAAutoplanAgent input): Boolean;
/*

Date		Who		Reason
21 August 2013	cnwer1	Initial creation PAR 32261

*/

vars
	cmifRequest	: CMIF_YARequest;
begin
	if not  inheritMethod(_yaAgent)then
		return false;
	endif;
	
	cmifRequest := _yaAgent.myCurrentCMIFYAAutoPlan.CMIF_YARequest;
	
	if cmifRequest.hasAllocation then //cnwrd1 ccms 1303 14.11.2012
		return self.testAutoPlanRequestYAAlloc(_yaAgent);
	endif;
	
	if cmifRequest.allAvailabilityGrades.size &gt; 0 then
		//NFS 3798 An undefined grade in the request means that all TI's comply
		if not cmifRequest.allAvailabilityGrades.includes(self.availabilityGrade) then
			_yaAgent.addLogEntry(AP_Log_YA_Default,id &amp; " has an Availability Grade (" &amp; self.availabilityGrade.String &amp; ") that does not match the request.", true);
			return false;		
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testCellSuitabilityForTI" id="e8c580ea-12a1-408e-8013-1444f48e95c4">
        <source>testCellSuitabilityForTI(_yaAgent : CM_YAAutoplanAgent input ) : CM_TILCController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2022	jlier1	Initial creation 54675

*/

vars
	ti : CM_TrackedItem;
	lc : CM_TILCController; 
	ignoreTEU : Boolean;
begin

	 // ### CUX BUG 57417 31MAR2023 NAVAB1
	if self.contentsStatus = TI_CONTENTS_STATUS_FULLLASHED 
	or self.contentsStatus = TI_CONTENTS_STATUS_FCL then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'MAFI ' &amp; self.id &amp; ' is fully lashed, skipping', true);
	endif;

	_yaAgent.addLogEntry(AP_Log_YA_Default,'Testing MAFI suitability of  ' &amp; self.id &amp; ' in location ' &amp; self.getPrimaryLocationId(REAL_MODE), true);
	
	ti:=_yaAgent.myCMIFYAAutoPlan.getMyTrackedItem;
	if ti = null then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'No cargo to test', true);
	
		return null;
	endif;
	
	
	if ti.myOperator &lt;&gt; null and not ti.operatorCode = NULL_OPERATOR_CODE then
		if self.myOperator &lt;&gt; null and not self.operatorCode = NULL_OPERATOR_CODE then
			if self.myOperator &lt;&gt; ti.myOperator then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'MAFI operator ' &amp; self.operatorCode &amp; " does not match cargo operator " &amp; ti.operatorCode, true);
				return null;
			endif;
		endif;
	endif;
	
	if ti.myVoyage &lt;&gt; null and not ti.myVoyage.isNullVoyage then
		if self.myVoyage &lt;&gt; null and not self.myVoyage.isNullVoyage  then
			if self.myVoyage &lt;&gt; ti.myVoyage then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'MAFI voyage ' &amp; self.voyageCode &amp; " does not match cargo voyage " &amp; ti.voyageCode, true);
				return null;
			endif;
		endif;
	endif;
	
	if ti.dischargePort &lt;&gt; null then
		if self.dischargePort &lt;&gt; null then
			if self.dischargePort &lt;&gt; ti.dischargePort then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'MAFI discharge port ' &amp; self.dischargePort &amp; " does not match cargo discharge port  " &amp; ti.dischargePort, true);
				return null;
			endif;
		endif;
	endif;
		
	//jlier1 TFS 56832 13/3/22 - the criteria stuff really only makes sense for the cargo
	//  cargo type and imex will likely be different
	/*create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
	cmifAutoPlan.attachTI( self );

	foreach criteria in _yaAgent.myCurrentAllocation.allCriteria discreteLock do	
		if criteria.myYACriteriaType.isKindOf(CM_YATypeVoyage) or	
			criteria.myYACriteriaType.isKindOf(CM_YATypeOperatorItem) or
			criteria.myYACriteriaType.isKindOf(CM_YATypeDischargePort) then
				continue; //we have checked these are ok and they are ok to be null as well
		endif;
		if not criteria.isCMIFAutoPlanDataMatch( cmifAutoPlan ) then
			_yaAgent.addLogEntry(AP_Log_YA_Default,'MAFI does not match the ya criteria of  ' &amp; criteria.getDescription, true);
			return null;
		endif;
	endforeach;*/
		
	ignoreTEU:=self.myTerminal.getConfig(IgnoreTrailerTypeTEUCap).Boolean;
	
	foreach lc in self.allLCs  discreteLock do
		//epr par 34576 18/7/14
		if not lc.hasContainers(true,true) then
			return lc;
		endif;
	
		if self.myTerminal.roadProcessIsASPA then
			break;
		endif;
		if ignoreTEU then
			break;
		endif;
	
	endforeach;
	
	_yaAgent.addLogEntry(AP_Log_YA_Default,'MAFI has no room on board', true);
	return null;
	
epilog
	
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="CM_TILCController"/>
    </JadeMethod>
    <JadeMethod name="totalWeight" id="17fee009-327e-460f-8dba-146f424ca6dd">
        <methodInvocation>mapping</methodInvocation>
        <source>totalWeight(set: Boolean; _value: Decimal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2014	cnwndl1	Initial creation	Par 33561

*/

vars

	total : Decimal [12,4];

begin

	if not set then
		
		//15/10/2025	navkc1 JIRA 36057
		if self.canUpdateTotalWeight() then
			_value := _value; // What they've entered is what they want //15/10/2025	navkc1 JIRA 36057
			return;
		endif;
		
		total := self.weightCargo + self.getTareWeight;
		_value := total;
		
		
	else
	
		inheritMethod(set, _value);
	
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateContentsStatus" id="c182bab5-20b5-41bd-b871-f5fa8e526312">
        <updating/>
        <source>updateContentsStatus() updating;
/*

Purpose:			
Moved from setForCreate
Parameters:			

Return Value:		

Date		Who		Reason
24 Sep 2024 navlc30 Bug 66251: CUX - Go Live 02 issue - Stops not applied when creating cargo via /cargo API

*/

vars
	ti : CM_TrackedItem;
	tis : CM_TISet;			// TFS 65323	
begin

	// start navlw1 #65323
	if self.allChildren.isNotEmpty then
		foreach ti in self.allChildren discreteLock do
			if not ti.isContainer then
				self.contentsStatus := TI_CONTENTS_STATUS_PRTLOAD;
			endif;
			if ti.isContainer then
				self.contentsStatus := TI_CONTENTS_STATUS_FCL;
				break;
			endif;
		endforeach;
	elseif self.allLCs.isNotEmpty then
		create tis transient;
		self.getAllOnboardTIs(tis);
		foreach ti in tis do
			if not ti.isContainer then
				self.contentsStatus := TI_CONTENTS_STATUS_PRTLOAD;
			endif;
			if ti.isContainer then
				self.contentsStatus := TI_CONTENTS_STATUS_FCL;
				break;
			endif;
		endforeach;
	endif;
	// end navlw1 #65323
	
	if self.contentsStatus = TI_CONTENTS_STATUS_NULL then // ### TFS BUG 57408 14APR2023 NAVAB1
		self.contentsStatus := TI_CONTENTS_STATUS_EMPTY; // ### TFS BUG 57408 14APR2023 NAVAB1
	endif;

epilog
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateDimensions" id="a4d52599-fd3b-4842-922a-54f5814a8777">
        <updating/>
        <source>updateDimensions() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
01 July 2024	navcs2	Bug 64926: CUX | Change of Trailer Type not updating the Trailer Details correctly

*/

vars

begin
	self.length := self.myTILCType.length;
	self.width := self.myTILCType.width;
	self.height := self.myTILCType.height;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateMAFIForVoyageChange" id="9540be80-9a1c-4eb2-a498-3d7c014b10e2">
        <updating/>
        <source>updateMAFIForVoyageChange(_passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2024	jlier1	Initial creation 65290
 
*/

vars
	lc : CM_TILCController;
	ti : CM_TrackedItem;
	onboardTI : CM_TrackedItem;
begin
	
	inheritMethod(_passport); //jlier1 TFS 65459 5/8/23
	
	if not self.isMAFI then
		return;
	endif;
	
	
	foreach lc in self.allLCs discreteLock do : outerLoop
		foreach onboardTI in lc.allTrackedItems discreteLock do
			onboardTI.updateMAFIForVoyageChange(_passport);	
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateRoadJobCargoChassis" id="c432aa0d-02e6-4546-af23-0aa9806651b6">
        <source>updateRoadJobCargoChassis(control: CMIF_MoveController input);
/*

Date		Who		Reason
20 May 2014	cnwer1	Initial creation PAR

*/

vars
	job : CM_RoadJob;
	wle : CM_WorkListEntry;
	moveController : CMIF_MoveController;
begin
	if control.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;
	
	if control.myWorkListEntry &lt;&gt; null and control.myWorkListEntry.isChassisToRelease then
		//move any release wles which are on the unknown trailer to this trailer 	
		job:=control.myWorkListEntry.job.CM_RoadJob;
		create moveController transient;
		foreach wle in job.workListEntries where not wle.isReceipt do
			if wle = control.myWorkListEntry then
				continue;
			endif;
			if wle.myTrackedItem = null then
				continue;
			endif;
			if wle.myTrackedItem.myPrimaryActualLocation = job.myVehicle.myUnknownChassis then
				delete moveController;
				create moveController transient;
				moveController.setMyWorkListEntry(wle);
				moveController.setMyTrackedItem(wle.myTrackedItem);
				moveController.setMyToPrimaryLocation(self.getNextFreeLC);
				moveController.setMoveMode(REAL_MODE);
				//15 July 2014	NDL	Par 34562
				if moveController.myToPrimaryLocation = null then
					app.raiseCMException2(Assign_Trailer_No_Space,self.id,wle.myTrackedItem.id,null,null);
					return;	
				endif;
				
				app.myUtilityUA.utlUpdateMoveTrackedItem(moveController,control.myPassport);
			endif;
		endforeach;
	endif;
epilog
	delete moveController;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTILCTotalWeightConfig" id="a4f7aa23-bd19-4205-90fc-4bcc5a000e01">
        <updating/>
        <source>updateTILCTotalWeightConfig(_allowUpdate : Boolean) updating;
/*

Purpose:			Re implemented in CM_TILC to update self.typeAttributes based on the Trailer Type config

Parameters:			

Return Value:		

Date		Who		Reason
15/10/2025	navkc1 JIRA 36057 CUX | Total Weight Specification for Trailers - DB Changes / Form /Jade

*/

vars

begin
	if  (_allowUpdate and self.typeAttributes.bitAnd(TILCTypeEnableTotalWeightEdit) = 0)  or 	// allow update but TI is not set to not allow update
		(not _allowUpdate and self.typeAttributes.bitAnd(TILCTypeEnableTotalWeightEdit) &gt; 0)	// do not allow update but ti is set to allow update
			then
			self.typeAttributes := self.typeAttributes.bitXor(TILCTypeEnableTotalWeightEdit); // set to allow/not allow update
		endif;

epilog

end;</source>
        <Parameter name="_allowUpdate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCargoMatchesVoyOpDisch" id="7f3f91c9-4a77-4287-90f7-ee43a8442528">
        <source>validateCargoMatchesVoyOpDisch(_cargo : CM_TrackedItem input);
/*

Purpose:		This is only called if CHECKLOCATION is set to true in the web config	

Parameters:			

Return Value:		

Date		Who		Reason
13 Oct 2022	jlier1	Initial creation 54676
20 Mar 2023	jlika1	CUX 53635 - Vehicle App MAFI setdown validation warning/error
25 Oct 2023	jlika1	CUX | Change mismatched operator from error to warning
24 Jul 2024	jlier1 	CR 65290 -MAFI Voyage Inheritance Rules - Update and Adjust
*/

vars
	tis 					: CM_TISet;
	trackedItem				: CM_TrackedItem;
	treatMAFIValAnError 	: Boolean;
	treatMAFIOperValAnError : Boolean;
	setDownOperatorCode, 
	mafiOperatorCode	: String;
begin
	
	// 26/02/2024 navkc1	Bug 62445: PEN - Blue operator error when using chassis
	if not self.isMAFI() then
		return;
	endif;
	
	treatMAFIValAnError := self.myTerminal.getConfig(TreatMAFIValAnError).Boolean;
	treatMAFIOperValAnError := self.myTerminal.getConfig(TreatMAFIOperValAnError).Boolean;
	
	if _cargo.myOperator &lt;&gt; null then
		setDownOperatorCode := _cargo.myOperator.code;
	endif;
	if self.myOperator &lt;&gt; null then
		mafiOperatorCode := self.myOperator.code;
	endif;
	
	if (setDownOperatorCode &lt;&gt; mafiOperatorCode and mafiOperatorCode &lt;&gt; NULL_OPERATOR_CODE and mafiOperatorCode &lt;&gt; null and setDownOperatorCode &lt;&gt; null) then // ### TFS BUG 57544 11APR2023 NAVAB1
		if treatMAFIOperValAnError then
			app.raiseCMException2(Mafi_does_not_match_opera_carg, self.id, _cargo.id,null,null);
			return;
		else
			app.raiseCMWarning2(Mafi_does_not_match_opera_carg, self.id, _cargo.id,null,null,null);
		endif;		
	endif;
		
	create tis transient;
	self.getAllOnboardTIs(tis);

	if tis.includes(_cargo) then
		//epr TFS 60822 annoying double up of errors and warnings
		tis.remove(_cargo);
	endif;
	
	if _cargo.isContainer then 
		if tis.first &lt;&gt; null then //other cargo on board then this is always an error 
			if _cargo.myVoyage &lt;&gt; self.myVoyage   then
				app.raiseCMException2(Mafi_does_not_match_voyage, self.id, _cargo.id,null,null);
			endif;
			if _cargo.dischargePort &lt;&gt; self.dischargePort then
				app.raiseCMException2(Mafi_does_not_match_disch_port, self.id, _cargo.id,null,null);
			endif;
		endif;
	else
		if ((_cargo.myVoyage &lt;&gt; null and not _cargo.myVoyage.isNullVoyage) and (self.myVoyage &lt;&gt; null and not self.myVoyage.isNullVoyage)) and _cargo.myVoyage &lt;&gt; self.myVoyage then
			if treatMAFIValAnError then
				app.raiseCMException2(Mafi_does_not_match_voyage, self.id, _cargo.id,null,null);
				return;
			else
				app.raiseCMWarning2(Mafi_does_not_match_voyage, self.id, _cargo.id,null,null,null);
			endif;		
		endif;
		if (_cargo.dischargePort &lt;&gt; null and self.dischargePort &lt;&gt; null) and _cargo.dischargePort &lt;&gt; self.dischargePort then
			if treatMAFIValAnError then
				app.raiseCMException2(Mafi_does_not_match_disch_port, self.id, _cargo.id,null,null);
				return;
			else
				app.raiseCMWarning2(Mafi_does_not_match_disch_port, self.id, _cargo.id,null,null,null);
			endif;	
		endif;
	endif;
	
epilog
	delete tis;
end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateFieldValueLength" id="2afc5840-c130-4e5b-a0d1-1985c6db3eaf">
        <source>validateFieldValueLength( _fieldName : String; _fieldValue : String; _errLinkObj : Object ) : Boolean protected;

/*
Purpose:	Validates that the field value is not too long for the field being updated.

Date			Who		Reason
29 July 2010	cnwrl1	Initial creation as part of PAR 23526 - CCMS 1075 - EDI Cargo Field Update needs additional fields.
07 March 2018	jlgrh7 TFS37374 MSL - Cargo field update with MAFI ML
*/
	
vars
	upperFieldName	: String;
	fieldLength		: Integer;
	
begin
	if _fieldValue.trimBlanks() = null then
		return true;
	endif;
	
	upperFieldName	:=	_fieldName.toUpper();
	
	if upperFieldName = CM_EDICargoFieldUpdateTI.F_TrailerType.toUpper() then
		fieldLength	:=	CM_TILCType::code.getLengthForString();		// ie 30
	elseif upperFieldName = CM_EDICargoFieldUpdateTI.F_AvailabilityGrade.toUpper() then						//+TFS37374 for availabilityGrade attribute
		fieldLength	:=	CM_TILC::availabilityGrade.getLengthForString();
	else
		return inheritMethod( _fieldName, _fieldValue, _errLinkObj );
	endif;
	
	if fieldLength &lt; _fieldValue.length() then
		app.raiseCMException2( Field_Value_Too_Long, _fieldName, fieldLength.asStringJMT(), _fieldName, _errLinkObj );
		return false;
	endif;
	
	return true;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_fieldValue" type="String"/>
        <Parameter name="_errLinkObj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForAttach" id="af0c111c-ea01-471d-83cb-8d599688ba71">
        <source>validateForAttach( _theParams: CMIF_ConnectParams input);
/* ---------------------------------------------------------------------------
Created:	27 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
------------------------------------------------------------------------------*/
vars
	otherTI		: CM_TrackedItem;
	aMsgString	: String;
	
begin

	otherTI := _theParams.myOtherTrackedItem;
	
	if not _theParams.dateTime.isValid() then
		app.raiseCMException2(ERR_INVALID_VALUE, "DateTime",null, null, null);
	endif;

	if otherTI = null then
		app.raiseCMException2(ERR_INVALID_VALUE, app.getErrorString(CM_Generator_GC), app.getErrorString(ERR_SelectGeneratorAttach), null, null);
	elseif self.myOperator &lt;&gt;  otherTI.myOperator then
		aMsgString := app.getErrorString(ERR_OperGeneratorContainer) &amp; Cr &amp; 
			self.id &amp; " is " &amp; self.myOperator.code &amp; " " &amp; Cr &amp; 
			otherTI.id &amp; " is " &amp;  otherTI.myOperator.code;
			app.raiseCMException2(ERR_INVALID_VALUE,  app.getErrorString(Operator), aMsgString, null, null);
	endif;

	// attaching a generator. Generator should be GeneratorType of Under-slung
	if otherTI.isKindOf( CM_Generator ) then
		if self.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Generator,otherTI.id.trimBlanks] = null then
			aMsgString := app.getErrorString1( ERR_TI_NOT_ONSITE, otherTI.id.trimBlanks );
			app.raiseCMException2(ERR_INVALID_VALUE, app.getErrorString(CM_Generator_GC), aMsgString, null, null);
		endif;
		if otherTI.CM_Generator.myGeneratorType = null
		or not otherTI.CM_Generator.myGeneratorType.isUnderSlung then
			//app.raiseCMException2( /*ERR_INVALID_VALUE*/, "Generator",aMsgString, null, null);
			//app.raiseUnexpectedProgramError( class.name, method.name, 'Generator should be Under-slung' );  //27.02.2018 cnwma1 ChangeRequest #36813
			app.raiseCMException2(Generator_MatchingType,  otherTI.id, GeneratorType_UnderSlung,null,null);   //27.02.2018 cnwma1 ChangeRequest #36813
		endif;
	endif;
	
	
	if app.getMyTerminalConfigDO_NOT_USE(RecordUserRequests).Boolean and _theParams.noCharge = false then
		if _theParams.urNumber.trimBlanks = null then
			aMsgString := app.getErrorString(ERR_UserRequestNo);
			app.raiseCMException2(ERR_INVALID_VALUE,  app.getErrorString(CM_User_Request_Number),aMsgString, null, null);
		endif;
	endif;
	

end;</source>
        <Parameter name="_theParams" type="CMIF_ConnectParams" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForBayPlan1" id="10a9fa1e-743e-433b-8905-93c8ee63296c">
        <updating/>
        <source>validateForBayPlan1(_control: CMIF_TIUpdateController; _passport: CM_Passport input) updating, protected;
/*

Date		Who		Reason
12 September 2014	cnwer1	Initial creation PAR

*/

vars

begin
