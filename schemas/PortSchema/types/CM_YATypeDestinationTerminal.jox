<Class name="CM_YATypeDestinationTerminal" id="52ef889d-90ee-4dca-8ca7-e637297b05a0">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getAllCriteriaValues" id="365008d6-7fbe-4b2e-a4fd-0cffc6d33ca4">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs : CM_ObjectArray);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/02/2011	cnwdap1	Initial creation PAR #26861 CCMS POL 2031
17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
*/
vars

begin
	app.myRoot.allTerminals.copy(_allCriteriaValues);

epilog

end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaObjectForTi" id="67e2ce55-73d1-429b-bce0-f69e4f3f7ab4">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/02/2011	cnwdap1	Initial creation PAR #26861 CCMS POL 2031
*/
vars

begin
	_criteriaObject := app.myRoot.allTerminals[_ti.destinationTerminal];

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="8aa2c2ca-8e02-4058-bd21-ba52b0d4b232">
