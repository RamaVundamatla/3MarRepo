	self.setBalances();
end;</source>
        <access>protected</access>
        <Parameter name="_select" type="Boolean"/>
        <Parameter name="_cashPayment" type="CM_CashPayment"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="4a040445-7f00-404c-8a73-2bdefe269468">
        <updating/>
        <source>doSave() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/

vars
	unCreditPayment,
	unCreditPaymentTax   : Decimal[23,6];
	pxyCashCredit	     : CM_CashCredit;
	pxyCreditDetail,
	pxyTaxCreditDetail    : CM_CashCreditDetail;
	drTerm 			      : CM_DebtorTerminal;
	now 			      : TimeStamp;
	user 			      : CM_User;
	bank	      	      : CM_Bank;
	allCashPayment,
	allPxyCashDetails     : ObjectArray;
	ti			          : CM_TrackedItem;
	cashPayment,
	cashPaymentTax       : CM_CashPayment;
	theReturn,
	index,
	row  		         : Integer;
	obj                  : Object;
	table                : CM_DataTable;
begin
	
	// don't create a credit if no value
	if self.creditTotal = 0 then
		return false;
	endif;
	
	now    := app.actualTimeServer;
	user   := app.getMyUser;
	drTerm := self.myTerminal.allDebtorTerminals.getAtKey( self.myDebtor );
	bank   := self.myTerminal.getDefaultCompanyBank();
	table  := self.tblCharges;
	
	create pxyCashCredit transient;
	pxyCashCredit.setProxy(	self.creditTotal,
							now,
							self.cashComments,
							bank,
							drTerm,
							self.myCashReceipt,
							user
							);

	row := 1;
	create allCashPayment 		transient;
	create allPxyCashDetails	transient;
	
	/*Get Selected Payment */
	while row &lt; table.rows do
		row := row + 1;
		obj := table.accessRow(row).itemObject;
		
		if 	table.accessCell(row, 1).text &lt;&gt; self.chkBoxSelected then
			continue;
		endif;
		
		if not obj.isKindOf(CM_CashPayment) then
			continue;
		endif;
		
		cashPayment := obj.CM_CashPayment;
		if cashPayment &lt;&gt; null then
			allCashPayment.addExclusive(cashPayment);
		endif;
	endwhile;
 
	
	foreach obj in allCashPayment do
		
		
		cashPayment     :=  obj.CM_CashPayment;
		ti			    := cashPayment.myTrackedItem;
		unCreditPayment := cashPayment.getUncreditedAmount;
		
		if unCreditPayment &gt; 0 then
			
			create pxyCreditDetail transient;
			pxyCreditDetail.setDerivedProxy(null, 
											cashPayment,
											ti,
											unCreditPayment,
											now);
											
			allPxyCashDetails.add(pxyCreditDetail);
			
			if cashPayment.hasTax &lt;&gt; null then			
				cashPaymentTax     := cashPayment.myCashPaymentForTax;
				unCreditPaymentTax := cashPaymentTax.getUncreditedAmount;
				
				if unCreditPaymentTax &gt; 0 then
					create pxyTaxCreditDetail transient;
					pxyTaxCreditDetail.setDerivedProxy(null,
														cashPaymentTax,
														ti,
														unCreditPaymentTax,
														now);
														
					allPxyCashDetails.add(pxyTaxCreditDetail);
				endif;
			endif;
		endif;
	endforeach;
	
	while true do
		app.myTrxCA.trxCreateCashCredit (pxyCashCredit, self.myNewCashCredit, allPxyCashDetails, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog("Cash Credit", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		
			return false;
		endif;
		break;
	endwhile;

	if self.chkPrintRec.value then
		self.myAssistant.INV_Assistant.printCashCredit(self.myNewCashCredit, 1, true, null, null, "");
	endif;

	return true;	

epilog

	if allPxyCashDetails &lt;&gt; null and not allPxyCashDetails.isEmpty then
		allPxyCashDetails.purge();
	endif;
	delete pxyCashCredit;
	delete allPxyCashDetails;
	delete allCashPayment;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="b29ff797-22de-49ec-aac3-7d3cfc0cb1fe">
        <updating/>
        <source>doSelectAll() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jul 2019	jlgsl4	TFS 44274 - Cash Credit
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/
vars
	row				: Integer;
	table			: Table;
	obj				: Object;
begin
	row   := 2;
	table := self.tblCharges;
	while row &lt;= table.rows do
				
		obj := table.accessRow(row).itemObject;
		if  obj&lt;&gt; null and obj.isKindOf(CM_TrackedItem) then
			row := row + 1;
			continue;
		endif;
		
		if table.accessCell(row, 1).inputType = Table.InputType_CheckBox then
			table.accessCell(row, 1).text := self.chkBoxSelected; 
		endif;
		
		self.doRowSelectDeselect(true,obj.CM_CashPayment);
		
		row := row + 1;
		
	endwhile;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUnselectAll" id="6bb26ee7-0cc4-49e1-8654-964fd5d5d103">
        <updating/>
        <source>doUnselectAll() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jul 2019	jlgsl4	TFS 44274 - Cash Credit
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/
vars
	row				: Integer;
	table			: Table;
	obj				: Object;
begin
	row   := 2;
	table := self.tblCharges;
	while row &lt;= table.rows do
				
		obj := table.accessRow(row).itemObject;
		if  obj&lt;&gt; null and obj.isKindOf(CM_TrackedItem) then
			row := row + 1;
			continue;
		endif;
		
		if table.accessCell(row, 1).inputType = Table.InputType_CheckBox then
			table.accessCell(row, 1).text := false.cnEcGetTableCheckBoxValue; 
		endif;
		
		self.doRowSelectDeselect(false,obj.CM_CashPayment);
		
		row := row + 1;
		
	endwhile;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doValidate" id="f31beb0f-60da-4114-8939-90210cf16f50">
        <source>doValidate() : Boolean;
/*

Purpose:			
		don't allow payment over the remaining receipt balance
Parameters:			

Return Value:		

Date		Who		Reason
19 Jul 2016 cnwma1  PAR37812  TFS 2339 JMT - 1090 error on Saving a Cash Credit form
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/

vars

begin
	
	if self.creditTotal = 0 then
		return false;
	endif;
	
	if self.myCashReceipt = null then
		return false;
	endif;
	
	
	if self.creditTotal &gt; self.myCashReceipt.getUncreditedAmount then
		app.raiseCMException( Cannot_credit_more_than_bal, null, null );
		return false;
	endif;

	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getUnCreditTotal" id="ea862b97-00b8-426a-8b4f-de4d77373ed9">
        <source>getUnCreditTotal(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2019	jlgma1:1	Initial creation

*/

vars
	row				: Integer;
	table			: Table;
	obj				: Object;
	totalCredit,
	totalCreditTax  : Decimal [23,6];
	cashPayment     : CM_CashPayment;
begin
	row   := 2;
	table := self.tblCharges;
	
	while row &lt; self.tblCharges.rows do
		row := row + 1;
		obj := self.tblCharges.accessRow(row).itemObject;
		if obj &lt;&gt; null and  obj.isKindOf(CM_CashPayment) then
		
			if 	table.accessCell(row, 1).text = self.chkBoxSelected then
				cashPayment := obj.CM_CashPayment;
				totalCredit := totalCredit + cashPayment.getUncreditedAmount();
				if cashPayment.hasTax() then
					totalCreditTax := cashPayment.myCashPaymentForTax.getUncreditedAmount();
					totalCredit := totalCredit + totalCreditTax;
				endif;
			endif;
		endif;
	endwhile;
	
	return totalCredit;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="80c0d16f-072c-4199-b5ea-6cb02a454613">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2012	cnwndl1	Initial creation

*/

vars

	str : String;

begin

	str	:=	inheritMethod();
	
	str := str &amp; global.formatAsXML( self.chkPrintRec.name, self.chkPrintRec.value.String );
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initChargesTable" id="5bc4e896-6981-41f5-893b-ae0c2cd0d70a">
        <source>initChargesTable();
/*

Purpose:		Table columns:
				1=select charge checkboxes, 2=charge details, 3=narration, 4=line total

Parameters:			

Return Value:		

Date		Who		Reason
23 Jul 2019	jlgsl4	TFS 44274 - Cash Credit
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/

vars
	headings : String;
	table : CM_DataTable;
begin
	table             				:= self.tblCharges;
	headings 		   				:= Tab &amp; "Details" &amp; Tab &amp; "Narration" &amp; Tab &amp; "Amount" &amp; Tab &amp; "Tax" &amp; Tab &amp; "Total" ;
	table.visible      				:= true;
	table.rows         			    := 1;
	table.fixedRows    			    := 1;
	table.columns     			    := 6;
	table.fixedColumns 				:= 0; 
	table.accessColumn(1).width     := 25;
	table.accessColumn(2).width     := 250;
	table.accessColumn(1).alignment := Table.Alignment_Center_Middle;
	table.accessColumn(4).alignment := Table.Alignment_Right;
	table.accessColumn(5).alignment := Table.Alignment_Right;
	table.accessColumn(6).alignment := Table.Alignment_Right;
	table.accessCell(1,2).fontBold  := true;
	table.accessCell(1,3).fontBold  := true;
	table.accessCell(1,4).fontBold  := true;
	table.accessCell(1,5).fontBold  := true;
	table.accessCell(1,6).fontBold  := true;
	self.mnuSelectAll.visible       := true;
	self.mnuUnselectAll.visible     := true;
	table.setCellText(1,1,headings);
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="b87f702d-7d5d-4409-be28-c4bcff9b795f">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2012	cnwndl1	Initial creation

*/

vars

	mopText : String;
	printRecText : String;

begin

	inheritMethod(_userWindow);
	
	printRecText := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.chkPrintRec.name );
