    <JadeMethod name="updateMe" id="38bccd9f-8415-4b9d-9efa-4ac80154d1fe">
        <updating/>
        <source>updateMe(pMethodObj:Method; pAlias:String; pClassObj:CnEcDocModelClass) updating;
// --------------------------------------------------------------------------------
// Created:		01 November 2002 by cnwdad2
//
// Purpose:		Update the receiver's details.
//
// Parameters:	pMethodObj - The method which this Documentation Method object represents.
//				pAlias - The alias name for the method.
//				pClassObj - The owner of this Documentation Method.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 23/01/2003	cnwdad1		Added support for an alias of the receiver's name.
// --------------------------------------------------------------------------------
begin
	self.alias			:=	pAlias;
	self.myMethod		:=	pMethodObj;
	self.methodName		:=	pMethodObj.name;
	self.myDocClass		:=	pClassObj;
end;</source>
        <Parameter name="pMethodObj" type="Method"/>
        <Parameter name="pAlias" type="String"/>
        <Parameter name="pClassObj" type="CnEcDocModelClass"/>
    </JadeMethod>
</Class>
