    <JadeMethod name="formLoad" id="18bdf151-74cd-45d8-a2cf-4a738d49a3e7">
        <updating/>
        <source>formLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnBrowse.enabled		:=	false;
	self.viewObjectsByOid	:=	self.getViewObjectsByOid();
	self.loadClasses();
	beginNotification(app, self.NOTIFY_REFRESH, Response_Continuous, 0);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="f609b6fe-408e-433b-ba4e-0fd1cc6ab288">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11/07/1999	cnwdad1		Added beginNotification for refresh event.
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer		:=	Busy;
	self.formLoad();
epilog
	self.statusMsg("");
end;</source>
    </JadeMethod>
    <JadeMethod name="loadClasses" id="f07fde93-455d-42d2-8517-95b295784ce4">
        <source>loadClasses() protected;
// --------------------------------------------------------------------------------
// Created:		09 January 1999 by cnwdad1
//
// Purpose:		Loads classes into an hierarchical structure within the listbox.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 13/2/1999	cnwdad1		The class list box is no longer fully populated at once,
//							but instead subclasses are only loaded when the folder
//							is opened by the User.
//
// --------------------------------------------------------------------------------
vars
	allSchemas		: Boolean;
	includeSystem	: Boolean;
	mdiForm			: Form;
	classColl		: ClassColl;
	class			: Class;
	listClass		: Class;
	classIndex		: Integer;

begin
	lstClasses.clear;
	btnBrowse.enabled	:=	false;
	mdiForm				:=	self.getMdiFrame();
	includeSystem		:=	mdiForm.CnEcJDBrowserMdi.mnuClassSystem.checked;
	allSchemas			:=	mdiForm.CnEcJDBrowserMdi.mnuClassSuper.checked;

	if includeSystem then
		class	:=	Object;

		classIndex								:=	lstClasses.addItem(self.classString(class));
		lstClasses.itemObject[classIndex]		:=	class;
		lstClasses.itemLevel[classIndex]		:=	1;
		self.classForeColor(class, lstClasses, classIndex);
		classIndex								:=	lstClasses.addItem(self.DUMMY_FOLDER);
		lstClasses.itemLevel[classIndex]		:=	2;
		beginClassNotification(class, false, Any_System_Event, Response_Continuous, 1);

	else
		create classColl transient;

		if allSchemas then
			// Get the top-level classes for all schemas.
			currentSchema.getClass(Object.name).getSubclasses(classColl);
		else
			// Get the top-level classes for the current schema only.
			currentSchema.getClass(Object.name).getSubclassesUpToSchema(currentSchema, classColl);
		endif;

		if classColl.isEmpty() then
			return;
		endif;

		foreach class in classColl do
			if (not class.isSystemObject) then
				if class._isSubschemaCopy then
					listClass	:=	class.cnEcGetImplementationSchema().getClass(class.name);
				else
					listClass	:=	class;
				endif;

				classIndex							:=	lstClasses.addItem(self.classString(listClass));
				lstClasses.itemObject[classIndex]	:=	listClass;
				lstClasses.itemLevel[classIndex]	:=	1;
				beginClassNotification(listClass, false, Any_System_Event, Response_Continuous, 1);
				self.classForeColor(listClass, lstClasses, classIndex);

				if listClass.hasSubclasses then
					classIndex	:=	lstClasses.addItem(self.DUMMY_FOLDER);
					lstClasses.itemLevel[classIndex]	:=	2;
				endif;
			endif;
		endforeach;
	endif;
epilog
	delete classColl;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSubClasses" id="c895b886-96a0-418c-b5a5-66bf2f94cbab">
        <source>loadSubClasses(pSubClass:Class; pLevel:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		09 January 1999 by cnwdad1
//
// Purpose:		Loads all subclasses of the currently selected class.
//
// Parameters:	pSubClass (Class) - The class to begin loading from.
//				pLevel (Integer) - The hierarchical list level to start from.
// Returns:		nothing	
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 13/2/1999	cnwdad1		The class list box is no longer fully populated at once,
//							but instead subclasses are only loaded when the folder
//							is opened by the User.
//
// --------------------------------------------------------------------------------
vars
	allSchemas		: Boolean;
	includeSystem	: Boolean;
	mdiForm			: Form;
	classColl		: ClassColl;
	class			: Class;
	listClass		: Class;
	classIndex		: Integer;

begin
	classIndex		:=	lstClasses.findObject(pSubClass);
	lstClasses.removeItem(classIndex + 1);	// Remove the dummy folder item.

	mdiForm			:=	self.getMdiFrame();
	includeSystem	:=	mdiForm.CnEcJDBrowserMdi.mnuClassSystem.checked;
	allSchemas		:=	mdiForm.CnEcJDBrowserMdi.mnuClassSuper.checked;
	create classColl transient;

	if allSchemas then
		// Get the top-level classes for all schemas.
		currentSchema.getClass(pSubClass.name).getSubclasses(classColl);
	else
		// Get the top-level classes for the current schema only.
		currentSchema.getClass(pSubClass.name).getSubclassesUpToSchema(currentSchema, classColl);
	endif;

	if classColl.isEmpty() then
		return;
	endif;

	foreach class in classColl do
		if	includeSystem
		or ((not includeSystem)
		and (not class.isSystemObject))
		then
			if class._isSubschemaCopy then
				listClass	:=	class.cnEcGetImplementationSchema().getClass(class.name);
			else
				listClass	:=	class;
			endif;

			classIndex							:=	classIndex + 1;
			lstClasses.addItemAt(self.classString(listClass), classIndex);
			lstClasses.itemObject[classIndex]	:=	listClass;
			lstClasses.itemLevel[classIndex]	:=	pLevel;
			beginClassNotification(listClass, false, Any_System_Event, Response_Continuous, 1);
			self.classForeColor(listClass, lstClasses, classIndex);

			if listClass.hasSubclasses then
				classIndex							:=	classIndex + 1;
				lstClasses.addItemAt(self.DUMMY_FOLDER, classIndex);
				lstClasses.itemLevel[classIndex]	:=	pLevel + 1;
			endif;
		endif;
	endforeach;
epilog
	delete classColl;
end;</source>
        <access>protected</access>
        <Parameter name="pSubClass" type="Class"/>
        <Parameter name="pLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lstClasses_click" id="e90a8744-2a87-4d03-a922-8a3aa59087e6">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstClasses_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (listbox.listIndex &lt;&gt; CNEC_NULL_INDEX) then
		btnBrowse.enabled	:=	true;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstClasses_dblClick" id="96c2195d-9fe7-437c-98dc-5d3005f48ae5">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstClasses_dblClick(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnBrowse_click(btnBrowse);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstClasses_mouseDown" id="30eb9db0-240f-4d9c-951d-624f00ad67e7">
        <controlMethod name="ListBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstClasses_mouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		11 July 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if listbox.listIndex &lt;&gt; CNEC_NULL_INDEX then
		if button = Window.MouseButton_Right then
			popupMenu(mnuPopup, (x.Integer + listbox.left.Integer), (y.Integer + listbox.top.Integer));
		endif;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="lstClasses_pictureClick" id="d625bbe9-b346-4c04-ae78-2fd7e5449fff">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstClasses_pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 13/2/1999	cnwdad1		The class list box is no longer fully populated at once,
//							but instead subclasses are only loaded when the folder
//							is opened by the User.
//
// --------------------------------------------------------------------------------
begin
	if (not listbox.itemExpanded[picIndex])
	and ((picIndex + 1) &lt;= listbox.listCount)
	and (listbox.itemText[picIndex + 1] = self.DUMMY_FOLDER)
	and (listbox.itemObject[picIndex].Class.hasSubclasses)
	then
		self.statusMsg("Loading classes...");
		self.loadSubClasses(listbox.itemObject[picIndex].Class, (listbox.itemLevel[picIndex] + 1));
	endif;

	listbox.itemExpanded[picIndex]	:=	(not listbox.itemExpanded[picIndex]);
epilog
	self.statusMsg("");
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mnuPopupBrowse_click" id="7f19efcd-49e3-4d6b-90c7-77851a5525e3">
