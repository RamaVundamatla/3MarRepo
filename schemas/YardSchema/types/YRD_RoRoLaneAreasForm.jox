    <JadeMethod name="showCargoPicture" id="2baac000-591e-4512-8381-ef368dff6802">
        <source>showCargoPicture(_theTI : CM_TrackedItem) : Binary;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	thePicture : Binary;
begin
	
	
	if _theTI = null then
		return null;
	endif;
 	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
 		return null;
 	endif;

	thePicture := _theTI.getPicture;
