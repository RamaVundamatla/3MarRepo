    <JadeMethod name="setAllCriteria" id="6329365e-4252-4393-bb4a-02678a3ed1ef">
        <source>setAllCriteria(_queue : CM_RadioTelemetryQueue);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 October 2025		jlizm1	Initial creation MTN 35861 RTQueue configuration - cargo attribute criteria

*/

vars
	crit 			: CM_YACriteria;
	pxyCrit			: CM_YARTQueueCriteria;
	cmifCriteria	: CMIF_YACriteriaPriority;
	code 			: String;
	value 			: Any;
	
begin
	if self.allCriteria.size &gt; 0 then
		self.allCriteria.purge;	
	endif;
	
	if _queue = null then
		return;
	endif;
	
	if _queue.allCriteria.isEmpty then
		return;
	endif;
	
	foreach crit in _queue.allCriteria do

		create pxyCrit transient;
		code := crit.myYACriteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		value := crit.myYAData.getDataValue();
		pxyCrit.setProxy(crit.myYACriteriaType, value, code);
		cmifCriteria := pxyCrit.getTransient();
		self.allCriteria.add(cmifCriteria);

	endforeach;
	
epilog

end;</source>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="4e01c0d8-392d-4d24-bdf5-c1d206060820">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
//--------------------------------------------------
// Created:	15 April 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpBackColour 			: Integer;

begin
	inheritMethod(_colorControl);

	tmpBackColour := self.backColor;
	
	self.grpAreasCovered1.backColor := tmpBackColour;
	self.grpAreasCovered2.backColor := tmpBackColour;
	self.grpMachineTypeGr.backColor	:= tmpBackColour;
	self.grpBaysCovered.backColor	:= tmpBackColour;
	self.setColorsForEntryTable(self.tblMain);
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="dea19e1c-97ef-490d-9844-b6d875903aa6">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/10/2025	jlizm1		MTN 35861 RTQueue configuration - cargo attribute criteria
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();

	self.btnEditCTA.enabled:=false;
	
	if self.mode = Mode_Add then
		self.tblMain.clearValues();
		self.tblMain.userInputEnabled := true;
	//	self.cmbType.setIndexForItemData(QTYPE_SUBQUEUE); //epr TFS 2344 28/7/16
	//	self.cmbType.click(self.cmbType);
	//	self.cmbParent.click(self.cmbParent);	
		self.grpAreasCovered1.multiClear();
		self.grpAreasCovered2.multiClear();
		self.grpMachineTypeGr.clearSelected();
		self.grpBaysCovered.clearSelected();
		self.tblMain.enableRowByName(ETRow_Type);
		self.shtFromAreas.caption := 'From Terminal Areas';
		self.shtToAreas.caption := 'To Terminal Areas';
		self.cmbCranes.clear();	
		self.optGetNext1.value := true;
		self.optGetNext1.click(self.optGetNext2);	
		self.optGetNext2.value := true;
		self.optGetNext2.click(self.optGetNext2);
		self.grpFrmLocations.multiClear();
		self.grpToLocations.multiClear();
		self.allCriteria.purge();
		
		self.cmbType.setIndexForItemData(QTYPE_SUBQUEUE); //28 Oct 2016	NDL	TFS - click populates, needs to be after the grpArea clear stuff
		self.cmbType.click(self.cmbType);
		self.cmbParent.click(self.cmbParent);

	else
		self.tblMain.userInputEnabled := true;	
		self.tblMain.disableRowByName(ETRow_Type);
				
	endif;
	self.grpAreasCovered1.userInputEnabled	:= true;
	self.grpAreasCovered2.userInputEnabled	:= true;
	self.grpMachineTypeGr.userInputEnabled	:= true;
	self.grpFrmLocations.userInputEnabled	:= true;
	self.grpToLocations.userInputEnabled	:= true;
	self.grpBaysCovered.userInputEnabled 	:= true;
	self.grpBaysCovered.userInputEnabled 	:=true;
	
	self.myDataClass := CM_SubQueue;
	//self.tblMain.setFocus();
	self.tblMain.moveFirst();
	self.fldDetailsTop.initSheetBackColors();
	
end;</source>
    </JadeMethod>
