    <JadeMethod name="loadCombos" id="8e8d6640-d4a7-4eba-acd2-58a954751e66">
        <source>loadCombos();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21/03/2013	cnwrd1	Initial creation
20/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk
*/

vars

begin
	self.myForm.cmbMeasureUnit.clear;
	
	self.myForm.cmbMeasureUnit.addItem(Type_Density);
	self.myForm.cmbMeasureUnit.addItem(Type_Displacement);
	self.myForm.cmbMeasureUnit.addItem(Type_Linear);
	self.myForm.cmbMeasureUnit.addItem(Type_StowageFactor);
	self.myForm.cmbMeasureUnit.addItem(Type_Temperature);
	self.myForm.cmbMeasureUnit.addItem(Type_Volume);
	self.myForm.cmbMeasureUnit.addItem(Type_Weight);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="bcd47980-db4d-4a72-819e-1db44cabb244">
        <updating/>
        <source>setControlsForAddEdit() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 February 2013	cnwrd1	Initial creation

*/

vars
	theForm : SOP_TableMaintForm;
begin
  
    theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.mulSelect1.userInputEnabled := true;
	theForm.mulSelect2.userInputEnabled := true;
	theForm.mulSelect3.userInputEnabled := true;
	theForm.mulSelect6.userInputEnabled := true;	
	theForm.btnSetDefault1.enabled := false;
	theForm.btnSingle1Edit.enabled:=true;
	theForm.btnSingle1Delete.enabled:=true;
	theForm.btnSingle1New.enabled:=true;
	theForm.btnSingle1Down.enabled:=true;
	theForm.btnSingle1Up.enabled:=true;
	
	self.loadCombos();
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_ShortName);
		theForm.tblInput1.enableRowByName(ETRow_Conversion);
		theForm.tblInput1.enableRowByName(ETRow_Unit);
		theForm.mulSelect1.setSelected(null);
		theForm.mulSelect2.setSelected(null);
		theForm.mulSelect3.setSelected(null);
		theForm.mulSelect6.setSelected(null);
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);		

	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_MeasurementType);
		// for system items, cannot change short name, conversion or unit
		if theForm.myProxyObject.CM_MeasurementType.isSystemType then
			theForm.tblInput1.disableRowByName(ETRow_ShortName);
			theForm.tblInput1.disableRowByName(ETRow_Conversion);
			
		else
			theForm.tblInput1.enableRowByName(ETRow_ShortName);
			theForm.tblInput1.enableRowByName(ETRow_Conversion);
			
		endif;
		theForm.tblInput1.disableRowByName(ETRow_Unit); //epr par 34850 21/11/14
		//cnwmc5 - 16 Dec 2013 - PAR 33203
		if theForm.myProxyObject.CM_MeasurementType.isFeetAndInches then
			theForm.tblInput1.disableRowByName(ETRow_Format);
		else
			theForm.tblInput1.enableRowByName(ETRow_Format);
		endif;
		
		// for a default measurement, cannot make it unavailable
		if theForm.myProxyObject.CM_MeasurementType.isDefault then
			theForm.tblInput1.disableRowByName(ETRow_Available);
		else
			theForm.tblInput1.enableRowByName(ETRow_Available);
		endif;
	endif;

	theForm.tblInput1.cnEcResizeContents();
	theForm.tblInput1.setFocus;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="2497804d-e1ef-4dd1-8af6-5cd31177940b">
