    <JadeMethod name="comboBoxHMSMoveType" id="72aaecb9-d3a6-46f8-adc7-c4c25233829f">
        <source>comboBoxHMSMoveType(pTbl : CM_EntryTable input; pAttrName : String; _moveType : String);
//--------------------------------------------------
// Created:	April 2004 By: cnwgd1
//--------------------------------------------------
vars
	row : Integer;
	str	: String;
begin
	
	row := pTbl.getRow(pAttrName);

	if (not pTbl.isValidRow(row)) then
		return;
	endif;
			
	str := app.getErrorString(AnyType) &amp; Tab &amp; 
			HMSMovementTypeArrival &amp; Tab &amp; 
			HMSMovementTypeDeparture &amp; Tab &amp;
			HMSMovementTypeShift;	

	pTbl.setComboValues(row, str);
	
	if _moveType = app.getErrorString(AnyType) or
	_moveType =	HMSMovementTypeArrival or
	_moveType =	HMSMovementTypeDeparture or
	_moveType =	HMSMovementTypeShift or
	_moveType =	null then
		pTbl.setValue(row, _moveType);		
	endif;
	
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="_moveType" type="String"/>
    </JadeMethod>
