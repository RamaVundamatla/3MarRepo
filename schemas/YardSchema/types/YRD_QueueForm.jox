    <JadeMethod name="doAllocateMachineToTask" id="949fc8ef-6d17-4d98-9d2d-05313c98dc67">
        <updating/>
        <source>doAllocateMachineToTask(pMachine : CM_Machine input) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------

vars
	loadStateSet : Boolean;
	lReturn : Integer;
	lRealTask, lProxyTask : CM_RTQueueTask;
	entry : CM_RTQueueEntry;
	allErrors : CM_ErrorSet;
	error : CM_Error;
	allSelectedEntries : CM_RTQueueEntryArray;
	sendMessage : Boolean;
begin
	if not pMachine.loggedOn then
		lReturn :=  app.msgBox(app.getErrorString1(ERR_MACH_NOTLOGGED, pMachine.id),"Allocate",MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon);
		if lReturn = MsgBox_Return_No then
			return;
		endif;
	endif;

	//28/02/2011 cnwdz2 27073 start
	if  self.allSelectedRTQEntries.isEmpty then
		app.msgBox(app.getErrorString(Please_select_task),"Allocate",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create allSelectedEntries transient;
	self.allSelectedRTQEntries.copy(allSelectedEntries);
	
	//only send machine message if it doesn't allocated tasks
	sendMessage:=pMachine.allAllocatedQueueTasks.isEmpty;
	
	create allErrors transient;
	foreach entry in allSelectedEntries   do 
		lRealTask:=entry.getFirstUncompletedTask();	
		if lRealTask = null then
			continue;
		endif;
		delete lProxyTask;
		//28/02/2011 cnwdz2 27073 end
		app.cmsBeginLoad(loadStateSet);
		lProxyTask := lRealTask.pxyCreateUpdateProxy();
		app.cmsEndLoad(loadStateSet);
		lProxyTask.setProxyAllocMachine(pMachine, lRealTask.myEntry, lRealTask.sourceLocation, lRealTask.targetLocation, lRealTask.ti);
		
		//epr par 23174 17/3/10 needed to be in a loop to give users a chance to respond to warnings
		while true do 
			app.myTrxUA.trxUpdateTaskAllocateMachine(lProxyTask,false,app.myPassport);
			if not app.myPassport.trxCompletedOK then
				if app.myPassport.noErrors then
					lReturn:=app.showErrorWarningDialog('Allocate', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   lReturn = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				app.myPassport.allErrors.copyNoDuplicates(allErrors,false);
				foreach error in allErrors do
					error.setMyErrorPassport(null);
				endforeach;
				break;
			endif;
			break;
		endwhile;
	endforeach;
	
	//important that this note is sent after the entry updates
	if sendMessage and not pMachine.allAllocatedQueueTasks.isEmpty then
		pMachine.sendBroadcastMessage("Control have ALLOCATED NEXT TASK.", true);
	endif;
		
	if allErrors.size &gt; 0 then
		app.myPassport.addErrorsFromSet(allErrors);
		app.showErrorWarningDialog('Allocate', app.myPassport, ErrWarnMode_Add);
	endif;
	

	
epilog
	app.cmsEndLoad(loadStateSet);		// 08/04/2011 cnwmh5 #27347
	delete lProxyTask;
	delete allErrors;
	delete allSelectedEntries;

end;</source>
        <Parameter name="pMachine" type="CM_Machine" usage="input"/>
    </JadeMethod>
