<Class name="CM_SnapshotField_Min" id="ed732d6c-aa12-46fa-9a73-ebb44d4c6a09">
    <superclass name="CM_SnapshotField"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="snapshots"/>
    <PrimAttribute name="min" id="ec5f169f-803e-452d-b460-d94de5f3b351">
        <precision>23</precision>
        <scaleFactor>8</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValue" id="cc92541b-d0c1-44c7-b727-11abd60b001f">
        <source>getValue(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwndl1	Initial creation

*/

vars
	value	:Decimal[23,8];
begin
	value := self.min;		
	
	if value = 0 then		
		return null;		
	endif;					
	
	return value.roundedTo (self.decimals).asStringJMTWithPrecision (self.decimals, self.useSeperator);	// cnwcs5 07/12/2009

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXTABFieldFunction" id="8fbf5282-3bb5-4bce-b710-1e3f9451b259">
        <source>getXTABFieldFunction(): Integer;
// ---------------------------------------------------------------------------
// Created:     10 December 2009 by cnwcs5:1
// Purpose:     ccms 1023 - snapshot summaries 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return CM_XTABField.Function_Min;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFromCmifAndXtabFields" id="cc175417-c34a-4ae0-8d1a-96cf49837bb1">
        <updating/>
        <source>setFromCmifAndXtabFields(_cmifField: CMIF_OutputField; _xtabField: CM_XTABField) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin

	inheritMethod(_cmifField, _xtabField);
	
	self.min := _cmifField.CMIF_OutputField_Min.min;

epilog

end;</source>
        <Parameter name="_cmifField" type="CMIF_OutputField"/>
        <Parameter name="_xtabField" type="CM_XTABField"/>
    </JadeMethod>
</Class>
