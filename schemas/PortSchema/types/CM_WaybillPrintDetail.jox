    <JadeMethod name="setProxy" id="ac10da7d-2462-46c7-88ac-03c363157608">
        <updating/>
        <source>setProxy(	_vvr : CM_VehicleVisitRecord ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2015	cnwndl1	Initial creation	Par 36777
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

constants
	
vars
	term : CM_Terminal;
	nullVoyage : CM_Voyage;
	reportCode : String;
	date : Date;
	now : TimeStamp;
	releaseSet : CM_TISet;
	ti : CM_TrackedItem;
	containerSet : CM_TISet;
	unpackedFrom : CM_TrackedItem;

begin

	term := _vvr.myTerminal;
	nullVoyage :=  term.getNullVoyage;
	reportCode := app.getErrorString(Waybill_report_code); // "WBL"
	now := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	create releaseSet transient;
	if _vvr.status &lt; CM_VehicleVisitRecord.Status_Complete then
		self.isProForma := true;
		_vvr.getAllLoadedCargo( releaseSet );
	else
		foreach ti in _vvr.allReleasedTrackedItems do
			releaseSet.addNoDuplicates( ti, false );
		endforeach;
	endif;
	
	//convert the releaseSet to a list of containers or the parent containers
	create containerSet transient;
	foreach ti in releaseSet do
		if ti.isContainer then
			containerSet.addNoDuplicates( ti, false );
		else
			unpackedFrom := null;
			unpackedFrom := ti.getMyUnpackedFromContainer();
			if unpackedFrom &lt;&gt; null and unpackedFrom.isContainer then
				containerSet.addNoDuplicates( unpackedFrom, false );
			endif;
		endif;
	endforeach;
			
	
	//1
	self.waybillNumberStr := term.code &amp; "-" &amp; reportCode &amp; "-" &amp; _vvr.visitNumber;
	//2
	self.setWaybillDateStr( _vvr, now.date );
	//3
	self.setConsigneeStr( containerSet, CrLf);
	//4
	self.setDebtorLongNameStr( containerSet, ", " );
	//5
	self.setVesselStr( containerSet, nullVoyage, ", " );
	//6
	self.setRotationNumberStr( containerSet, nullVoyage, ", " );
	//7
	self.setReleaseDateStr( containerSet, nullVoyage, ", " );
	//8
	self.setBillOfLadingNumberStr( containerSet, ", " );
	//9
	self.setVesselArrivalDateStr( containerSet, nullVoyage, ", " ); 
	//10
	self.setDeliveryOrderNumberStr( containerSet, nullVoyage, ", " );
	//11
	self.setBillOfEntryNumberStr( containerSet, ", " );
	//12
	self.setAgentsOperativeStr( containerSet, ", " );
	//13
	self.setOperativeIdNumberStr( containerSet, ", " );
	//14
	if _vvr.myDriverDetails &lt;&gt; null then
		self.driversNameStr := _vvr.myDriverDetails.name;
	endif;
	//15
	if _vvr.myDriverDetails &lt;&gt; null then
		self.vehicleRegistrationNumberStr := _vvr.myDriverDetails.secondaryCode; //yep spec says secondary code of driver is registration.  Go figure
	endif;
	//16
	self.setReleaseInstructionsStr( containerSet, ", " );
	//17
	//self.driversLicenseNumberStr := //*** NOT REQUIRED ***
	//18
	//self.placeOfLoadingStr := //*** NOT REQUIRED ***
	//19
	self.tallyClerk := app.getMyUser.userName;
	//20
	self.setContainerNumberStr( containerSet, ", " );
	//21
	self.setNumberOfPackagesStr( releaseSet ); 
	//22
	//self.packageTypeStr := //*** NOT REQUIRED ***
	//23
	//self.loadingCommencedStr := //*** NOT REQUIRED ***
	//24
	//self.loadingCompletedStr := //*** NOT REQUIRED ***
	//25
	self.setRemarksStr( containerSet, CrLf );
	//26
	self.setGoodsDescriptionStr( releaseSet, ", " );
	//27
	self.setMarksAndNumbersStr( releaseSet, ", " );
	//28
	//self.vehicleExitStr := //*** NOT REQUIRED ***
	//29
	//self.checkedBy := //*** NOT REQUIRED ***
	//30
	self.pdf147BarcodeStr := self.billOfEntryNumberStr &amp; '|' &amp; self.waybillNumberStr &amp; '|' &amp; self.vehicleRegistrationNumberStr &amp; '|' &amp; self.rotationNumberStr;
	self.setPdf147BarcodePic();
	//31
	//  PROFORMA is derived via method "titleStr"
	//32
	self.printDateTimeStr := now.Date.format("dd-MMM-yyy");
	

epilog

	delete containerSet;
	delete releaseSet;

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setReleaseDateStr" id="d44933e9-f9fc-48e0-bec1-8fd73425b173">
        <updating/>
        <source>setReleaseDateStr( _tiSet : CM_TISet; _nullVoyage: CM_Voyage; _delim : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	bolNumber : String;
	voyage : CM_Voyage;
	allBols : CM_BOLSet;
	ti : CM_TrackedItem;
	completeStr : String;
	bol : CM_BOL;
	bolRelDate : Date;

begin

	create allBols transient;
	
	foreach ti in _tiSet do
		bolNumber := ti.billOfLading;
		if bolNumber.trimBlanks = null then
			continue;
		endif;
		voyage := ti.myVoyage;
		if voyage = null or voyage = _nullVoyage then
			continue;
		endif;
		bol := voyage.getBOL(bolNumber);
		if bol &lt;&gt; null then
			allBols.addNoDuplicates( bol, false );
		endif;
	endforeach;
	
	foreach bol in allBols do
		bolRelDate  := bol.getDateShippingLineStopRemoved();
		if bolRelDate &lt;&gt; null and bolRelDate.isValid then
			if completeStr = null then
				completeStr := bolRelDate.format("dd-MMM-yyy");
			else
				completeStr := completeStr &amp; _delim &amp; bolRelDate.format("dd-MMM-yyy");
			endif;
		endif;
	endforeach;
	
	self.releaseDateStr := completeStr;

epilog

	delete allBols;

end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_nullVoyage" type="CM_Voyage"/>
        <Parameter name="_delim" type="String"/>
    </JadeMethod>
    <JadeMethod name="setReleaseInstructionsStr" id="6430562f-45d6-40e5-9035-867f9baa505b">
        <updating/>
        <source>setReleaseInstructionsStr( _containerSet : CM_TISet; _delim : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	commodity : CM_Commodity;
	allRelInstructions : StringArray;
	ti : CM_TrackedItem;
	upperCode : String;
	relStr : String;
	completeStr : String;

begin

	create allRelInstructions transient;
	
	if app &lt;&gt; null then
	
		foreach ti in _containerSet do
			commodity := ti.getCommodityObject();
			if commodity = null then
				continue;
			endif;
			upperCode := commodity.code.toUpper;
			if upperCode.length &lt; 2 then
				continue;
			endif;
			if upperCode[1:2] = "US" then
				relStr := app.getErrorString(Unstuffing);
			elseif upperCode[1:2] = "DD" then
				relStr := app.getErrorString(Direct_delivery);
			else
				continue;
			endif;
			if not allRelInstructions.includes( relStr ) then
				allRelInstructions.add( relStr );
			endif;
		endforeach;
		
		foreach relStr in allRelInstructions do	
			if completeStr = null then
				completeStr := relStr;
			else
				completeStr := completeStr &amp; _delim &amp; relStr;
			endif;
		endforeach;
	
	endif;
	
	self.releaseInstructionsStr := completeStr;

epilog

	delete allRelInstructions;

end;</source>
        <access>protected</access>
        <Parameter name="_containerSet" type="CM_TISet"/>
        <Parameter name="_delim" type="String"/>
    </JadeMethod>
    <JadeMethod name="setRemarksStr" id="d577084c-1fa6-4556-ad36-d8099f442e63">
        <updating/>
        <source>setRemarksStr( _containerSet : CM_TISet; _delim : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	numArray : IntegerArray;
	isoTypeArray : StringArray;
	ti : CM_TrackedItem;
	cont : CM_Container;
	isoTypeStr : String;
	isoType : CM_ISOType;
	pos : Integer;
	contTypeStr : String;
	completeStr : String;

begin

	create isoTypeArray transient;
	create numArray transient;
	
		foreach ti in _containerSet do
			cont := ti.CM_Container;
			isoType := cont.getISOTypeObject;
			if isoType = null then 
				continue;
			endif;
			isoTypeStr := isoType.code &amp; " " &amp; isoType.description;
			if not isoTypeArray.includes( isoTypeStr ) then
				isoTypeArray.add( isoTypeStr );
				numArray.add(1);
			else
				pos := isoTypeArray.indexOf( isoTypeStr );
				numArray[pos] := numArray[pos] + 1;
			endif;
		endforeach;
		
	if not isoTypeArray.isEmpty then
		foreach pos in 1 to isoTypeArray.size do
			contTypeStr := numArray[pos].String &amp; "x" &amp; isoTypeArray[pos];
			if completeStr = null then
				completeStr := contTypeStr;
			else
				completeStr := completeStr &amp; _delim &amp; contTypeStr;
			endif;
		endforeach;
	endif;
	
	self.remarksStr := completeStr;

epilog

	delete numArray;
	delete isoTypeArray;

end;</source>
        <access>protected</access>
        <Parameter name="_containerSet" type="CM_TISet"/>
        <Parameter name="_delim" type="String"/>
    </JadeMethod>
    <JadeMethod name="setRotationNumberStr" id="679353f8-db25-4fdf-9502-3d5691a4475d">
        <updating/>
        <source>setRotationNumberStr( _tiSet : CM_TISet; _nullVoyage: CM_Voyage; _delim : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	voyage : CM_Voyage;
	allVoyages : CM_VoyageSet;
	ti : CM_TrackedItem;
	inwardCode : String;
	completeStr : String;

begin

	create allVoyages transient;
	
	foreach ti in _tiSet do
		voyage := ti.myVoyage;
		if voyage = null or voyage = _nullVoyage then
			continue;
		endif;
		allVoyages.addNoDuplicates( voyage, false );
	endforeach;
	
	foreach voyage in allVoyages do
		inwardCode  := voyage.inwardCode;
		if inwardCode.trimBlanks &lt;&gt; null then
			if completeStr = null then
				completeStr := inwardCode;
			else
				completeStr := completeStr &amp; _delim &amp; inwardCode;
			endif;
		endif;
	endforeach;
	
	self.rotationNumberStr := completeStr;

epilog

	delete allVoyages;

end;</source>
        <access>protected</access>
