    <JadeMethod name="validateMe" id="a7203274-e8e9-41a1-be8b-51b464ba687a">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'ShippingLine Code', null, null);
		app.raiseCMException(Input_required_field_shipLine, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'ShippingLine Description', null, null);
		app.raiseCMException(Input_required_field_shpLneDes, null, null); // cnwdb2	PAR 35364
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
