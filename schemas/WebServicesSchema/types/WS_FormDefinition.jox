    <JadeMethod name="buildMandatoryFields" id="219a743c-2751-4a55-bee8-96a26ada946c">
        <source>buildMandatoryFields(madatoryFields : StringArray);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2009	#cnwdz2	 

*/

vars
	rowName			: String;
	fieldDef		: WS_FieldDefinition;
begin
	foreach rowName in madatoryFields do
		fieldDef := self.allFormFieldsByKey.getAtKey(rowName);
		fieldDef.isMandatory := true;	
	endforeach;
epilog

end;</source>
