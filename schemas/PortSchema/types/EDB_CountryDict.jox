<ExternalCollClass name="EDB_CountryDict" id="dafaf2ea-fac2-419e-b124-c42180420fc8">
    <externalDatabase name="EDB_PortDss"/>
    <includesPredicate>( ( country."code" = ? ) AND ( country."description" = ? ) AND ( country."edition" = ? ) AND ( country."oid" = ? ) )</includesPredicate>
    <includesPredicateInfo>AQAAAAIAAAADAAAABAAAAA==</includesPredicateInfo>
    <keyEqPredicate>( country."oid" = ? )</keyEqPredicate>
    <keyEqPredicateInfo>AQAAAA==</keyEqPredicateInfo>
    <keyGeqPredicate>( country."oid" &gt;= ? )</keyGeqPredicate>
    <keyGeqPredicateInfo>AQAAAA==</keyGeqPredicateInfo>
    <keyGtrPredicate>( country."oid" &gt; ? )</keyGtrPredicate>
    <keyGtrPredicateInfo>AQAAAA==</keyGtrPredicateInfo>
    <keyLeqPredicate>( country."oid" &lt;= ? )</keyLeqPredicate>
    <keyLeqPredicateInfo>AQAAAA==</keyLeqPredicateInfo>
    <keyLssPredicate>( country."oid" &lt; ? )</keyLssPredicate>
    <keyLssPredicateInfo>AQAAAA==</keyLssPredicateInfo>
    <orderByList>country."oid" ASC </orderByList>
    <memberType name="EDB_Country"/>
    <superclass name="ExternalDictionary"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
