    <JadeMethod name="zRoadExample60793" id="ab0e828d-1850-40c0-8c3e-94a872883c06">
        <source>zRoadExample60793(_type : String ;_mode : String; _clientRef : String; _vbsID : String; _itemPrefix : String; _itemsCount : Integer) : String;
//
// Purpose:		Load test for Road manifest	
