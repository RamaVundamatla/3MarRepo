		dateTime.setDate(self.txtDateBox.getDate());
		dateTime.setTime(self.txtEffectiveTime.getTime());
		if dateTime &gt; now then
			app.msgBox(app.getErrorString(RetrospectiveOperations), 'Retrospective Date', MsgBox_Stop_Icon + MsgBox_OK_Only);
		endif;
	else
		self.txtDateBox.setDate(now.date);
		self.txtEffectiveTime.setTime(now.time);
		self.txtDateBox.enabled := false;
		self.txtEffectiveTime.enabled := false;
