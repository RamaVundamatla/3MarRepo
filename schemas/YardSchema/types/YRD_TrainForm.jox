vars
	mode : Integer;
begin
	mode := YRD_TrainWagonForm.Mode_Update;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		mode := YRD_TrainWagonForm.Mode_View;

	endif;

	self.doEditViewWagon(mode); //+ cnwmd1, CCMS 1067, Par 19913
end;


</source>
