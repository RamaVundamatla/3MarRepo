    <JadeMethod name="reset" id="f7dab984-9ecd-4b56-9584-6865ce08543d">
        <updating/>
        <source>reset() updating;
// ---------------------------------------------------------------------------
// Created:     17 September 2003	cnwth2
//
// Purpose:     
// 27 May 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 23 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.id := null;
	self.allQryTIs.clear();
	self.terminalAreaTypes.clear();
	self.allTerminals.clear();
	self.allQryTIs.clear();
	self.setMyLoadPort( null );
	self.setMyPort( null );
	self.setMyProduct( null );
	self.mySiteState := null;
	self.setMyVoyage( null );
	self.saveToWorkList := false;
	self.setMyShippingLine(null);	// 27.05.2022 navak20 TFS 53204
	self.setCountryOfOrigin(null);	// 23.08.2022 navak20 TFS 54441
end;</source>
    </JadeMethod>
