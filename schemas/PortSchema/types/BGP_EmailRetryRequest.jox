<Class name="BGP_EmailRetryRequest" id="5fe20faf-d859-4ea9-a7e9-5ea17f54aa90">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Email(Retry Failed Emails)&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="action" id="959b7029-a644-417e-820e-dc22969f2e0a">
        <updating/>
        <source>action(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 January 2023	navmd1	Initial creation TFS 55020 OAuth Email Enhancements

*/

vars
	errCode				: Integer;
	errTxt				: String;
begin
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, false);
	on LockException do app.alertLockExceptionHandler(exception);

	self.setUser();
	
	app.writeLog(method.qualifiedName &amp; " called!", LogINFO);

epilog
	inheritMethod();
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
