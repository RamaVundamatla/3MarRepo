    <JadeMethod name="doScrollToCorners" id="27df2ac3-1a2f-4965-ba28-34b79dbbe44b">
        <source>doScrollToCorners(_corner : Integer);

/*

Purpose:			Scroll the receiver to the selected corner

Parameters:			Integer value from ViewMode category

Return Value:		None


Date		Who		Reason
28 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

begin
	if self.myScrollableFrame = null then
		return;
	endif;
	
	if _corner = VIEW_LEFT_TOP then
		self.myScrollableFrame.scrollTopLeft();
	elseif _corner = VIEW_RIGHT_TOP then
		self.myScrollableFrame.scrollTopRight();
	elseif _corner = VIEW_LEFT_BOTTOM then
		self.myScrollableFrame.scrollBottomLeft();
	elseif _corner = VIEW_RIGHT_BOTTOM then
		self.myScrollableFrame.scrollBottomRight();
	endif;


epilog

end;</source>
        <Parameter name="_corner" type="Integer"/>
    </JadeMethod>
