    <JadeMethod name="getRepMethodInFullTree" id="21123250-94aa-42dd-bb3c-a66f1402891c">
        <source>getRepMethodInFullTree(name: String): Method;

// returns a method from a superclass or subclass.
// it only returns a method from a subclass if all methods with the same name
// in distinct subclasses have the same number, type and length of parameters and the
// same return type.
vars
	allmeths:        MethodSet;
	retType:         Type;
	length:          Integer;
	params:          ParameterColl;
	paramIndex:      Integer;
	aMethod:         Method;
	theMethod:       Method;
	index:           Integer;
begin
	create allmeths transient;

	getMethodsInFullTree(name, allmeths);

	if allmeths.size = 0 then
		return null;
	elseif allmeths.size = 1 then
		return allmeths.first;
	else
		// determine consistency
		index := 1;
		foreach aMethod in allmeths do
			if index = 1 then
				params := aMethod.getParameters;
				retType := aMethod.getTypeOfReturnType;
				length := aMethod.returnType.length;
				theMethod := aMethod;
			else
				if aMethod.getTypeOfReturnType &lt;&gt; retType then
					return null;
				elseif aMethod.getParameters.size &lt;&gt; params.size then
					return null;
				else
					// check parameters 
					foreach paramIndex in 1 to params.size do
						if aMethod.getParameters[paramIndex].type &lt;&gt; params[paramIndex].type or
							aMethod.getParameters[paramIndex].length &lt;&gt; params[paramIndex].length then
							return null;
						endif;
					endforeach;
				endif;
			endif;
			index := index + 1;
		endforeach;
	endif;

epilog
	delete allmeths;
end;
</source>
        <Parameter name="name" type="String"/>
        <ReturnType type="Method"/>
    </JadeMethod>
    <JadeMethod name="getRepMethodsInFullTree" id="e336c2c6-c53d-41da-8d46-dcffbf695ba5">
        <source>getRepMethodsInFullTree(name: String; methds: MethodSet input);

// returns a method from a superclass or subclass.
// it only returns a method from a subclass if all methods with the same name
// in distinct subclasses have the same number, type and length of parameters and the
// same return type.
vars
	retType:         Type;
	length:          Integer;
	params:          ParameterColl;
	paramIndex:      Integer;
	aMethod:         Method;
	theMethod:       Method;
	index:           Integer;
begin
	getMethodsInFullTree(name, methds);

	if methds.size &gt; 1 then
		// determine consistency
		index := 1;
		foreach aMethod in methds do
			if index = 1 then
				params := aMethod.getParameters;
				retType := aMethod.getTypeOfReturnType;
				length := aMethod.returnType.length;
				theMethod := aMethod;
			else
				if aMethod.getTypeOfReturnType &lt;&gt; retType then
					methds.clear;
					break;
				elseif aMethod.getParameters.size &lt;&gt; params.size then
					methds.clear;
					break;
				else
					// check parameters 
					foreach paramIndex in 1 to params.size do
						if aMethod.getParameters[paramIndex].type &lt;&gt; params[paramIndex].type or
							aMethod.getParameters[paramIndex].length &lt;&gt; params[paramIndex].length then
							methds.clear;
							break;
						endif;
					endforeach;
				endif;
			endif;
			index := index + 1;
		endforeach;
	endif;

epilog
end;</source>
        <Parameter name="name" type="String"/>
        <Parameter name="methds" type="MethodSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRepPropertiesInFullTree" id="5e6bc595-98bf-4778-813e-df261377da87">
        <source>getRepPropertiesInFullTree(name: String; props: PropertySet input);

// returns a property from a superclass or subclass.
// it only returns a property from a subclass if all properties with the same name
// in distinct subclasses have the same type.
// Different lengths are allowed e.g. String[10] and String[20] where longest
// property is returned.
// a rep
vars
	type:            Type;
	length:          Integer;
	aProperty:       Property;
	theProperty:     Property;
begin
	getPropertiesInFullTree(name, props);

	if props.size &gt; 1 then
		// determine consistency
		foreach aProperty in props do
			if type = null then
				type := aProperty.type;
				length := aProperty.getLength;
				theProperty := aProperty;
			else
				if aProperty.type &lt;&gt; type then
					// inconsistent set of properties so clear collection
					props.clear;
					break;
				elseif aProperty.getLength &gt; theProperty.getLength then
					theProperty := aProperty;
				endif;
			endif;

		endforeach;
	endif;
end;</source>
        <Parameter name="name" type="String"/>
        <Parameter name="props" type="PropertySet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRepPropertyInFullTree" id="d25774ac-37da-49ba-b0fa-0604bf44c812">
        <source>getRepPropertyInFullTree(name: String): Property;

// returns a property from a superclass or subclass.
// it only returns a property from a subclass if all properties with the same name
// in distinct subclasses have the same type.
// Different lengths are allowed e.g. String[10] and String[20] where longest
// property is returned.
// a rep
vars
	allprops:        PropertySet;
	type:            Type;
	length:          Integer;
	aProperty:       Property;
	theProperty:     Property;
begin
	create allprops transient;

	getPropertiesInFullTree(name, allprops);

	if allprops.size = 0 then
		return null;
	elseif allprops.size = 1 then
		return allprops.first;
	else
		// determine consistency
		foreach aProperty in allprops do
			if type = null then
				type := aProperty.type;
				length := aProperty.getLength;
				theProperty := aProperty;
			else
				if aProperty.type &lt;&gt; type then
					return null;
				elseif aProperty.getLength &gt; theProperty.getLength then
					theProperty := aProperty;
				endif;
			endif;

		endforeach;
	endif;

epilog
	delete allprops;
end;</source>
        <Parameter name="name" type="String"/>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="getStringPropertyLength" id="7a5142a1-1f81-409c-ba6b-59f577cf12f7">
        <source>getStringPropertyLength(propName : String) : Integer;

// djc, 17 Aug 2000
// Returns the length (in character units) of the requested string property.
// Returns zero if the property doesn't exist, or if the property is not a
// string attribute. Unbounded slobs will return a negative length.

vars
	prop : Property;
	cls : Class;
	
begin
	cls := self;
	while cls &lt;&gt; null do
		prop := cls.rootType.properties[propName];
		if prop &lt;&gt; null and prop.isKindOf(Attribute) and prop.type = String then
			if app.isUnicode then
				return (prop.getLength div 2) - 1;
			endif;
			return prop.getLength - 1;
		endif;
		cls := cls.superclass;
	endwhile;
	return 0;
end;</source>
        <Parameter name="propName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSubclassByName" id="5586edbd-03c4-48b8-88e1-188e79cda5c3">
        <source>getSubclassByName(_clsName : String) : Class;
// ---------------------------------------------------------------------------
// Created:     13 March 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ccDict	: ClassNDict;
begin

	create ccDict transient;
	self.getAllSubclassesAnywhere(ccDict);
	
	return ccDict[_clsName];

epilog
	delete ccDict;

end;</source>
        <Parameter name="_clsName" type="String"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getUserFriendlyName" id="19c37846-6c96-4d17-86d5-c6773d73d0f5">
        <source>getUserFriendlyName(): String;
//----------------------------------------------------------------
//	Created:	May 2006 cmwrs1
//  Turn CM_ReleaseJob to 'Release Job' etc
//----------------------------------------------------------------
vars
	idx : Integer;
	myName : String;
	str : String;
	name : String;
	ch : Character;
	last : Boolean;
begin
	myName :=  self.name;
	idx := myName.pos("_",1) + 1;
	str := myName[idx:end];
	foreach idx in 1 to str.length do
		if idx &gt; 1 and idx &lt; str.length and str[idx] &lt;&gt; str[idx].toUpper() and str[idx+1] = str[idx+1].toUpper() then
			name := name  &amp; str[idx]&amp; ' '; //lower case char followed by Capital so add blank after last lower case char
		elseif idx &gt; 2 and idx &lt; (str.length) and str[idx-1] = str[idx-1].toUpper() and str[idx] = str[idx].toUpper() and str[idx+1] &lt;&gt; str[idx+1].toUpper() then
			name := name &amp; ' ' &amp; str[idx]; //Capital char preceeded by Capital which is followed by lower case so add blank after last lower case char
		else
			name := name &amp; str[idx];
		endif;
	endforeach;
	return name;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isSubclassOf" id="5f0cfbce-9c10-4bed-89dd-801fef1b967c">
        <source>isSubclassOf(cls: Class) : Boolean;

begin
	if self.superclass = null then
		return false;
	endif;
		
	if self.superclass.rootType = cls then
		return true;
	endif;
		
	return self.superclass.rootType.isSubclassOf(cls);
			
end;</source>
        <Parameter name="cls" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="listAttributes" id="a89f2345-1927-497e-9a6f-071ad6829a40">
        <source>listAttributes();
// ---------------------------------------------------------------------------
// Created:     24 November 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cls	: Class;
	propertyCollObj	: PropertyColl;
	prop	: Property;
	inversed	: String;

begin

	cls := self;
	
	//propertyCollObj := cls.allProperties;
	propertyCollObj := cls.allPropertiesUpTo(CM_Container);
	
	app.writeStatement( '');
	app.writeStatement( 'Attributes for ' &amp; cls.name);
	write 'Name' &amp; Tab &amp; 'Type';
	foreach prop in propertyCollObj do
		if prop.isSystemObject or prop.virtual then
			continue;
		endif;
		app.writeStatement( prop.name &amp; Tab &amp; prop.getType.name);
	endforeach;
epilog
	delete propertyCollObj;

end;</source>
    </JadeMethod>
    <JadeMethod name="listReferences" id="6b0aa00f-4b57-4f3d-b7bc-6bd0a0d332e7">
        <source>listReferences();
// ---------------------------------------------------------------------------
// Created:     24 November 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cls	: Class;
	propertyCollObj	: PropertyColl;
	prop	: Property;
	inversed	: String;

begin

	cls := self;
	
	propertyCollObj := cls.allProperties;
	
	app.writeStatement( '');
	app.writeStatement( 'References for ' &amp; cls.name);
app.writeStatement('Name' &amp; Tab &amp; 'Type' &amp; Tab &amp; 'Inversed');
	foreach prop in propertyCollObj do
		if prop.isSystemObject or prop.virtual then
			continue;
		endif;
		if prop.isKindOf(Reference) then
			if prop.isKindOf(ExplicitInverseRef) then
				inversed := 'Yes';
			else
				inversed := 'No';
			endif;
			app.writeStatement( prop.name &amp; Tab &amp; prop.getType.name &amp; Tab &amp; inversed);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="typeConstant" id="96241f84-bb2a-4bae-811c-875bfd6d9b45">
        <source>typeConstant(): Integer;

begin
	return Type_Object_Reference;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zDocumentFeatures" id="64ed97a4-50ee-436d-9555-7c96a96f09e7">
        <source>zDocumentFeatures(_includeSuper: Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Aug 2008	cnwkpd1	Internal documentation
27 Jan 2016	cnwkpd1	PAR #35261 - Changes for JADE 7.1

*/

vars
	prop			: Property;
	meth			: Method;
	
begin
	if _includeSuper and self = Object then
		write "==&gt; Omitting " &amp; self.name;
		return;
	endif;
	
	if _includeSuper and self.superclass &lt;&gt; null then
		self.superclass.zDocumentFeatures(_includeSuper);
	endif;

	write "==&gt; Properties of " &amp; self.name &amp; " (" &amp; self.number.String &amp; ")";
	foreach prop in self.properties do
		write prop.name &amp; " &lt;" &amp; prop.type.name&amp;"&gt;, SubId: " &amp; prop.getPropertyValue('subId').Integer.String &amp; ", Ordinal: " &amp; prop.ordinal.String;
	endforeach;
	
	write "==&gt; Methods of " &amp; self.name;
	foreach meth in self.methods do
		write meth.makeHeader;
	endforeach;

	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_includeSuper" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zDocumentSubclasses" id="e97e26bc-bd6e-4b42-a18f-64441ac3a43e">
        <source>zDocumentSubclasses(_indent : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Aug 2008	cnwkpd1	Internal documentation

*/


vars
	cc				: ClassColl;
	c				: Class;
	s				: String;
	
begin
	if _indent &gt; 0 then
		s[_indent] := "x";
		s.fillString(" ");
	endif;
	
	create cc transient;
	self.getSubclasses(cc);
	foreach c in cc do
		write s &amp; c.name;
		c.zDocumentSubclasses(_indent + 2);
	endforeach;
	
	
epilog
	delete cc;
	
end;</source>
        <access>protected</access>
        <Parameter name="_indent" type="Integer"/>
    </JadeMethod>
</Class>
