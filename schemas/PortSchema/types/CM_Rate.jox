    <JadeMethod name="getRateHookCodeType" id="b57d9db4-5002-43df-9802-b2c8863ba465">
        <source>getRateHookCodeType() : String;
// 24024 added for reporting, returns the CM_CalculationType description if it has rate hook code
vars
	result	: String;
begin
	if self.service &lt;&gt; null and
	   self.service.myCalculationType &lt;&gt; null and
	   self.service.myCalculationType.myHookCodeRate &lt;&gt; null then
		result := self.service.myCalculationType.description;
	endif;
	return result;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
