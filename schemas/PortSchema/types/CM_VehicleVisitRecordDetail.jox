    <JadeMethod name="getExtraInfo_BulkGateModified" id="6efea0bc-04c3-4e6e-a53f-c64b00205217">
        <source>getExtraInfo_BulkGateModified(_returnValue : String output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2017	cnwns1	Initial creation

*/

vars
	start 			: Integer;
	pos				: Integer;
	inRawWeightSt 	: String;
	inModWeightSt 	: String;
	rawWeightDec 	: Decimal[16,4];
	modWeightDec 	: Decimal[16,4];
	outRawWeightSt 	: String;
	outModWeightSt 	: String;
	measure 		: CM_MeasurementType;
	
begin
	if self.extraInfo.isDecimal then
		return false;
	endif;
	
	pos := self.extraInfo.pos("^",1);

	if pos = 0 then
		return false;
	endif;
		
	start := 10;
	
	if self.extraInfo.length &lt;= start  then
		return false;
	endif;
	

	inRawWeightSt := self.extraInfo[start:pos - start]; 
	
	if inRawWeightSt &lt;&gt; null and inRawWeightSt.isDecimal then
		rawWeightDec := inRawWeightSt.Decimal;
	else
		return false;
	endif;

	pos := pos + 1;	
	inModWeightSt := self.extraInfo[pos:End];
	
	if inModWeightSt &lt;&gt; null and	 inModWeightSt.isDecimal then
		modWeightDec := inModWeightSt.Decimal;
	else
		return false;
	endif; 
	
	measure := app.getDefaultMeasurementForType(Type_Weight);
		
	if rawWeightDec &gt; 0 then
		outRawWeightSt := app.convertMeasurementForDisplay(measure.shortName, rawWeightDec);
	else
		outRawWeightSt := "0.0";
	endif;
	
	if modWeightDec &gt; 0 then
		outModWeightSt := app.convertMeasurementForDisplay(measure.shortName, modWeightDec);
	else
		outModWeightSt := "0.0";
	endif;
	
	_returnValue := outRawWeightSt &amp; Space &amp; measure.shortName &amp; " Changed to " &amp; outModWeightSt &amp; Space &amp; measure.shortName &amp; " [" &amp; self.userCode &amp; "] " &amp; self.computerName;
	
	return true;
epilog

end;</source>
        <Parameter name="_returnValue" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo_BulkGateOutWts" id="8da886d5-a91c-475e-9812-f6f9d552e778">
        <source>getExtraInfo_BulkGateOutWts( _scaleOutWeight, _adjustedOutWeight : Decimal output; _adjusted : Boolean output );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2019	jlgndl1	Initial creation	TFS 46849

*/

vars

	start : Integer;
	pos : Integer;
	scaleWeightStr : String;
	adjustedWeightStr: String;

begin

	if self.extraInfo.isDecimal then
		//Its the original unchanged version
		_adjusted := false;
		_adjustedOutWeight := null;
		_scaleOutWeight := getExtraInfo_BulkGateInOrOut(); 
		
	else
		//Its one of the adjusted ones. i.e. the user has manually overwritten the outward scale weight
		start := 10;
		if self.extraInfo.length &lt;= start  then
			//bail, no data
			return;
		endif;
		
		pos := self.extraInfo.pos("^",start);
		if pos = 0 then
			//bail, no data or wrong format
			return;
		endif;
		
		_adjusted := true;
		
		scaleWeightStr := self.extraInfo[start:pos - start]; 
		if scaleWeightStr &lt;&gt; null and scaleWeightStr.isDecimal then
			_scaleOutWeight := scaleWeightStr.Decimal;
		endif;

		adjustedWeightStr := self.extraInfo[(pos + 1) : end];
		if adjustedWeightStr &lt;&gt; null and adjustedWeightStr.isDecimal then
			_adjustedOutWeight := adjustedWeightStr.Decimal;	
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="_scaleOutWeight" type="Decimal" usage="output"/>
        <Parameter name="_adjustedOutWeight" type="Decimal" usage="output"/>
        <Parameter name="_adjusted" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo_Cancel" id="36605abe-9b6c-4fbb-9673-3bd08f6b8a7b">
        <source>getExtraInfo_Cancel():String;
// ---------------------------------------------------------------------------
// Created:     22 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// extra info contains cancellation reson
	return self.extraInfo;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo_CargoMove" id="6583f333-569a-48e9-a692-fd825744037c">
        <source>getExtraInfo_CargoMove():String;
/*
Date		Who		Reason
17 Jun 2013	cnwcs5	Initial Creation - par 31670
*/
vars
	value, id, qty	:String;
	array			:StringArray;
	comment : String;
begin
	value := self.extraInfo;
	
	if value = null or value.pos ('^', 1) = 0 then
		return value;
	endif;
	
	create array transient;
	
	value.getTokensForDelimiter ('^', array);
	
	if array.size = 0 then
		return null;
	endif;
	
	if array.size &gt; 0 then
		value := array[1];
	endif;
	
	if array.size &gt; 1 then
		value := array[2] &amp; 'x' &amp; value;
	endif;
	
	//25 Oct 2018	NDL	TFS 41180
	if array.size &gt; 2 then
		comment := array[3].trimBlanks;
		if comment &lt;&gt; null then
			value := value &amp; " - " &amp; comment;
		endif;
	endif;
	
	return value;
epilog
	delete array;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo_DeletedEntry" id="588b348f-6385-4075-b091-288045e90da9">
        <source>getExtraInfo_DeletedEntry():String;
/*
Date		Who		Reason
18 Feb 2011	cnwndl1	Initial creation	par 27046
17 Jun 2013	cnwcs5	par 31670 - breakbulk changes
11/03/2015	cnwmh5	Transient Leaks
*/
vars
	value, id, qty,
	reason			:String;
	array			:StringArray;
begin
	// the initiale implementation of this never recorded the reason so we need to handle 
	// records both with and without a reason
	
	value := self.extraInfo;
	
	if value = null then
		// don't expect this to happen
		return null;
	endif;
	
	if value.pos ('^', 1) = 0 then
		// old style without the reason
		// extra info contains wle &amp; ti ID
		return self.extraInfo &amp; " [" &amp; self.userCode &amp; "]";
	endif;
	
	// new style containing reason^wle/ti info^qty (break bulk only)
	create array transient;
	
	value.getTokensForDelimiter ('^', array);
	
	if array.size = 0 then
		return null;	// don't expect this to happen
	endif;
	
	reason := array[1];
	
	if array.size &gt; 1 then
		id := array[2];
	endif;
	
	if array.size &gt; 2 then
		qty := array[3];
	endif;
	
	if qty = null then
		value := reason &amp; ' - '  &amp; id;
	else
		value := reason &amp; ' - '  &amp; qty.String &amp; 'x' &amp; id;
	endif;
	
	// now append user code
	value := value &amp; " [" &amp; self.userCode &amp; "]";
	
	return value;
epilog
	delete array;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo_GateLane" id="c5f9b21f-5a9c-4af6-99c1-15abfbc2e1a5">
        <source>getExtraInfo_GateLane():String;
/*

Date		Who		Reason
22 July 2013	cnwer1	Initial creation PAR

*/

vars
	lane : CM_LaneController;
	detail : String;
	details : StringArray;
	invalidObject : Boolean;
begin

	if self.myExtraInfoObject = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject (exception, lane, invalidObject);
	
	if not self.myExtraInfoObject.isKindOf(CM_LaneController) then
		return null;
	endif;
	
	lane:=self.myExtraInfoObject.CM_LaneController;
	
	create details transient;
	self.extraInfo.getTokensForDelimiter(Tab,details);
	
	detail:=details[1];
	
	if lane.myTerminalArea.isKindOf(CM_AreaWithLanes) and not lane.myTerminalArea.CM_AreaWithLanes.isBufferZone then		
		detail := detail &amp; Space  &amp;  self.myExtraInfoObject.CM_LaneController.getLaneNumber.asStringJMT ;
	endif;

	
	return detail;
epilog
	delete details;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo_Move" id="184010a5-356e-427c-8c2f-9304b19e11ad">
        <source>getExtraInfo_Move() : CM_Move;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2019	jlger1	Initial creation 44965

*/

vars
	move : CM_Move;
	invalidObject	:Boolean;
	int				:Integer;
begin
	if self.myExtraInfoObject = null then
		return null;
	endif;
	
	if self.isCargoMove then
		on Exception do app.handleDeletedObject (exception, move, invalidObject);	
		
		if self.myExtraInfoObject.isKindOf(CM_Move) then
			move:= self.myExtraInfoObject.CM_Move;
		endif;
		
		if move = null then
			return null;
		endif;
		
		// access property to force exception if ti is invalid
		int := move.edition;
		
		if invalidObject then
			return null;
		endif;
		
		return move;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_Move"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo_MoveTotal" id="3bb10abf-c747-4ff7-a697-8eb6139d102d">
        <source>getExtraInfo_MoveTotal() : Integer;
/*

Date		Who		Reason
10 October 2013	cnwer1	Initial creation PAR 32717

*/

vars
	value	:String;
	array			:StringArray;
	ti : CM_TrackedItem;
	move : CM_Move;
begin
	//epr TFS 45705 23/7/19 - only show totalQuantity if bulk just return 1
	move:=self.getExtraInfo_Move;
	if move &lt;&gt; null then
		return move.totalQuantity;
	endif;
	
	ti:=self.getExtraInfo_TrackedItem;
	if ti &lt;&gt; null and ti.isBulkCargo then
		return 1;
	endif;
	
	value := self.extraInfo;
	
	if value = null then
		return 0;
	endif;
	
	if value.pos ('^', 1) = 0 then
		return 1;
	endif;
	
	create array transient;
	
	value.getTokensForDelimiter ('^', array);
	
	if array.size = 0 then
		return 0;
	endif;
	
	if array.size &gt; 1 then
		return array[2].Integer;
	endif;
	
	return 0;
epilog
	delete array;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo_MoveTotalTI" id="86264a96-9d26-4218-9ec2-26b48a45d153">
        <source>getExtraInfo_MoveTotalTI(_ti : CM_TrackedItem input) : Decimal;
/* Changes

Date		Name	TFS#		Description
============================================================================
28/04/ 2016	cnwer1				Initial creation PAR
20/03/2019	jlgka1 	TFS 43259	STWO - HH Truck Unloader with Edit Config Issue.
								for the computation we need to make sure that we are referring to the same
								tracked item entry otherwise just return zero value when it is a removal.
								if not removal then we need to validate that it is equal to the same queued location.
16 Dec 2019	jlgdi1	47879		Simplify the computation of getting the total move item or quantity
============================================================================*/
vars
	value		: String;
	array		: StringArray;
	trackedItem	: CM_TrackedItem;
	invalidTI 	: Boolean;
	move : CM_Move;
	
begin
	
	on Exception do app.handleDeletedObject(exception,trackedItem,invalidTI);
	//epr TFS 44965 26/6/19
	trackedItem := self.getExtraInfo_TrackedItem;
	
	if trackedItem = null then
		return 0;
	endif;
	
//	if ti &lt;&gt; _ti then
//		return 0;
//	endif;
	//30 Aug 2018	NDL	TFS 39769 - If its been merged into the existing on-site pile then re-loaded, it wont be the same oid.	
	if trackedItem.id &lt;&gt; _ti.id or trackedItem.myCargoType &lt;&gt; _ti.myCargoType then
		return 0;
	endif;
	
	if invalidTI then
		return 0;
	endif;
	
	value := self.extraInfo;
	
	if value = null then
		return 0;
	endif;
	
	if value.pos ('^', 1) = 0 then
		return 1;
	endif;
	
	move := self.getExtraInfo_Move();
	if move = null then
		return 0;
	endif;
	
	if not hasBeenInTheLocation(trackedItem, _ti, move) then 
		return 0;
	endif;	
	
	/*	
	//jlgka1 TFS 43259 --&gt;	
	if _ti.myMasterTi &lt;&gt; null then
		if _ti.myMasterTi.myMasterTi &lt;&gt; null then
			if trackedItem &lt;&gt; _ti then 				
				if (_ti.site = TI_SITE_UNDEFINED or trackedItem.site = TI_SITE_UNDEFINED) and self.recordType = VisitRecord_CargoPlaced then
				elseif trackedItem.myPrimaryQueuedLocation = null then
					return 0;
				else
					if trackedItem.myPrimaryQueuedLocation &lt;&gt; _ti.myPrimaryQueuedLocation then
						return 0;
					endif;
				endif;					
			endif;		
		else
			if trackedItem &lt;&gt; _ti then 
				if (_ti.site = TI_SITE_UNDEFINED or trackedItem.site = TI_SITE_UNDEFINED) and self.recordType = VisitRecord_CargoPlaced then
				elseif trackedItem.myPrimaryQueuedLocation = null then
					return 0;
				else
					if trackedItem.myPrimaryQueuedLocation &lt;&gt; _ti.myPrimaryQueuedLocation then
						return 0;
					endif;
				endif;					
			endif;		
		endif;
	endif;
	//jlgka1 TFS 43259 &lt;--
	*/
	
	create array transient;
	
	value.getTokensForDelimiter ('^', array);
	
	if array.size = 0 then
		return 0;
	endif;
	
	if array.size &gt; 1 then
		if trackedItem.isBulkByQuantity then
			return array[2].Integer;
		else
			return array[2].Decimal;
		endif;
		
	endif;
	
	return 0;
epilog
	delete array;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo_MoveTotalTIID" id="9ff76303-122f-4c85-81ef-d53edc6954e5">
        <source>getExtraInfo_MoveTotalTIID(_tiID : String) : Decimal;
/*

Date		Who		Reason
10 October 2013	cnwer1	Initial creation PAR 32717
29 Sep 2014	cnwer1	CCMS 1366 bulk changed to decimal to return a weight/vol along with quantity
*/

vars
	value	:String;
	array			:StringArray;
	ti : CM_TrackedItem;
	invalidTI : Boolean;
	array2 : StringArray;	//05 Nov 2020	NDL	TFS 50271
	
begin
	
	on Exception do app.handleDeletedObject(exception,ti,invalidTI);
	
	//epr TFS 44965 26/6/19
	ti := self.getExtraInfo_TrackedItem;		
	
	if ti = null then
		return 0;
	endif;
	
	if ti.id &lt;&gt; _tiID then
		return 0;
	endif;
	
	if invalidTI then
		return 0;
	endif;
	
	value := self.extraInfo;
	
	if value = null then
		return 0;
	endif;
	
	if value.pos ('^', 1) = 0 then
		return 1;
	endif;
	
	create array transient;
	
	value.getTokensForDelimiter ('^', array);
	
	if array.size = 0 then
		return 0;
	endif;
	
	if array.size &gt; 1 then
		if ti.isBulkByQuantity then
			return array[2].Integer;
		else
			if array[2].isDecimal then	//05 Nov 2020	NDL	TFS 50271
				return array[2].Decimal;
			else
				//05 Nov 2020	NDL	TFS 50271
				create array2 transient;
				array[2].getTokensForDelimiter (' ', array2);
				//in this case the string value is actually a decimal plus a string unit separated by a space character
				if array2.size &gt; 1 and array2[1].isDecimal then
					//need to convert to kilos / m3
					return app.convertMeasurementForStorage( array2[2], array2[1].Decimal );
				endif;
				
			endif;
		endif;
		
	endif;
	
	return 0;
	
epilog

	delete array;
	delete array2;
	
	
end;</source>
        <Parameter name="_tiID" type="String"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo_MoveTotalTIKgs" id="94a8adb0-3e5c-40b6-b700-20bd19f38b9c">
        <source>getExtraInfo_MoveTotalTIKgs(_ti : CM_TrackedItem input) : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
12/09/2018	jlgndl1	TFS 40776	Initial creation
20/03/2019	jlgka1	TFS 43259	STWO - HH Truck Unloader with Edit Config Issue.
								for the computation we need to make sure that we are referring to the same
								tracked item entry otherwise just return zero value when it is a removal.
								if not removal then we need to validate that it is equal to the same queued location.
16 Dec 2019	jlgdi1	47879		Simplify the computation of getting the total move item or quantity
============================================================================*/

vars
	value 			: String;
	array 			: StringArray;
	trackedItem 	: CM_TrackedItem;
	invalidTI		: Boolean;
	shortUnit 		: String;
	fullDisplay 	: String;
	displayAmount 	: Decimal[16,4];
	retValue 		: Decimal[16,4];
	measurementType : CM_MeasurementType;
	spacePos		: Integer;
	density 		: Decimal[16,4];
	volumeM3 		: Decimal[16,4]; 
	move : CM_Move;
	
begin
	
	on Exception do app.handleDeletedObject(exception,trackedItem,invalidTI);
	//epr TFS 44965 26/6/19
	trackedItem := self.getExtraInfo_TrackedItem;	
	
	if trackedItem = null then
		return 0;
	endif;
	
	if trackedItem.id &lt;&gt; _ti.id or trackedItem.myCargoType &lt;&gt; _ti.myCargoType then
		return 0;
	endif;
	
	if invalidTI then
		return 0;
	endif;
	
	value := self.extraInfo;
	
	if value = null then
		return 0;
	endif;
	
	if value.pos ('^', 1) = 0 then
		return 1;
	endif;
	
	move := self.getExtraInfo_Move();
	if move = null then
		return 0;
	endif;
	
	if not hasBeenInTheLocation(trackedItem, _ti, move) then 
		return 0;
	endif;
	
	/*
	//jlgka1 TFS 43259 --&gt;	
	if _ti.myMasterTi &lt;&gt; null then
		if _ti.myMasterTi.myMasterTi &lt;&gt; null then
			if trackedItem &lt;&gt; _ti then 
				if (_ti.site = TI_SITE_UNDEFINED or trackedItem.site = TI_SITE_UNDEFINED) and self.recordType = VisitRecord_CargoPlaced then
				elseif trackedItem.myPrimaryQueuedLocation = null then
					return 0;
				else
					if trackedItem.myPrimaryQueuedLocation &lt;&gt; _ti.myPrimaryQueuedLocation then
						return 0;
					endif;
				endif;					
			endif;					
		else
			if trackedItem &lt;&gt; _ti then 
				if (_ti.site = TI_SITE_UNDEFINED or trackedItem.site = TI_SITE_UNDEFINED) and self.recordType = VisitRecord_CargoPlaced then
				elseif trackedItem.myPrimaryQueuedLocation = null then
					return 0;
				else
					if trackedItem.myPrimaryQueuedLocation &lt;&gt; _ti.myPrimaryQueuedLocation then
						return 0;
					endif;
				endif;					
			endif;		
		endif;
	endif;	
	//jlgka1 TFS 43259 &lt;--
	*/
	
	create array transient;
	
	value.getTokensForDelimiter ('^', array);
	
	if array.size = 0 then
		return 0;
	endif;

	
	if array.size &gt; 1 then
		if trackedItem.isBulkByQuantity then
			return array[2].Integer;
		else
			fullDisplay := array[2].trimBlanks;  // will be something like "10.00 ft3"  or "12.5 MT"
			displayAmount := fullDisplay.Decimal;
			spacePos := fullDisplay.pos(" ",1);
			if spacePos &gt; 1 then
				shortUnit := fullDisplay[ spacePos + 1 : end];
				if shortUnit &lt;&gt; null then
					measurementType := app.myRoot.allMeasurementTypesByShortName.getAtKey( shortUnit );
				endif;
				if measurementType = null or ( measurementType.isWeight and  measurementType.isSameAsDatabaseValue ) then
					// no units, or already kgs, no conversion to be done
					retValue := displayAmount;
				elseif measurementType &lt;&gt; null and measurementType.isVolume then
					// Volumetric,  need to convert volume to cubic metres then the cubic metres to kgs
					density := _ti.getDensity;
					if measurementType.isSameAsDatabaseValue then
						//already cubic metres
						volumeM3 := displayAmount;
					else
						// convert to cubic metres
						volumeM3 := app.convertMeasurementForStorage( measurementType.shortName, displayAmount );
					endif;
					retValue := volumeM3 * density; 	// convert volume to weight
				else
					//need to convert weight it to kgs.
					retValue := app.convertMeasurementForStorage( measurementType.shortName, displayAmount );
				endif;
			else
				retValue := displayAmount;
			endif;
			return retValue;
		endif;
	endif;
	
	return 0;
epilog
	delete array;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo_SealDetails" id="70245893-4dea-4555-9512-0885f49f8221">
        <source>getExtraInfo_SealDetails() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

*/

vars
	
begin

	if self.myExtraInfoObject = null or self.myEvent = null then
		return null;
	endif;
	
	if self.myExtraInfoObject.isKindOf(CM_TruckSeal) and self.myEvent.isKindOf(CMEVT_TruckEvent) then
	
		if self.recordType = VisitRecord_SealAdd then
			return self.myExtraInfoObject.CM_TruckSeal.getDescriptionForEvent(self.myEvent.CMEVT_TruckEvent, true);
		elseif self.recordType = VisitRecord_SealDelete then
			return self.myExtraInfoObject.CM_TruckSeal.getDescriptionForEvent(self.myEvent.CMEVT_TruckEvent, false);
		endif;
	endif;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo_TrackedItem" id="21f4d01b-1e07-4b4e-ac94-e43cac5db7da">
        <source>getExtraInfo_TrackedItem():CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     20 May 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Tracked item for cargo Pickup/Dropoff
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti				:CM_TrackedItem;
	invalidTI,
	invalidMove 	:Boolean;
	int				:Integer;
	move 			: CM_Move;
begin
	if self.myExtraInfoObject = null then
		return null;
	endif;
	
	if self.isCargoMove then
		on Exception do app.handleDeletedObject (exception, ti, invalidTI);
		on Exception do app.handleDeletedObject (exception, move, invalidMove);
		
		//epr TFS 44965 26/6/19
		if self.myExtraInfoObject.isKindOf(CM_Move) then
			move:=self.myExtraInfoObject.CM_Move;
			ti:= move.myTrackedItem;
			if invalidMove  then
				return null;
			endif;
		elseif  self.myExtraInfoObject.isKindOf(CM_TrackedItem) then
			ti := self.myExtraInfoObject.CM_TrackedItem;	
		endif;
				
		if ti = null then
			return null;
		endif;
		
		// access property to force exception if ti is invalid
		int := ti.edition;
		
		if invalidTI then
			return null;
		endif;
		
		return ti;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo_TrackedItemId" id="6784570f-d0c6-48be-8be9-b2ee4a1d3a66">
        <source>getExtraInfo_TrackedItemId():String;
// ---------------------------------------------------------------------------
// Created:     20 May 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/06/2013	cnwcs5		par 31670 - check if ti has been merged
// ---------------------------------------------------------------------------
vars
	ti 	:CM_TrackedItem;
begin
	if not self.isCargoMove then
		return null;
	endif;
	
	ti := self.getExtraInfo_TrackedItem;
	
	if ti &lt;&gt; null  then //epr par 32730 10/10/13
		return ti.id;
	endif;
	
	return self.extraInfo;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
