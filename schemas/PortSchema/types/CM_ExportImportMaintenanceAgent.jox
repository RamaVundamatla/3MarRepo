    <JadeMethod name="configureProduct" id="0a55d9c6-426d-4213-9795-26ab58ba1a84">
        <updating/>
        <source>configureProduct(_exportClass: CM_ExportImportClass io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation

*/

vars
    builder: CM_ExportPropertyConfigBuilder;
    parentClass: CM_ExportImportClass;
begin
    create builder transient;
    
    builder.forClass(_exportClass)
        // Parent reference - links to CM_CargoType
        .property(CM_Product::myCargoType, "Cargo Type").asParent()
        
        // Own key - code is the business key for Product
        .property(CM_Product::code, "Cargo Subtype Code").asKey()
        
        // Add any Product-specific properties here
        // (Currently Product only has code beyond inherited properties)
        
        .commit();
    
    // Link to parent export class
    // This enables inheritance of properties in export/import
    parentClass := app.myRoot.allExportImportClasses[CM_CargoType.name];
    
    if parentClass = null then
        self.writeLog("  ? WARNING: Parent class CM_CargoType not found for CM_Product");
        self.writeLog("    Make sure CM_CargoType is configured before CM_Product");
    else
       // _exportClass.myParentExportClass := parentClass;
        self.writeLog("  Parent class linked: CM_CargoType");
    endif;
    
epilog
    delete builder;
end;</source>
        <Parameter name="_exportClass" type="CM_ExportImportClass" usage="io"/>
    </JadeMethod>
