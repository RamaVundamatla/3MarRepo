			cargo := self.addContainerAtLocnDisch("GENL3011772", "UT30", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);

			strs.clear;
			strs.add("AUTOLOCN403");
			_voyage.findLocation(strs, false, theSlot, idx);
			cargo := self.addContainerAtLocnDisch("GENL3011773", "UT30", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);

						strs.clear;
			strs.add("AUTOLOCN541");
			_voyage.findLocation(strs, false, theSlot, idx);
			cargo := self.addContainerAtLocnDisch("GENL3021771", "UT30", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);

			strs.clear;
			strs.add("AUTOLOCN542");
			_voyage.findLocation(strs, false, theSlot, idx);
			cargo := self.addContainerAtLocnDisch("GENL3021772", "UT30", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);

			strs.clear;
			strs.add("AUTOLOCN543");
			_voyage.findLocation(strs, false, theSlot, idx);
			cargo := self.addContainerAtLocnDisch("GENL3021773", "UT30", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, aPort, _voyage);

		endif;
	endif;
epilog
	delete lcs;
	delete strs;
	delete tsController;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createExchangeDates" id="cbe90fdc-a33e-4a4e-9b51-04ae48025b16">
        <source>createExchangeDates(_voy : CM_Voyage input);
// ---------------------------------------------------------------------------
// Created:     24 August 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 15/03/2018		jlgdap1			TFS 37427 PEL1 Voyage Status Enhancements
// ---------------------------------------------------------------------------

vars
	_pilotOnBoardDT,
	_labourOB,
	_labourOS:TimeStamp;
	_shipExchangeDT,
	_shipExchangeCompleteDT,
	_departTargetDT	: TimeStamp;
	_pilotReturnDT : TimeStamp;
	_anchorDownDT : TimeStamp;
	
	dte : Date;
	tme : Time;
	
begin
	dte := _voy.arrivedDT.date;
	tme := _voy.arrivedDT.time;
	
	

	tme := tme - 3600000;
	_pilotOnBoardDT.setDate(dte);
	_pilotOnBoardDT.setTime(tme);

	tme := _voy.arrivedDT.time;
	tme := tme + 3600000;
	_anchorDownDT.setDate(dte);
	_anchorDownDT.setTime(tme);
	tme := tme + 3600000;
	_labourOB.setDate(dte);
	_labourOB.setTime(tme);
	tme := tme + 3600000;
	_shipExchangeDT.setDate(dte);
	_shipExchangeDT.setTime(tme);
	tme := tme + 3600000;
	_shipExchangeCompleteDT.setDate(dte);
	_shipExchangeCompleteDT.setTime(tme);
	tme := tme + 3600000;
	_labourOS.setDate(dte);
	_labourOS.setTime(tme);
	tme := tme + 3600000;
	_departTargetDT.setDate(dte);
	_departTargetDT.setTime(tme);
	tme := tme + 3600000;
	_pilotReturnDT.setDate(dte);
	_pilotReturnDT.setTime(tme);

	_voy.setProxyExchangeData(_voy.starboardBerthed, 
											_pilotOnBoardDT, 
											_labourOB,
											_labourOS,
											_voy.dateFirstAvailable,
											_shipExchangeDT,
											_shipExchangeCompleteDT,
											_departTargetDT,
											_voy.totalTimeInPort,
											_voy.nonChargeTime,
											_voy.stopChargingAt,
											_voy.loadRate,
											_voy.dischargeRate,
											_voy.status,
											_pilotReturnDT,
											_anchorDownDT,
											false,
											_voy.myVoyageProcess				// TFS 37427
											);
	
epilog

end;</source>
        <Parameter name="_voy" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createExtraMovesDetails" id="73ad106c-3c02-45b0-8859-577072f3a678">
        <source>createExtraMovesDetails(_voy : CM_Voyage input);
// ---------------------------------------------------------------------------
// Created:     24 August 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	controller : CMIF_VoyageExtraMoveDtl;
begin
	create controller transient;
	controller.setFromVoyage(_voy);
	controller.numCageMoves := 100;
	controller.numExtraMoves := 200;
	controller.numLashingBinMoves := 300;
	controller.numLashings := 400;
	controller.numUnlashings := 500;
	
	app.myTrxUA.trxSetVoyageExtraMoveDtls(controller, app.myPassport);		
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Extra Move Problems &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

//	beginTransaction;
//	_voy.setExtraMoveDtls(controller,app.myPassport);
//	commitTransaction;
epilog
	delete controller;
end;</source>
        <Parameter name="_voy" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createLidJobs" id="a6e0b045-3be9-4c50-bd27-3b0dd14c61c6">
        <updating/>
        <source>createLidJobs() updating;
// ---------------------------------------------------------------------------
// Created:     04 June 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bay : CM_Bay;
	req : CM_SlotRequest;
	voy : CM_Voyage;
begin
	voy := self.getVoyage("UTBISH1");
	foreach bay in voy.myCellularVoyageStructure.allBayVoyagesById discreteLock do
		// create a hatchlid job if we have under deck colour coding
		foreach req in bay.CM_BayVoyage.allSlotRequestByMoveType  discreteLock do
			if req.mySlotController.ordinalDeck = DeckUnderDeck then
				self.createHatchLidJobs(bay, "CRN1");
				break;
			endif;
		endforeach;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createVesselVoyage" id="5790b196-64e5-4765-94c0-d6bad168f062">
        <updating/>
        <source>createVesselVoyage(_voyage : String; _vessel : String; _operator :CM_Operator) : CM_Voyage updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2: CM_TrackedItem;
	location: CM_LocationsController;
	voyage1: CM_Voyage;
	voyage2: CM_Voyage;
	vessel: CM_Vessel; 
	
begin
	voyage1 := self.getVoyage(_voyage);
	if voyage1 &lt;&gt; null then
		self.loadAllJobsToOps(voyage1, false);
	endif;
	deleteVoyage(_voyage);
	deleteVessel("UTBISHOP");
	
	vessel := self.addVesselLOLOholdsRORO("UTBISHOP", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	
	
	
	
	
	self.addVesselDefnReefer40(vessel);

	voyage1:=self.addVoyageWithConRORO(_voyage, "UTBISHOP", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	
	
	
	
	return voyage1;
epilog

end;</source>
        <Parameter name="_voyage" type="String"/>
        <Parameter name="_vessel" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVoyageDischargeJobs" id="47406c9e-8f46-4cd7-b8ab-eaf82f396634">
        <source>createVoyageDischargeJobs();
// ---------------------------------------------------------------------------
// Created:     02 June 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	slots : CM_SlotControllerArray;
	roroLCs : CM_LCArray; //CM_VoyageROROControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
	theDeck : CM_DeckVoyage;
	cellIdx : Integer;
begin
	// ### LOLO DISCHARGE JOB
	create slots transient;
	voyage := self.getVoyage("UTBISH1");
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,1,1,24,slots);
	voyageJob:=self.addVoyageJob(voyage,"CRN1",slots, true);
	assertTrue(voyageJob &lt;&gt; null);
	
	
	foreach cellIdx in 1 to 6 do
		slots.clear;
		self.getJobSlotControllers("UTBISH1","09",DeckOnDeck,cellIdx,2,3,slots);
		voyageJob:=self.addVoyageJob(voyage,"CRN2",slots, true);
		assertTrue(voyageJob &lt;&gt; null);
	endforeach;
	
	// ### RORO SLOT DISCHARGES
	create roroLCs transient;
	theDeck := voyage.myROROStructure.allDecksByCode[DECK1];
	self.getJobROROSlotController("UTBISH1", DECK1, roroLCs, false,104);
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "DD1071O1", roroLCs, false, 1); 
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "DD1073O1", roroLCs, false, 1); 
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "DD1074O1", roroLCs, false, 1); 
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "DD1074O2", roroLCs, false, 1); 
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "DD1076O1", roroLCs, false, 1); 
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "DD1076O2", roroLCs, false, 1); 

	voyageJob:=self.addVoyageROROJob(voyage,theDeck, "UT_KPI",roroLCs, true);
	assertTrue(voyageJob &lt;&gt; null);
	
	
	roroLCs.clear();
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN421", roroLCs, false, 1); 
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN422", roroLCs, false, 1); 
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN423", roroLCs, false, 1); 
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN491", roroLCs, false, 1); 
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN492", roroLCs, false, 1); 
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN493", roroLCs, false, 1); 
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN561", roroLCs, false, 1); 
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN562", roroLCs, false, 1); 
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN563", roroLCs, false, 1); 
	
	
	voyageJob:=self.addVoyageROROJob(voyage,theDeck, "UT_KP2",roroLCs, true);
	assertTrue(voyageJob &lt;&gt; null);
	
	
	
	// ### RORO GC DISCHARGES
	roroLCs.clear();
	theDeck := voyage.myROROStructure.allDecksByCode[DECK1];
	self.getJobROROGCController("UTBISH1", DECK1, roroLCs, false);

	voyageJob:=self.addVoyageROROJob(voyage,theDeck, "UT_KPI",roroLCs, true);
	assertTrue(voyageJob &lt;&gt; null);
	

epilog
	delete slots;
	delete roroLCs;
end;</source>
    </JadeMethod>
    <JadeMethod name="createVoyageLoadJobs" id="6cb48cb3-0ed5-4383-8cf2-de5ceda75cc9">
        <source>createVoyageLoadJobs();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
	voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
begin
	//create a voyage job for bay 
	
	voyage := self.getVoyage("UTBISH1");
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType :=true;
	tmpLoadCC.myDischargePort:=app.myRoot.allPorts["NZAKL"];

	
	// ### GET SLOTS NOTE - tier ordinals start at bottom left, cell tiers start at top left.
	// 40 GENL
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,1,1,6,slots);
	tmpLoadCC.myCommodityGroup := null;
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	slots.clear;
	// 20 GENL
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,2,3,6,slots);
	tmpLoadCC.myCommodityGroup := null;
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	slots.clear;

	// 40 REEFER
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,4,1,6,slots);
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	tmpLoadCC.myCommodityGroup := app.myRoot.allCommodityGroups["FROZ"];
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Power);
	slots.clear;

	// 20 REEFER
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,5,3,6,slots);
	tmpLoadCC.myCommodityGroup := app.myRoot.allCommodityGroups["FROZ"];
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Power);
	slots.clear;

	// 40 EMPTY
	self.getJobSlotControllers("UTBISH1","01",DeckUnderDeck,1,1,5,slots);
	tmpLoadCC.myCommodityGroup := null;
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Empty);
	slots.clear;


	// 40 GENL OD
	self.getJobSlotControllers("UTBISH1","01",DeckUnderDeck,2,3,5, slots);
	tmpLoadCC.myCommodityGroup := null;
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_OD);
	slots.clear;
	
	
	/// ## MAKE JOB
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,1,1,24,slots);
	self.getJobSlotControllers("UTBISH1","01",DeckUnderDeck,1,1,10,slots);
	voyageJob:=self.addVoyageJob(voyage,"CRN1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);

epilog
	delete slots;
	delete tmpLoadCC;

end;</source>
    </JadeMethod>
    <JadeMethod name="createVoyageLoadJobsHighC" id="e4f7907d-a099-4000-9bef-720956726ef9">
        <source>createVoyageLoadJobsHighC();
//24 September 2010	cnwas3	  

vars
	voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
begin
	//create a voyage job for bay 
	
	voyage := self.getVoyage("UTBISH1");
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType :=true;
	tmpLoadCC.myDischargePort:=app.myRoot.allPorts["NZAKL"];

	
	// ### GET SLOTS NOTE - tier ordinals start at bottom left, cell tiers start at top left.
	// 40 GENL
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,1,1,6,slots);
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Hicubed);
	
	voyageJob:=self.addVoyageJob(voyage,"CRN1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);

epilog
	delete slots;
	delete tmpLoadCC;

end;</source>
    </JadeMethod>
    <JadeMethod name="createVoyageLoadJobsVA" id="80020549-dae6-43ce-a25f-2be4cace0634">
        <updating/>
        <source>createVoyageLoadJobsVA() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
	altRoroLCs, roroLCs : CM_LCArray;
	realAlloc 				: CM_VoyageAllocation;
	voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	altSlots, slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
	voyageDeck : CM_DeckVoyage;
	gcDefn : CM_ROROGCDefnVoyage;
	theLCs: CM_LCArray;
	ct : CM_CargoType;
	product: CM_Product;
	theEditions : CM_ObjectByOidEditionDict;
	lc : CM_LocationsController;
	theTI : CM_TrackedItem;
begin
	ct	:= self.getTerminal.getFirstNonSystemCargoType().CM_CargoType;
	product := ct.allProducts.first;

	//create a voyage job for bay 
	
	voyage := self.getVoyage("UTBISH1");
	create theLCs transient;
	create slots transient;
	create altSlots transient;
	create theEditions transient;
	create roroLCs transient;
	create altRoroLCs transient;

	// ### GET SLOTS. NOTE - tier ordinals start at bottom left, cell tiers start at top left.
	// 20 GENL PRENOTES
	self.getJobSlotControllers("UTBISH1","05",DeckOnDeck,1,1,4,slots);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "GEN2", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.clear;
	
	// 40 GENL
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,1,1,6,slots);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "40BX", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.clear;

	// 20 GENL
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,2,3,6,slots);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "GEN2", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.clear;

	// 40 REEFER
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,4,1,6,slots);
	self.opts.purge();
	self.opts.addAssoc("CommodityGroupOnly", true);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "REF4", "REEF", TI_CargoType_Container, true, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);

	slots.clear;

	// 20 REEFER
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,5,3,6,slots);
	self.opts.purge();
	self.opts.addAssoc("CommodityGroupOnly", true);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "REF2", "REEF", TI_CargoType_Container, true, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);

	slots.clear;

	// 40 EMPTY
	self.getJobSlotControllers("UTBISH1","01",DeckUnderDeck,1,1,5,slots);
	self.opts.purge();
	self.opts.addAssoc("CommodityGroupOnly", true);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "GEN4", "MT", TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);

	slots.clear;


	// 40 GENL OD
	self.getJobSlotControllers("UTBISH1","01",DeckUnderDeck,2,3,5, slots);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "GEN4", "", TI_CargoType_Container, false, true);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.clear;
	
	
	/// ## MAKE SLOT JOB
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,1,1,24,slots);
	self.getJobSlotControllers("UTBISH1","01",DeckUnderDeck,1,1,10,slots);
	
	voyageJob:=self.addVoyageJob(voyage,"CRN1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);
	
	


	// 30 EMPTY
	slots.clear;
	self.getJobSlotControllers("UTBISH1","09",DeckOnDeck,1,4,1,slots);
	self.getJobSlotControllers("UTBISH1","09",DeckOnDeck,2,4,1,slots);
	self.getJobSlotControllers("UTBISH1","09",DeckOnDeck,3,4,1,slots);
	self.opts.purge();
	self.opts.addAssoc("CommodityGroupOnly", true);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "30BX", "MT", TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);

	// 45 EMPTY
	slots.clear;
	self.getJobSlotControllers("UTBISH1","09",DeckOnDeck,1,3,1,slots);
	self.getJobSlotControllers("UTBISH1","09",DeckOnDeck,2,3,1,slots);
	self.getJobSlotControllers("UTBISH1","09",DeckOnDeck,3,3,1,slots);
	self.opts.purge();
	self.opts.addAssoc("CommodityGroupOnly", true);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "45BX", "MT", TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);

	// 53 EMPTY
	slots.clear;
	self.getJobSlotControllers("UTBISH1","09",DeckOnDeck,1,2,1,slots);
	self.getJobSlotControllers("UTBISH1","09",DeckOnDeck,2,2,1,slots);
	self.getJobSlotControllers("UTBISH1","09",DeckOnDeck,3,2,1,slots);
	self.opts.purge();
	self.opts.addAssoc("CommodityGroupOnly", true);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "53FT", "MT", TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	
	
	
	
	// PAR 28522 ADD LOAD CC for PRENOTES to a JOB
	slots.clear;
	self.getJobSlotControllers("UTBISH1","05",DeckOnDeck,1,1,4,slots);
	voyageJob:=self.addVoyageJob(voyage,"CRN1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);
	self.pnJobNum := voyageJob.id;


	
	// PAR 28968 DLR from LOL to RORO linked
	theEditions.clear();
	slots.clear;
	altRoroLCs.clear();
	roroLCs.clear();
	// GET LOLO DLR
	self.getJobSlotControllers("UTBISH1","09",DeckOnDeck,3,1,1,slots); 
	// GET RORO DLR
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN351", altRoroLCs, true, 1);
	slots.copyNoDuplicates(theEditions);
	altRoroLCs.copyNoDuplicates(theEditions);
	slots.copyNoDuplicates(roroLCs);
	app.myTrxUA.doRORORequestDLRSoB(roroLCs, altRoroLCs, false,DLR_MOVETYPE, theEditions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	theTI := roroLCs.last.allTrackedItems.first;
	self.assertTrueMsg(theTI.isRehandle, theTI.id &amp; " should be a DLR Rehandle");
	voyageJob:=self.addVoyageJob(voyage,"CRN2",slots, true);
	assertTrue(voyageJob &lt;&gt; null);

	// PAR 28968 SoB from LOLO to RORO linked
	theEditions.clear();
	slots.clear;
	altRoroLCs.clear();
	roroLCs.clear();
	// GET LOLO SOB
	self.getJobSlotControllers("UTBISH1","09",DeckOnDeck,2,1,1,slots); 
	// GET RORO SOB
	self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN302", altRoroLCs, true, 1);
	slots.copyNoDuplicates(theEditions);
	altRoroLCs.copyNoDuplicates(theEditions);
	slots.copyNoDuplicates(roroLCs);
	app.myTrxUA.doRORORequestDLRSoB(roroLCs, altRoroLCs, false,SOB_MOVETYPE, theEditions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	theTI := roroLCs.last.allTrackedItems.first;
	self.assertTrueMsg(theTI.isSOB, theTI.id &amp; " should be a SOB Shift on Board");
	voyageJob:=self.addVoyageJob(voyage,"CRN2",slots, true);
	assertTrue(voyageJob &lt;&gt; null);
	
	// PAR 28522 ADD COLOUR CODING for DLR
	
	// ### DISCHARGE
	slots.clear;
	theEditions.clear();
	self.getJobSlotControllers("UTBISH1","05",DeckOnDeck,3,1,4,slots);
	self.getJobSlotControllers("UTBISH1","07",DeckOnDeck,3,1,4,slots);
	slots.copyNoDuplicates(theEditions);
	app.myTrxUA.trxUpdateSlotRequestAttribute(slots, altSlots, false, theEditions, CM_SlotRequest.Attribute_DLR, null, app.myPassport);	
	

	self.assertNoTrxErrorsOrWarnings();
	voyageJob:=self.addVoyageJob(voyage,"CRN2",slots, true);
	assertTrue(voyageJob &lt;&gt; null);

	// ### LOAD
	slots.clear;
	theEditions.clear();
	
	self.getJobSlotControllers("UTBISH1","05",DeckOnDeck,3,1,4,slots);
	self.getJobSlotControllers("UTBISH1","07",DeckOnDeck,3,1,4,slots);
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "U20G", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.copyNoDuplicates(theEditions);
	app.myTrxUA.trxUpdateSlotRequestAttribute(slots, altSlots, true, theEditions, CM_SlotRequest.Attribute_DLR, null, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	voyageJob:=self.addVoyageJob(voyage,"CRN2",slots, false);
	assertTrue(voyageJob &lt;&gt; null);

	
	if voyage.myROROStructure &lt;&gt; null then
		voyageDeck:=voyage.myROROStructure.allDecksByCode[DECK1];
		if voyageDeck &lt;&gt; null then
		
		
		
			// ADD IN 30/45/53 DLRs
			theEditions.clear();
			altRoroLCs.clear();
			roroLCs.clear();
			// GET DISCH DLR
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN681", roroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN682", roroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN683", roroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN611", roroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN612", roroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN613", roroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN541", roroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN542", roroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN543", roroLCs, true, 1);
			// GET LOAD DLR
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN681", altRoroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN682", altRoroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN683", altRoroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN611", altRoroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN612", altRoroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN613", altRoroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN541", altRoroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN542", altRoroLCs, true, 1);
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN543", altRoroLCs, true, 1);
			
			roroLCs.copyNoDuplicates(theEditions);
			altRoroLCs.copyNoDuplicates(theEditions);
		
			app.myTrxUA.doRORORequestDLRSoB(roroLCs, altRoroLCs, false,DLR_MOVETYPE, theEditions, app.myPassport);	
			self.assertNoTrxErrorsOrWarnings();
			theTI := roroLCs.last.allTrackedItems.first;
			self.assertTrueMsg(theTI.isRehandle, theTI.id &amp; " should be a DLR Rehandle");
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KP2",roroLCs, true);
			assertTrue(voyageJob &lt;&gt; null);
			
			
			
		
		
		
		
		
			// ### CONTAINER POSITIONS including OOTL
			roroLCs.clear();
			altRoroLCs.clear();
			self.getJobROROSlotController("UTBISH1",DECK1, roroLCs, true, 75);
			
			realAlloc := self.addVoyageAllocation(voyage, "NZWLG", "GEN2", "", TI_CargoType_Container, false, false);
			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
		

			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KPI",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
	
	
	
			// ### 30 Exports
			roroLCs.clear();
			altRoroLCs.clear();
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN421", roroLCs, true, 1); 
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN422", roroLCs, true, 1); 
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN423", roroLCs, true, 1); 
			
			realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "30BX", "", TI_CargoType_Container, false, false);
			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KP2",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
	
			// ### 45 Exports
			roroLCs.clear();
			altRoroLCs.clear();
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN491", roroLCs, true, 1); 
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN492", roroLCs, true, 1); 
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN493", roroLCs, true, 1); 
			
			realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "45BX", "", TI_CargoType_Container, false, false);
			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KP2",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
	
			// ### 53 Exports
			roroLCs.clear();
			altRoroLCs.clear();
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN561", roroLCs, true, 1); 
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN562", roroLCs, true, 1); 
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN563", roroLCs, true, 1); 
			
			realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "53FT", "", TI_CargoType_Container, false, false);
			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KP2",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
	
	
	
	
	
			// PAR 28968
			roroLCs.clear();
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN351", roroLCs, true, 1); // DLR
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KPI",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
			roroLCs.clear();
			self.getJobROROControllerByID("UTBISH1",DECK1, null, "AUTOLOCN302", roroLCs, true, 1); // SOB
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KPI",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
			
			
			
			self.planLoadItemDLR_RORO("DLRR2022452","AUTOLOCN351",  "DLR");
// ALREADY PLANNED			self.planLoadItemDLR_RORO("SOBB2022452","AUTOLOCN302",  "SOB");

			// ### GC ALLOCATION
			realAlloc := self.addVoyageAllocation(voyage, "AUSYD", "", "", ct.id, false, false); // Cannon Balls
 			// ### GC POSITIONS
			roroLCs.clear();
			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 25, -20, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 50, -20, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 75, -20, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);

		
			// ### GC JOB
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KPI",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
			
			// Plan the GC Items to the GC Positions
			roroLCs.copy(theLCs);
			self.planTIsRORO(self.allTIs,theLCs, realAlloc.allRequests.first.CM_RORORequest);
			

			
			
			
			// ### GC ALLOCATION
			realAlloc := self.addVoyageAllocation(voyage, "AUMEL", "", "", ct.id, false, false); // Cannon Balls
 			// ### GC POSITIONS
			roroLCs.clear();
			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 50, 10, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null,null, null, 50, -5, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 75, -5, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);

		
			// ### GC JOB
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KP2",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
			
			// Plan the GC Items to the GC Positions
			self.allTIs.clear();
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899091"]);
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899092"]);
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899093"]);
			theLCs.clear();
			roroLCs.copy(theLCs);

			self.planTIsRORO(self.allTIs,theLCs, realAlloc.allRequests.first.CM_RORORequest);
		endif;
		voyageDeck:=voyage.myROROStructure.allDecksByCode[DECK2];
		if voyageDeck &lt;&gt; null then
		
			// ### GC ALLOCATION
			realAlloc := self.addVoyageAllocation(voyage, "AUSYD", "", "", ct.id, false, false); // Cannon Balls
 			// ### GC POSITIONS
			roroLCs.clear();
			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 25, -20, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 50, -20, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);

		
			// ### GC JOB
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KP2",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
			
			// Plan the GC Items to the GC Positions
			theLCs.clear();
			roroLCs.copy(theLCs);
			self.allTIs.clear();
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899004"]);
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899005"]);
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899006"]);
			self.planTIsRORO(self.allTIs,theLCs, realAlloc.allRequests.first.CM_RORORequest);
			

			
			
			
			// ### GC ALLOCATION
			realAlloc := self.addVoyageAllocation(voyage, "AUMEL", "", "", ct.id, false, false); // Cannon Balls
 			// ### GC POSITIONS
			roroLCs.clear();

			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null, null,50, -5, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null, null,75, -5, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);

		
			// ### GC JOB
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KP2",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
			
			// Plan the GC Items to the GC Positions
			theLCs.clear();
			roroLCs.copy(theLCs);
			self.allTIs.clear();
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899094"]);
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899095"]);
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899096"]);

			self.planTIsRORO(self.allTIs,theLCs, realAlloc.allRequests.first.CM_RORORequest);
		endif;
	endif;

epilog
	delete slots;
	delete theLCs;
	delete altRoroLCs;
	delete roroLCs;
	delete tmpLoadCC;
	delete altSlots;
	delete theEditions;

end;</source>
    </JadeMethod>
    <JadeMethod name="createVoyageSlotsLoadCC" id="39804e59-2316-4299-9dfa-f377c27b01b5">
        <source>createVoyageSlotsLoadCC();
/*23 September 2010	cnwas3	  */

vars
	voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
begin
	//create a voyage job for bay 
	
	voyage := self.getVoyage("UTBISH1");
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType :=true;
	tmpLoadCC.myDischargePort:=app.myRoot.allPorts["NZAKL"];

	
	// ### GET SLOTS NOTE - tier ordinals start at bottom left, cell tiers start at top left.
	// 40 GENL
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,1,1,6,slots);
	//self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	slots.clear;
	// 20 GENL
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,2,3,6,slots);
	//self.markSlotsAsLoadJob(slots,tmpLoadCC);
	slots.clear;

	// 40 REEFER
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,4,1,6,slots);
	//self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Power);
	slots.clear;

	// 20 REEFER
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,5,3,6,slots);
	//self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Power);
	slots.clear;

	// 40 EMPTY
	self.getJobSlotControllers("UTBISH1","01",DeckUnderDeck,1,1,5,slots);
	//self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Empty);
	slots.clear;


	// 40 GENL OD
	self.getJobSlotControllers("UTBISH1","01",DeckUnderDeck,2,3,5, slots);
	//self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_OD);
	slots.clear;
	
	
	/// ## MAKE JOB
	/*self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,1,1,24,slots);
	self.getJobSlotControllers("UTBISH1","01",DeckUnderDeck,1,1,10,slots);
	voyageJob:=self.addVoyageLoadJob(voyage,"CRN1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);*/

epilog
	delete slots;
	delete tmpLoadCC;

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteVoyageSlotsLoadCC" id="af3a588d-9176-47c6-81d5-087b04018279">
        <source>deleteVoyageSlotsLoadCC();
/*23 September 2010	cnwas3	  Initial creation*/


vars
	voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
begin
	//create a voyage job for bay 
	
	voyage := self.getVoyage("UTBISH1");
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType :=true;
	tmpLoadCC.myDischargePort:=app.myRoot.allPorts["NZAKL"];

	
	// ### GET SLOTS NOTE - tier ordinals start at bottom left, cell tiers start at top left.
	// 40 GENL
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,1,1,6,slots);
	
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Erase);
	slots.clear;
	// 20 GENL
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,2,3,6,slots);
	
	slots.clear;

	// 40 REEFER
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,4,1,6,slots);
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Erase);
	
	slots.clear;

	// 20 REEFER
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,5,3,6,slots);
	
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Erase);
	slots.clear;

	// 40 EMPTY
	self.getJobSlotControllers("UTBISH1","01",DeckUnderDeck,1,1,5,slots);
	
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Erase);
	
	slots.clear;


	// 40 GENL OD
	self.getJobSlotControllers("UTBISH1","01",DeckUnderDeck,2,3,5, slots);
	
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Erase);
	
	slots.clear;
	
	/*
	/// ## MAKE JOB
	self.getJobSlotControllers("UTBISH1","01",DeckOnDeck,1,1,24,slots);
	self.getJobSlotControllers("UTBISH1","01",DeckUnderDeck,1,1,10,slots);
	voyageJob:=self.addVoyageLoadJob(voyage,"CRN1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);*/

epilog
	delete slots;
	delete tmpLoadCC;

end;</source>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="b2ed2e2b-ed55-46f0-9b9b-aefcf8bf8349">
        <source>getVoyage(_name: String): CM_Voyage;
// ---------------------------------------------------------------------------
// Created:     04 June 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voy : CM_Voyage;
begin
	voy := self.getTerminal.allVoyagesByCode.getAtKeyGeq(_name, null);
	if voy &lt;&gt; null and voy.code &lt;&gt; _name then
		return null;
	endif;
	
	return voy;

epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="moveAllCargo" id="55ae0cc6-11f1-48b1-8182-948bd7a19813">
        <source>moveAllCargo();
// ---------------------------------------------------------------------------
// Created:     02 June 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyages : ObjectSet;
	voy : CM_Voyage;
	ya : CM_YardAllocation;
	bs : CM_TerminalArea;
	jobSheet : CM_JobSheet;
	job:CM_Job;
	req : CM_Request;
	wle : CM_WorkListEntry;
	location : CM_LocationsController;
	wlesToMove, wlesWithWarnings : CM_WLEArray;
	completedDate : TimeStamp;
	delay : Integer;
begin
	voy := self.getVoyage("UTBISH1");
	self.opts.purge;

	self.opts.addAssoc("Sleep", 5000);
	self.opts.addAssoc("WPOpHrs", 2);	//10 Apr 2012	NDL	Par 29369.
	self.moveAllCargoOnVoyage(voy, REAL_MODE);

epilog

end;</source>
    </JadeMethod>
