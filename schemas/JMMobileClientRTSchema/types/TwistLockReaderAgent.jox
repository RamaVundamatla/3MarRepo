    <JadeMethod name="create" id="5b181aef-758c-4f7d-b6af-58629479e381">
        <updating/>
        <source>create() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	create myConnection as WinCEJadeSerialPort transient;
	self.myCESerialConnection.usePresentationClient:=true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="3db489ce-3413-4b6b-8677-bfae25ee8d42">
        <updating/>
        <source>delete() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.endNotificationForSubscriber(self);
	delete self.myConnection;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClose" id="87d57c32-3f3c-49e0-8b02-093175e53d6e">
        <source>doClose();
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myCESerialConnection &lt;&gt; null then
		self.myCESerialConnection.WinCEJadeSerialPort.close;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOpen" id="6a1ad9a9-124a-42f1-9eb7-bc646bdc0702">
        <source>doOpen();
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myCESerialConnection &lt;&gt; null then
		self.myCESerialConnection.WinCEJadeSerialPort.openAsynch(self,TwistLockReaderAgent::doOpenSuccessful.name);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenSuccessful" id="5d55f8d6-c1dc-4739-a7ae-7b742658e720">
        <source>doOpenSuccessful(connection: Connection);
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	messge : String;
begin
	messge:="Open connection successfully";
	app.writeLog(messge);

epilog

end;</source>
        <Parameter name="connection" type="Connection"/>
    </JadeMethod>
    <JadeMethod name="doRead" id="8122a1f9-2a6e-4a10-97a4-270994bd664d">
        <source>doRead();
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.myCESerialConnection.fillReadBuffer:=true;
	self.myCESerialConnection.readUntilAsynch(EOLBinary ,200,self,TwistLockReaderAgent::doReadSuccessful.name);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doReadSuccessful" id="947a8172-b5c0-4cee-8e01-555a5a60359d">
        <source>doReadSuccessful(connection: Connection;bin: Binary);
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	twistlockInfo : String;
begin
	twistlockInfo:=bin.String;
	global.causeEvent(EVENT_TWISTLOCK_RESPONSE,true,twistlockInfo);
epilog

end;</source>
        <Parameter name="connection" type="Connection"/>
        <Parameter name="bin" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getClientConnectionDetails" id="27727e16-eea2-43ac-9912-30db3b547ebc">
        <source>getClientConnectionDetails();
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

iniFileName : String;
	comName : String;
	speedBps,
	dataBits,
	parity,
	stopBits,
	flowControl,
 	timeout: Integer;
begin
	
	iniFileName := app.getIniFileName();
	comName		:= app.getProfileString(iniFileName, SerialConnectionIniSection, Key_SerialName, null);
	timeout		:= app.getProfileString(iniFileName, SerialConnectionIniSection, Key_SerialTimeout, null).Integer;
	speedBps	:= app.getProfileString(iniFileName, SerialConnectionIniSection, Key_SerialSpeedBps, null).Integer;
	dataBits	:= app.getProfileString(iniFileName, SerialConnectionIniSection, Key_SerialDataBits, null).Integer;
	stopBits	:= app.getProfileString(iniFileName, SerialConnectionIniSection, Key_SerialStopBits, null).Integer;
	parity	:= app.getProfileString(iniFileName, SerialConnectionIniSection, Key_SerialParity, null).Integer;
	flowControl:= app.getProfileString(iniFileName, SerialConnectionIniSection, Key_SerialFlowControl, null).Integer;
	
	if speedBps = null then
		speedBps:=57600;
	endif;
	if dataBits = null then 
		dataBits:=WinCEJadeSerialPort.DataBits8;
	endif;
	if stopBits = null then
		stopBits:=WinCEJadeSerialPort.StopBits_1_0;
	endif;
	if parity = null then
		parity:=WinCEJadeSerialPort.Parity_None;
	endif;
	if flowControl = null then
		flowControl:=WinCEJadeSerialPort.FlowControl_Hardware;
	endif;
	
	//spc.name:="COM1:";
	self.myCESerialConnection.name:=comName;
	self.myCESerialConnection.timeout:=timeout;
	self.myCESerialConnection.speedBps := speedBps;
	self.myCESerialConnection.dataBits := dataBits;
	self.myCESerialConnection.parity := parity;
	self.myCESerialConnection.stopBits :=stopBits;
	self.myCESerialConnection.flowControl := flowControl;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="myCESerialConnection" id="1e8bab7b-da30-4dac-a7a4-8946488c6df6">
        <methodInvocation>mapping</methodInvocation>
        <source>myCESerialConnection(set: Boolean; _value: WinCEJadeSerialPort io) mapping;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if set then
		// set code here
	else
		// get code here
		_value:=myConnection.WinCEJadeSerialPort;
	endif;



epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="WinCEJadeSerialPort" usage="io"/>
    </JadeMethod>
    <JadeMethod name="startNotes" id="9929d88d-ba48-4d64-bdf3-6682daf1abd5">
        <source>startNotes();
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.beginNotification(global, EVENT_TWISTLOCK_READ ,Response_Continuous , null);	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="13405acb-43ed-4009-abe6-f8f4b59aa3e1">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if eventType = EVENT_TWISTLOCK_READ then
		self.doRead();
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="730fa1df-c00b-4073-8678-29063895d7a1">
        <source>validateMe(): Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	message : String;
	allMessages : StringArray;
begin

	create allMessages transient;
	if myConnection = null then
		message:="Connection is null";
		allMessages.add(message);
	endif;
	
	if self.myCESerialConnection.name = null then
		allMessages.add("Connection name is null");
	endif;
	
	
	
	if self.myCESerialConnection.speedBps = null then
		allMessages.add("Connection speed Bps is null");
	endif;
	
	/*
	if self.myCESerialConnection.dataBits = null then
		allMessages.add("Connection data Bits is null");
	endif;
	
	if self.myCESerialConnection.flowControl = null then
		allMessages.add("Connection flow control is null");
	endif;
	
	if self.myCESerialConnection.parity = null then
		allMessages.add("Connection parity is null");
	endif;*/

	if allMessages.size = 0 then
		return true;
	else
		foreach message in allMessages do
			app.writeLog(message);
		endforeach;
		return false;
	endif;
	
epilog
	delete allMessages;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
