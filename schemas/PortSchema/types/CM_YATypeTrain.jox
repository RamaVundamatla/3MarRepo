    <JadeMethod name="getObjects" id="8d5d4e47-e018-480a-92a5-26f2d94abc61">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2009	conkc1	Initial creation
*/
vars
	train    : CM_Train;
	terminal : CM_Terminal;
begin

	terminal := app.getMyTerminalDO_NOT_USE;
	
	foreach train in terminal.allTrainsOnTerminal do 
		objects[train.getYADisplay()] := train;
	endforeach;

epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
