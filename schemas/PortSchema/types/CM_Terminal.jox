    <JadeMethod name="handleCashDebtorInDebt" id="f956bb19-6802-4051-a112-63e93257ebdf">
        <source>handleCashDebtorInDebt( _isError : Boolean output;
						_isWarning : Boolean output;
						_isIgnore : Boolean output
						):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2018	jlgndl1	Initial creation	TFS 38952
// ### JIRA 33806 21JAN2025 NAVAB1

*/

vars

	int : Integer;

begin

	int := self.getConfig(CashOnlyInDebtOption).Integer;
	
	if int = CashOnlyInDebtOption_ERROR then // ### JIRA 33806 23JAN2025 NAVAB1 was wrong global constnat
		_isError := true;
		return app.getErrorString(Cash_debtor_debt_raise_error);
	elseif int = CashOnlyInDebtOption_WARNING then
		_isWarning := true;
		return app.getErrorString(Cash_debtor_debt_raise_warnin);
	elseif int = CashOnlyInDebtOption_NOACTION then
		_isIgnore := true;
		return app.getErrorString(Cash_debtor_debt_no_action);
	else
		_isWarning := true;	// This is the old default behaviour of 'CashProcUnderpayIsError'
		return null;
	endif;

epilog

end;</source>
        <Parameter name="_isError" type="Boolean" usage="output"/>
        <Parameter name="_isWarning" type="Boolean" usage="output"/>
        <Parameter name="_isIgnore" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleWarningLights" id="23bb62ce-59e5-484e-b3c2-037617a883e5">
        <source>handleWarningLights(_stackArea :CM_StraddleStack; _newLCs :CM_LCArray; _directory :String; _reqFileName :String; _resFileName :String; _timeout :Integer) :String;
// Par 17827 CCMS 1507 Hook for Port Otago

vars
	areaA,
	areaC		: CM_StraddleStack;
	lightA1,
	lightA2,
	lightC1,
	lightC2,
	isDelete,
	success,
	fileExists,
	filePathInvalid,
	reqFileDeleted	: Boolean;
	lightStr,
	lightStrRes,
	preStr,
	cellStr,
	errorStr,
	returnStr,	
	resString,
	lightA1Str,
	lightA2Str,
	lightC1Str,
	lightC2Str	: String;
	reqFile,
	resFile		: File;
	folder		: FileFolder;
	i, pos,
	check		: Integer;
	
begin
	if not app.myRoot.client = Client_PortOtago then
		return null;
	endif;
	
	areaA 	:= self.allTerminalAreas["A"].CM_StraddleStack;
	areaC	:= self.allTerminalAreas["C"].CM_StraddleStack;
	
	if areaA = null or areaC = null then
		return "Hook : Not Valid Stack Areas";
	endif;
	
	if _stackArea &lt;&gt; areaA and _stackArea &lt;&gt; areaC then
		return null;
	endif;
	
	isDelete	:= _newLCs = null;
	areaA.labourRestrictionLightsPOA(lightA1, lightA2);
	areaC.labourRestrictionLightsPOC(lightC1, lightC2);
	lightStr	:=	"AE=" &amp; lightA1.dataDumpFormat &amp; "," &amp;
					"AW=" &amp; lightA2.dataDumpFormat &amp; "," &amp;
					"CS=" &amp; lightC1.dataDumpFormat &amp; "," &amp;
					"CN=" &amp; lightC2.dataDumpFormat;
	check := lightA1.Integer + lightA2.Integer + lightC1.Integer + lightC2.Integer;
		
	create reqFile;
	reqFile.mode := File.Mode_Output;	// 26/2/16 cnwmp6 PAR 36286 unicode version
	create resFile;
	resFile.kind := File.Kind_Unknown_Text;	// 26/2/16 cnwmp6 PAR 36286 unicode version
	create folder;
	folder.fileName := _directory;
	filePathInvalid	:= not folder.isAvailable();
	
	if not filePathInvalid then
		reqFile.fileName	:= _directory &amp; _reqFileName;
		resFile.fileName	:= _directory &amp; _resFileName;
		fileExists			:= reqFile.isAvailable();
	endif;
	
	if filePathInvalid then
		errorStr	:= "LIGHT CHANGE FILE PATH INVALID: ";
	elseif not fileExists then
		reqFile.writeLine("AE,AW,CS,CN,Check");
		reqFile.writeLine(lightA1.dataDumpFormat &amp; "," &amp; lightA2.dataDumpFormat &amp; "," &amp; lightC1.dataDumpFormat &amp; "," &amp; lightC2.dataDumpFormat &amp; "," &amp; check.String);
		reqFile.close();
		
		while i &lt; _timeout do
			process.sleep(1000);
			if reqFileDeleted and resFile.isAvailable() then	// response file found
				// process response file
				resFile.readLine();
				resString 	:= resFile.readLine();
				pos 		:= 1;
				lightA1Str 	:= resString.scanUntil(",", pos);	pos := pos + 1;
				lightA2Str 	:= resString.scanUntil(",", pos);	pos := pos + 1;
				lightC1Str 	:= resString.scanUntil(",", pos);	pos := pos + 1;
				lightC2Str 	:= resString.scanUntil(",", pos);
				lightStrRes	:=	"AE=" &amp; lightA1Str &amp; "," &amp; "AW=" &amp; lightA2Str &amp; "," &amp;
								"CS=" &amp; lightC1Str &amp; "," &amp; "CN=" &amp; lightC2Str;
								
				if lightA1Str = 'F' or lightA2Str = 'F' or lightC1Str = 'F' or lightC2Str = 'F' then
					errorStr := "LIGHT CHANGE FAIL. Response: " &amp; lightStrRes &amp; " Request: ";
				elseif lightStr &lt;&gt; lightStrRes then
					errorStr := "RESPONSE FILE DOES NOT MATCH REQUEST. Response: " &amp; lightStrRes &amp; " Request: ";
				else
					success := true;
				endif;
				
				resFile.close();
				break;
			endif;
			if not reqFileDeleted and not reqFile.isAvailable() then	// request file read by PLC and removed
				reqFileDeleted	:= true;
				continue;
			endif;
			i	:= i + 1;
		endwhile;
		if not success and errorStr = "" then	// Timeout
			if not reqFileDeleted then
				errorStr	:= "REQUEST FILE NOT REMOVED: ";
			else
				errorStr	:= "RESPONSE FILE NOT RECEIVED: ";
			endif;
		endif;
	else
		errorStr	:= "LIGHT CHANGE FILE ALREADY PRESENT: ";
	endif;
	
	if isDelete then
		preStr	:= "Labour Restriction Removed from " &amp; _stackArea.id &amp; ": ";
		cellStr	:= null;
	else
		preStr	:= "Labour Restriction Added: ";
		cellStr	:= " Cells in " &amp; _stackArea.id &amp; " : " &amp; _newLCs.auditIdDisplay();
	endif;
	
	if success then
		returnStr	:= preStr &amp; "The request to reset warning lights has been sent successfully: " &amp; lightStr;
	else
		returnStr	:= preStr &amp; "The request to reset warning lights has been UNSUCCESSFUL: " &amp; errorStr &amp; lightStr &amp;
						" Please RESET the warning lights MANUALLY";
	endif;
	if success then
		self.createCommitStringAlertWithSev("Labour Restriction Warning Lights", returnStr &amp; cellStr &amp; " User: " &amp; app.myPassport.myUser.userName, SEVERE_INFO);
	else
		self.createCommitStringAlertWithSev("ERROR: Labour Restriction Warning Lights", returnStr &amp; cellStr &amp; " User: " &amp; app.myPassport.myUser.userName, SEVERE_ERROR);
	endif;
	
	return returnStr;
epilog
	delete reqFile;
	delete resFile;
	delete folder;
end;</source>
        <Parameter name="_stackArea" type="CM_StraddleStack"/>
        <Parameter name="_newLCs" type="CM_LCArray"/>
        <Parameter name="_directory" type="String"/>
        <Parameter name="_reqFileName" type="String"/>
        <Parameter name="_resFileName" type="String"/>
        <Parameter name="_timeout" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleWarningLights7" id="542dd311-fe3c-465e-8fd7-7137b7de1c23">
        <source>handleWarningLights7(_stackArea :CM_StraddleStack; _newLCs :CM_LCArray; _directory :String; _reqFileName :String; _resFileName :String; _timeout :Integer) :String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2019	jlgndl1	Initial creation	TFS 46576 - Extend Labour on Block lights from 4 to 7 for POL

*/

vars
	areaA,
	areaC		: CM_StraddleStack;
	lightAE,
	lightAW,
	lightASUB,
	lightCS,
	lightCN,
	lightCSUB,
	lightCPTI,
	isDelete,
	success,
	fileExists,
	filePathInvalid,
	reqFileDeleted	: Boolean;
	lightStr,
	lightStrRes,
	preStr,
	cellStr,
	errorStr,
	returnStr,	
	resString,
	lightAEStr,
	lightAWStr,
	lightASUBStr,
	lightCSStr,
	lightCNStr,
	lightCSUBStr,
	lightCPTIStr : String;
	reqFile,
	resFile		: File;
	folder		: FileFolder;
	i, pos,
	check		: Integer;
	
begin
	if not app.myRoot.client = Client_PortOtago then
		return null;
	endif;
	
	areaA 	:= self.allTerminalAreas["A"].CM_StraddleStack;
	areaC	:= self.allTerminalAreas["C"].CM_StraddleStack;
	
	if areaA = null or areaC = null then
		return "Hook : Not Valid Stack Areas";
	endif;
	
	if _stackArea &lt;&gt; areaA and _stackArea &lt;&gt; areaC then
		return null;
	endif;
	
	isDelete	:= _newLCs = null;
	areaA.labourRestrictionLightsPOA3(lightAE, lightAW, lightASUB);
	areaC.labourRestrictionLightsPOC4(lightCS, lightCN, lightCSUB, lightCPTI);
	lightStr	:=	"AE=" &amp; lightAE.dataDumpFormat &amp; "," &amp;
					"AW=" &amp; lightAW.dataDumpFormat &amp; "," &amp;
					"ASUB=" &amp; lightASUB.dataDumpFormat &amp; "," &amp;
					"CS=" &amp; lightCS.dataDumpFormat &amp; "," &amp;
					"CN=" &amp; lightCN.dataDumpFormat &amp; "," &amp;
					"CSUB=" &amp; lightCSUB.dataDumpFormat &amp; "," &amp;
					"CPTI=" &amp; lightCPTI.dataDumpFormat;
	check := lightAE.Integer + lightAW.Integer + lightASUB.Integer + lightCS.Integer + lightCN.Integer + lightCSUB.Integer + lightCPTI.Integer;
		
	create reqFile;
	reqFile.mode := File.Mode_Output;	
	create resFile;
	resFile.kind := File.Kind_Unknown_Text;	
	create folder;
	folder.fileName := _directory;
	filePathInvalid	:= not folder.isAvailable();
	
	if not filePathInvalid then
		reqFile.fileName	:= _directory &amp; _reqFileName;
		resFile.fileName	:= _directory &amp; _resFileName;
		fileExists			:= reqFile.isAvailable();
	endif;
	
	if filePathInvalid then
		errorStr	:= "LIGHT CHANGE FILE PATH INVALID: ";
	elseif not fileExists then
		reqFile.writeLine("AE,AW,ASUB,CS,CN,CSUB,CPTI,Check");
		reqFile.writeLine(	  lightAE.dataDumpFormat &amp; ","
							&amp; lightAW.dataDumpFormat &amp; ","
							&amp; lightASUB.dataDumpFormat &amp; ","
							&amp; lightCS.dataDumpFormat &amp; ","
							&amp; lightCN.dataDumpFormat &amp; ","
							&amp; lightCSUB.dataDumpFormat &amp; ","
							&amp; lightCPTI.dataDumpFormat &amp; ","
							&amp; check.String );
		reqFile.close();
		
		while i &lt; _timeout do
			process.sleep(1000);
			if reqFileDeleted and resFile.isAvailable() then	// response file found
				// process response file
				resFile.readLine();
				resString 	:= resFile.readLine();
				pos 		:= 1;
				lightAEStr 	:= resString.scanUntil(",", pos);	pos := pos + 1;
				lightAWStr 	:= resString.scanUntil(",", pos);	pos := pos + 1;
				lightASUBStr := resString.scanUntil(",", pos);	pos := pos + 1;
				lightCSStr 	:= resString.scanUntil(",", pos);	pos := pos + 1;
				lightCNStr 	:= resString.scanUntil(",", pos);	pos := pos + 1;
				lightCSUBStr := resString.scanUntil(",", pos);	pos := pos + 1;
				lightCPTIStr := resString.scanUntil(",", pos);
				lightStrRes	:=	  "AE=" &amp; lightAEStr &amp; ","
								&amp; "AW=" &amp; lightAWStr &amp; ","
								&amp; "ASUB=" &amp; lightASUBStr &amp; ","
								&amp; "CS=" &amp; lightCSStr &amp; ","
								&amp; "CN=" &amp; lightCNStr &amp; ","
								&amp; "CSUB=" &amp; lightCSUBStr &amp; ","
								&amp; "CPTI=" &amp; lightCPTIStr;
								
				if lightAEStr = 'F' or lightAWStr = 'F' or lightASUBStr = 'F'  or lightCSStr = 'F' or lightCNStr = 'F' or lightCSUBStr = 'F' or lightCPTIStr = 'F' then
					errorStr := "LIGHT CHANGE FAIL. Response: " &amp; lightStrRes &amp; " Request: ";
				elseif lightStr &lt;&gt; lightStrRes then
					errorStr := "RESPONSE FILE DOES NOT MATCH REQUEST. Response: " &amp; lightStrRes &amp; " Request: ";
				else
					success := true;
				endif;
				
				resFile.close();
				break;
			endif;
			if not reqFileDeleted and not reqFile.isAvailable() then	// request file read by PLC and removed
				reqFileDeleted	:= true;
				continue;
			endif;
			i	:= i + 1;
		endwhile;
		if not success and errorStr = "" then	// Timeout
			if not reqFileDeleted then
				errorStr	:= "REQUEST FILE NOT REMOVED: ";
			else
				errorStr	:= "RESPONSE FILE NOT RECEIVED: ";
			endif;
		endif;
	else
		errorStr	:= "LIGHT CHANGE FILE ALREADY PRESENT: ";
	endif;
	
	if isDelete then
		preStr	:= "Labour Restriction Removed from " &amp; _stackArea.id &amp; ": ";
		cellStr	:= null;
	else
		preStr	:= "Labour Restriction Added: ";
		cellStr	:= " Cells in " &amp; _stackArea.id &amp; " : " &amp; _newLCs.auditIdDisplay();
	endif;
	
	if success then
		returnStr	:= preStr &amp; "The request to reset warning lights has been sent successfully: " &amp; lightStr;
	else
		returnStr	:= preStr &amp; "The request to reset warning lights has been UNSUCCESSFUL: " &amp; errorStr &amp; lightStr &amp;
						" Please RESET the warning lights MANUALLY";
	endif;
	if success then
		self.createCommitStringAlertWithSev("Labour Restriction Warning Lights", returnStr &amp; cellStr &amp; " User: " &amp; app.myPassport.myUser.userName, SEVERE_INFO);
	else
		self.createCommitStringAlertWithSev("ERROR: Labour Restriction Warning Lights", returnStr &amp; cellStr &amp; " User: " &amp; app.myPassport.myUser.userName, SEVERE_ERROR);
	endif;
	
	return returnStr;
epilog
	delete reqFile;
	delete resFile;
	delete folder;
end;</source>
        <Parameter name="_stackArea" type="CM_StraddleStack"/>
        <Parameter name="_newLCs" type="CM_LCArray"/>
        <Parameter name="_directory" type="String"/>
        <Parameter name="_reqFileName" type="String"/>
        <Parameter name="_resFileName" type="String"/>
        <Parameter name="_timeout" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
