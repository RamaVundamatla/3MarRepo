    <JadeMethod name="getAvailableMemoryString" id="ed5b499a-db41-45d8-9561-2fb6a5e005de">
        <source>getAvailableMemoryString() : String;

vars
	a, t : Integer;
	
begin
	a := self.availableMemory;
	t := self.totalMemory;
	
	if a &lt; 1 or t &lt; 1 then
		return "0" &amp; Tab &amp; "0%";
	endif;

	return a.asMegabytes.roundedTo(1).String &amp; Tab &amp;
		((a / t) * 100).roundedTo(1).String &amp; "%";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableString" id="6c03bd69-e766-4c4f-9100-06282f127120">
        <source>getTableString() : String;

vars
	freePercentage : Real;
	a, t : Integer;
	s : String;
	
begin
	a := self.availableMemory;
	t := self.totalMemory;
	
	if a &lt; 1 or t &lt; 1 then
		freePercentage := 0;
	else
		freePercentage := (a / t) * 100;
	endif;

	s := self.name;
	if self.isDbServer then
		s := s &amp; " (Server)";
	endif;
		
	return s &amp;
		   Tab &amp;
		   self.cpu &amp;
		   Tab &amp;
		   t.asMegabytes.roundedTo(2).String &amp;
		   Tab &amp;
		   a.asMegabytes.roundedTo(2).String &amp;
		   Tab &amp;
		   freePercentage.roundedTo(2).String &amp;
		   '%' &amp;
		   Tab &amp;
		   self.allNodeDescriptors.size.String &amp;
		   Tab &amp;
		   self.allProcessDescriptors.size.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isDbServer" id="e3d319fe-11be-4179-bee7-a4a33c7bf52f">
        <source>isDbServer() : Boolean;

begin
	return self.mySessionDescWhenDbServer &lt;&gt; null;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAvailableMemory" id="478c5b8b-0b9c-449b-8685-4b0a87f588cb">
        <updating/>
        <source>setAvailableMemory(_availMem : Integer) updating;

begin
	if _availMem &lt;= 0 then
		self.availableMemory := 0;
	else
		self.availableMemory := _availMem;
	endif;
end;</source>
        <Parameter name="_availMem" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTotalAndAvailableMemory" id="22bc8dcd-9942-45cc-b3e2-8abd3cff94ea">
        <updating/>
        <source>setTotalAndAvailableMemory(_totalMem, _availMem : Integer) updating;

begin
	if _totalMem &lt;= 0 then
		self.totalMemory := 0;
	else
		self.totalMemory := _totalMem;
	endif;
	
	if _availMem &lt;= 0 then
		self.availableMemory := 0;
	else
		self.availableMemory := _availMem;
	endif;
end;</source>
        <Parameter name="_totalMem" type="Integer"/>
        <Parameter name="_availMem" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateForCreate" id="61985bd9-c166-4d54-9373-04870a1cb518">
        <updating/>
        <source>updateForCreate(_name : String; _totalMem, _availMem : Integer;
	_cpu : String; _session : SessionDescriptor) updating;

begin
	self.name := _name;
	
	self.setTotalAndAvailableMemory(_totalMem, _availMem);
	
	self.cpu := _cpu.trimBlanks;

	self.mySessionDescriptor := _session;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_totalMem" type="Integer"/>
        <Parameter name="_availMem" type="Integer"/>
        <Parameter name="_cpu" type="String"/>
        <Parameter name="_session" type="SessionDescriptor"/>
    </JadeMethod>
</Class>
