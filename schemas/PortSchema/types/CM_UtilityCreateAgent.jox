    <JadeMethod name="utlCreateTIsForGenCargo" id="f20952a7-428c-40a7-8b46-22500e82f67b">
        <updating/>
        <source>utlCreateTIsForGenCargo(pIntFaceArray : CMIF_TIObjectArray; _validateOnly: Boolean; _passport : CM_Passport input) updating;
/*
	Created on 18 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	item		: CMIF_TIObject;
	nullObject	: CM_Object;
	tmpEvent	: Integer;
	todo, done	: Integer;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	// do the validation here
	foreach item in pIntFaceArray do
		if item.isKindOf(CMIF_Receival) then
			item.validateForCreate(_passport);		//Also does the sub items
			app.setContinueCMExceptions(true);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Item is not a Tracked Item (' &amp; item.String &amp; ')');
		endif;
	endforeach;
	
	if (not self.checkValidationWithPassport(_passport))
	and (not _validateOnly)then
		return;
	endif;

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;

	todo := pIntFaceArray.size;
	foreach item in pIntFaceArray do
		done := done + 1;
		if (_passport.myCMIFMonitor &lt;&gt; null) then
			_passport.myCMIFMonitor.updateProgress("Creating tracked item", todo, done);
		endif;
				
		//want to keep going to get all errors at once while _validateOnly = true
		if (not item.actionForCreate(nullObject, _passport))
		and (not _validateOnly) then 	//Also does sub items
			break;
		endif;
		
		if (not _passport.noErrors())
		and (not _validateOnly) then
			break;
		endif;
		
	endforeach;

	if _passport.noErrors 
	and (not _validateOnly) then
		// issue notifications on created objcets
		tmpEvent := _passport.myTerminal.getTerminalEvent(TIEvent_PreNote_Add);
		foreach item in pIntFaceArray do
			if item.isKindOf(CMIF_Receival) then
				item.CMIF_Receival.myPersistentTrackedItem.causeEvent(tmpEvent, false, item.CMIF_PreNote.myPersistentTrackedItem);
			endif;
		endforeach;
	endif;	

end;</source>
        <Parameter name="pIntFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateTSWWebService" id="2ade7b74-7b0f-4e06-8648-80f74bc85f1e">
        <source>utlCreateTSWWebService(	_pxyTSWWebService 	: CM_TSWWebService; 
						_newTSWWebService 	: CM_TSWWebService output; 
						_cmifConfig 		: CMIF_ConfigRoot input;		// TFS 52746
						_expectedEdition 	: Integer;						// TFS 52746
						_passport			: CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
// 10/03/2022	navdap1		TFS 52746 PNL Custom Hold Clearance for Export Units using BOL with TSW EDI
// 31/03/2025 	navma1  	MTN-34387 MTN - Removing Unnecessary Audits
vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valTSWWebService(_pxyTSWWebService);
    
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	   
	app.setContinueCMExceptions(false);

	create _newTSWWebService persistent;
	
	_newTSWWebService.setForCreate(_pxyTSWWebService);
	
	/*
	31.03.2025 navma1 #MTN-34387
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newTSWWebService);
	endif;
	*/
	
	if _passport.noErrors then																	// TFS 52746
		app.myUtilityUA.utlUpdateConfig(_cmifConfig, app.myRoot, _expectedEdition, _passport);	// TFS 52746
	endif;																						// TFS 52746

epilog

end;</source>
        <Parameter name="_pxyTSWWebService" type="CM_TSWWebService"/>
        <Parameter name="_newTSWWebService" type="CM_TSWWebService" usage="output"/>
        <Parameter name="_cmifConfig" type="CMIF_ConfigRoot" usage="input"/>
        <Parameter name="_expectedEdition" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
