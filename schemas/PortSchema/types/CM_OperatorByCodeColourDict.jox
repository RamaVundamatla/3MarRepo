<CollClass name="CM_OperatorByCodeColourDict" id="2280deef-801f-40b7-b310-c859f0eaa5d5">
    <memberType name="CM_Operator"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <MemberKey>
        <property name="CM_Operator::code"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_Operator::colour"/>
    </MemberKey>
    <JadeMethod name="removeObject" id="4093bea7-85ce-4538-8e2a-e2333c6d9ee8">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_obj : MemberType) : Boolean updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter	: Iterator;
	tmpObj	: MemberType;
	keyCode	: String;
	keyNum	: Integer;
begin
	iter := self.createIterator();
	
	while iter.next(tmpObj) do
		if tmpObj = _obj then
			self.getIteratorKeys(keyCode, keyNum, iter);
			self.removeKey(keyCode, keyNum);
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
