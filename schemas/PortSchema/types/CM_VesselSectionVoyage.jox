    <JadeMethod name="cloneMySelf" id="6cb38c0e-d8d2-4760-9b89-c0cf982b8498">
        <updating/>
        <source>cloneMySelf(_newVoyage : CM_VoyageStructuralElements) : CM_VesselSectionVoyage updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	newMe : SelfType;
begin
	newMe := self.cloneSelf(false);
	//newMe.myVoyageStructure := _newVoyage;
	newMe.myVoyageStructuralElement := _newVoyage;
		
	return newMe;

epilog

end;</source>
        <Parameter name="_newVoyage" type="CM_VoyageStructuralElements"/>
        <ReturnType type="CM_VesselSectionVoyage"/>
    </JadeMethod>
    <JadeMethod name="delete" id="a16b5deb-74b2-4751-a32a-f70f360021ec">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if self.isTransient then
		return;
	endif;
	
	if self.myVoyageStructuralElement &lt;&gt; null then
		self.myVoyageStructuralElement.causeEvent(EVENT_SECTION_DELETE,false,self);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditParent" id="6d9968b6-b382-432a-b2d2-dae388a51a13">
        <source>getAuditParent(): CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if self.myVoyageStructuralElement = null then
		return null;
	endif;
	
	return self.myVoyageStructuralElement.myVoyage;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getStructure" id="07d89b96-ae91-4112-a310-d6963949c294">
        <source>getStructure(): CM_VoyageStructuralElements;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	return self.myVoyageStructuralElement;

epilog

end;</source>
        <ReturnType type="CM_VoyageStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="23026f0f-3b3e-4148-9ed8-6d42c5e7ae9c">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	pxySelf : SelfType;
	completedOK		: Boolean;
begin
	pxySelf:= inheritMethod();
	
	pxySelf.myVoyageStructuralElement:=self.myVoyageStructuralElement;
	
	completedOK := true;			
	return pxySelf;

epilog
	if not completedOK then			
		delete pxySelf;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7623bbce-bc5c-4d18-b6d7-5f7133e65c24">
        <updating/>
        <source>setForUpdate(_proxySelf: SelfType; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116
22 June 2011	cnwer1  added auditing
*/

vars

	voyage : CM_Voyage;
	beforeAuditText,
	afterAuditText	: String;
	realStructure : CM_VoyageStructuralElements;
begin
	
	if _proxySelf.myVoyageStructuralElement.isTransient then
		realStructure:=_proxySelf.myVoyageStructuralElement.pxyGetRealObject();
	else
		realStructure:=_proxySelf.myVoyageStructuralElement;
	endif;

	if  realStructure &lt;&gt; null then
		beforeAuditText:=realStructure.getAuditText;
	endif;
	
	inheritMethod(_proxySelf, _passport);
	
	self.myVoyageStructuralElement:=realStructure;
	
	if self.myVoyageStructuralElement &lt;&gt; null then
		
		voyage:= self.myVoyageStructuralElement.myVoyage;
		afterAuditText:=self.myVoyageStructuralElement.getAuditText;
		app.myAA.auditUpdateTrx(voyage,beforeAuditText, afterAuditText);
	
		
		if _proxySelf.pxyGetRealObject =null then
			self.myVoyageStructuralElement.causeEvent(EVENT_SECTION_CREATE,false,self);
		else
			self.myVoyageStructuralElement.causeEvent(EVENT_SECTION_UPDATE,false,self);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_proxySelf" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyageStructure" id="dbc0733d-79c9-4298-92ae-c151010abe54">
        <updating/>
        <source>setMyVoyageStructure(_voyageStructure : CM_VoyageStructuralElements ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if not _voyageStructure.isKindOf(CM_VoyageStructuralElements) then
	// ONLY STORE SECTIONS ON THE CELLULAR STRUCTURE NOT THE RORO STRUCTURE
		app.raiseCMException2(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,null,null);
		return;
	endif;
	
	self.myVoyageStructuralElement :=_voyageStructure;
epilog

end;</source>
        <Parameter name="_voyageStructure" type="CM_VoyageStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="a384abd9-e4a8-4370-b564-34b911acad0a">
        <source>validateCreate(_passport: CM_Passport input);

/*

Purpose:		Add validate for code and position

Parameters:			

Return Value:		


Date			Who		Reason
19 October 2011	cnwmh5	Initial creation #28440

*/

vars

begin

	inheritMethod(_passport);

	if self.myVoyageStructuralElement &lt;&gt; null then
		self.validateAllSectionsAndByPos(self.myVoyageStructuralElement.allSections, 
			self.myVoyageStructuralElement.allSectionsByPosition);
	endif;		
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="6e4cedc4-fa47-4b61-b608-da4a67956ff1">
        <source>validateUpdate(_passport: CM_Passport input);

/*

Purpose:		Add validation for duplicate code and position

Parameters:			

Return Value:		


Date			Who		Reason
18 October 2011	cnwmh5	Initial creation #28440

*/

vars

begin

	inheritMethod(_passport);

	if self.myVoyageStructuralElement &lt;&gt; null then
		self.validateAllSectionsAndByPos(self.myVoyageStructuralElement.allSections, 
			self.myVoyageStructuralElement.allSectionsByPosition);
	endif;		
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
