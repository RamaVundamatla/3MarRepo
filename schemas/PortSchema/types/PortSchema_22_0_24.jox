    </JadeMethod>
    <JadeMethod name="setEDIHSCodeValidConfig" id="8d892bf7-1ac4-4150-8472-8fd440e52f80">
        <source>setEDIHSCodeValidConfig(_controller : CnEcReleaseController);
/*

Purpose:			Set Terminal Config "EDI HS Code must be valid" to true for all terminals

Parameters:			

Return Value:		

Date				Who		Reason
04 July 2024		jlizm1	Initial creation TFS 64736 HS Code edi allow invalid codes

*/

vars
	terminal : CM_Terminal;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Initializing EDI HS Code Must be valid setting", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initializing EDI HS Code Must be valid setting") ;	
	endif;
	
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals do
		terminal.setConfig(EdiHSCodeMustBeValid, true);
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Initializing EDI HS Code Must be valid setting complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Initializing EDI HS Code Must be valid setting complete") ;
	endif;

	self.addScriptRun(method.name);
	
epilog
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setExtApiLastSuccessfulTS" id="cda2fd4b-295b-4505-a32e-23eae2f8a8e6">
        <source>setExtApiLastSuccessfulTS(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Dec 2025	navah1	Initial creation
11 Dec 2025	navah1	MTN-36365: NSW | OnePort API Last Run Date - Populate terminal-specific Last Successful Date/Time on upgrade
*/

vars
	externalWebService : CM_ExternalWebServiceDef;
	externalAPIDef	: CM_APIEndpointServiceDef;
	terminal : CM_Terminal;
	allExternalWebServices : CM_ExtWebServiceDefDict;
	allTerminals : CM_TerminalByCodeDict;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; Tab &amp; "Setting lastSuccessfullTS on all API endpoints to null", LogINFO);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Adding terminal specific lastSuccessfullTS on all API endpoints", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting lastSuccessfullTS on all API endpoints to null");
		_controller.logEntry("Adding terminal specific lastSuccessfullTS on all API endpoints");
	endif;
	
	create allExternalWebServices transient;
	create allTerminals transient;
	
	app.myRoot.allExternalWebServices.tryCopy(allExternalWebServices);
	app.myRoot.allTerminals.tryCopy(allTerminals);
	
	foreach	externalWebService in allExternalWebServices do
		if not externalWebService.isAPIDef() then
			continue;
		endif;
		externalAPIDef := externalWebService.CM_APIEndpointServiceDef;
		beginTransaction;
		externalAPIDef.setLastSuccessfulTS(null);
		foreach terminal in allTerminals do
			if externalAPIDef.allTerminalLastSuccessDT[terminal.code] = null then
				externalAPIDef.setLastSuccessfulTSByTerminal(null, terminal);
			endif;
		endforeach;
		commitTransaction;
	endforeach;

	app.writeLog(method.qualifiedName &amp; Tab &amp; "Setting lastSuccessfullTS on all API endpoints to null Completed OK", LogINFO);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Adding terminal specific lastSuccessfullTS on all API endpoints Completed OK", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting lastSuccessfullTS on all API endpoints to null Completed OK");
		_controller.logEntry("Adding terminal specific lastSuccessfullTS on all API endpoints Completed OK");
	endif;

	self.addScriptRun(method.name);
	
epilog
	delete allTerminals;
	delete allExternalWebServices;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setExtFinancialSystemForNSW" id="b2a680b6-b3b0-496e-9325-b6742857b087">
        <source>setExtFinancialSystemForNSW(_controller : CnEcReleaseController);
/*

Purpose:			This script will only run for NSW.
					It goes through each terminal in NSW that currently is using External Financial System Config "CM_InvoiceAPI" and change it to use "CM_InvoiceAPINSW"

Parameters:			

Return Value:		

Date		Who		Reason
10/02/2025	navkc1 JIRA Story MTN-33896: NSW | Invoicing Differentiate NSW Hard Coded Functionality

*/

vars
	currentExtFinIO		: CM_ExtFinanceIO;
	extFinIONSW			: CM_InvoiceAPINSW;
	allTerminals		: ObjectArray;
	terminal			: CM_Terminal;
	
begin
	
	// Only do for NSW
	if not app.myRoot.isClientNSWPorts() then
		return;
	endif;
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	extFinIONSW := CM_InvoiceAPINSW.firstInstance();
	
	if extFinIONSW = null then
		return;
	endif;
	
	create allTerminals transient;
	
	app.writeLog(method.qualifiedName &amp; "NSW changing External Financial System Config to use Invoice API NSW", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry("NSW changing External Financial System Config to use Invoice API NSW") ;	
	endif;
	
	CM_Terminal.allInstances(allTerminals, 0, false);
	
	beginTransaction;
	
	foreach terminal in allTerminals as CM_Terminal do
		currentExtFinIO := terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		
		if currentExtFinIO.isKindOf(CM_InvoiceAPI) then
			app.writeLog(method.qualifiedName &amp; "Changing for Terminal " &amp; terminal.code, LogINFO);
			
			if _controller &lt;&gt; null then
				_controller.logEntry("Changing for Terminal " &amp; terminal.code) ;	
			endif;
			
			// Change to use NSW External Financial System
			terminal.setConfig(FinancialIOClass, extFinIONSW);
			
			app.writeLog(method.qualifiedName &amp; "Done changing for Terminal " &amp; terminal.code, LogINFO);
			
			if _controller &lt;&gt; null then
				_controller.logEntry("Done changing for Terminal " &amp; terminal.code) ;	
			endif;
		endif;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Completed NSW changing External Financial System Config to use Invoice API NSW", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry("Completed NSW changing External Financial System Config to use Invoice API NSW") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete allTerminals;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setIgnoreBerthLOAErrors" id="2b9a7f86-8615-4a33-8bda-3ca5d6d806b2">
        <source>setIgnoreBerthLOAErrors(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2024	navhn30	Initial creation Bug 61636: NSW | Tech Debt - POB QShips Port Authority Config

*/

vars
	harbour  : HMS_Harbour;
	harbours : HMS_HarbourByCodeDict;
	pxyHarbour: HMS_Harbour;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; Tab &amp; "Setting ignoreBerthLOAErrors on all harbours to true for Port of Brisbane", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting ignoreBerthLOAErrors on all harbours to true for Port of Brisbane");
	endif;
	
	if not app.myRoot.isClientPortBrisbane then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Client is not Port of Brisbane - nothing to do", LogINFO);
		self.addScriptRun(method.name);
		return;
	endif;
	
	harbours := app.myRoot.allHarbours;
	if app.myRoot.isClientPortBrisbane then
		foreach harbour in harbours do
			pxyHarbour := app.createUpdateProxy(harbour).HMS_Harbour;
			pxyHarbour.setIgnoreBerthLOAErrors(true);
			app.myTrxUA.trxUpdateHMSObject(pxyHarbour, app.myPassport);
			
			if not app.myPassport.trxCompletedOK then
				app.writeLog(method.qualifiedName &amp;" Failed to Set ignoreBerthLOAErrors to true for " &amp; harbour.description &amp; CrLf  &amp; app.myPassport.getErrorsAsString, LogERROR);
			endif;
		endforeach;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Setting ignoreBerthLOAErrors on all harbours to true for Port of Brisbane Completed OK", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting ignoreBerthLOAErrors on all harbours to true for Port of Brisbane Completed OK") ;
	endif;

	self.addScriptRun(method.name);
	
epilog
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setReeferJobGroupDefault" id="2196facf-20dc-4a3d-aa99-0e4a1be8cd45">
        <source>setReeferJobGroupDefault(_controller : CnEcReleaseController);
/*

Purpose:			
	Initial enabling of ReeferJobGroup config
Parameters:			

Return Value:		

Date		Who		Reason
27OCT2022  NAVSP1  ChangeRequest 54899: PEN - Reefer Monitor App Changes

*/

vars
	term : CM_Terminal;
begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Initial enabling of ReeferJobGroup config", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initial enabling of ReeferJobGroup config") ;	
	endif;
	
	beginTransaction;
	foreach term in app.myRoot.allTerminals do
		if term.getConfig(ReeferJobGrouping).String = null then
			term.setConfig(ReeferJobGrouping, ReeferAppShowDefault);		
		endif;
	endforeach;
	commitTransaction;

	app.writeLog(method.qualifiedName &amp; " Initial enabling of ReeferJobGroup config, Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Initial enabling of ReeferJobGroup config, Completed") ;
	endif;
	
	self.addScriptRun(method.name);
epilog	
end;</source>
