    <JadeMethod name="tblData_click" id="98cfecdc-6310-4375-b684-03d833ec2560">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_click(table: Table input) updating;
/*
Purpose:			

Date		Who		Reason
09 September 2021	navab1	TFS 51853
*/

vars

	icon : CMUI_ToolbarIcon;
	newName : String;
begin
	
	icon := self.tblData.allSelectedObjects.first.CMUI_ToolbarIcon;
	
	if icon = null then
		return;
	endif;

	self.txtIconName.text := icon.caption.removeInvalidChars;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="def06848-964a-40af-909a-b144d814110e">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;

vars

begin
	if table.row &gt; table.fixedRows then
		table.accessRow(table.row).itemObject.inspect;
		return;
	endif;
	
	table.sortColumn[1] := table.column;
	table.sortAsc[1] := not table.sortAsc[1] ;

	table.resort;
	

end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_mouseUp" id="dd9a0951-ca91-4ac6-9af4-8d5ae97f6595">
        <controlMethod name="CM_DataTable::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_mouseUp(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
Purpose:			

Date		Who		Reason
09 September 2021	navab1	TFS 51853
*/

vars

	icon : CMUI_ToolbarIcon;
	newName : String;
begin
	
	icon := self.tblData.allSelectedObjects.first.CMUI_ToolbarIcon;
	
	if icon = null then
		return;
	endif;

	self.txtIconName.text := icon.caption.cnEcRemoveSubstring(" ").cnEcRemoveSubstring("&amp;").cnEcRemoveSubstring(".");


epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="updateDiskName" id="4054759e-4e34-4bbe-a3d9-d46e2126885b">
        <updating/>
        <source>updateDiskName() updating;
 // ### TFS 50421 17SEP2021 NAVAB1
vars
	root : CMUI_Root;
	table : CM_DataTable;
	button : CMUI_ToolbarIcon;
	dataline : String;
	idx : Integer;
	temppic : Picture;
	icon : CMUI_IconFile;
	key : Binary;
	foundEN, foundDIS : Boolean;
begin
	app.mousePointer := Form.MousePointer_HourGlass;

	root := CMUI_Root.firstInstance;
	
	table := self.tblData;
	

	foreach idx in table.fixedRows + 1 to table.rows do
	
		button := table.accessRow(idx).itemObject.CMUI_ToolbarIcon;
		
		beginTransaction;
			button.disabledIconNameDisk := table.accessCell(idx,1).text;
			button.enabledIconNameDisk := table.accessCell(idx,2).text;
		
		
		commitTransaction;
	endforeach;
	app.mousePointer := Form.MousePointer_Default;

end;
</source>
    </JadeMethod>
    <JadeMethod name="updateNewIconsToDB" id="b61b2e26-d74c-4377-88c9-06fe1e133348">
        <updating/>
        <source>updateNewIconsToDB() updating;
 // ### TFS 50421 17SEP2021 NAVAB1
vars
	root : CMUI_Root;
	button : CMUI_ToolbarIcon;
	icon : CMUI_IconFile;
begin
	app.mousePointer := Form.MousePointer_HourGlass;

	root := CMUI_Root.firstInstance;
	
	foreach button in root.allToolbarIcons do
	
		if button.disabledIconOld = null and button.enabledIconOld = null then
			continue;
		endif;
	

			
		// ### NEW ENABLED
		foreach icon in root.allIconFilesByName do : iconloop
			if button.enabledIconNameDisk &amp; ".png" = icon.name then
				
				beginTransaction;
				button.enabledIconNew := icon.icon;
				commitTransaction;
				
				// ### NEW DISABLED
				foreach icon in root.allIconFilesByName do : innerIconloop
					if button.enabledIconNameDisk &amp; ".png_dis" = icon.name then
						beginTransaction;
						button.disabledIconNew := icon.icon;
						commitTransaction;
						
						break innerIconloop;
					endif;
				endforeach;
				
				break iconloop;
			endif;
		endforeach;
			
	endforeach;
	app.mousePointer := Form.MousePointer_Default;

end;
</source>
    </JadeMethod>
</GUIClass>
