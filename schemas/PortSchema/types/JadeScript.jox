        <source>rel821_par31448();
/*
Purpose:			New XL strings for consignee/or address maintenance, new ent table rows and updated tables for address
					display in maintenance.

Date		Who		Reason
13/08/2013	cnwjre1 Initial creation PAR #31448
*/
vars
	transAgent 	: CM_TranslationAgent;
	tmpArray 	: StringArray;
	entAgent	: EntTableAgent;
	entArray	: StringArray;
	
begin
	app.initialize();
	create transAgent transient;
	create tmpArray transient;
	
	tmpArray.add('Address1');
	tmpArray.add('Address2');
	tmpArray.add('Address3');
	tmpArray.add('PostCode');
	tmpArray.add('Country');
	transAgent.trxLoadSpecificErrors(tmpArray);
	
	create entAgent transient;
	create entArray transient;
	entAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	entArray.add ("ETRow_AddressLine1");
	entArray.add ("ETRow_AddressLine2");
	entArray.add ("ETRow_AddressLine3");
	entArray.add ("ETRow_AddressPostCode");
	entArray.add ("ETRow_AddressRegion");
	entArray.add ("ETRow_AddressCountry");
	entArray.add ("ETDef_ConsignMaintTbl");
	entAgent.trxUpdateFromConstant(entArray);

	return;
	
	write Address1;
	write Address2;
	write Address3;
	write PostCode;
	write Country;
	// XL ' Region' already exists

	write ETRow_AddressLine1;
	write ETRow_AddressLine2;
	write ETRow_AddressLine3;
	write ETRow_AddressPostCode;
	write ETRow_AddressRegion;
	write ETRow_AddressCountry;
	
	write ETDef_ConsignMaintTbl;
	
epilog
	delete tmpArray;
	delete transAgent;
end;</source>
    </JadeMethod>
