<Class name="WS_InternalAppRestResponse" id="13f1df4e-995b-4489-9ad4-546e7875fd6d">
    <superclass name="WS_RestResponse"/>
    <transient/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="result" id="73923fa8-d76d-4e89-900e-d5f4ce988628">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="getResponseCode" id="a49485a7-7bbe-4c93-9eee-b9eac6630850">
        <source>getResponseCode(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Apr 2024	navmj1	Initial creation

*/

vars

begin
	// If we have any errors, and no specific response error code set yet, set to Client Error
	if self.result = 1 then
		return HttpResponseClientError;
	else 
		return HttpResponseOK;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
