<Class name="CMIF_InvWq" id="cfede88f-27c5-45d2-ae0e-f5f2d4892f11">
    <superclass name="CMIF_OpsViewTables"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>

DATASET - Waterside, Road, Rail, Yard

Mapping 
 MTN : CM_VoyageJob
 N4  : inv_wq

[gkey] 			   		[bigint] NOT NULL,
[first_shift_gkey] 		[bigint] NULL,
[first_shift_pkey] 		[bigint] NULL,

</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="first_shift_gkey" id="4f6fb2d5-999d-43f7-b861-75caeef8a89b">
        <embedded/>
        <type name="Integer64"/>
    </PrimAttribute>
    <PrimAttribute name="first_shift_pkey" id="544991f3-e249-41e0-ade3-0dc87ec8556d">
        <embedded/>
        <type name="Integer64"/>
    </PrimAttribute>
    <PrimAttribute name="pkey" id="c792c7c9-d70b-4a92-9ff7-195309b360f1">
        <embedded/>
        <type name="Integer64"/>
    </PrimAttribute>
    <JadeMethod name="initializeForActivity" id="2abc8966-bbc1-486c-bc74-82f454cfff78">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*
Purpose:			

Date		Who		Reason
27 August 2021	navab1	TFS 51853
*/

vars
	job   	: CM_Job;
begin
	inheritMethod(_any, _ewsOpsView);
	
	 // ### TFS 53569 10MAY2022 NAVAB1 moved the delete to the top
	self.tableName				:= self.Inv_wq;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey				 := self.generateFullGKey(_any, "");
		self.pkey 				 := self.generateFullGKey(_any, "");
		self.first_shift_gkey 	 := self.generateFullGKey(_any, "");
		self.first_shift_pkey 	 := self.generateFullGKey(_any, "");
		return;
	endif;

	if _any.isKindOf(CM_Job) then // ### TFS 53569 10MAY2022 NAVAB1
		job 	:= _any.CM_Job; // ### TFS 53569 10MAY2022 NAVAB1
		job.initializeForActivity(_ewsOpsView,self); // ### TFS 53569 10MAY2022 NAVAB1
	endif;
	
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
