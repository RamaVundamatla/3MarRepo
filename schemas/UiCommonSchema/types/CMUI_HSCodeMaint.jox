    <JadeMethod name="doSearch" id="93e73d02-c68c-47b6-b6e0-fd0f09089bfa">
        <source>doSearch();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes
26/02/2023				navkc1 	CR 59577 Task 62411: UI - Change Maint to handle new HS Taric
*/

vars
	hs		: CM_HarmonizedSystem;
	pxyHS	: CM_HarmonizedSystem;
	section : CM_HSCodeSection;
	heading : CM_HSCodeHeading;
	chapter : CM_HSCodeChapter;
	code	: CM_HSCodeCode;
	subCode	: CM_HSCodeSubCode;
	taric	: CM_HSCodeTaric;
	coll	: CM_HarmonizedSystemSet;
	theDataLine : String;
	idx,
	colNumber : Integer;
	
begin
	self.tblCodes.clearAllData();
	
	create coll transient;
	section := self.cmbSection.listObject.CM_HSCodeSection;
	chapter := self.cmbChapter.listObject.CM_HSCodeChapter;
	heading := self.cmbHeading.listObject.CM_HSCodeHeading;
	
	if heading &lt;&gt; null and chapter = null then
		chapter:=heading.myHSChapter;
	endif;
	
	
	if section = null and chapter = null and heading = null then
		return;
	endif;
	
	if section &lt;&gt; null and chapter = null  then
		section.allHSCodeChapters.copy(coll);
	endif;
	
	if chapter &lt;&gt; null then
		coll.add(chapter);
	endif;
	
	if chapter = null and section &lt;&gt; null then
		foreach chapter in section.allHSCodeChapters do
			chapter.allHSCodeHeadings.copy(coll);
			foreach heading in chapter.allHSCodeHeadings do
				heading.allHSCodes.copy(coll);
				foreach code in heading.allHSCodes do
					code.allHSSubCodes.copy(coll);
					//26/02/2023	navkc1 CR 59577 Task 62411 - Taric code
					foreach subCode in code.allHSSubCodes do
						subCode.allHSTarics.copy(coll);
					endforeach;
				endforeach;
			endforeach;
		endforeach;
		
	elseif heading = null and chapter &lt;&gt; null then
		chapter.allHSCodeHeadings.copy(coll);
		foreach heading in chapter.allHSCodeHeadings do
			heading.allHSCodes.copy(coll);
			foreach code in heading.allHSCodes do
				code.allHSSubCodes.copy(coll);
				//26/02/2023	navkc1 CR 59577 Task 62411 - Taric code
				foreach subCode in code.allHSSubCodes do
					subCode.allHSTarics.copy(coll);
				endforeach;
			endforeach;
		endforeach;
		
	else
		coll.add(heading);
		heading.allHSCodes.copy(coll);
		foreach code in heading.allHSCodes do
			code.allHSSubCodes.copy(coll);
			//26/02/2023	navkc1 CR 59577 Task 62411 - Taric code
			foreach subCode in code.allHSSubCodes do
				subCode.allHSTarics.copy(coll);
			endforeach;
		endforeach;
	endif;

	foreach hs in coll do
		if not global.isValidObject(hs) then
			return;
		endif;
		if hs.isActivated then
			continue;
		endif;
		theDataLine := hs.getAttributeStringForDefArray(self.tblCodes.allTblDataEntRows);
		idx := self.tblCodes.addItem(theDataLine);
		self.tblCodes.accessRow(idx).itemObject := hs;
	endforeach;
		
epilog
	delete coll;

end;</source>
    </JadeMethod>
    <JadeMethod name="initTable" id="a3a429f7-c1d5-4520-9703-a65082e8c3bd">
        <source>initTable(_table : CM_DataTable);
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;
	
begin
	if _table = null then
		return;
	endif;
	
	theTable := _table;
	
	theTable.userInputEnabled := false;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.multiSelect := CM_EntryTable.MultiSelect_Simple;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(ETDef_HSCodeMaint);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	
	theTable.sortColumn[1] := 2;
	theTable.sortType[1] := theTable.SortType_Numeric;
	
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="loadActiveTable" id="29d4db29-3f1b-41e3-bb6c-a6f144bc457c">
        <source>loadActiveTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
08 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	hs 			: CM_HarmonizedSystem;
	theDataLine : String;
	idx 		: Integer;
	
begin

	self.lblActiveCodes.caption := app.getErrorString1(Currently_active_hs_codes, app.myRoot.allHSCodesActive.size.asStringJMT());
	self.tblCodesActive.clearAllData();
	
	foreach hs in app.myRoot.allHSCodesActive discreteLock do
		if not global.isValidObject(hs) then
			return;
		endif;
		theDataLine := hs.getAttributeStringForDefArray(self.tblCodesActive.allTblDataEntRows);
		idx := self.tblCodesActive.addItem(theDataLine);
		self.tblCodesActive.accessRow(idx).itemObject := hs;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="80ddbf2a-568b-4d71-8bae-b36a42ecdc0f">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	inheritMethod();

	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnAdd.enabled	:= false;
		self.btnRemove.enabled := false;
		self.grpLoadFile.enabled := false;
	endif;
	
	self.cmbSectionBuild();
	self.cmbChapterBuild();
	self.cmbHeadingBuild();
	
	self.initTable(self.tblCodes);
	self.initTable(self.tblCodesActive);
	self.loadActiveTable();
	
	self.optPurge.value := true;
	
	self.sptMain.setLeftControl(self.frmLeft);
	self.sptMain.setRightControl(self.frmRight);
	self.sptMain.showLeftControl(50, false);
	self.sptMain.showRightControl(50, false);
	
epilog

end;</source>
    </JadeMethod>
