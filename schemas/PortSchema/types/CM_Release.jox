    <JadeMethod name="setForDelete" id="b33f4edb-0d90-48ca-b76b-e3a948817a8b">
        <updating/>
        <source>setForDelete(_reason: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2018	jlgndl1	Initial creation	TFS 41971

*/

vars

begin

	inheritMethod(_reason);
	
	//clear the released date and type
	self.myTrackedItem.setReleasedDT(null);
	self.myTrackedItem.setReleasedTransportMode(0);
	
	//reset it from whatever is left.
	self.myTrackedItem.setReleasedDTfromTrxs();

epilog

end;</source>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
