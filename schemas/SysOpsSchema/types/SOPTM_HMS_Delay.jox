    <JadeMethod name="setControlsForAddEdit" id="aa1b2ac1-8a77-4546-b714-5ca32946006a">
        <updating/>
        <source>setControlsForAddEdit() updating;
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 15 July 2003
//
//----------------------------------------------------------

vars
	theForm	:	SOP_TableMaintForm;
	
begin
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_IsChargeable);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
	else
		self.showThumbnail(theForm.myProxyObject.HMS_Delay);
		
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_IsChargeable);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="2249cc03-d654-449b-8bfb-05a4306ffa7d">
        <source>setupThumbnailDetails();
//--------------------------------------------------------
//
// Created by: cnwsh3 
//
// Date: 15 July 2003
//
//----------------------------------------------------------

vars
	defName	:	String;
	theForm	:	SOP_TableMaintForm;
	
begin
	//inheritMethod();
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_HMSDelay);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);
	
	theForm.shtTblInput1.caption := 'Details';
	
	defName := ETDef_HMSDelay;
	
	theForm.initTblInput(theForm.tblInput1, defName);
	theForm.shtTblInput1.visible := true;
	
  	theForm.tblData.userInputEnabled := false;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="057417fb-e445-4c4e-9f88-6f402ac4f1dc">
        <updating/>
        <source>showThumbnail(pObj: HMS_Delay) updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Code, pObj.code);
	theForm.tblInput1.setValueByName(ETRow_Description,pObj.description);
	theForm.tblInput1.setValueByName(ETRow_IsChargeable, pObj.isChargeable);
end;</source>
        <Parameter name="pObj" type="HMS_Delay"/>
    </JadeMethod>
</Class>
