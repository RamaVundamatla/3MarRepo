    <JadeMethod name="setPictureDragCursor" id="e34cbe71-9a9a-473a-bd99-419d87e5b83f">
        <source>setPictureDragCursor(_picture : Picture input);
//--------------------------------------------------------------
//Created: 04 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
//	root : CM_Root;
begin

//	root := self.myTerminal.myRoot;
	
	if self.moveModeForm = REAL_MODE then
	
//		_picture.picture := root.getConfig(PicMvInstantCur).Binary;
		_picture.picture := self.picMvInstantCur.picture;
	elseif self.moveModeForm = QUEUE_MODE then
//		_picture.picture := root.getConfig(PicMvQueueCur).Binary;
		_picture.picture := self.picMvQueueCur.picture;
	elseif self.moveModeForm = PLANNING_MODE then
//		_picture.picture := root.getConfig(PicMvPlanCur).Binary;
		_picture.picture := self.picMvPlanCur.picture;
	elseif self.moveModeForm = YA_GROUP_MODE then
		_picture.picture := self.picYAGroupCur.picture;
	elseif self.moveModeForm = YA_BLOCK_MODE then
		_picture.picture := self.picYAAreaCur.picture;
	endif;
end;</source>
        <Parameter name="_picture" type="Picture" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setRawDefaultSize" id="0d5ab848-2341-4194-aab6-ddb55e82f478">
        <updating/>
        <source>setRawDefaultSize() updating;

/*

Purpose:
			
	In the event that a form has been stretched in painter to be very wide or very
	long, and the user has never had any default values stored for the form, the form
	may open at an inappropriate size, the first time.
	
Parameters:			

Return Value:		


Date		Who		Reason
14 September 2009	cnwndl1	Initial creation	Par 20641

*/
constants
	StdWidth	: Integer = 1020;		// was 800
	StdHeight	: Integer = 700;		// was 600

vars
	pos : Integer;
	cntrl : Control;
	baseCntrl : Window;
	parentCntrl : Window;
begin

	if self.width &gt; StdWidth then
		if self.minimumWidth &gt; StdWidth then
			self.width := self.minimumWidth;
		elseif self.minimumWidth &gt; 0 then
			self.width := self.minimumWidth;
		else
			self.width := StdWidth;
		endif;
	endif;
	
	if self.height &gt; StdHeight then
		if self.minimumHeight &gt; StdHeight then
			self.height := self.minimumHeight;
		elseif self.minimumHeight &gt; 0 then
			self.height := self.minimumHeight;
		else
			self.height := StdHeight;
		endif;
	endif;
	

	//15 Sep 2009	NDL	Par 20482 - Initial users first visit to a form where the JadeDockBars are declared as zero height.
	foreach pos in 1 to self.controlCount do
		cntrl := self.controls(pos);
	
		if cntrl.isKindOf(CMUI_JadeDockBar) then
			if not cntrl.visible or ( cntrl.parent &lt;&gt; null and not cntrl.parent.visible ) then
				// don't want to see it anyway.
				continue;
			endif;
			
			if cntrl.height = 0 then
				// this is one that has an issue.
				baseCntrl := cntrl;
				parentCntrl := cntrl.parent;
				//find the first parent up the tree that has a height &gt; 0.
				while parentCntrl &lt;&gt; null and parentCntrl.height = 0 do
					if not parentCntrl.isKindOf(Control) then
						parentCntrl := null;
						break;
					endif;
					baseCntrl := parentCntrl;
					parentCntrl := baseCntrl.Control.parent;
				endwhile;
				if parentCntrl = null or parentCntrl.height = 0 or ( not parentCntrl.visible ) or ( not baseCntrl.visible ) then
					continue;
				endif;
				//set the height of this one to half its parent's height, and all should be well.
				baseCntrl.height := parentCntrl.height / 2;
			endif;
		endif;
	endforeach;

	
epilog

end;</source>
    </JadeMethod>
