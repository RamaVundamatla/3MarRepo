    <JadeMethod name="delete" id="b6fcdd16-b026-42d1-a7c7-756a6ccffc38">
        <updating/>
        <source>delete() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2012	cnwdw1	Initial creation
*/
vars

begin
	self.allMovementLegs.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFrom" id="1ce45dab-8b63-455f-9b94-f669d8979a74">
        <updating/>
        <source>setFrom(_movement: CM_KPIMovementDtl) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2012	cnwdw1	Initial creation
*/
vars
	leg: CM_KPIMovementLegDtl;
	ws_leg: WS_KPIMovementLegDtl;
begin
	
	foreach leg in _movement.allMovementLegs do
		create ws_leg transient;
		ws_leg.setFrom(leg);
		self.allMovementLegs.add(ws_leg);
	endforeach;
	
	self.cargoId := _movement.cargoId;
	self.cargoType := _movement.cargoType;
	self.duration := _movement.duration;
	self.travelDuration := _movement.travelDuration;
	self.finishTime := _movement.finishTime.asStringForWebInterface;
	self.iso := _movement.iso;
	self.isoGroup := _movement.isoGroup;
	self.operatorId := _movement.operatorId;
	self.shiftId := _movement.shiftId;
	self.source := _movement.source;
	self.sourceType := _movement.sourceType;
	self.startTime := _movement.startTime.asStringForWebInterface;
	self.target := _movement.target;
	self.targetType := _movement.targetType;
	self.terminalId := _movement.terminalId;
	self.teu := _movement.teu;
	self.weight := _movement.weight;
	self.workPointId := _movement.workPointId;
	self.dischargePort :=_movement.dischargePort;
	
epilog

end;</source>
        <Parameter name="_movement" type="CM_KPIMovementDtl"/>
    </JadeMethod>
</Class>
