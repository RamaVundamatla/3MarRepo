    <JadeMethod name="setProxyWodReceival" id="b2fb8bae-eb1a-40f0-8299-3cd6853f2080">
        <updating/>
        <source>setProxyWodReceival(_booking 				  : CM_BookingRef;
					_bookingRefItem			  : CM_BookingRefItem;
					_bol					  : CM_BOL;
					_bolDetail				  : CM_BOLDtl;
					_customExportEntryNumber  : String;
					_transportObject		  : Object;
					_transportMode			  : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
// 20/06/2018   cnwma1		ChangeRequest 38815: PEL1 - WP TI Work Order Changes
// 28/12/2022   navdp20     ChangeRequest 56661:[56012] - Add Transport Mode to Receive and Release work orders
// 17 Apr 2023  navhl20 	ChangeRequest 57322:[57323] EUP - VAS Task linked with Receive Cargo work Order
// 27 Jun 2023	navlw1		ChangeRequest 58730: EUP | Link bill of lading item to Receive work orders
vars

begin
	self.myBookingRef			 := _booking;
	self.myBookingRefItem		 := _bookingRefItem;				//17.4.2023 navhl20 #57322[57323]
	self.myBillOfLading 		 := _bol;
	self.customExportEntryNumber := _customExportEntryNumber; 		//20.6.2018 cnwma1 TFS #38815
	self.transport 				 := _transportMode;					//28.12.2022 navdp20 TFS 56661:[56012]
	self.myBillOfLadingDtl		 := _bolDetail;						//28.6.2023 navlw1 TFS #58730
	
	if _transportObject.isKindOf(CM_Train) then
		self.myTrain 				 := _transportObject.CM_Train;
	elseif _transportObject.isKindOf(CM_Voyage) then
		self.myVoyage 				 := _transportObject.CM_Voyage;
	endif;
epilog

end;</source>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_bookingRefItem" type="CM_BookingRefItem"/>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_bolDetail" type="CM_BOLDtl"/>
        <Parameter name="_customExportEntryNumber" type="String"/>
        <Parameter name="_transportObject" type="Object"/>
        <Parameter name="_transportMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTransportMode" id="f21d8b17-a20c-4be3-8ba0-4eecf8945976">
        <updating/>
