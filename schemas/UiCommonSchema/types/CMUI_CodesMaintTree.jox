    <JadeMethod name="initForm" id="7b21f7bc-85ae-44dc-83e6-028eeb213353">
        <updating/>
        <source>initForm() updating;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars

begin 
	
	lblView.left		:= WinLeftMargin;
	cmbCodeGroup.left	:= WinLeftMargin + lblView.width + HorizontalSpacing;

	lstData.scrollHorizontal := lstData.ScrollHorizontal_Auto;	
	self.shtTblInput1.visible := false;
	self.shtMultiSelect1.visible := false;
	self.shtMultiSelect2.visible := false;
	self.shtMultiSelect3.visible := false;
	self.fldInput.stretchToParent := true;
	
	self.fldInput.useSheetBackColors := true;
	self.fldInput.setDefaultSheetBackColors();
	self.fldInput.initSheetBackColors();

	if self.myViewListbox = null then
		create self.myViewListbox transient;
	endif;
	
	self.allowAdd	 	:= true;
	self.allowAddChild	:= true;
	self.allowDelete 	:= true;
	self.allowPrint := false;
	self.allowUpdate := true;

	self.frmDetailsBottom.visible := false;
	
	self.myDataClass := CM_CodeGroup;
	
	cmbCodeGroup.sorted := false;

	self.mulSelect1.multiSelect	:= ListBox.MultiSelect_Extended;

	self.mulSelect2.multiSelect	:= ListBox.MultiSelect_Extended;

	self.mulSelect3.multiSelect	:= ListBox.MultiSelect_Extended;

	self.iniSheetMultiSelect();
	self.myViewListbox.myListbox := lstData;


	self.cmbCodeGroup.setFocus();
	self.chkInclNotAvail.visible := false;	//21 June 2013	NDL	Par 31770
	self.loadDataForFirstTime();
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblInput" id="068fadc0-77bc-4f9d-8f14-499fbf83aa8f">
        <source>initTblInput(pTable : CM_EntryTable; pDef : String);
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableControl	: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	
begin

	theTable := pTable;
	theTable.rows := 0;
		
	theTable.optimiseRowHeight := true;
	
	theTable.top 	:= 5;
	theTable.left	:= 0;
	theTable.parentTopMargin	:= theTable.top;
	theTable.parentLeftMargin	:= theTable.left;
	theTable.parentRightMargin	:= 15;
	theTable.parentBottomMargin := 10;

	theTable.lockBottom := false;
	theTable.lockRight	:= false;
	theTable.stretchHeight := true;
	theTable.stretchWidth := true;
	
	theTable.pictureViewMethod := 'picViewMethod';
	theTable.pictureLoadMethod := 'picLoadMethod';
	theTable.pictureExtractMethod := 'picExtractMethod';

	entTableControl := app.myController.getEntTableDef(pDef);
	theTable.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
//	theTable.adjustHeight(200);

	//theTable.resetSize();
	//theTable.optimiseHeadingColumn();
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	theTable.cnEcResizeContents();
	
	
end;</source>
        <Parameter name="pTable" type="CM_EntryTable"/>
        <Parameter name="pDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="30ebc3c7-930c-41ea-a9d7-306f032df837">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theActiveControl	: Control;
begin

	inheritMethod(keyCode, shift);
	// DVB changed 22/10/04 
	if keyCode = J_key_Tab then
		theActiveControl := app.activeControl;
		if theActiveControl.parent.isKindOf(CM_EntryTable) then
			theActiveControl := theActiveControl.parent.Control;
		endif;
		if theActiveControl.isKindOf(CM_EntryTable) then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
	//	else
	//		tblInput1.handleFormTab(keyCode, shift, shtTblInput1, cmbCodeGroup);
		endif;
	endif;

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadCodeGroupTypes" id="db92ab6e-d791-4beb-ad05-3140b7d7c243">
        <updating/>
        <source>loadCodeGroupTypes()updating;
// -----------------------------------------------------------------------------
// Created:		28 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;
	descr 		: String;
	strArray	: StringArray;
	value,
	idx			: Integer;
	canDoContainers,
	canDoLogs	: Boolean;
begin

	self.cmbCodeGroup.clear();
	self.allCodeGroupKeys.clear();
	
	canDoLogs := app.myCurrentUserCan(self.myTerminal, Mod_Logs);
	canDoContainers := app.myCurrentUserCan(self.myTerminal, Mod_CargoHandling);	

	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory(CodeGroupTypes);
	constDict := category.getConstants();

	create strArray transient;

	foreach const in constDict do
	
		descr := const.text.cnEcGetTagValueOfName('Descr');
		if descr &lt;&gt; null then
			if allowCodeGroupType(canDoLogs, canDoContainers, const.valueAsInteger) then
				strArray.add(descr);
				self.allCodeGroupKeys.add(const.valueAsInteger);
			endif;
		endif;
		
	endforeach;

	idx := 0;
	foreach descr in strArray do 
		idx := idx + 1;
		if idx &gt; CodeGroup_MaxNumber then
			break;
		endif;

		value := self.allCodeGroupKeys[idx];
		
		if allowCodeGroupType(canDoLogs, canDoContainers, value) then
			self.cmbCodeGroup.addItem(strArray[idx]);
		endif;
		
	endforeach;

epilog
	delete strArray;	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="2c94a892-81a4-4d0a-b2a1-ff6aa5b50edb">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      29 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	self.loadCodeGroupTypes();
	self.currentGroupType := -1;
	if self.cmbCodeGroup.listCount &gt; 0 then
		self.cmbCodeGroup.listIndex := 1;
	endif;
	self.doShowCodeGroup();
	self.doResize();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="replaceDummyLineInTree" id="d7f062b4-b275-4ff4-b9f6-2562d2581423">
        <updating/>
        <source>replaceDummyLineInTree(_vmObj: SOP_ViewModelObject; _index: Integer) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2013	cnwndl1	Initial creation	Par 31770

*/

vars

	level : Integer;
	realObject : CM_Object;
	code : CM_Code;	
	iter : Iterator;
	insertIndex : Integer;
	dummyLineObj : SOP_ViewModelObject;
	includeNotAvail : Boolean;
	tooMany : Boolean;
	msg : String;
begin

	on UserInterfaceException do self.handle14025(exception,tooMany); 

	if _vmObj &lt;&gt; null then
		realObject := _vmObj.myObject;
		if realObject &lt;&gt; null and realObject.isKindOf(CM_CodeGroup) then
			if realObject.CM_CodeGroup.groupType = CodeGroup_SourceLocation then
				if self.lstData.itemText[ _index + 1 ] = app.getErrorString(Empty) then
					// we have a dummy line that the user has just clicked the parent of.
					level := self.lstData.itemLevel[ _index + 1 ];
					//remove the dummy line from the listbox and the dummy object form the forms collection 
					dummyLineObj := self.lstData.itemObject[ _index + 1 ].SOP_ViewModelObject;
					self.lstData.removeItem( _index + 1 );				
					self.allVMObjects.remove( dummyLineObj );
					delete dummyLineObj;
					
					includeNotAvail := self.chkInclNotAvail.visible and self.chkInclNotAvail.value;
					iter := realObject.CM_CodeGroup.allCodes.createIterator();
					insertIndex := _index + 1;
					while iter.next(code) do
						if includeNotAvail or not code.notAvailableForEntry then
							code.replaceDummyInTreeViewArray(self.allVMObjects, level, self, _vmObj, insertIndex);
						endif;
					endwhile; 
				endif; 
			endif;
		endif;
	endif;
	
	if tooMany then
		msg := "Attempt to display too much data in the listbox." &amp; CrLf &amp; "Maximum of 3200 lines permitted." &amp; CrLf &amp; "Please close the form and re-open";
		app.msgBox(msg, app.getErrorString(Warning),MsgBox_OK_Only);
	endif;

epilog
	delete iter;					// 09/201/2013 cnwmh5 #28731
end;</source>
        <access>protected</access>
        <Parameter name="_vmObj" type="SOP_ViewModelObject"/>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resizeMulSelectControl" id="e14331ab-59df-468a-99f1-d1cad037d646">
        <updating/>
        <source>resizeMulSelectControl(_control : CMUI_MultiSelectGroupBox input) updating;
// -----------------------------------------------------------------------------
// Created:		15 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// ----------------------------------------------------------------------------
constants
	LeftMargin		: Integer = 10;
	TopMargin		: Integer = 10;
	VerticalSpacing	: Integer = 5;

vars
	currentTop	: Real;
begin

	currentTop := TopMargin;
	
	_control.top 	:= currentTop;
	_control.left	:= LeftMargin;

	_control.width 	:= _control.parent.width - 10;
	_control.height := _control.parent.height - _control.top - 10;
	_control.cnEcResizeContents();	
end;</source>
        <Parameter name="_control" type="CMUI_MultiSelectGroupBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectVMObject" id="ba1fb91a-911b-4516-918b-4b30855a95e5">
        <updating/>
        <source>selectVMObject(_vmObject : SOP_ViewModelObject; _expand : Boolean) : Integer updating;
// -----------------------------------------------------------------------------
// Created:		20 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	index 	: Integer;
	expand	: Boolean;
	theObj	: SOP_ViewModelObject;
begin

	theObj := _vmObject;
	if not global.isValidObject(theObj) then
		theObj := self.allVMObjects.first.SOP_ViewModelObject;
	endif;
	index := self.allVMObjects.indexOf(theObj);
	if index &lt; 1 then 
		if self.allVMObjects.size = 0 then
			self.setControlsForNoSelection;
			self.doTreeSelect(null);
			return 0;
		else
			index := 1;
		endif;
	else
		expand := _expand;
	endif;
	
	self.lstData.listIndex := index;
	if expand then
		self.lstData.itemExpanded[index] := _expand;
	endif;
	self.doTreeSelect(theObj);
	
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDeleteTV.enabled:= false;
		self.btnEditTV.enabled:= false;
		self.btnNewChildTV.enabled:= false;
		self.btnNewTV.enabled:= false;
		
	endif;
	
	return index;
	
	
end;</source>
        <Parameter name="_vmObject" type="SOP_ViewModelObject"/>
        <Parameter name="_expand" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
