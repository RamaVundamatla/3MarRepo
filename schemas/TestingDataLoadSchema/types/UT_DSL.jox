    <JadeMethod name="createTemperatureReading" id="310264fa-3460-425e-8c04-3b6e27e5c66a">
        <source>createTemperatureReading(_ti : CM_TrackedItem; _dateTime : TimeStamp; _temp : Real; _noCharge : Boolean);
//
// 27/09/2021	navdap1	TFS 52081 MTN Cannot Add Reading for a Reefer for a time other than Now
vars
	tempReadingParams	: CMIF_TempReading;
	loadState			: Boolean;
	theProxyTI			: CM_TrackedItem;

begin

	create tempReadingParams transient;
	
/*	tempReadingParams.isRefConReading := false;
	tempReadingParams.isRefConAlarm := false;
	tempReadingParams.refConRawData := null;
	tempReadingParams.dateTime := _dateTime;
	tempReadingParams.noCharge := _noCharge;
	tempReadingParams.userId := app.getMyUserCode();
	tempReadingParams.myTerminal := self.getTerminal; */
					
	app.cmsBeginLoad(loadState);
	theProxyTI := _ti.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);

/*	tempReadingParams.myTrackedItem := theProxyTI;
	tempReadingParams.noCharge := _ti.noChargeForTemperature(_noCharge, _dateTime);
	tempReadingParams.temperature := _temp; */
	
	//01 Sep 2021	NDL	TFS 51874 - Use common code instead of 14 different variant copies....
	tempReadingParams.initialise(	theProxyTI,	//_reefer : CM_TrackedItem;
									_noCharge,	//_defaultNoChargeValue : Boolean;
									_dateTime,	//_dateTime : TimeStamp;		// TFS 52081
									_temp	//_temperature : Real
									);
			
	app.myTrxCA.trxCreateTempReading(tempReadingParams, null, app.myPassport);	

epilog
	app.cmsEndLoad(loadState);
	delete tempReadingParams;
	delete theProxyTI;
			
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_temp" type="Real"/>
        <Parameter name="_noCharge" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createToDoTaskDesc" id="49cd8d4a-aa20-4f9f-b80b-03ed850c31a0">
        <source>createToDoTaskDesc( _code : String ):CM_ToDoTaskDesc;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
15 October 2010		cnwndl1	Initial creation
02 Nov	   2022 	navds20 ChangeRequest 56634[54259]: EUP - Todo Task Description Maintenance
11 December 2023	TFS 61654 CUX ToDo Task don't block RTL
*/

vars

	term : CM_Terminal;
	selectedCargoTypes : ObjectArray;
	selectedResourceTypes : CM_ObjectSet;
	toDoDesc : CM_ToDoTaskDesc;
	proxy : CM_ToDoTaskDesc;
	createdTransactionType : CM_TransactionType;
	completedTransactionType : CM_TransactionType;
	
	reportDesc		: String;
	requiresExtraInfo : String;
	shortDesc		: String;
	sortKey			: Integer;
	doNotBlockRTL	: Boolean;
	
begin
	term := self.getTerminal;
	
	create selectedCargoTypes transient;
	selectedCargoTypes.add(app.myRoot.allCargoTypesById[ TI_CargoType_Container ]);
	create selectedResourceTypes transient;
	
	if self.opts.includesKey("ReportDesc") then
		reportDesc := self.opts.str("ReportDesc");
	endif;
	shortDesc := _code;
	if self.opts.includesKey("ShortDesc") then
		shortDesc := self.opts.str("ShortDesc");
	endif;
	if self.opts.includesKey("RequiresExtraInfo") then
		requiresExtraInfo := self.opts.str("RequiresExtraInfo");
	endif;
	
	completedTransactionType := app.myRoot.allTransactionTypes[self.opts.int(ETRow_TransactionToCreate)];
	if self.opts.includesKey("TrxTypeOnCompletion") then
		completedTransactionType := self.opts.obj("TrxTypeOnCompletion").CM_TransactionType;
	endif;
	createdTransactionType := app.myRoot.allTransactionTypes[self.opts.int(ETRow_TrxToCreateOnCreation)];
	if self.opts.includesKey("TrxTypeOnCreation") then
		createdTransactionType := self.opts.obj("TrxTypeOnCreation").CM_TransactionType;
	endif;
	
	if self.opts.includesKey("SortKey") then
		sortKey := self.opts.int("SortKey");
	endif;
	
	if self.opts.includesKey("DoNotBlockRTL") then
		doNotBlockRTL := self.opts.bool("DoNotBlockRTL");
	endif;
	
	create proxy transient;
	//createdTransactionType := app.myRoot.allTransactionTypes[self.opts.int(ETRow_TrxToCreateOnCreation)];
	//completedTransactionType := app.myRoot.allTransactionTypes[self.opts.int(ETRow_TransactionToCreate)];
	proxy.setProxy(	_code,	//pDesc:String;
					shortDesc,	//pShortDesc:String;
					sortKey,	//pSortKey:Integer;
					reportDesc,	//pReportDesc:String;
					0,	//pEmptyReportColumn: Integer;
					completedTransactionType,	//_trxTypeOnCompletion : CM_TransactionType;			// 22 Feb 2010 RJS - PAR 22099
					createdTransactionType,	//_trxTypeOnCreation : CM_TransactionType; //cnwrs1 CCMS 1826 29 July 2010
					selectedCargoTypes,	//pAllCargoTypes : Collection;
					selectedResourceTypes,	//pAllResourceTypes : Collection;//18 Dec 2009	NDL	CCMS MES 1006
					false,	//_requiresWorkOrder : Boolean;
					requiresExtraInfo,	//_requiredExtraInfo : String;
					null,	//_selectedTerminals : CM_TerminalSet;	//13 Oct 2010	NDL Par 23991
					term.allSubTerminals,	//_selectedSubTerminals : CM_SubTerminalByCodeDict	//13 Oct 2010	NDL Par 23991
					TODO_TYPE_GROUP_TI,	//02/11/2022 navds20 TFS 56634[54259]
					null,	//02/11/2022 navds20 TFS 56634[54259]
					null,	//02/11/2022 navds20 TFS 56634[54259]
					doNotBlockRTL
					);
	
	app.myTrxCA.trxCreateToDoTaskDesc(proxy, toDoDesc, app.myPassport);
	
	if self.opts.includesKey("Code") then
		beginTransaction;
		toDoDesc.setPropertyValue("code", self.opts.int("Code"));
		commitTransaction;
	endif;	
	
	if self.opts.includesKey("EmptyReportSummaryColumn") then
		beginTransaction;
		toDoDesc.setPropertyValue("emptyReportColumn", self.opts.int("EmptyReportSummaryColumn"));
		commitTransaction;
	endif;
	
	return toDoDesc;

epilog

	delete selectedCargoTypes;
	delete selectedResourceTypes;
	delete proxy;

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="createTrackedItem" id="552c6b6a-0b53-4736-9eec-3beeb8fa2a03">
        <source>createTrackedItem(_id: String; _cargoType: Integer; _commodity: String; _operator: CM_Operator; _asTransient : Boolean; _location : CM_LocationsController) : CM_TrackedItem;
//23 August 2010 cnwml2
//
vars
	cargoTypeInt	: Integer;
	pxyTI			: CM_TrackedItem;
	realTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	root			: CM_Root;
	remarks			: String;
begin
	root := CM_Root.firstInstance;
	
	app.myPassport.setWarningsIgnored(true);			//25/01/2017 cnwmh5
	
	if not _asTransient then
		self.assertNotNullMsg(_location, "Location controller cannot be blank");											// 25/01/2017 cnwmh5
	endif;
	
	cargoType		:= root.allCargoTypesById[ _cargoType ];
	self.assertNotNullMsg(cargoType, "Cargo Type (" &amp; _cargoType.String &amp; ") does not exist");							// 24/01/2017 cnwmh5
	
	// 24/01/2017 cnwmh5
	if _commodity &lt;&gt; null and cargoType.isCommodityRequired then
		self.assertNotNullMsg(cargoType.allCommodities[_commodity], "Cargo Type (" &amp; cargoType.description &amp; ") does not contain Commodity (" &amp; _commodity &amp; ")");
	endif;
	
	if _asTransient then
		pxyTI := self.getTerminal.createTI(cargoType, _asTransient);
		pxyTI.setPxyFromDefaultTI(self.getTerminal, cargoType.id, _id, _commodity, _operator);
		pxyTI.changeState(TI_STATE_NORMAL, app.myPassport);
		pxyTI.setTotalWeight(4000, null, null);					
		if _commodity = "REEF" then
			pxyTI.setTemperature(4);
		endif;
		global.setExtraData(pxyTI.allExtraData, pxyTI, "createdByUnitTest" , self.getClassMethodCreatedBy());
		pxyTI.zSetPxyRemarks(self.createdByUnitTest(pxyTI.remarks));
		return pxyTI;
	else
		beginTransaction;
		realTI := self.getTerminal.createTI(cargoType, _asTransient);
		realTI.setPxyFromDefaultTI(self.getTerminal, cargoType.id, _id, _commodity, _operator);
		realTI.changeState(TI_STATE_NORMAL, app.myPassport);
		realTI.setPropertyValue( "totalWeight", "4000".Decimal );					
		if _commodity = "REEF" then
			realTI.setTemperature(4);
		endif;
		global.setExtraData(realTI.allExtraData, realTI, "createdByUnitTest" , self.getClassMethodCreatedBy());
		// 13/07/015 cnwmh5
		realTI.setRemarks(remarks &amp; self.createdByUnitTest(realTI.remarks), true);
		if realTI.cargoType = TI_CargoType_Log then
			realTI.setPropertyValue("myProduct", cargoType.allProducts.first);
		endif;
		commitTransaction;
		self.move(realTI, _location);					// 24/01/2017 cnwmh5
		return realTI;
	endif;

epilog
	
end;
</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_asTransient" type="Boolean"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
