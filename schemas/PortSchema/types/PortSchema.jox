    <JadeMethod name="isInternalEnvironment" id="60a9e684-d182-479b-9a98-5983220f67a4">
        <source>isInternalEnvironment(_chcOnlyServer : Boolean) : Boolean;
/*

Purpose:			Move common 'environment checking' code to one place

Parameters:			_chcOnlyServer 	- 	Restricts the check to only passing for Christchurch based servers (ie, CNWCHCS71, CNWCHCS101, and CNWCHCS11)
										Probably not really required, but kept in to keep existing code the same

Return Value:		

Date				Who		Reason
04 November 2020	jlgmd1	Initial creation

*/

vars
	envName,
	compName	: String;
begin

	envName := app.myCnKarmaCntrl.environmentId.toLower()[1:3];

	if envName.isOneOf("cnw", "jlg", "nav") then
		compName := app.computerNameAppServer();
		if _chcOnlyServer and compName[4:3] &lt;&gt; "CHC" then
			return false;
		endif;
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_chcOnlyServer" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
