    <JadeMethod name="txtQuantity_lostFocus" id="e631e090-afe4-482b-8ac7-e3a1c4106857">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtQuantity_lostFocus(textbox: GTE_TextBox input) updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sheet	: GTE_Sheet;
	contFrm	: GTE_ContainerFrame;
	qty,
	len,
	idx,
	size	: Integer;
	id		: String;
		
begin
	
	sheet := textbox.mySheet;

	qty := textbox.text.Integer;
	if qty = 0 then
		// quantity must always be at least 1
		qty := 1;
		textbox.text := qty.String;
	endif;

	self.setCellTextFromControl(textbox.mySheet, textbox, textbox.text);

	if sheet.myMenuAction.code &lt;&gt; NavObj_GTE_Out then
		return;
	endif;

	size := sheet.allContainerFrames.size;
	
	if qty &gt; size then
		// need to add some containers
		contFrm := sheet.allContainerFrames.first;
		if contFrm &lt;&gt; null then
			len := contFrm.length;
			id	:= contFrm.id;
		else
			len := 0;
			id	:= sheet.myMenuAction.getHeading;
		endif;
		
		foreach idx in 1 to qty - size do
			trkLayoutOut.setContainer(0, id, len, true, sheet);
		endforeach;
		trkLayoutOut.displayContainers();

	elseif qty &lt; size then
		// need to remove some containers
		
		while true do
			contFrm := sheet.allContainerFrames.last;
			if contFrm &lt;&gt; null then
				// removes from the collection.
				contFrm.clearDetails();
			else
				// must have cleared out all container frames.
				// this should never happen
				break;
			endif;
			if sheet.allContainerFrames.size = qty then
				break;
			endif;
		endwhile;
		trkLayoutOut.displayContainers();

	endif;	

end;</source>
        <Parameter name="textbox" type="GTE_TextBox" usage="input"/>
    </JadeMethod>
