    <JadeMethod name="setLogsInspectedFumigated" id="e7f2dae2-75a5-4c47-9c9c-a85aa2455f6a">
        <source>setLogsInspectedFumigated(_inspect, _fumigate : Boolean);

/*
Date		Who		Reason
09 September 2009	cnwar2	Initial creation (CCMS1107/#20627)

*/
vars
	ti			: CM_TrackedItem;
	txnParams	: CMIF_TITransactionController;
	trans		: CM_TITransaction;
	tmpPassport	: CM_Passport;
	editTrans	: CM_Edit;
	
begin

	tmpPassport := app.myPassport;

	create txnParams transient;
	
	// update each log in the row
	foreach ti in self.allTrackedItems discreteLock do
		if not ti.isKindOf(CM_Log) then
			continue;
		endif;
		
		editTrans := null;
		
		if _inspect then
			if ti.inspectDT = null then	// do not overwite inspect txn if one already exists
				txnParams.type 			:= TRANS_TYPE_INSPECT;
				txnParams.myTrackedItem := ti;
				ti.createTransaction(txnParams, tmpPassport);
			endif;
		else
			ti.setNotInspected(editTrans, tmpPassport);
		endif;
		
		if _fumigate then
			if ti.fumigateDT = null then	// do not overwite fumigate txn if one already exists
				txnParams.type 			:= TRANS_TYPE_FUMIGATE;
				txnParams.myTrackedItem := ti;
				ti.createTransaction(txnParams, tmpPassport);
			endif;
		else
			ti.setNotFumigated(editTrans, tmpPassport);
		endif;
	endforeach;
	
epilog
	delete txnParams;
end;</source>
        <Parameter name="_inspect" type="Boolean"/>
        <Parameter name="_fumigate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="d0b0260e-9f67-4992-83f4-3e8da4881e9d">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

/*
Date		Who		Reason
09 September 2009	cnwar2	Initial creation (CCMS-1107/#20627)

*/
vars
	propName	: String;

begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName = CM_LogController::myLogAreaWhenEmpty.name or
	   propName = CM_LogController::myLocationRestriction.name or
	   propName = CM_LogController::myRow.name or
	   propName = CM_LogController::statusDateTime.name then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="status" id="4d2056f6-745e-4994-8dac-c48992a56070">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>status(set: Boolean; _value: Integer io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     13 August 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	saveStatus	: Integer;
	tmpTA		: CM_TerminalArea;
begin

	if set then
		exclusiveLock(self);

		// this will always return something as there is a
		// mapping method on myTerminalArea
		tmpTA := self.myTerminalArea;
		saveStatus := self.status;

		inheritMethod(set, _value);

		if _value &lt;&gt; saveStatus then
			// only do this if status has changed
		
			if tmpTA.isKindOf(CM_LogArea) then
				if _value = LC_Status_PhysicallyEmpty then
					self.myLogAreaWhenEmpty	:= tmpTA.CM_LogArea;
				   	self.myTerminalArea 	:= null;
				   	
				elseif saveStatus = LC_Status_PhysicallyEmpty then
					//if self.status &lt;&gt; LC_Status_Archived then
					if _value &lt;&gt; LC_Status_Archived then		// PAR 14097
						// myTerminalArea and myTerminalAreaArchived will have been
						// updated correctly in inheritMethod
					   	self.myTerminalArea 	:= tmpTA;	// self.myLogAreaWhenEmpty;
					endif;
				   	self.myLogAreaWhenEmpty := null;
				endif;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateSOHForLogs" id="57666b31-9fb6-44ae-b8aa-9e277238cfb2">
        <updating/>
        <source>updateSOHForLogs(_adjAmt : Real; _cnt : Integer; _mean : Real; _unscaleCnt : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     09 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	totVol	: Decimal[20];

begin

//	totVol := self.totalVolume;
//	if totVol &gt; self.maximumVolumeReached then
//		self.maximumVolumeReached := totVol;
//	endif;
	self.maximumNumLogs := self.maximumNumLogs.max(self.numTIs);
	
	self.countForSEDMean := self.countForSEDMean + _cnt;
	if self.countForSEDMean &lt; 0 then
		self.countForSEDMean := 0;
	endif;
	
	self.totalSEDMean := self.totalSEDMean + _mean;
	if self.totalSEDMean &lt; 0 then
		self.totalSEDMean := 0;
	endif;
/*	
	if self.countForSEDMean = 0 then
		self.averageSED := 0;
	else
		self.averageSED := (self.totalSEDMean / self.countForSEDMean).roundedTo(2);
	endif;
*/
	
	self.numUnscaledLogs := self.numUnscaledLogs + _unscaleCnt;
	if self.numUnscaledLogs &lt; 0 then
		self.numUnscaledLogs := 0;
	endif;

end;</source>
        <Parameter name="_adjAmt" type="Real"/>
        <Parameter name="_cnt" type="Integer"/>
        <Parameter name="_mean" type="Real"/>
        <Parameter name="_unscaleCnt" type="Integer"/>
    </JadeMethod>
