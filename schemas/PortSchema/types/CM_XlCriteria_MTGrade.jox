    <JadeMethod name="create" id="6a3ec09c-ab5c-4cd3-9d4c-b812169df543">
        <updating/>
        <source>create() updating;
/*
Date		Who		Reason
27 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	self.temperatureFrom	:= NULL_TEMPERATURE;
	self.temperatureTo		:= NULL_TEMPERATURE;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCriteriaDisplay" id="7569f6ad-1090-446e-9266-ab5f01b7ec32">
        <source>getCriteriaDisplay(_short: Boolean): String;
/*
Date		Who		Reason
12 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
11 Jun 2013	cnwcs5	par 31658 - NULL_TERMPERATUREs and displayFarenheit
20 Oct 2016 cnwma2  TFS #2837 PAR #38326 POL - EDI translation ava grades operator HLL- Key Words field
*/
vars
	result, text		: String;
	tempFrom, tempTo	:Real;
	operator			:CM_Operator;
	displayF,hasTemp	:Boolean;
begin
	tempFrom 	:= self.temperatureFrom;
	tempTo		:= self.temperatureTo;
	operator	:= self.getMyOperator; 
	hasTemp		:= tempFrom &lt;&gt; NULL_TEMPERATURE and tempTo &lt;&gt; NULL_TEMPERATURE;
	
	if operator &lt;&gt; null then
		displayF 	:= operator.displayTempFahrenheit;
		
		if displayF then
			if tempFrom &lt;&gt; NULL_TEMPERATURE then
				tempFrom := app.temperatureConversion(true, tempFrom);
			endif;
			if tempTo &lt;&gt; NULL_TEMPERATURE then
				tempTo := app.temperatureConversion(true, tempTo);
			endif;
		endif;
	endif;
	
	text := self.text;
	
	if _short then
		if hasTemp then  // 20/10/2016 cnwma1 TFS #2837 PAR #38326
			if displayF then
				result := app.getErrorString2 (Xlation_Temp_RangeF, tempFrom.asStringJMT, tempTo.asStringJMT);
			else
				result := app.getErrorString2 (Xlation_Temp_Range, tempFrom.asStringJMT, tempTo.asStringJMT);
			endif;
	
			if text &lt;&gt; null then
				if result &lt;&gt; null then
					result := result &amp; ' / ' &amp; text;
				endif;
			endif;
		else
			result := text;    	// 20/10/2016 cnwma1 TFS #2837 PAR #38326
		endif;
		
		return result;
	else
		if text = null then
			if displayF then
				return app.getErrorString3 (Xlation_Criteria_TempF, self.myXlation.foreignCode, tempFrom.asStringJMT, tempTo.asStringJMT);
			else
				return app.getErrorString3 (Xlation_Criteria_Temp, self.myXlation.foreignCode, tempFrom.asStringJMT, tempTo.asStringJMT);
			endif;
		else
			if displayF then
				return app.getErrorString4 (Xlation_Criteria_TempTextF, self.myXlation.foreignCode, tempFrom.asStringJMT, tempTo.asStringJMT, text);
			else
				return app.getErrorString4 (Xlation_Criteria_TempText, self.myXlation.foreignCode, tempFrom.asStringJMT, tempTo.asStringJMT, text);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCriteriaMatch" id="baa0591f-9bc3-4717-8687-b6d8c49fdde0">
        <source>isCriteriaMatch(_score :Integer output; _params: ParamListType): Boolean;
/*
Date		Who		Reason
02 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
14 Jul 2025 navsp1  JIRA-35290 POL | Temperature specific EDI translations applying incorrectly
*/
vars
	count	:Integer;
	temp	:Real;
	param	:Any;
	textComp:String;    //JIRA-35290
	score	:Integer;
begin
	count 	:= app.getParamListTypeLength (_params);
	temp 	:= NULL_TEMPERATURE;

	if count = 2 then
		param := app.getParamListTypeEntry (1, _params);
		
		if param.isKindOf(Real) then
			temp := param.Real;
		else
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Method called with incorrect parameter type');
		endif;
		
		param := app.getParamListTypeEntry (2, _params);
		
		if param.isKindOf(String) then
			textComp := param.String.toUpper;   //JIRA-35290
		else
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Method called with incorrect parameter type');
		endif;
	else
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Method called with incorrect number of parameters');
	endif;
	
	// we expect a temperature - no criteria will match a null temperature
	if self.temperatureFrom = NULL_TEMPERATURE and self.temperatureTo = NULL_TEMPERATURE then
		// no temperature criteria - cant match on it
	else
		if temp &lt; self.temperatureFrom or temp &gt; self.temperatureTo then
			return false;
		endif;
		// we matched on temperature
		score := score + 1;
	endif;
	
	// we have a temperature match
	if self.text = null then
		// no text to match so consider this the match
		_score := score;
		return true;
	endif;
	
	// if the text passed in includes our criteria string then we have a match
	if textComp.pos (self.text, 1) &gt; 0 then //JIRA-35290
		score 	:= score + 1;
		_score 	:= score;
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_score" type="Integer" usage="output"/>
        <Parameter name="_params" type="ParamListType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSameAs" id="33438da9-6d4a-40b0-9ef3-a2c2129bf4a1">
        <source>isSameAs(_criteria: CM_XlCriteria_MTGrade): Boolean;
/*
Date		Who		Reason
03 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	return self.temperatureFrom = _criteria.temperatureFrom and
			self.temperatureTo = _criteria.temperatureTo and
			self.text = _criteria.text;
epilog

end;</source>
        <Parameter name="_criteria" type="CM_XlCriteria_MTGrade"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="225bf6a4-eba4-4201-a8c6-c47171adb0b0">
        <updating/>
        <source>setForUpdate(_proxy :CM_XlCriteria_MTGrade)updating;
/*
Date		Who		Reason
26 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	self.temperatureFrom	:= _proxy.temperatureFrom;
	self.temperatureTo		:= _proxy.temperatureTo;
	self.text				:= _proxy.text;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_XlCriteria_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="a7aaad12-f390-44e9-b3a6-f0dc6c22f782">
        <updating/>
        <source>setProxy(_tempFrom,_tempTo :Real; _text :String) updating;
/*
Date		Who		Reason
26 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	self.temperatureFrom	:= _tempFrom;
	self.temperatureTo		:= _tempTo;
	self.text				:= _text;
epilog

end;</source>
        <Parameter name="_tempFrom" type="Real"/>
        <Parameter name="_tempTo" type="Real"/>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="ef0651fb-f7b9-48db-bc80-c8721dd65e24">
        <source>validateMe();
/*
Date		Who		Reason
26 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	// neither or both should be entered
	if self.temperatureFrom = NULL_TEMPERATURE	and self.temperatureTo = NULL_TEMPERATURE and self.text = null then
		// GUI should have taken care of this
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Expecting temperatures or text  - none entered');
		return;
	endif;
	
	self.validateTemperatureRange (self.temperatureFrom, self.temperatureTo);
epilog

end;</source>
    </JadeMethod>
</Class>
