begin	
	 
	if self.flipV then
		y1 := self.myDrawingFrame.height + self.yDrawOffset - self.bottomOffset;	
	else
		y1 := self.yDrawOffset + self.topOffset;
	endif;
	
	gridWidth  := self.getGridWidth();
	gridHeight := self.getGridHeight();
	
	if self.flipV then
		row := self.bottomGridRowDraw;	
	else
		row := self.topGridRowDraw;
	endif;

	while not finishedRows do	
		
		gridRow := self.myGridArea.allGridRows[row];	
		//self.drawRowsLandscape(y1, gridWidth, gridHeight, gridRow);
				
		row := row + 1;
		if self.flipV then
			finishedRows := row &gt; self.topGridRowDraw;
		else
			finishedRows := row &gt; self.bottomGridRowDraw;
		endif;	
		
		
		// Move up/down
		if self.flipV then
			y1 := y1 - gridHeight;
		else
			y1 := y1 + gridHeight;
		endif;
		
	endwhile;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawAreaSubsetPortrait" id="bd49dab7-cae5-4fde-937d-efd362ec415e">
        <source>drawAreaSubsetPortrait() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2010	cnwjk3	Initial creation

*/

vars
	x1 				: Real;
	flipCol,
	col 			: Integer;
	gridWidth,
	gridHeight		: Real;
	gridRow 		: CM_GridRow;
	finishedCols	: Boolean;
begin
	
	// Drawing  portrait, so rows == columns &amp; columns == rows
	
	if self.flipH then
		x1 := self.myDrawingFrame.clientWidth() + self.xDrawOffset - self.rightOffset;	
	else
		x1 := self.xDrawOffset + self.leftOffset;
	endif;
		
	gridWidth  := self.getGridWidth();
	gridHeight := self.getGridHeight();
	
	if self.flipH then
		col := self.rightGridColDraw;	
	else
		col := self.leftGridColDraw;
	endif;
	
	while not finishedCols do	
		
		self.drawRowsPortrait(x1, gridWidth, gridHeight, col /*remember, this is row*/);
		
		
		col := col + 1;
		if self.flipH then
			finishedCols := col &gt; self.leftGridColDraw;
		else
			finishedCols := col &gt; self.rightGridColDraw;
		endif;	
		
		// Move accross
		if self.flipH then
			x1 := x1 - gridWidth;
		else
			x1 := x1 + gridWidth;
		endif;

	endwhile;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawAreaSubsetPortraitOLD" id="c79ab2b1-76fd-42eb-8ea1-47d0a6845ab1">
