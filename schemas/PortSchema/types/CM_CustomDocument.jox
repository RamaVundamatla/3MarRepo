    <JadeMethod name="cancelStops" id="6e99ecf9-ffd5-4add-9c08-2c3021f85f75">
        <updating/>
        <source>cancelStops(_allTIs : CM_TISet input; _stopsToClear : CM_StopsTableSet) updating;
/*
Purpose - 	incoming proxy TIs, add proxy stops to clear.
Who - NAVAB1
Date - 29AUG2023
ADO - CR 60052 TASK 60054 
*/


vars
	stop : CM_StopsTable;
	docType : CM_CustomDocumentType;
	ti, cgti, proxyTI : CM_TrackedItem;
	cg : CM_CargoGroup;
	pxyStop : CM_Stops;
	expiryDate : Date;
begin

	docType:= self.myCustomDocumentType;
	
	if docType = null then
		return;
	endif;
	
	expiryDate := null;
	
	foreach proxyTI in _allTIs discreteLock do
		foreach stop in _stopsToClear discreteLock do
			pxyStop	:= proxyTI.getStop( stop.id );
			// stop not set for this ti so can't clear it
			if pxyStop = null then
				continue;
			endif;
			pxyStop.setClearanceExpiryDate(null);
			pxyStop.pxySetCancelStop();
		
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_allTIs" type="CM_TISet" usage="input"/>
        <Parameter name="_stopsToClear" type="CM_StopsTableSet"/>
    </JadeMethod>
    <JadeMethod name="checkDoUpdateCode" id="aacfc7e5-5d95-40a3-ae0c-de9b54ca0ed9">
        <source>checkDoUpdateCode(_proxy : SelfType; _generateAutoId : Boolean output) : Boolean;
/*

Purpose:			This method checks wheter we want to update the code/use auto ID by comparing the document type

Parameters:			

Return Value:		

Date		Who		Reason
29/08/2023	navkc1	CR 59556  Task 59593: UI - Cust Docs Auto Id

*/

vars
	realDoc			: SelfType;
	oldDocType,
	newDocType		: CM_CustomDocumentType;
	update			: Boolean;
begin

	realDoc := _proxy.pxyGetRealObject();
	
	// Creating new custom doc, set code
	if realDoc = null then
		return true;
	endif;
	
	// Updating custom doc
	
	oldDocType := realDoc.myCustomDocumentType;
	newDocType := _proxy.myCustomDocumentType;
	
	// Doc type hasn't changed
	if oldDocType = newDocType then
		// If doc type is not using auto id, user can manually change it, update code;
		if not newDocType.hasAutoId then
			update:= true;
		endif;
	else
		// Changed from AutoId to Manual, update code
		if oldDocType.hasAutoId and not newDocType.hasAutoId then
			update := true;
		// Changed from Manual to Manual, update code
		elseif not oldDocType.hasAutoId and not newDocType.hasAutoId then
			update := true;
		// Changed from Manual to Auto, don't update code here, update later using Auto Id
		elseif not oldDocType.hasAutoId and newDocType.hasAutoId then
			_generateAutoId := true;
		endif;
	endif;
	
	return update;
	
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_generateAutoId" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearStops" id="eacc3c9b-9937-4a21-af0e-0b107ec9a8b2">
        <updating/>
        <source>clearStops(_allTIs : CM_TISet input; _stopsToClear : CM_StopsTableSet) updating;
/*
Purpose - 	incoming proxy TIs, add proxy stops to clear.
Who - NAVAB1
Date - 25AUG2023
ADO - CR 60052 TASK 60054 
*/


vars
	stop : CM_StopsTable;
	docType : CM_CustomDocumentType;
	ti, cgti, proxyTI : CM_TrackedItem;
	cg : CM_CargoGroup;
	pxyStop : CM_Stops;
	expiryDate : Date;
begin

	docType:= self.myCustomDocumentType;
	
	if docType = null then
		return;
	endif;
	
	expiryDate := null;
	
	foreach proxyTI in _allTIs discreteLock do
		foreach stop in _stopsToClear discreteLock do
			pxyStop	:= proxyTI.getStop( stop.id );
			// stop not set for this ti so can't clear it
			if pxyStop = null then
				continue;
			endif;
			// record any information that must be captured to clear the stop
			if stop.requiresInfo then
				proxyTI.setRequiresInformation( stop.requiresInfoType, self.code );
			endif;
			// record expiry date if set and relevant
			if stop.allowClearanceExpiryDate and expiryDate &lt;&gt; null then
				// don't delete - just set the clearance date (what if date is null - we won't be able to tell);
				pxyStop.setClearanceExpiryDate(expiryDate );
			else
				// we need to delete the stop 
				delete pxyStop;
			endif;

		
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_allTIs" type="CM_TISet" usage="input"/>
        <Parameter name="_stopsToClear" type="CM_StopsTableSet"/>
    </JadeMethod>
    <JadeMethod name="createTransactionForTI" id="2b3aff8b-f10e-4c39-ba37-03b12dd9e493">
        <source>createTransactionForTI(_type : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2023	navkc1	CR 59934 Task 59935: Jade - Cust Doc Cargo Transactions
07/09/2023	navkc1	CR 60376 Task 60377: Jade - Cargo Group Regions

*/

vars
	ti 			: CM_TrackedItem;
	cgTi		: CM_TrackedItem;
	txnParams	: CMIF_TITransactionController;
	transaction	: CM_CustomDocTransaction;
	cg			: CM_CargoGroup;
begin
	
	foreach ti in self.allTrackedItems discreteLock do
		if ti.isZombie() then
			continue;
		endif;
		create txnParams transient;
		txnParams.type := _type;
		transaction := ti.createTransaction(txnParams, app.myPassport).CM_CustomDocTransaction;
		transaction.setDetailsFromCusDoc(self);
		delete txnParams;
		//07/09/2023	navkc1	CR 60376 Task 60377
		if ti.isCargoGroupItem() then
			CMIF_TrxActionCargoGroup@createAction(null, ti.CM_CargoGroup, app.myPassport);
		else
			CMIF_TrxActionCargoGroup@createAction(ti, null, app.myPassport);
		endif;
	endforeach;
	
epilog
	delete txnParams;
end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
