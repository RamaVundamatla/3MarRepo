    <JadeMethod name="setForCreate" id="81f9a088-d587-4955-aa48-c04a88836620">
        <updating/>
        <source>setForCreate(pProxy: CM_LogTreatment) updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pProxy);
	self.myCodeGroupLogSpecs := pProxy.myCodeGroupLogSpecs;

end;</source>
        <Parameter name="pProxy" type="CM_LogTreatment"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="a09b1755-18ac-456f-8997-aebac6c9e79d">
        <updating/>
        <source>setProxy(pCode, pDescription:String; _notAvailableForEntry:Boolean; pCodeGroup : CM_CodeGroupLogSpecs)updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.setSuperClassDetailsForProxy(pCode, pDescription, _notAvailableForEntry, null);
	self.myCodeGroupLogSpecs := pCodeGroup;

end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="pCodeGroup" type="CM_CodeGroupLogSpecs"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="23dac18e-178a-44de-a00c-919dbc3e8de1">
        <source>validateForCreate();
// -----------------------------------------------------------------------------
// Created:		27 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	inheritMethod();
	if self.myCodeGroupLogSpecs &lt;&gt; null and
	   self.myCodeGroupLogSpecs.allLogTreatments.includesKey(self.code) then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, 'code', null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="5d62f539-504c-4745-8d18-dae555e3ddf3">
        <source>validateForDelete();
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if (not self.allLogGrades.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Log Treatment ' &amp; self.code, 
							  self.allLogGrades.size.String &amp; ' Log Grades', null, null);
	endif;

	if (not self.allProducts.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Log Treatment ' &amp; self.code, 
							  self.allProducts.size.String &amp;' '&amp; app.getErrorString(Cargo_subtype_data), null, null);
	endif;

end;</source>
    </JadeMethod>
</Class>
