    <JadeMethod name="btnMonitoringOnOff_click" id="0defbf2d-7627-4db3-9578-0374574c5c64">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnMonitoringOnOff_click(btn: Button input) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 09 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description
18/06/2020		jlgmd1		49599		Refactor search to make it faster and less lock prone

****************************************************/
begin
	if self.frmMode = self.Monitoring_Mode then
		self.frmMode := self.Query_Mode;
		self.btnMonitoringOnOff.caption := "Start Monitoring Mode";	
		self.tblLogInformation.hideColumnByColName(ETRow_Process);
		self.btnMonitoringOnOff.bubbleHelp := "Start Monitoring Mode";	
		self.unregisterNotifications();
		self.statusLine.caption := "";	// TFS 49599
	else
		self.frmMode := self.Monitoring_Mode;
		self.btnMonitoringOnOff.caption := "Stop Monitoring Mode";
		self.tblLogInformation.showColumnByColName(ETRow_Process);
		self.btnMonitoringOnOff.bubbleHelp := "Stop Monitoring Mode";
		self.registerNotifications();		
		self.statusLine.caption := "";	// TFS 49599
	endif;	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
