    <JadeMethod name="voyage_AddToView" id="6b0637c1-0f65-4422-a2ca-aabfcf94e705">
        <updating/>
        <source>voyage_AddToView(_hmsVoyage: HMS_VoyageData): CMIF_HMS_WorkingVoyage updating;
//--------------------------------------------------
// Created:	30 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	workingVoyage : CMIF_HMS_WorkingVoyage;
begin
	workingVoyage := inheritMethod(_hmsVoyage);
	if workingVoyage = null then
		return null;
	endif;

	self.myGraphicalView.addVoyageToView(workingVoyage);

	return workingVoyage;
	
end;</source>
        <Parameter name="_hmsVoyage" type="HMS_VoyageData"/>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="voyage_RemoveFromView" id="d025960f-1ada-496a-ba60-f1c877c100eb">
        <updating/>
        <source>voyage_RemoveFromView(_hmsObject: HMS_VoyageData): CMIF_HMS_WorkingVoyage updating;
//--------------------------------------------------
// Created:	27 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	workingVoyage : CMIF_HMS_WorkingVoyage;
begin
	workingVoyage := inheritMethod(_hmsObject);
	
	if workingVoyage = null then
		return workingVoyage;
	endif;

	self.myGraphicalView.removeVoyage(workingVoyage);
	
	delete workingVoyage;
	
	return null;

end;</source>
        <Parameter name="_hmsObject" type="HMS_VoyageData"/>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="voyage_UpdateView" id="72e30700-8418-4fe7-999f-eb0936ab2466">
        <updating/>
        <source>voyage_UpdateView(_hmsVoyage : HMS_VoyageData): CMIF_HMS_WorkingVoyage updating;
//--------------------------------------------------
// Created:	28 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	workingVoyage : CMIF_HMS_WorkingVoyage;
begin
	workingVoyage := inheritMethod(_hmsVoyage);
	if (not global.isValidObject(self.myCurrentWorkingMovement)) then
		self.setMySelectedMovement(null);
	endif;
	if workingVoyage &lt;&gt; null then
		self.myGraphicalView.rebuildVoyage(workingVoyage, self.myCurrentWorkingMovement);
	endif;
	return workingVoyage;
end;</source>
        <Parameter name="_hmsVoyage" type="HMS_VoyageData"/>
        <ReturnType type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
</Class>
