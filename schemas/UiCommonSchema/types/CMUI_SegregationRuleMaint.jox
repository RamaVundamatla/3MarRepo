    <JadeMethod name="doSaveCondition" id="96149c11-d9cb-4aaa-9566-fa71bbd022b6">
        <updating/>
        <source>doSaveCondition() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	newCondition			: CM_SegregationCondition;
	result					: Integer;
	
begin
	
	self.setSegCondFromTbl();
	
	while true do
		if self.mode = Mode_AddCondition then
			app.myTrxCA.trxCreateSegregationCond(self.myPxySegregationCond, newCondition, app.myPassport);
		else
			app.myTrxUA.trxUpdateSegCondition(self.myPxySegregationCond, app.myPassport);
		endif;

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.doShowHideCondFrm(false);
			self.doMatrixEdit(false);//refresh the matrix
			return;
		else
			result := app.showErrorWarningDialog('Segregation Condition Update', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
	
		return;
	endwhile;
	
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowHideCondFrm" id="b28c77f3-a8ca-4b4b-8cae-8e70d29de547">
        <updating/>
        <source>doShowHideCondFrm(_show : Boolean) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.grpCondEdit.parent := self;
	self.grpCondEdit.top := 50;
	self.grpCondEdit.left := (self.width /2) - (self.grpCondEdit.width /2);
	self.grpCondEdit.height := self.tblCondEdit.height + self.frmToolCondEdit.height + 5;
	self.grpCondEdit.zOrder(1);
	
	self.tblCondEdit.top := self.frmToolCondEdit.height; // ### TFS 50421 17SEP2021 NAVAB1
	if _show then
		self.grpCondEdit.visible := true;
		self.grpCondEdit.enabled := true;
		self.tblCondEdit.enabled := true;
		self.splRuleMaint.enabled := false;
		self.cmbRuleMode.enabled := false;
	else
		self.grpCondEdit.visible := false;
		self.grpCondEdit.enabled := false;
		self.tblCondEdit.enabled := false;
		self.splRuleMaint.enabled := true;
		self.cmbRuleMode.enabled := true;
		self.mode := self.Mode_View;
		delete self.myPxySegregationCond;
		
	endif;

end;


</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblMatrixMouseDown" id="57e71243-e86b-4f80-b5f8-1deb2b345ed1">
        <source>doTblMatrixMouseDown(_button : Integer) protected;
/*
----------   ----------  --------------------------------------------------
Created:	28 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	row,
	col					: Integer;
	matrixTrans			: CM_SegregationMatrixTrans;
	tbl					: CM_DataTable;
	pxySegRule			: CM_SegregationRule;
	isItselfSymmetrically	: Boolean;
begin
	if self.mode &lt;&gt; self.Mode_UpdateMatrix then
		return;
	endif;
	
	tbl := self.tblMatrix;
	row := tbl.row;
	col := tbl.column;
	if row &lt;= tbl.fixedRows or col &lt;= tbl.fixedColumns then
		return;
	endif;
	
	if self.mySelectedCondition = null then
		app.msgBox('You must select a segregation condition in the top table to apply a rule.','No segregation condition selected.', MsgBox_Information_Icon);
		return;
	endif;
	
	isItselfSymmetrically := (row = col-1) and (col = row+1);
	self.assignConditionToCell(row, col, _button);
	
	if not isItselfSymmetrically then
		self.assignConditionToCell(col-1, row+1, _button);
	endif;
	
	
end;


</source>
        <access>protected</access>
        <Parameter name="_button" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exportSegregationMatrix" id="e4de6012-96e0-435d-ad75-732e22485b02">
        <source>exportSegregationMatrix() protected;
/*
----------   ----------  --------------------------------------------------
Created:	29 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	diag			: CMDFileSave;
	file			: File;
	objArray		: ObjectArray;		
begin
	create diag transient;
	create file transient;
	
	create objArray transient;
	diag.defaultExt := '*.xml';
	if diag.open = 0 then	//user clicked OK
		file.mode := File.Mode_Output;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		file.fileName := diag.fileName;
		
		if file.fileName = null then
			app.msgBox('File name cannot be null', 'File name invalid', MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	else
		return;
	endif;
	
	self.mySegregationMatrixAgent.ruleType := null;
	self.mySegregationMatrixAgent.exportMeXML(file, objArray, true, true);
	self.mySegregationMatrixAgent.ruleType := self.ruleMode;
	
epilog
	file.close;
	delete file;
	delete diag;
	delete objArray;	

end;


</source>
        <access>protected</access>
    </JadeMethod>
