    <JadeMethod name="convertAlternativeIdsToUpper" id="3ff02898-1c53-4c78-970d-2bb8f449bd2c">
        <source>convertAlternativeIdsToUpper();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2013	cnwndl1	Initial creation

*/

vars
	term : CM_Terminal;
	ti : CM_TrackedItem;
begin
	app.writeLog( method.qualifiedName &amp; ' Upgrading Alternative Ids to upper case', LogINFO);
	
	foreach term in CM_Terminal.instances do
		foreach ti in term.allOnsiteTIsByAlternativeId do
			if ti.alternativeId.toUpper &lt;&gt; ti.alternativeId then
				beginTransaction;
				ti.setPropertyValue("alternativeId",ti.alternativeId.toUpper);
				commitTransaction;
			endif;
		endforeach;
	endforeach;

	app.writeLog( method.qualifiedName &amp; ' Completed Upgrading Alternative Ids to upper case', LogINFO);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="convertCalendarRefOnCalcType" id="65a0339e-3efd-45dc-a340-082a8e7b7f2d">
        <source>convertCalendarRefOnCalcType();
// ---------------------------------------------------------------------------
// Created:     04 December 2012 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	calcType		:CM_CalculationType;
begin
	app.writeLog( method.qualifiedName &amp; ' Upgrading calculation type data from 8.1.2 to 8.2.1', LogINFO);
	beginTransaction;
	
	foreach calcType in app.myRoot.allCalculationTypesByCode do
		calcType.convertExtensionObjectValue (Obj_Extn_myCalendarType1, CM_CalculationType::myCalendarType1);
		calcType.convertExtensionObjectValue (Obj_Extn_myCalendarType2, CM_CalculationType::myCalendarType2);
	endforeach;

	commitTransaction;
	app.writeLog( method.qualifiedName &amp; ' Completed calculation type data from 8.1.2 to 8.2.1', LogINFO);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="convertConsigneeLicense" id="ad29783f-63d5-4792-9e6c-11331bbb5de1">
        <source>convertConsigneeLicense();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2013	cnwndl1	Initial creation	Par 30901

*/

vars
	consignee	: CM_ConsigneeConsignor;
begin
	app.writeLog( method.qualifiedName &amp; ' Upgrading ConsigneeConsignor external reference from 8.1.2 to 8.2.1', LogINFO);
	beginTransaction;
	
	foreach consignee in CM_ConsigneeConsignor.instances do
		consignee.convertExtensionObjectValue (Obj_Extn_licenseExpiryDate, CM_ConsigneeConsignor::licenseExpiryDate);
		consignee.convertExtensionObjectValue (Obj_Extn_license, CM_ConsigneeConsignor::license);
	endforeach;

	commitTransaction;
	app.writeLog( method.qualifiedName &amp; ' Completed ConsigneeConsignor external reference from 8.1.2 to 8.2.1', LogINFO);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="convertDebtorExternalReference" id="45a8438b-5422-4db7-96c1-c4795f831913">
        <source>convertDebtorExternalReference();
// ---------------------------------------------------------------------------
// Created:     25 Feb 2013 by cnwjre1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//	Convert CM_Debtor externalReference	par 31193
// ---------------------------------------------------------------------------

vars
	debtor	: CM_Debtor;
begin
	app.writeLog( method.qualifiedName &amp; ' Upgrading debtor external reference from 8.1.2 to 8.2.1', LogINFO);
	beginTransaction;
	
	foreach debtor in CM_Debtor.instances do
		debtor.convertExtensionObjectValue (Obj_Extn_externalReference, CM_Debtor::externalReference);
	endforeach;

	commitTransaction;
	app.writeLog( method.qualifiedName &amp; ' Completed debtor external reference from 8.1.2 to 8.2.1', LogINFO);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="convertInvoiceCalcTypes" id="6e82c15d-a3d4-49e7-b3c7-3826157db8f4">
        <source>convertInvoiceCalcTypes();
/*
Purpose:			
Date		Who		Reason
29 October 2012	cnwab1	Initial creation
15 November 2012 cnwjre1	Add HMS block unit defaulting and rename
*/

vars
	newDesc : String;
	aCT : CM_CalculationType;
begin
//	app.initialize();
		
	beginTransaction;
	foreach aCT in app.myRoot.allCalculationTypesByCode do
		// CCMS QNS 2178
		if aCT.calculationType = INV_CALC_TYPE_VESSEL_TON or
		   aCT.calculationType = INV_CALC_TYPE_VESSEL_TON_QTY1 or
		   aCT.calculationType = INV_CALC_TYPE_VESSEL_TON_RANGE then
			aCT.setPropertyValue("theCalcTypeUnit", INV_CALC_TYPE_UNIT_GRT);
			app.writeLog( method.qualifiedName &amp; " Converting Invoice Calculation Type " &amp; aCT.calculationType.String  &amp; " Setting Block Unit to Vessel Dimension GRT", LogINFO);
		endif;

		if not aCT.isStandardCargo() then
			continue;
		endif;
		
		newDesc := app.getInvoiceCalcTypeLabel(aCT.calculationType, true);
		
		if CM_CalculationType::description.name = newDesc then
			continue;
		endif;
		
		aCT.setPropertyValue(CM_CalculationType::description.name, newDesc);
		
		app.writeLog( method.qualifiedName &amp; " Converting Standard Cargo Invoice Calculation Type " &amp; aCT.calculationType.String  &amp; " Description From " &amp; aCT.description &amp; " to " &amp; newDesc, LogINFO);
	endforeach;
	commitTransaction;


epilog

end;</source>
    </JadeMethod>
