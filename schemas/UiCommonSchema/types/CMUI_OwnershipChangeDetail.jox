    <JadeMethod name="btnAudits_click" id="bd99b32c-0fb4-4a86-8978-d2c1e1fb5beb">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAudits_click(btn: Button input) updating;
/*
Purpose:			

Date		Who		Reason
24 July 2023	navab1	 CR 58246 TASK 58249 
*/

vars

begin
	if self.myOwnershipChangeDetail = null then
		return;
	endif;
	
	app.viewAuditFormModal(self.myOwnershipChangeDetail, self.myAssistant.class, self.myTerminal);
	

epilog

end;</source>
