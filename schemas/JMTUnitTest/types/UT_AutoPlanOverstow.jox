    <JadeMethod name="tForkUseOSRulesYA1" id="e1decd50-b8e9-4dd3-bdc3-351bccfe4c16">
        <source>tForkUseOSRulesYA1();
/* cnwer1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwer1	Initial creation

*/

vars
	taSource,
	taTarget: CM_ForkLiftStack;
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti, nextTI, osTI: CM_TrackedItem;
	location: CM_LocationsController;
	containers : String;
	rtQueueEntry : CM_RTQueueEntry;
	tiArray 	 : CM_TIArray;
	sideAccessDirection : Integer;
begin
	deleteTerminalArea("UTFORK");
	taSource:= self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");
	
	deleteTerminalArea("UTFORK1");
	taTarget:= self.addForkLiftStack("UTFORK1", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK1");
	
	self.deleteContainer("TEST0000001");
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000001");
	self.move(ti ,taSource.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 3], "Did not move TEST0000001 to correct location");
		
	self.moveQueued(ti,taTarget.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(ti.myPrimaryQueuedLocation, taTarget.allGridControllersByRowColumn[2, 3], "Did not queue TEST0000001 to correct location");
	
	
	self.deleteContainer("TEST0000002");
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 3], "Did not move TEST0000002 to correct location");
	//add some cargo 
	
	//locations are Top Left &amp; bottom Right
	create locations transient;
	locations.add(taSource.allGridControllersByRowColumn[2, 2]);
	locations.add(taSource.allGridControllersByRowColumn[5, 4]);
	
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	assertNotNullMsg(ya, "UT Yard Allocation");
	self.updateDeckingRulesYA("UT", true, DeckingRule_ByRow, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	self.updateDeckingRulesYA("UT", false, DeckingRule_ByRow, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	rtQueueEntry:=ti.getQueueEntry();
	assertNotNullMsg(rtQueueEntry, "Q Entry");
	create tiArray transient;
	ti.getAllOverstowedTIs(tiArray,true,sideAccessDirection,null);
	app.myTrxUA.trxAutoPlanOverstowedCargo(ti,tiArray,ti.myTerminalArea,null,null,null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	rtQueueEntry:=osTI.getQueueEntry;
	assertNotNullMsg(rtQueueEntry, "OS Q Entry");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTFORK 000202", "Overstow tasks target location is incorrect"  );
	
epilog
	delete locations;
	delete tiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tForkUseOSRulesYA2" id="d8b5c82f-4e04-403b-92d7-28df9fdad1aa">
        <source>tForkUseOSRulesYA2();
/* cnwer1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwer1	Initial creation

*/

vars
taSource,
	taTarget: CM_ForkLiftStack;
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti, nextTI, osTI: CM_TrackedItem;
	location: CM_LocationsController;
	containers : String;
	tiRTQueueEntry,
	rtQueueEntry : CM_RTQueueEntry;
	tiArray 	 : CM_TIArray;
	currentQ	 : CM_RadioTelemetryQueue;
	qIndex,sideAccessDirection		: Integer;
begin
	deleteTerminalArea("UTFORK");
	taSource:= self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");
	
	deleteTerminalArea("UTFORK1");
	taTarget:= self.addForkLiftStack("UTFORK1", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK1");
	
	self.deleteContainer("TEST0000001");
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000001");
	self.move(ti ,taSource.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 3], "Did not move TEST0000001 to correct location");
		
	self.moveQueued(ti,taTarget.allGridControllersByRowColumn[4, 3]);
	self.assertEqualMsg(ti.myPrimaryQueuedLocation, taTarget.allGridControllersByRowColumn[4, 3], "Did not queue TEST0000001 to correct location");
	
	
	self.deleteContainer("TEST0000002");
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 3], "Did not move TEST0000002 to correct location");
	//add some cargo 
	
	//more overstowed cargo
	self.deleteContainer("TEST0000003");
	nextTI:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000003");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[5, 3]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[5, 3], "Did not move TEST0000003 to correct location");
	
	//locations are Top Left &amp; bottom Right
	create locations transient;
	locations.add(taSource.allGridControllersByRowColumn[2, 2]);
	locations.add(taSource.allGridControllersByRowColumn[5, 4]);
	
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	assertNotNullMsg(ya, "UT Yard Allocation");
		self.updateDeckingRulesYA("UT", true, DeckingRule_ByRow, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	self.updateDeckingRulesYA("UT", false, DeckingRule_ByRow, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	tiRTQueueEntry:=ti.getQueueEntry();
	assertNotNullMsg(tiRTQueueEntry, "Q Entry");
	
	currentQ:=tiRTQueueEntry.myQueue;
	
	create tiArray transient;
	//tiArray.add(osTI);
	ti.getAllOverstowedTIs(tiArray,true,sideAccessDirection,null);
	
	app.myTrxUA.trxAutoPlanOverstowedCargo(ti,tiArray,ti.myTerminalArea,null,null,null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	qIndex:=currentQ.allEntries.indexOf(tiRTQueueEntry);	
	rtQueueEntry:=osTI.getQueueEntry;
	
/*
	21 Mar 2012	NDL	Par 28122
	Rule change means we don't use Deck out rules in this situation, so "TEST0000002" is no longer considered to be overstowed.
	
	assertNotNullMsg(rtQueueEntry, "OS 1 Q Entry");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTFORK 000402 1", "Overstow tasks target location is incorrect"  );
	self.assertTrueMsg(currentQ.allEntries.indexOf(rtQueueEntry) &lt; qIndex,"Overstowed ti TEST0000002 not queued before  original ti");
	
	rtQueueEntry:=nextTI.getQueueEntry;
	assertNotNullMsg(rtQueueEntry, "OS 2 Q Entry");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTFORK 000202 1", "Overstow tasks target location is incorrect"  );
	self.assertTrueMsg(currentQ.allEntries.indexOf(rtQueueEntry) &lt; qIndex,"Overstowed ti TEST0000003 not queued before  original ti");
*/
	assertNotNullMsg(rtQueueEntry, "OS 1 Q Entry");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTFORK 000202", "Target location is incorrect"  );
	

epilog
	delete locations;
	delete tiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tForkUseOSRulesYA3" id="128b6181-01f4-4836-ba30-f0a358d372d7">
        <source>tForkUseOSRulesYA3();
/* cnwer1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwer1	Initial creation

*/

vars
	taSource,
	taTarget: CM_ForkLiftStack;
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti, osTI2, osTI,
	nextTI: CM_TrackedItem;
	location: CM_LocationsController;
	containers : String;
	tiRTQueueEntry,
	rtQueueEntry : CM_RTQueueEntry;
	tiArray 	 : CM_TIArray;
	currentQ	 : CM_RadioTelemetryQueue;
	qIndex,sideAccessDirection		: Integer;
begin
	deleteTerminalArea("UTFORK");
	taSource:= self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");
	
	deleteTerminalArea("UTFORK1");
	taTarget:= self.addForkLiftStack("UTFORK1", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK1");
	
	self.deleteContainer("TEST0000001");
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000001");
	self.move(ti ,taSource.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 3], "Did not move TEST0000001 to correct location");
		
	self.moveQueued(ti,taTarget.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(ti.myPrimaryQueuedLocation, taTarget.allGridControllersByRowColumn[2, 3], "Did not queue TEST0000001 to correct location");
	
	
	self.deleteContainer("TEST0000002");
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 3], "Did not move TEST0000002 to correct location");

	
	//more overstowed cargo this is retricting access
	self.deleteContainer("TEST0000003");
	osTI2:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI2, "TEST0000003");
	self.move(osTI2 ,taSource.allGridControllersByRowColumn[5, 3]);
	self.assertEqualMsg(osTI2.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[5, 3], "Did not move TEST0000003 to correct location");
	
	//add some cargo 

	self.deleteContainer("TEST0000004");
	nextTI:= self.addContainerOpts("TEST0000004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000004");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[2, 2]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 2], "Did not move TEST0000004 to correct location");
	
	
	//locations are Top Left &amp; bottom Right
	create locations transient;
	locations.add(taSource.allGridControllersByRowColumn[2, 2]);
	locations.add(taSource.allGridControllersByRowColumn[5, 4]);
	
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	assertNotNullMsg(ya, "UT Yard Allocation");
		self.updateDeckingRulesYA("UT", true, DeckingRule_ByRow, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	self.updateDeckingRulesYA("UT", false, DeckingRule_ByRow, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	tiRTQueueEntry:=ti.getQueueEntry();
	assertNotNullMsg(tiRTQueueEntry, "Q Entry");
	
	currentQ:=tiRTQueueEntry.myQueue;
	
	create tiArray transient;
	//tiArray.add(osTI);
	ti.getAllOverstowedTIs(tiArray,true,sideAccessDirection,null);
	
	app.myTrxUA.trxAutoPlanOverstowedCargo(ti,tiArray,ti.myTerminalArea,null,null,null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	qIndex:=currentQ.allEntries.indexOf(tiRTQueueEntry);
	
	/*
	21 Mar 2012	NDL	Par 28122
	Rule change means we don't use Deck out rules in this situation, so "TEST0000002" is no longer considered to be overstowed.
	
	rtQueueEntry:=osTI.getQueueEntry;
	assertNotNullMsg(rtQueueEntry, "OS 1 Q Entry");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTFORK 000202 2", "Overstow tasks target location is incorrect"  );
	self.assertTrueMsg(currentQ.allEntries.indexOf(rtQueueEntry) &lt; qIndex,"Overstowed ti TEST0000002 not queued before  original ti");
	
	rtQueueEntry:=osTI2.getQueueEntry;
	assertNotNullMsg(rtQueueEntry, "OS 2 Q Entry");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTFORK 000402 1", "Overstow tasks target location is incorrect"  );
	self.assertTrueMsg(currentQ.allEntries.indexOf(rtQueueEntry) &lt; qIndex,"Overstowed ti TEST0000003 not queued before  original ti");
	*/
	
	rtQueueEntry:=osTI.getQueueEntry;
	assertNotNullMsg(rtQueueEntry, "OS 1 Q Entry");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTFORK 000402", "Target location is incorrect"  );
	
epilog
	delete locations;
	delete tiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tForkUseOSRulesYA4" id="96feff45-e58d-4df6-bd07-a66d92864fdd">
        <source>tForkUseOSRulesYA4();
/* cnwer1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwer1	Initial creation

*/

vars

	taSource,
	taTarget: CM_ForkLiftStack;
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti, osTI2, osTI,
	nextTI: CM_TrackedItem;
	location: CM_LocationsController;
	containers : String;
	tiRTQueueEntry,
	rtQueueEntry : CM_RTQueueEntry;
	tiArray 	 : CM_TIArray;
	currentQ	 : CM_RadioTelemetryQueue;
	qIndex,sideAccessDirection		: Integer;
begin
	deleteTerminalArea("UTFORK");
	taSource:= self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");
	
	deleteTerminalArea("UTFORK1");
	taTarget:= self.addForkLiftStack("UTFORK1", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK1");
	
	self.deleteContainer("TEST0000001");
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000001");
	self.move(ti ,taSource.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 3], "Did not move TEST0000001 to correct location");
		
	self.moveQueued(ti,taTarget.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(ti.myPrimaryQueuedLocation, taTarget.allGridControllersByRowColumn[2, 3], "Did not queue TEST0000001 to correct location");
	
	
	self.deleteContainer("TEST0000002");
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 3], "Did not move TEST0000002 to correct location");

	
	//more overstowed cargo this is retricting access
	self.deleteContainer("TEST0000003");
	osTI2:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI2, "TEST0000003");
	self.move(osTI2 ,taSource.allGridControllersByRowColumn[5, 3]);
	self.assertEqualMsg(osTI2.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[5, 3], "Did not move TEST0000003 to correct location");
	
	//add some cargo 

	self.deleteContainer("TEST0000004");
	nextTI:= self.addContainerOpts("TEST0000004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000004");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[6, 2]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[6, 2], "Did not move TEST0000004 to correct location");
	
	
	//locations are Top Left &amp; bottom Right
	create locations transient;
	locations.add(taSource.allGridControllersByRowColumn[2, 2]);
	locations.add(taSource.allGridControllersByRowColumn[5, 4]);
	
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	self.updateDeckingRulesYA("UT", true, DeckingRule_ByRow, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	self.updateDeckingRulesYA("UT", false, DeckingRule_ByRow, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	assertNotNullMsg(ya, "UT Yard Allocation");
	tiRTQueueEntry:=ti.getQueueEntry();
	assertNotNullMsg(tiRTQueueEntry, "Q Entry");
	
	currentQ:=tiRTQueueEntry.myQueue;
	
	create tiArray transient;
	//tiArray.add(osTI);
	ti.getAllOverstowedTIs(tiArray,true,sideAccessDirection,null);
	
	app.myTrxUA.trxAutoPlanOverstowedCargo(ti,tiArray,ti.myTerminalArea,null,null,null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	qIndex:=currentQ.allEntries.indexOf(tiRTQueueEntry);
	
	rtQueueEntry:=osTI.getQueueEntry;
	assertNotNullMsg(rtQueueEntry, "OS 1 Q Entry");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTFORK 000402", "Target location is incorrect"  );
	
	/*
	21 Mar 2012	NDL	Par 28122
	Rule change means we don't use Deck out rules in this situation, so "TEST0000002" is no longer considered to be overstowed by
	"TEST0000003", becuase access is available from the other side.
	
	self.assertTrueMsg(currentQ.allEntries.indexOf(rtQueueEntry) &lt; qIndex,"Overstowed ti TEST0000002 not queued before  original ti");
	
	rtQueueEntry:=osTI2.getQueueEntry;
	assertNotNullMsg(rtQueueEntry, "OS 2 Q Entry");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTFORK 000402 1", "Overstow tasks target location is incorrect"  );
	self.assertTrueMsg(currentQ.allEntries.indexOf(rtQueueEntry) &lt; qIndex,"Overstowed ti TEST0000003 not queued before  original ti");
	*/
	
epilog
	delete locations;
	delete tiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tForkUseOSRulesYA5" id="cfd499b8-1313-4ad6-9033-5e71ecb74311">
        <source>tForkUseOSRulesYA5();
/* cnwer1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2010	cnwer1	Initial creation

*/

vars
taSource,
	taTarget: CM_ForkLiftStack;
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti, osTI2, osTI,
	nextTI: CM_TrackedItem;
	location: CM_LocationsController;
	containers : String;
	tiRTQueueEntry,
	rtQueueEntry : CM_RTQueueEntry;
	tiArray 	 : CM_TIArray;
	currentQ	 : CM_RadioTelemetryQueue;
	qIndex,sideAccessDirection		: Integer;
begin
	deleteTerminalArea("UTFORK");
	taSource:= self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");
	
	deleteTerminalArea("UTFORK1");
	taTarget:= self.addForkLiftStack("UTFORK1", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK1");
	
	self.deleteContainer("TEST0000001");
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000001");
	self.move(ti ,taSource.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 3], "Did not move TEST0000001 to correct location");
		
	self.moveQueued(ti,taTarget.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(ti.myPrimaryQueuedLocation, taTarget.allGridControllersByRowColumn[2, 3], "Did not queue TEST0000001 to correct location");
	
	
	self.deleteContainer("TEST0000002");
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 3], "Did not move TEST0000002 to correct location");

	
	//more overstowed cargo this is retricting access
	self.deleteContainer("TEST0000003");
	osTI2:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI2, "TEST0000003");
	self.move(osTI2 ,taSource.allGridControllersByRowColumn[5, 3]);
	self.assertEqualMsg(osTI2.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[5, 3], "Did not move TEST0000003 to correct location");
	
	//add some cargo 

	self.deleteContainer("TEST0000004");
	nextTI:= self.addContainerOpts("TEST0000004", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000004");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[3, 2]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[3, 2], "Did not move TEST0000004 to correct location");
	
	self.deleteContainer("TEST0000005");
	nextTI:= self.addContainerOpts("TEST0000005", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000005");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[3, 4]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[3, 4], "Did not move TEST0000005 to correct location");
	
	//locations are Top Left &amp; bottom Right
	create locations transient;
	locations.add(taSource.allGridControllersByRowColumn[2, 1]);
	locations.add(taSource.allGridControllersByRowColumn[5, 5]);
	
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	assertNotNullMsg(ya, "UT Yard Allocation");
		self.updateDeckingRulesYA("UT", true, DeckingRule_ByRow, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	self.updateDeckingRulesYA("UT", false, DeckingRule_ByRow, DeckingRule_Increasing, DeckingRule_Increasing, DeckingRule_Columnwise, 0);
	tiRTQueueEntry:=ti.getQueueEntry();
	assertNotNullMsg(tiRTQueueEntry, "Q Entry");
	
	currentQ:=tiRTQueueEntry.myQueue;
	
	create tiArray transient;
	//tiArray.add(osTI);
	ti.getAllOverstowedTIs(tiArray,true,sideAccessDirection,null);
	
	app.myTrxUA.trxAutoPlanOverstowedCargo(ti,tiArray,ti.myTerminalArea,null,null,null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	qIndex:=currentQ.allEntries.indexOf(tiRTQueueEntry);
	
	rtQueueEntry:=osTI.getQueueEntry;
	assertNotNullMsg(rtQueueEntry, "OS 1 Q Entry");
	/*
	21 Mar 2012	NDL	Par 28122
	Rule change means we don't use Deck out rules in this situation, so "TEST0000002" is no longer considered to be overstowed by
	"TEST0000003", becuase access is available from the other side.
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTFORK 000403 2", "Overstow tasks target location is incorrect"  );
	self.assertTrueMsg(currentQ.allEntries.indexOf(rtQueueEntry) &lt; qIndex,"Overstowed ti TEST0000002 not queued before  original ti");
	
	rtQueueEntry:=osTI2.getQueueEntry;
	assertNotNullMsg(rtQueueEntry, "OS 2 Q Entry");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTFORK 000203 2", "Overstow tasks target location is incorrect"  );
	self.assertTrueMsg(currentQ.allEntries.indexOf(rtQueueEntry) &lt; qIndex,"Overstowed ti TEST0000003 not queued before  original ti");
	*/
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTFORK 000203", "Target location is incorrect"  );
	
epilog
	delete locations;
	delete tiArray;


end;</source>
    </JadeMethod>
    <JadeMethod name="tStradUseOSRulesOLD1" id="43e15aae-603b-453d-b8e0-d8531db16bb2">
        <source>tStradUseOSRulesOLD1();
/* cnwer1

Purpose:	Testing the shift overstows without using YA i.e. the old method - these are config flags
				the OLD isn't in reference to a method you can delete

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	cnwer1	Initial creation

*/

vars
taSource,
	taTarget: CM_StraddleStack;
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti, nextTI, osTI: CM_TrackedItem;
	location: CM_LocationsController;
	containers : String;
	rtQueueEntry : CM_RTQueueEntry;
begin
	deleteTerminalArea("UTSTRD");
	taSource:= addStraddleStack("UTSTRD", 3, 8, 2);
	assertNotNullMsg(taSource, "UTSTRD");


	deleteTerminalArea("UTSTRDA");
	taTarget:= addStraddleStack("UTSTRDA", 3, 8, 2);
	assertNotNullMsg(taTarget, "UTSTRD");
	//taSource:=self.getTerminalArea("UTSTRD").CM_StraddleStack;
	//taTarget:=self.getTerminalArea("UTSTRDA").CM_StraddleStack;
	
	self.deleteContainer("TEST0000001");
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000001");
	self.move(ti ,taSource.allGridControllersByRowColumn[2, 5]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 5], "Did not move TEST0000001 to correct location");
		
	self.moveQueued(ti,taTarget.allGridControllersByRowColumn[2, 5]);
	self.assertEqualMsg(ti.myPrimaryQueuedLocation, taTarget.allGridControllersByRowColumn[2, 5], "Did not queue TEST0000001 to correct location");
	
	
	self.deleteContainer("TEST0000002");
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 5]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 5], "Did not move TEST0000002 to correct location");
	//add some cargo 
	
	//locations are Top Left &amp; bottom Right
	create locations transient;
	locations.add(taSource.allGridControllersByRowColumn[1, 4]);
	locations.add(taSource.allGridControllersByRowColumn[3, 6]);
	
	
	self.deleteYA("UT");
	containers := "20";
	ya := self.addYA1("UT", YACriteriaType_ContainerLength, containers, locations);
	assertNotNullMsg(ya, "UT Yard Allocation");
	rtQueueEntry:=ti.getQueueEntry();
	assertNotNullMsg(rtQueueEntry, "Q Entry");
	beginTransaction;
	ti.moveOverstowingBoxes(rtQueueEntry, null,null,null);
	commitTransaction;
	self.assertEqualMsg( rtQueueEntry.allTasks.size,4, "Did not queue overstow tasks");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.isOverstowTask,true, "First Task not overstow task");
	self.assertEqualMsg( rtQueueEntry.allTasks.first.targetLocationId,"UTSTRD 020006 1", "Overstow tasks target location is " &amp;rtQueueEntry.allTasks.first.targetLocationId &amp; " should be UTSTRD 020006 1"  );
epilog
	delete locations;

end;</source>
    </JadeMethod>
