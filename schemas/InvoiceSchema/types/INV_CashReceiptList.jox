    <JadeMethod name="tblCharges_contextMenu" id="1cab63d5-4b95-4e77-bd68-e64108dde6b4">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCharges_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			32974 access to cargo enquiry

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2013	cnwjre1	Initial creation
28/05/2018 	JLGNS1	Bug 38730: Cash Collection - Extra charge lines

*/

vars

	row		: Integer;
	obj		: Object;
	tiArray : CM_TIArray;
	cashPayment : CM_CashPayment;
begin
	self.mnuShowCashCredit.visible := false;
	obj := table.accessRow(table.row).itemObject;
	if obj &lt;&gt; null then 
		if obj.isKindOf(CM_CashReceipt)  then
			obj := table.accessRow(table.row - 1).itemObject;
			if obj &lt;&gt; null then 
				if obj.isKindOf(CM_CashPayment)  then
				
					cashPayment := obj.CM_CashPayment;
					
					if cashPayment.pxyIsProxy() then
						cashPayment := cashPayment.pxyGetRealObject();
						
						if cashPayment &lt;&gt; null then
							self.mnuShowCashCredit.visible := true;
							self.mnuShowCashCredit.userObject := cashPayment.myCashReceipt;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;


	self.mnuInspect.visible := app.isAllowedToInspect();
	
	
	return self.showContextMenu(self.mnuTableContext, table, conwin, mouse, x, y);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
