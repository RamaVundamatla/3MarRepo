    <JadeMethod name="checkExcelCanBeUsed" id="c6226a48-52df-4846-af89-ca29a58f791c">
        <source>checkExcelCanBeUsed() : Boolean;

/*****************************************************
	Written by	:	cnwpra1		16 July 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	wb		: I_Workbook;

begin
	if myExcelApplication = null then
		return false;
	endif;
	
	if excelBad then
		return false;
	endif;
	
	wb := myExcelApplication.activeWorkbook;	// if we can get the workbook then probably all ok
	
	if wb &lt;&gt; null then
		return true;
	else
		return false;
	endif;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkExcelOK" id="cf965e03-19b0-42e2-9a7d-2cd4c8705e84">
        <updating/>
        <source>checkExcelOK() : Boolean updating;

/*****************************************************
	Written by	:	cnwpra1:p		25 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	wb		: I_Workbook;

begin
	if myExcelApplication = null then
		app.msgBox('Excel appears to have been closed, please restart the definition process', 'Workbook Error', MsgBox_OK_Only);
		fatalError := true;
		return false;
	endif;
	
	excelBad := true;
	wb := myExcelApplication.activeWorkbook;
	excelBad := false;
	
	if wb = null then
		app.msgBox('Unable to find a Workbook, please restart the definition process', 'Workbook Error', MsgBox_OK_Only);
		fatalError := true;
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearWorksheetData" id="5beba5dc-53e3-4083-aad4-5ff5f5a582c2">
        <updating/>
        <source>clearWorksheetData() updating;

/*****************************************************
	Written by	:	cnwpra1		14 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if myDataWorksheet &lt;&gt; null then
		myDataWorksheet.activate;
		myDataWorksheet.cells.clear;
		myDataWorksheet.range('A1', 'A1').select;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="closeExcel" id="629faa8c-585e-4c7f-bddc-4ce09927564d">
        <updating/>
        <source>closeExcel() updating;

/*****************************************************
	Written by	:	cnwpra1		09 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if myExcelApplication &lt;&gt; null and not excelBad then
	
		doingClose := true;
		doingExcelClose := true;
		
		myExcelApplication.endNotifyAutomationEvent(self, 'myAEvents');
		
		if myExcelApplication.workbooks.count &gt; 0 then
			myExcelApplication.activeWorkbook.saved := true;
		endif;
		myExcelApplication.quit;
		delete myExcelApplication;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="dataWorksheetUpdated" id="0183183f-3bac-4b4e-a329-6747be2fd4a8">
        <updating/>
        <source>dataWorksheetUpdated() : Boolean updating;

/*****************************************************
	Written by	:	cnwpra1		14 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if myDataWorksheet.cells &lt;&gt; null then
		return true;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="4e48d5d8-ebfc-4237-badb-9ab7093ab646">
        <updating/>
        <source>delete() updating;

/*****************************************************
	Written by	:	cnwpra1		05 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	wb		: I_Workbook;

begin
	if myFileManagementDA &lt;&gt; null then
		delete myFileManagementDA;
	endif;
	if myExcelApplication &lt;&gt; null and not excelBad then
		wb := myExcelApplication.activeWorkbook;
		if wb &lt;&gt; null then
			myExcelApplication.activeWorkbook.saved := true;
		endif;
		myExcelApplication.endNotifyAutomationEvent(self, 'myAEvents');
		//myExcelApplication.endNotifyAutomationEvent(self, 'myWBE');
		myExcelApplication.quit; 
		delete myExcelApplication;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCleanupProcessing" id="18cdc10e-e587-4ce8-b320-a88c32932315">
        <updating/>
        <source>doCleanupProcessing() updating;

/*****************************************************
	Written by	:	cnwpra1		26 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	if not doingCleanup then
		
		doingCleanup := true;
		
		beginTimer(2000, Timer_OneShot, 2);
	endif;
epilog

end;</source>
    </JadeMethod>
