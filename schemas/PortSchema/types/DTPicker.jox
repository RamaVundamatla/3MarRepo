    <JadeMethod name="showCalendar" id="5bd81556-289a-461b-bd29-e96345893a33">
        <source>showCalendar();

constants
	WM_LBUTTONDOWN  = #0201;
	MK_LBUTTON      = #0001;
vars
	ocxChild:   Integer;
	yxPos:      Integer;
begin
	if upDown = false and checkBox = false then
		// A mouse click on the child window with class 'DTPicker20WndClass' will show the calendar
		if clientHeight.Integer &gt; 0 and clientWidth.Integer &gt; 5 then
			// ocx will only respond to click if height &gt;= 1 and width &gt;= 6
			ocxChild := call findWindowEx(hwnd, 0, "CtlFrameWork_ReflectWindow", "");
			ocxChild := call findWindowEx(ocxChild, 0, "DTPicker20WndClass", "");
			// y position of zero is OK
			yxPos := (0 * #10000) + clientWidth.Integer - 5;
			call postMessage(ocxChild, WM_LBUTTONDOWN, MK_LBUTTON, yxPos);
		endif;
	endif;
end;</source>
    </JadeMethod>
