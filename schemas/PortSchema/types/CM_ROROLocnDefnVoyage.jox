    <JadeMethod name="canIBeErased" id="971ce463-fef9-4248-a22b-4541b2730250">
        <source>canIBeErased(): Boolean;
/*
Purpose:			PAR 31442
Date		Who		Reason
31 May 2013	cnwab1	Initial creation
*/

vars
begin
	
	if not self.isOOTL then
		return false;
	endif;
	
	// PAR 32121 OOTL on LOAD so can be erased.
	if self.isOOTL and self.isOnLayerLoad then
		if self.hasTIs(PLANNING_MODE) then
			return false;
		elseif self.hasTIs(QUEUE_MODE) then
			return false;
		elseif self.hasTIs(REAL_MODE) then
			return false;
		endif;
		
		return true;
	endif;

	return inheritMethod();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProxySlots" id="1c294e97-121c-41b7-a131-14e519252b62">
        <source>createProxySlots();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	pxySlot : CM_ROROSlotDefnVoyage;
	idx : Integer;
begin

	foreach idx in 1 to self.numTiers do
		create pxySlot transient;
		pxySlot.setProxy(self.code &amp; idx.String, null, null, idx, true, false, self);
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawRotationMasterMark" id="ef5b8519-c4e9-4441-99f4-fee047826690">
        <source>drawRotationMasterMark(_myDrawingFrame : Frame input; _scaleFactor : Decimal);
// ---------------------------------------------------------------------------
// Created:     16 May 2013 by cnwab1 // 31569
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 
// ---------------------------------------------------------------------------

vars
	x1, y1 : Real;
	aft : CM_ROROLocnDefnVoyage;
	scale : Decimal [12,2];
begin
	
	
	if _scaleFactor &lt;&gt; 0 then
		scale:=	_scaleFactor;
	else
		scale:=1;
	endif;
		
	aft := self.myAdjacentSlotAft.CM_ROROLocnDefnVoyage;
	
	// Is the rotation master, draw a red dot.
	if aft &lt;&gt; null
	and aft.isRotationMaster() then
		x1 := aft.myLayout.myPolygonPixels[4].x;
		y1 := aft.myLayout.myPolygonPixels[4].y;
	
		_myDrawingFrame.drawFillColor := Red;
		_myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		_myDrawingFrame.drawEllipse((x1+2)*scale, (y1-2)*scale, (x1+10)*scale, (y1-10)*scale,Red);
	endif;

epilog

end;</source>
        <Parameter name="_myDrawingFrame" type="Frame" usage="input"/>
        <Parameter name="_scaleFactor" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="erase" id="7533b6bc-a1e8-4bc2-8dde-6b11804c7a19">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
Purpose:			
Date		Who		Reason
11 August 2011	cnwab1	Initial creation
23 Jan 2014	cnwkpd1	PAR #33353 - tidy up creation of RootSchema classes

*/

vars
	theCargoLayer : CM_DeckLayerLayout;
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	height : Real;
begin
	foreach slotDefn in self.allROROSlotDefnByOrdinal do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotLC = null then
			continue;
		endif;
		if slotLC.myRORORequestLoad &lt;&gt; null then
			slotLC.eraseRequest(slotLC.myRORORequestLoad);
		endif;
		if slotLC.myRORORequestDischarge &lt;&gt; null then
			slotLC.eraseRequest(slotLC.myRORORequestDischarge);
		endif;
	endforeach;

	if self.isOOTL() then
		theCargoLayer := self.myLayout.myDeckLayer.myDeckLayout.getCargoLayer(); // PAR 30264
		self.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,theCargoLayer); // PAR 28890 send the load layer or null
	endif;

	// PAR #33353 - moved up to destructor of parent class
	// PAR 30265 myPreRotatePoints is not exclusive so should delete them just in case this LocnDefn is deleted.
//	if self.myPreRotatePoints &lt;&gt; null then
//		delete self.myPreRotatePoints; 
//	endif;
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseForUnrotate" id="270af88c-b0d7-4804-9859-66d8178788de">
        <updating/>
        <source>eraseForUnrotate(_clearActual : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
24 February 2012	cnwab1	Initial creation
*/

vars
	otherLocn, actualLocn, loadLocn : CM_ROROLocnDefn;
	cargoLayer : CM_DeckLayerLayout;
	items, split : Integer;
	isRotatedOnLoad : Boolean;
begin

	isRotatedOnLoad := (self.isRotatedLoadLayer() and self.isPlannedRotated);

	items := self.allPlannedRotatedLocnDefns.size;
	if items = 10 or items = 6 then
		split := 2;
	else
		split := 1;
	endif;

	self.myDeck.myDeckLayout.getCargoLayer();
	foreach otherLocn in self.allPlannedRotatedLocnDefns discreteLock do
		
		if _clearActual then // we are the master on the load clones. The Clones are being un rotated
			if otherLocn = self then
				continue;
			endif;
			actualLocn := otherLocn.getRotatedLinked();
			
			if not isRotatedOnLoad then // PAR 29884 if this is rotated on the load layer then it means that we are just a clone and do not need to sort out the aft/fwd linking
				// PAR 28990 
				if actualLocn.myPreRotateAftLocn &lt;&gt; null then
					// If my pre rotate aft is now itself rotated, link to it's clone
					if actualLocn.myPreRotateAftLocn.myRotateLoad &lt;&gt; null then
						actualLocn.myPreRotateAftLocn.myRotateLoad.setFwdLocn(null);
						actualLocn.setAftLocn(actualLocn.myPreRotateAftLocn.myRotateLoad);
					else
						// If my pre rotate aft is NOT rotated, link to it my pre rotate forward
						actualLocn.myPreRotateAftLocn.setFwdLocn(null);
						actualLocn.setAftLocn(actualLocn.myPreRotateAftLocn);
					endif;
				endif;
				if actualLocn.myPreRotateFwdLocn &lt;&gt; null then
					// If my pre rotate forward is now itself rotated, link to it's clone
					if actualLocn.myPreRotateFwdLocn.myRotateLoad &lt;&gt; null then
						actualLocn.myPreRotateFwdLocn.myRotateLoad.setAftLocn(null);
						actualLocn.setFwdLocn(actualLocn.myPreRotateFwdLocn.myRotateLoad);
					else
					// If my pre rotate forward is NOT rotated, link to it my pre rotate forward
						actualLocn.myPreRotateFwdLocn.setAftLocn(null);
						actualLocn.setFwdLocn(actualLocn.myPreRotateFwdLocn);
					endif;
				endif;
			endif;

			
			// PAR 28990 - break the link with the actual location
			if actualLocn &lt;&gt; null then
				actualLocn.setRotateCloneLink(null);
			endif;
			delete otherLocn;
		else // we are the actual, delete the clones. Then else where un rotate me
			actualLocn := otherLocn;

			// PAR 28990 
			if actualLocn.myPreRotateAftLocn &lt;&gt; null then
				// If my pre rotate aft is now itself rotated, link to it's clone
				if actualLocn.myPreRotateAftLocn.myRotateLoad &lt;&gt; null then
					actualLocn.myPreRotateAftLocn.myRotateLoad.setFwdLocn(null);
					actualLocn.setAftLocn(actualLocn.myPreRotateAftLocn.myRotateLoad);
				else
					// If my pre rotate aft is NOT rotated, link to it my pre rotate forward
					actualLocn.myPreRotateAftLocn.setFwdLocn(null);
					actualLocn.setAftLocn(actualLocn.myPreRotateAftLocn);
				endif;
				actualLocn.myPreRotateAftLocn.myPreRotateFwdLocn := actualLocn;
			endif;
			if actualLocn.myPreRotateFwdLocn &lt;&gt; null then
				// If my pre rotate forward is now itself rotated, link to it's clone
				if actualLocn.myPreRotateFwdLocn.myRotateLoad &lt;&gt; null then
					actualLocn.myPreRotateFwdLocn.myRotateLoad.setAftLocn(null);
					actualLocn.setFwdLocn(actualLocn.myPreRotateFwdLocn.myRotateLoad);
				else
				// If my pre rotate forward is NOT rotated, link to it my pre rotate forward
					actualLocn.myPreRotateFwdLocn.setAftLocn(null);
					actualLocn.setFwdLocn(actualLocn.myPreRotateFwdLocn);
				endif;
				actualLocn.myPreRotateFwdLocn.myPreRotateAftLocn := actualLocn;
			endif;
			
			loadLocn := actualLocn.getRotatedLinked(); // Get the clone
			delete loadLocn;
			
			// The actual rotate is in the graphic
			actualLocn.myLayout.setLocnDefnsToUnrotate(actualLocn.myPreRotatePoints);
			
			 // PAR 29990
			if actualLocn.isOOTLLocn 
			and actualLocn.isRotatedLoadLayer() then
				actualLocn.isPlannedRotated := false;
				actualLocn.setOppositeOrientation();
				// PAR 31129 DMAST ONLY 821 - actualLocn.allPlannedRotatedLocnDefns.clear();
				actualLocn.clearAllPlannedRotatedLocnDefn();
			endif;
			actualLocn.myPreRotatePoints.clear();
			delete actualLocn.myPreRotatePoints; // PAR 30265 myPreRotatePoints is not exclusive so should delete them just in case this LocnDefn is deleted.
			actualLocn.myPreRotateFwdLocn := null;
			actualLocn.myPreRotateAftLocn := null;
		endif;
	endforeach;

	if _clearActual then
		// PAR 28990 - break the link with the actual location
		actualLocn := self.getRotatedLinked(); //myDeck.allROROLocnDefnByOrdinal[self.voltageType];
		if actualLocn &lt;&gt; null then
			actualLocn.setRotateCloneLink(null);
		endif;
		self.erase(NORMAL_ERASE);
	endif;

	
epilog

end;</source>
        <Parameter name="_clearActual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAftLCFor40" id="37f77ccb-dfc6-4544-8175-7f2b1443603e">
        <source>getAftLCFor40(_mode : Integer) : CM_ROROLocnDefnVoyage;
/*
Purpose:			
Date		Who		Reason
23 August 2011	cnwab1	Initial creation
*/

vars

	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	obj : Object;
	has40s : Boolean;
	aTI : CM_TrackedItem;
	tis : CM_TIArray;
begin

	create tis transient;
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotLC &lt;&gt; null then
			slotLC.getTIs(tis, _mode, true); // PAR 27749
			foreach aTI in tis do
				if not aTI.isTwenty() then
					if _mode = PLANNING_MODE then
						if aTI.myPrimaryPlannedLocation = slotLC then
							has40s := true;
						endif;
					elseif _mode = REAL_MODE then
						if aTI.myPrimaryActualLocation = slotLC then
							has40s := true;
						endif;
					elseif _mode = QUEUE_MODE then
						if aTI.myPrimaryQueuedLocation = slotLC then
							has40s := true;
						endif;
					endif;
					
					if has40s then
						break;
					endif;
				endif;
			endforeach;
		endif;
	endforeach;	

	if has40s then
		return self.myAdjacentSlotAft.CM_ROROLocnDefnVoyage;
	endif;

epilog
delete tis;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_ROROLocnDefnVoyage"/>
    </JadeMethod>
    <JadeMethod name="getAftLCFor40Proposed" id="8ccf1b24-9361-43d7-9a93-cb461634fe28">
        <source>getAftLCFor40Proposed() : CM_ROROLocnDefnVoyage;
/*
Purpose:			
Date		Who		Reason
16 September 2011	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	obj : Object;
	has40s : Boolean;
	aTI : CM_TrackedItem;
	tis : CM_TIArray;
begin

	create tis transient;
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotLC &lt;&gt; null then
			slotLC.getProposedTIs(tis);
		endif;
		
		foreach aTI in tis discreteLock do
			if aTI.myPrimaryPlannedLocation = slotLC 
			or aTI.myPrimaryActualLocation = slotLC then
				has40s := true;
				break;
			endif;

		endforeach;
	endforeach;	
	if has40s then
		return self.myAdjacentSlotAft.CM_ROROLocnDefnVoyage;
	endif;

epilog
delete tis;
end;</source>
        <ReturnType type="CM_ROROLocnDefnVoyage"/>
    </JadeMethod>
    <JadeMethod name="getAllTIByIMEX" id="957b4d70-bbb7-4753-9ddf-0e0b0d1b6487">
        <source>getAllTIByIMEX(_imex: Integer; _tis: CM_TIArray input; _clear: Boolean);
/*
Purpose:			
Date		Who		Reason
19 September 2011	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;

	has40s : Boolean;
	aTI : CM_TrackedItem;

begin
	if _tis = null then
		return;
	endif;
	
	if _clear then
		_tis.clear();
	endif;
	

	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
	
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
	
		if slotLC &lt;&gt; null then
			slotLC.getAllTIByIMEX(_imex, _tis, true);
		endif;
	endforeach;	

epilog
end;</source>
        <Parameter name="_imex" type="Integer"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllTIs" id="b35ba9bd-6bc5-4137-b5da-4963245eeead">
        <source>getAllTIs(_mode : Integer; _tis : CM_TIArray input; _clear : Boolean);
/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation

PAR28900 - draw fwd 20s, then aft 20s then 40s
*/

vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;

	has40s : Boolean;
	aTI : CM_TrackedItem;
	tis, tis40, tis20A, tis20F : CM_TIArray;
begin
	if _tis = null then
		return;
	endif;
	
	if _clear then
		_tis.clear();
	endif;
	create tis transient;
	create tis40 transient;
	create tis20A transient;
	create tis20F transient;
	
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotLC &lt;&gt; null then
			slotLC.getTIs(tis, _mode, true); // PAR 27749
// PAR 28900			tis.copy(_tis);

			

			foreach aTI in tis do
				if aTI.isTwenty() then
					tis20F.add(aTI); // PAR 28900
					
				else
					tis40.add(aTI); // PAR 28900
					if _mode = PLANNING_MODE then
						if aTI.myPrimaryPlannedLocation = slotLC then
							has40s := true;
						endif;
					elseif _mode = REAL_MODE then
						if aTI.myPrimaryActualLocation = slotLC then
							has40s := true;
						endif;
					elseif _mode = QUEUE_MODE then
						if aTI.myPrimaryQueuedLocation = slotLC then
							has40s := true;
						endif;
					endif;
					
// PAR 28900					if has40s then
//						break;
//					endif;
				endif;
			endforeach;
		endif;
	endforeach;	
	// get Aft 20s
	if has40s then
		if self.myAdjacentSlotAft &lt;&gt; null then
			foreach slotDefn in self.myAdjacentSlotAft.allROROSlotDefnByOrdinal discreteLock do
				slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
				
				if slotLC &lt;&gt; null then
					slotLC.getTIs(tis, _mode, true); // PAR 27749
					foreach aTI in tis do
						if aTI.isTwenty() then
// PAR 28900							_tis.insert(1,aTI);

						tis20A.add(aTI); // PAR 28900


						endif;
					endforeach;
				endif;
			endforeach;
		
		endif;
	endif;
	
	tis20F.copy(_tis);
	tis20A.copy(_tis);
	tis40.copy(_tis);
	

epilog
delete tis;
delete tis40;
delete tis20A;
delete tis20F;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllTIsForDisplayMode" id="c47298a8-0185-4797-a1cc-362755d41444">
        <source>getAllTIsForDisplayMode(_viewMode,
						_viewModeSub : Integer; 
						_tis : CM_TIArray input; 
						_clear : Boolean;
						_has40s : Boolean output) ;
/*

Date		Who		Reason
18 July 2013	cnwer1	Initial creation PAR 31936

*/

vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;

	has40s : Boolean;
	aTI : CM_TrackedItem;
	tis, tis40, tis20A, tis20F : CM_TIArray;
begin
		
	if _tis = null then
		return;
	endif;
	
	if _clear then
		_tis.clear();
	endif;
	create tis transient;
	create tis40 transient;
	create tis20A transient;
	create tis20F transient;
	
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotLC &lt;&gt; null then
			if _viewMode = ShpDisplayMode_ColCodeDisch then
				slotLC.getTIs(tis, REAL_MODE, true); // PAR 27749
			elseif _viewMode = ShpDisplayMode_ColCodeLoad then
				slotLC.getROB(tis, true, false);	
			endif;
			foreach aTI in tis do
				if aTI.isTwenty() then
					tis20F.add(aTI); // PAR 28900
					
				else
					if _viewMode = ShpDisplayMode_ColCodeDisch and _viewModeSub = ShpDisplayModeSub_ExportsHide then  
						if aTI &lt;&gt; null and (aTI.isExport or aTI.isRehandle or aTI.isSOB)  
						 or aTI.isTranshipExport() then
							continue;
						endif;
					endif;
					
					if _viewMode = ShpDisplayMode_ColCodeLoad
						and (aTI.isToBeDischargedHere() 
											or (aTI.isRehandle or aTI.isSOB))  // PAR 29770 
						and aTI.getVoyageWLEUnactioned(false) &lt;&gt; null then // is colour coded
							continue;
						endif;
					
					tis40.add(aTI); // PAR 28900
					
					if aTI.myPrimaryActualLocation = slotLC then
						has40s := true;
					endif;
				endif;
			endforeach;
		endif;
	endforeach;	
	// get Aft 20s
	if has40s then
		if self.myAdjacentSlotAft &lt;&gt; null then
			foreach slotDefn in self.myAdjacentSlotAft.allROROSlotDefnByOrdinal discreteLock do
				slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
				
				if slotLC &lt;&gt; null then
					if _viewMode = ShpDisplayMode_ColCodeDisch then
						slotLC.getTIs(tis, REAL_MODE, true); // PAR 27749
					elseif _viewMode = ShpDisplayMode_ColCodeLoad then
						slotLC.getROB(tis, true, false);	
					endif;
					foreach aTI in tis do
						if aTI.isTwenty() then
						tis20A.add(aTI); // PAR 28900
					endif;
					endforeach;
				endif;
			endforeach;
			
		endif;
	endif;
	
	tis20F.copy(_tis);
	tis20A.copy(_tis);
	tis40.copy(_tis);
	_has40s:=has40s;
epilog
delete tis;
delete tis40;
delete tis20A;
delete tis20F;


end;</source>
        <Parameter name="_viewMode" type="Integer"/>
        <Parameter name="_viewModeSub" type="Integer"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_has40s" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getAllTIsRoB" id="70f91212-f5a3-447a-957b-56ed12b9901c">
        <source>getAllTIsRoB(_tis : CM_TIArray input; _clear : Boolean; _ediProposed : Boolean);
/*
Purpose:			
Date				Who			Reason
FEB 2012		CNWAB1		Initial creation
*/
//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;

	has40s : Boolean;
	aTI : CM_TrackedItem;
	tis, tis40, tis20A, tis20F : CM_TIArray;
begin
	if _tis = null then
		return;
	endif;
	
	if _clear then
		_tis.clear();
	endif;
	create tis transient;
	create tis40 transient;
	create tis20A transient;
	create tis20F transient;
	
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotLC &lt;&gt; null then
			slotLC.getROB(tis, true, _ediProposed);	//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed

			foreach aTI in tis do
				if aTI.isTwenty() then
					tis20F.add(aTI);
					
				else
					tis40.add(aTI);
					if aTI.myPrimaryActualLocation = slotLC then
						has40s := true;
					endif;
				endif;
			endforeach;
		endif;
	endforeach;	
	// get Aft 20s
	if has40s then
		if self.myAdjacentSlotAft &lt;&gt; null then
			foreach slotDefn in self.myAdjacentSlotAft.allROROSlotDefnByOrdinal discreteLock do
				slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
				
				if slotLC &lt;&gt; null then
					slotLC.getROB(tis, true, _ediProposed);	//15 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
					foreach aTI in tis do
						if aTI.isTwenty() then
							tis20A.add(aTI); 
						endif;
					endforeach;
				endif;
			endforeach;
		
		endif;
	endif;
	
	tis20F.copy(_tis);
	tis20A.copy(_tis);
	tis40.copy(_tis);
	

epilog
delete tis;
delete tis40;
delete tis20A;
delete tis20F;

end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_ediProposed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllVoyageControllers" id="0a1a8224-d8a7-4f8e-95d5-85de5f0ec2a6">
        <source>getAllVoyageControllers(_allControllers: CM_VoyageROROControllerArray io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	slotController : CM_ROROSlotController;
	roroSlotDefn		: CM_ROROSlotDefn;
	roroSlotDefnVoyage : CM_ROROSlotDefnVoyage;
begin
	
	if self.allROROSlotDefnByOrdinal.isEmpty then
		return;
	endif;
	
	foreach roroSlotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		roroSlotDefnVoyage:=roroSlotDefn.CM_ROROSlotDefnVoyage;
		slotController:=roroSlotDefnVoyage.mySlotController;
		if slotController = null then
			continue;
		endif;
		
		if not _allControllers.includes(slotController) then
			_allControllers.add(slotController);
		endif;
	endforeach;
	

epilog

end;</source>
        <Parameter name="_allControllers" type="CM_VoyageROROControllerArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllVoyageRequests" id="731465f7-3f7e-496a-9deb-1466e963d522">
        <source>getAllVoyageRequests(_allRequests: CM_VoyageRequestArray io);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwer1	Initial creation CCMS MES 1033
13 Sep 2012	cnwrs1	Par 29388 don't add null requests
*/

vars
	slotController : CM_ROROSlotController;
	req : CM_RORORequest;
	roroSlotDefn		: CM_ROROSlotDefn;
	roroSlotDefnVoyage : CM_ROROSlotDefnVoyage;
begin
	
	if self.allROROSlotDefnByOrdinal.isEmpty then
		return;
	endif;
	
	foreach roroSlotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		roroSlotDefnVoyage := roroSlotDefn.CM_ROROSlotDefnVoyage;
		slotController := roroSlotDefnVoyage.mySlotController;
		if slotController = null then
			continue;
		endif;
		req := slotController.myRORORequestLoad;
		if req = null then
			req := slotController.myRORORequestDischarge;
		endif;
		if req &lt;&gt; null then
			_allRequests.add(req);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_allRequests" type="CM_VoyageRequestArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCargoDetails" id="183c00e3-bbb1-4c85-8216-c34e673c27d2">
        <source>getCargoDetails(_mode, _modeView, _modeViewSubSub: Integer): String;


/*
Purpose:			
Date				Who		Reason
14 December 2011	cnwab1	Initial creation
19/07/2012			cnwmh5	#29966 - Rewrite foreach to handle getting details of aft slots if fwd as 40ft in it
29/01/2013			cnwmh5	#31090 - Rewrite to handle situations correctly
14/05/2013			cnwmh5 	#31367 - Fix what discharge is displaying at each step
*/


vars

	locnDefnVoyage				: CM_ROROLocnDefnVoyage;
	slotDefn 					: CM_ROROSlotDefn;
	slotLC 						: CM_ROROSlotController;
	aftLocn						: CM_ROROLocnDefn;
	fwdLocn						: CM_ROROLocnDefn;
	ti 							: CM_TrackedItem;
	aReq 						: CM_RORORequest;
	
	itemDescs 					: StringArray;
	itemID 						: StringArray;
	itemCount 					: IntegerArray;
	locnDefnArray				: ObjectArray;
	coll 						: CM_TIArray;

	temp						: String;
	tiList						: String;
	index						: Integer;
	idx							: Integer;
	idxSt						: Integer;
	idxEnd 						: Integer;
	dontAdd						: Boolean;
	

begin

	create coll transient;
	create itemDescs transient;
	create itemCount transient;
	create itemID transient;

	create locnDefnArray transient;	
	locnDefnArray.add(self);
	
	aftLocn := self.myAdjacentSlotAft;
	fwdLocn := self.myAdjacentSlotFwd;
	
	if _modeView = ShpDisplayMode_ColCodeDisch then
		
		if _modeViewSubSub = ShpDisplayModeSub_ExportsShow then				// 20/05/2013 cnwmh5 #31367
			aReq := self.getFirst40Request(true);
			if aReq &lt;&gt; null or self.hasTIs40(REAL_MODE, aftLocn &lt;&gt; null) then
				if self &lt;&gt; fwdLocn and aftLocn &lt;&gt; null and not locnDefnArray.includes(aftLocn) then
					locnDefnArray.add(aftLocn);
				endif;
			endif;
		elseif _modeViewSubSub = ShpDisplayModeSub_ExportsHide then
			aReq := self.getFirst40Request(false);
			if aReq &lt;&gt; null then
				if aftLocn &lt;&gt; null // PAR 31652
				and not locnDefnArray.includes(aftLocn) then
						locnDefnArray.add(aftLocn);
				endif;
			else
				aReq := self.getFirst40Request(true);
				if aReq = null and self.hasTIs40(REAL_MODE, aftLocn &lt;&gt; null) and not locnDefnArray.includes(aftLocn) then
					if aftLocn &lt;&gt; null then // PAR 31652
						locnDefnArray.add(aftLocn);
					endif;
				endif;
			endif;
		endif;
		
		/*
		aReq := self.getFirst40Request(false);
		if aReq &lt;&gt; null then
			if self &lt;&gt; fwdLocn and aftLocn &lt;&gt; null and not locnDefnArray.includes(aftLocn) then
				locnDefnArray.add(aftLocn);
			endif;
		else
			//if self.hasTIs40(REAL_MODE, aftLocn &lt;&gt; null) then  // 14/05/2013 cnwmh5 #31367
			aReq := self.getFirstRequest(true);
			if (aReq = null and self.hasTIs40(REAL_MODE, aftLocn &lt;&gt; null)) or 
					(_modeViewSubSub = ShpDisplayModeSub_ExportsShow and self.hasTIs40(REAL_MODE, aftLocn &lt;&gt; null)) then
				if self &lt;&gt; fwdLocn and aftLocn &lt;&gt; null and not locnDefnArray.includes(aftLocn) then
					locnDefnArray.add(aftLocn);
				endif;
			endif;
		endif;
		*/
	elseif _modeView = ShpDisplayMode_ColCodeLoad then
		aReq := self.getFirst40Request(true);
		if aReq &lt;&gt; null then
			if self &lt;&gt; fwdLocn and aftLocn &lt;&gt; null and not locnDefnArray.includes(aftLocn) then
				locnDefnArray.add(aftLocn);
			endif;
		else
			if self.hasTIs40(PLANNING_MODE, aftLocn &lt;&gt; null) then
				if self &lt;&gt; fwdLocn and aftLocn &lt;&gt; null and not locnDefnArray.includes(aftLocn) then
					locnDefnArray.add(aftLocn);
				endif;
			endif;
		endif;
	else
		if _mode = ShpDisplayMode_Actual then
			if self.hasTIs40(REAL_MODE, aftLocn &lt;&gt; null) then
				if self &lt;&gt; fwdLocn and aftLocn &lt;&gt; null and not locnDefnArray.includes(aftLocn) then
					locnDefnArray.add(aftLocn);
				endif;
			endif;
		elseif _mode = ShpDisplayMode_Proposed then
			if self.hasTIs40(PLANNING_MODE, aftLocn &lt;&gt; null) then
				if self &lt;&gt; fwdLocn and aftLocn &lt;&gt; null and not locnDefnArray.includes(aftLocn) then
					locnDefnArray.add(aftLocn);
				endif;
			endif;
		endif;
		
	endif;
	
	index := 0;
	while true do
		index := index + 1;
		if index &gt; locnDefnArray.size then
			break;
		endif;

		locnDefnVoyage := locnDefnArray[index].CM_ROROLocnDefnVoyage;
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if slotLC &lt;&gt; null then
								
				if _mode = ShpDisplayMode_Proposed then // PAR 28990
					slotLC.getProposedTIs(coll);
				else
					slotLC.getTIs(coll,REAL_MODE,true); // PAR 29298
					
					// 14/05/2013 cnwmh5 #31367
					if _modeView = ShpDisplayMode_ColCodeDisch and _modeViewSubSub = ShpDisplayModeSub_ExportsHide then
						if slotLC.myRORORequestDischarge &lt;&gt; null then
							ti := slotLC.myRORORequestDischarge.getTrackedItem();
							if ti &lt;&gt; null then
								coll.clear();
								if not itemID.includes(ti.id) then
									coll.add(ti);
								else
									dontAdd := true;
								endif;
							endif;
						endif;
					elseif _modeView = ShpDisplayMode_ColCodeLoad then
						if slotLC.myRORORequestLoad &lt;&gt; null then
							ti := slotLC.myRORORequestLoad.getTrackedItem();
							if ti &lt;&gt; null then
								if not itemID.includes(ti.id) then
									coll.add(ti);
								else
									dontAdd := true;
								endif;
							endif;
						endif;
					else
						slotLC.getTIs(coll,REAL_MODE,true); // PAR 29298
					endif;
				endif;
				
				foreach ti in coll discreteLock do
				
					if not itemID.includes(ti.id) then
						itemID.add(ti.id);
					else
						if not ti.is20 then
							dontAdd := true;
						endif;
					endif;
					
					if _mode = ShpDisplayMode_Proposed then
						if ti.getPrimaryLocation(REAL_MODE).isKindOf(CM_ROROSlotController) and not ti.is20 then
							if self &lt;&gt; fwdLocn and aftLocn &lt;&gt; null and not locnDefnArray.includes(aftLocn) then
								locnDefnArray.add(aftLocn);
							endif;
						endif;
					endif;
					
					temp := ti.getCargoDetails();
					
					idx := itemDescs.indexOf(temp);
					
					if idx = 0 then
						itemDescs.add(temp);
						idx := itemDescs.size;
						itemCount[idx] := 1;
					else
						if not dontAdd then
							itemCount[idx] := itemCount[idx] + 1;
						endif;
					endif;
					
				endforeach;
			
			endif;
		endforeach;
		
	endwhile;
		
	idxSt := 1;
	idxEnd := itemDescs.size;
	temp := null;
	
	if self.myAdjacentSlotAft &lt;&gt; null then
		temp := "Aft: " &amp; self.myAdjacentSlotAft.code;
	endif;
	if self.myAdjacentSlotFwd &lt;&gt; null then
		temp := temp &amp; " Fwd: " &amp; self.myAdjacentSlotFwd.code;
	endif;
	if temp &lt;&gt; null then
		temp := temp &amp; " ";
	endif;
	
	foreach idx in idxSt to idxEnd do
		if temp = null then
			temp := itemCount[idx].String &amp; " x " &amp; itemDescs[idx];
		else
			temp := temp &amp; "| " &amp; itemCount[idx].String &amp; " x " &amp; itemDescs[idx];
		
		endif;
	endforeach;
	
	foreach idx in idxSt to itemID.size do							// 19/07/2012 cnmwh5 #29966
		if tiList = null then
			tiList := itemID[idx];
		else
			tiList := tiList &amp; ', ' &amp; itemID[idx];
		endif;
	endforeach;
	
	return self.code &amp; " | " &amp; temp &amp; " | " &amp;  tiList;
	
epilog

	delete locnDefnArray;
	delete coll;
	delete itemDescs;
	delete itemCount;
	delete itemID;
	
end;
</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_modeView" type="Integer"/>
        <Parameter name="_modeViewSubSub" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCellPileColourHeight" id="0d93943f-c0e2-4198-9f71-17d82e6b9e14">
        <source>getCellPileColourHeight() : Real;
/*
Purpose:			
Date		Who		Reason
28 July 2011	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	height : Real;
begin
	foreach slotDefn in self.allROROSlotDefnByOrdinal reversed do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotLC.myRORORequestLoad = null then
			height := height + HEIGHT_FULL_HIGH_CUBE;
		else
			if slotLC.myRORORequestLoad.getAttrHiCubed() then
				height := height + HEIGHT_FULL_NORMAL - HEIGHT_FULL_HIGH_CUBE;
			else
				height := height + HEIGHT_FULL_HIGH_CUBE - HEIGHT_FULL_NORMAL;
			endif;
		endif;
	endforeach;
	
	return height;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getColourCoding40" id="ee4c1b52-c1d7-4389-aec4-843d2a70ed13">
        <source>getColourCoding40(_type: Integer; _aft : Boolean): CM_ROROSlotRequest;
/*
Purpose:			
Date				Who			Reason
March 2012		CNWAB1		Initial creation
*/

vars

	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	obj : Object;
	is40 : Boolean;
	aTI : CM_TrackedItem;
	roroReq : CM_ROROSlotRequest;
begin
	
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		
		if slotLC &lt;&gt; null then
			if _type = LOAD_MOVETYPE then
				roroReq := slotLC.myRORORequestLoad.CM_ROROSlotRequest;
			elseif _type = DISCHARGE_MOVETYPE then
				roroReq := slotLC.myRORORequestDischarge.CM_ROROSlotRequest;
			endif;
			if roroReq &lt;&gt; null then
				if _aft then
					if roroReq.getAttrIsBackend() then
						return roroReq;
					endif;
				else
					is40 := roroReq.getAttrIsNOT20(); // PAR 30253
					if is40 and not roroReq.getAttrIsBackend() then
					// PAR 30253 if roroReq.getAttrIs40 and not roroReq.getAttrIsBackend() then
						return roroReq;
					endif;
				endif;
			endif;
		endif;
	endforeach;

	
	return null;

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_aft" type="Boolean"/>
        <ReturnType type="CM_ROROSlotRequest"/>
    </JadeMethod>
    <JadeMethod name="getDefnFor40RemainOnBoard" id="d8d0cad4-3eff-4508-98f9-2472e069538a">
        <source>getDefnFor40RemainOnBoard() : CM_ROROLocnDefnVoyage;

/*

Purpose:			

Date			Who		Reason
30 July 2012	cnwmh5	Initial creation

*/

vars

	fwdSlot					: Boolean;

begin

	// check to see whether we are fwd slot
	fwdSlot := (self.getAftLocnDefn() = null).Boolean;
	
	if self.hasTIs40(REAL_MODE, not fwdSlot) then
		if fwdSlot then
			return self.getFwdDefnFor40Proposed();
		else
			return self.getAftLCFor40Proposed();
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_ROROLocnDefnVoyage"/>
    </JadeMethod>
    <JadeMethod name="getFirst40Request" id="c1298459-d6ea-4981-8594-d58f81e2228b">
        <source>getFirst40Request(_isLoad : Boolean) : CM_RORORequest;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/


vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	theReq : CM_RORORequest;
	is40 : Boolean;
begin
		foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if slotLC = null then
				continue;
			endif;
			
			if _isLoad then
				theReq := slotLC.myRORORequestLoad;
			else
				theReq := slotLC.myRORORequestDischarge;
			endif;
			if theReq &lt;&gt; null then
				is40 := theReq.getAttrIsNOT20(); // PAR 30253
				// PAR 30253 if theReq.getAttrIs40()  then
				if is40  then
					return theReq;
				endif;
			endif;
		endforeach;
		
		return null;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="getFirstLC" id="a7afd0c4-ea2c-4c6c-9cd9-43d836ba7b7c">
        <source>getFirstLC(): CM_VoyageROROController;
/*
Purpose:			
Date		Who		Reason
26 September 2011	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
begin
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		if slotDefn.CM_ROROSlotDefnVoyage.mySlotController &lt;&gt; null  then
			return slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_VoyageROROController"/>
    </JadeMethod>
    <JadeMethod name="getFirstRequest" id="9bb2cbd7-e038-458b-b795-4cced1228e21">
        <source>getFirstRequest(_isLoad : Boolean) : CM_RORORequest;
/*
Purpose:		31347	
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/


vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	theReq : CM_RORORequest;
	is40 : Boolean;
begin
		foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if slotLC = null then
				continue;
			endif;
			
			if _isLoad then
				theReq := slotLC.myRORORequestLoad;
			else
				theReq := slotLC.myRORORequestDischarge;
			endif;
			if theReq &lt;&gt; null then
				return theReq;
			endif;
		endforeach;
		
		return null;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="getFirstTI" id="94d2e477-b750-44e6-889e-849a39c3d797">
        <source>getFirstTI() : CM_TrackedItem;
/*
Purpose:			
Date		Who		Reason
23 June 2011	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
begin
		foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			
			if slotLC &lt;&gt; null and not slotLC.allTrackedItems.isEmpty() then
				return slotLC.allTrackedItems.first();
			endif;
		endforeach;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getFirstUnplannedRequest" id="c44c9798-8233-462a-80f7-dc7b0d6bc9e2">
        <source>getFirstUnplannedRequest(_isLoad : Boolean) : CM_RORORequest;
/*
Purpose:			
Date				Who			Reason
OCTOBER 2011		CNWAB1		Initial creation
*/


vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	theReq : CM_RORORequest;
	theTI : CM_TrackedItem;
	theWLE : CM_VoyageWLE;
begin
		foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock  do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if slotLC = null then
				continue;
			endif;
			
			if _isLoad then
				theReq := slotLC.myRORORequestLoad;
			else
				theReq := slotLC.myRORORequestDischarge;
			endif;
			if theReq &lt;&gt; null then

				if not _isLoad then // DISCHARGE
					theTI := theReq.getFirstUnplannedTI();
					if theTI &lt;&gt; null then
						return theReq;
					endif;
				else // PAR 28942
					theWLE :=  theReq.getFirstUnusedWLE().CM_VoyageWLE;
					if theWLE &lt;&gt; null then
						if theWLE.myTrackedItem = null then
							return theReq;
						endif;
					endif;
				endif;
			endif;
		endforeach;
		
		return null;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="getFullId" id="93b5cde3-0bf6-42bf-9160-6e12d0da7dc5">
        <source>getFullId() : String;
/*
Purpose:			
Date		Who		Reason
28 July 2011	cnwab1	Initial creation
*/

vars
	firstSlot : CM_ROROSlotDefnVoyage;
begin
	firstSlot := self.allROROSlotDefnByOrdinal.first.CM_ROROSlotDefnVoyage;
	if firstSlot = null then
		return self.code;
	endif;
	if firstSlot.mySlotController = null then
		return self.code;
	endif;
	
	return firstSlot.mySlotController.getFullId();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFwdDefnFor40Proposed" id="8c7abaf1-896c-4bbd-ad1a-b7c378b0c1cb">
        <source>getFwdDefnFor40Proposed(): CM_ROROLocnDefnVoyage;
/*
Purpose:			
Date		Who		Reason
19 Jul 2012	cnwab1	Initial creation 29978
*/

vars
	slotDefn : CM_ROROSlotDefn;
	fwdSlotLC,
	slotLC : CM_ROROSlotController;
	aTI : CM_TrackedItem;
	tis : CM_TIArray;
	
	fwdSlotDefn : CM_ROROSlotDefnVoyage;		//cnwmc5 - 24 April 2014 - PAR 33163
begin

	create tis transient;
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotLC &lt;&gt; null then
			slotLC.getProposedTIs(tis);
		endif;
		if self.myAdjacentSlotFwd &lt;&gt; null then
			//cnwmc5 - 24 April 2014 - PAR 33163 - changed the below code block to first check if the slot defn is null..
			//fwdSlotLC:=self.myAdjacentSlotFwd.allROROSlotDefnByOrdinal[self.myAdjacentSlotFwd.ordinal,slotDefn.ordinal].CM_ROROSlotDefnVoyage.mySlotController;
			fwdSlotDefn := self.myAdjacentSlotFwd.allROROSlotDefnByOrdinal[self.myAdjacentSlotFwd.ordinal,slotDefn.ordinal].CM_ROROSlotDefnVoyage;
			if fwdSlotDefn &lt;&gt; null then
				fwdSlotLC := fwdSlotDefn.mySlotController;
			endif;
		endif;
		foreach aTI in tis discreteLock do
			if aTI.myPrimaryPlannedLocation = slotLC 
			or aTI.myPrimaryActualLocation = slotLC then
				return self; //this is the fwd slot return
			endif;
			if fwdSlotLC &lt;&gt; null then
				if aTI.myPrimaryPlannedLocation = fwdSlotLC
				or aTI.myPrimaryActualLocation = fwdSlotLC	then
					return self.myAdjacentSlotFwd.CM_ROROLocnDefnVoyage;
				endif;
			endif;
		endforeach;
	endforeach;	
	return null;

epilog
delete tis;

end;</source>
        <ReturnType type="CM_ROROLocnDefnVoyage"/>
    </JadeMethod>
    <JadeMethod name="getHeightMetresTIs" id="84489f5b-b2cc-4792-9f69-12d26b280819">
        <source>getHeightMetresTIs(_mode : Integer; _clear : Boolean) : Real;
/*
Purpose:			
Date		Who		Reason
28 June 2011	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
	theTI : CM_TrackedItem;
	height : Real;
	theTIs : CM_TIArray;
begin
	create theTIs transient;
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		if not slotDefn.isAvailable then
			continue;
		endif;
		
		slotDefn.CM_ROROSlotDefnVoyage.mySlotController.getTIs(theTIs, _mode, _clear);
		foreach theTI in theTIs discreteLock do
			height := height + (theTI.getActualHeightRaw() / 100);
		endforeach;

	endforeach;

	return height;

epilog
	delete theTIs;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_clear" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getJRWReportingType" id="8d8a4821-dacf-42df-88f5-35465253df5e">
