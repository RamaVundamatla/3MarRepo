    <JadeMethod name="assertTIPlannedToLocation" id="89e8c27b-0b00-401f-9194-5839795d4730">
        <source>assertTIPlannedToLocation(_trackedItem : CM_TrackedItem; _slotRequest : CM_SlotRequest; _gridController : CM_GridController; _expectedPos : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 December 2008	cnwer1	Initial creation

*/

vars
	actualPosInStack : Integer;
begin
	assertTrueMsg(_trackedItem.myPrimaryActualLocation = _gridController,"Voyage slot " &amp; _slotRequest.getSeqNum.String &amp; " " &amp; _slotRequest.id &amp; " container "  &amp; _trackedItem.id &amp; 
		" expected location = "  &amp;  _gridController.getFullId &amp; " actual location = "  &amp; _trackedItem.myPrimaryActualLocation.getFullId); 
	
	actualPosInStack:=_trackedItem.getPositionInStack(REAL_MODE);
	assertTrueMsg(actualPosInStack = _expectedPos, "Voyage slot " &amp; _slotRequest.getSeqNum.String &amp; " " &amp; _slotRequest.id &amp; " expected trackedItem to be at position = " &amp;  _expectedPos.String &amp; " actual position = " &amp; actualPosInStack.String);
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
        <Parameter name="_gridController" type="CM_GridController"/>
        <Parameter name="_expectedPos" type="Integer"/>
    </JadeMethod>
