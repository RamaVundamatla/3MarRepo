    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="carrierId" id="9fb43828-f1db-4b93-a819-508230ac4a1b">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="driverId" id="ad843020-84ec-4762-9387-ca200eb9cb53">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="gateName" id="4940643c-2e3d-4f67-a8fb-e4854df06e15">
        <length>31</length>
        <embedded/>
