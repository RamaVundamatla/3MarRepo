    <JadeMethod name="pwUTGetMethodCount" id="2efba5c6-63ba-4480-aeb0-9656a207b15d">
        <source>pwUTGetMethodCount(_user : String) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2024	navpw1	Initial creation

*/

vars
	indexOf 					: Integer;
	methodCount					: String;
	
begin
	indexOf := self.allMethodOwners.indexOf(_user);
	if indexOf &gt; 0 then
		methodCount := self.allOwnerMethodsCount[indexOf].String;
	endif;

	return methodCount;
	
end;</source>
        <access>protected</access>
        <Parameter name="_user" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pwUTGetUnitTestMethodDetails" id="2286dc6d-720c-4fc2-8f61-543b7944bab6">
        <source>pwUTGetUnitTestMethodDetails() protected;

/*

Purpose:		Populate the Unit Test Details Dict

Date			Who		Reason
09/07/2015		cnwmh5	Initial creation

*/

vars
	cls						: Class;
	meth						: Method;

	classes						: ClassColl;
	methodsDict					: MethodNDict;
	
	tokens						: StringArray512;
	
	userName					: String;
	linePos						: Integer;
	cnwPos						: Integer;
	line						: String;
	token						: String;
	scm : Schema;
	utDsl : Class;
	
begin

	// clear the dict
	self.unitTestDetailsDict.clear();
	
	// get the classes to check
	scm := rootSchema.getSchema("JMTUnitTest");
	utDsl := scm.getClass("UT_DSL");
	if utDsl = null then
		return;
	endif;
	
	create classes transient;
	classes.add(cls);
	cls.allLocalSubclasses(classes);
	
	create tokens transient;
		
	foreach cls in classes do
		methodsDict := cls.cnGetMethods();
		
		foreach meth in methodsDict where meth.sendMsg("isRunnableUnitTestMethod").Boolean do
			linePos := 1;
			meth.getSource.cnEcGetNextLine(linePos);
			while linePos &gt; 0 do
				line :=  meth.getSource.cnEcGetNextLine(linePos);
				if (line[1:9] = 'constants' and line.trimBlanks().length = 9) or 		
						(line[1:4] = "vars" and line.trimBlanks().length = 4) then
					break;
				endif;
				line.replaceChar(Tab, ' ');
				tokens.clear;
				line.getTokensForDelimiter(" ", tokens);
				userName := null;
				foreach token in tokens do
					if token.toUpper().cnContains("CNW") or token.toUpper().cnContains("JLG") or  token.toUpper().cnContains("NAV")  then
						cnwPos := token.toUpper.pos("CNW", 1);
						if cnwPos = 0 then
							cnwPos := token.toUpper.pos("JLG", 1);
						endif;
						
						if cnwPos = 0 then
							cnwPos := token.toUpper.pos("NAV", 1);
						endif;
						
						if cnwPos = 0 then
							continue;
						endif;
						userName := token[cnwPos:end];
						if token.toUpper().cnContains("CNW") or token.toUpper().cnContains("JLG") or token.toUpper().cnContains("NAV") then
							linePos := -1;
							break;
						endif;
					endif;
				endforeach;
			endwhile;
			
			if userName &lt;&gt; null then
				self.unitTestDetailsDict.putAtKey(userName.toLower(), meth.getSchemaType().name, meth.name, meth);
			endif;			
			
		endforeach;
	
	endforeach;

epilog

	delete classes;
	delete tokens;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="pwUTGetUserMethodCount" id="a0cc97f9-708b-4a26-b15d-fc7035738f8d">
        <updating/>
        <source>pwUTGetUserMethodCount() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2024	navpw1	Initial creation

*/

vars

	cls						: Class;
	meth						: Method;
	
	classes						: ClassColl;
	methodsDict					: MethodNDict;
	tokens						: StringArray512;
	
	found						: Boolean;
	linePos						: Integer;
	line						: String;
	token						: String;
	cnwPos						: Integer;
	userName					: String;
	indexOf						: Integer;
	scm : Schema;
	utDsl : Class;
	
begin
	// get UT_DSL class
	scm := rootSchema.getSchema("JMTUnitTest");
	utDsl := scm.getClass("UT_DSL");
	if utDsl = null then
		return;
	endif;
	
	// create classes
	create classes transient;
	classes.add(utDsl);
	utDsl.allLocalSubclasses(classes);
	
	create tokens transient;
	foreach cls in classes do
	
		methodsDict := cls.cnGetMethods();
		
		foreach meth in methodsDict where meth.sendMsg("isRunnableUnitTestMethod").Boolean do
		
			found := false;
			linePos := 1;
			meth.getSource.cnEcGetNextLine(linePos);
			while linePos &gt; 0 do
				line :=  meth.getSource.cnEcGetNextLine(linePos);
				if (line[1:9] = 'constants' and line.trimBlanks().length = 9) or 		
						(line[1:4] = "vars" and line.trimBlanks().length = 4) then
					break;
				endif;
				line.replaceChar(Tab, ' ');
				tokens.clear;
				line.getTokensForDelimiter(" ", tokens);
				foreach token in tokens do
					if token.toUpper().cnContains("CNW") or 
						token.toUpper().cnContains("JLG") or  
						token.toUpper().cnContains("NAV") then     //30.09.2024 navma1
						cnwPos := token.toUpper.pos("CNW", 1);
						
						if cnwPos = 0 then
							cnwPos := token.toUpper.pos("JLG", 1);
						endif;
						
						if cnwPos = 0 then
							cnwPos := token.toUpper.pos("NAV", 1);  //30.09.2024 navma1
						endif;
						
						if cnwPos = 0 then
							continue;
						endif;
						userName := token[cnwPos:end];
						if not self.allMethodOwners.includes(userName.toUpper) then
							self.allMethodOwners.add(userName.toUpper);
							self.allOwnerMethodsCount.add(1);
							linePos := -1;
							break;
						else
							indexOf := self.allMethodOwners.indexOf(userName.toUpper);
							if indexOf &lt;&gt; 0 then
								self.allOwnerMethodsCount[indexOf] := self.allOwnerMethodsCount[indexOf] + 1;
							endif;
						endif;
						if token.toUpper().cnContains("CNW") or 
							token.toUpper().cnContains("JLG") or 
							token.toUpper().cnContains("NAV1") then  //30.09.2024 navma1
							linePos := -1;
							break;
						endif;
					endif;
				endforeach;
			endwhile;
			
		endforeach;
		
	endforeach;

epilog
	delete tokens;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="pwUTGetUserMethodCounts" id="e083b4d9-5314-4b24-913c-4f20ced124cb">
        <updating/>
        <source>pwUTGetUserMethodCounts() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2024	navpw1	Initial creation

*/

vars
	utUserNameMethodCountArr	: StringArray;
	fileSave					: CMDFileSave;
	exportFile					: File;
	exportPath					: String;
	str							: String;
	
begin
	create utUserNameMethodCountArr transient;
	create self.unitTestDetailsDict transient;
	
	self.unitTestDetailsDict.setMembership(Method);
	self.unitTestDetailsDict.addExternalKey(String, 50, false, false);					// Current Unit Test Owner
	self.unitTestDetailsDict.addExternalKey(String, 100, false, false);					// Unit Test Class Name
	self.unitTestDetailsDict.addExternalKey(String, 100, false, false);					// Unit Test Method Name
	self.unitTestDetailsDict.endKeys(false);		
	
	self.pwUTGetUnitTestMethodDetails();
	
	self.pwUTGetUserMethodCount();
	
	self.pwUTPopulateData(utUserNameMethodCountArr);
	
	//Write to csv
	create fileSave transient;
	fileSave.dialogTitle := "Unit Test Methods Assigned to Users";
	fileSave.resetCurrentPath := true;
	exportPath := "C:\temp\";
	fileSave.initDir := exportPath;
	fileSave.fileName := "utUserMethodCount.csv";
	
	if fileSave.open = 0 then
		create exportFile transient;
		
		if fileSave.fileName.toUpper().pos(".CSV",1) = 0  // 20 March 2023	navmk20	Bug 56954, No CSV
		and fileSave.fileName.pos(".",1) = 0 then // 20 March 2023	navmk20	Bug 56954, no suffix
			exportFile.fileName := fileSave.fileName &amp; ".csv"; // 20 March 2023	navmk20	Bug 56954
		else // 20 March 2023	navmk20	Bug 56954
			exportFile.fileName := fileSave.fileName;
		endif;
		exportFile.mode := File.Mode_Output;

		if (not exportFile.tryOpen) then
			app.raiseCMException1(FileUnavailable, exportFile.fileName, null, null);	
		endif;
	endif;
	
	if exportFile = null then
		return;
	endif;
	
	foreach str in utUserNameMethodCountArr discreteLock do
		exportFile.writeLine(str);
	endforeach;
	
	exportFile.close();
	
epilog
	delete utUserNameMethodCountArr;
	delete exportFile;
	delete fileSave;
	delete self.unitTestDetailsDict;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwUTPopulateData" id="a5684b80-b20b-49ea-97d9-5cd5b5338311">
        <updating/>
        <source>pwUTPopulateData(_utUserNameMethodCountArr : StringArray input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2024	navpw1	Initial creation

*/

vars
	user : CM_User;
	rowNum		: Integer;
	userName : String;
	count : Integer;
	iter : Iterator;
	obj : Object;
	currentUser,
	className,
	methName : String;
	
begin
	_utUserNameMethodCountArr.add("UserName" &amp; Comma &amp; "Count");
	foreach user in app.myRoot.allUsers do
		//rowNum := self.tblUserData.addItem(null);
		//self.setupNewRow(rowNum);
		
		//self.tblUserData.accessCell(rowNum, 1).text := userEmail.isAdmin.Integer.String &amp; Tab &amp; 
		//userEmail.user &amp; Tab &amp; 
		//self.getMethodCount(userEmail.user) &amp; Tab &amp; 
		
		userName := user.code;
		count := self.pwUTGetMethodCount(user.code).Integer;
		
		if count = null then
			continue;
		endif;
		
		_utUserNameMethodCountArr.add(userName &amp; Comma &amp; count.String);
		
		delete iter;
		iter := self.unitTestDetailsDict.createIterator;
		
		while iter.next(obj) do
			self.unitTestDetailsDict.getIteratorKeys(currentUser, className, methName, iter);
			if currentUser.toUpper() &lt;&gt; user.code.toUpper() then
				continue;
			endif;
			
			_utUserNameMethodCountArr.add("" &amp; Comma &amp; "" &amp; Comma &amp; className &amp; "::" &amp; methName);
			
		endwhile;
		
	endforeach;
	
epilog
	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_utUserNameMethodCountArr" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pwUTPopulateMethodOwnerArrays" id="2493f24a-6a04-4295-b220-19be5180e3d2">
        <updating/>
        <source>pwUTPopulateMethodOwnerArrays(_lookFor : String; _tokens : StringArray512 input) : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2024	navpw1	Initial creation

*/

vars

	token					: String;
	lookForPos				: Integer;
	linePos					: Integer;
	userName				: String;
	indexOf					: Integer;
	loopBrokenOutOf			: Boolean;

begin

	loopBrokenOutOf := false;
	//write '_lookFor: ' &amp; _lookFor;

	foreach token in _tokens do
		if token.toUpper().cnContains(_lookFor) then
			lookForPos := token.toUpper.pos(_lookFor, 1);
			if lookForPos = 0 then
				continue;
			endif;
			userName := token[lookForPos:end];
			if not self.allMethodOwners.includes(userName.toUpper) then
				self.allMethodOwners.add(userName.toUpper);
				self.allOwnerMethodsCount.add(1);
				linePos := -1;
				loopBrokenOutOf := true;
				break;
			else
				indexOf := self.allMethodOwners.indexOf(userName.toUpper);
				if indexOf &lt;&gt; 0 then
					self.allOwnerMethodsCount[indexOf] := self.allOwnerMethodsCount[indexOf] + 1;
				endif;
			endif;
			if token.toUpper().cnContains(_lookFor) then
				linePos := -1;
				loopBrokenOutOf := true;
				break;
			endif;
		endif;
	endforeach;
	
	return loopBrokenOutOf;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lookFor" type="String"/>
        <Parameter name="_tokens" type="StringArray512" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pwUnitTestClassCounts" id="5eedfe1d-6ac5-4afe-a6fd-a7a79342d7d5">
        <source>pwUnitTestClassCounts();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2024	navpw1	Initial creation

*/

constants
	Capitals				: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
	
vars
	class : Class;
	classCol : ClassColl;
	subClassCol : ClassColl;
	meth : Method;
	methNDict : MethodNDict;
	classNames : StringArray;
	methodCounts : IntegerArray;
	currentRunnableMethodCount : Integer;
	countMethods,
	indexOf: Integer;
	classStr : String;
	cnt : Integer;
	scm : Schema;
	cls : Class;
	
begin
	scm := rootSchema.getSchema("JMTUnitTest");
	cls := scm.getClass("UT_DSL");
	
	create classNames transient;
	create methodCounts transient;
	create methNDict transient;
	create classCol transient;
	cls.getSubclasses(classCol);
	
	foreach class in classCol do
		methNDict.clear();
		class.getMethods(methNDict);
		currentRunnableMethodCount := 0;
		foreach meth in methNDict do
			if self.isRunnableUnitTestMethod(meth) then
				currentRunnableMethodCount += 1;
			endif;
		endforeach;
		
		//currentCountMethods := methNDict.size;
		indexOf := classNames.indexOf(class.name);
		if indexOf &gt; 0 then
			countMethods := methodCounts[indexOf].Integer;
			countMethods += currentRunnableMethodCount;
			methodCounts[indexOf] := countMethods;
		else
			classNames.add(class.name);
			methodCounts.add(currentRunnableMethodCount);
		endif;
		
		if class.hasSubclasses then
			self.pwUnitTestsGetSubClassesCnt(class, classNames, methodCounts);
		endif;
		
	endforeach;
	
	foreach classStr in classNames do
		indexOf := classNames.indexOf(classStr);
		write classStr &amp; Comma &amp; methodCounts[indexOf].String;
	endforeach;
	
	currentRunnableMethodCount := 0;
	foreach cnt in methodCounts do
		currentRunnableMethodCount += cnt;
	endforeach;
	
	write "Total Runnable: " &amp; currentRunnableMethodCount.String;
	write "Ignored: " &amp; currentRunnableMethodCount.String;
	write "Total (Overall): " &amp; currentRunnableMethodCount.String;
	
epilog
	delete classCol;
	delete classNames;
	delete methodCounts;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwUnitTestClassCountsObj" id="dff2a9c3-548b-4721-8f73-40a0028e1e64">
        <source>pwUnitTestClassCountsObj();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2024	navpw1	Initial creation

*/

constants
	Capitals				: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
	
vars
	class : Class;
	classCol : ClassColl;
	subClassCol : ClassColl;
	meth : Method;
	methNDict : MethodNDict;
	classNames : StringArray;
	methodCounts : IntegerArray;
	runnableMethodCount,
	ignoredMethodCount,
	utilityMethodCount,
	verificationMethodCount : Integer;
	countMethods,
	indexOf: Integer;
	classStr : String;
	cnt : Integer;
	scm : Schema;
	cls : Class;
	unitTestDetail : CMIF_UnitTestDetail;
	unitTestClassTotal : CMIF_UnitTestClassTotal;
	objSet		: ObjectSet;
	dict : DynaDictionary;
	totalRunnableCnt,
	totalIgnoredCnt,
	totalUtilityCnt,
	totalVerificationCnt : Integer;
	
begin
	scm := rootSchema.getSchema("JMTUnitTest");
	cls := scm.getClass("UT_DSL");
	
	create classNames transient;
	create methodCounts transient;
	create methNDict transient;
	create classCol transient;
	cls.getSubclasses(classCol);
	
	create dict transient;
	dict.setMembership(CMIF_UnitTestClassTotal);
	dict.addMemberKey(CMIF_UnitTestClassTotal::className.name, false, false);
	dict.endKeys(false);		
	
	foreach class in classCol do
		create unitTestClassTotal transient;
		unitTestClassTotal.className := class.name;
		dict.add(unitTestClassTotal);
		
		methNDict.clear();
		class.getMethods(methNDict);
		
		foreach meth in methNDict do
			create unitTestDetail transient;
			unitTestDetail.className := class.name;
			unitTestDetail.methodName := meth.name;
			unitTestDetail.isRunnable := self.isRunnableUnitTestMethod(meth);
			unitTestDetail.isIgnored := self.isIgnoredUnitTestMethod(meth);
			unitTestDetail.isUtility := self.isUtilityUnitTestMethod(meth);
			unitTestDetail.isVerification := self.isVerificationUnitTestMethod(meth);
			unitTestClassTotal.allMethods.add(unitTestDetail);
		endforeach;
		
		if class.hasSubclasses then
			self.pwUnitTestsGetSubClassesCntObj(dict, class);
		endif;
		
	endforeach;
	
	foreach unitTestClassTotal in dict as CMIF_UnitTestClassTotal do
		runnableMethodCount := 0;
		ignoredMethodCount := 0;
		utilityMethodCount := 0;
		verificationMethodCount := 0;
		
		foreach unitTestDetail in unitTestClassTotal.allMethods as CMIF_UnitTestDetail do
			if unitTestDetail.isRunnable then
				runnableMethodCount += 1;
			endif;
			
			if unitTestDetail.isIgnored then
				ignoredMethodCount += 1;
			endif;
			
			if unitTestDetail.isUtility then
				utilityMethodCount += 1;
			endif;
			
			if unitTestDetail.isVerification then
				verificationMethodCount += 1;
			endif;
			
		endforeach;
		
		unitTestClassTotal.totalIgnored := ignoredMethodCount;
		unitTestClassTotal.totalRunnable := runnableMethodCount;
		unitTestClassTotal.totalUtility := utilityMethodCount;
		unitTestClassTotal.totalVerification := verificationMethodCount;
	endforeach;
	
	write "className" &amp; Comma &amp; "totalRunnable" &amp; Comma &amp; "totalIgnored" &amp; Comma &amp; "totalUtility" &amp; Comma &amp; "totalVerification";
	foreach unitTestClassTotal in dict as CMIF_UnitTestClassTotal do
		write unitTestClassTotal.className &amp; Comma &amp; unitTestClassTotal.totalRunnable.String &amp; Comma &amp; unitTestClassTotal.totalIgnored.String &amp; Comma &amp; unitTestClassTotal.totalUtility.String &amp; Comma &amp; unitTestClassTotal.totalVerification.String;
		totalRunnableCnt += unitTestClassTotal.totalRunnable;
		totalIgnoredCnt += unitTestClassTotal.totalIgnored;
		totalUtilityCnt += unitTestClassTotal.totalUtility;
		totalVerificationCnt += unitTestClassTotal.totalVerification;
		
	endforeach;
	
	
	write "Total Runnable: " &amp; totalRunnableCnt.String;
	write "Total Ignored: " &amp; totalIgnoredCnt.String;
	write "Total (Overall): " &amp; (totalRunnableCnt + totalIgnoredCnt).String;
	write "Total Utility: " &amp; totalUtilityCnt.String;
	write "Total Verification: " &amp; totalVerificationCnt.String;
	
epilog
	delete classCol;
	delete classNames;
	delete methodCounts;
	if dict.isNotEmpty then
		dict.purge;
	endif;
	delete dict;
	
end;</source>
    </JadeMethod>
