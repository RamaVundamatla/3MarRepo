    <JadeMethod name="validateClearedAmount" id="9ea46ef6-91cd-4e6b-a19c-da18f4d379f1">
        <source>validateClearedAmount() : Boolean;
/*
Purpose:			

Date		Who		Reason
18 August 2023	navab1	CR 59615 TASK 59620
*/

vars
	prevCustDocDetail : CM_CustomDocumentDetail;
	ti : CM_TrackedItem;
	ct : CM_CargoType;
begin
	prevCustDocDetail := self.getPrevCustDocDetail();
	
	if prevCustDocDetail &lt;&gt; null then
		ti := self.myTrackedItem;
		ct := ti.myCargoType;
		
		if ct = null 
		or ct.isBreakBulk then
			return self.clearedQuantity = prevCustDocDetail.clearedQuantity;
		elseif ct.isBulkByVolume then
			return self.clearedVolume = prevCustDocDetail.clearedVolume;
		
		elseif ct.isBulkByWeight then
			return self.clearedWeight = prevCustDocDetail.clearedWeight;
		
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="87375090-3efa-4669-9259-0d3efec51550">
        <source>validateForCreate();
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
vars

begin

	if self.myTrackedItem = null then
		app.raiseCMException(Custom_docume_must_have_cargo,null,null);
	endif;

	// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
	if self.myTrackedItem.myCountryOfOrigin = null 
	and self.included then// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
// ### TFS CR 59942 TASK 59943 23AUG2023 NAVAB1		app.setContinueCMExceptions(true);// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
// ### TFS CR 59942 TASK 59943 23AUG2023 NAVAB1		app.raiseCMWarning1(Item_does_not_have_count_origi,self.myTrackedItem.id,null,null,null);
	endif;
	
	if self.myParentCustomDocumentDetail = null// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
	and self.myParentCustomDocument = null then
		app.raiseCMException(Custom_docume_must_have_header,null,null);
	endif;
	
	self.validateForUpdate();
epilog

end;</source>
    </JadeMethod>
