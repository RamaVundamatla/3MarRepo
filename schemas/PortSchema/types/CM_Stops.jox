        <updating/>
        <source>setForCreate(
	_theTI			: CM_TrackedItem input;
	_aStop			: Integer;
	_stopTable		: CM_StopsTable;
	_remarks		: String;
	_preAuthorised	: Boolean;
	_expiryDate		: Date;		// cnwrl1 19/01/2010 PAR 21889
	_noCharge		: Boolean;
	_passport		: CM_Passport input ) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19/01/2010	cnwrl1		PAR 21889 - to allow the clearance expiry date to be set
// 14/03/2012	cnwjre1		Par 28930 - add _remarks parameter for Cargo Stops Request updates to be passed down to transaction create
// ---------------------------------------------------------------------------

vars
	now				: TimeStamp;
	txnParams		: CMIF_TITransactionController;
	aTITrans		: CM_TITransaction;
	theTI			: CM_TrackedItem;
	
begin
	if _stopTable = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_stopTable', null, null);
		return;
	endif;

	theTI := _theTI;
	if theTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'theTI', null, null);
		return;
	endif;
	
	now := app.serverTimestampAtTrxStart;
	self.id := _aStop;
	
	if (not app.myRoot.allAvailableStopsTables.includes(_stopTable)) then
		app.raiseCMException1(NotAvailableForEntry, _stopTable.heading.display, null, null);
		return;
	endif;
	
	if self.setMyTrackedItem(theTI) then
		self.userId			:= _passport.userCode;
		self.dateTime		:= now;
		self.myStopsTable	:= _stopTable;
		self.setClearanceExpiryDate( _expiryDate );			// cnwrl1 19/01/2010 PAR 21889
		
		// RECORD This event
		create txnParams transient;
		txnParams.type := TRANS_TYPE_STOPSET;
		txnParams.myTrackedItem := theTI;
		txnParams.userId := _passport.userCode;
		txnParams.myStop := self;
		txnParams.systemGenerated := _preAuthorised;
		txnParams.remarks := _remarks;		// 28930 Mar 2012
		txnParams.noCharge:=_noCharge; 	//epr par 7/3/2014 CCMS 1366 if its for a break/bulk multi cargo only charge on the one its set for not its dups
		aTITrans := theTI.createTransaction(txnParams, _passport);	
	else
		delete self;
	endif;

epilog
	delete txnParams;
	
end;
</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_aStop" type="Integer"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_preAuthorised" type="Boolean"/>
        <Parameter name="_expiryDate" type="Date"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateBOL" id="3f967a7e-d932-45ad-aab8-91f2ecdfa753">
        <updating/>
        <source>setForCreateBOL(_bol : CM_BOL input; _aStop : Integer; _stopTable : CM_StopsTable; _isManual : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 Dec 2022 navma1		Defect 55852: MTN - 1090 exception while loading a Ship Manifest and BOL via EDI
// ---------------------------------------------------------------------------

vars
	now		  : TimeStamp;
	txnParams : CMIF_TITransactionController;
	trans	  : CM_BOLTransaction;
begin

	self.raiseExceptionIfTransient(method);

	if _stopTable = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_stopTable', null, null);
		return;
	endif;

	if _bol = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_bolIn', null, null);
		return;
	endif;
	
	now 	:= app.serverTimestampAtTrxStart;
	self.id := _aStop;

	if (not app.myRoot.allAvailableStopsTables.includes(_stopTable)) then
		app.raiseCMException1(NotAvailableForEntry, _stopTable.heading, null, null);
		return;
	endif;
	
	if self.setMyBOL(_bol) then
		self.userId 	  := _passport.userCode;
		self.dateTime	  := now;
		self.myStopsTable := _stopTable;
		
		create txnParams transient;
		txnParams.type     := TRANS_TYPE_BOL_STOP_ADD;
		txnParams.userId   := _passport.userCode;
		txnParams.myStop   := self;
		txnParams.isManual := _isManual;
		
		trans := _bol.createTransaction(txnParams, _passport).CM_BOLTransaction;
		
		//jlier1 TFS 55788 12/12/22
		if trans &lt;&gt; null then
			trans.createCharge();	//06 Nov 2019	NDL	TFS 47100
		endif;
	else
		delete self;
	endif;
	
epilog
	delete txnParams;
end;</source>
        <Parameter name="_bol" type="CM_BOL" usage="input"/>
        <Parameter name="_aStop" type="Integer"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <Parameter name="_isManual" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateCustDoc" id="e95a2473-1d11-4e26-b839-6b4ecf2c9589">
        <updating/>
        <source>setForCreateCustDoc(_proxyStop : SelfType) updating;
/*
Purpose:			

Date		Who		Reason
01 September 2023	navab1	CR 59942 TASK 59943 
*/

vars

	expiryDate : Date;
	custDoc : CM_CustomDocument;
	custDocDetail : CM_CustomDocumentDetail;
begin

	self.myCustomDocumentDetlAppliedBy := _proxyStop.myCustomDocumentDetlAppliedBy;
	self.myCustomDocumentDetlClearedBy := _proxyStop.myCustomDocumentDetlClearedBy;
	
	custDocDetail := self.myCustomDocumentDetlAppliedBy;
	if custDocDetail&lt;&gt; null then
		custDoc := custDocDetail.getCustomDocumentHeader();
		if custDoc &lt;&gt; null then
			self.custDocCode := custDoc.code;
			self.custDocSequence := custDoc.sequence.String;
			if  custDoc.myCustomLicense &lt;&gt; null then
				self.custDocLicense := custDoc.myCustomLicense.code;
			endif;
			self.custDocType := custDoc.myCustomDocumentType.code &amp; " " &amp; CM_CustomDocumentType@getDirectStrFromInt(custDoc.direction);

			self.myTransaction.setCustDocFromTI(self.myTrackedItem); // ### TFS CR 59942 TASK 59943 12SEP2023 NAVAB1

		endif;
	endif;
	
	if self.myCustomDocumentDetlClearedBy &lt;&gt; null then
		expiryDate.setDate(1,1,3000);
		self.clearanceExpiryDate := expiryDate;
	endif;
	
epilog

end;</source>
        <Parameter name="_proxyStop" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateCustDoc" id="fee49dd5-32f7-43e8-852e-24b234005ddc">
        <updating/>
        <source>setForUpdateCustDoc(_proxyStop : SelfType) updating;
/*
Purpose:			

Date		Who		Reason
01 September 2023	navab1	CR 59942 TASK 59943 
*/

vars

	expiryDate : Date;
begin

	self.myCustomDocumentDetlAppliedBy := _proxyStop.myCustomDocumentDetlAppliedBy;
	self.myCustomDocumentDetlClearedBy := _proxyStop.myCustomDocumentDetlClearedBy;
	
	self.custDocCode := _proxyStop.custDocCode;
	self.custDocLicense := _proxyStop.custDocLicense;
	self.custDocSequence := _proxyStop.custDocSequence;
	self.custDocType := _proxyStop.custDocType;
epilog

end;</source>
        <Parameter name="_proxyStop" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMyBOL" id="36af2495-e69d-473c-be2c-cd04904a4f05">
        <updating/>
        <source>setMyBOL(_bol : CM_BOL input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aOK : Boolean;
	tmpStopTable	: CM_StopsTable;
begin

	if _bol = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'theTI', null, null);
		return false;
	endif;

	tmpStopTable := self.myStopsTable;
	if tmpStopTable = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'self.myStopsTable', null, null);
		return false;
	endif;
	
	if (not tmpStopTable.isValidForCargoType(_bol.bolType)) then		
		app.raiseCMException3(StopNotValidForCargoType, tmpStopTable.heading, _bol.bolTypeDesc, _bol.number.String, null, null);
		return false;
	endif;

	if (not _bol.allStops.includesKey(self.id)) then
		self.myBOL := _bol;
		aOK := true;
	else
		// BOL already has this stop - don't bother with a warning/error
	endif;
	
	return aOK;
end;</source>
        <Parameter name="_bol" type="CM_BOL" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyStopClearTxn" id="2ca6a115-19cf-4f0c-83af-cfba9c7473aa">
