    <JadeMethod name="setupThumbnailDetails" id="6be2d6a7-f72d-47df-a5d8-e25d99292f67">
        <updating/>
        <source>setupThumbnailDetails()updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_PortTbl);
//	theForm.zAddColumn('Port Id', 'code', Table.InputType_None, 25);
//	theForm.zAddColumn('Description', 'description', Table.InputType_None, 60);
//	theForm.zAddColumn('Color','color',Table.InputType_None,15);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_PortMaint);
	theForm.shtTblInput1.visible := true;

	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);			
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="7554273a-1902-41eb-847b-383089d3a998">
        <updating/>
        <source>showThumbnail(pPort : CM_Port) updating;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/6/2006	RBarr		CM_Port::codeDisplay attribute obsolete, portCode renamed to portCode
// ---------------------------------------------------------------------------

vars

	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pPort.code);
	theForm.tblInput1.setValueByName(ETRow_PortCode, pPort.portCode);
	theForm.tblInput1.setValueByName(ETRow_Description,	pPort.description);
	theForm.tblInput1.setValueByName(ETRow_Colour, pPort.colour);

	if pPort.myCountry &lt;&gt; null then
		theForm.cmbCountry.setObject(pPort.myCountry);
		theForm.tblInput1.setValueByName(ETRow_Country, theForm.cmbCountry.text);
	else
		theForm.cmbCountry.setObject(null);
	endif;

	if pPort.myPortGroup &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_Group, pPort.myPortGroup.code);
		theForm.cmbPortGroup.setObject(pPort.myPortGroup);
	else
		theForm.cmbPortGroup.setObject(null);
	endif;

	theForm.tblInput1.setValueByName(ETRow_CcodePrint,	pPort.ccodePrint);
	theForm.tblInput1.setValueByName(ETRow_UsLocationCode,	pPort.usLocationID); //cnwrd1 ccms 2317
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pPort.isNotAvailableForEntry);
	theForm.tblInput1.setValueByName(ETRow_IsPort, pPort.bIsPort);
	//par 18536 cnwjo3
	//fix removed
	/*if pPort.bIsPort = true then
		theForm.tblInput1.showRowByName(ETRow_Group,false);
	else
		theForm.tblInput1.setValueByName(ETRow_Group,"");
		theForm.tblInput1.hideRowByName(ETRow_Group,false);		
	endif;*/
	theForm.tblInput1.setValueByName(ETRow_IsRail, pPort.bIsRail);
	theForm.tblInput1.setValueByName(ETRow_IsRoad, pPort.bIsRoad);
	theForm.tblInput1.setValueByName(ETRow_IsAirport, pPort.bIsAirport);
	theForm.tblInput1.setValueByName(ETRow_IsMultiModal, pPort.bIsMultiModal);
	theForm.tblInput1.setValueByName(ETRow_IsFixedTransport, pPort.bIsFixedTransport);
	theForm.tblInput1.setValueByName(ETRow_IsPostalExchange, pPort.bIsPostalExchange);
	theForm.tblInput1.setValueByName(ETRow_IsBorderCrossing, pPort.bIsBorderCrossing);
//	tblInput1.setValueByName('colour',	pPort.colour);
	
end;</source>
        <Parameter name="pPort" type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="71db74e3-15fa-4f5f-b8f2-e3919562968c">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//--------------------------------------------------
// Created:	25 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	port:CM_Port;
	cell : JadeTableCell;
begin
//	return inheritMethod(table, theSheet, pObj, theRow, bcontinue);
	port := _obj.CM_Port;
	if(_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then	
			cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;
			cell.backColor := port.colour;	
		endif;
	endif;
	
end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
