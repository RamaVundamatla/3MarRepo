    <JadeMethod name="doResize" id="e273b89d-0ee8-40b3-98df-b713944b5369">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	15 August 2003 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/901/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
vars

	x, y : Real;

begin

//	inheritMethod();
	if self.frmToolbar.visible then
		self.frmToolbar.repositionAfterResize;
	endif;
	y := ((self.clientHeight + self.frmToolbar.height - self.frmTidalModel.height) / 2).max(self.frmToolbar.height);
	x := (self.clientWidth - self.frmTidalModel.width) / 2;
	self.frmTidalModel.move(x, y, self.frmTidalModel.width, self.frmTidalModel.height);	
//	self.picSummary.top := self.frmTidalModel.height- picSummary.height;
	self.handleMenusForModalDisplay();						// PAR #33337
end;</source>
    </JadeMethod>
    <JadeMethod name="drawGraphs" id="76a84942-8cbe-475b-af6b-f3c72693d4e9">
        <updating/>
        <source>drawGraphs(_moveTimeStandardTime : TimeStamp)updating;

vars
	selectedRegion		: HMS_HarbourRegion;
	daylightAdjust 		: Time;
	i					: Integer;
	tidalModel			: HMS_TidalModelDefinition;
	
begin
	selectedRegion := cmbRegion.listObject.HMS_HarbourRegion;
	
	self.depthArray.clear();
	self.flowRateArray.clear();
	self.hiLoArray.clear();
	self.tideTypeArray.clear();
	self.daylightArray.clear();
	self.timeArray.clear();
	self.tblDepth.clearGraphics();
	self.tblFlowRate.clearGraphics();
	
	if selectedRegion = null then
		return;
	endif;
	
	if self.txtDraft.text = null then
	    //self.txtDraft.text := selectedRegion.getChartDatum().String;		// cnwdad1 10/07/2009 - PAR #20270.
		self.txtDraft.text := selectedRegion.getChartDatum().asStringJMT();	// cnwdad1 10/07/2009 - PAR #20270.
	endif;
	
	self.chartDatum := null;
	app.myHMSRvTide.populateTimestampArray(_moveTimeStandardTime, self.timeArray);
	
	//rvTide.getGraphValues(selectedRegion,_moveTimeStandardTime, self.flowRateArray, self.depthArray, self.hiLoArray, self.tideTypeArray, self.daylightArray, self.timeArray);
	if selectedRegion.myCurrentCheckpoint &lt;&gt; null then
		tidalModel := selectedRegion.myCurrentCheckpoint.myTidalModel;
		
		if tidalModel &lt;&gt; null then
			app.myHMSRvTide.getFloodCurrent(tidalModel, self.timeArray, self.flowRateArray);
			if tidalModel.dataSource = HMS_TidalDataSourceGetTideFile and //cnwrs1 June 2009 Par 19678
			   (tidalModel.lowestValue &lt;&gt; 0 or 
			    tidalModel.highestValue &lt;&gt; 0) then
				self.plotGraphCurrentGraduated(tidalModel, self.flowRateArray, Black, Tidal_Multiplier_Current);
			else
				self.plotGraphCurrent(tidalModel, self.flowRateArray, Black, Tidal_Multiplier_Current);
			endif;
		endif;
	endif;
	
	if selectedRegion.myHeightCheckpoint &lt;&gt; null then
		tidalModel := selectedRegion.myHeightCheckpoint.myTidalModel;
		
		if tidalModel &lt;&gt; null then
			self.chartDatum := tidalModel.getChartDatum();
			app.myHMSRvTide.getTideGaugeLevel(tidalModel, self.timeArray, self.depthArray);
			self.plotGraphHeight(tidalModel, self.depthArray, Black, Tidal_Multiplier_Depth);
		endif;
	endif;
	
	if selectedRegion.myHiLoCheckpoint &lt;&gt; null then
		tidalModel := selectedRegion.myHiLoCheckpoint.myTidalModel;
		
		if tidalModel &lt;&gt; null then
			app.myHMSRvTide.getHiLoData(tidalModel, self.timeArray, self.hiLoArray, self.tideTypeArray);
// taken out Lorcan 
//			self.plotGraphHiLo(tidalModel, self.hiLoArray,self.tideTypeArray, Black, Tidal_Multiplier_Current);
		endif;
	endif;
	
	/*  Not sure whay this is here but time gap check points have no relation to tidal data 
		Perhaps this was once a day light check point - who knows
	
		if selectedRegion.myTimeGapCheckpoint &lt;&gt; null then
		tidalModel := selectedRegion.myTimeGapCheckpoint.myTidalModel;
		if tidalModel &lt;&gt; null then
			app.myHMSRvTide.getDaylightData(tidalModel, self.timeArray, self.daylightArray);
			self.plotGraphDaylight(tidalModel, self.daylightArray, Black, Tidal_Multiplier_Current);
		endif;
	endif;*/
	
	if self.moveTimeIsDST and not self.systemTimeIsDST then		//Add one hour to get NZDT
		daylightAdjust.setTime(1,0,0,0);
		
		foreach i in 1 to self.timeArray.size do
			self.timeArray[i] := self.timeArray[i] + daylightAdjust;
		endforeach;
	endif;

	if not self.moveTimeIsDST and self.systemTimeIsDST then		//Subtract one hour to get NZST
		daylightAdjust.setTime(1,0,0,0);
		
		foreach i in 1 to self.timeArray.size do
			self.timeArray[i] := self.timeArray[i] - daylightAdjust;
		endforeach;
	endif;
end;</source>
        <Parameter name="_moveTimeStandardTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="drawMe" id="1515deab-8292-4f28-93bd-9bed5fe84958">
        <updating/>
        <source>drawMe() updating, protected;

vars
	now,
 	moveTime,
 	moveTimeStandardTime,
 	tTTATime,
 	chkptTime			: TimeStamp;
 	clocksChangeForMove,
 	clocksChangeToday  				: Boolean;
	
begin
	moveTime.setDate(self.dateMask.getDate());
	moveTime.setTime(self.txtTime.getTime());
	
	now	:=	app.actualTimeServer();

	self.moveTimeIsDST	:=	self.myTerminal.checkIfDaylightSaving(moveTime, clocksChangeForMove);
	self.systemTimeIsDST	:=	self.myTerminal.checkIfDaylightSaving(now, clocksChangeToday);

	if self.moveTimeIsDST then
		lblZoneTime.caption		:=	"All Times are Daylight Time";
		moveTimeStandardTime	:=	moveTime.changeByXXMinutes(-60);		//Convert move time from NZDT to NZST
	else
		lblZoneTime.caption		:=	"All Times are Standard Time";
		moveTimeStandardTime	:=	moveTime;
	endif;

	lblTZWarning.visible	:=	clocksChangeForMove;

	self.drawGraphs(moveTimeStandardTime);

	// get the values for the window of opportunity graph
	self.getEntranceWindowValues(moveTimeStandardTime);

	chkptTime := moveTime.changeByXXMinutes(self.baseTimeToChkpt);
	tTTATime := chkptTime.changeByXXMinutes(self.chkptToTTTATime);

	self.drawTime();
	//Plot the entrance window with the time we pass through the
	//checkpoint forming the main part of the red line
	self.plotEntranceWindow(tTTATime, chkptTime);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawTime" id="17b4be75-81e4-4062-aac5-cd374938859a">
        <updating/>
        <source>drawTime() updating;


vars
	t1,t2,t3, now : Time;
	s1,s2,s3 : String;
	daylightAdjust : Integer;

begin
	//daylightAdjust := 60 * 60000;

	now := app.actualTimeServer().time();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	self.lblTime1.clearGraphics();
	self.lblTime2.clearGraphics();
	self.lblTime3.clearGraphics();
	self.lblTime4.clearGraphics();

	/*Old code
	t2 := timestampCenter.time;
	t1 := t2 - (12 * 60 * 60000);
	t3 := t2 + (12 * 60 * 60000);*/

	//AA 23/8/01: Use time stamps from the time array so that they match the
	//plotted data
	if self.timeArray.isEmpty() then
		t2 := now;
		t1 := now;
		t3 := now;
	else
		t2 := self.timeArray[(self.timeArray.size / 2).Integer].Time;
		t1 := self.timeArray.first.Time;
		t3 := self.timeArray.last.Time;
	endif;

	s1 := t1.format('HH:mm');
	s2 := t2.format('HH:mm');
	s3 := t3.format('HH:mm');

	self.lblTime1.drawTextAt(s1, self.tblDepth.left, 0, Black);
	self.lblTime1.drawTextAt(s2, self.tblDepth.left + self.tblDepth.width / 2, 0, Black);
	self.lblTime1.drawTextAt(s3, self.tblDepth.left + self.tblDepth.width, 0, Black);

	self.lblTime2.drawTextAt(s1, self.tblDepth.left, 0, Black);
	self.lblTime2.drawTextAt(s2, self.tblDepth.left + self.tblDepth.width / 2, 0, Black);
	self.lblTime2.drawTextAt(s3, self.tblDepth.left + self.tblDepth.width, 0, Black);

	self.lblTime3.drawTextAt(s1, self.tblDepth.left, 0, Black);
	self.lblTime3.drawTextAt(s2, self.tblDepth.left + self.tblDepth.width / 2, 0, Black);
	self.lblTime3.drawTextAt(s3, self.tblDepth.left + self.tblDepth.width, 0, Black);
end;</source>
    </JadeMethod>
    <JadeMethod name="getEntranceWindowValues" id="42057963-f4d8-4609-b620-cacaceca2cf7">
        <updating/>
        <source>getEntranceWindowValues(moveTime : TimeStamp)updating, protected;
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------
// 09/10/2013	cnwdap1		PAR #32656 Correct daylight savings adjustments - since PAR 28250, self.windowArray
//							can have null entries in the first and last positions, so don't do adjustments to these
// 30/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements - filter window array by high tides only if harbour admin option is set
// 07/10/2014	cnwdap1		PAR #35022 Avoid 1090 error if no tidal regions have been defined
//03 Oct 2017	cnwma1  	TFS #7257 JMT - Refactoring - Commodity Planning
vars
	selectedRegion:			HMS_HarbourRegion;
	tideClass:				HMS_TidalClass;
 	currentLimitPosve:		Real;
 	currentLimitNegve:		Real;
 	draftLimit:				Real;
 	enterLeaveStatus:		String;
 	tmpSize,
 	int,
    i : Integer;
    daylightAdjust : Time;
    tmpBerth : HMS_Berth;
//    tmpHarbour : HMS_Harbour;
	newWindowArray:			TimeStampArray;					// PAR #33337
	checkPoint:				HMS_CheckPoint;					// PAR #33337
	maximumDraft:			Decimal [3,1];					// PAR #33337
	
begin
	self.windowArray.clear();
	
	if not global.isValidObject(self.myWorkingMovement) then
		self.myWorkingMovement := null;
	endif;
	
	// Get first region with checkpoints
	if self.myWorkingMovement &lt;&gt; null and self.initialLoad then
	    selectedRegion := self.myWorkingMovement.getFirstRegionWithChkPts(	self.baseTimeToChkpt,
																			enterLeaveStatus,
																			self.myWorkingMovement.getMovementPrevious);
	else
		selectedRegion := self.cmbRegion.listObject.HMS_HarbourRegion;
	endif;

	if selectedRegion &lt;&gt; null then
		self.lblTime2.visible		:=	true;
		self.lblFlow.visible		:=	true;
		self.lblFRPositive.visible	:=	true;
		self.lblFlowRate.visible	:=	true;
		self.lblFRNegitive.visible	:=	true;
		self.tblFlowRate.visible	:=	true;
	else
		//tmpHarbour	:=	self.myTerminal.myHarbour; - commented, not used in this method
	endif;

	tideClass := cmbTidalClass.listObject.HMS_TidalClass;

	if tideClass &lt;&gt; null then
		if self.optArrival.value then
			currentLimitPosve := tideClass.allMaximumCurrents[1];	// flood tide
			currentLimitNegve := (tideClass.allMaximumCurrents[2])*-1;	// ebb tide
		else
			currentLimitPosve := tideClass.allMaximumCurrents[3];	// flood tide
			currentLimitNegve := (tideClass.allMaximumCurrents[4])*-1;	// ebb tide
		endif;
	else
		currentLimitPosve := 100;
	 	currentLimitNegve := -100;
	endif;

	draftLimit := self.txtDraft.text.Real;
	
	// Adjust tidal restriction windows times to report relative to pilot on board time or time at wharf
	// depending on the preference setting.

	self.setOffsetTimeAndLocation();

    //AJA 19/6/00: Use rewritten function to get tidal windows
	app.myHMSRvTide.getTidalWindows2(	selectedRegion,
										moveTime,
										currentLimitPosve,
										currentLimitNegve,
										draftLimit,
										self.windowArray,
										self.baseTimeToChkpt);
	
	// PAR #33337 If Harbour option "Maximum Draft" is set, and this vessel's draft exceeds that value, // PAR #33337
	// filter the windowArray to only contain high-water windows										// PAR #33337
	//if selectedRegion.getHarbour &lt;&gt; null then															// PAR #33337	// PAR #35022
	if selectedRegion &lt;&gt; null and selectedRegion.getHarbour &lt;&gt; null then								// PAR #33337	// PAR #35022
		maximumDraft := selectedRegion.getHarbour.maximumDraft;											// PAR #33337
		//if maximumDraft &lt;&gt; null and self.txtDraft.text.Decimal &gt; maximumDraft then						// PAR #33337
		if maximumDraft &lt;&gt; null and self.txtDraft.text.asDecimalJMT &gt; maximumDraft then	//22 Oct 2015	NDL	Par 36655
			create newWindowArray transient;															// PAR #33337
			self.windowArray.copy(newWindowArray);														// PAR #33337
			checkPoint := selectedRegion.myCurrentCheckpoint;											// PAR #33337
			app.myHMSRvTide.filterWindowsByHighTide(newWindowArray, checkPoint);						// PAR #33337
			self.windowArray.clear();																	// PAR #33337
			newWindowArray.copy(self.windowArray);														// PAR #33337
		endif;																							// PAR #33337
	endif;																								// PAR #33337
	
	tmpSize := self.windowArray.size;
	
	if moveTimeIsDST and not systemTimeIsDST then
		daylightAdjust.setTime(1,0,0,0);
		
		foreach i in 1 to tmpSize do
			if self.windowArray[i] &lt;&gt; null then									// PAR #32656
				self.windowArray[i] := self.windowArray[i] + daylightAdjust;
			endif;																// PAR #32656
		endforeach;
	endif;

	if systemTimeIsDST and not moveTimeIsDST then
		daylightAdjust.setTime(1,0,0,0);
		
		foreach i in 1 to tmpSize do
			if self.windowArray[i] &lt;&gt; null then									// PAR #32656
				self.windowArray[i] := self.windowArray[i] - daylightAdjust;
			endif;																// PAR #32656
		endforeach;
	endif;

	self.legendRegion.visible := true;
	self.legendBerth.visible := true;
	
	if selectedRegion &lt;&gt; null then
		self.lblLegendRegion.caption := 'Region : ' &amp; selectedRegion.description;
	else
		self.lblLegendRegion.caption := 'Region : None selected';
	endif;

	if self.reportTimeCaption &lt;&gt; null then
		self.lblLegendBerth.caption := self.reportTimeCaption;
	elseif self.myWorkingMovement &lt;&gt; null then
		tmpBerth := self.myWorkingMovement.getBaseTimeBerth();
		
		if tmpBerth &lt;&gt; null then
			self.lblLegendBerth.caption	:= 'Berth : ' &amp; tmpBerth.description;
		else
			self.lblLegendBerth.caption := 'Berth : ';
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="moveTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="handleNotificationRefreshView" id="99480cc2-0728-46ea-a7c9-06c481ba2953">
        <updating/>
        <source>handleNotificationRefreshView(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 10/02/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhamcements
vars

begin
	if CMIF_HMS_WorkingMovement.hasInstance(theObject) then						// PAR #33337
		if self.myWorkingMovement &lt;&gt; theObject.CMIF_HMS_WorkingMovement then	// PAR #33337
			self.myWorkingMovement := theObject.CMIF_HMS_WorkingMovement;		// PAR #33337
		endif;																	// PAR #33337
	endif;																		// PAR #33337
	if not global.isValidObject(myWorkingMovement) then							// PAR #33337
		self.myWorkingMovement := null;											// PAR #33337
	endif;																		// PAR #33337
	self.movementDefaults;														// PAR #33337
	
	self.doRefresh();
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="be76e7b1-03dd-46c3-923b-8f69ec7f4911">
        <updating/>
        <source>initForm()updating;
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
vars
	region 	: HMS_HarbourRegion;
	index	: Integer;
	
begin
	// populate the comboboxes
	self.buildComboRegion();

	self.lblTidalClass.visible	:=	true;
	self.cmbTidalClass.visible	:=	true;

	
	self.cmbTidalClass.listCollection(app.myRoot.allTidalClasses,true,0);
	self.cmbVesselHMS.isVesselComboByName := self.myTerminal.getConfig(VesselComboByName).Boolean;

//	self.myAssistant.comboBoxHMSVessel(self.cmbVessel, null);
	//------------------------------------------
	//  Rocky 23/03/99
    if self.myWorkingMovement &lt;&gt; null then
		self.optDeparture.value := true;
    else
        self.optArrival.value := true;
	endif;
	//------------------------------------------
	self.showRelativeTimesOnTidalModel := self.showRelativeTimes();
	

	// setup the shading, rows and columns on the tables
	self.setupTable(self.tblDepth);
	self.setupTable(self.tblFlowRate);
	self.setupTable(self.tblEntranceWindow);

	// setup the graphic properties for anything that will be drawn on
	self.lblTime1.autoRedraw := true;
	self.lblTime2.autoRedraw := true;
	self.lblTime3.autoRedraw := true;
	self.lblTime4.autoRedraw	:= true;

	self.lblTime1.drawTextAlign	:= DrawTextAlign_Center;
	self.lblTime2.drawTextAlign	:= DrawTextAlign_Center;
	self.lblTime3.drawTextAlign	:= DrawTextAlign_Center;
	self.lblTime4.drawTextAlign	:= DrawTextAlign_Center;

	self.lblTime1.drawFontName	:= 'Arial';
	self.lblTime1.drawFontSize	:= 8;
	self.lblTime2.drawFontName	:= 'Arial';
	self.lblTime2.drawFontSize	:= 8;
	self.lblTime3.drawFontName	:= 'Arial';
	self.lblTime3.drawFontSize	:= 8;
	self.lblTime4.drawFontName	:= 'Arial';
	self.lblTime4.drawFontSize	:= 8;

	// set the minutes per pixel item
	self.minutesPerPixel := 1440 / self.tblDepth.width;

	self.legendRegion.backColor 	:= Black;
	self.legendBerth.backColor	:= TidalWindowBlue;
	self.legendRegion.visible	:= true;
	self.legendBerth.visible		:= true;
	
	// setup form with any selected movement defaults
	self.movementDefaults();
	
	// draw the tidal information for the selected movement or the default region/class
	self.drawMe();

	self.xLow := self.tblDepth.left;
	self.xHigh := self.tblDepth.left + self.tblDepth.width - self.picSlider.width;
end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="d9864780-efdf-4a4d-95a1-764d81b45da1">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 26 October 2004
//
//********************************************************************
vars

begin

	//Redraw the tidal model if we hit enter. We don't save anything on this form.
	//just redisplay it.
	if keyCode = J_key_Enter then
		self.doBtnApply();
	elseif keyCode = J_key_LeftArrow then
		self.advanceMinutes(-30);
	elseif keyCode = J_key_RightArrow then
		self.advanceMinutes(30);
	
	else
		inheritMethod(keyCode, shift);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="makeTimeLabel" id="518040ff-b922-48f2-9117-5bdc5969dabe">
        <updating/>
        <source>makeTimeLabel(_ts:TimeStamp; _x : Real)updating;

vars
	tmpTS	: TimeStamp;
	str		: String;
	h		: Real;
	t		: Time;
	mo		: Integer;
	hour,min,sec,ms:Integer;
	
begin

	mo := self.chkptToTTTATime.abs;
	hour := (mo/60).Integer;
	min  := (mo - (hour * 60)).Integer;
	sec  := 0;
	ms	 := 0;
	t.setTime(hour,min,sec,ms);
	
	tmpTS := _ts;	// this is theoretical timne for black box. Par 17906 Feb 2009
	if self.showRelativeTimesOnTidalModel then	// show relative time for blue box
		if self.chkptToTTTATime &lt; 0 then
			tmpTS := tmpTS - t;
		else
			tmpTS := tmpTS + t;
		endif;		
	endif;

	str := tmpTS.time.format('HHmm');

	h := lblTime4.drawTextHeight(str[1:1])-4;
	lblTime4.drawTextAt(str[1:1],_x,0,Black);
	lblTime4.drawTextAt(str[2:1],_x,1*h,Black);
	lblTime4.drawTextAt(str[3:1],_x,2*h,Black);
	lblTime4.drawTextAt(str[4:1],_x,3*h,Black);

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_x" type="Real"/>
    </JadeMethod>
    <JadeMethod name="movementDefaults" id="8d0c5d36-75df-4e4d-b054-eb415ddd0d71">
        <updating/>
        <source>movementDefaults()updating;

vars
	vessel				: CM_Vessel;
	selectedRegion		: HMS_HarbourRegion;
	str					: String;
	defaultTideClass	: HMS_TidalClass;  // Modified by Russell 29/03/99
	
begin
	if not global.isValidObject(self.myWorkingMovement) then
		self.myWorkingMovement := null;
	endif;
	
	if self.myWorkingMovement = null then
		self.dateMask.setDate(app.actualTimeServer.date);
		self.txtDate.setDate(app.actualTimeServer.date);
		self.txtTime.setTime(app.actualTimeServer.Time);
		
		// default in the tidal class, region and draft if no selected movement
		if self.cmbRegion.listCount &gt; 0 then
			self.cmbRegion.listIndex := 1;
		endif;
		
		if self.cmbTidalClass.listCount &gt; 0 then
			self.cmbTidalClass.listIndex := 1;
		endif;
		
		return;
	endif;

	self.dateMask.setDate(self.myWorkingMovement.occursOnDT.date);
 	self.txtDate.setDate(self.myWorkingMovement.occursOnDT.date);
 	self.txtTime.setTime(self.myWorkingMovement.occursOnDT.Time);
 	
 	vessel	:=	self.myWorkingMovement.myWorkingVoyage.getMyVessel;
	
 	if vessel &lt;&gt; null then
 		self.cmbVesselHMS.setObject(vessel.myHMSVesselData);
 	endif;

 	if self.myWorkingMovement.myMoveTidalClass = null then
 		// Modified by Russell 29/03/99
 		// -----------------------------------------------------------------------
 		if self.myWorkingMovement.moveType = HMSMovementTypeDeparture then
 			defaultTideClass	:=	self.myWorkingMovement.myWorkingVoyage.myHMSVoyageData.myTidalClassDept;
 		else
 			defaultTideClass	:=	self.myWorkingMovement.myWorkingVoyage.myHMSVoyageData.myTidalClass;
 		endif;
		
 		if defaultTideClass &lt;&gt; null then
 			self.cmbTidalClass.listIndex	:=	self.cmbTidalClass.findObject(defaultTideClass);
		else
			self.cmbTidalClass.listIndex	:=	1;
		endif;
		// -----------------------------------------------------------------------
	else
		self.cmbTidalClass.listIndex	:=	self.cmbTidalClass.findObject(self.myWorkingMovement.myMoveTidalClass);
	endif;

	if self.myWorkingMovement.draftMax &gt; 0.1 then
		//txtDraft.text	:=	self.myWorkingMovement.draftMax.String;	//4.1.1 Use movement drafts by default				// cnwdad1 10/07/2009 - PAR #20270.
		txtDraft.text	:=	self.myWorkingMovement.draftMax.asStringJMT();	//4.1.1 Use movement drafts by default		// cnwdad1 10/07/2009 - PAR #20270.
	elseif vessel &lt;&gt; null then
		if vessel.myHMSVesselData.dim_DraftAft &gt; vessel.myHMSVesselData.dim_DraftFore then	//Else use vessel max drafts
		 	//self.txtDraft.text	:=	vessel.myHMSVesselData.dim_DraftAft.String;			// cnwdad1 10/07/2009 - PAR #20270.
			self.txtDraft.text	:=	vessel.myHMSVesselData.dim_DraftAft.asStringJMT();		// cnwdad1 10/07/2009 - PAR #20270.
		else
		 	//self.txtDraft.text	:=	vessel.myHMSVesselData.dim_DraftFore.String;		// cnwdad1 10/07/2009 - PAR #20270.
			self.txtDraft.text	:=	vessel.myHMSVesselData.dim_DraftFore.asStringJMT();		// cnwdad1 10/07/2009 - PAR #20270.
		endif;
	else
		self.txtDraft.text	:=	null;
	endif;

    selectedRegion	:=	self.myWorkingMovement.getFirstRegionWithChkPts(self.baseTimeToChkpt,
																		str,
																		self.myWorkingMovement.getMovementPrevious);
	
    if selectedRegion &lt;&gt; null then
	 	self.cmbRegion.listIndex	:=	self.cmbRegion.findObject(selectedRegion);
	endif;

	if str = HMSMovementTypeEntering then
		self.optArrival.value	:=	true;
	else
		self.optDeparture.value	:=	true;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="optArrival_click" id="193e1171-5812-4345-8771-26fd1a8bb7b5">
