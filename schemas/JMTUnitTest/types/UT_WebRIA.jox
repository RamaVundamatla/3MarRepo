    <JadeMethod name="xCreateProxyLogRow" id="975ab77e-5e09-44ad-9efe-1b6cb868fd2b">
        <source>xCreateProxyLogRow(_cmif_LogRow : CMIF_LogRowRestriction io; _logAreaId : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2014	cnwmc5	Initial creation

*/
constants

	OPER			: String = "DOUG";
	SPECIES			: String = "DUGFIR";
	GRADE			: String = "HIGH";
	LOG_TYPE		: String = "AA";
	TREAT			: String = "NONE";
	LENGTH			: String = "2M";
	
	LOC_ID			: String = "LGR1";	
	
vars

	operator		: CM_Operator;
	obj				: CM_Object;
	
begin

	operator := self.getOperator(OPER);
	
	_cmif_LogRow.allOperators.add(operator);

	obj := operator.getLogSpecies(SPECIES);
	_cmif_LogRow.allSpecies.add(obj);

	obj := operator.getLogGrade(SPECIES, GRADE);
	_cmif_LogRow.allGrades.add(obj);

	obj := operator.getLogType(LOG_TYPE);
	_cmif_LogRow.allTypes.add(obj);

	obj := operator.getLogTreatment(TREAT);
	_cmif_LogRow.allTreatments.add(obj);

	obj := operator.getLogLength(LENGTH);
	_cmif_LogRow.allLengths.add(obj);
	
	_cmif_LogRow.myRowArea := self.getTerminalArea(_logAreaId).CM_LogArea;
	_cmif_LogRow.id := LOC_ID;

	_cmif_LogRow.transport := 3;  // there is no constant
	
	_cmif_LogRow.status := LC_Status_Open;
	
	_cmif_LogRow.width := 12;  //see LOG_LogRowMaintForm :: setRowWidth();

	_cmif_LogRow.user := app.getMyUserCode;
	
epilog

end;</source>
        <Parameter name="_cmif_LogRow" type="CMIF_LogRowRestriction" usage="io"/>
        <Parameter name="_logAreaId" type="String"/>
    </JadeMethod>
    <JadeMethod name="xCreateSourceLocations" id="1a1f56a1-fc40-47bb-a912-efca20f4e285">
        <source>xCreateSourceLocations();
/*

Purpose:			Has the ability to create lots more than 1..

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2014	cnwmc5	Initial creation

*/
constants
	DESC		: String = "UT Soruce Location";
	NAME		: String = "UT_Loc";
vars

	index : Integer;
	codeGroup : CM_CodeGroup;
	
	iter : Iterator;
	deleteCodeSet : CM_CodeSet;
	subSub : CM_SourceSubSubLocation; 
	sub : CM_SourceSubLocation;
	sLoc : CM_SourceLocation;
	deleteCodeGroups : CM_CodeGroupsByTypeNameDict;

begin

	create deleteCodeSet transient;
	iter := CM_SourceSubSubLocation.instances.createIterator;
	while iter.next(subSub) do
		if subSub.description.pos(DESC,1) &gt; 0 then
			deleteCodeSet.add(subSub);
		endif;
	endwhile;
	if not deleteCodeSet.isEmpty then
		beginTransaction;
		deleteCodeSet.purge();
		commitTransaction;
	endif;
	delete deleteCodeSet;
	delete iter;
	
	create deleteCodeSet transient;
	iter := CM_SourceSubLocation.instances.createIterator;
	while iter.next(sub) do
		if sub.description.pos(DESC,1) &gt; 0 then
			deleteCodeSet.add(sub);
		endif;
	endwhile;
	if not deleteCodeSet.isEmpty then
		beginTransaction;
		deleteCodeSet.purge();
		commitTransaction;
	endif;
	delete deleteCodeSet;
	delete iter;
	
	create deleteCodeSet transient;
	iter := CM_SourceLocation.instances.createIterator;
	while iter.next(sLoc) do
		if sLoc.description.pos(DESC,1) &gt; 0 then
			deleteCodeSet.add(sLoc);
		endif;
	endwhile;
	if not deleteCodeSet.isEmpty then
		beginTransaction;
		deleteCodeSet.purge();
		commitTransaction;
	endif;
	delete deleteCodeSet;
	delete iter;
	
	create deleteCodeGroups transient;
	iter := app.myRoot.allCodeGroups.createIterator;
	while iter.next(codeGroup) do
		if codeGroup.groupType &lt;&gt; CodeGroup_SourceLocation then
			continue;
		endif;
		if codeGroup.name.pos(NAME,1) = 1 then
			deleteCodeGroups.add(codeGroup);
		endif;
	endwhile;
	if not deleteCodeGroups.isEmpty then
		beginTransaction;
		deleteCodeGroups.purge();
		commitTransaction;
	endif;
	delete deleteCodeGroups;
	delete iter;

	foreach index in 1 to 1 do		
		//codeGroup := app.myRoot.allCodeGroups.getAtKeyGeq(CodeGroup_SourceLocation, NAME &amp; index.padLeadingWith("0",2) );
		//if codeGroup = null or codeGroup.groupType &lt;&gt; CodeGroup_SourceLocation then
		//	codeGroup := self.addCodeGroup( NAME &amp; index.padLeadingWith("0",2), CodeGroup_SourceLocation );
		//else
		//	continue;
		//endif;
		
		codeGroup := self.addCodeGroup( NAME &amp; index.padLeadingWith("0",2), CodeGroup_SourceLocation );
		
		self.addSourceLocation( codeGroup,	//_codeGroup : CM_CodeGroup;
								"A" &amp; index.padLeadingWith("0",2),	//_code : String;
								DESC,	//_description : String;
								5,	//_numSubs : Integer;
								2	//_numSubSubs :Integer
								);
	endforeach; 

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="xJadeCodeForCargoIdConv" id="111a6503-3c94-4e79-92c7-1bdceb7266c5">
        <source>xJadeCodeForCargoIdConv():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2021	navndl1	Initial creation	TFS 

*/

vars

begin

return
'doConvertCargoId( _cmif : CMIF_IDConversion ):String;
//

//Purpose:			

//Parameters:			

//Return Value:		

//Date		Who		Reason
//05 July 2016	cnwndl1	Initial creation TFS 2275 / 2216

//

vars

	rawScannedValue : String;
	length : Integer;
	firstChar : Character;
	secondChar : Character;
	thirdChar : Character;
	lastChar : Character;
	spacePos : Integer;

begin
	// The default behaviour is to just return "_cmif.scannedValue";
	// This performs no conversion at all. It simply returns the same value
	// as was scanned.
	//
	// An alternate behaviour is to "return _cmif.convertedCargoId;"
	// This will ensure that the scanned value will be trucncated to
	// its maximum allowable length if it is too long, The maximum length is
	// 20 characters for use as a Cargo Id, and 30 characters for an Alternate Id
	
	// Comment following line out and the example code will be used instead
	
	//return _cmif.scannedValue;
	
	//The _cmif will always have:
	//"scannedValue", a string being the text returned from the scan
	//"myTerminal", the terminal object where we are working
	//"isAlternateId", a Boolean, indicating that the value is being used for 
	//              population of the "Alternate Id" as opposed to the "Cargo Id". 
	
	//Optional fields that may also be present include:
	//"cargoType", an integer representing the cargo type we are related to
	//"myVoyage", the Voyage object we are working within
	//"imexStatus", an integer reoresenting the imex status we care about. 
	//"callerName", a contextual string value, provided for JMT internal use.
	
	//The following 3 lines are for JMT Unit testing.
	if _cmif.callerName &lt;&gt; "UT"
	and _cmif.callerName &lt;&gt; "MOB_HHVehicleLanderMove"
	and _cmif.callerName &lt;&gt; "MOB_HHVehicleROROLaneStd"	//TFS 4160/4238
	then
		return _cmif.scannedValue;
	endif;
	

	//Example of simple some of the rules that may be required...
	
	//find the exact length of the original scanned value as it was scanned
	rawScannedValue := _cmif.scannedValue;
	length := rawScannedValue.length;
	
	if length = 0 then
		return rawScannedValue;
	endif;
	
	// Establish what the first and last characters are in the scanned value
	firstChar := _cmif.scannedValue[1].toUpper;
	lastChar := _cmif.scannedValue[length].toUpper;
	
	if firstChar = "&lt;" and lastChar = "&gt;" then
		//This is probably a hand held field instruction like "&lt;PLEASE ENTER CARGO ID&gt;"
		//dont convert it
		return _cmif.scannedValue;
	endif;
	
	//Suzuki specififc code. 04 July 2017 NDL / for AAT
	//Needs to be inserted immediately before generic space handling code
	if length = 21 then
		secondChar := rawScannedValue[2].toUpper;
		thirdChar := rawScannedValue[3].toUpper;
		if secondChar = "J" and thirdChar = "S" then
			// return 17 characters starting at the second character
			return rawScannedValue[2:17];
		endif;
	endif;
	
	//TFS 2519
	//Check for an embedded space character, and record its position
	spacePos := rawScannedValue.pos(" ", 1);
	if spacePos &gt; 0 and spacePos &lt; length then
		// return everything after the first embedded space.
		return rawScannedValue[spacePos+1:end];
	endif;	
	
	if length &lt;= 17 then
		// if the length is less than or equal to 17 characters in length, just return it
		return rawScannedValue;
	endif;
	
	// formats and meaning of the data in the VIN is as per information found in 
	//"https://en.wikipedia.org/wiki/Vehicle_identification_number"
	
	// It is apparently common to prefix the bar-coded VIN number
	// with an "I" apparently indicating an "Import"
	// The first 3 chars are the "World Manufacturer Identifier"
	// and none of them start with "I"
	
	//So first simple rule 
	if length = 18 then
		if firstChar = "I" then
			// The value is one character too long and starts with an "I"
			// return the value starting at the second character
			return _cmif.scannedValue[2:end];
		endif;
	endif;
	
	//apparently some numbers are actually wrapped in asterix (both ends)
	//So second simple rule
	if length = 19 then
		if firstChar = "*" and lastChar = "*" then
			// return 17 characters starting at the second character
			return rawScannedValue[2:17];
		endif;
	endif;
	
	secondChar := rawScannedValue[2].toUpper;
	thirdChar := rawScannedValue[3].toUpper;
	//A more specific rule, apparently Japanese assembled Toyotas can have suffixs on the vin
	// The first character represents the country of origin.
	// The second and third character(s) represents the manufacturer.
	
	if firstChar = "J" and secondChar = "T" then
		// So first character "J" = Japan, second character "T" = Toyota 
		// return 17 characters starting at the first character
		return rawScannedValue[1:17];
	endif;
	
	//08 Aug 2016 NDL TFS 2504 &amp; 2550
	if length = 18 and firstChar = "M" and secondChar = "R" then
		//"MR" - possibly means Thailand Toyota... anyway examples seem to have an additional suffix.
		// return 17 characters starting at the first character
		return rawScannedValue[1:17];
	endif;
	
	//Other specific rules should be implemented immediate under this comment...
	
	
	
		
	// Finally if no other rules have been invoked
	// apply the default behaviour.
	
	return _cmif.convertedCargoId;
	
epilog

end;';

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
