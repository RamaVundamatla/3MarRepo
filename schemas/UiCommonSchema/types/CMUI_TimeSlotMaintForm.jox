    <JadeMethod name="setupForm" id="571135fe-a6e5-4aaa-a7e4-fd7466b0f97e">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Andrew Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	now : Date;
begin
	inheritMethod();
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.beginClassNotification(CM_TimeSlot, false, self.myTerminal.getTerminalEvent(Event_TimeSlotStd_Add), Response_Continuous, null);
	self.beginClassNotification(CM_TimeSlot, false, self.myTerminal.getTerminalEvent(Event_TimeSlotStd_Update), Response_Continuous, null);
	self.beginClassNotification(CM_TimeSlot, false, self.myTerminal.getTerminalEvent(Event_TimeSlotStd_Delete), Response_Continuous, null);
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmToolbar.priorityRight := true;
	self.myTerminal := app.myPassport.myTerminal;
	
	self.setStartDate(now);
	self.initForm();
	self.width := self.tblCalendar.width;
	self.height := self.tblCalendar.height + 150;
	self.getXMLSettingsForSetup();
end;</source>
    </JadeMethod>
