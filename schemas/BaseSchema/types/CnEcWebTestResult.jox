This class stores a timestamp for each Test Message, recording the
following information:

	1. The time the Test Message was requested;
	2. The time the Test Message response was received;
	3. The data received in the Test Message response.</text>
    <DbClassMap file="WebTest"/>
    <ExplicitInverseRef name="myBaseRoot" id="957f5a9c-7867-492b-b176-07523f72ab26">
        <kind>child</kind>
        <embedded/>
        <type name="CnEcBaseRoot"/>
        <access>readonly</access>
        <Inverse name="CnEcBaseRoot::allWebTestResults"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myTestMessage" id="cf9d9411-4805-4072-a815-0ab19b98de55">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CnEcWebTestMessage"/>
        <access>readonly</access>
        <Inverse name="CnEcWebTestMessage::allTestResults"/>
    </ExplicitInverseRef>
    <PrimAttribute name="resultData" id="e6cd9444-311a-4fa0-ac69-6f480d7e6676">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="timeReceived" id="6124ad73-55c9-4bc4-80f8-d08d8de11457">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="timeRequested" id="39ca1e2c-e157-4807-aa15-7b0ce34f1672">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDisplay" id="8ff0a31a-078b-42a5-a30e-2e4e44ecf852">
        <source>getDisplay():String;
// --------------------------------------------------------------------------------
// Created:		06 June 2000 by cnwdad1
//
// Purpose:		Return a display string for the receiver.
//
// Parameters:	None
//
// Returns:		The display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	displayString	: String;

begin
	displayString	:=	"Result for Message '" &amp; self.myTestMessage.messageName &amp; "' " &amp;
						"requested " &amp; timeRequested.String &amp; ", receieved: " &amp; self.timeReceived.String;
epilog
	return displayString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="6225bf43-a10f-4469-a9ba-79d48a074ca1">
        <updating/>
        <source>initializeMe(	pBaseRoot:CnEcBaseRoot;
				pTestMessage:CnEcWebTestMessage;
				pTimeRequested:TimeStamp;
				pTimeReceived:TimeStamp;
				pResponseData:String) updating;
// --------------------------------------------------------------------------------
// Created:		01 June 2000 by cnwdad2
//
// Purpose:		Initialize the receiver's property values.
//
// Parameters:	pBaseRoot - The BaseSchema root object.
//				pTestMessage - The web test message object.
//				pTimeRequested - Timestamp when the test message started.
//				pTimeReceived - Timestamp when the test message responded.
//				pResponseData - The test message response.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set the property values...

	self.resultData		:=	pResponseData;

	// Now set any key property values...

	self.timeRequested		:=	pTimeRequested;
	self.timeReceived		:=	pTimeReceived;

	// Last, set any references...

	self.myTestMessage		:=	pTestMessage;
	self.myBaseRoot			:=	pBaseRoot;
end;</source>
        <Parameter name="pBaseRoot" type="CnEcBaseRoot"/>
        <Parameter name="pTestMessage" type="CnEcWebTestMessage"/>
        <Parameter name="pTimeRequested" type="TimeStamp"/>
        <Parameter name="pTimeReceived" type="TimeStamp"/>
        <Parameter name="pResponseData" type="String"/>
    </JadeMethod>
</Class>
