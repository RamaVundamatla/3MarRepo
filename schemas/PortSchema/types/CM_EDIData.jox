/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2022	navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
15 Mar 2023 	navra1		Bug TFS 57122 - US .010 'a' - EDI Advanced Search is only working on 
							data from the first line of an EDI file - it doesn't search for other
*/

vars
	ediTi: CM_EDITrackedItem;	
begin
	/*if self.operatorCode &lt;&gt; null then
		return self.operatorCode;
	endif;
	foreach ediTi in self.allEDITrackedItems  do
		return ediTi.getOperatorCode;
	endforeach;
	return null;
	*/		
	foreach ediTi in self.allEDITrackedItems  do								//navra1 - TFS 57122 - 15th Mar 2023	
		if not _ediTiOperatorCodes .includes(ediTi.getOperatorCode) then		//navra1 - TFS 57122 - 15th Mar 2023
			_ediTiOperatorCodes.add(ediTi.getOperatorCode);						//navra1 - TFS 57122 - 15th Mar 2023
		endif;																	//navra1 - TFS 57122 - 15th Mar 2023
	endforeach;																	//navra1 - TFS 57122 - 15th Mar 2023
	
epilog

end;</source>
