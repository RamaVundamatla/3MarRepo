	self.setupInvStatusEmailDefault(PINEmail_InvProcDefOffset + CM_Invoice.INVOICE_POSTED_REVERSE, // ie. 305
									app.invoiceStatusEnumToString(CM_InvoiceProcessDefault.firstInstance, CM_Invoice.INVOICE_POSTED_REVERSE),
									'Invoice', sa);
	
	self.setupInvStatusEmailDefault(PINEmail_InvProcDefOffset + CM_Invoice.INVOICE_POSTED_CREDIT, // ie. 306
									app.invoiceStatusEnumToString(CM_InvoiceProcessDefault.firstInstance, CM_Invoice.INVOICE_POSTED_CREDIT),
									'Invoice', sa);						
							
	self.setupInvStatusEmailDefault(PINEmail_InvProcLinxOffset + CM_Invoice.INVOICE_OPEN, // ie. 320
									app.invoiceStatusEnumToString(CM_InvoiceProcessLinx.firstInstance, CM_Invoice.INVOICE_OPEN),
									'Invoice', sa);
									
	self.setupInvStatusEmailDefault(PINEmail_InvProcLinxOffset + CM_Invoice.INVOICE_PENDING, // ie. 321
									app.invoiceStatusEnumToString(CM_InvoiceProcessLinx.firstInstance, CM_Invoice.INVOICE_PENDING),
									'Invoice', sa);
	
	self.setupInvStatusEmailDefault(PINEmail_InvProcLinxOffset + CM_Invoice.INVOICE_POSTED, // ie. 322
									app.invoiceStatusEnumToString(CM_InvoiceProcessLinx.firstInstance, CM_Invoice.INVOICE_POSTED),
									'Invoice', sa);

	self.setupInvStatusEmailDefault(PINEmail_InvProcLinxOffset + CM_Invoice.INVOICE_VOID, // ie. 323
									app.invoiceStatusEnumToString(CM_InvoiceProcessLinx.firstInstance, CM_Invoice.INVOICE_VOID),
									'Invoice', sa);

	self.setupInvStatusEmailDefault(PINEmail_InvProcLinxOffset + CM_Invoice.INVOICE_POSTED_REVERSE, // ie. 325
									app.invoiceStatusEnumToString(CM_InvoiceProcessLinx.firstInstance, CM_Invoice.INVOICE_POSTED_REVERSE),
									'Invoice', sa);
									
	self.setupInvStatusEmailDefault(PINEmail_InvProcLinxOffset + CM_Invoice.INVOICE_POSTED_CREDIT, // ie. 326
