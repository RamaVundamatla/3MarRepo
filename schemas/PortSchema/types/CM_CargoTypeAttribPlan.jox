    <JadeMethod name="setForUpdateX" id="2f899690-4114-4de3-843c-60ad8f98c31c">
        <updating/>
        <source>setForUpdateX(_commodityGroup : CM_CommodityGroup; _isoTypeGroup : CM_ISOTypeGroup; _myCargoType : CM_CargoType; _imexStatus : Integer; _movePlan : CM_MovePlan; _id : String) updating;
/*
 ------------------------------------------------------------------------
Created:			13 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	if _commodityGroup = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MethodWithNullParam , method.name,  "commodityGroup",null, null);
		return;
	endif;
	if _isoTypeGroup = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MethodWithNullParam , method.name,  "ISOType Group",null, null);
		return;
	endif;
	if _myCargoType = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MethodWithNullParam , method.name,  "Cargo Type",null, null);
		return;
	endif;
	if _movePlan = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MethodWithNullParam , method.name,  "Move Plan",null, null);
		return;
	endif;

	self.commodityGroup := _commodityGroup;
	self.id := _id;
	self.imexStatus := _imexStatus;
	self.isoTypeGroup := _isoTypeGroup;
	self.myCargoType := _myCargoType;
	if not self.movePlans.includes(_movePlan) then
		self.movePlans.add(_movePlan);
	endif;
	self.myMoveMap := _movePlan.moveMap;
end;</source>
        <Parameter name="_commodityGroup" type="CM_CommodityGroup"/>
        <Parameter name="_isoTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_myCargoType" type="CM_CargoType"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_movePlan" type="CM_MovePlan"/>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
