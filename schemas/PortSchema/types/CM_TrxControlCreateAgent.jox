    <JadeMethod name="trxCreateEDIParty" id="90f731a8-fce4-4856-a27a-cf94463f5e3d">
        <updating/>
        <source>trxCreateEDIParty(_proxy :CM_EDIParty; _party :CM_EDIParty output; _passport :CM_Passport input)updating;
/*
Date		Who		Reason
16 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateEDIParty(_proxy, _party, _passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxy" type="CM_EDIParty"/>
        <Parameter name="_party" type="CM_EDIParty" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDIPortAuthVoyage" id="87b2c6a2-4203-45f0-836c-b4309d7e1bc3">
        <updating/>
        <source>trxCreateEDIPortAuthVoyage(_webService: CM_ExternalWebServiceDef input; //TFS 63842
						 _lastSuccessfullTS: TimeStamp;
						 _terminal: CM_Terminal;
						 _ediFile: CM_EDIFile io;
						 _ediFileType: CM_EDIFileType io;//TFS 63842
						 _ediDataVoyage: CM_EDIData io;
						 _filePath: String;
						 _response: String;
						 _transformedResponse: String;
						 _passport: CM_Passport io) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 30 March 2023
TFS#		: 57276
Function	:

*** Changes ***
Date			Name		TFS#		Description
19/04/2023		jlika1		57622		POB - QShips Response Received but no Voyages Created in EDI Operations		
11/08/2023 		navra1		TFS 59763	POB - Object Not Found Error When Processing QSHIPS Response
18/07/2024      navsp1      63842       ChangeRequest 63842: NSW | OnePort Integration Dev - (method renamed from 'trxCreateEDIQshipsVoyage', parameter changed)
09/09/2024		navdap1		TFS 66034	NSW - OnePort Integration Post-Dev Demo Issues
02/10/2024		navdap1		MTN-32771	NSW | FR - 1090 Error Preventing Voyage Data Displaying in EDI Operations
05/12/2024		navmd1		MTN-33527	Make sure we save the NON-transformed message to the EDI file, just in case something weird happens with the trnasform
****************************************************/

vars
	lastSuccess : TimeStamp;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	lastSuccess.cnEcSetDateAndTime(app.actualTimeServer.date, null);						// TFS 66034
	app.myUtilityUA.utlUpdQshipsWSLastSuccessTS(_webService, lastSuccess, app.myPassport);	// TFS 66034

	//navra1 - TFS 59763 - 11th Aug 2023
	if app.myPassport.hasErrors() then
		return;
	endif;

	app.myUtilityCA.utlCreateEDIFile(_ediFile, _ediFileType, _filePath, app.actualTimeAppServer(), _ediFile.EDI_STATUS_UNPROCESSED, _terminal.myEdiConfig, app.myPassport, null, _webService.name, _response.asANSI(0), _transformedResponse, true);	// MTN-32771

	//navra1 - TFS 59763 - 11th Aug 2023
	if app.myPassport.hasErrors() then
		return;
	endif;

	if _ediFileType.isKindOf(CM_EDIFileTypeXMLQShipsVoyage) then																																//TFS 63842
		_ediFileType.CM_EDIFileTypeXMLQShipsVoyage.setMyTerminal(_terminal);																													//TFS 63842
		app.myUtilityCA.utlCreateEDIData(_ediDataVoyage, CM_EDIDataVoyageQships, EDIDataType_Voyage, EDIFileType_XMLQShipsVoyage, _ediFile.ediConfig, _ediFile, _ediFileType, app.myPassport);	//TFS 63842
	elseif _ediFileType.isKindOf(CM_EDIFileTypeJSONOnePortVoy) then																																//TFS 63842
		_ediFileType.CM_EDIFileTypeJSONOnePortVoy.setMyTerminal(_terminal);																														//TFS 63842
		app.myUtilityCA.utlCreateEDIData(_ediDataVoyage, CM_EDIDataVoyageQships, EDIDataType_Voyage, EDIFileType_JSONOnePortVoyage, _ediFile.ediConfig, _ediFile, _ediFileType, app.myPassport);//TFS 63842
	endif;																																														//TFS 63842

	//navra1 - TFS 59763 - 11th Aug 2023
	if app.myPassport.hasErrors() then
		return;
	endif;

	//_ediFileType.setMyTerminal(_terminal);  //TFS 63842 - moved to top
	_ediFileType.processFileData(_ediFile ,_passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_webService" type="CM_ExternalWebServiceDef" usage="input"/>
        <Parameter name="_lastSuccessfullTS" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="io"/>
        <Parameter name="_ediFileType" type="CM_EDIFileType" usage="io"/>
        <Parameter name="_ediDataVoyage" type="CM_EDIData" usage="io"/>
        <Parameter name="_filePath" type="String"/>
        <Parameter name="_response" type="String"/>
        <Parameter name="_transformedResponse" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="io"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDIPreNotes" id="2b750dad-57f9-4c91-aee8-9e84eef275d4">
        <updating/>
        <source>trxCreateEDIPreNotes(_intFaceArray : CMIF_TIObjectArray; _validateOnly: Boolean; _ediData : CM_EDIData input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     Takes an array of CM_InterfaceObjects (all members should be CM_IntFaceReceival)
//				and creates pre-notified tracked items from these.
//
// Parameters:  The array of interface objects.
//
// Returns:     True if successful.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/02/2009	cnwdad1		PAR #18927.  Added validation (for create) prior to
//							entering transaction state so that lookups to check
//							whether a Prenote already exists won't retain any
//							locks of the dictionaries it looks up. The validation
//							method (called by the Utility method) has been changed
//							so that it will not do the lookup again if it has already
//							been done here.
//
//	30/04/2009	cnwdad1		CCMS 1735.  Changed to set mySubTerminal to a
//							default object reference if it is null.
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 2
// 20 Jun 2012	cnwrs1	Par 31625 DPH Load list changes the above change for 31143 is incorrect as it applies to Load List only
// ---------------------------------------------------------------------------
vars
	itemObj		: CMIF_TIObject;
//	status : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	//
	// Improve performance on EDI loads by only getting voyages once
	// PAR 22396
	//
	_passport.allCurrentCellularVoyages.clear;
	_passport.myTerminal.getAllCurrentCellularVoyagesNC(_passport.allCurrentCellularVoyages, false, false);

	app.myValCA.valPreNotes(_intFaceArray, _passport);
	
	
	app.setContinueCMExceptions(true);
	
	endLoad;
	
	if _passport.noErrors() then
		beginTransaction;
	
		if not _validateOnly then
			_passport.useTIDictDeferUpdate			:=	true;
			_passport.useTITransactionDeferUpdate	:=	true;
		endif;
		
		app.myUtilityCA.utlCreatePreNotes(_intFaceArray, _validateOnly, _passport);
	endif;
	
	// use passport to get new status for EDI Data
//	status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);

	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
						
//			app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

//	if _validateOnly or _passport.hasErrors then
//		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
//	endif;
	_passport.allCurrentCellularVoyages.clear;
end;</source>
        <Parameter name="_intFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDISendRecipFileType" id="244c0a8d-f8d5-429b-8e97-f8ec100c0f9c">
        <updating/>
        <source>trxCreateEDISendRecipFileType(_proxy : CM_EDISenderRecipFileType; _real : CM_EDISenderRecipFileType output; _ediData : CM_EDIData; _terminal : CM_Terminal; _passport : CM_Passport input) updating;
//
//28 Aug 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateEDISendRecipFileType(_proxy, _real, _ediData, _terminal, _passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxy" type="CM_EDISenderRecipFileType"/>
        <Parameter name="_real" type="CM_EDISenderRecipFileType" usage="output"/>
