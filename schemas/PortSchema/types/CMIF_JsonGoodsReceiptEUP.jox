<Class name="CMIF_JsonGoodsReceiptEUP" id="72c0a7d7-ea95-4ee2-8937-0da5102056ca">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cams"/>
    <ImplicitInverseRef name="header" id="d0ce9b9d-2058-4339-adbe-e97b61f885f0">
        <embedded/>
        <type name="CMIF_JsonHeaderEUP"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="transports" id="7d98e228-3f78-4d07-b9f3-1d01967d7767">
        <memberTypeInverse/>
        <type name="CMIF_JsonTransportsArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="4d479d0a-8ec3-44c0-b788-79d28ef721b4">
        <updating/>
        <source>delete() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 30 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if self.header &lt;&gt; null then 
		delete self.header;
	endif;
	
	self.transports.purge;	
end;</source>
    </JadeMethod>
    <JadeMethod name="setValue" id="52c6e961-08cb-471e-bd9e-70ce641eff7e">
        <updating/>
        <source>setValue(header : CMIF_JsonHeaderEUP; transport : CMIF_JsonTransportFullEUP)  updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 23 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	self.header := header;
	self.transports.add(transport);
end;</source>
        <Parameter name="header" type="CMIF_JsonHeaderEUP"/>
        <Parameter name="transport" type="CMIF_JsonTransportFullEUP"/>
    </JadeMethod>
</Class>
