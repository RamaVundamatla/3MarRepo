    <JadeMethod name="getFullId" id="0a7cf3b6-170e-44fa-88bc-14c3e93cb717">
        <source>getFullId(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 September 2011	cnwndl1	Initial creation
18 july 2022 		navds21 TFS 53965 MTN - Adding cargo from cargo lander adds 000000 at the end of the voyage

*/

vars
	tmpStr : String;
begin

	tmpStr := inheritMethod();
	
	//return tmpStr &amp; " 000000";	 //18 july 2022 navds21 TFS 53965
	return tmpStr &amp; " ";	 //18 july 2022 navds21 TFS 53965
end;</source>
        <ReturnType type="String"/>
