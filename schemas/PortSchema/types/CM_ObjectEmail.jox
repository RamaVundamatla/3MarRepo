    <JadeMethod name="setForCreate" id="52db8c7f-2a97-4f45-bdc0-af554d49107b">
        <updating/>
        <source>setForCreate(
	_entTable			: String;
	_fields				: StringArray;
	_message			: String;
	_subject			: String;
	_name				: String;
	_objectType			: String;
	_type				: Integer;
	_terminal			: CM_Terminal;
	_copyTo				: String;					// cnwrl1 27/07/2009 PAR 20349
	_sendToCarrier		: Boolean;					// cnwrl1 27/07/2009 PAR 20349
	_sendToConsignee	: Boolean ) updating;		// cnwrl1 27/07/2009 PAR 20349
//----------------------------------------------------------------
//	Created:	21 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.type			:= _type;
	self.name			:= _name;
	self.objectType		:= _objectType;
	self.subjectLine	:= _subject;
	self.message		:= _message;
	self.entTableName	:= _entTable;
	
	// cnwrl1 27/07/2009 PAR 20349 - start of coding
	self.copyTo				:= _copyTo;
	self.sendToCarrier		:= _sendToCarrier;
	self.sendToConsignee	:= _sendToConsignee;
	// cnwrl1 27/07/2009 PAR 20349 - end of coding
	
	if _fields &lt;&gt; null then
		_fields.copy(self.allIncludedFields);
	endif;
	
	//add to collection
	self.myTerminal := _terminal;
	
end;</source>
        <Parameter name="_entTable" type="String"/>
        <Parameter name="_fields" type="StringArray"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_objectType" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_copyTo" type="String"/>
        <Parameter name="_sendToCarrier" type="Boolean"/>
        <Parameter name="_sendToConsignee" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="53f03ddc-ef53-463c-b1af-3311b7e9e47c">
        <updating/>
        <source>setForUpdate(_proxy: CM_ObjectEmail) updating;
//----------------------------------------------------------------
//	Created:	23 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	//not much can be updated for these - they are "system" objects
	self.subjectLine := _proxy.subjectLine;
	self.message := _proxy.message;
	self.enabled := _proxy.enabled;
	// cnwrl1 27/07/2009 PAR 20349 - start of coding
	self.copyTo				:= _proxy.copyTo;
	self.sendToCarrier		:= _proxy.sendToCarrier;
	self.sendToConsignee	:= _proxy.sendToConsignee;
	// cnwrl1 27/07/2009 PAR 20349 - end of coding
	self.allIncludedFields.clear;
	_proxy.allIncludedFields.copy(self.allIncludedFields);
	

end;</source>
        <Parameter name="_proxy" type="CM_ObjectEmail"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="974d5359-7a5a-469b-92a6-6ba4d3193bb2">
        <updating/>
        <source>setProxy(
	_subject			: String;
	_message			: String;
	_includedFields		: StringArray;
	_enabled			: Boolean;
	_copyTo				: String;
	_sendToCarrier		: Boolean;
	_sendToConsignee	: Boolean ) updating;
//----------------------------------------------------------------
//	Created:	21 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	self.subjectLine		:= _subject;
	self.message			:= _message;
	self.enabled			:= _enabled;
	// cnwrl1 29/07/2009 PAR 20349 - start of coding
	self.copyTo				:= _copyTo;
	self.sendToCarrier		:= _sendToCarrier;
	self.sendToConsignee	:= _sendToConsignee;
	// cnwrl1 29/07/2009 PAR 20349 - end of coding
	
	self.allIncludedFields.clear;
	_includedFields.copy(self.allIncludedFields);
	
end;</source>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_includedFields" type="StringArray"/>
        <Parameter name="_enabled" type="Boolean"/>
        <Parameter name="_copyTo" type="String"/>
        <Parameter name="_sendToCarrier" type="Boolean"/>
        <Parameter name="_sendToConsignee" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="0f3c4e8b-58d6-4414-bb2e-4327a39e0b49">
        <source>validateForUpdate();
//----------------------------------------------------------------
//	Created:	23 February 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	//warn if subject line is blank
	if self.subjectLine = null then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'subject', 'subjectLine', null, self);
		app.raiseCMWarning(Input_required_field_subject, 'subjectLine', null, self); // cnwdb2	PAR 35364
	endif;
	
	// validate as best as possible the email addresses entered multiple ones are allowed
	app.validateEmailAddress( self.copyTo );
	
end;</source>
    </JadeMethod>
</Class>
