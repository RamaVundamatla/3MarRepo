    <JadeMethod name="getDisplayStringForAttribute" id="b81be7e6-1b22-4dea-8527-12e58fe31ce9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     14 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpStr	: String;
begin

	if _attrName = ETRow_LockDate then
		return self.lockDT.date.shortFormatJMT();
	elseif _attrName = ETRow_LockTime then
		return self.lockDT.time.shortFormatJMT();
	elseif _attrName = ETRow_LockTypeStr then
		tmpStr := self.lockTypeStr;
		if tmpStr = null then
			tmpStr := 'Lock(?)';	// tmp measure for old data
		endif;
		return tmpStr;
// cnwdad1 30/08/2006 - Constant is no longer used.
//	elseif _attrName = ETRow_LockDateSort then
//		return self.lockDT.date.formatAsYYYYMMDD();
	elseif _attrName = ETRow_LockedByTerminal then
		return self.lockedByTerminalCode;
	elseif _attrName = ETRow_LockedTerminal then
		return self.lockedTerminalCode;
	elseif _attrName = ETRow_LockedByDetails then
		return self.lockedByDetails &amp; ' ' &amp; self.info;
	endif;

	return inheritMethod(_attrName, _short);



end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lockedByDuration" id="00ba0bdc-350d-4bb6-be6e-95c785d08049">
        <methodInvocation>mapping</methodInvocation>
        <source>lockedByDuration(set: Boolean; _value: Decimal io) mapping;
// ---------------------------------------------------------------------------
// Created:     15 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	if self.lockedByTrxStartTime.isValid() and
	   self.lockedByTrxEndTime.isValid() then
		_value := self.lockedByTrxEndTime.cnEcMillisecondsSince(self.lockedByTrxStartTime) / 1000;
	elseif self.lockedByTrxStartTime.isValid() and
	   self.lockDT.isValid() then
		_value := self.lockDT.cnEcMillisecondsSince(self.lockedByTrxStartTime) / 1000;
	else
		_value := TrxDurationUnknown;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="490d21fc-e219-450f-b53b-4b3efb2cba82">
        <updating/>
        <source>setForCreate(_lockDT : TimeStamp;
	_lockTypeStr, 
	_lockedUser, _lockedTerminal,
	_lockedByUser, _lockedByTerminal,
	_lockTargetOid, _lockTargetClass, 
	_lockedByNode, _lockedByApp,
	_lockedByDetails, _info,
	_obtainedLockOid, _obtainedLockClass : String;
	_trxStartTime, _trxEndTime : TimeStamp;
	_stack : String200Array;
	_root : CM_GlobalProcessRoot) updating;
// ---------------------------------------------------------------------------
// Created:     10 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.lockDT					:= _lockDT;
	self.lockTargetClass		:= _lockTargetClass;
	self.lockTargetOid			:= _lockTargetOid;
	self.lockTypeStr			:= _lockTypeStr;

	self.lockedUser				:= _lockedUser;
	self.lockedTerminalCode		:= _lockedTerminal;

	self.lockedByUser			:= _lockedByUser;
	self.lockedByTerminalCode	:= _lockedByTerminal;
	self.lockedByDetails		:= _lockedByDetails;
	self.lockedByAppName		:= _lockedByApp;
	self.lockedByNodeName		:= _lockedByNode;
	self.lockedByTrxStartTime	:= _trxStartTime;
	self.lockedByTrxEndTime		:= _trxEndTime;

	self.obtainedLockClass		:= _obtainedLockClass;
	self.obtainedLockOid		:= _obtainedLockOid;
	
	self.info					:= _info;
	
	if _stack &lt;&gt; null then
		_stack.copy(self.stackDump);
	endif;
	
	self.myGlobalProcessRoot	:= _root;
	
end;</source>
        <Parameter name="_lockDT" type="TimeStamp"/>
        <Parameter name="_lockTypeStr" type="String"/>
        <Parameter name="_lockedUser" type="String"/>
        <Parameter name="_lockedTerminal" type="String"/>
        <Parameter name="_lockedByUser" type="String"/>
        <Parameter name="_lockedByTerminal" type="String"/>
        <Parameter name="_lockTargetOid" type="String"/>
        <Parameter name="_lockTargetClass" type="String"/>
        <Parameter name="_lockedByNode" type="String"/>
        <Parameter name="_lockedByApp" type="String"/>
        <Parameter name="_lockedByDetails" type="String"/>
        <Parameter name="_info" type="String"/>
        <Parameter name="_obtainedLockOid" type="String"/>
        <Parameter name="_obtainedLockClass" type="String"/>
        <Parameter name="_trxStartTime" type="TimeStamp"/>
        <Parameter name="_trxEndTime" type="TimeStamp"/>
        <Parameter name="_stack" type="String200Array"/>
        <Parameter name="_root" type="CM_GlobalProcessRoot"/>
    </JadeMethod>
</Class>
