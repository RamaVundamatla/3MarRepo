    <JadeMethod name="addHazardClass" id="ee7809e6-2d84-4720-94f6-ad115b7ebbe3">
        <source>addHazardClass(_hazardClassId, _hazardClassDesc, _alternateCode : String; _notAvailableForEntry : Boolean) : CM_HazardClass;

/*

Purpose:		Add a Hazard Code

Date			Who		Reason
09/12/2011		cnwmh5	Initial creation
12/05/2015		cnwdap1	PAR #36206 TFS 324/334 Graphical Representation of Hazard Class
*/

vars

	pxyHazardClass					: CM_HazardClass;
	hazardClass						: CM_HazardClass;
	pxyDraw							: CM_DrawingAttribute;
	
	colour							: Integer;
	font							: String;
	fontCharacter					: Integer;
	
begin

	self.deleteHazardClass(_hazardClassId);
	
	if self.opts.includesKey("Colour") then
		colour := self.opts.int("Colour");
	endif;

	create pxyHazardClass transient;
	
	// create drawing attribute if exists
	if self.opts.includesKey("DrawingAttributes") then
		create pxyDraw transient;
		
		font := self.opts.str("font");
		fontCharacter := self.opts.int("fontCharacter");
		
		if font = null then
			delete pxyDraw;
		endif;
		
		pxyDraw.setProxy("HazardClass_" &amp; _hazardClassId, font, fontCharacter, colour, app.myRoot);
	
	endif;
	
	
	pxyHazardClass.setProxy(_hazardClassId,					// Id / Code
							 _hazardClassDesc,				// Description
							 _alternateCode,				// alternateCode
							 colour, 							// colour
						     _notAvailableForEntry); 		// not available for entry
												  
	//app.myTrxCA.trxCreateHazardClass(pxyHazardClass, hazardClass, app.myPassport);		// PAR #36206
	app.myTrxCA.trxCreateHazardClass(pxyHazardClass, hazardClass, pxyDraw, app.myPassport);	// PAR #36206
	self.assertNoTrxErrorsOrWarnings();
	return hazardClass;

epilog

	delete pxyDraw;
	delete pxyHazardClass;
	
end;</source>
        <Parameter name="_hazardClassId" type="String"/>
        <Parameter name="_hazardClassDesc" type="String"/>
        <Parameter name="_alternateCode" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <ReturnType type="CM_HazardClass"/>
    </JadeMethod>
    <JadeMethod name="addIMV" id="d12a3c2a-cbbd-4bdd-82c9-df0a5e3948e5">
        <source>addIMV(_name: String; _deviceId: Integer; _taAccess: StringArray; _queue: String): CM_Machine;
//07 January 2009	cnwdw1	
//
begin
	return self.addMachine(MACHINETYPE_IMV, _name, _deviceId, _taAccess, _queue);
end;</source>
        <Parameter name="_name" type="String"/>
