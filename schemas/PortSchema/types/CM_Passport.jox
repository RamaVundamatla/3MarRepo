    <JadeMethod name="moveErrorsToSet" id="a7c01525-9c4e-4616-8998-4fd1b665e4e3">
        <updating/>
        <source>moveErrorsToSet(_errorSet : CM_ErrorSet input) updating;
// -------------------------------------------
// Created 20 May 2004 by cnwdvb1
// -------------------------------------------
vars

	error : CM_Error;

begin

	foreach error in self.allErrorWarnings do
		_errorSet.add(error);
		error.addToPassport(null);
	endforeach;
end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
