    <JadeMethod name="tReleaseMTByIDOpCarrier" id="9562ca12-1beb-412c-9f38-b53b89430449">
        <source>tReleaseMTByIDOpCarrier();
//
// 28 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
// 22 Aug 2019 	jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	ti: CM_TrackedItem;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	mt: CM_Container;
	operator : CM_Operator;
	driver : CM_DriverDetails;
	carrier, dougCarrier : CM_Carrier;
	carrierCode : String;
	carrierSet : CM_CarrierSet;
	cargoType : CM_CargoType;
	error : CM_Error;
	foundError : Boolean;
	pxyCriteria : CM_YACriteria;
	criteria : CMIF_Array;
	cmifCriterion : CMIF_YACriteriaPriority;
	pxyOpCrit : CM_OperatorCarrierCriteria;
	realOpCrit : CM_ObjectMatchCriteria;
	ls : Boolean;
begin
	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	create carrierSet transient;
	create criteria transient;
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	carrier := app.myRoot.allCarriers["CCC"];
	carrierSet.add(carrier);
	
	create pxyCriteria transient;
	pxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType], cargoType.getYAIdentifier, "Cargo Type");
	cmifCriterion := pxyCriteria.getTransient();
	criteria.add(cmifCriterion);
	create pxyOpCrit transient;
	pxyOpCrit.setProxy(criteria, null);
	carrierSet.copy(pxyOpCrit.allCarriers);
	pxyOpCrit.setMyOperator(operator);
	app.myTrxCA.trxCreateObjMatchCrit(pxyOpCrit, realOpCrit, app.myPassport);
	self.assertTrueMsg(operator.allOperatorCarrierCriteria.size = 1, "Operator has no carrier criteria");
	
	mt := self.addContainer("UUT12345678", operator, "2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	self.move(mt, bs.myLocationsController);
	self.opts.purge();
	self.opts.addAssoc("ExpectErrors", true);

	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", mt, true, dualGate, null);
	
	// check to see that this has failed with error Opera_denie_carri_acces_cargo_
	foreach error in app.myPassport.allErrors do
		if error.errorCode &lt;= app.myRoot.baseErrorNum then
			self.assertTrueMsg(false, error.text);
			return;
		endif;	
	endforeach;

	foreach error in app.myPassport.allErrors do
		if error.errorCode = Opera_denie_carri_acces_cargo_ then
			foundError := true;
			break;
		endif;
	endforeach;
	if not foundError then
		self.assertTrueMsg(false, " error message not found");
	endif;

	// now add carrier DOUG to allowed list
	carrierSet.clear;
	carrierCode := self.getProfileStr(UT_Profile.P_CARRIER);
	dougCarrier := app.myRoot.allCarriers[carrierCode];
	carrierSet.add(dougCarrier);
	carrier := app.myRoot.allCarriers["CCC"];
	carrierSet.add(carrier);
	
	delete pxyOpCrit;
	app.cmsBeginLoad(ls);
	pxyOpCrit := realOpCrit.pxyCreateUpdateProxy().CM_OperatorCarrierCriteria;
	app.cmsEndLoad(ls);
	
	pxyOpCrit.allCarriers.clear;
	carrierSet.copy(pxyOpCrit.allCarriers);
	app.myTrxUA.trxUpdateObjMatchCrit(pxyOpCrit, app.myPassport);
	self.assertTrueMsg(operator.allOperatorCarrierCriteria.first.allCarriers.includes(dougCarrier), "DOUG Carrier not in operator carrier criteria");
	
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", mt, true, dualGate, null);
	
	// check to see that this has NOT failed with error Opera_denie_carri_acces_cargo_
	foundError := false;
	foreach error in app.myPassport.allErrors do
		if error.errorCode &lt;= app.myRoot.baseErrorNum then
			self.assertTrueMsg(false, error.text);
			return;
		endif;	
	endforeach;

	foreach error in app.myPassport.allErrors do
		if error.errorCode = Opera_denie_carri_acces_cargo_ then
			foundError := true;
			break;
		endif;
	endforeach;
	if foundError then
		self.assertTrueMsg(false, " error message found, there should not be one.");
	endif;

	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, mt);

	// Delete the road job 
	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Cancelled);
	self.assertFalse(mt.isPreNote);	// PAR 23675
epilog
	delete carrierSet;
	if criteria &lt;&gt; null then
		criteria.purge;
	endif;
	delete criteria;
	delete pxyOpCrit;
	
	// Make sure we always remove any restrictions at the end of this test
	if operator &lt;&gt; null then
		beginTransaction;
		operator.allOperatorCarrierCriteria.purge();
		commitTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseMTByIDWithStops" id="6e1aac2a-497d-4277-837f-7fc8990c7a67">
        <updating/>
        <source>tReleaseMTByIDWithStops() updating;
// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2010	cnwndl1	Initial creation	for Par 24448

*/

vars
	ti: CM_TrackedItem;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	mt: CM_Container;
	stopsTable : CM_StopsTable;
	selectedStopsTable : CM_StopsTable;
	stop : CM_Stops;
	term : CM_Terminal;
	controller : CMIF_FlexiGateController;
	pxyGateEntity, gateEntity: CMGTE_Entity;
	pxyVVR : CM_VehicleVisitRecord;
	activeStops : CM_StopsByIdDict;
	subTerm : CM_SubTerminal;
	
begin

	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");
	
	if bs = null then
		self.deleteTerminalArea("UTBS1");
		bs := self.addBlockStack("UTBS1", 100, null);
	endif;
	if dualGate = null then
		dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	endif;
	
	mt := self.addContainer("UUT12345678", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	self.move(mt, bs.myLocationsController);
	
	// find a relevant stop to use on the container. ( Not one that prevents it from being exported etc, or requires info to close and is valid for containers. )
	term := self.getTerminal();
	foreach stopsTable in app.myRoot.allStopsTable do
		if stopsTable.isNotAvailableForEntry then
			continue;
		endif;
		if stopsTable.requiresInfo then
			continue;
		endif;
		if not stopsTable.isStopRelevant(mt) then
			continue;
		endif;
		selectedStopsTable := stopsTable;
		break;
	endforeach;
	
	// check that we found a viable stopTable to use
	assertEqual(selectedStopsTable &lt;&gt; null, true);
	
	// add the stop to the container.
	addStop(mt, stopsTable);
	
	// check that the stop has been added.
	create activeStops transient;
	mt.getAllActiveStops(activeStops);
	assertEqual(activeStops.size, 1);
	
	
	// Create the Vehicle Visit Record
	vvr := addVehicleVisitRecord("UTTRUCK", null, "UTDRIVER", dualGate.name);
	
	// Create the GTE Entity and add to VVR
	create controller transient;
	create pxyGateEntity as CMGTE_Release transient;
	controller.myTerminal := term;
	controller.jobType := CMGTE_Entity.JobType_EmptyOUT;
	controller.numItems := 1;
	controller.id := mt.id;
	controller.isoTypeCode := mt.isoType;
	controller.operatorCode := mt.operatorCode;
	controller.cargoType := TI_CargoType_Container;
	controller.myVehicleVisitRecord := vvr;
	if app.isSubTerminalsOn(term) then
		subTerm := term.getDefaultSubTerminal(	CM_SubTerminal.Type_BulkRelease,
												null,	// cnwdad1 27/01/2010 - PAR #22205.
												0,
												null,
												false);
		if subTerm &lt;&gt; null then
			controller.subTerminalCode := subTerm.code;
		endif;
	endif;
	pxyGateEntity.setPXYFromController(controller); 
	pxyGateEntity.CMGTE_Release.setIsReleaseById(true);
	
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiGateEntity(vvr, pxyGateEntity, gateEntity, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyGateEntity;
	delete controller;
	
	// Complete the Gate Out - Road job is created
	pxyVVR := app.createUpdateProxy(vvr).CM_VehicleVisitRecord;
	self.ignoreTrxWarnings(true);
	app.myTrxCA.trxCreateInOutFlexiJob(pxyVVR, vvr,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
		
	// check that the container still has the stop on it.
	activeStops.clear;
	mt.getAllActiveStops(activeStops);
	assertEqual(activeStops.size, 1);
		
	// Delete the road job 
	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
		
	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");

epilog

	delete activeStops;
	delete pxyGateEntity;
	delete controller;
	delete pxyVVR;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseMTByIdFromArea" id="1244da36-c47c-460d-900c-32ae9f2c394e">
        <source>tReleaseMTByIdFromArea();
// cnwmp6
// 08/02/2010	cnwjre1
// copied from tReleaseMTById
vars
	ti: CM_TrackedItem;
	truck: CM_Vehicle;
