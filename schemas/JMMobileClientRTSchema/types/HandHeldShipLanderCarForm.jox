    <JadeMethod name="doShowFrmDamage" id="642dd46c-3400-451b-b5ac-1101d83ebf54">
        <updating/>
        <source>doShowFrmDamage() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	errorMsgs		: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	theTI : CM_TrackedItem;
begin
	create errorMsgs transient;

	if not app.myHandHeldCarGuiAgent.myHandHeldCarAgent.canDoCarDamage() then
		app.msgBox("Cargo Type 'CAR' is not setup to handle damage codes. See your administrator to allow this.", "Damaged", MsgBox_OK_Only);
		return;
	endif;
	theTI := app.myHandHeldCarGuiAgent.myHandHeldCarAgent.doConfirmTI(self.txtAltID.text.trimBlanks(), self.txtVehicle.text.trimBlanks(), errorMsgs);
	if theTI = null then
		app.msgBox("Please enter a valid car VIN", "Damaged", MsgBox_OK_Only);
		return;
	endif;
	if not errorMsgs.isEmpty then
		self.doApplyErrors(errorMsgs);
		self.fldMain.topSheet := self.shtError;
		return;
	endif;
	
	
	
	self.doHideFrm(self.frmMain);
	self.doShowFrm(self.frmDamage);
	
	self.btnDamageOK.default := true;
	self.btnDamageCancel.cancel := true;
	self.lblDamage.caption := 'Damage ' &amp; theTI.id;

	if theTI &lt;&gt; null then
		// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
		//self.tblDamage.setTableFromTI(theTI.allDamageInstances);
		self.tblDamage.setTableFromTI(theTI.allDamageInstancesByPos);
		self.txtDamage.text := theTI.remarks;
	endif;
	
	self.setLogicalFocus();
epilog
	delete errorMsgs;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowFrmMain" id="fcb2f242-ec8d-4c91-8012-0d6bc9077b0a">
        <updating/>
        <source>doShowFrmMain() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.doShowFrm(self.frmMain);
	self.doHideFrm(self.frmDamage);
	
	self.btnMove.default := true;
	self.btnLogOff.cancel := true;
	self.showingAftContainer := false;
	self.showingFowardContainer := false;
	self.setLogicalFocus();
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
