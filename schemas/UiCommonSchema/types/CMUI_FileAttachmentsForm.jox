    <JadeMethod name="getXMLSettingsForSave" id="6b78e943-ce36-438a-b7c5-35b7743abe76">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes

*/

vars

	xml		: String;
	
begin

	xml	:=	inheritMethod();
	
	xml := xml &amp; self.tblFiles.getXmlStrForColumns(false);  // ### TFS 55796 15DEC2022 NAVAB1
