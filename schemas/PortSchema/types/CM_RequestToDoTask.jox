<Class name="CM_RequestToDoTask" id="ed77d4f6-8f6a-47cc-b7b2-3cd6f72fb865">
    <superclass name="CM_ToDoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <ExplicitInverseRef name="myRequest" id="b7107275-b772-4c80-9c44-e7e53803ac8d">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_ToDoRequest"/>
        <access>readonly</access>
        <Inverse name="CM_ToDoRequest::allToDoTasks"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myWORequest" id="1becbc6d-4b8e-4ad1-995e-1dba812fba04">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_WOToDoRequest"/>
