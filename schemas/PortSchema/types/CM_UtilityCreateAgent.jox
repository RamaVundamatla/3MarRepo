// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valStopsTable(_proxyStopTable);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create _newStopTable persistent;
	_newStopTable.setForCreate(_proxyStopTable);
	
	if _passport.noErrors then
		app.myRoot.stopQueryPropertyAdd(_newStopTable, _passport);
	endif;
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newStopTable);
	endif;

end;</source>
