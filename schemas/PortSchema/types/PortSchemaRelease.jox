    <JadeMethod name="makeSystemObjectsStable" id="ae6d1e46-b5a1-4ebf-8ba6-892023f9ffe9">
        <source>makeSystemObjectsStable() protected;

/*

Purpose:			Make the required system objects stable to improve runtime performance.
					Will be called at the end of a standard release process

Parameters:			None

Return Value:		None


Date		Who		Reason
12 Apr 2010	cnwkpd1	PAR #23525 - System performance enhancements
24 Jan 2011	cnwkpd1	PAR #25822 - Make logging conditional for CM_ObjectVolatilityConverter

*/

vars
	ovc				: CM_ObjectVolatilityConverter;
	
begin
	create ovc transient;
	ovc.logMessages := true;
	ovc.createLogFile();
	ovc.makeSystemObjectsStable();
	
	
epilog
