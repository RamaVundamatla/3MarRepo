    <JadeMethod name="translateForm" id="86a1981f-5ed9-464b-9ccc-8c116f4c81a3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 30 September 2019 08:41:02.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006212, locale);
	btnConvert.translateBubbleHelp(Xlat_0002178, locale);
	btnConvert.translateCaption(Xlat_0002189, locale);
	btnInvoiceItems.translateBubbleHelp(Xlat_0002179, locale);
	btnInvoiceItems.translateCaption(Xlat_0002190, locale);
	btnNext.translateBubbleHelp(Xlat_0002180, locale);
	btnNext.translateCaption(Xlat_0002191, locale);
	btnNormal.translateBubbleHelp(Xlat_0002181, locale);
	btnNormal.translateCaption(Xlat_0002192, locale);
	btnQueryCargo.translateBubbleHelp(Xlat_0002182, locale);
	btnQueryCargo.translateCaption(Xlat_0002193, locale);
	btnRatesAll.translateBubbleHelp(Xlat_0002183, locale);
	btnRatesAll.translateCaption(Xlat_0002194, locale);
	btnRatesOR.translateBubbleHelp(Xlat_0002184, locale);
	btnRatesOR.translateCaption(Xlat_0002195, locale);
	btnSearchCargo.translateCaption(Xlat_0023746, locale);
	btnShowInvoice.translateBubbleHelp(Xlat_0002185, locale);
	btnShowInvoice.translateCaption(Xlat_0002196, locale);
	cmbCargoSite_.translateBubbleHelp(Xlat_0002186, locale);
	cmbCargoType_.translateBubbleHelp(Xlat_0002187, locale);
	cmbCargoVoyage_.translateBubbleHelp(Xlat_0002188, locale);
	lblCargoID_.translateCaption(Xlat_0002197, locale);
	lblCargoSite_.translateCaption(Xlat_0002198, locale);
	lblCargoType_.translateCaption(Xlat_0002199, locale);
	lblCargoVoyage_.translateCaption(Xlat_0002200, locale);
	lblInvLineTypeQu.translateCaption(Xlat_0020199, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotificationUpdate" id="76743be2-15fc-43cd-9de7-10285ec4119f">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _noteobj : CM_Object; _obj: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29 Mar 2023	navmv20 Bug 57023: EUP - inconsistent search behaviour with external number
// 12 April 2023  navmv20 TFS 55304 Task 55544: Jade - Invoice Line Copy Audits

vars
	cashPayment		: CM_CashPayment;
	theInvoiceLine : CM_InvoiceLine;
	theInvoice : CM_Invoice;
	theDataLine : String;
	idx : Integer;
begin

	if _obj = null then
		return;
	endif;
	if _event = Event_InvoiceLineUpdate then
		theInvoiceLine := _obj.CM_InvoiceLine;
		self.tblData.findObjectInRow(theInvoiceLine,idx);
		if idx &gt; self.tblData.fixedRows then
			theDataLine := theInvoiceLine.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			self.tblData.accessCell(idx, 1).text := theDataLine;
		// from 35232 refresh associated payments from status change as well
			foreach cashPayment in theInvoiceLine.allCashPayments do
				idx := 1;
				self.tblData.findObjectInRow(cashPayment, idx);
				if idx &gt; self.tblData.fixedRows then
					theDataLine := cashPayment.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
					self.tblData.accessCell(idx, 1).text := theDataLine;
				endif;
			endforeach;
// ### TFS BUG 62926 02APR2024 NAVAB1			self.setEnableObjects();
		endif;
	//12/04/2023 navmv20 TFS 55304 Task 55544 - start
	elseif _event = Event_InvoiceLineCreate then
		theInvoiceLine := _obj.CM_InvoiceLine;
		if self.includeLine(theInvoiceLine) then
			self.doQueryAddLine(theInvoiceLine);
		endif;
	//12/04/2023 navmv20 TFS 55304 Task 55544 - end
	// from 35232 refresh payment from status change
	elseif _event = Event_CashPaymentUpdate then
		cashPayment := _obj.CM_CashPayment;
		self.tblData.findObjectInRow(cashPayment, idx);
		if idx &gt; self.tblData.fixedRows then
			theDataLine := cashPayment.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			self.tblData.accessCell(idx, 1).text := theDataLine;
			self.setEnableObjects();
		endif;
	elseif _event = Event_InvoiceUpdate then
		self.myCurrentInvoice := _obj.CM_Invoice;
		self.textSearch.text := self.myCurrentInvoice.sequenceNum.String;
		//self.optSearchInvoice.value := true; //29/03/2023 navmv20 Bug 57023
		self.cmbSearchFor.findStringExact(1,app.getErrorString(Invoice_invoice_number)); //29/03/2023 navmv20 Bug 57023
		self.doQuery();
	endif;
end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
</GUIClass>
