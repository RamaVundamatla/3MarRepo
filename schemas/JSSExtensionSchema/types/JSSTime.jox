    <DbClassMap file="jssxs_datavalue_primitive"/>
    <PrimAttribute name="timeClient" id="426a559b-5193-4a8d-aefe-cdb0205cd368">
        <embedded/>
        <type name="Time"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="timeServer" id="5dbf434b-89ce-4026-b33b-3ac288b745cb">
        <embedded/>
        <type name="Time"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addHours" id="8038ff8a-fa76-48f7-9d64-531aedaaf658">
        <updating/>
        <source>addHours(pHours:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.timeClient	:=	self.timeClient.jssAddHours(pHours);
end;</source>
        <Parameter name="pHours" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addMinutes" id="45bfe04d-d152-435a-b945-0dbeb8a3f8d1">
        <updating/>
        <source>addMinutes(pMinutes:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.timeClient	:=	self.timeClient.jssAddMinutes(pMinutes);
end;</source>
        <Parameter name="pMinutes" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addSeconds" id="cc9273e9-0bb7-4066-9d65-940ede0058eb">
        <updating/>
        <source>addSeconds(pSeconds:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.timeClient	:=	self.timeClient.jssAddSeconds(pSeconds);
end;</source>
        <Parameter name="pSeconds" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="e8376bf3-5ca9-44d0-9ec6-567bb02b0b8b">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setTimeClient();
	self.setTimeServer();
end;</source>
    </JadeMethod>
    <JadeMethod name="setTimeClient" id="5a85aa06-1060-481a-bb0e-1f84857730cb">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setTimeClient() updating, protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTime	: Time;
	
begin
	self.timeClient	:=	currentTime;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTimeServer" id="61fd3809-10c7-4996-b861-788e2f65deb5">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>setTimeServer() updating, protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTime	: Time;
	
begin
	self.timeServer	:=	currentTime;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateMe" id="f90b2903-872a-4e2a-9fc2-5435cec30c1a">
        <updating/>
        <source>updateMe(pTime:Time) updating;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.timeClient &lt;&gt; pTime then
		self.timeClient	:=	pTime;
	endif;
end;</source>
        <Parameter name="pTime" type="Time"/>
    </JadeMethod>
</Class>
