    <JadeMethod name="doComboVoyageBuild" id="a7ff832e-0b4c-4884-81b5-526f0ce80ad0">
        <updating/>
        <source>doComboVoyageBuild() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aVoyage 	: CM_Voyage;
	idx 		: Integer;
	voyDict		: CM_VoyageByCodeArrivalDT;
	cmb			: CMUI_ComboBox;
begin
	voyDict := self.myTerminal.allVoyagesByCode;
	cmb := self.cmbVoyage;
	cmb.clear;
	
	foreach aVoyage in voyDict do
		if aVoyage.myCellularVoyageStructure = null then
			continue;
		endif;
		if aVoyage.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;		
		cmb.itemObject[cmb.addItem(aVoyage.getDisplayDetails(false))] := aVoyage;
	endforeach;
	
	//cnwjo3 par 23105
	aVoyage := app.getMyCurrentVoyage();
	
	if aVoyage &lt;&gt; null and aVoyage.myCellularVoyageStructure &lt;&gt; null then
		cmb.listIndex := cmb.findObject(aVoyage);
		self.myCurrentVoyage := aVoyage;
		self.setCaption(app.getErrorString(TBAList) &amp; " " &amp; self.myCurrentVoyage.code);
		self.setNavigatorHeading(self.caption);
		beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Event_TBA_Create), Response_Continuous, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doComboVoyageClick" id="524a0594-68cc-4b5d-8972-801f67ed6385">
        <updating/>
        <source>doComboVoyageClick(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
begin
	self.myCurrentVoyage := combobox.itemObject[combobox.listIndex].CM_Voyage;
	self.doShowButtons(false);
	//if app.myCurrentVoyage &lt;&gt; self.myCurrentVoyage then
	//cnwjo3 par 23105
	if app.getMyCurrentVoyage() &lt;&gt; self.myCurrentVoyage then
		//app.myCurrentVoyage := self.myCurrentVoyage;
		//cnwjo3 par 23105
		app.setMyCurrentVoyage(self.myCurrentVoyage);
		beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(Event_TBA_Create), Response_Continuous, null);
	endif;
	self.setCaption(app.getErrorString(TBAList) &amp; " " &amp; self.myCurrentVoyage.code);
	self.setNavigatorHeading(self.caption);

	self.btnNew.enabled := true;
	// TFS 45590 self.displayTable();
	self.doQuery(); // TFS 45590

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditItem.enabled := false;
		self.btnDelete.enabled := false;
		self.btnRemarks.enabled := false;
		self.btnNew.enabled:= false;

	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="897140a9-1b78-458a-aa3c-55dde6bc1767">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
	theResult : Integer;
	result : Boolean;
	theObject : Object;
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if not app.myCurrentUserCan(self.myTerminal,PmAdmTbalistMaint) then
		return;
	endif;	
	theObject := self.tblData.accessRow(self.tblData.row).itemObject;
	if theObject &lt;&gt; null and theObject.isKindOf(CM_TrackedItem) then
		theTI := theObject.CM_TrackedItem;

		theResult := app.msgBox("Delete TBA " &amp; theTI.id &amp; " on voyage " &amp; self.cmbVoyage.text.trimBlanks  &amp; "?", "Delete Attribute Plan",MsgBox_Yes_No);
		if theResult = MsgBox_Return_Yes then
		
			//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxDA.trxDeleteTITba(theTI, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Todo Task', app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				return;
				
			endwhile;
			
		endif;
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;


end;</source>
    </JadeMethod>
    <JadeMethod name="doEditItem" id="ba772d43-199c-4384-8781-2b262949112a">
        <updating/>
        <source>doEditItem() updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
	theRow : Integer;
	table : CM_DataTable;
begin
	table := self.tblData;
	inheritMethod();
	
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	theTI := table.accessRow(table.row).itemObject.CM_TrackedItem;
	if theTI &lt;&gt; null then
		self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, true);	
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuInspectObject" id="78eff5e0-da3e-428d-9532-8488c8c794dd">
        <source>doMnuInspectObject();
//--------------------------------------------------
// Created:	12 December 2003 By: cnwgd1
//--------------------------------------------------
vars
	theTI : CM_TrackedItem;
	theRow : Integer;
	table : CM_DataTable;
begin
	table := self.tblData;
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	theTI := table.accessRow(table.row).itemObject.CM_TrackedItem;
	if theTI &lt;&gt; null then
		theTI.inspectModal;
	elseif self.myCurrentVoyage &lt;&gt; null then
		self.myCurrentVoyage.inspectModal;
	else
		inheritMethod();
	endif;

end;</source>
    </JadeMethod>
