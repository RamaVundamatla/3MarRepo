    <JadeMethod name="getGroundPlacedExpROROConts" id="f8fcf2c6-67e0-42cb-9d42-fefbb3eebb2f">
        <source>getGroundPlacedExpROROConts(_tiSet : CM_TISet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 September 2022	jlizm1	Initial creation TFS 54702 CUX MAFI Auto Queueing
01 August 2024		jlizm1	TFS 65492 Issues with requeueing containers already queued

*/

vars
	iter : Iterator;
	ti  : CM_TrackedItem;
	
begin

	if self.myROROStructure = null or self.myCellularVoyageStructure &lt;&gt; null then
		return;
	endif;
	
	iter := self.allOnsiteTIsByCargoTypeId.createIterator();
	self.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_Container, "", iter);
	
	while iter.next(ti) do
		if not ti.isContainer then
			break;
		endif;
		
		if not ti.isExport
		or ti.isOnMAFI
		or ti.isPlanned(REAL_MODE) then
			continue;
		endif;
		
		_tiSet.add(ti);
	endwhile;
	
	return;
	
epilog

end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getHolds" id="40e9c563-e0b0-47d3-96ec-896621d4c019">
        <source>getHolds(_lcSet : CM_LCSet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jan 2023 navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request

*/

vars
	tmpDict 			: CM_GeneralCCtrByHatchPlaceDict;
	hatch 				: CM_LocationsController;
begin
	if self.myShipBlockStack &lt;&gt; null then
		_lcSet.addNoDuplicates(self.myShipBlockStack,false);
	endif;
	
	if self.myGeneralCargoVoyage &lt;&gt; null then
		tmpDict := self.myGeneralCargoVoyage.allLocationsByHatchPlace;
	
		foreach hatch in tmpDict discreteLock, reversed do
			_lcSet.addNoDuplicates(hatch,false);		
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_lcSet" type="CM_LCSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getHoursAtBerth" id="62453f4e-6299-42d4-a455-b623f7abd512">
        <source>getHoursAtBerth():Decimal;
/*
	Purpose:		Returns time at berth in hours (e.g 12.75 hours)		
	Parameters:			
	Return Value:		

Date			Who		Reason
05 August 2008	concms1	PAR 17593 Initial creation
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	ts				:TimeStamp;
	milliseconds	:Integer64;
begin
	if self.arrivedDT = null then
		return null;	// not arrived yet
	endif;
	
	ts := self.departedDT;
	
	if ts = null then
		ts := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif; 
	
	milliseconds := (ts - self.arrivedDT).getMilliseconds; 
	
	return (milliseconds/MillisecondsPerHour).roundedTo (2);
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getHoursAtBerth_HHMM" id="82fe5aac-52e9-4e46-858f-579f59bc1f66">
        <source>getHoursAtBerth_HHMM():String;
/*
	Purpose:		Returns time at berth in hours/minutes (e.g 12:45 = 12 hours 45 minutes)		
	Parameters:			
	Return Value:		

Date			Who		Reason
05 August 2008	concms1	PAR 17593 Initial creation
*/

vars
	
begin
	return self.getHoursAtBerth.asHoursMinutes;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getId" id="ed4351d9-260e-4a9f-bd6d-977d265587ab">
        <source>getId(): String;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
