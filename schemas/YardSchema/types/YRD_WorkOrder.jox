    <JadeMethod name="buildListTasks" id="00909616-7129-4faf-85c6-1605eb542c5d">
        <source>buildListTasks(_newTask : CM_WorkOrderDtl);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1  ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	cargoRequest : CM_WodCargoRequest;
	wodtl 		: CM_WorkOrderDtl;
	idx,
	pos 		: Integer;
	firtCargoWod : CM_WorkOrderDtl;
	listWod : CM_WorkOrderDtl;
	
begin
	self.lstTasks.clear();
	
	if self.myPxyWorkOrder.allWoDtls &lt;&gt; null then
		foreach wodtl in self.myPxyWorkOrder.allWoDtls do
			pos := pos + 1;
			if wodtl.isKindOf(CM_WodVoyageCargoRequest) then
				firtCargoWod := self.myPxyTask.CM_WodVoyageCargoRequest.allCargoDetails.first;

				foreach wodtl in self.myPxyTask.CM_WodVoyageCargoRequest.allCargoDetails do
				self.lstTasks.addObjectAt(wodtl.getDisplayString(true), pos, wodtl, 1, false);
				endforeach;
			else
				self.lstTasks.addObjectAt(wodtl.getDisplayString(true), pos, wodtl, 1, false);
			
				if wodtl.isKindOf(CM_WodPermitRequest) then
					if wodtl.CM_WodPermitRequest.permitType = INV_WO_PERMIT_CARGOPENALTY 
					or wodtl.CM_WodPermitRequest.permitType = INV_WO_PERMIT_CARGONOPENALTY then
						foreach cargoRequest in wodtl.CM_WodPermitRequest.allCargoDetails do
							idx := self.lstTasks.addItem(cargoRequest.getDisplayString(false));
							self.lstTasks.itemObject[idx]:=cargoRequest;
						endforeach;
						
					endif;
				endif;
			endif;
		endforeach;
	endif;
	
	if _newTask.isKindOf(CM_WodVoyageCargoRequest) then
		listWod := firtCargoWod;
	else
		listWod := _newTask;
	endif;

	if listWod &lt;&gt; null then
		self.lstTasks.listObject := listWod;
		self.lstTasks.selectObject(listWod);
		if listWod.isKindOf(CM_WodCargoRequest) then
			self.lstTasks.click(self.lstTasks);		// 27 may 2022 navgm20 TFS 52351 
		endif;
		
	else
		if self.lstTasks.listCount &gt; 0 then
			self.lstTasks.listIndex := 1;
			//self.lstTasks.click(self.lstTasks);		 
		endif;
	endif;
	
	//self.enableTaskActions();
epilog

end;</source>
        <Parameter name="_newTask" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="buildListToDoTasks" id="6844c6a5-5819-4a12-9c63-1941ad8f6be5">
        <source>buildListToDoTasks(_cargoType : CM_CargoType);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Mar 2022	navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
06 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
30 Mar 2023 navhl20	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
20 Apr 2023 navma1  ChangeRequest 57324:[57325] EUP - VAS Task linked with Release Cargo Work Order
24 Apr 2024	navhl20	ChangeRequest 63634: EUP | FR - VAS Work Order Transactions - 2
30 Jul 2024 navhl20	ChangeRequest 65468: EUP -  VAS Mobile App - Enable Remarks for ToDo Tasks on Cargo Work Orders
22 May 2025	navbs1	ChangeRequest 34819: MTN - Filtered Group Box Changes
*/

vars
	taskDict 		: CM_ToDoTaskDescByCode;
	todoSet  		: CM_ToDoTaskDescSet;
	cnt		 		: Integer;
	toDoTaskDescType: Integer;
	wod				: CM_WorkOrderTIDtl;
	wodToDo			: CM_WodToDo;
begin
	
	if not self.shtToDoTasks.visible   then
		return;
	endif;
	
	toDoTaskDescType := self.myPxyTask.getToDoTaskDescType();			
	
	create taskDict transient;
	app.myPassport.myUser.getToDoTaskDescList( taskDict,_cargoType,self.myTerminal, toDoTaskDescType);	//06.03.2023 navma1 #56457:[56458] //17.04.2023 navma1 #57324:[57325]
	self.mulToDoTasks.setVisibleButtons(false,false,false);										//22.05.2025 navbs1 #34819
	self.mulToDoTasks.setupControl( "Tasks", taskDict, YRD_TaskJobTasks::getTaskDescription.name );
	
	self.mulToDoTasks.myAvailableListBox.sorted := true;
	self.mulToDoTasks.mySelectedListBox.sorted  := true;
	self.mulToDoTasks.setSelected( null );
	self.mulToDoTasks.cnEcResizeContents();			//1.6.2022 navma1 #52351
	
	/*Populate  Selected ToDo Tasls*/
	
	if self.myPxyTask &lt;&gt; null  and self.myPxyTask.isWorkOrderTIDtl then
		wod := self.myPxyTask.CM_WorkOrderTIDtl;									//30.07.2024 navhl20 #65468
		if  not wod.allToDoRequests.isEmpty and
			wod.canAddTodoTaskToCargoWO then
			create todoSet transient;
			wodToDo := wod.allToDoRequests.first.CM_WodToDo;
			cnt := wodToDo.allToDoTasksDescs.size;									//30.3.2023 navhl20	#56614[56615];
			if cnt &gt; 0 then
				wod.getAllToDoTaksDescsUsed( todoSet );
			endif;
		
			if cnt &gt; 0 then
				self.mulToDoTasks.setSelected( todoSet );
				self.shtToDoTasks.caption := 'ToDo Tasks [' &amp; cnt.String &amp;']';
			endif;
			
			self.txtToDoRemarks.text := wodToDo.remarks;							//30.07.2024 navhl20 #65468
			if wodToDo.priority = CM_WorkOrder.WO_Priority_High then				//30.07.2024 navhl20 #65468
				self.chkPriority.value := true;
			else
				self.chkPriority.value := false;
			endif;	
		endif;
	endif;
	self.hideVASControl();															//24.04.2024 navhl20 #63634
	
	self.mulToDoTasks.enabled := not self.isApproved;								//06.03.2023 navma1 #56457:[56458]
epilog
	delete taskDict;
	delete todoSet;
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="buildListVasNonOperational" id="a468ab90-992b-4e99-8738-7db6c0a2820a">
        <source>buildListVasNonOperational();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2022	navcs2	ChangeRequest 56632:[56057] EUP - VAS Non Operational Work Order
20 Mar 2023  		navhl20 Defect 57233: MTN - Editing Vas Tasks is not working correctly
22 Mar 2023			navhl20 Defect 57231: MTN - WO - Available debtors disappears when selecting an operator while creating a Non Operational to do work order
05/04/2023	navcs2	ChangeRequest 57299:[57300]: EUP - Create new filter multi-select group box control
14 April 2023		navcs2	Defect 57574: MTN - WO - The filter text is not getting cleared when selecting a new work order task


*/
constants
	ENTITYName :String = "Operators";
	SecondaryENTITYName :String = "Debtors";
vars
	debtorSet 	: CM_DebtorNodeByNameDict;
	cnt		 	: Integer;
	theBank 	: CM_Bank;
	rdg			: CM_RootDebtorGroup;
	debtorNode	: CM_DebtorNode;
	operatorSet,
	oprSet		: CM_OperatorSet;
	debtor 		: CM_Debtor;
	operator	: CM_Operator;
begin
	self.mulToDoSecondaryEntites.visible := true;
	self.adjustMulTablesHeights(true);
	
	if not self.shtDetails.visible   then
		return;
	endif;
	
	/**
	build the operators multi select box 
	**/
	
	create operatorSet transient;
	//self.myTerminal.myRoot.allOperators.copy(operatorSet);																//20.3.2023 navhl20	#57233
	self.getListOperators(operatorSet,false);																				//20.3.2023 navhl20	#57233
	self.mulToDoSecondaryEntites.setupControl( ENTITYName, operatorSet, YRD_WorkOrder::getOperatorsDescription.name );		//05/04/2023 navcs2	#57299:[57300]
	
	self.mulToDoSecondaryEntites.top := 20;																					// 14.04.2023 navcs2 Defect 57574 
	self.mulToDoSecondaryEntites.myAvailableListBox.sorted := true;
	self.mulToDoSecondaryEntites.mySelectedListBox.sorted  := true;
	self.mulToDoSecondaryEntites.setSelected( null );
	self.mulToDoSecondaryEntites.cnEcResizeContents();
	
	self.mulToDoSecondaryEntites.caption := ENTITYName;																		//05/04/2023 navcs2	#57299:[57300]
	self.shtEntity.caption := "Non Operational";
	
	
	/**
	build the debtors multi select box 
	**/
	
	create debtorSet transient;
	theBank := app.myRoot.myRootCompany;
	rdg := theBank.getRootDebtorGroup();
	
	foreach debtorNode in rdg.allChildDebtorNodes where debtorNode.isGroup = false do
		debtorSet.add(debtorNode);
	endforeach;
	
	self.mulToDoEntity.setupControl( SecondaryENTITYName, debtorSet, YRD_WorkOrder::getDebtorDescription.name );			//05/04/2023 navcs2	#57299:[57300]
	
	self.mulToDoEntity.top := 210;																							// 14.04.2023 navcs2 Defect 57574
	self.mulToDoEntity.myAvailableListBox.sorted := true;	
	self.mulToDoEntity.mySelectedListBox.sorted  := true;
	self.mulToDoEntity.availableHeading 			:= app.getErrorString(Available_debtors);
	self.mulToDoEntity.selectedHeading  			:= app.getErrorString(Selected_debtors);
	self.mulToDoEntity.setSelected( null );
	self.mulToDoEntity.cnEcResizeContents();
	
	self.mulToDoEntity.caption := SecondaryENTITYName;																		//05/04/2023 navcs2	#57299:[57300]
	
	/*Populate  Selected Debtors*/
	if self.myPxyTask &lt;&gt; null  then
		if  self.myPxyTask.isKindOf(CM_WodToDoNonOperational) then
			cnt := self.myPxyTask.CM_WodToDoNonOperational.allDebtors.size;
		endif; 
		
		create oprSet transient;															//22.3.2023 navhl20	#57231
		foreach debtor in self.myPxyTask.CM_WodToDoNonOperational.allDebtors do				//22.3.2023 navhl20	#57231
			foreach operator in debtor.operators do
				oprSet.addNoDuplicates(operator,false);
			endforeach;
		endforeach;
		
		if oprSet.isNotEmpty() then															//22.3.2023 navhl20	#57231
			self.mulToDoSecondaryEntites.setSelected( oprSet );
			self.updateDebtorSelectionBox();
		endif;
		
		if cnt &gt; 0 then
			self.mulToDoEntity.setSelected( self.myPxyTask.CM_WodToDoNonOperational.allDebtors );
			self.shtEntity.caption := 'Debtors [' &amp; cnt.String &amp;']';
		endif;
	endif;

epilog
	delete debtorSet;
	delete oprSet;
	delete operatorSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildListVasToDoTasks" id="dadb67f4-4b76-4f3a-ad90-c89f1d194499">
        <source>buildListVasToDoTasks();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Dec 2022	navcs2	ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
14 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
20 Mar 2023 navma1  Defect 57195: MTN - WO - Priority is showing some random number on the to do work orders on the yard operations form  
23 Apr 2024 navbs1  ChangeRequest 63634: EUP | FR - VAS Work Order Transactions - 2
22 May 2025	navbs1	ChangeRequest 34819: MTN - Filtered Group Box Changes
*/

vars
	taskDict			: CM_ToDoTaskDescByCode;
	toDoTaskDesc		: CM_ToDoTaskDesc;
	cnt		 			: Integer;
	task	 			: CM_WorkOrderToDoDtl;
	toDoTaskDescType	: Integer;
begin
	
	if self.myPxyTask &lt;&gt; null then
		task := self.myPxyTask.CM_WorkOrderToDoDtl;
	endif;
	
	if not self.shtDetails.visible   then
		return;
	endif;
	
	if task = null then										//14.03.2023 navma1 #56457:[56458]
		return;
	endif;
	
	toDoTaskDescType := task.getToDoTaskDescType();			//14.03.2023 navma1 #56457:[56458]
	
	create taskDict transient;
	app.myPassport.myUser.getToDoTaskDescList( taskDict,null,self.myTerminal, toDoTaskDescType);	//06.03.2023 navma1 #56457:[56458]
	
	self.mulToDoTasks.setVisibleButtons(false,false,false);										//22.05.2025 navbs1 #34819
	self.mulToDoTasks.setupControl( null, taskDict, YRD_TaskJobTasks::getTaskDescription.name );
	
	self.mulToDoTasks.myAvailableListBox.sorted := true;
	self.mulToDoTasks.mySelectedListBox.sorted  := true;
	self.mulToDoTasks.availableHeading 			:= app.getErrorString(Available_tasks);
	self.mulToDoTasks.selectedHeading  			:= app.getErrorString(Selected_tasks);
	self.mulToDoTasks.setSelected( null );
	self.mulToDoTasks.cnEcResizeContents();	
		
	// Populate  Selected ToDo Tasks
	if task &lt;&gt; null  then
		if  task.isKindOf(CM_WorkOrderToDoDtl) then
			cnt := task.CM_WorkOrderToDoDtl.allToDoTasksDescs.size;
		endif; 
		
		if cnt &gt; 0 then
			self.mulToDoTasks.setSelected(  task.CM_WorkOrderToDoDtl.allToDoTasksDescs );
			self.shtDetails.caption := 'Todo Tasks [' &amp; cnt.String &amp;']';
		endif;
	else
		self.shtDetails.caption := 'Todo Tasks';
	endif;
	
	if self.isApproved then						//20.03.2023 navma1 #57195
		self.mulToDoTasks.enabled := false;
	endif;
	
	self.hideVASControl();						//24.04.2024 navhl20 #63634
epilog
	delete taskDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildListVasTrains" id="576b3697-c47f-45fa-bdfe-004c5dcdf759">
        <source>buildListVasTrains();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2022	navcs2	ChangeRequest 56833:[56834] EUP - VAS Train Work Order
20 Mar 2023  		navhl20 Defect 57233: MTN - Editing Vas Tasks is not working correctly
05/04/2023	navcs2	ChangeRequest 57299:[57300]: EUP - Create new filter multi-select group box control

*/
constants
	ENTITYName :String = "Trains";
vars
	trainSet,
	trainSetProxies : CM_TrainSet;
	cnt : Integer;
begin
	self.mulToDoSecondaryEntites.visible := false;
	self.adjustMulTablesHeights(false);
	
	if not self.shtEntity.visible   then
		return;
	endif;
	
	create trainSet transient;
	//self.myTerminal.allTrainsOnTerminal.copy(trainSet);												//20.3.2023 navhl20	#57233
	self.getListTrains(trainSet,false);																	//20.3.2023 navhl20	#57233
	self.mulToDoEntity.setupControl( ENTITYName, trainSet, YRD_WorkOrder::getTrainDescription.name);	//05/04/2023 navcs2	#57299:[57300]
	
	self.mulToDoEntity.myAvailableListBox.sorted := true;
	self.mulToDoEntity.mySelectedListBox.sorted  := true;
	self.mulToDoEntity.setSelected( null );
	self.mulToDoEntity.cnEcResizeContents();	
	
	self.shtEntity.caption := ENTITYName;																//05/04/2023 navcs2	#57299:[57300]
	self.mulToDoEntity.caption := ENTITYName;															//05/04/2023 navcs2	#57299:[57300]
	
	
	// Set the proxies trains if they exist
	if self.myPxyTask &lt;&gt; null  then
		create trainSetProxies transient;
		if  self.myPxyTask.isKindOf(CM_WodToDoTrain) then
			cnt := self.myPxyTask.CM_WodToDoTrain.allTrains.size;
		endif; 
		
		if cnt &gt; 0 then
			//self.mulToDoTasks.setSelected( self.myPxyTask.CM_WodToDoTrain.allTrains );
			self.mulToDoEntity.setSelected( self.myPxyTask.CM_WodToDoTrain.allTrains );
			self.shtToDoTasks.caption := 'Trains [' &amp; cnt.String &amp;']';
		endif;
		
	endif;
epilog
	delete trainSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildListVasTrucks" id="b8c45284-7386-4004-8acd-ef710fa990fd">
        <source>buildListVasTrucks();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2022	navcs2	ChangeRequest 56835:[56836] EUP - VAS Truck Work Order
05/04/2023	navcs2	ChangeRequest 57299:[57300]: EUP - Create new filter multi-select group box control

*/

constants
	ENTITYName :String = "Vehicle Visits";
vars
	vvSet	 		: CM_VehicleVisitRecordSet;
	cnt		 		: Integer;
	vehicleBookings : CM_VehicleBookingTimeSlotById;
	
begin
	self.mulToDoSecondaryEntites.visible := false;
	self.adjustMulTablesHeights(false);
	
	if not self.shtDetails.visible   then
		return;
	endif;
	
	create vvSet transient;
	self.myTerminal.allVehicleVisitsByNumDT.copy(vvSet);
	self.mulToDoEntity.setupControl( ENTITYName, vvSet, YRD_WorkOrder::getVehicleVisitDescription.name );	//05/04/2023 navcs2	#57299:[57300]
	
	self.mulToDoEntity.myAvailableListBox.sorted := true;
	self.mulToDoEntity.mySelectedListBox.sorted  := true;
	self.mulToDoEntity.setSelected( null );
	self.mulToDoEntity.cnEcResizeContents();	
	
	self.mulToDoEntity.caption := ENTITYName;																//05/04/2023 navcs2	#57299:[57300]
	self.shtEntity.caption := ENTITYName;																	//05/04/2023 navcs2	#57299:[57300]
	
	/*Populate  Selected Debtors*/
	if self.myPxyTask &lt;&gt; null  then
		if  self.myPxyTask.isKindOf(CM_WodToDoVehicleVisit) then
			cnt := self.myPxyTask.CM_WodToDoVehicleVisit.allVehicleVisits.size;
		endif; 
		
		if cnt &gt; 0 then
			self.mulToDoEntity.setSelected( self.myPxyTask.CM_WodToDoVehicleVisit.allVehicleVisits );
			self.shtEntity.caption := 'Vehicle Visits [' &amp; cnt.String &amp;']';
		endif;
		
	endif;
epilog
	delete vvSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildListVasVBSlots" id="b7bde0bc-49b2-4da9-83b7-43002e14054c">
        <source>buildListVasVBSlots();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Dec 2022	navcs2	ChangeRequest 56835:[56836] EUP - VAS Truck Work Order
23 Mar 2023 navma1	Bug 57256: MTN - WO - Vehicle Booking Timeslot task can be deleted once added
23 Mar 2023 navma1  Bug 57255: MTN - WO - Issues when creating Vehicle Booking Work order

*/
constants
	ENTITYName :String = "Vehicle Bookings";
vars
	vbsSet,
	vbsSetProxies : CM_VehicleBookingTimeSlotById;
	cnt			  : Integer;
	isMax		  : Boolean;
begin

	self.mulToDoSecondaryEntites.visible := false;
	self.adjustMulTablesHeights(false);
	
	if not self.shtEntity.visible   then
		return;
	endif;
	
	create vbsSet transient;
	self.myTerminal.myVehicleBookingTerminal.allVBTimeslotsById.copy(vbsSet);
	self.mulToDoEntity.setupControl( ENTITYName, vbsSet, YRD_WorkOrder::getVBSDescription.name); //23.03.2023 navma1 #57255
	
	self.mulToDoEntity.myAvailableListBox.sorted 	:= true;
	self.mulToDoEntity.mySelectedListBox.sorted  	:= true;
	self.mulToDoEntity.setSelected( null );
	self.mulToDoEntity.cnEcResizeContents();	
	
	self.shtEntity.caption 		:= ENTITYName;
	self.mulToDoEntity.caption  := ENTITYName;
	
	
	// Set the proxies VB Slots if they exist
	if self.myPxyTask &lt;&gt; null  then
		if  self.myPxyTask.isKindOf(CM_WodToDoVBS) then
			cnt := self.myPxyTask.CM_WodToDoVBS.allVBSSlots.size;
		endif; 
		
		if cnt &gt; 0 then
			self.mulToDoEntity.setSelected( self.myPxyTask.CM_WodToDoVBS.allVBSSlots );
			self.shtEntity.caption :=  ENTITYName &amp;' [' &amp; cnt.String &amp;']';
		endif;
		
	endif;
epilog
	delete vbsSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildListVasVoyages" id="eaf13cb4-e9bd-4a54-9ad7-6adfd36ac9a4">
