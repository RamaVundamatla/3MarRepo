    <JadeMethod name="convertForResetData" id="9ac93dbc-e0ca-425c-bad9-565aed5e0e5e">
        <updating/>
        <source>convertForResetData()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2019	jlgndl1	Initial creation	TFS 43018

*/

vars

	localResetValue : Integer;
	localDate : Date;
	yyInt : Integer;
	mmString : String;
	mmInt : Integer;
	day : Integer;
	month : Integer;
	year : Integer;

begin

	if self.lastGeneratedDate.isValid then
		//Its alreday been converted
		return;
	endif;
	
	localDate := app.actualTimeAppServer.Date;
	day := localDate.day;
	month := localDate.month;
	year := localDate.year;
	
	if self.isExternalNumber
	or self.isExternalReceiptNumber
	or self.isPaymentId
	or self.isTaxNumber
	then
		localResetValue := self.Reset_On_Year_Chg_Int;
		
	elseif self.isVoyageWorkOrderId then
		localResetValue := self.Reset_On_Year_Chg_Int;
	
	else
	
		if self.idStyle = AutoIdStyle_P_YY_SSS
		or self.idStyle = AutoIdStyle_YY_SSS
		or self.idStyle = AutoIdStyle_P_MM_YY_SSS
		or self.idStyle = AutoIdStyle_P_YY_MM_SSS
		then
			localResetValue := self.Reset_On_Year_Chg_Int;
			
			if self.idStyle = AutoIdStyle_P_MM_YY_SSS
			or self.idStyle = AutoIdStyle_P_YY_MM_SSS
			then
				//try and get the 'MM' value
				if self.lastIdGenerated &lt;&gt; null and self.lastIdGenerated.length &gt; ( self.idPrefix.length + 4 ) then
					//try to make sure the prefix still matches the last generated ids prefix
					if self.lastIdGenerated[1:self.idPrefix.length] = self.idPrefix then
						if self.idStyle = AutoIdStyle_P_MM_YY_SSS then
							mmString := self.lastIdGenerated[self.idPrefix.length + 1:2];
						elseif self.idStyle = AutoIdStyle_P_YY_MM_SSS then
							mmString := self.lastIdGenerated[self.idPrefix.length + 3:2];
						endif;
						if mmString.isInteger then
							mmInt := mmString.Integer;
							if mmInt &gt; 0 and mmInt &lt;= 12 then
								month := mmInt;
								if month = 2 then
									if day &gt; 28 then
										day := 28;
									endif;
								elseif day = 31 then
									if month = 4
									or month = 6
									or month = 9
									or month = 11 
									then
										day := 30;
									endif;
								endif;
							endif;
						endif;
					endif;
				endif;
			endif;
		else
			localResetValue := self.Reset_On_Overflow_Int;
		endif;
	
	endif;
	
	if self.lastIdGeneratedYear &lt;&gt; null and self.lastIdGeneratedYear.isInteger then
		yyInt := self.lastIdGeneratedYear.Integer;
		year := yyInt + 2000;
	endif;
	
	localDate.setDate( day, month, year );
//	write localDate.String &amp; " " &amp; localResetValue.String &amp; " " &amp; self.class.name &amp; " " &amp; self.myTerminal.String;
	
	self.resetSeqOn := localResetValue;
	self.lastGeneratedDate := localDate;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="b51b7aa1-4992-4078-a2b6-25aaef18ad32">
        <source>getAuditTextForProperty(_property: Property): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55524

*/

vars

	propName	: String;
	value		: String;
	
begin
	
	propName := _property.name;
	
	if _property = CM_AutoIdGenerator::idStyle then
		value := self.getStringForIdStyle(self.idStyle);
		return self.formatAuditText(propName, value);
	elseif _property = CM_AutoIdGenerator::idType then
		value := self.getDisplayStringForId(self.idType);
		return self.formatAuditText(propName, value);
	elseif _property = CM_AutoIdGenerator::resetSeqOn then
		value := self.getStringForResetOption(self.resetSeqOn);
		return self.formatAuditText(propName, value);
	else
		return inheritMethod(_property);
	endif;

epilog

end;
</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForId" id="88d3b551-3898-4b26-b576-c9091cf65d17">
        <source>getDisplayStringForId( _id : Integer ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 March 2015	cnwndl1	Initial creation
22/12/2022		navkc1	TFS CR 55300 TASK 55524
29/08/2023		navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id
10/09/2024		jlizm1	TFS 65953 NSW Dynamics Integration - Auto Generate ID
*/

vars

begin

	if  _id = CargoIdType then
		return app.getErrorString(CargoId);
	elseif  _id = BookingIdType then
		return app.getErrorString(BookingId);
	elseif  _id = ReleaseIdType then
		return app.getErrorString(Web_Release_Id);	//21 Jan 2019	NDL	TFS 42954 
	elseif  _id = EIRNumberType then
		return app.getErrorString(EIRNumber);
	elseif  _id = VehicleBookingIdType then
		return app.getErrorString(VehicleBookingId);
	elseif  _id = WorkOrderIdType then	//12 Jun 2018	NDL	TFS 39142
		return app.getErrorString(Work_order_id);
	elseif	_id = PaymentIdType then	//13 Jun 2018	NDL	TFS 39197
		return app.getErrorString(Payment_type_id);
	elseif	_id = TaxNumberType then	//13 Jun 2018	NDL	TFS 39197
		return app.getErrorString(Tax_Number);
	elseif	_id = ExternalNumberType then	//13 Jun 2018	NDL	TFS 39197
		return app.getErrorString(CM_External_invoice_number);
	elseif	_id = ExternalReceiptNumberType then	          //01.11.2018 cnwma1 TFS #41688
		return app.getErrorString(CM_External_receipt_number);
	elseif  _id = VoyWorkOrderIdType then	//15 Aug 2018	NDL	TFS 40249
		return app.getErrorString(Voyage_work_order_id);
	elseif _id = RoadServiceOrderNumberType then
		return app.getErrorString(Aspa_service_order_number);
	elseif _id = InvExtNumberType then
		return app.getErrorString(Invoice_external_number);	// 22/12/2022	navkc1	TFS CR 55300 TASK 55524
	elseif _id = CrdExtNumberType then
		return app.getErrorString(Credit_note_ext_number);	// 22/12/2022	navkc1	TFS CR 55300 TASK 55524
	elseif _id = CrdInvExtNumberType then
		return app.getErrorString(Credit_invoice_external_number);
	elseif _id = CustDocNumberType then
		return app.getErrorString(Customs_document_number); //29/08/2023	navkc1	CR 59556  Task 59557
	endif;
	
	return "Unknown Auto Id type";
epilog

end;</source>
        <Parameter name="_id" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextId" id="a2c262a0-c797-4377-8e15-08659b6d7351">
        <updating/>
        <source>getNextId(
		  _cargoTypeAbbr : String; //01/09/2022 navmv20 TFS 54610
		  _terminalCode	 : String  // 19/12/2022	navkc1	TFS CR 55300 TASK 55521
		  )  :String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Jul 2014	cnwndl1	Initial creation	Par 34660
13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
01 Sep 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
12 Jan 2026 navma1	MTN-36895 MTN  - Improve Auto-Generation Performance for Cargo
*/

vars
	serverDate		 : Date;
	prefix 			 : String;
	year 			 : String;
	month 			 : String;
	seqNum 			 : Real;
	newId 			 : String;
	nextSeqNum 		 : Real;
	failSafeCount 		: Integer;
	inTransactionState  : Boolean;
begin

	// get the value set up last time thru, or by the last user edit.
	seqNum 	   := self.nextSequenceNum;
	serverDate := app.actualTimeServer.Date;
	year 	   := serverDate.format("yy");	
	month 	   := serverDate.format("MM");	
	
	//23 Jan 2019	NDL	TFS 43018
	if self.resetOnDateChange( serverDate ) then
		// new year, new,month or new Day, may be time to reset the counter.
		seqNum := 1;
	endif;

	if self.idStyle = AutoIdStyle_P_YY_SSS
	or self.idStyle = AutoIdStyle_P_SSS
	or self.idStyle = AutoIdStyle_P_MM_YY_SSS
	or self.idStyle = AutoIdStyle_P_YY_MM_SSS // TFS 39976
	or self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS //01/09/2022 navmv20 TFS 54610
	then

	   if (self.isKindOf(CM_AutoCargoIdGen) and self.CM_AutoCargoIdGen.useCargoTypeAbbrv) then
		    prefix := _cargoTypeAbbr;
		else
			prefix := self.idPrefix;
		endif;  
	endif;
	
	if self.idStyle = AutoIdStyle_P_MM_YY_SSS then
		
		prefix := prefix &amp; month;
	endif;
	
	if self.idStyle = AutoIdStyle_P_YY_SSS
	or self.idStyle = AutoIdStyle_YY_SSS
	or self.idStyle = AutoIdStyle_P_MM_YY_SSS
	or self.idStyle = AutoIdStyle_P_YY_MM_SSS 	  // TFS 39976
	or self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS //01/09/2022 navmv20 TFS 54610
	then
		prefix := prefix &amp; year;
	endif;
	
	if self.idStyle = AutoIdStyle_P_YY_MM_SSS or self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS then //01/09/2022 navmv20 TFS 54610
		month   := serverDate.format("MM");	 // TFS 39976	/12.01.2026 navma1 #MTN-36895
		prefix  := prefix &amp; month;
	endif;
	
	//START 01/09/2022 navmv20 TFS 54610
	if self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS then  
		prefix := prefix &amp; serverDate.format("dd");			//12.01.2026 navma1 #MTN-36895
	endif;
	//END 01/09/2022 navmv20 TFS 54610
	
	while true do
		if seqNum.String.length &gt; self.idSeqNumLength then
			// just in case the user has made the seq num length shorter since last time thru,
			// or we have naturally reached the end of the series and need to reset.
			seqNum := 1;
		endif;
		newId := prefix &amp; seqNum.String.padLeadingZeros(self.idSeqNumLength);
		
		if self.newIdNotAlreadyUsed( newId ) then
			// no object of this type already uses this id.
			break;
		endif;
		
		seqNum := seqNum + 1;
		
		failSafeCount := failSafeCount + 1;
		if failSafeCount &gt; 9 then
			return null;
		endif;
		
	endwhile;
	
	
	nextSeqNum := seqNum + 1;
	if nextSeqNum.String.length &gt; self.idSeqNumLength then
		nextSeqNum := 1;
	endif;
	
	//epr par 35553 CCMS 1409 can be called whilst in transaction state
	inTransactionState:=process.isInTransactionState;
	if not inTransactionState then
		beginTransaction;
	endif;
	self.setLastAndNextValues(	newId, nextSeqNum, 0, serverDate);
	if not inTransactionState then
		commitTransaction;
	endif;
	return newId;

epilog

end;</source>
        <Parameter name="_cargoTypeAbbr" type="String"/>
        <Parameter name="_terminalCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextIdForYear" id="b79e00c2-2edd-4532-976c-78c36b6cc224">
        <updating/>
        <source>getNextIdForYear( _date : Date): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlgndl1	Initial creation	TFS 39197
01 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
29/08/2023	navkc1	CR 59556  Task 59557: Jade - CustDocs Auto Id
*/

vars

	year : Integer;
	seqNum : Real;
	newId : String;
	nextSeqNum : Real;
	inTransactionState : Boolean;

begin

	if not self.isExternalNumber
	and not self.isExternalReceiptNumber //01.11.2018 cnwma1 TFS #41688
	and not self.isPaymentId
	and not self.isTaxNumber
	and not self.isCustDocNumber() //29/08/2023	navkc1	CR 59556  Task 59557
	then
		//anything else doesn't have teh integer arrays to store multiple nest seq nums
		//return getNextId(); //1 Sept 2022 navmv20 TFS 54610
		return getNextId(null, null); //1 Sept 2022 navmv20 TFS 54610
	endif;
	
	if _date = null or not _date.isValid then
		year := app.actualTimeServer.Date.format("yy").Integer;
	else
		year := _date.format("yy").Integer;
	endif;
	
	seqNum := self.getNextSequenceNumArray( year );
	if seqNum = 0 then
		seqNum := 1;
	endif;
	
	newId := seqNum.String.padLeadingZeros(self.idSeqNumLength);
	nextSeqNum := seqNum + 1;
	
	inTransactionState := process.isInTransactionState;
	if not inTransactionState then
		beginTransaction;
	endif;
	self.setLastAndNextValues(	newId, nextSeqNum, year, _date );
	if not inTransactionState then
		commitTransaction;
	endif;
	
	return newId;
	
epilog

end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="String"/>
    </JadeMethod>
