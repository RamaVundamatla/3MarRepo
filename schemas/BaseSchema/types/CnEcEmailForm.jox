    </JadeMethod>
    <JadeMethod name="populateWithLastEmail" id="25041ab1-1b5c-4f36-b8e4-86b6396edade">
        <updating/>
        <source>populateWithLastEmail() updating, protected;

vars
	errorMsg	: String;
	arrayPos	: Integer;
	
begin
	self.setStatusLine("Form re-populated with last Email to allow re-send.");
	
	lstAttachments.clear();
	
	if aMyLastEmail.allAttachmentsArray.size() &gt; 0 then 	
		foreach arrayPos in 1 to aMyLastEmail.allAttachmentsArray.size() do
			lstAttachments.addItem(aMyLastEmail.allAttachmentsArray[arrayPos]);
		endforeach;
	endif;
	
	btnDelAttach.enabled := false;
	txtTo.text		:= aMyLastEmail.sentTo;
	txtCc.text		:= aMyLastEmail.ccList;
	txtBcc.text		:= aMyLastEmail.bccList;
	txtSubject.text	:= aMyLastEmail.messageHeader;
	txtMessage.text	:= aMyLastEmail.messageBody;
	
	if aMyLastEmail.encodingType = CnSmtpConnection.None or aMyLastEmail.encodingType = "" then 
		optNoEncode.value := true;	
		optBase64.value := false;	
		txtUserEncoded.text := "";
	elseif aMyLastEmail.encodingType = CnSmtpConnection.Base64 then
		optNoEncode.value := false;	
		optBase64.value := true;	
		txtUserEncoded.text := "";
	else
		optNoEncode.value := false;	
		optBase64.value := false;	
		txtUserEncoded.text := aMyLastEmail.encodingType;
	endif;
	
	if aMyLastEmail.encodingType = CnSmtpConnection.Plain then
		optPlain.value := true;
		optHtml.value := false;
	elseif aMyLastEmail.encodingType = CnSmtpConnection.Html then
		optPlain.value := false;
		optHtml.value := true;
	endif;
	
	self.deleteMyLastEmail();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="putAddressInTextbox" id="6e9b1450-f8dd-4a5f-815f-956dd8a500ba">
        <source>putAddressInTextbox(pTextBoxObj : CnEcTextBox io; address : String) protected;

begin
	if pTextBoxObj.text = null then
		pTextBoxObj.text := address;
	else
		pTextBoxObj.text := address &amp; "; " &amp; pTextBoxObj.text;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTextBoxObj" type="CnEcTextBox" usage="io"/>
        <Parameter name="address" type="String"/>
    </JadeMethod>
    <JadeMethod name="sendEmail" id="6ba26aac-c7d1-4b38-ac8f-61716620fb5a">
        <updating/>
        <source>sendEmail(email : CnEcEmail io) updating, protected;

vars
//	kc					: CnKarmaCntrl;
//	sm					: CnSmtpConnection;
//	errorMsg			: String;
//	attachment			: CnAttachment;
//	pos					: Integer;
	formObj				: CnEcEmailForm;
	
begin
	self.aMyLastEmail	:=	email;
	btnSend.enabled		:=	false;		
	self.aIsWaiting		:=	true;
	formObj				:=	self;
	
	email.sendMeFromForm(formObj); 					

	self.setStatusLine("Email sent to server     ...waiting confirmation of receipt");
	self.initializeForm();
end;</source>
        <access>protected</access>
        <Parameter name="email" type="CnEcEmail" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setEmailInfo" id="798175d3-0f31-441b-a2e5-57c0e1f5b68f">
        <updating/>
        <source>setEmailInfo(pSubject:String; pBody:String) updating;
// --------------------------------------------------------------------------------
// Created:		10 January 2007 by cnwdad1
//
// Purpose:		Stores the subject and body of the email to pre-fill the email message
//				when the for is loaded.
//
// Parameters:	pSubject - The subject of the email message.
//				pBody - The body of the email message.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	emailSubject	: String;
	
begin
	if pSubject.length() &gt; (CnEcEmailForm::aEmailSubject.length - 1) then
		emailSubject	:=	pSubject[1:100];
	else
		emailSubject	:=	pSubject;
	endif;
	
	self.aEmailSubject	:=	emailSubject;
	self.aEmailBody		:=	pBody;
end;</source>
        <Parameter name="pSubject" type="String"/>
        <Parameter name="pBody" type="String"/>
    </JadeMethod>
    <JadeMethod name="setStatusLine" id="17d5f672-37da-4642-8383-9497b4500056">
        <source>setStatusLine(pStatus : String) protected;

begin
	statusLine1.caption := "";
	
	if pStatus &lt;&gt; null then
		statusLine1.foreColor	:= Red;
		statusLine1.caption		:= pStatus;
	else
		statusLine1.foreColor	:= Black;		
		statusLine1.caption		:= "Ready...";
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="textBreak" id="65436c65-28a0-489f-93b4-0205c84c4998">
        <updating/>
        <source>textBreak(pString : String; pMaxLineLength : Integer; pDelimiter : String; pLinesOutput : Integer io): String updating;

vars
	output			: String;
	lastBreakPos	: Integer;
	charPos			: Integer;
	char			: Character;
	
begin
	output	:=	pString;

 	if output.length &gt; pMaxLineLength then
 		lastBreakPos	:=	1;
        charPos			:=	pMaxLineLength - 1;
        
        while charPos &lt; output.length() do
        	char	:=	output[charPos:1].Character;
        	
        	if char = " " or char = "-" or char = "," or char = "." then   // valid delimiting characters
        		output := output[1:charPos] &amp; pDelimiter &amp; output[charPos + pDelimiter.length:output.length + pDelimiter.length];
        		pLinesOutput	:=	pLinesOutput + 1;
        		lastBreakPos	:=	charPos + pDelimiter.length;
        		charPos			:=	charPos + pMaxLineLength;
        	else
        		charPos	:=	charPos - 1;
        		
        		if charPos = lastBreakPos then  // gone all the way backwards to the last break, and no delimiting characters found.
        			charPos			:=	charPos + pMaxLineLength + 2;
        			output			:=	output[1:charPos] &amp; "-" &amp; pDelimiter &amp; output[charPos + pDelimiter.length:output.length + pDelimiter.length + 1];
        			pLinesOutput	:=	pLinesOutput + 1;
        			lastBreakPos	:=	charPos + pDelimiter.length + 1;
        			charPos			:=	charPos + pMaxLineLength;
        		endif;
        	endif;	
        endwhile;
    endif;

	return output;
end;</source>
        <Parameter name="pString" type="String"/>
        <Parameter name="pMaxLineLength" type="Integer"/>
        <Parameter name="pDelimiter" type="String"/>
        <Parameter name="pLinesOutput" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
