    <JadeMethod name="totalQuantity" id="ec1703ea-0237-4fad-951c-b7870657a78d">
        <methodInvocation>mapping</methodInvocation>
        <source>totalQuantity(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     15 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//  Apr/2003	RJS			Removed serverExecution - sped up move
// ---------------------------------------------------------------------------
vars
	ti			: CM_TrackedItem;
	tot			: Integer;
	soh			: CM_SOHLocation;
	loadState	: Boolean;	
	invalidSOH : Boolean; 
begin

//	on Exception do app.handleDeletedObject(exception, soh, invalidSOH); //cnwrd1 par 30385 7.12.2012
	
	if set then
		app.raiseSetVirtualError(Class.name, method.name);
	else
		app.cmsBeginLoad(loadState);
		//global.resynchObject(self);
		if self.isStockControlled then
			foreach soh in self.allProductLocations do
				//resynchObject(soh);
				tot := tot + soh.currentQuantity;
			endforeach;
		else
			tot := self.getTrackedItemCount;	//cnwrd1 31736 break bulk counting
		endif;
		_value := tot;
	endif;

epilog
	app.cmsEndLoad(loadState);

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="totalVolume" id="24fae413-4e8d-4023-9610-1e3a5c56aeeb">
