<Class name="UT_Discrepancy" id="69fcb85e-cf8f-40f4-8d64-651399e81cf9">
    <superclass name="UT_Booking"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;test1aasdfakhsdflkj&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="addBookingAndPrenoteForTest" id="5d549812-4c87-4084-9ad4-a54e62cd5c14">
        <source>addBookingAndPrenoteForTest( 	_subTest : String;
								_booking : CM_BookingRef output;
								_ti : CM_TrackedItem output;
								_operator: CM_Operator;
								_bookingName : String;
								_tiId : String;
								_bookCommodity : String;
								_tiCommodity : String;
								_bookHumidity : Decimal;
								_tiHumidity : Decimal
								) protected;
/*
//cnwndl1
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2009	cnwndl1	Initial creation
27 May 2013		cnwdap1	PAR #31596 Added freight forwarder parameter
05 Jun 2018		jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
02 Oct 2020 	cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	pxyBooking : CM_BookingRef;
	pxyBookingItem: CM_BRefItemContainer;
	release: CM_BulkRelease;
	dischargePorts: StringArray;
	hazards: ObjectArray;
	
	voyage : CM_Voyage;
	dischargePort: String;
	isoType: String;
	number: Integer;
	bookingItem : CM_BookingRefItem;
	ifArray: CMIF_TIObjectArray;
	ifPreNote: CMIF_PreNote;
	weight : Decimal [14,4];
	temperatue : Real;

begin
	//just in case...
	self.deleteBooking(_bookingName);
	self.deleteContainer(_tiId);
	
	voyage := self.getTerminal.getNullVoyage;
	dischargePort := app.myRoot.allActivePorts.first.code;
	isoType := "22R8";
	number := 1;
	weight := 2000;
	temperatue := 3;	//NULL_TEMPERATURE;

	create dischargePorts transient;
	create hazards transient;

	create pxyBooking transient;
	pxyBooking.setProxy(_bookingName, 0, false, null,null, null,	null, dischargePort,null, dischargePorts, // adm 160310 Par 22937 remove bolType
						hazards, _bookHumidity, false, "", null, null, _operator, voyage, 0, null,
						null, temperatue, NULL_VENTILATION, 0,0,0,null,null,null, null, 0, 0, 0, 0, 0, 
						self.getTerminal, null, true, false, null, null, null, null, null, null, null, null,
						false, false, false, false, null, false, false, false, false, BOOKING_REF_ACTIVE,
						null, null, null, false, null, null,
						null, 		// customsAgent	// cnwrl1 18/02/2010 PAR 22393
						null, 		// edivoyageCode
						null,		// ediVesselName //cnwrs1 CCMS 1882 03 June 2010
						null,	// direct delivery
						null,	// freight forwarder
						null, 	//carrier
						null    //stevedore //02.10.2020 cnwma1 TFS #50112
						);
	create pxyBookingItem transient;		
	pxyBookingItem.setProxy(TI_CargoType_Container, _bookCommodity, null, null, null, isoType, number, weight, 0, 0, _bookHumidity, temperatue, NULL_VENTILATION, 0
							, NULL_CARBON_DIOXIDE, NULL_OXYGEN, false, false, false, null, null, false, null, null, null, CM_BookingRefItem.BASIC_MATCH);		//navra1 - CR 63764/Task 64227 - 23rd May 2024
	pxyBooking.allBookingRefItems.add(pxyBookingItem);
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateBookingBulkRel(pxyBooking, _booking, release, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	bookingItem := _booking.allBookingRefItems.first;
	
	create ifArray transient;
	create ifPreNote transient;	
	ifPreNote.id := _tiId;
	ifPreNote.myTerminal := self.getTerminal;
	ifPreNote.cargoType := TI_CargoType_Container;
	ifPreNote.isoType := bookingItem.isoType;
	ifPreNote.commodity := _tiCommodity;
	ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	ifPreNote.operatorCode := _operator.code;
	ifPreNote.weightTotal := weight;
	ifPreNote.voyageCode := voyage.code;
	ifPreNote.dischargePort := dischargePort;
	ifPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
	ifPreNote.bookingReference := _bookingName;
	ifPreNote.myBookingRefItem := bookingItem;
	ifPreNote.setHumidity( _tiHumidity );
	ifPreNote.carriageTempC := temperatue;
	ifPreNote.packTempC := temperatue;
	ifArray.add(ifPreNote);
	
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreatePreNotes(ifArray, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	_ti := ifPreNote.myPersistentTrackedItem;
	
epilog

	delete pxyBooking;
	delete dischargePorts;
	delete hazards;
	delete ifArray;
	delete ifPreNote;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_subTest" type="String"/>
        <Parameter name="_booking" type="CM_BookingRef" usage="output"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_bookingName" type="String"/>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_bookCommodity" type="String"/>
        <Parameter name="_tiCommodity" type="String"/>
        <Parameter name="_bookHumidity" type="Decimal"/>
        <Parameter name="_tiHumidity" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="deleteTiAndBooking" id="0f1012e3-506b-42e7-bde0-ff1fbb44cb4e">
        <source>deleteTiAndBooking(	_subTest: String;
					_booking: CM_BookingRef io;
					_ti: CM_TrackedItem io
					) protected;

/*
//cnwndl1
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2009	cnwndl1	Initial creation
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
*/

vars

begin

	if _ti &lt;&gt; null then
		app.myTrxDA.trxDeleteTI(_ti, false, app.myPassport);
	endif;

	if _booking &lt;&gt; null then
		self.deleteBookingObj(_booking);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_subTest" type="String"/>
        <Parameter name="_booking" type="CM_BookingRef" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tBookingRefDiscrepancy" id="f9714eeb-bb98-41fd-84e5-e299d6f988c1">
        <source>tBookingRefDiscrepancy();
// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
15 October 2009	cnwndl1	Initial creation
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 14 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
21/08/2019		jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
// 10 Sep 2019	cnwrs1	TFS 46030
*/
vars
	bookingName : String;
	tiId : String;
	
	operator : CM_Operator;
	allForwardersObj : CM_ConsigneeConsignorSet;
	allBRefDiscrepsAttrStrings : StringArray;
	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	
	subTest : String;
	
	booking : CM_BookingRef;
	ti : CM_TrackedItem;
	bookCommodity : String;
	tiCommodity : String;
	bookHumidity : Decimal[6,2];
	tiHumidity : Decimal[6,2];
	
	commod1 : String;
	commod2 : String;
	commod3 : String;
	commodity : CM_Commodity;
	
	bookingCmif : CMIF_BookingRef;
	bookingRefItemCmif : CMIF_BookingRefItem;
	pxyBooking : CM_BookingRef;
	pxyTI : CM_TrackedItem;
	isDoClearanceCheck : Boolean;
	
	requiresHumidity : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);

	bookingName := "UT_BOOKING";
	tiId := "UUT00000001";
	commod1 := "UT_1";	// "MT"
	commod2 := "UT_2";	// "BEER"
	commod3 := "UT_3";	//"CARP"
	
	//reset commodity visibility
	commodity := app.myRoot.allCommodities.getAtKey(commod1);
	if commodity &lt;&gt; null and commodity.isNotAvailableForEntry then
		beginTransaction;
		commodity.setPropertyValue("isNotAvailableForEntry",false);
		commitTransaction;
	endif;
	commodity := app.myRoot.allCommodities.getAtKey(commod2);
	if commodity &lt;&gt; null and commodity.isNotAvailableForEntry then
		beginTransaction;
		commodity.setPropertyValue("isNotAvailableForEntry",false);
		commitTransaction;
	endif;
	commodity := app.myRoot.allCommodities.getAtKey(commod3);
	if commodity &lt;&gt; null and commodity.isNotAvailableForEntry then
		beginTransaction;
		commodity.setPropertyValue("isNotAvailableForEntry",false);
		commitTransaction;
	endif;
	
	//set up the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	create allBRefDiscrepsAttrStrings transient;
	create allForwardersObj transient;
	operator.allFFsForBookRefUpdate.copy(allForwardersObj);
	self.ignoreTrxWarnings(true);
	
	requiresHumidity := operator.requiresHumidity;
	
	beginTransaction;
	operator.setRequiresHumidity(true);
	commitTransaction;
	
	app.myTrxUA.trxUpdateOperatorAdvSettings(operator, allForwardersObj, allBRefDiscrepsAttrStrings, app.myPassport);					// TFS 45836
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.ignoreTrxWarnings(false);
	
	//A
	//add booking and pre-note(ti) with different commoditys, for an operator not doing discrepancy checking
	subTest := "Sub test A.";
	bookCommodity := commod1;
	tiCommodity := commod2;
	bookHumidity := NULL_HUMIDITY;
	tiHumidity := NULL_HUMIDITY;
	addBookingAndPrenoteForTest( subTest, booking, ti, operator, bookingName, tiId, bookCommodity, tiCommodity, bookHumidity, tiHumidity );
	
	//check that no discreps created on either the booking ref or the ti.
	self.assertTrueMsg(booking.allBookingRefDiscreps.isEmpty, "Booking has had Discrepancy event(s) incorrectly created during " &amp; subTest);
	self.assertTrueMsg(ti.allBookingRefDiscreps.isEmpty, "TI has had Discrepancy event(s) incorrectly created during " &amp; subTest);
	
	//delete booking and pre-note
	deleteTiAndBooking( subTest, booking, ti);
	/////////////End of A.
	

	//add a selection of discrep items to check on against the operator (some, but not all)
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_BookingRefDiscrep];
	entTableRow := entTableDef.getEntTableRow(ETRow_Commodity);
	allBRefDiscrepsAttrStrings.add(entTableRow.getHeading(null,null,app.myCurrentLocale));
	entTableRow := entTableDef.getEntTableRow(ETRow_CargoType);
	allBRefDiscrepsAttrStrings.add(entTableRow.getHeading(null,null,app.myCurrentLocale));
	entTableRow := entTableDef.getEntTableRow(ETRow_Voyage);
	allBRefDiscrepsAttrStrings.add(entTableRow.getHeading(null,null,app.myCurrentLocale));
	app.myTrxUA.trxUpdateOperatorAdvSettings(operator, allForwardersObj, allBRefDiscrepsAttrStrings, app.myPassport);					// TFS 45836
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	//B
	//add booking and pre-note(ti) with different checkable, but NON checked discrepancy details 
	subTest := "Sub test B.";
	bookCommodity := commod1;
	tiCommodity := commod1;
	bookHumidity := 20.02;
	tiHumidity := 15.51;
	addBookingAndPrenoteForTest( subTest, booking, ti, operator, bookingName, tiId, bookCommodity, tiCommodity, bookHumidity, tiHumidity );
	
	//check that no discreps created on either booking ref or ti.
	self.assertTrueMsg(booking.allBookingRefDiscreps.isEmpty, "Booking has had Discrepancy event(s) incorrectly created during " &amp; subTest);
	self.assertTrueMsg(ti.allBookingRefDiscreps.isEmpty, "TI has had Discrepancy event(s) incorrectly created during " &amp; subTest);
	
	//delete booking and pre-note
	deleteTiAndBooking( subTest, booking, ti);
	/////////////End of B.
	
	//add a humidity and ventilation as discrep items to check on against the operator
	self.ignoreTrxWarnings(true);
	entTableRow := entTableDef.getEntTableRow(ETRow_Humidity);
	allBRefDiscrepsAttrStrings.add(entTableRow.getHeading(null,null,app.myCurrentLocale));
	entTableRow := entTableDef.getEntTableRow(ETRow_Ventilation);
	allBRefDiscrepsAttrStrings.add(entTableRow.getHeading(null,null,app.myCurrentLocale));
	
	app.myTrxUA.trxUpdateOperatorAdvSettings(operator, allForwardersObj, allBRefDiscrepsAttrStrings, app.myPassport);					// TFS 45836
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	//C
	//add booking and pre-note(ti) with different (checked discrepancy) details 
	//where the booking ref end is a null value. - (Shouldn't create a discrepancy if the booking end is null)
	subTest := "Sub test C.";
	bookCommodity := commod1;
	tiCommodity := commod1;
	bookHumidity := NULL_HUMIDITY;
	tiHumidity := 15.51;
	addBookingAndPrenoteForTest( subTest, booking, ti, operator, bookingName, tiId, bookCommodity, tiCommodity, bookHumidity, tiHumidity );
	
	//check that no discreps created on either booking ref or ti.
	self.assertTrueMsg(booking.allBookingRefDiscreps.isEmpty, "Booking has had Discrepancy event(s) incorrectly created during " &amp; subTest);
	self.assertTrueMsg(ti.allBookingRefDiscreps.isEmpty, "TI has had Discrepancy event(s) incorrectly created during " &amp; subTest);
	
	//delete booking and pre-note
	deleteTiAndBooking( subTest, booking, ti);
	/////////////End of C.
	
	//D
	//add booking and pre-note(ti) with different (checked discrepancy) details 
	subTest := "Sub test D.";
	bookCommodity := commod1;
	tiCommodity := commod2;
	bookHumidity := 20.02;
	tiHumidity := 15.51;
	addBookingAndPrenoteForTest( subTest, booking, ti, operator, bookingName, tiId, bookCommodity, tiCommodity, bookHumidity, tiHumidity );
	
	//check that discreps created on both booking ref and ti.
	self.assertTrueMsg(booking.allBookingRefDiscreps.size = 1, "Booking has NOT had Discrepancy event(s) created during " &amp; subTest);
	self.assertTrueMsg(ti.allBookingRefDiscreps.size = 1, "TI has NOT had Discrepancy event(s) created during " &amp; subTest);
	
	//E
	//change a (checked) item to a new value on the booking ref
	subTest := "Sub test E.";
	bookHumidity := 25.52;
	
	beginLoad;
	pxyBooking := booking.pxyCreateUpdateProxy();
	endLoad;
	create bookingCmif transient;
	bookingCmif.setMyProxyBookingRef(pxyBooking);
	bookingRefItemCmif := bookingCmif.getInterfaceItem(booking.allBookingRefItems.first);
	updateBookingRefItem( bookingRefItemCmif, bookHumidity );
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateBookingRefMulti(bookingCmif, app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyBooking;
	delete bookingCmif;
	
	//check that additional discreps created on both booking ref and ti.
	self.assertTrueMsg(booking.allBookingRefDiscreps.size = 2, "Booking has NOT had Discrepancy event(s) created during " &amp; subTest);
	self.assertTrueMsg(ti.allBookingRefDiscreps.size = 2, "TI has NOT had Discrepancy event(s) created during " &amp; subTest);
	
	//F
	subTest := "Sub test F.";
	bookHumidity := 20.02;
	//reverse the change made in E. on the booking ref
	beginLoad;
	pxyBooking := booking.pxyCreateUpdateProxy();
	endLoad;
	create bookingCmif transient;
	bookingCmif.setMyProxyBookingRef(pxyBooking);
	bookingRefItemCmif := bookingCmif.getInterfaceItem(booking.allBookingRefItems.first);
	updateBookingRefItem( bookingRefItemCmif, bookHumidity );
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateBookingRefMulti(bookingCmif, app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyBooking;
	delete bookingCmif;
	
	//check that NO additional discreps created on booking ref or ti.
	self.assertTrueMsg(booking.allBookingRefDiscreps.size = 2, "Booking has had Discrepancy event(s) incorrectly created during " &amp; subTest);
	self.assertTrueMsg(ti.allBookingRefDiscreps.size = 2, "TI has had Discrepancy event(s) incorrectly created during " &amp; subTest);

	//delete booking and pre-note
	deleteTiAndBooking( subTest, booking, ti);
	
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	endLoad;				// 08/04/2011 cnwmh5 #27347

	//reset commodity visibility
	commodity := app.myRoot.allCommodities.getAtKey(commod1);
	if commodity &lt;&gt; null and commodity.isNotAvailableForEntry then
		beginTransaction;
		commodity.setPropertyValue("isNotAvailableForEntry",true);
		commitTransaction;
	endif;
	commodity := app.myRoot.allCommodities.getAtKey(commod2);
	if commodity &lt;&gt; null and commodity.isNotAvailableForEntry then
		beginTransaction;
		commodity.setPropertyValue("isNotAvailableForEntry",true);
		commitTransaction;
	endif;
	commodity := app.myRoot.allCommodities.getAtKey(commod3);
	if commodity &lt;&gt; null and commodity.isNotAvailableForEntry then
		beginTransaction;
		commodity.setPropertyValue("isNotAvailableForEntry",true);
		commitTransaction;
	endif;

	//delete transients created.
	delete allBRefDiscrepsAttrStrings;
	delete allForwardersObj;
	delete pxyBooking;
	delete bookingCmif;
	delete pxyTI;
	
	beginTransaction;
	operator.setRequiresHumidity(requiresHumidity);
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBookingRefDiscrepancy63776" id="cb7593e8-68cd-4ad5-8899-9458787403e9">
        <source>tBookingRefDiscrepancy63776();
// cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
15 October 2009	cnwndl1	Initial creation
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 14 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
21/08/2019		jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
// 10 Sep 2019	cnwrs1	TFS 46030
// 15 Apr 2024	jlirs1	TFS 63776 Unit test failing for Prenote Booking discrepancies
*/
vars
	bookingName : String;
	tiId : String;
	count : Integer;
	operator : CM_Operator;
	allForwardersObj : CM_ConsigneeConsignorSet;
	allBRefDiscrepsAttrStrings : StringArray;
	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	
	subTest : String;
	
	booking : CM_BookingRef;
	ti : CM_TrackedItem;
	bookCommodity : String;
	tiCommodity : String;
	bookHumidity : Decimal[6,2];
	tiHumidity : Decimal[6,2];
	
	commod1 : String;
	commod2 : String;
	commod3 : String;
	commodity : CM_Commodity;
	
	bookingCmif : CMIF_BookingRef;
	bookingRefItemCmif : CMIF_BookingRefItem;
	pxyBooking : CM_BookingRef;
	pxyTI : CM_TrackedItem;
	isDoClearanceCheck : Boolean;
	discrepancy : CMEVT_BookingRefDiscrep;
	field : CM_BookingRefDiscrepFieldValue;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);

	bookingName := "UT_BOOKING";
	tiId := "UUT00000001";
	commod1 := "UT_1";	// "MT"
	commod2 := "UT_2";	// "BEER"
	commod3 := "UT_3";	//"CARP"
	
	//reset commodity visibility
	commodity := app.myRoot.allCommodities.getAtKey(commod1);
	if commodity &lt;&gt; null and commodity.isNotAvailableForEntry then
		beginTransaction;
		commodity.setPropertyValue("isNotAvailableForEntry",false);
		commitTransaction;
	endif;
	commodity := app.myRoot.allCommodities.getAtKey(commod2);
	if commodity &lt;&gt; null and commodity.isNotAvailableForEntry then
		beginTransaction;
		commodity.setPropertyValue("isNotAvailableForEntry",false);
		commitTransaction;
	endif;
	commodity := app.myRoot.allCommodities.getAtKey(commod3);
	if commodity &lt;&gt; null and commodity.isNotAvailableForEntry then
		beginTransaction;
		commodity.setPropertyValue("isNotAvailableForEntry",false);
		commitTransaction;
	endif;
	
	//set up the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	create allBRefDiscrepsAttrStrings transient;
	create allForwardersObj transient;
	operator.allFFsForBookRefUpdate.copy(allForwardersObj);
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateOperatorAdvSettings(operator, allForwardersObj, allBRefDiscrepsAttrStrings, app.myPassport);					// TFS 45836
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.ignoreTrxWarnings(false);
	
	//A
	//add booking and pre-note(ti) with different commoditys, for an operator not doing discrepancy checking
	subTest := "Sub test A.";
	write subTest;
	bookCommodity := commod1;
	tiCommodity := commod2;
	bookHumidity := NULL_HUMIDITY;
	tiHumidity := NULL_HUMIDITY;
	addBookingAndPrenoteForTest( subTest, booking, ti, operator, bookingName, tiId, bookCommodity, tiCommodity, bookHumidity, tiHumidity );
	
	//check that no discreps created on either the booking ref or the ti.
	self.assertTrueMsg(booking.allBookingRefDiscreps.isEmpty, "Booking has had Discrepancy event(s) incorrectly created during " &amp; subTest);
	self.assertTrueMsg(ti.allBookingRefDiscreps.isEmpty, "TI has had Discrepancy event(s) incorrectly created during " &amp; subTest);
	write "Booking has had no Discrepancy event(s) created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.size.String;
	write "";
	
	//delete booking and pre-note
	deleteTiAndBooking( subTest, booking, ti);
	/////////////End of A.
	

	//add a selection of discrep items to check on against the operator (some, but not all)
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	entTableDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_BookingRefDiscrep];
	entTableRow := entTableDef.getEntTableRow(ETRow_Commodity);
	allBRefDiscrepsAttrStrings.add(entTableRow.getHeading(null,null,app.myCurrentLocale));
	entTableRow := entTableDef.getEntTableRow(ETRow_CargoType);
	allBRefDiscrepsAttrStrings.add(entTableRow.getHeading(null,null,app.myCurrentLocale));
	entTableRow := entTableDef.getEntTableRow(ETRow_Voyage);
	allBRefDiscrepsAttrStrings.add(entTableRow.getHeading(null,null,app.myCurrentLocale));
	app.myTrxUA.trxUpdateOperatorAdvSettings(operator, allForwardersObj, allBRefDiscrepsAttrStrings, app.myPassport);					// TFS 45836
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	//B
	//add booking and pre-note(ti) with different checkable, but NON checked discrepancy details 
	subTest := "Sub test B.";
	write subTest;
	bookCommodity := commod1;
	tiCommodity := commod1;
	bookHumidity := 20.02;
	tiHumidity := 15.51;
	addBookingAndPrenoteForTest( subTest, booking, ti, operator, bookingName, tiId, bookCommodity, tiCommodity, bookHumidity, tiHumidity );
	
	//check that no discreps created on either booking ref or ti.
	self.assertTrueMsg(booking.allBookingRefDiscreps.isEmpty, "Booking has had Discrepancy event(s) incorrectly created during " &amp; subTest);
	self.assertTrueMsg(ti.allBookingRefDiscreps.isEmpty, "TI has had Discrepancy event(s) incorrectly created during " &amp; subTest);
	write "Booking has had no Discrepancy event(s) created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.size.String;
	write "";
	
	//delete booking and pre-note
	deleteTiAndBooking( subTest, booking, ti);
	/////////////End of B.
	
	//add a humidity and ventilation as discrep items to check on against the operator
	self.ignoreTrxWarnings(true);
	entTableRow := entTableDef.getEntTableRow(ETRow_Humidity);
	allBRefDiscrepsAttrStrings.add(entTableRow.getHeading(null,null,app.myCurrentLocale));
	entTableRow := entTableDef.getEntTableRow(ETRow_Ventilation);
	allBRefDiscrepsAttrStrings.add(entTableRow.getHeading(null,null,app.myCurrentLocale));
	
	app.myTrxUA.trxUpdateOperatorAdvSettings(operator, allForwardersObj, allBRefDiscrepsAttrStrings, app.myPassport);					// TFS 45836
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	//C
	//add booking and pre-note(ti) with different (checked discrepancy) details 
	//where the booking ref end is a null value. - (Shouldn't create a discrepancy if the booking end is null)
	subTest := "Sub test C.";
	write subTest;
	bookCommodity := commod1;
	tiCommodity := commod1;
	bookHumidity := NULL_HUMIDITY;
	tiHumidity := 16.51;
	addBookingAndPrenoteForTest( subTest, booking, ti, operator, bookingName, tiId, bookCommodity, tiCommodity, bookHumidity, tiHumidity );
	
	//check that no discreps created on either booking ref or ti.
//	self.assertTrueMsg(booking.allBookingRefDiscreps.isEmpty, "Booking has had Discrepancy event(s) incorrectly created during " &amp; subTest);
//	self.assertTrueMsg(ti.allBookingRefDiscreps.isEmpty, "TI has had Discrepancy event(s) incorrectly created during " &amp; subTest);
	self.assertTrueMsg(booking.allBookingRefDiscreps.size = 0, "Booking has had Discrepancy event(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.size.String);
	self.assertTrueMsg(ti.allBookingRefDiscreps.size = 0, "TI has had Discrepancy event(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;ti.allBookingRefDiscreps.size.String);
//	self.assertTrueMsg(booking.allBookingRefDiscreps.first.allBookingRefDiscrepFieldVs.size = 0, "Booking has had Discrepancy event(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.first.allBookingRefDiscrepFieldVs.size.String);
	write "Booking has had no Discrepancy event(s) created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.size.String;
	write "";
	//delete booking and pre-note
	deleteTiAndBooking( subTest, booking, ti);
	/////////////End of C.
	
	//D
	//add booking and pre-note(ti) with different (checked discrepancy) details 
	subTest := "Sub test D.";
	write subTest;
	bookCommodity := commod1;
	tiCommodity := commod2;
	bookHumidity := 21.02;
	tiHumidity := 17.51;
	addBookingAndPrenoteForTest( subTest, booking, ti, operator, bookingName, tiId, bookCommodity, tiCommodity, bookHumidity, tiHumidity );
	
	//check that discreps created on both booking ref and ti.
	self.assertTrueMsg(booking.allBookingRefDiscreps.size = 1, "Booking has had Discrepancy event(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.size.String);
	self.assertTrueMsg(ti.allBookingRefDiscreps.size = 1, "TI has had Discrepancy event(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;ti.allBookingRefDiscreps.size.String);
	self.assertTrueMsg(booking.allBookingRefDiscreps.first.allBookingRefDiscrepFieldVs.size = 4, "Booking has had Discrepancy field(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.first.allBookingRefDiscrepFieldVs.size.String);
	write "Booking has had Discrepancy event(s) created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.size.String;
	count := 0;
	foreach discrepancy in booking.allBookingRefDiscreps do
		count := count + 1;
		write count;
		if count = 1 then
			self.assertTrueMsg(discrepancy.allBookingRefDiscrepFieldVs.size = 4, "Booking has had Discrepancy field(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.first.allBookingRefDiscrepFieldVs.size.String);
		endif;
		foreach field in discrepancy.allBookingRefDiscrepFieldVs do
			write(field.fieldName&amp;' Ti Value='&amp;field.tiFieldValue&amp;' Booking Value='&amp;field.bookingRefFieldValue);
		endforeach;
	endforeach;
	write '';
	
	//E
	//change a (checked) item to a new value on the booking ref
	subTest := "Sub test E.";
	write subTest;
	bookHumidity := 22.52;
	
	beginLoad;
	pxyBooking := booking.pxyCreateUpdateProxy();
	endLoad;
	create bookingCmif transient;
	bookingCmif.setMyProxyBookingRef(pxyBooking);
	bookingRefItemCmif := bookingCmif.getInterfaceItem(booking.allBookingRefItems.first);
	updateBookingRefItem( bookingRefItemCmif, bookHumidity );
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateBookingRefMulti(bookingCmif, app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyBooking;
	delete bookingCmif;
	
	//check that additional discreps created on both booking ref and ti.
	self.assertTrueMsg(booking.allBookingRefDiscreps.size = 2, "Booking has had Discrepancy event(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.size.String);
	self.assertTrueMsg(ti.allBookingRefDiscreps.size = 2, "TI has had Discrepancy event(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;ti.allBookingRefDiscreps.size.String);
	self.assertTrueMsg(booking.allBookingRefDiscreps.first.allBookingRefDiscrepFieldVs.size = 4, "Booking has had Discrepancy field(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.first.allBookingRefDiscrepFieldVs.size.String);
	write "Booking has had Discrepancy event(s) created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.size.String;
	count := 0;
	foreach discrepancy in booking.allBookingRefDiscreps do
		count := count + 1;
		write count;
		if count = 1 then
			self.assertTrueMsg(discrepancy.allBookingRefDiscrepFieldVs.size = 4, "Booking has had Discrepancy field(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.first.allBookingRefDiscrepFieldVs.size.String);
		elseif count = 2 then
			self.assertTrueMsg(discrepancy.allBookingRefDiscrepFieldVs.size = 5, "Booking has had Discrepancy field(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.first.allBookingRefDiscrepFieldVs.size.String);
		endif;
		foreach field in discrepancy.allBookingRefDiscrepFieldVs do
			write(field.fieldName&amp;' Ti Value='&amp;field.tiFieldValue&amp;' Booking Value='&amp;field.bookingRefFieldValue);
		endforeach;
	endforeach;
	write '';

	//F
	subTest := "Sub test F.";
	write subTest;
	bookHumidity := 23.02;
	//reverse the change made in E. on the booking ref
	beginLoad;
	pxyBooking := booking.pxyCreateUpdateProxy();
	endLoad;
	create bookingCmif transient;
	bookingCmif.setMyProxyBookingRef(pxyBooking);
	bookingRefItemCmif := bookingCmif.getInterfaceItem(booking.allBookingRefItems.first);
	updateBookingRefItem( bookingRefItemCmif, bookHumidity );
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateBookingRefMulti(bookingCmif, app.myPassport, null);
	self.assertNoTrxErrorsOrWarnings();
	delete pxyBooking;
	delete bookingCmif;
	
	//check that NO additional discreps created on booking ref or ti.
	self.assertTrueMsg(booking.allBookingRefDiscreps.size = 3, "Booking has had Discrepancy event(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.size.String);
	self.assertTrueMsg(ti.allBookingRefDiscreps.size = 3, "TI has had Discrepancy event(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;ti.allBookingRefDiscreps.size.String);
	self.assertTrueMsg(booking.allBookingRefDiscreps.first.allBookingRefDiscrepFieldVs.size = 4, "Booking has had Discrepancy field(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.first.allBookingRefDiscrepFieldVs.size.String);
	write "Booking has had Discrepancy event(s) created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.size.String;
	count := 0;
	foreach discrepancy in booking.allBookingRefDiscreps do
		count := count + 1;
		write count;
		if count = 1 then
			self.assertTrueMsg(discrepancy.allBookingRefDiscrepFieldVs.size = 4, "Booking has had Discrepancy field(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.first.allBookingRefDiscrepFieldVs.size.String);
		elseif count = 2 then
			self.assertTrueMsg(discrepancy.allBookingRefDiscrepFieldVs.size = 5, "Booking has had Discrepancy field(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.first.allBookingRefDiscrepFieldVs.size.String);
		elseif count = 3 then
			self.assertTrueMsg(discrepancy.allBookingRefDiscrepFieldVs.size = 5, "Booking has had Discrepancy field(s) incorrectly created during " &amp; subTest&amp;' actual='&amp;booking.allBookingRefDiscreps.first.allBookingRefDiscrepFieldVs.size.String);
		endif;
		foreach field in discrepancy.allBookingRefDiscrepFieldVs do
			write(field.fieldName&amp;' Ti Value='&amp;field.tiFieldValue&amp;' Booking Value='&amp;field.bookingRefFieldValue);
		endforeach;
	endforeach;
	write '';
	//delete booking and pre-note
	deleteTiAndBooking( subTest, booking, ti);
//	assertFalse(true);		//still not fixeded values are not correct
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	endLoad;				// 08/04/2011 cnwmh5 #27347

	//reset commodity visibility
	commodity := app.myRoot.allCommodities.getAtKey(commod1);
	if commodity &lt;&gt; null and commodity.isNotAvailableForEntry then
		beginTransaction;
		commodity.setPropertyValue("isNotAvailableForEntry",true);
		commitTransaction;
	endif;
	commodity := app.myRoot.allCommodities.getAtKey(commod2);
	if commodity &lt;&gt; null and commodity.isNotAvailableForEntry then
		beginTransaction;
		commodity.setPropertyValue("isNotAvailableForEntry",true);
		commitTransaction;
	endif;
	commodity := app.myRoot.allCommodities.getAtKey(commod3);
	if commodity &lt;&gt; null and commodity.isNotAvailableForEntry then
		beginTransaction;
		commodity.setPropertyValue("isNotAvailableForEntry",true);
		commitTransaction;
	endif;

	//delete transients created.
	delete allBRefDiscrepsAttrStrings;
	delete allForwardersObj;
	delete pxyBooking;
	delete bookingCmif;
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateTiBookingDiscrepancy" id="08ce8e8c-2b9e-43e4-a72c-f9bb39bc3288">
        <updating/>
        <source>tUpdateTiBookingDiscrepancy()updating;
/*

Purpose: Update TrackedItem from Booking Discrepancy			

Date		Who		Reason
24/04/2014	cnwma1	Initial creation
09/05/2014  cnwma1  Reconcile Booking
// 10 Sep 2019	cnwrs1	TFS 46030
*/

constants
	BookingNum	 = "MA_BOOK300";
	VoyNum		 = "AMA6060";
	CNTR		 = "MSYD888777";
	TrkNum		 = "TRK800";
vars
	booking		 : CM_BookingRef;
	operator	 : CM_Operator;
	voyage		 : CM_Voyage;
	ti	 		 : CM_TrackedItem;
	vvr 		 : CM_VehicleVisitRecord;
	gate		 : CM_Gate;
	discrepSet   :CM_BookingRefDiscrepsSet;
	bookRefItem  : CM_BookingRefItem;
	bookingSet   : CM_BookingRefSet;
	bookingDiscrep : CMEVT_BookingRefDiscrep;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	operator :=self.getOperator("APL");
	self.assertNotNull(operator);
	
	self.deleteVoyage(VoyNum);
	voyage := self.addVoyageWithContainerStructur(VoyNum,"AMA","APL","APL");
	
	self.deleteBooking(BookingNum);
	booking := self.addBookingForContainer(BookingNum, operator, voyage, "AUSYD", "2210", "GENL");
	self.assertNotNull(booking);

	deleteVehicle(TrkNum);
	self.deleteContainer(CNTR);
	
	
	bookRefItem := booking.allBookingRefItems.first;
	self.assertNotNull(bookRefItem);
	self.opts.purge;
	self.opts.addAssoc("BookingItem",booking.allBookingRefItems.first);
	self.opts.addAssoc("Voyage", voyage.code);
	
	vvr := self.gateInContainer(TrkNum, CNTR, "20T8", booking.operatorCode, "APPL", gate);
		
	self.workVehicle(vvr);
	create discrepSet transient;
	booking.allBookingRefDiscreps.copy(discrepSet);
	
	// 22/05/2015 cnwmh5
	bookingDiscrep := booking.allBookingRefDiscreps.first;
	self.assertNotNull(bookingDiscrep);
	app.myTrxUA.trxUpdateBookingRefRemarks(bookingDiscrep, "UTMHTEST REMARKS", false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(bookingDiscrep.remarks, "UTMHTEST REMARKS");

	self.assertEqual(booking.allTIs.first.commodity,"APPL");
	app.myTrxUA.trxUpdateTIFromBookingDiscrep(discrepSet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	ti := self.getTrackedItem(CNTR);
	self.assertNotNull(ti);
	self.assertEqual(ti.commodity,"GENL");
	self.assertEqual(ti.getISOType,"2210");
	
	create bookingSet transient;
	bookingSet.add(booking);
	app.myTrxUA.trxUpdateBookingsSetReconciled(bookingSet,"UT Recon",null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(booking.recReason,"UT Recon");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete bookingSet;
	delete discrepSet;
end;
</source>
    </JadeMethod>
    <JadeMethod name="updateBookingRefItem" id="dbea7e6b-4647-429e-9762-319bf2736211">
        <source>updateBookingRefItem(	_bRefItem: CMIF_BookingRefItem io;
						_humidity: Decimal
						) protected;

/*
//cnwndl1
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 October 2009	cnwndl1	Initial creation

*/
// adm 160310 Par 22937 remove bolType
vars
	hazards : ObjectArray;
begin
	create hazards transient;
	_bRefItem.allTIHazards.copy(hazards);
	_bRefItem.set(	_bRefItem.cargoType,	//pCargoType : Integer;
					_bRefItem.clean,	//pClean : Boolean;
					_bRefItem.commodity,	//pCommodity : String;
					_bRefItem.description,	//pDescription : String;
					hazards,	//pHazards : ObjectArray;
					_humidity,	//pHumidity : Decimal;
					_bRefItem.inspected,	//pInspected : Boolean;
					_bRefItem.isoType,	//pIsoType : String;
					_bRefItem.quantity,	//pQuantity : Integer;
					_bRefItem.remarks,	//pRemarks : String;
					_bRefItem.temperature,	//pTemperature : Real;
					_bRefItem.ventilation,	//pVentilation : Decimal; 
					_bRefItem.getOxygen,	//pOxygen : Decimal;			
					_bRefItem.getCarbonDioxide,	//pCarbonDioxide : Decimal;	
					_bRefItem.curtainsIn,	//pCurtainsIn : Boolean;		
					_bRefItem.height,	//pHeight : Decimal;
					_bRefItem.length,	//pLength : Decimal;
					_bRefItem.width,	//pWidth : Decimal;
					_bRefItem.heightString,	//pHeightStr : String;
					_bRefItem.lengthString,	//pLengthStr : String;
					_bRefItem.widthString,	//pWidthStr : String;
					_bRefItem.typeString,	//pTypeStr : String;
					_bRefItem.shippingMarks,	//pShippingMarks : String;
					_bRefItem.density.Integer,	//pDensity : Integer;
					_bRefItem.volume,	//pVolume : Real;
					_bRefItem.productQuantity,	//pProductQuantity : Integer;
					_bRefItem.weight,	//pWeight : Decimal; //02.2.09 cnwrd1 par #18821 
					_bRefItem.cubicMetres,	//pCubicMetres : Real; 
					_bRefItem.myProduct,	//pProduct : CM_Product;
					_bRefItem.blnChangedByUser ,	//pChangedByUser : Boolean;
					_bRefItem.myEDIBookingRefTI,	//pEDIBookingRefTI : CM_EDIBookingRefTI;
					_bRefItem.rawEDIData,	//_rawEDIData : String;
					_bRefItem.myGeneratorType 	//_generatorType: CM_GeneratorType //cnwrd1 par 18220 23.2.09
					);
epilog
	delete hazards;
end;</source>
        <access>protected</access>
        <Parameter name="_bRefItem" type="CMIF_BookingRefItem" usage="io"/>
        <Parameter name="_humidity" type="Decimal"/>
    </JadeMethod>
</Class>
