    <JadeMethod name="getLocationDisplay" id="990075e7-9f16-41c0-aaab-fc22b72d8265">
        <source>getLocationDisplay(): Integer;
/*
----------   ----------  --------------------------------------------------
Created:	08 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.power then
		return LOC_Display_HasPower;	
	else
		return LOC_Display_Gap;
	endif;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
