    <JadeMethod name="setSealDetails" id="e8e46e71-8fee-4487-a337-340d4de336ce">
        <source>setSealDetails(_sealNumbers : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

