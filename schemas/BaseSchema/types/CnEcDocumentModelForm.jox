    <JadeMethod name="browseForDirectory" id="5376305a-4639-4dfd-8ddf-4579bd5c1fe7">
        <source>browseForDirectory(pStartDirectory:String):String protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2001 by cnwdad1
//
// Purpose:		Using a FileFolder object, let the user browse for a directory name,
//				and return the result.
//
// Parameters:	None
//
// Returns:		The name of the selected directory, or null if the usr cancelled.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 12/03/2003	cnwdad1		Added start directory when browsing.
// --------------------------------------------------------------------------------
vars
	fileFolderObj	: FileFolder;
	directoryPath	: String;
	
begin
	create fileFolderObj transient;
	directoryPath	:=	fileFolderObj.browseForFolder("Select data file directory", pStartDirectory);

	return directoryPath;
epilog
	delete fileFolderObj;
end;</source>
        <access>protected</access>
        <Parameter name="pStartDirectory" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="browseForFile" id="5923934a-3717-4519-a755-2dea51c91cb0">
        <source>browseForFile():String protected;
// --------------------------------------------------------------------------------
// Created:		30 October 2002 by cnwdad1
//
// Purpose:		Using a File object, let the user browse for an existing file, and
//				and return its name.
//
// Parameters:	None
//
// Returns:		The name of the selected file, or null if the usr cancelled.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	xmlFileObj	: File;
	fileFilter	: String;
	
begin
	create xmlFileObj transient;
	fileFilter	:=	"All Files (*.*)|*.*|XML Files (*.xml)|*.xml";
	
	if xmlFileObj.cnEcSetOpenName(true, true, fileFilter) then
		return xmlFileObj.fileName;
	else
		return null;
	endif;
epilog
	delete xmlFileObj;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="btnBrowseDir_click" id="bacdc615-4dd7-4ba1-b7de-4a083b411a13">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBrowseDir_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		05 July 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 12/03/2003	cnwdad1		Added default start directory when browsing.
// --------------------------------------------------------------------------------
vars
	directoryPath	: String;
	
begin
	app.mousePointer	:= Busy;
	directoryPath		:=	txtDirectoryName.cnEcString();
	directoryPath		:=	self.browseForDirectory(directoryPath);
	
	if directoryPath &lt;&gt; txtDirectoryName.cnEcString() then
		txtDirectoryName.cnEcSet(directoryPath);
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnBrowseInput_click" id="2eaa8133-a783-46c6-87e9-8b235725f4b4">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnBrowseInput_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		30 October 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	filePath	: String;
	
begin
	app.mousePointer	:= Busy;
	filePath			:=	self.browseForFile();
	
	if filePath &lt;&gt; null then
		txtInputFile.text	:=	filePath;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
