    </JadeMethod>
    <JadeMethod name="testIsControllerAvailSubBlock" id="53893d59-2897-43e4-bc50-d62cb5c05f3e">
        <source>testIsControllerAvailSubBlock(pCheckLabour, pCheckLocation, pCheckSubBlock : Boolean): Boolean;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		This test for availability is used during convertion from grid area to a sub block stack
//				This is a different requirement from testIsControllerAvailable which is used during autoplanning and moving
//				The 2 methods ask different questions for different situations
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.usage &lt;&gt; NORMAL_USE then
		app.raiseCMException(ERR_LC_INAPPROPRIATE, null, null);
		return false;
	endif;

	if self.availability = PAD_UNAVAILABLE or self.availability = PAD_USER_UNAVAILABLE then
		app.raiseCMException(ERR_LC_UNAVAILABLE, null, null);
		return false;
	endif;

// NEED THE SUB BLOCK STACKJ to check this incase we are updating
//	if pCheckSubBlock then
//		if self.mySubBlockStack &lt;&gt; null then
//			app.raiseCMException(ERR_CONV_HAS_SUB_BLOCK, null, null);
//			return false;
//		endif;
//	endif;

	return inheritMethod(pCheckLabour, pCheckLocation, pCheckSubBlock);
end;</source>
        <Parameter name="pCheckLabour" type="Boolean"/>
        <Parameter name="pCheckLocation" type="Boolean"/>
        <Parameter name="pCheckSubBlock" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerAvailable" id="8cb54c88-914d-4d0b-9d69-5614277c351f">
        <source>testIsControllerAvailable(_autoMovePlan: CMIF_AutoMovePlan input);
//Is this Stack Controller available?
vars
	numControllers : Real;
	noAccessString	: String;
begin
	_autoMovePlan.updateController(null);

	if self.usage = BUILDING_USE then
		_autoMovePlan.addVerboseLogEntry(app.getErrorString1(Building_unusable, self.getFullId), IsError, Building_unusable);
		return;
	endif;
	if self.usage = LIGHT_TOWER_USE then
		_autoMovePlan.addVerboseLogEntry(app.getErrorString1(Light_tower_unusable, self.getFullId), IsError, Light_tower_unusable);
		return;
	endif;
	if self.availability = PAD_UNAVAILABLE or self.availability = PAD_USER_UNAVAILABLE then
		_autoMovePlan.addVerboseLogEntry(app.getErrorString1(Unavailable, self.getFullId), IsError, Unavailable);
		return;
	endif;

	//epr 12/8/13 don't actually need to do this testIsControlerFull will &amp; gc.isStackFull will check pad height availability to determine if full
	if not self.amIAvailable() then // PAR 17886
		_autoMovePlan.addLogEntry(app.getErrorString1(Unavailable, self.getFullId), IsError, Unavailable);
		return;
	endif;
	//-----------------
	//Test for sub block stacks
	//-----------------
	if self.mySubBlockStack &lt;&gt; null then
		//_autoMovePlan.addLogEntry(self.getFullId &amp; " is Sub-block stacked.", IsError); //- cnwmd1, Par 20524
		_autoMovePlan.addLogEntry(app.getErrorString1(Subblock_stacked, self.getFullId), IsError, Subblock_stacked);
		return;
	endif;
	//---------------
	//Check NEXT area
	//---------------
	numControllers := self.calculateMoveLCs(_autoMovePlan.myTrackedItem);
	if numControllers &gt; 1 and not _autoMovePlan.checkingSecondary then
		if self.getNextControllerOfType(CM_TowerController) &lt;&gt; null then
			_autoMovePlan.addVerboseLogEntry(app.getErrorString1(Reefer_tower_is_present,self.getFullId), IsError, Reefer_tower_is_present);
			return;
		endif;
		if self.myNextController = null then // AKBJULY2002 removed not	
			_autoMovePlan.addVerboseLogEntry(app.getErrorString(Next_positi_contai_longer_than), IsError, Next_positi_contai_longer_than);// PAR 17386 		
			return;
		endif;	
		if self.myNextController.isSuitableForTI(_autoMovePlan) = false then
			//epr par 31492 - with resequencing need to beable to plan/queue with warning until the real move which is a error
			if _autoMovePlan.isAutoPlanMove then	
				_autoMovePlan.addVerboseLogEntry(app.getErrorString1(Suitab_contai_longer_than_foot,self.getFullId), _autoMovePlan.getLogType, Suitab_contai_longer_than_foot); // PAR 5723 PAR 17386		
			endif;
			return;
		endif;
		_autoMovePlan.checkingSecondary := true;
		self.myNextController.testIsControllerAvailable(_autoMovePlan);
		_autoMovePlan.checkingSecondary := false;
		if _autoMovePlan.getController = null then
			return;
		endif;

		// Fork Lift Stack Enhancements		
		if _autoMovePlan.myTrackedItem.getActualLength() &gt; self.myTerminalArea.locationLength and self.getMyNextController(CM_GapController) &lt;&gt; null then
			_autoMovePlan.addVerboseLogEntry(app.getErrorString1(Cannot_over,self.getFullId), IsError, Cannot_over); // PAR 17386
			return;
		endif;

	endif;

	// for fork lift stacks. check whether we can access this location by height. check the FLS maximum heights for Full, MT and Power against the TI we are moving
	if not self.testControllerHeightAccess(_autoMovePlan) then
		//epr par 31492 - with resequencing need to beable to plan/queue with warning until the real move which is a error
		_autoMovePlan.addVerboseLogEntry(app.getErrorString2(Locati_height_access_restri_fu,_autoMovePlan.myTrackedItem.id, self.getFullId), _autoMovePlan.getLogType, Locati_height_access_restri_fu);
		if _autoMovePlan.isAutoPlanMove then
			return;
		endif;
	endif;

	if _autoMovePlan.moveMode &lt;&gt; REAL_MODE or _autoMovePlan.isRadioTelemetryMove then
		if not _autoMovePlan.myTrackedItem.canTIAccessTarget(_autoMovePlan, self) then
			noAccessString := self.myTerminalArea.getNoAccessString(_autoMovePlan.myTrackedItem, self);
			// epr 24556 25/6/10 This is to sort a problem with reaching over a real cargo item
			if self.allTrackedItems.size = 0 then
				_autoMovePlan.addVerboseLogEntry(noAccessString, IsError, Locat_restr_acces_cargo_front_);
			else
				_autoMovePlan.addVerboseLogEntry(noAccessString, IsWarning, Locat_restr_acces_cargo_front_);// PAR 15364 was IsError
			endif;
			
			return;
		endif;
	endif;

	//We are happy, so set ref to us.
	_autoMovePlan.updateController(self);
end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerSuitable" id="5f775f27-640a-4b23-95cd-54e2dd88c8ce">
        <source>testIsControllerSuitable(	_cmifAutoPlan 			: CMIF_AutoMovePlan;	
							lTIOriginalIs40, 
							lTIToMoveIs40					: Boolean;
							sourceLocn, targetLocn			: CM_StackController;
							_currentAccess 					: Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/06/2018	jlgmd1		TFS #37853 - Allow overstowing to work for 30, 45 and 53's
// ---------------------------------------------------------------------------

vars
	selfAccess,
	targetAccess,
	lTargetAccess40	: Integer;
	fullId			: String;
	differentArea,
	tiIs45,
	tiIs53			: Boolean;
	lcToCheck		: CM_GridController;
	ti				: CM_TrackedItem;
	
begin

	// Get the access that our primary ti target locations has.
	fullId := self.getFullId;
	
	// Get access of self.
	selfAccess := self.myTerminalArea.isAccessRestricted(false,self, null,null); // What is their  access like - front, back or both?
	
	if selfAccess = TA_ACCESS_NO then
		
		//_cmifAutoPlan.addLogEntry('No access at ' &amp; fullId, IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString1(Access,fullId), IsForLogging, Access);
		return false;
	endif;
	
	if self.myTerminalArea.allLocationsControllers.includes(targetLocn) then
		targetAccess := self.myTerminalArea.isAccessRestricted(false, targetLocn, null,null); 
	else
		// We aren't in same area so can't get in the way.
		differentArea := true;
		targetAccess := _currentAccess;
	endif;
	
	// if the  TI to move, as an overstow, is a 40 then we can not place over a gap
	if lTIToMoveIs40 
	and self.testMyNextController(CM_GapController) then
		//_cmifAutoPlan.addLogEntry('Cannot place 40 over gap', IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString(Cannot_place_over), IsForLogging, Cannot_place_over);
		return false;
	 endif; 
	 
	 // if we are moving a 40, as an overstow, then check that the location next to is suitable to stack a 40 at this height
	if lTIToMoveIs40 and
	   self.testMyNextController(CM_StackController) and
	   self.myNextController.CM_StackController.numTIs &lt;&gt; self.numTIs then
	   //_cmifAutoPlan.addLogEntry('Cannot place 40. Surface not flat', IsForLogging); //- cnwmd1, Par 20524
	   _cmifAutoPlan.addLogEntry(app.getErrorString(Cannot_place_surface_flat), IsForLogging, Cannot_place_surface_flat);
		return false;
	endif;

	// Don't want to block the target column if we have same access and target access isn't both.
	if not differentArea and (targetLocn.CM_StackController.column = self.column) then// and targetAccess &lt;&gt; _currentAccess then
		//_cmifAutoPlan.addLogEntry('Blocking target location', IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString(Blocking_target_location), IsForLogging, Blocking_target_location);
		return false;
	endif;
	
	// Don't what to hang over target column if we have the same access and target access isn't both.
	 if not differentArea and lTIToMoveIs40 and self.testMyNextController(CM_StackController) then
	 	if targetLocn.column = self.myNextController.CM_StackController.column then// and targetAccess &lt;&gt; _currentAccess then
	 		//_cmifAutoPlan.addLogEntry('40 back end is blocking target column', IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString(Back_blockin_target_column), IsForLogging, Back_blockin_target_column);
	 		return false;
	 	endif;
	 endif;

	// Don't want anything on top of original 40s right side.
	if not differentArea and lTIOriginalIs40
	and targetLocn.testMyNextController(CM_StackController)
	and targetLocn.myNextController.CM_StackController.column =  self.column  then
		//_cmifAutoPlan.addLogEntry('Cannot place over 40s back end target location', IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString(Canno_place_over_back_targe_lo), IsForLogging, Canno_place_over_back_targe_lo);
		return false;
	endif;

	// Don't put it back on yourself.	
	if sourceLocn = self then
		//_cmifAutoPlan.addLogEntry('Cannot place in own location', IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString(Cannot_place_location), IsForLogging, Cannot_place_location);
		return false;
	endif;

	// Don't get in the way of yourself 40.
	if lTIOriginalIs40 
	and sourceLocn.testMyNextController(CM_StackController)
	and sourceLocn.myNextController = self  then
		//_cmifAutoPlan.addLogEntry('Cannot place in 40s back end source location', IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString(Cannot_place_back_source_locat), IsForLogging, Cannot_place_back_source_locat);
		return false;
	endif;

	// Get access if we are moving 40/
	if lTIToMoveIs40 and self.testMyNextController(CM_StackController) then
		lTargetAccess40 := self.myTerminalArea.isAccessRestricted(false,self.myNextController, null,null); // What is their  access like - front, back or both?
		if lTargetAccess40 = TA_ACCESS_NO or (lTargetAccess40 &lt;&gt; _currentAccess and lTargetAccess40 &lt;&gt; TA_ACCESS_FRONT_BACK) then
			//_cmifAutoPlan.addLogEntry('No access for 40 back end ' &amp; self.myNextController.getFullId, IsForLogging); //- cnwmd1, Par 20524
			_cmifAutoPlan.addLogEntry(app.getErrorString1(Access_back, self.myNextController.getFullId), IsForLogging, Access_back);
			return false;
		endif;
	endif;
	
	if selfAccess = _currentAccess or selfAccess = TA_ACCESS_FRONT_BACK then 
	else
		
		//_cmifAutoPlan.addLogEntry('Different access', IsForLogging); //- cnwmd1, Par 20524
		_cmifAutoPlan.addLogEntry(app.getErrorString(Different_access), IsForLogging, Different_access);
		return false;
	endif;
	
	
	// Do a cut down strict grid check (this only applied to the start LC, not any of the rest)
	if lTIToMoveIs40 then
		ti := _cmifAutoPlan.myTrackedItem;
		tiIs45 := ti.isAttributeTrue(TI_Attrib_IsFortyFive);
		tiIs53 := ti.isAttributeTrue(TI_Attrib_IsFiftyThree);
		
		if tiIs45 then
			// Make sure we're within our grid
			if self.offset45 = CM_LocationsController.Offset45_Unavailable then
				_cmifAutoPlan.addLogEntry(app.getErrorString(Cannot_place_locati_strict45), IsForLogging, Access_back);
				return false;
			endif;
		endif;
		
		if tiIs53 then
			// Make sure we're within our grid
			if self.offset53 = CM_LocationsController.Offset53_Unavailable then
				_cmifAutoPlan.addLogEntry(app.getErrorString(Cannot_place_locati_strict53), IsForLogging, Access_back);
				return false;
			endif;
		endif;
		
		if tiIs45 or tiIs53 then
			// Make sure our backend doesn't end up somewhere it shouldn't
			if self.testMyNextController(CM_GridController) then
				if self.myNextController.testMyNextController(CM_GapController) then
					_cmifAutoPlan.addLogEntry(app.getErrorString(Cannot_place_over), IsForLogging, Cannot_place_over);
					return false;
				endif;
				
				// and check our backend isn't obstructing anything else
				if self.myNextController.testMyNextController(CM_GridController) then
					// The backend LC
					lcToCheck := self.myNextController.myNextController.CM_GridController;
	
					if lcToCheck.numTIs &gt; 0 and lcToCheck.offsetFlexi &lt; (ti.getActualLength mod lcToCheck.myTerminalArea.locationLength) then
						_cmifAutoPlan.addLogEntry(app.getErrorString(Conta_backe_conta_conta_canno_), IsForLogging, Access_back);
						return false;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	return true;
end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_AutoMovePlan"/>
        <Parameter name="lTIOriginalIs40" type="Boolean"/>
        <Parameter name="lTIToMoveIs40" type="Boolean"/>
        <Parameter name="sourceLocn" type="CM_StackController"/>
        <Parameter name="targetLocn" type="CM_StackController"/>
        <Parameter name="_currentAccess" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testOverstowLCAvailability" id="4086517c-cd8e-4e51-9cd2-758da8707ba6">
        <source>testOverstowLCAvailability() : Integer;
// ---------------------------------------------------------------------------
// Created:		15 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	accessHeight, heightAllowed,accessLocn	: Integer;
	lcToTest								: CM_GridController;
	gridRow									: CM_GridRow;
begin

	// if I have a height restriction, either none at all or a ' nothing from...' setting then use that to calculate the height. 
	// If the pad is generally available then go along the row to find the average height
	accessHeight := 0;
	if self.availability = PAD_UNAVAILABLE then 
		heightAllowed := 0;
		accessHeight := heightAllowed;
	elseif self.availability &lt;&gt; PAD_AVAILABLE and self.availability &lt;&gt;  PAD_USER_UNAVAILABLE then
		heightAllowed := self.availability - PAD_USER_UNAVAILABLE - 1;
		accessHeight := heightAllowed;
	else			
		accessHeight := self.myGridArea.heightOfStack;
	endif;
	return accessHeight;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="testOverstowLocations" id="2858ae3e-0d61-4b58-b548-7188179a4b7e">
        <updating/>
        <source>testOverstowLocations(obj: CMIF_AutoMovePlan input; rowLimit: Integer) updating;
//AJA 1/12/99: Tests locations either side of self for suitability as overstow
//locations
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	lcToTest		: CM_StackController;
	lc				: CM_LocationsController;
	closestNextLC,
	nextLC,
	priorLC, 
	closestPriorLC	: CM_StackController;
	i, closestNext, closestPrior :Integer;
	columns,
	rowAccessHeight,
	numberOfTis		: Integer;
begin

	app.verboseLogging := true;
	obj.updateController(null);
	rowAccessHeight := self.myGridArea.testOverstowLCAvailability(self);
	//obj.addLogEntry('Row Access Height for ' &amp; self.ident &amp; ' ' &amp; self.myGridArea.id &amp; ' ' &amp; rowAccessHeight.String, IsForLogging); //- cnwmd1, Par 20524
	obj.addLogEntry(app.getErrorString3(Access_height, self.ident, self.myGridArea.id, rowAccessHeight.String), IsForLogging, Access_height);
	lc := getMyNextController(CM_StackController);
	
	if lc &lt;&gt; null and lc.isKindOf(CM_StackController) then
		lcToTest := lc.CM_StackController;
		//------------------
		//Test the slots ahead of us in rows up to row limit value
		//------------------
		while lcToTest &lt;&gt; null do
			closestNextLC := null;
			closestNext := 0;
			
			i := i + 1;
			// We stop if greater than 100.
			// Par 9054 Isn't counting rows. Controllers stopping too soon.
	//		if i &gt; 100 then
	//			break;
	//		endif;
			if (lcToTest.row - self.row).abs &gt; rowLimit then
			
				//we have gone too far
				break;
			endif;
	
			numberOfTis := (lcToTest.numTIs + lcToTest.numQueuedTIs + lcToTest.numPlannedTIs);
			//obj.addLogEntry('Total tis for ' &amp; lcToTest.ident &amp; ' ' &amp; numberOfTis.String, IsForLogging); //- cnwmd1, Par 20524
			obj.addLogEntry(app.getErrorString2(Total_tis, lcToTest.ident, numberOfTis.String), IsForLogging,Total_tis);
			if not numberOfTis &gt;= rowAccessHeight then
				lcToTest.testOverstowMoveLocation(obj);	//test the pad
				if obj.getController() &lt;&gt; null then  //found a space
					
	  				closestNextLC := obj.getController.CM_StackController;
		  			closestNext := i;
					//obj.addLogEntry(closestNextLC.getFullId &amp; " is suitable", IsForLogging); //- cnwmd1, Par 20524
					obj.addLogEntry(app.getErrorString1(Parm_is_Suitable, closestNextLC.getFullId), IsForLogging, Parm_is_Suitable);
	    			break;
		    	endif;
		    endif;
			//------------------
			//get the next 'next' slot to test
			//------------------
	    	nextLC := lcToTest.getMyNextController(CM_StackController).CM_StackController;

		    if nextLC = null then   	//end of the row, jump to next row
				nextLC := lcToTest.myTerminalArea.CM_GridArea.allGridControllersByRowColumn[lcToTest.row + 1,1].CM_StackController;
		    endif;
		    lcToTest := nextLC;
		endwhile;
	endif;

	lc := self.getMyPreviousController(CM_StackController);
	if lc = null then
		
    	columns := self.myTerminalArea.CM_GridArea.allGridColumns.size;
		lc := self.myTerminalArea.CM_GridArea.allGridControllersByRowColumn[self.row - 1,columns];
	endif;
	if lc &lt;&gt; null and lc.isKindOf(CM_StackController) then
		lcToTest := lc.CM_StackController;
		obj.updateController(null);
		i := 0;
	
		//test the pads behind us up to the row limit
		while lcToTest &lt;&gt; null do
			closestPriorLC := null;
			closestPrior := 0;
			
			i := i + 1;
			// We stop if greater than 100.
			// Par 9054 Isn't counting rows. Controllers stopping too soon.
		//	if i &gt; 100 then
		//		break;
		//	endif;
		 	if (lcToTest.row - self.row).abs &gt; rowLimit then
		 		
		   		break;    //too far
		   	endif;
	
			numberOfTis := (lcToTest.numTIs + lcToTest.numQueuedTIs + lcToTest.numPlannedTIs);
			// obj.addLogEntry('Total tis for ' &amp; lcToTest.ident &amp; ' ' &amp; numberOfTis.String, IsForLogging); //- cnwmd1, Par 20524
			obj.addLogEntry(app.getErrorString2(Total_tis_2Params, lcToTest.ident, numberOfTis.String), IsForLogging, Total_tis_2Params);
			if not  numberOfTis &gt;= rowAccessHeight then
				lcToTest.testOverstowMoveLocation(obj); 	//test the pad
				if obj.getController &lt;&gt; null then  //found a space
					
			   		closestPriorLC := obj.getController.CM_StackController;
			   		closestPrior := i;
					//obj.addLogEntry(closestPriorLC.getFullId &amp; " is suitable", IsForLogging); //- cnwmd1, Par 20524
					obj.addLogEntry(app.getErrorString1(Parm_is_Suitable, closestPriorLC.getFullId), IsForLogging, Parm_is_Suitable);
					break;
				endif;
			endif;
			//get the next 'prior' slot
			lc := lcToTest.getMyPreviousController(CM_StackController);
			priorLC := lc.CM_StackController;
			if priorLC = null then   //end of row, jump to previous row
				
		    	columns := lcToTest.myTerminalArea.CM_GridArea.allGridColumns.size;
				lc := lcToTest.myTerminalArea.CM_GridArea.allGridControllersByRowColumn[lcToTest.row - 1,columns];
				if lc = null then
					break;
				endif;
				if lc.isKindOf(CM_StackController) then
					priorLC := lc.CM_StackController;
				else
					
					break;
				endif;
		    endif;
		   
		    lcToTest := priorLC;
		endwhile;
	endif;

	//Decide which location (if any) is best
	if closestNext &lt;&gt; 0 then		//we found a next slot
		if closestNext &lt;= closestPrior or closestPrior = 0 then
			
			obj.updateController(closestNextLC);
		else
			
			obj.updateController(closestPriorLC);		//but the prior slot is nearer
		endif;
	else
		if closestPrior &lt;&gt; 0 then		//must use prior slot
			obj.updateController(closestPriorLC);
		endif;
	endif;
	app.verboseLogging := false;
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="rowLimit" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateFromCMIF_GridRegion" id="99429b89-8cd3-41a7-87f2-34f073ebb137">
        <updating/>
        <source>updateFromCMIF_GridRegion(_controller : CMIF_GridTARegion) updating;
// ---------------------------------------------------------------------------
// Created:		21 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
		self.availability := _controller.availability;
		if self.availability = PAD_AVAILABLE and self.usage = UNAVAILABLE_USE then
			self.usage := NORMAL_USE;
		endif;
end;</source>
        <Parameter name="_controller" type="CMIF_GridTARegion"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="d2a922cb-96d1-4fc0-bc7f-f7116721db9d">
        <source>validateForUpdate(_realController: CM_StackController; _passport: CM_Passport input);
// -------------------------------------------
// Created 06 October 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_realController, _passport);
	if _realController &lt;&gt; null and _realController.hasTIs() then
		// Unavailable.
		if	self.availability = PAD_UNAVAILABLE and
			self.usage = UNAVAILABLE_USE and
			self.power = false then
			app.raiseCMException1(Track_items_there_canno_made_u, self.getFullId, null, null);
		// Has Power
		elseif	self.availability = PAD_AVAILABLE and
				self.usage = NORMAL_USE and
				self.power = true then
		// Light Tower
		elseif	self.availability = PAD_UNAVAILABLE and
				self.usage = LIGHT_TOWER_USE and
		 		self.power = false then
		 		app.raiseCMException1(Track_items_there_canno_made_l,self.getFullId, null, null);
		// Building
		elseif	self.availability = PAD_AVAILABLE and
				self.usage = BUILDING_USE and
				self.power = false then
				app.raiseCMException1(Track_items_there_canno_made_b, self.getFullId, null, null);
		// Available
		elseif	self.availability = PAD_AVAILABLE and
				self.usage = NORMAL_USE and
				self.power = false then
		endif;
	endif;


end;</source>
        <Parameter name="_realController" type="CM_StackController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="width" id="f66c23d1-3b14-4792-9171-19ec4efcca09">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>width(set: Boolean; _value: Real io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
	//	self.width := 2;
		self.width := _value;
//		if _value &lt;&gt; 2 then
			// At some point in the future the system will allow the user to specify a width for
			// a stack controller object. This has implications for determining what stackControllers
			// are required for a move, etc.
	//		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to set width to an invalid value - only 1 allowed');
//		endif;
	else
		_value := self.width;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Real" usage="io"/>
    </JadeMethod>
</Class>
