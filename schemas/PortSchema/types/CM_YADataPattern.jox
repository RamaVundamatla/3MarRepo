    <JadeMethod name="matches" id="5867a210-1788-4a68-9a70-b81ae646d7ad">
        <source>matches(_value: Object): Boolean;
//08 March 2010	cnwdw1	
//14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  
vars
	obj	 		: Object;
	objSet		: ObjectLongNameDict;
	pattern: CMIF_YAPattern;
	iter: Iterator;
	name: String;
begin

	create pattern transient;
	if self.myCriteriaType.type = YACriteriaType_ID then						//+cnwml2 PAR23586 POL CCMS 1878
		pattern.setPattern(self.pattern, CMIF_YAPattern.YAPattern_Range);
	else
		pattern.setPattern(self.pattern, CMIF_YAPattern.YAPattern_Wildcard);
	endif;
	
	create objSet transient;
	self.myCriteriaType.getObjects(objSet);
	iter := objSet.createIterator;
	while iter.next(obj) do
		iter.getCurrentKeys(name); //MTN-35226
		if pattern.match(name) and obj = _value then
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
	delete objSet;
	delete pattern;
end;</source>
        <Parameter name="_value" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="matchesStorage" id="3060895c-4dc1-4e4e-a0f8-c6864e273258">
        <source>matchesStorage(_value: Object): Boolean;
// 18/03/2013	cnwjre1	31221 do pattern match for storage configuration detail config - match the pattern against the parameter value 
//		not all possible candidates as method 'matches' does.
vars
	pattern: CMIF_YAPattern;
	name: String;
begin

	create pattern transient;
	if self.myCriteriaType.type = YACriteriaType_ID then						//+cnwml2 PAR23586 POL CCMS 1878
		pattern.setPattern(self.pattern, CMIF_YAPattern.YAPattern_Range);
	else
		pattern.setPattern(self.pattern, CMIF_YAPattern.YAPattern_Wildcard);
	endif;
	
	if _value &lt;&gt; null then
		name := _value.getYAIdentifier();
		if pattern.match(name) then
			return true;
		endif;
	endif;

	return false;

epilog
	delete pattern;
end;</source>
        <Parameter name="_value" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
