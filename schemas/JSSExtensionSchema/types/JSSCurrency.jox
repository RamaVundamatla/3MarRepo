    <JadeMethod name="setAmount" id="876fafc2-8ceb-4687-99c3-a5fe09a8b166">
        <updating/>
        <source>setAmount(pAmount:Real) updating;
// --------------------------------------------------------------------------------
// Created:		15 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.amount &lt;&gt; pAmount then
		self.amount	:=	pAmount;
	endif;
end;</source>
        <Parameter name="pAmount" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setExchangeRate" id="46cdf94f-5df5-42ca-a58d-9df633a54cfa">
        <updating/>
        <source>setExchangeRate(pExchangeRate:Real) updating;
// --------------------------------------------------------------------------------
// Created:		15 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.exchangeRate &lt;&gt; pExchangeRate then
		self.exchangeRate	:=	pExchangeRate;
	endif;
end;</source>
        <Parameter name="pExchangeRate" type="Real"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="1a71ff7d-8f95-46a7-ab1e-0e96b1df514e">
        <updating/>
        <source>updateMe(pAmount:Real; pExchangeRate:Real; pTheLocaleInfo:LocaleFullInfo; pTheRemoteLocaleInfo:LocaleFullInfo) updating;
// --------------------------------------------------------------------------------
// Created:		15 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setAmount(pAmount);
	self.setLocaleInfo(pTheLocaleInfo);
	self.setExchangeRate(pExchangeRate);
	self.setRemoteLocaleInfo(pTheRemoteLocaleInfo);
end;</source>
        <Parameter name="pAmount" type="Real"/>
        <Parameter name="pExchangeRate" type="Real"/>
        <Parameter name="pTheLocaleInfo" type="LocaleFullInfo"/>
        <Parameter name="pTheRemoteLocaleInfo" type="LocaleFullInfo"/>
    </JadeMethod>
    <JadeMethod name="wholeAmountInWords" id="87d89ab5-e98c-4716-8ae3-c30276b5a881">
        <source>wholeAmountInWords(pWholeUnits:String; pDecimalUnits:String):String;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Returns the receiver's currency amount, with the whole amount
//				expressed in words, and the decimal portion as digits.
//
// Parameters:	pWholeUnits - The name of the whole currency units, e.g. "Dollars".
//				pDecimalUnits - The name of the decimal currency units, e.g. "Cents".
//
// Returns:		The currency amount expressed in words.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theLocaleInfo	: LocaleFullInfo;
	stringValue		: String;
	wholeValue		: Integer;
	wholeAmount		: String;
	decimalAmount	: String;
	wordedAmount	: String;
	
begin
	create theLocaleInfo transient;
	self.getLocaleFullInfo(theLocaleInfo, true);
	
	stringValue		:=	self.getDecimalCurrency().String;
	wholeValue		:=	stringValue.Decimal.truncated();
	wholeAmount		:=	wholeValue.jssAsWords(theLocaleInfo);
	decimalAmount	:=	stringValue[(stringValue.pos(".", 1) + 1):end];

	if pWholeUnits = null then
		wordedAmount	:=	wholeAmount &amp; " " &amp; $JSS_LIT_AND;
	else
		wordedAmount	:=	wholeAmount &amp; " " &amp; pWholeUnits &amp; " " &amp; $JSS_LIT_AND;
	endif;
	
	if pDecimalUnits = null then
		wordedAmount	:=	wordedAmount &amp; " " &amp; decimalAmount;
	else
		wordedAmount	:=	wordedAmount &amp; " " &amp; decimalAmount &amp; " " &amp; pDecimalUnits;
	endif;
epilog
	delete theLocaleInfo;
	
	return wordedAmount;
end;</source>
        <Parameter name="pWholeUnits" type="String"/>
        <Parameter name="pDecimalUnits" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
