    <JadeMethod name="doSummarise" id="38edb4f7-8656-42db-aaea-973d62af69e0">
        <source>doSummarise(_all : Boolean);
/*

Date		    Who			Reason
13 October 2010	cnwas3	  Initial creation

*/

vars	
	tiSet : ObjectArray;
begin
	
	create tiSet transient;
	if _all then								//summarise all
		self.getAllCellsTIs(tiSet);
	else
		self.getSelectedCellsTIs(tiSet);			//summarise only selected cells
	endif;
		
	tiSet.removeInvalidObjects();
	tiSet.removeDuplicateObjects();
	
	if tiSet.isEmpty() then
		app.msgBox(app.getErrorString(Select_some_cargo_summarise), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;	
	
	self.myAssistant.showXTABSummaryDefinitionForm(tiSet,false,false,false,false);
	
epilog	
	delete tiSet;
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUserNotifications" id="f8796ca5-9b1d-4af2-9d7f-4b7cfffcb069">
        <source>doUserNotifications(_eventType : Integer; _theObject : Object; _eventTag : Integer; _userInfo : Any);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/03/2011	cnwdap1	Initial creation PAR #25163 CCMS SFW 1108
*/
vars
	result : String;

begin
	if _eventType = Event_KPICargoCountCompleted then
		result := app.getErrorString(Completed_successfully);
		self.statusLine.caption := app.getErrorString1(Cargo_count_generat_termina, _theObject.CM_Terminal.code) &amp; result;
	elseif _eventType = Event_KPICargoCountFailed then
		result := app.getErrorString(Failed);
		self.statusLine.caption := app.getErrorString1(Cargo_count_generat_termina, _theObject.CM_Terminal.code) &amp; result;
	endif;
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_theObject" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
