<Class name="CM_QStrDestTerminalMethod" id="0ee51fa3-066e-4cd7-a399-b4a0183d6282">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
