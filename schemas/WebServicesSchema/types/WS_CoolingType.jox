<Class name="WS_CoolingType" id="89377fe4-d975-4c67-9c14-1c30bdab4651">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Reefer container cooling type</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="description" id="aeb6e533-f81c-496d-af5d-8faabb7caab4">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Cooling Type Description ex. 1 = Air Cooled , 2 = Water Cooled</text>
    </PrimAttribute>
    <PrimAttribute name="id" id="50879f7c-dde3-4e32-a20d-85f5493f2c1d">
        <embedded/>
        <type name="Integer"/>
        <text>Cooling Type ID ex.1,2</text>
    </PrimAttribute>
    <JadeMethod name="initFields" id="e5534125-602c-4e7b-be2b-f3c8165faccb">
        <updating/>
        <source>initFields(_id:Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2009	#cnwdz2	 

*/

vars

begin
	self.id			:=  _id;
	if _id = ContainerAirCooled then
		self.description	:= ContainerAirCooledStr;
	endif;
	
	if _id = ContainerWaterCooled then
		self.description	:= ContainerWaterCooledStr;
	endif;
	
	if _id = ContainerCooledNull then
		self.description	:= ContainerCooledNullStr;
	endif;
epilog

end;</source>
        <Parameter name="_id" type="Integer"/>
    </JadeMethod>
</Class>
