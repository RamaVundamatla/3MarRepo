        <source>initForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189

*/

vars
	theTable : CM_EntryTable;
	entTableDef		: EntTableDef;
begin

	self.showDataOnStartup := false; 
	self.allowMultiSelectDelete := self.allowUpdate; 
	
	self.setTblDataEntRows(ETDef_DutyDoc);		

	//the following is needed to hide the thumbnail (not sure what useTblThumb does seemed to hide all tables
