    <JadeMethod name="setProxy" id="d20bce2c-a503-4efd-95d0-8773576d5165">
        <updating/>
        <source>setProxy(	_isActive : Boolean;
			_maxThresholdLevel : Integer;
			_minThresholdLevel : Integer;
			_myISOTypeGroup : CM_ISOTypeGroup;
			_myOperator : CM_Operator;
			_processingPriority : Integer;
			_reNotificationMinutes : Integer;
			_myTerminal : CM_Terminal
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.isActive := _isActive;
	self.maxThresholdLevel := _maxThresholdLevel;
	self.minThresholdLevel := _minThresholdLevel;
	self.myISOTypeGroup := _myISOTypeGroup;
	self.myOperator := _myOperator;
	self.processingPriority := _processingPriority;
	self.reNotificationMinutes := _reNotificationMinutes;
	
	self.myTerminal := _myTerminal;

epilog

end;</source>
        <Parameter name="_isActive" type="Boolean"/>
        <Parameter name="_maxThresholdLevel" type="Integer"/>
        <Parameter name="_minThresholdLevel" type="Integer"/>
        <Parameter name="_myISOTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_myOperator" type="CM_Operator"/>
        <Parameter name="_processingPriority" type="Integer"/>
        <Parameter name="_reNotificationMinutes" type="Integer"/>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="f4ef4f68-684f-458a-bfdf-8f7d0044fd68">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwndl1	Initial creation

*/

vars

begin

	if _property.name = CM_Threshold::lastNotified.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="d907ac88-c05a-4589-8dc6-ec25900721d5">
        <source>validateForDelete();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	if self.isActive then
		app.raiseCMException(Threshold_active, null, null);
	endif; 
	
	if self.lastNotified.Date.isValid then
		app.raiseCMException(Threshold_last_notified_set, null, null);
	endif; 

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="4f129763-8f59-4c48-93c2-a2a844b2ef1b">
        <source>validateMe();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	if self.myTerminal = null then
		app.raiseCMException(No_Terminal_specified, null, null);
	endif;
	
	if self.processingPriority &lt; 1 then
		app.raiseCMException(Threshold_priority_less_one, null, null);
	endif;
	
	if minThresholdLevel &gt; 0 and  maxThresholdLevel &gt; 0 then
		if minThresholdLevel &gt; maxThresholdLevel then
			app.raiseCMWarning(Min_greater_than_max, null, null, null);
		endif;
	endif;
	
	if minThresholdLevel &lt; 0 then
		app.raiseCMWarning(Level_not_less_than_zero, null, null, null);
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
</Class>
