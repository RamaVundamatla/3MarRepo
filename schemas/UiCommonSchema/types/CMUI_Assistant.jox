    <JadeMethod name="showAdditionalFreeStorage" id="2a5ff9d7-1617-49ba-afb6-ebfa79b0ba2e">
        <source>showAdditionalFreeStorage(_tiArray : CM_TIArray input;
							_inEditMode : Boolean) :  CMIF_TITransactionController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2012	cnwer1	Initial creation SFW 1295
08 August 2016	cnwma1	   TFS #2467 PAR #38101 PEN - Mass Edit Free Storage Time
*/

vars
	tmpForm : CMUI_AdditionalFreeStorage;
begin
	tmpForm := app.loadForm(CMUI_AdditionalFreeStorage, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_AdditionalFreeStorage;
	
	if tmpForm = null then
		return null;
	endif;
	

	
	tmpForm.inEditMode:=_inEditMode;
	//tmpForm.myTrackedItem := _ti;         // 09/08/2016 cnwma1 TFS #2467 PAR #38101
	tmpForm.setMyTrackedItems(_tiArray);    // 09/08/2016 cnwma1 TFS #2467 PAR #38101
	if tmpForm.showModal() = IDOK then
		return tmpForm.transController;
	endif;
epilog

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_inEditMode" type="Boolean"/>
        <ReturnType type="CMIF_TITransactionController"/>
    </JadeMethod>
    <JadeMethod name="showAdditionalInfoForm" id="c159593b-f3a3-496f-b204-39f08b831dbe">
        <source>showAdditionalInfoForm(_object : Object; _menuAction : CMUI_MenuAction);
//--------------------------------------------------
// Created:	28 October 2003 By: cnwgd1
//--------------------------------------------------
vars
	theForm : CMUI_AdditionalInfoNonMDI;
begin

	if _object = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _Object');
		return;
	endif;

	create theForm;
	theForm.setMyTerminal(self.myTerminal);
	theForm.createMyAssistant(CMUI_Assistant);	
	theForm.showWithObjectMode(_object, null);
	
end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showAggregateBreakBulkForm" id="c43c57d1-a653-468c-97c9-79dad1c8470a">
        <source>showAggregateBreakBulkForm( _ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2014	cnwndl1	Initial creation

*/

vars

	form : CMUI_AggregateBreakBulkForm;
	msg : String;

begin

	if _ti = null then
		msg := app.getErrorString(No_Cargo_selected);
	elseif not _ti.canMergeBreakBulk then	//24 Jun 2013
		msg := app.getErrorString(No_merge_cargo_not_BB);
	elseif not _ti.isOnSite then	//14 Jun 2013	NDL	Par 31826
		msg := app.getErrorString1(ERR_TI_NOT_ONSITE,_ti.id);
	endif;
	if msg &lt;&gt; null then
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	form := app.loadForm(CMUI_AggregateBreakBulkForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_AggregateBreakBulkForm;
	if form = null then
		return;
	endif;	
	
	if form.setMyTrackedItem(_ti) then
		form.showModal();
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="showAmendfreeStorage" id="9ef67232-f5fd-4c61-9cfa-49d67d2b5e3c">
        <source>showAmendfreeStorage(_tiArray : CM_TIArray input;
							_inEditMode : Boolean) :  CMIF_TITransactionController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days
*/

vars
	tmpForm : CMUI_AddFutureStAnniversary;
	tiArray : CM_TIArray;
	ti 		: CM_TrackedItem;
begin
	create tiArray transient;
	foreach ti in _tiArray do
//		if ti.getTransactionOfType(TRANS_TYPE_FUTURE_STORAGE) &lt;&gt; null  then
 // ### TFS BUG 60548 		if ti.hasStartedFutureStorageProcess()  then // ### TFS BUG 58953 29JUN2023 NAVAB1
		if ti.getBGPFutureActor(CM_FutureStorageProcess) &lt;&gt; null   then // ### TFS BUG 60548 29JUN2023 NAVAB1
			tiArray.add(ti);
		endif;
	endforeach;
	
	if tiArray.size() &lt;&gt; _tiArray.size() then
		app.msgBox( app.getErrorString2(Cargos_have_future_storag_tran,(_tiArray.size()- tiArray.size()).String,_tiArray.size.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
	
	tmpForm := app.loadForm(CMUI_AddFutureStAnniversary, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_AddFutureStAnniversary;
	
	if tmpForm = null then
		return null;
	endif;
	
	tmpForm.inEditMode:=_inEditMode;
	tmpForm.setMyTrackedItems(tiArray); 
	if tmpForm.showModal() = IDOK then
		return tmpForm.transController;
	endif;
epilog
	delete tiArray;
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
