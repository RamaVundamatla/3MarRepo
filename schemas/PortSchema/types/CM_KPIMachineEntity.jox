    <JadeMethod name="updateForSetdown" id="94e03692-9819-4f1e-a54b-b9dd88184295">
        <updating/>
        <source>updateForSetdown(_history :CM_MachineMoveHistory)updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	kpiLift	:CM_KPIMachineLiftDtl;
	kpiMove :CM_KPIMachineMoveDtl;
begin
	// setdown
	self.numMoves		:= self.numMoves + 1;		// number of moves that completed in period
	self.numTEU			:= self.numTEU + _history.getTEU;
	
	if _history.isEndOfLift then
		self.numLifts		:= self.numLifts + 1;	// number of lifts that completed in period
		
		kpiLift := self.createKPILiftDtl (_history);
		
		self.grossWorkingTime := self.grossWorkingTime + kpiLift.grossDuration;
		
		if kpiLift.isSingleLift then
			self.numSingleLift	:= self.numSingleLift + 1;
		endif;
		
		if kpiLift.isTwinLift then
			self.numTwinLift	:= self.numTwinLift + 1;
		elseif kpiLift.isTandemLift then
			self.numTandemLift	:= self.numTandemLift + 1;
		endif;
		
		if kpiLift.isMultiLift then
			self.numMultiLift	:= self.numMultiLift + 1;
		endif;
		
	endif;
	
	// create a move detail for every setdown
	kpiMove := self.createKPIMoveDtl (_history);
	
	self.allMachineHistory.add (_history);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_history" type="CM_MachineMoveHistory"/>
    </JadeMethod>
</Class>
