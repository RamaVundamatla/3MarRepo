    <JadeMethod name="displaySelectorGridObject" id="d2ff5fb3-7260-41ca-98c2-d391ebcd59cc">
        <updating/>
        <source>displaySelectorGridObject(_gridObject: CM_GridObject) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2011	cnwrd1	Initial creation

*/

vars
	aGO : CM_GridObject;
	aTA : CM_TerminalArea;
begin
	aGO :=_gridObject;
	if aGO &lt;&gt; null then
		aTA := aGO.getGridArea;
		
		self.allSelectedTAs.add(aTA);
		self.allSelectedTAGridObjs.add(aGO);		
		self.txtYardSource.caption := self.getYardSourceText();
	
		self.myAssignedTrackedItem := null;
		self.lblAssignCargo.visible := false;
		self.txtAssignCargo.visible := false;
		self.lblSrcLocn.visible := true;
		self.cmbSourceLocn.visible := true;
	endif;

epilog

end;</source>
        <Parameter name="_gridObject" type="CM_GridObject"/>
    </JadeMethod>
    <JadeMethod name="displaySelectorLocation" id="e5a41e62-fc34-4919-a1ea-8eddfe5eb8ac">
        <updating/>
        <source>displaySelectorLocation(_termArea: CM_TerminalArea) updating;

vars

begin
	if _termArea &lt;&gt; null then
		cmbSourceLocn.cnEcSetObjectIndex(_termArea);
		self.myAssignedTrackedItem := null;
		self.lblAssignCargo.visible := false;
		self.txtAssignCargo.visible := false;
		self.lblSrcLocn.visible := true;
		self.cmbSourceLocn.visible := true;
	endif;

end;
</source>
        <Parameter name="_termArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doAssignTI" id="10db3e9a-8719-44e4-a964-84f24d75a579">
        <updating/>
        <source>doAssignTI() updating, protected;

vars

	result : Integer;
	moveController : CMIF_MoveController;
	wle		: CM_WorkListEntry;
begin

	wle := self.myCurrentWLE;
	if wle = null then
		return;
	else
		sharedLock(wle);
	endif;

	create moveController transient;
	moveController.setMyToPrimaryLocation(self.getLocationController);
	moveController.setMyWorkListEntry(wle);
	moveController.setMyTrackedItem(self.myAssignedTrackedItem);
	moveController.setMoveMode(REAL_MODE);

	while true do
		app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Assign To Release', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
	
epilog
	if wle &lt;&gt; null then
		unlock(wle);
	endif;
	delete moveController;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="b8d2b21b-54f8-4791-8502-6ff9c22b4566">
        <updating/>
        <source>doSave() updating;

vars
	theReturn	: Integer;
	obj			: Object;
	pxyRequest 	: CM_Request;
	wle			: CM_WorkListEntry;
	wleArray 		: CM_WLEArray;
begin

	if self.myRequest = null then
		return;
	endif;
	
	
	app.mousePointer := MousePointer_HourGlass;
	
	//pxyRequest := app.createUpdateProxy(self.myRequest).CM_Request;	
	

	//create wleArray transient;
	
	//if not self.allWLEs.isEmpty then // cnwrd1 par 31069 22.2.2013
	//	self.allWLEs.copy ( wleArray );
	//else
	//	self.myRequest.allWorkListEntries.copy (wleArray);
	//endif;
	
	/*if self.allSelectedTAs.isEmpty() and
	   cmbSourceLocn.listObject &lt;&gt; null then
		self.allSelectedTAs.add(cmbSourceLocn.listObject.CM_TerminalArea);
		self.allSelectedTAGridObjs.add(null);
	endif;*/
	

	while true do
		app.myTrxUA.trxAmendBreakBulkRTQuantity( self.myCurrentWLE, self.txtNewQuantity.text.Integer, app.myPassport);
	//	app.myTrxUA.trxUpdateRequestDetails(pxyRequest, wleArray, self.allSelectedTAs, self.allSelectedTAGridObjs, self.isBestPick, self.isFIFO, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		else			
			theReturn := app.showErrorWarningDialog('Edit Break Bulk info ', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return;
		endif;
		break;
	endwhile;
	
	if self.myAssignedTrackedItem &lt;&gt; null then
		self.doAssignTI();
	endif;

	self.unloadForm();
epilog
	delete pxyRequest;
	delete wleArray;
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="getLocationController" id="66436e5a-43aa-43c7-b1b0-6267aa30c36d">
        <source>getLocationController() : CM_LocationsController protected;

vars

begin
	if self.myCurrentWLE &lt;&gt; null then
		// road
		if self.myCurrentWLE.job.isKindOf(CM_RoadJob) then
			return self.myCurrentWLE.getRoadReleaseLC();
		// rail
		elseif CM_YardWLE.hasInstance(self.myCurrentWLE) and not self.myCurrentWLE.CM_YardWLE.allLocationControllers.isEmpty then
			return self.myCurrentWLE.CM_YardWLE.allLocationControllers.first;
		endif;
	endif;
	return null;

end;</source>
        <access>protected</access>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getYardSourceText" id="63e8e93b-84c1-4c87-b872-ab0661765099">
        <source>getYardSourceText() : String protected;
// show source locations and options from CMUI_SelectISOSourceMulti
vars
	ta 		: CM_TerminalArea;
	aGO		: CM_GridObject;
	sep 	: String;
	result 	: String;
	count	: Integer;
begin	

	count := 1;
	foreach ta in self.allSelectedTAs do
		if self.allSelectedTAGridObjs &lt;&gt; null and self.allSelectedTAGridObjs.size &gt;= count then
			aGO := self.allSelectedTAGridObjs[count];
		else
			aGO := null;
		endif;
			
		if aGO = null then
			result := result &amp; sep &amp; ta.id;
		else
			result := result &amp; sep &amp; ta.id &amp; '(' &amp; aGO.label &amp; ')';
		endif;
		
		sep := ', ';
		count := count +1;
	endforeach;
	
	/*if self.isBestPick and
	   result &lt;&gt; "" then
		result := result &amp; " (" &amp; app.getErrorString(Best_pick) &amp; ")";
	endif;*/
	
	return result;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="36b18146-116c-4cee-b33a-9661d5b8f47d">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// populate form from selected delivery request
vars
	canEdit	: Boolean;
	str			: String;
	ti 			: CM_TrackedItem;
	aWle		: CM_WorkListEntry;
	aEntry		: CM_RTQueueEntry;
	aTask		: CM_RTQueueTask;
begin
	self.isSelectorCapable := false;


	/*str := app.getErrorString4(DeliveryRequestInfo,
							   self.myDeliveryRequest.deliveryNumber,
							   self.myDeliveryRequest.totalRequested.String,
							   isoType,
							   self.myDeliveryRequest.consigneeCode);
	if self.myDeliveryRequest.myOriginatingBulkRelease &lt;&gt; null and 
	   self.myDeliveryRequest.myOriginatingBulkRelease.canBeHiLoCube then
		str := str	&amp; " " &amp; app.getErrorString(CanBeHiLowCube) &amp; ".";
	endif;*/
	aWle := self.myCurrentWLE;
	ti := aWle.myTrackedItem;
	
	if ti.isOnTruck or ti.isOnWagon or ti.isOnShip then
		str := 'Cargo : ' &amp; ti.id &amp; ', Current Quantity Required ' &amp; aWle.quantity.asStringJMT;
	else
		//internal move or release
		str := 'Cargo : ' &amp; ti.id &amp; ', Current Quantity Required ' &amp; aWle.quantity.asStringJMT &amp; ', from ' &amp; ti.myPrimaryActualLocation.myTerminalArea.id;
	endif;
	
	self.lblRequestDesc.caption := str;
	
	//self.myAssistant.comboBoxSourceArea2(self.cmbSourceLocn, self.myRequest.allTerminalAreas.first, false, false);

	// require permission to edit many of the fields
	//canEdit := app.getMyUser.canDo(self.myTerminal, PmYardEditRelReq);
	canEdit := true;
	
//	self.caption := app.getErrorString(Edit_Request) &amp; " " &amp; self.myDeliveryRequest.deliveryNumber &amp; " " &amp; self.myTerminal.code;
	
	self.cmbSourceLocn.setFocus();
end;
</source>
        <access>protected</access>
    </JadeMethod>
