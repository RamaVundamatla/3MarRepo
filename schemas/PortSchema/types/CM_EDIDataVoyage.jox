    <JadeMethod name="getVesselName" id="37a7059f-ce26-42b8-b8aa-940308a33576">
        <source>getVesselName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022 navsj20	ChangeRequest 55084: EUP - EDI Administration Usability Requirements
02 Jan 2023 navdp20 Bug 55706: MTN - Getting a 1201 error when doing an EDI Message Admin search (advanced search) by vessel
*/

vars
	ediTi: CM_EDITrackedItem;
begin
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDIVoyageTI) then   //2.1.2023 navdp20 TFS 55706
			return ediTi.CM_EDIVoyageTI.vesselName;
		endif;	//2.1.2023 navdp20 TFS 55706
	endforeach;
	return null;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
