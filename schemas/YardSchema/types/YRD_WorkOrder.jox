    <JadeMethod name="cmbTerminalAreaType_lostFocus" id="46e70083-faff-42db-85ca-9f870654c896">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTerminalAreaType_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
30 March 2022	navma1	Initial creation   TFS 52351
03/08/2022		navcs2	Bug 54407: MTN - Work Order Maintenance - Inappropriate To Terminal Area List when To Terminal Area Type hasn't been Selected
*/

vars
	areaTypeCode : Integer;
	areaType 	 : CM_TerminalAreaType;
	ta			 : CM_TerminalArea;
	
begin


	areaTypeCode := TA_TYPE_NULL;
	
	if combobox.listObject &lt;&gt; null then		
		areaTypeCode := combobox.listObject.CM_TerminalAreaType.type; 
	endif;
	
	if self.myPxyTask &lt;&gt; null and self.myPxyTask.CM_WodMove.myTargetLocation &lt;&gt; null   then
		ta   	:= self.myPxyTask.CM_WodMove.myTargetLocation.myTerminalArea;
	endif;
	
	// 03/08/2022	navcs2	Bug 54407
	if areaTypeCode = TA_TYPE_NULL or areaTypeCode = null then
		cmbTerminalArea.clear;
		cmbYardLocation.clear;	// 15/08/2022	navcs2	Bug 54407
		return; 
	endif;
	
	self.cmbTerminalArea.gotFocus(self.cmbTerminalArea);	
	myAssistant.comboBoxTerminalArea(self.cmbTerminalArea,areaTypeCode,ta);
	self.cmbTerminalArea.lostFocus(self.cmbTerminalArea);
	self.cmbTerminalArea.enabled := true;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbTerminalArea_lostFocus" id="5e45da5d-0918-462d-98cc-09988e038307">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTerminalArea_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2022		navma1	Initial creation   TFS 52351
 // ### JIRA 27470 29OCT2024 NAVAB1 - there was a local variable collection that was the same as a collection on the form, 
														the local var was created added to the combo and then deleted in the epilog. 
														Now it is using the collection of the form.
*/

vars
	tmpTA 		: CM_TerminalArea;
	allLCsSet	: CM_LCSet;
begin
	
	tmpTA := combobox.listObject.CM_TerminalArea;
	
	// create allLCsSet transient;
	self.allLCsSet.clear();
	
	if tmpTA = null then
		self.cmbYardLocation.clear();		
	elseif not tmpTA.isKindOf(CM_BlockStack) then
	
		if tmpTA.isKindOf(CM_Rail) then	
			//allLCsSet.clear();
			tmpTA.CM_Rail.getValidLCsCollectionForMove(self.allLCsSet);
			self.myAssistant.comboBoxLocationControllers(self.cmbYardLocation, self.allLCsSet, false);
		elseif tmpTA.isKindOf(CM_IrregularBlockArea) then	
			//allLCsSet.clear(); 
			tmpTA.CM_IrregularBlockArea.getValidLCsCollectionForMove(self.allLCsSet);
			self.myAssistant.comboBoxLocationControllers(self.cmbYardLocation, self.allLCsSet, false);
		else
			self.myAssistant.comboBoxLocationControllers(self.cmbYardLocation, tmpTA.getLCsCollectionForDisplay, false);
		endif;
		
		self.cmbYardLocation.enabled := true;
		//self.cmbYardLocation.lostFocus(self.cmbYardLocation);
	endif;
	
	
epilog
	//delete allLCsSet;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
