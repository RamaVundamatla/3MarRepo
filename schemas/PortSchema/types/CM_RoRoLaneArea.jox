		self.pxySetLabels(_leftLabel, _rightLabel, null, null);
		
		self.laneCount 		:= _laneCount;
		self.maxLaneLen 	:= _maxLaneLen;
		self.standardGap 	:= _standardGap;
		
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_maxLaneLen" type="Decimal"/>
        <Parameter name="_standardGap" type="Decimal"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
