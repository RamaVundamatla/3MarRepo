    <JadeMethod name="createPassport" id="c32101a8-e8fe-4f19-911e-0615319867fa">
        <updating/>
        <source>createPassport() : CM_Passport updating;
// ---------------------------------------------------------------------------
// Created:     06 December 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
17 Dec 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	saveUseSilentLockExHandler : Boolean;
	saveSilentLockRetries : Integer;
	context : Integer;									//navra1 - MTN-36928 - 8th Jan 2026-1

begin
	saveUseSilentLockExHandler := false;
	if app.myPassport &lt;&gt; null then
		// Carry forward the silent locking handler PAR 17377
		saveUseSilentLockExHandler := app.myPassport.useSilentLockExHandler;
		saveSilentLockRetries := app.myPassport.silentLockRetries;
		context := app.myPassport.context;													//navra1 - MTN-36928 - 8th Jan 2026-1
		
		delete app.myPassport;
	endif;
	
	create app.myPassport transient;
	
	app.myPassport.useSilentLockExHandler := saveUseSilentLockExHandler;
	app.myPassport.silentLockRetries := saveSilentLockRetries;
	app.myPassport.setContext(context);														//navra1 - MTN-36928 - 8th Jan 2026-1

//	PAR #17554 - removed this code, because it causes a 1048 exception
//	if self.isWebApp then
//		currentSession.myPassport := app.myPassport;
//	endif;
	
	// Par 14252
	if self.isRTApp then
		app.myPassport.setWarningsIgnored(true);
	endif;
	
	// Deadlock replay
	app.myPassport.hadDeadlock              := false;
	app.myPassport.silentDeadlockLimit      := 3;
	app.myPassport.silentDeadlockRetryCount := 0;
	app.myPassport.silentDeadlockSleepTime  := 2000;

	return app.myPassport;

end;</source>
        <ReturnType type="CM_Passport"/>
    </JadeMethod>
