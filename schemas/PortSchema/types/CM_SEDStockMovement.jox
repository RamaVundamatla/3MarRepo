<Class name="CM_SEDStockMovement" id="1b2a549e-ef7b-48c0-9612-5ebba7bca0d2">
    <superclass name="CM_LogObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="logObjs"/>
    <PrimAttribute name="adjustVolume" id="f49ce0d8-14d9-4af2-86a3-1d8de9786d8b">
        <precision>12</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="adjustWeightKgs" id="e5bfc5fb-4c8e-4586-88c7-f7eceb3fbdff">
        <precision>14</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <CompAttribute name="allTrackedItemIDs" id="2eded6d0-1a73-45bf-8b3c-65ebb4ccf4fc">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <ImplicitInverseRef name="allTrackedItems" id="4bbe9160-e922-4743-b738-34b9f621b55c">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myStockMovementExt" id="17e2ffa8-4a35-40ba-ac91-00fbf2dcef38">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_StockMoveLogExt"/>
        <access>readonly</access>
        <Inverse name="CM_StockMoveLogExt::allSEDStockMoves"/>
    </ExplicitInverseRef>
    <PrimAttribute name="sedMean" id="28f79ee9-1c19-480f-92e8-748a227f116c">
        <precision>6</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addTrackedItem" id="27a7b2ee-275c-49ff-b842-9a3359c0ba16">
        <updating/>
        <source>addTrackedItem(_ti : CM_Log; _weight : Decimal; _volume : Real) updating;
// ---------------------------------------------------------------------------
// Created:     05 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _ti.sedMean &lt;&gt; self.sedMean then
		app.raiseUnexpectedProgramError(class.name, method.name, 
					'Attempt to add ti (' &amp; _ti.String &amp; ') with incorrect mean (' &amp;
					_ti.sedMean.String &amp; ',  ' &amp; self.sedMean.String &amp;
					') to ' &amp; self.String);
		return;
	endif;

	self.allTrackedItems.add(_ti);
	self.allTrackedItemIDs.add(_ti.id);
	
	self.adjustWeightKgs := self.adjustWeightKgs + _weight;
	self.adjustVolume := self.adjustVolume + _volume;

end;</source>
        <Parameter name="_ti" type="CM_Log"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Real"/>
    </JadeMethod>
    <JadeMethod name="init" id="94d8311d-eda2-419c-93d4-4715c1728956">
        <updating/>
        <source>init(_sedMean : Real; _stkMove : CM_StockMoveLogExt) updating;
// ---------------------------------------------------------------------------
// Created:     05 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.sedMean			:= _sedMean;
	self.myStockMovementExt	:= _stkMove;

end;</source>
        <Parameter name="_sedMean" type="Real"/>
        <Parameter name="_stkMove" type="CM_StockMoveLogExt"/>
    </JadeMethod>
</Class>
