    <JadeMethod name="getSelectedDLRSOBSlots" id="cc347a00-0998-4e9f-baa1-ceeec7c31845">
        <source>getSelectedDLRSOBSlots(_theSlots: CM_LCArray input; _theSlotsAlt: CM_LCArray input; _editions: CM_ObjectByOidEditionDict input; _isLoad : Boolean); // PAR 31144
/*
Purpose:			
Date		Who		Reason
09 September 2011	cnwab1	Initial creation
*/

vars

begin
	if self.mySideViewForm &lt;&gt; null then // PAR 29054
		self.mySideViewForm.myROROLocnDrawingController.getSelectedDLRSOBSlots(_theSlots, _theSlotsAlt, _isLoad); // PAR 31144
		self.mySideViewForm.myROROLocnDrawingController.allObjectEditions.copyNoDuplicates(_editions, false);
	endif;

	if not _theSlots.includesVoyageROROController() then		//cnwmc5 - 4 August 2014 - PAR 34361
	//if _theSlots.isEmpty() then // PAR 29054					//cnwmc5 - 4 August 2014 - PAR 34361
		self.myROROPlanDrawController.getSelectedDLRSOBSlots(_theSlots, _theSlotsAlt, _isLoad); // PAR 31144
		self.myROROPlanDrawController.allObjectEditions.copyNoDuplicates(_editions,false);
	endif;
epilog

end;</source>
        <Parameter name="_theSlots" type="CM_LCArray" usage="input"/>
        <Parameter name="_theSlotsAlt" type="CM_LCArray" usage="input"/>
        <Parameter name="_editions" type="CM_ObjectByOidEditionDict" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
