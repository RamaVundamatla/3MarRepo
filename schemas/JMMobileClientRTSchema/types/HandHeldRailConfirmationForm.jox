        <updating/>
        <source>btnConfirm_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		27 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.showingForInwards then
		self.doConfirmContainerIn();
	else
		self.doConfirmContainerOut();
	endif;	
end;</source>
