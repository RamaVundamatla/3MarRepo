	app.mousePointer := Window.MousePointer_HourGlass;
	self.scrollTo(self.myHScroll.max, 1);
	
epilog 
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="scrollsHorizontally" id="ad59526f-d720-4123-9d6f-ebabcf2a5050">
        <source>scrollsHorizontally() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theWidth : Integer;
begin

	if self.myScrollingFrame &lt;&gt; null then
		theWidth := (self.myScrollingFrame.width + self.myVLabels.width).Integer;

		if (self.scrollBars = ScrollBars_Horizontal or 
		   self.scrollBars = ScrollBars_Both) and 
		   self.clientWidth &lt; theWidth then
			return true;
		endif;
	endif;	
	return false;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="scrollsVertically" id="4aa868d1-efd9-431d-9b5c-c29da73be342">
        <source>scrollsVertically() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theHeight : Integer;

begin

	if self.myScrollingFrame &lt;&gt; null then
		if self.hasHLabels then
			theHeight := (self.getVerticalHeight() + self.myHLabels.height + self.bottomLabelMargin).Integer;
		else
			theHeight := (self.getVerticalHeight() + self.bottomLabelMargin).Integer;
		endif;
		
		if (self.scrollBars = ScrollBars_Vertical or
		   self.scrollBars = ScrollBars_Both) then
		   return self.clientHeight &lt; theHeight;
		endif;
	endif;	
	return false;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBottomLabelMargin" id="41438739-421b-44b3-8842-7988096fdb0e">
        <updating/>
        <source>setBottomLabelMargin(_margin : Real)updating;
//--------------------------------------------------
// Created:	12 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.bottomLabelMargin := _margin;
end;</source>
        <Parameter name="_margin" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setFocusToDummy" id="eb6b38e0-fe4c-4927-879d-56e228dd9eef">
        <source>setFocusToDummy();
// ---------------------------------------------------------------------------
// Created:     04 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txtBox	: TextBox;
begin

/*	
	if self.form.class.name = 'HMS_GraphicalViewX' then
		txtBox := self.form.getPropertyValue('txtDummy').TextBox;
	endif;
*/

	txtBox := self.myDummyTextBox;
	if txtBox &lt;&gt; null then
		txtBox.setFocus();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFrameDefaults" id="e42e0a5d-46dc-4410-bda6-a3048c29bdcc">
        <updating/>
        <source>setFrameDefaults(pFrame : CMUI_Frame input) updating ,protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	pFrame.bevelInner		:= 0;
	pFrame.bevelInnerWidth	:= 0;
	pFrame.bevelOuter		:= 0;
	pFrame.bevelOuterWidth	:= 0;
	pFrame.boundaryBrush	:= BoundaryBrush_Solid; //pFrame.BoundaryBrush_Dotted;//BoundaryBrush_Solid;
	pFrame.boundaryWidth	:= 0;
	pFrame.caption			:= null;
	pFrame.autoRedraw 		:= true;

end;</source>
        <access>protected</access>
        <Parameter name="pFrame" type="CMUI_Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHLabelDetails" id="4215ecb0-97d1-4f2e-89c2-1595cec86dfc">
        <updating/>
        <source>setHLabelDetails(pHeight : Real; _alignBottom : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	newTop,
	oldHeight	: Real;

begin
	self.hLabelsAlignBottom := _alignBottom;
	oldHeight := self.myHLabels.height;
	self.myHLabels.height := pHeight;
	self.myTopLeftFillerFrame.height := pHeight + self.bottomLabelMargin;
	
	if _alignBottom then
		self.myHLabels.top := self.clientHeight - pHeight - self.myHScroll.clientHeight;
		self.myHLabels.parentAspect := ParentAspect_AnchorBottom;
		self.myTopLeftFillerFrame.top := self.myHLabels.top- self.bottomLabelMargin;
		self.myTopLeftFillerFrame.parentAspect := ParentAspect_AnchorBottom;
		
		if self.myScrollingFrame &lt;&gt; null
		and self.myScrollingFrame.top &gt; 0
		then
			self.myScrollingFrame.top := 0;
			self.myVLabels.top := 0;
		endif;
	else
		newTop := self.myVLabels.top - oldHeight + pHeight;
		self.myVLabels.top := newTop;
		
		if self.myScrollingFrame &lt;&gt; null then
			self.myScrollingFrame.top := newTop;
		endif;
	endif;
end;</source>
        <Parameter name="pHeight" type="Real"/>
        <Parameter name="_alignBottom" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLeftLabelMargin" id="c36e9e23-6b84-4c16-97c5-a313cc2ef1ff">
        <updating/>
        <source>setLeftLabelMargin(_value : Real) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
16 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.leftLabelMargin &lt;&gt; _value then
		self.leftLabelMargin:=_value;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setScrollingFrame" id="681b673d-e6e0-4eaf-b771-3ee6ddbe2b75">
        <updating/>
        <source>setScrollingFrame(_frame : CMUI_ScrollingFrame input) updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _frame = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'frame', null, null);
		return;
	endif;

	if self.myScrollingFrame = _frame then
		return;
	endif;

	if self.myScrollingFrame &lt;&gt; null then
		delete self.myScrollingFrame;
	endif;
	
	self.myScrollingFrame := _frame;

   	_frame.move(0, 0, _frame.width, _frame.height);
	_frame.visible := true;
	self.setFrameDefaults(_frame);
	_frame.borderStyle := BorderStyle_None;
	_frame.parent 	:= self;
	
	_frame.zOrder(0);		// send to the back
	
	self.myHLabels.zOrder(1);
	self.myVLabels.zOrder(1);
	self.myHScroll.zOrder(1);
	self.myVScroll.zOrder(1);
	self.myTopLeftFillerFrame.zOrder(1);
	self.myBottomRightFillerFrame.zOrder(1);

end;</source>
        <Parameter name="_frame" type="CMUI_ScrollingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setVLabelDetails" id="459af5f7-46b6-4bd4-9cd4-2669017b9196">
        <updating/>
        <source>setVLabelDetails(pWidth : Real; _alignLeft : Boolean)updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newLeft,
	oldWidth	: Real;

begin
	self.vLabelsAlignLeft := _alignLeft;
	oldWidth := self.myVLabels.width;
	self.myVLabels.width := pWidth;
	self.myTopLeftFillerFrame.width := pWidth;
	
	if self.vLabelsAlignLeft then
		newLeft := self.myVScroll.width;
		self.myVLabels.left := newLeft;
		self.myTopLeftFillerFrame.left := newLeft;
		self.myBottomRightFillerFrame.left := 0;
	endif;
	
	newLeft := self.myHLabels.left - oldWidth + pWidth + self.myVLabels.left;

	self.myHLabels.left := newLeft;

	if self.myScrollingFrame &lt;&gt; null then
		self.myScrollingFrame.left := newLeft;
	endif;
end;</source>
        <Parameter name="pWidth" type="Real"/>
        <Parameter name="_alignLeft" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showControl" id="21f65e35-e06a-4459-b011-88a0e306014c">
        <source>showControl(pControl : Control input);
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pControl = null then
		return;
	endif;
	
	pControl.visible := true;
	
end;</source>
        <Parameter name="pControl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="dada24ad-6276-4c4d-8e08-5759975dc455">
        <updating/>
        <source>windowCreated(cntrl: CMUI_ScrollableFrame input; persistCntrl: CMUI_ScrollableFrame) updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.isInPainter then
		return;
	endif;
	
	self.caption := null;
	self.autoRedraw := true;

	// Note that the order of creation is important here
	// as this sets the zOrder for the controls
	self.createLabelFrames();
	self.createHScroll();
	self.createVScroll();
	self.createFillerFrames();
	self.createDummyTextBox();

end;</source>
        <Parameter name="cntrl" type="CMUI_ScrollableFrame" usage="input"/>
        <Parameter name="persistCntrl" type="CMUI_ScrollableFrame"/>
    </JadeMethod>
