    <JadeMethod name="getAuditText" id="deadedea-1186-4830-bce6-3cbdbab08a44">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     May 2007 by cnwvu1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	txt			: String;
	tmpStr		: String;
	pathSegment	: HMS_PathSegment;
begin

	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();

	foreach pathSegment in allPathSegments do				
		if tmpStr = null then			
			tmpStr := pathSegment.description;		
		else	
			tmpStr := tmpStr &amp;', ' &amp; pathSegment.description;
		endif;	
	endforeach;		
	txt := txt &amp; 'PathSegments' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;		
	tmpStr:=null;		

	return txt;
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMinimumSteamingTime" id="ac50843a-24a0-4a32-b519-d95389adbb0c">
        <source>getMinimumSteamingTime(_vessel : CM_Vessel):Integer;
// --------------------------------------------------------------------------------
// Created:		03 March 2008 by cnwdad1
//
// Purpose:		Returns the minimum steaming time required to traverse the Movement
//				Path's path segments.
//
// Parameters:	_vessel - A reference to the Vessel using the Movement Path.
//
// Returns:		The nimimum steaming time, in minutes.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	steamingTime	: Integer;
	segmentObj		: HMS_PathSegment;
	
begin
	steamingTime	:=	0;
	
	foreach segmentObj in self.allPathSegments do
		steamingTime	:= steamingTime + segmentObj.getMinimumSteamingTime(_vessel);
	endforeach;
	
	return steamingTime;
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSteamingTimeForVessel" id="5aa7dce6-779f-4a2a-97c8-9b37b129fba5">
        <source>getSteamingTimeForVessel( _vessel : CM_Vessel) : Integer;
//-----------------------------------------------------------------------
//	Created:	01 February 2007 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	ps 			: HMS_PathSegment;
	duration	: Integer;
begin
	
	foreach ps in self.allPathSegments do
		duration := duration + ps.getSteamingTimeForVessel(_vessel);
	endforeach;
	
	return duration;
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="b5911187-183b-4c8f-b0d7-13756d6680df">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy 			: HMS_MovementPath;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myHarbour := self.myHarbour;
	proxy.myRegionFrom := self.myRegionFrom;
	proxy.myRegionTo := self.myRegionTo;
	proxy.myRoot := self.myRoot;
	
	self.allPathSegments.copy(proxy.allPathSegments);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6b402143-fc82-4f61-b379-39292d7b8fab">
        <updating/>
        <source>setForUpdate(_pxyMovement: HMS_MovementPath; _passport: CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyMovement, _passport);
	
	self.code 			:= _pxyMovement.code.toUpper.trimBlanks;
	self.description 	:= _pxyMovement.description;
	self.myHarbour 		:= _pxyMovement.myHarbour;
	self.myRegionFrom 	:= _pxyMovement.myRegionFrom;
	self.myRegionTo 	:= _pxyMovement.myRegionTo;
	
	self.allPathSegments.clear();
	_pxyMovement.allPathSegments.copy(self.allPathSegments);
	
	self.myRoot			:= _pxyMovement.myRoot;

end;</source>
        <Parameter name="_pxyMovement" type="HMS_MovementPath"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="5b18e698-9ccf-4c9f-b82d-4a721d5597f0">
        <updating/>
        <source>setProxy(_root : CM_Root; _regionFrom, _regionTo : HMS_HarbourRegion)updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.myRegionFrom := _regionFrom;
	self.myRegionTo := _regionTo;
	
	self.code 			:= code;
	self.description 	:= description;
	
	self.myRoot := _root;
	
end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_regionFrom" type="HMS_HarbourRegion"/>
        <Parameter name="_regionTo" type="HMS_HarbourRegion"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="3582535a-bcce-4342-b2f5-b0e13c784ddc">
        <source>validateForDelete(_passport: CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		13 October 2006 by cnwdad1
//
// Purpose:		Standard validation method for when the receiver is being deleted.
//
// Parameters:	_passport - A reference to the current User's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.allRoutes.cnEcIsNotEmpty() then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "Voyage Route", null, null);	
	endif;
	
	inheritMethod(_passport);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="8323fa3f-b1b1-4830-9022-5c4974cb3d43">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 04 July 2003 By: cnwgd1
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//--------------------------------------------------------------
vars

	realMovementPath,
	tmpMovementPath : HMS_MovementPath;
	pathSegment		: HMS_PathSegment;
	set				: ObjectSet;		
	
begin
	inheritMethod(_passport);
	
	create set transient;
	
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description,  null);
		app.raiseCMException(Input_required_field_desc, ETRow_Description,  null); // cnwdb2	PAR 35364
	endif;
	
	/* Lorcan no validation on harbour anymore
	if self.myHarbour = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Harbour', ETRow_MyHarbour,  null);
	endif;
	*/
	
	if self.myRegionFrom = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Region From', ETRow_MyRegionFrom,  null);
		app.raiseCMException(Input_required_field_regFrom, ETRow_MyRegionFrom,  null); // cnwdb2	PAR 35364
	elseif self.myRegionFrom.isTerminal() then
//		app.raiseCMException(HMS_Route_NotStartAtTerminal, ETRow_MyRegionFrom,  null);
	endif;
	
	if self.myRegionTo = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Region To', ETRow_MyRegionTo,  null);
		app.raiseCMException(Input_required_field_regTo, ETRow_MyRegionTo,  null); // cnwdb2	PAR 35364
	endif;
	
	if not app.isConverting then
		if self.allPathSegments.isEmpty then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Path Segment', null,  null);
			app.raiseCMException(Input_required_field_pathSeg, null,  null); // cnwdb2	PAR 35364
		endif;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;

	tmpMovementPath := self.myRoot.allHMSMovementPaths.getAtKey(self.code);
	
	if tmpMovementPath &lt;&gt; null then
		realMovementPath := self.pxyGetRealObject();
		if tmpMovementPath &lt;&gt; realMovementPath then
			//app.raiseCMException2(DuplicateItem, 'Route', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// Route already exists for %1 : Route_alreadyexists
			app.raiseCMException1(Route_alreadyexists, self.code, ETRow_Code, null); //14.06.2022 navds20 53760
		endif;
	endif;
	
	foreach pathSegment in self.allPathSegments do
		if not set.includes(pathSegment) then
			set.add(pathSegment);
		else
			//app.raiseCMException2(DuplicateItem, 'Path Segment ' &amp; pathSegment.code, 'Movement Path ' &amp; self.code,null,null); //14.06.2022 navds20 53760
			// Path Segment %1 already exists for Movement Path %2 : Path_segme_alrea_exist_move
			app.raiseCMException2(Path_segme_alrea_exist_move, pathSegment.code, self.code,null,null); //14.06.2022 navds20 53760
			return;
		endif;
	endforeach;
	
	// lorcan - we can now start and stop at the same place
	//if self.myRegionTo = self.myRegionFrom then
	//	app.raiseCMException3(HMSRegionToSame, self.myRegionTo.code, self.myRegionFrom.code, self.code, ETRow_MyRegionEnd, null);
	//endif;
epilog
	delete set;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
