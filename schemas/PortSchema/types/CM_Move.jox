	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tbaPatch" id="597b1aec-5358-4edc-a3f8-df65d0feb0f5">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>tbaPatch(set: Boolean; _value: Boolean io) updating, mapping;

begin
	if set then
		if _value then
			flags := flags.bitOr(TBAPatchFlag);
		else
			flags := flags.getValueWithBitUnset(TBAPatchFlag);
		endif;
	else
		_value := (flags.bitAnd(TBAPatchFlag) &lt;&gt; 0);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="typeString" id="ee81cfb1-e07c-4038-b3f9-a15295dff9e3">
        <methodInvocation>mapping</methodInvocation>
        <source>typeString(_set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.mode = PLANNING_MODE then

		if self.unplan then
			//_value := "Unplanned";
			_value := app.getErrorString(MOVE_TYPE_Unplanned);
		elseif self.isReplan then
			//_value := "Replan";
			_value := app.getErrorString(MOVE_TYPE_Replan);
		else
			//_value := "Planned";
			_value := app.getErrorString(MOVE_TYPE_Planned);
		endif;
	elseif self.mode = QUEUE_MODE then
		if self.unplan then
			//_value := "Unqueue";
			_value := app.getErrorString(MOVE_TYPE_Unqueue);
		elseif self.isReQueue then
			//_value := "Re-queue";
			_value := app.getErrorString(MOVE_TYPE_Requeue);
		else
			//_value := "Queued";
			_value := app.getErrorString(MOVE_TYPE_Queued);
		endif;
	else
		//epr par 33718 18/3/14
		if  self.unplan then
			_value:=app.getErrorString(MOVE_TYPE_Undo);
		else
			inheritMethod(_set, _value);
		endif;
	endif;

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="unplan" id="4ea3ef1f-a53c-49c8-bc2f-16e2ac47abaa">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>unplan(set: Boolean; _value: Boolean io) updating, mapping;

begin
	if set then
		if _value then
			flags := flags.bitOr(UnplanFlag);
		else
			flags := flags.getValueWithBitUnset(UnplanFlag);
		endif;
	else
		_value := (flags.bitAnd(UnplanFlag) &lt;&gt; 0);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="c927618b-4ae2-40cb-abb4-3172c55518e5">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;

vars
	trans : CM_TITransaction;
begin
	inheritMethod(_passport);
	if self.myTrackedItem = null then
		return;
	endif;
	
	self.myTrackedItem.setMovedDT(TI_Moved);

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateCMIF_TITransCntrl" id="cd032adc-b9a8-4090-96c1-dd2f77b66571">
        <source>validateCMIF_TITransCntrl(_tiTransCntrl: CMIF_TITransactionController): Boolean;
//--------------------------------------------------
// Created:	09 March 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if (not inheritMethod(_tiTransCntrl)) then
		return false;
	endif;
	
	if (not CMIF_MoveTransactionController.hasInstance(_tiTransCntrl)) then
		//Invalid controller type
		app.raiseCMException2(ERR_INVALID_VALUE, 'transaction type ' &amp; '( ' &amp; _tiTransCntrl.typeString &amp; ' )', 'Move transaction type is required.', null, null);
		return false;
	endif;
	
	return true;

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
