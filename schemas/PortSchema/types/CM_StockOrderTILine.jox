    <JadeMethod name="calUnallocatedAmount" id="dba64d7d-5fe9-4a5b-8559-2d8cb558b69f">
        <source>calUnallocatedAmount(): Decimal;
// ---------------------------------------------------------------------------
// Created:     05 July 2002 by cnwsb1
// ---------------------------------------------------------------------------	
vars
	bolOutLine			: CM_BOLOutStockOrderLineTI;	
begin
	bolOutLine := self.allBOLOutStockOrderTIs.first;
	if bolOutLine.isFulfilled then
		return 1;
	endif;

	return 0;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="doMatch" id="2515dc04-ba48-4f31-a2a6-35b526fa93ad">
        <updating/>
        <source>doMatch(_bolOut: CM_BOLOut; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2004	cnwth2
//
// Purpose:     Easy for this line type, as we already have a specific TI. If it's included
//				in the TI collection passed in (from the BOLLOut docket) then consider it %100 fulfilled
//			 
// ----------   ----------  --------------------------------------------------
vars
	allocatedTI				: CM_TrackedItem;
	bolOutOrderLine			: CM_BOLOutStockOrderLineTI;
begin
	allocatedTI := self.myTrackedItem;
	
	if allocatedTI = null then//validation in creation should ensure this never happens
		return;
	endif;

	if _bolOut.allTrackedItems.includes(allocatedTI) then
		//instances of CM_BOLOutStockOrderLineTI are the matching go-between objects
		//between stockOrderLines and BOLOuts (outward dockets)
		//Because this is a TI line type (a single TI allocated to this line), there
		//should only be a single bolOutOrderLine. If it's null, something has gone wrong
		//in the stockOrder creation trx -we shouldn't be creating them here
		bolOutOrderLine := self.allBOLOutStockOrderTIs.first;
		if bolOutOrderLine = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'BOLOut Order Line is null');
			return;
		endif;
		
		bolOutOrderLine.setForUpdate(_bolOut, self, allocatedTI);
	endif;
end;</source>
        <Parameter name="_bolOut" type="CM_BOLOut"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ce360e17-b013-42c2-be4a-b3f4bab36b04">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     05 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	
	if _attrName = ETRow_MyCargoType 	or
		_attrName = ETRow_FixedMyProduct 	or
		_attrName = ETRow_MyProduct 		or
		_attrName = ETRow_FixedQuantity		or
		_attrName = ETRow_Id				then
		
		if self.myTrackedItem &lt;&gt; null then
			return	self.myTrackedItem.getDisplayStringForAttribute(_attrName, false);
		else
			return null;
		endif;

	elseif _attrName = ETRow_LineType then
		return StockOrderLine_TI_Descr;

	elseif _attrName = ETRow_OperatorRef1 then
		return self.operatorRef1.String;
	elseif _attrName = ETRow_OperatorRef2 then
		return self.operatorRef2.String;
	elseif _attrName = ETRow_RequiredID then //returns quantity if product line, or TI id if TI line type
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.id;
		else
			return null;
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorString" id="572455a2-6262-4d4d-bd41-63ab868c3b5d">
        <source>getErrorString(): String;
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars

begin
	return "Tracked Item " &amp; self.myTrackedItem.id;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
