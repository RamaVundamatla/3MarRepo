    <JadeMethod name="canReceiveBulkMove" id="186e71c9-34da-44b2-991e-0c14ae0fa198">
        <source>canReceiveBulkMove(): Boolean;

// Created by cnwdvb1 on 03 December 2007

vars

begin
	
	// If the machine can tandem lift then we can do a bulk move.
	
	if self.myMachine = null then
		return false;
	endif;
	
	// Will most likely have to add new lift types here as they are created.
	if self.myMachine.isTandemLift then
		return true;
	endif;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canTwinLiftWithLocation" id="7fb98c26-7ff2-45d3-8f43-55beecbfc248">
        <source>canTwinLiftWithLocation(_nextLocation: CM_LocationsController; 
						_myTrackedItem: CM_TrackedItem; 
						_nextLocationTrackedItem: CM_TrackedItem;
						_mode		: Integer;
						_direction : Integer output;
						_errorString : String io): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2009	cnwer1	Initial creation

*/

vars

begin
	if not inheritMethod(_nextLocation,_myTrackedItem,_nextLocationTrackedItem,_mode,_direction,_errorString) then
		return false;
	endif;
	
	_direction:=CM_RTQueueEntry.TWIN_NONE;
	if not self = _nextLocation then
		_errorString:= app.getErrorString(Next_locatio_this_machine);
		return false;
	endif;

	_direction:=CM_RTQueueEntry.TWIN_BOTH ;	
	return true;

epilog

end;</source>
        <Parameter name="_nextLocation" type="CM_LocationsController"/>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_nextLocationTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_direction" type="Integer" usage="output"/>
        <Parameter name="_errorString" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="cb994b16-47c2-4623-ace1-8714d5a375fb">
        <updating/>
        <source>erase(_eraseLevel : Integer) updating;

begin
	if self.allTrackedItems.isEmpty = false then
		app.setContinueCMExceptions(false);
		// AKB2009SEP app.raiseCMException2(ERR_LC_HAS_TIS," ACTUAL ", self.getFullId, null, null); 
		app.raiseCMException1(ERR_LC_HAS_TIS_ACTUAL, self.getFullId, null, null); // AKB2009SEP
		return;
	endif;
	if self.allPlannedFutureMoves.isEmpty = false then
		app.setContinueCMExceptions(false);
		// AKB2009SEPapp.raiseCMException2(ERR_LC_HAS_TIS," PLANNED ",self.getFullId, null, null); 
		app.raiseCMException1(ERR_LC_HAS_TIS_PLANNED, self.getFullId, null, null); // AKB2009SEP
		return;
	endif;
	if self.allQueuedFutureMoves.isEmpty then
		app.setContinueCMExceptions(false);
		// AKB2009SEPapp.raiseCMException2(ERR_LC_HAS_TIS," QUEUED ",self.getFullId, null, null); 
		app.raiseCMException1(ERR_LC_HAS_TIS_QUEUED, self.getFullId, null, null); // AKB2009SEP
		return;
	endif;
	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
