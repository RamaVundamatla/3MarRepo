    <JadeMethod name="myMenuDtl" id="dbbff0e1-fd0a-4885-b28c-5a42a35e815b">
        <methodInvocation>mapping</methodInvocation>
        <source>myMenuDtl(set: Boolean; _value: CM_MenuDtl io) mapping;

vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.myMenuItem.isKindOf(CM_MenuDtl) then
		_value := self.myMenuItem.CM_MenuDtl;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_MenuDtl" usage="io"/>
    </JadeMethod>
    <JadeMethod name="saveAsSystemEntity" id="3431011e-2345-4804-9a15-9fa15251f6e8">
        <updating/>
        <source>saveAsSystemEntity(_parent : CM_MenuEntity input; 
				_pos : Integer; 
				_agent : CM_MenuAgent input;
				_deleteSet : CM_MenuEntitySet input;
				_menuRoot : CM_MenuRoot input;
				_hdrPrefix : String) updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	parentEntity,
	menuEnt		: CM_MenuEntity;
	menDtl		: CM_MenuDtl;

begin
	inheritMethod(_parent, _pos, _agent, _deleteSet, _menuRoot, _hdrPrefix);

	if (not self.myMenuItem.isKindOf(CM_MenuDtl)) then
		return;
	endif;

	menDtl := self.myMenuItem.CM_MenuDtl;
	
	menDtl.setForUpdateFromUserDtl(_parent, _pos, self, _menuRoot);

end;</source>
        <Parameter name="_parent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_pos" type="Integer"/>
        <Parameter name="_agent" type="CM_MenuAgent" usage="input"/>
        <Parameter name="_deleteSet" type="CM_MenuEntitySet" usage="input"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
        <Parameter name="_hdrPrefix" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="803e5ca0-b724-4056-afe1-8ac1114f2c5d">
        <updating/>
        <source>setForCreate(_proxy: SelfType; _parent: CM_MenuEntity input; _pos: Integer) updating;

vars

begin

	inheritMethod(_proxy, _parent, _pos);
	
	self.level := _parent.getLevel() + 1;
	//self.level := 3;

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_parent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateToolbarAdd" id="11b5a395-9956-41df-acd5-a0288655da42">
        <updating/>
        <source>setForUpdateToolbarAdd(_theRealUserTerminal : CM_UserTerminal input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _theRealUserTerminal = null then
		return;
	endif;
	
	self.myUserTerminalIFOnToolbar := _theRealUserTerminal;

end;</source>
        <Parameter name="_theRealUserTerminal" type="CM_UserTerminal" usage="input"/>
    </JadeMethod>
