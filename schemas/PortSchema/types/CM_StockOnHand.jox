    <JadeMethod name="adjustStock" id="64c0c2f1-2913-44f0-b270-bef8923b5955">
        <updating/>
        <source>adjustStock(_date : Date; _type : Integer; _moveOut : Boolean; 
			_ti : CM_TrackedItem; _tiUpdCntrl : CMIF_TIUpdateController;
			_txn : CM_TITransaction input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 May 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpMove		: CM_StockMoveBucket;
	tmpMoveOut	: Boolean;
	tmpType,
	sohQty,
	totQty		: Integer;
	sohWeight,
	totWeight	: Decimal[14,4];
	sohVol,
	totVol		: Decimal[16,4];

begin

	tmpMoveOut := _moveOut;
	tmpType	:= _type;

	//if _tiUpdCntrl = null then
	//	app.raiseUnexpectedProgramError(class.name, method.name, 'Null _tiUpdCntrl');
	//	return;
	//endif;
	// ti should already be locked but do a belts and braces
	
	if tmpType = StkMove_ValueUpdateOut then
		// Should just pass in StkMove_ValueUpdateIn and this method will work out
		// if the move is an increase or decrease
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid parameter "StkMove_ValueUpdateOut"');
		return;
	endif;
	
	exclusiveLock(self);
	exclusiveLock(_ti);
	
	// This MUST be done before adjusting the stock as the stockmove
	// holds the soh BEFORE the adjustment is applied.
	tmpMove := self.allStockMovementsByDate[_date];

	if tmpMove = null then
		create tmpMove as self.getStockMovementClass() persistent;
		tmpMove.init(_date, self.currentQuantity, self.currentWeightKgs, self.currentVolume, self);
	endif;
	
	if tmpType = StkMove_ValueUpdateIn then
		// This is a value update to an existing TI in this location.  We
		// calculate the difference in determine if this is an in or out
		if _tiUpdCntrl = null then
			app.raiseUnexpectedProgramError(class.name, method.name, '_tiUpdCntrl is required parameter for StkMove_ValueUpdateIn');
			return;
		endif;

		_ti.getSOHValues(sohQty, sohWeight, sohVol);		

		sohQty 		:= sohQty - _tiUpdCntrl.quantity;
		sohWeight	:= sohWeight - _tiUpdCntrl.totalWeight;
		sohVol 		:= sohVol - _tiUpdCntrl.volume;
		
		if (sohQty &gt; 0) or (sohWeight &gt; 0) or (sohVol &gt; 0) then
			tmpMoveOut := false;
		else
			tmpMoveOut := true;
			tmpType := StkMove_ValueUpdateOut;
		endif;
		
	elseif tmpMoveOut then
		if _tiUpdCntrl &lt;&gt; null then
			sohQty 		:= -(_tiUpdCntrl.quantity);
			sohWeight	:= -(_tiUpdCntrl.weight);
			sohVol 		:= -(_tiUpdCntrl.volume);
		else
			// if no _tiUpdCntrl then assume that just moving
			// without updating the values
			_ti.getSOHValues(sohQty, sohWeight, sohVol);
			sohQty 		:= -(sohQty);
			sohWeight 	:= -(sohWeight);
			sohVol 		:= -(sohVol);
		endif;
	else
		_ti.getSOHValues(sohQty, sohWeight, sohVol);		
	endif;

	self.currentQuantity	:= self.currentQuantity + sohQty;
	self.currentWeightKgs	:= self.currentWeightKgs + sohWeight;
	self.currentVolume		:= self.currentVolume + sohVol;

	tmpMove.addTrackedItem(tmpType, _ti, sohQty, sohWeight, sohVol, _txn);

	if self.myExtension &lt;&gt; null then
		self.myExtension.adjustStock(_tiUpdCntrl, _type, tmpMoveOut, _ti, sohQty, sohWeight, sohVol);
	endif;
	
	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		if self.myExtension &lt;&gt; null then
			self.updateObjectEdition( self.myExtension );
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_moveOut" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiUpdCntrl" type="CMIF_TIUpdateController"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="adjustStockByForBulk" id="eba3f104-48a8-403d-9f54-553fd3cd5619">
        <updating/>
        <source>adjustStockByForBulk(_date : Date; _type : Integer; 
			_adjQty : Integer; _adjVol : Real; _adjWeight : Decimal;
			_ti : CM_TrackedItem; _txn : CM_TITransaction input) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2002 by cnwrs2
//
// Purpose:     Should only be called by the Bulk split and merge functions
// ---------------------------------------------------------------------------
vars
	tmpMove		: CM_StockMoveBucket;
	tmpMoveOut	: Boolean;
	sohQty		: Integer;	
	sohWeight	: Decimal[14,4];
	sohVol		: Decimal[16,4];

begin

	if (not _ti.isBulkCargo) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'TI (' &amp; _ti.String &amp; ') is not Bulk cargo');
		return;
	endif;
	
	exclusiveLock(self);
	exclusiveLock(_ti);
	
	// This MUST be done before adjusting the stock as the stockmove
	// holds the soh BEFORE the adjustment is applied.
	tmpMove := self.allStockMovementsByDate[_date];

	if tmpMove = null then
		create tmpMove as self.getStockMovementClass() persistent;
		tmpMove.init(_date, self.currentQuantity, self.currentWeightKgs, self.currentVolume, self);
	endif;

	if _type = StkMove_MoveOut then
		tmpMoveOut := true;
		sohQty 		:= -(_adjQty);
		sohWeight	:= -(_adjWeight);
		sohVol 		:= -(_adjVol);
	elseif _type = StkMove_MoveIn then
		tmpMoveOut := false;
		sohQty 		:= _adjQty;
		sohWeight	:= _adjWeight;
		sohVol 		:= _adjVol;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid parameter value (' &amp; _type.String &amp; ') for _type"');
	endif;
	
	self.currentQuantity	:= self.currentQuantity + sohQty;
	self.currentWeightKgs	:= self.currentWeightKgs + sohWeight;
	self.currentVolume		:= self.currentVolume + sohVol;

	tmpMove.addTrackedItem(_type, _ti, sohQty, sohWeight, sohVol, _txn);

//	if self.myExtension &lt;&gt; null then
//		self.myExtension.adjustStock(_tiUpdCntrl, tmpMoveOut, _ti, sohQty, sohWeight, sohVol);
//	endif;

	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		if self.myExtension &lt;&gt; null then
			self.updateObjectEdition( self.myExtension );
		endif;
	endif;

end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_adjQty" type="Integer"/>
        <Parameter name="_adjVol" type="Real"/>
        <Parameter name="_adjWeight" type="Decimal"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="adjustStockFixup" id="f2a9b96f-6fdf-48db-abd5-4cd323b0b104">
        <updating/>
        <source>adjustStockFixup(_date : Date) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2002 by cnwrs2
//
// Purpose:     Called for CM_SOHTerminal and CM_SOHTerminalArea only to
//				reset the figures if there has been an error so they no
//				longer addup to the sum of all child locations/
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpDate		: Date;
	tmpMove		: CM_StockMoveBucket;
	sohQty,
	totQty		: Integer;
	sohWeight,
	totWeight	: Decimal[14,4];
	sohVol,
	totVol		: Decimal[16,4];

begin

	// ti should already be locked but do a belts and braces
	exclusiveLock(self);
	
	// This MUST be done before adjusting the stock as the stockmove
	// holds the soh BEFORE the adjustment is applied.
	tmpMove := self.allStockMovementsByDate[_date];
	if tmpMove = null then
		create tmpMove as self.getStockMovementClass() persistent;
		tmpMove.init(_date, self.currentQuantity, self.currentWeightKgs, self.currentVolume, self);
	endif;
	
	self.getChildSOHValues(sohQty, sohWeight, sohVol);

	sohQty 		:= -(self.currentQuantity - sohQty);
	sohWeight	:= -(self.currentWeightKgs - sohWeight);
	sohVol 		:= -(self.currentVolume - sohVol);
	
	if sohQty &lt;&gt; 0 or sohWeight &lt;&gt; 0 or sohVol &lt;&gt; 0 then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  doing fix for ' &amp; self.String);
		self.currentQuantity	:= self.currentQuantity + sohQty;
		self.currentWeightKgs	:= self.currentWeightKgs + sohWeight;
		self.currentVolume		:= self.currentVolume + sohVol;
	
		tmpMove.addFixup(StkMove_Fixup, sohQty, sohWeight, sohVol);
	endif;
	
	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		if self.myExtension &lt;&gt; null then
			self.updateObjectEdition( self.myExtension );
		endif;
	endif;

end;</source>
        <Parameter name="_date" type="Date"/>
    </JadeMethod>
    <JadeMethod name="adjustStock_docketCorrection" id="06b1407e-ad86-42fe-a9ec-60493a003940">
        <updating/>
        <source>adjustStock_docketCorrection(	_ts : TimeStamp; _type : Integer; _moveOut : Boolean;
								_quantity: Integer; _weightKgs : Decimal; _volume, _sedMean : Decimal;
								_ti : CM_TrackedItem; _txn : CM_TITransaction input; _newBucket : CM_StockMoveBucket output ) updating, protected;
// --------------------------------------------------------------
// Created: 11 March 2008 By: cnwvu1
// --------------------------------------------------------------

vars
	sohQty		: Integer;
	sohWeight	: Decimal[14,4];
	sohVol		: Decimal[16,4];
	tmpQuantity	: Integer;
	tmpWeight	: Decimal[14,4];
	tmpVolume	: Decimal[16,4];	// following the CM_TrackedItem::volume
//	sohTxn		: CM_SOHTransaction;
	iter		: Iterator;

begin

	exclusiveLock(self);
	exclusiveLock(_ti);

	// ---------------------------------------------------------------------------------
	//							correcting a current bucket
	// ---------------------------------------------------------------------------------
	_newBucket := self.allStockMovementsByDate[ _ts.date ];
	
	if _newBucket = null then
		if _moveOut then
			app.raiseUnexpectedProgramError( class.name, method.name, 'Docket Correction cannot find stock bucket' );
			return;
		endif;
		self.getSOHLevelsForDate( _ts.date, false, tmpQuantity, tmpVolume, tmpWeight );
		create _newBucket as self.getStockMovementClass() persistent;
		_newBucket.init( _ts.date, tmpQuantity, tmpWeight, tmpVolume, self );
	endif;

	if _moveOut then
		sohQty 		:= -(_quantity);
		sohWeight 	:= -(_weightKgs);
		sohVol 		:= -(_volume);
	else
		sohQty 		:= (_quantity);
		sohWeight 	:= (_weightKgs);
		sohVol 		:= (_volume);
	endif;

	_newBucket.removeTrackedItem_DocketCorrec(_type, _moveOut, _ti, _ts, sohQty, sohWeight, sohVol, _txn);

	//if _stockOnHandToBeChanged then // when changing product, we have to correct and stockOnHand. 
		//if log has been removed from terminal, stockOnHand will be reversed and corrected by following movement
		self.currentQuantity	:= self.currentQuantity + sohQty;
		self.currentWeightKgs	:= self.currentWeightKgs + sohWeight;
		self.currentVolume		:= self.currentVolume + sohVol;
		if self.myExtension &lt;&gt; null then
			self.myExtension.adjustStock_docketCorrection( _moveOut, _ti, sohQty, sohWeight, sohVol, _sedMean );
		endif;
//	endif;

	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		if self.myExtension &lt;&gt; null then
			self.updateObjectEdition( self.myExtension );
		endif;
	endif;

end;
</source>
        <access>protected</access>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_moveOut" type="Boolean"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weightKgs" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_sedMean" type="Decimal"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
        <Parameter name="_newBucket" type="CM_StockMoveBucket" usage="output"/>
    </JadeMethod>
    <JadeMethod name="createTransaction" id="390bef5a-5a1f-4198-aad8-31af8056b508">
        <source>createTransaction(_transType : Integer; _passport : CM_Passport input; _comment : String; _parent : Object) : CM_SOHTransaction;
//--------------------------------------------------------------
//Created: 29 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	sohTxn 		: CM_SOHTransaction;
	theClass	: Class;
begin
	
	if _transType = TRANS_TYPE_SOH_FIXUP then
		theClass := CM_SOHFixup;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'TransType (' &amp; _transType.String &amp; ') unknown.');
		return sohTxn;
	endif;
	
	create sohTxn as theClass persistent;
	
	sohTxn.setValuesPriorUpdate(self, _transType, _passport.userCode, _comment, _parent);
	
	if (not _passport.noErrors) then
		delete sohTxn;
		sohTxn := null;
	endif;
		
	return sohTxn;
end;</source>
        <Parameter name="_transType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_parent" type="Object"/>
        <ReturnType type="CM_SOHTransaction"/>
    </JadeMethod>
    <JadeMethod name="currentWeightTonnes" id="80026124-a564-4cd4-a0a6-13e243f5d4cd">
        <methodInvocation>mapping</methodInvocation>
        <source>currentWeightTonnes(set: Boolean; _value: Decimal io) mapping;
// ---------------------------------------------------------------------------
// Created:     17 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := self.currentWeightKgs /1000;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="fixupStockOnHand" id="811782a1-eff3-44b3-a359-ec1bf498b873">
        <updating/>
        <source>fixupStockOnHand(_passport : CM_Passport input; _comment: String; _parent : Object;_cmifMonitor : CMIF_Monitor input) updating; //, serverExecution;
//--------------------------------------------------------------
//Created: 29 October 2002 By: cnwgd1
//--------------------------------------------------------------
//Note: Should only be called via CM_Terminal::fixupStockOnHand 
//as a last resort to fix up stock levels.
//Used to fixup CM_SOHTerminal and CM_SOHTerminalArea values
vars
	sohTxn		: CM_SOHTransaction;
	sohVol 		: Decimal[16,4];
	sohQty		: Integer;
	sohWgt	 	: Decimal[14,4];
	tmpMove		: CM_StockMoveBucket;
	date		: Date;		
begin
	exclusiveLock(self);
	date := app.serverTimestampAtTrxStart.date;

	self.getChildSOHValues(sohQty, sohWgt, sohVol);
	
	sohQty 		:= -(self.currentQuantity - sohQty);
	sohWgt		:= -(self.currentWeightKgs - sohWgt);
	sohVol 		:= -(self.currentVolume - sohVol);
	
	//compare actual to self and update if required.
	if sohQty &lt;&gt; 0 or sohWgt &lt;&gt; 0 or sohVol &lt;&gt; 0 then
		// This MUST be done before adjusting the stock as the stockmove
		// holds the soh BEFORE the adjustment is applied.
		tmpMove := self.allStockMovementsByDate[date];
		if tmpMove = null then
			create tmpMove as self.getStockMovementClass() persistent;
			tmpMove.init(date, self.currentQuantity, self.currentWeightKgs, self.currentVolume, self);
		endif;
		app.writeLog('Fixup SOH for (' &amp; self.getID &amp; ') ' &amp; sohQty.String &amp;
					', ' &amp; sohVol.String &amp; ', ' &amp; sohWgt.String, LogINFO);
		sohTxn := self.createTransaction(TRANS_TYPE_SOH_FIXUP, _passport, _comment, _parent);
		if (not _passport.noErrors) then
			return;
		endif;		
		self.currentQuantity	:= self.currentQuantity + sohQty;
		self.currentWeightKgs	:= self.currentWeightKgs + sohWgt;
		self.currentVolume		:= self.currentVolume + sohVol;	
		sohTxn.setValuesPostUpdate(null);
		tmpMove.addFixup(StkMove_Fixup, sohQty, sohWgt, sohVol);		
	endif;
	
	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//15 Jan 2014	NDL	Par 33264
		if self.myExtension &lt;&gt; null then
			self.updateObjectEdition( self.myExtension );
		endif;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_parent" type="Object"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
