    <JadeMethod name="mnuAssignCargoIDs_click" id="5c04dd72-1b0a-4f08-b281-6477602fee4a">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAssignCargoIDs_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 September 2011	cnwndl1	Initial creation	Par 28285

*/

vars

	receivalReq : CM_ReceivalRequest;
	receivalInfo : CM_ReceivalRequestInfo;
	receivalInfoSet : CM_ObjectArray;
	picker : CMUI_Picker;
	pickedObject : CM_Object;
	form : CMUI_EnterCargoIds;
	cargoIDs : StringArray;
	mess : String;
	str : String;
	ti : CM_TrackedItem;
	tiArray : CM_ObjectArrayActual;

begin

	if menuItem.userObject = null then
		return;
	endif;
	
	receivalReq :=  menuItem.userObject.CM_ReceivalRequest;
	create receivalInfoSet transient;	
	foreach receivalInfo in receivalReq.allReceivalInfo do
		if receivalInfo = null
		or receivalInfo.myBooking = null
		or receivalInfo.myCargoType = null
		or not receivalInfo.allTrackedItems.isEmpty
		then
			continue;
		endif;
		receivalInfoSet.add(receivalInfo);
	endforeach;
	
	if receivalInfoSet.isEmpty then
		return;
	elseif receivalInfoSet.size = 1 then
		receivalInfo := receivalInfoSet.first.CM_ReceivalRequestInfo;
	else
		//launch the picker
		if self.myAssistant.pickerForReceivalRequestInfo( receivalInfoSet, pickedObject ) = MsgBox_Return_Cancel then
			return;
		endif;
		receivalInfo := pickedObject.CM_ReceivalRequestInfo;
	endif;
	
	if receivalInfo = null
	or receivalInfo.myBooking = null
	or receivalInfo.myCargoType = null
	or not receivalInfo.allTrackedItems.isEmpty
	then
		return;
	endif;
	
	create form;
	form.centreWindow;
	form.setMyTerminal(self.myTerminal);
	form.txtNumber.text := receivalInfo.quantity.String;
	form.showModal;
	
	create cargoIDs transient;
	if form.modalResult = ModalResultOK then
		form.ids.copy(cargoIDs);	
	endif;
	
	if cargoIDs.isEmpty then
		return;
	endif;
	
	if receivalInfo.quantity &lt;&gt; cargoIDs.size then
		mess := "The documentation shows " &amp; receivalInfo.quantity.String &amp; " " &amp; receivalInfo.myCargoType.description &amp; ", but you have listed " &amp; cargoIDs.size.String &amp; " ID's to use." &amp; CrLf &amp; app.getErrorString(Continue) &amp; "?"; 
		if app.msgBox(mess, app.getErrorString(Continue), MsgBox_Yes_No ) &lt;&gt; MsgBox_Return_Yes then
			return;
		endif;
	endif;
	
	foreach str in cargoIDs do
		// check the proposed cargo id is not already used.
		ti := self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKey( receivalInfo.myCargoType.id, str );
		if ti &lt;&gt; null then
			mess := "Existing cargo already using an ID of " &amp; str &amp; " was found on site.";
			app.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only );
			return;
		endif;
		ti := self.myTerminal.allNotifiedTIsByCargoTypeId.getAtKey( receivalInfo.myCargoType.id, str );
		if ti &lt;&gt; null then
			mess := "Existing pre-notified cargo already using an ID of " &amp; str &amp; " was found.";
			app.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only );
			return;
		endif;
	endforeach;
		
	foreach str in cargoIDs do
		if not self.convertIdToCargoOnRecInfo( receivalInfo, str ) then
			return;
		endif;
	endforeach;
	
	create tiArray transient;
	foreach str in cargoIDs do
		ti := self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKey( receivalInfo.myCargoType.id, str );
		if ti &lt;&gt; null then
			tiArray.add(ti);
		endif;
	endforeach;
	
	if not tiArray.isEmpty then
		self.myAssistant.showCargoIdLabelPrintForm(tiArray);
	endif;

epilog

	delete tiArray;
	delete cargoIDs;
	delete receivalInfoSet;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
