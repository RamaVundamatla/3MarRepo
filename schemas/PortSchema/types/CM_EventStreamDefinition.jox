    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="1120765b-d72c-4dbc-afc2-c3d8fdd38295">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI
23/06/2022 		NAVDS20 			TFS 53760  DuplicateItem not Translatable

*/

vars
	root		: CM_PushEventsRoot;
	existingDef	: CM_EventStreamDefinition;
	realDef		: CM_EventStreamDefinition;
	pos			: Integer;
	
begin
	self.raiseExceptionIfNotTransient(method);
	
	if self.name = null then
		app.raiseCMException(Input_required_field_name, 'name', null);
		return;
	endif;
	
	pos := 1;
	self.name.scanUntil(",:;|", pos);
	if pos &lt;&gt; 0 then
		app.raiseCMException2(Field_contains_invalid_chars, app.getErrorString(Name), "|,:;" , null, null);
	endif;
	
	root := CM_PushEventsRoot.firstInstance();
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	if root = null then
		app.raiseCMException(Push_Events_not_running, null, null);
		return;
	endif;
	
	// Check only one Definition exisits with this name
	existingDef := root.allEventStreamDefinitions[self.name];
	realDef := self.pxyGetRealObject();
	if existingDef &lt;&gt; null and existingDef &lt;&gt; realDef then
		  //app.raiseCMException2(DuplicateItem, app.getErrorString(Event_stream_definition), self.name, null, null);  //23/06/2022 NAVDS20 TFS 53760
		  //Event Stream Definition already exists for %1 : Event_stream_defini_alread_exi
		  app.raiseCMException1(Event_stream_defini_alread_exi, self.name, null, null); //23/06/2022 NAVDS20 TFS 53760
		return;
	endif;
	
	if self.targetURL = null then
		app.raiseCMException(Input_required_field_targetURL, 'targetURL', null);
	endif;
	
	if self.numRetries &lt;= 0 then
		app.raiseCMException(Input_required_field_retries, 'Number Retries', null);
	endif;
	
	// doesn't need to have an email, but if does have one it must be valid
	if self.email &lt;&gt; null then
		app.validateEmailAddress(self.email);
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
