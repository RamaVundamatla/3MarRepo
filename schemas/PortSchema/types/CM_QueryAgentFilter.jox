    <JadeMethod name="qryExpectedVsArrivalDT" id="5f0761f8-8aad-417f-9144-b51bb7ec9f21">
        <updating/>
        <source>qryExpectedVsArrivalDT(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
//----------------------------------------------------------------
//	Created:	15 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWTrackedItems;
	tiFilter			: CMQF_TrackedItem;
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tiFilter := _filter.CMQF_ExpectedVsArrivalDT;
	jrwTrans := self.createJRWTransient(CM_JRWTrackedItems).CM_JRWTrackedItems;
	jrwTrans.allTrackedItems.clear();

	jrwTrans.setAllTerminals(tiFilter.allTerminals);
	tiFilter.filterObjects(jrwTrans.allTrackedItems, _passport);

	jrwTrans.myVoyage 		:= tiFilter.getMyVoyage;

	jrwTrans.myOperator 	:= tiFilter.myOperator;
	jrwTrans.myCargoType	:= tiFilter.getMyCargoType.CM_CargoType;
	jrwTrans.arrivedEarlierThan := tiFilter.CMQF_ExpectedVsArrivalDT.arrivedEarlierThan;
	jrwTrans.arrivedLaterThan := tiFilter.CMQF_ExpectedVsArrivalDT.arrivedLaterThan;

	numSelected := jrwTrans.allTrackedItems.size;
epilog

	return numSelected;

end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryGCSOHLocation" id="7959d06e-977e-4922-a611-7bdf0ddad85e">
        <updating/>
        <source>qryGCSOHLocation(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     28 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	numSelected				: Integer;
	jrwTrans				: CM_JRWSOHLocation;
	sohFilter				: CMQF_SOHLocationGC;
	tmpCargoType			: CM_CargoType;
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	sohFilter := _filter.CMQF_SOHLocationGC;
	jrwTrans := self.createJRWTransient(CM_JRWSOHLocation).CM_JRWSOHLocation;
	jrwTrans.allSOHReporters.clear();
	_filter.filterObjects(jrwTrans.allSOHReporters, _passport);
	
//	sohFilter.allTerminals.copy(jrwTrans.allTerminals);
	jrwTrans.setAllTerminals(sohFilter.allTerminals);
	jrwTrans.myOperator 	:= sohFilter.myOperator;
	jrwTrans.myTerminalArea := sohFilter.getMyTerminalArea;
	jrwTrans.myLocationsController := sohFilter.getMyLocationsController;
	
	jrwTrans.myProduct	 	:= sohFilter.getMyProduct;
	tmpCargoType := app.myRoot.allCargoTypesById[sohFilter.cargoType];
	if tmpCargoType &lt;&gt; null then
		jrwTrans.cargoType		:= tmpCargoType.id;
		jrwTrans.cargoTypeDescr := tmpCargoType.description;
	//else
	//	jrwTrans.cargoTypeDescr := "**Any**";
	endif;
	//the following age analysis properties are log specific, but if we need them for 
	//General Cargo in the future, this should all work the same way
	jrwTrans.blockLength 	:= sohFilter.blockLength;
	jrwTrans.baseDate		:= sohFilter.baseDate;
	jrwTrans.ageType		:= sohFilter.ageType;

	numSelected := jrwTrans.allSOHReporters.size;
	
epilog
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryGateReceipt" id="038e286c-6e32-42f2-b7a8-b99dcb7b988d">
        <updating/>
        <source>qryGateReceipt(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2022	navkc1	Initial creation	Bug 54342: PRP - VVR Report

*/

vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWGateReceipt;
	tifilter			: CMQF_TrackedItem;
	ti, tiClone			: CM_TrackedItem;
	vvr		: CM_VehicleVisitRecord;
	
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tifilter := _filter.CMQF_TrackedItem;
	
	jrwTrans := self.createJRWTransient(CM_JRWGateReceipt).CM_JRWGateReceipt;
	
	jrwTrans.allTrackedItems.clear();
	
	jrwTrans.setAllTerminals(tifilter.allTerminals);
	
	jrwTrans.myVehicleVisit := tifilter.getMyVehicleVisit();
	
	jrwTrans.vehicleVisitOid := tifilter.getMyVehicleVisit().getOidString();

	vvr := jrwTrans.myVehicleVisit;
	
	vvr.copyAllRcvTIsExceptCancelled(vvr.allReceivedTrackedItems, jrwTrans.allTrackedItems);
	
	foreach ti in vvr.allReleasedTrackedItems do
		if jrwTrans.allTrackedItems.includes(ti) then
			tiClone := ti.cloneSelf(true);
			jrwTrans.allTrackedItems.addNoDuplicates(tiClone, false);
		else
			jrwTrans.allTrackedItems.addNoDuplicates(ti, false);
		endif;
	endforeach;
	
	numSelected := jrwTrans.allTrackedItems.size();
	
epilog
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryHMSGlobalVoyage" id="c2a2dd1d-bd0e-46fb-97c1-0eab606f0c6f">
        <updating/>
        <source>qryHMSGlobalVoyage(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// -------------------------------------------
// Created 24 February 2005 by cnwdvb1
// -------------------------------------------
vars
	numSelected 	: Integer;
	jrwTrans		: CM_JRWVoyages;
	filter			: CMQF_HMSGlobalVoyages;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	
	filter := _filter.CMQF_HMSGlobalVoyages;
	jrwTrans := self.createJRWTransient(CM_JRWVoyages).CM_JRWVoyages;

	// Par 10146
	jrwTrans.setAllTerminals(filter.allTerminals);
	
	filter.filterObjects(jrwTrans.allGlobalVoyages, _passport);

	jrwTrans.arriveTsFrom.setDate(filter.arriveDateFrom);
	jrwTrans.arriveTsFrom.setTime(filter.arriveTimeFrom);
			
	jrwTrans.arriveTsTo.setDate(filter.arriveDateTo);
	jrwTrans.arriveTsTo.setTime(filter.arriveTimeTo);
	
	numSelected := jrwTrans.allGlobalVoyages.size;

epilog
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryHMSMovements" id="e2b6c501-b1d8-45b4-b208-e2caf707aeda">
        <updating/>
        <source>qryHMSMovements(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// -------------------------------------------
// Created 25 February 2005 by cnwdvb1
// -------------------------------------------
vars

	numSelected 	: Integer;
	jrwTrans		: CM_JRWHMSTransactions;
	filter			: CMQF_HMSMovements;
	
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	
	filter := _filter.CMQF_HMSMovements;
	jrwTrans := self.createJRWTransient(CM_JRWHMSTransactions).CM_JRWHMSTransactions;
	
	// Par 10146
	jrwTrans.setAllTerminals(filter.allTerminals);
	
	filter.filterObjects(jrwTrans.allHMSTransactions, _passport);
	filter.filterMoves(jrwTrans.allReportMovements, _passport);
	
	
	jrwTrans.startTs.setDate(filter.movementDateFrom);
	jrwTrans.startTs.setTime(filter.movementTimeFrom);

	jrwTrans.endTs.setDate(filter.movementDateTo);
	jrwTrans.endTs.setTime(filter.movementTimeTo);
	
	numSelected := jrwTrans.allHMSTransactions.size.max(jrwTrans.allReportMovements.size);
	
epilog
	
	return numSelected;


end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryHMSVoyages" id="4633d790-5b1b-4dbc-91a8-a35bde6a9c7b">
        <updating/>
        <source>qryHMSVoyages(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// -------------------------------------------
// Created 24 February 2005 by cnwdvb1
//23 March 2017	cnwma1	  TFS #3841:LNX Reporting on Voyage Job information and Delays
//27 March 2017 cnwma1    TFS #3883:AAT - Vessel Schedule
// -------------------------------------------
vars
	numSelected 	: Integer;
	jrwTrans		: CM_JRWVoyages;
	filter			: CMQF_HMSVoyages;
	voyActArr : CMIF_VoyageActivityArray;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	
	filter := _filter.CMQF_HMSVoyages;
	jrwTrans := self.createJRWTransient(CM_JRWVoyages).CM_JRWVoyages;

	// Par 10146
	jrwTrans.setAllTerminals(filter.allTerminals);
	
	filter.filterObjects(jrwTrans.allVoyages, _passport);
	
	jrwTrans.myVessel := filter.getMyVessel;
	jrwTrans.myVoyage := filter.getMyVoyage;

	jrwTrans.arriveTsFrom.setDate(filter.arriveDateFrom);
	jrwTrans.arriveTsFrom.setTime(filter.arriveTFrom);
			
	jrwTrans.arriveTsTo.setDate(filter.arriveDateTo);
	jrwTrans.arriveTsTo.setTime(filter.arriveTTo);
	
	jrwTrans.departTsFrom.setDate(filter.departDateFrom);
	jrwTrans.departTsFrom.setTime(filter.departTFrom);
	
	jrwTrans.departTsTo.setDate(filter.departDateTo);
	jrwTrans.departTsTo.setTime(filter.departTTo);
	
	jrwTrans.inPortTsFrom.setDate(filter.inPortDateFrom);
	jrwTrans.inPortTsFrom.setTime(filter.inPortTFrom);
	
	jrwTrans.inPortTsTo.setDate(filter.inPortDateTo);
	jrwTrans.inPortTsTo.setTime(filter.inPortTTo);
	
	jrwTrans.includeCancelled := filter.includeCancelled;// cnwrd1 par 23993 25.5.2010 
	
	
	if jrwTrans.myVoyage &lt;&gt; null then    //27/03/2017 cnwma1 TFS #3883
		create jrwTrans.allCMIFVoyageActivity as CMIF_VoyageActivityArray transient;  // 23/03/2017cnwma1 TFS #3841
		voyActArr := jrwTrans.myVoyage.getVoyageActivity();
		if not voyActArr.isEmpty then
			voyActArr.copy(jrwTrans.allCMIFVoyageActivity);
		endif;
	endif;
	numSelected := jrwTrans.allVoyages.size;
	
 

	 

epilog
	delete voyActArr;
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryHazardous" id="3b3c9407-c2af-4521-958a-52ab41c57ac5">
        <updating/>
        <source>qryHazardous(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		14 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	numSelected 		: Integer;
	jrwTrans			: CM_JRWTrackedItems;
	tiFilter			: CMQF_Hazardous;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tiFilter := _filter.CMQF_Hazardous;
	jrwTrans := self.createJRWTransient(CM_JRWTrackedItems).CM_JRWTrackedItems;
	jrwTrans.allTrackedItems.clear();
	_filter.filterObjects(jrwTrans.allTrackedItems, _passport);
	
//	tiFilter.allTerminals.copy(jrwTrans.allTerminals);
	jrwTrans.setAllTerminals(tiFilter.allTerminals);
	jrwTrans.myOperator := tiFilter.myOperator;
	jrwTrans.qryStartDate := tiFilter.startDate;
	jrwTrans.qryEndDate := tiFilter.endDate;
	jrwTrans.myTerminalArea := tiFilter.getMyTerminalArea;
	jrwTrans.myVoyage := tiFilter.getMyVoyage;

	jrwTrans.qrySiteStateString := tiFilter.getSiteString();
	//tiFilter.allQrySitesREMOVE.asCSV(false);
	
	jrwTrans.myPort := tiFilter.getMyPort;
	jrwTrans.myLoadPort := tiFilter.getMyLoadPort;
	numSelected := jrwTrans.allTrackedItems.size; 

epilog
	return numSelected;

end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryInvoice" id="9b1836a5-20ff-40ff-ba71-a6e77a828fa0">
        <source>qryInvoice(_filter : CMQF_FilterReports; _passport : CM_Passport) : Integer;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		13 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------
vars
	numSelected 		: Integer;
	voyage				: CM_Voyage;
	berth				: HMS_Berth;
	berthDescription	: String;
	jrwTrans			: CM_JRWInvoice;
	theFilter			: CMQF_Invoice;
	term        		: CM_Terminal;
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	theFilter := _filter.CMQF_Invoice;
	jrwTrans := self.createJRWTransient(CM_JRWInvoice).CM_JRWInvoice;
	jrwTrans.allInvoices.clear();
	
	theFilter.filterObjects2(jrwTrans.allInvoices, jrwTrans, _passport);
	jrwTrans.setCMIFInvSumF1Lines(); //10 Aug 2017	NDL	TFS 5679
	
	jrwTrans.setAllTerminals(theFilter.allTerminals);
	jrwTrans.myCompany 		:= theFilter.allCompaniesByCode.first();
	jrwTrans.myDebtor		:= theFilter.getMyDebtor;
	jrwTrans.myInvoiceType 	:= theFilter.getMyInvoiceType;
	jrwTrans.invoiceStatus 	:= theFilter.invoiceStatus;
	
	if _passport.myTerminal = null then
		if not theFilter.allCompaniesByCode.isEmpty then
			term := theFilter.allCompaniesByCode.first.CM_Bank.getMyTerminal;
		elseif not theFilter.allTerminals.isEmpty then	//02 Jul 2019	NDL	TFS 45427
			term := theFilter.allTerminals.first;
		endif;
	else
		term := _passport.myTerminal;	
	endif;
	if term &lt;&gt; null then	//02 Jul 2019	NDL	TFS 45427
		jrwTrans.invoiceStatusString := app.getInvoiceStatusString(term.getDefaultCompanyBank().getMyInvoiceProcess, theFilter.invoiceStatus); // TFS 39618
	else //02 Jul 2019	NDL	TFS 45427
		jrwTrans.invoiceStatusString := app.getInvoiceStatusString(null, theFilter.invoiceStatus);
	endif;
	
	jrwTrans.invoiceNumber	:= theFilter.invoiceNumber;
	jrwTrans.dateEnd 		:= theFilter.endDate;
	jrwTrans.dateStart		:= theFilter.startDate;
	jrwTrans.cargoId		:= theFilter.cargoId;
	if theFilter.getMyCargoType.isKindOf(CM_Car) then
		jrwTrans.myCargoType	:= theFilter.getMyCargoType.CM_CargoType;
	endif;
	jrwTrans.myConsignee	:= theFilter.getMyConsignee;
	jrwTrans.myCustomsAgent	:= theFilter.getMyCustomsAgent;
	jrwTrans.site			:= theFilter.siteState;
	voyage					:= theFilter.getMyVoyage;
	jrwTrans.myVoyage		:= voyage;
	// TFS 5155 add berthDescription
	if voyage &lt;&gt; null and
	   voyage.myHMSVoyageData &lt;&gt; null then
		berth := voyage.myHMSVoyageData.getMyBerth;
		if berth &lt;&gt; null then
			berthDescription := berth.description;
		endif;
	endif;
	jrwTrans.berthDescription := berthDescription;
	
	numSelected 			:= jrwTrans.allInvoices.size;
	
epilog
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryInvoiceContract" id="b4cb5f99-c82c-472a-bb5c-b69bb66be5c2">
        <source>qryInvoiceContract(_filter : CMQF_InvoiceContract; _passport : CM_Passport) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting

*/

vars
	numSelected 		: Integer;
	jrwTrans			: CM_JRWInvoiceContract;
	theFilter			: CMQF_InvoiceContract;
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	theFilter := _filter.CMQF_InvoiceContract;
	jrwTrans := self.createJRWTransient(CM_JRWInvoiceContract).CM_JRWInvoiceContract;
	jrwTrans.allContracts.clear();
	
	theFilter.allContractDetails.clear(); // 22/11/2023	navkc1 Bug 61266
	theFilter.allContractRateEntries.clear(); // 22/11/2023	navkc1 Bug 61266
	
	theFilter.filterObjects(jrwTrans.allContracts, _passport);
	
	theFilter.allContractDetails.copy(jrwTrans.allContractDetails);// 22/11/2023	navkc1 Bug 61266
	theFilter.allContractRateEntries.copy(jrwTrans.allContractRateEntries); // 22/11/2023	navkc1 Bug 61266
	
	jrwTrans.allCalculationTypes.clear();
	theFilter.allCalculationTypes.copy(jrwTrans.allCalculationTypes);
	
	jrwTrans.allDebtors.clear();
	theFilter.allDebtors.copy(jrwTrans.allDebtors);
	
	jrwTrans.allInvoiceTypes.clear();
	theFilter.allInvoiceLineTypes.copy(jrwTrans.allInvoiceTypes);
	
	jrwTrans.allRateServices.clear();
	theFilter.allRateServices.copy(jrwTrans.allRateServices);
	
	jrwTrans.allUnitOfMeasures.clear();
	theFilter.allUnitOfMeasures.copy(jrwTrans.allUnitOfMeasures);
	
	jrwTrans.contractFromStartDate := theFilter.contractFromStartDate;
	jrwTrans.contractFromEndDate := theFilter.contractFromEndDate;
	jrwTrans.contractId := theFilter.contractId;
	jrwTrans.contractToStartDate := theFilter.contractToStartDate;
	jrwTrans.contractToEndDate := theFilter.contractToEndDate;
	jrwTrans.description := theFilter.description;
	jrwTrans.detailsFromStartDate := theFilter.detailsFromStartDate;
	jrwTrans.detailsFromEndDate := theFilter.detailsFromEndDate;
	jrwTrans.detailsToStartDate := theFilter.detailsToStartDate;
	jrwTrans.detailsToEndDate := theFilter.detailsToEndDate;
	jrwTrans.isActive := theFilter.isActive;
	jrwTrans.isPrimary := theFilter.isPrimary;
	jrwTrans.myBusinessUnit := theFilter.getMyBusinessUnit;
	jrwTrans.rateFromStartDate := theFilter.rateFromStartDate;
	jrwTrans.rateFromEndDate := theFilter.rateFromEndDate;
	jrwTrans.rateToStartDate := theFilter.rateToStartDate;
	jrwTrans.rateToEndDate := theFilter.rateToEndDate;
	jrwTrans.isVolBased := theFilter.isVolBased; // 22/11/2023	navkc1 Bug 61266
	
	// 22/11/2023	navkc1 Bug 61266
	if theFilter.isRateDatesEntered() then
		numSelected := jrwTrans.allContractRateEntries.size();
	elseif theFilter.isDetailDatesEntered() then
		numSelected := jrwTrans.allContractDetails.size();
	else
		numSelected := jrwTrans.allContracts.size();
	endif;
epilog
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_InvoiceContract"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryInvoiceLine" id="ea040319-3c52-4319-a086-ad4229b2b8db">
        <source>qryInvoiceLine(_filter : CMQF_FilterReports; _passport : CM_Passport) : Integer;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		13 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// 25/01/2019	jlgdi1		Set the value of exposed attributes 'printTrackedItems' and 'oneLinePerFinancialPeriod'.
//----------------------------------------------------------------------
vars
	numSelected : Integer;
	voyage		: CM_Voyage;
	berth		: HMS_Berth;
	berthDescription	: String;
	jrwTrans	: CM_JRWInvoice;
	theFilter	: CMQF_InvoiceLine;
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	theFilter := _filter.CMQF_InvoiceLine;
	jrwTrans := self.createJRWTransient(CM_JRWInvoice).CM_JRWInvoice;
	jrwTrans.allInvoiceLines.clear();
	
	theFilter.filterObjects(jrwTrans.allInvoiceLines, _passport);
	
	jrwTrans.setAllTerminals(theFilter.allTerminals);
	jrwTrans.myCompany 		:= theFilter.allCompanies.first();
	jrwTrans.myDebtor		:= theFilter.getMyDebtor;
	jrwTrans.myConsignee	:= theFilter.getMyConsignee;
	jrwTrans.invoiceNumber	:= theFilter.invoiceNumber;
	jrwTrans.dateEnd 		:= theFilter.endDate;
	jrwTrans.dateStart		:= theFilter.startDate;
	jrwTrans.site			:= theFilter.siteState;
	jrwTrans.billOfLading	:= theFilter.billOfLading;
	jrwTrans.cargoId		:= theFilter.cargoId;
	if theFilter.getMyCargoType.isKindOf(CM_CargoType) then
		jrwTrans.myCargoType	:= theFilter.getMyCargoType.CM_CargoType;
	endif;
	jrwTrans.myInvoiceLineType	:= theFilter.getMyInvoiceLineType;
	jrwTrans.myInvoiceType	:= theFilter.getMyInvoiceType;
	voyage					:= theFilter.getMyVoyage;
	jrwTrans.myVoyage		:= voyage;
	// TFS 5155 add berthDescription
	if voyage &lt;&gt; null and
	   voyage.myHMSVoyageData &lt;&gt; null then
		berth := voyage.myHMSVoyageData.getMyBerth;
		if berth &lt;&gt; null then
			berthDescription := berth.description;
		endif;
	endif;
	jrwTrans.berthDescription := berthDescription;
	
	if jrwTrans.myInvoiceLineType &lt;&gt; null then 
		jrwTrans.printTrackedItems := jrwTrans.myInvoiceLineType.bPrintTrackedItems;
		jrwTrans.oneLinePerFinancialPeriod := jrwTrans.myInvoiceLineType.bOneLinePerFinancialPeriod;
	endif;	
	
	numSelected := jrwTrans.allInvoiceLines.size;
	
epilog
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryInvoiceProforma" id="a4a4d7b7-f1cf-41fb-861a-a6b3bec6d939">
        <source>qryInvoiceProforma(_filter : CMQF_InvoiceProforma input; _passport : CM_Passport) : Integer;
/*

Date		Who		Reason
18 August 2015	cnwer1	Initial creation PAR 36778 CCMS 2368

*/

vars
	numSelected : Integer;
	jrwTrans	: CM_JRWInvoice;
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	jrwTrans := self.createJRWTransient(CM_JRWInvoice).CM_JRWInvoice;
	_filter.filterObjects2(jrwTrans.allCashReceiptReporting, jrwTrans, _passport);
	jrwTrans.setAllTerminals(_filter.allTerminals);
	jrwTrans.myCompany 		:= _filter.allCompaniesByCode.first();
	jrwTrans.myDebtor		:= _filter.getMyDebtor;
	jrwTrans.cargoId		:= _filter.cargoId;
	jrwTrans.myConsignee	:= _filter.getMyConsignee;
	jrwTrans.myCustomsAgent	:= _filter.getMyCustomsAgent;
	jrwTrans.myVoyage		:= _filter.getMyVoyage;
	jrwTrans.billOfLading	:= _filter.billOfLading;
	numSelected 			:= jrwTrans.allCashReceiptReporting.size;
epilog
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_InvoiceProforma" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
