    <JadeMethod name="windowCreated" id="94881fd7-d04e-4863-b919-88293879f1a6">
        <controlMethod name="CM_BaseTable::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
//--------------------------------------------------
// Created:	29 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpUser	: CM_User;
begin
	inheritMethod(cntrl, persistCntrl);
	self.setMaxSortColumns(3);

	self.autoSize 		:= Table.AutoSize_Column;
	
	self.setMargins();

	// wordWrap not used as does not work for autoSize option
	//self.wordWrap	 := true;
	
	if not self.isInPainter() then
		tmpUser := app.getMyUser();
		if tmpUser &lt;&gt; null then
			self.partialTextIndication	:= tmpUser.getPartialTextIndication;
		else
			self.partialTextIndication	:= true;
		endif;
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="zAddColumn" id="6cf21b18-95e8-4ab8-abda-13010cf46aa5">
        <updating/>
        <source>zAddColumn(pHeading, pProperty : String; pInputType : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
begin

	self.allTblDataColHeadings.add(pHeading);
	self.allTblDataColPropertyNames.add(pProperty);
	self.allTblDataColInputTypes.add(pInputType);

end;</source>
        <access>protected</access>
        <Parameter name="pHeading" type="String"/>
        <Parameter name="pProperty" type="String"/>
        <Parameter name="pInputType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zAddSortColumn" id="8ff29028-fa1a-4fd5-ad76-eac23311fba4">
        <updating/>
        <source>zAddSortColumn(pColProperty : String; pDescending : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.allTblDataSortColumns.add(pColProperty);
	self.allTblDataSortDescending.add(pDescending);
end;</source>
        <Parameter name="pColProperty" type="String"/>
        <Parameter name="pDescending" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zAddTableObjectsMemberKeys" id="60ed33e2-ca9a-4056-81d8-2ead85d006c1">
        <updating/>
        <source>zAddTableObjectsMemberKeys(_cols :Integer; _dd :CM_ExtKeyDynaDictionary input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config/road ops form changes
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/05/2015	cnwdap1		PAR #36235 Use first ent row as key if we've somwehow ended up with no sort columns
// ---------------------------------------------------------------------------
constants
	KeyLength = 30;
vars
	index, row	:Integer;
	rowName		:String;
	descending	:Boolean;
	entRow		:EntTableRow;
	primType	:PrimType;
	msg : String;
begin
	index := 1;
	
	while index &lt;= _cols do
		rowName 	:= self.allTblDataSortColumns[index];
		descending 	:= self.allTblDataSortDescending[index];
		entRow 		:= self.getEntRowColumnByRowName(rowName, row);

		if entRow &lt;&gt; null then	//17 Jan 2014	NDL	Par 33326
			if row &gt; 0 then
				self.accessCell(self.fixedRows, row).fontBold := false;
			endif;
					
			primType := self.convertInputTypeToPrimType(entRow.inputType);
			
			_dd.addExternalKeyForEntRow(rowName, primType, KeyLength, descending, true);
		else
			//17 Jan 2014	NDL	Par 33326
			msg := app.getErrorString1(Colum_sort_attri_longe_avail_t, rowName )
				&amp; CrLf &amp; app.getErrorString(Pleas_check_your_colum_organ_a);
			mousePointer := MousePointer_Default;
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
		endif;
		
		index := index + 1;
	endwhile;
	if _dd.noKeys() then																// PAR #36235
		entRow := self.allTblDataEntRows.first;											// PAR #36235
		primType := self.convertInputTypeToPrimType(entRow.inputType);					// PAR #36235
		_dd.addExternalKeyForEntRow(rowName, primType, KeyLength, descending, true);	// PAR #36235
	endif;																				// PAR #36235
end;</source>
        <access>protected</access>
        <Parameter name="_cols" type="Integer"/>
        <Parameter name="_dd" type="CM_ExtKeyDynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zRemoveSortColumn" id="bf08f549-54bf-4893-a8ec-770eac9ff156">
        <source>zRemoveSortColumn(_name : String);
// ---------------------------------------------------------------------------
// Created:     26 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx 	: Integer;
	
begin

	idx := self.allTblDataSortColumns.indexOf(_name);
	if idx &lt;&gt; 0 then
		self.allTblDataSortColumns.removeAt(idx);
		self.allTblDataSortDescending.removeAt(idx);
	endif;
	

end;</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="zTblDataSetup" id="ccfbe912-fcc1-4b31-aed6-11222253b976">
        <updating/>
        <source>zTblDataSetup() updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	numCols,
	colInputType,
	idx		: Integer;
	col		: JadeTableColumn;
	colHeading,
	tblHeading	: String;
	entRow		: EntTableRow;
begin

	// Do this to force table column widths to be auto-resized
	// when new data is redisplayed
	self.columns := 0;

	numCols 		:= self.allTblDataColHeadings.size;
	self.columns 	:= numCols;

	foreach idx in 1 to numCols do
		col := self.accessColumn(idx);
		colInputType := self.allTblDataColInputTypes[idx];
		if colInputType = SortColInputType then
			col.inputType := InputType_None;
			col.visible := false;
			col.width := 0;
			colHeading := SortColHeadingPrefix &amp; self.allTblDataColHeadings[idx];
		else
			//th2 changed 02/08/2006 to consider the entry table row visible attribute
			entRow := self.allTblDataEntRows[idx];
			if entRow &lt;&gt; null then
				col.visible := entRow.visible;
			else
				col.visible := true;
			endif;
			
			col.inputType := colInputType;
			colHeading := self.allTblDataColHeadings[idx];
		endif;

		if idx= 1 then //tblHeading = null then epr 5/9/11 if first column has a empty heading value still want it added
			tblHeading := colHeading;
		else
			tblHeading := tblHeading &amp; Tab &amp; colHeading;
		endif;
	endforeach;

	if tblHeading &lt;&gt; null then
		if self.rows &lt; 1 then
			self.rows := 1;
			self.fixedRows := 1;
		endif;
		self.accessCell(self.fixedRows, 1).text := tblHeading;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
