<GUIClass name="GRP_DragDrop6023" id="8b41dec2-3727-42c7-927e-07d257a26c79">
    <superclass name="CnForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="frame1" id="5156c42e-d8d1-4e11-b5c6-362b22e61df5">
        <embedded/>
        <type name="Frame"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="frame2" id="c644ee00-bbeb-4db2-992d-943eae7967e6">
        <embedded/>
        <type name="Frame"/>
    </ImplicitInverseRef>
    <PrimAttribute name="origX" id="59a1a16a-6661-4c9b-97c9-10bf0c56fb9f">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="origY" id="6291f5db-c87e-41cc-870f-298e635b74da">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <JadeMethod name="dragDetected" id="cfb531f9-d5c8-4d93-9aed-9c217b302d44">
        <source>dragDetected(x,y : Real) : Boolean;
// ---------------------------------------------------------------------------
// Created:		28 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if origX &lt;= 0 or 
	   origY &lt;= 0 then
		return false;
	endif;
	if ((origX - x).abs &gt; 7) or
	   ((origY - y).abs &gt; 7) then
	    return true;
	endif;

	return false;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="frame1_dragDrop" id="8e619cba-3636-4b3f-9e42-4e782a46459a">
        <controlMethod name="Frame::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frame1_dragDrop(frame: Frame input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		28 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	frame.enableEvent("mouseMove",false);
	frame.dragMode := DragMode_None;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="frame1_mouseDown" id="5a5a6a6e-a2ea-4e11-8391-5d41b7f65024">
        <controlMethod name="Frame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frame1_mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		28 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.origX := x;
	self.origY := y;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="frame1_mouseMove" id="4002b9e1-d89f-4469-bff8-b04c855c604b">
        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frame1_mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		28 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if button = Window.MouseButton_Left 
	and frame.dragMode &lt;&gt; DragMode_Drag
	and self.dragDetected(x,y) then
			frame.dragMode := DragMode_Drag;
			frame.enableEvent("mouseMove",true);
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="frame1_mouseUp" id="a5728d90-7232-494e-b6dd-266e9e34e7a0">
        <controlMethod name="Frame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frame1_mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		28 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	frame.caption := "X: " &amp; x.String;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
