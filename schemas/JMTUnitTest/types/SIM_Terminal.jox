    <JadeMethod name="getTasks" id="431cb638-409e-4f2f-b71b-a31ccd5fac41">
        <source>getTasks(_oid: Object) : SIM_Task;

vars

begin
	return allTasksByTaskDict[_oid].SIM_Task;
epilog

end;</source>
        <Parameter name="_oid" type="Object"/>
