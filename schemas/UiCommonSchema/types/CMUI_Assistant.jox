    <JadeMethod name="comboBoxUser" id="6e99a8b8-fb82-46fb-8d51-db33c037342c">
        <source>comboBoxUser(pCmb : ComboBox input; pUser : CM_User);
vars

	user 	: CM_User;
	iter	: Iterator;
	int, 
	index	: Integer;

begin
	pCmb.sorted := false;
	pCmb.clear();
/*	pCmb.listCollection(app.myRoot.allUsers, true, 0);
	
	if pUser &lt;&gt; null then
		pCmb.text := self.displayEntryUser(pUser);
		pCmb.listObject := pUser;
	endif;*/
	iter := app.myRoot.allUsers.createIterator;
	while iter.next(user) do
		if user.code &lt;&gt; 'SUPERUSER' then
			index := pCmb.addItem(user.code);		
			pCmb.itemObject[index] := user;
		endif;
	endwhile;
	
	if pUser &lt;&gt; null then 
		int := pCmb.findObject(pUser);
		pCmb.listIndex := int;
	endif;	


epilog
	delete iter;	
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pUser" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="comboBoxUserInternal" id="f03d74b5-b84d-4ae6-bcea-1d8b8be4fcad">
        <source>comboBoxUserInternal(pCmb : ComboBox input; pUser : CM_User);
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	user 	: CM_User;
	iter	: Iterator;
	int, 
	index	: Integer;

begin
	pCmb.sorted := true;
	pCmb.clear();

	
	iter := app.myRoot.allUsers.createIterator;
	while iter.next(user)  do
		if user.isNotAvailableForEntry then
			continue;
		endif;
		if user.myOrganisation = null then
			continue;
		endif;
		if user.myOrganisation.isExternal then
			continue;
		endif;
		if user.code &lt;&gt; 'SUPERUSER' then
			index := pCmb.addItem(user.userName &amp; ' ('&amp;user.code&amp;')');		
			pCmb.itemObject[index] := user;
		endif;
		
	endwhile;
	
	if pUser &lt;&gt; null then 
		int := pCmb.findObject(pUser);
		pCmb.listIndex := int;
	endif;	


epilog
	delete iter;	
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pUser" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="comboBoxUserQuery" id="3a3defe4-809d-4460-94ea-aedb78dc44a0">
        <source>comboBoxUserQuery(pCmb 				  : ComboBox input;
				  pUserQueryName      : String;
				  _queryMode 		  : Integer;
				  _onlyTIQueryModes   : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jan 2013	cnwndl1	Initial creation	Par 30901
13 Dec 2019 jlger1	TFS 47132 - added param
18 Mar 2020 cnwma1  Bug 48897: SNO - New cargo enquiry screen
30 Jun 2025 navma1  MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
*/


vars

	userQuery 	       : CM_MenuUserQuery;
	iter	           : Iterator;
	int, 
	index	           : Integer;
	theCargoBOLType    : CM_CargoBOLType;
	queryTerminal      : CM_Terminal;
	isValidForTerminal : Boolean;
	criteriaLineHolder : CM_QueryCriteriaLineHolder;
	queryLine          : CM_SelectorCriteriaLine;
	hasTerminal        : Boolean;
	searchValue        : Any;
	root			   : CM_Root;
begin
	
	//pCmb.sorted := false;  18.03.2020 cnwma1 #48897
	pCmb.clear();
	
	index := pCmb.addItem(" ");
	root  := app.myRoot;
	iter  := root.myQueryMenuRoot.allMenuUserItemsWithAMenuItem.createIterator;
	
	while iter.next(userQuery) do
		// 20/11/2023	navkc1 Bug 61284 - Reinstate this condition. 60429 commented this out and the changes done in that CR is no longer applicable
		if _queryMode &lt;&gt; null then //12/09/2023	navkc1	CR 60429 Task 60445 - Tracked Item Mode is 0 (null)
			if _queryMode &lt;&gt; userQuery.queryMode then
				continue;
			endif;
		endif;
		//epr TFS 47132 19/11/19 
		if _onlyTIQueryModes  then
			if  userQuery.queryMode &lt;&gt; 0 then
				theCargoBOLType := root.allCargoTypesById[userQuery.queryMode];					//30.06.2025 navma1 #MTN-34090
				if theCargoBOLType = null then
					continue;
				endif;
			endif;
			queryTerminal      := userQuery.getCriteriaTerminal;
			hasTerminal        := false;
			isValidForTerminal := false;
			foreach criteriaLineHolder in userQuery.allCriteriaLineHolders do : outerLoop
				foreach queryLine in criteriaLineHolder.allCriteriaLines do
					if queryLine.myQueryProperty.propertyName = CM_TrackedItem::myTerminal.name then
						hasTerminal := true;
						searchValue := queryLine.myQueryOperator.getSearchValue;
						if searchValue &lt;&gt; null and searchValue.isKindOf(CM_Terminal) 
						   and searchValue.CM_Terminal = self.myTerminal then
							isValidForTerminal := true;
							break outerLoop;
						endif;
					endif;
				endforeach;
			endforeach;
				
			if hasTerminal and not isValidForTerminal then
				continue;
			endif;
		endif;
		
		index                  := pCmb.addItem(userQuery.heading);		
		pCmb.itemObject[index] := userQuery;
	endwhile;
	
	if pUserQueryName &lt;&gt; null then 
		int            := pCmb.findStringExact(1,pUserQueryName);
		pCmb.listIndex := int;
	endif;	

epilog
	delete iter;	
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pUserQueryName" type="String"/>
        <Parameter name="_queryMode" type="Integer"/>
        <Parameter name="_onlyTIQueryModes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxUserStatus" id="0ce17461-2d94-4fe8-96f9-3bb1a814c0f5">
        <source>comboBoxUserStatus(pTbl : CM_EntryTable input; pAttrName : String; _includeNull : Boolean);
// ---------------------------------------------------------------------------
// Created:     02 February 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Date				Who		Reason
//06 Nov 2025		navlw1	JIRA-36369: Add a new status “PENDING” for users and use this status for new imported users
vars
	str	: String;
	
begin

	if _includeNull then
		str := Tab;
	endif;
	
	str := str &amp;
			DisabledBySysAdminUserDescr &amp; Tab &amp;
			EnabledNormalUserDescr &amp; Tab &amp;
			NewUserDescr &amp; Tab &amp;
			SuspendedBadPasswordsUserDescr &amp; Tab &amp;
			PendingUserDescr;			

	pTbl.setComboValues(pTbl.getRow(pAttrName), str);

end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="_includeNull" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVehicleObj" id="f79cc9bd-90a6-48a6-9c35-050c69141994">
        <source>comboBoxVehicleObj(_cmb : CMUI_ComboBox input; _carrier : CM_Carrier; _vehicle : CM_Vehicle);
// ---------------------------------------------------------------------------
// Created:     30 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

//18 Feb 2011	NDL	Par 27046 - allow no carrier, and sort the things...
// Jul 2013 cnwjre1 31890 add discreteLocks
vars
	vehicle			: CM_Vehicle;
	terminal : CM_Terminal;
begin
	_cmb.clear();
	_cmb.sorted := true;
	
	if _carrier = null then
	
		terminal := self.myTerminal;
		if terminal = null then
			return;
		endif;
		
		foreach vehicle in terminal.vehicles discreteLock where not vehicle.isNotAvailableForEntry do
			_cmb.itemObject[_cmb.addItem(vehicle.regNumber)] := vehicle;
		endforeach;
		
	else
	
		foreach vehicle in _carrier.vehicles discreteLock where not vehicle.isNotAvailableForEntry do
			_cmb.itemObject[_cmb.addItem(vehicle.regNumber)] := vehicle;
		endforeach;
	
	endif;
	
	if _cmb.findObject(_vehicle) &gt; 0 then
		_cmb.listObject := _vehicle;
	endif;
	
	
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVehicleTable" id="d94fee4b-7626-4984-a95b-aee4f505fc8a">
        <source>comboBoxVehicleTable(_tbl : CM_EntryTable input; _attrName : String; _carrier : CM_Carrier);
// ---------------------------------------------------------------------------
// Created:     30 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	str				: String;
	vehicle			: CM_Vehicle;
begin
	if _carrier = null then
		return;
	endif;
	
	foreach vehicle in _carrier.vehicles where not vehicle.isNotAvailableForEntry do
		str := str &amp; vehicle.regNumber &amp; Tab;
	endforeach;
	_tbl.setComboValues(_tbl.getRow(_attrName), str);
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_carrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVentilationUnits" id="d9bbbbc7-dc51-43ca-b988-003dd55cd8e5">
        <source>comboBoxVentilationUnits(_combo : CMUI_ComboBox);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2008	cnwer1	Initial creation

*/

vars
	
begin

	_combo.clear;
	_combo.addItemAt(Metres3perHourDesc.asStringJMT,Metres3perHour);
