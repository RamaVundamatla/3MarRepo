<Class name="BGP_VehicleBookingSlotCont" id="b43b6f8a-2ca5-430c-bf4d-7eb3ac0d7089">
    <superclass name="BGP_Controller"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;VS Booking Generator Controller&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myTerminal" id="d11931d1-ffcb-4b53-a812-da8bcfe5f5bf">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <JadeMethod name="doTheNeedful" id="c9cb74e6-e10f-45e2-9bbe-eb53f208caac">
        <updating/>
        <source>doTheNeedful() updating;
/*

Purpose:			Does the work of generating vehicle booking time slots

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
06 August 2013	cnwndl1	Initial creation	Par 32077
03 Jan 2013		cnwrs1	32983 crash after user deleted.
13 May 2016		cnwns1	TFS 488 - Multi Timezone Support
*/
vars
	startDate,
	endDate		: Date;
	term		: CM_Terminal;
	msg,
	errorMess	: String;
	now			: TimeStamp;

begin
	term := self.myTerminal;
	
	if term = null and self.myCurrentRequest &lt;&gt; null then
		term := self.myCurrentRequest.myTerminal;
	endif;
	
	if term = null or not term.isVehicleBookingEnabled then
		app.isBGPAppAbort := true;
		if term = null then
			msg := 'ERR &gt;&gt; Terminal = null';
		else
			msg := 'ERR &gt;&gt; Terminal ' &amp; term.name &amp; ' does not use Vehicle Scheduling';
		endif;
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		app.exitLogFile();
		terminate;
	endif;
	
	if app.myPassport &lt;&gt; null then
 		app.myPassport.setMyUser(self.myUser);
  	endif;
	
	on Exception do handleLoggingOfException( exception, errorMess );		//16 Jan 2014	NDL	Par 33198

	if not app.isBGPAppAbort and not app.isSDSSecondaryDB then
		startDate := app.actualTimeServer.Date;								// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endDate   := startDate + term.getConfig( VsGenerateDaysInAdvance ).Integer;
		msg 	  := "About to generate VB Slots for period " &amp; startDate.asStringJMT &amp; " - " &amp; endDate.asStringJMT;
		app.writeLog(msg, LogINFO);											//25 Nov 2019	NDL	TFS 47053
		
		
		term.myVehicleBookingTerminal.generateSlotsFromTemplate( startDate, endDate );
		
		beginTransaction;
		self.setLastCompleted();
		commitTransaction;
		
		now := app.actualTimeServer;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		now := now.cnEcAddHours( 12 );
		msg := "About to set timer for next VB Slot generate for " &amp; now.asStringJMT;
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		self.beginTimer( 12 * 60 * 60 * 1000, Timer_OneShot, AutoTimer_Event_Tag);	// every 12 hrs...
	endif;

epilog
	//16 Jan 2014	NDL	Par 33198
	if errorMess &lt;&gt; null then
		app.writeLog(errorMess, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.createAlert(errorMess, true);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="finish" id="f50fa0fe-df5a-4f49-a2d9-481065354375">
        <updating/>
        <source>finish() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2013	cnwndl1	Initial creation	Par 32077

*/
vars

begin

	self.endTimer(AutoTimer_Event_Tag);
	
	inheritMethod();
	
end;
</source>
    </JadeMethod>
