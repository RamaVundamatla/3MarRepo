<Class name="WS_ISOType" id="67934a60-fe38-497c-975b-9cf60071457d">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>ISO Type of cargo. E.g. 22G1, 42G1.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="097bdc70-f099-4dce-a1a5-b9c8f2131f0c">
        <length>5</length>
        <embedded/>
        <type name="String"/>
        <text>ISO Type code. E.g. 22G1, 42G1.</text>
    </PrimAttribute>
    <PrimAttribute name="colour" id="eb07a9b3-6490-4efe-9dfb-d19ad4aa75be">
        <embedded/>
        <type name="Integer"/>
        <text>The RGB colour of the ISO Type.</text>
    </PrimAttribute>
    <PrimAttribute name="comboboxDescription" id="5d51a2bb-5534-4632-8f30-18e1cab1c38c">
        <type name="String"/>
        <text>Concatenated code and description of the ISO Type.</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="af874d64-98e9-4cba-8809-7f751105cfcc">
        <type name="String"/>
        <text>Description of the ISO Type. Ex. General,Tank Container</text>
    </PrimAttribute>
    <PrimAttribute name="isReefer" id="11c5df05-e979-41dc-886c-602dde38848e">
        <embedded/>
        <type name="Boolean"/>
        <text>If this ISO Type is a refrigerated ISO Type or not.</text>
    </PrimAttribute>
    <PrimAttribute name="lengthFeet" id="77f1c869-5ed8-489d-a7c1-cffbb6d368c4">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="tareWeight" id="45b63a7e-e634-4556-8f00-e3f998afdac8">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="20e0a511-72ff-4474-bcc6-d94186f9c40a">
        <updating/>
        <source>setProxyFromObject(_object: CM_ISOType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	inheritMethod(_object);
	
	self.code := _object.code;
	self.description := _object.description;
	self.comboboxDescription := self.code &amp; " " &amp; self.description;
	self.colour := _object.colour;
	self.lengthFeet := _object.getLengthInFeet();
	
	self.isReefer := _object.isReefer();
	self.tareWeight := _object.tareKilos;

epilog

end;</source>
        <Parameter name="_object" type="CM_ISOType"/>
    </JadeMethod>
</Class>
