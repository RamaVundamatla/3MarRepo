    <JadeMethod name="load" id="ce0c64e6-02cd-4365-bf63-b1a89975c0fe">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
//----------------------------------------------------------------
//	Created:	14 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	intRow : Integer;
	inputCol	: JadeTableColumn;
begin

	self.table1.stretch := Table.Stretch_Cell;
		
	inputCol := self.table1.accessColumn(2);
	inputCol.inputType := Table.InputType_TextBox;
	inputCol.backColor := LightBlue;
	self.init();
	
		
end;</source>
    </JadeMethod>
