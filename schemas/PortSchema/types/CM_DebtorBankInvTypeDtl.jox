    <JadeMethod name="getAuditText" id="5aa01583-b46d-4d7b-ac3c-fec92bccf108">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	txt,
	str,tmpStr	: String;


	
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();

	if self.myBank &lt;&gt; null then
		tmpStr := self.myBank.code;
		txt := txt &amp; app.getFormCaptionsString(Xlat_0017100) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.myDebtor &lt;&gt; null then
		tmpStr := self.myDebtor.name;
		txt := txt &amp; app.getErrorString(Debtor_GC) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.myFinancialPeriodEnd &lt;&gt; null then
		tmpStr := self.myFinancialPeriodEnd.description;
		txt := txt &amp; 'Period' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.myInvoiceType &lt;&gt; null then
		tmpStr := self.myInvoiceType.description;
		txt := txt &amp; app.getErrorString(Invoice_type) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	return txt;
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
