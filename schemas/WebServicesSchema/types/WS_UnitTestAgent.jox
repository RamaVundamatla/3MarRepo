    <JadeMethod name="wsRESTPreProcessRequest" id="b945b2a2-52c7-4706-8ac4-ce2ad158104b">
        <source>wsRESTPreProcessRequest(_loginString: String; _json: String io; _pathString: String; _expectFailure: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 December 2023	navlw1	Bug 60597: 	CUX | EDBIC - Put /voyage/{id} RestAPI doesn't do what the swagger definition suggests
13 December 2023	navmd1	TFS 60597 Fixed test using queryString instead of pathString

*/

vars
	request				: WS_RestVoyageArray;
	requestLogin		: WS_RESTLoginAuthRequest;
	webService			: MasterTerminalAPIService;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	login 				: WS_InterfaceObject;
	responseLogin  		: WS_NAuthTokenResponse;
	pathIn,
	queryString,
	requestBody,
	verb,
	contentType,
	ref					: String;
begin
	create webService transient;
	create transientJSONObjs transient;
	create parser transient;
	
	// call POST /login
	requestLogin := parser.parse(_loginString, WS_RESTLoginAuthRequest, transientJSONObjs).WS_RESTLoginAuthRequest;
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/login");
	
	login := webService.postLogin(requestLogin);
	if not login.isKindOf(WS_NAuthTokenResponse) then
		delete login;
		if webService.httpStatusCode = HttpResponseUnauthorized then
			return HttpResponseUnauthorized.String &amp; " Unauthorized - Username / Password not OK";
		endif;
		return "Login failed";
	endif;
	
	responseLogin := login.WS_NAuthTokenResponse;
	webService.unitTestData.addAssoc("HTTP_AUTHORIZATION", "Bearer " &amp; responseLogin.accessToken);
	
	requestBody 	:= _json;
	pathIn 			:= _pathString; // /Voyage/{id}
	verb 			:= JadeHTTPConnection.Verb_PUT;
	
	// call the transform request method
	// preProcessRequest(httpIn: String io; queryStr: String; pathIn: String; methodType: String; contentType: String) updating, protected;
	webService.sendMsgWithIOParams(MasterTerminalAPIService::preProcessRequest.name, requestBody, queryString, pathIn, verb, contentType);
	_json := requestBody;
	return null;
	
	ref := CM_UnitTestAgent::wsRESTPreProcessRequest.name;
	
epilog
	if webService.objectsToBeDeleted.isNotEmpty then
		webService.objectsToBeDeleted.purge;
	endif;
	delete webService;
	delete parser;
	delete requestLogin;
	delete request;
	transientJSONObjs.purge();
	delete transientJSONObjs;
end;</source>
        <Parameter name="_loginString" type="String"/>
        <Parameter name="_json" type="String" usage="io"/>
        <Parameter name="_pathString" type="String"/>
        <Parameter name="_expectFailure" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsRESTPutBarrierConfirmation" id="874a8791-bd46-4584-8d6f-5389324691cf">
        <source>wsRESTPutBarrierConfirmation(_loginString: String; _truckRego, _queryString: String; _expectErrors: Boolean):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 March 2024	navsp1	Initial creation TFS ChangeRequest 61975: CUX | EDBIC - API message to proceed truck to yard or road
25 March 2024	navmd1	TFS 61975 Tweaks after spec'ing API. Rename from putProceedTruck to putBarrierConfirmation

*/

vars
	requestLogin		: WS_RESTLoginAuthRequest;
	webService			: MasterTerminalAPIService;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	response 			: WS_Response;
	ref 				: String;
begin
	create webService transient;
	create transientJSONObjs transient;
	create parser transient;
	
	// Login Request
	self.loginREST(webService);	
	
	// set up the WS_Request object
	if _truckRego = null then
		webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/BarrierConfirmation");
	else
		webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/BarrierConfirmation/"&amp;_truckRego);
	endif;
	webService.qsData.parseNameValuePair(_queryString);
	
	response := webService.putBarrierConfirmation(_truckRego);
	
	// If we're expecting to fail, then return early
	if _expectErrors then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		return response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		if response.allErrors.size &gt; 0 then
			app.writeLog(response.allErrors.first.text, LogERROR);
		endif;
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details" &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTPutCargoUpdate.name;
	
epilog
	webService.objectsToBeDeleted.purge;
	webService.qsData.purge();
	delete webService;
	delete parser;
	delete requestLogin;
	transientJSONObjs.purge();
	delete transientJSONObjs;
end;</source>
