/*
Date		Who		Reason
27 May 2009	cnwar2	Initial creation

*/
vars
	adjust : Boolean;
begin
	 // ### JIRA 34524 08APR2025 NAVAB1
	adjust := self.shipCutoffsAutoAdjust or not self.ckbOverrideDef.value;
	if adjust then
//	if not self.ckbOverrideDef.value then // ### JIRA 34556 07APR2025 NAVAB1
		self.adjustProxyCutoffs(DefaultRelativeTo_Arrival); // ### JIRA 34233 06MAR 2025 NAVAB1
	else  // ### JIRA 34524 08APR2025 NAVAB1
		self.adjustProxyCutoffsHours(DefaultRelativeTo_Arrival);
	endif;
