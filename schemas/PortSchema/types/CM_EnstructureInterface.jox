    <JadeMethod name="getVoyage" id="c482ff86-c7ee-43ce-bbf7-2407c6acab2a">
        <source>getVoyage(_invoice : CM_Invoice) : CM_Voyage;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	line : CM_InvoiceLine;
begin
	if _invoice = null then
		return null;
	endif;
	
	if _invoice.myVoyage &lt;&gt; null then
		return _invoice.myVoyage;
	endif;
	
	foreach line in _invoice.invoiceLines do
		if line.trackedItem &lt;&gt; null then
			return line.trackedItem.myVoyage;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
</Class>
