    <JadeMethod name="trxUpdateVoyageJobsNumber" id="b22aeb98-8e27-4c37-b256-a5a784b55b9e">
        <updating/>
        <source>trxUpdateVoyageJobsNumber(_allJobs :CM_VoyageJobByJobNumDict; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aJob : CM_Job;
	aVJob : CM_VoyageJob;	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;
	
	app.myUtilityUA.utlUpdateVoyageJobsNumber(_allJobs, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_allJobs" type="CM_VoyageJobByJobNumDict"/>
