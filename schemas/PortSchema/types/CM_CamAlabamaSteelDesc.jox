<Class name="CM_CamAlabamaSteelDesc" id="553f45e3-436d-4041-94ab-5bb3f9f5c33c">
    <superclass name="CM_CamProtocolDesc"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="cams"/>
    <PrimAttribute name="transmissionNumber" id="23b65432-5354-4f99-bef0-8b4dfdd67a18">
        <embedded/>
        <type name="Integer"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="addMessage" id="5e1f10a1-d607-4ecf-89a6-24756742eb89">
        <source>addMessage( _anArray : HugeStringArray input; _aString : String);
//
//11 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//23 Feb 2015	cnwrs1	par 35738 - Fixup HugeStringArray processing
//02 Jun 2015	cnwrs1	Par 36365 - Change to support strings longer than 512 bytes
vars
	msgLength :Integer;	
	theString : String;
begin
	theString := _aString;
	msgLength := theString.length;
	
	while msgLength &gt; 2047 do
		_anArray.add(theString[1:2047]);	
		theString := theString[2048:msgLength];
		msgLength := theString.length;
	endwhile;
	
	_anArray.add(theString);
end;</source>
        <Parameter name="_anArray" type="HugeStringArray" usage="input"/>
        <Parameter name="_aString" type="String"/>
    </JadeMethod>
    <JadeMethod name="availableCargoTypes" id="7c93306b-c61b-46f7-ab0b-caa9e9a84f27">
