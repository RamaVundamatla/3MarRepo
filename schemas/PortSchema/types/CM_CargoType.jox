    <JadeMethod name="validateBulkProduct" id="88391b9b-0f84-48eb-86cb-76032ed468e7">
        <source>validateBulkProduct() protected;
// ---------------------------------------------------------------------------
// Created:     23 March 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.isBulkProduct and
	   ((not app.myRoot.canDo(Mod_BulkCargo) )) then
		app.raiseCMException1(NotLicensedToPerformAction, app.getLicenseName(Mod_BulkCargo), null, null);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateDefaultCommodity" id="7a5f3afc-1104-413c-bc52-71b303ec7a90">
        <source>validateDefaultCommodity();
/* ---------------------------------------------------------------------------
Created:	21 May 2009	by cnwvu1

Purpose:	CCMS 1080 PAR 19704. July 2009
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.isCommodityRequired and self.defaultCommodityCode &lt;&gt; null then
		if self.allCommodities[self.defaultCommodityCode] = null 
		and not self.allCommodities.isEmpty()	// when there are no selected commodities for cargo type, all commodities are valid
		then
			app.raiseCMException1(ERR_MustIncludeDefaultCommodit, self.defaultCommodityCode, null, null);
		endif;
	endif;

	if not self.isCommodityRequired and not self.allCommodities.isEmpty then
		app.raiseCMException(ERR_SelectCommodForCargoType, null, null);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateDuplicates" id="d3d05d29-90a3-4260-954f-d51a9adbc36b">
        <source>validateDuplicates() protected;
/*

Date		Who		Reason
09 April 2015	cnwer1	Initial creation PAR 36005
29/07/2016 		cnwma1 TFS #2452  1310 Error in LOLO Planning when using Voyage Allocations
//13/06/2022    navds20 TFS 53760 DuplicateItem not Translatable
*/

vars
	realCargoType,
	cargoType	: CM_CargoType;
	iter			: Iterator;
begin
	realCargoType:=self.pxyGetRealObject();
	//check no duplicate names or abbreviations
	iter := self.myRoot.allCargoTypesById.createIterator();
	while iter.next(cargoType) do
		if realCargoType &lt;&gt; null and 
			realCargoType = cargoType then
			continue;
		endif;
		if (cargoType.abbreviation.toUpper = self.abbreviation.toUpper) or     //29/07/2016 cnwma1 TFS #2452
			(cargoType.description = self.description) then
			//app.raiseCMException2(DuplicateItem, 'Abbreviation or Description', 'another Item', null, null); //13.06.2022 navds20 53760
			// Abbreviation or Description already exists for another Item : Abbre_descr_alrea_exist_anoth_
			app.raiseCMException(Abbre_descr_alrea_exist_anoth_, null, null); //13.06.2022 navds20 53760
			return;
		endif;
	endwhile;
	
	if self.myRoot.allCargoTypesById[self.id] &lt;&gt; null then
		if realCargoType = null or realCargoType &lt;&gt; self.myRoot.allCargoTypesById[self.id] then
			app.raiseCMException2(VB_DUPLICATED_ITEM, self.id.String, 'ID', null, null);
		endif;
	endif;
epilog	
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="c6160b03-0d99-435a-84a0-8b4346108c23">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
// 16/12/2014   cnwdb2	    PAR 35364
// ---------------------------------------------------------------------------
vars
begin
	if self.myRoot = null then
		app.raiseCMException(Input_required_field_refrcRoot, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	//epr par 36005 9/4/15	
	self.validateForUpdate();
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="86bfb01a-3451-49d6-a0ca-0ad64000d57a">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 04/03/2010	cnwcs5	par 22762 - check can be deleted flag
// 04/12/2012	cnwcs5	par 30753 - check cargo type not used in any trailer types
//11/04/2019 	JLGNS1	Bug 44243: PEL1 add inverses to prevent deleting consigniees if used in a WODCargoRequest

vars

	entries	: Integer;
	term : CM_Terminal;
	map : CM_TranMapInvoiceLineMapping;
begin
	// ### TFS CR 65336 TASK 65337 08AUG2024 NAVAB1
	map :=  self.allTMInvoiceLineMappings.first;
	if map &lt;&gt; null then
		app.raiseCMWarning2(Cargo_type_used_invoi_mappi_su, self.abbreviation,map.getTranMapBreadCrumb(),null,null, self);
	endif;
	
	if not self.hasNoNonInversedUsages then												// 04/03/2010 cnwcs5 par 22762 
		// can't be deleted - check this first
		app.raiseCMException1(ERR_CannotDeleteCargoType, self.description, null, null);	// 04/03/2010 cnwcs5 par 22762 
		return;																			// 04/03/2010 cnwcs5 par 22762 
	endif;
	
	if self.id &lt;= TI_CargoType_Max then
		app.raiseCMException1(ERR_CannotDeleteSysCargoTypes, self.description, null, null);
		return;
	endif;
	
	// par 30753 - check the cargo type is not used in any trailer types
	entries := self.allTILCTypes.size;
	
	if entries &lt;&gt; 0 then
		app.raiseCMException2 (ERR_CannotDeleteTrCargoType, self.description, entries.String, null, null);
	endif;
	
	// 07/03/2012 cnwar2 #28974
	if not self.allTIServiceMaps.isEmpty then
		app.raiseCMException1(CannotDeleteTransMap, self.description, null, null);
		return;
	endif;
	
	entries := self.allTIServiceMaps.size;
	
	if entries &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.description, entries.String, "Invoice Maps", null);
	endif;
	
	entries := self.allWodCargoRequests.size;																					//Bug 44243
																																//Bug 44243
	if entries &gt; 0 then																											//Bug 44243
		app.raiseCMException2(ObjectStillHasEntries, self.description, entries.String, app.getErrorString(Work_order), null);	//Bug 44243
	endif;																														//Bug 44243
	
	//29 Apr 2021	NDL	TFS 50906
	foreach term in self.allTerminals do
		if term.hasLocationActivityFor( self ) then
			app.raiseCMException2(ObjectStillHasEntries, term.code, app.getErrorString(Location_activity), app.getErrorString(Location_activity), null);
		endif;
	endforeach;
	
	// If there is cargo for this type and it is deleted then JMTerminal will puke all over your shoes!
	// so make sure there is no cargo for this type before deleting it.
	inheritMethod();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="563646a0-5eea-46b0-977e-b7147b2edc97">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 05/12/2014  	cnwma1  	PAR #35338 Not selecting a Volume measurement can cause 1090 errors
// 07/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
// ---------------------------------------------------------------------------
vars
	tmpTI		: Object;
	realCargoType	: CM_CargoType;
	terminal	: CM_Terminal;
	transCargoType : CM_CargoType;
begin
	
	inheritMethod();
	//epr par 36005 9/4/15
	self.validateDuplicates();
	// This should all still work via mapping methods for new structure.
	if self.myClassToCreate &lt;&gt; null then
		create tmpTI as self.myClassToCreate transient;
		
		if (not tmpTI.isKindOf(CM_TrackedItem)) then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Class to create is not a CM_TrackedItem for (' &amp; self.description &amp; ')');
			return;
		endif;
		
		//if self.id &gt; TI_CargoBOLType_Max and self.id &lt; TI_CargoBOLType_JMTMax then																			// TFS 49252
		if (self.id &gt; TI_CargoBOLType_Max and self.id &lt; TI_CargoBOLType_JMTMax) or (self.id &gt; TI_CargoBOLType_JMTMax and app.myRoot.isClientCentrePort) then	// TFS 49252
			// This is a user defined cargo type
			//if tmpTI.CM_TrackedItem.cargoType &lt;&gt; TI_CargoType_BreakBulk then
			//	app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid class (' &amp; self.classNameToCreate &amp; ') for (' &amp; self.description &amp; ')');
			//endif;

		elseif tmpTI.CM_TrackedItem.cargoType &lt;&gt; self.id and self.id &lt;&gt; TI_CargoType_Chassis then
			// create method on tmpTI should set cargoType to be the id (for chassis does not set the
			// cargo id as the CM_TILC class is also used for user defined cargo types)
			app.raiseUnexpectedProgramError(class.name, method.name, 
				'Class (' &amp; self.myClassToCreate.name &amp; ') does not instantiate itself correctly - ' &amp;
				'cargoType not set to ' &amp; self.id.String &amp; '  for ' &amp; self.description &amp; ' in the create method');
			return;
		endif;
		
		realCargoType:=self.pxyGetRealObject();
		// R Barr 2/11/2006 Comalco - BulkProduct setting cannot be changed if tracked items exist
		if realCargoType &lt;&gt; null and isBulkProduct &lt;&gt; realCargoType.isBulkProduct then 
			foreach terminal in allTerminals where terminal.hasTrackedItemForCargoType(id, false) do
				app.raiseCMException1(Bulk_product_no_change_withTIs, description, null, null);			
				return;
			endforeach;		
		endif;
		
	endif;
	
	self.validateBulkProduct();

	if not app.isConverting then	// don't check, when going to the new JMT version - don't stop an upgrade because of the validation. It will be caught by a user later.
		self.validateTerminals();			// 27086 Feb 2011
		self.validateDefaultCommodity();	//PAR 19704, CCMS 1080 May 2009
	endif;

	self.validateMySystemProductType();	//par 21369 Oct 2009
	
	if self.isBulkMulti then											// 05/12/2014 cnwma1 PAR 335338																		
		if self.trackByMeasureType = null then															
			app.raiseCMException(Input_required_field_trckBy, null, null);									
		endif;																								
																											
		if self.trackByMeasureType = CargoType_TrackByWeight and self.myWeightMeasurementType = null then	
			app.raiseCMException(Input_required_field_dfltWght, null, null); // cnwdb2	PAR 35364
		endif;																								
																											
		if self.trackByMeasureType = CargoType_TrackByVolume then
			if self.myVolumeMeasurementType = null then			
				app.raiseCMException(Input_required_field_dfltVolWt, null, null); // cnwdb2	PAR 35364
			endif;
			//epr par 36005 9/4/15
			if self.mySystemProductType &lt;&gt; null and self.mySystemProductType.getDensityValue = null then
				app.raiseCMException(Density_Rqd_Tracked_By_Volume, null, null);
			endif;
		endif;
	endif;	
	
	//21 May 2021	NDL	TFS 51243
	if not self.allRecipes.isEmpty then
		if self.isTransient then
			transCargoType := self;
			realCargoType := self.pxyGetRealObject;
		else
			transCargoType := self.pxyGetProxyObject;
			realCargoType := self;
		endif;
		if transCargoType &lt;&gt; null and realCargoType &lt;&gt; null then
			if  transCargoType.trackByMeasureType &lt;&gt; realCargoType.trackByMeasureType then
				app.raiseCMException( Not_chang_track_value_when_hav, null, null );
			endif;
		endif;  
	endif;
	

	/*		18/3/19 MAP TFS41707
	if self.allowAutoVolumeCalc then
		// is only allowed when cargo tyoe is track as break bulk
		if self.productType &lt;&gt; ProductType_BreakBulk
		// only valid if allow cargo sub types (products)
		or not self.isSubCargoTypeRequired
		//only valid when quantity and volume are available.
		or not self.allAttributesOnProduct.includes(ETRow_MyVolume)
		or not self.allAttributesOnProduct.includes(ETRow_MyQuantity)
		then
			app.raiseCMException(AllowAutoVolumeCalc, null, null);
		endif;
		
	endif;
	*/

epilog
	delete tmpTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMySystemProductType" id="88829094-19a2-4803-8c7f-08c104ff514d">
        <source>validateMySystemProductType();
/* ---------------------------------------------------------------------------
Created:	22 October 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	entDef		: EntTableDef;
	entRow		: EntTableRow;
	prodAttr	: CM_ProductAttr;

begin

	if self.requiresSystemProductType() then
	
		if self.mySystemProductType = null then
			app.raiseUnexpectedProgramError( class.name, method.name, 'System cargo subtype is null' );
			return;
		endif;
		
		if self.mySystemProductType.myCargoType &lt;&gt; null then	// because it should be not included in cargoType.allProducts collection - it is not inversed.
			app.raiseUnexpectedProgramError( class.name, method.name, 'Cargo type for system product type should be null' );
			return;
		endif;
		
		//also, validate self.allAttributesOnProduct. 
		//all viewable prod attributes on self.mySystemProductType should be inlcuded in self.allAttributesOnProduct.
		// all not viewable attributes should be not included.
		entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_AllAttributes];
		foreach entRow in entDef.allEntTableRows do
			prodAttr := self.mySystemProductType.getProdAttrFromName(entRow.name);
			if prodAttr.isViewable then	// when prodAttr is viewable - it should be included in the collection
				if not (self.allAttributesOnProduct.includes(entRow.name)) then
					app.raiseUnexpectedProgramError( class.name, method.name, 'Attribute '&amp; entRow.name&amp; ' should be included into cargoType.allAttributesOnProduct collection' );
					return;
				endif;
			else	// when prodAttr not viewable - it should be not included in the collection
				if self.allAttributesOnProduct.includes(entRow.name) then
					app.raiseUnexpectedProgramError( class.name, method.name, 'Attribute '&amp; entRow.name&amp; ' should be not included into cargoType.allAttributesOnProduct collection' );
					return;
				endif;
			endif;
		endforeach;
		
	else
	
		if self.mySystemProductType &lt;&gt; null then
			app.raiseUnexpectedProgramError( class.name, method.name, 'System cargo subtype should be null' );
			return;
		endif;
		
		// for system cargo type, plus trailers and vehicles, this allAttributesOnProduct collection should be null.
		if not self.isSubCargoTypeRequired then
			if not self.allAttributesOnProduct.isEmpty() then
				app.raiseUnexpectedProgramError( class.name, method.name, 'All cargoType.allAttributesOnProduct collection is not empty' );
				return;
			endif;
		endif;
	
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateTerminals" id="2689bd0b-74ad-450f-a698-8b54f21d3458">
        <source>validateTerminals();
/* ---------------------------------------------------------------------------
Created:	21 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
Feb 2010		cnwjre1	27086 fix the test of terminals removed from the cargo type list
------------------------------------------------------------------------------*/
vars
	term			: CM_Terminal;
	userTerminals	: CM_TerminalByCodeDict;
	currentTerminals,
	newTerminals	: CM_TerminalArray;
	realCargoType	: CM_CargoType;

begin
	realCargoType:=self.pxyGetRealObject();
	if realCargoType = null then
		return;
	endif;
	
	create userTerminals transient;
	create currentTerminals transient;
	create newTerminals transient;
	
	app.getMyUser().getTerminals(userTerminals);	//getting visible terminals for a user. Unvisible terminals are untouched and don't require to be validated.

	foreach term in realCargoType.allTerminals do
		if userTerminals.includes(term) then
			currentTerminals.add(term);
		endif;
	endforeach;
	foreach term in self.allTerminals do
		if userTerminals.includes(term) then
			newTerminals.add(term);
		endif;
	endforeach;

	foreach term in currentTerminals do
		//checking whether terminal has been removed from the list in Cargo Types screen.
		if not newTerminals.includes(term) then	 			
			if term.defaultCargoBolType = self.id then		//default cargo BOL type cannot be removed from a terminal
				app.raiseCMException1(ERR_CARGOBOLTYPE_DEFAULT,term.name,null, null);
			endif;
			//to check whether there are some cargo on-site for this cargo type. In this case cannot remove terminal in the list (Cargo Types screen)
			if term.hasTrackedItemForCargoType(self.id, true) then 
				app.raiseCMException2(Cant_remove_cargotype_terminal, term.name, self.abbreviation, null, null);
			endif;
			
		endif;
		
	endforeach;

epilog
	delete userTerminals;
	delete currentTerminals;
	delete newTerminals;
end;</source>
    </JadeMethod>
</Class>
