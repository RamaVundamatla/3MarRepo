<GUIClass name="CM_MenuEntityPicture" id="2fa3c760-ced5-4747-bfac-48f76a5cefd2">
    <superclass name="Picture"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="diskName" id="4c7e0392-c373-45f6-bc5a-93822bea1c5a">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="savePictureToDatabase" id="08c36efa-b48b-418b-9419-6b1212b2f223">
        <source>savePictureToDatabase(_root : CM_Root);
/*
Purpose:	hystorically there were 3 pictures per navigator, but now just save the same image under the 3 different root configs.		

Date		Who		Reason
12OCT2021	NAVAB1	TFS 50421
*/

vars
	
begin

	_root.setConfig(self.helpKeyword, self.picture, false);
	_root.setConfig(self.tag, self.picture, false);
	_root.setConfig(self.hyperlink, self.picture, false);

end;</source>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
