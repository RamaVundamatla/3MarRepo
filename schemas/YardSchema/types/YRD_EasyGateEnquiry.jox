    <JadeMethod name="btnUnloadTruck_click" id="76b7630c-206c-4281-bf39-69f921432422">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUnloadTruck_click(btn: Button input) updating;
/*

Date				Who		Reason
02 February 2010	cnwrd1	Initial creation

*/
vars

begin
	if self.myCurrentInterTerminalMove = null then
		return;
	endif;
	
	if self.myCurrentInterTerminalMove.status = ITT_LOADED or self.myCurrentInterTerminalMove.status = ITT_UNLOADING then
		if self.myCurrentInterTerminalMove.myTargetTerminal = self.myTerminal then
			self.doMnuUnloadTruckEG();
		endif;
	endif;

epilog

end;</source>
