    <JadeMethod name="doSave" id="d174e07d-1929-4ca6-b7cb-ce98ac6de495">
        <updating/>
        <source>doSave():Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwndl1	Initial creation	Par 30901
31 July     2014    cnwma1 PAR 34408 Credit Customer current charges

*/

vars

	pxyItem : CM_DutyDocItem;
	isCar : Boolean;
	
	//attributes
	hsCode : String;
	packing : Integer;
	origin : String;
	quantity : Integer;
	volume : Decimal [12,2];
	grossWeight : Decimal [12,2];
	netWeight : Decimal [12,2];
	currency : String;
	currencyRate : Decimal[16,4];
	exchange : CM_DutyDocExchangeRate;
	foreignValue : Decimal [16,4];
	localValue : Decimal [16,4];
	freight : Decimal [16,4];
	insurance : Decimal [16,4];
	dutyCode : String;
	dutyExempt : String;
	duty : Decimal [16,4];
	dutyRate : Decimal [5,2];
	exemptBenefit : String;
	exemptSource : String;
	dutyDocRoot : CM_DutyDocTerminalRoot;
	consignee,
	pol,pod, bol: String;
	
	//extra attributes if a car
	vccNo : String;
	vccDate : Date;
	vehicleMake : String;
	vehicleType : String;
	vehicleModel : String;
	chassisNo : String;
	engineNo : String;
	color : String;
	numberPlate : String;
	theReturn : Integer;
	agent: CM_DutyDocAgent;
	invoiceLine : CM_InvoiceLine; 		   
	invoiceStatus	: CMIF_InvoiceStatus;  
	pxyInvoiceLine	: CM_InvoiceLine;	   
	ti : CM_TrackedItem;					  
	txn : CM_TITransaction;
	txnSet : CM_TITransactionSet;
	invoiceLineSet : CM_InvoiceLineSet;
	oldDuty		: Decimal[5,2];
	oldHsCode : String ;
	ls: Boolean;
begin

	create agent transient;
		
	if self.allDutyDocItems.size &gt; 1 then
		return self.doSaveMulti();
	endif;
	
	if self.chkDutyExempt.value and self.txtDutyExempt.text = null and self.txtExemptBenefit.text = null and self.txtExemptSource.text = null then
		// Not exempt details entered so will not be exempt, need to re calc duty
		self.chkDutyExempt.value := false;
		self.evaluateValues;
	endif;
	
	if self.cmbPacking.listIndex &gt; 0 then
		packing := agent.getPackingId(self.cmbPacking.itemText[self.cmbPacking.listIndex]);
	else
		packing := 0;
	endif;
	//origin := self.txtOrigin.text.trimBlanks;
	//08 Aug 2013	NDL	Par 32305
	if self.cmbOrigin.listObject = null then
		origin := null;
	else
		origin := self.cmbOrigin.listObject.CM_Country.getIsoCountryCodeForConversion;	
	endif;
	quantity := self.txtQuantity.text.trimBlanks.Integer;
	volume := self.txtVolume.text.trimBlanks.Decimal;
	grossWeight := self.txtGrossWeight.text.trimBlanks.Decimal;
	netWeight := self.txtNetWeight.text.trimBlanks.Decimal;
	currency := self.cmbCurrency.text.trimBlanks;
	exchange := self.cmbCurrency.listObject.CM_DutyDocExchangeRate;
	if exchange &lt;&gt; null then
		currencyRate := exchange.rate;
	endif; 
	foreignValue := self.txtForeignValue.getCurrencyStringAsDecimal();
	localValue := self.txtLocalValue.getCurrencyStringAsDecimal();
	freight := self.txtLocalFreight.getCurrencyStringAsDecimal();
	insurance := self.txtLocalIns.getCurrencyStringAsDecimal();
	dutyCode := self.txtDutyCode.text.trimBlanks;
	duty := self.txtDuty.getCurrencyStringAsDecimal();
	dutyRate := self.txtRatePercent.text.Decimal;
	dutyExempt := self.txtDutyExempt.text.trimBlanks;
	exemptSource := self.txtExemptSource.text.trimBlanks;
	exemptBenefit := self.txtExemptBenefit.text.trimBlanks;

	hsCode := self.getHSCode;
	/*if hsCode = null then
		return false;
	endif;*/
	consignee:=self.getConsignee;
	pol:=self.getPOL;
	pod:=self.getPOD;
	bol:=self.getBOL;
	
	isCar := self.grpCar.visible;
	if isCar then
		vccNo := self.txtVCCNum.text.trimBlanks;
		vccDate := self.txtVccDate.getDate();
		vehicleMake := self.cmbVehMake.text;
		vehicleType := self.cmbVehType.text;
		vehicleModel := self.cmbVehModel.text;
		chassisNo := self.txtChassis.text.trimBlanks;
		engineNo := self.txtEngine.text.trimBlanks;
		color := self.cmbVehColour.text;
		numberPlate := self.txtNumPlate.text.trimBlanks;
	endif;

	if myDutyDocItem &lt;&gt; null then
		oldDuty := self.myDutyDocItem.duty;
		oldHsCode := self.myDutyDocItem.hsCode;
		beginLoad;
		pxyItem := myDutyDocItem.pxyCreateUpdateProxy().CM_DutyDocItem;
		endLoad;
		self.myTrackedItem:=pxyItem.getMyTrackedItem;
	else
		if isCar then
			create pxyItem as CM_DutyDocCarItem transient;
		else
			create pxyItem transient;
		endif;
	endif;
	
	dutyDocRoot := app.myDutyDocRoot.allDutyDocTerminalRoots[self.myTerminal];
	pxyItem.setProxy(	dutyDocRoot,
						self.myDutyDoc,
						self.myTrackedItem,
						self.txtCargoDetail.text,
						self.txtVoyage.text,
						self.txtOperator.text,
						self.txtAgent.text, //agent
						consignee, //consignee
						pol, //port of load
						pod, //port destination
						bol,	//_bol	: CM_BOLIn;
						self.txtDO.text.trimBlanks,	//_deliveryNo : String;
						self.txtDOExp.getDate, //_deliveryExpiry
						hsCode,	//_hsCode : String;
						packing,	//_packing : Integer;
						origin,	//_origin : String;
						quantity,	//_quantity : Integer;
						volume,	//_volume,
						grossWeight,	//_grossWeight,
						netWeight,	//_netWeight : Decimal;
						currency,	//_currency : String;
						currencyRate,
						foreignValue,	//_foreignValue,
						localValue,	//_localValue,
						freight,	//_freight,
						insurance,	//_insurance : Decimal;
						dutyCode,	//_dutyCode : String;
						dutyExempt,	//_dutyExempt : String;
						duty,	//_duty, 
						dutyRate,	//_dutyRate : Decimal;
						exemptBenefit,	//_exemptBenefit : String;
						exemptSource	//_exemptSource : String
						);
	
	if pxyItem.isCar then
		pxyItem.CM_DutyDocCarItem.setProxyCar(	vccDate,	//_vccDate : Date;
												vehicleType,	//_vehicleType : String;
												vehicleMake,	//_vehicleName : String;
												vehicleModel,	//_vehicleModel : String;
												chassisNo,	//_chassisNo : String;
												engineNo,	//_engineNo : String;
												color,	//_color : String;
												numberPlate	//_numberPlate : String
												);
	endif;
	
	while true do
		if self.myDutyDocItem = null then													
			// Create DutyDocItem
			app.myTrxCA.trxCreateDutyDocItem( pxyItem, self.myDutyDocItem, app.myPassport );
			if not app.myPassport.trxCompletedOK then
				app.showErrorWarningDialog("Duty Documentation Item", app.myPassport, ErrWarnMode_AddUpdate);
				return false;
			endif;
			if  self.myDutyDoc &lt;&gt; null then
				// Create Duty Charges
				if self.myDutyDoc.dutyDeposit = 0 then
					app.myTrxUA.trxDutyDocDutyCharge(self.myDutyDocItem, app.myPassport);       // cnwma1 31/07/2014 PAR 34408
					if not app.myPassport.trxCompletedOK then
						app.showErrorWarningDialog("Duty Documentation Item Charge", app.myPassport, ErrWarnMode_AddUpdate);
						return false;
					endif;
				endif;
			endif;	
		else
			//Update DutyDoc Item 
			app.myTrxUA.trxUpdateDutyDocItem( pxyItem, app.myPassport );                     // cnwma1 31/07/2014 PAR 34408
			if not app.myPassport.trxCompletedOK then
				app.showErrorWarningDialog("Duty Documentation Item", app.myPassport, ErrWarnMode_AddUpdate);
				return false;
			endif;
			
				if oldDuty = null    then
					app.myTrxUA.trxDutyDocDutyCharge(self.myDutyDocItem, app.myPassport);       // cnwma1 31/07/2014 PAR 34408
					if not app.myPassport.trxCompletedOK then
						app.showErrorWarningDialog("Duty Documentation Item Charge", app.myPassport, ErrWarnMode_AddUpdate);
						return false;
					endif;
					
				endif;
		endif;
		
		if self.myDutyDoc &lt;&gt; null then
			if oldDuty &lt;&gt; null then
				if  self.myDutyDoc.dutyDeposit = 0  and oldDuty &lt;&gt; pxyItem.duty then
					ti:= self.myDutyDocItem.getMyTrackedItem;
					create txnSet transient;
					create invoiceLineSet transient;
					txnSet := self.myDutyDocItem.getMyTrackedItem.getTransOfType(TRANS_TYPE_DUTY_CHARGE);
					if txnSet.size &lt;&gt; 0 then
						foreach txn in txnSet do
						 if txn.myInvoiceLine &lt;&gt; null then
							if  txn.myInvoiceLine.getRate.roundedTo(2) = oldDuty and    txn.myInvoiceLine.trackedItem = ti and txn.myInvoiceLine.voided=false then
								invoiceLineSet.addNoDuplicates(txn.myInvoiceLine,false);
							endif;
						 endif;
						endforeach;
						if invoiceLineSet.size = 0 then 
							app.myTrxUA.trxDutyDocDutyCharge(self.myDutyDocItem, app.myPassport);       // cnwma1 31/07/2014 PAR 34408
							if not app.myPassport.trxCompletedOK then
								app.showErrorWarningDialog("Duty Documentation Item Charge", app.myPassport, ErrWarnMode_AddUpdate);
								return false;
							endif;
						endif;
						invoiceLine := invoiceLineSet.first;
						if invoiceLine &lt;&gt; null  then
							create invoiceStatus transient;						
							app.cmsBeginLoad(ls);
							pxyInvoiceLine := app.createUpdateProxy(invoiceLine).CM_InvoiceLine;
							app.cmsEndLoad(ls);
							
							invoiceStatus.allInvoiceLines.add(pxyInvoiceLine);
							invoiceStatus.newStatus := CM_InvoiceLine.STATUS_VOIDED;
							// Void Invoice Line
							app.myTrxUA.trxUpdateInvoiceStatus(invoiceStatus, app.myPassport);
							if not app.myPassport.trxCompletedOK then
								app.showErrorWarningDialog("Duty Documentation", app.myPassport, ErrWarnMode_AddUpdate);
								return false;
							endif;
							// Update Invoice Line
							app.myTrxUA.trxDutyDocDutyCharge(self.myDutyDocItem, app.myPassport);    // cnwma1 31/07/2014 PAR 34408
							if not app.myPassport.trxCompletedOK then
								app.showErrorWarningDialog("Duty Documentation", app.myPassport, ErrWarnMode_AddUpdate);
								return false;
							endif;
						endif;
					else
						// Create Duty Charges  From Select Container
						if self.myDutyDoc.dutyDeposit = 0 then
							app.myTrxUA.trxDutyDocDutyCharge(self.myDutyDocItem, app.myPassport);       // cnwma1 31/07/2014 PAR 34408
							if not app.myPassport.trxCompletedOK then
								app.showErrorWarningDialog("Duty Documentation Item Charge", app.myPassport, ErrWarnMode_AddUpdate);
								return false;
							endif;
						endif;
					endif;
				endif;
			endif;
			if self.myDutyDoc.isImport then
				createReleaseRequest(self.myDutyDoc,self.myDutyDocItem);
			endif;
		endif;
		break;		
	endwhile;
	return true;
	
epilog

	app.cmsEndLoad(ls);	
	delete pxyItem;
	self.myDutyDocItem:=null;
	self.btnAsCar.visible := false;	//07 Aug 2013	NDL	Par 31804
	delete agent;
	if invoiceStatus &lt;&gt; null then // cnwma1 31/07/2014 PAR 34408
		invoiceStatus.allInvoiceLines.purge;
	endif;
	delete invoiceStatus;          // cnwma1 31/07/2014 PAR 34408
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveMulti" id="81f935fb-4e04-44fc-b7dd-ba101e7e6fdd">
        <source>doSaveMulti() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2013	cnwer1	Initial creation HAT 2189
31 July     2014    cnwma1 PAR 34408 Credit Customer current charges
*/

vars
	quantity, remQuantity : Integer;
	volume : Decimal [12,2];
	grossWeight : Decimal [12,2];
	netWeight : Decimal [12,2];
	foreignValue : Decimal [16,4];
	localValue : Decimal [16,4];
	freight : Decimal [16,4];
	insurance : Decimal [16,4];
	netValue : Decimal [16,4];
	duty : Decimal [16,4];
	dutyRate : Decimal [5,2];
	dutyItemCount : Integer;
	dutyDocCar		: CM_DutyDocCarItem;
	dutyDocItem,pxyItem   : CM_DutyDocItem;
	hsCode,
	dutyExempt : String;
	exemptBenefit : String;
	exemptSource : String;
	dutyCode : String;
	currency,
	origin,
	consignee,
	pod,
	pol,
	bol,
 	delOrd : String;
	packing : Integer;
	delOrdExp : Date;
	//extra attributes if a car
	vccNo : String;
	vccDate : Date;
	vehicleMake : String;
	vehicleType : String;
	vehicleModel : String;
	chassisNo : String;
	engineNo : String;
	color : String;
	numberPlate : String;
	//changed values
	consigneeChanged,
	polChanged,
	podChanged,
	bolChanged,
	hsCodeChanged,
	doChanged,
	doExpChanged,
	packingChanged,
	originChanged,
	vccNoChanged,
	vccDateChanged,
	vTypeChanged,
	vMakeChanged,
	vModelChanged,
	chassisChanged,
	engineChanged,
	colorChanged,
	noPlateChanged,
	dutyExemptChanged,
	excemptSourceChanged,
	excemptBenefitChanged
	: Boolean;
	allProxyDutyDocItems : CM_DutyDocItemSet;
	invTerms : String;
	hsCodeObj : CM_DutyDocHSCode;
	theReturn : Integer;
	agent: CM_DutyDocAgent;
	txn : CM_TITransaction;
	txnSet : CM_TITransactionSet;
	invoiceLine : CM_InvoiceLine;
	invoiceStatus	: CMIF_InvoiceStatus;
	pxyInvoiceLine	: CM_InvoiceLine;
	invoiceLineSet : CM_InvoiceLineSet;
	ls: Boolean;
	oldDuty		: Decimal[5,2];
begin
	create agent transient;
	
	dutyItemCount:=self.allDutyDocItems.size;
	
	if app.msgBox(app.getErrorString1(Bulk_Edit_Items, self.allDutyDocItems.listString(",",CM_DutyDocItem::cargoId.name)),app.getErrorString(Warning),MsgBox_Yes_No) = MsgBox_Return_No then
		return false;
	endif;
	//bulk edit going to divy up what was entered in the below values between the duty doc items 
	quantity := self.txtQuantity.text.Integer div dutyItemCount;
	remQuantity := self.txtQuantity.text.Integer mod dutyItemCount;
	volume 	:= self.txtVolume.text.Decimal/dutyItemCount;
	grossWeight := self.txtGrossWeight.text.Decimal/dutyItemCount;
	netWeight := self.txtNetWeight.text.Decimal/dutyItemCount;
	
	
	if self.grpFinancial.visible then
		currency := self.cmbCurrency.text.trimBlanks;
		foreignValue:=self.txtForeignValue.getCurrencyStringAsDecimal()/dutyItemCount;
		localValue := self.txtLocalValue.getCurrencyStringAsDecimal()/dutyItemCount;
		freight := self.txtLocalFreight.getCurrencyStringAsDecimal()/dutyItemCount;
		insurance := self.txtLocalIns.getCurrencyStringAsDecimal()/dutyItemCount;
	endif;
	
	//get first duty doc item - check for values that have changed - only bulk update if changed
	dutyDocItem:=self.allDutyDocItems.first;
	//if same hasn't changed null
	consignee:=self.getConsignee;
	consigneeChanged:= dutyDocItem.consignee &lt;&gt; consignee;
	// load port
	pol :=self.getPOL;
	polChanged:=dutyDocItem.pol &lt;&gt; pol;
	//destination port
	pod :=self.getPOD;
	podChanged:=dutyDocItem.pod &lt;&gt; pod;
	//bol
	bol :=self.getBOL;
	bolChanged:=dutyDocItem.bol &lt;&gt; bol;
	// delivery order
	delOrd :=self.txtDO.text.trimBlanks;
	doChanged:=dutyDocItem.deliveryOrder &lt;&gt; delOrd;
	// do expiry
	delOrdExp:=self.txtDOExp.getDate;
	doExpChanged:=dutyDocItem.deliveryOrderExpiryDate &lt;&gt; delOrdExp;
	//hs code
	hsCode:= self.getHSCode;
	hsCodeChanged:=dutyDocItem.hsCode &lt;&gt; hsCode;
	// if hs code changed then duty needs to be recalculated
	
	//packing 
	if self.cmbPacking.listIndex &gt; 0 then
		packing := agent.getPackingId(self.cmbPacking.itemText[self.cmbPacking.listIndex]);
	endif;
	packingChanged:=dutyDocItem.packing &lt;&gt; packing;
	//origin
	//origin := self.txtOrigin.text.trimBlanks;
	origin := self.cmbOrigin.text;//08 Aug 2013	NDL	Par 32305
	originChanged:=dutyDocItem.origin &lt;&gt; origin;
	
	//car stuff
	if self.grpCar.visible and dutyDocItem.isKindOf(CM_DutyDocCarItem) then
		dutyDocCar:=dutyDocItem.CM_DutyDocCarItem;
		vccNo := self.txtVCCNum.text.trimBlanks;
		vccNoChanged:= dutyDocCar.vccNo &lt;&gt; vccNo;
		
		vccDate := self.txtVccDate.getDate();
		vccDateChanged:=dutyDocCar.vccDate &lt;&gt; vccDate;
		
		vehicleMake := self.cmbVehMake.text;
		vMakeChanged:=dutyDocCar.vehicleMake &lt;&gt; vehicleMake;
		
		vehicleType := self.cmbVehType.text;
		vTypeChanged:=dutyDocCar.vehicleType &lt;&gt; vehicleType;
		
		vehicleModel := self.cmbVehModel.text;
		vModelChanged:=dutyDocCar.vehicleModel &lt;&gt; vehicleModel;
		
		chassisNo := self.txtChassis.text.trimBlanks;
		chassisChanged:=dutyDocCar.chassisNo &lt;&gt; chassisNo;
		engineNo := self.txtEngine.text.trimBlanks;
		engineChanged:=dutyDocCar.engineNo &lt;&gt; engineNo;
		color := self.cmbVehColour.text;
		colorChanged:=dutyDocCar.color &lt;&gt; color;
		numberPlate := self.txtNumPlate.text.trimBlanks;
		noPlateChanged:=dutyDocCar.numberPlate &lt;&gt; numberPlate;
		
	endif;
	
	
	//dutyExcept
	dutyExempt := self.txtDutyExempt.text.trimBlanks;
	dutyExemptChanged:= dutyDocItem.exemptDutyCode &lt;&gt; dutyExempt;
	exemptSource := self.txtExemptSource.text.trimBlanks;
	excemptSourceChanged:= dutyDocItem.exemptSource &lt;&gt; exemptSource;
	exemptBenefit := self.txtExemptBenefit.text.trimBlanks;
	excemptBenefitChanged:=dutyDocItem.exemptBenefit &lt;&gt; exemptBenefit;
	
	create allProxyDutyDocItems transient;
	foreach dutyDocItem in self.allDutyDocItems do
		beginLoad;
		pxyItem := dutyDocItem.pxyCreateUpdateProxy().CM_DutyDocItem;
		endLoad;
		if dutyDocItem = self.allDutyDocItems.last then
			quantity:=quantity + remQuantity;
		endif;
		
		if not consigneeChanged then
			consignee:=pxyItem.consignee;
		endif;
		invTerms := dutyDocItem.myDutyDoc.invTerms;
		if invTerms = CIF then
			netValue := localValue;
		elseif invTerms = CNF then
			netValue := localValue + insurance;
		else	//if invTerms = FOB then
			netValue := localValue + freight + insurance;
		endif;
		
		if not hsCodeChanged then
			hsCode:=pxyItem.hsCode;
		endif;
		hsCodeObj:=app.myDutyDocRoot.allDutyDocHSCodes.getAtKey( hsCode.Integer64 );
		if hsCodeObj &lt;&gt; null then
			dutyRate := hsCodeObj.dutyRate;
			dutyCode:=hsCodeObj.dutyType;
		endif;
		
		if not dutyExemptChanged then
			dutyExempt:=pxyItem.exemptDutyCode;
		endif;
		if not excemptSourceChanged then
			exemptSource:=pxyItem.exemptSource;
		endif;
		if not	excemptBenefitChanged then
			exemptBenefit:=pxyItem.exemptBenefit;
		endif;		
		
		duty:= 0;
		if dutyExempt = null and exemptSource = null and exemptBenefit = null then
			if netValue &gt; 0 and dutyRate &gt; 0 then
				duty := (( netValue * dutyRate ) / 100);
			endif;
		endif;
		
		if not polChanged then
			pol:=pxyItem.pol;
		endif;
		if not podChanged then
			pod:=pxyItem.pod;
		endif;
		if not bolChanged then
			bol:=pxyItem.bol;
		endif;
		if not doChanged then
			delOrd:=pxyItem.deliveryOrder;
		endif;
		if not doExpChanged then
			delOrdExp := pxyItem.deliveryOrderExpiryDate;
		endif;
		
		if not packingChanged then
			packing :=pxyItem.packing;
		endif;
		
		if not originChanged then
			origin:=pxyItem.origin;
		endif;
		
		pxyItem.setProxy(pxyItem.myDutyDocTerminalRoot,
							pxyItem.myDutyDoc,
							pxyItem.getMyTrackedItem,
							pxyItem.cargoDetails,
							pxyItem.voyageDetails,
							pxyItem.operator,
							pxyItem.agent,
							consignee,
							pol,
							pod,
							bol,
							delOrd,
							delOrdExp,
							hsCode,
							packing,
							origin,
							quantity,
							volume,
							grossWeight,
							netWeight,
							currency,
							dutyDocItem.currencyRate,
							foreignValue,
							localValue,
							freight,
							insurance,
							dutyCode,
							dutyExempt,
							duty,
							dutyRate,
							exemptBenefit,
							exemptSource);
		
		if pxyItem.isKindOf(CM_DutyDocCarItem) then
			if not vccNoChanged then
				vccNo:=pxyItem.CM_DutyDocCarItem.vccNo;
			endif;
			if not vccDateChanged then
				vccDate:=pxyItem.CM_DutyDocCarItem.vccDate;
			endif;
			if not vTypeChanged then
				vehicleType:=pxyItem.CM_DutyDocCarItem.vehicleType;
			endif;
			if not vMakeChanged then
				vehicleMake:=pxyItem.CM_DutyDocCarItem.vehicleMake;
			endif;
			if not vModelChanged then
				vehicleModel:=pxyItem.CM_DutyDocCarItem.vehicleModel;
			endif;
			if not chassisChanged then
				chassisNo:=pxyItem.CM_DutyDocCarItem.chassisNo;
			endif;
			if not engineChanged then
				engineNo:=pxyItem.CM_DutyDocCarItem.engineNo;
			endif;
			if not colorChanged then
				color:=pxyItem.CM_DutyDocCarItem.color;
			endif;
			if not noPlateChanged then
				numberPlate:=pxyItem.CM_DutyDocCarItem.numberPlate;
			endif;
			
			pxyItem.CM_DutyDocCarItem.setProxyCar(	vccDate,	//_vccDate : Date;
												vehicleType,	//_vehicleType : String;
												vehicleMake,	//_vehicleName : String;
												vehicleModel,	//_vehicleModel : String;
												chassisNo,	//_chassisNo : String;
												engineNo,	//_engineNo : String;
												color,	//_color : String;
												numberPlate	//_numberPlate : String
												);
			
		endif;
		allProxyDutyDocItems.add(pxyItem);
	endforeach;

	while true do
		
		app.myTrxUA.trxUpdateDutyDocItems( allProxyDutyDocItems, app.myPassport );
		if app.myPassport.trxCompletedOK then
			if  self.myDutyDoc &lt;&gt; null then
				// Create Duty Charges
				if self.myDutyDoc.dutyDeposit = 0 then
					app.myTrxUA.trxDutyDocDutyCharges(allProxyDutyDocItems, app.myPassport);       // cnwma1 31/07/2014 PAR 34408
						if not app.myPassport.trxCompletedOK then
							app.showErrorWarningDialog("Duty Documentation Item Charge", app.myPassport, ErrWarnMode_AddUpdate);
							return false;
						endif;
				endif;
			endif;			
		else
			theReturn := app.showErrorWarningDialog("Duty Documentation Item", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		
		// Update Invoice Lines  WILL BE USED IF  need to Update Muliple Items 
		if self.myDutyDoc &lt;&gt; null then
			foreach dutyDocItem in allDutyDocItems do
				/*if  self.myDutyDoc.dutyDeposit = 0   then //and oldDuty &lt;&gt; pxyItem.duty
					create txnSet transient;
					create invoiceLineSet transient;
					txnSet := dutyDocItem.getMyTrackedItem.getTransOfType(TRANS_TYPE_DUTY_CHARGE);	
					if txnSet.size &lt;&gt; 0 then
						foreach txn in txnSet do
						 if txn.myInvoiceLine &lt;&gt; null then
							if  txn.myInvoiceLine.trackedItem =dutyDocItem.getMyTrackedItem and txn.myInvoiceLine.voided=false then //txn.myInvoiceLine.getRate = oldDuty and 
								invoiceLineSet.addNoDuplicates(txn.myInvoiceLine,false);
								
							endif;
							invoiceLineSet.clear;
						 endif;
						endforeach;
						if invoiceLineSet.size = 0 then 
							app.myTrxUA.trxDutyDocDutyCharge(dutyDocItem, app.myPassport);       // cnwma1 31/07/2014 PAR 34408
							if not app.myPassport.trxCompletedOK then
								app.showErrorWarningDialog("Duty Documentation Item Charge", app.myPassport, ErrWarnMode_AddUpdate);
								return false;
							endif;
						endif;
						invoiceLine := invoiceLineSet.first;
						if invoiceLine &lt;&gt; null  then
							create invoiceStatus transient;
							
							app.cmsBeginLoad(ls);
							pxyInvoiceLine := app.createUpdateProxy(invoiceLine).CM_InvoiceLine;
							app.cmsEndLoad(ls);
							invoiceStatus.allInvoiceLines.add(pxyInvoiceLine);
							invoiceStatus.newStatus := CM_InvoiceLine.STATUS_VOIDED;
							// Void Invoice Line
							app.myTrxUA.trxUpdateInvoiceStatus(invoiceStatus, app.myPassport);
								if not app.myPassport.trxCompletedOK then
									app.showErrorWarningDialog("Duty Documentation", app.myPassport, ErrWarnMode_AddUpdate);
									return false;
								endif;
							// Update Invoice Line
							app.myTrxUA.trxDutyDocDutyCharge(dutyDocItem, app.myPassport);    // cnwma1 31/07/2014 PAR 34408
								if not app.myPassport.trxCompletedOK then
									app.showErrorWarningDialog("Duty Documentation", app.myPassport, ErrWarnMode_AddUpdate);
									return false;
								endif;
						endif;
					else
						// Create Duty Charges Comming From Select Container
						if self.myDutyDoc.dutyDeposit = 0 then
							app.myTrxUA.trxDutyDocDutyCharge(dutyDocItem, app.myPassport);       // cnwma1 31/07/2014 PAR 34408
								if not app.myPassport.trxCompletedOK then
									app.showErrorWarningDialog("Duty Documentation Item Charge", app.myPassport, ErrWarnMode_AddUpdate);
									return false;
								endif;
						endif;
					endif;
					
				endif;*/
			createReleaseRequest(self.myDutyDoc,dutyDocItem);
			endforeach;
		endif;
		break;
	endwhile;
	return true;
epilog
	app.cmsEndLoad(ls);													// 19/04/2013 cnwmh5 #31457
	if allProxyDutyDocItems &lt;&gt; null then
		allProxyDutyDocItems.purge;
		delete allProxyDutyDocItems;
	endif;
	delete agent;
	/*if invoiceStatus &lt;&gt; null then
		invoiceStatus.allInvoiceLines.purge;
	endif;
	delete invoiceStatus;*/

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveNext" id="cfb173f9-c6d4-418c-b4b7-1c97a9c6c256">
        <updating/>
        <source>doSaveNext() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

begin

	if self.doSave then
		self.isSaveNext:=true;
		self.myDutyDocItem:=null;
		//save next have some nonsense about keeping values from the last save and not populating
		self.clearAllFields();
		// and we are ready to go again
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSearchHSCodes" id="15534565-2cbf-4483-9750-3c9b2f900e08">
        <source>doSearchHSCodes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2013	cnwer1	Initial creation HAT 2189

*/

vars
	hsCode, existingHSCode 		: CM_DutyDocHSCode;
	searchTxt ,newString: String;
	iter : Iterator;
	pos, foundPos  : Integer;
begin

	existingHSCode := self.cmbHSCodeCode.listObject.CM_DutyDocHSCode;
	searchTxt:=self.cmbHSCodeCode.text;
	
	// 11 Mar 2013	NDL	Par 31273
	if existingHSCode &lt;&gt; null and searchTxt = ( existingHSCode.code.asStringJMT &amp; " - " &amp; existingHSCode.longDescription ) then
		return;
	endif;
	// 11 Mar 2013	NDL	Par 31273
	if searchTxt.isInteger64 then
		searchTxt := searchTxt.trimBlanks;
	endif;
	
	self.cmbHSCodeCode.clear;
	iter:=	app.myDutyDocRoot.allDutyDocHSCodes.createIterator;
	while iter.next(hsCode) do
		if searchTxt = null then
			self.cmbHSCodeCode.addItemObject(hsCode.code.asStringJMT &amp; " - " &amp; hsCode.longDescription,hsCode );
		else
			if searchTxt.isInteger64 then
				if hsCode.code.String.startsWith(searchTxt) then
					self.cmbHSCodeCode.addItemObject(hsCode.code.asStringJMT &amp; " - " &amp; hsCode.longDescription,hsCode );
				endif;
			else
				pos := 1;
				foundPos:=0;
			//	foundPos := hsCode.longDescription.pos(searchTxt, pos);
				foundPos := hsCode.longDescription.toUpper.pos(searchTxt.toUpper, pos);	// 11 Mar 2013	NDL	Par 31273
				if foundPos &gt; 0 then
					self.cmbHSCodeCode.addItemObject(hsCode.code.asStringJMT &amp; " - " &amp; hsCode.longDescription,hsCode );
				endif;
			endif;
		endif;
	endwhile;
	

	self.cmbHSCodeCode.showDropDown();
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="evaluateValues" id="b9937868-752a-46cc-8842-612c5a42568d">
        <source>evaluateValues() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	invTerms : String;
	exchange : CM_DutyDocExchangeRate;
	exchangeRate : Decimal [16,4];
	insuranceRate : Decimal [16,4];
	localValue : Decimal [16,4];
	foreignValue : Decimal [16,4];
	localFreight : Decimal [16,4];
	localInsurance : Decimal [16,4];
	netValue : Decimal [16,4];
	dutyRate : Decimal [16,4];
	duty : Decimal [16,4];

begin
	
	if self.myDutyDoc = null then
		return;
	endif;
	

	exchange := self.cmbCurrency.listObject.CM_DutyDocExchangeRate;
	if exchange &lt;&gt; null then
		exchangeRate := exchange.rate;
	endif; 
	
	foreignValue := txtForeignValue.text.Decimal;
	if foreignValue &gt; 0 then
		localValue := foreignValue * exchangeRate;
	endif;
	 
	if localValue &gt; 0 then
		self.txtLocalValue.text := localValue.asCurrencyJMT;
	else
		self.txtLocalValue.text := null;
	endif;
	
	localFreight := self.txtLocalFreight.text.Decimal;
	
	invTerms := self.myDutyDoc.invTerms;

	self.txtLocalIns.text := null;
	if invTerms &lt;&gt; CIF then    // 34050
	//epr par 31322 21/3/2013
		localInsurance := (localValue +localFreight) * .01;
		
		if localInsurance &gt; 0 then
			self.txtLocalIns.text := localInsurance.asCurrencyJMT;
		endif;
	endif;
	
	if invTerms = CIF then
		self.txtLocalFreight.enabled := false;	//22 Apr 2013	NDL	Par 31424
		netValue := localValue;
	elseif invTerms = CNF then
		self.txtLocalFreight.enabled := false;	//22 Apr 2013	NDL	Par 31424
		netValue := localValue + localInsurance;
	else	//if invTerms = FOB then
		self.txtLocalFreight.enabled := true;	//22 Apr 2013	NDL	Par 31424
		netValue := localValue + localFreight + localInsurance;
	endif;
	
	if netValue &gt; 0 then
		self.txtNetValue.text := netValue.asCurrencyJMT;
	else
		self.txtNetValue.text := null;
	endif;
	
	if self.myDutyDocHSCode &lt;&gt; null then
		dutyRate := self.myDutyDocHSCode.dutyRate;
	endif;
	
	if netValue &gt; 0 and dutyRate &gt; 0 then
		duty := (( netValue * dutyRate ) / 100).truncatedTo(2);
	endif;
	
	if self.chkDutyExempt.value then
		self.txtDuty.alignment := TextBox.Alignment_Left;
		self.txtDuty.text := "Exempt";
	elseif duty &gt; 0 then
		self.txtDuty.alignment := TextBox.Alignment_Right;
		self.txtDuty.text := duty.asCurrencyJMT;
	else
		self.txtDuty.alignment := TextBox.Alignment_Right;
		self.txtDuty.text := null;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getBOL" id="e15f3686-bbbe-4289-84a1-9a839f7f5333">
        <source>getBOL() : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2013	cnwer1	Initial creation HAT 2189
11 Mar 2013	NDL	Par 31273 - Allow entry of a bol new number

*/

vars
	bolObj : CM_BOL;
	bolNum : String;
begin
	bolObj:=self.cmbBOL.getCurrentItemObject.CM_BOLIn;
	if bolObj &lt;&gt; null then
		bolNum := bolObj.number;
	else
		bolNum := cmbBOL.text;
	endif;
	
	return bolNum;
epilog

end;</source>
