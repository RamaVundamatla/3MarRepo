    <JadeMethod name="doDelete" id="c6dcbe96-a9b6-4c83-aab3-1c681a794cab">
        <updating/>
        <source>doDelete(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	cmObject : CM_Object;
	invalid : Boolean;
	edition : Integer;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815

begin

	cmObject := self.myCurrentObject.CM_CargoGroup;
	
	if cmObject = null then
		return false;
	endif;
	on Exception do app.handleDeletedObject( exception, cmObject, invalid );
	edition := cmObject.edition;
	if invalid then
		return false;
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteCMObject( cmObject, app.myPassport );
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Cargo_group_assignment), app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;

	app.setMyCurrentCargoType(null);			
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="64118749-2a0e-40ff-b497-4f8da46d790b">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	pxy : CM_CargoGroup;
	allPreAssigned : StringArray;
	
	id : String;
	defaultLocation : String;
	remarks : String;
	minWeightKgs : Decimal [14,4];
	maxWeightKgs : Decimal [14,4];
	
	result : Integer;
	weightType : CM_MeasurementType;

begin

	weightType := app.getDefaultMeasurementForType(Type_Weight);

	id := self.tblCGNInput.getValueByName( ETRow_CargoGroupId ).String;
	defaultLocation := self.tblCGNInput.getValueByName( ETRow_DefaultLocation ).String;
	remarks := self.tblCGNInput.getValueByName( ETRow_Remarks).String;
	minWeightKgs := self.getConvertedDisplayValue( ETRow_MinWeight, weightType ).Decimal;
	maxWeightKgs := self.getConvertedDisplayValue( ETRow_MaxWeight, weightType ).Decimal;
	
	create allPreAssigned transient;

	if self.mode = Mode_Add then
		pxy := self.myCargoGroupAssignment.createCargoGroupPxy(	id,	//_cargoGroupId : String;
																self.cmbOperator.listObject.CM_Operator,	//_oper : CM_Operator;
																self.cmbCargoType.listObject.CM_CargoType,	//_cargoType : CM_CargoType;
																minWeightKgs,	//_minWeight : Decimal;
																maxWeightKgs,	//_maxWeight : Decimal;
																remarks,	//_remarks : String;
																defaultLocation,	//_defaultLocation : String;
																allPreAssigned	//_allPreAssigned : StringArray
																);
	elseif self.mode = Mode_Update then
		pxy := self.myProxyObject.CM_CargoGroup;
		pxy.zSetPxyId( id );
	//	if not pxy.allPreAssignedCargoIds.isEmpty then
	//		pxy.allPreAssignedCargoIds.copy( allPreAssigned );
	//	endif;
		pxy.setDefaultLocation( defaultLocation );
		pxy.setPxyMinMaxWeights( minWeightKgs, maxWeightKgs );
		pxy.setMyOperator( self.cmbOperator.listObject.CM_Operator );
		pxy.setRemarks( remarks, false );
	else
		return false;
	endif;

	
	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateCargoGroup( pxy, self.myCurrentObject, app.myPassport);
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateTrackedItem(pxy, null, TI_UPDMODE_NORMAL, null, app.myPassport);
		endif;
	
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog(app.getErrorString(Cargo_group), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
					
			return false;
			
		else
			return true;
			
		endif;
	endwhile;
	
epilog

	delete allPreAssigned;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
