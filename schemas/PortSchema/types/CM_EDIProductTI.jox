    <JadeMethod name="assignValueSpecial" id="9c61c4b9-2a34-4117-8826-02d944bc5d95">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/09/2014	cnwdap1		Initial creation PAR #34874 Correct Volume setting
// 17/10/2024	navcs2		MTN-33066 EUP - NTO-980 - "89636: Total Weight Should Not be Zero" Error when Uploading Transport Manifest with weights in kilograms only
// 07/11/2024	navdap1		MTN-33400 MTN - User Defined EDI is not longer loading Volume details
// 13/11/2024 	navsaa30 	MTN-19242 TPT| User Defined Cargo Sub Type Uploads
vars

	intValue : Integer;
	value,									// 17 Oct 2024		navcs2	MTN-33066
	str,									// 17 Oct 2024		navcs2	MTN-33066
	type				: String;			// 17 Oct 2024		navcs2	MTN-33066
begin
	
	if _propName = ETRow_HandlingType then	//28 July 2015	NDL	Par 36564 			//13/11/2024 navsaa30 #19242
		if not _processedValue.isInteger then
			intValue := app.myRoot.allHandlingTypes.getIdFor( _processedValue.toUpper );
			self.handlingType := intValue;
			return true;
		endif;
	endif;
	
	if _propName.isMeasurementType then	
		_propName.getRowNameMeasureType(str, type);	
		value 	:= app.convertMeasurementForStorage(type, _processedValue.Decimal).asStringJMT;
		if str = ETRow_Height then
			self.height := value.asDecimalJMT;
			return true;
		elseif str = ETRow_Length then							//13/11/2024 navsaa30 #19242
			self.length := value.asDecimalJMT;
			return true;
		elseif str = ETRow_Width then
			self.width := value.asDecimalJMT;
			return true;
		elseif str = ETRow_Volume then
			self.volume := value.asDecimalJMT;
			return true;
		else																			// MTN-33400
			return self.assignValueSpecial(str, _processedValue, _xlationOperator);		// MTN-33400
		endif;
	endif;
	
	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="code" id="8c248b6a-2dbc-4bb6-860f-19b925129be4">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>code(set : Boolean; _value : String io) mapping, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Jun 2008	cnwkpd1	PAR #17014 - keep code and id in sync for EDI form table colours to stay correct
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
*/

vars

begin
	if set then
		self.setId(_value);
	endif;
	

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="eddc3183-2945-49e7-8957-d2f84dc35dfb">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     10 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 23/04/2014	cnwdap1		Initial creation PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
//09 Apr 2024	jlirs1	TFS 63491 - TPT user defined EDI Cargo subtype is missing height
//
vars
	rowName, type	: String;												// PAR #33005
begin
	if _attrName = ETRow_WeightTons then
		return (self.weight * .001).asStringWeightJMT;
//		return (self.weight * .001).String;		// cnwrl1 19/11/2009 PAR 21009 - what it was
	//elseif _attrName = ETRow_Weight then //cnwrd1 par  19701 18.5.09					//-cnwml2 MSL CCMS 1017
	elseif _attrName = ETRow_TotalWeight then											//+cnwml2 MSL CCMS 1017
		return self.weight.asStringWeightJMT();
	elseif _attrName = ETRow_Width then
		return self.width.asStringMeasurementJMT();		
	elseif _attrName = ETRow_Length then
		return self.length.asStringMeasurementJMT();
	elseif _attrName = ETRow_Height then				//09 Apr 2024	jlirs1	TFS 63491 - TPT user defined EDI Cargo subtype is missing height
		return self.height.asStringMeasurementJMT();
	
	elseif _attrName = ETRow_AutoWeightCalculate then	//26 Jan 2018	NDL	TFS 36697
		return self.autoWeightCalculate.asStringJMT;
		
	elseif _attrName.isMeasurementType then									// PAR #33005
		_attrName.getRowNameMeasureType(rowName, type);						// PAR #33005
		return self.getMeasurementStringForAttrib(rowName, type, _short);	// PAR #33005
		
	endif;
	
	return inheritMethod(_attrName, _short);
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
