    <JadeMethod name="populateCmbDueRule" id="ba641ee5-27cf-4c84-938e-fb4d167eaf17">
        <source>populateCmbDueRule();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/01/2023	navkc1 ChangeRequest 59145 Task 61328: UI - Terms of Trade Maintenance

*/

vars
	combo	: CMUI_ComboBox;
begin
	
	combo := self.cmbDueRule;
	
	combo.clear();
	combo.addItemWithData(" ", 0);
	combo.addItemWithData(CM_InvoiceTermsOfTrade.EndOfPeriodPlusDueDaysStr, CM_InvoiceTermsOfTrade.EndOfPeriodPlusDueDays);
	combo.addItemWithData(CM_InvoiceTermsOfTrade.PostedDatePlusDueDaysStr, CM_InvoiceTermsOfTrade.PostedDatePlusDueDays);
	combo.addItemWithData(CM_InvoiceTermsOfTrade.EndDatePlusDueDaysStr, CM_InvoiceTermsOfTrade.EndDatePlusDueDays);
	combo.addItemWithData(CM_InvoiceTermsOfTrade.InvoiceDatePlusDueDaysStr, CM_InvoiceTermsOfTrade.InvoiceDatePlusDueDays);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateEntDetailTable" id="aa7c04d2-f249-4721-9242-fe44341a5344">
        <source>populateEntDetailTable();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	entRow			: EntTableRow;
	invoiceType : CM_InvoiceTermsOfTrade;
	displayValue	: String;	
	prodAttr		: String;
	handlingType	: CM_HandlingType;
	sysType			: Boolean;

	entDef		:EntTableDef;
begin
	entDef := app.myController.getEntTableDef(ETDef_InvMaintTermsTrade);

	invoiceType := self.myCurrentObject.CM_InvoiceTermsOfTrade;
	
	self.populateCmbDueRule(); //15/01/2023	navkc1 ChangeRequest 59145 Task 61328
	
	if self.mode = Mode_Add then
		self.tblEntDetail.clearValues();
		return;
	endif;	
	
	if invoiceType = null then
		return;
	endif;
	
	foreach entRow in entDef.allEntTableRows do
		if invoiceType &lt;&gt; null then
			displayValue := invoiceType.getDisplayStringForAttribute(entRow.name, false).String;
		else
			displayValue := null;
		endif;
		
		tblEntDetail.setValueByName(entRow.name, displayValue);		
		
		//15/01/2023	navkc1 ChangeRequest 59145 Task 61328
		if entRow.name = ETRow_DueRule then
			//tblEntDetail.setValueByName(entRow.name, null);
			self.cmbDueRule.listIndex := self.cmbDueRule.findStringExact(0, displayValue);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
