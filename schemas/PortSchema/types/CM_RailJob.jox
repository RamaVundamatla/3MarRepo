    <JadeMethod name="getWagonFromTrain" id="8f05f7b9-e0af-4e1f-8017-828c31d90835">
        <source>getWagonFromTrain() : CM_Wagon;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023	navlw1	Bug 60382: MTN - The Work Order Operations form's column organizer is missing some fields.
29 Apr 2024 navma1	Bug 63868: MTN - 1081 from performance test QA-PerformanceTest-Dumps_20240424
*/

vars
	trainCode 	: String;
	train 		: CM_Train;
	wagon 		: CM_Wagon;
begin
	
	trainCode := self.getTrainNumber;
	
	if trainCode &lt;&gt; null then
		train := self.myTerminal.allTrainsOnTerminal.getAtKeyGeq(trainCode, null);
		if train &lt;&gt; null then
			
			wagon := train.allWagonsByIdInward.first();			//29.04.2024 navma1 #63868
			
			if wagon &lt;&gt; null then
				return wagon;
			endif;
			
			wagon := train.allWagonsByIdOutward.first();	     //29.04.2024 navma1 #63868	
			
			if wagon &lt;&gt; null then
				return wagon;
			endif;
			
		endif;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="getWagonFromWle" id="da38a3a1-1e32-4c82-8415-19393834c1b8">
        <source>getWagonFromWle():CM_Wagon;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues
17 Sep 2024 navma1	Bug 64789: EUP | FR 53891 - Mobile App Delivery Dispatch Rail - Quantity Display
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle		: CM_WorkListEntry;
	wagon	: CM_Wagon;
begin
	foreach wle in self.workListEntries discreteLock do	//06.03.2025 navma1 #MTN-34179
		if wle.status &lt;&gt; WLE_COMPLETED and  wle.isYardWle and wle.CM_YardWLE.allLocationControllers.isNotEmpty() then
			return wle.CM_YardWLE.allLocationControllers.first.myWagon;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="getWagonLCForTI" id="f9fb9596-2680-4d0f-99fd-74abf7efb303">
        <source>getWagonLCForTI(_ti : CM_TrackedItem):CM_LocationsController;
//--------------------------------------------------
// Created:	05 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	wagonNum : String;
	theWagon : CM_Wagon;
	theTrain : CM_Train;
begin
	if _ti = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Tracked Item reference');
		return null;
	endif;
	wagonNum := _ti.wagon;
	theWagon := self.allWagons[wagonNum];
	if theWagon = null then
		// PAR 19710 theWagon := self.getMyTerminal.allWagons[wagonNum, null];
		theTrain := _ti.myTrainAssigned;
		if theTrain &lt;&gt; null then
			theWagon := theTrain.allWagonsByIdInward[wagonNum];
		endif;
		if theWagon = null then
			theWagon := self.getMyTerminal.getLatestWagonByCode(wagonNum);
		endif;
	endif;
	if theWagon &lt;&gt; null then
		//return theWagon.getNextFreeWagonController(_ti, REAL_MODE, null, true);
		return theWagon.getNextFreeWagonController(_ti, REAL_MODE, null, null, true);//10 May 2010	NDL Par 24064
	endif;
	
	return null;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getWagonStrFromWle" id="381e0ff0-177a-4a3c-80d3-cc27f9f85732">
        <source>getWagonStrFromWle(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Nov 2023	navhl20	Bug 61048: EUP - Spinning wheel appears when performing the Rail Load using WO Operations app.
08 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
30 Aug 2024 navma1	Bug 64789: EUP | FR 53891 - Mobile App Delivery Dispatch Rail - Quantity Display
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle		: CM_WorkListEntry;
	str		: String;
	objSet	: CM_ObjectSet;
	lc 		: CM_WagonController;
begin
	create objSet transient;
	foreach wle in self.workListEntries discreteLock do
		
		if not wle.isYardWle then
			continue;
		endif;
		
		lc := wle.CM_YardWLE.allLocationControllers.first;
		
		if lc &lt;&gt; null and lc.myWagon &lt;&gt; null then
			objSet.tryAdd(lc.myWagon);
		endif;
		
	endforeach;
	
	if objSet.isNotEmpty() then
		return objSet.listString(Comma,CM_Wagon::id.name);
	endif;
	return str;
epilog
	delete objSet;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWagonTrainsFromWles" id="7e5c86f1-1093-414d-b65a-bb19442172b1">
        <source>getWagonTrainsFromWles(_wagonSet : CM_ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Aug 2024 navma1	Bug 64789: EUP | FR 53891 - Mobile App Delivery Dispatch Rail - Quantity Display

*/

vars
	wle		: CM_WorkListEntry;
	lc 		: CM_WagonController;
begin
	foreach wle in self.workListEntries discreteLock do
		
		if not wle.isYardWle then
			continue;
		endif;
		
		lc := wle.CM_YardWLE.allLocationControllers.first;
		
		if lc &lt;&gt; null and lc.myWagon &lt;&gt; null then
			_wagonSet.tryAdd(lc.myWagon);
		endif;
		
	endforeach;
epilog

end;</source>
        <Parameter name="_wagonSet" type="CM_ObjectSet" usage="input"/>
    </JadeMethod>
