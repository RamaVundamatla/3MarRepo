    <JadeMethod name="getBerthDescriptionForDateTime" id="853f6f00-1fcf-4f23-9860-e887f481b314">
        <source>getBerthDescriptionForDateTime(_dateTime : TimeStamp) : String;
/* ---------------------------------------------------------------------------
Usage:		THIS IS USED IN CUSTOMER REPORTS.  DO NOT RENAME OR REMOVE

Created:     13 July 2009 by cnwrs2

Purpose:     CCMS-JMH-1022.  See HMS_VoyageData::getBerthForDateTime for more details
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
