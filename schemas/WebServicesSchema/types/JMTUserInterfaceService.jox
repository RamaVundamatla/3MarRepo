    <JadeWebServicesMethod name="getVehiclesForCarrier" id="faa330e1-c233-4f13-9a8a-e1abb24bdff6">
        <source>getVehiclesForCarrier(carrierCode : String) : WS_VehiclesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2013	cnwmc5	Initial creation
10 Feb 2015 cnwmc5	Now correctly accepts the carrier code (and also the OID to support the RIA) - PAR 35658
*/

vars
	response 		: WS_VehiclesResponse;
	realCarrier		: CM_Carrier;
	wsVehicle		: WS_Vehicle;
	vehicle			: CM_Vehicle;
	completedOK 	: Boolean;
	obj				: Object;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	if carrierCode &lt;&gt; null then
		realCarrier := app.myRoot.allCarriers[carrierCode];
	endif;
	//epr TFS 5535 4/8/17 
	if realCarrier = null then
		realCarrier := app.myPassport.getObjectOfTypeFromOid(carrierCode,CM_Carrier).CM_Carrier;
	endif;
	
	if realCarrier = null then
		app.raiseCMException2(ERR_Carrier_Unknown, carrierCode, null, null, null);
		completedOK := true;
		return response;
	endif;

	foreach vehicle in realCarrier.vehicles discreteLock do
		if vehicle.myTerminal &lt;&gt; app.myPassport.myTerminal then
			continue;
		endif;
		create wsVehicle transient;
		wsVehicle.setProxyFromObject( vehicle );
		response.allVehicles.add( wsVehicle );
	endforeach;
	
	completedOK := true;
	return response;
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
		delete wsVehicle;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="carrierCode" type="String"/>
        <ReturnType type="WS_VehiclesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVehiclesForDriver" id="26a040ec-ed1a-406d-9087-030af78a7c47">
        <source>getVehiclesForDriver(driverCode : String) : WS_VehiclesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
9  Feb 2015	cnwmc5	Initial creation	PAR 35658

*/

vars
	response 		: WS_VehiclesResponse;
	realDriver		: CM_DriverDetails;
	wsVehicle		: WS_Vehicle;
	vehicle			: CM_Vehicle;
	completedOK 	: Boolean;
	obj				: Object;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	if driverCode &lt;&gt; null then
		realDriver := app.getMyTerminalDO_NOT_USE().allDriversByCode[driverCode];
	endif;
	
	if realDriver = null then
		//epr TFS 5535 4/8/17 
		realDriver := app.myPassport.getObjectOfTypeFromOid(driverCode,CM_DriverDetails).CM_DriverDetails;
	endif;
	
	if realDriver = null then
		app.raiseCMException2(ERR_Driver_Unknown, driverCode, null, null, null);
		completedOK := true;
		return response;
	endif;

	foreach vehicle in realDriver.allVehicleMachines discreteLock do
		if vehicle.myTerminal &lt;&gt; app.myPassport.myTerminal then
			continue;
		endif;
		create wsVehicle transient;
		wsVehicle.setProxyFromObject( vehicle );
		response.allVehicles.add( wsVehicle );
	endforeach;
	
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
		delete wsVehicle;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="driverCode" type="String"/>
        <ReturnType type="WS_VehiclesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getVehiclesForSwap" id="f5e8dedf-0691-454c-ae8e-147be90d561b">
        <source>getVehiclesForSwap(): WS_VehiclesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2016	cnwma1	Initial creation

*/

vars
	response 		: WS_VehiclesResponse;
	wsVehicle		: WS_Vehicle;
	vehicle			: CM_Vehicle;
	completedOK 	: Boolean;
	obj				: Object;
	truckSwapController: CMIF_MobileTruckLoaderUnloader;
	terminal			: CM_Terminal;
	vehicleSet       : CM_VehicleSet;
	
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	terminal:=app.myPassport.myTerminal;
	
	create truckSwapController transient;
	
	truckSwapController.setMyTerminal(terminal);
	
	create vehicleSet transient;
	truckSwapController.getAllCurrentTrucks(vehicleSet);
	foreach vehicle in vehicleSet discreteLock do
		if vehicle.myTerminal &lt;&gt; app.myPassport.myTerminal then
			continue;
		endif;
		create wsVehicle transient;
		wsVehicle.setProxyFromObject( vehicle );
		response.allVehicles.add( wsVehicle );
	endforeach;
	
	completedOK := true;
	return response;
	
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
		delete wsVehicle;
	endif;
	delete truckSwapController;
	delete vehicleSet;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_VehiclesResponse"/>
    </JadeWebServicesMethod>
