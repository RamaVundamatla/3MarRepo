24 Mar 2023		 	navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
*/

vars

begin
	self.allDebtors.clear();																		//20.3.2023 navhl20	#57233
	_allSelectedEntities.CM_DebtorSet.copyNoDuplicates(self.allDebtors, false);
epilog

end;</source>
        <Parameter name="_allSelectedEntities" type="Any"/>
