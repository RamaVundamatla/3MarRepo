    <JadeMethod name="getObjects" id="7f776811-efa5-4e44-96da-258f78ef1524">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2018	jlgmp6	Initial creation	TFS37555

*/

vars
	tt: CM_VoyageJobTransferType;
begin
	foreach tt in app.myRoot.allVoyageJobTransferTypes do
		objects[tt.getYAIdentifier] := tt;
	endforeach;
epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
