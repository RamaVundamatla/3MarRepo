    </JadeMethod>
    <JadeMethod name="doLoadAllVoyageEvent" id="3dfdf4b8-9c06-4643-90b1-5ede482d0df1">
        <source>doLoadAllVoyageEvent( _list : CMUI_ListTable; _defaultValueStr : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2019	jlgndl1	Initial creation	TFS 46131

*/

vars

	iter : Iterator;
	event : CM_EventType;
	index : Integer;
	list : CMUI_ListTable;
	strArray : CnStringArray;
	str : String;
	strTrimmed : String;
	col : Integer;
	idx : Integer;
	max : Integer;
	obj : Object;
	chkBoxColumn : Integer;

begin

	list := _list;
	list.clear();
	list.allSelectedObjects.clear();
	list.rows := 0;
	
	iter := app.myRoot.allEventTypesByCategory.createIterator;
	event := app.myRoot.allEventTypesByCategory.getAtKeyGeq(CM_EventType.VOYAGE_EVENT,0);
	if event &lt;&gt; null then
		iter.startAtObject( event );
	endif;
	while iter.next( event ) do
		if not event.isVoyageEvent then
			break;
		endif;
		index := list.addItemObject( event.name, event );
	endwhile;
	
	chkBoxColumn := list.getChkBoxColumn;
	if list.chkBoxFirst then
		col := chkBoxColumn + 1;
	else
		col := chkBoxColumn - 1;
	endif;
	max := list.rows;
	
	if _defaultValueStr &lt;&gt; null and max &gt;= 1 then
		strArray := _defaultValueStr.cnGetTokens(",");
		foreach str in strArray do
			strTrimmed := str.trimBlanks;
			if strTrimmed &lt;&gt; null then
				foreach idx in 1 to max do
					if list.accessCell(idx, col).text = strTrimmed then
						obj := list.accessRow(idx).itemObject;
						list.accessCell(idx, chkBoxColumn).text := TableCheckBox_Selected;	
						if obj &lt;&gt; null then
							list.allSelectedObjects.addExclusive( obj );
						endif;
					endif;
				endforeach;	
			endif;
		endforeach;
	endif;

epilog

	delete strArray;

end;</source>
        <Parameter name="_list" type="CMUI_ListTable"/>
        <Parameter name="_defaultValueStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadAllocatedRows" id="ab53884a-5542-4164-aae7-66c49b35b22a">
        <source>doLoadAllocatedRows(_cmb : CMUI_ComboBox input; _globalVoyage : CM_VoyageGlobal; _value : String);
// ---------------------------------------------------------------------------
// Created:     16 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	globalVoyage			: CM_VoyageGlobal;
	voyage					: CM_Voyage;
	stkOrderSum				: CM_StockOrderSummary;
	stkOrderAllocation		: CM_StockOrderAllocation;
	lcSet					: CM_LCSet;
	foundRow				: Boolean;
begin	
	if _cmb.listCount &lt; 2 then
		if _globalVoyage = null then 
			return;
		endif;
	
		_cmb.clear();
		
		create lcSet transient;
		foreach voyage in _globalVoyage.allVoyages discreteLock where self.allTerminals.includes(voyage.myTerminal) do 
			foreach stkOrderSum in voyage.allStockOrderSummaries discreteLock do
				foreach stkOrderAllocation in stkOrderSum.allStockAllocations discreteLock do
					if (not lcSet.includes(stkOrderAllocation.myLocationsController)) and
					   CM_LogController.hasInstance(stkOrderAllocation.myLocationsController) then
						lcSet.add(stkOrderAllocation.myLocationsController);
						if stkOrderAllocation.myLocationsController.CM_LogController.id = _value then
							foundRow := true;
						endif;
					endif;
				endforeach;
			endforeach;
		endforeach;
		
		_cmb.listCollectionWithAny(lcSet, 'id');
	else
		foundRow := true;//assume the entry will be in the combobox if it's already loaded once
	endif;
		
	if foundRow then
		_cmb.text := _value;
	else
		_cmb.text := Any_String;		
	endif;		

	self.setValueByName(ETRow_RowId, _cmb.text);

epilog
	delete lcSet;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_globalVoyage" type="CM_VoyageGlobal"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadAvaGrade" id="f20d5ee4-8875-4372-ab75-3a99af661afc">
        <source>doLoadAvaGrade(_lstTable	: CMUI_ListTable input; _defaultTemplate : CMQF_FilterReports) protected;
//----------------------------------------------------------------
//	Created:	04 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//
// 17 July 2018		jlgmd1	TFS 39407 SNO - Fixed Bulk Release criteria not saving on the template
//

vars
	defaultGrades		: IntegerArray;
	grade				: CM_MTGrade;
	idx					: Integer;
	operator			: CM_Operator;
	theCode,
	theDescription		: String;
	code				: CM_MTGradeCode;
	select				: Integer;
	operatorGroup		: CM_OperatorGroup;
	canDisplay			: Boolean;
	
begin
	if CMQF_Container.hasInstance(_defaultTemplate) then
		defaultGrades := _defaultTemplate.CMQF_Container.allQryAvaGrades;
	elseif CMQF_BulkRelease.hasInstance(_defaultTemplate) then
		defaultGrades := _defaultTemplate.CMQF_BulkRelease.allQryAvaGrades;
	endif;

	if _lstTable = null then
		return;
	endif;
	
	_lstTable.rows := _lstTable.fixedRows;
	_lstTable.clearSelected();
	
	operator := self.getSelectedOperator();
	operatorGroup := self.getSelectedOperatorGroup();

	foreach grade in app.myRoot.allAvailabilityGrades do
		
		grade.getTranslationForOperator(null, operator, operatorGroup, code, canDisplay);
		if code &lt;&gt; null then
			theCode := code.code;
			theDescription := code.description;
		elseif canDisplay then
			theCode := grade.code.String;
			theDescription := grade.description;
		else
			continue;
		endif;
		
		select := 0;
		if defaultGrades &lt;&gt; null and defaultGrades.includes(grade.code) then
			select := 1;
			_lstTable.allSelectedObjects.add(grade);	
		endif;
		
		idx := _lstTable.addItem(select.String &amp; Tab &amp; theCode &amp; " - " &amp; theDescription); 
		_lstTable.accessRow(idx).itemObject := grade;
	endforeach;		

end;</source>
        <access>protected</access>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_defaultTemplate" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadBOLTypes" id="38d7ea9a-061d-49ef-a9f3-3ddb380a2036">
        <source>doLoadBOLTypes(_cmb : CMUI_ComboBox input; _description : String) protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bolType		: CM_CargoBOLType;
	terminal			: CM_Terminal;
	bolTypeDict		: CM_BOLTypesByIdDict;
begin

	//only load CM_BOLType objects
	if _cmb = null then
		return;
	endif;
	if _cmb.listCount &lt; 2 then
		_cmb.clear();
		_cmb.addItem(Any_String);
		
		if self.allTerminals.isEmpty then
			bolTypeDict := app.myRoot.allBOLTypes;
			foreach bolType in bolTypeDict where bolType.id &lt; BOLType_Max do
				_cmb.itemObject[_cmb.addItem(bolType.description)] := bolType;
			endforeach;
		else
			foreach terminal in self.allTerminals do
				foreach bolType in terminal.allCargoBOLTypes 
				   where bolType.id &gt; BOLType_Min and bolType.id &lt; BOLType_Max do
					_cmb.itemObject[_cmb.addItem(bolType.description)] := bolType;
				endforeach;
			endforeach;
		endif;
	endif;
		
	if _description &lt;&gt; null then
		_cmb.text := _description;
	else
		_cmb.text := Any_String;
	endif;
	
	self.setValueByName(ETRow_BolType, _cmb.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadBookingStatus" id="0c4b4dbe-1199-41c2-bea1-4a6bc865eef1">
        <source>doLoadBookingStatus(_cmb : CMUI_ComboBox input; _status : String) protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 16 August 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
// 1608/2010 	cnwsh3		CCMS1063 PAR25404 Add Booking filters for report framework.
//----------------------------------------------------------------------
vars
	combo : CMUI_ComboBox;
begin
	if _cmb = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'An Invoice combo box was expected but cannot be located.');
	endif;
	
	combo := _cmb;
	combo.clear();
	combo.sorted := false;
	
	combo.addItem(Any_String);
	combo.itemData[combo.newIndex] := -1;

	combo.listIndex := combo.newIndex;
	combo.addItem(app.getErrorString(Pending));
	combo.itemData[combo.newIndex] := BOOKING_REF_PENDING;
	combo.addItem(app.getErrorString(Active));
	combo.itemData[combo.newIndex] := BOOKING_REF_ACTIVE;
	combo.addItem(app.getErrorString(Closed));
	combo.itemData[combo.newIndex] := BOOKING_REF_CLOSED;
	combo.addItem(app.getErrorString(Archived));
	combo.itemData[combo.newIndex] := BOOKING_REF_ARCHIVED;
	
	if _status &lt;&gt; null then
		combo.text := _status;
	else
		combo.listIndex := BOOKING_REF_ACTIVE;
		combo.text := app.getErrorString(Active);
	endif;
	
	self.setValueByName(ETRow_BookingStatus, combo.text);
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_status" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadBooleanCombo" id="db495bb8-9668-41da-8770-0ce0b0e0b253">
        <source>doLoadBooleanCombo(_cmb : CMUI_ComboBox input; _defaultValue : String) protected;
// ---------------------------------------------------------------------------
// Created:     26 March 2004	cnwth2
//
// Purpose:     for those times when matching true to true or false to false arn't
//				going to cut the mustard
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	_cmb.clear();
	_cmb.sorted := false;
	
	_cmb.itemData[_cmb.addItem(CMQF_FilterReports.BOOLEAN_EITHER_STR)] := CMQF_FilterReports.BOOLEAN_EITHER;
	_cmb.itemData[_cmb.addItem(CMQF_FilterReports.BOOLEAN_TRUE_STR)] := CMQF_FilterReports.BOOLEAN_TRUE;
	_cmb.itemData[_cmb.addItem(CMQF_FilterReports.BOOLEAN_FALSE_STR)] := CMQF_FilterReports.BOOLEAN_FALSE;

	if _defaultValue = null then
		_cmb.text := CMQF_FilterReports.BOOLEAN_EITHER_STR;
	else
		_cmb.text := _defaultValue;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_defaultValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadCalculationType" id="029e97b9-eb6e-4773-a821-3cf72062b062">
        <source>doLoadCalculationType(_cmb : CMUI_ComboBox input; _description : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting

*/

vars
	tmpDesc 	: String;
	aCT			: CM_CalculationType;
	root		: CM_Root;
	
begin
	
	_cmb.clear();
	_cmb.sorted := true;
	
	_cmb.addItem(Any_String);
	
	root := app.myRoot;
	
	foreach aCT in root.allCalculationTypesByCode discreteLock  where not aCT.isNotAvailableForEntry do
		if (not aCT.isCargoCalcType ) then
			continue;
		endif;
		
		tmpDesc := "Cargo - ";

		tmpDesc := tmpDesc &amp; aCT.description;               
		
		_cmb.addItemObject(tmpDesc,aCT);
	endforeach;
epilog

end;
</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadCargoTypes" id="5d444daa-98cf-4098-8d77-67723aeb85f5">
        <source>doLoadCargoTypes(_cmb : CMUI_ComboBox input; _description : String) protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2003	cnwth2
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 07/05/2020	jlgdap1		TFS 49252 Cargo Types not showing in System Admin
vars
	cargoBOLType		: CM_CargoBOLType;
	terminal			: CM_Terminal;
	cargoTypeDict		: CM_CargoTypesByIdDict;
begin
	//only load CM_CargoType objects
	if _cmb = null then
		return;
	endif;
	if _cmb.listCount &lt; 2 then
		_cmb.clear();
		_cmb.addItem(Any_String);
		
		if self.allTerminals.isEmpty then
			cargoTypeDict := app.myRoot.allCargoTypesById;
			//foreach cargoBOLType in cargoTypeDict where cargoBOLType.id &lt; TI_CargoBOLType_JMTMax do													// TFS 49252
			foreach cargoBOLType in cargoTypeDict where cargoBOLType.id &lt; TI_CargoBOLType_JMTMax or app.myRoot.isClientCentrePort do					// TFS 49252
				_cmb.itemObject[_cmb.addItem(cargoBOLType.description)] := cargoBOLType;
			endforeach;
		else
			foreach terminal in self.allTerminals do
				//foreach cargoBOLType in terminal.allCargoBOLTypes where cargoBOLType.id &lt; TI_CargoBOLType_JMTMax do									// TFS 49252
				foreach cargoBOLType in terminal.allCargoBOLTypes where cargoBOLType.id &lt; TI_CargoBOLType_JMTMax or app.myRoot.isClientCentrePort do	// TFS 49252
					//if CM_CargoType.hasInstance(cargoBOLType) then
						_cmb.itemObject[_cmb.addItem(cargoBOLType.description)] := cargoBOLType;
					//endif;
				endforeach;
			endforeach;
		endif;
	endif;
		
	if _description &lt;&gt; null then
		_cmb.text := _description;
	else
		_cmb.text := Any_String;
	endif;
	
	self.setValueByName(ETRow_CargoType, _cmb.text);
end;</source>
