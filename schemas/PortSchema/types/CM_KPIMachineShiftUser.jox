    <JadeMethod name="setShift" id="2850844a-6782-4d98-82fb-cdaaf06dda91">
        <updating/>
        <source>setShift(_shift :CM_Shift)updating;
// ---------------------------------------------------------------------------
// Created:     10 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.myShift 			:= _shift;
	self.shiftCode			:= _shift.code;
	self.shiftDescription	:= _shift.description;
	self.shiftStartTS		:= _shift.startDateTime;
	self.shiftEndTS			:= _shift.endDateTime;
epilog

end;</source>
        <Parameter name="_shift" type="CM_Shift"/>
    </JadeMethod>
    <JadeMethod name="updateForLogoff" id="828920b6-cbf9-47d7-90f2-7e2762af70a1">
        <updating/>
        <source>updateForLogoff(_history: CM_MachineLogOnOffHistory) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Update KPI for logon
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	executeWhen JMTDevelopmentEnvironment;
	if _history.dateTime &lt; self.shiftStartTS or _history.dateTime &gt; self.shiftEndTS then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Wrong date for logoff KPI');
	endif;
	endExecuteWhen;	
	
	inheritMethod (_history);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_history" type="CM_MachineLogOnOffHistory"/>
    </JadeMethod>
    <JadeMethod name="updateForLogon" id="685b8b04-f338-4ce8-b52c-a0972094b39c">
        <updating/>
        <source>updateForLogon(_history: CM_MachineLogOnOffHistory) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Update KPI for logon
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	executeWhen JMTDevelopmentEnvironment;
	if _history.dateTime &lt; self.shiftStartTS or _history.dateTime &gt; self.shiftEndTS then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Wrong date for logon KPI');
	endif;
	endExecuteWhen;
	
	inheritMethod (_history);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_history" type="CM_MachineLogOnOffHistory"/>
    </JadeMethod>
    <JadeMethod name="updateForPickup" id="0d820ecd-61d2-4c7d-bc0a-f3af66b792e7">
        <updating/>
        <source>updateForPickup(_history: CM_MachineMoveHistory) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Keep track of any incomplete moves for the period
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ts	:TimeStamp;
begin
	executeWhen JMTDevelopmentEnvironment;
	if _history.dateTime &lt; self.shiftStartTS or
		_history.dateTime &gt; self.shiftEndTS then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Wrong date for KPI');
	endif;
	endExecuteWhen;
	
	ts := _history.getEndOfMoveTS;
	
	if ts = null or ts &gt; self.shiftEndTS then
		// incomplete move
		self.numIncompleteMoves := self.numIncompleteMoves + 1;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_history" type="CM_MachineMoveHistory"/>
    </JadeMethod>
</Class>
