	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE); 
	
	if _tran.dateTime.isValid then
		now := _tran.dateTime;	
	else
		now := app.serverTimestampAtTrxStart;	
	endif;

	invLine.setForCreate(seqNum, false, null, self, invoice, _debtor, bank, 0, now); 
