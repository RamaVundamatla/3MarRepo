    <JadeMethod name="doChangeIMEX" id="3d1d6ede-4c17-4c46-bb4f-81890238adf6">
        <updating/>
        <source>doChangeIMEX(_isExport : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.isExport := _isExport;
	if _isExport then
		self.initTblCCAllocation(ETDef_ColourCodingPallette);
	else
		self.initTblCCAllocation(ETDef_DischargeCCPalette);
	endif;
	
	//self.displayCCTable(); //-cnwas3 par 26840 redundant second call of this method...it's also being called in initTblCCAllocation()
	self.btnSaveBase.enabled := self.isExport;
	self.btnSaveCC.visible := self.isExport;
	self.btnSaveProj.enabled := self.isExport;
	self.btnSummBooking.enabled := self.isExport;
	self.btnSummCargo.enabled := self.isExport;
	self.doSetCaption();
epilog

end;</source>
        <Parameter name="_isExport" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuFormContextMenu" id="daaa9bf3-9b4b-4a4c-a2a8-1cb9362bd02d">
        <updating/>
        <source>doMnuFormContextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 January 2010	cnwas3	Initial creation

*/

vars
	x1, y1				: Real;
begin

	// clone menus in sub-classes
	if app.isAllowedToInspect() then
	   	
		self.mnuInspectObject.visible	:=	true;
		self.mnuInspectObject.userObject := self.myCurrentVoyageAllocation;
	else
	   	
		self.mnuInspectObject.visible	:=	false;
		self.mnuInspectObject.userObject := null;
	endif;

	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	self.popupMenu(mnuViewContext, x1.Integer, y1.Integer);
	return false;

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="dea3ac73-ff83-4edd-adc7-0d55bf95c7d8">
        <source>doNotableAdd(_anObject : Object);
/*

Date		    Who			Reason
07 February 2011	cnwas3	  par26840a

*/

vars
	invalid : Boolean;
	ed : Integer;
begin
	if _anObject = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception,_anObject,invalid);
	ed := _anObject.edition;
	if invalid then
		return;
	endif;
	
	if not self.allNotableObjects.includes(_anObject) then
		if CM_TrackedItem.hasInstance(_anObject) then
			self.allNotableObjects.add(_anObject);
			beginNotification(_anObject, Object_Update_Event, Response_Continuous, null);
			beginNotification(_anObject, Object_Delete_Event, Response_Continuous, null);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="05c447d8-3e88-4bb7-b5a3-25d9fee4ce3d">
        <source>doNotableClear();
/*

Date		    Who			Reason
07 February 2011	cnwas3	  par26840a

*/

vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		if anObject.isKindOf(CM_TrackedItem) then
			endNotification(anObject, Object_Update_Event);		
			endNotification(anObject, Object_Delete_Event);
		endif;
	endforeach;	
	
	self.allNotableObjects.clear;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableRemove" id="a3e8cdc2-704e-48f8-9ea0-608693a98c42">
        <source>doNotableRemove(_anObject : Object);
/*

Date		    Who			Reason
18 February 2011	cnwas3	  Initial creation

*/

vars

begin
	if _anObject = null then
		return;
	endif;
	if not global.isValidObject(_anObject) then
		return;
	endif;
	if  self.allNotableObjects.includes(_anObject) then
		if _anObject.isKindOf(CM_TrackedItem) then
			self.allNotableObjects.remove(_anObject);
			endNotification(_anObject, Object_Update_Event);	
			endNotification(_anObject, Object_Delete_Event);
		endif;
	endif;
end;</source>
        <Parameter name="_anObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doNoteDeleteAllocation" id="64974eb1-bd2d-40da-b206-bd0b631fc34a">
        <updating/>
        <source>doNoteDeleteAllocation(_voyAlloc : CM_VoyageAllocation) updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2010 by cnwab1
//
/*

Date		Who		Reason
01 Mar 2011	cnwkpd1	PAR #27032 - Load Colour Code performance
					Actually need to reload table when an allocation is deleted, because exports
					may now count in a different allocation

*/

vars
	theDataLine 	: String;
	idx, colourCol : Integer;
	tbl				: CM_DataTable;
begin
//	tbl := self.tblCCAllocation;
//	self.mousePointer := Window.MousePointer_HourGlass;
//	colourCol := tbl.getColumnByRowName(ETRow_AllocName);	
	
	if _voyAlloc = null then
		return;
	endif;

	self.doQueueRefresh();
	
/*	if tbl.findObjectInRow(_voyAlloc, idx) then
		tbl.accessRow(idx - 1).gridBottom := false;
		tbl.removeItem(idx);
		if self.myCurrentVoyageAllocation = _voyAlloc then
			self.myCurrentVoyageAllocation := null;
		endif;

		self.displayCCTableTotalsRemove(); // PAR 23817
		self.displayCCTableTotals(); // PAR 23817

	endif;
*/

epilog
//	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="doNoteUpdateAllocation" id="cafe2e1d-48ab-4e4e-a6ec-52d63357ecbb">
        <updating/>
        <source>doNoteUpdateAllocation(_voyAlloc : CM_VoyageAllocation) updating;
// ---------------------------------------------------------------------------
// Created:     27 January 2010 by cnwab1
//
/*

Date		Who		Reason
01 Mar 2011	cnwkpd1	PAR #27032 - Load Colour Code performance

*/

vars
	theDataLine 	: String;
	idx, 
	colourCol 		: Integer;
	tbl				: CM_DataTable;
	invalidAlloc	: Boolean;			// PAR #27032
	
begin
	tbl := self.tblCCAllocation;
	self.mousePointer := Window.MousePointer_HourGlass;
	colourCol := tbl.getColumnByRowName(ETRow_AllocName);	
	
	if _voyAlloc = null then		// or not app.isValidObject(_voyAlloc) then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, _voyAlloc, invalidAlloc);			// PAR #27032
	
	if not (self.isExport = _voyAlloc.isExportAllocation()) then
		return;
	endif;
	
	if invalidAlloc then
		self.doQueueRefresh();
	endif;

	if self.isExport then
		// changed to using this for exports as all the projections need to be re calculated as the exports may no longer match the allocation
		// self.displayCCTable();
		self.doQueueRefresh();
	else
		theDataLine := _voyAlloc.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		if tbl.findObjectInRow(_voyAlloc, idx) then
			tbl.accessCell(idx,1);
			tbl.accessedCell.text := theDataLine;
		else
			idx := tbl.addItem(theDataLine);
			tbl.accessRow(idx).itemObject := _voyAlloc;			
			tbl.accessCell(idx, colourCol).backColor := _voyAlloc.color;		
			tbl.accessCell(idx, colourCol).foreColor := _voyAlloc.color.getInverseColour();
			tbl.accessRow(idx).gridRight := false;
			tbl.accessRow(idx).gridBottom := false;
		endif;
	endif;
	
	
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="doNoteUpdateVAExportsChange" id="13de5c14-76d5-4cd9-bbbe-96570c7263d3">
