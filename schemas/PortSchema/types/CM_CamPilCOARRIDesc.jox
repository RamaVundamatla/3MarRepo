    <JadeMethod name="outputHeader_TDT" id="c6f850f1-e773-4186-8474-5856ef52ef22">
        <updating/>
        <source>outputHeader_TDT(_camTaskHistory :CM_CamTaskHistory input; _protocol :CM_CamProtocol; _camVoyage :CM_CamVoyage; _count :Integer io; _coll :HugeStringArray input) : String updating, protected;
//
//Purpose:		Output TDT+20 segment for voyage	
		
//Date		Who		Reason
// 9 May 2017	cnwrs1	TFS 3671 POL PIL new work//
vars
	voyage	:CM_Voyage;
	strLine : String;
begin
	voyage	:= _camVoyage.voyageOid;
	
	if _protocol.camGroup.useCallSign then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeTDT20Segment (_protocol, _camVoyage.getSanitisedVoyageCode(), '1', 
													null, 'PCIU', '172', null, null, null, voyage.callSign.trimRight, '103', null, voyage.vesselName.trimRight.toUpper), _coll);
	else
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeTDT20Segment (_protocol, _camVoyage.getSanitisedVoyageCode(), '1', 
													null, 'PCIU', '172', null, null, null, voyage.lloydsNumber, '146', null, voyage.vesselName.trimRight.toUpper), _coll);
	endif;

	_count := _count + 1;
	return strLine;
epilog

end;</source>
