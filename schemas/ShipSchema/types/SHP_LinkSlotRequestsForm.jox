// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if button = Window.MouseButton_Left 
	and app.dragDetected(x, y, origXPos, origYPos) then
		table.dragMode := Window.DragMode_Drag;
		table.dragCursor := self.picJobPartComCur.picture;
	endif;
end;</source>
