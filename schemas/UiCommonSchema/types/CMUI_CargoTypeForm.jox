    <JadeMethod name="tblEntDetail_cellInputReady" id="870e9af0-28a6-48df-9512-538b92a6b7df">
        <controlMethod name="CM_EntryTable::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEntDetail_cellInputReady(table: Table input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/03/2014	cnwdap1		Initial creation PAR #33606 CCMS SFW 1366 Bulk
//
vars
	entTableRow	: EntTableRowTransient;

begin
	entTableRow := table.accessRow(table.row).itemObject.EntTableRowTransient;
	if entTableRow = null then
		return;
	endif;
	
	if entTableRow.name = ETRow_DefaultWeightType then
		self.cmbWeightType.text := table.accessCell(table.row, CM_EntryTable.ColumnValue).text;
	elseif entTableRow.name = ETRow_DefaultVolumeType then
		self.cmbVolumeType.text := table.accessCell(table.row, CM_EntryTable.ColumnValue).text;
	elseif entTableRow.name = ETRow_TrackBy then
		self.cmbTrackBy.text := table.accessCell(table.row, CM_EntryTable.ColumnValue).text;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tblEntDetail_change" id="48851b9f-abff-4dcf-be5d-0ce86231dea0">
        <controlMethod name="CM_EntryTable::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEntDetail_change(table: CM_EntryTable input) updating;

// R Barr 2/11/2006 Comalco - Change attribute list restriction when Is Bulk Product is changed via the keyboard
//							  See doClickIsBulkProduct() for similar mouse action
// cnwdap1	22/03/2010	PAR #22995 Allow Break-Bilk with no cargo subtypes to have reefer properties
// 18.05.2022 navds20 	ChangeRequest 53508: EUP - Cargo Uniqueness - UI
// 11 July 2023 navmv20 CR 58244 Task 58245: UI - Multiple Operators

vars
	entTableRow	: EntTableRowTransient;
	jrow		: JadeTableRow;
	_productType: Integer;
	
begin
	jrow := table.accessRow(table.row);
	if jrow = null then
		return;
	endif;
	
	entTableRow := jrow.itemObject.EntTableRowTransient;
	if entTableRow = null then
		return;
	endif;
	
	if entTableRow.name = ETRow_IsCommodityRequired then
		self.showHideCommodityCode();
	endif;
	
	//11/07/2023 navmv20 CR 58244 Task 58245 - start
	if entTableRow.name = ETRow_IsCargoGroupRequired then
		self.showHideMultipleOperators();
	endif;
	//11/07/2023 navmv20 CR 58244 Task 58245 - end

	if entTableRow.name = ETRow_IsSubCargoTypeRequired then
		self.showHideTblAttributes();
		self.showHideReeferProperties();// PAR #22995
	endif;
	
	//start 20 May 2022 navds20 TFS 53508
	if self.cmbProductType.listIndex &lt;&gt; -1 then
		_productType :=self.cmbProductType.listData();
	else
		if self.myCurrentObject = null then	// when creating a new cargo type
			self.cmbProductType.listIndex := 1;	// go to the first item in the combobox
			_productType := self.cmbProductType.listData();
		else
			_productType := self.myCurrentObject.CM_CargoType.productType;
		endif;
	endif;
	if entTableRow.name = ETRow_AllowDuplicates and (_productType = ProductType_Bulk or _productType = ProductType_BreakBulk) then 
		self.showHideCargoUniqueness();
	endif;
	//end 20 May 2022 navds20 TFS 53508
	
				
	
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
