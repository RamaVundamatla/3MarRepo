    <JadeMethod name="areWarningsSame" id="dbf54c3f-130f-4e3e-a384-32836d933833">
        <updating/>
        <source>areWarningsSame() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 November 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	err		: CM_Error;
	str		: String;	
	idx		: Integer;
	tmpSA	: HugeStringArray;
	
begin

	if self.allWarnings.size &gt; self.allSavedWarnings.size then
		// There are more warnings so can't be the same
		if self.debug then
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  allWarnings.size (' &amp;
								self.allWarnings.size.String &amp; ') &lt;&gt; allSavedWarnings.size (' &amp;
								self.allSavedWarnings.size.String &amp; ')');
		endif;
		return false;
	endif;
	
	
	create tmpSA transient;
	self.allSavedWarnings.copy(tmpSA);

	foreach err in self.allWarnings do
		str := err.getDetailsAsString();
		idx := tmpSA.indexOf(str);
		if idx = 0 then
			// warning was not found in saved collection
			if self.debug then
				app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '   warning (' &amp; str &amp; ') not found in allSavedWarnings');
			endif;
			return false;
		endif;
		// remove the warning so not found a second time
		tmpSA.removeAt(idx);
	endforeach;

	return true;
	
epilog
	delete tmpSA;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkValidation" id="ac61245f-7fa6-4d62-9bd4-640b8d924a6a">
        <updating/>
        <source>checkValidation() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.numWarningsAtValidationStage := self.allWarnings.size;

	if self.hasErrorsIgnored() then //jlier1 34221 27/5/25
		if self.debug then
			app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  hasErrors - saving warnings');
		endif;
		self.saveWarnings();
		return false;
	endif;

	if self.hasWarnings() and not self.warningsIgnored then
		if self.warningsAcknowledged then
			// need to check if these are the same as the previous and check
			if self.areWarningsSame() then
				return true;
			else
				
				self.status := TRXStatus_AdditionalWarnings;
				return false;
			endif;
		else
			self.status := TRXStatus_WarningsToBeAck;
			return false;
		endif;
	endif;
	
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearDeferUpdatesCollections" id="af4f8ed4-622b-4c38-8856-f6c170e14a53">
        <updating/>
        <source>clearDeferUpdatesCollections() updating;
/*
// ---------------------------------------------------------------------------
// Created:     03 March 2004	cnwth2
//
// Purpose:     
// 28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors	
// 18 Oct 2024 navnk30	JIRA 19927: EUP - Error 1081 When using Rail Lander
// ----------   ----------  --------------------------------------------------
*/
vars

begin
	self.allTIsForDeferredUpdate.clear();
	self.allTITransactionsForDeferUpd.clear();
	self.allEventsForDeferUpd.clear();			 // ### TFS CR 63938 TASK 63942 02MAY2024 NAVAB1
	self.allFutureActorForDefUpd.clear();		 //28.05.2024 navma1 #64224
	self.allWOTransactionsForDeferUpd.clear();		//18.10.2024 navnk30 JIRA #19927
	
	self.allTisToAutoPlan.clear();				 //13 Oct 2017	NDL	TFS 7283
	self.allTisToAutoQueue.clear();				 //13 Oct 2017	NDL	TFS 7283

	self.myTITransactionTerminal := null;
end;</source>
    </JadeMethod>
