//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSpecialAfter" id="41310b75-ef94-413a-834d-957708ec118e">
        <source>drawSpecialAfter();
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSpecialBefore" id="53a58e6e-865f-4582-9d89-51ee685798bb">
        <updating/>
        <source>drawSpecialBefore() updating;
// ---------------------------------------------------------------------------
// Created:		May  2002 By Andrew Bishop cnwab1
//
// Purpose:		This allow the drawing of shapes and labels etc. before the actual location controllers are represented with GridPoints.
//				What ever is drawn here could be drawn on top of by the drawing of the grid points. See drawSpecialAfter.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	TopTextMargin		: Integer = 5;
	BottomTextMargin	: Integer = 20;

vars
	rowPointer	: Integer;
	backColor	: Integer;
	lineColor	: Integer;
	textExtent	: Integer;
	skipRows	: Integer;
	rowCount	: Integer;
	numRows		: Integer;
	x1			: Real;
	y1			: Real;
	x2			: Real;
	y2			: Real;
	rowWidth	: Real;
	displayVal	: String;
	
begin
//	if (not self.myRowArea.isMarkedUp) then
		// No labels for non-marked up areas
//		return;
//	endif;

	backColor := self.myGridAreaFrame.backColor;	//Gray;
	self.myGridAreaFrame.drawFillColor := backColor;
	lineColor := backColor + 1;
	self.myGridAreaFrame.drawFilledRectangle(1, 0, self.totalPointWidth, self.height - BottomTextMargin, lineColor);
	numRows := self.myRowArea.allLabels.size;
	
	if numRows = 0 then
		return;
	endif;
	
	rowWidth := (self.totalPointWidth / numRows);
	self.myGridAreaFrame.drawFontSize := 8;
	textExtent := self.myGridAreaFrame.getTextExtent(self.myRowArea.allLabels.first) + 2;
	
	if textExtent &gt;= rowWidth then
		// If there is insufficient room for each label only printer every xth one.
		skipRows := (textExtent / rowWidth).Integer + 1;
	endif;

	rowCount := 1; 

	y1 := 0;
	y2 := y1 + self.height - BottomTextMargin;

	foreach displayVal in self.myRowArea.allLabels do
		if rowPointer &lt; numRows -1 then
			// Do not print the last line as the box above has already drawn this one.
			// Draw a box for each row.
			x1 := (rowPointer * rowWidth);
			
			if x1 &lt; 1 then
				x1 := 1;
			endif;
			
			x2 := x1 + rowWidth;
			self.myGridAreaFrame.drawLine(x2, y1, x2, y2, lineColor);
	//		self.myGridAreaFrame.drawFilledRectangle(x1, y1, x2, y2, lineColor);
		endif;
		
		rowPointer	:=	rowPointer + 1;

		if skipRows = 0 or rowCount = skipRows then
			// draw the label for the row
			rowCount := 1; 
			x1	:=	(rowPointer * rowWidth) - (rowWidth / 2) - ((displayVal.length * 7) / 2); 	// all this puts the label in the middle.
			self.myGridAreaFrame.drawTextAt(displayVal, x1, y2 + TopTextMargin, lineColor);
		else
			rowCount := rowCount + 1;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSpecialBeforeSAVE" id="e786fa61-7363-4bed-be6c-b0b5eee052be">
        <source>drawSpecialBeforeSAVE() ;
// ---------------------------------------------------------------------------
// Created:		May  2002 By Andrew Bishop cnwab1
//
// Purpose:		This allow the drawing of shapes and labels etc. before the actual location controllers are represented with GridPoints.
//				What ever is drawn here could be drawn on top of by the drawing of the grid points. See drawSpecialAfter.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	TopTextMargin		: Integer = 5;
	BottomTextMargin	: Integer = 20;

vars
	rowPointer	: Integer;
	backColor	: Integer;
	lineColor	: Integer;
	textExtent	: Integer;
	skipRows	: Integer;
	rowCount	: Integer;
	numRows		: Integer;
	x1			: Real;
	y1			: Real;
	x2			: Real;
	y2			: Real;
	rowWidth	: Real;
	displayVal	: String;
	
begin
//	if (not self.myRowArea.isMarkedUp) then
		// No labels for non-marked up areas
//		return;
//	endif;

	backColor := self.myGridAreaFrame.backColor;	//Gray;
	self.myGridAreaFrame.drawFillColor := backColor;
	
	if self.myRowArea.allLabels.isEmpty then
		self.myGridAreaFrame.drawFilledRectangle(1, 0, self.totalPointWidth, self.height - BottomTextMargin, backColor + 1);
		return;
	endif;
	
	numRows := self.myRowArea.allLabels.size;
	
	if numRows &lt;&gt; 0 then
		rowWidth := (self.totalPointWidth / numRows);
	else
		rowWidth := 10;
	endif;

	self.myGridAreaFrame.drawFontSize := 8;
	textExtent := self.myGridAreaFrame.getTextExtent(self.myRowArea.allLabels.first);
	
	if textExtent &gt;= rowWidth then
		// if there is insufficient room for each label only printer every xth one
		skipRows := (textExtent / rowWidth).Integer + 1;
	endif;

	rowCount := 1; 
	lineColor := backColor + 1;

	foreach displayVal in self.myRowArea.allLabels do
		// Draw a box for each row
		x1 := (rowPointer * rowWidth);
		
		if x1 &lt; 1 then
			x1 := 1;
		endif;
		
		y1 := 0;
		x2 := x1 + rowWidth;
		y2 := y1 + self.height - BottomTextMargin;
		self.myGridAreaFrame.drawFilledRectangle(x1, y1, x2, y2, lineColor);
		rowPointer	:=	rowPointer + 1;

		if skipRows = 0 or rowCount = skipRows then
			// draw the label for the row
			rowCount	:=	1;
			x1	:=	(rowPointer * rowWidth) - (rowWidth / 2) - ((displayVal.length * 7) / 2); 	// all this puts the label in the middle
			self.myGridAreaFrame.drawTextAt(displayVal, x1, y2 + TopTextMargin, lineColor);
		else
			rowCount	:=	rowCount + 1;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawVLabels" id="44e15f9c-0f24-44b6-a3ef-1983ee2fdb87">
        <updating/>
        <source>drawVLabels() updating, protected;

vars
	theY	: Integer;
	offset	: Integer;
	
begin
	offset	:=	self.height.Integer;
	
	self.myVLabelsFrame.autoRedraw	:=	true;
	self.myVLabelsFrame.drawTextCharRotation	:=	90;
	self.myVLabelsFrame.drawTextRotation	:=	90;

	theY	:=	(((self.row - 1) * offset) + (offset / 2)).Integer;
	self.myVLabelsFrame.drawTextAt(self.label, 12, theY + 1, White);
	self.myVLabelsFrame.drawTextAt(self.label, 11, theY, Black);
	self.myVLabelsFrame.drawTextRotation		:=	0;
	self.myVLabelsFrame.drawTextCharRotation	:=	0;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ae138b06-1f16-4871-adbb-e188b3a37e6b">
        <updating/>
        <source>setForCreate(pRowArea : CM_RowArea; pAssistant : CMUI_Assistant; pEdit : Boolean; pFrame : CMUI_GridAreaFrame) updating;
// ---------------------------------------------------------------------------
// Created:     14 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	yRow		: GC_RowAreaRow;
	cRow		: CM_RowAreaRow;
	yCol		: GC_RowAreaColumn;
	idx			: Integer;
	rowIndex	: Integer;
	
begin
	if pRowArea = null then
		return;
	endif;

	beginLoad;
	
	self.label				:=	pRowArea.id;
	self.depthOfArea		:=	100;
	self.lengthOfArea		:=	pRowArea.lengthOfArea;
	self.myGridAreaFrame	:=	pFrame;
	self.myAssistant		:=	pAssistant;
	self.myRowArea			:=	pRowArea;
	
	rowIndex	:=	pAssistant.allGridAreasByLabel.size;
	self.row	:=	rowIndex;

	create yRow transient;
	yRow.setForCreate(1, self);

	foreach cRow in pRowArea.allRows do
		idx := idx + 1;
		create yCol transient;
		yCol.setForCreate(cRow, idx, self);
	endforeach;
epilog
	endLoad;
end;</source>
        <Parameter name="pRowArea" type="CM_RowArea"/>
        <Parameter name="pAssistant" type="CMUI_Assistant"/>
        <Parameter name="pEdit" type="Boolean"/>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame"/>
    </JadeMethod>
    <JadeMethod name="setGridRowColPositions" id="f9d4c874-b4e0-47bf-b96b-37b4fbcaa771">
        <updating/>
        <source>setGridRowColPositions() updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	TopMargin		: Integer = 1;
	BottomMargin	: Integer = 1;
	LeftMargin		: Integer = 1;
	RightMargin		: Integer = 1;
	RowHeight		: Integer = 60;
	RowSpacing		: Integer = 1;
	ColWidth		: Integer = 2;

vars
	tmpRow		: CMUI_GridRow;
	tmpCol		: CMUI_GridColumn;
	yRow		: GC_RowAreaRow;
	yCol		: GC_RowAreaColumn;
	theColWidth	: Real;
	lastPos		: Real;
	totHeight	: Real;
	totWidth	: Real;
	tmpPos1		: Real;
	tmpPos2		: Real;
		
begin
	totHeight 	:= self.depthOfArea * self.scaleYFactor;
	totWidth	:= ColWidth * self.lengthOfArea * self.scaleXFactor;

	foreach tmpRow in self.allGridRows do
		yRow := tmpRow.GC_RowAreaRow;
		yRow.setYPos(TopMargin, TopMargin + totHeight);
	endforeach;
	
	self.totalPointHeight := TopMargin + totHeight + BottomMargin;
	
	foreach tmpCol in self.allGridColumns do
		yCol := tmpCol.GC_RowAreaColumn;
		theColWidth := (ColWidth * self.scaleXFactor * yCol.width);
		
		if lastPos = 0 then
			lastPos := LeftMargin;
		endif;
		
		tmpPos1 := lastPos; //+ 1;
		tmpPos2 := tmpPos1 + theColWidth;
		yCol.setXPos(tmpPos1, tmpPos2);
		lastPos := tmpPos2;
		yCol.setRowPositions(totHeight);
	endforeach;

	self.totalPointWidth := totWidth.max(tmpPos2 + RightMargin);
end;</source>
    </JadeMethod>
    <JadeMethod name="setZoomFactorTo" id="7b1f31a4-c5f0-4049-9087-f82fbc2e957f">
        <updating/>
        <source>setZoomFactorTo(pFactor: Real) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	// the logs get wider, but they don't get any taller!
	self.scaleXFactor := pFactor;
	self.scaleYFactor := 1;
end;</source>
        <Parameter name="pFactor" type="Real"/>
    </JadeMethod>
</Class>
