    <JadeMethod name="utlDeleteProduct" id="cc95d022-ea9a-44c7-bbe4-2fad9295e9f5">
        <source>utlDeleteProduct(_product: CM_Product io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     11 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	productTypeObj	: CM_YATypeProduct;
	
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.myValDA.valProduct(_product);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_product);
	endif;

	if _passport.noErrors then
		productTypeObj	:=	CM_YATypeProduct.firstInstance();
		
		if productTypeObj &lt;&gt; null then
			productTypeObj.removeMyDataObject(_product);
		endif;
		//navsp1 01Jun2022 TFS#53104		
		if _passport.isOpsViewEnabled(null) then
			_product.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE, BGP_OpsViewWSRequest.OPS_TYPE_CARGOSUBTYPE, _product);
		endif;
		_product.erase(NORMAL_ERASE);
	endif;

epilog
	return;
end;</source>
        <Parameter name="_product" type="CM_Product" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
