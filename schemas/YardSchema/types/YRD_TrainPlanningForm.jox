    <JadeMethod name="showWagonEnquiryForm" id="b7708239-7c20-4cc7-8a3d-6517d031d8a3">
        <updating/>
        <source>showWagonEnquiryForm( _wagon : CM_Wagon ) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	wagonColl : ObjectSet;
	
begin
	create wagonColl transient; // deleted by assistant
	
	if _wagon = null then
		self.getSelectedWagons(wagonColl, null);
	else
		wagonColl.add(_wagon);
	endif;
	
	self.myAssistant.YRD_Assistant.showWagonEnquiry(wagonColl, null, self.optDirInTB.value, false, self.myMasterMenuAction, self);

epilog
//	delete wagonColl;
end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="showWagonMaintForm" id="bb241021-bba8-47d7-b041-dc67cd390470">
        <updating/>
        <source>showWagonMaintForm(_object : CM_Object; _mode, _position : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	heading : String;
	wagonForm : YRD_TrainWagonForm;
	wagon : CM_Wagon;
	trainForWagonCombo : CM_Train;
	mode : Integer;
	inward : Boolean;
	railArea : CM_RailLine;
begin

	app.mousePointer := MousePointer_HourGlass;
	
	if CM_RailLine.hasInstance(_object) then
		heading := _object.CM_RailLine.getIdString();
		mode := YRD_TrainWagonForm.Mode_Add;
		railArea := _object.CM_RailLine;
	elseif CM_Wagon.hasInstance(_object) and _object.CM_Wagon.myRailLine &lt;&gt; null then
		wagon := _object.CM_Wagon;
		heading := wagon.myRailLine.getIdString();
		mode := YRD_TrainWagonForm.Mode_Update;
	elseif CM_Wagon.hasInstance(_object) then	// 25 Aug 2009	NDL CCMS 1094
		wagon := _object.CM_Wagon;
		heading := wagon.id;
		mode := YRD_TrainWagonForm.Mode_Update;
	else
		return;
	endif;
	self.setNavigatorHeading(heading &amp; " Wagon Maintenance"); 
	
	
/*	
	wagonForm.centreWindow;
	wagonForm.setMyTerminal(self.myTerminal);
	wagonForm.myTrain := self.cmbTrain.listObject.CM_Train;
	wagonForm.initForm(_object, self.myCurrentSDF.viewMode, _mode, _position);
	wagonForm.show;
	*/

	if wagon = null and mode = YRD_TrainWagonForm.Mode_Update then
		app.msgBox(app.getErrorString(Please_select_wagon), app.getErrorString(No_Wagon_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
/*
	if wagon &lt;&gt; null and wagon.confirmed then
		if app.msgBox(app.getErrorString(This_wagon_been_confi_conno_ed), app.getErrorString(Wagon_confirmed), MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			mode :=  YRD_TrainWagonForm.Mode_View;
		else
			return;
		endif;
	endif;
	*/
	inward := self.optDirInTB.value;
	if wagon &lt;&gt; null then
		if inward then
			trainForWagonCombo := wagon.myTrainInwards;
			if trainForWagonCombo = null then
				trainForWagonCombo := wagon.myTrainOutwards;
			endif;
		else
			trainForWagonCombo := wagon.myTrainOutwards;
		endif;
	endif;
	app.mousePointer := MousePointer_HourGlass;
	
	wagonForm := app.getForm(YRD_TrainWagonForm.name).YRD_TrainWagonForm;
	if wagonForm = null then
		wagonForm := app.loadForm(YRD_TrainWagonForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TrainWagonForm;
	endif;
	
	if wagonForm = null then
		return;
	endif;
	
	self.setNavigatorHeading(app.getErrorString(Wagon_maintenance)); 
	wagonForm.setParentForm(self);
	wagonForm.setMyTerminal(self.myTerminal);
	wagonForm.setMyTrainForWagonCombo(trainForWagonCombo);
	wagonForm.initialiseForm(trainForWagonCombo, wagon, mode);
	if railArea &lt;&gt; null then
		wagonForm.myRailArea := railArea.myRailArea;
	endif;
	wagonForm.myRailRake := railArea;
	wagonForm.rakePos := _position;
	wagonForm.show;
		
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_position" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="switchViewMode" id="682a17eb-07c0-40f4-8321-968e136895a5">
        <updating/>
        <source>switchViewMode(_theIndex : Integer; _btn : Button input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	obj : Object;
	sdf : CMUI_ScrollableDrawingFrame;
begin

	if _btn &lt;&gt; null then
		_btn.value := true;
	endif;

	foreach obj in self.allGridAreaDockBars do
		sdf := obj.YRD_RailDockBar.mySDF;
		sdf.setViewMode(_theIndex);
		if obj.YRD_RailDockBar.visible then
			sdf.drawSelf();
			if not self.frmColLegendTIs.displayViewModeCodes(_theIndex, sdf.myDrawingAttrController) then
				self.frmColLegendTIs.doChangeViewMode(_theIndex);
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_theIndex" type="Integer"/>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="8e839743-4146-4d24-8c42-2de4f9ce634c">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	trainsColl : ObjectSet;
	
begin
	if CM_Train.hasInstance(theObject) then
		if eventType = Object_Delete_Event then
			create trainsColl transient;
			self.allTrains.copy(trainsColl);
			if trainsColl.includes(theObject) then
				trainsColl.remove(theObject.CM_Train);
				self.myFilterTrain := null;
				self.setDisplayedObject(trainsColl);
				self.doRefresh();
			endif;
		endif;
		self.myAssistant.comboBoxTrain(self.cmbTrain, self.myFilterTrain, false, self.isDisplayedRailAreas, false);
	endif;

epilog
	delete trainsColl;
end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
