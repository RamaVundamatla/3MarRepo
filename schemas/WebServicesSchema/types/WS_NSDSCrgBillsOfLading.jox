    <JadeMethod name="setProxyObject" id="4b0abc7e-66ea-4d03-a156-925d50b39729">
        <updating/>
        <source>setProxyObject(_any: Any) updating;
/*
Purpose:			

Date		Who		Reason
31 May 2022	navab1	TFS 53105
*/

vars
	helper 	: CMIF_CrgBillsOfLading;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.agent_gkey := helper.agent_gkey;
	self.bl_type := helper.bl_type;
	self.cargoSuperType := helper.cargoSuperType;
	self.category := helper.category;
	self.client_id := helper.client_id;
	self.complex_gkey := helper.complex_gkey;
	self.consignee_gkey := helper.consignee_gkey;
	self.consignee_name := helper.consignee_name;
	self.cv_gkey := helper.cv_gkey;
	self.destination := helper.destination;
	self.gid := helper.gid;
	self.gkey := helper.gkey;
	self.is_direct := helper.is_direct;
	self.line_gkey := helper.line_gkey;
	self.manifested_qty := helper.manifested_qty;
	self.nbr := helper.nbr;
	self.notes := helper.notes;
	self.oid := helper.oid;
	self.origin := helper.origin;
	self.pin := helper.pin;
	self.shipper_gkey := helper.shipper_gkey;
	self.shipper_name := helper.shipper_name;
	self.tableName := helper.tableName;
epilog
	delete helper;
	delete ewsOpsView;
end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
