    <JadeMethod name="showCargoEnquiry" id="a1203ab3-a9f9-4fd8-8238-60a5a14c74e7">
        <source>showCargoEnquiry(_ti : CM_TrackedItem);
//--------------------------------------------------
// Created:	16 September 2003 By: cnwgd1
//--------------------------------------------------
vars
	cargoEnquiry : CM_ContainerEnqForm;
begin

	cargoEnquiry := app.loadForm(CM_ContainerEnqForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CM_ContainerEnqForm;	
	if cargoEnquiry = null then
		return;
	endif;
	cargoEnquiry.setMyTerminal(self.myTerminal);	
	cargoEnquiry.showWithObject(_ti, true, false);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="showCargoEnquiryForBOLs" id="ccb866aa-ee39-42e8-9d40-67606a485e5b">
        <source>showCargoEnquiryForBOLs(_masterBOL : CM_BOL;
					_objArray : ObjectArray;
					_masterMenuAction : CMUI_MenuAction;
					_edit : Boolean): CM_ContainerEnqForm;
//-----------------------------------------
// Created: 2 February 2006 By: cnwgd1
//-----------------------------------------
vars
	cargoEnqForm 	: CM_ContainerEnqForm;
	menuAction 		: CMUI_MenuAction;
begin
	
	if _masterBOL = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Master BOL is null');
		return null;
	endif;
	
	if _objArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Array is null');
		return null;
	endif;
	
	menuAction := app.myController.createMenuAction(PmAdmCargoEnquiryView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return null;
	endif;
	
	cargoEnqForm := menuAction.goToObject(null, null, false, null).CM_ContainerEnqForm;
	if cargoEnqForm = null then
		return null;
	endif;
	
	cargoEnqForm.showForBulkEditBOLs(_masterBOL, _objArray, _edit);
	
epilog
	return cargoEnqForm;
end;</source>
        <Parameter name="_masterBOL" type="CM_BOL"/>
        <Parameter name="_objArray" type="ObjectArray"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_edit" type="Boolean"/>
        <ReturnType type="CM_ContainerEnqForm"/>
    </JadeMethod>
    <JadeMethod name="showCargoEnquiryForTIs" id="444a8d76-6431-48e3-b575-578927a3e0e2">
        <source>showCargoEnquiryForTIs(_masterTI : CM_TrackedItem;
					_objArray : ObjectArray;
					_masterMenuAction : CMUI_MenuAction;
					_edit : Boolean): CM_ContainerEnqForm;
// ---------------------------------------------------------------------------
// Created:     09 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	cargoEnqForm 	: CM_ContainerEnqForm;
	menuAction 		: CMUI_MenuAction;
	//user			: CM_User;
begin
	
	if _masterTI = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Master TI is null');
		return null;
	endif;
	
	if _objArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'TI array is null');
		return null;
	endif;
	
	/* PAR 10878 security is checked below using the correct permission
	user := app.getMyUser();
	
	if not user.canDo(self.myTerminal, PmAdmCargoEnquiryView) then
		app.msgBox('You do not have the sufficient security rights to perform this operation','Not allowed',0);
		return null;
	endif;*/
	
	menuAction := app.myController.createMenuAction(PmAdmCargoEnquiryView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return null;
	endif;
	
	cargoEnqForm := menuAction.goToObject(null, null, false, null).CM_ContainerEnqForm;
	if cargoEnqForm = null then
		return null;
	endif;
	
	cargoEnqForm.showForBulkEdit(_masterTI, _objArray, _edit);
	
epilog
	return cargoEnqForm;
end;</source>
        <Parameter name="_masterTI" type="CM_TrackedItem"/>
        <Parameter name="_objArray" type="ObjectArray"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_edit" type="Boolean"/>
        <ReturnType type="CM_ContainerEnqForm"/>
    </JadeMethod>
    <JadeMethod name="showCargoEnquiryForVoyageJob" id="a8fe5975-7cb8-44aa-8bd8-030adf8e0ec8">
        <source>showCargoEnquiryForVoyageJob(	_voyageJob : CM_VoyageJob input; 
								_masterMenuAction : CMUI_MenuAction);
/*

Date		Who		Reason
27 March 2017	cnwer1	Initial creation TFS 830

*/

vars

	objArray : ObjectArray;
	invalid		: Boolean;
begin
	if _voyageJob = null then
		return;
	endif;
	
	
	on Exception do app.handleDeletedObject(exception,_voyageJob,invalid);
	_voyageJob.fetchLatest; //gets the edition
	
	if invalid then
		return;
	endif;	
	
	create objArray transient;
	_voyageJob.allReceiveTrackedItems.copy(objArray);
	_voyageJob.allReleaseTrackeditems.copy(objArray);
	_voyageJob.allSOBTrackedItems.copy(objArray);
	
	if objArray.size = null then
		return;
	endif;

	self.showCargoEnquiryForTIs(objArray.first.CM_TrackedItem, objArray, _masterMenuAction, false);

epilog
	delete objArray;

end;</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob" usage="input"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showCargoEnquiryForm" id="e1b74eea-748b-4feb-95ee-c6d650101d77">
        <source>showCargoEnquiryForm(_object : CM_Object; _masterMenuAction : CMUI_MenuAction;
					_thumbnailOnly, _doEdit : Boolean);
//--------------------------------------------------------------
//Created: 30 April 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cargoEnqForm : CM_ContainerEnqForm;
	menuAction : CMUI_MenuAction;
	failedDAC	: CM_DataAccessController;
	
	schema : Schema;
	klass : Class;
	assistClass : Class;
	
begin

	menuAction := app.myController.createMenuAction(PmAdmCargoEnquiryView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	if _object &lt;&gt; null and (not _object.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		// PAR 16522 - do check that user can access the object being viewed
//			app.msgBox('Warning, you do not have security access to view ' &amp; theTI.cargoTypeDescr &amp; ' ' &amp;
//						theTI.id &amp; '. Please check the number and try again.', 'Warning', MsgBox_OK_Only);
			app.raiseCMException(Autho_view_full_detai_this_car, null, null);
	endif;
	
	//16 Mar 2021	NDL	TFS 50487
	if _object &lt;&gt; null and _object.isKindOf(CM_TerminalArea) then
		schema := currentSchema.getSchema("YardSchema");
		klass := schema.getClass("YRD_LocationEnquiryFrm");
		assistClass := schema.getClass("YRD_Assistant");
		cargoEnqForm := app.loadForm(klass, assistClass, false, false, false, self.myTerminal, null).CM_ContainerEnqForm;
	else
		cargoEnqForm := menuAction.goToObject(null, null, false, null).CM_ContainerEnqForm;
	endif;
	if cargoEnqForm = null then
		return;
	endif;
	
	if _object &lt;&gt; null then
		cargoEnqForm.showWithObject(_object, _thumbnailOnly, _doEdit);
	else
		cargoEnqForm.show();
	endif;

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showCargoEnquiryFormForRcvlReq" id="bd07d13e-7ab9-4814-834f-ca0885667576">
        <source>showCargoEnquiryFormForRcvlReq(_receivalRequest : CM_ReceivalRequest; _masterMenuAction : CMUI_MenuAction);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwjk3	ccms 1071

*/

vars
	objs : CM_ObjectArray;
begin
	if _receivalRequest = null then
		return;
	endif;
	
	if _receivalRequest.hasReceivedTIs() then
		create objs transient;
		_receivalRequest.getReceivedTIs(objs);
		self.showCargoEnquiryForTIs(objs.first.CM_TrackedItem, objs, _masterMenuAction, false);
	endif;
epilog
	delete objs;
end;</source>
        <Parameter name="_receivalRequest" type="CM_ReceivalRequest"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showCargoIdLabelPrintForm" id="88ae0d00-3f22-41de-bc65-7ee241bd4ffa">
        <source>showCargoIdLabelPrintForm( _objArray : CM_ObjectArrayActual );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2010	cnwndl1	Initial creation	CCMS MES 1004
18/03/2010	cnwmh5	PAR 22665 - Form is now modal.  Change so error doesn't occur when opening from context menu
*/

vars

	form : CMUI_CargoLabelPrintRequest;
	
begin
	
	if _objArray &lt;&gt; null and _objArray.size &gt; 999 then
		app.msgBox(app.getErrorString2(Too_many_items_selected,_objArray.size.String,"999"),app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;

//	create form;
	//09 Dec 2010	NDL	 Par 26484 - so it can get the user window stuff correctly.
	form := app.getForm(CMUI_CargoLabelPrintRequest.name).CMUI_CargoLabelPrintRequest;
	if form = null then	//29 Jun 2017	NDL Form leak.
		form := app.loadForm(CMUI_CargoLabelPrintRequest, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_CargoLabelPrintRequest;
	endif;
	
	if form = null then		//29 Jun 2017	NDL Potential 1090
		return;
	endif;
	
	form.setSelectedObjects(_objArray);
	///form.showModal();
	form.show();				// 18/03/2010 cnmwh5 #22655
	
epilog

end;</source>
        <Parameter name="_objArray" type="CM_ObjectArrayActual"/>
    </JadeMethod>
    <JadeMethod name="showCargoListViewForTIs" id="9e64c000-b16c-41b4-80f1-9b7b40df6464">
        <source>showCargoListViewForTIs(_objArray : ObjectArray;
					_masterMenuAction : CMUI_MenuAction;
					_edit : Boolean) : CMUI_CargoListView;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2025	navnk30	JIRA 14605: EUP | Implement Satellite View of Large Dataset Display using "displayCollection"

*/

vars
	cargoListView	: CMUI_CargoListView;
begin
	if _objArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'TI array is null');
		return null;
	endif;
	
	cargoListView := app.loadForm(CMUI_CargoListView, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_CargoListView;
	cargoListView.setAllTIs(_objArray);
	cargoListView.show();
	return cargoListView;
epilog

end;</source>
        <Parameter name="_objArray" type="ObjectArray"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_edit" type="Boolean"/>
        <ReturnType type="CMUI_CargoListView"/>
    </JadeMethod>
    <JadeMethod name="showCargoMoveOverstowForm" id="5f93c2ea-e27d-452a-ae17-74827d1306d1">
        <source>showCargoMoveOverstowForm(_ti : CM_TrackedItem; _masterMenuAction : CMUI_MenuAction);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwphb1	Initial creation (PAR 21532 CCMS SFW 1025)

*/

vars
	overstowForm	: Form;
	aClass			: Class;
	assistClass		: Class;
	jrw				: Schema;
begin

	
	jrw := rootSchema.getSchema("YardSchema");
	aClass := jrw.getClass("YRD_MoveOverstowCargoForm");
	assistClass := jrw.getClass("YRD_Assistant");
	
	overstowForm := app.loadForm(aClass, assistClass, false, false, true, self.myTerminal, _masterMenuAction);
	if overstowForm = null then
		return;
	endif;
	overstowForm.CM_BaseForm.setFormObject(_ti);

	overstowForm.show();
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showCargoReceiptFromFlexiGate" id="a1655aad-c341-44c9-91b4-30744a173f76">
        <updating/>
        <source>showCargoReceiptFromFlexiGate(_parentForm : CM_BaseForm; _modal : Boolean; _flexiCargoType, _columns, _controlWidth : Integer;
							  _tranNum : String; _copy : Boolean; _gteEntity : CMGTE_Entity; _bulkRelease : CM_BulkRelease; 
							  _reserve : CM_ReserveDetail; _ti : CM_TrackedItem; _brItem : CM_BookingRefItem; _bolDtl : CM_BOLDtl;
							  _vehicleVisit : CM_VehicleVisitRecord; _itemIds : StringArray) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/08/2009	cnwdap1	Initial creation
14/10/2009	cnwdap1	PAR #21334 Make receival form non-modal except for attachments form
15/07/2024	navpw1	TFS: 61525 (61527) - Added Vehicle booking timeslot item
*/
vars
	form	: CMUI_ReceiveCargoForm;
begin
	if _modal then
		form := app.loadForm(	CMUI_ReceiveCargoFormModal, 
								self.class, 
								false, false, false, 
								self.myTerminal, null).CMUI_ReceiveCargoFormModal;
	else
		form := app.loadForm(	CMUI_ReceiveCargoForm, 
								self.class, 
								false, false, false, 
								self.myTerminal, null).CMUI_ReceiveCargoForm;
	endif;
							
	// If user fails security we don't want to show a null form.
	if form &lt;&gt; null then
		//form.setIsFull(_isFull);
		
		if _flexiCargoType = CMUI_FlexiCargoForm.FLEXI_CARGO_FULL then
			form.setIsFullContainer();
		elseif _flexiCargoType = CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY then
			form.setIsEmptyContainer();
		elseif _flexiCargoType = CMUI_FlexiCargoForm.FLEXI_CARGO_ANY then
			form.setIsAnyCargo();
		elseif _flexiCargoType = CMUI_FlexiCargoForm.FLEXI_CARGO_GENERAL then
			form.setIsGeneralCargo();
		else
			app.raiseUnexpectedProgramError(class.name, method.name, "Undefined flexi cargo type");
		endif;
		
		form.setColumnsAndControlWidth(_columns, _controlWidth);	// columns, default control width
		// 29287 Apr 2012 multi-select pre-notes in road gate, _itemIds are ids of selected pre-notes
		form.initFromFlexiGateForm(_parentForm, _tranNum, _copy, _gteEntity, _bulkRelease, _reserve, _ti, _brItem, _bolDtl, _vehicleVisit, _itemIds, null);
		
		if _modal then
			form.showModal();
		else
			form.show();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_modal" type="Boolean"/>
        <Parameter name="_flexiCargoType" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_tranNum" type="String"/>
        <Parameter name="_copy" type="Boolean"/>
        <Parameter name="_gteEntity" type="CMGTE_Entity"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserve" type="CM_ReserveDetail"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
        <Parameter name="_bolDtl" type="CM_BOLDtl"/>
        <Parameter name="_vehicleVisit" type="CM_VehicleVisitRecord"/>
        <Parameter name="_itemIds" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="showCargoReceiptFromPreNote" id="41ea3de1-6510-411f-88e3-8e2edc2410fb">
        <source>showCargoReceiptFromPreNote(_parentForm : CM_BaseForm; _isNewItem : Boolean; _columns, _controlWidth : Integer; _trackedItem : CM_TrackedItem; _preNote : CMIF_PreNote; _showModal : Boolean; _transportMode : String);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/08/2009	cnwdap1	Initial creation
14/10/2009	cnwdap1	PAR #21334 Make form non-modal, except for attachments form
*/
vars
	form 	: CMUI_ReceiveCargoForm;

begin
	if _showModal then
	form := app.loadForm(	CMUI_ReceiveCargoFormModal,
							self.class,
							false,
							false,
							_showModal,
							self.myTerminal, null).CMUI_ReceiveCargoFormModal;
	else
		form := app.loadForm(	CMUI_ReceiveCargoForm,
								self.class,
								false,
								false,
								_showModal,
								self.myTerminal, null).CMUI_ReceiveCargoForm;
	endif;
	
	form.setColumnsAndControlWidth(_columns, _controlWidth);	// columns, default control width
	form.initFromPreNoteForm(_parentForm, _trackedItem, null, _preNote, _transportMode);
	form.setIsNewItem(_isNewItem);
	
	if _showModal then
		form.showModal;
	else
		form.show;
	endif;

epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_isNewItem" type="Boolean"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_preNote" type="CMIF_PreNote"/>
        <Parameter name="_showModal" type="Boolean"/>
        <Parameter name="_transportMode" type="String"/>
    </JadeMethod>
    <JadeMethod name="showCargoReceiptFromRailCargo" id="cd0b3fb1-d577-42d3-8aab-acf59a157068">
        <source>showCargoReceiptFromRailCargo(_parentForm : CM_BaseForm; _isNewItem : Boolean; _columns, _controlWidth : Integer; _trackedItem : CM_TrackedItem; _cargoType : CM_CargoType; _train : CM_Train; _wagon : CM_Wagon; _wagonClass : CM_WagonClass );
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/08/2009	cnwdap1	Initial creation
14/10/2009	cnwdap1	Make form non-modal
10 Apr 2023 navhl20 ChangeRequest 56628:[54992] EUP - Receive Cargo Form- Enhancement
*/
vars
	form 	: CMUI_ReceiveCargoForm;

begin
	form := app.loadForm(	CMUI_ReceiveCargoForm,
							self.class,
							false,
							false,
							true,
							self.myTerminal, null).CMUI_ReceiveCargoForm;
	
	form.setColumnsAndControlWidth(_columns, _controlWidth);	// columns, default control width
	form.initFromRailCargoForm(_parentForm, _trackedItem, _cargoType);
	form.setIsNewItem(_isNewItem);
	form.show;
	form.initTrainDetails(_train,_wagon,_wagonClass);												//10.4.2023 navhl20	#56628[54992]

epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_isNewItem" type="Boolean"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
    </JadeMethod>
    <JadeMethod name="showCargoReleaseFromFlexiGate" id="383f3a4a-197d-4f70-854a-c82ec8f272ad">
        <updating/>
        <source>showCargoReleaseFromFlexiGate(	_parentForm : CM_BaseForm; 
								_modal : Boolean; 
								_flexiCargoType, _columns, _controlWidth : Integer; 
								_tranNum : String; 
								_copy : Boolean; 
								_gteEntity : CMGTE_Entity; 
								_bulkRelease : CM_BulkRelease; 
								_reserve : CM_ReserveDetail; 
								_ti : CM_TrackedItem; 
								_brItem : CM_BookingRefItem;
								_bolDtl : CM_BOLDtl;	//06 Oct 2020	NDL	TFS 49189
								_vehicleVisit : CM_VehicleVisitRecord;
								_workOrder : CM_WorkOrder;
								_vbsti : CM_VehicleBookingTimeSlotItem	//31.8.2023 navhl20 #60183
								) updating;			// TFS 38501
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/08/2009	cnwdap1	Initial creation
14/10/2009	cnwdap1	Make form non-modal
14/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes - new _workOrder parameter
31 Aug 2023 navhl20 Bug 60183: FR | 53429 - VBS changes - Quantity assigned in the VBS is not remembered during Road Gate announcement
15/07/2024	navpw1	TFS: 61525 (61527) - Added Vehicle booking timeslot item
08/10/2024	navcs2	MTN-14819 EUP | Release By Weight - VBS Weight Limit Dev - Thin Client - Extra Changes

*/
vars
	form	: CMUI_ReleaseCargoForm;
	
begin
	form := app.loadForm(	CMUI_ReleaseCargoForm, 
							self.class, 
							false, false, false, 
							self.myTerminal, null).CMUI_ReleaseCargoForm;
														
	// If user fails security we don't want to show a null form.
	if form &lt;&gt; null then
		//form.setIsFull(_isFull);
		if _flexiCargoType = CMUI_FlexiCargoForm.FLEXI_CARGO_FULL then
			form.setIsFullContainer();
		elseif _flexiCargoType = CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY then
			form.setIsEmptyContainer();
		elseif _flexiCargoType = CMUI_FlexiCargoForm.FLEXI_CARGO_GENERAL then
			form.setIsGeneralCargo();  // Assume for now...	
		else
			app.raiseUnexpectedProgramError(class.name, method.name, "Undefined flexi cargo type");
		endif;		
		form.setColumnsAndControlWidth(_columns, _controlWidth);	// columns, default control width
		form.initFromFlexiGateForm(_parentForm, _tranNum, _copy, _gteEntity, _bulkRelease, _reserve, _ti, _brItem, _bolDtl, _vehicleVisit, null, _vbsti);			// 08/10/2024	navcs2	MTN-14819
		form.setMyWorkOrder(_workOrder);					// TFS 38501
		
		if _modal then
			form.showModal();
		else
			form.show();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_modal" type="Boolean"/>
        <Parameter name="_flexiCargoType" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_tranNum" type="String"/>
        <Parameter name="_copy" type="Boolean"/>
        <Parameter name="_gteEntity" type="CMGTE_Entity"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserve" type="CM_ReserveDetail"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
        <Parameter name="_bolDtl" type="CM_BOLDtl"/>
        <Parameter name="_vehicleVisit" type="CM_VehicleVisitRecord"/>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <Parameter name="_vbsti" type="CM_VehicleBookingTimeSlotItem"/>
    </JadeMethod>
    <JadeMethod name="showCargoSearchForm" id="b70c1e26-4335-46b2-99c7-4ae88f6c44ca">
        <source>showCargoSearchForm(_parent 	    : CM_BaseForm; 
					_mts 			: Boolean; 
					_allSelectedTIs : CM_TIArray; 
					_bItem 		    : CM_BookingRefItem; 
					_reserveItem    : CM_ReserveDetail;
					_cargoType      : CM_CargoType;
					_voyage			: CM_Voyage;
					_bol			: CM_BOL;
					_contextObject  : CM_Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		 Reason
27 Aug 2009	cnwml2
18 MAr 2010 cnwrd1   par 21162 added reserveDetail
13 Mar 2023 navma1   ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
17 Apr 2023 navhl20	 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
16 Oct 2023 navlc30  ChangeRequest 58996: EUP | VBS changes MTN - Adding multiple items at once (From Ticket FR 53429)
*/

vars
	//form : CMUI_CargoSearchForm;
	form : CMUI_CargoSearchFormModal;
begin
	/*form := app.loadForm(CMUI_CargoSearchForm, 					
							CMUI_Assistant, 
							false, 
							false,
							false, 
							self.myTerminal,
							null).CMUI_CargoSearchForm;	*/			//16.10.2023 navlc30 #58996
	form := app.loadForm(CMUI_CargoSearchFormModal, 
							CMUI_Assistant, 
							false, 
							false,
							false, 
							self.myTerminal,
							null).CMUI_CargoSearchFormModal;		//16.10.2023 navlc30 #58996
							
	form.setColumnsAndControlWidth(3, 175);
	form.setParentForm(_parent);
	form.setMTs(_mts);
	form.setSelectedTIs(_allSelectedTIs);
	
	form.setCargoType(_cargoType);
	form.setMyBookingItem(_bItem);
	form.setBolfromWO(_voyage,_bol);								//17.4.2023 navhl20 #55443[54991]
	form.setMyReserveDetail(_reserveItem);							//cnwrd1 18.3.2010 par 21162
	form.setContextSearchObject(_contextObject);					//13.03.2023 navma1 #56457:[56458]
	
	//form.show;													//16.10.2023 navlc30 #58996
	form.showModal;													//16.10.2023 navlc30 #58996
epilog

end;</source>
        <Parameter name="_parent" type="CM_BaseForm"/>
        <Parameter name="_mts" type="Boolean"/>
        <Parameter name="_allSelectedTIs" type="CM_TIArray"/>
        <Parameter name="_bItem" type="CM_BookingRefItem"/>
        <Parameter name="_reserveItem" type="CM_ReserveDetail"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_contextObject" type="CM_Object"/>
    </JadeMethod>
