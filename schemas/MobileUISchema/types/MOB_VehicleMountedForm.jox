    <JadeMethod name="doRTQueueEntryChanged" id="5f1d1b7f-a5f3-4fa0-8207-ce3489a623ba">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::doRTQueueEntryChanged"/>
        </interfaceImplements>
        <updating/>
        <source>doRTQueueEntryChanged(_rtQueueEntry : CM_RTQueueEntry) updating;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 Apr 2010	cnwer1	Initial creation
07 Dec 2010 cnwer1	PAr 25611 - refresh issues with control completing tasks
*/

vars
	theEdition : Integer;
	invalidObject : Boolean;
begin
	self.setFramesVisible();
	if self.isEnquiryMode or self.isShowOverstowCargo then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception,_rtQueueEntry,invalidObject);
	
	if _rtQueueEntry &lt;&gt; null then
		theEdition:= _rtQueueEntry.edition;
	endif;
	
	self.goToTaskFrame;
	self.refreshTableEntry(_rtQueueEntry);
	
	self.btnAccept.caption:=app.myVMAgent.getMoveTaskStr;
epilog
	
end;</source>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry"/>
