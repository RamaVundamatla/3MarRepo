    <JadeMethod name="trxSetBookRefsStatus" id="94866240-9ef1-426d-9cf7-777e3c856f49">
        <updating/>
        <source>trxSetBookRefsStatus(_status:Integer; _allBookingRefs:CM_BookingRefSet; _passportObj:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		19 March 2009 by cnwdad1
//
// Purpose:		Sets the status of all Booking References in the specified set to the
//				specified Status.
//
// Parameters:	_status - The status to set the Booking Refs's to.
//				_allBookingRefs - A reference to the set of BR's to set.
//				_passportObj - A reference to the current User's passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Always initialize the activity first.
	self.initialiseActivityWithPassport(_passportObj, method);
	
	// Arm our base exception handlers.
	on Exception do agtPassportExHandler(exception, _passportObj);
	on LockException do agtPassportLockExHandler(exception, _passportObj);
	
	app.setContinueCMExceptions(false);
	
	beginTransaction;
	
	app.myUtilityUA.utlSetBookRefsStatus(_status, _allBookingRefs, _passportObj);
epilog
	self.finaliseActivityWithPassport(_passportObj);
end;</source>
