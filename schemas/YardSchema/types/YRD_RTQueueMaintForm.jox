    <JadeMethod name="cmbParent_click" id="914f06e0-15c3-41af-b9df-ce7cd1b288ff">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbParent_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theID : String;
	subQueue : CM_SubQueue;
	taMaster : CM_TerminalAreaMaster;
	allRTGColumns : CM_RTGColumnByAreaIdColDict;
begin
	self.tblMain.setValueByControlName(combobox.name,combobox.text);
	if self.cmbType.getCurrentItemData = QTYPE_CRANE then
		theID := self.tblMain.getValueByName(ETRow_Parent).String;
		theID := theID &amp; " " &amp; self.tblMain.getValueByName(ETRow_Cranes).String;
		self.tblMain.setValueByName(ETRow_Id,theID);
	elseif  self.cmbType.getCurrentItemData = QTYPE_WORKPOINT then
		theID := self.tblMain.getValueByName(ETRow_Parent).String;
		theID := theID &amp; " " &amp; self.tblMain.getValueByName(ETRow_WorkPoint).String;
		self.tblMain.setValueByName(ETRow_Id,theID);
	elseif self.cmbType.getCurrentItemData = QTYPE_RTGSUBQUEUE then
		if combobox.listObject &lt;&gt; null then
			subQueue:=combobox.listObject.CM_SubQueue;
			create allRTGColumns transient;
			foreach taMaster in subQueue.allMoveFromTAMasters do
				if  taMaster.isKindOf(CM_RTGArea) then
					taMaster.CM_RTGArea.allGridColumns.copy( allRTGColumns);
				endif;
			endforeach;
			self.doDisplayRTGBays(allRTGColumns);		
		endif;
	endif;
epilog
	delete allRTGColumns;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
