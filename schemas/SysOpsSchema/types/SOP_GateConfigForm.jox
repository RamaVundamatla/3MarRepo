    <JadeMethod name="doResize" id="f1c8ddd1-561b-4db0-817b-f2b88a1de8ba">
        <updating/>
        <source>doResize() updating;

/*
Date			Who		Reason
25 March 2011	cnwar2	#26100

*/
vars

begin
	inheritMethod();
	self.fldMain.top 	:= self.frmToolbar.clientHeight + 4;
	self.fldMain.height := self.btnSave.top - self.fldMain.top - 4;
