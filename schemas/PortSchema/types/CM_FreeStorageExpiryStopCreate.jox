12 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 12th June 2024

*/

vars

begin
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myProduct &lt;&gt; null then		
