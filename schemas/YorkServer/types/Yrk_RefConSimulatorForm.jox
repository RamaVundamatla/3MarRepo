    <JadeMethod name="setTemperature" id="f20c3a7d-a759-48a4-80fd-de07dd84ebeb">
        <updating/>
        <source>setTemperature() updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	number,anumber: Integer;
	temp: Real;
	ti: Yrk_Container;
begin
	exclusiveLock(self.config);
	beginTransaction;
	foreach ti in Yrk_Container.instances do
		anumber := app.random(80);
		number := app.random((ti.tempMax - ti.tempMin).Integer);
		if anumber &lt;&gt; 69 and anumber &lt;&gt; 70 then
			temp := ti.tempMin + number;
		elseif anumber = 69 then
			temp := 0;
		else
			temp := ti.tempMax + number; //cause an alarm
		endif;
		ti.setTempSupply(temp);
	endforeach;
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8bc7822c-41c5-4dfe-b1c2-a20b352831bb">
        <updating/>
        <source>setupForm() updating;

// cnwdvb1 29 April 2003 

vars

	terminal : CM_Terminal;

begin
	inheritMethod();
	self.handleMenusForModalDisplay;
		terminal := app.myRoot.allTerminals['T1'];
	app.setMyTerminal(terminal);
	self.myTerminal := terminal;
	self.staMain.boundaryColor := Blue;

	config := Yrk_Configuration.firstInstance;
	beginTransaction;
	if config = null then
		create config;
	endif;
//	config.setPropertyValue("listernPort",1000);
	commitTransaction;

	inheritMethod;

	self.beginTimer(30000, Timer_Continuous, 1); //im alive
	//self.beginTimer(3600000, Timer_Continuous, 2); //update reading
	//self.beginTimer(3600000, Timer_Continuous, 3); //send everything
	self.doMonitorClick();
	self.openListen();
	self.txtMonitor.stretchWidth := true;
	self.txtMonitor.stretchHeight := true;
	self.windowState := Form.WindowState_Maximized;
	self.resize();

end;</source>
    </JadeMethod>
    <JadeMethod name="timeOfAct" id="8998eb92-2c99-4065-819c-19e1d6bd9adb">
        <source>timeOfAct(_time: TimeStamp):String protected;

vars
	timeUTC : TimeStamp;
	message: String;
begin
	timeUTC := _time.localToUTCTime();
	message := timeUTC.date.format("yyyyMMdd") &amp; timeUTC.time.format("HHmmss");
	//message := _time.date.format("yyyyMMdd")&amp;_time.time.format("HHmmss");
	return message;
end;</source>
        <access>protected</access>
        <Parameter name="_time" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="f47eda8c-bf67-499e-b1e0-163a3c3354ca">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	message: Binary;
begin
	if eventTag = 1 then  //send Imalive
		if self.connected then
//			if not self.sentImAlive then
//				self.staMain.caption := "Client has died!";
//				self.logMonitor("Client has died!");
//				self.logReport(class,method,"Client has died!");
//			endif;
			message := self.imAliveTelegram();
			self.sendTelegram(message);
			sentImAlive := true;
		endif;
	elseif eventTag = 2 then //update temperatures
		if self.connected then
			self.setTemperature(); //pseudo read from container 
			self.findAlarms();
		endif;
	elseif eventTag = 3 then //semd every thing
//	write class.name&amp;"::"&amp;method.name&amp;" "&amp;eventTag.String;
		if self.connected then
			self.logMonitor("Send all.");
			self.logReport("Send all");
			self.sendAll();
		endif;
	endif;
//	inheritMethod(eventTag);
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
