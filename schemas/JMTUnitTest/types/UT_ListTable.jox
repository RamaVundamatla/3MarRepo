    <JadeMethod name="purgeTableObjects" id="5e99f1f3-8fb3-4e9c-87c8-fed6b21204d6">
        <updating/>
        <source>purgeTableObjects() updating;
//----------------------------------------------------------------
//	Created:	29 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	self.allSelectedObjects.clear;
	
	inheritMethod();

end;</source>
