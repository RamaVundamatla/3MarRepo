        <source>setControlsForView();
//--------------------------------------------------
// Created:	02 August 2005 By: cnwgd1
/* Changes

Date		Name	TFS#		Description
============================================================================
21/11/2016	cnwrh7	TFS	2974	Voyage Enquiry security
29/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
12/03/2020	cnwma1	Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue	
11/06/2021	navdap1	TFS 51326 ASPA Bulk Edit Voyages
11 Oct 2021 jlier1	TFS 51963 removed inaportnet options
05 May 2022 navlw1 	TFS 53402 Barge Vessel Change
20 May 2022 navlw1 	TFS	53654 Context menu still allows barge vessel change
29 Jul 2022 navsj20 TFS 54220 ChangeRequest 54220: EUP - INB - Change Vessel Name
25 Jul 2025	naviv1	MTN-35310 : CUX - Changing Vessel not possible
============================================================================*/

vars
	voyStatus 		: CM_VoyageStatus;
	currentVoyage   : CM_Voyage;
	reportStr 		: String;
begin
	
	currentVoyage := self.myCurrentVoyage;
	
	self.btnArchive.enabled			:= false;
	self.btnDelete.enabled			:= false;
	self.btnBayDefinition.enabled	:= false;	
	self.mnuBayDefinition.enabled 	:= false;
	self.btnResourcesUsed.enabled	:= false;	
	self.btnJobPriority.enabled		:= false;	
	self.btnROROEnquiry.enabled		:= false;
	self.btnHoldDef.enabled			:= false;	
	self.mnuArchiveVoyage.enabled 	:= false;
	self.mnuDeleteVoyage.enabled	:= false;
	self.mnuResources.enabled		:= false;
	self.mnuHarbourInvoices.enabled := false;
	self.mnuReeval.enabled			:= false;
	self.mnuRunCurrStat.enabled 	:= false;	
	self.btnOOWConfirm.enabled 		:= false;	
	self.mnuResendInaport.visible	:= false;
	self.mnuBargeBulkCopy.enabled	:= false;	//27 May 2020	NDL	TFS 49417
	self.mnuBargeBulkCreate.enabled := app.myCurrentUserCan(self.myTerminal, PmShipBargeCreate);	//29 May 2020	NDL	TFS 49417
	self.mnuBargeVessChg.enabled 	:= false; 
	self.mnuBulkEditVoyages.enabled	:= false;		// TFS 51326
	
	reportStr := self.myTerminal.getConfig(InvProformaInvoiceReport).String;
	self.mnuReportProforma.visible := reportStr &lt;&gt; null; // ### TFS CR 65820 TASK 65821 27AUG2024 NAVAB1

	
	
	if currentVoyage &lt;&gt; null then
		voyStatus						:= currentVoyage.getVoyageStatusObject;
		self.btnResourcesUsed.enabled	:= currentVoyage.myHMSVoyageData &lt;&gt; null;
		self.btnHMSInvoice.enabled		:= currentVoyage.myHMSVoyageData &lt;&gt; null;
		self.mnuResources.enabled	    := currentVoyage.myHMSVoyageData &lt;&gt; null;
		self.mnuHarbourInvoices.enabled := currentVoyage.myHMSVoyageData &lt;&gt; null;
		self.mnuReeval.enabled 			:= currentVoyage.shipExchangeCompleteDT &lt;&gt; null;		// Nov 2010 CCMS 2020 par 26107
		self.mnuRunCurrStat.enabled 	:= currentVoyage.statusHasReport();					    //31 May 2018	NDL	TFS 38905
		self.btnOOWConfirm.enabled 		:= currentVoyage.myVoyageProcess &lt;&gt; null and currentVoyage.myVoyageProcess.showOOWConfirmation(currentVoyage);	//15 Jun 2018	NDL	TFS 39167
		self.btnJobPriority.enabled  	:=	self.btnBayDefinition.enabled and app.myCurrentUserCan(self.myTerminal, PmShpJobPriorityMaint);
		
		if not currentVoyage.archived then
			if currentVoyage.myCellularVoyageStructure &lt;&gt; null then
				self.btnBayDefinition.enabled	:= true;
				self.mnuBayDefinition.enabled 	:= true;
			endif;
			self.btnROROEnquiry.enabled := currentVoyage.myROROStructure &lt;&gt; null;		//epr CCMS 116 1/5/2011
			self.btnHoldDef.enabled     := currentVoyage.myGeneralCargoVoyage &lt;&gt; null;	//15 July 2013	NDL	Par 31965
		endif;
			
		
		if app.myCurrentUserCan(currentVoyage.myTerminal, PmAdmVoyageDefEdit) then
			self.btnDelete.enabled	:=	app.myCurrentUserCan(currentVoyage.myTerminal, PmShipVoyageEnquiryDel);	//29 May 2020	NDL	TFS 49417
			
			if app.myCurrentUserCan(self.myTerminal, PmVoyageArchive) then	
				self.btnArchive.enabled			:= not currentVoyage.archived;     //12.03.2020 cnwma1  #48863
				self.mnuArchiveVoyage.enabled 	:= self.btnArchive.enabled;        //12.03.2020 cnwma1  #48863
			endif;
			self.mnuDeleteVoyage.enabled := app.myCurrentUserCan(currentVoyage.myTerminal, PmShipVoyageEnquiryDel);	//29 May 2020	NDL	TFS 49417
		endif;

		//27 May 2020	NDL	TFS 49417
		/*if currentVoyage.isBarge then
			if currentVoyage.myHMSVoyageData &lt;&gt; null then
				if currentVoyage.myHMSVoyageData.allVoyageMovements.isEmpty then
					self.mnuBargeBulkCopy.enabled := app.myCurrentUserCan(self.myTerminal, PmShipBargeCopy);
					self.mnuBargeVessChg.enabled := app.myCurrentUserCan(self.myTerminal, PmShipBargeChange);
				endif;
			else
				self.mnuBargeBulkCopy.enabled := app.myCurrentUserCan(self.myTerminal, PmShipBargeCopy);
				self.mnuBargeVessChg.enabled := app.myCurrentUserCan(self.myTerminal, PmShipBargeChange);
			endif;		
		endif;
		*/
		// 05 May 2022 navlw1 TFS# 53402
		// START 29 Jul 2022	navsj20	TFS 54220
		if not currentVoyage.isBarge then 
			self.mnuBargeVessChg.caption:= app.getErrorString(Change_voyage_vessel);
		else 
			self.mnuBargeVessChg.translateCaption(Xlat_0023924, app.myCurrentLocale); // this is the standard translation used in SHP_VoyageEnquiryForm::translateForm – it may be different in WMAST
		endif;
		// END 29 Jul 2022	navsj20	TFS 54220
		if currentVoyage.isBarge and currentVoyage.allTITransactionsByTypeDT.size = 0 	// 20 May 2022 navlw1 TFS# 53654 changed the collection
			or (not currentVoyage.isBarge and currentVoyage.canDoBulkCopyOrVoyChange()) then 	//29 Jul 2022	navsj20	TFS 54220 //MTN-35310
			self.mnuBargeBulkCopy.enabled := app.myCurrentUserCan(self.myTerminal, PmShipBargeCopy);
			self.mnuBargeVessChg.enabled := app.myCurrentUserCan(self.myTerminal, PmShipBargeChange);
		endif;
				
		self.mnuBulkEditVoyages.enabled := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); 	// TFS 51326
		
	elseif app.myCurrentUserCan(self.myTerminal, PmAdmVoyageDefEdit) and currentVoyage &lt;&gt; null then
		self.btnDelete.enabled		 :=	app.myCurrentUserCan(currentVoyage.myTerminal, PmShipVoyageEnquiryDel);	//29 May 2020	NDL	TFS 49417	
		self.mnuDeleteVoyage.enabled := app.myCurrentUserCan(currentVoyage.myTerminal, PmShipVoyageEnquiryDel);	//29 May 2020	NDL	TFS 49417
	elseif app.myCurrentUserCan(self.myTerminal, PmShpJobPriorityMaint) then
		self.btnJobPriority.enabled	:=	true;
	endif;

	self.btnShowSearch.enabled		:=	true;
	self.btnSelectAll.enabled		:=	true;
	self.btnEdit.enabled			:=	true;
	//self.btnEditGV.enabled		:=	true; // jlgka1 TFS 45620
	self.btnPrint.enabled			:=	true;
	self.btnReportOptions.enabled	:=	true;
	self.btnCancelBase.enabled		:=	true;
	self.btnNew.enabled				:=	true;
	self.btnTranslations.enabled	:=	true;
	self.btnExchangeSum.enabled		:=	true;
	
	self.btnNewCargo.enabled := app.myCurrentUserCan(self.myTerminal, PmShipPrenoteMaint ); //02 Sep 2019	NDL	TFS 46317
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		//self.btnShowSearch.enabled	:= false;		//-TFS2974
		self.btnShowSearch.enabled		:= true;		//+TFS2974
		self.btnSelectAll.enabled		:= false;
		self.btnEdit.enabled			:= false;
		//self.btnEditGV.enabled		:= false;		//jlgka1 TFS 45620
		//self.btnPrint.enabled			:= false;		//-TFS2974
		self.btnPrint.enabled			:= true;		//+TFS2974
		self.btnReportOptions.enabled	:= false;
		self.btnCancelBase.enabled		:= false;
		self.btnNew.enabled				:= false;
		self.btnTranslations.enabled	:= false;
		self.btnExchangeSum.enabled		:= false;
		self.btnCopyVoyage.enabled		:= false;
		self.btnArchive.enabled			:= false;
		self.mnuArchiveVoyage.enabled 	:= false;
		self.btnCustomsEDI.enabled		:= false;
		self.btnKPIUpdate.enabled		:= false;
		self.mnuCopyVoyage.enabled		:= false;
		self.mnuAddVoyage.enabled		:= false;
		self.mnuEditVoyage.enabled		:= false;
		self.mnuHarbourInvoices.enabled := false;
		self.btnNewCargo.enabled		:= false;   // TFS 2734
		self.mnuBargeBulkCopy.enabled	:= false;	//27 May 2020	NDL	TFS 49417
		self.mnuBargeBulkCreate.enabled	:= false;	//27 May 2020	NDL	TFS 49417
		self.mnuBargeVessChg.enabled	:= false;	//27 May 2020	NDL	TFS 49417
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableSearcherControls" id="d750254b-d7f5-4988-8e44-09a6d00c3949">
        <source>setEnableSearcherControls(_cntr : Control);
//--------------------------------------------------
// Created:	31 August 2005 By: cnwgd1
// 03 Jun 2020 cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
//--------------------------------------------------
begin
	if _cntr = self.ckbAll then
		if self.ckbAll.value then
			self.ckbArchived.value		:=	true;
			self.ckbFuture.value		:=	true;
			self.ckbArchived.readOnly	:=	true;
			self.ckbFuture.readOnly		:=	true;
			self.ckbIncludeCancel.value	:= 	true;  //cnwrd1 par 23993 24.5.2010 CCMS 1928
			self.chkNoDates.value		:=	false;
			self.chkNoDates.readOnly	:=	false;
			self.ckbIncludeDeparted.value		:=	true;	//02 Jun 2020	NDL	TFS 49417
			self.ckbIncludeDeparted.readOnly	:=	true;	//02 Jun 2020	NDL	TFS 49417
		else
			self.ckbArchived.value		:=	false;
			self.ckbFuture.value		:=	false;
			self.ckbArchived.readOnly	:=	false;
			self.ckbFuture.readOnly		:=	false;
			self.chkNoDates.value		:=	false;
			self.chkNoDates.readOnly	:=	false;
			self.ckbIncludeCancel.value	:= 	false;  //cnwrd1 par 23993 24.5.2010 CCMS 1928
			self.ckbIncludeDeparted.value		:=	false;	//02 Jun 2020	NDL	TFS 49417
			self.ckbIncludeDeparted.readOnly	:=	false;	//02 Jun 2020	NDL	TFS 49417
		endif;
	
	elseif _cntr = self.txtVoyageCode then
		if self.txtVoyageCode.text &lt;&gt; null then
			self.grpDateRange.enabled		:=	false;
			self.grpSearch.enabled			:=	false;
			self.lstTerminals.enabled		:=	false;
			self.cmbFilterVessel.enabled	:=	false;
			self.lstStatus.enabled			:=	false;	//02 Jun 2020	NDL	TFS 49417
		else
			self.grpDateRange.enabled		:=	true;
			self.grpSearch.enabled			:=	true;
			self.lstTerminals.enabled		:=	true;
			self.cmbFilterVessel.enabled	:=	true;
			self.lstStatus.enabled			:=	true;	//02 Jun 2020	NDL	TFS 49417
			self.ckbArchived.readOnly		:=	false;
			self.ckbFuture.readOnly			:=	false;
			self.chkNoDates.readOnly		:=	false;
			self.ckbIncludeDeparted.value			:=	false;	//02 Jun 2020	NDL	TFS 49417
			self.ckbIncludeDeparted.readOnly		:=	false;	//02 Jun 2020	NDL	TFS 49417
		endif;
	elseif _cntr = self.txtVoyageGroupCode then        //03/06/2020 cnwma1 Tfs #49400
		if self.txtVoyageGroupCode.text &lt;&gt; null then
			self.grpDateRange.enabled		:=	false;
			self.grpSearch.enabled			:=	false;
			self.lstTerminals.enabled		:=	false;
			self.cmbFilterVessel.enabled	:=	false;
			self.lstStatus.enabled			:=	false;	
		else
			self.grpDateRange.enabled		:=	true;
			self.grpSearch.enabled			:=	true;
			self.lstTerminals.enabled		:=	true;
			self.cmbFilterVessel.enabled	:=	true;
			self.lstStatus.enabled			:=	true;	
			self.ckbArchived.readOnly		:=	false;
			self.ckbFuture.readOnly			:=	false;
			self.chkNoDates.readOnly		:=	false;
			self.ckbIncludeDeparted.value	:=	false;	
			self.ckbIncludeDeparted.readOnly:=	false;	
		endif;
	endif;
end;</source>
        <Parameter name="_cntr" type="Control"/>
    </JadeMethod>
    <JadeMethod name="setFilterDefaults" id="1bd35283-93eb-4f27-a5a1-c7619f558e5c">
        <updating/>
        <source>setFilterDefaults(_setDefaults : Boolean)updating;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
// 25 Apr 2022 navhl20 TFS 53352 EUP - Voyage External Reference Field Usability - UI
//--------------------------------------------------
vars
	now : Date;
	
begin
	self.txtVoyageCode.text			:=	null;
	self.txtVoyageExtCode.text := null;         //25 Apr 2022 navhl20 TFS 53352
	self.txtVoyageExtRef.text := null;			//25 Apr 2022 navhl20 TFS 53352
	//self.cmbVoyageStatus.listIndex	:=	-1;
	self.lstStatus.clearSelected();//02 Jun 2020	NDL	TFS 49417
	self.cmbFilterVessel.listIndex	:=	-1;
	
	if (not self.initialising) then
		self.ckbAll.value				:=	false;
		self.ckbArchived.value			:=	false;
		self.chkNoDates.value			:=	false;
		self.ckbIncludeCancel.value		:=	false;			// cnwrl1 28/06/2010 PAR 24764
		self.filterArchivedVoyages		:=	false;
		self.dateArrivalsFrom.text		:=	null;
		self.dateArrivalsTo.text		:=	null;
		self.dateDepartFrom.text 		:=	null;
		self.dateDepartTo.text			:=	null;
		self.dateInPortFrom.text		:=	null;
		self.dateInPortTo.text			:=	null;
		// set in port date range
		self.filterDateInPortFrom		:=	null;
		self.filterDateInPortTo			:=	null;
		// set arrivals date range
		self.filterDateArrivalsFrom		:=	null;
		self.filterDateArrivalsTo		:=	null;
		// set departures date range
		self.filterDateDeparturesFrom	:=	null;
		self.filterDateDeparturesTo		:=	null;
		
		if _setDefaults then
			self.ckbFuture.value	:=	true;
			self.btnTodayInPort.click(self.btnTodayInPort);
		else
			self.lstTerminals.clearAllSelected();
			self.ckbFuture.value	:=	false;
		endif;
	endif;
	
	self.allSelectedTerminals.clear();
	
	if self.lstTerminals.allSelectedObjects.size &gt; 0 then
		self.lstTerminals.allSelectedObjects.copy(self.allSelectedTerminals);
		self.myAssistant.listTableTerminal(self.lstTerminals, true, true, app.myRoot.allTerminals, self.allSelectedTerminals);
	else
		self.allSelectedTerminals.add(self.myTerminal);
		self.myAssistant.listTableTerminal(self.lstTerminals, true, true, app.myRoot.allTerminals, self.allSelectedTerminals);
	endif;

	if (not app.myRoot.isMultiTerminal()) then
		//User only has access to one terminal so hide terminal filter
		self.lstTerminals.visible	:=	false;
		self.lblTerminals.visible	:=	false;
		self.frmSearch.height := self.lstTerminals.top;
	else
		self.lstTerminals.visible	:=	true;
		self.lblTerminals.visible	:=	true;
		self.frmSearch.height		:=	self.lstTerminals.top + self.lstTerminals.height+20;
	endif;
end;</source>
        <Parameter name="_setDefaults" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSearchToolbar" id="7bf9743e-c266-4e10-a2aa-fd1f18e7732e">
        <source>setSearchToolbar();
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 20 April 2006
// 02 Jun 2020	NDL	TFS 49417
// 03 Jun 2020  cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 21 Apr 2022 navhl20 TFS 53352 EUP - Voyage External Reference Field Usability - UI
//----------------------------------------------------------------------

vars
	voyageTop,
	vesselTop,
	voyageGrpTop,
	voyStatusTop,
	voyageExtCode,
	voyageExtRef   :	Real;
	
begin
	//What is the main toolbar doing?
	self.frmSearchToolbar.showCaptions := self.frmToolbar.showCaptions;
	
	//Set the height of the framce according to caption status so we have room for controls.
	if self.frmSearchToolbar.showCaptions then
		self.frmSearch.height := ToolbarCaptionsHeight;
	else
		self.frmSearch.height := ToolbarNoCaptionsHeight;
	endif;
	
	//Voyage code label and textbox position is based on what the toolbar height is
	voyageTop := self.frmSearchToolbar.top + self.frmSearchToolbar.height + 4;
	self.lblVoyageCode.top := voyageTop;
	self.txtVoyageCode.top := voyageTop;
	
	//Vessel code label and combo position based on what the voyage code position is
	vesselTop := self.txtVoyageCode.top + self.txtVoyageCode.height + 4;
	self.lblVessel.top := vesselTop;
	self.cmbFilterVessel.top := vesselTop;
	
	//03/06/2020 cnwma1 Tfs #49400
	voyageGrpTop := self.cmbFilterVessel.top + self.cmbFilterVessel.height + 4;
	self.lblVoyageGrpCode.top   := voyageGrpTop;
	self.txtVoyageGroupCode.top := voyageGrpTop;
	
	//Start 21 Apr 2022 navhl20 TFS 53352
	voyageExtCode := self.txtVoyageGroupCode.top + self.txtVoyageGroupCode.height + 4;
	self.lblVoyageExtCode.top   := voyageExtCode;
	self.txtVoyageExtCode.top := voyageExtCode;
	
	voyageExtRef := self.txtVoyageExtCode.top + self.txtVoyageExtCode.height + 4;
	self.lblVoyageExtRef.top   := voyageExtRef;
	self.txtVoyageExtRef.top := voyageExtRef + 4;
	//End 21 Apr 2022 navhl20 TFS 53352
	
	//Voyage status lable and combo position
	//voyStatusTop := voyageGrpTop + self.txtVoyageExtRef.height + 10;    //03/06/2020 cnwma1 Tfs #49400
	voyStatusTop := voyageExtRef + self.txtVoyageExtRef.height + 10;      //TFS 53352
	self.lblVoyageStatus.top := voyStatusTop;
	
	self.lstStatus.top := voyStatusTop + self.lblVoyageStatus.height; 
//	self.cmbVoyageStatus.top := voyStatusTop;
	
	//Search details postion
	//self.grpSearch.top := self.lstStatus.top + self.lstStatus.height + 4;     //TFS 53352
	self.grpSearch.top := voyageTop;											//TFS 53352
	
	//Date range position
	self.grpDateRange.top := self.grpSearch.top + self.grpSearch.height + 6;
	
	self.lblTerminals.top := self.grpDateRange.top + self.grpDateRange.height + 2;
	
	self.lstTerminals.top := self.lblTerminals.top + self.lblTerminals.height;
	
	self.ckbNoQueryOnStartUp.top := self.lstTerminals.top + self.lstTerminals.height + 4;
	
	self.frmSearch.height := self.ckbNoQueryOnStartUp.top + self.ckbNoQueryOnStartUp.height + 16;
	
	self.lstStatus.height := self.frmSearch.clientHeight - self.lstStatus.top - 20;//TFS 53352 NAVAB1 20MAY2022
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setSelectedVoyage" id="397811af-9644-4ada-a681-8c7bdf36a5d9">
        <updating/>
        <source>setSelectedVoyage(_voyage : CM_Voyage)updating;
//--------------------------------------------------
// Created:	15 July 2005 By: cnwgd1
//--------------------------------------------------
// 20 Apr 2022  navtnr20	TFS 53142 Cargo Forecast on Voyage &amp; Train
// 04 Jul 2024	navnk30	ChangeRequest 64613: NSW - Auto Voyage Configuration. Task 64639.
vars
	autoVoy : Boolean;
begin
	self.picVessel.picture := null;
	self.myCurrentVoyage := _voyage;
	// Display extra information table
	self.displayExtraInfo();
	
	// Display vessel picture
	if self.myCurrentVoyage &lt;&gt; null then
		self.btnKPIUpdate.caption := "Update KPI statistics for '" &amp; self.myCurrentVoyage.code &amp; "'";
		self.picVessel.picture := self.myCurrentVoyage.bitmap;
		self.setNavigatorHeading(self.myCurrentVoyage.getDisplayDetails(false));
		
		// PAR 20197
		self.btnKPIUpdate.enabled := (self.myCurrentVoyage.myCellularVoyageStructure &lt;&gt; null);
		self.btnKPIView.enabled := self.btnKPIUpdate.enabled;
		
		//Cargo Forecast Form 
		self.btnCargoForecast.enabled := true;			//20-Apr-2022 TFS 53142
		self.btnCargoForecast.userObject := _voyage;	//20-Apr-2022 TFS 53142
		
		if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myVoyageProcess &lt;&gt; null then										//navra1 - BUG 66128 - 17th Sep 2024
			autoVoy := self.myCurrentVoyage.myVoyageProcess.isAutomaticProcess(); // ### TFS CR 64612 TASK 64659 18JUL2024 NAVAB1
		endif;																														//navra1 - BUG 66128 - 17th Sep 2024
		
		self.btnAutoVoyageConfig.visible := autoVoy; //04.07.2024 navnk30 CR #64613 Task #64639
		self.btnAutoVoyageProgress.visible := autoVoy; // ### TFS CR 64612 TASK 64659 18JUL2024 NAVAB1

	else
		self.setNavigatorHeading(self.caption);	
	endif;
	
	self.setControlsForView();
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="4410e3d3-3caa-4d7d-afc5-404b89dacaa6">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	rowIdx : Integer;
begin

	//inheritMethod(_theTable);
	self.displayVoyages();
	if self.tblData.findObjectInRow(self.myCurrentVoyage, rowIdx) then
		self.tblData.selectRow(rowIdx, false);
	endif;
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="66d140e7-bf05-427d-9bf0-485d1bfe626d">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
// 24/02/2017 	cnwrh7      TFS3464       #- Voyage definition / voyage status
// 15/03/2018	jlgdap1		TFS 37427 PEL1 Voyage Status Enhancements
// 04 Mar 2022  navgm20     TFS #53051 MTN - Add Filter to Vessel Enquiry, Voyage Enquiry
// 20 Apr 2022  navtnr20	TFS 53142 Cargo Forecast on Voyage &amp; Train
vars

begin
	inheritMethod();

	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.initTblData();	
	self.setFilterDefaults(true);

	self.setNavigatorHeading(self.caption);

	self.cmbFilterVessel.isVesselComboByName := self.myTerminal.getConfig(VesselComboByName).Boolean;
	
	self.doBuildCmbStatus( true );			// TFS 37427
	
	self.beginClassNotification(CM_Voyage, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_Voyage, false, Object_Update_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_Voyage, false, Object_Delete_Event, Response_Continuous, 0);	
	
	// not use on this form, disable 
	self.btnSaveBase.enabled := false;
	//25/06/2024	navkc1 CR 64823 Task 64824 //self.btnClearFilter.enabled:= false; 	// TFS 53051
	self.btnCargoForecast.enabled := false; // TFS 53142
	
	self.frmTableFilter.setupControl(self.tblData, null); //05/06/2024	navkc1 CR 63736 Task 63770
	self.frmTableFilter.setCallbackMethod(SHP_VoyageEnquiryForm::doFilterTable.name); //05/06/2024	navkc1 CR 63736 Task 63770
end;</source>
