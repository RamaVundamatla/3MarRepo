        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConfigCodeNiceName" id="7ec0629f-c578-4d58-ba23-584120872c3c">
        <source>getConfigCodeNiceName( _codeString : String; _short : Boolean ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2011	cnwndl1	Initial creation
*/
// 28 May 2013		cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
// 05 Nov 2019		jlgmd1	TFS 47321 Show an error if External Code is modified and terminal config says it shouldn't

vars

	entDef : EntTableDef;
	entRow : EntTableRow;
	tabName : String;
	match : Boolean;
	index : Integer;

begin
	
	foreach index in 1 to 12 do 
		if index = 1 then
			//Settings sheet;
			tabName := "Settings";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalSettings];
		elseif index = 2 then
			//Gate sheet;
			tabName := "Gate";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_GateConfig];
		elseif index = 3 then
			//Defaults sheet;
			tabName := "Defaults";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalDefaultsConfig];
		elseif index = 4 then
			//Financial sheet;
			tabName := "Financial";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalFinancial];
		elseif index = 5 then
			//cams sheet;
			tabName := "Cams";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_CamsConfig];
		elseif index = 6 then
			//edi  sheet
			tabName := "EDI";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_EDIConfig];
		elseif index = 7 then
			//logs
			tabName := "Log Specific";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalLogSpecific];
		elseif index = 8 then
			//ship
			tabName := "Ship Sequencing";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_ShipSettings];
		elseif index = 9 then
			//rail
			tabName := "Rail";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RailConfig];
		elseif index = 10 then
			//reefer
			tabName := "refCon";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RefConConfig];
		elseif index = 11 then
			//email receive
			tabName := "Email Read Server";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_EmailReadServerConfig];
			
		elseif index = 12 then
			tabName := "VGM";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VGMConfig];
		endif;
		
		if entDef &lt;&gt; null then
			foreach entRow in entDef.allEntTableRows do
				match := false;
				if entRow.name.toUpper.pos(_codeString.toUpper,1) &gt; 0 then
					match := true;
				elseif entRow.getRawHeadingValue.toUpper.pos(_codeString.toUpper,1) &gt; 0 then
					match := true;
				endif;
				if match then
					if not _short then
						return "Terminal Config, " &amp; tabName &amp; " tab, '" &amp; entRow.getRawHeadingValue &amp; "'";
					else
						return entRow.getRawHeadingValue;
					endif;
				endif;
			endforeach;
		endif;
	
	endforeach;
		
	foreach index in 1 to 4 do 
		if index = 1 then
			//Settings sheet;
			tabName := "Defaults";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RootDefaults];
		elseif index = 2 then
			//Security sheet;
			tabName := "Security";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_SecurityConfig];
		elseif index = 3 then
			//Auto Admin sheet;
			tabName := "Auto Admin";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_AutoConfig];
		elseif index = 4 then
			//Email sheet;
			tabName := "Email Server";
			entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_EmailServerConfig];
		endif;
		
		if entDef &lt;&gt; null then
			foreach entRow in entDef.allEntTableRows do
				match := false;
				if entRow.name.toUpper.pos(_codeString.toUpper,1) &gt; 0 then
					match := true;
				elseif entRow.getRawHeadingValue.toUpper.pos(_codeString.toUpper,1) &gt; 0 then
					match := true;
				endif;
				if match then
					if not _short then
						return "System Config, " &amp; tabName &amp; " tab, '" &amp; entRow.getRawHeadingValue &amp; "'";
					else
						return entRow.getRawHeadingValue;
					endif;
				endif;
			endforeach;
		endif;
	
	endforeach;

	return _codeString;

epilog

end;</source>
        <Parameter name="_codeString" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConfigLMWidth" id="e831999e-9c67-4bd8-96fa-b49cdc8f0387">
        <source>getConfigLMWidth() : Decimal;
/*
