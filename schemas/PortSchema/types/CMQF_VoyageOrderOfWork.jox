    <JadeMethod name="filterObjects" id="01ddbfda-f5e8-4bc9-b272-0154cb11b0c8">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     22 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	jobTITotals 		: CMIF_JobTITotals;
	jobArray			: CM_JobArray;
	job					: CM_Job;
	voyageJob			: CM_VoyageJob;
	voy					: CM_Voyage;
	querySelf			: CMQF_VoyageOrderOfWork;
	firstTime			: Boolean;
	breakOut			: Boolean;
	lashTotal			: Integer;
begin
	querySelf := self;
	voy := querySelf.getMyVoyage;
	if voy = null then
		return;
	endif;
	
	create jobArray transient;
	querySelf.populateVoyageJobs(jobArray);

	firstTime := true;

	foreach job in jobArray do
		voyageJob := job.CM_VoyageJob;

		if voyageJob.isHatchLidJob and self.hideNonCargoJobs then
			continue;
		endif;
		
		// ccms1052 cnwvu1 - to organize HATCH LID job comment on a report
		if firstTime and voyageJob.isHatchLidJob() and self.doHatchLidJobRemarks then
			self.hatchLidJobRemarks := app.getErrorString(FirstJobIsHatchLid) &amp; CrLf &amp; CrLf &amp; 
									"' " &amp; voyageJob.getRemarks() &amp; " '";
		endif;
		firstTime := false;
		
		create jobTITotals transient;
		jobTITotals.myJob := voyageJob;
		voyageJob.getJobTITotals(jobTITotals);
		
		//get cage lash details	
		
		//epr 4/8/2011 found while looking at CCMS 1033 cage with last totals always return 0 when true passed in
		//voyageJob.getCageWithLashTotal(voyageJob.getColourCodeType(),true,lashTotal);
		jobTITotals.cageWithLashTotals := 0;
		voyageJob.getCageWithLashTotal(lashTotal);
		jobTITotals.cageWithoutLashTotals := lashTotal;

		querySelf.numFound := querySelf.numFound + 1;
		querySelf.numSearched := querySelf.numSearched + 1;

		querySelf.checkStatusIncludesObject(null, _passport, breakOut);
		
		querySelf.totalSelfFromVoyageJob(jobTITotals);
		_collection.add(jobTITotals);
	endforeach;
	

epilog
	delete jobArray;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getJobTypeDescription" id="46befe21-612e-4360-8ede-9175413202bf">
        <source>getJobTypeDescription() : String;
// ---------------------------------------------------------------------------
// Created:     22 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.jobType = self.JobType_All then
		return 'All Jobs';
	elseif self.jobType = self.JobType_Unallocated then
		return 'Unallocated';
	elseif self.jobType = self.JobType_Crane then
		return 'Crane ' &amp; self.craneId.String;
	elseif self.jobType = self.JobType_PartComplete then
		return 'Part Complete';
	elseif self.jobType = self.JobType_Complete then
		return 'Complete';
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="populateVoyageJobs" id="8218004d-3438-466f-83ba-cdb6b8f7f149">
        <source>populateVoyageJobs(_jobArray : CM_JobArray input) protected;
// ---------------------------------------------------------------------------
// Created:     22 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	jobSheet			: CM_VoyageJobSheet;
	job					: CM_Job;
	voy					: CM_Voyage;
	doSort : Boolean;
	sortJobs 			: CM_VoyageJobByJobNumDict;

begin
	if _jobArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Job Array passed in was null');
		return;
	endif;

	voy := self.getMyVoyage;	
	//epr par 18381 29/10/08
	voy.getOOWJobs(self.jobType,self.craneId,self.hideNonCargoJobs,_jobArray);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_jobArray" type="CM_JobArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="totalSelfFromVoyageJob" id="53721cde-014b-421e-b8e6-7d026485c660">
        <updating/>
        <source>totalSelfFromVoyageJob(_tiTotals : CMIF_JobTITotals) updating;
// ---------------------------------------------------------------------------
// Created:     31 July 2003		cnwth2	
//
// Purpose:  
// cnwgb1 Anything with a 30, 45 or 53 in it is added for PAR 16415 3 June 2008   		 
// ----------   ----------  --------------------------------------------------
vars
	queryObj		: CMQF_VoyageOrderOfWork;
begin
	queryObj := self;
	if _tiTotals.myJob.isDischarge or _tiTotals.myJob.isSOB() then 
	
		queryObj.total20DischargeFull		:= queryObj.total20DischargeFull + _tiTotals.numFull20;
		queryObj.total20DischargeMty		:= queryObj.total20DischargeMty + _tiTotals.numEmpty20;
		queryObj.total20DischargeDLRFull	:= queryObj.total20DischargeDLRFull + _tiTotals.numFull20RH;
		queryObj.total20DischargeDLRMty		:= queryObj.total20DischargeDLRMty + _tiTotals.numEmpty20RH;
		
		queryObj.total30DischargeFull		:= queryObj.total30DischargeFull + _tiTotals.numFull30;
		queryObj.total30DischargeMty		:= queryObj.total30DischargeMty + _tiTotals.numEmpty30;
		queryObj.total30DischargeDLRFull	:= queryObj.total30DischargeDLRFull + _tiTotals.numFull30RH;
		queryObj.total30DischargeDLRMty		:= queryObj.total30DischargeDLRMty + _tiTotals.numEmpty30RH;

		queryObj.total40DischargeFull		:= queryObj.total40DischargeFull + _tiTotals.numFull40;
		queryObj.total40DischargeMty		:= queryObj.total40DischargeMty + _tiTotals.numEmpty40;
		queryObj.total40DischargeDLRFull	:= queryObj.total40DischargeDLRFull + _tiTotals.numFull40RH;
		queryObj.total40DischargeDLRMty		:= queryObj.total40DischargeDLRMty + _tiTotals.numEmpty40RH;
	
		queryObj.total45DischargeFull		:= queryObj.total45DischargeFull + _tiTotals.numFull45;
		queryObj.total45DischargeMty		:= queryObj.total45DischargeMty + _tiTotals.numEmpty45;
		queryObj.total45DischargeDLRFull	:= queryObj.total45DischargeDLRFull + _tiTotals.numFull45RH;
		queryObj.total45DischargeDLRMty		:= queryObj.total45DischargeDLRMty + _tiTotals.numEmpty45RH;

		queryObj.total53DischargeFull		:= queryObj.total53DischargeFull + _tiTotals.numFull53;
		queryObj.total53DischargeMty		:= queryObj.total53DischargeMty + _tiTotals.numEmpty53;
		queryObj.total53DischargeDLRFull	:= queryObj.total53DischargeDLRFull + _tiTotals.numFull53RH;
		queryObj.total53DischargeDLRMty		:= queryObj.total53DischargeDLRMty + _tiTotals.numEmpty53RH;
		
		queryObj.totalDischargeBreakBulk 	:= queryObj.totalDischargeBreakBulk + _tiTotals.numBBLK; // PAR 31756  now a mapping method
		queryObj.totalDischargeBreakBulkDLR := queryObj.totalDischargeBreakBulkDLR +  _tiTotals.numBBLKRH; // PAR 31756  now a mapping method
		queryObj.totalDischargeTimber		:= queryObj.totalDischargeTimber + _tiTotals.numTimber; // PAR 31756  now a mapping method
		queryObj.totalDischargeTimberDLR	:= queryObj.totalDischargeTimberDLR + _tiTotals.numTimberRH; // PAR 31756  now a mapping method
		queryObj.totalDischargeOther		:= queryObj.totalDischargeOther + 0;  // PAR 31756 _tiTotals.numMisc;
		queryObj.totalDischargeOtherDLR		:= queryObj.totalDischargeOtherDLR + 0;  // PAR 31756  _tiTotals.numMiscRH;	
	
	else
		
		queryObj.total20LoadingFull			:= queryObj.total20LoadingFull + _tiTotals.numFull20;
		queryObj.total20LoadingMty			:= queryObj.total20LoadingMty + _tiTotals.numEmpty20;
		queryObj.total20LoadingDLRFull		:= queryObj.total20LoadingDLRFull + _tiTotals.numFull20RH;
		queryObj.total20LoadingDLRMty		:= queryObj.total20LoadingDLRMty + _tiTotals.numEmpty20RH;
		
		queryObj.total30LoadingFull			:= queryObj.total30LoadingFull + _tiTotals.numFull30;
		queryObj.total30LoadingMty			:= queryObj.total30LoadingMty + _tiTotals.numEmpty30;
		queryObj.total30LoadingDLRFull		:= queryObj.total30LoadingDLRFull + _tiTotals.numFull30RH;
		queryObj.total30LoadingDLRMty		:= queryObj.total30LoadingDLRMty + _tiTotals.numEmpty30RH;
		
		queryObj.total40LoadingFull			:= queryObj.total40LoadingFull + _tiTotals.numFull40;
		queryObj.total40LoadingMty			:= queryObj.total40LoadingMty + _tiTotals.numEmpty40;
		queryObj.total40LoadingDLRFull		:= queryObj.total40LoadingDLRFull + _tiTotals.numFull40RH;
		queryObj.total40LoadingDLRMty		:= queryObj.total40LoadingDLRMty + _tiTotals.numEmpty40RH;
	
		queryObj.total45LoadingFull			:= queryObj.total45LoadingFull + _tiTotals.numFull45;
		queryObj.total45LoadingMty			:= queryObj.total45LoadingMty + _tiTotals.numEmpty45;
		queryObj.total45LoadingDLRFull		:= queryObj.total45LoadingDLRFull + _tiTotals.numFull45RH;
		queryObj.total45LoadingDLRMty		:= queryObj.total45LoadingDLRMty + _tiTotals.numEmpty45RH;
	
		queryObj.total53LoadingFull			:= queryObj.total53LoadingFull + _tiTotals.numFull53;
		queryObj.total53LoadingMty			:= queryObj.total53LoadingMty + _tiTotals.numEmpty53;
		queryObj.total53LoadingDLRFull		:= queryObj.total53LoadingDLRFull + _tiTotals.numFull53RH;
		queryObj.total53LoadingDLRMty		:= queryObj.total53LoadingDLRMty + _tiTotals.numEmpty53RH;
	
		queryObj.totalLoadingBreakBulk 		:= queryObj.totalLoadingBreakBulk +  _tiTotals.numBBLK; // PAR 31756  now a mapping method
		queryObj.totalLoadingBreakBulkDLR 	:= queryObj.totalLoadingBreakBulkDLR + _tiTotals.numBBLKRH; // PAR 31756  now a mapping method
		queryObj.totalLoadingTimber			:= queryObj.totalLoadingTimber + _tiTotals.numTimber; // PAR 31756  now a mapping method
		queryObj.totalLoadingTimberDLR		:= queryObj.totalLoadingTimberDLR + _tiTotals.numTimberRH; // PAR 31756  now a mapping method
		queryObj.totalLoadingOther			:= queryObj.totalLoadingOther + 0; // PAR 31756 _tiTotals.numMisc;
		queryObj.totalLoadingOtherDLR		:= queryObj.totalLoadingOtherDLR + 0; // PAR 31756 _tiTotals.numMiscRH;
	endif;	
	
	queryObj.total20SOBFull	:= queryObj.total20SOBFull + _tiTotals.numFull20SOB;
	queryObj.total20SOBMty	:= queryObj.total20SOBMty + _tiTotals.numEmpty20SOB;

	queryObj.total30SOBFull	:= queryObj.total30SOBFull + _tiTotals.numFull30SOB;
	queryObj.total30SOBMty	:= queryObj.total30SOBMty + _tiTotals.numEmpty30SOB;

	queryObj.total40SOBFull	:= queryObj.total40SOBFull + _tiTotals.numFull40SOB;
	queryObj.total40SOBMty	:= queryObj.total40SOBMty + _tiTotals.numEmpty40SOB;

	queryObj.total45SOBFull	:= queryObj.total45SOBFull + _tiTotals.numFull45SOB;
	queryObj.total45SOBMty	:= queryObj.total45SOBMty + _tiTotals.numEmpty45SOB;

	queryObj.total53SOBFull	:= queryObj.total53SOBFull + _tiTotals.numFull53SOB;
	queryObj.total53SOBMty	:= queryObj.total53SOBMty + _tiTotals.numEmpty53SOB;

	queryObj.totalLifts 	:= queryObj.totalLifts + _tiTotals.totalLifts; // CCMS1527
	
end;</source>
        <Parameter name="_tiTotals" type="CMIF_JobTITotals"/>
    </JadeMethod>
</Class>
