    <JadeMethod name="setPointsPolygon" id="3e4af496-2c86-4035-9c2b-4a96b775ffe6">
        <updating/>
        <source>setPointsPolygon(_newPoints : PointArray) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin 
	self.pointsPolygon.clear;
	if _newPoints &lt;&gt; null then
		_newPoints.copy(self.pointsPolygon);
	endif;
end;</source>
