    <JadeMethod name="setForCreate" id="938a8626-87bb-40c4-b085-68a59169edbe">
        <updating/>
        <source>setForCreate(_extWebService : CM_ExternalWebServiceDef) updating;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars

begin
	_extWebService.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_extWebService);
	self.myRoot := app.myRoot;
epilog

end;</source>
        <Parameter name="_extWebService" type="CM_ExternalWebServiceDef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d6befc79-2b98-4958-9dc5-9b5785071e00">
        <updating/>
        <source>setForUpdate(_extWebService : CM_ExternalWebServiceDef) updating;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
// 17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
// 05 Dec 2025  navsp1  MTN-36362 NSW | OnePort API Last Run Date - Add a Last Successful Date/Time to Web Service Definition
vars
	pxyEndpoint, endpoint : CM_Endpoint;
	endpointsToDelete, lastDTToDelete : ObjectArray;
    lastDT, pxyLastDT          : CM_EWSTerminalLastSuccessDT;
    iter                       : Iterator;  //MTN-36362
    terminalCode               : String;    //MTN-36362
begin
	self.active := _extWebService.active;
	self.baseEndpoint := _extWebService.baseEndpoint;
	self.maxRetries := _extWebService.maxRetries;
	self.name := _extWebService.name;
	self.password := _extWebService.password;
	self.timeBetweenRetries := _extWebService.timeBetweenRetries;
	self.userCode := _extWebService.userCode;
	self.timeoutSeconds := _extWebService.timeoutSeconds;
	self.versionString	:=_extWebService.versionString; //epr TFS 45207
	self.raiseAlertOnFailure := _extWebService.raiseAlertOnFailure;	//14.feb.24 navsp1 TFS 62068
	
	create endpointsToDelete transient;
	foreach endpoint in self.allEndpoints where _extWebService.allEndpoints[endpoint.defName] = null do
		endpointsToDelete.add(endpoint);
	endforeach;
	foreach pxyEndpoint in _extWebService.allEndpoints do
		endpoint := self.allEndpoints[pxyEndpoint.defName];
		if endpoint = null then
			create endpoint persistent;
		endif;
		endpoint.setProxy(pxyEndpoint.defName, pxyEndpoint.endpoint, pxyEndpoint.verb, self);
	endforeach;
	endpointsToDelete.purge;
    
    //Last Successful DT                                                                                //MTN-36362
    iter := _extWebService.allTerminalLastSuccessDT.createIterator;                                     //MTN-36362
    while iter.next(pxyLastDT) do                                                                       //MTN-36362
        iter.getCurrentKeys(terminalCode);                                                              //MTN-36362
        lastDT := self.allTerminalLastSuccessDT[terminalCode];                                          //MTN-36362
        if lastDT = null then                                                                           //MTN-36362
            create lastDT persistent;                                                                   //MTN-36362
        endif;                                                                                          //MTN-36362
        lastDT.setProxy(pxyLastDT.lastSuccessDt, self, pxyLastDT.myTerminal);                           //MTN-36362
    endwhile;                                                                                           //MTN-36362
epilog
	delete endpointsToDelete;
    delete iter;                                                                                        //MTN-36362
end;</source>
        <Parameter name="_extWebService" type="CM_ExternalWebServiceDef"/>
    </JadeMethod>
