    <JadeMethod name="tGateOutTrailer" id="9c452df8-b685-4235-a791-2c59a1499808">
        <source>tGateOutTrailer();
/*

Date		Who		Reason
08 July 2013	cnwer1	Initial creation CCMS DPH 2274
10 March 2023	jlika1	Add width to trailer.
*/

constants
	Cargo_Type = "UTCHAS";
	TrailerType ="UTTT20";
	TruckID = "UTCHAS";
	TrailerID = "CHAS1234";
	CargoID = "UTCHAS1234";
vars
	ct : CM_CargoType;
	tt	: CM_TILCType;
	bs1 : CM_BlockStack;
	trailer : CM_TILC;
	vvr : CM_VehicleVisitRecord;
	truck : CM_Vehicle;
	tiTrans : CM_TITransaction;
begin
	
	self.deleteAllCargo(TrailerID,ct);
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs",ProductType_Trailer);
	ct:=self.addCargoType(Cargo_Type, false);
	
	self.assertNotNull(ct);
	self.assertEqual(ct.productType,ProductType_Trailer);
	self.assertEqual(ct.myClassToCreate, CM_TILC);
	
	tt:=self.addTrailerType(TrailerType,TrailerType,ct,500,1,50,30000,13000,null,null,500);
	self.assertNotNull(tt);
	self.assertEqual(tt.numControllers,1);
	self.assertEqual(tt.width.asStringJMT,"500.0000");	
	
	bs1:=self.addBlockStack("BSCHAS",999,null);
	
	
	trailer:=self.addTrailerAtLocation(TrailerID,ct,tt,self.getOperator("PON"),bs1.myLocationsController).CM_TILC;
	self.assertNotNull(trailer);
	self.assertEqual(trailer.myPrimaryActualLocation,bs1.myLocationsController);
	self.assertEqual(trailer.width.asStringJMT,"500.0000");	
	
	self.deleteVehicle(TruckID);
	
	vvr:=self.gateOutTrailerAndContainer(TruckID,trailer,null,self.dualGate, null);
	
	truck:=self.getTerminal.vehicles[TruckID,null];
	self.assertNotNull(truck);
	self.moveVehicleToLane(vvr.vehicle, self.pin, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
	
	self.moveQueuedCargo(vvr.myOutCMGTE_Chassis.myYardRequest.allWorkListEntries.first);
	self.assertEqual(trailer.myPrimaryActualLocation,truck.locationsController); 
	
	self.roadExit(vvr);
	self.assertEqual(trailer.state, TI_STATE_OFFSITE);
	tiTrans:=trailer.getLastTransOfType(TRANS_TYPE_REL_ROAD);
	self.assertNotNull(tiTrans);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tGateOutTrailerByTypeWithCargo" id="9fc9bc24-d7d7-4d82-aff4-cd3121a73e8c">
        <source>tGateOutTrailerByTypeWithCargo();
/*

Date		Who		Reason
17 March 2014	cnwer1	Initial creation PAR
10 March 2023	jlika1	Add width to trailer.
*/

constants
	Cargo_Type = "UTCHAS";
	TrailerType ="UTTT20";
	TruckID = "UTCHAS";
	TrailerID = "CHAS1234";
	CargoID = "UTCHAS1234";
vars
	ct : CM_CargoType;
	tt	: CM_TILCType;
	bs1 : CM_BlockStack;
	trailer : CM_TILC;
	vvr : CM_VehicleVisitRecord;
	truck : CM_Vehicle;
	tiTrans : CM_TITransaction;
	container : CM_Container;
	wle : CM_WorkListEntry;
begin
	
	self.deleteAllCargo(TrailerID,ct);
	self.deleteAllCargo(CargoID,app.myRoot.getCargoTypeFromAbbrevOrDescr("CONT"));
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs",ProductType_Trailer);
	ct:=self.addCargoType(Cargo_Type, false);
	
	self.assertNotNull(ct);
	self.assertEqual(ct.productType,ProductType_Trailer);
	self.assertEqual(ct.myClassToCreate, CM_TILC);
	
	tt:=self.addTrailerType(TrailerType,TrailerType,ct,5000,1,50,30000,13000,null,null,500);
	self.assertNotNull(tt);
	self.assertEqual(tt.numControllers,1);
	self.assertEqual(tt.width.asStringJMT,"500.0000");	
	
	bs1:=self.addBlockStack("BSCHAS",999,null);
		
	trailer:=self.addTrailerAtLocation(TrailerID,ct,tt,self.getOperator("PON"),bs1.myLocationsController).CM_TILC;
	self.assertNotNull(trailer);
	self.assertEqual(trailer.myPrimaryActualLocation,bs1.myLocationsController);
	self.assertEqual(trailer.allLCs.size,1);
	self.assertEqual(trailer.width.asStringJMT,"500.0000");	
	
	container:=self.addContainerAtLocation(CargoID,self.getOperator("PON"),"2200","MT",TI_IMEX_STATUS_STORAGE,trailer.getNextFreeLC);

	
	self.deleteVehicle(TruckID);
	
	vvr:=self.gateOutTrailerByTypeAndCont(TruckID,tt,"PON",container,self.dualGate);
	
	truck:=self.getTerminal.vehicles[TruckID,null];
	self.assertNotNull(truck);
	
	
	
	//self.moveVehicleToLane(vvr.vehicle, self.pin, 1);
	
//	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.pin, 1));
		
	//self.moveVehicleToYard(vvr.vehicle);
	
	self.assignTiToRoadWLE(trailer,vvr.myOutCMGTE_Chassis.myYardRequest.allWorkListEntries.first);
	
	//self.moveQueuedCargo(vvr.myOutCMGTE_Chassis.myYardRequest.allWorkListEntries.first);
	
	
	self.assertEqual(trailer.myPrimaryActualLocation,truck.locationsController); 
	
	app.myTrxUA.trxUndoReleaseByTypeAssign(vvr.myOutCMGTE_Chassis.myYardRequest.allWorkListEntries.first,app.myPassport);
	
	self.assertEqual(trailer.myPrimaryActualLocation,bs1.myLocationsController);
	self.assertEqual(trailer.priorLocation,"Nowhere");
	
	self.assertEqual(vvr.myOutCMGTE_Chassis.myYardRequest.allWorkListEntries.first.myTrackedItem,null);
	
	self.assignTiToRoadWLE(trailer,vvr.myOutCMGTE_Chassis.myYardRequest.allWorkListEntries.first);
	
	/*self.roadExit(vvr);
	self.assertEqual(trailer.state, TI_STATE_OFFSITE);
	tiTrans:=trailer.getLastTransOfType(TRANS_TYPE_REL_ROAD);
	self.assertNotNull(tiTrans);*/

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Failing1&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tGateOutTrailerCargo" id="6e912160-09d0-45ea-a118-68cbcb67ca5d">
        <source>tGateOutTrailerCargo();
/*

Date		Who		Reason
08 July 2013	cnwer1	Initial creation CCMS DPH 2274
10 March 2023	jlika1	Add width to trailer.
*/

constants
	Cargo_Type = "UTCHAS";
	TrailerType ="UTTT20";
	TruckID = "UTCHAS";
	TrailerID = "CHAS1234";
	CargoID = "UTCHAS1234";
vars
	count	: Integer;
	ct : CM_CargoType;
	tt	: CM_TILCType;
	bs1 : CM_BlockStack;
	trailer : CM_TILC;
	vvr : CM_VehicleVisitRecord;
	truck : CM_Vehicle;
	tiTrans : CM_TITransaction;
	container : CM_Container;
	ti	: CM_TrackedItem;
begin
	
	self.deleteAllCargo(TrailerID,ct);
	self.deleteAllCargo(CargoID,app.myRoot.getCargoTypeFromAbbrevOrDescr("CONT"));
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs",ProductType_Trailer);
	ct:=self.addCargoType(Cargo_Type, false);
	
	self.assertNotNull(ct);
	self.assertEqual(ct.productType,ProductType_Trailer);
	self.assertEqual(ct.myClassToCreate, CM_TILC);
	
	tt:=self.addTrailerType(TrailerType,TrailerType,ct,500,1,50,30000,13000,null,null,500);
	self.assertNotNull(tt);
	self.assertEqual(tt.numControllers,1);
	self.assertEqual(tt.width.asStringJMT,"500.0000");	
	
	bs1:=self.addBlockStack("BSCHAS",999,null);
		
	trailer:=self.addTrailerAtLocation(TrailerID,ct,tt,self.getOperator("PON"),bs1.myLocationsController).CM_TILC;
	self.assertNotNull(trailer);
	self.assertEqual(trailer.myPrimaryActualLocation,bs1.myLocationsController);
	self.assertEqual(trailer.width.asStringJMT,"500.0000");	
	
	container:=self.addContainerAtLocation(CargoID,self.getOperator("PON"),"2200","MT",TI_IMEX_STATUS_STORAGE,trailer.getNextFreeLC);

	
	self.deleteVehicle(TruckID);
	
	vvr:=self.gateOutTrailerAndContainer(TruckID,trailer,container,self.dualGate, null);
	
	truck:=self.getTerminal.vehicles[TruckID,null];
	self.assertNotNull(truck);
	self.moveVehicleToLane(vvr.vehicle, self.pin, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(self.pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
	
	self.moveQueuedCargo(vvr.myOutCMGTE_Chassis.myYardRequest.allWorkListEntries.first);
	self.assertEqual(trailer.myPrimaryActualLocation,truck.locationsController); 
	
	self.roadExit(vvr);
	self.assertEqual(trailer.state, TI_STATE_OFFSITE);
	tiTrans:=trailer.getLastTransOfType(TRANS_TYPE_REL_ROAD);
	self.assertNotNull(tiTrans);
	// 35202 check that the VVR allReleasedTIs is still populated
	foreach ti in vvr.allReleasedTrackedItems do
		count := count + 1;
	endforeach;
	self.assertEqualMsg(count, 2, "Vehicle Visit allReleasedTrackedItem count");
epilog
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseTrailerByType" id="b57c1d9d-b80b-4129-b188-b1ab0b028eef">
        <source>tReleaseTrailerByType();
// cnwer1
/*
cnwdw1	Release a trailer by type. Trailer is in allocation with criteria of Trailer Type PAR 35575
10 March 2023	jlika1	Add width to trailer.
*/

constants
	Cargo_Type = "UTCHAS";
	TrailerType ="UTTT20";
	TruckID = "UTCHAS";
	TrailerID = "CHAS1234";
vars
	ct : CM_CargoType;
	tt	: CM_TILCType;
	bs1 : CM_BlockStack;
	trailer : CM_TILC;
	vvr : CM_VehicleVisitRecord;
	truck : CM_Vehicle;
	tiTrans : CM_TITransaction;
	wle : CM_WorkListEntry;
begin
	
	self.disableAllYA(true);
	self.deleteAllCargo(TrailerID,ct);
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs",ProductType_Trailer);
	ct:=self.addCargoType(Cargo_Type, false);
		self.assertNotNull(ct);
		self.assertEqual(ct.productType,ProductType_Trailer);
		self.assertEqual(ct.myClassToCreate, CM_TILC);
	
	tt:=self.addTrailerType(TrailerType,TrailerType,ct,5000,1,50,30000,13000,null,null,500);
		self.assertNotNull(tt);
		self.assertEqual(tt.numControllers,1);
		self.assertEqual(tt.width.asStringJMT,"500.0000");	
		
	bs1:=self.addBlockStack("BSCHAS",999,null);
		self.addYAToBlockStack("UT_YACHAS", YACriteriaType_TrailerType, tt, bs1);
	
	trailer:=self.addTrailerAtLocation(TrailerID,ct,tt,self.getOperator("PON"),bs1.myLocationsController).CM_TILC;
		self.assertNotNull(trailer);
		self.assertEqual(trailer.myPrimaryActualLocation,bs1.myLocationsController);
		self.assertEqual(trailer.allLCs.size,1);
		self.assertEqual(trailer.width.asStringJMT,"500.0000");	
		
	self.deleteVehicle(TruckID);
	
	vvr := self.gateOutTrailerByTypeAndCont(TruckID,tt,"PON",null,self.singleGate);
	
	self.assertTrue(vvr.myOutCMGTE_Chassis.myYardRequest.allWorkListEntries.first.isQueued);
	
	self.assignTiToRoadWLE(trailer,vvr.myOutCMGTE_Chassis.myYardRequest.allWorkListEntries.first);
	
	self.roadExit(vvr);
		self.assertEqual(trailer.state, TI_STATE_OFFSITE);

	tiTrans:=trailer.getLastTransOfType(TRANS_TYPE_REL_ROAD);
		self.assertNotNull(tiTrans);
epilog
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="uTest33440Test" id="360e4a1d-5e7e-4e37-bc52-9e549d671e78">
        <source>uTest33440Test();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2024	navsp1	Initial creation MTN-33440

*/
constants
	
	REF 			: String = "33440";
	CARRIERCODE 	: String = REF &amp; "CAR";
	SUBCARRIERCODE 	: String = REF &amp; "SUB";
	DRIVERID    	: String = REF &amp; "DRIVER";
	VEHICLEID   	: String = REF &amp; "VEHICLE";
	ID				: String = "IDUT" &amp; REF;
	TRAILERID 		: String = REF &amp; "TRAILER";
	SOURCE_CARGO 	: Integer= 2;
	TrailerType 	: String = REF &amp; "TT20";
	Cargo_Type 		: String = "UTCHAS";
	Trailer 		: String = REF &amp; "UTTRAILER";
	ContainerID		: String = "CNTU" &amp; REF;
	ReleaseRequestID: String = "REL" &amp; REF; 
vars
	realVbsTimeSlot,
	proxyVbsTimeSlot		: CM_VehicleBookingTimeSlot;
	vbsSlotType				: CM_VehicleBookingTimeSlotType;
	date					: Date;
	startTime,
	endTime					: TimeStamp;
	vbsTimeSlotItem			: CM_VehicleBookingTimeSlotItem;
	trackedItem				: CM_TrackedItem;
	tiStringArray			: StringArray;
	vehicleBookingTerminal	: CM_VehicleBookingTerminal;
	carrier					: CM_Carrier;
	subCarrier				: CM_Carrier;
	driver					: CM_DriverDetails;
	vehicle					: CM_Vehicle;
	allCarriers 			: CM_CarrierByCodeDict;	
	allVehicleMachines 		: CM_VehicleSet; 
	email					: CM_EmailEntityByTypeNameDict;
	bs1 					: CM_BlockStack;
	vvr,pxyVVR				: CM_VehicleVisitRecord;
	trailer 				: CM_TILC;
	tt						: CM_TILCType;
	ct 						: CM_CargoType;

	direction,		
	quantity, 
	sequence,
	sourceType				: Integer;
	pin						: CM_GateArea;
	dualGate 				: CM_Gate;
	carrierCode 			: String;
	truck 					: CM_Vehicle;
	objectArray				: ObjectArray;
	terminal 				: CM_Terminal;
	vbsProcess				: CM_VBSProcess;
	releaseRequest			: CM_BulkRelease;
	operator				: CM_Operator;
	source: CM_LocationsController;
	locations : CM_LCArray;
	ti : CM_TrackedItem;
begin	
	self.deleteVbsTimeSlotAdv(ID);
	self.deleteVbsTimeslotType(REF);
	terminal := self.getMyTerminal;
	
	//Set the vbs process to Slot Type Validation
	beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_SLVALIDATION_CODE]);//getMyVBSProcess();
	commitTransaction;
	
	/*Add location*/
	bs1:=self.addBlockStack("BS"&amp;REF,999,null);
	
	/*add cargo type*/
	app.myPassport.ignoreErrors();
	self.opts.purge;
	self.opts.addAssoc("TrackAs",ProductType_Trailer);
	self.opts.addAssoc("AllowDuplicateId", true);
	ct := self.getCargoType(Cargo_Type);
	if ct = null then
		ct:=self.addCargoType(Cargo_Type, false);
	endif;
	self.assertNotNull(ct);
	self.assertEqual(ct.productType,ProductType_Trailer);
	self.assertEqual(ct.myClassToCreate, CM_TILC);
	
	/*Add trailer type*/
	tt:=self.addTrailerType(TrailerType,TrailerType,ct,500,1,50,30000,13000,null,null,500);
	self.assertNotNull(tt);
	self.assertEqual(tt.numControllers,1);	
	self.assertEqual(tt.width.asStringJMT,"500.0000");
	
	self.deleteVehicle(VEHICLEID);
	self.deleteDriverDetails(DRIVERID);
	
	/*VBS Timeslot - Booking*/
	vehicleBookingTerminal := self.getMyTerminal.myVehicleBookingTerminal;
	vbsSlotType 		   := self.addVbsTimeslotType(REF, "Slot Type Create" &amp; REF); 	
	create proxyVbsTimeSlot transient;	
	direction  := DIRECTION_DELIVERY;
	quantity   := 0;
	sequence   := 0;
	sourceType := SOURCE_CARGO;
	self.deleteContainer(ContainerID);
	
	create vbsTimeSlotItem transient;
	
	vbsTimeSlotItem.setProxy(direction,
							null,
							null,
							null,
							null,
							trackedItem,
							proxyVbsTimeSlot,
							quantity,
							sequence,
							sourceType,
							0,
							null,
							null);	// ### TFS 61525 (61527) 11Jul2024 NAVPW1
							
	
	/* get tracked item*/
	
	create tiStringArray transient;
	
	/* create carrier and subcarrier*/
	create email transient;
	self.deleteCarrier(SUBCARRIERCODE);
	carrierCode := self.getProfileStr(UT_Profile.P_CARRIER);
	carrier := app.myRoot.allCarriers[carrierCode];
	subCarrier := self.addCarrier(SUBCARRIERCODE, SUBCARRIERCODE, email, false, true, true, null);

	/* create vehicle*/
	vehicle := self.addVehicle( VEHICLEID, carrier, self.getTerminal());
	self.assertNotNull(vehicle);
	
	/* create driver details*/
	create allCarriers transient;
	allCarriers.add(carrier);
	create allVehicleMachines transient;
	allVehicleMachines.add(vehicle);
	driver := self.createDriverDetails(DRIVERID, allCarriers, allVehicleMachines);
	
	/*Gate*/
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	/*Create vehicle booking*/
	startTime.setTime(vbsSlotType.startTime);
	startTime.setDate(date.cnEcAddDays(1));
	
	endTime.setTime(vbsSlotType.startTime.addMinutes(vbsSlotType.duration));
	endTime.setDate(date.cnEcAddDays(1));	
	
	proxyVbsTimeSlot.setProxy(startTime, endTime, vehicleBookingTerminal, carrier, subCarrier, driver, vehicle, null, true, false, tiStringArray, vvr, vbsSlotType, ID, null, null, null, false, false, vbsSlotType.kioskCheck, null, null); // 08 Aug 2024 navcs2	ChangeRequest 63928
	app.myTrxCA.trxCreateVehicleBookingAdv(proxyVbsTimeSlot, realVbsTimeSlot,false, app.myPassport);			//24.5.2023 navhl20 #58041

	/*Create VVR*/
	self.opts.purge;
	self.opts.addAssoc("Location", bs1.myLocationsController.getFullId);
	self.opts.addAssoc("VehicleBookingTS",realVbsTimeSlot);	
	vvr:=self.gateInTrailerAndContainer(VEHICLEID,Trailer,ContainerID,tt.code,"2200","ABC","FULL",dualGate);
	self.assertNotNull(vvr);
	
	truck:=self.getTerminal.vehicles[VEHICLEID,null];
	self.assertNotNull(truck);
	
	/*Trailer*/
	trailer:=vvr.myInCMGTE_Chassis.myTrackedItem.CM_TILC;
	self.assertNotNull(trailer);
	self.assertEqual(trailer.myPrimaryActualLocation,truck.locationsController); 	
	self.assertEqual(trailer.width.asStringJMT,"500.0000");
	
	/*-------------------------------------Gate IN-------------------------------------------*/ 
	pin 		:= self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);	
	self.assertNotNull(pin);
	
	/*Move vehicle to lane*/
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
	assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
		
	/*Move vehicle to yard*/
	self.moveVehicleToYard(vvr.vehicle);
	self.moveQueuedCargo(vvr.myInCMGTE_Chassis.myYardRequest.allWorkListEntries.first);
	self.assertEqual(trailer.myPrimaryActualLocation,bs1.myLocationsController); 
	
	//Create release by type request
	deleteReleaseRequest(ReleaseRequestID);
	
	//Operator ABC
	operator := app.myRoot.allOperators["ABC"];
	
	// Create the Release request by type
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("Operator", operator);
	releaseRequest := addReleaseByTypeRequestOpts(ReleaseRequestID, BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);	

	create locations transient;
	locations.add(bs1.allLocationsControllers.first.CM_YardController);
	
	//self.moveQueuedCargo(vvr.myInCMGTE_Chassis.myYardRequest.allWorkListEntries.first);
	//self.assertEqual(trailer.myPrimaryActualLocation,bs1.myLocationsController); 
	// Make sure that the expected source is found by autoplan
	//source := app.sourceTisForRequestYA(self.getTerminal(), releaseRequest.requests.first);
	//assertNotNullMsg(source, getYAAutoPlanMessages);
	//assertEqual(source.getName(), locations.first.getName());
	
	// Gate Out
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	self.opts.addAssoc("clientRef", "XXXXX");
	self.opts.addAssoc("GTERemarks", "Bob did it");	//01 Sep 2015	NDL	Par 36839
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , null);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	//assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "RT");
	//assertEqual(truck.allRoadJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.sourceLocationId, bs.id);
	
	ti := self.getTrackedItem(ContainerID);
	assertNotNull(ti);
	
	self.assignTiToRoadWLE(ti, truck.allRoadJobs.first.workListEntries.first);
	assertEqual(ti.clientRef, "");
	
	self.roadExit(vvr);
	assertEqual(ti.clientRef, "XXXXX");
	assertEqual(ti.remarks, "Bob did it");		//01 Sep 2015	NDL	Par 36839
	
	/*Road exit*/
	self.opts.purge();
	self.expectedTrxErrors.clear();
	self.roadExit(vvr);	
	
	/*Trx to delete time slot*/
	create objectArray transient;
	objectArray.add(realVbsTimeSlot);
	app.myTrxDA.trxDeleteMultiVehicleBookSlots(objectArray, app.myPassport);

epilog
	beginTransaction;
		terminal.setMyVBSProcess(app.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE]);
	commitTransaction;
	
	delete tiStringArray;
	delete allCarriers;
	delete email;
	delete allVehicleMachines;
	delete proxyVbsTimeSlot;
	delete objectArray;
	delete pxyVVR;
end;</source>
    </JadeMethod>
</Class>
