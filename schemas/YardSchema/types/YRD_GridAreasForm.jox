    <JadeMethod name="doMnuStopClick" id="5ef99c1a-3857-40bb-99d9-8efaa95cd227">
        <updating/>
        <source>doMnuStopClick( menuItem : MenuItem input ) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27/01/2010	cnwrl1		PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
// 15/06/2010	cnwcs5		par 24342 - new form for maintaining stops
// ---------------------------------------------------------------------------

