	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cargoTypeId" id="3e51b33d-699c-4ebc-992d-e2a5d0d5c02e">
        <methodInvocation>mapping</methodInvocation>
        <source>cargoTypeId(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:		13 August 2003 by cnwsb1
//
// Purpose:		Used by the Data Extract.
// ---------------------------------------------------------------------------
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.myCargoType &lt;&gt; null then
			_value := self.myCargoType.id;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetDuplicate" id="70979203-7f57-4c55-905b-998de922c72b">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	code : String;
	isotype : CM_ISOType;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if code &lt;&gt; null then
		isotype := app.myRoot.allISOTypes.getAtKey( code );
	endif;

epilog

	return isotype;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="delete" id="597644bf-54cf-4b48-8736-3eec6c0531b7">
        <updating/>
        <source>delete() updating;
// cnwrs1 june 2006 was missing
vars
	
begin

	//21 Jun 2019	NDL	TFS 44895
	if app.myAlternateDict &lt;&gt; null then
		app.myAlternateDict.setIsoTypeDictNeedsRefresh();
	endif;
	
	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152
end;</source>
    </JadeMethod>
    <JadeMethod name="displayForXlation" id="f4dd0417-24a7-4fcf-a3bd-31e804887cea">
        <source>displayForXlation(_codeFirst : Boolean) : String;

vars

begin
	if _codeFirst then
		return self.code.trimBlanks&amp;' ['&amp;self.description.trimBlanks&amp;']';
	else
		return self.description.trimBlanks&amp;' ['&amp;self.code.trimBlanks&amp;']';
	endif;
end;
</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="erase" id="d7abea09-9501-43e9-b7d2-aaf8bb254a46">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
Date		Who		Reason
25 March 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	self.exclusiveLock(self);

	self.eraseXlations (self.allXlations, NORMAL_ERASE);
	
	inheritMethod(_eraseLevel);
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="7bcd1c6b-c444-4f69-a631-b25788799a3b">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     15 March 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	txt		: String;
	tmpStr	: String;
	port    : CM_Port;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();

	txt := txt &amp; 'General' &amp; AuditStringSeparator &amp; self.isGeneral.String.length.String &amp; AuditStringSeparator &amp; self.isGeneral.String &amp; AuditStringSeparator;
	txt := txt &amp; 'Flat' &amp; AuditStringSeparator &amp; self.isFlat.String.length.String &amp; AuditStringSeparator &amp; self.isFlat.String &amp; AuditStringSeparator;
	txt := txt &amp; 'Crib' &amp; AuditStringSeparator &amp; self.isCrib.String.length.String &amp; AuditStringSeparator &amp; self.isCrib.String &amp; AuditStringSeparator;
	txt := txt &amp; 'Tank' &amp; AuditStringSeparator &amp; self.isTank.String.length.String &amp; AuditStringSeparator &amp; self.isTank.String &amp; AuditStringSeparator;
	txt := txt &amp; 'Open Top' &amp; AuditStringSeparator &amp; self.isOpenTop.String.length.String &amp; AuditStringSeparator &amp; self.isOpenTop.String &amp; AuditStringSeparator;
    txt := txt &amp; 'Reefer' &amp; AuditStringSeparator &amp; self.isReefer.String.length.String &amp; AuditStringSeparator &amp; self.isReefer.String &amp; AuditStringSeparator;
	txt := txt &amp; 'Porthole' &amp; AuditStringSeparator &amp; self.isPorthole.String.length.String &amp; AuditStringSeparator &amp; self.isPorthole.String &amp; AuditStringSeparator;
	txt := txt &amp; 'Integral' &amp; AuditStringSeparator &amp; self.isIntegral.String.length.String &amp; AuditStringSeparator &amp; self.isIntegral.String &amp; AuditStringSeparator;
	txt := txt &amp; 'Fan' &amp; AuditStringSeparator &amp; self.isFantainer.String.length.String &amp; AuditStringSeparator &amp; self.isFantainer.String &amp; AuditStringSeparator;
	txt := txt &amp; 'Powered' &amp; AuditStringSeparator &amp; self.isPowered.String.length.String &amp; AuditStringSeparator &amp; self.isPowered.String &amp; AuditStringSeparator;
	txt := txt &amp; '20 Foot' &amp; AuditStringSeparator &amp; self.is20ftLong.String.length.String &amp; AuditStringSeparator &amp; self.is20ftLong.String &amp; AuditStringSeparator;
	txt := txt &amp; '30 Foot' &amp; AuditStringSeparator &amp; self.is30ftLong.String.length.String &amp; AuditStringSeparator &amp; self.is30ftLong.String &amp; AuditStringSeparator;
	txt := txt &amp; '53 Foot' &amp; AuditStringSeparator &amp; self.is53ftLong.String.length.String &amp; AuditStringSeparator &amp; self.is53ftLong.String &amp; AuditStringSeparator;
	txt := txt &amp; '40 Foot' &amp; AuditStringSeparator &amp; self.is40ftLong.String.length.String &amp; AuditStringSeparator &amp; self.is40ftLong.String &amp; AuditStringSeparator;
	txt := txt &amp; '45 Foot' &amp; AuditStringSeparator &amp; self.is45ftLong.String.length.String &amp; AuditStringSeparator &amp; self.is45ftLong.String &amp; AuditStringSeparator;
	txt := txt &amp; '8ft High' &amp; AuditStringSeparator &amp; self.is8ftHigh.String.length.String &amp; AuditStringSeparator &amp; self.is8ftHigh.String &amp; AuditStringSeparator;
	txt := txt &amp; '8ft 6in High' &amp; AuditStringSeparator &amp; self.is8ft6High.String.length.String &amp; AuditStringSeparator &amp; self.is8ft6High.String &amp; AuditStringSeparator;
	txt := txt &amp; '9ft 6in High' &amp; AuditStringSeparator &amp; self.is9ft6High.String.length.String &amp; AuditStringSeparator &amp; self.is9ft6High.String &amp; AuditStringSeparator;
	txt := txt &amp; '4ft High' &amp; AuditStringSeparator &amp; self.is4ftHigh.String.length.String &amp; AuditStringSeparator &amp; self.is4ftHigh.String &amp; AuditStringSeparator;
	txt := txt &amp; '4ft 3in High' &amp; AuditStringSeparator &amp; self.is4ft3High.String.length.String &amp; AuditStringSeparator &amp; self.is4ft3High.String &amp; AuditStringSeparator;
	if self.myCargoType &lt;&gt; null then
		txt := txt &amp; 'Cargo Type' &amp; AuditStringSeparator &amp; self.myCargoType.description.length.String &amp; AuditStringSeparator &amp; self.myCargoType.description.String &amp; AuditStringSeparator;
    endif;
	return txt;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="c1a16a6f-aa0b-403f-a309-df8210492cfe">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	if _short then
		return self.code;
	else
		return '('&amp;self.code&amp;')  '&amp;self.description;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0fcef198-72bf-4f10-9d2e-3240ed3ee268">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 15 Oct 2019	NDL	TFS 47008
vars

	type : String;					
	str	: String;					
	value : Decimal [23,10];

begin
	if _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_Twenty or _attrName = ETRow_TwentyYesNo then
		return self.is20ftLong().cnEcGetYesNo();
	elseif _attrName = ETRow_Thirty or _attrName = ETRow_ThirtyYesNo then
		return self.is30ftLong().cnEcGetYesNo();
	elseif _attrName = ETRow_Forty or  _attrName = ETRow_FortyYesNo then
		return self.is40ftLong().cnEcGetYesNo();
	elseif _attrName = ETRow_FortyFive or _attrName = ETRow_FortyFiveYesNo then
		return self.is45ftLong().cnEcGetYesNo();
	elseif _attrName = ETRow_FiftyThree or _attrName = ETRow_FiftyThreeYesNo then
		return self.is53ftLong().cnEcGetYesNo();
	elseif _attrName = ETRow_CanTwinLift or _attrName = ETRow_CanTwinLiftYesNo then
		return (not self.isNotTwinLiftCapable).cnEcGetYesNo();
	elseif _attrName = ETRow_NotAvailableForEntry or _attrName = ETRow_NotAvailableYesNo then
//		return (not self.isNotAvailableForEntry).cnEcGetYesNo();	// cnwrl1 05/07/2010 PAR 24606 - what it was
		return self.isNotAvailableForEntry.cnEcGetYesNo();
	elseif _attrName = ETRow_Crib or _attrName = ETRow_CribYesNo then
		return self.isCrib().cnEcGetYesNo();
	elseif _attrName = ETRow_Height4 or _attrName = ETRow_Height4YesNo then
		return self.is4ftHigh().cnEcGetYesNo();
	elseif _attrName = ETRow_Height43 or  _attrName = ETRow_Height43YesNo then
		return self.is4ft3High().cnEcGetYesNo();
	elseif _attrName = ETRow_Height8 or _attrName = ETRow_Height8YesNo then
		return self.is8ftHigh().cnEcGetYesNo();
	elseif _attrName = ETRow_Height86 or _attrName = ETRow_Height86YesNo then
		return self.is8ft6High().cnEcGetYesNo();
	elseif _attrName = ETRow_Height96 or _attrName = ETRow_Height96YesNo then
		return self.is9ft6High().cnEcGetYesNo();
	elseif _attrName = ETRow_Integral or _attrName = ETRow_IntegralYesNo then
		return self.isIntegral().cnEcGetYesNo();
	elseif _attrName = ETRow_Frame or _attrName = ETRow_FrameYesNo then	//18 Feb 2018	NDL	TFS 36752
		return self.isFrame().cnEcGetYesNo();
	elseif _attrName = ETRow_Fan or _attrName = ETRow_FanYesNo then
		return self.isFantainer().cnEcGetYesNo();
	elseif _attrName = ETRow_Flat or _attrName = ETRow_FlatYesNo then
		return self.isFlat().cnEcGetYesNo();
	elseif _attrName = ETRow_General or _attrName = ETRow_GeneralYesNo  then
		return self.isGeneral().cnEcGetYesNo();
	elseif _attrName = ETRow_OpenTop or _attrName = ETRow_OpenTopYesNo then
		return self.isOpenTop().cnEcGetYesNo();
	elseif _attrName = ETRow_Porthole or _attrName = ETRow_PortholeYesNo then
		return self.isPorthole().cnEcGetYesNo();
	elseif _attrName = ETRow_Powered or _attrName = ETRow_PoweredYesNo  then
		return self.isPowered().cnEcGetYesNo();
	elseif _attrName = ETRow_Reefer or _attrName = ETRow_ReeferYesNo then
		return self.isReefer().cnEcGetYesNo();
	elseif _attrName = ETRow_Tank or _attrName = ETRow_TankYesNo then
		return self.isTank().cnEcGetYesNo();
	elseif _attrName = ETRow_IsRotatable or _attrName = ETRow_IsRotatableYesNo then //02/10/2025	navkc1 JIRA 36151
		return self.isRotatable().cnEcGetYesNo();
	elseif _attrName = ETRow_TareWeight then
		return self.tareKilos.asStringJMT();
	elseif _attrName = ETRow_MyCargoType then
		if self.myCargoType = null then
			return null;
		else
			return self.myCargoType.description;
		endif;
	
	elseif _attrName.isMeasurementType then											
		// _attrName will be formatted as WTRow_&lt;real ent row name&gt;_&lt;weight unit&gt;	
		_attrName.getRowNameMeasureType(str, type);									
		return self.getMeasurementStringForAttrib(str, type, _short);				

	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGeneralShortCode" id="d460d78f-f617-499a-b4a3-7afd066f5732">
        <source>getGeneralShortCode() : String;
// ---------------------------------------------------------------------------
// Created:		29 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.isFantainer then
		return "#FAN";
	elseif self.isCrib then
		return "#CRIB";
	elseif self.isFlat then
		return "#FLAT";
	elseif self.isOpenTop then
		return "#OPEN";
	elseif self.isTank() then
		return "#TANK";
	endif;
	
	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHeight" id="3cdd8ce3-65a7-4955-9a26-fcf601e68144">
        <source>getHeight() : Real;
// ---------------------------------------------------------------------------
// Created:		October 2001 By Andrew Bishop cnwab1
//
// Purpose:		Get Height in feet
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.isFlat then
		return HEIGHT_HALF_FLAT;
	elseif self.is8ftHigh then
		return HEIGHT_FULL_NORMAL;
	elseif self.is8ft6High then
		return HEIGHT_FULL_OD;
	elseif self.is4ftHigh then
		return HEIGHT_HALF_NORMAL;
	elseif self.is4ft3High then
		return HEIGHT_HALF_OD;
	elseif self.is9ft6High then
		return HEIGHT_FULL_HIGH_CUBE;
	endif;
	return 0;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getHeightReportStringImperial" id="44fc3e70-240a-4844-b872-7b77468788fd">
        <source>getHeightReportStringImperial() : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 31 August 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
// 31/10/2010	cnwsh3		CCMS1951 - PAR25219 Show a string value in imperial for reports.
//							
//----------------------------------------------------------------------
vars

begin
	if self.isFlat then
		return app.getErrorString(Flat);
	elseif self.is8ftHigh then
		return app.getErrorString(EightFoot);
	elseif self.is8ft6High then
		return app.getErrorString(EightFootSix);
	elseif self.is4ftHigh then
		return app.getErrorString(FourFoot);
	elseif self.is4ft3High then
		return app.getErrorString(FourFootThree);
	elseif self.is9ft6High then
		return app.getErrorString(NineFootSix);
	endif;
	return "";
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLengthInFeet" id="7e294374-923e-4ce0-8f85-5d6bc4c864e3">
        <source>getLengthInFeet():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwndl1	Initial creation CCMS 1094

*/

vars

begin

	if self.is20ftLong() then 
		return 20;
	elseif self.is40ftLong() then 
		return 40;
	elseif self.is30ftLong() then 
		return 30;
	elseif self.is45ftLong() then   
		return 45;
	elseif self.is53ftLong() then 
		return 53;
	else
		return 10; // PAR 22481 DEFAULT should be 10 not 0
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLengthInUnitsForWagon" id="ebe16a26-0d36-4edf-ad80-90276a39914b">
        <source>getLengthInUnitsForWagon():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwndl1	Initial creation	CCMS 1094

*/

vars

begin

	if self.is20ftLong() then 
		return 2;
	elseif self.is40ftLong() then 
		return 4;
	elseif self.is30ftLong() then 
		return 3;
	elseif self.is45ftLong() then   
		return 5;
	elseif self.is53ftLong() then 
		return 6;
	else
		return 1; // PAR 22481 DEFAULT should be 1 not 0
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLengthReportStringImperial" id="187f348e-aa07-4416-a74f-b96712aaad98">
        <source>getLengthReportStringImperial() : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 31 August 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
// 31/10/2010	cnwsh3		SCT would like to be able to see a string value in imperial for their reports.
//----------------------------------------------------------------------
vars

begin
	if self.is20ftLong() then 
		return app.getErrorString(TwentyFoot);
	elseif self.is40ftLong() then 
		return app.getErrorString(FortyFoot);
	elseif self.is30ftLong() then 
		return app.getErrorString(ThirtyFoot);
	elseif self.is45ftLong() then   
		return app.getErrorString(FortyFiveFoot);
	elseif self.is53ftLong() then 
		return app.getErrorString(FiftyThreeFoot);
	else
		return app.getErrorString(TenFoot); //DEFAULT should be 10 not 0
	endif;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="b8b0b657-b710-4e25-9c6e-038e8be8a3e0">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

begin

	if _attrName = ETRow_TareWeight then
		return app.convertMeasurementForDisplay(_measureType, self.tareKilos);
	// TFS 2026 23/05/2016 tare was using total and total was using tare, now fixed
	elseif _attrName = ETRow_MaxTareWeight then
		return app.convertMeasurementForDisplay(_measureType, self.maxTareWeight);
	elseif _attrName = ETRow_MaxTotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.maxTotalWeight);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
