    <JadeMethod name="getEffectiveDateLocalTZ" id="21ba2d51-90e0-4220-96b0-930f9024cd58">
        <source>getEffectiveDateLocalTZ() :Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2016	cnwns1	Initial creation
