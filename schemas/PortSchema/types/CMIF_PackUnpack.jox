    <JadeMethod name="setValuesFromTI" id="2887db99-31c9-43f7-bab1-91fee2de067c">
        <updating/>
        <source>setValuesFromTI(_ti : CM_TrackedItem) updating;
// --------------------------------------------------------------------------------
// Created:		30 April 2009 by cnwjo3
//
// Purpose:		copy values from original TI and place in CMIF_PackUnpack obj
//
// Parameters:	_ti
vars

begin
	self.billOfLading := _ti.billOfLading;
	self.bookingReference := _ti.bookingReference;
	self.cargoType := _ti.cargoType;
	self.carrier := _ti.carrier;
	self.cargoGroupId := _ti.getMyCargoGroupId;	//15 Feb 2016	NDL	Par 37544
	self.commodity := _ti.commodity;
	self.companyCode := _ti.companyCode;
	self.consignorVoyageCode := _ti.consignorVoyageCode;
	self.customExportEntryNumber := _ti.customExportEntryNumber;
	self.damaged := _ti.damaged;
	self.density := _ti.density;
	self.description := _ti.description;
	self.destinationPort := _ti.destinationPort;
	self.dischargePort := _ti.dischargePort;
	self.myTranshipToPort := _ti.myTranshipToPort;//cnwas3 ccms 1028
	self.eirNumber := _ti.eirNumber;
	self.freightForwarderCode := _ti.freightForwarderCode;
	self.height := _ti.height;
	self.id := _ti.id;
	self.isEDI := _ti.isEDI;
	self.length := _ti.length;
	self.loadPort := _ti.loadPort;
	self.mark := _ti.mark;
	self.markNumber := _ti.markNumber;
	self.myBookingRefItem := _ti.myBookingRefItem;
	self.myProduct := _ti.myProduct;
	self.mySubTerminal := _ti.mySubTerminal;
	self.myTerminal := _ti.myTerminal;
	self.operatorCode := _ti.operatorCode;
	self.purchaseOrder := _ti.purchaseOrder;
	self.quantity := _ti.quantity;
	self.receiptTransportMode := _ti.receiptTransportMode;
	self.remarks := _ti.remarks;
	self.totalVolume := _ti.getMyTotalVolume;
	self.volume := _ti.getMyCargoVolume;
	self.voyageCode := _ti.voyageCode;
	self.wasCreatedFromMobileApp := _ti.wasCreatedFromMobileApp;
	//self.weight := _ti.weight;					//-cnwml2 MSL CCMS 1017
	self.weightTotal := _ti.totalWeight;					//+cnwml2 MSL CCMS 1017
	self.weightTare := _ti.weightTare;						//+cnwml2 MSL CCMS 1017
	self.weightCargo := _ti.weightCargo;					//+cnwml2 MSL CCMS 1017
	self.width := _ti.width;
	

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
