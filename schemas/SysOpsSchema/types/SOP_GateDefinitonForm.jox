    <JadeMethod name="zLstDataSysNotifyDelete" id="9cea407b-f061-4a8d-9803-fe335d9a1b9a">
        <updating/>
        <source>zLstDataSysNotifyDelete(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.mode = Mode_View and
		theObject = self.myCurrentObject then
		// they have deleted the object we are viewing
		app.msgBox(app.getErrorString1(XLAT_Viewed_Object_Deleted, app.getErrorString (Gate)), app.getErrorString (Warning), MsgBox_OK_Only);
		
		self.zClearThumbnailData;
		
	endif;
	
	inheritMethod(eventType, theObject, eventTag);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zSetControlsForView" id="334c6bff-a0b9-4ab1-84a3-57b149571da3">
        <updating/>
        <source>zSetControlsForView() updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	if self.myCurrentObject = null then
		btnEditTV.enabled	:= false;
	else
		btnEditTV.enabled	:= allowUpdate;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zSetFormDefaults" id="194b14cb-f546-4fd1-af01-9d1e6aea25e4">
        <updating/>
        <source>zSetFormDefaults() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	self.allowAdd		:= app.myCurrentUserCan (self.myTerminal, self.permissionMaint);
	self.allowUpdate	:= app.myCurrentUserCan (self.myTerminal, self.permissionMaint);
	self.allowDelete	:= app.myCurrentUserCan (self.myTerminal, self.permissionMaint);
	self.allowPrint		:= false;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zShowThumbnailData" id="d985a105-c201-4161-9fe8-4baeb0c27017">
        <updating/>
        <source>zShowThumbnailData(_object: Object) updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gate		:CM_Gate;
begin	
	if CM_Gate.hasInstance (_object) then
		gate := _object.CM_Gate;
	elseif CM_GateAreaUsage.hasInstance (_object) then
		gate := _object.CM_GateAreaUsage.myGate;
	endif;
	
	// select tree entry if none selected (cancel will refresh tree)
	if self.lstData.selectedCount = 0 then
		self.zLstDataSelectObject(_object.CM_Object);
	endif;
	
	inheritMethod(gate);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
</GUIClass>
