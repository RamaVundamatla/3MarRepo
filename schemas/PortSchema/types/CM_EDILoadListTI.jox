    <JadeMethod name="sealShipper" id="5812a8a2-1b1d-4030-bea3-fd5ec5858a8c">
        <methodInvocation>mapping</methodInvocation>
        <source>sealShipper(set : Boolean; _value : String io) mapping;
//
// 28 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars

begin
	if set then
		self.setSealsAsObjects(_value, SealType_Shipper);
	else
		_value := self.getSealsAsString(SealType_Shipper);
		if _value = null then
			_value := self.sealShipper;
		endif;
	endif;	
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
