<Class name="CM_EDIFileTypeIFTMBC96B" id="a5dfdd5c-4d3a-404d-920d-fcd001283c8c">
    <superclass name="CM_EDIFileTypeIFTMBC"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="5be5fcd7-19fd-47cc-99db-9e0f90929d41">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     May 2006 cmwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.name	:= "IFTMBC 96B - Booking Reference";
	self.type	:= EDIFileType_IFTMBC96B;
end;</source>
    </JadeMethod>
    <JadeMethod name="processFile" id="d4f3a411-746f-4bc5-94a6-20b08a298e00">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) protected, updating;
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - commodity xlations
// 16 Sep 2013 cnwah9 removed error messages and unnecessary code
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	bookingHdr : CM_EDIBookingHeaderTI; //cnwrs1 CCMS 1882 25 May 2010
	bookingItem : CM_EDIBookingItemTI;
	ediDataBooking	: CM_EDIDataBooking;
	lineStr				: String;
	message				: String;
	int					: Integer;
	voyageCode			: String;
	vesselName			: String;
	operatorSenderCode	: String;				// cnwrl1 20/07/2010 PAR 25046
	operatorVoyageCode	: String;				// cnwrl1 20/07/2010 PAR 25046
	lloydsNumber		: String;				// cnwrl1 20/07/2010 PAR 25046
	callSign			: String;				// cnwrl1 20/07/2010 PAR 25046
	dischargePort		: String;
	destinationPort		: String;
	port				: String;
	isotype				: String;
	carrierCode			: String;
	group				: Integer;
	rngType				: String;
	temperature			: Real;
	tmpMin				: Real;
	tmpMax				: Real;
	messageMode			: String;
	myTerminal			: CM_Terminal;
	operatorSender		: CM_Operator;			// cnwrl1 21/07/2010 PAR 25093
	operatorVoyage		: CM_Operator;			// cnwrl1 21/07/2010 PAR 25093
	msgCount			: Integer;
	numMsgs				: Integer;
	passport			: CM_Passport;
	haz					: String;
	undg				: String;
	msgHelper			: CMIF_EDIFACTHelper;
	brISOType			: CM_ISOType;
	isoTypeDef			: CM_ISOType;
//	brCmdty				: CM_Commodity;
	rawEDIData			: String;
//	binaryLine			: Binary;
	foundMatch			: Boolean;
	params 				: CMIF_EDIFACTParams;
	theLines : HugeStringArray;
	rawSenderCode : String;
	creationTS : TimeStamp;
	sequence : String;
	fileType : String;
	version : String;
	recipientCode : String;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport := app.myPassport;
	myTerminal := passport.myTerminal;
	
	isoTypeDef := myTerminal.getConfig(DefISOType).CM_ISOType;
	ediDataBooking := _ediFile.ediData.CM_EDIDataBooking;
	create msgHelper transient;
	msgHelper.setEDIFile(_ediFile);
	
	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach lineStr in theLines do
		rawEDIData	:=	rawEDIData&amp;lineStr&amp;CrLf;
		
		msgCount	:=	msgCount + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;

		msgHelper.setNextMessage(lineStr);	//set the current message
		
		//get current
		message := msgHelper.currentMessage;
//BGM*
		if msgHelper.currentTag = "BGM" then
			group := 0;
			if group = 0 then
				msgHelper.setNextField;
				if msgHelper.currentField = "770" then
					msgHelper.setNextField;
					msgHelper.setNextField;
					if msgHelper.currentField = "1" then
						messageMode := CM_EDITrackedItem.EDI_ACTION_DELETE;
					elseif msgHelper.currentField = "5" then
						messageMode := CM_EDITrackedItem.EDI_ACTION_UPDATE;
					elseif msgHelper.currentField = "9" then
						messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
					endif;
				endif;
			endif;
//CNT*
		
//COM*

//CPI*
		elseif msgHelper.currentTag = "CPI" then
			if group &gt; 9 and group &lt; 14 then
				group := 14;
			endif;
			if group = 14 then
			endif;
//CTA***
		elseif msgHelper.currentTag = "CTA" then
			if group &gt; 9 and group &lt; 11 then
				group := 11;
			endif;
			if group &gt;= 27 and group &lt; 28 then
				group := 28;
			endif;
			if group = 33 then
				group := 34;
			endif;

//CUX

//DIM
		elseif msgHelper.currentTag = "DIM" then
			if group = 16 or group = 17 or group = 18 then
				group := 19;
			endif;
	
		
//DOC
		elseif msgHelper.currentTag = "DOC" then
			if group = 4 then
				group := 5;
			endif;
			if group &gt; 9 and group &lt; 12 then
				group := 12;
			endif;
			if group &gt; 15 and group &lt; 22 then
				group := 22;
			endif;
			
//DGS
		elseif msgHelper.currentTag = "DGS" then
			if group &gt; 15 and group &lt; 27 then 
				group := 27;
			endif;
			if group = 27 then
				msgHelper.setNextField;
				if msgHelper.currentField = "IMD" then
					msgHelper.setNextField;
					haz := msgHelper.currentSubItem;
					msgHelper.setNextField;
					undg := msgHelper.currentSubItem;	//par26798 cnwrs1 25 Jan 2011
					bookingItem.imCodes.add(haz &amp; ":+" &amp; undg);
				endif;
			endif;
//DTM
		
//EQD
		elseif msgHelper.currentTag = "EQD" then
			if group &lt; 32 then
				group := 32;
			endif;
			if group = 32 then
				msgHelper.setNextField;
				if msgHelper.currentField = "CN" then
					bookingHdr.setCargoType(TI_CargoType_Container);
					msgHelper.setNextField;
					msgHelper.setNextField;
					isotype := msgHelper.currentField[1:4];
					//now use xlation CCMS 1157
					if operatorSender &lt;&gt; null then
						 bookingItem.isoType := operatorSender.getXlationSystemCode(isotype, XLATION_TYPE_ISOTYPE_BYOP, foundMatch);
					//else //Par 31315
					//	bookingItem.isoType := isotype.trimBlanks;
					endif;
					
					if bookingItem.isoType = null 
					and isoTypeDef &lt;&gt; null then
						bookingItem.isoType := isoTypeDef.code;
					endif;
					
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextField;
					if msgHelper.currentField = "4" then
						bookingItem.fullOrMT := "E";
					elseif msgHelper.currentField = "5" then
						bookingHdr.fullOrMT := "F";						
					endif;
					int := int + 1;

					// par 31259 - there was some code in here that tried to set a default temperature using the isoType (isIntegral) and
					// commodity (hasTemp)  At this stage it is hard to see how the commodity could be anything but the default commodity 
					// so i have taken the code out.
					
			
				endif;
			endif;
//EQN****
		elseif msgHelper.currentTag = "EQN" then 
			if group = 6 then
			elseif group = 18 then
				msgHelper.setNextField;
				bookingItem.number := msgHelper.currentSubItem.Integer; 
			
			endif;
//FTX***
		elseif msgHelper.currentTag = "FTX" then
		if group = 16 then
				msgHelper.setNextField;
				if msgHelper.currentField = "AAA" then
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextField;
					bookingItem.commodityDescription := msgHelper.currentSubItem[1:30];
				endif;
			endif;
//GDS
		elseif msgHelper.currentTag = "GDS" then
			if group = 17 then
				group := 16;
			endif;
		
//GID
		elseif msgHelper.currentTag = "GID" then
			if group &lt; 16 then
				group := 16;
			endif;
			
//GIN

//GOR
		elseif msgHelper.currentTag = "GOR" then
			if group &lt; 4 then
				group := 4;
			endif;
			
//HAN

//LOC
		elseif msgHelper.currentTag = "LOC" then
			if group = 0 then
				group := 1;
			endif;
			if group = 3 then
				group := 4;
			endif;
			if group = 7 then
				group := 8;
			endif;
			msgHelper.setNextField;
			/*if group = 1 then
			elseif group = 2 then
			elseif group = 6 then
			else*/if group = 8 then
				if msgHelper.currentField = "7" then
					msgHelper.setNextField;
					port := msgHelper.currentSubItem[1:5].trimBlanks;
					destinationPort := port;
					if operatorSender &lt;&gt; null then
						bookingHdr.destinationPort := operatorSender.getXlationSystemCode(destinationPort, XLATION_TYPE_PORT_BYOP, foundMatch);
					else
						bookingHdr.destinationPort := destinationPort.trimBlanks;
					endif;
				elseif msgHelper.currentField = "9" then
					msgHelper.setNextField;
					port := msgHelper.currentSubItem[1:5].trimBlanks;
//					loadPort := port;
//					if operator &lt;&gt; null then
//						bookingHdr.loadPort := operator.getXlationSystemCode(loadPort, XLATION_TYPE_PORT_BYOP);
//					else
//						bookingHdr.loadPort := loadPort.trimBlanks;
//					endif;
				elseif msgHelper.currentField = "11" then
					msgHelper.setNextField;
					port := msgHelper.currentSubItem[1:5].trimBlanks;
					dischargePort := port;
					if operatorSender &lt;&gt; null then
						bookingHdr.dischargePort := operatorSender.getXlationSystemCode(dischargePort, XLATION_TYPE_PORT_BYOP, foundMatch);
					else
						bookingHdr.dischargePort := dischargePort.trimBlanks;
					endif;
				
				endif;
			
			endif;
//MEA****
		elseif msgHelper.currentTag = "MEA" then
			if group = 16 or group = 17 then
				group := 18;
			endif;
			if group = 23 then
				group := 24;
			endif;
			if group = 25 then 
				group := 26;
			endif;
			if group &gt;= 27 and group &lt; 29 then
				group := 29;
			endif;
			if group = 30 then
				group := 31;
			endif; 
			if group = 32 then
				msgHelper.setNextField;
				if msgHelper.currentField = "AAE" then
					msgHelper.setNextField;
					if msgHelper.currentField = "WT" then
						msgHelper.setNextField;
						if msgHelper.currentSubItem = "KGM" then
							msgHelper.setNextSubItem;
							bookingItem.weight := msgHelper.currentSubItem.Integer;
						elseif msgHelper.currentSubItem = "LBR" then
							msgHelper.setNextSubItem;
							bookingItem.weight := (msgHelper.currentSubItem.asEDIReal()/2.2).Integer;
						endif;
					endif;
				endif;
			endif;
//MOA

//NAD
		elseif msgHelper.currentTag = "NAD" then
			if group &lt; 10 then
				group := 10;
			endif;
			if group = 16 then
				group := 17;
			endif;
			if group = 32 then
				group := 33;
			endif;
			if group = 10 then
				msgHelper.setNextField;
				if msgHelper.currentField = "CA" then			// Sender operator
					msgHelper.setNextField;
					/* cnwrl1 21/07/2010 PAR 25093 - what it was
					bookingHdr.operatorCode    := app.myRoot.getXlationSystemOperatorCode( operator, msgHelper.currentSubItem );
					operator := app.myRoot.allOperators[ bookingHdr.operatorCode ];
					cnwrl1 21/07/2010 PAR 25093 - end of what it was */
					
					//par 31315 current code resets operator to null.
					
					
					// cnwrl1 21/07/2010 PAR 25093 - start of replacement coding
					/*operatorSenderCode	:= msgHelper.currentSubItem;
					operatorSenderCode	:= app.myRoot.getXlationSystemOperatorCode( operatorSender, operatorSenderCode, foundMatch)[1:4];
					operatorSender		:= app.myRoot.allOperators[ operatorSenderCode ];
					bookingHdr.operatorCode	:= operatorSenderCode;*/
					
					// cnwrl1 21/07/2010 PAR 25093 - end of coding
				elseif msgHelper.currentField = "CZ" then
					msgHelper.setNextField;
					if msgHelper.currentSubItem &lt;&gt; null then
						if operatorSender &lt;&gt; null then
							bookingHdr.consignee := operatorSender.getXlationSystemCode(msgHelper.currentField, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);
						else
							bookingHdr.consignee := msgHelper.currentField.trimBlanks[1:10];
						endif;
					else
						msgHelper.setNextField;
						bookingHdr.consignee := msgHelper.currentField[1:10];
					endif;
				endif;
			endif;
//PCD

//PCI
		elseif msgHelper.currentTag = "PCI" then
			if group &gt; 15 and group &lt; 21 then
				group := 21;
			endif;
			
//PIA
		
//PRI
		
//QTY

//RFF
		elseif msgHelper.currentTag = "RFF" then
			if group &lt; 3 then
				group := 3;
			endif;
			if group = 7 then
				group := 8;
			endif;
			if group &gt; 9 and group &lt; 13 then
				group := 13;
			endif;
			if group &gt;= 16 and group &lt; 20 then 
				group := 20;
			endif;
			if group = 3 then
				msgHelper.setNextField;
				if msgHelper.currentSubItem = "SI" then
				elseif msgHelper.currentSubItem = "BN" then // ???
					if bookingHdr &lt;&gt; null then //finish any previous bookingref 
						bookingHdr.rawEDIData := rawEDIData;
					endif;
					create bookingHdr persistent;
					bookingHdr.setForCreateNew(ediDataBooking);
					create bookingItem persistent;
					bookingItem.setForCreateNew(ediDataBooking);
					bookingItem.myParent := bookingHdr;	//cnwrs1 Par 27392  04 May 2011
					
					msgHelper.setNextSubItem;
					bookingHdr.setId(msgHelper.currentSubItem[1:11].toUpper);
					bookingItem.setId(bookingHdr.id); //cnwrs1 CCMS 1882 25 May 2010
					/* cnwrl1 20/07/2010 PAR 25046 - what it was
					if operator &lt;&gt; null then
//						bookingHdr.voyageCode := operator.getXlationSystemCode(voyageCode, XLATION_TYPE_VOYAGETERMINAL);	// cnwrl1 09/06/2010 PAR 24299 - what it was
						// make sure the manual collection on CM_EDIConfig gets maintained
						bookingHdr.setVoyageCode( operator.getXlationSystemCode(voyageCode, XLATION_TYPE_VOYAGETERMINAL) );
					else
//						bookingHdr.voyageCode := voyageCode.trimBlanks[1:30];	// cnwrl1 09/06/2010 PAR 24299 - what it was
						// make sure the manual collection on CM_EDIConfig gets maintained
						bookingHdr.setVoyageCode( voyageCode.trimBlanks[1:30] );
					endif;
					cnwrl1 20/07/2010 PAR 25046 - end of what it was */
					
					// cnwrl1 20/07/2010 PAR 25046 - start of replacement coding
					// Use the operator voyage code translation if it exists.
					voyageCode	:= self.getXlationOperatorVoyageCode(	operatorSender,
																		operatorVoyage,
																		voyageCode,
																		vesselName,
																		lloydsNumber,
																		callSign );
					// make sure the manual collection on CM_EDIConfig gets maintained
					bookingHdr.setVoyageCode( voyageCode.trimBlanks[1:30] );
					// cnwrl1 20/07/2010 PAR 25046 - end of coding
					
					if operatorSender &lt;&gt; null then
						bookingHdr.carrierCode := operatorSender.getXlationSystemCode(carrierCode, XLATION_TYPE_CARRIER_BYOP, foundMatch);
					else
						bookingHdr.carrierCode := carrierCode[1:11];
					endif;
					bookingItem.temperature := NULL_TEMPERATURE;
					bookingHdr.messageMode := messageMode;
					//par cnwah9 31315 
					//return; //jc	No point continuing from here as we wont have a bookingHdr	
				endif;
			
			else
				
					//par cnwah9 31315 
				//return; //jc	No point continuing from here	
			endif;
//RNG*
		elseif msgHelper.currentTag = "RNG" then
			if group = 16 then
				msgHelper.setNextField;
				if msgHelper.currentField = "5" then
					msgHelper.setNextField;
					rngType := msgHelper.currentField;
					msgHelper.setNextSubItem;
					tmpMin := msgHelper.currentSubItem.asEDIReal();
					msgHelper.setNextSubItem;
					tmpMax := msgHelper.currentSubItem.asEDIReal();
					if rngType = "CEL" then
//						if container.temperature = NULL_TEMPERATURE then
//							container.temperature := tmpMin;
//						endif;
					elseif rngType = "FAH" then
//						if container.temperature = NULL_TEMPERATURE then
//							container.temperature := app.temperatureConversion(false,tmpMin);
//						endif;
					endif;
				endif;
			endif;
//SGP
		elseif msgHelper.currentTag = "SGP" then
			if group &gt; 15 and group &lt; 25 then
				group := 25;
			endif;
			if group &gt;= 27 and group &lt; 30 then
				group := 30;
			endif;
		
//TCC
		elseif msgHelper.currentTag = "TCC" then
			if group &lt; 6 then
				group := 6;
			endif;
			
//TMD

//TDT
		elseif msgHelper.currentTag = "TDT" then
			if group &lt; 7 then
				group := 7;
			endif;
			msgHelper.setNextField;
			if group = 7 then
				if msgHelper.currentField = "20" then
					/* cnwrl1 20/07/2010 PAR 25046 - what it was
					msgHelper.setNextField;
					voyageCode := msgHelper.currentField;
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextField;
//					operatorCode := msgHelper.currentField;
					//bookingHdr.operatorCode := app.myRoot.getXlationSystemCode(msgHelper.currentSubItem, XLATION_TYPE_OPERATOR);
					bookingHdr.operatorCode    := app.myRoot.getXlationSystemOperatorCode(operator, msgHelper.currentSubItem); // cnwrd1 par 19675 14.5.09
					operator := app.myRoot.allOperators[bookingHdr.operatorCode];
					if operator &lt;&gt; null then
//						bookingHdr.voyageCode := operator.getXlationSystemCode(voyageCode, XLATION_TYPE_VOYAGETERMINAL);	// cnwrl1 09/06/2010 PAR 24299 - what it was
						// make sure the manual collection on CM_EDIConfig gets maintained
						bookingHdr.setVoyageCode( operator.getXlationSystemCode(voyageCode, XLATION_TYPE_VOYAGETERMINAL) );
					else
//						bookingHdr.voyageCode := voyageCode.trimBlanks[1:30];	// cnwrl1 09/06/2010 PAR 24299 - what it was
						// make sure the manual collection on CM_EDIConfig gets maintained
						bookingHdr.setVoyageCode( voyageCode.trimBlanks[1:30] );
					endif;
					
					//added by cnwyl1 for CCMS1477
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextField;
					msgHelper.setNextSubItem;
					msgHelper.setNextSubItem;
					msgHelper.setNextSubItem;
					vesselName := msgHelper.currentSubItem;
					if vesselName &lt;&gt; null then
						bookingHdr.vesselName := vesselName;
					endif;
					//add end
					cnwrl1 20/07/2010 PAR 25046 - end of what it was */
					
					// cnwrl1 20/07/2010 PAR 25046 - start of replacement coding
					// Note: We might not use all of the returned strings but this is a standard method for TDT+20.
					self.getVoyageDetailsFromTDT(	msgHelper,
													voyageCode,
													operatorVoyageCode,
													operatorVoyage,			// cnwrl1 26/07/2010 PAR 25093
													vesselName,
													lloydsNumber,
													callSign );
					
					// cnwrl1 26/07/2010 PAR 25093 - start of coding
					// Because some of Nelson's clients (ANL and COS) in particular do not send
					// through the mandatory UNB record the operator is not getting set up.
					// To cater for this we will use the first valid TDT+20 operator
					// if and only if the operator is not already set up.
					
					if operatorSender = null then
						operatorSender		:= operatorVoyage;
						operatorSenderCode	:= operatorVoyageCode;
					endif;
					// cnwrl1 26/07/2010 PAR 25093 - end of coding
						_ediFile.ediData.operatorCode	:= operatorSenderCode;
					
					// Use the operator voyage code translation if it exists.
					voyageCode	:= self.getXlationOperatorVoyageCode(	operatorSender,
																		operatorVoyage,
																		voyageCode,
																		vesselName,
																		lloydsNumber,
																		callSign );
					// make sure the manual collection on CM_EDIConfig gets maintained
				
				
					bookingHdr.setVoyageCode(voyageCode[1:30]);
					
					//par cnwah9 31315 
					if operatorSenderCode &lt;&gt; null then
					bookingHdr.operatorCode := operatorSenderCode;
					endif;
					
					
					
		
					if vesselName &lt;&gt; null then
						bookingHdr.vesselName	:= vesselName;
					endif;
					// cnwrl1 20/07/2010 PAR 25046 - end of coding
				endif;
			endif;
//TMP*
		elseif msgHelper.currentTag = "TMP" then
			if group = 16 or
			   group = 32 then
				msgHelper.setNextField;
				if msgHelper.currentField = "2" then
					msgHelper.setNextField;
					temperature := msgHelper.currentSubItem.asEDIReal();
					msgHelper.setNextSubItem;
					
					if msgHelper.currentSubItem = "CEL" then
						bookingItem.temperature := temperature;
					elseif msgHelper.currentSubItem = "FAH" then
						bookingItem.temperature := app.temperatureConversion(false,tmpMin);
					endif;
				endif;
			endif;
//TOD
		elseif msgHelper.currentTag = "TOD" then
			if group &lt; 2 then
				group := 2;
			endif;
			
//TPL
		elseif msgHelper.currentTag = "TPL" then
			if group &gt; 15 and group &lt; 23 then
				group := 23;
			endif;
			
//TSR
		elseif msgHelper.currentTag = "TSR" then
			if group &gt; 9 and group &lt; 15 then
				group := 15;
			endif;
			
// cnwdad1 08/11/2010 - PAR #26017.
// cnwdad1 16/11/2010 - Temporarily put original code back, until we have a design to implement UNA handling.
//UNA
//		elseif msgHelper.currentTag = "UNA" then
//			msgHelper.setFirstField();
//UNB
		elseif msgHelper.currentTag = self.UNB then
			// cnwrl1 22/07/2010 PAR 25093 - start of coding
			// get The translated Sender Operator and Code.
			self.getUNB_ElementData(	msgHelper,
										operatorSenderCode,
										operatorSender, rawSenderCode, recipientCode, creationTS, sequence);
										
			// cnwrl1 22/07/2010 PAR 25093 - end of coding
//UNH*
		elseif msgHelper.currentTag = "UNH" then
			self.getUNHData(_ediFile.ediData, msgHelper, fileType, version);
			if _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE and
			   not self.processSenderRecipientSeq(rawSenderCode, recipientCode, fileType, version, _ediFile.ediData.fileName, creationTS, sequence, _ediFile.ediData, passport.myTerminal) then
				ediDataBooking.status := CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE;
			endif;
//UNT
		elseif msgHelper.currentTag = "UNT" then
			group := 0;
			msgHelper.setNextField;
//UNZ
		//elseif msgHelper.currentTag = "UNZ" then
		endif;
//		app.doWindowEvents(0);
	endforeach;
	
//	self.doTranslations (_ediFile, null);
epilog
	delete theLines;
	delete msgHelper;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
