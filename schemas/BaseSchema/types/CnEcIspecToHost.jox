    <JadeMethod name="setValue" id="60fad81b-65d5-471c-b41a-8b2cbdf6432d">
        <updating/>
        <source>setValue(ispecName : String; fieldName : String; value :String ) updating;

vars
	lincIspec : CnEcLincIspecDef;
	lincField : CnEcLincFieldDef;
	subLen : Integer;
	subPos : Integer;
	formattedValue : String;
	intReturn : Integer;

begin
	// first get the field definition object 

	lincIspec := myLincSystemDef.allLincIspecDefs [ispecName.toLower];
	if lincIspec = null then
		intReturn := app.msgBox(("No internal data for ispec" &amp; ispecName),"Internal Problem",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;	

	lincField := lincIspec.allLincFieldDefs [fieldName.toLower];
	if lincField = null then
		intReturn := app.msgBox(("No internal data for field" &amp; ispecName &amp; "/" &amp; fieldName),"Internal Problem",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	// now we can set up the appropriate chunk in the noformsData layout

    formattedValue := formatOutField(value, lincField.type, lincField.length, lincField.decimals, lincField.decimalsKeyed);

	subLen := lincField.trueLength;
    subPos := lincField.offset;

	//  for decimal keyed fields, start one pos to the left to allow for the decimal point
	// that has been included, or added by the routine

//	if lincField.decimalsKeyed = true then
//		subPos := lincField.offset - 1;
//	endif;        	

	noformsData[subPos:subLen] := formattedValue;

	// whilst we are in here then we will set up the ispec value if its not already set up
	// note that we will set up the LINC header prior to the queued data being sent

	if ispec = null then
		ispec := ispecName.toUpper;
	endif;		
end;</source>
        <Parameter name="ispecName" type="String"/>
        <Parameter name="fieldName" type="String"/>
        <Parameter name="value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setValueCopyFrom" id="a863ff32-5bad-4b6b-b80d-42c8f90c4198">
        <updating/>
        <source>setValueCopyFrom(ispecName : String; fieldName : String; value :StringArray ) updating;

vars
	lincIspec : CnEcLincIspecDef;
	lincField : CnEcLincFieldDef;
	intLen : Integer;
	intPos : Integer;
	intReturn : Integer;
	intArrayIndex : Integer;
	strFormattedValue : String;

begin
	// first get the field definition object 

	lincIspec := myLincSystemDef.allLincIspecDefs [ispecName.toLower];
	if lincIspec = null then
		intReturn := app.msgBox(("No internal data for ispec " &amp; ispecName ),"Internal Problem",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;	

	lincField := lincIspec.allLincFieldDefs [fieldName.toLower];
	if lincField = null then
		intReturn := app.msgBox(("No internal data for field" &amp; ispecName &amp; "/" &amp; fieldName),"Internal Problem",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	intLen := lincField.trueLength;

	// now we can set up the appropriate chunk in the noformsData layout for the 
	// individual array items ....

	while intArrayIndex &lt; lincField.copyFromOccurs do
		intArrayIndex := intArrayIndex + 1;

	 	if intArrayIndex  &gt; value.size() then
	 		break;
	 	endif;

	 	// now format this data

 	 	strFormattedValue := formatOutField(value[intArrayIndex], lincField.type,
 	   								 lincField.length, lincField.decimals, lincField.decimalsKeyed);

		// now calculate the offset 

		intPos := (lincField.offset +  (lincField.copyFromGroupLength * (intArrayIndex - 1))) ; 


		// now 'tweak' the offset for decimals keyed fields

		if lincField.decimalsKeyed = true  then
			intPos := lincField.offset - 1;
		endif;        	

		// finally put him into the buffer

		noformsData[intPos:intLen] := strFormattedValue;			

	endwhile;

	if ispec = null then
		ispec := ispecName.toUpper;
	endif;		
end;</source>
        <Parameter name="ispecName" type="String"/>
        <Parameter name="fieldName" type="String"/>
        <Parameter name="value" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="settimeoutNotified" id="69d9cc8b-bb6d-4c12-b24a-ae6c39335c5c">
