    <JadeMethod name="getVoyageConfiguration" id="22b8bc04-eded-453f-9b6c-a0cd57bd2b38">
        <source>getVoyageConfiguration( _terminal : CM_Terminal; _termElement : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

	entDef : EntTableDef;
	entRow : EntTableRow;
	tabName : String;
	category : ConstantCategory;
	constant : Constant;
	constantName : String;
	int : Integer;
	schema : Schema;
	form : Form;
	formClass : Class;
	value : String;
	sourceValue : String;

begin

	//SHP_VoyageConfiguration

	category := self.myPortSchema.getCategory(ConfigConstants);
	
	schema := rootSchema.getSchema("ShipSchema");
	formClass := schema.getClass("SHP_VoyageConfiguration");

	
	create form as formClass transient; //SHP_VoyageConfiguration
	form.sendMsg("translateForm");
	//Configuration for Terminal tab.
	tabName := self.getControlCaption( form, "shtConfigTerm");
	
	entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_ShipSettings];
	if entDef &lt;&gt; null then
		
		int := 0;
		foreach entRow in entDef.allEntTableRows do
			int := int + 1;
			if entRow.name.toUpper[1:11] = "ZTABLEBREAK" then
				continue;
			endif;
			
			constantName := null;
			value := null;
			
			//First check constants where the value doesn't match its name have not been followed 
			// or hard coded attributes exist.
			if entRow.name = ETRow_RelReqOnRailLoadList then
				constantName := ShowRelReqOnRailLoadList; // to leave a reference to it.
				constantName := "ShowRelReqOnRailLoadList";
				value := self.getTermValueForDisplay(_terminal,ShowRelReqOnRailLoadList,null).String;
			elseif entRow.name = ETRow_RelReqOnShipLoadList then
				constantName := ShowRelReqOnShipLoadList; // to leave a reference to it.
				constantName := "ShowRelReqOnShipLoadList";
				value := self.getTermValueForDisplay(_terminal,ShowRelReqOnShipLoadList,null).String;
			elseif entRow.name = ETRow_ShpLinearMeterWidthRORO then
				constantName := RoRoLinearMeteringWidth;  // to leave a reference to it.
				constantName := "RoRoLinearMeteringWidth";
				value := self.getTermValueForDisplay(_terminal,RoRoLinearMeteringWidth,null).String;
			else 
				// all others
				foreach constant in category.getConstants do
					if constant.name.toUpper = entRow.name.toUpper then
						constantName := constant.name;
						sourceValue := constant.getSource.replaceString("'"," ");
						sourceValue := sourceValue.replaceString('"'," ");
						sourceValue := sourceValue.trimBlanks;
						value := self.getTermValueForDisplay(_terminal,sourceValue,null).String;
						break;
					endif;
				endforeach;
			endif;
			
			self.addItem( _termElement, entRow.getRawHeadingValue, self.Voyage_Config, tabName, "row " &amp; int.String, value, constantName, true);
			
		endforeach;
	endif;
	
	
epilog

	delete form;

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_termElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getYAMConfig" id="8391301d-c326-4e6c-9bd2-4c998aec17cb">
        <source>getYAMConfig( _terminal : CM_Terminal; _termElement : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2014	cnwndl1	Initial creation

*/

constants

	Grp : String = " (Group)";

vars

	tabName : String;
	constantName : String;
	position : String;
	value : String;
	schema : Schema;
	form : Form;
	formClass : Class;
	configOpts : CMIF_YAConfig;
	yaConfig : CM_YAConfig;

begin

	
	//constantName := "No constant, hard coded!";
	constantName := null;
	
	schema := rootSchema.getSchema("UiCommonSchema");
	formClass := schema.getClass("CMUI_YAConfigForm");
	
	if _terminal &lt;&gt; null then
		create configOpts transient;
		configOpts.setFromTerminal( _terminal );
		yaConfig := _terminal.myYAConfig;
	endif;

	create form as formClass transient;
	form.sendMsg("translateForm");
	
	// Auto-planning sheet
	tabName := self.getControlCaption( form, "shtAutoPlan");
	position := null;
	
	if configOpts &lt;&gt; null then
		constantName := AutoPlanEnabled;
		value := configOpts.autoPlanEnabled.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkAPEnabled"), self.YardAlloc_Config, tabName, position, value, constantName, true);
	
	if configOpts &lt;&gt; null then
		constantName := AutoPlanAllowLogging;
		value := configOpts.autoPlanAllowLogging.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkAPAllowLog"), self.YardAlloc_Config, tabName, position, value, constantName, true);
	
	if configOpts &lt;&gt; null then
		constantName := AutoPlanGenerateSwapForYardInt;
		value := configOpts.autoPlanGenerateSwapForYardInt.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkAPGenSwapYard"), self.YardAlloc_Config, tabName, position, value, constantName, true);
	
	if configOpts &lt;&gt; null then
		constantName := AutoPlanGenerateSwapJob;
		value := configOpts.autoPlanGenerateSwapJob.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkAPGenSwapJob"), self.YardAlloc_Config, tabName, position, value, constantName, true);
	
	if configOpts &lt;&gt; null then
		constantName := AutoPlanUseOverstowRules;
		value := configOpts.autoPlanUseOverstowRules.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkAPUseOstowRul"), self.YardAlloc_Config, tabName, position, value, constantName, true);
	
	if configOpts &lt;&gt; null then
		constantName := AutoPlanYAGroupedBlocks;
		value := configOpts.autoPlanYAGroupedBlocks.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkAPYAGroupBlk"), self.YardAlloc_Config, tabName, position, value, constantName, true);
	
	if configOpts &lt;&gt; null then
		constantName := AutoPlanPreNotifications;
		value := configOpts.autoPlanPreNotifications.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkAPPreNotif"), self.YardAlloc_Config, tabName, position, value, constantName, true);
	
	if configOpts &lt;&gt; null then
		constantName := UseBestPickDirector;
		value := configOpts.autoPlanUseBestPickDirector.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkUseBestPickDr"), self.YardAlloc_Config, tabName, position, value, constantName, true);
	
	if configOpts &lt;&gt; null then
		constantName := AutoPlanUsePriorityLookup;
		value := configOpts.autoPlanUsePriorityLookup.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "chkUsePriLookup"), self.YardAlloc_Config, tabName, position, value, constantName, true);
	
	if configOpts &lt;&gt; null then
		constantName := AutoPlanPreNotiEmail;
		value := configOpts.autoPlanPreNotiEmail.String;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblAPEmail"), self.YardAlloc_Config, tabName, position, value, constantName, true);
	
	if configOpts &lt;&gt; null then
		constantName := FillOption;
		if configOpts.fillOption = YAFillOption_InOrder then
			value := YAFillOption_InOrderStr;
		elseif configOpts.fillOption = YAFillOption_Alternating then
			value := YAFillOption_AlternatingStr;
		elseif configOpts.fillOption = YAFillOption_FIFO then
			value := YAFillOption_FIFOStr;
		endif;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblDefaultFill"), self.YardAlloc_Config, tabName, position, value, constantName, true);
	
	if yaConfig &lt;&gt; null then
		constantName := "CM_YAConfig.autoPlanOverstowRule";
		if yaConfig.autoPlanOverstowRule = 0 or yaConfig.autoPlanOverstowRule = 1 then
			value := app.getErrorString(CMUI_YAConfigForm_ClosetPos).String;
		elseif yaConfig.autoPlanOverstowRule = 2 then
			value := app.getErrorString(CMUI_YAConfigForm_YA).String;
		elseif yaConfig.autoPlanOverstowRule = 3 then
			value := app.getErrorString(CMUI_YAConfigForm_HookCode).String;
		endif;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblAPOverstow"), self.YardAlloc_Config, tabName, position, value, constantName, true);
	
	if configOpts &lt;&gt; null then
		constantName := AutoPlanMTReleaseStrategy;
		if configOpts.autoPlanMTReleaseStrategy = 1 then
			value := app.getErrorString(MTRelStratYAOnly);
		elseif configOpts.autoPlanMTReleaseStrategy = 2 then
			value := app.getErrorString(MTRelStratBoth);
		elseif configOpts.autoPlanMTReleaseStrategy = 3 then
			value := app.getErrorString(MTRelStratTerminalOnly);
		endif;
	endif;
	self.addItem( _termElement, self.getControlCaption( form, "lblMTRelStrategy"), self.YardAlloc_Config, tabName, position, value, constantName, true);
	
epilog

	delete form;
	delete configOpts;

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_termElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isObjectStringUsedinConfig" id="ffe47b7f-c4c9-43fb-87fb-54578513c079">
        <source>isObjectStringUsedinConfig( _obj : Object; _returnStr : String output ): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2020	jlgndl1	Initial creation	TFS 50279 - These ones just store a string representing the objects

*/

vars

	objDisplay : String;
	terminal : CM_Terminal;
	operator : CM_Operator;


begin
	
	if _obj.isKindOf( CM_Commodity ) then
		objDisplay := _obj.CM_Commodity.code;
		foreach terminal in app.myRoot.allTerminals discreteLock do
			if objDisplay = terminal.getConfig(DefCommodity).String then
				_returnStr := app.getErrorString3( Terminal_config_uses, terminal.code, DefCommodity, objDisplay );
				return true;
			elseif objDisplay = terminal.getConfig(DefHazCommodity).String then
				_returnStr := app.getErrorString3( Terminal_config_uses, terminal.code, DefHazCommodity, objDisplay );
				return true;
			elseif objDisplay = terminal.getConfig(DefReeferComdty).String then
				_returnStr := app.getErrorString3( Terminal_config_uses, terminal.code, DefReeferComdty, objDisplay );
				return true;
			elseif objDisplay = terminal.getConfig(EmptyCommodity).String then
				_returnStr := app.getErrorString3( Terminal_config_uses, terminal.code, EmptyCommodity, objDisplay );
				return true;
			elseif objDisplay = terminal.getConfig(DefCommodityGroup).String then // this is actually derived from a commodity.
				_returnStr := app.getErrorString3( Terminal_config_uses, terminal.code, DefCommodityGroup, objDisplay );
				return true;
			endif;
		endforeach;
		
	elseif _obj.isKindOf( CM_ConsigneeConsignor ) then
		objDisplay := _obj.CM_ConsigneeConsignor.code;
		foreach operator in app.myRoot.allOperators discreteLock do
			if objDisplay = operator.getConfig(DefaultFreightPayerCode).String then
				_returnStr := app.getErrorString3( Operator_config_uses, operator.code, DefaultFreightPayerCode, objDisplay );
				return true;
			endif;
		endforeach;
		
	elseif _obj.isKindOf( CM_Carrier ) then
		objDisplay := _obj.CM_Carrier.code;
		foreach terminal in app.myRoot.allTerminals discreteLock do
			if objDisplay = terminal.getConfig(DefRailCarrier).String then
				_returnStr := app.getErrorString3( Terminal_config_uses, terminal.code, DefRailCarrier, objDisplay );
				return true;
			endif;
		endforeach;
		
	elseif _obj.isKindOf( CM_Operator ) then
		objDisplay := _obj.CM_Operator.code;
		foreach terminal in app.myRoot.allTerminals discreteLock do
			if objDisplay = terminal.getConfig(DefRecTrailOper).String then
				_returnStr := app.getErrorString3( Terminal_config_uses, terminal.code, DefRecTrailOper, objDisplay );
				return true;
			endif;
		endforeach;
		
	elseif _obj.isKindOf( CM_WagonClass ) then
		objDisplay := _obj.CM_WagonClass.code;
		foreach terminal in app.myRoot.allTerminals discreteLock do
			if objDisplay = terminal.getConfig(DefWagonClass).String then
				_returnStr := app.getErrorString3( Terminal_config_uses, terminal.code, DefWagonClass, objDisplay );
				return true;
			endif;
		endforeach;
		
	elseif _obj.isKindOf( CM_ToDoTaskDesc ) then
		objDisplay := _obj.CM_ToDoTaskDesc.description;
		foreach terminal in app.myRoot.allTerminals discreteLock do
			if objDisplay = terminal.getConfig(DefNoInfoToDo).String then
				_returnStr := app.getErrorString3( Terminal_config_uses, terminal.code, DefNoInfoToDo, objDisplay );
				return true;
			endif;
		endforeach;
		
	endif;

	return false;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_returnStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isObjectUsedinConfig" id="913bda27-bbac-44cb-a73a-a5e92f6857c6">
        <source>isObjectUsedinConfig( _obj : Object; _returnStr : String output ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2020	jlgndl1	Initial creation	TFS 50279 - check to see where this object is in use.

*/

vars

	objDisplay : String;
	key : String;
	terminal : CM_Terminal;
	user : CM_User;
	operator : CM_Operator;
	bank : CM_Bank;

begin

	if _obj = null then
		return false;
	endif;

	if _obj.isKindOf( CM_Bank ) then
		objDisplay := _obj.CM_Bank.code;
	elseif _obj.isKindOf( CM_Operator ) then
		objDisplay := _obj.CM_Operator.code;
	elseif _obj.isKindOf( CM_ISOType ) then
		objDisplay := _obj.CM_ISOType.code;
	elseif _obj.isKindOf( CM_SelectorQueryAccess ) then
		objDisplay := _obj.CM_SelectorQueryAccess.description;
	elseif _obj.isKindOf( CM_Voyage ) then
		objDisplay := _obj.CM_Voyage.code;
	elseif _obj.isKindOf( CM_ToDoTaskDesc ) then
		objDisplay := _obj.CM_ToDoTaskDesc.description;
	elseif _obj.isKindOf( CM_Stevedore ) then
		objDisplay := _obj.CM_Stevedore.code;
	elseif _obj.isKindOf( CM_ExtFinanceIO ) then
		objDisplay := _obj.CM_ExtFinanceIO.getNiceName;
	elseif _obj.isKindOf( CM_Gate ) then
		objDisplay := _obj.CM_Gate.name;
	elseif _obj.isKindOf( CM_InvoiceDesc ) then
		objDisplay := _obj.CM_InvoiceDesc.description;
	elseif _obj.isKindOf( CM_InvoiceLineDesc ) then
		objDisplay := _obj.CM_InvoiceLineDesc.narration;
	elseif _obj.isKindOf( CM_VoidDebtor ) then
		objDisplay := _obj.CM_VoidDebtor.name;
	elseif _obj.isKindOf( CM_ConsigneeConsignor ) then
		objDisplay := _obj.CM_ConsigneeConsignor.code;
	elseif _obj.isKindOf( CM_SubTerminal ) then
		objDisplay := _obj.CM_SubTerminal.code;
	elseif _obj.isKindOf( CM_DebtorType ) then
		objDisplay := _obj.CM_DebtorType.code;
	elseif _obj.isKindOf( CM_OutputFormat ) then
		objDisplay := _obj.CM_OutputFormat.name;
	elseif _obj.isKindOf( CM_TerminalAreaType ) then
		objDisplay := _obj.CM_TerminalAreaType.description;
	elseif _obj.isKindOf( CM_WagonClass ) then
		objDisplay := _obj.CM_WagonClass.code;
	elseif _obj.isKindOf( CM_StopsTable ) then
		objDisplay := _obj.CM_StopsTable.code;
	elseif _obj.isKindOf( CM_Vessel ) then
		objDisplay := _obj.CM_Vessel.code;
	elseif _obj.isKindOf( CM_DayType ) then
		objDisplay := _obj.CM_DayType.code;
	elseif _obj.isKindOf( HMS_HarbourRegion ) then
		objDisplay := _obj.HMS_HarbourRegion.code;
	elseif _obj.isKindOf( CM_DelayTypeGroup ) then
		objDisplay := _obj.CM_DelayTypeGroup.description;
	elseif _obj.isKindOf( CM_StorageConfigType ) then
		objDisplay := _obj.CM_StorageConfigType.getNiceName;
	elseif _obj.isKindOf( CM_RoadProcess ) then
		objDisplay := _obj.CM_RoadProcess.description;
	else
		//AND for string values representing objects
		return self.isObjectStringUsedinConfig( _obj, _returnStr );
	endif;
	
	//The following set are where teh object itself is stored
	if app.myRoot.hasStateDataRefToObj( _obj, key ) then
		_returnStr := app.getErrorString2( System_config_uses, key, objDisplay );
		return true;
	endif;
	
	foreach terminal in app.myRoot.allTerminals discreteLock do
		if terminal.hasStateDataRefToObj( _obj, key ) then
			_returnStr := app.getErrorString3( Terminal_config_uses, terminal.code, key, objDisplay );
			return true;
		endif;
	endforeach;
	
	foreach user in app.myRoot.allUsers discreteLock do
		if user.hasStateDataRefToObj( _obj, key ) then
			_returnStr := app.getErrorString3( User_config_uses, user.code, key, objDisplay );
			return true;
		endif;
	endforeach;
	
	foreach operator in app.myRoot.allOperators discreteLock do
		if operator.hasStateDataRefToObj( _obj, key ) then
			_returnStr := app.getErrorString3( Operator_config_uses, operator.code, key, objDisplay );
			return true;
		endif;
	endforeach;
	
	foreach terminal in app.myRoot.allTerminals discreteLock do
		foreach bank in terminal.companies discreteLock do
			if bank.hasStateDataRefToObj( _obj, key ) then
				_returnStr := app.getErrorString3( Bank_config_uses, terminal.code &amp; "/" &amp; bank.code, key, objDisplay );
				return true;
			endif;
		endforeach;
	endforeach;
	
	//and now for teh ones that may be strings stored representing objects.
	return self.isObjectStringUsedinConfig( _obj, _returnStr );

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_returnStr" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateDisplayLineObjects" id="5def2318-fc5a-4bdd-9f83-77dc309c6270">
        <source>populateDisplayLineObjects();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
14 Aug 2014	cnwndl1	Initial creation
20 Sep 2019	jlgndl1	45972	Added storage configuration
21 Mar 2023	jlika1	TFS 57126	CUX - Make VMT filtering configurable per RT Config
*/

begin
	if self.allDisplayLineObjects &lt;&gt; null then
		self.allDisplayLineObjects.purge();
	endif;
	
	if self.myTerminal = null then
		return;
	endif;
	
	self.getTermConfigOptions( self.myTerminal, null );
	self.getYAMConfig( self.myTerminal, null );
	self.getSystemConfigOptions( null );
	self.getGateConfiguration( self.myTerminal, null );
	self.getRailConfiguration( self.myTerminal, null );
	self.getVoyageConfiguration( self.myTerminal, null );
// ### JIRA 33504 11DEC2024 NAVAB1	self.getVehicleRTConfiguration( self.myTerminal, null );
	self.getVesselRoRoConfig( null );
	self.getInvoiceSystemDefaults( self.myTerminal, null );
	self.getAutoIdConfiguration( self.myTerminal, null  );
	self.getHandHeldConfig( self.myTerminal, null  );
	self.getStorageConfig( self.myTerminal, null  );
	self.getVehicleRTVehAppsSettings( self.myTerminal, null );
end;</source>
    </JadeMethod>
    <JadeMethod name="populateXmlDoc" id="461b298f-1927-434a-baf8-d92ad39e47ae">
        <updating/>
        <source>populateXmlDoc() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2014	cnwndl1	Initial creation
20 Sep 2019	jlgndl1	45972 Added storage configuration
21 Mar 2023	jlika1	TFS 57126	CUX - Make VMT filtering configurable per RT Config
*/

vars
	docElement : JadeXMLElement;
	rootElement	: JadeXMLElement;
	termElement	: JadeXMLElement;
	xmlElement	: JadeXMLElement;
	rootAttrib : Boolean;
	
begin
	if self.xmlDoc &lt;&gt; null then
		delete self.xmlDoc;
	endif;
	
	if self.myTerminal = null then
		return;
	endif;
	
	create xmlDoc transient;
	docElement := xmlDoc.addElement( "Configs" );
	rootElement := docElement.addElement( "System" );
	rootElement.addCDATA( self.sysEnviron );
	termElement := docElement.addElement( "Terminal" );
	termElement.addCDATA( self.termEnviron );
	
	self.getTermConfigOptions( self.myTerminal, termElement );
	self.getYAMConfig( self.myTerminal, termElement );
	self.getSystemConfigOptions( rootElement);
	self.getGateConfiguration( self.myTerminal, termElement );
	self.getRailConfiguration( self.myTerminal, termElement );
	self.getVoyageConfiguration( self.myTerminal, termElement );
// ### JIRA 33504 11DEC2024 NAVAB1	self.getVehicleRTConfiguration( self.myTerminal, termElement );
	self.getVesselRoRoConfig( rootElement );
	self.getInvoiceSystemDefaults( self.myTerminal, termElement );
	self.getAutoIdConfiguration( self.myTerminal, termElement );
	self.getHandHeldConfig( self.myTerminal, termElement  );
	self.getStorageConfig( self.myTerminal, termElement  );
	self.getVehicleRTVehAppsSettings( self.myTerminal, null );
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTerminal" id="7d875169-3104-4acd-9416-b7308fac5f62">
        <updating/>
        <source>setMyTerminal( _terminal : CM_Terminal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
14 August 2014	cnwndl1	Initial creation
11 July 2018	jlgmd1	Fixed 1035 for default Starter DB name

*/

vars

	environ : String;
	strArray : CnStringArray;
	str : String;

begin

	self.myPortSchema := rootSchema.getSchema("PortSchema");

	self.myTerminal := _terminal;
	
	if self.myTerminal = null then
		return;
	endif;
	
	strArray := global.cnGetServerInstallDir().cnGetTokens("/");
	
	if strArray &lt;&gt; null then
		foreach str in strArray do
			if str.toUpper.pos("JMT",1) &gt; 0 then
				environ := str;
				break;
			endif;
			if str.toUpper.pos("MAST",1) &gt; 0 then
				environ := str;
				break;
			endif;
		endforeach;
	endif;
	
	if environ = null then
		sysEnviron := app.myRoot.getVersionAndPatchLevel.replaceString(".","_");
		termEnviron := ( self.myTerminal.code &amp; "_" &amp;  sysEnviron )[1:30];
	else
		sysEnviron := environ &amp; "_" &amp;  app.myRoot.getVersionAndPatchLevel.replaceString(".","_");
		termEnviron := ( self.myTerminal.code &amp; "_" &amp;  sysEnviron )[1:30];
	endif;

epilog

	if strArray &lt;&gt; null then
		delete strArray;
	endif;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="valuesMatch" id="a9b327e9-53dd-46b6-8073-649e83117f18">
        <source>valuesMatch( _value1 : String; _value2 : String ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2014	cnwndl1	Initial creation

*/

vars

begin

	if _value1 = _value2 then
		return true;
	endif;
	
	if ( _value1.trimBlanks = null and _value2 = "false" )
	or ( _value2.trimBlanks = null and _value1 = "false" )
	then
		return true;
	endif;
	
	if ( _value1.trimBlanks = null and _value2 = "0" )
	or ( _value2.trimBlanks = null and _value1 = "0" )
	then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_value1" type="String"/>
        <Parameter name="_value2" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
