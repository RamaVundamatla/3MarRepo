    <JadeMethod name="getNewLabels" id="60f97292-229a-42ee-a2f4-f913a198c0a6">
        <source>getNewLabels(_allRowLabels, _allColumnLabels : StringArray input);

vars

	gridColumn	: CMUI_GridColumn;
	gridRow		: CMUI_GridRow;

begin

	foreach gridColumn in self.allGridColumns do
