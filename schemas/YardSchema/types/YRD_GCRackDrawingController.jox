    <JadeMethod name="init" id="8079abed-41c2-47b1-ba9b-f105a18f4529">
        <updating/>
        <source>init(_terminalArea: CM_TerminalAreaMaster; _rows: CM_ObjectArray) updating;
/*
Purpose:			
Date		Who		Reason
06 September 2013	cnwab1	Initial creation
*/

vars
	yalloc : CM_YardAllocation;
begin
	inheritMethod(_terminalArea, _rows);

	
	self.myDrawingAttrController.allYardAllocations.clear;
		
	foreach yalloc in self.myTerminalArea.CM_IrregularBlockArea.allYardAllocations discreteLock where not (yalloc.isDisabled or not yalloc.includeInYardDisplays()) do
		self.myDrawingAttrController.allYardAllocations.addNoDuplicates(yalloc,false);
	endforeach;

epilog

end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalAreaMaster"/>
        <Parameter name="_rows" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="isForGCRack" id="a8ced655-9709-4160-94f4-c4ccb108130f">
