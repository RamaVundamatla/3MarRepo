<Class name="CM_TestDataMove" id="439c44ef-e139-4dd2-9d67-c17f893b55ee">
    <superclass name="CM_TestDataEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="testData"/>
    <ImplicitInverseRef name="allLCs" id="bce412df-6c0f-4948-a5b7-cebd5226d1cd">
        <memberTypeInverse/>
        <type name="CM_LCArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allTIs" id="df51a1ba-75b9-47af-8b20-2023e5f8775d">
        <memberTypeInverse/>
        <type name="CM_TIArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="myTestDataRoot" id="6e7946c8-442e-45ec-8ac2-97dcf2c7e178">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_TestDataRoot"/>
        <access>readonly</access>
        <Inverse name="CM_TestDataRoot::myTestDataMove"/>
