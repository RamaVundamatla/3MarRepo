    <JadeMethod name="colourBackground" id="40e56c30-9f29-45af-a4ae-f1db0c06e606">
        <updating/>
        <source>colourBackground() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	conkc1	Initial creation

*/

vars

begin
	tbx_o1.backColor := White;
	tbx_o2.backColor := White;
	tbx_o3.backColor := White;
	tbx_o4.backColor := White;
	tbx_o5.backColor := White;

	if v_objectNumber = 0 then
		tbx_o1.backColor := LightYellow;
	elseif v_objectNumber = 1 then
		tbx_o2.backColor := LightYellow;
	elseif v_objectNumber = 2 then
		tbx_o3.backColor := LightYellow;
	elseif v_objectNumber = 3 then
		tbx_o4.backColor := LightYellow;
	elseif v_objectNumber = 4 then
		tbx_o5.backColor := LightYellow;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getLockString" id="d83cdbc6-91a6-48f8-b7f4-95b0f21dbcbd">
        <updating/>
        <source>getLockString() updating;

vars
	obStr    : String;
	lockType : Integer;
begin
	if v_objectNumber = 0 then
		if tbx_o1.text.trimBlanks &lt;&gt; null then
			obStr := tbx_o1.text;
			lockType := getLockType(opt1_s.value, opt1_r.value, opt1_e.value);
		else
		endif;
	elseif v_objectNumber = 1 then
		if tbx_o1.text.trimBlanks &lt;&gt; null then
			obStr := tbx_o2.text;
			lockType := getLockType(opt2_s.value, opt2_r.value, opt2_e.value);
		else
		endif;
	elseif v_objectNumber = 2 then
		if tbx_o1.text.trimBlanks &lt;&gt; null then
			obStr := tbx_o3.text;
			lockType := getLockType(opt3_s.value, opt3_r.value, opt3_e.value);
		else
		endif;
	elseif v_objectNumber = 3 then
		if tbx_o1.text.trimBlanks &lt;&gt; null then
			obStr := tbx_o4.text;
			lockType := getLockType(opt4_s.value, opt4_r.value, opt4_e.value);
		else
		endif;
	elseif v_objectNumber = 4 then
		if tbx_o1.text.trimBlanks &lt;&gt; null then
			obStr := tbx_o1.text;
			lockType := getLockType(opt5_s.value, opt5_r.value, opt5_e.value);
		else
		endif;
	else
	endif;
	lockObject(obStr, Exclusive_Lock, Transaction_Duration);
end;
</source>
    </JadeMethod>
    <JadeMethod name="getLockType" id="bd198d22-f545-466f-9169-68457d95d028">
        <updating/>
        <source>getLockType(opt1 : Boolean; opt2 : Boolean; opt3 : Boolean) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 November 2009	conkc1	Initial creation

*/

vars
	lockType : Integer;
begin

	if opt1 = true then
		lockType := Share_Lock;
	elseif opt2 = true then
		lockType := Reserve_Lock;
	else
		lockType := Exclusive_Lock;
	endif;
	
	return lockType;
epilog

end;</source>
        <Parameter name="opt1" type="Boolean"/>
        <Parameter name="opt2" type="Boolean"/>
        <Parameter name="opt3" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getUnlockString" id="6aec7b8e-b943-4ee0-b337-57ae477d2385">
        <updating/>
        <source>getUnlockString() updating;

vars
	obStr : String;
begin
	if v_objectNumber = 0 then
		if tbx_o1.text.trimBlanks &lt;&gt; null then
			obStr := tbx_o1.text;
		else
		endif;
	elseif v_objectNumber = 1 then
		if tbx_o1.text.trimBlanks &lt;&gt; null then
			obStr := tbx_o2.text;
		else
		endif;
	elseif v_objectNumber = 2 then
		if tbx_o1.text.trimBlanks &lt;&gt; null then
			obStr := tbx_o3.text;
		else
		endif;
	elseif v_objectNumber = 3 then
		if tbx_o1.text.trimBlanks &lt;&gt; null then
			obStr := tbx_o4.text;
		else
		endif;
	elseif v_objectNumber = 4 then
		if tbx_o1.text.trimBlanks &lt;&gt; null then
			obStr := tbx_o1.text;
		else
		endif;
	else
	endif;
	unlockObject(obStr);
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="d6c8544c-993c-4e76-9215-66a62fe87aa4">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	conkc1	Initial creation

*/

vars

begin
	colourBackground;
	process.setPersistentDeadlockPriority(1000);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="lockObject" id="a8aa2950-7ced-4888-8b00-601d3f1d296e">
        <updating/>
        <source>lockObject(obStr : String; lockType : Integer; lockDuration : Integer) updating;

vars
	object : Object;
	time   : Time;
begin
	object := obStr.asOid;
	if object &lt;&gt; null then
		lock(object, lockType, lockDuration, 100000);
		sl_status.caption := time.String &amp; ' ' &amp; obStr &amp; ' locked';
		v_objectNumber := v_objectNumber + 1;
	else
		sl_status.caption := time.String &amp; ' ' &amp; obStr &amp; ' invalid';
	endif;
	colourBackground;
end;
</source>
        <Parameter name="obStr" type="String"/>
        <Parameter name="lockType" type="Integer"/>
        <Parameter name="lockDuration" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tbx_o1_gotFocus" id="c7605560-f9aa-4fda-bc0e-42b7bba55262">
