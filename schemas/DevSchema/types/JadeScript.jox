Return Value:		

Date		Who		Reason
19 September 2023	jlier1	Initial creation

*/

vars
	kiosk : CM_Kiosk;
	printer : CM_PrinterDef;
	allPrintErrors :  CM_ErrorsByTypeStatusDict;
	printError : CM_ErrorPersistent;
	text : String;
	
		msgLen, i : Integer;
	currentChar, nextChar : Character;
	numSubs : Integer;	
	vvr : CM_VehicleVisitRecord;
	file : File;
	fileName : String;
	jadeReport				: JadeReport;
begin	

	/*text:="%1 passengers exceeds the maximum of %2 allowed";
	
	

	msgLen := text.length;
	
	foreach i in 1 to msgLen do
		currentChar := text[i];
		if i + 1 &lt;= msgLen then
			nextChar := text[i + 1];
		else
			nextChar := null;
		endif;
		
		if currentChar = '%' and nextChar &gt;= '1' and nextChar &lt;= '9' then
			numSubs := numSubs + 1;
			i := i + 2;
		endif;
	endforeach;
	
	
	return;*/
	
	
	app.initialize;
	app.myPassport.setMyUserFromCode("JL1ER1");

	kiosk := "10375.26".asOid.CM_Kiosk;
	printer:="3377.6418".asOid.CM_PrinterDef;
	/*create allPrintErrors transient;
	create printError transient;
	printError.setTextValues("WRONG TRANSPORT REFERENCE, CALL YOUR BOSS","RIFERIMENTO TRASPORTO ERRATO, CHIAMA IL CAPO");
	allPrintErrors.add(printError);
	
	kiosk.printKioskErrors(printer,allPrintErrors,null,null);*/
	
	app.setMySecondaryLocale("7298.822".asOid.CM_Locale);
	
	/*on CM_Exception do self.handleCMException(exception);
	
	app.raiseCMException2(Passeng_exceeds_allowed_maximu,"4", "3",null,null);	
		//print report
	kiosk.printKioskErrorsFromPPErrors(printer,null,"234234234");
	*/
	vvr:="3100.1992034".asOid.CM_VehicleVisitRecord;
	
	
	create jadeReport transient;
	jadeReport.copies:=1;
	app.printer.setReport(jadeReport);
	
	vvr.myRoadJob.printDriverDetails(1,false,null,printer.physicalPrinterName);	
	
	fileName:="C:\Temp\DriverDetails_"  &amp; app.actualTimeServer.fileNameFormat &amp; "_" &amp; 
				self.getInstanceIdForObject64(process).String &amp; "_" &amp; 
				self.getInstanceIdForObject64(self).String &amp; ".pdf";
	
	create file transient;
	file.mode := File.Mode_Output;
	file.fileName := fileName ;		
	app.printer.setPrintFileName(fileName);
	app.printer.printReport(jadeReport);
		
epilog
	if allPrintErrors &lt;&gt; null then
		allPrintErrors.purge;
	endif;
	delete allPrintErrors;
	delete jadeReport;
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestKiwiRailRequest" id="aa1d32e2-99db-4e0b-b045-deeece050a13">
        <source>eprTestKiwiRailRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 January 2019	jlger1	Initial creation

*/

vars

conn			: JadeHTTPConnection;
	ws : CM_InaportnetWSConsumerAgent;
	request : CMIF_IPNGetPKKRequest;
	response : CMIF_IPNGetPKKResponse;
	
	request2 : CMIF_IPNGetRKBMRequest;
	response2 : CMIF_IPNGetRKBMResponse;
	timeoutMS		: Integer;
	json : String;
		sendSuccess		: Boolean;
			returnVal		: String;
	xml  : JadeXMLDocument;
	xmlEquipment,
	xmlBody,
	xmlCheckIn,
	xmlMessage : JadeXMLElement;
begin
	
	create xml transient;
	xml.outputDeclaration := false;
	xmlMessage:=xml.addElement("soapenv:Envelope");
	xmlMessage.addAttribute("xmlns:soapenv","http://schemas.xmlsoap.org/soap/envelope/");
	xmlMessage := xml.rootElement.addElement("soapenv:Header");
	xmlBody := xml.rootElement.addElement("soapenv:Body");
	xmlCheckIn := xmlBody.addElement("chec:CheckIn");
	xmlMessage := xmlCheckIn.addElement("metadata");
	xmlCheckIn := xmlCheckIn.addElement("checkIn");
	xmlEquipment:= xmlCheckIn.addElement("equipment");
	xmlEquipment:= xmlCheckIn.addElement("equipment");
	
	write xml.writeToString();
	//return;
/*	xmlElement := xmlMessage.addElement("type");
	xmlElement.addElement("dataType").setText("ProfileType");
	xmlElement.addElement("value").setText(cargoType);
	xmlElement := xmlMessage.addElement("aliasId");
	xmlElement.addElement("dataType").setText("AliasId");
	xmlElement.addElement("value").setText(_cargo.getOidAsString());
	xmlElement := xmlMessage.addElement("aliasName");
	xmlElement.addElement("dataType").setText("AliasName");
	xmlElement.addElement("value").setText(_cargo.id);
	xmlElement := xmlMessage.addElement("creationDate");
	cargoJSON := jsonHelper.convertXMLToJson(xml.writeToString());*/
	
	
	create conn transient;
	
	// Set timeouts of required
	//if self.timeoutSeconds &lt;&gt; 0 then
		timeoutMS := 60 * 1000;
		conn.sendTimeout := timeoutMS;
		conn.receiveTimeout := timeoutMS;
	//endif;
	
	json:='&lt;?xml version="1.0" encoding="UTF-8"?&gt;

-&lt;soapenv:Envelope xmlns:met="http://www.kiwirail.co.nz/metadata" xmlns:chec="http://www.kiwirail.co.nz/checkin/" xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/"&gt;

&lt;soapenv:Header/&gt;


-&lt;soapenv:Body&gt;


-&lt;chec:CheckIn&gt;


-&lt;metadata&gt;

&lt;met:requestID&gt;?&lt;/met:requestID&gt;

&lt;met:timestamp&gt;?&lt;/met:timestamp&gt;

&lt;met:requestOrganisation&gt;?&lt;/met:requestOrganisation&gt;

&lt;met:replyOrganisation&gt;?&lt;/met:replyOrganisation&gt;

&lt;!--Zero or more repetitions:--&gt;


&lt;met:responseID&gt;?&lt;/met:responseID&gt;


-&lt;met:credentials&gt;

&lt;met:username&gt;?&lt;/met:username&gt;

&lt;met:password&gt;?&lt;/met:password&gt;

&lt;/met:credentials&gt;

&lt;/metadata&gt;


-&lt;checkIn&gt;

&lt;bookingID&gt;?&lt;/bookingID&gt;

&lt;timestamp&gt;?&lt;/timestamp&gt;

&lt;!--Optional:--&gt;


&lt;customerReference&gt;?&lt;/customerReference&gt;

&lt;!--Optional:--&gt;


&lt;commodityCode&gt;?&lt;/commodityCode&gt;

&lt;!--Optional:--&gt;


&lt;freightPayerCode&gt;?&lt;/freightPayerCode&gt;

&lt;!--Optional:--&gt;


&lt;checkInLocation&gt;?&lt;/checkInLocation&gt;

&lt;!--1 or more repetitions:--&gt;



-&lt;equipment&gt;

&lt;equipmentType&gt;?&lt;/equipmentType&gt;

&lt;equipmentID&gt;?&lt;/equipmentID&gt;

&lt;!--Optional:--&gt;


&lt;tareWeightKG&gt;?&lt;/tareWeightKG&gt;

&lt;netWeightKG&gt;?&lt;/netWeightKG&gt;

&lt;!--Optional:--&gt;


&lt;sizeTypeCode&gt;?&lt;/sizeTypeCode&gt;

&lt;overheight&gt;?&lt;/overheight&gt;

&lt;empty&gt;?&lt;/empty&gt;

&lt;!--Optional:--&gt;


&lt;orderNumber&gt;?&lt;/orderNumber&gt;

&lt;!--Optional:--&gt;



+&lt;checkInParticulars&gt;
&lt;!--Optional:--&gt;
+&lt;refrigeration&gt;
&lt;!--Optional:--&gt;
+&lt;imex&gt;

&lt;!--Zero or more repetitions:--&gt;
-&lt;seals&gt;

&lt;sealNumber&gt;?&lt;/sealNumber&gt;

&lt;/seals&gt;

&lt;!--Zero or more repetitions:--&gt;
+&lt;consignments&gt;
&lt;!--Zero or more repetitions:--&gt;
+&lt;hazardous&gt;

&lt;!--Optional:--&gt;
&lt;overGauge&gt;?&lt;/overGauge&gt;

&lt;!--Optional:--&gt;
	&lt;underBond&gt;?&lt;/underBond&gt;
&lt;/equipment&gt;

&lt;senderCode&gt;?&lt;/senderCode&gt;

&lt;railDestination&gt;?&lt;/railDestination&gt;

&lt;/checkIn&gt;

&lt;/chec:CheckIn&gt;

&lt;/soapenv:Body&gt;

&lt;/soapenv:Envelope&gt;';
	
	conn.url := "https://ws-test.kiwirail.co.nz/EDIWeb/CheckIn";
	sendSuccess := conn.sendRequest("POST", 'Content-Type: application/xml', xml.writeToString());
		write sendSuccess;
		if sendSuccess then
		conn.readBody(0);
		returnVal := conn.responseBody.StringUtf8.String;
	
		write returnVal;
	endif;

epilog
	delete xml;
	delete conn;

end;</source>
    </JadeMethod>
