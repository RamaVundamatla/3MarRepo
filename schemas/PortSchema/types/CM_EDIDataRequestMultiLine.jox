    <JadeMethod name="getEDIPartyCoparnRules" id="c9f16b94-9990-4884-bcb9-0ebd6eb335ff">
        <source>getEDIPartyCoparnRules(_sender : String) : CM_EDIPartyCoparnRules;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
// 09 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
vars
	party : CM_EDIParty;
	rule : CM_EDIPartyRules;
begin
	if _sender = null then
		return null;
	endif;
	
	party := self.getMyTerminal().allEDIPartiesBySenderCode[_sender];
	
	if party &lt;&gt; null then
		return party.getRulesForFileType(EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	endif;
epilog

end;</source>
        <Parameter name="_sender" type="String"/>
        <ReturnType type="CM_EDIPartyCoparnRules"/>
