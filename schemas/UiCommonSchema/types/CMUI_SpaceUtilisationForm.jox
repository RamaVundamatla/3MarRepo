    <JadeMethod name="fileExceptionHandler" id="aa324f4e-6867-40f5-bbe6-73d9e5695167">
        <source>fileExceptionHandler(exObj: Exception): Integer;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	errorText: String;
begin
	errorText := "Opening file: '" &amp; exObj.FileException.file.fileName &amp; "' caused error";
	errorText := errorText &amp; Lf &amp; exObj.text &amp; Lf &amp; "    Aborting Export Operation!";
	app.msgBox(errorText, "File Open Error",
		MsgBox_OK_Only  + MsgBox_System_Modal + MsgBox_Exclamation_Mark_Icon);

	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;

	return Ex_Abort_Action;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getKPITAfromRealTA" id="797353a4-1d10-4afe-bffb-d3848de34deb">
        <source>getKPITAfromRealTA(_real : CM_TerminalArea) : CM_KPITerminalArea;
// ---------------------------------------------------------------------------
// Created:		07 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	kpi : CM_KPI;
begin
	foreach kpi in self.myQueryAgent.allKPITerminalAreas discreteLock do
		if kpi.CM_KPITerminalArea.terminalAreaCode = _real.id then
			return kpi.CM_KPITerminalArea;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_real" type="CM_TerminalArea"/>
        <ReturnType type="CM_KPITerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="853d6db7-3b45-4545-b8f5-178c8d56167d">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	anObj : Object;
	tmpStr, xmlStr	: String;
	entRow	: EntTableRow;	
begin
	xmlStr := inheritMethod();
	xmlStr := xmlStr &amp; self.tblHaz.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblYA.getXmlStrForColumns(true);
	
	foreach anObj in self.lstTermArea.allSelectedObjects do
		tmpStr := tmpStr &amp; anObj.CM_TerminalAreaMaster.id &amp; "/";
	endforeach;
	
	xmlStr := xmlStr &amp; global.formatAsXML("TAS", tmpStr);
	
	return xmlStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="f56942c5-42f4-4a07-ad70-c3764770c71f">
        <source>getXMLSettingsForSetup();
// ---------------------------------------------------------------------------
// Created:		07 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
08 Sep 2022	jlika1	TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
============================================================================*/
vars
	userWindow		: CM_UserWindow;
	theCode, theXML, theXMLValue : String;
	tas : StringArray;
	theTA : CM_TerminalAreaMaster;
begin
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
	endif;

	create tas transient;
	theXML := userWindow.xmlInfo;

 	theXMLValue := theXML.cnEcGetTagValueOfName("TAS");
 	if theXMLValue &lt;&gt; null then
		tas := theXMLValue.getTokens();
	endif;
	
	if not tas.isEmpty then
		foreach theCode in tas do
			theTA := self.myTerminal.allTerminalAreas[theCode];
			if theTA = null then
				theTA := self.myTerminal.allTerminalAreaMastersById[theCode];
			endif;
			
			if theTA &lt;&gt; null then
					//21 Jun 2016	NDL	TFS 1752 - was loading an old rogue one..
				if theTA.type  = TA_TYPE_STRADDLE_STACK
				or theTA.type = TA_TYPE_FORK_LIFT_STACK
				or theTA.type = TA_TYPE_RTG 
				or theTA.type = TA_TYPE_RMG
				or theTA.type = TA_TYPE_BLOCK_STACK   
				or theTA.type = TA_TYPE_RORO_LANE_AREA	
				or theTA.type = TA_TYPE_IRREGULAR_BLOCK_AREA
				or theTA.type = TA_TYPE_MAFI
				then
					self.lstTermArea.addSelectedObject(theTA);
				endif;
			endif;
		endforeach;
	endif;
 epilog
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="hasCONT" id="4e8c8917-5613-49f8-8f73-28e147ff7c77">
        <source>hasCONT() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2025	navkc1 JIRA 35623

*/

vars

begin
	return self.myQueryAgent.hasCONT();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasRoRoOnly" id="25c0ff67-8306-4622-b6b9-3b02a8e441d9">
        <source>hasRoRoOnly() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2025	navkc1 JIRA 35623

*/

vars
	obj	  : Object;
	kpiTA : CM_KPITerminalArea;
begin
	
	// We have something in the collection, means we just did a query.
	if self.myQueryAgent.allKPITerminalAreas.isNotEmpty() then
		return self.myQueryAgent.hasRoRoOnly();
	else
	// We must have selected a KPI_TerminalArea from the combobox, i.e. displaying a saved result.
		obj := self.cmbKPITA.listObject;
		
		if obj &lt;&gt; null and obj.isKindOf(CM_KPITerminalArea) then
			kpiTA := obj.CM_KPITerminalArea;
			
			return kpiTA.isRoRoLane();
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="e1975b7a-3114-402a-8eda-56f9be0511fd">
        <source>initQueryFrame() protected;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	HorzGap = 5;
vars
	sht			: CMUI_Sheet;
	lstTable	: CMUI_ListTable;
begin
	
	sht := self.shtQuery1;
	sht.caption := "Terminal Areas";
	sht.visible := true;
	
	sht := self.shtQuery2;
	sht.caption := app.getErrorString(CargoTypes);
	sht.visible := true;

	sht := self.shtQuery3;
	sht.caption := app.getErrorString(Operators);
	sht.visible := true;
	
	sht := self.shtQuery4;
	sht.caption := "Options";
	sht.visible := true;
	self.fldQuery.topSheet := sht;
	
	sht := self.shtQuery5;
	sht.caption := app.getErrorString(Ports);
	sht.visible := true;
	
	
	sht := self.shtQuery6;
	sht.caption := "Types";
	sht.visible := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTableData" id="7de4a6cf-7907-4f57-bef6-14cd77528e1b">
        <source>initTableData(_theEntDef : String);
// ---------------------------------------------------------------------------
// Created:		09 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	int		: Integer;
	tbl		: CM_DataTable;
	pads,
	teus,
	availStr : String;
	onlyRoRo : Boolean;
begin
	tbl := self.tblData;
	
	tbl.clear();
	tbl.selectionType	:= CM_BaseTable.SelectionType_Row;
	tbl.selectMode		:= Table.SelectMode_WholeRows;
	tbl.multiSelect		:=	CM_BaseTable.MultiSelect_Simple;
	tbl.fixed3D 		:= false;
	tbl.rows			:= 2;
	tbl.top := 1;
	tbl.fixedRows		:= 2;
	tbl.fixedColumns	:= 0;
	tbl.gridLines		:= true;
	tbl.gridColor		:= Grey;
	tbl.columns			:= 20;
	
	self.setColorsForTable(tbl);

	foreach int in 2 to (tbl.columns) do
		tbl.accessColumn(int).alignment := Table.Alignment_Right;
	endforeach;

	tbl.accessColumn(2).width := 100;
	tbl.accessColumn(3).width := 100;
	tbl.accessColumn(4).width := 100;
	//tbl.accessColumn(tbl.columns).alignment := Table.Alignment_Center;
	
	tbl.accessRow(1).alignment := Table.Alignment_Center_Middle;
	
	tbl.accessCell(1, 2).mergeCells := Table.MergeCells_Merge;
	tbl.accessedCell.alignment := Table.Alignment_Center;
	tbl.accessCell(1, 4).mergeCells := Table.MergeCells_Merge;
	tbl.accessedCell.alignment := Table.Alignment_Center;
	tbl.accessCell(1, 6).mergeCells := Table.MergeCells_Merge;
	tbl.accessedCell.alignment := Table.Alignment_Center;
	tbl.accessCell(1, 8).mergeCells := Table.MergeCells_Merge;
	tbl.accessedCell.alignment := Table.Alignment_Center;
	tbl.accessCell(1, 10).mergeCells := Table.MergeCells_Merge;
	tbl.accessedCell.alignment := Table.Alignment_Center;
	tbl.accessCell(1, 13).mergeCells := Table.MergeCells_Merge;
	tbl.accessedCell.alignment := Table.Alignment_Center;
	
	onlyRoRo := self.hasRoRoOnly(); //05/09/2025	navkc1 JIRA 35623
	
	if onlyRoRo then
		pads := "Length";
		teus := "Length";
	else
		pads := "Pads";
		teus := "TEUs";
	endif;
	
	tbl.accessCell(1, 1).text := Tab &amp; 
								"Total" &amp; Tab &amp; Tab &amp; 
								"Empty" &amp; Tab &amp;	Tab &amp;
								"Occupied" &amp; Tab &amp; Tab &amp;
								"Full" &amp; Tab &amp; Tab &amp; 
								"Capacity"&amp; Tab &amp; Tab &amp; Tab &amp; 
								"Availability By Height";
	foreach int in 1 to 8 do
		availStr := availStr &amp; Tab &amp; int.String;
	endforeach;
	tbl.accessCell(2, 1).text := 'Area' &amp; Tab &amp; 
							'Items' &amp; Tab &amp; teus &amp; Tab	&amp;
							pads &amp; Tab &amp; '%' &amp; Tab &amp;
							pads &amp; Tab &amp; '%' &amp; Tab &amp;
							pads &amp; Tab &amp; '%' &amp; Tab &amp;
							'Used ' &amp; teus &amp; Tab &amp; 'Total ' &amp; teus &amp; Tab &amp; '% ' &amp; teus
							&amp; availStr ;

end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initTblSpaceDtl" id="1e0bebda-1bd5-499b-b42c-95dc1d008a9b">
        <source>initTblSpaceDtl(_theEntDef : String);
// ---------------------------------------------------------------------------
// Created:		09 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	int		: Integer;
	tbl		: CM_DataTable;
	teuHeading,
	isoHeading1,
	isoHeading2 : String;
begin
	tbl := self.tblSpaceDtl;
	
	tbl.clear();
	tbl.selectionType	:= CM_BaseTable.SelectionType_Row;
	tbl.selectMode		:= Table.SelectMode_WholeRows;
	tbl.multiSelect		:=	CM_BaseTable.MultiSelect_Simple;
	tbl.fixed3D 		:= false;
	tbl.rows			:= 2;
	tbl.top := 1;
	tbl.fixedRows		:= 2;
	tbl.fixedColumns	:= 0;
	tbl.gridLines		:= true;
	tbl.gridColor		:= Grey;
	//tbl.columns			:= 6;
	tbl.columns			:= 7; //05/09/2025	navkc1 JIRA 35623
	self.setColorsForTable(tbl);

	foreach int in 1 to tbl.fixedRows do
		tbl.accessRow(int).alignment := Table.Alignment_Left;
	endforeach;
	
	//foreach int in 5 to (tbl.columns-1) do
	foreach int in 6 to (tbl.columns-1) do //05/09/2025	navkc1 JIRA 35623
		tbl.accessColumn(int).alignment := Table.Alignment_Right;
	endforeach;

	tbl.accessColumn(2).width := 100;
	tbl.accessColumn(3).width := 100;
	tbl.accessColumn(4).width := 100;
	tbl.accessColumn(5).width := 100; //05/09/2025	navkc1 JIRA 35623
	tbl.accessColumn(tbl.columns).alignment := Table.Alignment_Center;
	
	//tbl.accessCell(1,5).mergeCells := Table.MergeCells_Merge;
	tbl.accessCell(1,6).mergeCells := Table.MergeCells_Merge; //05/09/2025	navkc1 JIRA 35623
	tbl.accessedCell.alignment := Table.Alignment_Center;
	
	//05/09/2025	navkc1 JIRA 35623
	if self.hasCONT() then
		isoHeading1 := "ISO";
		isoHeading2 := "Group";
		teuHeading 	:= "TEU";
	else
		isoHeading1 := "Cargo";
		isoHeading2 := "SubType";
		teuHeading  := "Length";
	endif;
	
	tbl.accessCell(1, 1).text :=	"" &amp; Tab &amp; 			"ImEx" &amp; Tab &amp;		"Cargo" &amp; Tab &amp;		isoHeading1 &amp; Tab &amp;		"Contents" &amp; Tab &amp; 	"Total";
	tbl.accessCell(2, 1).text :=	"Area" &amp; Tab &amp; 		"Status" &amp; Tab &amp;	"Type" &amp; Tab &amp;		isoHeading2 &amp; Tab &amp;		"Status" &amp; Tab &amp; 	'Items' &amp; Tab &amp; teuHeading;	//24 July 2014	NDL	Par 34335

end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initTiDataTable" id="ce98b8a3-f296-469e-8df5-73d8c8f5b7db">
        <source>initTiDataTable(_theEntDef: String; _theTable : CM_DataTable);
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;
begin
	theTable := _theTable;
	
	theTable.userInputEnabled := false;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(_theEntDef);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;



end;</source>
        <Parameter name="_theEntDef" type="String"/>
        <Parameter name="_theTable" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="d53b7f73-3b36-4c41-b4a9-bfaf467533e2">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpH : Integer;
begin
	inheritMethod();
	self.splMain.stretchHeight := true;
	
	self.splMain.parent := self.shtSpace;
	self.fldMain.move(0,self.frmToolbar.clientHeight,self.clientWidth,self.clientHeight);
	self.splMain.top := 0;
	self.splMain.height := self.shtSpace.clientHeight;
	tmpH := self.clientHeight - self.frmToolbar.clientHeight - 10;
	self.fldMain.move(0,self.frmToolbar.clientHeight + 2,self.clientWidth,tmpH);

	self.fldMain.cnEcResizeContents();
	self.fldMain.useSheetBackColors := true;
	self.fldMain.setDefaultSheetBackColors();
	self.fldMain.initSheetBackColors();

end;</source>
        <access>protected</access>
    </JadeMethod>
