<Class name="CMIF_InterfaceTransactionHook" id="f511243f-277f-4d69-b90a-7a20e712de11">
    <superclass name="CMIF_InterfaceObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This class is used to invoke a method at the end of a successful transaction.</text>
    <DbClassMap file="mobileServer"/>
    <PrimAttribute name="hookMethodName" id="cab94757-fc6f-4703-83a0-20aec592e4b7">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myHookObject" id="b4d3e5d6-9de7-4d85-ac6d-84dcbda3ac5b">
        <embedded/>
        <type name="Object"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="doProcessingForInterface" id="db39bbf7-715c-4fa7-b098-4fd7a88223a1">
        <source>doProcessingForInterface(_passport : CM_Passport input);

/*

Purpose:			Invoke wrap up processing method for calling interface

Parameters:			None

Return Value:		None


Date		Who		Reason
16 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.myHookObject.sendMsgWithParams(self.hookMethodName, _passport);
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="set" id="1ab39f89-514a-4d0d-8a7d-4d5a2a8a2c3f">
        <updating/>
        <source>set(_hookObject : Object; _method : JadeMethod) updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
20 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.myHookObject		:= _hookObject;
	self.hookMethodName		:= _method.name;
	
epilog

end;</source>
        <Parameter name="_hookObject" type="Object"/>
        <Parameter name="_method" type="JadeMethod"/>
    </JadeMethod>
</Class>
