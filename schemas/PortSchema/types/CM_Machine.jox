    <JadeMethod name="isIdle" id="e3530528-c279-4586-9821-1afdf4553919">
        <source>isIdle(_mins : Integer output; _idleHist : CM_MachineHistory output) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/09/2020	jlgdap1		Initial creation TFS 49316 MTN Machine Idle Time
//
vars
	iter : Iterator;
	config : CM_RTVehicleConfig;
	hist : CM_MachineHistory;
	now : TimeStamp;
	int : TimeStampInterval;
	mins : Integer;

begin
	if not self.loggedOn then
		return false;
	endif;
	
	if not self.myTerminal.getConfig(IdleTimeEnabled).Boolean then
		return false;
	endif;
	
	//config := self.myRTVehicleConfig;                           //20.01.2021 cnwma1 #50433
	config := self.myTerminal.getRTVehicleConfigForObject(self);  //20.01.2021 cnwma1 #50433
	
	if config = null then
		return false;
	endif;
	
	if config.idleTimeAllowable = null then
		return false;
	endif;
	
	now := app.actualTimeServer;
	iter := self.history.createIterator;
	while iter.back(hist) do
		// ignore Information history
		if hist.type = hist.Type_Info then
			continue;
		endif;
		
		if hist.type = hist.Type_Idle then
			_idleHist := hist;
		endif;
		// it's not idle if the last thing it did was a logoff, went offline, accept, pickup, delay start or idle
		if hist.isNotIdleHistory() then
			return false;
		endif;
		int := now - hist.dateTime;
		mins := int.asMinutes.Integer;
		if _idleHist &lt;&gt; null then
			mins := mins + config.idleTimeAllowable;
		endif;
		if mins &gt; config.idleTimeAllowable then
			_mins := mins.Integer;
			return true;
		else	//09 Aug 2021	NDL	TFS 50145 - If we get to here it is idle but is still within the time frame,
				// all good so bail, otherwise we will go around again and add 'config.idleTimeAllowable' minutes to the previous guy
				// overstating the time.
			return false;
		endif;
	endwhile;
	
	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_mins" type="Integer" usage="output"/>
        <Parameter name="_idleHist" type="CM_MachineHistory" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInQueue" id="1b8bacf5-b61d-49c7-bb6b-b9d78c5297d6">
        <source>isInQueue(toCheck	:	CM_RadioTelemetryQueue)	:	Boolean;
//Checks to see if this machine can access the passed in queue.
//A machine can be INHERITED from a queue BELOW this one, but
//not ABOVE.
vars
	aQ	:	CM_RadioTelemetryQueue;
begin

	if toCheck = null then
		return false;
	endif;
	if toCheck = self.myPrimaryQueue then
		return true;	//I'm here!
	endif;
	if self.myPrimaryQueue = null then
		return false; 	//I'm not even IN a Queue!
	endif;
	if self.myPrimaryQueue.includesQueue(toCheck) then
		return true;
	endif;
	//-----------------
	//Check for secondary queues
	//-----------------

	if self.allQueues.includes(toCheck) then
		return true;
	endif;
	
	//PAR 17875 - need to check if toCheck queue is a sub-queue of any of our secondary queues
	foreach aQ in self.allQueues do
		if aQ.includesQueue(toCheck) then
			return true;
		endif;
	endforeach;
	
	/*
	//PAR 17875 - this is done in self.myPrimaryQueue.includesQueue(toCheck) called above
	if self.myPrimaryQueue.allSubQueuesById.size  = 0 then
		return false;	//No sub-queues
	endif;
	foreach aQ in self.myPrimaryQueue.allSubQueuesById do
		if aQ.includesQueue(toCheck) then
			return true;
		endif;
	endforeach;
	*/
	return false;
end;</source>
        <Parameter name="toCheck" type="CM_RadioTelemetryQueue"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
