    </JadeMethod>
    <JadeMethod name="btnEditTV_click" id="663c046f-dabd-4539-9cc0-fe6f41e339db">
        <updating/>
        <source>btnEditTV_click(btn: Button input) updating;
/*

Purpose:	since i am going to open a new form rather than using the thumbnail ent table
			i have reimplemented this method 


Return Value:		


Date		Who		Reason
14 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	faultForm : SOP_FaultMaintForm;
	fault : CM_Fault;
begin
//	inheritMethod(btn);

	if self.myCurrentObject = null then
		return;
	endif;

	fault:= self.myCurrentObject.CM_Fault;

	
	faultForm	:= app.loadForm(SOP_FaultMaintForm, self.myAssistant.class, false, false ,true ,self.myTerminal, null).SOP_FaultMaintForm;
	if faultForm = null then
		return;
	endif;
	
	faultForm.init(self.myTerminal,fault);
	//faultQuestionForm.init(theForm.myCurrentObject.CM_MachineType, faultQuestion);
	faultForm.show;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
