    <JadeMethod name="setReportSelectionCriteria" id="90c8d770-4f1b-4564-bd32-4b946ee22fb9">
        <source>setReportSelectionCriteria(_jrwTransient: CM_JRWReserveDetails input);
//----------------------------------------------------------------
//	Created:	04 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	_jrwTransient.myOperator := self.myFilterOperator;
