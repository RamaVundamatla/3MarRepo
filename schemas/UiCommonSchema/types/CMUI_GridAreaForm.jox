    <JadeMethod name="displaySelectorResults" id="ec1aecfe-1e0a-47c8-abe7-b62301757c15">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _mode &gt; TI_CargoType_Max then
		app.msgBox('The grid area screen cannot display item for the selected mode (' &amp; _mode.String &amp; ')', 'Invalid selector mode', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.sdf01.allSelectorTIs.clear;
	_resultCollection.copy(self.sdf01.allSelectorTIs);
	self.sdf01.drawSelf();	
	
	if not self.sdf02.allGridAreasByRowColumn.isEmpty then
		self.sdf02.allSelectorTIs.clear;
		_resultCollection.copy(self.sdf02.allSelectorTIs);
		self.sdf02.drawSelf();	
	endif;
	
	if not self.sdf03.allGridAreasByRowColumn.isEmpty then
		self.sdf03.allSelectorTIs.clear;
		_resultCollection.copy(self.sdf03.allSelectorTIs);
		self.sdf03.drawSelf();	
	endif;

end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
