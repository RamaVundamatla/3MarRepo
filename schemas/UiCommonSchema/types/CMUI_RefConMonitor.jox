    <JadeMethod name="addToolbarControls" id="452e4770-6531-4608-8323-cfb5bdcb2e94">
        <updating/>
        <source>addToolbarControls() updating, protected;
//----------------------------------------------------------------
//	Created:	13 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;

begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnStopStartMon, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	showCaptions := toolbar.showCaptions;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
