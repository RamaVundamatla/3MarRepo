    <JadeMethod name="qlbClassData_dblClick" id="e6424712-c111-43fe-9237-6f4bbaa2d744">
        <controlMethod name="CMUI_ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>qlbClassData_dblClick(listbox: ListBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	devEnt,
	schemaObjectEntity	: DEV_SchemaObjectEntity;
	classConstant		: DEV_ClassConstant;
	schema 				: Schema;
	currentClass 		: Class;
	currentConstant 	: Constant;
	checked				: Boolean;
	
	selIndex,
	selLevel,
	index,
	level				: Integer;
	
begin
	if listbox.text &lt;&gt; null then
		schemaObjectEntity := listbox.itemObject[listbox.listIndex].DEV_SchemaObjectEntity;
	endif;
	
	if schemaObjectEntity &lt;&gt; null and schemaObjectEntity.isClassConstant then
		classConstant := schemaObjectEntity.DEV_ClassConstant;
		
		schema := rootSchema.getSchema(classConstant.myClass.mySchema.name);
		currentClass := schema.getClass(classConstant.myClass.name);
		currentConstant := currentClass.getConstant(classConstant.name);
		
		if currentConstant &lt;&gt; null and 
			classConstant.type = currentConstant.type.name and 
			classConstant.documentationTextData = currentConstant.text and 
			classConstant.value = currentConstant.getSource()
		then
			self.qlbClassData.enabled := false;
			
			if self.mnuLBContext.userObject = null then
				write method.qualifiedName &amp; " No userObject set on mnuLBContext";
				return;
			endif;
			
			selIndex := listbox.listIndex;
			if selIndex &lt; 1 then
				return;
			endif;
			
			devEnt := listbox.itemObject[selIndex].DEV_SchemaObjectEntity;
			
			// Mark the difference object as 'resolved'
			if devEnt &lt;&gt; null and devEnt.resolvedBy = null then
				if app.msgBox("Mark as Resolved ?", "Clear and Resolve", MsgBox_Yes_No) = MsgBox_Return_Yes then
					devEnt.setResolved(process.getComputerName);
				endif;
			endif;
			
			if selIndex &lt; 1 or selIndex &gt; listbox.listCount then
				app.raiseUnexpectedProgramError(class.name, method.name, "Invalid Item Index");
				return;
			endif;
			
			selLevel := listbox.itemLevel[selIndex];

			// Remove the selected item
			listbox.removeItem(selIndex);
			
			// Also remove the 'Header' items if this was the only subitem
			index := selIndex;
			level := selLevel;
			while index &gt; 1 do
				// If the one above us is at a lower level,
				// and the one below us (if it exists) is also at a lower level
				if listbox.itemLevel[index-1] &lt; level and (listbox.listCount &lt; index or listbox.itemLevel[index] &lt; level) then
					listbox.removeItem(index-1);
					index -= 1;
					level -= 1;
					continue;
				endif;
				break;
			endwhile;
			
			checked := true;
		endif;
		
	endif;
	
	if not checked then
		self.doShowDetails(listbox);
		
	endif;
	
epilog
	self.qlbClassData.enabled := true;
	
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="qlbClassData_keyDown" id="7a2005f7-becf-4957-9fa7-9c59957d2eb5">
