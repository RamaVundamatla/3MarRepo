begin
		return self.id;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationsForSpan" id="669f67af-e577-4352-92b6-8e528208937d">
        <source>getLocationsForSpan(_vertSpan, _horzSpan, _depthSpan : Integer; _lcDict : CM_LCSet input);
/*
----------   ----------  --------------------------------------------------
Created:	23 November 2006 By cnwth2

Purpose:	return row controllers surrounding self that will need to be checked for 
			hazardous segregation rule violation
			
			vertical span = accross rows
			horizontal span = N/A - rows only
			depth span = N/A 


Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
23 July 2015	NDL	Par 36568	- remove use of LC collection with 'myTerminalArea' as key, replace with LC Set
*/
vars
	rowArea						: CM_RowArea;
	rowAreaRow					: CM_RowAreaRow;
	rowController				: CM_RowController;
	
	rowIdx,
	selfRowPos,
	probeVertMin,
	probeVertMax				: Integer;
	segCond						: CM_SegregationCondition;
	doLog						: Boolean;
begin
	rowArea := self.myRowArea;
	
	//get probe perimeter values
	selfRowPos := self.myRow.getRowPosition();
	probeVertMin 	:= (selfRowPos - _vertSpan).max(1);
	probeVertMax 	:= (selfRowPos + _vertSpan).min(rowArea.allRows.size);
	
	doLog := app.myPassport.myActivityCapture.captureDiagnositcs;
	if doLog then
		app.myPassport.myActivityCapture.logDiagnostic('GetLocationForSpan - from ' &amp; self.getFullId &amp; CrLf &amp;
													'probeVertMin=' &amp; probeVertMin.String &amp; ', probeVertMax=' &amp; probeVertMax.String); 
	endif;
	
	
	foreach rowIdx in probeVertMin to probeVertMax do
		rowAreaRow := rowArea.allRows[rowIdx];
		if rowAreaRow = null then
			continue;
		endif;
		
		foreach rowController in rowAreaRow.allRowControllers do
			if (not _lcDict.includes(rowController)) then
				if doLog then
					app.myPassport.myActivityCapture.logDiagnostic('Adding rowController for span:' &amp; rowController.getFullId());
				endif;
				_lcDict.add(rowController);
			endif;
		endforeach;
	endforeach;
	
end;



</source>
        <Parameter name="_vertSpan" type="Integer"/>
        <Parameter name="_horzSpan" type="Integer"/>
        <Parameter name="_depthSpan" type="Integer"/>
        <Parameter name="_lcDict" type="CM_LCSet" usage="input"/>
    </JadeMethod>
