    <JadeMethod name="delete" id="aa44adb1-6924-4fb1-8afe-2117adbd225f">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2021	jlier1	Initial creation

*/

vars

begin
	self.allCargoSummaries.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCanPackAll" id="ef9e7b35-9811-4d86-b13c-5f5c9716004d">
        <updating/>
        <source>setCanPackAll( _tiSet : CM_TISet input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2021	jlier1	Initial creation 51879

*/

vars
	cargoCheck	  : CM_CargoCheck;
	terminal 	  : CM_Terminal;
	ti : CM_TrackedItem;
	hasChecks : Boolean;
	cmifAutoPlan	: CMIF_YAAutoPlanNormal;
	check 			: CM_CargoCheckItem;
begin
	self.canPackAll:=true;
	terminal 	:= app.myPassport.myTerminal;
	if not  app.getMyUser.canDo(app.myPassport.myTerminal, PmHHAllowLoadAll) then
		self.canPackAll:=false;
		return;
	endif;
	cargoCheck := terminal.allCargoChecks[CARGO_CHECK_CONTEXT_PACK];
	hasChecks:=cargoCheck &lt;&gt; null and cargoCheck.allCargoCheckItems.first &lt;&gt; null;
	//see if any cargo that needs an amount
	foreach ti in _tiSet discreteLock do
		if ti.canSplitTotalQuantity then
			self.canPackAll:=false;
			return;
		endif;
		if hasChecks then
			delete cmifAutoPlan;
			create cmifAutoPlan transient;
			cmifAutoPlan.attachTI(ti);		
			foreach check in cargoCheck.allCargoCheckItems discreteLock do
				if  check.doesTIMatchMe(cmifAutoPlan) then	
					self.canPackAll:=false;
					return;
				endif;
			endforeach;
		endif;
	endforeach;
		
epilog
	delete cmifAutoPlan;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setWeightAndCounts" id="e98e18b2-6921-4272-9321-d8b6c306f6fc">
        <updating/>
        <source>setWeightAndCounts(_release : CM_BulkRelease; _parent : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2021	jlier1	Initial creation 51879
04 Oct 2024 navhl20 Bug 12500 EUP | No warning message on the work order operations app after packing part of one child line
*/

vars
	measureType : CM_MeasurementType;
	ti : CM_TrackedItem;
	childReserve : CM_ReserveDetail;
	totalPacked	 : Integer;
begin
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType = null then
		self.weightPacked:= _parent.totalWeight.asStringWeightJMT;
	endif;
	self.weightPacked:=  app.convertMeasurementForDisplay(measureType.shortName, _parent.totalWeight) &amp; " " &amp; measureType.shortName;
	
	if _release &lt;&gt; null then
		foreach ti in _parent.allChildren discreteLock do
			//13 Jun 2016	NDL	TFS 2133
			if not ti.allBulkReleasesAssigned.includes( _release ) then
				continue;
			endif;		
			self.countPacked := self.countPacked + ti.totalQuantity.max(1);
		endforeach;
		
		totalPacked := _release.getTotalPackedQuant();							//04.10.2024 navhl20 #12500
		if self.countPacked &lt;&gt; totalPacked then									//04.10.2024 navhl20 #12500
			self.countPacked := totalPacked;
		endif;
	
		foreach childReserve in _release.allReservePackingChildren discreteLock do
				self.countToPack := self.countToPack + childReserve.totalRequested.max(1);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_parent" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
