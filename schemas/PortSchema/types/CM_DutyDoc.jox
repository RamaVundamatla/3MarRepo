    <JadeMethod name="getDocumentationDepositValue" id="40441356-5fe1-4ce4-a295-31e5fa591afb">
        <source>getDocumentationDepositValue():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2013	cnwndl1	Initial creation	Par 33229

*/
vars

	debtor : CM_Debtor;
	term : CM_Terminal;
	allExtraChargeInvs : CM_InvoiceSet;
	invoice : CM_Invoice;
	invLine : CM_InvoiceLine;
	totalCharges : Decimal [23,6];
	cashAmount	: Decimal [16,4];
	outstandingAmount : Decimal [23,6];
	dutyDocDep : Decimal [16,4];


begin

	debtor := self.getMyDebtor;
	term := self.getMyTerminal;
	
	if debtor = null or term = null then
		return 0.0;
	endif;
	
	create allExtraChargeInvs transient;
	debtor.getDutyDocExtraCharges( term, allExtraChargeInvs );
	if allExtraChargeInvs.isEmpty then
		return 0.0;
	endif;
	
	foreach invoice in allExtraChargeInvs do
		if invoice.isExtraChargeForDutyDocSystem( totalCharges, cashAmount, outstandingAmount) then
			foreach invLine in invoice.invoiceLines where not invLine.voided do
				if invLine.remarks.pos(self.id,1) &lt;&gt; 1 then
					continue;
				endif;
				if invLine.invoiceLineDesc = null then
					continue;
				endif;
				if invLine.invoiceLineDesc.narration &lt;&gt; "Duty Documentation Deposit" then
					continue;
				endif;
				dutyDocDep := dutyDocDep + invLine.lineTotal;
				
			endforeach;
		endif;
	endforeach;

	return dutyDocDep;

epilog

	delete allExtraChargeInvs;

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDutyCharge" id="25a0216f-fcce-4d23-89b6-a4e6f9514b14">
        <source>getDutyCharge(_ti: CM_TrackedItem) : Decimal;
/*
31 July     2014    cnwma1 PAR 34408 Credit Customer current charges
*/
vars
	item: CM_DutyDocItem;
	charge: Decimal[12,2];
begin

	foreach item in self.allDutyDocItems do
		if item.getMyTrackedItem() = _ti then
			//charge := charge + item.duty;  // -cnwma1 31/07/2014 PAR 34408
			charge :=  item.duty;			// +cnwma1 31/07/2014 PAR 34408
		endif;
	endforeach;
	
	return charge;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
