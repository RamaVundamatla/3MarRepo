    <JadeMethod name="doFillFileFormatCombo" id="8f9c10a7-40dc-415a-a541-18ba355027d5">
        <source>doFillFileFormatCombo(_cmb: ComboBox input; _extractType : String; _defFormat: String);
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 21 December 2011	cnwgb1	CCMS MSL 1009 Par 29024
// 23 May 2016		cnwdap1	TFS #1881 BAPLIE/EDI VGM Updates
vars
    object 		: Object;
    userDefFile : CM_EDIFileTypeUser;

begin
	_cmb.clear();
	
	if _extractType = EDIFILE_TYPE_ACTUAL_BAYPLAN or _extractType = EDIFILE_TYPE_PROPOSED_BAYPLAN then  
		_cmb.addItem(self.EDI_FORMAT_BAPLIE_15);
		_cmb.addItem(self.EDI_FORMAT_BAPLIE_20);
		_cmb.addItem(self.EDI_FORMAT_BAPLIE_22);				// TFS #1881
		_cmb.addItem(self.EDI_FORMAT_MASTER_PLAN);
		_cmb.addItem(self.EDI_FORMAT_XML_CELINA);
		_cmb.addItem(self.EDI_FORMAT_WWL);
		
	elseif _extractType = EDIFILE_TYPE_ACTUAL_DECKPLAN or _extractType = EDIFILE_TYPE_PROPOSED_DECKPLAN then
        // Add all the RORO Deckplan User-defined Formats with a type of EDIDataType_DeckPlan
        //Fix this up
        foreach object in CM_EDIFileTypeUser.instances do
            userDefFile := object.CM_EDIFileTypeUser;
            if userDefFile.dataType = EDIDataType_DeckPlan then
              _cmb.addItem(userDefFile.name);  
            endif;
        endforeach;
        
	elseif _extractType = EDIFILE_USER_EXPORTSTRANSHIPS then
		_cmb.addItem(self.EDI_FORMAT_ANF);
		_cmb.addItem(self.EDI_FORMAT_CSV_WWL);
		
	elseif _extractType = EDIFILE_USER_OUTWARDRAIL then
		_cmb.addItem(self.EDI_FORMAT_XML_TOLLNZ);
		
	elseif _extractType = EDIFILE_TYPE_STOW_ADVICE then
		_cmb.addItem(self.EDI_FORMAT_STOW_ADVICE);
		
	elseif _extractType = EDIFILE_TYPE_X12 then
		_cmb.addItem(self.EDI_FORMAT_X12_309_4010);
		_cmb.addItem(self.EDI_FORMAT_X12_404_4010);
		
	endif;
	
	if app.isDevelopmentSystem() then 							//cnwrs1 June 2009
		if _extractType = EDIFILE_TYPE_LOADLIST_TI_COMP or
		   _extractType = EDIFILE_TYPE_DISCHLIST_TI_COMP then 	//cnwrs1 CCMS 1137 15 June 2010
			_cmb.addItem(self.EDI_FORMAT_COPRAR);
		elseif _extractType = EDIFILE_TYPE_STOW_ADVICE then 	//cnwrs1 27 July 2010
			_cmb.addItem(self.EDI_FORMAT_MOVINS);
		endif;
	endif;
	
	if _defFormat &lt;&gt; null then
		_cmb.text := _defFormat;
		
		self.tblDetail.setValueByName(ETRow_ExtractFormat, _cmb.text);	
	endif;
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_extractType" type="String"/>
        <Parameter name="_defFormat" type="String"/>
    </JadeMethod>
    <JadeMethod name="doFillFileTypeCombo" id="d6954cc5-23b6-4ead-a264-f8a5fa9c6cd6">
        <source>doFillFileTypeCombo(_cmb: ComboBox input; _defType: String);
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//21 December 2011	cnwgb1	CCMS MSL 1009 Par 29024

vars

begin
	_cmb.clear();
	
	_cmb.addItem(self.EDIFILE_TYPE_ACTUAL_BAYPLAN);
	_cmb.addItem(self.EDIFILE_TYPE_PROPOSED_BAYPLAN);
	_cmb.addItem(self.EDIFILE_TYPE_STOW_ADVICE);		//ccms 1062
    _cmb.addItem(self.EDIFILE_TYPE_ACTUAL_DECKPLAN); 	//cnwgb1 CCMS MSL 1009
    _cmb.addItem(self.EDIFILE_TYPE_PROPOSED_DECKPLAN); 	//cnwgb1 CCMS MSL 1009

// non-standard items
	_cmb.addItem(self.EDIFILE_USER_EXPORTSTRANSHIPS);
	_cmb.addItem(self.EDIFILE_USER_OUTWARDRAIL);
	_cmb.addItem(self.EDIFILE_TYPE_X12);
	
	if app.isDevelopmentSystem() then 							//cnwrs1 June 2009
		_cmb.addItem(self.EDIFILE_TYPE_LOADLIST_TI_COMP);
		_cmb.addItem(self.EDIFILE_TYPE_DISCHLIST_TI_COMP);   	//cnwrs1 CCMS 1137 15 June 2010
	endif;
	
	if _defType &lt;&gt; null then
		_cmb.text := _defType;
		
		self.tblDetail.setValueByName(ETRow_ExtractFileType, _cmb.text);
	endif;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_defType" type="String"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="96583936-05c9-48bd-8eae-02d2c5784581">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 21 Dec 2011	cnwgb1	CCMS MSL 1009  Par 29024
// 21/03/2012	cnwcs5	CCMS POL 2144 / Par 29312 - Extract Baplie by Operator
// 29/10/2012	cnwcs5	par 30640 - 1090 after exception in first trx method
// 19/09/2017	jlgdap1	TFS 6851 SSL Indicate whether inward code or voyage code to be used
// 11/10/2017	jlgdap1	TFS 7366 CIG Only use inwards code if voyage actually has one
vars
	planType		: String;
	ediData			: CM_EDIData;
	ediFile			: CM_EDIFile;
	fileType		: CM_EDIFileType;
	ediDataParams	: CMIF_EDIDataDetails;
	result			: Integer;
	aFileName		: String;
	port			: CM_Port;
	extractFormat 	: String;
	table			: CM_EntryTable;
	length			: Integer;								// TFS 6851
	useInwardsCode	: Boolean;								// TFS 6851
begin
	app.mousePointer 	:= MousePointer_HourGlass;
	table				:= self.tblDetail;
	
	create ediDataParams transient;
	
	self.modalResult 	:= IDOK;
	planType 			:= table.getValueByName(ETRow_ExtractFileType).String;
	aFileName 			:= table.getValueByName(ETRow_ExtractFileName).String;
	extractFormat 		:= table.getValueByName(ETRow_ExtractFormat).String;
	fileType 			:= self.getFileType(extractFormat, planType);

	if (not app.myRoot.canDoEDIFileType(fileType.type)) then
		app.raiseCMException1(NotLicensedToPerformAction, 'Extract EDI File ' &amp; fileType.name, null, null);
		return;	
	endif;	

	port := self.cmbToPort.myObject.CM_Port;

	if port &lt;&gt; null then
		ediDataParams.dischargePort := port.code;
	endif;
	
	ediDataParams.arriveDate 	:= table.getValueByName(ETRow_EstArrivalDate).TimeStamp;
	ediDataParams.departDate 	:= table.getValueByName(ETRow_EstDepartureDate).TimeStamp;
	ediDataParams.operator 		:= self.myRecipient;
	
	if ediDataParams.operator &lt;&gt; null then
		ediDataParams.operatorCode := ediDataParams.operator.code;
	endif;
	
	if self.extractFileName = null then
		self.extractFileName := aFileName;
	endif;
	
	ediDataParams.shipperCode := table.getValueByName(ETRow_ShipperDesc).String;
	
	if ediDataParams.shipperCode = null and ediDataParams.operator &lt;&gt; null then
		ediDataParams.shipperCode := ediDataParams.operator.code; //par 16270 cnwrs1 Mar 2008
	endif;
	
	if self.myVoyage = null then
		self.myVoyage := self.myTerminal.getNullVoyage();
	endif;
	if self.myVoyage.inwardCode &lt;&gt; null then					// TFS 7366
		length := self.myVoyage.inwardCode.length;								// TFS 6851
		if self.cmbVoyage.text[1:length] = self.myVoyage.inwardCode then		// TFS 6851
			useInwardsCode := true;												// TFS 6851
		endif;																	// TFS 6851
	endif;														// TFS 7366

	while true do	
		if self.myEDIData = null then	//a new one to produce from voyage/DB data

	// Actual bayplan
			if planType = self.EDIFILE_TYPE_ACTUAL_BAYPLAN then
				//ediData := self.myEDIAgent.loadBayPlanTIs(self.myVoyage, ACTUAL_BAYPLANS, self.extractFileName, ediDataParams.shipperCode, self.myRecipient, self.myCargoOperator, fileType);	// par 29312 - march 2012		// TFS 6851
				ediData := self.myEDIAgent.loadBayPlanTIs(self.myVoyage, ACTUAL_BAYPLANS, self.extractFileName, ediDataParams.shipperCode, self.myRecipient, self.myCargoOperator, fileType, useInwardsCode);					// TFS 6851
				
	// Proposed bayplan
			elseif planType = self.EDIFILE_TYPE_PROPOSED_BAYPLAN then
				//ediData := self.myEDIAgent.loadBayPlanTIs(self.myVoyage, PROPOSED_BAYPLANS, self.extractFileName, ediDataParams.shipperCode, self.myRecipient, self.myCargoOperator, fileType);	// par 29312 - march 2012	// TFS 6851
				ediData := self.myEDIAgent.loadBayPlanTIs(self.myVoyage, PROPOSED_BAYPLANS, self.extractFileName, ediDataParams.shipperCode, self.myRecipient, self.myCargoOperator, fileType, useInwardsCode);					// TFS 6851
				
			elseif planType = self.EDIFILE_TYPE_STOW_ADVICE then
				if self.myRecipient = null then
					ediDataParams.operator := self.myVoyage.myOperator;
					
					if ediDataParams.operator &lt;&gt; null then
						ediDataParams.operatorCode := ediDataParams.operator.code;
					endif;
					
					self.myRecipient := self.myVoyage.myOperator;
				endif;
				
				ediData := self.myEDIAgent.loadStowAdviceTIs(self.myVoyage, self.extractFileName, self.myRecipient, fileType);
				
	// Exports onsite for voyage/operator
			elseif planType = self.EDIFILE_USER_EXPORTSTRANSHIPS then
				ediData := self.myEDIAgent.doGeneralSearch(self.myVoyage, CM_EDIData.SEARCH_ONSITE_EXP_TRANSHIP, self.extractFileName, self.filterOperator, fileType);
				
	// Outward rail info
			elseif planType = self.EDIFILE_USER_OUTWARDRAIL then
				ediData := self.myEDIAgent.doGeneralSearch(self.myVoyage, CM_EDIData.SEARCH_OUTWARD_RAIL, self.extractFileName, self.filterOperator, fileType);
				
	// X12 ASC Rail Carrier Info
			elseif planType = self.EDIFILE_TYPE_X12 then
				ediData := self.myEDIAgent.doOutwardWagonSearch(self.extractFileName, self.filterOperator, fileType);
				
	// for development create load list file cnwrs1 june 2009
			elseif planType = self.EDIFILE_TYPE_LOADLIST_TI_COMP then
				ediData := self.myEDIAgent.doGeneralSearch(self.myVoyage, CM_EDIData.SEARCH_TI_FOR_LOAD_LIST_COMPAR, self.extractFileName, self.filterOperator, fileType); //cnwrs1 CCMS 1137 15 June 2010

				if ediData &lt;&gt; null then
					beginTransaction;
					ediData.CM_EDIDataLoadList.setVoyageCode(self.myVoyage.code); //cnwrs1 Aug 2009
					ediData.CM_EDIDataLoadList.setListType("L");
					commitTransaction;
				endif;
				
			elseif planType = self.EDIFILE_TYPE_DISCHLIST_TI_COMP then //cnwrs1 CCMS 1137 15 June 2010
				ediData := self.myEDIAgent.doGeneralSearch(self.myVoyage, CM_EDIData.SEARCH_TI_FOR_DISCH_LIST_COMPA, self.extractFileName, self.filterOperator, fileType);
				
				if ediData &lt;&gt; null then
					beginTransaction;
					ediData.CM_EDIDataLoadList.setVoyageCode(self.myVoyage.code); //cnwrs1 Aug 2009
					ediData.CM_EDIDataLoadList.setListType("D");
					commitTransaction;
				endif;
				
			elseif planType = self.EDIFILE_TYPE_ACTUAL_DECKPLAN then	//cnwrs1 18 jan 2012 CCMS MSL 1009
				ediData 				:= self.myEDIAgent.loadDeckPlanTIs(self.myVoyage, ACTUAL_BAYPLANS, aFileName, self.myVoyage.myOperator, fileType);
				ediDataParams.operator 	:= self.myVoyage.myOperator;
				
			elseif planType = self.EDIFILE_TYPE_PROPOSED_DECKPLAN then	//cnwrs1 18 jan 2012 CCMS MSL 1009
				ediData 				:= self.myEDIAgent.loadDeckPlanTIs(self.myVoyage, PROPOSED_BAYPLANS, aFileName, self.myVoyage.myOperator, fileType);
				ediDataParams.operator 	:= self.myVoyage.myOperator;
				
			else
				//other file types ?
				app.raiseUnexpectedProgramError(class.name, method.name, 'invalid type of file');
				return;
			endif;
		else	
		// produce from edi data
			self.myEDIAgent.setEDIDataForExtract(self.myEDIData, self.extractFileName, fileType); // CCMS1117 cnwrs1 3 May 2010
			ediData := self.myEDIData;
		endif;	
	
		if (not app.myPassport.trxCompletedOK) then
			result := app.showErrorWarningDialog (self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			
			// par 30640 - we need to return here as we have errors and don't want to continue on and do the extract
			return;
		else
			// all OK
			self.clearErrorWarnings();
	//		self.unloadForm();										
			break;
		endif;
	endwhile;

	// create disk file
	if ediData &lt;&gt; null and ediData.fileName &lt;&gt; null then
		//dump to file
		if ediData.myEDIFile &lt;&gt; null then 			 	// ccms1117 cnwrs1 29 Apr 2010
			ediFile := ediData.ediFileArray.last;		//should be the one we just created 
			
			self.myEDIAgent.extractFile(ediFile, ediData.number, ediDataParams);
			
			if (not app.myPassport.trxCompletedOK) then
				app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add);
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
		endif;
	endif;
																																																																																																																																																																																																																																																																																														
epilog
	delete ediDataParams;	
	app.mousePointer := MousePointer_Default;
	
	self.unloadForm();	//03 Dec 2019	NDL	TFS 47781 - moved down
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="66d59301-e396-4cdf-ada6-b6577c8f889f">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 27/04/2010	cnwcs5	ccms 1118 / par 23580 - EDI form enhancements 
constants

vars
	topVal		: Real;
	table		: Table;	// par23580
begin
	inheritMethod();
	
	topVal 	:= self.frmToolbar.height;
	table	:= self.tblDetail;			// par23580
		
	table.move(0, topVal, self.clientWidth, self.clientHeight - topVal);// par23580
	
	// now set the column width
	table.accessColumn (2).width := table.clientWidth - table.accessColumn(1).width;// par23580
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getDiskFileName" id="848f511f-4e6d-4e7f-8da0-b8052f536150">
        <updating/>
        <source>getDiskFileName(_fileName: String io) updating;
// ---------------------------------------------------------------------------
// Created:		25 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	fileNameLength		: Integer;
	fileGet		 		: CMDFileSave;
begin
	create fileGet;
	
	fileGet.filter 			:= '*.*';
	fileGet.fileName 		:= _fileName;
	fileGet.overwritePrompt := false;

	fileGet.initDir := self.myTerminal.getConfig_FileDirectory(EDIFileDirectory).String;

	if fileGet.open = 0 then	//user clicked OK
		// need to check that the file name including directories is not larger than 255
		fileNameLength	:= fileGet.fileName.length;

		if fileNameLength &gt; self.extractFileName.maxLength then
			app.msgBox(	app.getString( ExtractFileName_TooLong, self.extractFileName.maxLength.display ),
						app.getString( Error ),
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
			return;
		endif;
		
		self.extractFileName := fileGet.fileName;
		
		_fileName := self.extractFileName;
	endif;
	
end;</source>
        <Parameter name="_fileName" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getFileType" id="ab9868c5-2256-4799-9c3f-09ca99934486">
        <source>getFileType(_format: String; _planType: String): CM_EDIFileType;
//----------------------------------------------------------------
//	Created:	27 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//21 December 2011	cnwgb1	 	CCMS MSL 1009 Par 29024
//20 May 2016		cnwdap1		TFS #1881 BAPLIE/EDI VGM Updates
vars

begin

	if _format = self.EDI_FORMAT_BAPLIE_15 then
		return app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_Baplie15, null);
	elseif _format = self.EDI_FORMAT_BAPLIE_20 then
		return app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_Baplie20, null);
	elseif _format = self.EDI_FORMAT_BAPLIE_22 then											// TFS #1881
		return app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_Baplie22, null);			// TFS #1881
	elseif _format = self.EDI_FORMAT_STOW_ADVICE then
		return app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_VSLStow, null);
	elseif _format = self.EDI_FORMAT_MASTER_PLAN then
	  	return app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_BayFile, null);
	elseif _format = self.EDI_FORMAT_ANF then
	  	return app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_Anf, null);
	elseif _format = self.EDI_FORMAT_XML_TOLLNZ then
	  	return app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_XML_TOLL_PREADVICE, null);
	elseif _format = self.EDI_FORMAT_XML_CELINA then
	  	return app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_XML_Celina, null);
	elseif _format = self.EDI_FORMAT_WWL then
	  	return app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_WWLCar, null);
	elseif _format = self.EDI_FORMAT_CSV_WWL then
	  	return app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_CSVWWL, null);
	elseif _format = self.EDI_FORMAT_COPRAR then
	  	return app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_Coprar, null); //cnwrs1 June 2009
	elseif _format = self.EDI_FORMAT_MOVINS then
	  	return app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_Movins, null); //cnwrs1 27 July 2010
	elseif _planType = self.EDIFILE_TYPE_ACTUAL_DECKPLAN or  _planType = self.EDIFILE_TYPE_PROPOSED_DECKPLAN then 
        //CCMS MSL 1009 cnwgb1
        //Could be user-defined file format (RORO Deck Plan)
        return app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_UserDefined, _format);
    else
		return null;
	endif;
	
end;</source>
        <Parameter name="_format" type="String"/>
        <Parameter name="_planType" type="String"/>
        <ReturnType type="CM_EDIFileType"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="ecf4050f-0ec4-48bd-b035-7f8c85ff12eb">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date						Who		Reason
01/09/2016		cnwrh7		Initial creation TFS2618

*/

vars
		extractFormatXML		:	String;
		type : String;
		extractTypeArray 		: StringArray;
		currentFormats 			: StringArray;
		extractType					: String;
		idx 										: Integer;
		currentFormat				: String;
		
begin
		create extractTypeArray transient;															//Adding up tags from Extract Type
		extractTypeArray.add(self.EDIFILE_TYPE_ACTUAL_BAYPLAN);
		extractTypeArray.add(self.EDIFILE_TYPE_PROPOSED_BAYPLAN);
		extractTypeArray.add(self.EDIFILE_TYPE_STOW_ADVICE);		
		extractTypeArray.add(self.EDIFILE_TYPE_ACTUAL_DECKPLAN); 	//cnwgb1 CCMS MSL 1009
		extractTypeArray.add(self.EDIFILE_TYPE_PROPOSED_DECKPLAN); 	//cnwgb1 CCMS MSL 1009
		// non-standard items
		extractTypeArray.add(self.EDIFILE_USER_EXPORTSTRANSHIPS);
		extractTypeArray.add(self.EDIFILE_USER_OUTWARDRAIL);
		extractTypeArray.add(self.EDIFILE_TYPE_X12);
		
		if app.isDevelopmentSystem() then 							
			extractTypeArray.add(self.EDIFILE_TYPE_LOADLIST_TI_COMP);
			extractTypeArray.add(self.EDIFILE_TYPE_DISCHLIST_TI_COMP);   	
		endif;
		
		create currentFormats transient;								//Adding Tag's saved values--Extract Format
		foreach idx in 1 to extractTypeArray.size do
			currentFormats.add(null);
			extractType := extractTypeArray[idx];
			currentFormat := app.getUserWindow(self.class.name, true).xmlInfo.cnEcGetTagValueOfName(extractType);
			if currentFormat &lt;&gt; null then
				currentFormats.atPut(idx, currentFormat);
			endif;
		endforeach;
	
		extractFormatXML := inheritMethod();				//extractFomratXML is clear at this point
		foreach idx in 1 to extractTypeArray.size do
			extractType := extractTypeArray[idx];
			if extractType = self.cmbFileType.text then								//the current combobox 
				extractFormatXML := extractFormatXML &amp; global.formatAsXML(self.cmbFileType.text , self.cmbFormat.text );			
			elseif  extractFormatXML.cnEcGetTagValueOfName(extractType) &lt;&gt; null then		//if there is one ExtractFormat in ExtractType then we don't need to change 
				// no doing anything
			else
				extractFormatXML := extractFormatXML &amp; global.formatAsXML(extractType, currentFormats[idx]);			//For Extract Type
			endif;
		endforeach;
		return extractFormatXML;
epilog
		delete extractTypeArray;
		delete currentFormats;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="fb6e679d-45ce-42d9-8ce4-74b92a040f87">
        <updating/>
        <source>getXMLSettingsForSetup() updating ;
/*

Purpose:			

Parameters:			

Return Value:		

Date						Who			Reason
01/09/2016	cnwrh7			Initial creation TFS2618

*/

vars
		userWindow					: CM_UserWindow;
		extractFormatXML		: String;
begin
		userWindow := self.myUserWindow;
		if userWindow = null then
			userWindow := app.getUserWindow(self.name, false);
			if userWindow = null then
				return;
			endif;
		endif;
		extractFormatXML := userWindow.xmlInfo;
		xmlExtractFormat := extractFormatXML.cnEcGetTagValueOfName(cmbFileType.text);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblDetail" id="f1261b5d-2bc0-4350-b52c-f6f45e9ffd07">
        <updating/>
        <source>initTblDetail() updating ;
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 21 December 2011	cnwgb1	CCMS MSL 1009 Par 29024
// 21 March 2012	cnwcs5	CCMS POL 2144 / Par 29312 - Extract Baplie by Operator

vars
	entTableControl	: EntTableDef;
	table		: CM_EntryTable;
	tmpCombo		: CMUI_ComboBox;
	voyage			: CM_Voyage;
	operator,
	vessel			: String;
	ediData			: CM_EDIData;
	ediDataParams	: CMIF_EDIDataDetails;
	tmpPort			: CM_Port;
begin
	ediData 	:= self.myEDIData;
	table 		:= self.tblDetail;
	table.rows 	:= 0;
	
	table.optimiseRowHeight := true;
		
	entTableControl := app.myController.getEntTableDef(ETDef_EDIDBExtractFinish); 
	
	table.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	
	
	if self.mode = StartMode then 
	
	elseif self.mode = FinishMode then 
		table.disableRowByName(ETRow_ExtractVoyage);
		table.hideRowByName(ETRow_ExtractFileType, false);
		table.hideRowByName(ETRow_CargoOperator, false);	// par 29312 - march 2012
	elseif self.mode = UserDefinedMode then
		table.disableRowByName(ETRow_ExtractVoyage);
		table.hideRowByName(ETRow_ExtractFileType, false);
	else
		return;
	endif;

	create ediDataParams transient;
	
	if ediData &lt;&gt; null then
		ediData.setParams(ediDataParams);	//remember to trim blanks when setting params
	endif;
	

	tmpCombo := cmbVoyage;
	
	self.myAssistant.comboBoxVoyageCurrent(	tmpCombo,
											voyage,
											true,
											false,
											true,
											true,
											false,
											false,
											false,
											true,
											false);
	
	table.setValueByName(ETRow_ExtractVoyage, tmpCombo.text);
	
	tmpCombo := cmbOperator;
	
	self.myAssistant.comboBoxOperator(tmpCombo, ediDataParams.operator, null);
	
	table.setValueByName(ETRow_ExtractOperator, tmpCombo.text);
	table.setValueByName(ETRow_FilterOperator, tmpCombo.text);
	table.setValueByName(ETRow_CargoOperator, tmpCombo.text); 			// par 29312 - march 2012
	
	tmpPort	:= app.myRoot.allPorts[ediDataParams.dischargePort];

	tmpCombo := self.cmbToPort;
	
	tmpCombo.CMUI_ComboPorts.myTerminal 	:= self.myTerminal;
	tmpCombo.CMUI_ComboPorts.myAssistant	:= self.myAssistant;
	tmpCombo.CMUI_ComboPorts.setObject(tmpPort);
	
	table.setValueByName(ETRow_ToPort, tmpCombo.text);

	self.setTblDates();
	
	tmpCombo := cmbFileType;
	
	self.doFillFileTypeCombo(tmpCombo, EDIFILE_TYPE_PROPOSED_BAYPLAN);		// 23/09/2008 cnwar2 #17815
	self.setTableForFileType(EDIFILE_TYPE_PROPOSED_BAYPLAN);

	tmpCombo := self.cmbFormat;
	//self.doFillFileFormatCombo(tmpCombo, EDIFILE_TYPE_ACTUAL_BAYPLAN, EDI_FORMAT_BAPLIE_20);			//-TFS2618
	
	if xmlExtractFormat &lt;&gt; null then																																							//+TFS2618
		self.doFillFileFormatCombo(tmpCombo, EDIFILE_TYPE_ACTUAL_BAYPLAN, xmlExtractFormat);				
	else
		self.doFillFileFormatCombo(tmpCombo, EDIFILE_TYPE_ACTUAL_BAYPLAN, EDI_FORMAT_BAPLIE_22);		//Default as BAPLIE 22
	endif;
	
	table.accessColumn(1).width := 135;
epilog
	delete ediDataParams;	
end;</source>
    </JadeMethod>
    <JadeMethod name="setEDIAgent" id="5baba632-91ae-4ec5-b700-ea6c5237747b">
        <updating/>
        <source>setEDIAgent(_ediAgent: CM_EDIControllerAgent) updating;
//----------------------------------------------------------------
//	Created:	25 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	self.myEDIAgent := _ediAgent;

end;</source>
        <Parameter name="_ediAgent" type="CM_EDIControllerAgent"/>
    </JadeMethod>
    <JadeMethod name="setEDIData" id="6e0ba747-f7e8-4b8e-bb11-399da2d033d1">
        <updating/>
        <source>setEDIData(_ediData: CM_EDIData) updating;
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	theOperator	: CM_Operator;
begin
	self.myEDIData := _ediData;
	
	if _ediData &lt;&gt; null then
		theOperator := _ediData.myOperator;
		
		if theOperator &lt;&gt; null then
			self.myRecipient := theOperator;
		else
			self.myRecipient := app.myRoot.allOperators[_ediData.operatorCode];
		endif;
	endif;
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="setTableForFileType" id="d0d695ac-6596-444a-8244-0c1136cbdb27">
        <updating/>
        <source>setTableForFileType(_typeName: String)  updating;
//----------------------------------------------------------------
//	Created:	16 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 21 December 2011	cnwgb1	CCMS MSL 1009  Par 29024
// 21 March 2012	cnwcs5	CCMS POL 2144 / Par 29312 - Extract Baplie by Operator
// 01/09/2016 		cnwrh7		TFS	2618
vars
	table	:CM_EntryTable;
begin
	table := self.tblDetail;
	self.getXMLSettingsForSetup();						//+TFS2618
	if _typeName = self.EDIFILE_USER_EXPORTSTRANSHIPS then 			//Exports and Tranship
		table.hideRowByName(ETRow_EstArrivalDate, false);
		table.showRowByName(ETRow_EstDepartureDate, false);
		table.hideRowByName(ETRow_ToPort, false);
		table.showRowByName(ETRow_FilterOperator, false);
		table.hideRowByName(ETRow_CargoOperator, false); 			// par 29312 - march 2012
		table.hideRowByName(ETRow_Recipient, false);
		table.showRowByName(ETRow_ExtractFileName, false);
		table.showRowByName(ETRow_ExtractOperator, false);
		table.hideRowByName(ETRow_ShipperDesc, false); 				//par16270 cnwrs1 mar 2008
		
		if xmlExtractFormat &lt;&gt; null then														//+TFS2618
			self.doFillFileFormatCombo(self.cmbFormat,  _typeName , xmlExtractFormat);	
		else
			self.doFillFileFormatCombo(self.cmbFormat, _typeName, self.EDI_FORMAT_ANF); //rs dec 2007
		endif;
		
	elseif _typeName = self.EDIFILE_USER_OUTWARDRAIL then 			//Wagon Advice
		table.hideRowByName(ETRow_EstArrivalDate, false);
		table.hideRowByName(ETRow_EstDepartureDate, false);
		table.hideRowByName(ETRow_ToPort, false);
		table.showRowByName(ETRow_FilterOperator, false);
		table.hideRowByName(ETRow_CargoOperator, false); 			// par 29312 - march 2012
		table.showRowByName(ETRow_Recipient, false);
		table.showRowByName(ETRow_ExtractFileName, false);
		table.showRowByName(ETRow_ExtractOperator, false);
		table.hideRowByName(ETRow_ShipperDesc, false); 				//par16270 cnwrs1 mar 2008
		
		if xmlExtractFormat &lt;&gt; null then														//+TFS2618
			self.doFillFileFormatCombo(self.cmbFormat,  _typeName , xmlExtractFormat);	
		else
			self.doFillFileFormatCombo(self.cmbFormat, _typeName, self.EDI_FORMAT_XML_TOLLNZ); //rs dec 2007
		endif;
		
	elseif _typeName = self.EDIFILE_TYPE_STOW_ADVICE then //Stow Advice
		table.hideRowByName(ETRow_EstArrivalDate, false);
		table.hideRowByName(ETRow_EstDepartureDate, false);
		table.hideRowByName(ETRow_ToPort, false);
		table.hideRowByName(ETRow_FilterOperator, false);
		table.hideRowByName(ETRow_CargoOperator, false); 			// par 29312 - march 2012
		table.hideRowByName(ETRow_Recipient, false);
		table.showRowByName(ETRow_ExtractFileName, false);
		table.hideRowByName(ETRow_ExtractOperator, false);
		table.hideRowByName(ETRow_ShipperDesc, false); 				//par16270 cnwrs1 mar 2008
		
		if xmlExtractFormat &lt;&gt; null then														//+TFS2618
			self.doFillFileFormatCombo(self.cmbFormat,  _typeName , xmlExtractFormat);	
		else
			self.doFillFileFormatCombo(self.cmbFormat, _typeName, self.EDI_FORMAT_STOW_ADVICE); //rs dec 2007
		endif;
		
	elseif _typeName = self.EDIFILE_TYPE_LOADLIST_TI_COMP or		//it is only for development environment - load list comparison testing
		_typeName = self.EDIFILE_TYPE_LOADLIST_TI_COMP then			// par 29312 - march 2012
		table.showRowByName(ETRow_EstArrivalDate, false);
		table.showRowByName(ETRow_EstDepartureDate, false);
		table.showRowByName(ETRow_ToPort, false);
		table.showRowByName(ETRow_FilterOperator, false);
		table.hideRowByName(ETRow_CargoOperator, false); 			// par 29312 - march 2012
		table.showRowByName(ETRow_Recipient, false);
		table.showRowByName(ETRow_ExtractFileName, false);
		table.showRowByName(ETRow_ExtractOperator, false);
		table.showRowByName(ETRow_ShipperDesc, false); 				//par16270 cnwrs1 mar 2008
		
		if xmlExtractFormat &lt;&gt; null then															//+TFS2618
			self.doFillFileFormatCombo(self.cmbFormat,  _typeName , xmlExtractFormat);	
		else
			self.doFillFileFormatCombo(self.cmbFormat, _typeName, self.EDI_FORMAT_COPRAR); //rs1 June 2009
		endif;
		
	elseif _typeName = self.EDIFILE_TYPE_X12 then //ASC X12
		table.showRowByName(ETRow_EstArrivalDate, false);
		table.showRowByName(ETRow_EstDepartureDate, false);
		table.showRowByName(ETRow_ToPort, false);
		table.hideRowByName(ETRow_FilterOperator, false);
		table.hideRowByName(ETRow_CargoOperator, false); 			// par 29312 - march 2012
		table.showRowByName(ETRow_Recipient, false);
		table.showRowByName(ETRow_ExtractFileName, false);
		table.showRowByName(ETRow_ExtractOperator, false);
		table.hideRowByName(ETRow_ShipperDesc, false); 				// par16270 cnwrs1 mar 2008
		
		if xmlExtractFormat &lt;&gt; null then														//+TFS2618
			self.doFillFileFormatCombo(self.cmbFormat,  _typeName , xmlExtractFormat);	
		else
			self.doFillFileFormatCombo(self.cmbFormat, _typeName, self.EDI_FORMAT_X12_309_4010); //rs dec 2007
		endif;
		
    elseif _typeName = EDIFILE_TYPE_PROPOSED_DECKPLAN or _typeName = EDIFILE_TYPE_ACTUAL_DECKPLAN then 
        //cnwgb1 4.1.2012 CCMS MSL 1009
		table.hideRowByName(ETRow_EstArrivalDate, false);
		table.hideRowByName(ETRow_EstDepartureDate, false);
		table.hideRowByName(ETRow_ToPort, false);
		table.hideRowByName(ETRow_FilterOperator, false);
		table.hideRowByName(ETRow_CargoOperator, false); 			// par 29312 - march 2012
		table.hideRowByName(ETRow_Recipient, false);
		table.showRowByName(ETRow_ExtractFileName, false);
		table.hideRowByName(ETRow_ExtractOperator, false);
		table.hideRowByName(ETRow_ShipperDesc, false); //par16270 cnwrs1 mar 2008
		
		if xmlExtractFormat &lt;&gt; null then												//+TFS2618
			self.doFillFileFormatCombo(self.cmbFormat,  _typeName , xmlExtractFormat);	
		else
			self.doFillFileFormatCombo(self.cmbFormat, _typeName, null);
		endif;
		
	else // proposed or actual bay plan 
		table.showRowByName(ETRow_EstArrivalDate, false);
		table.showRowByName(ETRow_EstDepartureDate, false);
		table.showRowByName(ETRow_ToPort, false);
		table.hideRowByName(ETRow_FilterOperator, false);
		
		if self.mode = self.StartMode then
			table.showRowByName(ETRow_CargoOperator, false); 			// par 29312 - march 2012
		endif;
		
		table.showRowByName(ETRow_Recipient, false);
		table.showRowByName(ETRow_ExtractFileName, false);
		table.showRowByName(ETRow_ExtractOperator, false);
		table.showRowByName(ETRow_ShipperDesc, false); 				// par16270 cnwrs1 mar 2008
		
		if xmlExtractFormat &lt;&gt; null then															//+TFS2618
			self.doFillFileFormatCombo(self.cmbFormat,  _typeName , xmlExtractFormat);	
		else
			//self.doFillFileFormatCombo(self.cmbFormat, _typeName, self.EDI_FORMAT_BAPLIE_20); //rs dec 2007			//-TFS2618
			self.doFillFileFormatCombo(self.cmbFormat, _typeName, self.EDI_FORMAT_BAPLIE_22); //rs dec 2007			//-TFS2618
		endif;
	endif;
	
	
	table.setValueByControlName(CMUI_EDIDBExtract::cmbFormat.name, self.cmbFormat.text);
end;</source>
        <Parameter name="_typeName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTblDates" id="1e39b345-f0b6-47cf-bc8e-e97db42f3ebf">
        <source>setTblDates();
//----------------------------------------------------------------
//	Created:	24 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	now		: TimeStamp;
	str		: String;
	table	: CM_EntryTable;
begin
	table 	:= self.tblDetail;
	str 	:= now.date.format("yyyy/MM/dd") &amp; " " &amp; now.time.format("HH:mm");
	
	table.setValueByName(ETRow_EstArrivalDate, str);
	table.setValueByName(ETRow_EstDepartureDate, str);
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a6824b5f-940e-4f41-a252-e40b92ddd061">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.btnOk.visible := false;
	self.btnCancel.visible := false;
	
	self.initTblDetail();
	self.setColorsForEntryTable(self.tblDetail);
	self.addToolbarControls();
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tblDetail_cellInputReady" id="59f4f012-cd1f-41f6-a5b8-d0de0f85779d">
        <controlMethod name="CM_EntryTable::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDetail_cellInputReady(_table: CM_EntryTable input; _control: Control input; _left: Real io; _top: Real io; _width: Real io; _height: Real io) updating;
/*
Purpose:	Sellect correct operator in the combo depending on which ET_Row we are

Date		Who		Reason
21/03/2012	cnwcs5	Initial creation - CCMS POL 2144 / Par 29312 - Extract Baplie by Operator
*/
vars
	attrName	:String;
	combo		:ComboBox;
begin
	attrName 	:= _table.getAttrName(_table.row);
	combo		:= self.cmbOperator;
	
	if attrName = ETRow_FilterOperator then
		combo.listObject := self.filterOperator;

	elseif attrName = ETRow_ExtractOperator then
		combo.listObject := self.myRecipient;
		
	elseif attrName = ETRow_CargoOperator then	
		combo.listObject := self.myCargoOperator;
		
	endif;
	

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_left" type="Real" usage="io"/>
        <Parameter name="_top" type="Real" usage="io"/>
        <Parameter name="_width" type="Real" usage="io"/>
        <Parameter name="_height" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tblDetail_dblClick" id="785dbc3d-d0ee-4cfa-8cc1-3806cad10bf0">
        <controlMethod name="CM_EntryTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDetail_dblClick(_table: CM_EntryTable input) updating;
// ---------------------------------------------------------------------------
// Created:		25 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	fileName : String;
begin
	if _table.row &lt;&gt; _table.getRowByName(ETRow_ExtractFileName) then
		return;
	endif;
	
	fileName := _table.getValueByName(ETRow_ExtractFileName).String;
	
	self.getDiskFileName(fileName);
	
	_table.setValueByName(ETRow_ExtractFileName,fileName);
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2c2612a1-fbef-4cf2-b8b9-795f5e83a3e3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007364, locale);
end;</source>
    </JadeMethod>
</GUIClass>
