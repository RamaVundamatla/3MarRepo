    <JadeMethod name="showOOWConfirmation" id="4d1f6762-7384-4b6b-8536-df762e38438a">
        <source>showOOWConfirmation(_voyage: CM_Voyage): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/04/2018	jlgdap1		Initial creation TFS 38215 PEl1 OOW Confirmation Changes
//
vars

begin
	return _voyage.status = Voyage_Status_CargoRequested;

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
