    <JadeMethod name="buildCmbCustDocType" id="bd453344-9214-4c62-868d-758868786991">
        <updating/>
        <source>buildCmbCustDocType(_prevDocType : CM_CustomDocumentType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars
	docType : CM_CustomDocumentType;
	terminal: CM_Terminal;
begin
	self.cmbCustDocType.clear();
	terminal := self.myTerminal;
	
	if _prevDocType &lt;&gt; null then
		foreach docType in _prevDocType.allNextDocumentTypes do
			if not docType.notAvailForEntry and docType.hasAutoId then
				self.cmbCustDocType.addItemObject(docType.code &amp; Tab &amp; docType.description, docType);
			endif;
		endforeach;
	else
		foreach docType in terminal.allCustomDocumentTypes do
			if not docType.notAvailForEntry and docType.hasAutoId then
				self.cmbCustDocType.addItemObject(docType.code &amp; Tab &amp; docType.description, docType);
			endif;
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_prevDocType" type="CM_CustomDocumentType"/>
    </JadeMethod>
    <JadeMethod name="buildCmbCustomAgent" id="cba1204d-fde5-4907-aa8f-6b7860a7a061">
        <source>buildCmbCustomAgent();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars
	custAgent : CM_CustomsAgent;
begin
	self.cmbAgent.clear();
	
	foreach custAgent in app.myRoot.allCustomsAgents discreteLock do
		if not custAgent.isNotAvailableForEntry then
            self.cmbAgent.addItemObject(custAgent.code &amp;  Tab &amp; custAgent.name, custAgent);
        endif;
    endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbDirection" id="29724b0d-e4b1-4579-9350-c6b374c34337">
        <source>buildCmbDirection(_custDocType : CM_CustomDocumentType);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars

begin
	self.cmbDirection.clear();
	
	if _custDocType&lt;&gt; null then
		if _custDocType.direction = CM_CustomDocumentType.CustDocTypeDir_Inward then
			self.cmbDirection.addItemWithData(CM_CustomDocumentType.CustDocTypeDirStr_Inward,CM_CustomDocumentType.CustDocTypeDir_Inward);
			self.cmbDirection.listIndex := 1;
		elseif _custDocType.direction = CM_CustomDocumentType.CustDocTypeDir_Outward then
			self.cmbDirection.addItemWithData(CM_CustomDocumentType.CustDocTypeDirStr_Outward,CM_CustomDocumentType.CustDocTypeDir_Outward);
			self.cmbDirection.listIndex := 1;
		else
			self.cmbDirection.addItemWithData(CM_CustomDocumentType.CustDocTypeDirStr_Inward,CM_CustomDocumentType.CustDocTypeDir_Inward);
			self.cmbDirection.addItemWithData(CM_CustomDocumentType.CustDocTypeDirStr_Outward,CM_CustomDocumentType.CustDocTypeDir_Outward);
		endif;
	else
		self.cmbDirection.addItemWithData(CM_CustomDocumentType.CustDocTypeDirStr_Both,CM_CustomDocumentType.CustDocTypeDir_Both);
		self.cmbDirection.addItemWithData(CM_CustomDocumentType.CustDocTypeDirStr_Inward,CM_CustomDocumentType.CustDocTypeDir_Inward);
		self.cmbDirection.addItemWithData(CM_CustomDocumentType.CustDocTypeDirStr_Outward,CM_CustomDocumentType.CustDocTypeDir_Outward);
	
	endif;
epilog

end;</source>
        <Parameter name="_custDocType" type="CM_CustomDocumentType"/>
    </JadeMethod>
    <JadeMethod name="buildCmbHSCode" id="9d8eeec8-ca43-45b3-a9bc-8f9c8526dc43">
        <source>buildCmbHSCode();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars
	hsCode : CM_HarmonizedSystem;
begin
	self.cmbHSCode.clear();
	
	foreach hsCode in app.myRoot.allHSCodesActive discreteLock do
		if not hsCode.notAvailableForEntry then
            self.cmbHSCode.addItemObject(hsCode.id &amp;  Tab &amp; hsCode.description, hsCode);
        endif;
    endforeach;
	/*
	if self.myCustomDocument &lt;&gt; null then
		hsCode := self.myCustomDocument.myHSCode;
		if hsCode &lt;&gt; null
		and self.cmbcmbHSCodeHSCodes.findObject(hsCode) &lt; 0 then
            self.cmbHSCode.addItemObject(hsCode.id &amp;  Tab &amp; hsCode.description, hsCode);
		
		endif;
	endif;*/
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbLicense" id="cec6183b-7190-4b40-9bf9-fb8432ac3123">
        <source>buildCmbLicense(_custDocType : CM_CustomDocumentType);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars
	docLicense : CM_CustomLicense;
	setDefaultLicense : Boolean;
	firstTi		: CM_TrackedItem;
	terminalArea: CM_TerminalArea;
	defaultLicense : CM_CustomLicense;
	defaultIndex	: Integer;
begin
	
	self.cmbCustLicense.clear();
	
	setDefaultLicense := self.myTerminal.getConfig(DefaultCustDocLicense).Boolean;
	
	firstTi := self.cmifCompanyCustDocAgent.allTIs.first();
	if firstTi &lt;&gt; null then
		terminalArea := firstTi.myTerminalArea;
		if terminalArea &lt;&gt; null then
			defaultLicense := terminalArea.myCustomLicense;
		endif;
	endif;
	
	if _custDocType&lt;&gt; null then
		foreach docLicense in _custDocType.allCustomLicenses do
			if not docLicense.notAvailForEntry then
				self.cmbCustLicense.addItemObject(docLicense.code &amp;  Tab &amp; docLicense.description, docLicense);
			endif;
		endforeach;
	else
		foreach docLicense in self.myTerminal.allCustomLicenses do
			if not docLicense.notAvailForEntry then
				self.cmbCustLicense.addItemObject(docLicense.code &amp;  Tab &amp; docLicense.description, docLicense);
			endif;
		endforeach;
	endif;
	
	if self.cmbCustDocType.listIndex &gt; 0 and setDefaultLicense then
		if self.cmbCustLicense.listCount = 1 then
			self.cmbCustLicense.listIndex := 1;
			
		else
			defaultIndex := self.cmbCustLicense.findObject(defaultLicense);
			if defaultIndex &gt; 0 then
				self.cmbCustLicense.listIndex := defaultIndex;
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_custDocType" type="CM_CustomDocumentType"/>
    </JadeMethod>
    <JadeMethod name="cmbCustDocType_click" id="b55b618b-6e2f-4e7d-9935-a31a5a44bbe9">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCustDocType_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/10/2023	navkc1	CR 60422 Task 60917: JADE - Group Selected TIs by Transport

*/

vars
	custDocType : CM_CustomDocumentType;
	license : CM_CustomLicense;
begin
	
	custDocType := self.cmbCustDocType.listObject.CM_CustomDocumentType;
	if custDocType &lt;&gt; null then
		self.buildCmbLicense(custDocType);
		self.buildCmbDirection(custDocType);
		
	endif;
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
