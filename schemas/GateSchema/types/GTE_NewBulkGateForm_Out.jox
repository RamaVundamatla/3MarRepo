    <JadeMethod name="initTable" id="5207b295-baed-48ec-a6c8-3a26adb71a40">
        <source>initTable();
// ---------------------------------------------------------------------------
// Created:     25 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.tblItems.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_VisitRecordBulkOut));
	self.tblItems.userInputEnabled 	:= false;
	self.tblItems.selectMode 		:= Table.SelectMode_CurrentRow;
	self.tblItems.selectionType 	:= CM_DataTable.SelectionType_Row;
	self.tblItems.multiSelect 		:= self.tblItems.MultiSelect_None;
	self.tblItems.stretchWidth 		:= true;
	self.tblItems.stretchHeight 	:= false;
	self.tblItems.clearSort();
 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="0391112c-7303-443d-ae97-0dc4cd8e6d17">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------

vars
	vvr			: CM_VehicleVisitRecord;
	startTime	: TimeStamp;
	iter		: Iterator;
	
begin
	
	self.setNotifications(true);	// ### TFS 55215 01Dec2022 NAVPW1 - Removed // ### TFS N/A 22Nov2023 NAVPW1 - Un-Commented for Major Release
	self.tblItems.rows := self.tblItems.fixedRows;
	
	startTime := null;
	startTime.setDate(app.actualTimeServer.Date - self.txtSearchDays.text.Integer);
		
	iter := self.myTerminal.allVehicleVisits.createIterator();
	self.myTerminal.allVehicleVisits.startKeyGeq(startTime, iter);
	
	while iter.next(vvr) do
		if not vvr.isIncomplete() then
			continue;
		endif;	
		if not vvr.isBulkGateVVR then
			continue;
		endif;
		
		self.updateTable(vvr,true);
	endwhile;
		

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadPrinterCombo" id="eccb063f-9a08-4c0b-a3e7-7c720dff4706">
        <source>loadPrinterCombo();



// Changed On	By			Reason
// ----------	--------	-------------------------------------------------

vars

	
	gate 		: CM_Gate;
	gateArea 	: CM_GateArea;
	obj 		: Object;
	objSet 		: CM_ObjectSet;
	objArr 		: CM_ObjectArray;
	laneCont 	: CM_LaneController;
	existingPrinterName : String;
	printerName : String;
	index 		: Integer;
	
begin

	if self.printerIsUserSelected and self.cmbPrinter.listIndex &gt; 0 then
		existingPrinterName := self.cmbPrinter.text;
	endif;
	
	self.myAssistant.comboBoxPrintersLocal( self.cmbPrinter, existingPrinterName );
	
	gate := self.cmbGate.listObject.CM_Gate;
	if gate &lt;&gt; null then										
		create objSet transient;
		create objArr transient;
		
		gate.getPGateAreas_OUT(objSet);
		foreach obj in objSet do
			gateArea := obj.CM_GateArea; 
			gateArea.getAllLaneControllers(objArr);
		endforeach;	
		
		foreach obj in objArr do
			laneCont := obj.CM_LaneController;
			if laneCont.getLaneNumber = self.cmbGateLanes.text.Integer then
				printerName := laneCont.getPrinterPhysicalName;
				if printerName &lt;&gt; null then
					index := self.cmbPrinter.findStringExact( 1, printerName );
					if index &gt; 0 then
						self.cmbPrinter.listIndex := index;
					endif;
				endif;
				return;
			endif;
		endforeach;
	endif;														
	
epilog
	delete objSet;
	delete objArr;
end;	</source>
    </JadeMethod>
