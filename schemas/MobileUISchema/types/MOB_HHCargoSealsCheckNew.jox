    <JadeMethod name="clickBtnBack" id="2636b8b8-7712-4f78-bc18-e07dc2f9efd2">
        <updating/>
        <source>clickBtnBack() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2010	cnwndl1	Initial creation	Par 25608	part of SFW CCMS 1131

*/

