    <JadeMethod name="setForCreate" id="e4320aeb-b314-4ffd-a052-710c23a14c7e">
        <updating/>
        <source>setForCreate(_extractClass: CM_DataDumpExtractClass; _extractedFromDateTime, _extractedUpToTs,
		_startTs, _finishTs: TimeStamp; _numCreates, _numUpdates,
		_numDeletes: Integer; _systemAlertCreated: Boolean;
		_userCode, _userName: String; _deleteOids, _addOids, _updateOids : StringArray) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	extractClass   : CM_DataDumpExtractClass;
	classNameArray : HugeStringArray;
	lengthPerEntry : Integer;
	aliasString    : String;
	aClassName     : String;
	arraySize      : Integer;
	count          : Integer;
begin

// PAR 24641 - ensure the history shows all SQL Tables - pack as must as we can into 128 characters

	create classNameArray transient;
	foreach extractClass in _extractClass.myDataDumpExtractDef.allDataDumpExtractClasses where extractClass.className = _extractClass.className do
		classNameArray.add(extractClass.sqlTableName);
	endforeach;
	
	arraySize      := classNameArray.size;
	lengthPerEntry := (self.classAlias.maxLength div arraySize) - 2;
	//
	//  if we have only 1 or there are too many to be meaningfull just use the first
	//
	if arraySize = 1 or lengthPerEntry &lt; 10 then
		self.classAlias := _extractClass.classAlias;
	else
		foreach aClassName in classNameArray do
			count := count + 1;
			aliasString := aliasString &amp; aClassName[1 : lengthPerEntry];
			if count &lt; arraySize then
				aliasString := aliasString &amp; ", ";
			endif;
		endforeach;
		self.classAlias := aliasString;
	endif;

	self.className := _extractClass.className;
	self.finishDateTime := _finishTs;
	self.systemAlertCreated := _systemAlertCreated;
	self.numCreates := _numCreates;
	self.numDeletes := _numDeletes;
	self.numUpdates := _numUpdates;
	self.startDateTime := _startTs;
	self.userCode := _userCode[1:self.userCode.maxLength].trimBlanks;
	self.userName := _userName[1:self.userName.maxLength].trimBlanks;
	self.extractedUpToDateTime := _extractedUpToTs;
	self.extractedFromDateTime := _extractedFromDateTime;	
	_deleteOids.copy(self.deleteOids);
	_addOids.copy(self.addOids);
	_updateOids.copy(self.updateOids);
	self.myExtractClass := _extractClass;
	
	self.validateForCreate;
epilog
	delete classNameArray;
end;</source>
        <Parameter name="_extractClass" type="CM_DataDumpExtractClass"/>
        <Parameter name="_extractedFromDateTime" type="TimeStamp"/>
        <Parameter name="_extractedUpToTs" type="TimeStamp"/>
        <Parameter name="_startTs" type="TimeStamp"/>
        <Parameter name="_finishTs" type="TimeStamp"/>
        <Parameter name="_numCreates" type="Integer"/>
        <Parameter name="_numUpdates" type="Integer"/>
        <Parameter name="_numDeletes" type="Integer"/>
        <Parameter name="_systemAlertCreated" type="Boolean"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_deleteOids" type="StringArray"/>
        <Parameter name="_addOids" type="StringArray"/>
        <Parameter name="_updateOids" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="55e82cdd-2c04-45aa-9f88-feddc775ff02">
        <source>validateForCreate() protected;
// ---------------------------------------------------------------------------
// Created:     29 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.raiseExceptionIfTransient(method);

	if self.extractedUpToDateTime &lt;&gt; null and
			not self.extractedUpToDateTime.isValid then
		app.raiseCMException(ERR_DATETIME_FORMAT, null, null);
	endif;
	if not self.startDateTime.isValid then
		app.raiseCMException(ERR_DATETIME_FORMAT, null, null);
	endif;
	if not self.finishDateTime.isValid then
		app.raiseCMException(ERR_DATETIME_FORMAT, null, null);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
