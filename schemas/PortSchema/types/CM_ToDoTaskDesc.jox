    <JadeMethod name="getTrxTypeOnCompleteClassName" id="fbc1adb4-0d9f-4803-a9d8-8c7fd5135cc2">
        <source>getTrxTypeOnCompleteClassName() : String;
// --------------------------------------------------------------------------------
// Created:		28 November 2005 by cnwdad1
//
// Purpose:		Returns the name of the Transaction Type of the receiver.
//
// Parameters:	None
//
// Returns:		The name of the receiver's Transaction Type class.
//
// Changed On	Changed By	Reason
