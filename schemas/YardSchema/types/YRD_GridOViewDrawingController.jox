    <JadeMethod name="doSatViewBlockStackColourCargo" id="1590d175-e8ff-4dfd-b26b-08423b5c1e47">
        <source>doSatViewBlockStackColourCargo(	_lc: CM_LocationsController;
								_theFrame : CMUI_GridAreaDrawingFrame io;
								_x1: Real;
								_y1: Real;
								_x2: Real;
								_y2: Real
								);

/*

Purpose:			

Parameters:			

Return Value:		


Date		 Who		Reason
29 Aug 2011	 cnwndl1	Initial creation	Par 28076
07 Apr 2014  cnwer1	    CCMS 1366 bulk changes this draws for block stacks and bulk areas if most of the cargo is bulk then the ratios are in weights
25 Aug 2017	 cnwma1	    TFS #5487 JMT - Sat View Cannot See Empty GC Areas
08 Sept 2022 navrk21    Bug 54717: GPHA -- Error 4033 in Satellite View
*/

vars

	startingFillColour : Integer;
	form : YRD_SatelliteViewForm;
	iter : Iterator;
	ti : CM_TrackedItem;
	colour, biggestColour : Integer;
	colourArray : IntegerArray;
	numberArray : IntegerArray;
	index : Integer;
	size : Real;
	countBulk : Integer;
	biggestHeight, totalHeight : Real;
	top : Real;
	start : Real;
	height : Real;
	bottom : Real;
	left : Integer;
	right : Integer;
	//totalWeight : Decimal[14,4];	// 08.09.2022 navrk21 #54717
	totalWeight : Decimal[23,4];	// 08.09.2022 navrk21 #54717
	isByWeight : Boolean;
	localTis : CM_TIArray;
	frameDrawWidth : Integer;
begin

	startingFillColour := _theFrame.drawFillColor;

	if self.myGridOverviewForm &lt;&gt; null and self.myGridOverviewForm.isKindOf( YRD_SatelliteViewForm ) then
		form := self.myGridOverviewForm.YRD_SatelliteViewForm;
	endif;
	
	//28 Mar 2017	NLD	TFS 3423 - Need to drill down to see all shelves on racks)
	create localTis transient;
	_lc.getTIs(localTis,REAL_MODE, true);
	
	//25/08/217 cnwma1 TFS #5487
	//if form = null or localTis.isEmpty then
	if form = null then
		return;
	endif;
	
	
	// get a collection of the colours to use, and how many cargo items to be associated with each colour
	iter := localTis.createIterator;	
	
	foreach ti in localTis do
		size:=size +  ti.totalQuantity.max(1);
		totalWeight:=totalWeight + ti.totalWeight;
		if ti.isBulkCargo then
			countBulk:=countBulk  + 1;
		endif;
	endforeach;
	
	//if the majority of cargo is bulk ratio by weight
	if countBulk &gt; (localTis.size/2).Integer then
		isByWeight:=true;
		size:=totalWeight;
	endif;
		
	
	create colourArray transient;
	create numberArray transient;
	
	colour := self.satelliteViewCellColour;

	while iter.next( ti ) do
		if self.useSelector then
			colour := self.satelliteViewCellColour;
			if self.allSelectorTIs.includes(ti) then
				colour := self.getFillColourForTI(ti);
			endif;
		else
			colour := self.getFillColourForTI(ti);
			if colour = NullColour then
				colour := self.satelliteViewCellColour;
			endif;
		endif;
		if colourArray.isEmpty then
			// add the first colour
			colourArray.add( colour );
			if isByWeight then
				numberArray.add(ti.totalWeight.Integer  );
			else
				numberArray.add(ti.totalQuantity  );// 1 
			endif;
		else
			// find the colour in our collection
			index := colourArray.indexOf(colour);
			if index &lt; 1 then
				// we don't have it yet, add it.
				colourArray.add( colour );
				if isByWeight then
					numberArray.add(ti.totalWeight.Integer  );
				else
					numberArray.add(ti.totalQuantity );// 1  
				endif;
			else
				
				if isByWeight then
					numberArray[index] := numberArray[index] + ti.totalWeight.Integer;
				else
					// we found it, increment the count for this colour
					numberArray[index] := numberArray[index] +  ti.totalQuantity  ;//; // +1
				endif;
			endif;
		endif;
	endwhile;
 	

	left := _x1.Integer + 1;	// left hand edge of the coloured rectangle we will draw
	right := _x2.Integer - 1;	// right hand edge of the coloured rectangle we will draw
	totalHeight := (_y2 - _y1) - 2; // total height for all colours in the block stack drawing
	start := _y1 + 1;	//starts is at the top of the area we can use.
	
	if size = 0 then	// 22/09/2014 cnwar2 #34924
		size := 1;		// protect against division by zero below
	endif;
	
	//25/08/217 cnwma1 TFS #5487
	if  _lc.isKindOf(CM_IrregularBlockController) and localTis.isEmpty then
		top := start;	
		height :=totalHeight; // height of this colour i.e. percentage of the total height.
		bottom := start + height; // botom edge of this colours rectangle
		frameDrawWidth :=_theFrame.drawWidth;
		_theFrame.drawWidth :=1; // TFS 49959 - draw width 1
		_theFrame.drawFillColor := self.satelliteViewCellColour; 
		_theFrame.drawFilledRectangle(left, top.Integer, right, bottom.Integer, Black);  // TFS 49959 filled rectangle
		_theFrame.drawWidth := frameDrawWidth;
		// JLGAB1 TFS 49959
		self.drawCapacityUsed(White, _lc, _theFrame, left, top.Integer, right, bottom.Integer);
		return;
	endif;
		
	biggestHeight := 0;
	foreach index in 1 to colourArray.size do
		top := start;	// top edge of this colours rectangle
		
		height := ( ( totalHeight * numberArray[index] ) / size ); // height of this colour i.e. percentage of the total height.
		bottom := start + height; // botom edge of this colours rectangle
		_theFrame.drawFillColor := colourArray[index];	// colour to use.
		_theFrame.drawFilledRectangle(left, top.Integer, right, bottom.Integer,  colourArray[index] ); // draw it.
		start := bottom; // set the start position for the next colour.
		
		if height &gt;	biggestHeight then
			biggestHeight := height; 
			biggestColour := index;
		endif;
	endforeach;
	
	// JLGAB1 TFS 49959
	if biggestColour = 0 then 
		biggestColour := colourArray.size();
	endif;
	if not colourArray.isEmpty 
	and (biggestColour &gt; 0 and biggestColour &lt;= colourArray.size()) then
		self.drawCapacityUsed(colourArray[biggestColour], _lc, _theFrame, _x1,_y1, _x2,_y2);
	else
		self.drawCapacityUsed(White, _lc, _theFrame, _x1,_y1, _x2,_y2);
	endif;
	
epilog

	delete iter;
	delete colourArray;
	delete numberArray;
	_theFrame.drawFillColor := startingFillColour;
	delete localTis;

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_theFrame" type="CMUI_GridAreaDrawingFrame" usage="io"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doZoom" id="49d6f49d-9c72-4c8f-a783-57f92e09317d">
        <updating/>
        <source>doZoom(pFactor: Real) updating;
// ---------------------------------------------------------------------------
// Created:		14 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theFactor : Real;
begin

	app.mousePointer := Window.MousePointer_HourGlass;

	theFactor := pFactor;
	
	if theFactor &lt;= 0 then
		theFactor := ScaleFactor_1;
	endif;

	self.setScale(theFactor, true, true);
	
	self.drawSelfALL();
	

epilog 
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="pFactor" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawALLMachinesWorkzone" id="a9a95c6c-1f3e-439a-b8af-0bbdcd5fc6b6">
        <source>drawALLMachinesWorkzone( );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2009	cnwer1	Initial creation

*/

vars
	iter	: Iterator;
	machine : CM_Machine;
	cmifMachineWorkzone : CMIF_MachineWorkzone;

begin
	//epr par 26329 15/11/10
	//if not set to draw machine workzones then hide them if they are already there
	if not self.showMachineWorkzones then
		self.clearRTGMachineWorkzones();
		return;
	endif;
	
	self.allCMIFMachineWorkzones.purge;
	iter:=self.myTerminal.machines.createIterator;
	while iter.next(machine) do
		if machine.machineType = MACHINETYPE_RTG or
			machine.machineType = MACHINETYPE_RMG then
			
			cmifMachineWorkzone:=machine.getCMIFMachineWorkzone();
			
			if cmifMachineWorkzone &lt;&gt; null then
				self.drawRTGMachinesWorkzone(cmifMachineWorkzone);
				self.allCMIFMachineWorkzones.add(cmifMachineWorkzone);
				
				
			endif;
			
			self.drawRTGLastKnowPosition(machine);
			self.notableObjectAdd(machine);
		else
			continue;
		endif;
	endwhile;
	//we actually 
epilog
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="drawAreaName" id="e7b26fa2-22c2-417a-b3d5-b2803a1b4139">
        <source>drawAreaName(x: Real io; y: Real io);
//12 August 2008	cnwdw1	
//CCMS 1030
vars
	frame: CMUI_Frame;
begin
	frame := self.myDrawingFrame;
	frame.drawFontSize := self.getFontSizeLabel;
	frame.drawTextAlign := Frame.DrawTextAlign_Left;
	frame.drawTextAt(self.myTerminalArea.id, 5 + x + 1, y, White);
	frame.drawTextAt(self.myTerminalArea.id, 5 + x, y+1, Black);	
	y := y + self.TitleHeight + self.Spacing;
end;</source>
        <Parameter name="x" type="Real" usage="io"/>
        <Parameter name="y" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawAreaTitle" id="889e9229-e48f-4030-b494-be12a4d6e105">
        <source>drawAreaTitle(_startX, _startY , _endX, _endY : Real;
				_displayTopColumnLabels : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 November 2010	cnwer1	Initial creation

*/

vars
	
begin
	
	//epr par 36616 13/10/15
	if ( 	self.myTerminalArea.isKindOf(CM_StraddleStack)
				or self.myTerminalArea.isKindOf(CM_RTGArea)
				or self.myTerminalArea.isKindOf(CM_ForkLiftStack)
				) then
		self.drawGriddedAreaTitle(_startX, _startY , _endX, _endY, _displayTopColumnLabels );
		return;
	else
		self.drawBlockAreaTitle(_startX, _startY , _endX, _endY );
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_startX" type="Real"/>
        <Parameter name="_startY" type="Real"/>
        <Parameter name="_endX" type="Real"/>
        <Parameter name="_endY" type="Real"/>
        <Parameter name="_displayTopColumnLabels" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawArrow" id="0f92b2bd-a497-4471-8c36-577ee65b4457">
        <source>drawArrow(_x1, _y1, _x2, _y2: Real; _colour: Integer; _frame: CMUI_Frame; _lesserEnd, _greaterEnd: Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 October 2017	jlgmp6	Initial creation

*/
vars
	paraOffset, perpOffset: Real;
begin
	paraOffset := 6 * self.scaleFactor;
	perpOffset := 4 * self.scaleFactor;
	
	_frame.drawLine(_x1, _y1, _x2, _y2, _colour);
	
	if _x1 = _x2 then		// vertical
		if _lesserEnd then
			_frame.drawLine(_x1, _y1, _x1 - perpOffset, _y1 + paraOffset, _colour);
			_frame.drawLine(_x1, _y1, _x1 + perpOffset, _y1 + paraOffset, _colour);
		endif;
		if _greaterEnd then
			_frame.drawLine(_x2 - perpOffset, _y2 - paraOffset, _x2, _y2, _colour);
			_frame.drawLine(_x2 + perpOffset, _y2 - paraOffset, _x2, _y2, _colour);
		endif;
	elseif _y1 = _y2 then	// horizontal
		if _lesserEnd then
			_frame.drawLine(_x1, _y1, _x1 + paraOffset, _y1 - perpOffset, _colour);
			_frame.drawLine(_x1, _y1, _x1 + paraOffset, _y1 + perpOffset, _colour);
		endif;
		if _greaterEnd then
			_frame.drawLine(_x2 - paraOffset, _y1 - perpOffset, _x2, _y1, _colour);
			_frame.drawLine(_x2 - paraOffset, _y1 + perpOffset, _x2, _y1, _colour);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_frame" type="CMUI_Frame"/>
        <Parameter name="_lesserEnd" type="Boolean"/>
        <Parameter name="_greaterEnd" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawBlankRow" id="8b80218d-2434-4b41-87e1-af37a83eeb1d">
        <source>drawBlankRow(_y1, _y2 : Real);
// ---------------------------------------------------------------------------
// Created:		23 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	tX1, tY1, tX2, tY2 : Integer;
begin
	theFrame := self.myDrawingFrame;

	tX1 := LeftMargin;
	tY1 := _y1.Integer;
	tX2 := (theFrame.width- LeftMargin).Integer;
	tY2 := _y2.Integer;
	

	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawFillColor := theFrame.backColor;
	theFrame.drawWidth := 1;
	theFrame.drawFilledRectangle(tX1, tY1, tX2, tY2, theFrame.backColor);

	self.gridObjectsRemove(tX1, tY1, tX2, tY2);

end;</source>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawBlockAreaTitle" id="5c28c732-9fb4-4678-8886-9b1882a036ca">
        <source>drawBlockAreaTitle(_startX, _startY , _endX, _endY : Real) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2011	cnwndl1	Initial creation	Par 28712

*/

vars

	yPos1,
	xPos1 : Real;
	taID : String;
	taViewPos : CM_TerminalAreaViewPosition;
	leftAlignAdjustment, leftOffSet, hCentre, hTextlength, topPoint, bottomPoint, leftPoint, rightPoint : Real;
	
begin

	taViewPos:=self.myTerminalAreaView.findViewPositionForTA(self.myTerminalArea.CM_TerminalArea);
	self.myDrawingFrame.drawFillColor := self.myTerminalArea.myTerminal.getConfig(SatelliteViewBackColour).Integer;
	self.myDrawingFrame.drawFontSize := self.labelFontSize;
	self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	self.myDrawingFrame.drawFontBold := true;
	
	//epr par 36616 13/10/15
	taID:=self.myTerminalArea.getSatViewHeading(taViewPos);
	yPos1 := yPos1 - self.getSpaceForDifferentFonts(3);
	
	// need to clobber any existing text cos we might be updating existing text (cargo count).
	// i.e. blank it out with a rectangle the sam ecolour as the background.
	if self.myDrawingFrame.swapXY then
		
		topPoint := _startX;
		bottomPoint := topPoint - ( self.TitleHeight + self.myDrawingFrame.getTextHeight(taID) );
		xPos1 := topPoint + ((bottomPoint - topPoint) / 2);
		
		leftOffSet := (self.getSpaceForDifferentFonts(1) ) + 3;
		leftPoint := _startY + leftOffSet;
		rightPoint := leftPoint + (taViewPos.getHeight() * self.scaleFactor); 

		hCentre := leftPoint + ( (rightPoint - leftPoint ) / 2 );// horizontal centre point of title area
					
		hTextlength := ( self.myDrawingFrame.getTextExtent( taID &amp; "XXX" ) );  // text length
		if self.scaleFactor = .375 then
			hTextlength := hTextlength / 2;
		elseif self.scaleFactor = .5 then
			hTextlength := hTextlength / 1.5;
		elseif self.scaleFactor = .75 then
			hTextlength := hTextlength / 1.25;
		elseif self.scaleFactor = 1 then
			hTextlength := hTextlength / 1.1;
		elseif self.scaleFactor = 1.5 then
			hTextlength := hTextlength / 0.9;
		elseif self.scaleFactor = 2 then
			hTextlength := hTextlength / 0.75;
		endif;
					
		leftPoint := hCentre - ( hTextlength / 2 );
		rightPoint := hCentre + ( hTextlength / 2 );
		yPos1 := leftPoint + ((rightPoint - leftPoint) / 2);
		
		leftAlignAdjustment := self.myDrawingFrame.drawTextHeight(taID) * 0.5;
		yPos1 := yPos1 - leftAlignAdjustment;
				
		self.myDrawingFrame.drawFilledRectangle( topPoint, leftPoint, bottomPoint, rightPoint, self.myDrawingFrame.drawFillColor);		
	else
	
		yPos1 := _startY -  self.myDrawingFrame.drawTextHeight(taID);		
		xPos1 := _startX + ((_endX - _startX) / 2);
		self.myDrawingFrame.drawFilledRectangle(_startX, yPos1, _endX, _startY - 1,  self.myDrawingFrame.drawFillColor);
		
	endif;
	
	self.myDrawingFrame.drawTextAt(taID, xPos1 + 1, yPos1, self.satelliteViewFontColour);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_startX" type="Real"/>
        <Parameter name="_startY" type="Real"/>
        <Parameter name="_endX" type="Real"/>
        <Parameter name="_endY" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawBlockStack" id="a813b452-eb84-4518-8c8f-2ed5cf07ff1c">
        <source>drawBlockStack(_taViewPos : CM_TerminalAreaViewPosition; _color: Integer; _x1: Real; _y1: Real) protected;
/*

Date		Who		Reason
13 Mar 2009	cnwkpd1	PAR #19154 - User self.myTerminal instead of app.getMyTerminal to prevent
					1090 exceptions when processing notes "in the background"
11 Nov 2010 cnwer1 	PAR 26189 - removed the allGridObjects.includes - expensive linear search and not required
*/
vars
	theFrame: CMUI_GridAreaDrawingFrame;
	x2, y2: Real;
	numItems : Integer;
	bs 		: CM_TerminalArea;
	lc : CM_LocationsController;
begin
	bs:=_taViewPos.myTerminalArea;
	lc := bs.getLocationsController;
	if lc = null then
		return;
	endif;
	theFrame := self.myDrawingFrame;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawWidth := 1;
	theFrame.drawFillColor := _color;

	//29 Aug 2011	NDL	Par 28076
	x2 := _x1 +  (_taViewPos.getWidth() *    self.scaleFactor); //epr CCMS 1366 when added Bulk Areas to Satellite view def changed so could resize
	y2 := _y1 +  (_taViewPos.getHeight() *    self.scaleFactor);  //epr CCMS 1366 when added Bulk Areas to Satellite view def changed so could resize
	theFrame.drawFilledRectangle(_x1, _y1, x2, y2,  self.satelliteViewGridColour);
	
	//29 Aug 2011	NDL	Par 28076
	numItems := lc.allTrackedItems.size;
	if numItems &gt; 0 then
		self.doSatViewBlockStackColourCargo( lc, theFrame,_x1, _y1, x2, y2 );
	else
		// JLGAB1 TFS 49959
		self.drawCapacityUsed(White, lc, theFrame, _x1,_y1, x2, y2);
	endif;

	if not self.drawFromNote then
		self.gridObjectsPutAtKey(_x1.Integer, _y1.Integer, x2.Integer, y2.Integer, lc);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_taViewPos" type="CM_TerminalAreaViewPosition"/>
        <Parameter name="_color" type="Integer"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawBlockStackFromNote" id="a2ca556d-dcaf-475a-a778-9746b0cfa82d">
        <updating/>
        <source>drawBlockStackFromNote( _bs : CM_TerminalArea  ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 August 2011	cnwndl1	Initial creation	Par 28076
04/09/2012 		cnwmh5	#29809 - if taViewPos if null then return as we don't need to do anything
*/

constants

	BottomMargin	: Integer = 10;
	RightMargin		: Integer = 10;

vars

	taViewPos : CM_TerminalAreaViewPosition;
	xPos1 : Real;
	yPos1 : Real;
	xPos2 : Real;
	yPos2 : Real;
	startX : Integer;
	startY : Integer;
	endX : Integer;
	endY : Integer;
	existingTa : CM_TerminalAreaMaster;
	
begin
	
	if _bs = null then
		return;
	endif;
	
	
	taViewPos:=self.myTerminalAreaView.findViewPositionForTA(_bs);
	
	if taViewPos = null then					// 04/09/2012 cnwmh5 #29809
		return;
	endif;
	
	self.getTAOriginForTAViewPos(taViewPos,xPos1, yPos1);

	startX := xPos1.Integer;
	startY := yPos1.Integer;

	xPos2 := xPos1;

	yPos2 := yPos1 + self.rowHeight;
	xPos1 := xPos2;
	
	self.setOrientation( taViewPos );	//18 Jan 2013	Par 30896
	self.drawBlockStack(taViewPos, self.satelliteViewCellColour, xPos1, yPos2 - self.getSpaceForDifferentFonts(0.3) * 2);

	endX := (xPos1 + (taViewPos.getWidth() *    self.scaleFactor)).Integer;
	endY := (yPos1 + (taViewPos.getHeight() *    self.scaleFactor)).Integer;
	
	existingTa := self.myTerminalArea;
	self.myTerminalArea := _bs;
	
	self.drawAreaTitle( startX, startY, endX, endY, taViewPos.displayTopColumnLabels );
	self.myTerminalArea := existingTa;
			
epilog

	self.setOrientation( null );	//18 Jan 2013	Par 30896
	
end;</source>
        <Parameter name="_bs" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="drawBuildingTop" id="ae39ccd9-9add-4d1f-84b7-7a85b5b86717">
        <source>drawBuildingTop(pColor: Integer; pHeight: Integer; pX1: Real; pY1: Real; pX2: Real; pY2: Real) protected;
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
//	// PAR 19227
//	MinFloodFillFactor = 0.5;
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	thick : Integer;
begin
	thick := (self.scaleFactor + 1).Integer;
	if thick &gt; 3 then
		thick := 3;
	endif;
	
	
	theFrame := self.myDrawingFrame;

	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawWidth := thick;
// PAR 19519	theFrame.drawFillColor := 14965; // Dark Brown
	theFrame.drawFillColor := 20639; // Dark Brown PAR 19519
	theFrame.drawFilledRectangle(pX1, pY1, pX2, pY2,  Black);
	theFrame.drawWidth := 1;

	theFrame.drawLine(pX1 + thick, pY1 + thick, pX2 - thick, pY2 - thick,Black);
	theFrame.drawLine(pX1 + thick, pY2 - thick, pX2 - thick, pY1 + thick,Black);

	theFrame.drawFillColor := 20639; // Dark Brown
	
//	PAR 19515 if self.scaleFactor &gt;= MinFloodFillFactor then
//		theFrame.drawFloodFill(pX1 + 10, pY1 + thick + 1,0,Black);
//	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pColor" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pX1" type="Real"/>
        <Parameter name="pY1" type="Real"/>
        <Parameter name="pX2" type="Real"/>
        <Parameter name="pY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawCapacityUsed" id="f02d33e2-085a-4d8b-bfa4-74723993f4e7">
        <source>drawCapacityUsed(_backColour : Integer; 
								_lc: CM_LocationsController;
								_theFrame : CMUI_GridAreaDrawingFrame io;
								_x1: Real;
								_y1: Real;
								_x2: Real;
								_y2: Real);
// JLGAB1 TFS 49959
constants
	SingleRow = 1;
	DoubleRow = 2;
	TripleRow = 3;
	SingleCol = 1;
	DoubleCol = 2;
	TripleCol = 3;
	QuadrupleCol = 4;
	QuintupleCol = 5;

vars
	fillColour, textColour, edge : Integer;
	textY, y3: Real;
	tCapacityPC, pCapacityPC, aCapacityPC, capacityMax : Integer;
	caption : String;
	theTI : CM_TrackedItem;
	tAmount, aAmount, pAmount, capAmount  : Decimal[23,1];
	tQuantity, aQuantity, pQuantity : Integer;
	ya : CM_YardAllocation;
	suffix : String;
	printSmall, printMedium, printLarge : Boolean;
	width, height : Real;
	rowtype, coltype : Integer;
	gclc : CM_IrregularBlockController;
	firstPoint : Point;
	lastPoint : Point;
	xSpan : Integer;
	ySpan : Integer;
	amountType, measurementTypeString : String;
	measurementTypeW : CM_MeasurementType;
	measurementTypeV : CM_MeasurementType;
	actualStr, plannedStr, totalStr, capacityStr : String;
begin

	if not self.showCapacity then
		return;
	endif;
	
	if self.scaleFactor &lt; 0.75 then // Menu scale 1.5
		return;
	endif;
	
	
	height := (_y2 -_y1);
	width := (_x2 -_x1);
	
	if  _lc.isShelf()  then
		return;
	endif;
		
	if _lc.isRowController() then
		if _lc.CM_GeneralCargoAllocController.myGroup.allLocations.first() &lt;&gt; _lc then
			return;
		endif;
	endif;
	
	measurementTypeW := app.getDefaultMeasurementForType(Type_Weight); // TFS 51393 BISH 21JUN2021
	measurementTypeV := app.getDefaultMeasurementForType(Type_Volume); // TFS 51393 BISH 21JUN2021

	amountType := _lc.getCapacityUsedDetails(pCapacityPC,aCapacityPC, pAmount, aAmount, capacityMax);
	
	if amountType = "BULKW" or amountType = "BULKV" then
		if amountType = "BULKW" then
			aAmount := measurementTypeW.convertValueAsValue(aAmount); // TFS 51393 BISH 21JUN2021
			pAmount := measurementTypeW.convertValueAsValue(pAmount); // TFS 51393 BISH 21JUN2021
			capAmount := measurementTypeW.convertValueAsValue(capacityMax); // TFS 51393 BISH 21JUN2021
			
			suffix := measurementTypeW.shortName;  // TFS 51393 BISH 21JUN2021
		else
			aAmount := measurementTypeV.convertValueAsValue(aAmount); // TFS 51393 BISH 21JUN2021
			pAmount := measurementTypeV.convertValueAsValue(pAmount); // TFS 51393 BISH 21JUN2021
			capAmount := measurementTypeV.convertValueAsValue(capacityMax); // TFS 51393 BISH 21JUN2021
			
			suffix := measurementTypeV.shortName;  // TFS 51393 BISH 21JUN2021
		endif;
		tAmount := aAmount + pAmount; // Bulk
		
		// Convert to string so has 1 decimal place
		actualStr := aAmount.asStringJMTWithPrecision(1,false);
		plannedStr := pAmount.asStringJMTWithPrecision(1,false);
		totalStr := tAmount.asStringJMTWithPrecision(1,false);
		capacityStr := capAmount.asStringJMT();
	else
		aQuantity := aAmount.Integer;
		pQuantity := pAmount.Integer; // TFS 51393 BISH 21JUN2021
		tQuantity := pQuantity + aQuantity; // Break Bulk
		
		// Convert to string so has 0 decimal place
		actualStr := aQuantity.asStringJMT();
		plannedStr := pQuantity.asStringJMT();
		totalStr := tQuantity.asStringJMT();
		capacityStr := capacityMax.asStringJMT();
	endif;
	

	fillColour := _backColour;
	
	tCapacityPC := pCapacityPC + aCapacityPC;
	
	// DEFAULT
	rowtype := TripleRow;
	coltype := QuadrupleCol;
	
	if _lc.isKindOf(CM_IrregularBlockController) then
		gclc := _lc.CM_IrregularBlockController;
	

		firstPoint := gclc.region.first;
		lastPoint := gclc.region.last;
		coltype := (lastPoint.x - firstPoint.x) + 1;
		rowtype := (lastPoint.y - firstPoint.y) + 1;
	endif;

	if rowtype = SingleRow then
		if coltype = SingleCol then
			caption := aCapacityPC.String &amp; "%";
		elseif coltype = DoubleCol then
			caption := "C: " &amp; aCapacityPC.String &amp; "%";
			
		elseif coltype = TripleCol or coltype = QuadrupleCol then
			caption := actualStr &amp; "/" &amp; capacityStr &amp; " " &amp; suffix &amp;  " - " &amp; aCapacityPC.String &amp; "%";
		elseif coltype = QuintupleCol then
			caption := "Actual: " &amp; actualStr &amp; "/" &amp; capacityStr &amp; " " &amp; suffix &amp;  " - " &amp; aCapacityPC.String &amp; "%";
		endif;
	elseif rowtype &gt;= DoubleRow then
		if coltype = SingleCol then
			caption := aCapacityPC.String &amp; "%" &amp;  CrLf  &amp; 
							pCapacityPC.String &amp; "%" &amp;  CrLf &amp; 
							tCapacityPC.String &amp; "%";
		elseif coltype = DoubleCol and rowtype = DoubleRow then
			caption := aCapacityPC.String &amp; "%" &amp;  CrLf  &amp; 
							pCapacityPC.String &amp; "%" ;
		elseif coltype = DoubleCol  then
			caption := aCapacityPC.String &amp; "%" &amp;  CrLf  &amp; 
							pCapacityPC.String &amp; "%" &amp;  CrLf  &amp; 
							tCapacityPC.String &amp; "%";
		elseif coltype = TripleCol or coltype = QuadrupleCol then
			caption := "A: " &amp;  actualStr &amp; "/" &amp; capacityStr &amp; " " &amp; suffix &amp;  " - " &amp; aCapacityPC.String &amp; "%" &amp;  CrLf  &amp; 
						"P: " &amp; plannedStr  &amp; "/" &amp; capacityStr &amp;  " " &amp; suffix &amp;  " - " &amp; pCapacityPC.String &amp; "%" &amp;  CrLf &amp; 
						"T: " &amp; totalStr  &amp; "/" &amp; capacityStr &amp;  " " &amp; suffix &amp;  " - " &amp; tCapacityPC.String &amp; "%" ;
		elseif coltype &gt;= QuintupleCol then
			caption := "Actual: " &amp; actualStr &amp; "/" &amp; capacityStr &amp; " " &amp; suffix &amp;  " - " &amp; aCapacityPC.String &amp; "%" &amp;  CrLf  &amp; 
						"Planned: " &amp; plannedStr  &amp; "/" &amp; capacityStr &amp;  " " &amp; suffix &amp;  " - " &amp; pCapacityPC.String &amp; "%" &amp;  CrLf &amp; 
						"Total: " &amp; totalStr  &amp; "/" &amp; capacityStr &amp;  " " &amp; suffix &amp;  " - " &amp; tCapacityPC.String &amp; "%";
		
		endif;
	endif;
	

	_theFrame.drawFontBold := false;
	_theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	_theFrame.drawFillColor := fillColour;
	textColour := fillColour.getInverseColour();
	textY := _y1 + 5;
	
	_theFrame.getTextDrawFontSizeForWidthHgt(caption,width - 5, height - 5);
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	_theFrame.drawTextAt(caption, _x1 + 3,textY,textColour);

end;
</source>
        <Parameter name="_backColour" type="Integer"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_theFrame" type="CMUI_GridAreaDrawingFrame" usage="io"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawColumnLabel" id="405c3d3e-2eda-42fd-88a1-edfc02a77dc6">
        <source>drawColumnLabel(_xpos1,_ypos1 : Real;_isTop : Boolean; tmpCaption : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwer1	Initial creation

*/
constants

	ColHeight = 10;
vars
	tmpX,
	tmpY : Real;

begin
	if self.myDrawingFrame.swapXY then
		tmpX := _xpos1;
		tmpY := _ypos1;
		if _isTop then
			self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Right;
		else
			self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Left;
		endif;
	else	
		tmpX := _xpos1 + (self.columnWidth / 2); 
		if _isTop then
			tmpY := _ypos1 - ColHeight;
		else
			tmpY := _ypos1;
		endif;
		self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	endif;
	self.myDrawingFrame.drawFontSize := self.getFontSizeRowColHeading;
	self.myDrawingFrame.drawTextAt(tmpCaption, tmpX, tmpY, self.satelliteViewFontColour);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xpos1" type="Real"/>
        <Parameter name="_ypos1" type="Real"/>
        <Parameter name="_isTop" type="Boolean"/>
        <Parameter name="tmpCaption" type="String"/>
    </JadeMethod>
    <JadeMethod name="drawGCAllocRowArea" id="01d9516d-37e3-4c5a-a2cf-0b7e809721fc">
        <updating/>
        <source>drawGCAllocRowArea(_taViewPos : CM_TerminalAreaViewPosition; _x, _y : Integer; _endX, _endY : Integer output) protected, updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// 23/07/2020	jlgdap1		TFS 49783 ASPA Graphical Display
//
vars
	theFrame: CMUI_GridAreaDrawingFrame;
	flipH : Boolean;
	ta : CM_GeneralCargoAllocRowArea;
	x1, y1, x2, y2 : Real;
	lcSet : CM_LCSet;
	nbrCols, pos : Integer;
	colWidth, colX, colX2, lastColX : Real;
	lc : CM_LocationsController;
	lcCol : CM_GeneralCargoAllocController;
	iter : Iterator;
	lastGroup : CM_GeneralCargoAllocGroup;
	textExtent : Integer;
	rangeX1, rangeY1, rangeX2, rangeY2 : Integer;
	tmpX1, tmpX2, tmpY1, tmpY2 : Integer;
	rangeLabel : String;

begin
	theFrame := self.myDrawingFrame;
	ta := _taViewPos.myTerminalArea.CM_GeneralCargoAllocRowArea;
	// General Cargo Allocation Row Areas can't be flipped vertically
	flipH := _taViewPos.horizontalFlip;
	
//	write _taViewPos.isFlippedHorizontal().String &amp; " " &amp; _taViewPos.isFlippedVertical().String &amp; " " &amp; _taViewPos.rotation.String;
	
	
	// draw area border
	x1 := _x;
	y1 := _y;
	x2 := x1 + ta.getSatDrawLengthInPixels(self.scaleFactor);
	y2 := y1 + ta.getSatDrawWidthInPixels(self.scaleFactor);
	
	theFrame.drawFillColor := self.satelliteViewCellColour;
	theFrame.drawFilledRectangle(x1, y1, x2, y2, self.satelliteViewGridColour);
	_endX := x2.Integer;
	_endY := y2.Integer;
	if not self.drawFromNote then
		self.selectionBoundsObjectsPutAtKey(x1.Integer, y1.Integer, x2.Integer, y2.Integer, ta);
	endif;
	
	// draw the columns and group boundaries
//	create lcSet transient;
	lcSet := ta.getLCSet;
	nbrCols := lcSet.size;
	colWidth := (x2 - x1) / nbrCols;
	colX := x1 + colWidth;
	iter := lcSet.createIterator;
	if flipH then
		iter.startAtIndex(lcSet.size);
	else
		iter.startAtIndex(1);
	endif;
	
	pos := 1;
	lastColX := x1;
	while pos &lt;= nbrCols do
		if flipH then 
			iter.back(lc);
		else
			iter.next(lc);
		endif;
		lcCol := lc.CM_GeneralCargoAllocController;
		
		// colour the cargo
		self.doSatViewBlockStackColourCargo(lcCol, theFrame, lastColX, y1, colX, y2);
		// draw a group boundary
		if lcCol.myGroup &lt;&gt; lastGroup then
			if lastGroup &lt;&gt; null then
				theFrame.drawSolidRectangle(lastColX, y1, lastColX+5, y2, self.satelliteViewGridColour);
			endif;
		endif;
		// draw a column boundary
		theFrame.drawLine(colX, y1, colX, y2, self.satelliteViewGridColour);
		// draw the column id
		colX2 := ((colX-lastColX)/2)-3;
		if not self.drawFromNote then
			theFrame.drawFontSize := self.getFontSizeRowColHeading;
			theFrame.drawTextAt(lc.ident, lastColX+colX2, y2+1, self.satelliteViewFontColour);
			self.gridObjectsPutAtKey(lastColX.Integer, y1.Integer, colX.Integer, y2.Integer, lcCol);
		endif;
		
		pos := pos + 1;
		lastColX := colX;
		colX := colX + colWidth;
		lastGroup := lcCol.myGroup;
	endwhile;
	
	// TFS 49783 draw the group labels once everything else is done, so they draw on top of everything
	if self.scaleFactor &gt;= 0.5 then
		delete iter;
		iter := lcSet.createIterator;
		if flipH then
			iter.startAtIndex(lcSet.size);
		else
			iter.startAtIndex(1);
		endif;
		pos := 1;
		while pos &lt;= nbrCols do
			if flipH then 
				iter.back(lc);
			else
				iter.next(lc);
			endif;
			lcCol := lc.CM_GeneralCargoAllocController;
			rangeLabel := lcCol.myGroup.rangeLabel;
			if not self.showCapacity // TFS 49959
			and rangeLabel &lt;&gt; null 
			and lcCol.myGroup.firstColumn = lcCol.id then
				if flipH then
					self.getPointsForGridObject(lcCol.myGroup.allLocations.last, rangeX1, rangeY1, rangeX2, rangeY2);
				else
					self.getPointsForGridObject(lcCol, rangeX1, rangeY1, rangeX2, rangeY2);
				endif;
				theFrame.drawFontSize := self.getFontSizeRowColHeading;
				textExtent := theFrame.getTextExtent(rangeLabel);
				// TFS 49783 mess about with the text extent for the smallest and largest fonts - otherwise the 
				// background is too big at the smallest font and too small at the largest font
				if theFrame.drawFontSize = 10 then
					textExtent := (textExtent * 1.25).Integer;
				elseif theFrame.drawFontSize = 6 then
					textExtent := (textExtent * 0.8).Integer;
				endif;
				theFrame.drawTextAlign := theFrame.DrawTextAlign_Left;
				// If the area graphic is rotated 90 or 270 degrees, swap the x and y coordinates
				if (_taViewPos.rotation = 90 or _taViewPos.rotation = 270) then
					tmpX1 := rangeX1;
					tmpX2 := rangeX2;
					tmpY1 := rangeY1;
					tmpY2 := rangeY2;
					rangeX1 := tmpY1 + theFrame.YRD_ContainerDrawingFrame.swapYadjustment;
					rangeX2 := tmpY2 + theFrame.YRD_ContainerDrawingFrame.swapYadjustment;
					rangeY1 := tmpX1 + theFrame.YRD_ContainerDrawingFrame.swapXadjustment;
					rangeY2 := tmpX2 + theFrame.YRD_ContainerDrawingFrame.swapXadjustment;
				endif;
				theFrame.YRD_ContainerDrawingFrame.drawSolidRectangleNoFlip(rangeX1+10, rangeY1+10, rangeX1+textExtent+5, rangeY1+(theFrame.drawFontSize*3), White);
				theFrame.drawTextAt(rangeLabel, rangeX1+10, rangeY1+10, self.satelliteViewFontColour);
			endif;
			pos := pos + 1;
		endwhile;
	endif;
	
epilog
	delete lcSet;
end;</source>
        <access>protected</access>
        <Parameter name="_taViewPos" type="CM_TerminalAreaViewPosition"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_endX" type="Integer" usage="output"/>
        <Parameter name="_endY" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="drawGCAllocRowAreaFromNote" id="2c878126-91db-4e43-87b4-8b32c5d78701">
        <updating/>
        <source>drawGCAllocRowAreaFromNote(_ta : CM_TerminalArea) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	taViewPos : CM_TerminalAreaViewPosition;
	xPos1 : Real;
	yPos1 : Real;
	xPos2 : Real;
	yPos2 : Real;
	startX : Integer;
	startY : Integer;
	endX : Integer;
	endY : Integer;
	existingTa : CM_TerminalAreaMaster;

begin
	if _ta = null then
		return;
	endif;
	
	taViewPos := self.myTerminalAreaView.findViewPositionForTA(_ta);
	
	if taViewPos = null then
		return;
	endif;
	
	self.getTAOriginForTAViewPos(taViewPos, xPos1, yPos1);

	startX := xPos1.Integer;
	startY := yPos1.Integer;

	xPos2 := xPos1;

	yPos2 := yPos1 + self.rowHeight;
	xPos1 := xPos2;
	
	self.setOrientation(taViewPos);
	self.drawGCAllocRowArea(taViewPos, startX, startY, endX, endY);

	existingTa := self.myTerminalArea;
	self.myTerminalArea := _ta;
	
	self.drawAreaTitle(startX, startY, endX, endY, taViewPos.displayTopColumnLabels);
	self.myTerminalArea := existingTa;
	
epilog
	self.setOrientation(null);
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="drawGrid" id="d3efe434-5a12-45e2-98e7-581405a0e99f">
        <source>drawGrid(_x, _y, _leftColumn, _rightColumn, _topRow, _bottomRow : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2009	cnwjk3	Initial creation

*/

vars
	column, row : Integer;
	x, y : Real;
	cellSize,
	left, right, top, bottom : Real;
begin
	self.myDrawingFrame.drawStyle := Frame.DrawStyle_Solid;
	self.myDrawingFrame.drawWidth := GridLineWidth;
	
	//epr par 36616 13/10/15
	left := _x;	
	cellSize:=self.getGCAreaCellSize;

	right := left  + (cellSize * _rightColumn) ;
	y:=_y + GridBorderWidth;
	foreach row in _topRow  to _bottomRow do
		y:= y + cellSize;
		self.myDrawingFrame.drawLine(left, y, right, y, self.satelliteViewGridColour);
	endforeach;

	top := _y;
	bottom:=top +  + (cellSize * _bottomRow) ;
	x:=_x + GridBorderWidth;
	foreach column in _leftColumn to _rightColumn do
		x:= x + cellSize;
		self.myDrawingFrame.drawLine(x, top, x, bottom, self.satelliteViewGridColour);
	endforeach;
end;
</source>
        <access>protected</access>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_leftColumn" type="Integer"/>
        <Parameter name="_rightColumn" type="Integer"/>
        <Parameter name="_topRow" type="Integer"/>
        <Parameter name="_bottomRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawGridBorder" id="280e3497-d613-4cac-9ca8-aa9e966484f3">
        <source>drawGridBorder( _x, _y, _columns, _rows : Integer; _endX, _endY : Integer output ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2009	cnwjk3	SFW1030

*/

vars
	x2, y2	: Real;
begin
	self.myDrawingFrame.drawStyle := Frame.DrawStyle_Solid;
	self.myDrawingFrame.drawWidth := GridBorderWidth;
	//epr par 36616 13/10/15
	x2:= (_x + GridBorderWidth) + (self.getGCAreaCellSize  * _columns) ;
	
	y2:= (_y + GridBorderWidth) + (self.getGCAreaCellSize * _rows);
	self.myDrawingFrame.drawRectangle(_x , _y , x2, y2, self.satelliteViewGridColour);   
	_endX := x2.Integer;
	_endY := y2.Integer;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_endX" type="Integer" usage="output"/>
        <Parameter name="_endY" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="drawGridLocation" id="ea6df496-03aa-49af-af8b-314f8af4fd52">
        <source>drawGridLocation(_x, _y : Integer; _lc : CM_IrregularBlockController) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2009	cnwjk3	SFW1030
11 Nov 2010 cnwer1 	PAR 26189 - removed the allGridObjects.includes - expensive linear search and not required
*/

vars
	topLeft, bottomRight 	: Point;
	x1, y1, x2, y2, textWidth 			: Real;
	aDT : CM_DrawingAttribute;
	origFont : String;
	trackedItem : CM_TrackedItem;
	clr : Integer;
	
	theFrame: CMUI_GridAreaDrawingFrame;
begin

	topLeft := gridCellToPixel(_lc.region.first);
	bottomRight := gridCellToPixel(_lc.region.last.add(1, 1));

	x1 := _x + topLeft.x + (GridLineWidth/2);
	y1 := _y + topLeft.y + (GridLineWidth/2);
	x2 := _x + bottomRight.x-GridLineWidth;
	y2 := _y + bottomRight.y-GridLineWidth;
	
	//28 Mar 2017	NDL	TFS 3423
	theFrame := self.myDrawingFrame;
	self.doSatViewBlockStackColourCargo( _lc, theFrame, x1, y1, x2, y2 );
	

/*	// ####// PAR 32836 #####
		clr := self.satelliteViewCellColour;
		_lc.getTIs(self.allTrackedItems,REAL_MODE, true);
		if self.allTrackedItems.size &gt; 0 then
			foreach trackedItem in self.allTrackedItems do
	
				clr := self.getFillColourForTI(trackedItem);
				break;
			endforeach;
		endif;
		
		if clr = -1 then
			clr := self.satelliteViewCellColour;
		endif;
	
	// #####// PAR 32836 #########
	
	
	
	// PAR 32836	self.myDrawingFrame.drawSolidRectangle(x1, y1,x2, y2, self.satelliteViewCellColour);
		self.myDrawingFrame.drawSolidRectangle(x1, y1,x2, y2, clr);
	
	*/
	
	if not self.showCapacity then // TFS 49959
	
		// Draw the LC's ID
// TFS 51393		self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Center;
		self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Left; // TFS 51393
// TFS 51393		self.myDrawingFrame.getTextDrawFontSizeForWidth(_lc.ident,(((x2-x1) - 2)).Integer);
		self.myDrawingFrame.getTextDrawFontSizeForWidthHgt(_lc.ident,(((x2-x1) - 2)).Integer,(((y2-y1) - 2)).Integer); // TFS 51393 fit the location ID within the rectangle
	
	
		self.myDrawingFrame.drawFontBold := true;
		textWidth := self.myDrawingFrame.drawTextWidth(_lc.ident); // JLGAB1 TFS 49959
	// JLGAB1	self.myDrawingFrame.drawTextAt(_lc.ident, x1+((x2-x1)/2), y1+((y2-y1)/2)-self.getFontSizeLabel, self.satelliteViewFontColour);
// TFS 51393		self.myDrawingFrame.drawTextAt(_lc.ident, x2 - textWidth/ 2, y2 -30, self.satelliteViewFontColour); // JLGAB1 TFS 49959
		self.myDrawingFrame.drawTextAt(_lc.ident, x1 + 2, y1 + 2, self.satelliteViewFontColour); // TFS 51393

	endif;
	//27 Aug 2013	NDL	Par 32308

	if _lc.isRack and self.scaleFactor &gt;= 1 then
		self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Left;
		origFont := self.myDrawingFrame.drawFontName;
		aDT := app.myRoot.allDrawingAttributes[PicTAShelf];
		self.myDrawingFrame.drawFontSize := 6;
		self.myDrawingFrame.drawFontName := aDT.fontName;
		self.myDrawingFrame.drawTextAt(aDT.fontCharacter.Character, x1, y2 - 16, aDT.colour); 
		self.myDrawingFrame.drawFontName := origFont;
		self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	endif;
	
	// Record the selection bounds for each LC
	
	if not self.allSelectionBoundsObjects.includes(_lc) then// PAR 32836
		self.selectionBoundsObjectsPutAtKey(x1.Integer, y1.Integer, x2.Integer, y2.Integer, _lc);
	endif;	
		// Key into the main collection which records the positions of all LCs
	if not self.allGridObjects.includes(_lc) then// PAR 32836
		self.gridObjectsPutAtKey(x1.Integer,y1.Integer,x2.Integer,y2.Integer, _lc);
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_lc" type="CM_IrregularBlockController"/>
    </JadeMethod>
    <JadeMethod name="drawGridLocations" id="376ab596-91fa-49b0-8fd5-38ea72109490">
        <source>drawGridLocations( _x, _y : Integer; _ta : CM_IrregularBlockArea ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2009	cnwjk3	SFW1030

*/

vars

	location: CM_LocationsController;
begin
	foreach location in _ta.allLocationsControllers do
		self.drawGridLocation(_x, _y, location.CM_IrregularBlockController);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_ta" type="CM_IrregularBlockArea"/>
    </JadeMethod>
    <JadeMethod name="drawGriddedAreaTitle" id="0a8a1faf-cd29-4d36-962e-3002bf5b7ddf">
        <source>drawGriddedAreaTitle(_startX, _startY , _endX, _endY : Real;
				_displayTopColumnLabels : Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2011	cnwndl1	Initial creation	Par 28758

*/

vars

	yPos1 : Real;
	taID : String;
	taViewPos : CM_TerminalAreaViewPosition;
	leftAlignAdjustment : Real;
	vCentre : Real;
	hCentre : Real;
	topPoint : Real;
	bottomPoint : Real;
	leftPoint : Real;
	rightPoint : Real;
	
begin

	taViewPos:=self.myTerminalAreaView.findViewPositionForTA(self.myTerminalArea.CM_TerminalArea);
	self.myDrawingFrame.drawFillColor := self.myTerminalArea.myTerminal.getConfig(SatelliteViewBackColour).Integer;
	self.myDrawingFrame.drawFontSize := self.labelFontSize;
	self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	self.myDrawingFrame.drawFontBold := true;
	
	
	if not self.myTerminalArea.isKindOf(CM_StraddleStack) then
		if not self.myTerminalArea.isKindOf(CM_RTGArea) then
			if not self.myTerminalArea.isKindOf(CM_ForkLiftStack) then	
				return;		
			endif;
		endif;
	endif;
	
	taID := self.myTerminalArea.id;	
		
	if self.myDrawingFrame.swapXY then
		
		topPoint := _startX;
		if _displayTopColumnLabels then
			topPoint := topPoint - self.TitleHeight;
		endif;
		bottomPoint := topPoint - self.myDrawingFrame.getTextHeight(taID);
		vCentre := topPoint + ((bottomPoint - topPoint) / 2);// vertical centre point of title area
	

		leftPoint := _startY;
		rightPoint := leftPoint + ((_endY - _startY) - self.TitleHeight);
		hCentre := leftPoint + ( (rightPoint - leftPoint ) / 2 );// horizontal centre point of title area
		
		//self.myDrawingFrame.drawFilledRectangle( topPoint, leftPoint, bottomPoint, rightPoint , Green); // testing

		leftAlignAdjustment := self.myDrawingFrame.drawTextHeight(taID) * 0.5;
		yPos1 := hCentre - leftAlignAdjustment;

	else
	
		yPos1 := _startY - self.TitleHeight;
		if _displayTopColumnLabels then
			yPos1 := yPos1 - self.TitleHeight;
		endif;
		vCentre := _startX + ((_endX - _startX) / 2);
	
	endif;
	
	self.myDrawingFrame.drawTextAt(taID, vCentre + 1, yPos1, self.satelliteViewFontColour);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_startX" type="Real"/>
        <Parameter name="_startY" type="Real"/>
        <Parameter name="_endX" type="Real"/>
        <Parameter name="_endY" type="Real"/>
        <Parameter name="_displayTopColumnLabels" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawHeightRestriction" id="3d220f2c-3e9d-4d99-9ddb-fe21db17d702">
        <source>drawHeightRestriction(pColor: Integer; pHeight: Integer; pX1: Real; pY1: Real; pX2: Real; pY2: Real) protected;
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24/3/15 cnwer1	PAR 33954 changes for new preferences as to how the height restriction is show
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	tmpX, tmpY  : Real;
	maxStackHeight,
	tmpHeight : Integer;
	heightString : String;

begin
	theFrame := self.myDrawingFrame;
	tmpHeight := pHeight - 2;
	if self.heightRestrictionOption = self.UNAVAILABLE_FROM then
		
	elseif self.heightRestrictionOption = self.UNAVAILABLE_NUMBER_UNAVAIL  then
		tmpHeight:=(tmpHeight-1);
		maxStackHeight:=self.myLocationsController.CM_GridController.getMaxHeight;
		tmpHeight:=(maxStackHeight-tmpHeight);
	elseif self.heightRestrictionOption = self.UNAVAILABLE_NUMBER_AVAIL then
		tmpHeight:=(tmpHeight-1);
	endif;
	heightString:= tmpHeight.String;
	if tmpHeight = 0 then
		return;
	endif;
	
	if self.scaleFactor &lt; 1 then
		theFrame.drawFontSize:=self.getFontSizeRowColHeading - 1;
		theFrame.drawFontBold:=false;
	else
		theFrame.drawFontBold:=true;
	endif;
	theFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	
	// ### DRAW TEXT
	
	tmpX := (pX1 + ((pX2 - pX1) / 2)) - 1;
	tmpY := (pY1 + ((pY2 - pY1) / 2)) - 1;
	tmpY := pY1 + (self.scaleFactor + (self.scaleFactor/2)).Integer;
	
	theFrame.drawTextAt(heightString, tmpX, tmpY,White);

	//tmpHeight := pHeight - 2;
	tmpX := (pX1 + ((pX2 - pX1) / 2));
	tmpY := (pY1 + ((pY2 - pY1) / 2));
	tmpY := pY1 + (self.scaleFactor + (self.scaleFactor/2)).Integer;

	theFrame.drawTextAt(heightString, tmpX, tmpY,Red);


epilog

	theFrame.drawWidth := 1;
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	
end;</source>
        <access>protected</access>
        <Parameter name="pColor" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pX1" type="Real"/>
        <Parameter name="pY1" type="Real"/>
        <Parameter name="pX2" type="Real"/>
        <Parameter name="pY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawIrregularBlockArea" id="d577d810-7cf1-41a6-96e4-f53b22cc301c">
        <updating/>
        <source>drawIrregularBlockArea( _ta : CM_IrregularBlockArea; _x, _y : Integer; _endX, _endY : Integer output) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 Feb 2009	cnwjk3	SFW 1030
11 Jll 2022	navdap1	TFS 53765 EUP Warehouse Yard Allocations
*/

vars

begin

	self.drawGridBorder(_x, _y, _ta.columns, _ta.rows, _endX, _endY);
	self.drawGrid(_x, _y, 1, _ta.columns, 1, _ta.rows);
	self.drawGridLocations(_x, _y, _ta);
	
	if self.myTerminal.getAutoPlanAllowFullGCArea then					// TFS 53765
		self.gridObjectsPutAtKey(_x, _y, _endX, _endY, _ta);			// TFS 53765
		self.selectionBoundsObjectsPutAtKey(_x, _y, _endX, _endY, _ta);	// TFS 53765
	endif;																// TFS 53765
	
	//epr par 36616 13/10/15
	self.drawBlockAreaTitle(_x, _y, _endX, _endY);
	
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_IrregularBlockArea"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_endX" type="Integer" usage="output"/>
        <Parameter name="_endY" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="drawLC" id="093883c4-8415-4804-8aa2-15a0e9533237">
        <updating/>
        <source>drawLC(_lc : CM_GridController) updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//      AKB    19MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
//		AKB		11FEB2009		PAR 18682 - Previously we have stored the LC in the XYs dict only. 
//										The LC's XYs would not be the 20 foot grid, but would be based on the length of the TI on it.
//										From today, we store the LC and the first TI as well. The LC is always based on the strict 20 
//										foot grid only and the first TI is based on its length
/*

Date		Who		Reason
13 Mar 2009	cnwkpd1	PAR #19154 - User self.myTerminal instead of app.getMyTerminal to prevent
					1090 exceptions when processing notes "in the background"
06 Oct 2010	cnwdap1	PAR #25971 Tranship drawing icon also depends on Tranship Imex Status, not just isTranship flag
10 Dec 2010 cnwer1  PAR 26189 ccms 1200 - changes to improve performance

*/


constants
	FONTSIZE = 6;
vars
	  startY,
	 endY, startX, endX	, offset	: Real;
	 idx,
	tmpNumTIs: Integer;
	theTI: CM_TrackedItem; // theDummyTI
	theFillColour : Integer;
	tmpTIs	: CM_TIArray;
	theFrame	: YRD_ContainerDrawingFrame;
	tmpLabourRestriction	: CM_LabourRestriction;
	tmpUsage,
	tmpAvail : Integer;
	tmpBlockStack	: CM_BlockStack;
	isUnavailable,
	hasHeightRestriction	: Boolean;
begin
	
	self.myLocationsController := _lc;
	idx := 1;

	startX := self.x1;
	endX := self.x2; // PAR 19283
	startY 	:= self.y1 ; 
	endY	:= self.y2;
	
	if self.drawFromNote then
		if _lc.isOverhang() then // PAR 19283
			if self.flipHorizontal then // PAR 19283
				endX := self.x1; // PAR 19283
			else
				endX := self.x2; // PAR 19283
			endif;
		endif;
	endif;	
	
	theFrame := self.myDrawingFrame;
	
	// #### SET UP  SOME LOCAL VARIABLES
	// ####
	// ####
	// ####
	if  self.getHeightOfStack = 0 and _lc.isKindOf(CM_GapController) then	// PAR 21532 CCMS SFW 1025
		if _lc.isKindOf(CM_OverhangController) then // PAR 18682		
			if self.flipHorizontal then//	PAR 19283
				offset := -1;//	PAR 19283
			else
				offset := 1;//	PAR 19283
			endif;
			self.drawBlankSpaceOverhang(theFrame, self.myDrawingFrame.backColor, idx, startX + offset, self.y1, endX, self.y2); 
		endif;
		// Nothing to draw
		return;
	endif;
	
	tmpLabourRestriction 	:= _lc.allLabourRestrictions.first;
	tmpBlockStack			:= _lc.mySubBlockStack;

	
	_lc.getAvailUsageHeight(tmpUsage,tmpAvail, hasHeightRestriction);
	isUnavailable := (tmpUsage = UNAVAILABLE_USE or 
						 tmpAvail = PAD_USER_UNAVAILABLE or 
		   				 tmpAvail = PAD_UNAVAILABLE);

	theFillColour := self.satelliteViewCellColour;
	
	tmpTIs := _lc.allTrackedItems;

	if tmpUsage = REEFERGANTRY_USE then
		self.drawReeferGantry(theFillColour, idx, startX, self.y1, self.x2, self.y2);
	// #### BUILDINGS
	// ####
	elseif tmpUsage = BUILDING_USE then // BUILDING
		if self.myTerminalArea.type = TA_TYPE_RTG then
			self.drawTransformer(theFillColour, idx,startX, startY, endX, endY - 1);
		else
			self.drawBuildingTop(theFillColour, idx, startX, startY, endX, endY - 1); // PAR 19519
		endif;
	// #### LIGHTS
	// ####
	elseif tmpUsage = LIGHT_TOWER_USE then // LIGHT
		self.drawLight();
	// #### BLOCKSTACKS
	// ####
	elseif tmpBlockStack &lt;&gt; null then
		self.drawSubBlockStack(tmpBlockStack);
	else
	
		theTI := null;
		tmpNumTIs := tmpTIs.size;
		// #### HAVE TIS TO DRAW CHECK PRIMARY LC
		// ####
		// ####
		// ####
		//last TI is the top tracked item
		if tmpNumTIs &gt; 0 then	
			theTI := tmpTIs[1];
			// PAR 15340
			if theTI.myPrimaryActualLocation &lt;&gt; _lc then
				// the TI will be drawn when its primary location is drawn
				return;
			endif;
		endif;
		// ##########################		
		// ##########################		
		// ##########################		
		// ##########################		

	
		theFrame.drawWidth	:= 1;
		if theTI &lt;&gt; null then
			self.drawTITopDown(_lc,theTI,tmpTIs);
		else
		// #######################
		// #######################
		// #######################
		// #######################
		// ### DRAW BLANKS/ RESTRICTIONS/ GAPS
			
			if isUnavailable then
				theFillColour := theFrame.backColor;
			else
				if _lc.hasPower() then 
					theFillColour := self.POWER_FILL_COLOUR;
				endif;
			endif;
			if self.flipHorizontal then
				endX:=self.x1;
			else
				endX:=self.x2;
			endif;
			self.adjustStartEndXForOffsets(null,startX,endX);
			
			self.drawBlankSpace(theFrame, theFillColour, idx, startX, startY, endX, endY , false);
	
			if self.yardGridAreaTranshipMark &lt;&gt; null then// CCMS 1574
				self.hasTranshipYardAllocation := _lc.includesYardAllocationCriteria(CM_YATypeIsTransShip, true, false); // CCMS 1574
			endif;	
			if self.hasTranshipYardAllocation then
				self.drawTranshipMark(theFrame, startX, startY,1);
			endif;
				
			if not self.isForSatelliteView then
				self.doDrawFMLetter(self.displayMode,1, theFillColour,startX, self.y1, self.y2 - 1); // Added '-1' so that FM and LC can both be in AllGridObj.
			endif;
					
			if tmpLabourRestriction &lt;&gt; null and (not isUnavailable) then
				self.drawLabour(theFrame, tmpLabourRestriction, startX, startY, endX, endY);
			endif;
			
			if 	tmpAvail &gt;= PAD_HEIGHT_1_UNAVAIL then
				self.drawHeightRestriction(Red,tmpAvail,startX, startY, endX, endY); // PAR 19519
			endif;
		endif;
	endif;

epilog

	if  tmpBlockStack = null and not self.drawFromNote then
		self.gridObjectsPutAtKey(self.x1.Integer,self.y1.Integer,self.x2.Integer,self.y2.Integer, self.myLocationsController);	
	endif;
	
	theFrame.drawFontSize := self.getFontSizeRowColHeading();
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="drawLCSelected" id="52381de9-9ef8-45f8-9cdc-495f0427ea03">
        <source>drawLCSelected(_x1: Real; _y1: Real; _x2: Real; _y2: Real) protected;
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	thick : Integer;
begin

	theFrame := self.myDrawingFrame;
	if self.scaleFactor &lt; 2 then
		thick := 2;
	else
		thick := (self.scaleFactor + 1).Integer;
	endif;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawWidth := thick + 1;

	theFrame.drawRectangle(_x1 + thick - 1 , _y1 + thick - 1, _x2 - thick, _y2 - thick,  White);

epilog
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	
end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawLCTopDown" id="a7eaa8f0-2c57-491a-9fa7-582674a716ab">
        <source>drawLCTopDown(_color: Integer;_x1: Real; _y1: Real; _x2: Real; _y2: Real) protected;
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_GridAreaDrawingFrame;
begin

	theFrame := self.myDrawingFrame;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawWidth := 1;

	if theFrame.drawFillColor &lt;&gt; _color then
		theFrame.drawFillColor := _color;
	endif;
	
	if self.isForSatelliteView then
		theFrame.drawFilledRectangle(_x1, _y1, _x2, _y2,  LightGray);	
		
	else
		theFrame.drawSolidRectangle(_x1, _y1, _x2, _y2,  Black);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_color" type="Integer"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawMinature" id="e1172c47-09ee-4b4a-8400-d2d79cbcc8a9">
        <source>drawMinature(_frame: Frame input; _tmpDkbPos	: CMUI_JadeDockBar input);
// ---------------------------------------------------------------------------
// Created:     08 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
begin

	if self.myTerminalArea.isTAGroup then
		global.beep;
		return;
	endif;
	if self.myTerminalArea.CM_TerminalArea.isRTGArea() then
		self.drawMinitureRTGs(_frame,_tmpDkbPos);
	else
		self.drawMinitureStraddle(_frame,_tmpDkbPos);
	endif;

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_tmpDkbPos" type="CMUI_JadeDockBar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawMinitureRTGs" id="afa89dcb-b9e0-415e-8968-dc5fc5ad2601">
        <source>drawMinitureRTGs(_frame: Frame input; _tmpDkbPos	: CMUI_JadeDockBar input);
// ---------------------------------------------------------------------------
// Created:     08 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	OFFSET = 4;
	ANGLE = 6;
vars
	theX1, theY1,
	theX2, theY2		: Real;
	colNum,
	rowNum	, idx			: Integer;
	grdRow : CM_GridRow;
	grdCol : CM_GridColumn;
	anLC : CM_LocationsController;
	tmpRLabel, tmpCLabel : String;
	drawnCol : Boolean;
begin

	_frame.drawFillColor := 16764573;
	_frame.drawFontSize := 8;
	_frame.drawFontName := Font_MicrosoftSansSerif;
	_frame.drawTextAlign := Frame.DrawTextAlign_Center;


	theX1 := OFFSET;
	theY1 := OFFSET;
	
	foreach grdRow in self.myTerminalArea.CM_GridArea.allGridRows do

		if  grdRow.hasGap then
			continue;
		endif;
		
		rowNum := rowNum + 1;
		if tmpRLabel = null then
			tmpRLabel := grdRow.CM_RTGRow.getLabel();
			/*if not grdRow.isGap() then
				if grdRow.CM_RTGRow.myRTGLane &lt;&gt; null then
					tmpRLabel := grdRow.CM_RTGRow.myRTGLane.getID();
				else
					tmpRLabel := grdRow.CM_RTGRow.getLabel();
				endif;
			endif;*/
		endif;
		
		if rowNum mod 7 = 0 then
			theY2 := theY1 + self.POSFRM_HEIGHT;
			colNum := 0;
			foreach anLC in grdRow.allControllersByColumn do
				colNum := colNum + 1;
				drawnCol := false;
				grdCol := anLC.CM_GridController.myGridColumn;
				if tmpCLabel = null then
					if not grdCol.hasGap then
						tmpCLabel := grdCol.label;
					endif;
				endif;			
				if colNum mod 5 = 0 then
					drawnCol := true;
					theX2 := theX1 + self.POSFRM_WIDTH;
					
					_frame.drawFilledRectangle(theX1,theY1,theX2,theY2,Black);
					_frame.drawTextAt(tmpRLabel &amp; tmpCLabel,(((theX2 - theX1) / 2) + theX1),theY1 + 1,Black);
					tmpCLabel := null;
					theX1 := theX2 + OFFSET;
				endif;
			endforeach;
			if not drawnCol then
				theX2 := theX1 + self.POSFRM_WIDTH;
				
				_frame.drawFilledRectangle(theX1,theY1,theX2,theY2,Black);
				_frame.drawTextAt(tmpRLabel &amp; tmpCLabel,(((theX2 - theX1) / 2) + theX1),theY1 + 1,Black);
				tmpCLabel := null;
				theX1 := theX2 + OFFSET;
				
			endif;
			tmpRLabel := null;
			theY1 := theY2 + OFFSET;
			theX1 := OFFSET;
		endif;
	endforeach;

	_tmpDkbPos.width := theX2 + 20; 
	_tmpDkbPos.height := theY2 + OFFSET + 50;
	
epilog

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_tmpDkbPos" type="CMUI_JadeDockBar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawMinitureStraddle" id="b55b92cc-2e27-4f06-a087-1cabe861d294">
        <source>drawMinitureStraddle(_frame: Frame input; _tmpDkbPos	: CMUI_JadeDockBar input);
// ---------------------------------------------------------------------------
// Created:     08 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	OFFSET = 4;
	ANGLE = 6;
vars
	theX1, theY1,
	theX2, theY2		: Real;
	colNum,
	rowNum	, idx			: Integer;
	grdRow : CM_GridRow;
	grdCol : CM_GridColumn;
	anLC : CM_LocationsController;
	tmpRLabel, tmpCLabel : String;
	drawnCol : Boolean;
begin

	_frame.drawFillColor := 16764573;
	_frame.drawFontSize := 8;
	_frame.drawFontName := Font_MicrosoftSansSerif;
	_frame.drawTextAlign := Frame.DrawTextAlign_Center;


	theX1 := OFFSET;
	theY1 := OFFSET;
	
	foreach grdRow in self.myTerminalArea.CM_GridArea.allGridRows do

		if  grdRow.hasGap then
			continue;
		endif;
			
		rowNum := rowNum + 1;
		if tmpRLabel = null then
			if not grdRow.hasGap then
				tmpRLabel := grdRow.getLabel();
			endif;
		endif;
		
		if rowNum mod 7 = 0 then
			theY2 := theY1 + self.POSFRM_HEIGHT;
			colNum := 0;
			foreach anLC in grdRow.allControllersByColumn do
				colNum := colNum + 1;
				drawnCol := false;
				grdCol := anLC.CM_GridController.myGridColumn;
				if tmpCLabel = null then
					if not grdCol.hasGap then
						tmpCLabel := grdCol.label;
					endif;
				endif;			
				if colNum mod 5 = 0 then
					drawnCol := true;
					theX2 := theX1 + self.POSFRM_WIDTH;
					
					_frame.drawFilledRectangle(theX1,theY1,theX2,theY2,Black);
					_frame.drawTextAt(tmpRLabel &amp; tmpCLabel,(((theX2 - theX1) / 2) + theX1),theY1 + 1,Black);
					tmpCLabel := null;
					theX1 := theX2 + OFFSET;
				endif;
			endforeach;
			if not drawnCol then
				theX2 := theX1 + self.POSFRM_WIDTH;
				
				_frame.drawFilledRectangle(theX1,theY1,theX2,theY2,Black);
				_frame.drawTextAt(tmpRLabel &amp; tmpCLabel,(((theX2 - theX1) / 2) + theX1),theY1 + 1,Black);
				tmpCLabel := null;
				theX1 := theX2 + OFFSET;
				
			endif;
			tmpRLabel := null;
			theY1 := theY2 + OFFSET;
			theX1 := OFFSET;
		endif;
	endforeach;

	_tmpDkbPos.width := theX2 + 20; 
	_tmpDkbPos.height := theY2 + OFFSET;
	
epilog

end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_tmpDkbPos" type="CMUI_JadeDockBar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawObject" id="a750ebcc-7943-47f9-ae55-1ed0cc0cf242">
        <updating/>
        <source>drawObject(_frame : CMUI_GridAreaDrawingFrame input; _obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		FROM NOTIFICATION
//
// ---------------------------------------------------------------------------
vars
	taViewPosition : CM_TerminalAreaViewPosition;
begin
	if _obj = null then
		return;
	endif;


	//could just get the co-ordinates and call draw LC - used to call the frame which would call self.drawLC
	if _obj.isKindOf(CM_GridController) then
		self.getPointsForGridObject(_obj,x1,y1,x2,y2);
		self.setForRedraw(_obj,x1.Integer,y1.Integer,x2.Integer,y2.Integer);
		self.setMyCurrentObject(_obj);
		taViewPosition:=self.myTerminalAreaView.findViewPositionForTA(_obj.CM_GridController.myTerminalArea);
		self.setOrientation(taViewPosition);
		self.drawLC(_obj.CM_GridController);
		return;
	else	
		self.myDrawingFrame.drawObject(_obj, self);
	endif;

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="drawOverLappingRectangle" id="8498d1d9-b781-44ec-bd63-1b8c95771b13">
        <source>drawOverLappingRectangle(_theSamePrev: Boolean; _theSameAbove: Boolean; _backColour: Integer; _foreColour: Integer; _frame: CMUI_GridAreaDrawingFrame input);

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
04 December 2008	consw1	Initial creation

*/

vars
	theFrame : CMUI_GridAreaDrawingFrame;
	anOffset1, anOffset2,anOffset3,anOffset4 : Real;
	aSlotHeight, aWindowHeight, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;
	increment1, increment2, increment3 : Real;
begin
	theFrame := _frame;
	
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

	increment1 := self.scaleFactor * 0.5;
	increment2 := self.scaleFactor * 1;
	increment3 := self.scaleFactor * 2;
	
	tmpx1 := self.x1.Integer;
	tmpy1 := self.y1.Integer;
	anOffset4 := increment1;
	tmpx2 := self.x2.Integer;
	tmpy2 := self.y2.Integer;
	if _theSameAbove then
		anOffset3 := increment3;
	else
		anOffset3 := 0;
	endif;
	if _theSamePrev then // the previous point is also the same sub block
		anOffset1:= increment1;
		anOffset2 := increment2;
	else
		anOffset1:= 0;
		anOffset2 := increment1;
	endif;

	theFrame.drawFillColor := _backColour;
	theFrame.drawFilledRectangle(tmpx1 - anOffset1 , tmpy1 - increment1 - anOffset3 , tmpx2 , tmpy2,_backColour);
	theFrame.drawFillColor := _foreColour;
	theFrame.drawFilledRectangle(tmpx1 - anOffset2, tmpy1 - increment2 - anOffset3, tmpx2 - anOffset4, tmpy2 - increment1,_foreColour);

end;</source>
        <Parameter name="_theSamePrev" type="Boolean"/>
        <Parameter name="_theSameAbove" type="Boolean"/>
        <Parameter name="_backColour" type="Integer"/>
        <Parameter name="_foreColour" type="Integer"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawOverSizedMark" id="0de1718b-b166-4bdd-bcc4-2ea67f115493">
        <source>drawOverSizedMark(_frame: CMUI_GridAreaDrawingFrame; _theTI : CM_TrackedItem; _color: Integer;  _x1: Real; _y1: Real; _x2: Real; _y2: Real) protected;
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//				25 May 2010 NDL	Par 24044 - Added '_frame' to param when migrating method to superclass.
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	lineX, thick : Integer;
begin
	theFrame := self.myDrawingFrame;
	thick := 1;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawWidth := 1;

	if self.flipHorizontal then // PAR 19283
		lineX := (_x1 - (self.scaleFactor *3 )).Integer; // PAR 19283
	else
		lineX := (_x2 - (self.scaleFactor *3 )).Integer;
	endif;
	theFrame.drawLine(lineX, _y1, lineX, _y2,  _color.getInverseColour());
	
	if _theTI.isAttributeTrue(TI_Attrib_IsThirty) then
		return;
	endif;
	
	lineX := (lineX - (self.scaleFactor *3)).Integer;
	theFrame.drawLine(lineX, _y1, lineX, _y2,  _color.getInverseColour());
	
	if _theTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
		return;
	endif;

	lineX := (lineX - (self.scaleFactor *3)).Integer;
	theFrame.drawLine(lineX, _y1, lineX, _y2,  _color.getInverseColour());
	
	
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_color" type="Integer"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawQueuedInOutStats" id="85a3fbdd-0337-460c-a805-db49c8b0d701">
        <source>drawQueuedInOutStats(_ta : CM_RTGArea; _taViewPos : CM_TerminalAreaViewPosition );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwer1	Initial creation

*/

vars
	xy1,
	xy2 : Point;
	startX,
	startY : Integer;
	newFrame : CMUI_Frame;
	satViewForm : YRD_SatelliteViewForm;
	gridColumn : CM_GridColumn;
	theWidth,
	theHeight : Real;
	
begin

	if _ta = null then
		return;
	endif;
	//epr par 21674 24/11/09
	if _taViewPos = null then
		return;
	endif;

	if self.myGridOverviewForm = null or not self.myGridOverviewForm.isKindOf(YRD_SatelliteViewForm)  then
		return;
	endif;
	
	
	satViewForm:=self.myGridOverviewForm.YRD_SatelliteViewForm;
	self.allSelectionBoundsObjects.findObjectInDictGetXY(_ta, xy1, xy2);
	startX:=xy1.x ;//+  self.myDrawingFrame.swapXadjustment ;
	startY:=xy2.y;// + self.myDrawingFrame.swapYadjustment;
	
	
	

	//either no rotation or rotatioed 180 degrees
	if _taViewPos.displayBottomColumnLabels then
		startY:=startY+self.rowHeight;
	endif;
	theWidth:=xy2.x-startX;
	theHeight:=self.rowHeight;
	
	
	newFrame:=self.getStatsFrameForTA(_ta,true);	
	newFrame.parent:=self.myDrawingFrame;
	newFrame.visible:=true;
	
	
	//if _ta.id = "E1E" then
	//always draw on the  to the left if rotated 90 or 270 degrees
	if _taViewPos.rotation = 90 or _taViewPos.rotation = 270 then
		startX:=xy2.x;
		if _taViewPos.displayBottomColumnLabels  then
			startX:=startX+newFrame.getTextExtent("05");//self.rowHeight
		endif;
		startY:=xy1.y;
		theWidth:=newFrame.getTextExtent("0/0").Integer; //self.getRowHeightForScale.Integer;
		theHeight:=xy2.y-startY;
	endif;
		



	
	newFrame.top:=startY;
	newFrame.left:=startX;
	
	newFrame.width:=theWidth;
	newFrame.height:=theHeight;
	
	
	newFrame.boundaryWidth:=0;

	newFrame.transparent:=true;
	newFrame.autoRedraw:=true;
	
	newFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	newFrame.drawFontSize := self.getFontSizeRowColHeading-2;
	

	
	newFrame.beginBatchDrawing;
	newFrame.clearGraphics;
	
	foreach gridColumn in _ta.CM_RTGArea.allGridColumns  do
		self.drawQueuedInOutStatsForColumn(gridColumn,_taViewPos,newFrame);
	endforeach;
	newFrame.endBatchDrawing;

epilog

end;</source>
        <Parameter name="_ta" type="CM_RTGArea"/>
        <Parameter name="_taViewPos" type="CM_TerminalAreaViewPosition"/>
    </JadeMethod>
    <JadeMethod name="drawQueuedInOutStatsForColumn" id="76f54cd8-5b00-41b8-b9b3-237ccf197471">
        <source>drawQueuedInOutStatsForColumn(_gridColumn : CM_GridColumn;
								_taViewPosition : CM_TerminalAreaViewPosition;
								newFrame : CMUI_Frame input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwer1	Initial creation

*/

vars
	startX,
	endX,
	startY,
	endY: Real;
	colX,
	colY,
	theWidth : Real;
	statString : String;
	qdIn,
	qdOut : Integer;
	taViewPos : CM_TerminalAreaViewPosition;
	ta :CM_GridArea;
	hasStats : Boolean;
begin
	ta:=_gridColumn.myGridArea;
	if ta = null then
		return;
	endif;
	if _taViewPosition = null then
		return;
	endif;
	if self.drawFromNote then
		_gridColumn.getNumTIsQueuedInOut(qdIn,qdOut);
	else	
		if _gridColumn.myLocationStatistics &lt;&gt; null then
			qdIn:=_gridColumn.myLocationStatistics.queuedIn;
			qdOut:=_gridColumn.myLocationStatistics.queuedOut;
		endif;
	endif;
	hasStats:=qdIn &lt;&gt; 0 or qdOut &lt;&gt; 0;
	if  not hasStats then
		return;
	endif;
	theWidth:= self.getColumnWidthForScale;
	
	self.findWorkzoneXYsForColumns(_gridColumn,null,newFrame,startX,endX,startY,endY,colX,colY);
	
	
	//middle of the column
	
	if hasStats  then
		statString:=qdIn.String &amp; "/" &amp; qdOut.String;
		newFrame.drawTextAt(statString, colX, colY,Black);
		//just tagging the frame so i know there is something drawn on it 
		// this way i know i only have to cleargraphics on frames that are drawn on
		//newFrame.tag:=1.String;
	endif;
epilog

end;</source>
        <Parameter name="_gridColumn" type="CM_GridColumn"/>
        <Parameter name="_taViewPosition" type="CM_TerminalAreaViewPosition"/>
        <Parameter name="newFrame" type="CMUI_Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawRTGLastKnowPosition" id="38d43427-9b5a-4a3c-b81d-6a1a73400c07">
        <source>drawRTGLastKnowPosition(_machine : CM_Machine);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2009	cnwer1	Initial creation

*/
constants
	NewFontName = "Wingdings";
	ArrowUp = #[E9].Integer;
vars
	ta : CM_TerminalArea;
	lastKnowLocation : CM_LocationsController;
	statsFrame,
	machLocationFrame : CMUI_Frame;
	startY,
	startX,
	endX,
	diffHeight: Real;
	startColumn : CM_GridColumn;
	classID,
	instanceID,
	newIdx,
	textWidth,
	textHeight,
	upArrowWidth: Integer;
	satViewForm 	: YRD_SatelliteViewForm; 
	taViewPos : CM_TerminalAreaViewPosition;
	
begin

	if _machine = null then
		return;
	endif;
	
	if _machine.myLastKnownLocation = null then
		return;
	endif;
	
	lastKnowLocation:=_machine.myLastKnownLocation;
	
	if not lastKnowLocation.isKindOf(CM_RTGController) then
		return;
	else
		startColumn:=lastKnowLocation.CM_RTGController.myGridColumn;
		if startColumn = null then
			return;
		endif;
	endif;
	
	
	ta:=lastKnowLocation.myTerminalArea;
	
	
	statsFrame:=self.getStatsFrameForTA(ta,false);
	if statsFrame = null then
		return;
	endif;
	
	satViewForm:=self.myGridOverviewForm.YRD_SatelliteViewForm;
	//get the y position to start the CMUI_Moveable frame at
	startY:=statsFrame.top;//+statsFrame.height;
	
	//start X need to get the column position of the 
	startX:=statsFrame.left + ((startColumn.column-1) * (self.getColumnWidthForScale + self.columnSpacing));
	endX :=startX + self.getColumnWidthForScale + self.columnSpacing;
	
	
		//epr par 31523 4/7/13
	newIdx:=self.getNewFrameIndex(_machine,self.MACH_LOC_FRAME_ID);
	
	//machLocationFrame:=satViewForm.frmTAQInOut.getControl(newIdx);
	machLocationFrame:=findClonedFrameAgain( _machine, newIdx );	//10 Feb 2015	NDL	Par 34309
	
	taViewPos:=self.myTerminalAreaView.findViewPositionForTA(ta);//ta.allTerminalAreaViewPositions.first;
	if taViewPos = null then
		if  machLocationFrame &lt;&gt; null then
			delete machLocationFrame;
		endif;
		return;
	endif;
	//epr par 21284
	if taViewPos.rotation &gt; 0 then
		return;
	endif;
	
	if machLocationFrame = null then
		machLocationFrame:=satViewForm.frmTAQInOut.loadControl(newIdx).CMUI_Frame;
	endif;
	
	machLocationFrame.userObject:=_machine;
	machLocationFrame.enabled:=true;
	machLocationFrame.transparent:=true;

	machLocationFrame.parent:=self.myDrawingFrame;
	machLocationFrame.clearGraphics;
	machLocationFrame.visible:=true;
	
	machLocationFrame.drawFontSize := self.getFontSizeRowColHeading-2;
	textWidth:=machLocationFrame.getTextExtent(_machine.id);
	textHeight:=machLocationFrame.getTextHeightForWidth(_machine.id,machLocationFrame.width.Integer);
	diffHeight:=self.getRowHeightForScale.Integer - textHeight;
	
	machLocationFrame.drawFontName:=NewFontName;
	upArrowWidth:=machLocationFrame.getTextExtent(ArrowUp.Character);
	//machLocationFrame.drawFontName:=self.myDrawingFrame.drawFontName;
	
	machLocationFrame.top:=startY + self.getFontSizeRowColHeading;// + diffHeight;
	machLocationFrame.left:=startX + (self.getColumnWidthForScale/2) - (upArrowWidth/2) ;
	machLocationFrame.width:=startX + textWidth + upArrowWidth;
	machLocationFrame.height:=textHeight;
	machLocationFrame.autoRedraw:=true;
	machLocationFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	
	machLocationFrame.zOrder(1);
	
	machLocationFrame.drawTextAt(ArrowUp.Character,0,0,_machine.colour );
	machLocationFrame.drawFontName:=self.myDrawingFrame.drawFontName;
	
	machLocationFrame.drawTextAt(_machine.id, upArrowWidth,0,_machine.colour );
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="drawRTGMachinesWorkzone" id="dfc9739a-9c5d-4deb-b114-987ad4bf1e3d">
        <source>drawRTGMachinesWorkzone(_cmifMachineWorkzone : CMIF_MachineWorkzone input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwer1	Initial creation

*/

vars
	startTA,
	endTA  : CM_RTGArea;
	endRTGLane,
	rtgLane    : CM_RTGLane;
	satViewForm : YRD_SatelliteViewForm;
	startX,
	endX,
	startY,
	endY : Real;
	startStatsFrame,
	endStatsFrame : CMUI_Frame;
	machineFrame : CMUI_ResizableRectFrame;
	classID,
	instanceID,
	newIdx: Integer;
	taViewPos : CM_TerminalAreaViewPosition;
	colX,colY,
	offsetX1,
	offsetX2,
	offsetY1,
	offsetY2: Real;
begin
	
	if self.myGridOverviewForm = null or not self.myGridOverviewForm.isKindOf(YRD_SatelliteViewForm)  then
		return;
	else
		satViewForm:=self.myGridOverviewForm.YRD_SatelliteViewForm;
	endif;

	if _cmifMachineWorkzone.myStartColumn = null or _cmifMachineWorkzone.myEndColumn = null then
		return;	
	endif;
	
	// get the start and end TA - can assume that because start and end should be RTGColumns that the 
	// grid area is a CM_RTGArea
	startTA:=_cmifMachineWorkzone.getMyStartGridArea.CM_RTGArea;
	endTA := _cmifMachineWorkzone.getMyEndGridArea.CM_RTGArea;
	
	taViewPos:=self.myTerminalAreaView.findViewPositionForTA(startTA);//startTA.allTerminalAreaViewPositions.first;
	if taViewPos = null then
		return;
	endif;
	
	// both these should be in the same RTG Lane if they are in different RTG Areas
	if startTA &lt;&gt; endTA then
		rtgLane:=startTA.allTerminalAreaGroups.first.CM_RTGLane;
		if rtgLane = null then
			return;
		endif;
		endRTGLane:=endTA.allTerminalAreaGroups.first.CM_RTGLane;
		if endRTGLane = null then
			return;
		endif;
		if rtgLane &lt;&gt; endRTGLane then
			return;
		endif;
	endif;
	
	startStatsFrame:=self.getStatsFrameForTA(startTA,false);
	if startStatsFrame = null then
		//somethings gone wrong there should always be a stats frame
		return;
	endif;
	
	
	//if start and end tas are different get the end stats frame
	if startTA &lt;&gt; endTA then
		endStatsFrame:=self.getStatsFrameForTA(endTA,false);
	else
		endStatsFrame:=startStatsFrame;
	endif;
	
	//need this to be on the satellite view form9
	if endStatsFrame = null then
		return;
	endif;

	self.findWorkzoneXYsForColumns(_cmifMachineWorkzone.myStartColumn,_cmifMachineWorkzone.myEndColumn,startStatsFrame,startX,endX,startY,endY,colX,colY);
	_cmifMachineWorkzone.flippedHorizontal:=taViewPos.isFlippedHorizontal;
	_cmifMachineWorkzone.flippedVertical:=taViewPos.isFlippedVertical;
	if taViewPos.rotation = 0 or taViewPos.rotation = 180 then
		_cmifMachineWorkzone.rotated90:=false;
		offsetX1:=startStatsFrame.left;
		offsetX2:=endStatsFrame.left;
		offsetY1:=startStatsFrame.top+(startStatsFrame.height);
		offsetY2:=offsetY1+startStatsFrame.height;
		
	elseif  taViewPos.rotation = 90 or taViewPos.rotation = 270 then
		_cmifMachineWorkzone.rotated90:=true;
		offsetX1:=startStatsFrame.left + (startStatsFrame.width);
		offsetX2:=offsetX1 + startStatsFrame.width;
		offsetY1:=startStatsFrame.top;
		offsetY2:=endStatsFrame.top;
	endif;
	

	startY:=startY+offsetY1;
	endY:=endY+offsetY2;
	startX:=startX+offsetX1;
	endX:=endX+offsetX2;
	
	
	//epr par 31523 4/7/13
	newIdx:=self.getNewFrameIndex(_cmifMachineWorkzone.myMachine,self.WORKZONE_FRAME_ID);

	machineFrame:=satViewForm.frmWorkZone.getControl(newIdx);
	
	if machineFrame = null then
		machineFrame:=satViewForm.frmWorkZone.loadControl(newIdx).CMUI_ResizableRectFrame;		
	endif;
	
	_cmifMachineWorkzone.myWorkzoneFrame:=machineFrame;
	
	machineFrame.userObject:=_cmifMachineWorkzone;
	machineFrame.enabled:=true;

	machineFrame.parent:=self.myDrawingFrame.myOverlayViewingFrame;
	self.myDrawingFrame.myOverlayViewingFrame.visible:=true;
	self.myDrawingFrame.myOverlayViewingFrame.init;
	self.myDrawingFrame.myOverlayViewingFrame.zOrder(1);
	
	machineFrame.clearGraphics;
	machineFrame.visible:=true;
	
	if startX &lt;  endX then
		machineFrame.left:=startX;
		machineFrame.width:=endX-startX;
	else
		machineFrame.left:=endX;
		machineFrame.width:=startX - endX;
	endif;
	if startY &lt; endY then
		machineFrame.top:=startY;
		machineFrame.height:=endY- startY;
	else
		machineFrame.top:=endY;
		machineFrame.height:=startY- endY;
	endif;
	
	//machineFrame.thickness:=machineFrame.thickness*2;
	//cnwjo3 par 24371
	machineFrame.thickness:=machineFrame.DefThickness*2;
	machineFrame.autoRedraw:=false;
	machineFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	machineFrame.drawFontSize := self.getFontSizeLabel ; //self.getFontSizeRowColHeading-2;
	machineFrame.canResizeHeight:=_cmifMachineWorkzone.rotated90;
	machineFrame.canResizeWidth:=not _cmifMachineWorkzone.rotated90;
	machineFrame.zOrder(1);
end;</source>
        <Parameter name="_cmifMachineWorkzone" type="CMIF_MachineWorkzone" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawReeferGantry" id="fb2331ae-8a1a-4c4e-b120-2aa33f78a994">
        <source>drawReeferGantry(pColor: Integer; pHeight: Integer; pX1: Real; pY1: Real; pX2: Real; pY2: Real) protected;
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	
begin

	theFrame := self.myDrawingFrame;

	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawWidth := 2;
	theFrame.drawFillColor := Red;
	theFrame.drawLine(pX2 + 1, pY1, pX2 + 1, pY2 + 4,  Red);
	theFrame.drawWidth := 1;


	
end;</source>
        <access>protected</access>
        <Parameter name="pColor" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pX1" type="Real"/>
        <Parameter name="pY1" type="Real"/>
        <Parameter name="pX2" type="Real"/>
        <Parameter name="pY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoAccessDirection" id="6579c156-a53c-4870-a332-7bba23b1380f">
        <source>drawRoRoAccessDirection(_x1, _y1, _x2, _y2: Real; _lc: CM_RoRoController; _angle: Real; _flipHorizontal, _flipVertical: Boolean; _ta: CM_RoRoLaneArea; _tx, _ty: Real; _ox1, _oy1, _ox2, _oy2: Real) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlgmp6	Initial creation

*/

vars
	x1, y1, x2, y2, cx, cy: Real;
	ox1, oy1, ox2, oy2, midSide: Real;
	extraAdj: Real;
begin
	if self.scaleFactor &lt; 1 then		// at lower zooms, draw squares at lane ends which allow entry
		midSide := self.scaleFactor * 4;
		extraAdj := (1 - self.scaleFactor) * 4;
		
		if (_angle = 0 and not _flipHorizontal) or (_angle = 180 and _flipHorizontal) then
			x2 := _x2;
			y1 := _y1 - midSide;
			x1 := x2 - 2 * midSide;
			y2 := _y2 + midSide;
			ox1 := x2 + _ta.getSatDrawWidthInPixels(self.scaleFactor) + CM_RoRoLaneArea.SAT_RORO_BORDER_WIDTH * 2 + CM_RoRoLaneArea.SAT_RORO_BORDER_PADDING * 2;
			ox2 := ox1 + 2 * midSide;
			oy1 := y1;
			oy2 := y2;
			if _flipVertical then		// fine tuning to account for rounding errors
				if _angle = 0 then
					y1 := y1 + extraAdj;
					y2 := y2 + extraAdj;
					oy1 := oy1 + extraAdj;
					oy2 := oy2 + extraAdj;
				else
					y1 := y1 - midSide;
					y2 := y2 - midSide;
					oy1 := oy1 - midSide;
					oy2 := oy2 - midSide;
				endif;
			endif;
		elseif (_angle = 0 and _flipHorizontal) or (_angle = 180 and not _flipHorizontal) then
			x1 := _x1 + CM_RoRoLaneArea.SAT_RORO_BORDER_PADDING;	// bonus padding required
			y1 := _y1 - midSide;
			x2 := x1 + 2 * midSide;
			y2 := _y2 + midSide;
			ox2 := x1 - _ta.getSatDrawWidthInPixels(self.scaleFactor) - CM_RoRoLaneArea.SAT_RORO_BORDER_WIDTH * 2 - CM_RoRoLaneArea.SAT_RORO_BORDER_PADDING * 4;
			ox1 := ox2 + 2 * midSide;
			oy1 := y1;
			oy2 := y2;
			if _flipVertical then		// fine tuning to account for rounding errors
				if _angle = 0 then
					y1 := y1 + extraAdj + 2;
					y2 := y2 + extraAdj + 2;
					oy1 := oy1 + extraAdj + 2;
					oy2 := oy2 + extraAdj + 2;
				else
					ox1 := ox1 - midSide;
					ox2 := ox2 - midSide;
					y1 := y1 - midSide;
					y2 := y2 - midSide;
					oy1 := oy1 - midSide;
					oy2 := oy2 - midSide;
				endif;
			elseif _angle = 180 then
				ox1 := ox1 - midSide;
				ox2 := ox2 - midSide;
			endif;
		elseif (_angle = 90 and _flipVertical) or (_angle = 270 and not _flipVertical) then
			y1 := _y1 + CM_RoRoLaneArea.SAT_RORO_BORDER_PADDING;
			x1 := _x1 - midSide;
			x2 := _x2 + midSide;
			y2 := y1 + 2 * midSide;
			ox1 := x1;
			ox2 := x2;
			oy2 := y1 - _ta.getSatDrawWidthInPixels(self.scaleFactor) - CM_RoRoLaneArea.SAT_RORO_BORDER_WIDTH * 2 - CM_RoRoLaneArea.SAT_RORO_BORDER_PADDING * 2;
			oy1 := oy2 - 2 * midSide;
			if _flipHorizontal then		// fine tuning to account for rounding errors
				if _angle = 90 then
					x1 := x1 + 6;
					x2 := x2 + 6;
					ox1 := ox1 + 6;
					ox2 := ox2 + 6;
				else
					x1 := x1 + extraAdj + 3;
					x2 := x2 + extraAdj + 3;
					ox1 := ox1 + extraAdj + 3;
					ox2 := ox2 + extraAdj + 3;
				endif;
			endif;
		elseif (_angle = 90 and not _flipVertical) or (_angle = 270 and _flipVertical) then
			y2 := _y2;
			x1 := _x1 - midSide;
			x2 := _x2 + midSide;
			y1 := y2 - 2 * midSide;
			ox1 := x1;
			ox2 := x2;
			oy1 := y2 + _ta.getSatDrawWidthInPixels(self.scaleFactor) + CM_RoRoLaneArea.SAT_RORO_BORDER_WIDTH * 2 + CM_RoRoLaneArea.SAT_RORO_BORDER_PADDING * 2;
			oy2 := oy1 + 2 * midSide;
			if _flipHorizontal then		// fine tuning to account for rounding errors
				if _angle = 270 then
					x1 := x1 + extraAdj;
					x2 := x2 + extraAdj;
					ox1 := ox1 + extraAdj;
					ox2 := ox2 + extraAdj;
				else
					x1 := x1 + extraAdj + 3;
					x2 := x2 + extraAdj + 3;
					ox1 := ox1 + extraAdj + 3;
					ox2 := ox2 + extraAdj + 3;
				endif;
			endif;
		endif;
		
		if _lc.accessDirection &lt;&gt; _lc.ACCESS_DIRECTION_RIGHT then
			self.myDrawingFrame.drawSolidRectangle(x1, y1, x2, y2, self.satelliteViewCellColour);
		endif;
		if _lc.accessDirection &lt;&gt; _lc.ACCESS_DIRECTION_LEFT then
			self.myDrawingFrame.drawSolidRectangle(ox1, oy1, ox2, oy2, self.satelliteViewCellColour);
		endif;
	else								// at higher zooms draw arrows to show lane entry direction
		x1 := _x1;
		y1 := _y1;
		x2 := _x2;
		y2 := _y2;
		if _angle = 90 or _angle = 270 then
			if (_angle = 90 and _flipVertical) or (_angle = 270 and not _flipVertical) then
				self.drawArrow(x1, y1, x2, y2, Black, self.myDrawingFrame, _lc.accessDirection &lt;&gt; _lc.ACCESS_DIRECTION_RIGHT, _lc.accessDirection &lt;&gt; _lc.ACCESS_DIRECTION_LEFT);
			else
				self.drawArrow(x1, y1, x2, y2, Black, self.myDrawingFrame, _lc.accessDirection &lt;&gt; _lc.ACCESS_DIRECTION_LEFT, _lc.accessDirection &lt;&gt; _lc.ACCESS_DIRECTION_RIGHT);
			endif;
		else
			if (_angle = 0 and _flipHorizontal) or (_angle = 180 and not _flipHorizontal) then
				self.drawArrow(x1, y1, x2, y2, Black, self.myDrawingFrame, _lc.accessDirection &lt;&gt; _lc.ACCESS_DIRECTION_RIGHT, _lc.accessDirection &lt;&gt; _lc.ACCESS_DIRECTION_LEFT);
			else
				self.drawArrow(x1, y1, x2, y2, Black, self.myDrawingFrame, _lc.accessDirection &lt;&gt; _lc.ACCESS_DIRECTION_LEFT, _lc.accessDirection &lt;&gt; _lc.ACCESS_DIRECTION_RIGHT);
			endif;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_lc" type="CM_RoRoController"/>
        <Parameter name="_angle" type="Real"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_flipVertical" type="Boolean"/>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_tx" type="Real"/>
        <Parameter name="_ty" type="Real"/>
        <Parameter name="_ox1" type="Real"/>
        <Parameter name="_oy1" type="Real"/>
        <Parameter name="_ox2" type="Real"/>
        <Parameter name="_oy2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoBorder" id="26eb389a-bb2b-4050-8e0d-b112fa68b67a">
        <source>drawRoRoBorder( _x, _y : Integer; _ta: CM_RoRoLaneArea; _angle : Real; _flipHorizontal, _flipVertical : Boolean; _endX, _endY : Integer output; _ox1, _oy1, _ox2, _oy2 : Real ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwjk3	ccms 1018

*/

vars
	x1, y1,
	x2, y2			: Real;
	borderWidth		: Integer;
begin
	borderWidth 	:= CM_RoRoLaneArea.SAT_RORO_BORDER_WIDTH;
	self.myDrawingFrame.drawStyle := Frame.DrawStyle_Solid;
	self.myDrawingFrame.drawWidth := borderWidth;
		
	// Calculate the border rectangle
	x1 := _x;
	y1 := _y;
	

	//epr par 36616 15/10/15
	x2 := _x + _ta.getSatDrawWidthInPixels(self.scaleFactor);
	y2 := _y + _ta.getSatDrawHeightInPixels(self.scaleFactor);
			
	// Rotate and flip the  rectangle
	self.calcRotatedFlippedRectangle(x1, y1, x2, y2, 
										_ta, _x, _y,
										_angle, _flipHorizontal, _flipVertical,
										_ox1, _oy1, _ox2, _oy2);					
																
	self.myDrawingFrame.drawRectangle(x1, y1, x2, y2, self.satelliteViewGridColour);   
	_endX := x2.Integer;
	_endY := y2.Integer;
	
	//Moved from 'drawRoRoLaneArea'	20 Jan 2012	NDL	Par 28901
	self.selectionBoundsObjectsPutAtKey(x1.Integer, y1.Integer, x2.Integer, y2.Integer, _ta);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_angle" type="Real"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_flipVertical" type="Boolean"/>
        <Parameter name="_endX" type="Integer" usage="output"/>
        <Parameter name="_endY" type="Integer" usage="output"/>
        <Parameter name="_ox1" type="Real"/>
        <Parameter name="_oy1" type="Real"/>
        <Parameter name="_ox2" type="Real"/>
        <Parameter name="_oy2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoLabel" id="074c33a6-d53b-49a9-a8f4-c01c802360bc">
        <source>drawRoRoLabel(_x1, _y1 : Integer; _label : String; _ta : CM_RoRoLaneArea; _angle : Real ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 February 2009	cnwjk3	SFW1030

*/

vars
	taDrawWidth,
	x2, x, y 		: Real;
	borderWidth		: Integer;
	paddingWidth	: Integer;
begin	
	if _angle = 90 or _angle = 270 then
		taDrawWidth :=  _ta.getSatDrawHeightInPixels(self.scaleFactor);
	else
		taDrawWidth :=  _ta.getSatDrawWidthInPixels(self.scaleFactor);
	endif;
	x2 := _x1 + taDrawWidth + (borderWidth + paddingWidth) / 2;
	x := _x1 + (x2-_x1)/2;
	y := _y1 - self.TitleHeight - GridBorderWidth-2;
	self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Center;
	self.myDrawingFrame.drawFontSize := self.getFontSizeLabel;
	self.myDrawingFrame.drawFontBold := true;
	y := y - self.getSpaceForDifferentFonts(3);
	self.myDrawingFrame.drawTextAt(_label, x, y, self.satelliteViewFontColour);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_label" type="String"/>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_angle" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoLane" id="6a3c5458-2f09-460c-8dc3-50835dddbbd4">
        <source>drawRoRoLane(_x, _y : Real; _lc : CM_RoRoController; _angle : Real; _flipHorizontal, _flipVertical : Boolean; _ta : CM_RoRoLaneArea; _tx, _ty : Real; _ox1, _oy1, _ox2, _oy2 : Real; _isDrawFromNote : Boolean ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwjk3	ccms 1018
11 Nov 2010 cnwer1 	PAR 26189 - removed the allGridObjects.includes - expensive linear search and not required

*/

vars
	startOffset,
	x1, y1, x2, y2 			: Real;
begin
	startOffset := _lc.getSatDrawStartOffsetInPixels(self.scaleFactor);
	
	// Form the rectangle for this lane
	x1 := _x + startOffset;
	x1 := x1 +(CM_RoRoLaneArea.SAT_RORO_LANE_LABEL_WIDTH * self.scaleFactor);
	y1 := _y;
	x2 := x1 + _lc.getSatDrawLengthInPixels(self.scaleFactor) - startOffset;
	y2 := _y + _lc.getSatDrawWidthInPixels(self.scaleFactor);
	
	
	// Rotate and flip the lane rectangle
	self.calcRotatedFlippedRectangle(x1, y1, x2, y2, 
										_ta, _tx, _ty,
										_angle, _flipHorizontal, _flipVertical,
										_ox1, _oy1, _ox2, _oy2);					
	
	// Don't re-draw the label if drawing from a note, as it will display as bold.  This is something to do with the drawing mode
	// we use and drawing over something exactly the same shape in exactly the same position.  It basically gets drawn thicker.
	// This is nothing to do with drawFontBold being left switched on in the drawing frame.
	if not _isDrawFromNote then
		self.drawRoRoLaneLabel(_x, _y, _lc, _angle, _flipHorizontal, _flipVertical, _ta, _tx, _ty, _ox1, _oy1, _ox2, _oy2);
	endif;	
			
	self.myDrawingFrame.drawSolidRectangle(x1, y1,x2, y2, self.satelliteViewCellColour);

	// Key into the main collection which records the positions of all LCs
	if not self.drawFromNote then
		self.gridObjectsPutAtKey(x1.Integer,y1.Integer,x2.Integer,y2.Integer, _lc);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_lc" type="CM_RoRoController"/>
        <Parameter name="_angle" type="Real"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_flipVertical" type="Boolean"/>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_tx" type="Real"/>
        <Parameter name="_ty" type="Real"/>
        <Parameter name="_ox1" type="Real"/>
        <Parameter name="_oy1" type="Real"/>
        <Parameter name="_ox2" type="Real"/>
        <Parameter name="_oy2" type="Real"/>
        <Parameter name="_isDrawFromNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoLaneArea" id="fc54e5fa-6a25-4298-b174-25d30bca8fa9">
        <source>drawRoRoLaneArea( _ta : CM_RoRoLaneArea; _x, _y : Integer; _endX, _endY : Integer output) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwjk3	ccms 1018

*/

vars
	angle,
	ox1, ox2,
	oy1, oy2 			: Real;
	adjY				: Real;
	flipV,
	flipH				: Boolean;
	areaViewPosition	: CM_TerminalAreaViewPosition;
begin	

	flipV := false;
	flipH := false;
	angle := 0;

	areaViewPosition := self.myTerminalAreaView.findViewPositionForTA(_ta);//_ta.allTerminalAreaViewPositions.first;
	if areaViewPosition &lt;&gt; null then
		flipH := areaViewPosition.horizontalFlip;
		flipV := areaViewPosition.verticalFlip;
		angle := areaViewPosition.rotation;
	endif;	

	if self.showAccessDirections and ((angle = 90 and (not flipV or self.scaleFactor &lt; 1)) or (angle = 270 and (flipV or self.scaleFactor &lt; 1))) then
		adjY := _y + _ta.SAT_RORO_ARROW_WIDTH * self.scaleFactor + _ta.SAT_RORO_BORDER_PADDING * 2;
	else
		adjY := _y;
	endif;

	// Calculate the translation offsets for rotations
	self.calcRoRoTranslationOffsets(_x, _y, _ta, angle, ox1, oy1, ox2, oy2); 
	
	// Note that in all of this drawing the border width, border padding and lane gap are not
	// affected by the scale factor.
	
	self.drawRoRoBorder(_x, adjY.Integer, _ta, angle, flipH, flipV, _endX, _endY, ox1, oy1, ox2, oy2);
	self.drawRoRoRows(_x, adjY.Integer, _ta, angle, flipH, flipV, ox1, oy1, ox2, oy2);
	self.drawRoRoLabel(_x, _y, _ta.id, _ta, angle);
	
	if angle = 90 or angle = 270 then
		_endX := _x + _ta.getSatDrawHeightInPixels(self.scaleFactor).Integer;
		_endY := _y + _ta.getSatDrawWidthInPixels(self.scaleFactor);
	else
		_endX := _x + _ta.getSatDrawWidthInPixels(self.scaleFactor);
		_endY := _y + _ta.getSatDrawHeightInPixels(self.scaleFactor).Integer;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_endX" type="Integer" usage="output"/>
        <Parameter name="_endY" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoLaneFromNote" id="ce4c5821-3b9f-4f04-998d-59cec7e71045">
        <source>drawRoRoLaneFromNote() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwjk3	Initial creation

*/

vars
	angle,
	ox1, oy1,
	ox2, oy2,
	tx, ty,
	x1, y1,
	x2, y2				: Real;
	lc					: CM_RoRoController;
	ta					: CM_RoRoLaneArea;
	flipV,
	flipH				: Boolean;
	areaViewPosition	: CM_TerminalAreaViewPosition;

begin
	inheritMethod();
	if not self.myCurrentObject.isKindOf(CM_RoRoController) then
		return;
	endif;
	lc := self.myCurrentObject.CM_RoRoController;
	ta := lc.myRoRoLaneArea;
	
	// get the drawing origin for the terminal area
	self.getTAOriginForTA(ta, tx, ty);
	
	// get flip state and rotation angle
	flipV := false;
	flipH := false;
	angle := 0;

	areaViewPosition := self.myTerminalAreaView.findViewPositionForTA(ta); //ta.allTerminalAreaViewPositions.first;
	if areaViewPosition &lt;&gt; null then
		flipH := areaViewPosition.horizontalFlip;
		flipV := areaViewPosition.verticalFlip;
		angle := areaViewPosition.rotation;
	endif;	
	
	// The lane rectangle we have is rotated.  All drawing methods expect that the rectangles are in their
	// un-rotated state, so we calculate the start point from the lane here.
	ta.calcSatXYStartForLane(lc, tx, ty, self.scaleFactor, x1, y1); 
	
	// Calculate the translation offsets
	self.calcRoRoTranslationOffsets(tx.Integer, ty.Integer, ta, angle, ox1, oy1, ox2, oy2);
	
	self.myDrawingFrame.swapXY := false;
	self.drawRoRoLane(x1, y1, lc, angle, flipH, flipV, ta, tx, ty, ox1, oy1, ox2, oy2, true);  
	self.drawRoRoTIsForLane(x1, y1, lc, angle, flipH, flipV, ta, tx, ty, ox1, oy1, ox2, oy2);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawRoRoLaneLabel" id="6035f9c5-9ccb-437e-bc6c-23ce3c0300a5">
        <source>drawRoRoLaneLabel(_x, _y : Real; _lc : CM_RoRoController; _angle : Real; _flipHorizontal, _flipVertical : Boolean; _ta : CM_RoRoLaneArea; _tx, _ty : Real; _ox1, _oy1, _ox2, _oy2 : Real) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2009	cnwjk3	ccms 1018
03 Aug 2016	TFS 2468
26/10/16 cnwns1  TFS 2808 PAR38102 STWO - RORO Lanes ordering - rewrote most of the logic
*/

vars
	taDrawHeight,
	taDrawWidth,
	cx, cy,
	x1, y1		: Real;
	textLength : Real;
	textHeight 	: Real;
	rowHeight : Real;
	rowWidth : Real;	//TFS 2808
	dirX1, dirY1,
	dirX2, dirY2: Real;
	
	
begin

//TFS 2808*************	
//	write "Ang " &amp; _angle.String &amp; Tab &amp; " H " &amp; _flipHorizontal.String &amp; Tab &amp; "V " &amp; _flipVertical.String ;
	
	//epr par 37164 12/11/15 at less than this zoom level looks like a blurry mess
//	if self.scaleFactor &lt; 0.75 then
//	if self.scaleFactor &lt; 1 then	//3 Aug 2016	NDL	TFS 	6/10/17 MAP TFS7084
//		return ;
//	endif;
	
	if _angle = 90 or _angle = 270 then
		taDrawWidth  :=  _ta.getSatRawDrawHeightInPixels(self.scaleFactor) - (_ta.SAT_RORO_BORDER_WIDTH * 2);	
		taDrawHeight := _ta.getSatDrawWidthInPixels(self.scaleFactor) - (_ta.SAT_RORO_BORDER_WIDTH * 2);
	else
		taDrawWidth := _ta.getSatDrawWidthInPixels(self.scaleFactor)- (_ta.SAT_RORO_BORDER_WIDTH * 2);
		taDrawHeight := _ta.getSatRawDrawHeightInPixels(self.scaleFactor)- (_ta.SAT_RORO_BORDER_WIDTH * 2);
	endif;

	
	self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	self.myDrawingFrame.drawFontSize := self.getFontSizeRowColHeading();
	self.myDrawingFrame.drawFontBold := false;
	
	textLength := self.myDrawingFrame.getTextExtent("000");
	textHeight := self.myDrawingFrame.getTextHeight("000");
	x1 := _x;
	y1 := _y;
	
	//At this point the x1,y1 are at the correct location for angle = 0, when NOT flipped, i.e. left hand side top of the row.
	// Testing NDL 03 Aug 2016
	//self.myDrawingFrame.drawWidth := 5;
	//self.myDrawingFrame.drawPoint(x1, y1,Blue);
	//self.myDrawingFrame.drawWidth := 2;
	
	// Rotate the text x,y relative to the terminal area's mid point
	self.getRoRoAreaMidPoint(_ta, _tx, _ty, cx, cy); 
	self.rotatePoint(x1, y1, _angle, cx, cy);
	
	// Adjust the label to line up with the terminal area (as it will have been moved after rotation)
	x1 := x1 + _ox1;
	y1 := y1 + _oy1;
	
	// Testing NDL 03 Aug 2016
	//self.myDrawingFrame.drawWidth := 5;
	//self.myDrawingFrame.drawPoint(x1, y1,Red); 
	//self.myDrawingFrame.drawWidth := 2;
	
	// We have the text position in roughly the right area, we just need to make some adjustments 
	// based on the size of the label font (which has been adjusted according to the scale factor)
	//epr par 37164 12/11/15
	
	if (_angle = 0 and not _flipHorizontal) or (_angle = 180 and _flipHorizontal) then
		dirX2 := x1 - _ta.SAT_RORO_BORDER_WIDTH - _ta.SAT_RORO_BORDER_PADDING * 2;
		if _flipHorizontal then
			dirY1 := y1 - (_lc.getSatDrawWidthInPixels(self.scaleFactor) / 2);
		else
			dirY1 := y1 + (_lc.getSatDrawWidthInPixels(self.scaleFactor) / 2);
		endif;
		dirX1 := dirX2 - (_ta.SAT_RORO_ARROW_WIDTH * self.scaleFactor);
		dirY2 := dirY1;
	elseif (_angle = 90 and not _flipVertical) or (_angle = 270 and _flipVertical) then
		if _flipVertical then
			dirX1 := x1 + (_lc.getSatDrawWidthInPixels(self.scaleFactor) / 2);
		else
			dirX1 := x1 - (_lc.getSatDrawWidthInPixels(self.scaleFactor) / 2);
		endif;
		dirY1 := y1 - (_ta.SAT_RORO_ARROW_WIDTH * self.scaleFactor) - _ta.SAT_RORO_BORDER_WIDTH - _ta.SAT_RORO_BORDER_PADDING * 2;
		dirX2 := dirX1;
		dirY2 := dirY1 + (_ta.SAT_RORO_ARROW_WIDTH * self.scaleFactor);
	elseif (_angle = 0 and _flipHorizontal) or (_angle = 180 and not _flipHorizontal) then
		dirX1 := x1 + _ta.SAT_RORO_BORDER_WIDTH + _ta.SAT_RORO_BORDER_PADDING * 2;
		if _flipHorizontal then
			dirY1 := y1 + (_lc.getSatDrawWidthInPixels(self.scaleFactor) / 2);
		else
			dirY1 := y1 - (_lc.getSatDrawWidthInPixels(self.scaleFactor) / 2);
		endif;
		dirX2 := dirX1 + (_ta.SAT_RORO_ARROW_WIDTH * self.scaleFactor);
		dirY2 := dirY1;
	elseif (_angle = 90 and _flipVertical) or (_angle = 270 and not _flipVertical) then
		if _flipVertical then
			dirX1 := x1 - (_lc.getSatDrawWidthInPixels(self.scaleFactor) / 2);
		else
			dirX1 := x1 + (_lc.getSatDrawWidthInPixels(self.scaleFactor) / 2);
		endif;
		dirY1 := y1 + _ta.SAT_RORO_BORDER_PADDING * 2;
		dirX2 := dirX1;
		dirY2 := dirY1 + _ta.SAT_RORO_ARROW_WIDTH * self.scaleFactor;
	endif;
	
	if not _flipHorizontal and not _flipVertical then
		if _angle = 90 then
			self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Right;
			y1 := y1 + _ta.SAT_RORO_BORDER_WIDTH;
		elseif _angle = 180 then	
			self.myDrawingFrame.drawTextRotation := 0;
			rowHeight := taDrawHeight / _ta.laneCount;
			self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Right;
			y1 := y1 - rowHeight + _ta.SAT_RORO_BORDER_WIDTH;
		elseif _angle = 270 then	
			y1 := y1 - (textHeight + _ta.SAT_RORO_BORDER_WIDTH);
		endif;
	else
		if _flipHorizontal then
			if _angle = 0 then
				self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Right;
				x1 := self.flipPointX(_tx, taDrawWidth, x1) + _ta.SAT_RORO_BORDER_WIDTH;
				dirX1 := x1 + _ta.SAT_RORO_BORDER_WIDTH + _ta.SAT_RORO_BORDER_PADDING * 2;
				dirX2 := dirX1 + (_ta.SAT_RORO_ARROW_WIDTH * self.scaleFactor);
			elseif _angle = 90 then
				self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Right;
				rowWidth := taDrawWidth / _ta.laneCount ;	
				if self.scaleFactor = 1 then
					rowWidth := rowWidth + 6;
				endif;	
				x1 := self.flipPointX(_tx, taDrawWidth, x1) +  _ta.SAT_RORO_BORDER_WIDTH  + rowWidth;				
				dirX1 := x1 - (_lc.getSatDrawWidthInPixels(self.scaleFactor) / 2);
				dirX2 := dirX1;
			elseif _angle = 180 then
				x1 := self.flipPointX(_tx, taDrawWidth, x1)+  _ta.SAT_RORO_BORDER_WIDTH * 2;
				dirX2 := x1 - _ta.SAT_RORO_BORDER_WIDTH - _ta.SAT_RORO_BORDER_PADDING * 2;
				dirX1 := dirX2 - (_ta.SAT_RORO_ARROW_WIDTH * self.scaleFactor);
			elseif _angle = 270 then	
				rowHeight := textHeight / 2;
				x1 := self.flipPointX(_tx, taDrawWidth, x1) - ( _ta.SAT_RORO_BORDER_WIDTH *self.scaleFactor);		
				dirX1 := x1 + (_lc.getSatDrawWidthInPixels(self.scaleFactor) / 2);
				dirX2 := dirX1;
			endif;
		else
			if _angle = 180 then
				x1 := x1 - textLength + _ta.SAT_RORO_BORDER_WIDTH;
			endif;
		endif;
		if _flipVertical then
			if _angle = 0 then	
				y1 := self.flipPointY(_ty, taDrawHeight, y1);													
				dirY1 := y1 + (_lc.getSatDrawWidthInPixels(self.scaleFactor) / 2);
				dirY2 := dirY1;
			elseif _angle = 90 then
				self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Right;
				y1 := self.flipPointY(_ty, taDrawHeight, y1);
				y1 := y1 - ( textHeight + _ta.SAT_RORO_BORDER_WIDTH );
				dirY1 := y1 + textHeight + _ta.SAT_RORO_BORDER_WIDTH + _ta.SAT_RORO_BORDER_PADDING * 4;
				dirY2 := dirY1 + (_ta.SAT_RORO_ARROW_WIDTH * self.scaleFactor);
			elseif _angle = 180 then
				y1 := self.flipPointY(_ty, taDrawHeight, y1);														
				y1 := y1 + textHeight;																			
				dirY1 := y1 + (_lc.getSatDrawWidthInPixels(self.scaleFactor) / 2);
				dirY2 := dirY1;
			elseif _angle = 270 then
				y1 := self.flipPointY(_ty, taDrawHeight, y1);
				y1 := y1 + _ta.SAT_RORO_BORDER_WIDTH * 2;
				dirY2 := y1 - _ta.SAT_RORO_BORDER_WIDTH - _ta.SAT_RORO_BORDER_PADDING * 2;
				dirY1 := dirY2 - (_ta.SAT_RORO_ARROW_WIDTH * self.scaleFactor);
			endif;
		else
			if _angle = 270 then
				y1 := y1 -textHeight - _ta.SAT_RORO_BORDER_WIDTH;
			endif;
		endif;
	endif;
	
	// Testing NDL 03 Aug 2016
//	self.myDrawingFrame.drawWidth := 5;
//	self.myDrawingFrame.drawPoint(_x, _y, Yellow);
//	self.myDrawingFrame.drawPoint(x1, y1, Green);
//	self.myDrawingFrame.drawPoint(dirX1, dirY1, Red);
//	self.myDrawingFrame.drawPoint(dirX2, dirY2, Blue);
//	self.myDrawingFrame.drawWidth := 2;
	
	if self.scaleFactor &gt;= 1 then	// 6/10/17 MAP TFS7084
		self.myDrawingFrame.drawTextAt(_lc.id, x1, y1, self.satelliteViewFontColour);	
	endif;

	self.myDrawingFrame.drawTextRotation := 0;

	if self.showAccessDirections then
		self.drawRoRoAccessDirection(dirX1, dirY1, dirX2, dirY2, _lc, _angle, _flipHorizontal, _flipVertical, _ta, _x, _y, _ox1, _oy1, _ox2, _oy2);
	endif;

epilog

	self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Left;

end;</source>
        <access>protected</access>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_lc" type="CM_RoRoController"/>
        <Parameter name="_angle" type="Real"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_flipVertical" type="Boolean"/>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_tx" type="Real"/>
        <Parameter name="_ty" type="Real"/>
        <Parameter name="_ox1" type="Real"/>
        <Parameter name="_oy1" type="Real"/>
        <Parameter name="_ox2" type="Real"/>
        <Parameter name="_oy2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoRows" id="ac7c030d-1e6c-4e5a-ba59-dd06060b6817">
        <source>drawRoRoRows(_x, _y : Integer; _ta : CM_RoRoLaneArea; _angle : Real; _flipHorizontal, _flipVertical : Boolean; _ox1, _oy1, _ox2, _oy2 : Real ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwjk3	ccms 1018

*/

vars
	lane 		: CM_RoRoController;
	x, y		: Real;
begin

	// adjust x for padding and border

	//epr par 36616 15/10/15
	x:= _x + _ta.SAT_RORO_BORDER_WIDTH; 

	y := _y + _ta.SAT_RORO_BORDER_WIDTH + (_ta.SAT_RORO_BORDER_PADDING * self.scaleFactor) ; 
	
	foreach lane in _ta.allLanesByLaneNumber do
		
		self.drawRoRoLane(x,y, lane, _angle, _flipHorizontal, _flipVertical, _ta, _x, _y, _ox1, _oy1, _ox2, _oy2, false);
		self.drawRoRoTIsForLane(x, y, lane, _angle, _flipHorizontal, _flipVertical, _ta, _x, _y, _ox1, _oy1, _ox2, _oy2);
		
		y := y + lane.getSatDrawWidthInPixels(self.scaleFactor);
		y := y + (_ta.SAT_RORO_LANE_GAP * self.scaleFactor);
	endforeach;

	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_angle" type="Real"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_flipVertical" type="Boolean"/>
        <Parameter name="_ox1" type="Real"/>
        <Parameter name="_oy1" type="Real"/>
        <Parameter name="_ox2" type="Real"/>
        <Parameter name="_oy2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawRoRoTIsForLane" id="c261aa95-59ce-418f-ad91-48342adb5bbb">
        <source>drawRoRoTIsForLane(_x, _y : Real; _lc : CM_RoRoController; _angle : Real; _flipHorizontal, _flipVertical : Boolean; _ta : CM_RoRoLaneArea; _tx, _ty : Real; _ox1, _oy1, _ox2, _oy2 : Real ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2010	cnwjk3	ccms 1018

*/

vars
	ti						: CM_TrackedItem;
	laneLength,
	len,
	lenMetres,
	standardGap,
	laneWidth,
	freedLength,
	startOffset,
	fx1, fy1, fx2, fy2,
	x1, y1, x2, y2 			: Real;
	idx						: Integer;
begin
	if  _lc.allTrackedItems.size() = 0 then
		return;
	endif;
	
	laneLength := _lc.getSatDrawLengthInPixels(self.scaleFactor);
	startOffset := _lc.getSatDrawStartOffsetInPixels(self.scaleFactor);
	freedLength := _lc.freedLength * _lc.myRoRoLaneArea.SAT_RORO_PIXELS_PER_METRE * self.scaleFactor;
	laneWidth 	:= _lc.getSatDrawWidthInPixels(self.scaleFactor);
	standardGap := _lc.myRoRoLaneArea.standardGap * _lc.myRoRoLaneArea.SAT_RORO_PIXELS_PER_METRE * self.scaleFactor;	
	
	x1 := _x;
	
	// Adjust for labels
		//epr par 36616 15/10/15
	x1 := x1 + (CM_RoRoLaneArea.SAT_RORO_LANE_LABEL_WIDTH * self.scaleFactor);

	// Adjust start x for first TI based on the lane startOffset
	x1 := x1 + startOffset;		
	// Adjust for any space freed from the front of the lane
	x1 := x1 + freedLength;
	
	y1 := _y+1;
	y2 := _y + laneWidth-1;
	
	// Get the colour to use for TIs
	self.getFillColourForRoRoTIs(_lc.allTrackedItems);
	
	
	idx := 1;
	foreach ti in _lc.allTrackedItems do 
		// Form the rectangle for this tracked item
		lenMetres :=  _lc.getTILengthInMetres(ti);
		len := lenMetres * _lc.myRoRoLaneArea.SAT_RORO_PIXELS_PER_METRE * self.scaleFactor;

		if x1 + len - startOffset - (CM_RoRoLaneArea.SAT_RORO_LANE_LABEL_WIDTH * self.scaleFactor) - _x &gt; _lc.getSatPhysicalLaneLengthPixels(self.scaleFactor) then
			// Stop drawing, we are over queued/planned.
			// This is allowed, but we don't want to draw the stuff that doesn't fit.
			break;
		endif;

		// Calculate end x for TI
		x2 := x1 + len;		
		
		fx1 := x1;
		fx2 := x2;
		fy1 := y1;
		fy2 := y2;
		
		// If we need to draw right-to-left then we can just flip the TI x points
		// relative to the lane length.
		if _lc.isDrawRightToLeft() then
			fx1 := self.flipPointX(_x + startOffset + (CM_RoRoLaneArea.SAT_RORO_LANE_LABEL_WIDTH * self.scaleFactor) , laneLength - startOffset, fx1)-1;
			fx2 := self.flipPointX(_x + startOffset + (CM_RoRoLaneArea.SAT_RORO_LANE_LABEL_WIDTH * self.scaleFactor) , laneLength - startOffset, fx2)-1;
		endif;

		
		
		// Rotate and flip the TI rectangle
		self.calcRotatedFlippedRectangle(fx1, fy1, fx2, fy2, 
										_ta, _tx, _ty,
										_angle, _flipHorizontal, _flipVertical,
										_ox1, _oy1, _ox2, _oy2);				
				
		// Draw the TI
		self.myDrawingFrame.drawSolidRectangle(fx1, fy1, fx2, fy2, self.allFillColours[idx]);
	
		x1 := x2 + standardGap;
		idx := idx + 1;
			
	endforeach;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_lc" type="CM_RoRoController"/>
        <Parameter name="_angle" type="Real"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_flipVertical" type="Boolean"/>
        <Parameter name="_ta" type="CM_RoRoLaneArea"/>
        <Parameter name="_tx" type="Real"/>
        <Parameter name="_ty" type="Real"/>
        <Parameter name="_ox1" type="Real"/>
        <Parameter name="_oy1" type="Real"/>
        <Parameter name="_ox2" type="Real"/>
        <Parameter name="_oy2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawRowLabel" id="20851bf0-e40d-4946-9bd5-82bd2b30cb78">
        <updating/>
        <source>drawRowLabel(_row : CM_GridRow;
				_yPos1 : Real io; 
				_yPos2 : Real io; 
				_startX, _endX : Real; 
				_rowIdx : Integer io;
				_taViewPos : CM_TerminalAreaViewPosition) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwer1	Initial creation

*/

constants
	RowSpacing		: Integer = 3;

vars

	tmpTA	: CM_GridArea;
	tmpRow	: CM_GridRow;
	colIdx	: Integer;
	tmpX, tmpY,
	yPos1, yPos2,
	xPos1, xPos2	: Real;	
	tmpCaption	: String;
	tmpFrame	: YRD_ContainerDrawingFrame;		//CMUI_Frame;
	drawLeftLabel : Boolean;
	drawRightLabel : Boolean;
begin

	tmpTA := self.myTerminalArea.CM_GridArea;
	if  tmpTA = null then
		return;
	endif;

	
	yPos1 := _yPos1;
	yPos2 := _yPos2;
	tmpRow := _row;
	tmpFrame := self.myDrawingFrame;
	drawLeftLabel :=_taViewPos.displayLeftRowLabels; 
	drawRightLabel:=_taViewPos.displayRightRowLabels; 
	xPos1 := _startX - self.columnWidth;
	xPos2 := _startX;
	
	
	tmpCaption := tmpRow.getLabel(); 
	if tmpFrame.swapXY then
			tmpY := yPos1;
		else
			tmpY := (yPos1 + ((yPos2 - yPos1) / 2)) - 5;
		endif;
		
	if  drawLeftLabel then
		if tmpFrame.swapXY then
			tmpX := xPos2 - 12;	
		else
			tmpX := xPos2 - 3;	
			tmpFrame.drawTextAlign := Frame.DrawTextAlign_Right;
		endif;
		
		if tmpCaption &lt;&gt; null
		and (self.scaleFactor &gt; 1  or _row.row mod 2 = 1) then
			tmpFrame.drawFontSize := self.getFontSizeRowColHeading;
			tmpFrame.drawTextAt(tmpCaption, tmpX, tmpY, self.satelliteViewFontColour);
			tmpFrame.drawTextAlign := Frame.DrawTextAlign_Left; 
		endif;	
	endif;
	
	colIdx := 0;
	self.y1 := yPos1;
	self.y2 := yPos2 ;

	xPos2:=_endX;
	if drawRightLabel then
		
		// Draw the row label at end of row
		if tmpCaption &lt;&gt; null
		and (self.scaleFactor &gt; 1  or _row.row mod 2 = 0) then
			if tmpFrame.swapXY then
				tmpX := xPos2 + 1;
			else
				tmpX := xPos2 + 3;
			endif;
			tmpFrame.drawTextAlign := Frame.DrawTextAlign_Left;
			tmpFrame.drawFontSize := self.getFontSizeRowColHeading;
			tmpFrame.drawTextAt(tmpCaption, tmpX, tmpY, self.satelliteViewFontColour);

		endif;
	endif;
	
	yPos1 := yPos1 + self.rowHeight;
	if self.isForSatelliteView then
		yPos1 := yPos1 + -1;	// No Spacing 
	else
		yPos1 := yPos1 + RowSpacing;
	endif;
	
	yPos2 := yPos1 + self.rowHeight;

	_rowIdx := _rowIdx + 1;

	_yPos1 := yPos1;
	_yPos2 := yPos2;
epilog



end;</source>
        <access>protected</access>
        <Parameter name="_row" type="CM_GridRow"/>
        <Parameter name="_yPos1" type="Real" usage="io"/>
        <Parameter name="_yPos2" type="Real" usage="io"/>
        <Parameter name="_startX" type="Real"/>
        <Parameter name="_endX" type="Real"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <Parameter name="_taViewPos" type="CM_TerminalAreaViewPosition"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="af47ffe0-3ffc-487d-aba7-24a667c7ab96">
        <updating/>
        <source>drawSelf(_clearSelected: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    19MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
constants
	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	RowSpacing		: Integer = 10;
	
vars
	maxX,
	maxY	: Integer;
	tmpTA	: CM_TerminalAreaMaster; //CM_GridArea;
	tmpGridArea : CM_GridArea;
	tmpRow	: CM_GridRow;
	tmpCol	: CM_GridColumn;
	tmpLC	: CM_GridController;
	tmpVLabelCentre,
	rowIdx,
	colIdx	: Integer;
	tmpX, tmpY,
	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2	: Real;	
	tmpCaption, tmpLbl	: String;
	tmpFrame	: CMUI_Frame;	//YRD_ContainerDrawingFrame;
	topLeftFiller : Frame;
	txtSize : Integer;
	tmpRTGArea : CM_RTGArea;
begin

//write class.name &amp; '::' &amp; method.name;
//beginTransaction;
	self.rowHeight := 12;
	self.columnWidth := (24 * self.scaleFactor).Integer;

	self.drawingAll := true;
	self.drawFromNote := false;
	self.allTempTIs.clear;

	if self.myTerminalArea = null then
		return;
	endif;

//	inheritMethod(_clearSelected);

	useSelectorObjects := self.useSelector();
	
	self.allGridObjects.clear;

	self.myDrawingFrame.clearGraphics();

	self.myVLabels.clearGraphics();
	self.myVLabels.width := YRD_GridOViewDrawingController.LABEL_WIDTH;
	self.myVLabels.top := YRD_GridOViewDrawingController.LABEL_WIDTH + 1;
	self.myVLabels.autoRedraw := true;
	self.myVLabels.drawTextAlign := Frame.DrawTextAlign_Center;
	tmpVLabelCentre := (self.myVLabels.clientWidth / 2).Integer;

	self.myHLabels.drawTextAlign := Frame.DrawTextAlign_Center;
	self.myHLabels.clearGraphics();
	self.myHLabels.height := YRD_GridOViewDrawingController.LABEL_WIDTH;
	self.myHLabels.autoRedraw := true;
	self.setFontDefaults();
	
	tmpTA := self.myTerminalArea; //.CM_GridArea;
	self.drawingLane := tmpTA.isRTGLane();
	
	topLeftFiller := self.myDockBar.myScrollableFrame.myTopLeftFillerFrame;
	topLeftFiller.ignoreSkin := true;
	topLeftFiller.clearGraphics();
	topLeftFiller.autoRedraw := true;
	topLeftFiller.drawFontSize := 10; 
	tmpLbl := tmpTA.getID();

	if tmpLbl.length &lt; 3 then 
		topLeftFiller.drawFontSize := 16;
	elseif tmpLbl.length &gt; 3 then 
		topLeftFiller.drawFontSize := 8;
	endif;
	topLeftFiller.drawTextAt(tmpLbl, 1, 8, Black); 
	if tmpTA.isRightAligned() then
		topLeftFiller.drawFontSize := 8; 
		topLeftFiller.drawTextAt("RIGHT", 1, 30, Red); 
	endif;
	topLeftFiller.visible := true;
	topLeftFiller.move(0,0,self.myDockBar.myScrollableFrame.myVLabels.clientWidth,self.myDockBar.myScrollableFrame.myHLabels.height);
	
	tmpFrame := self.myDrawingFrame;
	tmpFrame.caption := null;
	theRowHeight := self.getRowHeightForScale();
	theColWidth	 := self.getColumnWidthForScale();
	
	yPos1 := 5; //TopMargin;
	// draw the column headings
	colIdx := 0;
	xPos1 := self.LABELGAP;
	xPos2 := xPos1;

	if tmpTA.isKindOf(CM_GridArea) and not tmpTA.isKindOf(CM_YardInterchangeArea)  then
		if not self.hasLabels() then
			// If not showing the row lables, then just display the area name above the columns
			self.drawAreaName(xPos1, yPos1);
		else
			if self.flipHorizontal then
				foreach tmpCol in tmpTA.CM_GridArea.allGridColumns reversed do
					self.drawSelfColumn(tmpCol,xPos1); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
				endforeach;
			else
				foreach tmpCol in tmpTA.CM_GridArea.allGridColumns  do
					self.drawSelfColumn(tmpCol,xPos1); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
				endforeach;
			endif;
		endif;
	endif;	
	yPos2 := yPos1 + theRowHeight;

	tmpFrame := self.myVLabels;
	
	if self.flipVertically then
		if tmpTA.isKindOf(CM_GridArea)and not tmpTA.isKindOf(CM_YardInterchangeArea) then
			foreach tmpRow in tmpTA.CM_GridArea.allGridRows reversed do
				self.drawSelfRow(tmpRow,yPos1,yPos2,xPos2,rowIdx); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
			endforeach;
		endif;

	else
		// ########################################
		// ### DRAW RTG BLOCK
		// ########################################
		if tmpTA.isKindOf(CM_GridArea) and not tmpTA.isKindOf(CM_YardInterchangeArea) then
			foreach tmpRow in tmpTA.CM_GridArea.allGridRows  do
				self.drawSelfRow(tmpRow,yPos1,yPos2,xPos2,rowIdx); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;
				// ### CCMS 1509 - draw a red line if no access
				if not tmpTA.CM_GridArea.hasAccessRight() then
//					self.myDrawingFrame.drawWidth := 2;
//					self.myDrawingFrame.drawLine(xPos2 +2,yPos1 - theRowHeight,xPos2 +2,yPos2 - theRowHeight + 3,Red);
				endif;

			endforeach;
		endif;
	endif;	
	xPos2 := xPos2 + theColWidth;
	maxX := (xPos2 + RightMargin - theColWidth).Integer ;
	maxY := (yPos2 + BottomMargin - theRowHeight).Integer;
	
	// ### CCMS 1509 - draw a red line if no access
	if tmpTA.isKindOf(CM_GridArea) and not tmpTA.isKindOf(CM_YardInterchangeArea)then
		if not tmpTA.CM_GridArea.hasAccessRight() then
			self.myDrawingFrame.drawWidth := 2;
			self.myDrawingFrame.drawLine(maxX - 2 ,1,maxX - 2 ,maxY,Red);
		endif;
		if not tmpTA.CM_GridArea.hasAccessLeft() then
			self.myDrawingFrame.drawWidth := 2;
			self.myDrawingFrame.drawLine(1 ,1,1 ,maxY,Red);
		endif;
	endif;
	self.drawSubBlockStackLabels();
	self.myDockBar.resizeScrollingFrame(maxX, maxY);
	self.myDockBar.myScrollingFrame.left := self.LABEL_WIDTH + 1;
	self.myDockBar.myScrollingFrame.top := self.LABEL_WIDTH + 1;

	self.myDockBar.resetScrollValues();

epilog
	self.drawingAll := false;
end;</source>
        <Parameter name="_clearSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSelfALL" id="1bb8e8a3-9c83-432f-9778-751dd59ef5ac">
        <updating/>
        <source>drawSelfALL() updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    19MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
13 Mar 2009	cnwkpd1	PAR #19154 - User self.myTerminal instead of app.getMyTerminal to prevent
					1090 exceptions when processing notes "in the background"
14 Nov 2010 cnwer1  PAR 26189 Satellite view preformance changes
02 Apr 2014 cnwer1	CCMS 1366 - changes to draw bulk areas and 
12 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/
constants
	BottomMargin	: Integer = 10;
	RightMargin		: Integer = 10;

vars
	maxX,
	maxY	: Integer;
	tmpTA	: CM_TerminalArea; //CM_GridArea;
	tmpRow	: CM_GridRow;
	tmpCol	: CM_GridColumn;
	startX, startY,
	endX, endY,
	rowIdx 			: Integer;
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2	: Real;
	maxXWorkzone : Integer;
	maxYWorkzone : Integer;
	loadState	: Boolean;
	machineWZ : CMIF_MachineWorkzone;
	taViewPos 		: CM_TerminalAreaViewPosition;
	oldTerminalAreas : CM_TerminalAreaSet;
	statsFrame	: Frame;
begin	
	// cnwjk3 SFW1030
	self.allTempObjects.clear();
	self.allSelectionBoundsObjects.clear();

	self.rowHeight := self.getRowHeightForScale().Integer;
	self.columnWidth := self.getColumnWidthForScale.Integer;

	self.drawingAll := true;
	self.drawFromNote := false;
	self.drawingLane := false;
	self.allTempTIs.clear;
	self.allGridObjects.clear;
	
	create oldTerminalAreas transient;
	self.allTerminalAreas.copy(oldTerminalAreas);
	
	self.allTerminalAreas.clear;
	self.notableObjectsClear;
	self.myDrawingFrame.clearGraphics();
	
	
	self.useSelectorObjects := self.myGridOverviewForm.useSelector;
	self.showOSGrid :=false;

	self.setFontDefaults();
	self.myDrawingFrame.drawFontName := "Arial";
	self.labelFontSize:=self.getFontSizeLabel;
	
	self.myDockBar.myScrollableFrame.myTopLeftFillerFrame.visible := false;
	self.myHLabels.visible := false;
	self.myVLabels.visible := false;
	xPos1 := 10;
	
	if self.myTerminalAreaView &lt;&gt; null then
	// par 26721 Jan 2011 beginLoad exception
	//beginLoad;
	app.cmsBeginLoad(loadState);
	// #######################
	foreach taViewPos in self.myTerminalAreaView.allTerminalAreaViewPositions  do
		
		self.myDrawingFrame.endBatchDrawing;
		self.myDrawingFrame.beginBatchDrawing;
		tmpTA:=taViewPos.myTerminalArea;
		self.myTerminalArea := tmpTA;
		oldTerminalAreas.removeIfPresent(tmpTA);
		self.setOrientation(taViewPos);	
		self.myCurrentTAViewPosition:=taViewPos;
		
		self.allTerminalAreas.add(tmpTA);	
		self.notableObjectAdd(tmpTA); 
		// cnwjk3 ccms 1018 27/01/10
		self.getTAOriginForTAViewPos(taViewPos,xPos1, yPos1);
	
		startX := xPos1.Integer;
		startY := yPos1.Integer;
		if self.myProgressInterface &lt;&gt; null then
			self.myProgressInterface.updateProgress("Drawing Area " &amp; tmpTA.id &amp;  " ...",null,null); 
		endif;
		
		// cnwjk3-  New drawing code for General Cargo areas
		if tmpTA.isKindOf(CM_IrregularBlockArea) then
			self.drawIrregularBlockArea(tmpTA.CM_IrregularBlockArea, startX, startY, endX, endY);
			
			// Enable the frame to re-size correctly after drawing
			maxX := maxX.max(endX + RightMargin);
			maxY := maxY.max(endY + BottomMargin);

			continue;
		endif;

		// cnwjk3 ccms 1018 25/11/09
		if tmpTA.isKindOf(CM_RoRoLaneArea) then
			self.setOrientation(null);
			self.drawRoRoLaneArea(tmpTA.CM_RoRoLaneArea, startX, startY, endX, endY);
			
			// Enable the frame to re-size correctly after drawing
			maxX := maxX.max(endX + RightMargin);
			maxY := maxY.max(endY + BottomMargin);

			continue;
		endif;

		theColWidth	 := self.getColumnWidthForScale();
		
		xPos2 := xPos1;
	
		
		if tmpTA.isKindOf(CM_GridArea) and not tmpTA.isKindOf(CM_YardInterchangeArea)  then
			
		
			// draw the column headings
			if self.flipHorizontal then
				foreach tmpCol in tmpTA.CM_GridArea.allGridColumns reversed do
				//	if global.cnwer1 then
					self.drawSelfColumnALL(tmpCol,xPos1,yPos1,taViewPos);
				endforeach;
			else
				foreach tmpCol in tmpTA.CM_GridArea.allGridColumns  do
					//if global.cnwer1 then
					self.drawSelfColumnALL(tmpCol,xPos1,yPos1,taViewPos);
				endforeach;
			endif;
		
			endX := xPos1.Integer;
			endY := self.y2.Integer;
		
		endif;	

		yPos2 := yPos1 + self.rowHeight;
		xPos1 := xPos2;
	
		
			
		if  tmpTA.isKindOf(CM_YardInterchangeArea) then
			self.drawYardInterchangeArea(tmpTA.CM_YardInterchangeArea, self.satelliteViewCellColour, startX,startY); //xPos1, yPos2 - self.getSpaceForDifferentFonts(0.3) * 2);
			//18 Jan 2013	NDL	Par 30894
			endX := (xPos1 + (taViewPos.getWidth() *    self.scaleFactor)).Integer;
			endY := (yPos1 + (taViewPos.getHeight() *    self.scaleFactor)).Integer;
					
		elseif
			 tmpTA.isKindOf(CM_GridArea) and  not tmpTA.isKindOf(CM_YardInterchangeArea) then
			yPos1 := yPos1 + self.getSpaceForDifferentFonts(1);
			yPos2 := yPos2 + self.getSpaceForDifferentFonts(1);	
	
			if self.flipVertically then
				foreach tmpRow in tmpTA.CM_GridArea.allGridRows  reversed do
			
					self.drawRowLabel(tmpRow,yPos1,yPos2,xPos1,endX,rowIdx,taViewPos);
				endforeach;
			else
				foreach tmpRow in tmpTA.CM_GridArea.allGridRows  do			
		
					self.drawRowLabel(tmpRow,yPos1,yPos2,xPos1,endX,rowIdx,taViewPos);
				endforeach;
	
			endif;	
		
		// TFS 49453
		elseif tmpTA.isGeneralCargoAllocArea() then
			self.drawGCAllocRowArea(taViewPos, startX, startY, endX, endY);
		// TFS 49453
		
		else
			//if tmpTA.isKindOf(CM_BlockStack) then
			self.drawBlockStack(taViewPos, self.satelliteViewCellColour,startX, startY);// xPos1, yPos2 - self.getSpaceForDifferentFonts(0.3) * 2);

			//18 Jan 2013	NDL	Par 30894
			endX := (xPos1 + (taViewPos.getWidth() *    self.scaleFactor)).Integer;
			endY := (yPos1 + (taViewPos.getHeight() *    self.scaleFactor)).Integer;
		
		endif;	

				
		if self.myDrawingFrame.swapXY then
			maxX := maxX.max(endY + self.myDrawingFrame.swapYadjustment + BottomMargin);
			maxY := maxY.max(endX + self.myDrawingFrame.swapXadjustment + RightMargin);
		else
			maxX := maxX.max(endX + RightMargin);
			maxY := maxY.max(endY + BottomMargin);
		endif;

		// ### CCMS 1509 - draw a red line if no access
		if tmpTA.isKindOf(CM_GridArea) then
			if not tmpTA.CM_GridArea.hasAccessRight() then
				self.myDrawingFrame.drawWidth := 2;
				self.myDrawingFrame.drawLine(endX+1, startY, endX+1, endY, Red);
			endif;
			if not tmpTA.CM_GridArea.hasAccessLeft() then
				self.myDrawingFrame.drawWidth := 2;
				self.myDrawingFrame.drawLine(startX-2, startY, startX-2, endY, Red);
			endif;
		endif;
		
		self.drawAreaTitle(startX,startY,endX,endY,taViewPos.displayTopColumnLabels);

		// cnwjk3 SFW1030
		// Record bounding rectangles of terminal areas and RTG lanes
		self.setOrientation( null );
		self.setSelectionBoundsForTA(tmpTA,taViewPos);	
		
		
		//HERE create a new frame just for area stats and draw them
		self.setOrientation( taViewPos );
		if tmpTA.isKindOf(CM_RTGArea) then
			self.drawQueuedInOutStats(tmpTA.CM_RTGArea,taViewPos);
		endif;
		
	endforeach;
	endif;
	self.myDrawingFrame.endBatchDrawing;

	// #######################

	self.myTerminalArea := null;
	self.setOrientation( null );

	if self.scaleFactor &gt; 1 then
		self.drawSubBlockStackLabels();
	endif;

	//cnwjo3 par 24371
	if self.myTerminalAreaView &lt;&gt; null then
		self.drawALLMachinesWorkzone();
	else
		self.clearRTGMachineWorkzones();
	endif;
	
	if self.allCMIFMachineWorkzones.size &gt; 0 then
		foreach machineWZ in self.allCMIFMachineWorkzones do
			if machineWZ.myWorkzoneFrame &lt;&gt; null then
				if (machineWZ.myWorkzoneFrame.left + machineWZ.myWorkzoneFrame.width) &gt; maxXWorkzone then
					maxXWorkzone := (machineWZ.myWorkzoneFrame.left + machineWZ.myWorkzoneFrame.width).Integer;
				endif;
				
				if (machineWZ.myWorkzoneFrame.top + machineWZ.myWorkzoneFrame.height) &gt; maxYWorkzone then
					maxYWorkzone := (machineWZ.myWorkzoneFrame.top + machineWZ.myWorkzoneFrame.height).Integer;
				endif;
			endif;
		endforeach;
		
		if maxXWorkzone &gt; maxX then
			maxX := maxXWorkzone;
		endif;
		
		if maxYWorkzone &gt; maxY then
			maxY := maxYWorkzone;
		endif;	
	endif;
	
	//we might have rtg stats showing for the previous view have to get rid of them
	foreach tmpTA in oldTerminalAreas do
		statsFrame:=self.getStatsFrameForTA(tmpTA,false);	
		delete statsFrame;
	endforeach;
	
	self.myDockBar.myScrollingFrame.left := self.LABEL_WIDTH + 1;
	self.myDockBar.myScrollingFrame.top := self.LABEL_WIDTH + 1;

	self.myDockBar.resizeScrollingFrame(maxX+20, maxY+20);

epilog
	self.drawingAll := false;
	//endLoad;
	app.cmsEndLoad(loadState);
	
	delete oldTerminalAreas;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawSelfAllChangeHeightRest" id="8258b0a9-bcc3-4a07-86f4-9cd44218fa20">
        <updating/>
        <source>drawSelfAllChangeHeightRest(_heightRestrictOption : Integer) updating;
/*

Date		Who		Reason
24 March 2015	cnwer1	Initial creation PAR 33954

*/

vars
	 idx,
	startX, startY,
	endX, endY 	: Integer;
	obj : Object;
	gridController : CM_GridController;
	tmpUsage,
	tmpAvail : Integer;
	hasHeightRestriction : Boolean;
	iter : Iterator;
	loadState	: Boolean;
	theFillColour : Integer;
begin
	if self.heightRestrictionOption = _heightRestrictOption then
		return;
	endif;
	self.myDrawingFrame.drawFontSize := self.getFontSizeRowColHeading();
	self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	
	self.heightRestrictionOption:=_heightRestrictOption;
	
	iter:=self.allGridObjects.createIterator;
	idx := 1;
	app.cmsBeginLoad(loadState);
	self.myDrawingFrame.beginBatchDrawing;
	while iter.next(obj) do
		self.allGridObjects.getIteratorKeys(startX, startY,endX, endY,iter);
		
		self.setMyCurrentObject(obj);	
		if not obj.isKindOf(CM_GridController) then
			continue;
		endif;
		gridController:=obj.CM_GridController;
		if gridController.mySubBlockStack &lt;&gt; null then
			continue;
		endif;
		gridController.getAvailUsageHeight(tmpUsage,tmpAvail, hasHeightRestriction);
		if tmpUsage = REEFERGANTRY_USE or tmpUsage = BUILDING_USE or  tmpUsage = LIGHT_TOWER_USE then
			continue;
		endif;
		
		if gridController.allTrackedItems.size &gt; 0 then
			continue;
		endif;
		
		if 	tmpAvail &lt; PAD_HEIGHT_1_UNAVAIL then
			continue;
		endif;
		if gridController.hasPower() then 
			theFillColour := self.POWER_FILL_COLOUR;
		else
			theFillColour := self.satelliteViewCellColour;
		endif;
		
		self.setForRedraw(obj,startX,startY,endX,endY);
		self.myLocationsController:=obj.CM_LocationsController;
		self.drawBlankSpace(self.myDrawingFrame, theFillColour, idx, startX, startY, endX, endY , false);
		self.drawHeightRestriction(Red,tmpAvail,startX, startY, endX, endY); // PAR 19519
		
	endwhile;
	
	self.myDrawingFrame.endBatchDrawing;
epilog
	app.cmsEndLoad(loadState);
	self.drawFromNote:=false;
	delete iter;
end;</source>
        <Parameter name="_heightRestrictOption" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSelfAllChangeViewMode" id="87a3fd2d-dc18-474f-884b-2fce913c44d3">
        <updating/>
        <source>drawSelfAllChangeViewMode(_viewMode : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11/11/2010	cnwer1	Initial creation
18/06/2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars
	startX, startY,
	endX, endY 	: Integer;
	loadState	: Boolean;
	iter : Iterator;
	obj 	: Object;
	tmpUsage,
	tmpAvail : Integer;
	gLC 		: CM_GridController;
	roro		:  CM_RoRoController;
	hasHeightRestriction : Boolean;
	tmpTIs	: CM_TIArray;
	theTI 	: CM_TrackedItem;
	theFrame: CMUI_GridAreaDrawingFrame;
	ta : CM_TerminalArea;
	taViewPosition 		: CM_TerminalAreaViewPosition;
	xPos, yPos : Real;
	drawnGCAreas : ObjectArray;				// TFS 49453
begin
	self.viewMode:=_viewMode;
	self.columnWidth := self.getColumnWidthForScale.Integer;
	iter:=self.allGridObjects.createIterator;
	// par 26721 Jan 2011 beginLoad exception
	//beginLoad;
	app.cmsBeginLoad(loadState);
	self.myDrawingFrame.beginBatchDrawing;
	create drawnGCAreas transient;								// TFS 49453
	while iter.next(obj) do
		self.allGridObjects.getIteratorKeys(startX, startY,endX, endY,iter);
		
		self.setMyCurrentObject(obj);		
		if obj.isKindOf(CM_GridController) and not obj.isKindOf(CM_LaneController) then
			gLC:=obj.CM_GridController;
			if gLC.mySubBlockStack &lt;&gt; null then
				continue;
			endif;
			gLC.getAvailUsageHeight(tmpUsage,tmpAvail, hasHeightRestriction);
			if tmpUsage = REEFERGANTRY_USE or tmpUsage = BUILDING_USE or  tmpUsage = LIGHT_TOWER_USE then
				continue;
			endif;
			tmpTIs := gLC.allTrackedItems;
			theTI:= tmpTIs.first;
			if theTI = null then
				continue;
			endif;
			if theTI.myPrimaryActualLocation &lt;&gt; gLC then
				continue;
			endif;
			
			self.setForRedraw(obj,startX,startY,endX,endY);
			self.myLocationsController:=obj.CM_LocationsController;
			self.drawTITopDown(gLC,theTI,tmpTIs);
		elseif obj.isKindOf(CM_RoRoController) then	// cnwjk3 ccms 1018 26/01/10
			roro:=obj.CM_RoRoController;
			self.myLocationsController:=obj.CM_LocationsController;
			self.drawFromNote:=true;
			self.drawRoRoLaneFromNote();
			self.drawFromNote:=false;
		// PAR 32836
		elseif obj.isKindOf(CM_IrregularBlockController) then 

			taViewPosition:=self.myTerminalAreaView.findViewPositionForTA(obj.CM_IrregularBlockController.myTerminalArea);
			self.getTAOriginForTAViewPos(taViewPosition,xPos, yPos);
			startX := xPos.Integer;
			startY := yPos.Integer;
			self.drawGridLocation(startX,startY, obj.CM_IrregularBlockController);
		elseif obj.isKindOf(CM_BlockController) or obj.isKindOf(CM_BulkLocation) then
			theFrame := self.myDrawingFrame;
			self.setForRedraw(obj,startX,startY,endX,endY);
		//	self.doSatViewBlockStackColourCargo( obj.CM_BlockController.myTerminalArea.CM_BlockStack, theFrame, startX, startY, endX, endY );
			//22 Nov 2011	NDL	Par 28712
			self.drawFromNote:=true;
			self.drawBlockStackFromNote( obj.CM_LocationsController.myTerminalArea );
			self.drawFromNote:=false;
			
		// TFS 49453 start
		elseif obj.isKindOf(CM_GeneralCargoAllocController) then
			if not drawnGCAreas.includes(obj.CM_LocationsController.myTerminalArea) then
				self.drawFromNote := true;
				self.drawGCAllocRowAreaFromNote(obj.CM_LocationsController.myTerminalArea);
				self.drawFromNote := false;
				drawnGCAreas.add(obj.CM_LocationsController.myTerminalArea);
			endif;
		// TFS 49453 end
		endif;
	
	endwhile;
	self.myDrawingFrame.endBatchDrawing;
	
epilog
	//endLoad;
	app.cmsEndLoad(loadState);
	self.drawFromNote:=false;
	delete iter;
	delete drawnGCAreas;				// TFS 49453
end;</source>
        <Parameter name="_viewMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawSelfColumnALL" id="8c572013-1fcd-4e6c-93b2-3c1ca58574b2">
        <updating/>
        <source>drawSelfColumnALL(	_col : CM_GridColumn;
						_xpos1 : Real io; 
						_ypos1 : Real; 
						_taViewPosition : CM_TerminalAreaViewPosition) protected, updating;
/*

Purpose:  testing if changes made will speed up satellite view drawing			

Parameters:			

Return Value:		


Date		Who		Reason
14 September 2009	cnwer1	Initial creation

*/
vars
	theColWidth,
	yPos1,
	yPos2,
	xPos2,
	xPos1: Real;	
	tmpCaption		: String;
	tmpFrame		: YRD_ContainerDrawingFrame;
	tmpLC	: CM_GridController;
begin

	if self.myTerminalArea = null then
		return;
	endif;
	
	tmpFrame := self.myDrawingFrame;
	theColWidth	 := self.getColumnWidthForScale;
	if _col.hasGap then
		theColWidth := self.getGapDrawWidth(_col);
	endif;
	self.columnWidth:=theColWidth.Integer;
	if self.scaleFactor &gt; 1 
	or (_col.column mod 2).Boolean  then
		tmpCaption := _col.label;
	endif;

	if tmpCaption[1:1] = "_" then
		tmpCaption := null;
	endif;
	
	//draw the top column caption
	if tmpCaption &lt;&gt; null and _taViewPosition.displayTopColumnLabels  then
		self.drawColumnLabel(_xpos1,_ypos1,true,tmpCaption);
	endif;

	xPos1:=_xpos1 ;
	xPos2:= _xpos1 + self.columnSpacing + theColWidth;

	//draw the row 
	yPos1:=_ypos1  + self.getSpaceForDifferentFonts(1);
	yPos2:=_ypos1  + self.rowHeight + self.getSpaceForDifferentFonts(1);
	
	self.y1 := yPos1;
	self.y2 := yPos2;
	
	
	if self.flipVertically then
		foreach tmpLC in _col.allControllersByRow  reversed do
			self.x1 := xPos2 -theColWidth; 
			self.x2 := xPos2;

			self.drawLC(tmpLC);
			
			self.y1 := self.y1 + self.rowHeight -1;
			self.y2 := self.y1 + self.rowHeight;
		endforeach;
	else
		foreach tmpLC in _col.allControllersByRow   do
				
			self.x1 := xPos2 -theColWidth; 
			self.x2 := xPos2;

			self.drawLC(tmpLC);	

			self.y1 := self.y1 + self.rowHeight -1;
			self.y2 := self.y1 + self.rowHeight;
		endforeach;
	
	endif;
	
	tmpCaption:=null;
	if self.scaleFactor &gt; 1 
	or not (_col.column mod 2).Boolean  then
		tmpCaption := _col.label;
	endif;
	
	//25 Nov 2011	NDL
	if tmpCaption[1:1] = "_" then
		tmpCaption := null;
	endif;
	
	//draw the bottom column caption
	if  tmpCaption &lt;&gt; null and _taViewPosition.displayBottomColumnLabels  then
		self.drawColumnLabel(_xpos1,self.y2 - self.rowHeight,false,tmpCaption);
	endif;
	tmpFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	_xpos1 :=xPos2;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_col" type="CM_GridColumn"/>
        <Parameter name="_xpos1" type="Real" usage="io"/>
        <Parameter name="_ypos1" type="Real"/>
        <Parameter name="_taViewPosition" type="CM_TerminalAreaViewPosition"/>
    </JadeMethod>
    <JadeMethod name="drawSelfLC" id="81a8d428-3db7-44ce-9004-cd4825351b23">
        <updating/>
        <source>drawSelfLC(_lc: CM_GridController; _xpos1,_xpos2 : Real io; _colIdx	: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		PAR 18682 - so that we call drawLC() not drawLCJustTI()
//
// ---------------------------------------------------------------------------
vars
	theColWidth : Real;
begin

	theColWidth	 := self.ColumnWidth * self.scaleFactor;
	if _lc.myGridColumn.hasGap then
		theColWidth := self.getGapDrawWidth(_lc.myGridColumn);
	endif;
	_colIdx := _colIdx + 1;
	_xpos1 := _xpos2 + self.columnSpacing;
	_xpos2 := _xpos1 + theColWidth;

	self.x1 := _xpos1;
	self.x2 := _xpos2;

	self.drawLC(_lc);



end;</source>
        <Parameter name="_lc" type="CM_GridController"/>
        <Parameter name="_xpos1" type="Real" usage="io"/>
        <Parameter name="_xpos2" type="Real" usage="io"/>
        <Parameter name="_colIdx" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawSelfRow" id="a3722d3d-013f-412c-ae60-65b33434cb8c">
        <updating/>
        <source>drawSelfRow(_row : CM_GridRow; _yPos1 : Real io; _yPos2 : Real io; _xPos2 : Real io; _rowIdx : Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	LeftMargin		: Integer = 10;
	RowSpacing		: Integer = 3;   
vars
	tmpRow	: CM_GridRow;
	tmpLC	: CM_GridController;
	colIdx	: Integer;
	tmpX, tmpY,
	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2	: Real;	
	tmpCaption	: String;
	tmpFrame	: CMUI_Frame;	//YRD_ContainerDrawingFrame;

begin
	//1/12/2008 cnwdz2 par18378
	//tmpTA := self.myTerminalArea.CM_GridArea;
	if self.myTerminalArea = null then
		return;
	endif;
	
	yPos1 := _yPos1;
	yPos2 := _yPos2;
	tmpRow := _row;
	tmpFrame := self.myVLabels;
	theColWidth	 := self.getColumnWidthForScale();
	theRowHeight := self.getRowHeightForScale();

	xPos1 := LeftMargin;
	xPos2 := xPos1 + theColWidth;
	
	// Draw the row label
	tmpCaption := tmpRow.getLabel();
//	if tmpCaption[1:1] = "_" then
//		tmpCaption := null;
//	elseif tmpCaption[1:1] = "&lt;" then
//		tmpCaption := tmpCaption[4:end];
//	endif;
	if tmpCaption &lt;&gt; null then
		tmpX := 11;// PAR 10484
		tmpY := (yPos1 + ((yPos2 - yPos1) / 2)) - 10; // the 10 is half the height of the text in pixels
		tmpFrame.drawTextAt(tmpCaption, tmpX + 1, tmpY + 1, White);
		tmpFrame.drawTextAt(tmpCaption, tmpX, tmpY, Black);
		
	endif;	
//	if tmpTA.isStraddleStack() and not self.myDockBar.isForOverview then	//SFW1030
//		self.drawSelfRowDrawStackDir(_row,tmpFrame,(tmpX - 12).Integer,tmpY.Integer,yPos1.Integer,yPos2.Integer - 3);
//	endif;
	self.y1 := yPos1;
	self.y2 := yPos2;

	xPos1 := self.LABELGAP - theColWidth;
	xPos2 := self.LABELGAP;

	colIdx := 0;
	if self.flipHorizontal then
		foreach tmpLC in tmpRow.allControllersByColumn reversed do
			self.drawSelfLC(tmpLC, xPos1,xPos2,colIdx);
		endforeach;
	else
		foreach tmpLC in tmpRow.allControllersByColumn do
			self.drawSelfLC(tmpLC, xPos1,xPos2,colIdx);
		endforeach;
	endif;
	yPos1 := yPos1 + RowSpacing + theRowHeight;
	yPos2 := yPos1 + theRowHeight;

	_rowIdx := _rowIdx + 1;

	_yPos1 := yPos1;
	_yPos2 := yPos2;
	_xPos2 := xPos2;
end;</source>
        <Parameter name="_row" type="CM_GridRow"/>
        <Parameter name="_yPos1" type="Real" usage="io"/>
        <Parameter name="_yPos2" type="Real" usage="io"/>
        <Parameter name="_xPos2" type="Real" usage="io"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawSelfRowALL" id="8b3590ff-7c0a-417b-8748-317ec22a677c">
        <updating/>
        <source>drawSelfRowALL(_row : CM_GridRow; _yPos1 : Real io; _yPos2 : Real io; _xPos2 : Real io; _rowIdx : Integer io;
				_taViewPos : CM_TerminalAreaViewPosition) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
13 Mar 2009	cnwkpd1	PAR #19154 - User self.myTerminal instead of app.getMyTerminal to prevent
					1090 exceptions when processing notes "in the background"
*/
// adm 150509 Par 19145 label display when zoomimg
constants
	TopTextMargin	: Integer = 10;
	LeftTextMargin	: Integer = 5;

	TopMargin		: Integer = 10;
	BottomMargin	: Integer = 10;
	LeftMargin		: Integer = 10;
	RightMargin		: Integer = 10;
	RowSpacing		: Integer = 3;

vars
	tmpTA	: CM_GridArea;
	tmpRow	: CM_GridRow;
	tmpLC	: CM_GridController;
	colIdx	: Integer;
	tmpX, tmpY,
	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2	: Real;	
	tmpCaption	: String;
	tmpFrame	: YRD_ContainerDrawingFrame;		//CMUI_Frame;
	drawLeftLabel : Boolean;
	drawRightLabel : Boolean;
begin

	tmpTA := self.myTerminalArea.CM_GridArea;
	if  tmpTA = null then
		return;
	endif;
	
	yPos1 := _yPos1;
	yPos2 := _yPos2;
	tmpRow := _row;
	tmpFrame := self.myDrawingFrame;
	theColWidth	 := self.getColumnWidthForScale();
	theRowHeight := self.getRowHeightForScale();
	//epr CCMS 1076 20/8/09 
	drawLeftLabel :=_taViewPos.displayLeftRowLabels; 
	drawRightLabel:=_taViewPos.displayRightRowLabels; 
	xPos1 := _xPos2 - theColWidth;
	xPos2 := _xPos2;

	
	tmpCaption := tmpRow.getLabel(); 
	if tmpFrame.swapXY then
		tmpY := yPos1;
	else
		tmpY := (yPos1 + ((yPos2 - yPos1) / 2)) - 5;
	endif;

	
	if  drawLeftLabel then
		if tmpFrame.swapXY then
			tmpX := xPos2 - 12;	
		else		
			tmpX := xPos2 - 3;	
			tmpFrame.drawTextAlign := Frame.DrawTextAlign_Right;
		endif;
		if tmpCaption &lt;&gt; null
		and (self.scaleFactor &gt; 1  or _row.row mod 2 = 1) then
			tmpFrame.drawFontSize := self.getFontSizeRowColHeading;
			tmpFrame.drawTextAt(tmpCaption, tmpX, tmpY, self.satelliteViewFontColour);
			tmpFrame.drawTextAlign := Frame.DrawTextAlign_Left; 
		endif;	
	endif;
		
	colIdx := 0;
	self.y1 := yPos1;
	self.y2 := yPos2 ;

	if self.flipHorizontal then
		foreach tmpLC in tmpRow.allControllersByColumn reversed do
			self.drawSelfLC(tmpLC, xPos1,xPos2,colIdx);
		endforeach;
	else
		foreach tmpLC in tmpRow.allControllersByColumn do
			self.drawSelfLC(tmpLC, xPos1,xPos2,colIdx);
		endforeach;
	endif;

	if drawRightLabel then	
		// Draw the row label at end of row
		if tmpCaption &lt;&gt; null
		and (self.scaleFactor &gt; 1  or _row.row mod 2 = 0) then
			if tmpFrame.swapXY then
				tmpX := xPos2 + 1;
			else
				tmpX := xPos2 + 3;
			endif;
			tmpFrame.drawTextAlign := Frame.DrawTextAlign_Left;
			tmpFrame.drawFontSize := self.getFontSizeRowColHeading;
			tmpFrame.drawTextAt(tmpCaption, tmpX, tmpY, self.satelliteViewFontColour);
		endif;
	endif;

	yPos1 := yPos1 + theRowHeight;
	if self.isForSatelliteView then
		yPos1 := yPos1 + -1;	// No Spacing 
	else
		yPos1 := yPos1 + RowSpacing;
	endif;
	
	yPos2 := yPos1 + theRowHeight;

	_rowIdx := _rowIdx + 1;

	_yPos1 := yPos1;
	_yPos2 := yPos2;
	_xPos2 := xPos2;
end;</source>
        <Parameter name="_row" type="CM_GridRow"/>
        <Parameter name="_yPos1" type="Real" usage="io"/>
        <Parameter name="_yPos2" type="Real" usage="io"/>
        <Parameter name="_xPos2" type="Real" usage="io"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <Parameter name="_taViewPos" type="CM_TerminalAreaViewPosition"/>
    </JadeMethod>
    <JadeMethod name="drawTITopDown" id="d03a9095-51cb-4743-bd4a-5cfbdc3fcd47">
        <updating/>
        <source>drawTITopDown(_lc: CM_GridController;
				_theTI  : CM_TrackedItem; 
				_tmpTIs : CM_TIArray ) updating,protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 November 2010	cnwer1	Initial creation

*/

vars
	theCellHeight,
	theFillColour,
	fillSize,idx : Integer;
	startX,endX,endY,startY  : Real;
begin
	
	if _tmpTIs = null then
		return;
	endif;
	
	self.myDrawingFrame.drawWidth	:= 1;
	startY 	:= self.y1 ; 
	theFillColour:=	self.satelliteViewCellColour;
	if _theTI &lt;&gt; null then
		//draw tis
		self.cellHeight := (self.y2 - self.y1).Integer;
		self.getFillColourForTIs(_tmpTIs, _lc);
		fillSize := self.allFillColours.size;
		endX:=self.x2;
		self.adjustStartEndXForOffsets(_theTI,startX,endX);
		if startX &gt; self.x1 and _lc.allTrackedItemOSBackEnds.first = null then
			if _lc.hasPower() then 
				theFillColour := self.POWER_FILL_COLOUR;
			endif;
			self.drawBlankSpace(self.myDrawingFrame, theFillColour, 1, self.x1, self.y1, startX, self.y2 , false);
		
		endif;
		
		// #### ONE TI in STACK
		// ####
		theCellHeight := (self.cellHeight / fillSize).Integer;
		foreach idx in 1 to fillSize reversed do
		//foreach theFillColour in  self.allFillColours reversed do
			endY := startY + theCellHeight;
			theFillColour := self.allFillColours[idx];
			if theFillColour = NullColour then
				theFillColour := White;
			endif;
			if idx = 1 then
				endY:=self.y2;
			endif;
			self.drawLCTopDown( theFillColour,  startX, startY,endX , endY); 
			startY := endY;
		endforeach; 
		startY 	:= self.y1 ; 
		endY	:= self.y2;
		if _theTI &lt;&gt; null and _theTI.isOverSizedContainer() then
			self.drawOverSizedMark(null, _theTI, theFillColour,  startX, startY + 1,endX , endY - 1); 
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_GridController"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_tmpTIs" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="drawTransformer" id="14eeee60-241a-4154-b834-eecf49a92b12">
        <source>drawTransformer(pColor: Integer; pHeight: Integer; pX1: Real; pY1: Real; pX2: Real; pY2: Real) protected;
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_GridAreaDrawingFrame;
	
begin

	theFrame := self.myDrawingFrame;

	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawWidth := 3;
	theFrame.drawFillColor := White;
	theFrame.drawFilledRectangle(pX1+2, pY1+2, pX2-2, pY2-2,  Blue);
	theFrame.drawWidth := 1;


	
end;</source>
        <access>protected</access>
        <Parameter name="pColor" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pX1" type="Real"/>
        <Parameter name="pY1" type="Real"/>
        <Parameter name="pX2" type="Real"/>
        <Parameter name="pY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawYardInterchangeArea" id="1c50e36b-a48f-41cd-9490-f76472341aaf">
        <source>drawYardInterchangeArea(_yardIC: CM_YardInterchangeArea; _color: Integer; _x1: Real; _y1: Real) protected;
/*

Date		Who		Reason
26 Feb 2010	cnwer1	CCMS 1100 - Yard Interchange Areas should display in a similar size to block stacks &amp; display the number of containers 
11 Nov 2010 cnwer1 	PAR 26189 - removed the allGridObjects.includes - expensive linear search and not required
25 Jan 2017 cnwma1	TFS #3197:PAR38556 MSL - user FALCONIERI cannot open satellite view
*/
vars
	theFrame: CMUI_GridAreaDrawingFrame;
	 x2, y2,y1: Real;
	gridRow 	: CM_GridRow;
	theRowHeight  : Real;
	theColumnWidth : Real;
	theText		: String;
	yardICLaneController : CM_YardICAreaLaneController;
	taViewPostion : CM_TerminalAreaViewPosition;
begin
	theFrame := self.myDrawingFrame;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawWidth := GridLineWidth;
	theFrame.drawFillColor := _color;
	theFrame.drawTextAlign:=Frame.DrawTextAlign_Left;
	y1:=_y1;
	
	//epr par 36616 13/10/15
	taViewPostion:=self.myTerminalAreaView.findViewPositionForTA(_yardIC);
	
	//02 July 2020	NDL	TFS 49708 - If we can't find the terminal area view for the yard-IC in our terminal area view just bail.
	if taViewPostion = null then
		return;
	endif;
	
	theColumnWidth :=(taViewPostion.getWidth() *    self.scaleFactor);
	theRowHeight := (taViewPostion.getHeight() *    self.scaleFactor)/_yardIC.allGridRows.size; 
		
	foreach gridRow in _yardIC.allGridRows do
		x2 := _x1 + theColumnWidth ;
		y2 := y1 + theRowHeight;
		if theRowHeight &lt;&gt; 0 then     //25/01/2017 cnwma1	 TFS #3197 
			theFrame.drawFontSize:=(theRowHeight) * 0.7;
		else
			theFrame.drawFontSize:=1 * 0.7; //25/01/2017 cnwma1	 TFS #3197
		endif;
		theFrame.drawFilledRectangle(_x1, y1, x2, y2,  self.satelliteViewGridColour);
		yardICLaneController:=gridRow.allControllersByColumn.first.CM_YardICAreaLaneController;
		if _yardIC.isGateInterchangeArea then
			theText:=yardICLaneController.allVehicleMachines.size.asStringJMT;
		else
			theText:=yardICLaneController.numTIs.asStringJMT;
		endif;
		if theText &lt;&gt; "0" then
			theFrame.drawTextIn(theText,_x1, y1, x2, y2,	self.satelliteViewFontColour);
		endif;
		if not self.drawFromNote then
			self.gridObjectsPutAtKey(_x1.Integer, y1.Integer, x2.Integer, y2.Integer, yardICLaneController);
		endif;

		y1 := y2;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_yardIC" type="CM_YardInterchangeArea"/>
        <Parameter name="_color" type="Integer"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawYardInterchangeFromNote" id="e4328a87-d6df-4af5-b51a-01c0fee96351">
        <updating/>
        <source>drawYardInterchangeFromNote(_yardICArea : CM_YardInterchangeArea)   updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 February 2010	cnwer1	Initial creation
29 May 2025			navah1	Bug 34917 DPH - Error 1090 YRD_GridOViewDrawingController::drawYardInterchangeFromNote
*/

vars
	xPos1,
	yPos1,
	yPos2,
	theRowHeight : Real;
	taViewPosition : CM_TerminalAreaViewPosition;
	existingTa : CM_TerminalAreaMaster;
	startX : Real;
	startY : Real;
	endX : Integer;
	endY : Integer;
begin
	taViewPosition:=self.getTAOriginForTA(_yardICArea, xPos1, yPos1);
	if taViewPosition = null then									//29.05.2025 navah1 #34917		 
		return;
	endif;
	
	startX := xPos1.Integer;
	startY := yPos1.Integer;
	
	
	self.setOrientation(taViewPosition);

	theRowHeight := self.getRowHeightForScale();
	yPos2 := yPos1 + theRowHeight;
	
	self.drawYardInterchangeArea(_yardICArea, self.satelliteViewCellColour, xPos1, yPos2 - self.getSpaceForDifferentFonts(0.3) * 2);
	
	endX := (xPos1 + ( 5 * self.ColumnWidth * self.scaleFactor)).Integer;
	endY := (yPos1 + ( 5 * self.RowHeight * self.scaleFactor)).Integer;
	existingTa := self.myTerminalArea;
	self.myTerminalArea := _yardICArea;
	self.drawAreaTitle( startX, startY, endX, endY, taViewPosition.displayTopColumnLabels );
	self.myTerminalArea := existingTa;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_yardICArea" type="CM_YardInterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="findClonedFrameAgain" id="cf0b8246-c445-42ef-a1d8-e54fd4f5ac73">
        <source>findClonedFrameAgain( _machine : CM_Machine; _index : Integer ):CMUI_Frame;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2015	cnwndl1	Initial creation	Par 34309

*/

vars

	machLocationFrame : CMUI_Frame;
	satViewForm : YRD_SatelliteViewForm;
	cntrl : Control;
	index : Integer;

begin

	
	
	satViewForm:=self.myGridOverviewForm.YRD_SatelliteViewForm;
	
	if satViewForm &lt;&gt; null then
	
		machLocationFrame := satViewForm.frmTAQInOut.getControl( _index );
		if machLocationFrame &lt;&gt; null then
			return machLocationFrame;
		endif;
	
		foreach index in 1 to satViewForm.controlCount do
			cntrl:=satViewForm.controls(index);
			if cntrl &lt;&gt; null and cntrl.isKindOf(CMUI_Frame) then
				if cntrl.userObject = _machine then
					return cntrl.CMUI_Frame;
				endif;
			endif;
		endforeach;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="CMUI_Frame"/>
    </JadeMethod>
    <JadeMethod name="findMachineWorkzoneFrame" id="ca830535-6402-4cac-b31f-8245bc6b0c3c">
        <source>findMachineWorkzoneFrame(_cmifMachineWorkzone : CMIF_MachineWorkzone) : CMUI_ResizableRectFrame protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2010	cnwer1	Initial creation

*/

vars
	classID,instanceID,newIdx : Integer;
	machineFrame: CMUI_ResizableRectFrame;
begin
	newIdx:=self.getNewFrameIndex(_cmifMachineWorkzone.myMachine,self.WORKZONE_FRAME_ID);
	machineFrame:=self.myGridOverviewForm.YRD_SatelliteViewForm.frmWorkZone.getControl(newIdx);
	return machineFrame;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmifMachineWorkzone" type="CMIF_MachineWorkzone"/>
        <ReturnType type="CMUI_ResizableRectFrame"/>
    </JadeMethod>
    <JadeMethod name="findOtherMachineWorkzones" id="32e3da55-b209-4b8e-8174-29a898242b28">
        <source>findOtherMachineWorkzones(_x : Real; 
							_adjustment : Real;
							_currentCMIFMachineWorkzone : CMIF_MachineWorkzone;
							_allOtherMachineWorkzones : ObjectArray input;
							_findLeft,
							_findRight: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwer1	Initial creation

*/

vars
	otherWorkZoneFrame,otherMachineWZs : CMIF_MachineWorkzone;
	iter : Iterator;
	found : Boolean;
	x1, x2 : Real;
	otherAreasToCheck : ObjectArray;
	areaToCheck  : CM_TerminalAreaMaster;
	searching : Boolean;
	rectFrame : CMUI_ResizableRectFrame;
begin
	x1:=_x   - _adjustment;
	x2:=_x   + _adjustment;
	
	iter:= self.allCMIFMachineWorkzones.createIterator;
	create otherAreasToCheck transient;
	if _currentCMIFMachineWorkzone.myRTGLane.isKindOf(CM_RTGLane) then
		if _currentCMIFMachineWorkzone.myRTGLane.CM_RTGLane.allTAsByTypeId.size &gt; 0 then
			_currentCMIFMachineWorkzone.myRTGLane.CM_RTGLane.allTAsByTypeId.copy(otherAreasToCheck);
		endif;
	elseif _currentCMIFMachineWorkzone.myRTGLane.isKindOf(CM_RTGArea) then
		if _currentCMIFMachineWorkzone.myRTGLane.CM_RTGArea.allTerminalAreaGroups.size &gt; 0 then
			_currentCMIFMachineWorkzone.myRTGLane.CM_RTGArea.allTerminalAreaGroups.copy(otherAreasToCheck);
		endif;
	endif;
	
	self.allCMIFMachineWorkzones.startKeyGeq(_currentCMIFMachineWorkzone.myRTGLane,null,iter);
	areaToCheck:=_currentCMIFMachineWorkzone.myRTGLane;
	searching:=true;
	while searching do  : outerLoop 
		while iter.next(otherMachineWZs) do
		
			if otherMachineWZs = _currentCMIFMachineWorkzone then
				continue;
			endif;
			if otherMachineWZs.myRTGLane &lt;&gt; areaToCheck then
				break ;
			endif;
			rectFrame:=otherMachineWZs.myWorkzoneFrame.CMUI_ResizableRectFrame;
			if  _findLeft and
				( rectFrame.getAdjustedLeft &gt;= x1 and rectFrame.getAdjustedLeft &lt;= x2 )then
					_allOtherMachineWorkzones.add(otherMachineWZs);
					continue;
					
			endif;
			if _findRight and ((rectFrame.getAdjustedRight ) &gt;= x1 and 
					(rectFrame.getAdjustedRight) &lt;= x2) then
				_allOtherMachineWorkzones.add(otherMachineWZs);
				continue;	
				
			endif;
			
			if _findRight &lt;&gt; _findLeft then
				if rectFrame.getAdjustedLeft &lt;= x1 and
					rectFrame.getAdjustedRight &gt;= x2 then
					_allOtherMachineWorkzones.add(otherMachineWZs);
				endif;
			endif;
			
		endwhile;
		if otherAreasToCheck.size = 0 then
			break outerLoop;
		else
			areaToCheck:=otherAreasToCheck.first.CM_TerminalAreaMaster;
			iter.reset;
			self.allCMIFMachineWorkzones.startKeyGeq(areaToCheck,null,iter);
			
			otherAreasToCheck.remove(areaToCheck);
		endif;
	endwhile;
	
epilog
	delete iter;
	delete otherAreasToCheck;
end;</source>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_adjustment" type="Real"/>
        <Parameter name="_currentCMIFMachineWorkzone" type="CMIF_MachineWorkzone"/>
        <Parameter name="_allOtherMachineWorkzones" type="ObjectArray" usage="input"/>
        <Parameter name="_findLeft" type="Boolean"/>
        <Parameter name="_findRight" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findWorkzoneXYsForColumns" id="489b4995-1c36-42a2-b93e-2d6a47e9b4ba">
        <source>findWorkzoneXYsForColumns(	_startCol,
							_endCol 	: CM_GridColumn;
							_statsFrame : Frame input;
							_startX,
							_endX,
							_startY, 
							_endY,
							_colX,
							_colY: Real output) protected;
/*

Purpose:	find the XYs for the inputed columns - will be adjusted by rotation		

Parameters:			

Return Value:		


Date		Who		Reason
13 October 2009	cnwer1	Initial creation

*/

vars
	startTA,
	endTa : CM_GridArea;
	taViewPos : CM_TerminalAreaViewPosition;
	theWidth : Real;
begin
	startTA:=_startCol.myGridArea;
	if startTA = null then
		return;
	endif;
	
	taViewPos:=self.myTerminalAreaView.findViewPositionForTA(startTA);//.allTerminalAreaViewPositions.first;
	if taViewPos = null then
		return;
	endif;
	if _endCol &lt;&gt; null then
		endTa:=_endCol.myGridArea;
	else
		endTa:=startTA;
	endif;
	theWidth:= self.getColumnWidthForScale;
	//no rotation
	if taViewPos.rotation = 0 or taViewPos.rotation = 180 then
		_statsFrame.drawTextAlign := Frame.DrawTextAlign_Center;
		
		_startX:=((_startCol.column-1) * (theWidth + self.columnSpacing));
		if _endCol &lt;&gt; null then
			_endX:=((_endCol.column) * (theWidth + self.columnSpacing));
		endif;
		_startY:=0;
		_endY:=_statsFrame.height;
		_colY:=0;
		if not taViewPos.isFlippedHorizontal then
			_colX:=(	_startX + (	theWidth / 2));
			if _endCol = null or _endCol = _startCol then
				_endX:=_startX + theWidth;
			
			endif;
		else
			//flipped horizontally
			_startX:=((startTA.allGridColumns.size )* (theWidth + self.columnSpacing))-_startX;
			if endTa &lt;&gt; null then
				_endX:=((endTa.allGridColumns.size )* (theWidth + self.columnSpacing)) -_endX;
			endif;
			_colX:=(	_startX -(	theWidth / 2));
			if _endCol = null or _endCol = _startCol then
				_endX:=_startX - theWidth;
			endif;
		endif;	
			
			
		
	elseif taViewPos.rotation = 90 or taViewPos.rotation = 270 then
		_statsFrame.drawTextAlign := Frame.DrawTextAlign_Left;
		_startX:=0;
		_colX:=0;
		_endX:=_statsFrame.width;
		_startY:=((_startCol.column-1) * (theWidth +  self.columnSpacing));
		if _endCol &lt;&gt; null then
			_endY:=((_endCol.column) * (theWidth + self.columnSpacing));
		endif;
		
		if not taViewPos.isFlippedVertical  then
			_colY:=(_startY +(theWidth/2));
			if _endCol = null or _endCol = _startCol then
				_endY:=_startY+theWidth;
			endif;
		else
			
			//flipped vertically
			_startY:=((startTA.allGridColumns.size )* (theWidth + self.columnSpacing))-_startY;
			if endTa &lt;&gt; null then
				_endY:=((endTa.allGridColumns.size )* (theWidth + self.columnSpacing)) -_endY;
			endif;
			_colY:=(_startY -(theWidth/2));
			if _endCol = null or _endCol = _startCol then
				_endY:=_startY - theWidth;
			endif;
		endif;
	//	y2:=newFrame.width;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_startCol" type="CM_GridColumn"/>
        <Parameter name="_endCol" type="CM_GridColumn"/>
        <Parameter name="_statsFrame" type="Frame" usage="input"/>
        <Parameter name="_startX" type="Real" usage="output"/>
        <Parameter name="_endX" type="Real" usage="output"/>
        <Parameter name="_startY" type="Real" usage="output"/>
        <Parameter name="_endY" type="Real" usage="output"/>
        <Parameter name="_colX" type="Real" usage="output"/>
        <Parameter name="_colY" type="Real" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getFillColourForRoRoTIs" id="003d8b82-4499-4a1d-bfcc-b02e38e677d9">
        <source>getFillColourForRoRoTIs(_tis : CM_TIArray);
// ---------------------------------------------------------------------------
// Created:		January 2010 By John Knight
//
// Purpose:		CCMS 1018
//
// ---------------------------------------------------------------------------
vars
	viewMode : Integer;
	aTI : CM_TrackedItem;
	tmpColour : Integer;
begin
	viewMode := self.viewMode;
	
	self.allFillColours.clear();
	
	
	
	foreach aTI in _tis do
		if self.viewMode = VIEW_HEIGHT then
			tmpColour := self.myDrawingAttrController.yardStackColours[7];
			self.allFillColours.add(tmpColour);
		else
			tmpColour := self.myDrawingAttrController.getColourForMode(viewMode, aTI, null);
			if self.useSelectorObjects and not self.allSelectorTIs.includes(aTI) then
				tmpColour := White;
			endif;	
			self.allFillColours.add(tmpColour);
		endif;
	endforeach;
end;</source>
        <Parameter name="_tis" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="getFillColourForTIs" id="895cc5be-2395-41dc-b8c2-7b4a127624ee">
        <source>getFillColourForTIs(_tis	: CM_TIArray; _lc : CM_GridController);
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	viewMode : Integer;
	aTI : CM_TrackedItem;
	tmpColour : Integer;
begin
	viewMode := self.viewMode;
	
	self.allFillColours.clear();
	
	if self.viewMode = VIEW_HEIGHT then
		tmpColour := _lc.getStackHeightOfTIsColour();
		if tmpColour &lt;&gt; NullColour then
			tmpColour := self.myDrawingAttrController.yardStackColours[tmpColour];
		endif;
		self.allFillColours.add(tmpColour);
	else
		foreach aTI in _tis do
			tmpColour := self.myDrawingAttrController.getColourForMode(viewMode, aTI, null);
			if self.useSelectorObjects and not self.allSelectorTIs.includes(aTI) then
				tmpColour := White;
			endif;
			
			if not self.allFillColours.includes(tmpColour) then
				self.allFillColours.add(tmpColour);
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="_tis" type="CM_TIArray"/>
        <Parameter name="_lc" type="CM_GridController"/>
    </JadeMethod>
    <JadeMethod name="getForm" id="32e5d014-da1e-45aa-b4d6-f814ef0ff5c0">
