    <JadeMethod name="loadForkLiftStack" id="657ed881-0425-4592-ac64-479bc768de4d">
        <source>loadForkLiftStack(_proxyObject:CM_Object io):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation

*/

vars

	proxyObject: CM_ForkLiftStack;
	error: CM_Error;
	result: Boolean;
	rowIndex, colIndex: Integer;
	gridColumn: CM_GridColumn;
	gridRow: CM_GridRow;
	stackController: CM_StackController;
	yaDeckingOptions: CM_YADeckingOptionsTA;
	controller : CMIF_TerminalArea;
	realObject : CM_TerminalAreaMaster;
begin
	create controller transient;


	result := false;
	proxyObject := _proxyObject.CM_ForkLiftStack;
	/*foreach colIndex in 1 to proxyObject.numberOfColumns do
		create gridColumn transient;
		gridColumn.setForProxy(colIndex, colIndex.stringWithLeadingZeros(2), proxyObject);
	endforeach; 
	foreach rowIndex in 1 to proxyObject.numberOfRows do
		create gridRow transient;
		gridRow.setForProxy(rowIndex, rowIndex.stringWithLeadingZeros(2), proxyObject);
	endforeach; */
	/*foreach rowIndex in 1 to proxyObject.numberOfRows + 1 do
		foreach colIndex in 1 to proxyObject.numberOfColumns + 1  do
			create stackController transient;
			name := rowIndex.stringWithLeadingZeros(2)&amp;colIndex.stringWithLeadingZeros(4);
			/*stackController.setForProxy(PAD_AVAILABLE, 
							NORMAL_USE, 
							rowIndex, 
							colIndex,
							name,
							2,
							true,											
							false,
							null,
							proxyObject, false,null, false, null, false, null);
							stackController.setForProxyGridController(name,proxyObject.allGridColumns[colIndex],proxyObject.allGridRows[rowIndex],2);
			//stackController.setForProxy(PAD_AVAILABLE, NORMAL_USE, rowIndex, colIndex, rowIndex.stringWithLeadingZeros(2)&amp;colIndex.stringWithLeadingZeros(2), 2, true, false, null, proxyObject);
			write name;
		endforeach;
	endforeach;*/
	
	foreach rowIndex in 1 to proxyObject.allGridRows.size do
		gridRow := proxyObject.allGridRows[rowIndex];
		foreach colIndex in 1 to proxyObject.allGridColumns.size do
			gridColumn := proxyObject.allGridColumns[colIndex];
			
			create stackController transient;
			stackController.setForProxy(PAD_AVAILABLE, 
							NORMAL_USE, 
							gridRow.row, 
							gridColumn.column,
							gridRow.label &amp; gridColumn.label,
							2,
							false,											// 21/07/2015 cnwmh5
							false,
							null,
							proxyObject, false,null, false, null, false, null);
	

			stackController.setForProxyGridController(gridRow.label &amp; gridColumn.label, 
								gridColumn,
								gridRow,
								2);

		endforeach;
	endforeach;

	create yaDeckingOptions transient;
	yaDeckingOptions.setProxy(false, true, proxyObject);
	yaDeckingOptions.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	controller.myPxyTerminalAreaMaster := proxyObject;
	app.myTrxCA.trxCreateTerminalArea(proxyObject, realObject,  app.myPassport);
	
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
//		write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" OK";
		result := true;
	else
		foreach error in app.myPassport.allWarnings do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" WARNING: "&amp;error.text;
		endforeach;
		foreach error in app.myPassport.allErrors do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" ERROR: "&amp;error.text;
		endforeach;
	endif;
epilog
	delete controller;
	return result;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyObject" type="CM_Object" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadTerminalAreaView" id="e97de67d-038e-401d-afe2-6dffd43aa78d">
        <source>loadTerminalAreaView(_terminalProxy:CM_Object io) :Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation MTN-36811 - Use Case - Terminal Screen - Satellite View Definition Export/Import

*/

vars
	realObject, proxyObject: CM_TerminalAreaView;
	error: CM_Error;
begin

	proxyObject := _terminalProxy.CM_TerminalAreaView;
	if realObject = null then
		app.myTrxCA.trxCreateTerminalAreaView(proxyObject, realObject, app.myPassport);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.name&amp;" ERROR: "&amp;"Terminal already exists.",0);
		return false;
	endif;
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.name&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.name&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminalProxy" type="CM_Object" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
