    <JadeMethod name="getCCEventProperties" id="fc8bee72-aea7-465d-8c39-21126665ee72">
        <source>getCCEventProperties(ccEvent: CMIF_CCEvent) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 45963

*/

vars

	remarks : String;
	
begin

	remarks := self.getEnquiryRow;

	inheritMethod(ccEvent);
	
	ccEvent.addText( "remarks", remarks ) ;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="ccEvent" type="CMIF_CCEvent"/>
    </JadeMethod>
    <JadeMethod name="getCCEventType" id="b1a6e092-e441-41c1-9aa7-d08c88032611">
