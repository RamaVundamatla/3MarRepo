    <JadeMethod name="tblAddrDetails_dblClick" id="364cfdca-ea62-4758-bccd-8fe066d79dc3">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAddrDetails_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle

*/

vars

begin
	btnAddrSave.enabled := false;
	if table.row &lt;= table.fixedRows then
		table.CM_DataTable.resortTableByColumn(table.column);
		table.accessRow(1).fontBold := false;
		table.accessCell(1,table.column).fontBold := true;
	else
		self.btnAddrUpdate.click(btnAddrUpdate);
	endif;

epilog



end;</source>
        <Parameter name="table" type="Table" usage="input"/>
