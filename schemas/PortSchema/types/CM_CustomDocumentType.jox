    <JadeMethod name="isAdmin" id="d2ef4aab-3f1b-43ac-94b7-81654ab27c7d">
        <source>isAdmin() : Boolean;
/*
Purpose - 	
Who - NAVAB1
Date - 17OCT2023
ADO - CR 60424 TASK 60549 
*/

vars
	custDocType : CM_CustomDocumentType;
begin
	
	custDocType := self;
	
	if custDocType &lt;&gt; null then
		return (custDocType.allStopsToApply.isEmpty() and custDocType.allStopsToClear.isEmpty());
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInward" id="f7a9209a-43c7-40d0-9197-9a12dd4359ce">
        <source>isInward() : Boolean;
/*
Purpose - 	
Who - NAVAB1
Date - 17OCT2023
ADO - CR 60424 TASK 60549 
*/

vars

begin
	if  self.direction = CM_CustomDocumentType.CustDocTypeDir_Inward then
		if self.allStopsToApply.isNotEmpty() then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
