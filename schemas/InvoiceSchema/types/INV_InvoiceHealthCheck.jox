*/

vars

begin
	inheritMethod();
	self.doResizeColumnWidths(self.tblData, true);


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="50a4dad0-49f9-41cb-9391-9db278fb7f05">
        <source>doSelectAll();
/*
Purpose:			
Date		Who		Reason
21 September 2016	cnwab1	Initial creation
*/

vars
	
begin
	if self.fldQuery.topSheet = self.shtQuery1 then
		self.chkItemCalcType.value := not self.chkItemCalcType.value;
		self.chkItemInvLineType.value := self.chkItemCalcType.value;
		self.chkItemInvTypes.value := self.chkItemCalcType.value;
		self.chkItemServices.value := self.chkItemCalcType.value;
		self.chkItemTranMap.value := self.chkItemCalcType.value;
		
		self.chkTypeBank.enabled := self.chkItemCalcType.value;
		self.chkTypeCalcType.enabled := self.chkTypeBank.enabled;
		self.chkTypeGLCode.enabled := self.chkTypeBank.enabled;
		self.chkTypeInvoiceType.enabled := self.chkTypeBank.enabled;
		self.chkTypeMinCharge.enabled := self.chkTypeBank.enabled;
		self.chkTypeService.enabled := self.chkTypeBank.enabled;
		self.chkTypeTax.enabled := self.chkTypeBank.enabled;
		self.chkTypeTransMap.enabled := self.chkTypeBank.enabled;
		self.chkTypeHookQuantity.enabled := self.chkTypeBank.enabled;
		self.chkTypeHookRate.enabled := self.chkTypeBank.enabled;
		self.chkTypeCalendar.enabled := self.chkTypeBank.enabled;
		self.chkTypeMeasure.enabled := self.chkTypeBank.enabled;
		self.chkTypeInvoiceLines.enabled := self.chkTypeBank.enabled;
		self.chkTypeFinancial.enabled := self.chkTypeBank.enabled;
		self.chkTypeTermsTrade.enabled := self.chkTypeBank.enabled;
	elseif self.fldQuery.topSheet = self.shtQuery2 then

	
	
		self.chkTypeBank.value := not self.chkTypeBank.value;
		self.chkTypeCalcType.value := self.chkTypeBank.value;
		self.chkTypeGLCode.value := self.chkTypeBank.value;
		self.chkTypeInvoiceType.value := self.chkTypeBank.value;
		self.chkTypeMinCharge.value := self.chkTypeBank.value;
		self.chkTypeService.value := self.chkTypeBank.value;
		self.chkTypeTax.value := self.chkTypeBank.value;
		self.chkTypeTransMap.value := self.chkTypeBank.value;
		self.chkTypeHookQuantity.value := self.chkTypeBank.value;
		self.chkTypeHookRate.value := self.chkTypeBank.value;
		self.chkTypeCalendar.value := self.chkTypeBank.value;
		self.chkTypeMeasure.value := self.chkTypeBank.value;
		self.chkTypeInvoiceLines.value := self.chkTypeBank.value;
		self.chkTypeFinancial.value := self.chkTypeBank.value;
		self.chkTypeTermsTrade.value := self.chkTypeBank.value;
	elseif self.fldQuery.topSheet = self.shtQuery3 then
		if self.lstTerms.accessCell(1, self.lstTerms.getChkBoxColumn()).text = TableCheckBox_NotSelected then

			self.lstTerms.selectAll();
		else
			self.lstTerms.deselectAll();
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="fda6b3c9-a167-4b38-a70d-718226586495">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*
Purpose:			
Date		Who		Reason
19 October 2016	cnwab1	Initial creation
*/

