    <JadeMethod name="convertToNewStructure_SetLCs" id="e447cb67-0324-4ae2-820e-7efe423edf2e">
        <updating/>
        <source>convertToNewStructure_SetLCs(pTerminalArea : CM_TerminalArea;
							pStartRow, pStartCol, pEndRow, pEndCol : String;
							pControllers : CM_LCArray input) updating;
// ---------------------------------------------------------------------------
// Created:     04 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theTA		: CM_TerminalArea;
	theGridArea	: CM_GridArea;
	lc			: CM_LocationsController;
	yc			: CM_YardController;
	tmpArray		: CM_LCArray;

begin
	exclusiveLock(self);
	theTA := pTerminalArea;
	create tmpArray transient;

/*	theTA.CM_GridArea.getControllersBetweenRowsCols(pStartRow.trimBlanks.toUpper,
													pStartCol.trimBlanks.toUpper,
													pEndRow.trimBlanks.toUpper,
													pEndCol.trimBlanks.toUpper,
													tmpArray);*/
	theGridArea := theTA.CM_GridArea;
	theGridArea.CM_GridArea.getControllersBetweenRowsCols(theGridArea.getRowForLabel(pStartRow),
													theGridArea.getColumnForLabel(pStartCol),
													theGridArea.getRowForLabel(pEndRow),
													theGridArea.getColumnForLabel(pEndCol),
													tmpArray);
	
										
	foreach lc in tmpArray do
		if (not lc.isKindOf(CM_YardController)) then
			continue;
		endif;
		if not pControllers.includes(lc) then
		pControllers.add(lc);
		endif;
	endforeach;

epilog
	delete tmpArray;
	
end;</source>
        <Parameter name="pTerminalArea" type="CM_TerminalArea"/>
        <Parameter name="pStartRow" type="String"/>
        <Parameter name="pStartCol" type="String"/>
        <Parameter name="pEndRow" type="String"/>
        <Parameter name="pEndCol" type="String"/>
        <Parameter name="pControllers" type="CM_LCArray" usage="input"/>
    </JadeMethod>
