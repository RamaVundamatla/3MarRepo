    <JadeMethod name="updateVehiclesUnknownChassis" id="54c4797b-f61a-43fd-8880-f76dd4b0d0f3">
        <source>updateVehiclesUnknownChassis();
/*

Date		Who		Reason
23 August 2013	cnwer1	Initial creation PAR

*/

vars
	vehicle : CM_Vehicle;
	unknownChassis : CM_TILCRow;
begin

	foreach vehicle in CM_Vehicle.instances do
		if vehicle.myUnknownChassis &lt;&gt; null then
			continue;
		endif;
		
		beginTransaction;
			create unknownChassis persistent;
			unknownChassis.setMyVehicle(vehicle);
		
		commitTransaction;
		
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uppercaseVehicleColours" id="f919251f-1fab-4ead-a8c5-6789edf163b6">
        <updating/>
        <source>uppercaseVehicleColours() updating;
//
// Purpose:			Ensure all Vehicle Colour objects have only uppercase "colour" attributes
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/08/2013	cnwdap1		Initial creation PAR #32303
//
vars
	colour 		: CM_VehicleColour;
	toDelete	: ObjectArray;
	dutyDocRoot	: CM_DutyDocRoot;
	upper 		: String;

begin
	app.writeLog( method.qualifiedName &amp; ' Converting all Vehicle Colour codes to UPPERCASE 8.2.2', LogINFO);
	
	create toDelete transient;
	dutyDocRoot := CM_DutyDocRoot.firstInstance;
	if dutyDocRoot = null then
		app.writeLog(method.qualifiedName &amp; ' No Duty Doc Root - aborting Vehicle Colour code conversion', LogINFO);
		return;
	endif;
	
	beginTransaction;
	foreach colour in dutyDocRoot.allVehicleColours do
		if colour.colour.toUpper &lt;&gt; colour.colour then
			upper := colour.colour.toUpper();
			if dutyDocRoot.allVehicleColours[upper] &lt;&gt; null then
				toDelete.add(colour);
			else
				colour.setPropertyValue(CM_VehicleColour::colour.name, upper);
			endif;
		endif;
	endforeach;
	// toDelete contains instances where the colour code was not all upper case, but there was
	// another colour code that was the same upper cased e.g. Red and RED
	// Purge the toDelete array to get rid of these lowercased duplicates
	toDelete.purge;
	commitTransaction;

	app.writeLog( method.qualifiedName &amp; 'Finished converting all Vehicle Colour codes to UPPERCASE 8.2.2', LogINFO);
epilog
	delete toDelete;
end;</source>
    </JadeMethod>
</Class>
