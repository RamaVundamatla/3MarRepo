    <JadeMethod name="isDirectionDifferent" id="898e64a3-0986-4d0e-9ce3-5622d70e05a8">
        <source>isDirectionDifferent(_other : CM_GateLaneController) : Boolean;
// ---------------------------------------------------------------------------
// Created:	23 May 2008 By Graeme Black cnwgb1 PAR 16483
// ---------------------------------------------------------------------------
vars
begin
	if _other.isUnavailable &lt;&gt; self.isUnavailable or
	   _other.laneDirection &lt;&gt; self.laneDirection then
		return true;
	else
		return false;
	endif;
end;</source>
        <Parameter name="_other" type="CM_GateLaneController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="performLaneDirectionChange" id="6d610a90-061a-490b-98ca-c56cc044212f">
        <updating/>
        <source>performLaneDirectionChange( _proxyGLC : CM_GateLaneController) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:	18 May 2008 By Graeme Black cnwgb1 PAR 16483
// In transaction state, update GLC direction if necessary
// ---------------------------------------------------------------------------
vars
	different : Boolean;
begin
	different := self.isDirectionDifferent(_proxyGLC);
	if different then
		// Something to do
		if self.allVehicleMachines.isEmpty then
			self.vehicleDirection := _proxyGLC.laneDirection;
		endif;
		self.laneDirection := _proxyGLC.laneDirection;
		self.isUnavailable := _proxyGLC.isUnavailable;
	endif;
	return different;
end;</source>
        <Parameter name="_proxyGLC" type="CM_GateLaneController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="b9afd0cf-f3be-400c-8f72-ce11ef0406aa">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			


Return Value:		


Date			Who		Reason
07 August 2006	cnwer1	Initial creation - PAR#xxxx
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/
vars
	pxyGLC : CM_GateLaneController;
	pxyRFIDTag :CM_RFIDTagReader;
	completedOK		: Boolean;
begin
	
	pxyGLC:= inheritMethod();
	
	if self.myRFIDTagReader &lt;&gt; null then
		pxyRFIDTag:=self.myRFIDTagReader.pxyCreateUpdateProxy;
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyGLC;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyGLC;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="resetLaneDirection" id="bb1334f0-7474-437b-a6df-facaa8e4b8c1">
        <updating/>
        <source>resetLaneDirection() updating;
// ---------------------------------------------------------------------------
// Created:	19 May 2008 By Graeme Black cnwgb1 PAR 16483
// When a vehicle leaves a gate lane, check that the lane direction hasn't been changed
// ---------------------------------------------------------------------------
vars
begin
	// Only within Transaction state, on persistent object
	if  self.laneDirection &lt;&gt; self.vehicleDirection and self.allVehicleMachines.size = 1 then
		self.vehicleDirection := self.laneDirection;
		self.myLaneVTA.causeEvent(self.myTerminal.getTerminalEvent(Event_GateLane_Change), false, self.myLaneVTA);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="60e4df6d-1ca7-4430-a7da-d9d612b57c99">
        <updating/>
        <source>setForCreate(pProxy: CM_GateLaneController; pTerminalArea: CM_TerminalArea) updating;
/*

Purpose:			


Return Value:		


Date			Who		Reason
02 August 2006	cnwer1	Initial creation - PAR#xxxx
23/06/2009		concms1	ccms 1061 - change method signature

*/
vars

begin
	inheritMethod(pProxy, pTerminalArea);
	
	self.setID(pProxy.ident);
	self.setIsUnavailable(pProxy.isUnavailable);
	self.laneDirection := pProxy.laneDirection; 	//cnwgb1 16 May 2008 Par 16483
	self.vehicleDirection := pProxy.laneDirection; 	//Deliberate - not typo cnwgb1 16 May 2008 Par 16483
	
	if pTerminalArea.isKindOf (CM_VehicleTransferArea) then			// ccms 1061
		self.setMyLaneVTA(pTerminalArea.CM_VehicleTransferArea);	// ccms 1061
	endif;															// ccms 1061
	
	self.myPrinter := pProxy.myPrinter;
	self.boomPortNo := pProxy.boomPortNo;
	self.boomMachineName := pProxy.boomMachineName;
	
epilog

end;</source>
        <Parameter name="pProxy" type="CM_GateLaneController"/>
        <Parameter name="pTerminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7d578513-d0e5-441e-9434-decd8fae5606">
        <updating/>
        <source>setForUpdate(pProxy: CM_GateLaneController; pTerminalArea: CM_TerminalArea) updating;
/*

Purpose:			


Return Value:		


Date			Who		Reason
02 August 2006	cnwer1	Initial creation - PAR#xxxx
26 June 2009	concms1	ccms 1061 - gate config changes
*/
vars

begin
	inheritMethod(pProxy, pTerminalArea);

	// ccms 1016 - move to superclass along with properties
	self.setID(pProxy.ident);
	
	self.setIsUnavailable(pProxy.isUnavailable);
	self.laneDirection := pProxy.laneDirection; //cnwgb1 16 May 2008 Par 16483...
	
	if self.allVehicleMachines.isEmpty then
		self.vehicleDirection := pProxy.laneDirection;
	endif;										//cnwgb1 16 May 2008 Par 16483...
	
	self.setMyLaneVTA(pTerminalArea.CM_VehicleTransferArea);	// ccms 1061
	self.myPrinter := pProxy.myPrinter;
	self.boomPortNo := pProxy.boomPortNo;
	self.boomMachineName := pProxy.boomMachineName;
	
epilog

end;</source>
        <Parameter name="pProxy" type="CM_GateLaneController"/>
        <Parameter name="pTerminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="setGateLaneProxy" id="dcac4e65-8629-4add-bfb0-a066b9cd5f1a">
        <updating/>
        <source>setGateLaneProxy(_id		: String;
				_isUnavailable : Boolean;
				_laneDirection : Integer;
				_printer 		: CM_PrinterDef;
				_port 		: Integer;
				_machineName : String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	27 February 2007 By cnwth2

Purpose:	_machineName used to open connection - so can be IP or named pipe.

Note:		vehicleDirection not updated here. Transaction layer works this out

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.ident 			:= _id;
	self.isUnavailable 	:= _isUnavailable; 
	self.laneDirection  := _laneDirection; //cnwgb1 16 May 2008 Par 16483
	self.myPrinter		:= _printer;
	self.boomPortNo 	:= _port;
	self.boomMachineName := _machineName;
end;


</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isUnavailable" type="Boolean"/>
        <Parameter name="_laneDirection" type="Integer"/>
        <Parameter name="_printer" type="CM_PrinterDef"/>
        <Parameter name="_port" type="Integer"/>
        <Parameter name="_machineName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setGateLaneProxyDirection" id="07503f4e-9903-47c5-8ab2-1a3943035260">
        <updating/>
        <source>setGateLaneProxyDirection( _isUnavailable : Boolean; _laneDirection : Integer) updating;
// ---------------------------------------------------------------------------
// Created:	16 May 2008 By Graeme Black cnwgb1 PAR 16483
// Updates just the direction part of the proxy, vehicleDirection is determined
// by the Create/Update agents
// ---------------------------------------------------------------------------
vars

begin
	self.isUnavailable 	:= _isUnavailable; 
	self.laneDirection  := _laneDirection;
end;
</source>
        <Parameter name="_isUnavailable" type="Boolean"/>
        <Parameter name="_laneDirection" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setIsUnavailable" id="e2846a5a-8d91-47cf-abc3-055d4067e21d">
        <updating/>
        <source>setIsUnavailable(_value : Boolean) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.isUnavailable &lt;&gt; _value then
		self.isUnavailable:=_value;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyLaneVTA" id="dce325aa-86a9-4745-bb13-6a351519f6ce">
        <updating/>
        <source>setMyLaneVTA(_myVTA : CM_VehicleTransferArea) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.myLaneVTA &lt;&gt; _myVTA then
		self.myLaneVTA:=_myVTA;
	endif;

epilog

end;</source>
        <Parameter name="_myVTA" type="CM_VehicleTransferArea"/>
    </JadeMethod>
    <JadeMethod name="upgradeToFlexible" id="ea539948-ac3d-4497-b414-83340857c1ca">
        <updating/>
        <source>upgradeToFlexible() updating;
// ---------------------------------------------------------------------------
// Created:	23 May 2008 By Graeme Black cnwgb1 PAR 16483
// Only called from upgrade JadeScript 
// Gdansk had lanes 1-4 hardcoded as In, 5-8 as out
// ---------------------------------------------------------------------------
vars
begin
	if self.isUnavailable then
		self.laneDirection := CM_GateLaneController.Undecided;
		self.vehicleDirection := CM_GateLaneController.Undecided;
	else
		if self.ident = "1" or self.ident = "2" or self.ident = "3" or self.ident = "4" then
			self.laneDirection := CM_GateLaneController.InLane;
			self.vehicleDirection := CM_GateLaneController.InLane;
		elseif self.ident = "5" or self.ident = "6" or self.ident = "7" or self.ident = "8" then
			self.laneDirection := CM_GateLaneController.OutLane;
			self.vehicleDirection := CM_GateLaneController.OutLane;
		else
			self.laneDirection := CM_GateLaneController.Undecided;
			self.vehicleDirection := CM_GateLaneController.Undecided;
			self.isUnavailable := true;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="b957f1d1-7cf6-4f3a-b3c3-4fc0e395fd22">
        <source>validateForDelete();
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.allVehicleMachines.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, "Gate Lane " &amp; self.ident, "Vehicles", null, null);
	endif;


epilog

end;</source>
    </JadeMethod>
</Class>
