    <JadeMethod name="getObjects" id="6381662d-88c3-4f8b-86ff-1622769e6833">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 June 2022	navgm20	 53195: EUP - GEN/REP/INB - Additional Cargo Field ľ Shipping Line - Portschema
*/

// Return a dict of objects for this criteria type
vars
	shippingLine: CM_ShippingLine;
begin
	foreach shippingLine in app.myRoot.allShippingLines do
		objects[shippingLine.getYAIdentifier] := shippingLine;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
