    <DbClassMap file="unitTest"/>
    <JadeMethod name="uCompleteRoadJob" id="85211103-2555-4451-a970-4d16b1b28fd3">
        <source>uCompleteRoadJob();
//17 August 2009	cnwdw1	
//
vars
	oid: String;
	roadJob: CM_RoadJob;
	wle: CM_WorkListEntry;
begin
	oid := "2274.";
	read oid;
	roadJob := oid.asOid.CM_RoadJob;
	if roadJob &lt;&gt; null then
		beginTransaction;
			foreach wle in roadJob.workListEntries do
				wle.setStatus(WLE_COMPLETED);
			endforeach;
			roadJob.changeStatus(JOB_COMPLETE);
		commitTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="uDelRTQTaskInvalidSrcTrgLoc" id="6f2ebaae-0373-4efb-9219-dbf4c3aeaa7a">
        <source>uDelRTQTaskInvalidSrcTrgLoc();

/*

Purpose:		Read through CM_RTQueueTask and zap any which have invalid source/target locations	

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2010	cnwmh5	Initial creation

*/

vars

	rtqTask			: CM_RTQueueTask;
	
	invalidSource	: Boolean;
	invalidTarget	: Boolean;
	
begin
	
	foreach rtqTask in CM_RTQueueTask.instances discreteLock do
		
		invalidSource := (rtqTask.sourceLocation &lt;&gt; null and not global.isValidObject(rtqTask.sourceLocation));
		invalidTarget := (rtqTask.targetLocation &lt;&gt; null and not global.isValidObject(rtqTask.targetLocation));
	
		// either invalid then get rid of the task
		if invalidSource or invalidTarget then
			self.zapQueueTask(rtqTask);
		endif;
	
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uDeleteAllVehicles" id="979cdd99-4486-4fed-aede-e74e93698962">
        <source>uDeleteAllVehicles();
//17 August 2009	cnwdw1	
//
vars
	vehicle: CM_Vehicle;
begin
	foreach vehicle in self.getTerminal.vehicles do
		self.deleteVehicle(vehicle.code);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="uFixupCargoStuckOnMachine" id="57f2a914-eea2-43b3-b3dd-014a35fe9197">
        <source>uFixupCargoStuckOnMachine();
//17 August 2009	cnwdw1	
//
vars
	machineName: String;
	machine: CM_Machine;
	ti: CM_TrackedItem;
	obj: Object;
	reference: String;
	
begin
	read machineName;
	machine := self.getRoot.allMachines[machineName, self.getTerminal];
	if machine &lt;&gt; null then
		foreach ti in machine.getMyVehicleMachineController.allTrackedItems do
//			if ti.state = TI_STATE_MERGED then
				beginTransaction;
					ti.setPropertyValue("state", TI_STATE_NORMAL);
					ti.setPropertyValue("site", TI_SITE_ONSITE);
				commitTransaction;
//			endif;	
		endforeach;
	endif;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="uFixupDeleteObject" id="42930c36-ac00-422b-b085-dda5ad935d7c">
        <source>uFixupDeleteObject();
//17 August 2009	cnwdw1	
//
vars
	oid: String;
	obj: Object;
	reference: String;
begin
	read oid;
	obj := oid.asOid;
	if obj &lt;&gt; null then
		read reference;
		beginTransaction;
		obj.setPropertyValue(reference, null);
		obj.inspectModal;
		commitTransaction;
	endif;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="uFixupObjectArrays" id="8e7bcfc0-f0ef-4b23-8ce4-04d2f755d2d5">
        <source>uFixupObjectArrays();
/*
Purpose:			
	Rebuild all object arrays in a specified object
Parameters:			

Return Value:		

Date		Who		Reason
01 October 2012	cnwdw1	Initial creation
*/
vars
	oid: String;
	obj: Object;
	prop: Property;
	propColl: PropertyColl;
	propValue: Any;
	type: Type;
begin
	oid := "Enter OID of obj to rebuild";
	read oid;
	
	obj := oid.asOid;
	propColl := obj.class.allProperties();
	foreach prop in propColl do
		self.logMessageNow("Property " &amp; prop.name &amp; " " &amp; prop.getType.String);
		type := prop.getType();
		if type.inheritsFrom(ObjectArray) then
			beginTransaction;
				propValue := obj.getPropertyValue(prop.name);
				self.logMessageNow("Remove invalid objects for " &amp; prop.name &amp; " " &amp; propValue.String);
				propValue.ObjectArray.sendMsg("removeInvalidObjects");
			commitTransaction;
		endif;
	endforeach;

epilog
	delete propColl;
	abortTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="uFixupSwapConfig" id="c2b9811a-9917-4ed1-b731-e290af30b40d">
        <source>uFixupSwapConfig();

vars
	terminal: CM_Terminal;
begin
	foreach terminal in self.getRoot.allTerminals do
		if terminal.isAutoPlanGenSwapForYardInt() then
			self.logMessage("Terminal " &amp; terminal.code &amp; " has AutoPlanGenSwapForYardInt set to true");
			beginTransaction;
				terminal.setConfig(AutoPlanGenerateSwapForYardInt, false);
			commitTransaction;
		endif;	
		if terminal.isAutoPlanGenerateSwapJob() then
			self.logMessage("Terminal " &amp; terminal.code &amp; " has AutoPlanGenerateSwapJob set to true");
			beginTransaction;
				terminal.setConfig(AutoPlanGenerateSwapJob, false);
			commitTransaction;
		endif;	
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uFixupTrackedItem" id="9f264574-f69c-4a3c-b1f2-d957abf352a4">
        <source>uFixupTrackedItem();
//07 January 2011	cnwdw1	
// Fixup various problems with a tracked item
vars
	id: String;
	fixup: String;
	ti, parent: CM_TrackedItem;
begin
	id := "Enter Tacked Item Id";
	read id;
	ti := self.getTrackedItem(id);
	if ti = null then
		// try oid based lookup
		ti := id.asOid.CM_TrackedItem;
	endif;
	if ti &lt;&gt; null then
		fixup := "Enter Y to fixup problems";
		read fixup;
		// Fixup Already Queued errors 
		if ti.allQueues.size &gt; 0 and not ti.isQueued then
			self.logMessage("TI is not queued, but has entries in allQueues");
			if fixup.toUpper = "Y" then
				beginTransaction;
					ti.allQueues.clear;
					self.logMessage("TI allQueues has been cleared");
				commitTransaction;
			endif;
		endif;	
		if ti.allQueues.size = 0 and ti.isQueued then
			self.logMessage("TI is queued, but has no entries in allQueues");
			if fixup.toUpper = "Y" then
				beginTransaction;
					ti.setPropertyValue(CM_TrackedItem::myPrimaryQueuedLocation.name, null);
					self.logMessage("TI myPrimaryQueuedLocation has been cleared");
				commitTransaction;
			endif;
		endif;
		if ti.isChild then
			if fixup.toUpper = "Y" then
				beginTransaction;
				// Child uses the parent queued location, but could still have a 
				// an invalid queue location in its queued location (myPrimaryQueuedLocation is mapped)
				parent := ti.myParent;
				ti.setPropertyValue(CM_TrackedItem::myParent.name, null);
				if ti.allQueues.size = 0 and ti.isQueued then
					ti.setPropertyValue(CM_TrackedItem::myPrimaryQueuedLocation.name, null);
					self.logMessage("TI myPrimaryQueuedLocation has been cleared");
					ti.setPropertyValue(CM_TrackedItem::myParent.name, parent);
					commitTransaction;	
				else
					abortTransaction;
				endif;
			endif;
		endif;
		if ti.hasBeenMerged then
			if fixup.toUpper = "Y" then
				beginTransaction;
					ti.nullAllVoyageRefs;
					self.logMessage("TI " &amp; ti.id &amp; " voyage refs have been nulled");
				commitTransaction;	
			endif;
		endif;
					
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="uFixupTrackedItems" id="c4571243-6dc0-4abf-ab7c-58ef63c3886d">
        <source>uFixupTrackedItems();
// cnwndl1

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 March 2011	cnwndl1	Initial creation

*/

vars
	terminalCode: String;
	terminal: CM_Terminal;
	doFixup: Boolean;
	bad,
	oa : ObjectArray;
	ti : CM_TrackedItem;
	obj : Object;
	iter : Iterator;
	str : String;
	
begin

	terminalCode := "Enter Terminal Code";
	read terminalCode;
	terminal := self.getRoot.allTerminals[terminalCode];
	if terminal = null then
		return;
	endif;

	doFixup := false;
	read doFixup;
	
	create oa transient;
	create bad transient;
	
	CM_TrackedItem.allInstances(oa, 0, true);
	iter := oa.createIterator;
	while iter.next(ti) do
		if ti.myTerminal &lt;&gt; terminal then
			continue;
		endif;
		
		if ti.myCargoType = null then
			bad.add(ti);
			self.logMessage("Invalid CargoType " &amp; ti.myTerminal.code &amp; " / " &amp; ti.String &amp; " / " &amp; ti.id &amp; " / " &amp; ti.createdTime.asStringJMT);
			continue;
		endif;
		
		if not ti.myCargoType.isAllowDuplicates then
			if ti.totalQuantity &gt; 1 then
				bad.add(ti);
				self.logMessage("Invalid Total Quantity for GC " &amp; ti.myTerminal.code &amp; " / " &amp; ti.String &amp; " / " &amp; ti.id &amp; " / " &amp; ti.createdTime.asStringJMT);
				if doFixup then
					beginTransaction;
						ti.setTotalQuantity(1);
						self.logMessage("   Fixed: Set totalQuantity to 1");
					commitTransaction;
				endif;
			endif;
		endif;
		
		if ti.myVoyage &lt;&gt; null and ti.myVoyage.isNullVoyage and ti.voyageCode &lt;&gt; null then
			self.logMessage("myVoyage null but voyage code = " &amp; ti.voyageCode &amp; " / " &amp; ti.String &amp; " / " &amp; ti.id &amp; " / " &amp; ti.createdTime.asStringJMT);
			if doFixup then
				beginTransaction;
					ti.setVoyageCode(null, app.myPassport);
					self.logMessage("   Fixed: Set voyageCode to null");
				commitTransaction;
			endif;
		endif;
			
	endwhile;

	self.assertEqualMsg(bad.size, 0, "Number of Invalid Tis: " &amp; bad.size.String);
	
epilog

	delete oa;
	delete bad;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="uFixupVoyageRotations" id="95e41b55-08fc-49c8-ba98-3175c6c7456c">
        <source>uFixupVoyageRotations();
// cnwdw1

vars
	iter : Iterator;
	
	voyage : CM_Voyage;
	breakVoyage : Boolean;
	
	term : CM_Terminal;
	currentVoyages : CM_VoyageSet;

	portRotation: CM_PortRotation;
	portRotationsInError: CM_PortRotationArray;
	
	str: String;

begin

	create currentVoyages transient;
	create portRotationsInError transient;
	
	// get a collection of the the current voyages first	
	foreach term in app.myRoot.allTerminals discreteLock do
		iter := term.allVoyagesNew.createIterator();
		while iter.next(voyage) do
			if voyage.isNullVoyage then
				continue;
			endif;
			if voyage.displayOption = VoyageDisplayNever then
				continue;
			endif;
			if voyage.isCancelled then  //jlier1 TFS51963 5/10/21
				continue;
			endif;
			if voyage.archived or voyage.myTerminalArchived &lt;&gt; null then
				continue;
			endif;
			if not currentVoyages.includes(voyage) then
				currentVoyages.add(voyage);
			endif;
		endwhile;
		delete iter;
	endforeach;
	
	// iterate thru the current voyages finding those with bad slots
	foreach voyage in currentVoyages discreteLock do 
	
		//Check for null entries ibn Port Rotation
		foreach portRotation in voyage.allPortRotations do
			if portRotation.myPort = null and portRotation.myTrade = null then
				str := str &amp; "Voyage " &amp; voyage.code &amp; " has null port and trade in rotation" &amp; CrLf;
				portRotationsInError.add(portRotation);
			endif;
		endforeach;

		if portRotationsInError.size &gt; 0 then
			beginTransaction;
				str := str &amp; "Purged " &amp; portRotationsInError.size.String &amp; " Port Rotations" &amp;CrLf;
				portRotationsInError.purge();
			commitTransaction;
		endif;
		
	endforeach; 


	self.assertTrueMsg( str = null, str );

epilog

	delete iter;
	delete currentVoyages;
	delete portRotationsInError;

end;</source>
    </JadeMethod>
    <JadeMethod name="uFixupWagons" id="25170eee-a0a9-4c68-ae16-7872e8f5a232">
        <source>uFixupWagons();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2012	cnwdw1	Initial creation
*/
vars
	objArray: ObjectArray;
	obj: Object;
begin
	create objArray transient;
	CM_Wagon.allInstances(objArray, 0, false);
	foreach obj in objArray do
		beginTransaction;
			obj.CM_Wagon.allTIsReleased.rebuild;
			obj.CM_Wagon.allTIsReceived.rebuild;
		commitTransaction;
	endforeach;
epilog
	delete objArray;
end;</source>
    </JadeMethod>
</Class>
