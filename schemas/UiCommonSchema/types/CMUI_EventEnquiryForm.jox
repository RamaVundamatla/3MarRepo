    <JadeMethod name="sysNotify" id="22ea3336-8036-4c4a-a695-a63e9d570c4b">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	26 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if (eventType = Object_Create_Event) and 
	   (CM_EventTransaction.hasInstance(theObject)) then
		self.handleEventNotification(eventType, theObject.CM_EventTransaction, eventTag);
	endif;
	
	inheritMethod(eventType, theObject, eventTag);
end;

