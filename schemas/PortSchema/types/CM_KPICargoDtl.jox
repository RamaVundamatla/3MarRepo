<Class name="CM_KPICargoDtl" id="7809e34e-2dae-4c00-9733-164e0ba3ceca">
    <superclass name="CM_KPIDtlEntity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="statistic"/>
    <PrimAttribute name="containerLength" id="5178fd01-0a69-4392-bfb0-d5b88aca9d70">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myKPICargoEntity" id="6fbd1a29-40ea-45eb-8d38-63c2a084c92d">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_KPICargoEntity"/>
        <access>readonly</access>
        <Inverse name="CM_KPICargoEntity::allKPICargoDetails"/>
    </ExplicitInverseRef>
    <PrimAttribute name="totalItems" id="2ed8e981-29e0-4fe2-a234-25cdfcc3aaf2">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="totalQty" id="163c8bbf-5e91-47c8-adeb-489cc9e8c64a">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="totalTEU" id="7c9a8d18-f71a-4c3e-b07b-f0dc80bb04b5">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="totalVolume" id="f483124f-9d3a-401a-9385-b3d48914a3d0">
        <precision>12</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="totalWeight" id="656834f5-99b1-48cd-93d8-0f0e2602eec2">
        <precision>12</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addTrackedItem" id="637635e8-b1bb-45e5-894b-0e54f8d25597">
        <updating/>
        <source>addTrackedItem(_ti : CM_TrackedItem) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/09/2010	cnwdap1	Initial creation PAR #25163 CCMS SFW 1108
*/
vars

begin
	self.totalItems 		:= self.totalItems + 1;
	
	if CM_Container.hasInstance(_ti) then
		self.totalTEU 		:= self.totalTEU + _ti.getNumTEU.Integer;
	else
		self.totalQty 		:= self.totalQty + _ti.totalQuantity;
		self.totalVolume 	:= self.totalVolume + _ti.getMyCargoVolume;
		self.totalWeight 	:= self.totalWeight + _ti.totalWeight;
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c05c83ad-4564-4c1a-922a-b2c703290ca9">
        <updating/>
        <source>setForCreate(_kpiEntity : CM_KPICargoEntity; _length : Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/09/2010	cnwdap1	Initial creation PAR #25163 CCMS SFW 1108
*/
vars

begin
	self.containerLength	:= _length;
	self.myKPICargoEntity	:= _kpiEntity;
epilog

end;</source>
        <Parameter name="_kpiEntity" type="CM_KPICargoEntity"/>
        <Parameter name="_length" type="Integer"/>
    </JadeMethod>
</Class>
