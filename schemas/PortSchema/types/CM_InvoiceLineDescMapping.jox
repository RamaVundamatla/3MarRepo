    <JadeMethod name="getAuditText" id="08d9206b-9d34-4e0c-9b5b-d16e01eb9423">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/


vars
	txt,
	tmpStr	: String;

begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	

		
	if self.myInvoiceLineDesc &lt;&gt; null then
		tmpStr :=self.myInvoiceLineDesc.narration&amp;" "&amp; tmpStr ;
		txt := txt &amp; app.getErrorString(Invoice_line) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myInvoiceType &lt;&gt; null then
		tmpStr :=self.myInvoiceType.description&amp;" "&amp; tmpStr ;
		txt := txt &amp; app.getErrorString(Invoice_type) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
	

epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDebtorString" id="3b4fcdd2-27b9-4622-b7f8-f0c5a6ac0c59">
        <source>getDebtorString() : String;

vars

