    <JadeMethod name="getDestinationPortCode" id="5a7c6c36-d536-47af-af73-bfc616052c1a">
        <source>getDestinationPortCode() :String;
/* ---------------------------------------------------------------------------
Created:     15 June 2010 by cnwrs2

Purpose:     PAR24435 - SQL data export
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	
begin
	
	if self.myOriginPort &lt;&gt; null then
		return self.myOriginPort.code;
