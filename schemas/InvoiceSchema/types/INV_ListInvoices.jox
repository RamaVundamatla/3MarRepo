    <JadeMethod name="doMnuSendToReportInvoice" id="948b8616-2966-4b8f-86fa-ad2ad0e9b7be">
        <updating/>
        <source>doMnuSendToReportInvoice(_selectedOnly : Boolean) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		14 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// Note: The menu items for this have been implemented on CMUI_QueryEnquiry for historical reasons.
//       CMUI_QueryEnquiry contains a lot of context menu items that have implemented on lower schemas.
//		 Don't have time within this CCMS to investigate the correct design so have stuck with existing methodologies.
//----------------------------------------------------------------------
vars
	objArray : ObjectArray;
begin
	inheritMethod(_selectedOnly);
	
	// Report writer throws exceptions when in transaction state.
	// Added flag to app to ignore any transaction calls that are not in 
	// the trx layer (Eg, CM_Charge.evaluateRate).
	app.isReportWriter := true;
	
	create objArray transient;
	
	self.getInvoicesForReport(objArray, _selectedOnly);
	
	self.doSendToReport(objArray);
epilog
	delete objArray;
	app.isReportWriter := false;
end;</source>
        <Parameter name="_selectedOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMoveInvoiceLines" id="8821c56c-97df-4eaf-85d9-854f302a90ec">
        <updating/>
        <source>doMoveInvoiceLines(table: Table input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	object		: Object;
	theController : CMIF_InvoiceLineMove;
	theForm : INV_ListLines;
	theReturn : Integer;
begin

	if win.isKindOf(INV_ListLines) then
		theForm := win.INV_ListLines;
		create theController transient;
		// table now includes CM_CashPayment as well - just copy the CM_InvoiceLines
		///theForm.tblData.allSelectedObjects.copy(theController.allInvoiceLines);
		foreach object in theForm.tblData.allSelectedObjects do
			if object.isKindOf(CM_InvoiceLine) then
				theController.allInvoiceLines.add(object.CM_InvoiceLine);
			endif;
		endforeach;
		
		if not theController.allInvoiceLines.isEmpty then
			theController.myInvoice := self.myCurrentInvoice;
			
			while true do
				app.myTrxUA.trxUpdateInvoiceLineMove(theController, app.myPassport);
				if app.myPassport.trxCompletedOK then
					// Clear errors/warnings from form and err/warnings window
					self.clearErrorWarnings();
					global.beep;
					break;
				else
					theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Invoice_Line_Move), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors 
					and theReturn = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
					return;
				endif;
				break;
			endwhile;
		endif;
	endif;	
epilog
	delete theController;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="ee71cc97-8a69-45cd-90bd-b59a1df8c21f">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		if anObject.isKindOf(CM_Invoice) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(Event_InvoiceLineUpdate));
			removedNotification := removedNotification + 1;
		endif;
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNoteHandlingObject" id="0e0a460c-2efd-46bd-b74c-52c2cb898604">
        <updating/>
        <source>doNoteHandlingObject(_notificationRecord: CMIF_NotificationRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2025	jlier1	Initial creation MTN-34725

*/

vars
	object : Object;
	eventType,
	eventTag,
	termEvent		: Integer;
	userInfo 			: Any;
	invalid : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, object, invalid);

	object := _notificationRecord.myObject;
	eventType := _notificationRecord.eventType;
	eventTag := _notificationRecord.eventTag;
	userInfo := _notificationRecord.myUserInfo;
	
	// Get Terminal Event
	if self.myTerminal &lt;&gt; null then
		termEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	endif;
	
	self.userNotificationUpdate(termEvent,object.CM_Object,userInfo.CM_Object);
epilog

end;</source>
        <Parameter name="_notificationRecord" type="CMIF_NotificationRecord"/>
    </JadeMethod>
