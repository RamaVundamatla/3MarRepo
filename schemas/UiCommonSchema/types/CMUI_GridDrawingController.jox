    <JadeMethod name="getAllSelectedTIs" id="d06a5cfa-1a63-4dba-8005-4c50398766ac">
        <updating/>
        <source>getAllSelectedTIs(_tis : CM_TIArray input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
begin
	if _tis = null then
		return;
	endif;
	
	foreach anObject in self.allSelectedObjects discreteLock do
		if anObject.isKindOf(CM_TrackedItem) then
			_tis.add(anObject.CM_TrackedItem);
		endif;
	endforeach;
end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAttrXYforPosition" id="b3b87927-6021-4112-9f6b-5fb40a947990">
        <source>getAttrXYforPosition(_position : Integer; _x, _y : Real output) protected;
// ---------------------------------------------------------------------------
// Created:     12 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _position = 1 then
		_x := self.attrX1;
		_y := self.attrY1;
	elseif _position = 2 then
		_x := self.attrX2;
		_y := self.attrY2;
	elseif _position = 3 then
		_x := self.attrX3;
		_y := self.attrY3;
	elseif _position = 4 then
		_x := self.attrX4;
		_y := self.attrY4;
	elseif _position = 5 then
		_x := self.attrX5;
		_y := self.attrY5;
	elseif _position = 6 then
		_x := self.attrX6;
		_y := self.attrY6;
	elseif _position = 7 then
		_x := self.attrX7;
		_y := self.attrY7;
	elseif _position = 8 then
		_x := self.attrX8;
		_y := self.attrY8;
	elseif _position = 9 then
		_x := self.attrX9;
		_y := self.attrY9;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Position outside range (' &amp; _position.String &amp; ')');
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_position" type="Integer"/>
        <Parameter name="_x" type="Real" usage="output"/>
        <Parameter name="_y" type="Real" usage="output"/>
    </JadeMethod>
