    </PrimAttribute>
    <JadeMethod name="getDateFromLocalTZ" id="47fda1a0-eee9-401b-9fb7-657793afef77">
        <source>getDateFromLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2016	cnwns1	Initial creation
// 01 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.dateFrom);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDateToLocalTZ" id="46edb940-f030-4a0a-bfda-d19e1d1a1b41">
        <source>getDateToLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2016	cnwns1	Initial creation
// 01 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.dateTo);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="841c5b50-000f-4d05-929e-7eba75c0344a">
        <source>noOutputReturned(): Boolean;
//----------------------------------------------------------------
//	Created:	18 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.allMovements.isEmpty then
		return true;
	endif;
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
