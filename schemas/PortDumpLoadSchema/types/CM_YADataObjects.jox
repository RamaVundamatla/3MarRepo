<Class name="CM_YADataObjects">
    <JadeMethod name="exportPDXMLMyCollections" id="073e6cef-a89c-4b7e-b6ce-aa837b912c64">
        <source>exportPDXMLMyCollections(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars
	obj: Object;
begin
	if _property.name = CM_YADataObjects::allObjects.name then
		_file.writeLine('&lt;'&amp;CM_YADataObjects::allObjects.name&amp;'&gt;');
		foreach obj in self.allObjects do
			_file.writeLine('&lt;class&gt;' &amp; obj.class.name &amp; '&lt;/class&gt;');
			_file.writeLine('&lt;theKey&gt;' &amp; obj.CM_Object.theKey &amp; '&lt;/theKey&gt;');
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_YADataObjects::allObjects.name&amp;'&gt;');
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLCollections" id="e7bfb4ca-f826-421a-88dd-87de80f91b9e">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);

vars
	objArray: ObjectArray;
	object: Object;
	aClass: Class;
	objBlock, nameBlock, theCode, theKey: String;
	blockLength, pos: Integer;
begin
	create objArray transient;
	if _name = CM_YADataObjects::allObjects.name then
		objBlock := _collectionsBlock.cnEcGetTagValueOfName(CM_YADataObjects::allObjects.name);
		if objBlock = null then
			return;
		endif;
		pos := 1;
		blockLength := objBlock.length;
		while pos &lt; blockLength do
			theCode := objBlock.cnEcGetNextTagValueOfName('class', pos);
			if pos &lt; 1 then
				break;
			endif;
			theKey := objBlock.cnEcGetNextTagValueOfName('theKey', pos);
			
			if theCode = null then
				continue;
			endif;
			aClass := currentSchema.getClass(theCode);
			if aClass &lt;&gt; null then
				objArray.clear();
				aClass.allInstances(objArray, 0, false);
				foreach object in objArray do
					if object.theKey = theKey then
						self.allObjects.add(object);
					endif;				
				endforeach;
			endif;
		endwhile;
	endif;
epilog
	delete objArray;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLMyCollectionsOld" id="b6bc276e-96e5-4115-a307-89a0e4ce3986">
        <updating/>
        <source>importPLXMLMyCollectionsOld(_collectionsBlock: String) updating;

vars
	objArray: ObjectArray;
	object: Object;
	aClass: Class;
	objBlock, nameBlock, theCode, theKey: String;
	blockLength, pos: Integer;
begin
//write(class.name&amp;'::'&amp;method.name&amp;' _collectionsBlock='&amp;_collectionsBlock);
	objBlock := _collectionsBlock.cnEcGetTagValueOfName('allObjects');
	if objBlock = null then
//write class.name&amp;'::'&amp;method.name&amp; " return.";
		return;
	endif;

//write class.name&amp;'::'&amp;method.name&amp;' allObjects='&amp;objBlock;
	pos := 1;
	blockLength := objBlock.length;
	while pos &lt; blockLength do
		theCode := objBlock.cnEcGetNextTagValueOfName('name', pos);
		if pos &lt; 1 then
			break;
		endif;
		theKey := objBlock.cnEcGetNextTagValueOfName('theKey', pos);
//write class.name&amp;'::'&amp;method.name&amp;' theCode='&amp;theCode&amp;' theKey='&amp;theKey;
		
		if theCode = null then
			continue;
		endif;
		aClass := currentSchema.getClass(theCode);
		if aClass &lt;&gt; null then
			create objArray transient;
			aClass.allInstances(objArray, 0, false);
//write class.name&amp;'::'&amp;method.name&amp;' aClass='&amp;aClass.name&amp;' objArray='&amp;objArray.size.String;
			foreach object in objArray do
				if object.theKey = theKey then
					self.allObjects.add(object);
//write class.name&amp;'::'&amp;method.name&amp;' add='&amp;object.theKey;
				endif;				
			endforeach;
			delete objArray;		// PAR #27874
		endif;
	endwhile;
epilog
	delete objArray;
end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="8aa119de-a456-43d7-8b3e-e49adb118a62">
        <source>importPLXMLReference(_name: String; _theCode: String; _referencesBlock: String): Object;

vars

begin
	return null;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
