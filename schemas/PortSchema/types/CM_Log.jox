    <JadeMethod name="oos_BOLInOutsideMeanSED" id="45d51367-8df3-4495-bc1b-74665c5cbfed">
        <source>oos_BOLInOutsideMeanSED() : Boolean;
// 8/4/2013	cnwjre1	Par 31358 compare log sed values against the docket (BOL In) log grade values not self.log grade
//	to report the original log values after any regrading (the regrading changes the CM_Log.myLogGrade but not the BOL extension log grade).

vars
	logGrade	: CM_LogGrade;
begin
	if self.myReceivalBOL &lt;&gt; null and
	   self.myReceivalBOL.myExtension &lt;&gt; null then
		logGrade := self.myReceivalBOL.myExtension.myLogGrade;
	endif;
	if logGrade &lt;&gt; null then
		return (self.sedMean &lt; logGrade.minMeanSED or self.sedMean &gt; logGrade.maxMeanSED);
	else
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="oos_BOLInOutsideSED" id="6e87c268-6f14-42c3-9417-ce18a2a73198">
