    <JadeMethod name="updateWodReceiveEnhancement" id="afdcf8c9-a001-460b-8b56-29956a66cab1">
        <source>updateWodReceiveEnhancement(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 October 2022	navgm20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements

*/

vars
	wodReceive  : CM_WodReceive;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
