    <JadeMethod name="setControlsForAddEdit" id="bde4e811-8593-47b9-a7d5-1bb0d6ebb239">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
					cnwml2 	PAR23715 SFW CCMS 1131
06 April 2023		jlizm1	TFS 57098 EUP Seal numbers on trucks

*/
vars
	theForm : SOP_TableMaintForm;

begin
  
  theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	theForm.shtMultiSelect1.visible := true;
	theForm.mulSelect1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_AllowMultipleSealNo);
		theForm.tblInput1.enableRowByName(ETRow_ShowSealIfPres);
		theForm.tblInput1.enableRowByName(ETRow_NotAvailableForEntry);
		theForm.tblInput1.enableRowByName(ETRow_SavePreviousSeal);
		theForm.tblInput1.enableRowByName(ETRow_TruckSeal);
			
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.fldInput.initSheetBackColors();
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_SealType);
		// cannot update code		
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
	endif;
	
	self.enableMulSelect1Contents();
	self.enableMulSelect2Contents();
	
	theForm.tblInput1.cnEcResizeContents;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="abd5669d-187a-48b0-8585-67978663e75c">
        <updating/>
        <source>setCtrlsForView() updating;
//+cnwml2 PAR23715 SFW CCMS 1131

vars
	theForm : SOP_TableMaintForm;

begin
	inheritMethod();  
  	theForm := self.myForm;
  	theForm.tblInput1.userInputEnabled := false;
  	theForm.tblInput1.cnEcResizeContents;
  	theForm.shtMultiSelect1.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="acfc63b1-c7b1-42aa-a552-507f47724118">
        <updating/>
        <source>setupThumbnailDetails()updating;
//+cnwml2 PAR23715 SFW CCMS 1131

vars
	theForm : SOP_TableMaintForm;

begin
   	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_SealTypeTbl);

	theForm.shtTblInput1.caption := app.getString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_SealTypeTbl);
	theForm.shtTblInput1.visible := true;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="97540f3f-2c7f-4356-87c1-c7835c68593e">
        <updating/>
        <source>showThumbnail(_sealType : CM_SealType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
					cnwml2 	PAR23715 SFW CCMS 1131
06 April 2023		jlizm1	TFS 57098 EUP Seal numbers on trucks

*/
vars
	theForm : SOP_TableMaintForm;
begin
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, _sealType.sealType);
	theForm.tblInput1.setValueByName(ETRow_Description,	_sealType.description);
	theForm.tblInput1.setValueByName(ETRow_AllowMultipleSealNo, _sealType.allowMultipleSealNums);
	theForm.tblInput1.setValueByName(ETRow_ShowSealIfPres, _sealType.showSealOnCheck);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, _sealType.notAvailableForEntry);
	theForm.tblInput1.setValueByName(ETRow_SavePreviousSeal, _sealType.savePreviousSeal);
	theForm.tblInput1.setValueByName(ETRow_TruckSeal, _sealType.useForTrucks);	// TFS 57098
	
	theForm.mulSelect1.setSelected(_sealType.allCargoTypes);
	theForm.mulSelect2.setSelected(_sealType.allWagonClasses);	// TFS 57098
	self.disableMulSelect1Contents();

end;</source>
        <Parameter name="_sealType" type="CM_SealType"/>
    </JadeMethod>
</Class>
