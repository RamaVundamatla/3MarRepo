<Class name="CM_KPIVoyageSnapshotDtl" id="184cea03-fc1e-4318-9f4f-24ffd58bc3f7">
    <superclass name="CM_KPISnapshotDtl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="kpiPeriod"/>
    <ImplicitInverseRef name="actualMoveCounts" id="13defdd8-958f-4d51-9e62-b6dbceed0ff0">
        <embedded/>
        <type name="CM_KPIMoveCountDtl"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="plannedMoveCounts" id="4e050275-8ec4-4a2c-b941-2b284c076af7">
        <embedded/>
        <type name="CM_KPIMoveCountDtl"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="startTime" id="2bcc6bcd-53bb-4c59-b9bc-4b7dd3813e7d">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="targetFinishTime" id="7e165bf1-8384-45d4-8e11-30efed1430f1">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="dd8ed7ed-32a0-4560-9d91-87c699db3c67">
        <updating/>
        <source>create() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2012	cnwdw1	Initial creation
*/
vars

begin
	self.type := "VOYAGE";
	create self.plannedMoveCounts transient;
	create self.actualMoveCounts transient;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="8e85d2e2-efb4-4417-b17b-5893d07e6f67">
        <updating/>
        <source>delete() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2012	cnwdw1	Initial creation
*/
vars

begin
	delete self.actualMoveCounts;
	delete self.plannedMoveCounts;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayString" id="d93b689a-3386-4d27-af31-b2bd2b36dfd8">
        <source>displayString(): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2013	cnwdw1	Initial creation
*/
vars

begin
	return "Id: " &amp; self.id &amp; " Type: " &amp; self.type &amp; 
		" Planned Moves: " &amp; self.plannedMoveCounts.moveCount.String &amp; " Actual Moves: " &amp; self.actualMoveCounts.moveCount.String &amp;
		" Start Time: " &amp; self.startTime.asStringJMT &amp; " Target Time: " &amp; self.targetFinishTime.asStringJMT;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFrom" id="01363f75-d920-4e81-8136-846151b3e1cc">
        <updating/>
        <source>setFrom(_item : CM_Object; _at: TimeStamp; _movements: CM_KPIMovementDtlArray) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2012	cnwdw1	Initial creation
*/
vars
	voyage: CM_Voyage;
	voyStats : CMIF_VoyageStats;
begin
	voyage := _item.CM_Voyage;
	
	create voyStats transient;
	voyStats.init(voyage);
	voyStats.getStats(false);
	
	self.plannedMoveCounts.updatePlannedFromVoyage(voyage, voyStats);
	self.actualMoveCounts.updateActualFromVoyage(voyage, _at, voyStats);
	self.startTime := voyage.shipExchangeDate;
	self.targetFinishTime := voyage.departTargetDT;
	if not self.targetFinishTime.isValid then
		self.targetFinishTime := voyage.departedDT;
	endif;
	self.id := voyage.code;
	self.dateTime := _at;
	
epilog
	delete voyStats;
end;</source>
        <Parameter name="_item" type="CM_Object"/>
        <Parameter name="_at" type="TimeStamp"/>
        <Parameter name="_movements" type="CM_KPIMovementDtlArray"/>
    </JadeMethod>
</Class>
