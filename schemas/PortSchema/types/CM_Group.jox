    <JadeMethod name="validateForDelete" id="205fe0f4-eed6-48d5-a4e6-56465435bf88">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     13 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.entries.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, 'Group', null, null);
	endif;
	testIsUsedInAttributePlan;	
end;</source>
    </JadeMethod>
