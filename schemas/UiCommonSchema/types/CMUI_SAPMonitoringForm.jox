    <JadeMethod name="translateForm" id="328d73f6-3d97-4240-8eb4-09bd651dfc00">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 November 2018 08:39:32.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023089, locale);
	btnActivity.translateBubbleHelp(Xlat_0023097, locale);
	btnActivity.translateCaption(Xlat_0023090, locale);
	lblDateFrom.translateCaption(Xlat_0023091, locale);
	lblDateTo.translateCaption(Xlat_0023092, locale);
	lblTotalJMT.translateCaption(Xlat_0023093, locale);
	lblTotalJMTvalue.translateCaption(Xlat_0023094, locale);
	lblTotalSAP.translateCaption(Xlat_0023095, locale);
	lblTotalSAPvalue.translateCaption(Xlat_0023096, locale);
end;</source>
    </JadeMethod>
</GUIClass>
