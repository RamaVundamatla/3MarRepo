    <JadeMethod name="loadRateTableByColumnSL" id="b5a3534a-2d86-47ab-8fba-ea49da16148a">
        <source>loadRateTableByColumnSL(_sl : CM_ShippingLine; _company:CM_Bank; _level:Integer; _rateTable:Table io; _col:Integer io; _timeStamp:TimeStamp; _progress:CMS_Progress io);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20 Feb 2018	jlgmd1		TFS 36954 SNO - Error in SCT2 Rate Table (Swap $CM_RateEntry.decimalPlaces for terminal config)

// ---------------------------------------------------------------------------

vars
	shipPortGroup : CM_ShipPortGroup;
	lineGroupDebtor : CM_LineGroupDebtor;
	service : CM_Service;
	i,j : Integer;
	rateEntry : CM_RateEntry;
	dpl : Integer;
	symbol : Character;

begin

	// TFS 36954 MPD 20 Feb 2018
	dpl := self.getRateEntryDecimalPlaces;
	symbol := app.myRoot.getInvoiceCurrencySymbol.Character;

	foreach service in _company.services where not service.isNotAvailableForEntry do
		_rateTable.CM_DataTable.addItemObject(service, service.name);
	endforeach;

	foreach shipPortGroup in _sl.shipPortGroups do
		foreach lineGroupDebtor in shipPortGroup.lineGroupDebtors do
			_rateTable.row := 1;
			_rateTable.column := _col;
			_rateTable.text := lineGroupDebtor.code;
			_rateTable.accessColumn(_col).itemObject := lineGroupDebtor;
			j := 1;
			_progress.setAction("Getting rates for Line Group Debtor: " &amp; lineGroupDebtor.code);
			_progress.progress.partsDone := _col - 1;
			app.doWindowEvents(0);

		//	foreach service in _company.services do
			foreach service in _company.services where not service.isNotAvailableForEntry do	//18 Dec 2017	NDL	TFS 8227
				j := j + 1;
				_rateTable.row := j;
				rateEntry := lineGroupDebtor.getServiceTimeRate(_company, service, _timeStamp);
				if rateEntry &lt;&gt; null then
					//_rateTable.text := rateEntry.getDerivedCostPerUnit(self.effectiveDate.TimeStamp).userCurrencyFormat($CM_RateMoney);
					_rateTable.text := symbol &amp; rateEntry.getDerivedCostPerUnit(self.effectiveDate.TimeStamp).asStringJMTWithPrecision(dpl, false); // TFS 36954 MPD 20 Feb 2018
					_rateTable.accessCell(j,_col).itemObject := rateEntry;
					if rateEntry.rate.isKindOf(CM_LineGroupDebtorRate) then
						if rateEntry.rate.CM_LineGroupDebtorRate.lineGroupDebtor = lineGroupDebtor then
							_rateTable.accessedCell.fontBold := true;
						else
							_rateTable.accessedCell.fontBold := false;
						endif;
					else
						_rateTable.fontBold := false;
					endif;
					
				endif;
			endforeach;
			_col := _col + 1;

		endforeach;
	endforeach;

end;</source>
        <Parameter name="_sl" type="CM_ShippingLine"/>
        <Parameter name="_company" type="CM_Bank"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_rateTable" type="Table" usage="io"/>
        <Parameter name="_col" type="Integer" usage="io"/>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <Parameter name="_progress" type="CMS_Progress" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadRateTableByColumnVessel" id="00bf4ba7-bdbc-4c9b-8c62-d3d8556da1ed">
        <source>loadRateTableByColumnVessel(	_vessel : CM_Vessel; 
								_company : CM_Bank; 
								_level : Integer; 
								_rateTable : Table io; 
								_col : Integer io; 
								_timeStamp : TimeStamp; 
								_progress : CMS_Progress io	);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/03/2018	jlgdap1		Initial creation TFS 37794 PEL1 Vessel Rates
//
vars
	obj	: Object;
	service : CM_Service;
	i,j : Integer;
	rateEntry : CM_RateEntry;
	rate : Real;
	tmpNode	: CM_DebtorNode;
	dpl : Integer;
	symbol : Character;
	vesselName: String;
	
begin
	_rateTable.column := _col;
	_rateTable.row := 1;
	_rateTable.accessColumn(_col).itemObject := _vessel;
	
	vesselName := self.displayVessel(_vessel);
	_rateTable.row := 1;
	_rateTable.text := vesselName;
	j := _rateTable.fixedRows;
	_progress.setAction("Getting rates for vessel: " &amp; vesselName);
	_progress.progress.partsDone := _col - 1;
	_progress.doWindowEvents(0);
	
	// TFS 36954 MPD 20 Feb 2018
	dpl := self.getRateEntryDecimalPlaces;
	symbol := app.myRoot.getInvoiceCurrencySymbol.Character;

	foreach obj in self.allSelectedVesselServices do
		service := obj.CM_Service;
		j := j + 1;
		_rateTable.row := j;
		rateEntry := _vessel.getVesselServiceTimeRate(service, _timeStamp);
		if rateEntry &lt;&gt; null then
			rate := rateEntry.getDerivedCostPerUnit(self.effectiveDate.TimeStamp);
			if rate = 0.0 then
				// leave blank
			else
				_rateTable.text := symbol &amp; rate.asStringJMTWithPrecision(dpl, false);
			endif;
			
			_rateTable.accessCell(j, _col).itemObject := rateEntry;
			if rateEntry.rate.CM_VesselRate.myVessel = _vessel then
				_rateTable.accessedCell.fontBold := true;
			else
				_rateTable.accessedCell.fontBold := false;
			endif;
		endif;
	endforeach;
	
	_progress.doWindowEvents(0);

epilog

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_company" type="CM_Bank"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_rateTable" type="Table" usage="io"/>
        <Parameter name="_col" type="Integer" usage="io"/>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <Parameter name="_progress" type="CMS_Progress" usage="io"/>
    </JadeMethod>
