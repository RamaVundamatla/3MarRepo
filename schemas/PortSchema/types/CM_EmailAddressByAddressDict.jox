<CollClass name="CM_EmailAddressByAddressDict" id="9e59417a-30e2-46ee-9888-8e1e6a747b92">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_EmailAddress2"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <MemberKey>
        <property name="CM_EmailAddress2::emailAddress"/>
    </MemberKey>
    <JadeMethod name="getAddresses" id="c8a9f125-55aa-43a8-8bfb-5de1f9f7112c">
        <source>getAddresses() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 June 2011	cnwndl1	Initial creation	Par 27731 - copy of method on CM_EmailEntityByTypeNameDict

*/

vars

	entity	: CM_EmailEntity;
	str		: String;

begin

	foreach entity in self do
		str := str &amp; ';' &amp; entity.getEmailAddress();
	endforeach;
	if str.length &gt; 1 then
		return str[2:end];
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
