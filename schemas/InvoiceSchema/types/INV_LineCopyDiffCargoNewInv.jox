    <JadeMethod name="setTheCaption" id="f93c7169-6a6a-4281-bc25-6657a6c0da76">
        <updating/>
        <source>setTheCaption() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes

*/

vars

begin
	if self.allSelectedInvoiceLines.size() &gt; 0 then
		 // ### TFS BUG 58106 23MAY2023 NAVAB1
		self.caption := self.caption &amp; " - " &amp; self.allSelectedInvoiceLines.first.bank.code &amp; " - " &amp; self.allSelectedInvoiceLines.size().String &amp; " "
		&amp; app.getErrorString(Invoice_lines_selected) &amp; " - " &amp; app.getErrorString(Invoice)&amp; " " &amp; self.allSelectedInvoiceLines.first.invoice.sequenceNum.String;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7de1e40f-e752-4e0a-9988-d3e10fc38501">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2023	navmv20	Initial creation

*/

vars
	tblResults : CM_DataTable;
	entTableDef : EntTableDef;
	dateStr,
	timeStr     : String;
begin
	inheritMethod();
	//self.frmToolbarBtns.visible := false;
	//self.frmMain.visible := false;
	//self.frmToolbar.visible := false;
	//self.btnCancelBase.visible := false;
	//self.btnSaveBase.visible := false;
	tblResults := self.tblResults;
	tblResults.clear();
	entTableDef := app.myController.getEntTableDef(ETDef_CargoEnqDefaultData);
	self.tblInvProperties.showRowByName(ETRow_StartDate, false);
	self.tblInvProperties.showRowByName(ETRow_StartTime, false);
	self.tblResults.setTblDataEntRowsFromDef(entTableDef);
	self.tblResults.setMyDataClass(CM_TrackedItem);
	self.tblResults.fixedColumns := 0;
	self.tblResults.selectMode := CM_DataTable.SelectMode_FixedRow;
	self.tblResults.selectionType := CM_DataTable.SelectionType_Row;
	self.tblResults.multiSelect := CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(self.tblResults);
	self.tblResults.clearAllData();
	self.setTheCaption();
	
	self.btnSearchCargo.visible := true;
	self.frmToolbar.visible := false;
	self.showToolbar := true;
	self.fldMain.width := self.fldMain.width + 2;
epilog

end;</source>
    </JadeMethod>
