    <JadeMethod name="addObjectsToTable" id="9ad74c26-1eb5-4c22-b38c-9f49df3c5084">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
22 Jan 2018	jlgkpd1	TFS 36660 - Locking issues at Penn
	
*/

vars
	jobs			: CM_JobArray;
	
begin
	// TFS 36660 - minimise locking on Job Sheet collection
	jobs := self.myTerminal.myRoadJobSheet.allJobsByOrder.cloneSelf(true);
	self.copyCollectionToTable(jobs, _numItems);

	//self.resetNotifications(); ends the note therefore must reset it
	self.beginClassNotification(CM_RoadJob, false, Object_Create_Event, Response_Continuous, null);
	
epilog
	delete jobs;
	
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addRetroControlsToToolbar" id="a39af4aa-9de0-4d43-88df-ab109b340090">
        <source>addRetroControlsToToolbar();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit

*/

vars
	toolBar			: CMUI_Toolbar;
	frmOpsRetroDT	: CMUI_ToolbarFrame;
	nowLocal		: TimeStamp;
begin
	
	toolBar			:= self.frmToolbar;
	frmOpsRetroDT	:= self.frmRetroDT;
	
	toolBar.addFrame(frmOpsRetroDT, CMUI_Toolbar.Control_Alignment_Right);
	frmOpsRetroDT.width := self.lblRetroDate.width + self.txtRetroDate.width + self.lblRetroTime.width + self.txtRetroTime.width + 220;
	frmOpsRetroDT.top := 2;
	
	self.lblRetroDate.left	:= 160;
	self.txtRetroDate.left	:= self.lblRetroDate.left + self.lblRetroDate.width + 4;
	self.lblRetroTime.left := self.txtRetroDate.left + self.txtRetroDate.width + 20;
	self.txtRetroTime.left := self.lblRetroTime.left + self.lblRetroTime.width + 4;
	
	self.lblRetroDate.top	:= 12;
	self.txtRetroDate.top	:= 8;
	self.lblRetroTime.top	:= 12;
	self.txtRetroTime.top	:= 10;
	
	self.txtRetroDate.setDate(nowLocal.date());
	self.txtRetroTime.setTime(nowLocal.time());
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="299e71b2-aa85-4cfb-8c0f-abb1da367da1">
        <source>addToolbarControls() protected;
/*
------------------------------------------------------------------------
Created:			29 September 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
16 Feb 2024		navnk30			ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit	
01 Mar 2024		navnk30			Defect 62724: EUP - Ops Retrospective button is available on the Road Exit form even the gate config is set to false
---------------------------------------------------------------------------
*/

vars
	toolbar	: CMUI_Toolbar;
	
begin
	
	//epr par 34867 4/9/14
	toolbar := self.frmToolbar;
	btnSaveBase.caption := app.getErrorString(Process_road_exit);
	btnSaveBase.bubbleHelp := btnSaveBase.caption;
	btnSaveBase.picture := self.picProcessUp.picture;
	btnSaveBase.pictureDisabled := self.picProcessDown.picture;
	
	self.addRetroControlsToToolbar();		//16.02.2024 navnk30 #62414
	inheritMethod();
	/*//25/06/2024	navkc1 CR 64823 Task 64824
	// ### TFS 54049 (55843) 16May2023 NAVPW1
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmFilter, CMUI_Toolbar.Control_Alignment_Left);
	
	self.txtFilterBox.parent 	:= self.frmFilter;
	self.txtFilterBox.visible 	:= true;
	self.txtFilterBox.left 		:= 0;
	self.txtFilterBox.top 		:= 2;
	
	toolbar.addButton(self.btnClearFilter, CMUI_Toolbar.Control_Alignment_Left);
	// ### TFS 54049 (55843) 16May2023 NAVPW1
	*/
	//25/06/2024	navkc1 CR 64823 Task 64824
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTableFilter, CMUI_Toolbar.Control_Alignment_Left);
	//epr par 34867 save base button added in CM_TableViewForm
	//toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	
//	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	if app.getMyUser.canDo( self.myTerminal, self.permissionMaint ) then	//14 Feb 2019	TFS 43403
		toolbar.addButton(self.btnFindExit, CMUI_Toolbar.Control_Alignment_Left);	
	endif;
	
	toolbar.addButton(self.btnRetro, CMUI_Toolbar.Control_Alignment_Left);	//16.02.2024 navnk30 #62414
	if self.myTerminal.getConfig(IsRetrospectiveMode).Boolean then			//16.02.2024 navnk30 #62414
		self.btnRetro.visible := true;
	else
		//self.btnRetro.visible := true;			//01.03.2024 navnk30 #62724
		self.btnRetro.visible := false;				//01.03.2024 navnk30 #62724
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="armNotesForObject" id="3e62417a-c3be-498f-97c3-a46e15765d97">
        <source>armNotesForObject(_obj: Object);
//--------------------------------------------------
// Created:	04 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	tmpRoadJob	: CM_RoadJob;
	ti			: CM_TrackedItem;
begin

	self.beginNotification(_obj, Object_Delete_Event, Response_Continuous, 0);
	self.beginNotification(_obj, Object_Update_Event, Response_Continuous, 0);

	// effectively a delete from the visible list
	self.beginNotification(_obj, self.myTerminal.getTerminalEvent(TIEvent_Terminal_Release), Response_Continuous, 0);

	if _obj.isKindOf(CM_RoadJob) then  // arm notes for ti's on release so if ti changed screen will be updated. Par 10424
		tmpRoadJob := _obj.CM_RoadJob;
		foreach ti in tmpRoadJob.allReceiveTrackedItems do 
			self.beginNotification(ti, Object_Update_Event, Response_Continuous, 0);
		endforeach;
		
		foreach ti in tmpRoadJob.allReleaseTrackedItems do 
			self.beginNotification(ti, Object_Update_Event, Response_Continuous, 0);
		endforeach;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="btnFindExit_click" id="93d7c3d5-78f9-4beb-ac4a-96734274f686">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFindExit_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2019	jlgndl1	Initial creation	TFS 43403

*/

vars

	form : GTE_FindAndExit;

begin
	
	form := app.getForm('GTE_FindAndExit').GTE_FindAndExit;
	if form = null then
		form := app.loadForm(GTE_FindAndExit,
							GTE_Assistant,
							false,
							false,
							false,
							self.myTerminal, null).GTE_FindAndExit;
	endif;
	
	form.setParentForm( self );
	form.show();
	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnRetro_click" id="88b933e6-f6a7-4935-b4d4-95af2479fb01">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnRetro_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
01 Mar 2024 navhl20 ChangeRequest 62705: EUP | Ship Operations in DD - [54176.070] - [Road] Retrospective Operations Remedial
*/

vars
	isRetroMode	: Boolean;
	nowLocal	: TimeStamp;
begin
	isRetroMode := self.btnRetro.value;
	if self.btnRetro.value then
		self.btnRetro.myToolbarButton.drawButtonDown();
	else
		self.btnRetro.myToolbarButton.clearGraphics();
	endif;
	
	self.lblRetroDate.visible := isRetroMode;
	self.txtRetroDate.visible := isRetroMode;
	self.lblRetroTime.visible := isRetroMode;
	self.txtRetroTime.visible := isRetroMode;
	
	if isRetroMode then
		self.txtRetroDate.setDate(nowLocal.date());
		self.txtRetroTime.setTime(nowLocal.time());
	else
		self.txtRetroDate.text := null;
		self.txtRetroTime.text := null;
	endif;
	//self.doFilterTable();					//01.03.2024 navhl20 #62705
	//self.doBtnRetroChange(isRetroMode);	//01.03.2024 navhl20 #62705
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canCancelVisit" id="43124353-5ebe-4642-a22e-53e705c2c656">
        <source>canCancelVisit() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
25 November 2024		jlizm1	Initial creation MTN 33235 Delete current entry reverting already exported cargo

*/

vars
	roadJobObj 	: CM_RoadJob;
	vvr 		: CM_VehicleVisitRecord;
	
begin
	roadJobObj := self.myCurrentObject.CM_RoadJob;
    if roadJobObj &lt;&gt; null then
        vvr := roadJobObj.myVehicleVisit;
    endif;
	
	if vvr = null then
		return false;
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, PmGteGateCanCancelFlexiJob) then
		return false;
	endif;
	
	if vvr.isIncomplete and vvr.timeOut = null then
		return true;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
