    <JadeMethod name="pxyCreateUpdateProxy" id="4140286b-7a68-41c4-9acc-f4b01228f249">
        <source>pxyCreateUpdateProxy(): SelfType;
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyReceivalByType : CMGTE_ReceivalByType;
	receivalInfo: CM_ReceivalInfo;
	completedOK		: Boolean;
begin
	pxyReceivalByType := inheritMethod();
	if self.myReceivalInfo &lt;&gt; null then
		receivalInfo := self.myReceivalInfo.pxyCreateUpdateProxy();
		receivalInfo.setParent(pxyReceivalByType);
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyReceivalByType;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyReceivalByType;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="9dd019a2-32f4-4f29-9a43-246f2a7a3bfb">
        <updating/>
        <source>setForCreate(_pxyGTEEntity: CMGTE_ReceivalByType; _realVVR: CM_VehicleVisitRecord input) updating;
//15 February 2010	cnwdw1	
//
vars

begin
	inheritMethod(_pxyGTEEntity, _realVVR);
	self.setForUpdate(_pxyGTEEntity, _realVVR);
end;</source>
        <Parameter name="_pxyGTEEntity" type="CMGTE_ReceivalByType"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="231ada86-4c61-491f-8599-72fb3741204e">
        <updating/>
        <source>setForUpdate(_pxyGTEEntity: CMGTE_ReceivalByType; _realVVR : CM_VehicleVisitRecord ) updating;

vars
	receivalInfo: CM_GTEReceivalInfo;
begin
	inheritMethod(_pxyGTEEntity, _realVVR);
	receivalInfo := self.myReceivalInfo;
	if receivalInfo = null then
		create receivalInfo persistent;
		receivalInfo.setForCreate(_pxyGTEEntity.myReceivalInfo, self);
	else
		receivalInfo.setForUpdate(_pxyGTEEntity.myReceivalInfo, self);
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyGTEEntity" type="CMGTE_ReceivalByType"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setPXYFromController" id="6c8f9467-f780-4837-87a7-8419b22805f2">
        <updating/>
        <source>setPXYFromController(_flexi: CMIF_FlexiGateController) updating;
//12 February 2010	cnwdw1	
//
vars
	realGTE		: CMGTE_ReceivalByType;
	receivalInfo, realReceivalInfo: CM_GTEReceivalInfo;
	booking: CM_BookingRef;
	cargoType: CM_CargoType;
	voyage: CM_Voyage;
begin
	inheritMethod(_flexi);
		
	realGTE := self.pxyGetRealObject();
	if realGTE &lt;&gt; null then
		// We are updating an existing CMGTE_ReceivalByType instance, so we don't want to create a new CM_GTEReceivalInfo instance
		receivalInfo := self.myReceivalInfo;
		
		if receivalInfo = null then 
			app.raiseUnexpectedProgramError(class.name, method.name, "CM_GTEReceivalInfo for existing entity is null");
		endif;
	else 
		// This is a new instance of CMGTE_ReceivalByType, so we need to create a new instance of CM_GTEReceivalInfo
		create receivalInfo transient;
	endif;
	voyage := self.myTerminal.lookupVoyage (_flexi.voyageCode, null, false);
	booking := self.myTerminal.getBookingReference(_flexi.operatorCode, _flexi.bookingNumber, voyage);
	cargoType := app.myRoot.allCargoTypesById[_flexi.cargoType];
	receivalInfo.setProxy(booking, _flexi.myBookingRefItem, cargoType, _flexi.myProduct, _flexi.commodity, _flexi.numItems);
	
	if realGTE = null then
		receivalInfo.setParent(self);	// link to parent
	endif;
end;</source>
        <Parameter name="_flexi" type="CMIF_FlexiGateController"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="f17031a6-569e-4437-bdd2-078914792a69">
