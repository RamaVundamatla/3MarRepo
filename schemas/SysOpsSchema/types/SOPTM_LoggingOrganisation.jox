    <JadeMethod name="doSave" id="34bbce78-d382-4677-974c-8b5aa208b4f3">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	errObj:CM_Error;
	idx:Integer;
	tmpListBox:ListBox;
	ignoreWarnings,rtnValue:Boolean;
	proxyLogOrg:CM_LoggingOrganisation;
	lCode,lDescription:String;
	notAvailForEntry	: Boolean;
	theForm : SOP_TableMaintForm;
begin

  	theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	notAvailForEntry := theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_LoggingOrganisation transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyLogOrg := theForm.myProxyObject.CM_LoggingOrganisation;
	proxyLogOrg.setProxy(lCode, lDescription, notAvailForEntry);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateLoggingOrganisation(proxyLogOrg, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateLoggingOrganisation(proxyLogOrg, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
