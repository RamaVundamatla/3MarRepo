    <JadeMethod name="createProxyCutoff" id="021cbdcc-25fb-4d29-bf1e-6bcda7213ef9">
        <source>createProxyCutoff(_recCutoffTerminal :CM_ReceivalCutoffTermDef; _operator : CM_Operator) protected;
/*
Purpose - 	create a proxy from the defaults
Who - NAVAB1
Date - 08APR2025
ADO - JIRA 34524
*/
vars
	operator		: CM_Operator;
	recCutoffDefOp	: CM_ReceivalCutoffOpTerm;
	cutoffToShow : CM_ReceivalCutoffDef;
	defnCutoff : CM_ReceivalCutoffTermDef;
	pxyVoyageCutoff : CM_ReceivalCutoffVoyage;
	defRelativeTo			: Integer;
		defEarliest, 
	defCutoffPN ,
	defEarliestPN, 
	defCutoff 		:Decimal[7,2];
	targetTS, earliestTS, cutoffTS,
	earliestTSPN, cutoffTSPN,
	voyageDepartedDT:TimeStamp;
	handlePrenotes : Boolean;
begin
	 // ### JIRA 35634 12AUG2025 NAVAB1
	handlePrenotes := self.myTerminal.getConfig(ShipCutoffsForPrenotes).Boolean;
	if not handlePrenotes then
		handlePrenotes := self.ckbPrenoteCutoffs.value;
	endif;
	
	operator 	:= _operator;
	
	cutoffTS :=self.systemToLocalTime(app.actualTimeServer);
	
	if self.myCurrentVoyage &lt;&gt; null then
		if self.myCurrentVoyage.departedDT.isValid then
			voyageDepartedDT := self.systemToLocalTime(self.myCurrentVoyage.departedDT);
			if voyageDepartedDT &lt; cutoffTS then
				// set cut off default to Voyage Depart
				cutoffTS := voyageDepartedDT;
			endif;
		endif;
	endif;
	
	if operator &lt;&gt; null then
		recCutoffDefOp := operator.getTerminalReceivalCutoff(_recCutoffTerminal);
	endif;
	
	if recCutoffDefOp &lt;&gt; null then
		defRelativeTo 	:= recCutoffDefOp.defaultRelativeTo;
		defEarliest		:= recCutoffDefOp.defaultEarliestReceival;	// hours
		defCutoff		:= recCutoffDefOp.defaultCutoff;			// hours
		cutoffToShow := recCutoffDefOp;
		defnCutoff := recCutoffDefOp.myReceivalCutoffTermDef;
		defEarliestPN		:= recCutoffDefOp.defaultEarliestReceivalPN;	// hours
		defCutoffPN		:= recCutoffDefOp.defaultCutoffPN;			// hours
	else
		defRelativeTo 	:= _recCutoffTerminal.defaultRelativeTo;
		defEarliest		:= _recCutoffTerminal.defaultEarliestReceival;	// hours
		defCutoff		:= _recCutoffTerminal.defaultCutoff;			// hours
		cutoffToShow := _recCutoffTerminal;
		defnCutoff := _recCutoffTerminal;
		defEarliestPN		:= _recCutoffTerminal.defaultEarliestReceivalPN;	// hours
		defCutoffPN		:= _recCutoffTerminal.defaultCutoffPN;			// hours
	endif;
				
	targetTS := self.getCutoffRelativeToTS (defRelativeTo);
	
	if targetTS &lt;&gt; null then	
		if not _recCutoffTerminal.isEDIType and defEarliest &lt;&gt; null then
			// work out earliest receival date/time but only if:
			// - we are CARGO cutoff and
			// - earliest hours &lt;&gt; 0
			earliestTS 		:= targetTS.subtractHoursAndMinutes (defEarliest);
			
			earliestTSPN 		:= targetTS.subtractHoursAndMinutes (defEarliestPN);
			
		endif;
		if _recCutoffTerminal.isEDIType or defCutoff &lt;&gt; null then
			// work out cutoff date/time but only if:
			// - we are EDI cutoff OR
			// - cutoff hours &lt;&gt; 0
			cutoffTS		:= targetTS.subtractHoursAndMinutes (defCutoff);

			cutoffTSPN		:= targetTS.subtractHoursAndMinutes (defCutoffPN);

		endif;
	endif;
	
	
	if _recCutoffTerminal.defaultRelativeTo = DefaultRelativeTo_RecCutOff  then
		cutoffTS := null;
		earliestTS := null;
		cutoffTSPN := null;
		earliestTSPN := null;
		defCutoff := null;
		defCutoffPN := null;
		defEarliest := null;
		defEarliestPN := null;
	endif;
	
	if _recCutoffTerminal.isEDIType then
		earliestTS := null;
		earliestTSPN := null;
	endif;
	
	 // ### JIRA 35634 12AUG2025 NAVAB1
	if not handlePrenotes then
		cutoffTSPN := null;
		earliestTSPN := null;
		defCutoffPN := null;
		defEarliestPN := null;
	endif;

	cutoffTS := self.localToSystemTime(cutoffTS);
	earliestTS := self.localToSystemTime(earliestTS);
	cutoffTSPN := self.localToSystemTime(cutoffTSPN);
	earliestTSPN := self.localToSystemTime(earliestTSPN);
	 
	
	create pxyVoyageCutoff transient;
	pxyVoyageCutoff.setProxy(cutoffToShow.getCode(), cutoffTS, earliestTS,self.myCurrentVoyage, operator,  cutoffTSPN, earliestTSPN,defCutoff,defCutoffPN,defEarliest, defEarliestPN,defRelativeTo);
	pxyVoyageCutoff.setRecCutoffDef(defnCutoff);

	self.allProxyCutoffs.add(pxyVoyageCutoff);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_recCutoffTerminal" type="CM_ReceivalCutoffTermDef"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="createProxyCutoffs" id="242424f5-a88c-4b29-9055-212eefb25d7c">
        <updating/>
        <source>createProxyCutoffs(_voyage : CM_Voyage) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08APR2025
ADO - JIRA 34524
*/

vars
	recCutoff, proxyCutoff	 		: CM_ReceivalCutoffVoyage;
	recCutoffDef		: CM_ReceivalCutoffTermDef;
begin
	self.allProxyCutoffs.purge();
	
	if self.ckbOverrideDef.value and _voyage &lt;&gt; null then
		foreach recCutoff in _voyage.allReceivalCutoffs do 
			proxyCutoff := app.createUpdateProxy(recCutoff).CM_ReceivalCutoffVoyage;
			self.allProxyCutoffs.add(proxyCutoff);
		endforeach;

	else	// just showing defaults OR it is a new voyage
	
		// set receival restrictions based on terminal defaults
		foreach recCutoffDef in self.myTerminal.allReceivalCutoffDefs where recCutoffDef.isAvailableForEntry do
			// get defaults for this receival type
			self.createProxyCutoff (recCutoffDef, null);
		endforeach;
	endif;

		
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createProxyCutoffsForOperator" id="e6df0263-bb7d-4519-8a01-4e4873548c55">
        <updating/>
        <source>createProxyCutoffsForOperator(_voyage : CM_Voyage; _operator : CM_Operator) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 09APR2025
ADO - JIRA 34524
*/

vars
	recCutoffDef		: CM_ReceivalCutoffTermDef;
begin

	// set receival restrictions based on terminal defaults
	foreach recCutoffDef in self.myTerminal.allReceivalCutoffDefs where recCutoffDef.isAvailableForEntry do
		// get defaults for this receival type
		self.createProxyCutoff (recCutoffDef, _operator);
	endforeach;

		
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="createSystemVoyCode" id="b229b1c2-3879-4200-a61d-65244ae14146">
        <updating/>
        <source>createSystemVoyCode():String updating;
//vesselCode 25 + 4 digit number = 29 characters, but voyage code only 20 characters long
//changed to use 4 digit prefix (terminal code or config setting) + key series sequence number
/****Changes

Date		Name	TFS#			Description
============================================================================
05/10/2021	jlizm1	51963 			SAL Voyage Request Changes
============================================================================*/
vars
 	sysVoyCode:					String;	
 	msgBoxType:					Integer;
 	errorMsg:					String;
 	msgTitle:					String;
 	vesselCode:					String;
 	count:						Integer;
 	uniqueCode:					Integer;
 	existingPermVoyage:			CM_Voyage;
 	tmpVoyageCode:				String;
begin
	if self.myTerminal.getConfig(VoyageCodeHookTRX).Boolean then	// TFS 51963
		return null;												// TFS 51963
	endif;

	sysVoyCode := app.myHookAgent.runHookLinkPublic(HookType_VoyageCode, self.myTerminal, self.myTerminal, self.myTerminal, self.myCurrentVessel).String; // TFS 4390
	if sysVoyCode &lt;&gt; null and sysVoyCode &lt;&gt; "** not initialised **" then // TFS 4390
		return sysVoyCode; // TFS 4390
	endif; // TFS 4390
	sysVoyCode := ""; // TFS 4390
	
	tmpVoyageCode := self.txtVoyageCode.text;
	
	if (not self.shtHMSHarborData.visible)
		//Not licenced for HMS
	or (not self.ckbCreateHMSData.value)
		// No vessel selected
	or self.myCurrentVessel = null then
		// they can enter whatever they like
			return tmpVoyageCode;
	endif;

	// CCMS 1075
	if self.myTerminal.getConfig(ShowOnlyVoyageCode).Boolean then 
		return self.myCurrentVessel.code;
	else

		return self.myTerminal.getNextVoyageCode(self.myCurrentVessel, self.voyageNumber, app.myPassport);
	endif;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="createYAConfig" id="792318ee-1f5a-48ef-9c29-a0ee4f54b48a">
        <updating/>
        <source>createYAConfig():CM_YAConfig updating;
// --------------------------------------------------------------------------------
// Created:		14 December 2009 by cnwas3
//
// Purpose:		find a CM_YAConfig object for the form. ccms 1028
//
// Changed On	By			Reason
// ----------	---------	--------------------------------------------------------
// 25/08/2025	navdap1		MTN-35615 | ENS Bulk Creation of Yard Allocations
vars
	configOpts 		: CMIF_YAConfig;
	proxyYAConfig 	: CM_YAConfig;
	realYAConfig 	: CM_YAConfig;
	myYAVoyageConfig, 
	voyageConfig 	: CM_YAVoyageConfig;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	create proxyYAConfig transient;
	proxyYAConfig.setProxy(self.myTerminal, null, null, null, null);	// MTN-35615
	
	create configOpts transient;
	configOpts.setFromTerminal(self.myTerminal);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateYAConfig(proxyYAConfig, realYAConfig, configOpts, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		self.unloadForm;
		break;
		
	endwhile;

	return realYAConfig;
		
epilog
	delete proxyYAConfig;
	delete configOpts;
end;</source>
        <ReturnType type="CM_YAConfig"/>
    </JadeMethod>
    <JadeMethod name="dateArrival_lostFocus" id="20ace8cb-6608-4f6a-b1da-301c1a709236">
        <controlMethod name="CMUI_DateMask::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dateArrival_lostFocus(editMask: JadeEditMask input) updating;

vars
	tmpDate : Date;
	adjust : Boolean;
begin
	if self.mode = self.Mode_Add then
		tmpDate := self.dateArrival.getDate();
		if tmpDate.isValid() and tmpDate &gt;= self.dateDeparture.getDate() then
			self.dateDeparture.setDate(tmpDate+2);
		endif;
	endif;
	
	// 27/05/2009 cnwar2 CCMS1040
	
	 // ### JIRA 34524 08APR2025 NAVAB1
	adjust := self.shipCutoffsAutoAdjust or not self.ckbOverrideDef.value;
	if adjust then
//	if not self.ckbOverrideDef.value then
		// ### JIRA 34233 06MAR 2025 NAVAB1
		self.adjustProxyCutoffs(DefaultRelativeTo_Arrival);
	else  // ### JIRA 34524 08APR2025 NAVAB1
		self.adjustProxyCutoffsHours(DefaultRelativeTo_Arrival);
	endif;
end;</source>
