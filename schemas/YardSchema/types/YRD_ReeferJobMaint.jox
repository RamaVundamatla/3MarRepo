    <JadeMethod name="populateCmbGriddedAreas" id="31cb0de7-5879-43e1-9e14-4136c37aedff">
        <source>populateCmbGriddedAreas();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	ta : CM_TerminalArea;
	iter : Iterator;

begin

	self.cmbGridTermArea.clear();
	
	iter := self.myTerminal.allTerminalAreas.createIterator;
	while iter.next( ta ) do
		if ta.type.isOneOf( TA_TYPE_FORK_LIFT_STACK, TA_TYPE_RTG, TA_TYPE_STRADDLE_STACK ) then
			self.cmbGridTermArea.itemObject[self.cmbGridTermArea.addItem( ta.id )] := ta;
		endif;
	endwhile;
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
