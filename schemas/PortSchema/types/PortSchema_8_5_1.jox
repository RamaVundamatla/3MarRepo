    <JadeMethod name="setSystemSealsAllowMulti" id="5a9f2b9e-02c2-45f9-8587-7418af7ce74f">
        <source>setSystemSealsAllowMulti(_controller : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/12/2017	jlgdap1		Initial creation TFS 36347 STWR Set all system seal types to allow multiple seals
//
vars
	sealType : CM_SealType;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Setting all system seal types to allow multiple seals", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Setting all system seal types to allow multiple seals");
	endif;
	
	beginTransaction;
	sealType := app.myRoot.getSealType(SealType_Operator);
	if sealType &lt;&gt; null and not sealType.allowMultipleSealNums then
		sealType.setPropertyValue(CM_SealType::allowMultipleSealNums.name, true);
	endif;
	
	sealType := app.myRoot.getSealType(SealType_Customs);
	if sealType &lt;&gt; null and not sealType.allowMultipleSealNums then
		sealType.setPropertyValue(CM_SealType::allowMultipleSealNums.name, true);
	endif;
	
	sealType := app.myRoot.getSealType(SealType_Shipper);
	if sealType &lt;&gt; null and not sealType.allowMultipleSealNums then
		sealType.setPropertyValue(CM_SealType::allowMultipleSealNums.name, true);
	endif;
	
	sealType := app.myRoot.getSealType(SealType_Vent);
	if sealType &lt;&gt; null and not sealType.allowMultipleSealNums then
		sealType.setPropertyValue(CM_SealType::allowMultipleSealNums.name, true);
	endif;
	
	sealType := app.myRoot.getSealType(SealType_TerminalOperator);
	if sealType &lt;&gt; null and not sealType.allowMultipleSealNums then
		sealType.setPropertyValue(CM_SealType::allowMultipleSealNums.name, true);
	endif;
	
	sealType := app.myRoot.getSealType(SealType_Unknown);
	if sealType &lt;&gt; null and not sealType.allowMultipleSealNums then
		sealType.setPropertyValue(CM_SealType::allowMultipleSealNums.name, true);
	endif;
	commitTransaction;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
