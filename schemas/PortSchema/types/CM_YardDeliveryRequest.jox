    <JadeMethod name="validateForUpdate" id="ea49d44c-d9e1-41c7-9495-d31f4c409bcf">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ta : CM_TerminalArea;
begin
	inheritMethod();
	
	if self.totalRequested &lt;= 0 then											// 19/09/2012 cnwmh5 #29863
		app.raiseCMException(Delivery_No_Request_Invalid, null, null);
		return;
	endif;
	
	ta := self.getNominatedTA();	// 23098
	if ta = null and self.sourceLocation = null and self.targetLocation = null then
		if ta = null then	
			app.raiseCMException(Reques_failed_find_cargo_sourc, null, null);
				else		
		//	app.raiseCMException1(REQUIRED_FIELD, 'Source or Target location', null, null);
			app.raiseCMException(Input_required_field_sorcOrTar, null, null); // cnwdb2	PAR 35364
		endif;
		return;
	endif;
end;</source>
    </JadeMethod>
</Class>
