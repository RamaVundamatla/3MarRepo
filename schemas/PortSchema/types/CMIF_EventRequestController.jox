    <JadeMethod name="action" id="aad0f8d2-68de-4344-8d48-27a8601fa9b9">
        <updating/>
        <source>action(_passport : CM_Passport input)updating;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars

	email : CM_EventRequestEmail;

begin
	app.setContinueCMExceptions(false);
	
	// This must be first.
	if self.myPxyEventRequestEmail &lt;&gt; null then
		email := self.actionEmail(_passport);
	endif;
	
	if self.myPxyEventRequestNotify &lt;&gt; null then
		self.actionNotify(email, _passport);
	endif;
	
	//epr par 37551 17/2/16 removed actionStops
	
	self.actionAllCargoUpdateRequests(email,_passport);
	
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionAllCargoUpdateRequests" id="c3ba0162-902f-42c0-bdaa-243f07127176">
        <updating/>
        <source>actionAllCargoUpdateRequests(_email : CM_EventRequestEmail input; _passport : CM_Passport input)updating, protected;
/*

Date		Who		Reason
02 May 2014	cnwer1	Initial creation CCMS 2289

*/

vars
	pxyStopRequest : CM_EventRequestStops;
	obj : Object;
begin
	if self.allPxyCargoUpdateRequests.size = 0  then
		return;
	endif;
	
	foreach obj in self.allPxyCargoUpdateRequests do
		
		pxyStopRequest:= obj.CM_EventRequestStops;
		
		self.actionCargoUpdateRequest(pxyStopRequest,_email,_passport);
		
		if _passport.hasErrors then
			break;
		endif;
	
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_email" type="CM_EventRequestEmail" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionCargoUpdateRequest" id="65642e82-7a67-4091-a6e7-469a0e54e211">
        <updating/>
        <source>actionCargoUpdateRequest(_pxyCargoUpdateRequest :CM_EventRequestStops; 
							_email : CM_EventRequestEmail input;
							_passport : CM_Passport input)updating, protected;
/*

Date		Who		Reason
02 May 2014	cnwer1	Initial creation PAR

*/

vars

	expectedEdition : Integer;
	realRequest : CM_EventRequestStops;
begin

	app.setContinueCMExceptions(false);
	_pxyCargoUpdateRequest.pxyGetRealObjectAndEdition(realRequest, expectedEdition);
	
	//20 Aug 2019	NDL	TFS 45818 - If we are already in trouble, bail.
	if _passport.hasErrors then
		return;
	endif;
	
	if realRequest &lt;&gt; null then
		//updating	
		if _passport.noErrors and realRequest.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, realRequest.getDisplayDetails(true), null, null);
			return;
		endif;
		
		realRequest.setForUpdate(_pxyCargoUpdateRequest, _passport);
	else
		
		create realRequest as _pxyCargoUpdateRequest.class persistent;	// 02 May 2019	NDL	TFS 43918
		realRequest.setForCreate(_pxyCargoUpdateRequest, _passport);
	endif;


	if _passport.noErrors then
		realRequest.setMyEventRequestEmail(_email);
	endif;	
	
	self.updateStatusCount(realRequest);
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_pxyCargoUpdateRequest" type="CM_EventRequestStops"/>
        <Parameter name="_email" type="CM_EventRequestEmail" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionEmail" id="d4db0882-2001-40a2-b52e-59b0bee96489">
        <source>actionEmail(_passport : CM_Passport input) : CM_EventRequestEmail protected;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	expectedEdition : Integer;
	realEmail : CM_EventRequestEmail;
begin
	if self.myPxyEventRequestEmail = null then
		return null;
	endif;
		
	self.myPxyEventRequestEmail.pxyGetRealObjectAndEdition(realEmail, expectedEdition);
	
	if realEmail = null then
		if self.myPxyEventRequestEmail.allRunTimes.isEmpty then
			//No run times entered so don't create
		else
			create realEmail persistent;
			realEmail.setForUpdate(self.myPxyEventRequestEmail, _passport);
		endif;
	else
		//update
		if _passport.noErrors and realEmail.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, realEmail.getDisplayDetails(true), null, null);
			return null;
		endif;
		if self.myPxyEventRequestEmail.allRunTimes.isEmpty then
			//No run times then email will be sent when the TI is updated, so delete it
		//	realEmail.erase(NORMAL_ERASE);
		else
			realEmail.setForUpdate(self.myPxyEventRequestEmail, _passport);
		endif;
		
	endif;
	
	return realEmail;

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_EventRequestEmail"/>
    </JadeMethod>
    <JadeMethod name="actionNotify" id="f58df0a1-b974-4133-a508-cf9a1b505602">
        <updating/>
        <source>actionNotify(_email : CM_EventRequestEmail input;_passport : CM_Passport input)updating, protected;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	cnt,
	expectedEdition,
	pos,
	length : Integer;
	tmpType,
	tranUsedStr,
	tmpStr,
	delmiter,
	updateID,
	tmpCargoId : String;
	realRequest : CM_EventRequestTI;
	tmpObj		: Object;
	objType,
	objKey,
	idx			: Integer;
begin

	app.setContinueCMExceptions(false);
	self.myPxyEventRequestNotify.pxyGetRealObjectAndEdition(realRequest, expectedEdition);
	pos := 1;
	if realRequest &lt;&gt; null then
		//updating	
		if _passport.noErrors and realRequest.edition &lt;&gt; expectedEdition then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, realRequest.getDisplayDetails(true), null, null);
			return;
		endif;
		
		tranUsedStr := self.allEventNames.first;
		
		tmpObj := self.allSelectedObjects.first;
		
		tmpType := tranUsedStr.scanUntil(':', pos).trimBlanks;
		if pos &gt; 1 then
			tranUsedStr := tranUsedStr[pos+2:end].trimBlanks;
		else
			tmpType := null;
		endif;
		
		// Validation should have caught null object.
		self.getObjectKeyAndType(tmpObj, objKey, objType);
		
		self.myPxyEventRequestNotify.setProxyEventNameType(tranUsedStr, tmpType, objKey, objType);
		
		cnt := 1;
		updateID := self.cargoIds.getDelimitedToken(cnt, CrLf, delmiter);
		self.myPxyEventRequestNotify.setProxyCargoId(updateID);
		
		if _passport.noErrors then
			realRequest.setForUpdate(self.myPxyEventRequestNotify, _passport);
			realRequest.setMyEventRequestEmail(_email);
		endif;
		
		self.updateStatusCount(realRequest);
		
	endif;
	
	//-----------------------------------------------------------------------------------------
	// Adding - We re-use self.myPxyEventRequestNotify to create new requests for each new ID
	//-----------------------------------------------------------------------------------------
	length := self.cargoIds.length;
	cnt := 1;
	while true do

		tmpCargoId := self.cargoIds.getDelimitedToken(cnt, CrLf, delmiter);

		if tmpCargoId = null then
			if cnt &gt;= length then
				break;
			endif;
			continue;
		endif;

		if tmpCargoId.length &gt; TrackedItemID_Length then
			app.raiseCMException2(ContainerIdToLong, tmpCargoId, TrackedItemID_Length.String, ETRow_CargoId, null);	
			return;
		endif;			

		idx := 0;
		self.myPxyEventRequestNotify.setProxyCargoId(tmpCargoId.toUpper);
		foreach tmpStr in self.allEventNames do
			idx := idx + 1;
			pos := 1;
			tmpType := tmpStr.scanUntil(':', pos).trimBlanks;
			if pos &gt; 1 then
				tmpStr := tmpStr[pos+2:end].trimBlanks;
			else
				tmpType := null;
			endif;
			
			if tmpStr = tranUsedStr then		
				if updateID = tmpCargoId then
					// ID updated above for this transClassName don't create another
					continue;
				endif;
			endif;
			
			tmpObj := self.allSelectedObjects[idx];
			// Validation should have caught null object.
			self.getObjectKeyAndType(tmpObj, objKey, objType);
						
			self.myPxyEventRequestNotify.setProxyEventNameType(tmpStr, tmpType, objKey, objType);
			
			create realRequest as self.myPxyEventRequestNotify.class persistent;
			realRequest.setForCreate(self.myPxyEventRequestNotify, _passport);
			realRequest.setMyEventRequestEmail(_email);
			self.updateStatusCount(realRequest);
			
		endforeach;
		if cnt &gt;= length then
			break;
		endif;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_email" type="CM_EventRequestEmail" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="expandCargoIDs" id="0cfd070b-3b68-4f4d-bad5-c314fda842ed">
        <updating/>
        <source>expandCargoIDs(_validate : Boolean)  updating;
// ---------------------------------------------------------------------------
// Created:		02 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		CCMS 1542 This string may have a range of numbers 
//					e.g. kilo9101012 - kilo9101022 this needs to be expanded to a comma seperated list 
//					i.e. kilo9101011, kilo9101013, kilo9101014 etc
//
// ---------------------------------------------------------------------------
// 02/03/2011	cnwcs5	par 26977 - change range character from "-" to " - "
//								  - use constants for all special characters
//								  - also fix exception where range character is last position in string
constants
	RANGE_STRING 	= " - ";
	RANGE_CHARACTER = 01.Character.String;	// non printable character so won't have been entered by user
	COMMA			= ",";
vars
	tmpIDs 									: String;
	len, idx, idy, num3,  num1, num2 		: Integer;
	rangeStr, tmpStr 						: String;
	part1, part2 							: String;
	tmpID, cargoIDS, cargoID, lett1, lett2 	: String;
	ed,  a, b , c, pos						: Integer;
begin
	tmpStr := self.cargoIds;
	
	// treat '--' same as '-' (not sure why?)
	tmpStr := tmpStr.replace("--", "-");

	// no ranges so nothing to do
	if tmpStr.pos(RANGE_STRING, 1) = 0 then
		return;
	endif;
	
	// it is easier if our range is a single character
	tmpStr := tmpStr.replace(RANGE_STRING, RANGE_CHARACTER);
	// get rid of any spaces in there
	tmpStr := tmpStr.replace(" ", null);	// 02/03/2011 cnwcs5

	idx := 1;
	ed 	:= tmpStr.length;
	a 	:= 1;
	
	foreach idx in 1 to ed do
		if tmpStr[idx:1] = COMMA then
			b := idx;
			if b &gt; a then
				tmpID :=  tmpStr[a:(b-a)];
				if tmpID.pos(COMMA,1) = 0 then
					tmpID := tmpID.trimBlankCharacters() &amp; COMMA;
				endif;
				cargoIDS := cargoIDS &amp; tmpID;
				a := b + 1;
			endif;
		elseif tmpStr[idx:1] = RANGE_CHARACTER then
			c := tmpStr.pos(COMMA,idx);
			if c = 0 then
				rangeStr := tmpStr[b + 1 : end];
			else
				a := c + 1;
				rangeStr := tmpStr[b + 1 : (c - b - 1)];
			endif;
			
			pos		:= rangeStr.pos(RANGE_CHARACTER,1);	// 02/03/2011 cnwcs5
			part1 	:= rangeStr[1 : pos - 1];			// 02/03/2011 cnwcs5
			
			if pos &lt; rangeStr.length then				// 02/03/2011 cnwcs5
				part2 	:= rangeStr[pos + 1: end];		// 02/03/2011 cnwcs5
			else										// 02/03/2011 cnwcs5
				part2 	:= null;						// 02/03/2011 cnwcs5
			endif;										// 02/03/2011 cnwcs5
			
			part1	:= part1.trimBlankCharacters();
			part2 	:= part2.trimBlankCharacters();
			
			part1.splitIntoNumbersLetters(lett1, num1);
			part2.splitIntoNumbersLetters(lett2, num2);
			
			lett1 	:= lett1.trimBlankCharacters();
			lett2 	:= lett2.trimBlankCharacters();
			len 	:= part1.length() - lett1.length();
		
			if _validate then
				if (lett1 &lt;&gt; null and lett2 &lt;&gt; null ) and lett1 &lt;&gt; lett2 then
					app.raiseCMException2(Your_range_must_begin_with_sam, lett1, lett2, null, null);	
				endif;
				if num2 &lt; num1 then
					num3 := num1;
					num1 := num2;
					num2 := num3;
				endif;
				
				if (num2 - num1) &gt; 1000 then
					app.raiseCMException(Your_range_will_creat_more_tha, null, null);	
				endif;
				if num2 = 0 or num1 = 0 then
					app.raiseCMException(Your_range_must_have_numbe_ran, null, null);	
				endif;
				
				if app.myPassport.hasErrorsOrWarnings() then
					return;
				endif;
			endif;
			
			foreach idy in num1 to num2 do
				cargoID 	:= lett1.trimBlankCharacters() &amp; idy.padLeadingWith("0", len);
				cargoIDS 	:= cargoIDS &amp;   cargoID &amp; COMMA;
			endforeach;
			
			// no more commas
			if tmpStr.pos(COMMA,idx) = 0 then
				a := 0;
			endif;
		endif;
	endforeach;
	
	if a &gt; 0 and a &lt; ed then 
		tmpID 		:=  tmpStr[a:(ed-a + 1)];
		tmpID 		:= tmpID.trimBlankCharacters();
		cargoIDS 	:= cargoIDS &amp; tmpID;
	endif;

	self.cargoIds 	:= cargoIDS;
end;</source>
        <Parameter name="_validate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getObjectKeyAndType" id="30f66ef3-7cb8-4254-9ca6-29358eee109f">
        <source>getObjectKeyAndType(_object : Object input; _key, _type : Integer output) protected;

// Created by cnwdvb1 on 02 May 2007

vars

begin

	if _object = null then
		return;
	endif;
	
	if CM_TransactionType.hasInstance(_object) then
		_type := CM_EventRequestNotification.Event_Type_Transaction;
		_key := _object.CM_TransactionType.trxType;
		if _key = TRANS_TYPE_AvailableForRelease then
			_type := CM_EventRequestNotification.Event_Type_IsAvailable;
		endif;
	elseif CM_StopsTable.hasInstance(_object) then
		_type	:= CM_EventRequestNotification.Event_Type_Stop;
		_key 	:= _object.CM_StopsTable.id;
	elseif CM_ToDoTaskDesc.hasInstance(_object) then
		_type	:= CM_EventRequestNotification.Event_Type_TodoTask;
		_key	:= _object.CM_ToDoTaskDesc.code;
	else
		// Not interested.
		_key := 0;
		_type := 0;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="Object" usage="input"/>
        <Parameter name="_key" type="Integer" usage="output"/>
        <Parameter name="_type" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="updateStatusCount" id="65e57631-f020-474a-b662-847495299a3e">
        <updating/>
        <source>updateStatusCount(_realRequest : CM_EventRequest) updating, protected;
//--------------------------------------------------
// Created:	26 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if _realRequest = null then
		return;
	endif;
	
	if _realRequest.status = EventRequestActioned then
		self.numActioned := self.numActioned+1;
	
	elseif _realRequest.status = EventRequestMatched then
		
		if _realRequest.actionFailedReason &lt;&gt; null then
			self.numMatchFailed := self.numMatchFailed+1;			
		else
			self.numActioned := self.numActioned+1;
		endif;
	else
		self.numPending := self.numPending+1;			
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_realRequest" type="CM_EventRequest"/>
    </JadeMethod>
    <JadeMethod name="validate" id="88cb7faa-3ac2-4499-b80c-413d6e190d4d">
        <updating/>
        <source>validate(_passport : CM_Passport input)updating;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	obj : Object;
	pxyCargoUpdateRequest : CM_EventRequestStops;
begin
	self.validateIds(_passport);
	if _passport.hasErrors then
		return;
	endif;
	
	if self.myPxyEventRequestNotify &lt;&gt; null then
		self.validateNotify(_passport);
	endif;
	if self.myPxyEventRequestEmail &lt;&gt; null then
		self.myPxyEventRequestEmail.validateMe(_passport);
	endif;
	
	foreach obj in self.allPxyCargoUpdateRequests do
		pxyCargoUpdateRequest:= obj.CM_EventRequestStops;
		app.myValCA.valCM_Object( pxyCargoUpdateRequest, _passport );
	endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateIds" id="eeb1f7fc-84dc-4cb9-924c-0ec09c930dbf">
        <updating/>
        <source>validateIds(_passport : CM_Passport input)updating, protected;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
// 21/02/2011	cnwcs5	par 26977 - treat hyphen as a range ONLY for cargo type ISO Container
// 02/03/2011	cnwcs5	par 26977 - above changes backed out.  expandcargoIDs changed instead
vars
	cnt, length 			: Integer;
	delmiter, tmpCargoId 	: String;
	proxy 					: CM_EventRequestTI;
	cargoType				: CM_CargoBOLType;
begin
	self.expandCargoIDs(true);					

	self.cargoIds := self.cargoIds.splitToMultiLine();
	self.cargoIds := self.cargoIds.trimCharacters(CrLf); // trim the blank lines at the end of the String.

	length 	:= self.cargoIds.length;
	cnt 	:= 1;
	
	while true do
		tmpCargoId := self.cargoIds.getDelimitedToken(cnt, CrLf, delmiter);
		if tmpCargoId = null then
			if cnt &gt;= length then
				break;
			endif;		
			continue;
		endif;
		if tmpCargoId.length &gt; TrackedItemID_Length then
			app.raiseCMException2(ContainerIdToLong, tmpCargoId, TrackedItemID_Length.String, ETRow_CargoId, null);	
		endif;
		if cnt &gt;= length then
			break;
		endif;
	endwhile;
					
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateNotify" id="8b258180-3a63-47ba-9549-cf6d1a74f7bb">
        <source>validateNotify(_passport : CM_Passport input)protected;
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	cnt : Integer;
	saveID,
	delmiter,
	saveTransClass,
	tmpCargoId : String;
	obj			: Object;
	objKey,
	objType		: Integer;
begin

	if self.myPxyEventRequestNotify = null then
		return;
	endif;
	
	app.setContinueCMExceptions(true);
	
	saveID := self.myPxyEventRequestNotify.cargoId;
	saveTransClass := self.myPxyEventRequestNotify.eventName;
	cnt := 1;
	
	self.myPxyEventRequestNotify.setProxyCargoId(self.cargoIds.getDelimitedToken(cnt, CrLf, tmpCargoId));
	
	obj := self.allSelectedObjects.first;
	self.getObjectKeyAndType(obj, objKey, objType);
	self.myPxyEventRequestNotify.setProxyEventNameType(self.allEventNames.first, self.myPxyEventRequestNotify.eventType, objKey, objType);	
	
	app.myValCA.valCM_Object(self.myPxyEventRequestNotify, _passport);

//	self.myPxyEventRequestNotify.setProxyCargoId(saveID);
//	self.myPxyEventRequestNotify.setProxyEventNameType(saveTransClass, self.myPxyEventRequestNotify.eventType);		

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
