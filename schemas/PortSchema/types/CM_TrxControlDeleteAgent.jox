/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwas3	Initial creation

*/

vars
	alloc : CM_YardAllocation;
	voyAllocation : CM_VoyageAllocation;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	foreach alloc in _voyAllocations  discreteLock do
		voyAllocation := alloc.CM_VoyageAllocation;
		
		app.myUtilityDA.utlDeleteVoyageAllocation(voyAllocation, _passport);
		//cnwmc5 - par 30052 - removed this because it was causing the delete all to stop after a warning
		/*if _passport.hasErrorsOrWarnings() then
			break;
		endif;*/
		//cnwmc5 - par 30052 - replaced with this
		if _passport.hasErrors() then
			break;
		endif;
	endforeach;
epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
