    <JadeMethod name="addMethodToList" id="37d03996-627c-4a64-b7ed-81dc30a1b38d">
        <updating/>
        <source>addMethodToList(_method : Method; _level : Integer; _processSuperClassRefs : Boolean) updating;

/*

Purpose:			

Date			Who		Reason
12/04/2013		cnwmh5	Initial creation

*/

vars

	refMethod					: Method;			// The method in which "pMethod" is referenced (invoked).
	methodRefSet				: MethodSet;		// A set of the methods in which "pMethod" is referenced (invoked).
	superMethod					: Method;
	
	iter						: Iterator;
	
	index						: Integer;
	tabsToWrite					: String;
	count 						: Integer;
	usageFormUnitTest			: Character;
	
begin

	if self.allRefs.includes(_method) then
		return;
	endif;	
	
	// new so add to allRefs collection
	self.allRefs.add(_method);
	self.refsByLevel.add(_level);
	self.uniqueMethsByLevel.add(_level);
	
	// add to the dyna dict
	usageFormUnitTest := null;
	superMethod := _method.getPropertyValue("superMethod").Method;
	//if _method.schemaType.name = "JMTUnitTest" then
	if _method.getSchema().name = "JMTUnitTest" then
		if _method.isRunnableUnitTestMethod() or _method.name[1] = "v" then
			usageFormUnitTest := "U";
		else	
			usageFormUnitTest := "M";
		endif;
	///elseif _method.getSchemaType().isKindOf(Form) then
	elseif _method.getSchemaType().isKindOf(GUIClass) or _method.getSchemaType().isKindOf(Form) or
			(superMethod &lt;&gt; null and superMethod.getSchemaType().name = "SOP_TableMaintItem") then
		usageFormUnitTest := "F";
	else
		usageFormUnitTest := "M";
	endif;
	
	//write _method.getSchemaType().String &amp; Tab &amp; _method.getSchemaType().name &amp; Tab &amp; _method.schemaType.name &amp; Tab &amp; _method.getSchema().name &amp; Tab &amp; 
	//	_method.name &amp; Tab &amp; usageFormUnitTest &amp; Tab &amp; _level.String;
	
	if usageFormUnitTest &lt;&gt; null then
		if self.tempDictionary[self.currentMethod.getSchemaType().name, self.currentMethod.name, _method.getSchemaType().name,
				_method.name, usageFormUnitTest] = null then
			self.tempDictionary.putAtKey(self.currentMethod.getSchemaType().name, self.currentMethod.name, _method.getSchemaType().name, 
				_method.name, usageFormUnitTest, _method);
		endif;
	endif;
	
	create methodRefSet transient;
	_method.getMethodRefs(methodRefSet);
	foreach refMethod in methodRefSet do
		self.addMethodToList(refMethod, _level + 1, _processSuperClassRefs);
	endforeach;
	
	if _processSuperClassRefs then
		self.processSuperClassRefs(_method.schemaType, _method.name, _level, _processSuperClassRefs);
	endif;

epilog

	delete methodRefSet;
	delete iter;

end;</source>
        <Parameter name="_method" type="Method"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_processSuperClassRefs" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearCollections" id="707c4d97-d420-4717-9e0d-229d4d430e05">
        <updating/>
        <source>clearCollections(_clearTempDictionary : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
15 April 2013	cnwmh5	Initial creation

*/

vars

begin

	self.allRefs.clear();
	self.refsByLevel.clear();
	self.uniqueMethsByLevel.clear();
	if _clearTempDictionary then
		self.tempDictionary.clear();
	endif;
	
epilog

end;</source>
        <Parameter name="_clearTempDictionary" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="bf9a5de1-83bc-46f2-9aba-93db9b89b0e6">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 April 2013	cnwmh5	Initial creation

*/

vars

begin

	///if self.allRefs = null then
	///	create self.allRefs transient;
	///endif;
	
	if self.refsByLevel = null then
		create self.refsByLevel transient;
		//refsByLevel[500] := 0;
	endif;

	if self.uniqueMethsByLevel = null then
		create self.uniqueMethsByLevel transient;
		//uniqueMethsByLevel[500] := 0;
	endif;
	
	//if self.tempDictionary = null then
		//create self.tempDictionary transient;
		self.tempDictionary.setMembership(Method);
		self.tempDictionary.addExternalKey(String, 100, false, false);			// Trx Class Name
		self.tempDictionary.addExternalKey(String, 100, false, false);			// Trx Method Name
		self.tempDictionary.addExternalKey(String, 100, false, false);			// Method Class Name
		self.tempDictionary.addExternalKey(String, 100, false, false);			// Method Method Name
		self.tempDictionary.addExternalKey(Character, 1, false, false);			// Whether a (U)nit Test or (F)orm usage
		self.tempDictionary.endKeys(false);
	//endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="f1fe3e14-be0b-4518-a21d-72707296ff96">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
18 April 2013	cnwmh5	Initial creation

*/

vars

begin

	self.clearCollections(true);
	
	//delete self.tempDictionary;
	///delete self.allRefs;
	delete self.refsByLevel;
	delete self.uniqueMethsByLevel;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="processSuperClassRefs" id="e53e737a-4946-41dc-93e4-227bc48a3705">
        <updating/>
        <source>processSuperClassRefs(_type : Type; _methodName : String; _level : Integer; _processSuperClassRefs : Boolean) updating;

/*

Purpose:			

Date			Who		Reason
12/04/2013		cnwmh5	Initial creation

*/

vars

	meth						: Method;
	methodRefSet				: MethodSet;
	cls							: Class;
	
begin

	if _type.isKindOf(Class) then					// 16/07/2015 cnwmh5
		cls := _type.Class.getSuperclass;
	endif;
	if cls = null then
		return;
	endif;
	
	if cls.schema = rootSchema then
		return;
	endif;
	
	meth := cls.getMethod(_methodName);
	if meth &lt;&gt; null then
		if not self.allRefs.includes(meth) then
			self.addMethodToList(meth, _level, _processSuperClassRefs);
		endif;
	endif;
	
	self.processSuperClassRefs(cls, _methodName, _level, _processSuperClassRefs);

epilog

end;</source>
        <Parameter name="_type" type="Type"/>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_processSuperClassRefs" type="Boolean"/>
    </JadeMethod>
