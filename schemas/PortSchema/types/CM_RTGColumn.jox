    <JadeMethod name="getFullID" id="a0e547a9-1d24-478b-8163-fd9031a02bbd">
        <source>getFullID(_is40: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwer1	Initial creation

*/

vars
	tmpLbl : String;
	bayNum : Integer;
	iter : Iterator;
	nextBay : CM_GridColumn;
begin
	tmpLbl := self.getLabel();

	if _is40 and self.column.isEven and self.myGridArea.use40ftIds then
		if self.allControllersByRow.first.get40ftColumnLabel &lt;&gt; null then
			tmpLbl	:= self.allControllersByRow.first.get40ftColumnLabel;
		else
			iter:=self.myGridArea.allGridColumns.createIterator;
			iter.startAtObject(self);
			if self.myGridArea.areColumnsDecreasing then
				iter.back(nextBay);
				iter.back(nextBay);
			else
				iter.next(nextBay);
				iter.next(nextBay);
			endif;
			
			if nextBay &lt;&gt; null then
				bayNum:=((self.label.Integer + nextBay.label.Integer)/2).Integer;
				if bayNum &lt; 100 then
					tmpLbl := bayNum.padLeadingWith("0",2);
				else
					tmpLbl := bayNum.padLeadingWith("0",3);
				endif;
			endif;
			delete iter;
		endif;
	endif;
	
	tmpLbl := self.myGridArea.getID()  &amp;  tmpLbl;
	
	return tmpLbl;

epilog

end;</source>
        <Parameter name="_is40" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyLaneController" id="9ce85571-7604-48ec-8d81-05a0da738965">
        <source>getMyLaneController(): CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2009	cnwer1	Initial creation

*/

vars

begin
	
	if self.myTopGantryICColumn &lt;&gt; null then
		return self.myTopGantryICColumn.allControllersByRow[1];
	elseif self.myBottomGantryICColumn &lt;&gt; null then
		return self.myBottomGantryICColumn.allControllersByRow[1];
	endif;
	return null;
	
end;
</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="5308230c-12b9-4bad-81f4-14e05bb5ab9a">
        <source>getNiceName(): String;
// ---------------------------------------------------------------------------
// Created:		21 February 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realMe : SelfType;
begin
	realMe := self;
	
	if realMe.pxyIsProxy() then
		realMe := self.pxyGetRealObject();
	endif;

	return realMe.myGridArea.allGridColumnsByLabel.indexOf(realMe).padLeadingWith("0",2) &amp; " - Bay " &amp;  realMe.label.String;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setColumnLabel" id="594f9148-8a29-41ff-85b3-fa9224dacf36">
        <updating/>
        <source>setColumnLabel(_label: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwer1	Initial creation

*/

vars

begin
	inheritMethod(_label);
	if self.myBottomGantryICColumn &lt;&gt; null then
		self.myBottomGantryICColumn.setColumnLabel(_label);
	endif;
	if self.myTopGantryICColumn &lt;&gt; null then
		self.myTopGantryICColumn.setColumnLabel(_label);
	endif;

epilog

end;</source>
        <Parameter name="_label" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyBottomGantryICCol" id="2494284f-274d-4a2b-a2b3-2397ffefe2bb">
