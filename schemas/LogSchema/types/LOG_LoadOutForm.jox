	self.tblItems04.tabKey := J_key_Tab;
	self.tblItems05.tabKey := J_key_Tab;
	self.tblItems06.tabKey := J_key_Tab;				
	
	self.clearTblItems();
												
end;</source>
    </JadeMethod>
    <JadeMethod name="initTblNNData" id="fd28d7b4-b1e1-4ebe-9f5e-6dd1dfbcef47">
        <source>initTblNNData();
//--------------------------------------------------------------
//Created: 10 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entTableDef : EntTableDef;
	view	: EntTableView;
begin
	
	entTableDef := app.myController.getEntTableDef(ETDef_NoNumberData);
	tblNNData.userInputEnabled := true;
	//tblNNData.selectMode := Table.SelectMode_CurrentRow;
	tblNNData.rows := tblNNData.fixedRows;
	tblNNData.autoSize := Table.AutoSize_Column;
	tblNNData.readOnly := false;			
	tblNNData.setTblDataEntRowsFromDef(entTableDef);
	tblNNData.setMyDataClass(CM_SOHLocation);
	tblNNData.myDynaDict.addMemberKey('myProduct', false, true);
	tblNNData.myDynaDict.endKeys(true);
	tblNNData.tabKey := J_key_Tab;
	tblNNData.accessColumn(1).alignment := Table.Alignment_Center_Middle;
	tblNNData.accessColumn(2).alignment := Table.Alignment_Left_Middle;
	tblNNData.accessColumn(3).alignment := Table.Alignment_Left_Middle;
	tblNNData.accessColumn(4).alignment := Table.Alignment_Right_Middle;
	tblNNData.accessColumn(5).alignment := Table.Alignment_Right_Middle;
	tblNNData.accessColumn(6).alignment := Table.Alignment_Right_Middle;	
	tblNNData.accessColumn(7).alignment := Table.Alignment_Right_Middle;

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblOnBoard" id="cd193794-7418-4621-8c21-bdc4a1fbeedc">
        <source>initTblOnBoard();
//--------------------------------------------------------------
//Created: 10 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entTableDef : EntTableDef;
	str	: String;
begin
	
	entTableDef := app.myController.getEntTableDef(ETDef_ItemsOnBoard);
	tblOnBoard.userInputEnabled := false;
	tblOnBoard.selectMode := Table.SelectMode_None;
	tblOnBoard.autoSize := Table.AutoSize_Column;
	tblOnBoard.rows := tblOnBoard.fixedRows;
	tblOnBoard.readOnly := true;			
	tblOnBoard.setTblDataEntRowsFromDef(entTableDef);
//	tblOnBoard.setMyDataClass(CM_LogVoyageController);
//	tblOnBoard.myDynaDict.addMemberKey('myLogLot', false, true);
//	tblOnBoard.myDynaDict.endKeys(true);
	tblOnBoard.tabKey := J_key_Tab;
	tblOnBoard.alignment := Table.Alignment_Left_Middle;

	cmbFilterPlace.addItem(str);
	str := app.vesselPlaceEnumToStr(PlaceHold);
	cmbFilterPlace.addItem(str);
	str := app.vesselPlaceEnumToStr(PlaceDeck);
	cmbFilterPlace.addItem(str);
end;</source>
