    <JadeMethod name="getCargoGroups" id="1470bada-9973-400a-b097-f97f74ba3adf">
        <source>getCargoGroups();
/*
Purpose:			

Date		Who		Reason
30 June 2023	navab1	 CR 58857 TASK 58967 
*/

vars

begin
	
	if self.myVoyage &lt;&gt; null then
		self.myVoyage.getAllCargoGroups(self.allCargoGroups);
	elseif self.myCargoGroup &lt;&gt; null then
		self.allCargoGroups.add(self.myCargoGroup);
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="recalculate" id="cd61474a-9f38-4362-a6ca-2ac6e1ee3e26">
        <source>recalculate();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2022	navam1	Initial creation TFS 53390
27 May 2022	navdap1	TFS 53737 MTN Upgrading STW1 environment caused a 1090 Release App part of the upgrade
20 Apr 2023 navmd1	TFS 56062 EUP Show Pre-Noted cargo in Voyage Ops
18 May 2023	navmd1	TFS 56062 Fix incorrect header values
 // ### TFS  CR 58857 TASK 58967  30JUN2023 NAVAB1
09 Apr 2024	navdap1	TFS 63307 EUP | Performance - Cargo Enquiry Bulk Updates
*/

vars
	ti : CM_TrackedItem;
	dtl : CM_CargoGroupDetail;
	cargoGroup : CM_CargoGroup;
	transportCode : String;
	site : Integer;
	train : CM_Train;
	voyage : CM_Voyage;
	trans : CM_TITransaction;
	failed : Boolean;		// TFS 63307

begin


// ### TFS BUG 58853 10JUL2023 NAVAB1 - not used



























	
	// read all TIs attached to the Cargo Group and accumulate totals by transport code and site
	// transport code is - voyage code if site is On Ship or was received via ship
	//					 - "TRUCK" if cargo was received via road or is a road prenote
	//					 - train code if cargo was received via rail or is a rail prenote
	
	// ### TFS  CR 58857 TASK 58967  30JUN2023 NAVAB1	cargoGroup := self.myCargoGroup;
	foreach cargoGroup in self.allCargoGroups as CM_CargoGroup discreteLock do
		foreach ti in cargoGroup.allAssignedTrackedItems discreteLock do
			// only interested in on ship, on site, off site and prenotified
			if ti.site &gt; TI_SITE_ONSHIP then
				continue;
			endif;
			
			train := null;
			voyage := ti.myVoyage;
			transportCode := TI_TRANSMODE_NULL_STR;
			
			site := ti.site;		
			if site = TI_SITE_ONSHIP then
				transportCode := ti.myVoyage.code;
			elseif site = TI_SITE_UNDEFINED then
				if ti.myNotifiedWagon &lt;&gt; null then
					transportCode := ti.myNotifiedWagon.myTrainInwards.code;
				else
					transportCode := self.TRUCK;
				endif;
			elseif site = TI_SITE_OFFSITE or site = TI_SITE_ONSITE then
				trans := ti.getTransReceive();
				if trans.isKindOf(CM_ReceiveRail) then
					transportCode := trans.CM_ReceiveRail.trainCode;
					train := trans.CM_ReceiveRail.getMyTrain;
				elseif trans.isKindOf(CM_ReceiveShip) or trans.isKindOf(CM_ReceiveTranship) then
					transportCode := trans.getVoyageCode;		// TFS 53737
					//voyage := trans.getMyVoyage;				// TFS 53737	// TFS 56062 CM_CargoGroupDetail::myVoyage (and therefore CM_Voyage::allCargoGroupDetails) should be the current voyage, not the recevial one!
				elseif ti.receiptTransportMode = TI_TRANSMODE_ROAD then
					transportCode := self.TRUCK;
				else
					// Probably Dev Quick Create cargo, so lets just use the current voyage code
					transportCode := voyage.code;
				endif;
			endif;
			
			// do we have a detail record for this site / transport code yet
// ### TFS BUG 58853 10JUL2023 NAVAB1			dtl := self.allDetailsByTransportSite[cargoGroup,transportCode, site].CM_CargoGroupDetail;// ### TFS  CR 58857 TASK 58967  30JUN2023 NAVAB1 changed voyage to cargo group
			if dtl = null then
				create dtl persistent;
				dtl.initialise(transportCode, site, cargoGroup, train, voyage);
// ### TFS BUG 58853 10JUL2023 NAVAB1				self.allDetailsByTransportSite.add(dtl);
			endif;
			dtl.addTIToDetail(ti, failed);	// TFS 63307
			if failed then					// TFS 63307
				continue;					// TFS 63307
			endif;							// TFS 63307
		endforeach;
	endforeach;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="recalculateForVoyage" id="8c5d9250-19df-423a-9b87-b1fbe75b4430">
        <source>recalculateForVoyage();
/*
Purpose: EUP want to have TIs groups by cargo group in road, rail and voyage operations. Initially this is just for voyage operations.
			Create cargo group details for the voyage one for each site. In voyage operations can just display these to help with performance

Date		Who		Reason
06JUL2023	NAVAB1	BUG 58853
09 Apr 2024	navdap1	TFS 63307 EUP | Performance - Cargo Enquiry Bulk Updates
*/

vars
	ti : CM_TrackedItem;
	dtl : CM_CargoGroupDetail;
	cargoGroup : CM_CargoGroup;
	transportCode : String;
	site : Integer;
	voyage : CM_Voyage;
	failed : Boolean;			// TFS 63307

begin
	
	// read all TIs attached to the Cargo Group and accumulate totals by voyage code and site
	
	// ### TFS  CR 58857 TASK 58967  30JUN2023 NAVAB1	cargoGroup := self.myCargoGroup;
	foreach cargoGroup in self.allCargoGroups as CM_CargoGroup discreteLock do		: cargogroups		// TFS 63307
		foreach ti in cargoGroup.allAssignedTrackedItems discreteLock do
			// only interested in on ship, on site, off site and prenotified
			if ti.site &gt; TI_SITE_ONSHIP then
				continue;
			endif;
		
			if ti.isChild then // ### TFS BUG 58853 11JUL2023 NAVAB1
				continue;
			endif;
			
			voyage := ti.myVoyage;
			if voyage &lt;&gt; null then
				transportCode := voyage.code;
			else
				continue;
			endif;
			
			site := ti.site;		
			
			// do we have a detail record for this site / transport code yet
 // ### TFS BUG 58853 10JUL2023 NAVAB1			dtl := self.allDetailsByTransportSite[cargoGroup,transportCode, site].CM_CargoGroupDetail;// ### TFS  CR 58857 TASK 58967  30JUN2023 NAVAB1 changed voyage to cargo group
			
			dtl := voyage.allCargoGroupDtlBySiteCargoGrp[site,cargoGroup.id]; // ### TFS BUG 58853 10JUL2023 NAVAB1
			if dtl = null then
				create dtl persistent;
				dtl.initialise(transportCode, site, cargoGroup, null, voyage);
 // ### TFS BUG 58853 10JUL2023 NAVAB1				self.allDetailsByTransportSite.add(dtl);
			endif;
			dtl.addTIToDetail(ti, failed);		// TFS 63307
			// TFS 63307 if failed is true, we got a deadlock trying to add this TI the the
			// cargo group detail - just skip this cargo group, and this detail will be updated by the 
			// deadlocking process later
			if failed then
				app.writeLog(method.qualifiedName &amp; Tab &amp; "Deadlock - Skipping updates for all cargo groups", LogDEBUG);
				break cargogroups;
			endif;
			// TFS 63307 end
		endforeach;
	endforeach;
	
epilog
	
end;</source>
    </JadeMethod>
</Class>
