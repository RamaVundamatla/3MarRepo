    <JadeMethod name="setupForm" id="a0c567f8-3c01-4af2-a717-3ee76e30cc8f">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	str : String;
	totTIs, aveWGT : Integer;
	midTI : CM_TrackedItem;
begin	
	self.handleMenusForModalDisplay();
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	self.myTerminal	:= app.getMyTerminalDO_NOT_USE();
//	self.getXMLSettingsForSetup();
	self.initTableData(ETDef_LlHeadings);
	
	self.myJobController.allTIs.copy(self.allTIs);
	self.myJobController.allReasons.copy(self.allReasons);
	self.myCurrentVoyage := self.myJobController.myVoyage;
	
	self.caption := self.myCurrentVoyage.code &amp; " " &amp; self.caption;
	inheritMethod();

	self.doQuery();

end;</source>
    </JadeMethod>
