    <JadeMethod name="loadReports" id="98a2eff7-ad10-407c-826f-be7ed5ce0172">
        <source>loadReports() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	sourceCompareRoot	: DEV_SourceCompareRoot;
	sourceCompareReport	: DEV_SourceCompareReport;
	index				: Integer;
	
begin
	self.cmbSelectReport.clear();
	
	sourceCompareRoot := DEV_SourceCompareRoot.instances.first.DEV_SourceCompareRoot;
	
	if sourceCompareRoot &lt;&gt; null and sourceCompareRoot.allSourceCompareReports &lt;&gt; null then
		foreach sourceCompareReport in sourceCompareRoot.allSourceCompareReports reversed, discreteLock where sourceCompareReport.isAvailable do
			index := self.cmbSelectReport.addItem(sourceCompareReport.getDisplayName);
			self.cmbSelectReport.itemObject[index] := sourceCompareReport;
			
			if sourceCompareReport.reportType = DEV_SourceCompareReport.ReportType_Manual then
				self.cmbSelectReport.itemBackColor[index] := PalePink;
			endif;
			
		endforeach;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="mnuDetails_click" id="d22c023a-e81d-40f3-a859-925c87c5e61b">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuDetails_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	listBox		: ListBox;
	selIndex	: Integer;
	anObject	: Object;
	
begin
	if self.mnuLBContext.userObject = null then
		write method.qualifiedName &amp; " No userObject set on mnuLBContext";
		return;
	endif;
	
	listBox := self.mnuLBContext.userObject.ListBox;
	selIndex := listBox.listIndex;
	anObject := listBox.itemObject[selIndex];
	
	if listBox &lt;&gt; null then
		self.doShowDetails(listBox);
	endif;
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuInspect_click" id="e5aa804e-cd65-4db2-b56f-866c3061f5d2">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuInspect_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2024	navpw1	Initial creation

*/

vars
	listBox		: ListBox;
	selIndex	: Integer;
	anObject	: Object;
	
begin
	if self.mnuLBContext.userObject = null then
		write method.qualifiedName &amp; " No userObject set on mnuLBContext";
		return;
	endif;
	
	listBox := self.mnuLBContext.userObject.ListBox;
	selIndex := listBox.listIndex;
	anObject := listBox.itemObject[selIndex];
	
	if anObject &lt;&gt; null then
		anObject.inspectModal;
	endif;
	
end;</source>
