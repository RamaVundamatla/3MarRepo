    <JadeMethod name="pxyCreateUpdateProxy" id="b3c6c796-c53b-4a38-9db7-4add5fffe1fa">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlger1	Initial creation

*/

vars
	pxySelf : CM_WodMarineServicesInitial;
	completedOK : Boolean;
	pxyMarineService,
	marineService : CM_WodMarineServiceDetail;
	
begin
	
	pxySelf:= inheritMethod();
	foreach marineService in self.allMarineServiceDetails discreteLock do
		pxyMarineService:= marineService.pxyCreateUpdateProxy;
		if pxyMarineService &lt;&gt; null then	//17 Jul 2018	NDL	TFS 39742
			pxySelf.allMarineServiceDetails.add(pxyMarineService);
		endif;
	endforeach;
	
	pxySelf.myBerth := self.myBerth;	//25 Jun 2018	NDL	TFS 39248
	pxySelf.myTowingVoyage := self.myTowingVoyage;	//20 Sep 2018	NDL	TFS 40810
	
	
	completedOK:=true;
	return pxySelf;
epilog
	if not completedOK then
		delete pxySelf;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="requiresLengthOfTime" id="e70bf1ee-c4de-4048-916b-0b391d2fcf77">
        <source>requiresLengthOfTime(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2018	jlger1	Initial creation

*/

vars

begin
	if self.myBerth = null then
		return true;
	endif;
	//epr TFS 42396 13/12/18
	if self.myBerth.isLogicalBerth or not self.myBerth.requiresLengthOfTime then  
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="2bd7ac0c-3e46-44bc-8cd1-c09234e39418">
        <updating/>
        <source>setForCreate(_pxyWoDDtl: CM_WorkOrderDtl io; _realWorkOrder: CM_WorkOrder) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16/10/2018	jlgndl1	Initial creation	TFS 41412
04/12/2018	jlgdap1	TFS 42252 PEL1 Issues with voyages with no tug or pilot
03/04/2019	jlgdap1	TFS 43694 PEL1 Charging for Vessels that use a Ramp
*/

vars

	voyage : CM_Voyage;
	arrivalMovement : HMS_VoyageMovement;
	occursDateTime : TimeStamp;
	serviceTimings : HMS_MarineServicesTimings;				// TFS 42252

begin

	inheritMethod(_pxyWoDDtl, _realWorkOrder);
	
	self.originalHasRamp := _pxyWoDDtl.CM_WodMarineServicesInitial.hasRamp;			// TFS 43694
	self.hasRamp := _pxyWoDDtl.CM_WodMarineServicesInitial.hasRamp;					// TFS 43694

	voyage := self.getMyVoyageObject();
	if voyage &lt;&gt; null then
		arrivalMovement := voyage.getMovementArrival();
		if arrivalMovement &lt;&gt; null then
			occursDateTime := self.getOccursDT;
			//if occursDateTime.date.isValid and arrivalMovement.myMarineServiceTimings &lt;&gt; null then	// TFS 42252
			if occursDateTime.date.isValid then								// TFS 42252
				if arrivalMovement.myMarineServiceTimings = null then		// TFS 42252
					if arrivalMovement.isTransient then						// TFS 42252
						create serviceTimings transient;					// TFS 42252
					else													// TFS 42252
						create serviceTimings persistent;					// TFS 42252
					endif;													// TFS 42252
					serviceTimings.setMyVoyageMovement(arrivalMovement);	// TFS 42252
				endif;														// TFS 42252
				arrivalMovement.myMarineServiceTimings.setMovementDateTimes( occursDateTime, true, false, false, false );
				/* Ian says 'don't tick any box automatically and leave it up to the user to confirm on the movement 
									when the vessel moves away from the berth if the ramp was actually used there.'
				arrivalMovement.myMarineServiceTimings.setHasRamp(self.hasRamp);	// TFS 43694
				*/
			endif;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WorkOrderDtl" usage="io"/>
        <Parameter name="_realWorkOrder" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9851e016-f972-4211-bb36-766a5ee4eb6e">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WodMarineServicesInitial) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/06/2018	jlger1	Initial creation
23/07/2018	jlgdap1	TFS 39741 PEL1 Marine Service Timings Changes
03/04/2019	jlgdap1	TFS 43694 PEL1 Charging for Vessels that use a Ramp
*/

vars
	realMarineDetail,
	pxyMarineDetail : CM_WodMarineServiceDetail;
	pxyDetail : CM_WorkOrderDtl;
	
	wodMarineServiceDtl : CM_WodMarineServiceDetail;	//17 Jul 2018	NDL	TFS 39742
	purgeSet : CM_WodMarineServiceDetailSet;	//17 Jul 2018	NDL	TFS 39742
	voyage 		: CM_Voyage;
	permitRequest : CM_WodPermitRequest;
	arrivalMovement : HMS_VoyageMovement;				// TFS 43694
begin
	inheritMethod(_pxyWoDDtl);
	
	self.myBerth := _pxyWoDDtl.myBerth;	//25 Jun 2018	NDL	TFS 39248
	
	// TFS 40236
	self.bowMarkTo := _pxyWoDDtl.bowMarkTo;
	self.draftAft := _pxyWoDDtl.draftAft;
	self.draftFwd := _pxyWoDDtl.draftFwd;
	self.hasRamp := _pxyWoDDtl.hasRamp;
	self.starboardBerthed := _pxyWoDDtl.starboardBerthed;
	
	self.hasRamp := _pxyWoDDtl.hasRamp;														// TFS 43694
	voyage := self.getMyVoyageObject();														// TFS 43694
	if voyage &lt;&gt; null then																	// TFS 43694
		arrivalMovement := voyage.getMovementArrival();										// TFS 43694
		if arrivalMovement &lt;&gt; null and arrivalMovement.myMarineServiceTimings &lt;&gt; null then	// TFS 43694
				/* Ian says 'don't tick any box automatically and leave it up to the user to confirm on the movement 
									when the vessel moves away from the berth if the ramp was actually used there.'
			arrivalMovement.myMarineServiceTimings.setHasRamp(self.hasRamp);				// TFS 43694
			*/
		endif;																				// TFS 43694
	endif;																					// TFS 43694

	//17 Jul 2018	NDL	TFS 39742
	create purgeSet transient;
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if _pxyWoDDtl.allMarineServiceDetails.findWodMarineServiceDet( wodMarineServiceDtl.myHMSResource ) = null then
			purgeSet.add( wodMarineServiceDtl );
		endif;
	endforeach;
	if not purgeSet.isEmpty then
		foreach wodMarineServiceDtl in purgeSet do
			self.allMarineServiceDetails.remove( wodMarineServiceDtl );
		endforeach;
		purgeSet.purge();
	endif;
     
	foreach pxyMarineDetail in _pxyWoDDtl.allMarineServiceDetails discreteLock do
		 realMarineDetail:=pxyMarineDetail.pxyGetRealObject .CM_WodMarineServiceDetail;
		 pxyDetail:=pxyMarineDetail;
		 if realMarineDetail = null then
			 create realMarineDetail persistent;	
			
			 realMarineDetail.setForCreate(pxyDetail.CM_WodMarineServiceDetail, null);
			 self.allMarineServiceDetails.add(realMarineDetail);
		else
			realMarineDetail.setForUpdate(pxyMarineDetail);			
		endif;
	endforeach;
	
	// TFS 39741 Do we have a Pilot or Tug resource in allMarineServiceDetails
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if wodMarineServiceDtl.myHMSResource &lt;&gt; null then
		if wodMarineServiceDtl.myHMSResource.isResourceForClass(HMS_ResourceForPilot) 
		or wodMarineServiceDtl.myHMSResource.isResourceForClass(HMS_ResourceForTug) then
			wodMarineServiceDtl.doMarineServiceTimingsUpdate(true, true, false, false);
		endif;
		endif;
	endforeach;
	// TFS 39741 end
	
	self.myTowingVoyage := _pxyWoDDtl.myTowingVoyage;	//20 Sep 2018	NDL	TFS 40810
	//epr TFS 41946 10/11/18
	voyage :=self.getMyVoyageObject;
	if voyage &lt;&gt; null and voyage.myHMSVoyageData &lt;&gt; null then
		voyage.myHMSVoyageData.setMyTowingVoyage( _pxyWoDDtl.myTowingVoyage );
	endif;
	//epr 12/10/18 tfs 41310
	if self.myRelatedPermitRequest = null then
		
		if voyage &lt;&gt; null and voyage.myGeneralCargoVoyage = null then
			//find the ETMAL permit
			permitRequest:=voyage.allWorkOrders.getWODPermitForDetailType(self.detailType,WO_STATUS_COMPLETE).CM_WodPermitRequest;
			if permitRequest &lt;&gt; null then

				self.myRelatedPermitRequest:=permitRequest;
			endif;
			
		endif;
	endif;
	
epilog

	delete purgeSet;

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodMarineServicesInitial"/>
    </JadeMethod>
    <JadeMethod name="setMarineDetsFromResourceUsed" id="f1837393-2541-4e39-9aa8-b6d9ce89d2cb">
        <updating/>
        <source>setMarineDetsFromResourceUsed( _resourceUsedSet : HMS_ResourceUsedSet ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 July 2018	jlgndl1	Initial creation	TFS 39742

*/

vars

	wodMarineServiceDtl : CM_WodMarineServiceDetail;
	resourceUsed : HMS_ResourceUsed;
	purgeSet : CM_WodMarineServiceDetailSet;

begin
	
	create purgeSet transient;
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if _resourceUsedSet.findResourceUsedFor( wodMarineServiceDtl.myHMSResource ) = null then
			purgeSet.add( wodMarineServiceDtl );
		endif;
	endforeach;
	if not purgeSet.isEmpty then
		foreach wodMarineServiceDtl in purgeSet do
			self.allMarineServiceDetails.remove( wodMarineServiceDtl );
		endforeach;
		purgeSet.purge();
	endif;
	
	if _resourceUsedSet= null or _resourceUsedSet.isEmpty then
		return;
	endif;
	
	foreach resourceUsed in _resourceUsedSet do
		wodMarineServiceDtl := self.allMarineServiceDetails.findWodMarineServiceDet( resourceUsed.myResource );
		if wodMarineServiceDtl = null then
			if self.isTransient then
				create wodMarineServiceDtl transient;
			else
				create wodMarineServiceDtl persistent;
			endif;
			self.allMarineServiceDetails.add( wodMarineServiceDtl );
		endif;
		wodMarineServiceDtl.setProxyFromResourceUsed( resourceUsed );		
	endforeach;

epilog

	delete purgeSet;

end;</source>
        <Parameter name="_resourceUsedSet" type="HMS_ResourceUsedSet"/>
    </JadeMethod>
    <JadeMethod name="setMyBerth" id="db9acb59-011a-463a-9d3f-557dbb7e67b3">
