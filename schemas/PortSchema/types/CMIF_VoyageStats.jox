    <JadeMethod name="clearStats" id="02fe59bd-c2eb-4287-8069-6d05a75edcd6">
        <updating/>
        <source>clearStats() updating;
/*

Date		Who		Reason
05 August 2013	cnwer1	Initial creation PAR 31764

*/

vars

begin
    self.jobsCompleted		:= 0;
	self.jobsPartCompleted	:= 0;
	self.jobsUnactioned		:= 0;
	self.movesCompleted		:= 0;
	self.movesIncomplete	:= 0;
	self.liftsCompleted		:= 0;
	self.liftsIncomplete	:= 0;
	self.actualRate :=0;
	self.netRate := 0;
	self.estimatedRate:=0;
	self.estActualEndTime:=null;
	self.estTargetEndTime:=null;
	self.plannedLoad		:= 0;
	self.plannedDischarge	:= 0;
	self.actualLoad			:= 0;
	self.actualDischarge 	:= 0;
	self.totalQuantity 		:= 0;
	self.totalVolume		:= 0;
	self.totalWeight		:= 0;
	self.completeQuantity	:=0;
	self.completeVolume		:=0;
	self.completeWeight		:=0;
end;
</source>
    </JadeMethod>
    <JadeMethod name="createStatsObjectForJobSheet" id="79223219-6e36-4ee1-b799-6ce63784a086">
        <updating/>
        <source>createStatsObjectForJobSheet(_jobSheet : CM_JobSheet) : CMIF_JobSheetStats updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpJobSheetStats	: CMIF_JobSheetStats;
begin
	create tmpJobSheetStats transient;
	tmpJobSheetStats.init(_jobSheet);
	self.allJobSheetStats.add(tmpJobSheetStats);
	
	return tmpJobSheetStats;
end;</source>
        <Parameter name="_jobSheet" type="CM_JobSheet"/>
        <ReturnType type="CMIF_JobSheetStats"/>
    </JadeMethod>
    <JadeMethod name="delete" id="5abd9107-d373-4a77-8497-c3c3cf2c5c98">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:		22 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.allShifts.purge();		// PAR #24609
	self.allVoyageAllocCCAttributes.purge;
end;</source>
    </JadeMethod>
    <JadeMethod name="exportAsCSV" id="9324eb66-1d3e-49f5-a310-2bdbda203b19">
        <source>exportAsCSV() : String;
/*
Purpose:			
Date		Who		Reason
02 June 2015	cnwab1	Initial creation
*/

vars
	jss : CMIF_JobSheetStats;
	prop : Property;
	clas : Class;
	type : Type;
	headings, values : String;
begin

	foreach prop in CMIF_JobSheetStats.getProperties discreteLock do
		type := prop.type;
		if type.isKindOf(PrimType) then
			 if headings = "" then
				headings := prop.name;
			else
				headings := headings &amp; "," &amp; prop.name;
			endif;
		endif;
	
	endforeach;
	
	headings := headings &amp; CrLf;

	foreach jss in self.allJobSheetStats discreteLock do
		values := values &amp; jss.exportAsCSV() &amp; CrLf;
	endforeach;
	
	
	return headings &amp; values;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="919baeeb-f635-4ce5-a085-44af926d545b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	crane : CM_Crane;
	tmpTS : TimeStamp;
	tmpRate : Integer;
	measure		: CM_MeasurementType;
	unit		: String;
	converted	: String;
begin

	if _attrName = ETRow_ActualRate then
		return self.actualRate.roundedTo(1).asStringJMT;
	elseif _attrName = ETRow_TargetRate then
		return self.estimatedRate.roundedTo(1).asStringJMT;
	elseif _attrName = ETRow_NetRate then
		//return self.myVoyage.getKPIAllCranesNetRate.roundedTo(1).asStringJMT;
		return self.netRate.roundedTo(1).asStringJMT;	// 29722
	elseif _attrName = ETRow_MovesDone then
		return self.movesCompleted.asStringJMT;
	elseif _attrName = ETRow_MovesToDo then
		return self.movesIncomplete.asStringJMT;
	elseif _attrName = ETRow_LiftsDone then
		return self.liftsCompleted.asStringJMT;
	elseif _attrName = ETRow_LiftsToDo then
		return self.liftsIncomplete.asStringJMT;
	elseif _attrName = ETRow_DepartureTargetDate then
		tmpTS:=self.myVoyage.departTargetDT;
		if tmpTS = null then
			return  app.getErrorString(Not_Set);
		else
			return self.systemToLocalTime(tmpTS).asStringJMT;	// 23/5/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
	elseif _attrName = ETRow_DepartureTargetRate then
		return self.getWorkDepartureTargetRatePH().asStringJMT;
	elseif _attrName =  ETRow_WorkStarted then
		tmpTS := self.myVoyage.shipExchangeDate; 
		if tmpTS = null then
			return  app.getErrorString(Not_Set);
		else
			return self.systemToLocalTime(tmpTS).asStringJMT;	// 23/5/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
	elseif _attrName = ETRow_EstActualCompletion then
		if self.actualRate = 0 then
			return  app.getErrorString(Not_Set);
		else
			return self.systemToLocalTime(self.estActualEndTime).asStringJMT  ;	// 23/5/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
	elseif _attrName = ETRow_EstTargetCompletion then
		tmpTS := self.estTargetEndTime;
		if tmpTS = null then
			return app.getErrorString(Not_Set);
		else
			return self.systemToLocalTime(tmpTS).asStringJMT  ;	// 23/5/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
	elseif _attrName = ETRow_Cranes or
			_attrName = ETRow_WorkPoints then
		return app.getErrorString(All_Cranes);
	elseif _attrName = ETRow_WeightToMove then
		measure :=  app.getDefaultMeasurementForType(Type_Weight);
		unit := measure.shortName;
		converted := app.convertMeasurementForDisplay(unit, self.totalWeight - self.completeWeight);
		return converted &amp; Space &amp; unit;
	elseif _attrName = ETRow_WeightMoved then
		measure := app.getDefaultMeasurementForType(Type_Weight);
		unit := measure.shortName;
		converted := app.convertMeasurementForDisplay(unit, self.completeWeight);
		return converted &amp; Space &amp; unit;	
	elseif _attrName = ETRow_QuantityMoved then
		return self.completeQuantity.asStringJMT;
	elseif _attrName = ETRow_QuantityToMove then
		return (self.totalQuantity - self.completeQuantity).asStringJMT;
	elseif _attrName = ETRow_VolumeMoved then
		measure := app.getDefaultMeasurementForType(Type_Volume);
		unit := measure.shortName;
		converted := app.convertMeasurementForDisplay(unit,  self.completeVolume);
		return converted &amp; Space &amp; unit;
	elseif _attrName = ETRow_VolumeToMove then
		measure := app.getDefaultMeasurementForType(Type_Volume);
		unit := measure.shortName;
		converted := app.convertMeasurementForDisplay(unit,  self.totalVolume - self.completeVolume);
		return converted &amp; Space &amp; unit;
	else
	
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIsRequest20" id="22d2fbaf-2ff6-45e4-9af5-addc74b4e517">
        <source>getIsRequest20(_req : CM_Request input) : Boolean;
/*

Date		Who		Reason
03 February 2017	cnwer1	Initial creation TFS 3284 performance improvements

*/

vars
	voyageAllocCCAttributes : CMIF_VoyageAllocCCAttributes;
begin
	
	
	voyageAllocCCAttributes:=self.getVoyageAllocCCAttributes(_req);
	if voyageAllocCCAttributes = null then
		return _req.getAttrIs20();
	else
		return voyageAllocCCAttributes.is20;
	endif;

epilog

end;</source>
        <Parameter name="_req" type="CM_Request" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
