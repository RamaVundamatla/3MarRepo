vars

	itemList	: String;
	canContinue	: Boolean;
	huge		: HugeStringArray;
	oid			: String;

begin

	on SystemException do self.handleException(exception, canContinue);
	
	canContinue := true;	
	itemList := self.xmlStruct.findStructure(XML_ITEMLST).tagData;
	create huge transient;
	itemList.parseCSV(huge);
		
	_jobQuery.setProxyForJobQueryHdr(huge);

epilog
	delete huge;
	return canContinue;
end;</source>
        <Parameter name="_jobQuery" type="CM_RemoteJobQueryHdr" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
