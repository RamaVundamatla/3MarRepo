        <source>coolingTypeENumToStringObj(_value: Integer): CM_String;
//-----------------------------------------
// Created: October 2005 By: cnwgd1
//-----------------------------------------
vars
	cmString	: CM_String;
begin
	//must be cleaned up else where - maybe use _tbl.purgeTableObjects() if going into a table
	create cmString transient;
	cmString.string := self.coolingTypeENumToString(_value, false);

	return cmString;
	
end;</source>
