	self.mnuContextWPOpHrs.visible := self.myCurrentVoyage &lt;&gt; null;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuContextWPOpHrs" id="f8c6f300-6056-47a0-addb-64c3b61ec45a">
        <source>doMnuContextWPOpHrs( menuItem: MenuItem input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	job : CM_VoyageJob;
	obj : CM_Object;
	crane : CM_Crane;
	workPoint : CM_WorkPoint;

begin

	if menuItem.userObject.isKindOf(CM_VoyageJob) then
		job := menuItem.userObject.CM_VoyageJob;
		if job &lt;&gt; null then
			obj := job.getMyWorkPointObject();
		endif;
		if obj &lt;&gt; null then
			if obj.isKindOf(CM_Crane) then
				crane := obj.CM_Crane;
			elseif obj.isKindOf(CM_WorkPoint) then
				workPoint := obj.CM_WorkPoint;
			endif;
		endif;
	endif;

	self.myAssistant.showWorkPointHrsForm( self.myCurrentVoyage, null, crane, workPoint);

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuInspectObject" id="2e67a398-246b-4334-99a3-8826ab3f4750">
        <source>doMnuInspectObject();
//--------------------------------------------------
// Created:	12 December 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myCurrentJob &lt;&gt; null then
		self.myCurrentJob.inspectModal;
	elseif self.myCurrentVoyage &lt;&gt; null then
		self.myCurrentVoyage.inspectModal;
	else
		inheritMethod();	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuOOWFullPlanClick" id="cf7b7a08-0c76-47c1-bb4c-6d10624da669">
        <updating/>
        <source>doMnuOOWFullPlanClick(_menuItem: MenuItem) updating;
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
// 24/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
// ---------------------------------------------------------------------------
vars
	jobs 	: CM_JobArray;
	aJS 	: CM_JobSheet;
	mode 	: Integer;
begin
	//cnwjo3 par 26193
	if self.useDeckingRules() then
		self.doFullPlan();
		return;
	endif;

	create jobs transient;
	mode:= _menuItem.helpContextId;  //epr TFS 830 
	
	if mode = CMIF_ShipPlanningController.Mode_Voyage then
		foreach aJS in self.myCurrentVoyage.allJobSheets discreteLock do
			aJS.getJobsForPlanning(jobs);
		endforeach;
		self.myAssistant.showShipFullyPlanForm(self.myCurrentVoyage, jobs, null, mode, self.myMasterMenuAction);
	elseif mode = CMIF_ShipPlanningController.Mode_Crane then
		aJS := self.myCurrentVoyage.allJobSheets[_menuItem.userObject.CM_Crane.id];
		aJS.getJobsForPlanning(jobs);
		self.myAssistant.showShipFullyPlanForm(null, jobs, aJS.CM_VoyageJobSheet,mode, self.myMasterMenuAction);
	elseif mode = CMIF_ShipPlanningController.Mode_Job then
		self.doMenuPlanJobsClick();
	endif;
epilog
	delete jobs;
end;</source>
        <Parameter name="_menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuOOWFullUnplanClick" id="f04447f9-524b-4ee2-90cc-7f929e9ea74d">
        <updating/>
        <source>doMnuOOWFullUnplanClick(_menuItem: MenuItem) updating;
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// 01 Nov 2012		PJS		PAR #30631
// ---------------------------------------------------------------------------
vars
	jobs : CM_VoyageJobSet;
	js : CM_JobSheet;
	result : Integer;
	mode : Integer;
begin

	if _menuItem.helpContextId = null then
		return;
	endif;
	create jobs transient;
	mode:= _menuItem.helpContextId;  //epr TFS 830 refactored
	
	if mode = CMIF_ShipPlanningController.Mode_Voyage then
		if app.msgBox(app.getErrorString(Sure_Unplan_Exports_Voyage),app.getErrorString(Unplan_EXPORTS_Confirmation), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
		foreach js in self.myCurrentVoyage.allJobSheets discreteLock do
			js.getJobsForPlanning(jobs);
		endforeach;
	elseif mode = CMIF_ShipPlanningController.Mode_Crane then
		js := self.myCurrentVoyage.allJobSheets[_menuItem.userObject.CM_Crane.id];
		if app.msgBox(app.getErrorString1(Sure_Unplan_Exports_Crane,js.CM_VoyageJobSheet.crane),app.getErrorString(Unplan_EXPORTS_Confirmation), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
		js.getJobsForPlanning(jobs);
	elseif mode = CMIF_ShipPlanningController.Mode_Job then
		if app.msgBox(app.getErrorString(Sure_Unplan_Selected_Export),app.getErrorString(Unplan_EXPORTS_Confirmation), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
		self.getSelectedJobs(jobs,true);	
	endif;

	
	while true do
		app.myTrxUA.trxUpdateVoyageJobsUnplan(jobs, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(LoadPlanInfo_UnplanVoyageJobs), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
epilog
	delete jobs;

end;</source>
        <Parameter name="_menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="44bfbd87-c7bc-4978-b496-7a82839c08c4">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
begin

	self.validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doOOWQuery" id="6f064b78-2d4a-422e-8bdb-3872624c3ba0">
        <updating/>
        <source>doOOWQuery(_numJobs: Integer output) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28 May 2008	CNWGB1		PAR16415 Everything relating to 30, 45 and 53 foot containers
// 01 Nov 2012	PJS			PAR #30631 
//
// ---------------------------------------------------------------------------

vars
	idxNumFullSOB, idxNumEmptySOB, idxNumFullLoad, idxNumEmptyLoad, idxNumFullRHLoad,
	idxNumEmptyRHLoad, idxNumFullDisch, idxNumEmptyDisch, idxNumFullRHDisch, idxNumEmptyRHDisch, // PAR 17343
	idxNumTotalMoves, idxNumTotalLifts: Integer; 		//cnwmc5 - 15 Oct 2013 - PAR 32502
	foreColour, 
	backColour,
	rowColor, colStart, colEnd 				: Integer;
	anObject 				: Object;
	theVJob 				: CM_VoyageJob;
	theJob 					: CM_Job;
	idx,
	theRow,
	theJobTotal,
	theRunningTotal,
	theLiftsTotalActual,	//ccms1628	July 2008
	theLiftsTotal: Integer; //ccms1628	July 2008
	craneID,
	addRemarks,
	theDataLine 	: String;
	theJobTITotals 			: CMIF_JobTITotals;
	theReeferTotals,
	theCraneTotals,
	the20Totals,
	the40Totals,
	the30Totals,
	the45Totals,
	the53Totals,
	theOtherTotals 			: IntegerArray;
	theJobs 				: CM_JobArray;
	theTable 				: CM_DataTable;
	jobType					: Integer;
	showRemarks, 
	hideHatchJobs			: Boolean;
	runningTotalTime		: Integer;
	hours					: Integer;
	mins					: Integer;
	theOtherTotal, numTotalLines			: Integer;
begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	showRemarks := self.btnRemarks.value;
	hideHatchJobs := self.btnHideHatchJobs.value;
	
	theTable := self.tblData;
	create theJobs transient;
	self.setFormCaption();
		
	
	if self.myCurrentVoyage = null then
		app.msgBox(app.getErrorString(SHP_Please_Select_A_Voyage),app.getErrorString(Error),	MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
		
	jobType := self.getJobType();
	if self.filterWorkPoint &lt;&gt; null then
		craneID:=self.filterWorkPoint.getID;
	endif;	

	self.myCurrentVoyage.getOOWJobs(jobType,craneID,false,theJobs);
	
	if self.fldMain.topSheet = self.shtMain then
		self.frmQuery.visible := (theJobs.isEmpty);
	endif;
	
	theTable.rows := theTable.fixedRows;
	self.tblInfo.rows := 0;
	rowColor := theTable.backColor;

	theRow := 0;
	self.allJobTotals.purge;
	_numJobs := theJobs.size;

	foreach theJob in theJobs do
		theVJob := theJob.CM_VoyageJob;
		// PAR 26907 - in 782 all roro jobs are called RORO. Ignore in OOW. in 791/792 and future this will change
		if theVJob.jobNum = "RORO" then
			continue;
		endif;
		
		create theJobTITotals transient;
		theJobTITotals.myJob := theVJob;
		
		theVJob.getJobTITotals(theJobTITotals);
		theRow := theRow + 1;

		if hideHatchJobs and theVJob.isHatchLidJob and
			(not self.fldMain.topSheet = self.shtCompleteJobs or
			 not self.fldMain.topSheet = self.shtPartComplete) then
			 continue;
		endif;
		
		theDataLine := theJobTITotals.getAttributeStringForDefArray(theTable.allTblDataEntRows);

		idx := theTable.addItemObject(theVJob,theDataLine);
		
		self.allJobTotals.atPut(idx,theJobTITotals);

		runningTotalTime := runningTotalTime + theJobTITotals.myJob.getEstJobTimeUsingCraneRates(theJobTITotals.myJob.getJobCrane);//epr par 13661 getEstimatedJobTime;
		theJobTotal := theTable.getCellValueByName(ETRow_TotalJob,idx).Integer;
		theRunningTotal := theRunningTotal + theJobTotal;

		if theRunningTotal &lt;&gt; 0 and theJobTotal &lt;&gt; 0 then
			theTable.setCellValueByName(ETRow_TotalPlan,idx,theRunningTotal.String);
		endif;
		if runningTotalTime &lt;&gt; 0 then
			hours := (runningTotalTime/60).Integer;
			mins := runningTotalTime-(60*hours).Integer;
			theTable.setCellValueByName(ETRow_TotalTime,idx,hours.String &amp; "h " &amp; mins.String &amp; "mins" );	
		endif;
		
		// counting lifts in total. ccms1628	July 2008
		theLiftsTotalActual := theTable.getCellValueByName(ETRow_TotalActual,idx).Integer;
		theLiftsTotal := theLiftsTotal + theLiftsTotalActual;
		if theLiftsTotal &lt;&gt; 0 and theLiftsTotalActual &lt;&gt; 0 then
			theTable.setCellValueByName(ETRow_TotalLifts,idx,theLiftsTotal.String);
		endif;
		
		theVJob.getRowColour(foreColour, backColour);
		theTable.accessRow(idx).backColor := backColour;
		theTable.accessRow(idx).foreColor := foreColour;
		
		addRemarks := theVJob.getAdditionalRemarks;
		if showRemarks and addRemarks &lt;&gt; null then
			//create strObject transient;
			idx := theTable.addItemObject(theTable.accessedRow, Tab &amp; app.getErrorString(INV_Remarks) &amp; '  ' &amp; Tab &amp; Tab &amp; addRemarks);
			
			theTable.accessCell(idx, 2).foreColor := Red;
			theTable.accessedCell.mergeCells := Table.MergeCells_Merge;
			theTable.accessCell(idx, 4).mergeCells := Table.MergeCells_Merge;
		endif;
	endforeach;
	

	// initialize the integer arrays
	create theReeferTotals		transient;	theReeferTotals.atPut(100,0);
	create theCraneTotals 		transient;	theCraneTotals.atPut(100,0);
	create the20Totals 			transient;	the20Totals.atPut(100,0);
	create the30Totals 			transient;	the30Totals.atPut(100,0);
	create the40Totals 			transient;	the40Totals.atPut(100,0);
	create the45Totals 			transient;	the45Totals.atPut(100,0);
	create the53Totals 			transient;	the53Totals.atPut(100,0);
// PAR 31756 create theTimberTotals 		transient;	theTimberTotals.atPut(100,0);
// PAR 31756 create theBreakBulkTotals	transient;	theBreakBulkTotals.atPut(100,0);
	create theOtherTotals 		transient;	theOtherTotals.atPut(100,0);
	
	idxNumTotalLifts := theTable.getColumnByRowName(ETRow_TotalLifts);		//cnwmc5 - 15 Oct 2013 - PAR 32502
	idxNumTotalMoves := theTable.getColumnByRowName(ETRow_TotalPlan);		//cnwmc5 - 15 Oct 2013 - PAR 32502
	idxNumFullLoad := theTable.getColumnByRowName(ETRow_NumFull); // PAR 17343
	idxNumEmptyLoad := theTable.getColumnByRowName(ETRow_NumEmpty); // PAR 17343
	idxNumFullRHLoad := theTable.getColumnByRowName(ETRow_NumFullRH); // PAR 17343
	idxNumEmptyRHLoad := theTable.getColumnByRowName(ETRow_NumEmptyRH); // PAR 17343
	idxNumFullDisch := theTable.getColumnByRowName(ETRow_NumFullD); // PAR 17343
	idxNumEmptyDisch := theTable.getColumnByRowName(ETRow_NumEmptyD); // PAR 17343
	idxNumFullRHDisch := theTable.getColumnByRowName(ETRow_NumFullRHD); // PAR 17343
	idxNumEmptyRHDisch := theTable.getColumnByRowName(ETRow_NumEmptyRHD); // PAR 17343
	idxNumFullSOB := theTable.getColumnByRowName(ETRow_NumFullSOB); // PAR 17343
	idxNumEmptySOB := theTable.getColumnByRowName(ETRow_NumEmptySOB); // PAR 17343
	
	foreach anObject in self.allJobTotals do
		if anObject &lt;&gt; null then
			theJobTITotals := anObject.CMIF_JobTITotals;
			if theJobTITotals.myJob.jobType = JOB_TYPE_LOAD then
				theCraneTotals[idxNumFullLoad] 	 := theCraneTotals[idxNumFullLoad]    + theJobTITotals.numFull;
				theCraneTotals[idxNumEmptyLoad]  := theCraneTotals[idxNumEmptyLoad]   + theJobTITotals.numEmpty;
				theCraneTotals[idxNumFullRHLoad] := theCraneTotals[idxNumFullRHLoad]  + theJobTITotals.numFullRH;
				theCraneTotals[idxNumEmptyRHLoad]:= theCraneTotals[idxNumEmptyRHLoad] + theJobTITotals.numEmptyRH;

				the20Totals[idxNumFullLoad]		:= the20Totals[idxNumFullLoad] 		+ theJobTITotals.numFull20;
				the20Totals[idxNumEmptyLoad] 	:= the20Totals[idxNumEmptyLoad] 	+ theJobTITotals.numEmpty20;
				the20Totals[idxNumFullRHLoad] 	:= the20Totals[idxNumFullRHLoad] 	+ theJobTITotals.numFull20RH;
				the20Totals[idxNumEmptyRHLoad] 	:= the20Totals[idxNumEmptyRHLoad] 	+ theJobTITotals.numEmpty20RH;

				the30Totals[idxNumFullLoad] 	:= the30Totals[idxNumFullLoad] 		+ theJobTITotals.numFull30;
				the30Totals[idxNumEmptyLoad] 	:= the30Totals[idxNumEmptyLoad] 	+ theJobTITotals.numEmpty30;
				the30Totals[idxNumFullRHLoad] 	:= the30Totals[idxNumFullRHLoad] 	+ theJobTITotals.numFull30RH;
				the30Totals[idxNumEmptyRHLoad] 	:= the30Totals[idxNumEmptyRHLoad] 	+ theJobTITotals.numEmpty30RH;

				the40Totals[idxNumFullLoad] 	:= the40Totals[idxNumFullLoad] 		+ theJobTITotals.numFull40;
				the40Totals[idxNumEmptyLoad] 	:= the40Totals[idxNumEmptyLoad] 	+ theJobTITotals.numEmpty40;
				the40Totals[idxNumFullRHLoad] 	:= the40Totals[idxNumFullRHLoad] 	+ theJobTITotals.numFull40RH;
				the40Totals[idxNumEmptyRHLoad] 	:= the40Totals[idxNumEmptyRHLoad] 	+ theJobTITotals.numEmpty40RH;

				the45Totals[idxNumFullLoad] 	:= the45Totals[idxNumFullLoad]		+ theJobTITotals.numFull45;
				the45Totals[idxNumEmptyLoad] 	:= the45Totals[idxNumEmptyLoad] 	+ theJobTITotals.numEmpty45;
				the45Totals[idxNumFullRHLoad] 	:= the45Totals[idxNumFullRHLoad] 	+ theJobTITotals.numFull45RH;
				the45Totals[idxNumEmptyRHLoad] 	:= the45Totals[idxNumEmptyRHLoad] 	+ theJobTITotals.numEmpty45RH;
				
				the53Totals[idxNumFullLoad] 	:= the53Totals[idxNumFullLoad] 		+ theJobTITotals.numFull53;
				the53Totals[idxNumEmptyLoad] 	:= the53Totals[idxNumEmptyLoad] 	+ theJobTITotals.numEmpty53;
				the53Totals[idxNumFullRHLoad] 	:= the53Totals[idxNumFullRHLoad] 	+ theJobTITotals.numFull53RH;
				the53Totals[idxNumEmptyRHLoad] 	:= the53Totals[idxNumEmptyRHLoad] 	+ theJobTITotals.numEmpty53RH;

				theReeferTotals[idxNumFullLoad] 	:= theReeferTotals[idxNumFullLoad] 		+ theJobTITotals.numReefer;
				theReeferTotals[idxNumFullRHLoad] 	:= theReeferTotals[idxNumFullRHLoad] 	+ theJobTITotals.numReeferRH;

			elseif theJobTITotals.myJob.jobType = JOB_TYPE_DISCHARGE  or theJobTITotals.myJob.isSOB() then// PAR 17343 this had been comments out, so put back
				theCraneTotals[idxNumFullDisch] := theCraneTotals[idxNumFullDisch] + theJobTITotals.numFull;
				theCraneTotals[idxNumEmptyDisch] := theCraneTotals[idxNumEmptyDisch] + theJobTITotals.numEmpty;
				theCraneTotals[idxNumFullRHDisch] := theCraneTotals[idxNumFullRHDisch] + theJobTITotals.numFullRH;
				theCraneTotals[idxNumEmptyRHDisch] := theCraneTotals[idxNumEmptyRHDisch] + theJobTITotals.numEmptyRH;

				the20Totals[idxNumFullDisch] := the20Totals[idxNumFullDisch] + theJobTITotals.numFull20;
				the20Totals[idxNumEmptyDisch] := the20Totals[idxNumEmptyDisch] + theJobTITotals.numEmpty20;
				the20Totals[idxNumFullRHDisch] := the20Totals[idxNumFullRHDisch] + theJobTITotals.numFull20RH;
				the20Totals[idxNumEmptyRHDisch] := the20Totals[idxNumEmptyRHDisch] + theJobTITotals.numEmpty20RH;

				the40Totals[idxNumFullDisch] := the40Totals[idxNumFullDisch] + theJobTITotals.numFull40;
				the40Totals[idxNumEmptyDisch] := the40Totals[idxNumEmptyDisch] + theJobTITotals.numEmpty40;
				the40Totals[idxNumFullRHDisch] := the40Totals[idxNumFullRHDisch] + theJobTITotals.numFull40RH;
				the40Totals[idxNumEmptyRHDisch] := the40Totals[idxNumEmptyRHDisch] + theJobTITotals.numEmpty40RH;
// PAR 17343 these next 3 chunks were missing
				the30Totals[idxNumFullDisch] 	:= the30Totals[idxNumFullDisch] 		+ theJobTITotals.numFull30;
				the30Totals[idxNumEmptyDisch] 	:= the30Totals[idxNumEmptyDisch] 	+ theJobTITotals.numEmpty30;
				the30Totals[idxNumFullRHDisch] 	:= the30Totals[idxNumFullRHDisch] 	+ theJobTITotals.numFull30RH;
				the30Totals[idxNumEmptyRHDisch] 	:= the30Totals[idxNumEmptyRHDisch] 	+ theJobTITotals.numEmpty30RH;

				the45Totals[idxNumFullDisch] 	:= the45Totals[idxNumFullDisch]		+ theJobTITotals.numFull45;
				the45Totals[idxNumEmptyDisch] 	:= the45Totals[idxNumEmptyDisch] 	+ theJobTITotals.numEmpty45;
				the45Totals[idxNumFullRHDisch] 	:= the45Totals[idxNumFullRHDisch] 	+ theJobTITotals.numFull45RH;
				the45Totals[idxNumEmptyRHDisch] 	:= the45Totals[idxNumEmptyRHDisch] 	+ theJobTITotals.numEmpty45RH;
				
				the53Totals[idxNumFullDisch] 	:= the53Totals[idxNumFullDisch] 		+ theJobTITotals.numFull53;
				the53Totals[idxNumEmptyDisch] 	:= the53Totals[idxNumEmptyDisch] 	+ theJobTITotals.numEmpty53;
				the53Totals[idxNumFullRHDisch] 	:= the53Totals[idxNumFullRHDisch] 	+ theJobTITotals.numFull53RH;
				the53Totals[idxNumEmptyRHDisch] 	:= the53Totals[idxNumEmptyRHDisch] 	+ theJobTITotals.numEmpty53RH;

				theReeferTotals[idxNumFullDisch] := theReeferTotals[idxNumFullDisch] + theJobTITotals.numReefer;
				theReeferTotals[idxNumFullRHDisch] := theReeferTotals[idxNumFullRHDisch] + theJobTITotals.numReeferRH;
			endif;
			theCraneTotals[idxNumFullSOB]  := theCraneTotals[idxNumFullSOB] + theJobTITotals.numFullSOB;
			theCraneTotals[idxNumEmptySOB] := theCraneTotals[idxNumEmptySOB] + theJobTITotals.numEmptySOB;
						
			the20Totals[idxNumFullSOB]  := the20Totals[idxNumFullSOB] + theJobTITotals.numFull20SOB;
			the20Totals[idxNumEmptySOB] := the20Totals[idxNumEmptySOB] + theJobTITotals.numEmpty20SOB;

			the30Totals[idxNumFullSOB]  := the30Totals[idxNumFullSOB]  + theJobTITotals.numFull30SOB;
			the30Totals[idxNumEmptySOB] := the30Totals[idxNumEmptySOB] + theJobTITotals.numEmpty30SOB;

			the40Totals[idxNumFullSOB]  := the40Totals[idxNumFullSOB] + theJobTITotals.numFull40SOB;
			the40Totals[idxNumEmptySOB] := the40Totals[idxNumEmptySOB] + theJobTITotals.numEmpty40SOB;

			the45Totals[idxNumFullSOB]  := the45Totals[idxNumFullSOB]  + theJobTITotals.numFull45SOB;
			the45Totals[idxNumEmptySOB] := the45Totals[idxNumEmptySOB] + theJobTITotals.numEmpty45SOB;

			the53Totals[idxNumFullSOB]  := the53Totals[idxNumFullSOB]  + theJobTITotals.numFull53SOB;
			the53Totals[idxNumEmptySOB] := the53Totals[idxNumEmptySOB] + theJobTITotals.numEmpty53SOB;

			theReeferTotals[idxNumFullSOB] 		:= theReeferTotals[idxNumFullSOB] 	 + theJobTITotals.numReeferSOB;
			
		endif;
	endforeach;
	
	idx := theTable.addItem(Tab);
	theTable.accessRow(idx).inputType := Table.InputType_None;
	colStart := idxNumFullDisch; // PAR 17343
	
	colEnd := idxNumTotalMoves -1;																		//cnwmc5 - 15 Oct 2013 - PAR 32502
	foreach idx in colStart to colEnd do
		theCraneTotals[idxNumTotalMoves] := theCraneTotals[idxNumTotalMoves] + theCraneTotals[idx];		//cnwmc5 - 15 Oct 2013 - PAR 32502
		the20Totals[idxNumTotalMoves] := the20Totals[idxNumTotalMoves] + the20Totals[idx];				//cnwmc5 - 15 Oct 2013 - PAR 32502
		the40Totals[idxNumTotalMoves] := the40Totals[idxNumTotalMoves] + the40Totals[idx];				//cnwmc5 - 15 Oct 2013 - PAR 32502
		the45Totals[idxNumTotalMoves] := the45Totals[idxNumTotalMoves] + the45Totals[idx];				//cnwmc5 - 15 Oct 2013 - PAR 32502
		the30Totals[idxNumTotalMoves] := the30Totals[idxNumTotalMoves] + the30Totals[idx];				//cnwmc5 - 15 Oct 2013 - PAR 32502
		the53Totals[idxNumTotalMoves] := the53Totals[idxNumTotalMoves] + the45Totals[idx];				//cnwmc5 - 15 Oct 2013 - PAR 32502
		theReeferTotals[idxNumTotalMoves] := theReeferTotals[idxNumTotalMoves] + theReeferTotals[idx];	//cnwmc5 - 15 Oct 2013 - PAR 32502
	endforeach;
	theCraneTotals[idxNumTotalLifts] := theLiftsTotal;													//cnwmc5 - 15 Oct 2013 - PAR 32502
	colEnd := idxNumTotalLifts; 																		//cnwmc5 - 15 Oct 2013 - PAR 32502
	
	

	self.addTotalRowToTable(colStart,colEnd,app.getErrorString(Totals_20_foot),the20Totals);
	numTotalLines := numTotalLines + 1;
	if self.showLength30 then
		self.addTotalRowToTable(colStart,colEnd,app.getErrorString(Totals_30_foot),the30Totals);	
		numTotalLines := numTotalLines + 1;
	endif;
	self.addTotalRowToTable(colStart,colEnd, app.getErrorString(Totals_40_foot),the40Totals);
	numTotalLines := numTotalLines + 1;
	if self.showLength45 then	
		self.addTotalRowToTable(colStart,colEnd,app.getErrorString(Totals_45_foot),the45Totals);
		numTotalLines := numTotalLines + 1;
	endif;
	if self.showLength53 then
		self.addTotalRowToTable(colStart,colEnd,app.getErrorString(Totals_53_foot),the53Totals);
		numTotalLines := numTotalLines + 1;
	endif;

	if self.showLengthOther then
		theDataLine := Tab &amp; Tab &amp; app.getErrorString(Other_Length_Totals) &amp; Tab &amp; Tab &amp; Tab;
		numTotalLines := numTotalLines + 1;

		foreach idx in colStart to colEnd do

			theOtherTotal := 0;
			if not self.showLength30 then
				theOtherTotal := the30Totals[idx];
			endif;
			if not self.showLength45 then
				theOtherTotal := theOtherTotal + the45Totals[idx];
			endif;
			if not self.showLength53 then
				theOtherTotal := theOtherTotal + the53Totals[idx];
			endif;
			if theOtherTotal &lt;&gt; 0 then
				theDataLine := theDataLine &amp; theOtherTotal.String &amp; Tab;
			else
				theDataLine := theDataLine &amp; Tab;
			endif;
		endforeach;
		idx := theTable.addItem(theDataLine);
	endif;
	
//PAR 31756	self.addTotalRowToTable(colStart,colEnd,app.getErrorString(Timber_Totals),theTimberTotals);

//PAR 31756	self.addTotalRowToTable(colStart,colEnd,app.getErrorString(BreakBulk_Totals),theBreakBulkTotals);

	self.addTotalRowToTable(colStart,colEnd,app.getErrorString(Reefer_Totals),theReeferTotals);
	numTotalLines := numTotalLines + 1;
	
	
	
	self.doOOWQuerySummary(); // PAR 31756
	
	idx := theTable.addItem(Tab);
	theTable.accessRow(idx).inputType := Table.InputType_None;
	
	
	idx := self.addTotalRowToTable(colStart,colEnd,app.getErrorString(Total),theCraneTotals);
	theTable.accessRow(idx).fontBold := true;
	
	numTotalLines := numTotalLines + 1;
	
	self.doColourSummaryRows();
	
	if positionAtLastJob then
		theTable.topRow := theTable.rows;
	endif;
epilog
	self.updateTabCaptions();
	delete theJobs;

	delete theReeferTotals;
	delete theCraneTotals;
	delete the20Totals;
	delete the30Totals;
	delete the40Totals;
	delete the45Totals;
	delete the53Totals;
	delete theOtherTotals;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_numJobs" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doOOWQuerySummary" id="fd07f410-a746-47f3-af52-9aacc71ecbbd">
        <source>doOOWQuerySummary();
/*
Purpose:		PAR 31756	
Date		Who		Reason
19 June 2013	cnwab1	Initial creation
*/

vars
	colStart, colEnd 				: Integer;
	theJobTITotals 			: CMIF_JobTITotals;
	anObject : Object;
	iter : Iterator;
	cargoTypeTotal : CM_Association;
	totalKey 	: String;
	allCargoTypeTotals : CM_AssociationDict;
	ct : CM_CargoType;
	lineResults : IntegerArray;
	idxNumFullLoad, idxNumTotal, idxNumFullDisch,  idxNumFullRHLoad, idxNumFullRHDisch, idxNumFullSOB : Integer;
	theTable : CM_DataTable;
begin
	theTable := self.tblData;


	idxNumTotal := theTable.getColumnByRowName(ETRow_TotalPlan); 		//cnwmc5 - 15 Oct 2013 - PAR 32502
	idxNumFullLoad := theTable.getColumnByRowName(ETRow_NumFull); 
	idxNumFullDisch := theTable.getColumnByRowName(ETRow_NumFullD); 
	idxNumFullRHLoad := theTable.getColumnByRowName(ETRow_NumFullRH); 
	idxNumFullRHDisch := theTable.getColumnByRowName(ETRow_NumFullRHD); 
	idxNumFullSOB := theTable.getColumnByRowName(ETRow_NumFullSOB); 

	colStart := idxNumFullDisch;
	colEnd := idxNumTotal; 


	create allCargoTypeTotals transient;
	
	foreach anObject in self.allJobTotals do
		if anObject = null then
			continue;
		endif;
		
		theJobTITotals := anObject.CMIF_JobTITotals;
	
		// ### LOAD AND DISCHARGE
		self.doOOWQuerySummarySub(theJobTITotals, allCargoTypeTotals, theJobTITotals.allBBLKTotals, idxNumFullLoad, idxNumFullDisch, idxNumTotal);
		// ### REHANDLE LOAND AND DISCHARGE
		self.doOOWQuerySummarySub(theJobTITotals, allCargoTypeTotals, theJobTITotals.allBBLKTotalsRH, idxNumFullRHLoad, idxNumFullRHDisch, idxNumTotal);
		// ### SHIFT ON BOARD
		self.doOOWQuerySummarySub(theJobTITotals, allCargoTypeTotals, theJobTITotals.allBBLKTotalsSOB, idxNumFullSOB, idxNumFullSOB, idxNumTotal);

	endforeach;
	
	iter:=allCargoTypeTotals.createIterator;
	while iter.next(cargoTypeTotal) do
			totalKey:=iter.getCurrentKey(1).asStringJMT;
			ct := app.myRoot.getCargoTypeFromAbbrev(totalKey.toUpper);
			
			if ct &lt;&gt; null then
				totalKey := ct.description;
			endif;
		
		lineResults := cargoTypeTotal.asObject().IntegerArray;
				
		self.addTotalRowToTable(colStart,colEnd, totalKey,lineResults);

	endwhile;
	
	


epilog
	//epr TFS 830 more leaking transients tidied up
	if allCargoTypeTotals &lt;&gt; null then
		foreach cargoTypeTotal in allCargoTypeTotals discreteLock do
			delete cargoTypeTotal.asObject;
		endforeach;
	endif;
	
	delete allCargoTypeTotals;
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="doOOWQuerySummarySub" id="4a25ea89-7ca7-40c1-b763-8e0e730696c4">
        <source>doOOWQuerySummarySub(_theJobTITotals : CMIF_JobTITotals; _allCargoTypeTotals : CM_AssociationDict;_allBBlkDetails : CM_AssociationDict; _indexLoad : Integer; _indexDisch : Integer; _indexTotal : Integer);
/*
Purpose:			PAR 31756
Date		Who		Reason
19 June 2013	cnwab1	Initial creation
05/03/2015		cnwmh5	Transient Leak
*/

vars
	iter : Iterator;
	bblkTotal, cargoTypeTotal : CM_Association;
	totalKey 	: String;
	lineResults : IntegerArray;
begin
		iter:= _allBBlkDetails.createIterator;

		while iter.next(bblkTotal) do
//			write iter.getCurrentKey(1).asStringJMT &amp; " &gt;&gt;&gt;&gt;&gt; " &amp; bblkTotal.asInteger.String &amp; " " &amp; theJobTITotals.isLoad().String;
			
			totalKey:=iter.getCurrentKey(1).asStringJMT;
			
			cargoTypeTotal:= _allCargoTypeTotals[totalKey];
			if cargoTypeTotal = null then
				create lineResults transient;
				lineResults.atPut(100,0);
				
				if _theJobTITotals.isLoad() then
					lineResults[_indexLoad] := lineResults[_indexLoad] + bblkTotal.asInteger;
				else
					lineResults[_indexDisch] := lineResults[_indexDisch] + bblkTotal.asInteger;
				endif;
				lineResults[_indexTotal] := lineResults[_indexTotal] + bblkTotal.asInteger;
				
				_allCargoTypeTotals.addAssociation(totalKey,lineResults);
			else
			
				lineResults := cargoTypeTotal.asObject().IntegerArray;
				if _theJobTITotals.isLoad() then
					lineResults[_indexLoad] := lineResults[_indexLoad] + bblkTotal.asInteger;
				else
					lineResults[_indexDisch] := lineResults[_indexDisch] + bblkTotal.asInteger;
				endif;
				lineResults[_indexTotal] := lineResults[_indexTotal] + bblkTotal.asInteger;

				cargoTypeTotal.setValue(lineResults);
			endif;
			
			
		
			
		endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_theJobTITotals" type="CMIF_JobTITotals"/>
        <Parameter name="_allCargoTypeTotals" type="CM_AssociationDict"/>
        <Parameter name="_allBBlkDetails" type="CM_AssociationDict"/>
        <Parameter name="_indexLoad" type="Integer"/>
        <Parameter name="_indexDisch" type="Integer"/>
        <Parameter name="_indexTotal" type="Integer"/>
    </JadeMethod>
