        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuInspect_click(menuItem: MenuItem input) updating;
/*
Purpose:	During the change to 22.0.24 some combo boxes had their STYLE set to zero, this is a patchable way to fix that.				

Date		Who		Reason
17 June 2024	navab1	BUG 64462
*/

vars
	obj : Object;
begin
	obj := self.tblRequests.allSelectedObjects.first;
