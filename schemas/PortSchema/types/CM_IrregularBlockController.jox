    <JadeMethod name="valMoveToForHazTIAutoplan" id="41070632-6ba5-4db5-aa54-3f8b691f3798">
        <source>valMoveToForHazTIAutoplan(_tiBeingMoved: CM_TrackedItem; _yaAgent: CM_YAAutoplanAgent input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2015	cnwndl1	Initial creation	Par 36660

*/

vars

	hazTiToCheck		: CM_TrackedItem;

begin
	
	if not _tiBeingMoved.isHazardous then
		return true;
	endif;
	
	// ACTUAL
	foreach hazTiToCheck in self.allHazardousTIs where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.valHazCanCoexistAtLocAutoplan(hazTiToCheck, hazTiToCheck.myPrimaryActualLocation, self, Segregation_Type_Warehouse) then 
			_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " Hazardous conflict with cargo " &amp; hazTiToCheck.id, true);
			return false;
		endif;
	endforeach;
	// QUEUED
	foreach hazTiToCheck in self.allHazardousTIsQueued where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.valHazCanCoexistAtLocAutoplan(hazTiToCheck, self, hazTiToCheck.myPrimaryQueuedLocation, Segregation_Type_Warehouse) then 
			_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " Hazardous conflict with QUEUED cargo " &amp; hazTiToCheck.id, true);
			return false;
		endif;
	endforeach;
	// PLANNED
	foreach hazTiToCheck in self.allHazardousTIsPlanned where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.valHazCanCoexistAtLocAutoplan(hazTiToCheck, self,hazTiToCheck.myPrimaryPlannedLocation,  Segregation_Type_Warehouse) then 
			_yaAgent.addLogEntry(AP_Log_YA_Default,self.getFullId &amp; " Hazardous conflict with PLANNED cargo " &amp; hazTiToCheck.id, true);
			return false;
		endif;
	endforeach;
	
	return true;
	
epilog

	
end;</source>
        <Parameter name="_tiBeingMoved" type="CM_TrackedItem"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="ad0e8f51-9d2d-4844-aa79-03a1688568de">
        <source>validateMoveTo(_control: CMIF_MoveController input);
/*
Purpose:			
Date		Who		Reason
16 Sep 2013	cnwab1	Initial creation
05 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
*/

vars

	tis 		 : CM_TIArray;
	ti 			 : CM_TrackedItem;
	totWeight, 
	weightTot 	 : Real;
	capacity     : Integer;
	cargoCount   : Integer;
	totWeightStr : String;				//14 Mar 2017	NDL	TFS 3723
	measureType  : CM_MeasurementType;	//14 Mar 2017	NDL	TFS 3723
	moveQuantity : Integer;				//24 July 2020	NDl	TFS 49775
	moveWeight   : Real;				//24 July 2020	NDl	TFS 49775
	cargoType	 : CM_CargoType;
	contTI		 : CM_TrackedItem;
	fullId 		 : String;
begin
	inheritMethod(_control);
	
	fullId := self.getFullId();				//05.10.2022 navma1 #52967
	
	if self.isRack() then
		app.raiseCMException1(Illeg_move_cargo_only_moved_ra,fullId,null,self);
		return;
	endif;
	
	//27 Oct 2015	NDL	Par 36928
	capacity := self.getCurrentCapacity();
	if capacity &gt; 0 or self.maximumWeight &gt; 0 then
		create tis transient;
		self.getTIs(tis, REAL_MODE, true);
		if _control.moveMode &lt;&gt; REAL_MODE then
			self.getTIs(tis, _control.moveMode, false);
		endif;
	else
		return;
	endif;
	
	contTI    := _control.myTrackedItem;						//05.10.2022 navma1 #52967
	cargoType := contTI.myCargoType;							//05.10.2022 navma1 #52967
	//24 July 2020	NDL	TFS 49775 - so we don't get erroneous warnings when splitting GC cargo over multiple  areas during queuing
	
	if cargoType.allowDuplicates then
		if cargoType.isBulkByWeight then
			moveQuantity := contTI.totalQuantity;
			moveWeight := _control.weight;
			if moveWeight &lt;= 0 then
				moveWeight := contTI.totalWeight;
			endif;
		else
			moveQuantity := _control.quantity;
			if moveQuantity &lt;= 0 then
				moveQuantity := contTI.totalQuantity;
			endif;
			if moveQuantity &lt;  contTI.totalQuantity then
				moveWeight := contTI.totalWeight * ( moveQuantity /  contTI.totalQuantity );
			else
				moveWeight := contTI.totalWeight;
			endif;
		endif;
	else
		moveQuantity := contTI.totalQuantity;
		moveWeight   := contTI.totalWeight;
	endif;
	
	
	// Do the capacity checking for all classes here
	if capacity &gt; 0 then
		foreach ti in tis discreteLock do
			cargoCount := cargoCount + ti.totalQuantity;
		endforeach;
		cargoCount := moveQuantity + cargoCount;	//24 July 2020	NDL	TFS 49775
		if cargoCount &gt; capacity then
			app.raiseCMWarning1(Move_WillBeOverCap, fullId, null, null, self);
		endif;
	endif;
	
	if self.isKindOf( CM_RackShelfController ) then
		//CM_RackShelfController does its own weight checking.
		return;
	endif;
	
	if self.maximumWeight &gt; 0 then

		foreach ti in tis discreteLock do
			totWeight := totWeight + ti.totalWeight;
		endforeach;
		
		//14 Mar 2017	NDL	TFS 3723
		if totWeight = 0 then
			measureType := app.getDefaultMeasurementForType(Type_Weight);
			totWeightStr := " 0";
			if measureType &lt;&gt; null then
				totWeightStr := totWeightStr &amp; measureType.shortName;
			endif;
			totWeightStr := totWeightStr &amp; " ";
		else
			totWeightStr := app.getWeightForDefaultDisplay(totWeight);
		endif;
		
		weightTot := moveWeight + totWeight;	//24 July 2020	NDL	TFS 49775
		
		if weightTot &gt; self.maximumWeight then
			
			
			app.raiseCMWarning6(Locat_maxim_weigh_curre_total_, 
								fullId, 
								app.getWeightForDefaultDisplay(self.maximumWeight), 
								totWeightStr,
								contTI.id, 
								fullId,
								app.getWeightForDefaultDisplay(weightTot), 
								null, 
								null, 
								self);
		endif;
	
	endif;
	
epilog
	delete tis;
end;
</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMoveToForHazTI" id="161d933f-3bd1-46f7-b40d-6782df314d95">
        <source>validateMoveToForHazTI(_tiBeingMoved: CM_TrackedItem; _detailedErrMsg: Boolean; _allErrorWarnings: CM_ErrorSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2015	cnwndl1	Initial creation	Par 36660

*/

vars

	hazTiToCheck		: CM_TrackedItem;

begin
	
	// ACTUAL 
	foreach hazTiToCheck in self.allHazardousTIs where hazTiToCheck &lt;&gt; _tiBeingMoved do
		_tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self, hazTiToCheck.myPrimaryActualLocation, Segregation_Type_Warehouse, _detailedErrMsg, _allErrorWarnings);
	endforeach;
	// QUEUED 
	foreach hazTiToCheck in self.allHazardousTIsQueued where hazTiToCheck &lt;&gt; _tiBeingMoved do
		_tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self, hazTiToCheck.myPrimaryQueuedLocation, Segregation_Type_Warehouse, _detailedErrMsg, _allErrorWarnings);
	endforeach;
	// PLANNED 
	foreach hazTiToCheck in self.allHazardousTIsPlanned where hazTiToCheck &lt;&gt; _tiBeingMoved do
		_tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self, hazTiToCheck.myPrimaryPlannedLocation, Segregation_Type_Warehouse, _detailedErrMsg, _allErrorWarnings);
	endforeach;
	
epilog


end;


</source>
        <Parameter name="_tiBeingMoved" type="CM_TrackedItem"/>
        <Parameter name="_detailedErrMsg" type="Boolean"/>
        <Parameter name="_allErrorWarnings" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMoveToForHazTIGetTI" id="cce9703a-e4fa-483b-b7f7-98729bdee2ca">
        <source>validateMoveToForHazTIGetTI(_tiBeingMoved: CM_TrackedItem; _clashTIs: CM_TIByIdDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2015	cnwndl1	Initial creation	Par 36660

*/

vars

	hazTiToCheck		: CM_TrackedItem;
	allErrorWarnings 	: CM_ErrorSet;

begin
	
	create allErrorWarnings transient;
	
	// ACTUAL
	foreach hazTiToCheck in self.allHazardousTIs where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self,hazTiToCheck.myPrimaryActualLocation, Segregation_Type_Warehouse, false, allErrorWarnings) then
			_clashTIs.addNoDuplicates(hazTiToCheck, false);
		endif;
	endforeach;
	// QUEUED
	foreach hazTiToCheck in self.allHazardousTIsQueued where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self,hazTiToCheck.myPrimaryQueuedLocation, Segregation_Type_Warehouse, false, allErrorWarnings) then
			_clashTIs.addNoDuplicates(hazTiToCheck, false);
		endif;
	endforeach;
	// PLANNED
	foreach hazTiToCheck in self.allHazardousTIsPlanned where hazTiToCheck &lt;&gt; _tiBeingMoved do
		if not _tiBeingMoved.validateHazCanCoexistAtLoc(hazTiToCheck, self,hazTiToCheck.myPrimaryPlannedLocation, Segregation_Type_Warehouse, false, allErrorWarnings) then
			_clashTIs.addNoDuplicates(hazTiToCheck, false);
		endif;
	endforeach;
	
epilog

	delete allErrorWarnings;
end;
</source>
        <Parameter name="_tiBeingMoved" type="CM_TrackedItem"/>
        <Parameter name="_clashTIs" type="CM_TIByIdDict" usage="input"/>
    </JadeMethod>
</Class>
