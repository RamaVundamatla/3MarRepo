    <JadeMethod name="getCurrentLocation" id="b4568d36-084b-4275-b674-85f954ad69c8">
        <source>getCurrentLocation(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2018	jlgndl1	Initial creation	TFS 41272

*/

vars

begin
	if  self.myWorkOrderToCancel &lt;&gt; self.getMyParent then
		return self.myWorkOrderToCancel.getCurrentLocation();
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="6c3e7e2e-9d55-4362-8050-49f2209a001f">
        <source>getDisplayString(_useShortDesc: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 29 Sep 2021   navma1     ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
//
vars
	displayString : String;
	typeDesc      : String;
begin
	typeDesc := self.getTypeDescription();								  //29.09.2021 navma1 #51925
	
	if _useShortDesc then
		displayString := typeDesc;
	else
		displayString := self.getLongDescription(typeDesc,null);		//29.09.2021 navma1 #51925
	endif;
	
	return displayString;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDtlType" id="2a2e1a42-252b-4255-aa6b-75eca8c9a26a">
