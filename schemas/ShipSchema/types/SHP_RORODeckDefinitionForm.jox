        <source>mnuGrphAutoPillar_click(menuItem: MenuItem input) updating;
/*
Purpose:			
Date		Who		Reason
12 April 2011	cnwab1	Initial creation
*/

vars
	tmpFrame : CMUI_PointDrawingFrame;
	
begin
	tmpFrame := self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame;

	tmpFrame.doBtnClearClick(true); // PAR 28058
	
	tmpFrame.doDrawQuickPolyArray(self.origMouseX, self.origMouseY, 1,1 ,true, DeckItemLayoutType_Pillar, self.myCurrentProxyLayerLayout);
