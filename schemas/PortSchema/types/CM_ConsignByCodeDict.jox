<CollClass name="CM_ConsignByCodeDict" id="38245f34-c47d-4835-87b5-5d2864f4142e">
    <memberType name="CM_ConsigneeConsignor"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <MemberKey>
        <property name="CM_ConsigneeConsignor::code"/>
    </MemberKey>
    <JadeMethod name="getDisplayCodes" id="7aa5ee19-6a04-485f-a7d2-c683256c6de7">
        <source>getDisplayCodes() : String;
/*

Date		Who		Reason
09 July 2014	cnwer1	Initial creation PAR

*/

vars

	consignee : CM_ConsigneeConsignor;
	line : String;
	invalid 		: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, consignee, invalid);	
	foreach consignee in self discreteLock do
		if line = null then
			line := consignee.code;
		else
			line := line &amp; ", " &amp; consignee.code;
		endif;
	endforeach;
	
	return line;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
