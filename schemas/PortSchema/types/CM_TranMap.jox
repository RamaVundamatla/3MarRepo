    <JadeMethod name="doObjectVolatilityConversion" id="dfecef37-5c7d-4f33-84a3-f80e03d17653">
        <updating/>
        <source>doObjectVolatilityConversion(_converter: CM_ObjectVolatilityConverter input; _logIndent: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 September 2019	jlgzm1	Initial creation TFS 7286 Additional stable collections required to improve performance

*/

vars
	serviceMap	: CM_TIServiceMap;

begin
	inheritMethod(_converter, _logIndent);
	
	_converter.doChangeVolatilityOfObject(self.allTIServices, _logIndent);
	_converter.doChangeVolatilityOfObject(self.tiServiceMap, _logIndent);
	
	foreach serviceMap in self.allTIServices discreteLock do
		//_converter.logMessage("Processing collections for " &amp; serviceMap.String, _logIndent);				navma1 14.01.2026
		serviceMap.doObjectVolatilityConversion(_converter, _logIndent + 1);
		//_converter.logMessage("Finished processing collections for " &amp; serviceMap.String, _logIndent);	navma1 14.01.2026
	endforeach;
	

epilog

end;</source>
        <Parameter name="_converter" type="CM_ObjectVolatilityConverter" usage="input"/>
        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllMappedInvoiceLineTypes" id="5347c5c9-26d4-4f13-8792-6d46ca80edf3">
        <source>getAllMappedInvoiceLineTypes() : CM_InvoiceLineDescSet;
// TFS 40620 getAllMappedInvoiceLineTypes() : CM_InvoiceLineDescMapDict;
/*
Purpose:			
Date		Who		Reason
19 October 2016	cnwab1	Initial creation
*/

vars

	serviceMap		: CM_TIServiceMap;
	productGroupMap	: CM_ProductGroupMap;
	productMap		: CM_ProductMap;
	imexMap		: CM_ImexServiceMap;
	contentsMap		: CM_ContentsMap;
	commodityMap		: CM_CommodityMap;
	broker		: CM_TransServiceBroker;
	debtorMap	: CM_DebtorMap;
	qtyMap	: CM_QuantityMap;
	qtyMapRange : CM_QuantityRange;
	qtyMapRangeMap : CM_QuantityRangeMap;
	invLineDesc : CM_InvoiceLineDesc;
	calctype : CM_CalculationType;
// TFS 40620 	invLineDescs : CM_InvoiceLineDescMapDict;
	invLineDescs : CM_InvoiceLineDescSet; // TFS 40620
	mapping : CM_TranMapInvoiceLineMapping;
begin


	create invLineDescs transient;
	foreach serviceMap in self.allTIServices do

		foreach productGroupMap in serviceMap.allProductGroupMaps do
			foreach productMap in productGroupMap.allProductMaps do
				foreach imexMap in productMap.allImExMaps do
					foreach contentsMap in imexMap.contentsMaps do
						foreach commodityMap in contentsMap.commoditiesMap do
							foreach broker in commodityMap.allTransServiceBrokersByType do
								// ## Any debtor Maps???
								foreach debtorMap in broker.allDebtorMapsByDebtor do
									qtyMap := debtorMap.myChildQuantityMap;
									
									foreach qtyMapRangeMap in qtyMap.allQuantityRanges do
										// TFS 40620 foreach invLineDesc in qtyMapRangeMap.allInvoiceLineMaps do
										foreach mapping in qtyMapRangeMap.allTMInvoiceLineMappings do // TFS 40620
											invLineDesc := mapping.myTMInvoiceLineDesc; // TFS 40620
										
										
										
										
											invLineDescs.addNoDuplicates(invLineDesc,false);
										endforeach;
									endforeach;
								endforeach;
								
								// Service Maps
								qtyMap := broker.myChildQuantityMap;
								
								foreach qtyMapRangeMap in qtyMap.allQuantityRanges do
									// TFS 40620 foreach invLineDesc in qtyMapRangeMap.allInvoiceLineMaps do
									foreach mapping in qtyMapRangeMap.allTMInvoiceLineMappings do // TFS 40620
										invLineDesc := mapping.myTMInvoiceLineDesc; // TFS 40620
										
										
										invLineDescs.addNoDuplicates(invLineDesc,false);
									endforeach;
								endforeach;

							endforeach;
						
						endforeach;
					endforeach;
				endforeach;
			endforeach;
		endforeach;
	endforeach;
	
	return invLineDescs;
epilog

end;</source>
        <ReturnType type="CM_InvoiceLineDescSet"/>
    </JadeMethod>
    <JadeMethod name="getAllPaths" id="f5233728-4d29-4918-8662-ef69a662e430">
        <source>getAllPaths(_child : CM_FinancialObject; _paths : HugeStringArray input; _items : ObjectArray input);
// 32311 return the path text and tran map item for each tran map entry, other than the entered one in _child, at the same level
vars
	serviceMap		: CM_TIServiceMap;
begin
	
	foreach serviceMap in self.allTIServices do
		serviceMap.getAllPaths(_child, _paths, _items);
	endforeach;
	
end;
</source>
        <Parameter name="_child" type="CM_FinancialObject"/>
        <Parameter name="_paths" type="HugeStringArray" usage="input"/>
        <Parameter name="_items" type="ObjectArray" usage="input"/>
    </JadeMethod>
