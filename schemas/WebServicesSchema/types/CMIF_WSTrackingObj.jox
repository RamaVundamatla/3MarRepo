<Class name="CMIF_WSTrackingObj" id="fb604266-5401-4ce2-9b5e-26f804ca0f4c">
    <superclass name="CMIF_Object"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <Constant name="Timer_Interrupt_Event" id="34c817d3-c2f3-4320-a5c4-21c88f5a4222">
        <source>10001</source>
        <type name="Integer"/>
    </Constant>
    <ImplicitInverseRef name="myProcess" id="2ea1b6e3-c51b-4717-9665-67373cce253c">
        <embedded/>
        <type name="Process"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="mySupportAgent" id="7a8980f9-cdfd-425a-80a2-efc11186d1dd">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="WS_WebServiceSupportAgent"/>
        <access>readonly</access>
        <Inverse name="WS_WebServiceSupportAgent::allWSTrackingObjects"/>
    </ExplicitInverseRef>
    <PrimAttribute name="wsMethodName" id="398b6e22-6d74-4a8b-a93e-fc5dc9d56101">
        <length>101</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="startInterruptTimer" id="02483ddd-2284-4b5c-ae5e-8dfbb8616ce5">
        <updating/>
        <source>startInterruptTimer(_process : Process; _agent : WS_WebServiceSupportAgent; _long : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 April 2021	navmd1	Initial Creation TFS 42010 MTN - Early Termination of web services

*/

vars
	timeout	: Integer;
	iniFile	: File;
	message	: String;
	
	option, remaining: Integer;
begin
	if not self.myProcess = _process then
		self.myProcess		:= _process;
	endif;
	
	if not self.mySupportAgent = _agent then
		self.mySupportAgent	:= _agent;
	endif;
	
	self.wsMethodName := _process.userInfo;
	
	timeout := app.getWebConfig.responseTimeoutSecs;
	
	// I'm not really sure if this is the best approach... so this might change.
	// But for now, extending the timeout to the JadeHTTP MessageTimeout setting seems appropriate.
	if _long then
		// -30 seconds to give ourselves a little bit of time to respond before jadehttp cuts us off
		timeout := (_agent.jadeHTTPMessageTimeout - 30).max(270);	// At least 4.5 minutes
	endif;
	
	message := method.qualifiedName &amp; " " &amp; getOidStringForObject(self) &amp; " Starting Interrupt Timer (" &amp; CMIF_WSTrackingObj.Timer_Interrupt_Event.String &amp; ")" &amp;
				" for " &amp; _process.String &amp; " " &amp; self.wsMethodName &amp; " for " &amp; timeout.String &amp; " seconds";
	
	app.writeLog(message, LogDEBUG);
	
	if self.getTimerStatus(CMIF_WSTrackingObj.Timer_Interrupt_Event, option, remaining) then
		app.writeLog(method.qualifiedName &amp; " Timer already active! Skipping", LogERROR);
		return;
	endif;
	
	self.beginTimer(timeout * 1000, Timer_OneShot, CMIF_WSTrackingObj.Timer_Interrupt_Event);
	
epilog
	
end;</source>
        <Parameter name="_process" type="Process"/>
        <Parameter name="_agent" type="WS_WebServiceSupportAgent"/>
        <Parameter name="_long" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="8f8eb9bc-bb25-4031-a42d-6ebb09956e10">
        <updating/>
        <source>timerEvent(_eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
02 April 2021	navmd1	Initial Creation TFS 42010 MTN - Early Termination of web services

*/

vars
	invalid : Boolean;
	proc	: Process;
begin
	if _eventTag = CMIF_WSTrackingObj.Timer_Interrupt_Event then
		on Exception do app.handleDeletedObject(exception, self.myProcess, invalid);
		proc := self.myProcess;
		proc.edition;
		
		if invalid then
			return;
		endif;
		
		if proc.userInfo &lt;&gt; self.wsMethodName then
			app.writeLog(method.qualifiedName &amp; " " &amp; getOidStringForObject(self) &amp; " Different web call, throwing away timer. [Expecting: " &amp; self.wsMethodName &amp; ", Got: " &amp; proc.userInfo &amp; "]", LogERROR);
			return;
		endif;
		
		app.writeLog(method.qualifiedName &amp; " " &amp; getOidStringForObject(self) &amp; " Interrupting current Web Service method for " &amp; proc.String &amp; " " &amp; proc.userInfo, LogWARN);
		system.interruptUser(proc.node, proc);
	endif;
epilog

end;</source>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
</Class>
