    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardActivity"/>
    <JadeMethod name="create" id="7f572fc5-8aa5-47bd-bb56-8383cc437d10">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

begin

	self.type := self.ReeferConnect;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAction" id="0d6f530f-8ce1-47eb-983d-3e457c8d38a8">
        <updating/>
        <source>doAction() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars
	alarmJob : CM_YardActivity;
begin
	
	self.addReeferInfoTransaction();
	
	// TFS 51455 this method is called because a temperature has been recorded for a reefer
	if self.myTrackedItem &lt;&gt; null then
		alarmJob := self.myTrackedItem.getCurrentReeferAlarmJob();
		
		if alarmJob &lt;&gt; null then
			alarmJob.doAction();  // ### TFS 51455 09JUL2021 NAVAB1 -  delete the alarm job
		
		endif;
	endif;
		
epilog
	
	delete self;

end;</source>
    </JadeMethod>
