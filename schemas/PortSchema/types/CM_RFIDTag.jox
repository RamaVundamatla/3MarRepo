    <JadeMethod name="getDisplayStringForAttribute" id="488c0e26-0aaf-44da-8e73-d56310420b16">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_LocationOnTerminal then
		return self.getLocationOnTerminal();
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationOnTerminal" id="88600214-3bc5-46df-99c2-b1ddf110a5e5">
        <source>getLocationOnTerminal() : String;
// ---------------------------------------------------------------------------
// Created:		23 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myRoadJob &lt;&gt; null then
		if self.myRoadJob.myVehicle &lt;&gt; null then
			if self.myRoadJob.myVehicle.myPrimaryActualLocation &lt;&gt; null then
				return self.myRoadJob.myVehicle.myPrimaryActualLocation.getFullId();
			endif;
		endif;
	endif;
	
	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
