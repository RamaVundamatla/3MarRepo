    <JadeMethod name="clickOptionButton" id="909134eb-17e0-4b9b-ad7d-030a2ee26c04">
        <updating/>
        <source>clickOptionButton()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2020	jlgndl1	Initial creation	TFS 49189
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
16 Nov 2020 cnwma1 Bug 50343: Bug from Functional Review of 49179 - Road Gate &amp; Vehicle Visit
*/

vars

begin
	
	self.grpOperation.visible := self.optOps.value or self.optView.value;
	
	if self.optLoad.value then
		self.btnMove.caption := "Load";
		self.grpMove.caption := "Load";
	elseif self.optDischarge.value then
		self.btnMove.caption := "Discharge";
		self.grpMove.caption := "Discharge";
	elseif self.optGateOut.value then
		self.btnMove.caption := "Gate Out";
		self.grpMove.caption := "Gate Out";		
	endif;
	
	if self.optOps.value then
		self.resetDTtoLatestOnVVR(true);
		
		self.optGateOut.visible := ( self.myVehicleVisitRecord.getGateOutVVRDetail = null ); // i.e. not already gated out
		self.optLoad.caption := "Load";
		self.optDischarge.caption := "Discharge";
	
		self.grpOperation.caption := "Operation";
		self.grpMove.visible := self.optLoad.value or self.optDischarge.value;
		self.btnMove.enabled := ( self.tblCargo.row &gt; self.tblCargo.fixedRows ) or self.optGateOut.value;
		
		self.lblEffective.visible := true;
		self.txtDate.visible := true;
		self.txtTime.visible := true;
		
		if self.grpMove.visible then
			self.tblCargo.top := self.grpMove.top + self.grpMove.height + 3;
		else
			self.tblCargo.top := self.grpMove.top;
		endif;
		
		if self.optLoad.value then
			self.lblMoveMode.caption := "Load To:";
			self.lblsubLocation.visible := false;
			self.cmbSubLocation.visible := false;
			self.lblBOL.visible := true;
			self.cmbBOL.visible := true;
			self.lblRelease.visible := true;
			self.cmbRelease.visible := true;
		elseif self.optDischarge.value then
			self.lblMoveMode.caption := "Discharge To:";
			self.lblsubLocation.visible := true;
			self.cmbSubLocation.visible := true;
			self.lblBOL.visible := false;
			self.cmbBOL.visible := false;
			self.lblRelease.visible := false;
			self.cmbRelease.visible := false;
		endif;
		
		self.populateCmbLocations();
		self.populateCmbBOL();
		self.grpUpdate.visible  := false;  					      		 //04.11.2020 cnwma1 TFS #50112
	elseif self.optUpdate.value then   	  						 		 //04.11.2020 cnwma1 TFS #50112
		self.btnMove.caption 	:= app.getErrorString(Update_Caption);   //24.11.2020 cnwma1 #50423
		self.grpMove.visible    := false;
		self.grpUpdate.visible  := true;
		self.btnMove.enabled     := true;                         //16.11.2020 cnwma1 #50343
		if self.myVehicleVisitRecord &lt;&gt; null and 
		   self.myVehicleVisitRecord.myStevedore &lt;&gt; null then
			self.cmbStevedore.setObject(self.myVehicleVisitRecord.myStevedore);
		endif;
	else
		self.optGateOut.visible := false;
		self.optGateOut.value := false;
		self.optLoad.caption := "Loaded";
		self.optDischarge.caption := "Discharged";
		
		self.grpOperation.caption := "View";
		self.grpMove.visible := false;
		self.btnMove.enabled := false;
		
		self.lblEffective.visible := false;
		self.txtDate.visible := false;
		self.txtTime.visible := false;
		
		self.grpUpdate.visible  := false; //04.11.2020 cnwma1 TFS #50112
	endif;
	
	if self.optView.value then
		self.tblCargo.top := self.grpMove.top;
	endif;
	
	self.tblCargo.height := self.btnClose.top - ( self.tblCargo.top + 10 );
	
	if not optOps.value and not optView.value  then 
		//nothing selected
		self.tblCargo.visible := false;	
	else
		self.tblCargo.visible := true;
		self.populateTblCargo();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clickTableItem" id="68173bee-3e38-4686-9cb9-44af9fd462d1">
        <source>clickTableItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	msg : String;
	ta : CM_TerminalArea;
	location : CM_LocationsController;
	tiArray : CM_TIArray;

begin

	if self.optView.value then
		self.btnMove.enabled := false;
		//nothing to do here....
		return;
	endif;
	
	create tiArray transient;
	self.getSelected( tiArray );
	
	self.btnMove.enabled := not tiArray.isEmpty;
	
	if tiArray.isEmpty then
		return;
	endif;
	
	ta := self.cmbLocation.listObject.CM_TerminalArea;
	location := self.cmbSubLocation.listObject.CM_LocationsController;
	
	if self.optOps.value then
		if self.optDischarge.value then
			if location = null then
				self.btnMove.enabled := false;
				msg := "No Discharge Location selected.";
				app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only );
				if ta = null then
					self.cmbLocation.setFocus();
				else
					self.cmbSubLocation.setFocus();
				endif;
				return;
			endif;
		elseif self.optLoad.value then
			if location = null then
				self.btnMove.enabled := false;
				msg := "No Load Location selected.";
				app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only );			
				if ta = null then
					self.cmbLocation.setFocus();
				else
					self.cmbSubLocation.setFocus();
				endif;
				return;
			endif;
		endif;
	
	endif;
	

epilog

	delete tiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="clickUndo" id="28df78cd-0855-49f0-b7ce-2fbcbabede38">
        <updating/>
        <source>clickUndo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	tiArray : CM_TIArray;
	targetLocation : CM_LocationsController;
	moveController : CMIF_MoveController;
	allMoveControllers : ObjectArray;
	ti : CM_TrackedItem;
	localTimeStamp : TimeStamp;
	effectiveTimeStamp : TimeStamp;
	ret : Integer;
	foundHeight : Integer;
	
begin

	self.endNotes();

	ti := self.mnuUndo.userObject.CM_TrackedItem;
	if ti = null then
		return;
	endif;
	
	localTimeStamp.setDate( self.txtDate.getDate );
	localTimeStamp.setTime( self.txtTime.getTime );
	effectiveTimeStamp := self.myTerminal.localToSystemTime( localTimeStamp );
	
	create tiArray transient;
	self.getSelected( tiArray );
	
	if tiArray.isEmpty then
		return;
	endif;
	
	create allMoveControllers transient;
	
	foreach ti in tiArray do		
		create moveController transient;
		moveController.setMyTrackedItem( ti );
		
		targetLocation := null;
		if ti.myPrimaryActualLocation.isVehicle or ti.myPrimaryActualLocation.isTILCController then
			self.myTerminal.findLocationFromString( ti.priorLocation, true, targetLocation, foundHeight );
			moveController.setWeight( ti.totalWeight );
			moveController.setQuantity( ti.totalQuantity );
		else
			if self.myVehicleVisitRecord.myInCMGTE_Chassis &lt;&gt; null and self.myVehicleVisitRecord.myInCMGTE_Chassis.myTrackedItem &lt;&gt; null then
				targetLocation := self.myVehicleVisitRecord.myInCMGTE_Chassis.myTrackedItem.CM_TILC.allLCs.first;
			endif;
			if targetLocation = null then
				targetLocation := self.myVehicleVisitRecord.vehicle.locationsController;
			endif;
			if targetLocation &lt;&gt; null then
				//try to set the (weight and quantity) values to the total amount we removed
				self.myVehicleVisitRecord.setMoveAmountToUndo( moveController );
			endif;
		endif;
		
		if targetLocation = null then
			app.msgBox("Unable to find location to return to!", app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			continue;
		endif;
		moveController.setMyToPrimaryLocation(targetLocation);
		moveController.setMyOriginatingLocation( ti.myPrimaryActualLocation );
		moveController.setMoveMode( REAL_MODE );
		moveController.setEffectiveTimeStampOverride( effectiveTimeStamp );	
		moveController.myAssociatedVVR := self.myVehicleVisitRecord;
			
		allMoveControllers.add( moveController );
	endforeach;
	
	while true do
		app.myTrxUA.trxMoveMultiTrackedItems( allMoveControllers, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;	
		else
			ret := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   ret = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		endif;
		
		break;
	
	endwhile;

epilog

	self.beginNotes();

	if allMoveControllers &lt;&gt; null and not allMoveControllers.isEmpty then
		allMoveControllers.purge();
	endif;
	delete allMoveControllers;
	delete tiArray;
	self.clickOptionButton();

end;</source>
    </JadeMethod>
