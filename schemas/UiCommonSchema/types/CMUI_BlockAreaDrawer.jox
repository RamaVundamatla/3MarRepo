    <JadeMethod name="getCellIndex" id="88c2f2db-8fb5-4183-a066-5eaadc18a0ca">
        <source>getCellIndex(x, y : Integer) : Integer protected;
// The myCells array is a structured as a 2D array with rows and columns
begin
	return (self.columns * (y - 1)) + x;
end;
</source>
