    <JadeMethod name="initTblEDITI" id="5cc4e333-3f1b-4606-a31d-178d255a9a12">
        <source>initTblEDITI( _index : Integer);
// ---------------------------------------------------------------------------
// Created:		01 August 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 14/10/2009	cnwcs5	par 20836 - re-parent verify errors table
// 30/11/2011	cnwcs5	use local variable instead of repeated getPropertyValue and method calls
vars
	table	:CM_DataTable;	// cnwcs5 30/11/2011 
begin
	table := self.tblEDITI;
	
	table.stretchToParent	:= true;	// par 20836
	
	table := table.getControl(_index);
	
	table.clear;

	table.selectionType := CM_BaseTable.SelectionType_Row;
	table.selectMode 	:= CM_BaseTable.SelectMode_Row;
	table.selectMode 	:= CM_DataTable.SelectMode_FixedRow;
	table.multiSelect	:= CM_DataTable.MultiSelect_Simple;
		
	table.rows 			:= 1;
	table.inputType 	:= CM_BaseTable.InputType_TextBox;
	table.fixedRows 	:= 1;
	table.columns 		:= 0;
	table.fixedColumns	:= 0;
	
	table.cnAdjustColumnWidths();
	
end;</source>
