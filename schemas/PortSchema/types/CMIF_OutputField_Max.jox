<Class name="CMIF_OutputField_Max" id="0864e698-4d68-4edd-ad90-8dc6aa4f3857">
    <superclass name="CMIF_OutputField"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="max" id="025e2b74-2f6d-4037-85f3-8d696c689b3f">
        <precision>23</precision>
        <scaleFactor>8</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getCollectionForDrillDown" id="f3b79517-acf1-4b6d-a3b4-44c9a834d546">
        <source>getCollectionForDrillDown(): ObjectSet;
// ---------------------------------------------------------------------------
// Created:     22 February 2010 by cnwcs5
// Purpose:     CCMS 1925 / PAR 22295 Release Summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/02/2010	cnwcs5		par 22435 - release summary changes
// ---------------------------------------------------------------------------
vars

begin
	return self.allObjects;
epilog

end;</source>
        <ReturnType type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="getValue" id="d8bcae98-7caf-4c61-898e-759c8d5348ee">
        <source>getValue(): String;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/12/2009	cnwcs5	ccms 1028 - hide zeros values
// ---------------------------------------------------------------------------
vars
	value	:Decimal[23,8];
begin
	value := self.max;		// cnwcs5 07/12/2009
	
	if value = 0 then		// cnwcs5 07/12/2009
		return null;		// cnwcs5 07/12/2009
	endif;					// cnwcs5 07/12/2009
	
	return value.roundedTo (self.decimals).asStringJMTWithPrecision (self.decimals, self.useSeperator);	// cnwcs5 07/12/2009

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isMax" id="49577f6a-8bf5-4c53-ba9b-6636e9fa9658">
        <source>isMax(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSelf" id="aef6f3b2-8067-413d-bc73-70af78a92741">
        <updating/>
        <source>updateSelf(_value: Any; _obj :Object) updating;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/02/2010	cnwcs5		par 22435 - release summary extenstions
// ---------------------------------------------------------------------------
vars

begin
	if _value.isKindOf (CM_SnapshotField_Max) then
		if _value.CM_SnapshotField_Max.max &gt; self.max then
			self.max := _value.CM_SnapshotField_Max.max;
		endif;
	else
		// assume decmial
		if _value.Decimal = self.max then					// 22/02/2010 par 22435
			// keep all objects that have then max value
			self.allObjects.addNoDuplicates (_obj, false);	// 22/02/2010 par 22435
		endif;	
		if _value.Decimal &gt; self.max then
			self.max := _value.Decimal;
			
			self.allObjects.clear;							// 22/02/2010
			self.allObjects.addNoDuplicates (_obj, false);	// 22/02/2010
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
