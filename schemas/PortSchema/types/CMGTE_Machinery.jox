    <JadeMethod name="setForCreate" id="85ba5471-77d7-48af-bf8d-6f1b190d740c">
        <updating/>
        <source>setForCreate(_pxyGTEEntity: CMGTE_Machinery; _realVVR : CM_VehicleVisitRecord input) updating;
// ---------------------------------------------------------------------------
// Created:     22 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_pxyGTEEntity, _realVVR);
	
	self.isoType := _pxyGTEEntity.isoType;
	self.preTripDT := _pxyGTEEntity.preTripDT;

epilog

end;</source>
        <Parameter name="_pxyGTEEntity" type="CMGTE_Machinery"/>
