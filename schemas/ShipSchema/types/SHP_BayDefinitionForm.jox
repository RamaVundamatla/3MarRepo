    <JadeMethod name="translateForm" id="c684c1e3-7faa-4faf-8da5-cc809959f86d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:50:16.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017625, locale);
	btnBayPrintBay.translateBubbleHelp(Xlat_0010653, locale);
	btnBayPrintBay.translateCaption(Xlat_0010654, locale);
	btnDeleteBay.translateBubbleHelp(Xlat_0010655, locale);
	btnDeleteBay.translateCaption(Xlat_0010656, locale);
	btnDirDefaults.translateBubbleHelp(Xlat_0010657, locale);
	btnDirDefaults.translateCaption(Xlat_0010658, locale);
	btnEditBay.translateCaption(Xlat_0010659, locale);
	btnEditVoyVess.translateCaption(Xlat_0010660, locale);
	btnNewBay.translateBubbleHelp(Xlat_0010661, locale);
	btnNewBay.translateCaption(Xlat_0010662, locale);
	btnPrintBay.translateBubbleHelp(Xlat_0010663, locale);
	btnPrintBay.translateCaption(Xlat_0010664, locale);
	cMUI_Folder1Sh1.translateCaption(Xlat_0010665, locale);
	cMUI_Folder1Sh2.translateCaption(Xlat_0010666, locale);
	chk40ftBayIDs.translateCaption(Xlat_0010667, locale);
	grpBayDetails.translateCaption(Xlat_0023444, locale);
	grpVesselDetails.translateCaption(Xlat_0023445, locale);
	lblBay.translateCaption(Xlat_0010670, locale);
	lblBridge.translateCaption(Xlat_0010671, locale);
	lblStowNum.translateCaption(Xlat_0010672, locale);
	lblVoyVess.translateCaption(Xlat_0010673, locale);
end;</source>
    </JadeMethod>
