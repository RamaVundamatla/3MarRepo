    <JadeMethod name="getDefinitionXML" id="2f798cfb-11e8-4db5-91d7-5e5aa59af63d">
        <source>getDefinitionXML() : String;
/*
Purpose:			
Date				Who			Reason
MAY 2011		CNWAB1		Initial creation
*/

vars

	hml : String;
begin
	hml := "&lt;SECT&gt;" ;
	hml := hml &amp; "&lt;SECODE&gt;" &amp; self.code &amp; "&lt;/SECODE&gt;";
	hml := hml &amp; "&lt;SMAXAXEL&gt;" &amp; self.maxLoadAxel.String &amp; "&lt;/SMAXAXEL&gt;";
	hml := hml &amp; "&lt;SMAXM2&gt;" &amp; self.maxLoadM2.String &amp; "&lt;/SMAXM2&gt;";
	hml := hml &amp; "&lt;SMAXSTACK&gt;" &amp; self.maxLoadStack.String &amp; "&lt;/SMAXSTACK&gt;";
	hml := hml &amp; "&lt;SMAXTOTAL&gt;" &amp; self.maxLoadTotal.String &amp; "&lt;/SMAXTOTAL&gt;";
	hml := hml &amp; "&lt;SPOS&gt;" &amp; self.position.String &amp; "&lt;/SPOS&gt;";
	hml := hml &amp; "&lt;SREMARKS&gt;" &amp; self.remarks &amp; "&lt;/SREMARKS&gt;";
	hml := hml &amp; "&lt;/SECT&gt;";

	return hml;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="dea9da3b-636f-4309-bda8-fa167a1406cc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if _attrName = ETRow_Code then
		return self.code.asStringJMT;
	elseif _attrName = ETRow_Remarks then
		return self.remarks.asStringJMT;
	elseif _attrName = ETRow_Position then
		return self.position.asStringJMT;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
