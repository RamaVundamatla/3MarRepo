    <JadeMethod name="doDisAssocBooking" id="116bd535-77c0-43bd-807b-84bd73bddf7c">
        <updating/>
        <source>doDisAssocBooking(menuItem: MenuItem input) updating, protected;
/*

Purpose:			Disassociates a vehicle booking time slot from a vehicle visit record

Parameters:			menuItem	MenuItem	The menu item to use to get the vehicle booking time slot from

Return Value:		NONE

Date		Who		Reason
18 May 2023	navpw1	Initial creation TFS: 54049 (55843)

*/

vars
	roadJobObj : CM_RoadJob;
	vvr : CM_VehicleVisitRecord;
	vbts : CM_VehicleBookingTimeSlot;
	theReturn : Integer;
	
begin
	roadJobObj := self.myCurrentObject.CM_RoadJob;
    if roadJobObj &lt;&gt; null then
        vvr := roadJobObj.myVehicleVisit;
    endif;
	
	if vvr &lt;&gt; null then
		if vvr.allVehicleBookingSlots.isEmpty then
			return;
		endif;
		
		vbts := vvr.allVehicleBookingSlots.first;
		
	endif;
	
	if vbts = null then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxDisassocVehicleBookingVvr(vbts, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Vehicle_schedul_booking_slot), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="4c9faea0-ba32-49a0-8c17-7e34d601cb53">
        <updating/>
        <source>doFilterTable() updating, protected;
/*

Purpose:			Filters the table

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
16 May 2023	navpw1	Initial creation TFS: 54049 (55843)

*/

vars
	filterText		: String;
	rowIdx,
	colIdx,
	start			: Integer;
	cell			: JadeTableCell;
	cellText		: String;
	
begin
	//filterText := self.txtFilterBox.text.toUpper();
	filterText := self.frmTableFilter.txtFilterBox.text.toUpper(); //25/06/2024	navkc1 CR 64823 Task 64824
	if (filterText = "") then
		self.clearFilter();
		return;
	else
		//self.btnClearFilter.enabled := true;
		self.frmTableFilter.btnClearFilter.enabled := true; //25/06/2024	navkc1 CR 64823 Task 64824
	endif;
	/*
	start := self.tblData.fixedRows + 1;
	foreach rowIdx in start to self.tblData.rows do	: rowLoop
		self.tblData.accessRow(rowIdx);
		foreach colIdx in 1 to self.tblData.columns do
			cell := self.tblData.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.tblData.accessedRow.visible := true;
				continue rowLoop;
			endif;
		endforeach;
		self.tblData.accessedRow.visible := false;
	endforeach;
	*/
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadRoadExitCompleteForm" id="bb34a8fa-fb17-4d67-ba90-36e1adf00ede">
        <source>doLoadRoadExitCompleteForm() protected;
/*----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 30 May 2007
//
//----------------------------------------------------------------------
15 Mar 2013	cnwer1	Par 31290 only show enahnced form. old one was self.myAssistant.showRoadExitCompleteForm
*/
vars
	
begin
	if not app.myCurrentUserCan(self.myTerminal, PmGteRoadExitUpdate) then
		app.msgBox(app.getErrorString(NoPermission2), app.getErrorString(Road_exit), MsgBox_OK_Only);
