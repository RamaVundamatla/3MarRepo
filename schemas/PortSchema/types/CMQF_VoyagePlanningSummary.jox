<Class name="CMQF_VoyagePlanningSummary" id="f61c9f3b-848c-4dc2-8d8b-47b15a5bdb88">
    <superclass name="CMQF_VoyageSummary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="includesObject" id="ac9271ff-be43-47f2-9d5e-b3c69741380b">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	querySelf			: CMQF_VoyagePlanningSummary;
	failedDAC  :CM_DataAccessController;
begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	if (querySelf.myOperator &lt;&gt; null and _ti.myOperator &lt;&gt; querySelf.myOperator) or
	   (querySelf.planningState &lt;&gt; _ti.planningState) then
		return false;
	endif;
	
	if not _ti.canUserAccessSelf(null, failedDAC,_passport) then
		return false;
	endif;
	
	querySelf.numFound := querySelf.numFound +1;
	return true;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFields" id="a6760c92-2275-43bf-9c39-547f5281cef1">
        <updating/>
        <source>initFields() updating;
// ---------------------------------------------------------------------------
// Created:     06 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	self.planningStateDescr := app.planningStateEnumToString(self.planningState);
	self.useTotalSummaryObject := false;
end;</source>
    </JadeMethod>
</Class>
