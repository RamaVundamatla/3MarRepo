    <JadeMethod name="tblGridAreaInfo_contextMenu" id="bc73e696-cf2d-44b1-ad77-e2fd0d6e72df">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGridAreaInfo_contextMenu(_table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theObject : Object;
	showAll : Boolean;
begin
	
	self.doTurnOffContextMenus();

//	showAll := not self.sdf01.allGridAreasByRowColumn.isEmpty;
	showAll := self.showZoom(); // ???
	
	self.mnuGridSeperator02.visible := showAll;
	self.mnuZoomSub.visible := showAll;
	self.mnuGridSelector.visible := showAll;
	
	self.mnuGridHideLegend.visible := true;
	self.mnuGridHideMacro.visible := true;
	self.mnuGridBigFont.visible := _table.userObject &lt;&gt; null ;
	self.mnuGridSeperator01.visible := false;

	if _table.row &gt; 0 then
		theObject := _table.accessCell(_table.row,_table.column).itemObject;
		if theObject &lt;&gt; null then
			if theObject.isKindOf(CM_SlotController) 
			or theObject.isKindOf(CM_BayVoyage) 
			or theObject.isKindOf(CM_SlotDefn) then
				theObject.inspect;
			else
				if theObject.isKindOf(CM_TrackedItem)  then
					self.doBuildMnuContainer(theObject.CM_TrackedItem);
				endif;
			endif;
		endif;
	endif;

	return self.showContextMenu(mnuGridAreaContext, _table, conwin, mouse, x, y);
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
