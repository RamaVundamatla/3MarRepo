    <JadeMethod name="shortenStringLength" id="bbbe3d5f-78e3-462e-b597-6c73f81fcc93">
        <source>shortenStringLength(_string : String; _length : Integer): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 September 2008	#cnwdz2	 par 17299 shorten the input string to the last _length characters.

*/

vars
	length : Integer;
	shortString : String;
begin
	shortString := _string;
	length := _string.length;
	
	if length &gt; _length then
		shortString := _string[(length - _length + 1):end];
	endif;

	return shortString;
epilog

end;</source>
        <Parameter name="_string" type="String"/>
        <Parameter name="_length" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
