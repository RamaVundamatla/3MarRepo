    <JadeMethod name="setControlsForUpdate" id="ce2d7ca7-487b-453a-820b-d23b9d99c820">
        <updating/>
        <source>setControlsForUpdate() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.mode &lt;&gt; Mode_Update
	or self.viewModeOnly then
		return;
	endif;

	self.cmbBridgeAftBay.enabled := true;
	self.txtNumHolds.readOnly := false;		
	self.ckbISOHalfHeight.readOnly := false;
	self.ckb40BayIds.readOnly := false;		
	self.cmbStowageNumber.enabled := true;

	self.cmbVoyage.enabled := false;
	self.btnEditTV.enabled := false;
	self.btnSaveBase.enabled := true;
	self.btnCancelBase.enabled := true;			

	self.btnDirDefaults.enabled := true;			

	self.frmToolBarLayout.enabled := true;
	
	self.btn40BaySlots40.enabled := true;
	self.btnBayApplyBay.enabled := true;
	self.btnBayCopy.enabled := false;
	self.btnBayPrintBay.enabled := true;
	self.btnBayCancelbay.enabled := true;
	self.btnBayRemoveBay.enabled := true;
	self.btnBayEditBay.enabled := true;
	self.btnBayNewBay.enabled := true;
	
	self.tblComboHatchBay.enabled := true;
	self.cmbBayLayout.enabled := true;

	self.btnBayTempBay.enabled := true;
	self.btnBayEditBay.enabled := true;
	self.btnBayCancelbay.enabled := true;
	
	if not self.initWithBay then
		self.btnBaySeqBay.caption := self.CAPTION_BTN_ATTRIBUTES;
		self.btnBaySeqBay.bubbleHelp := self.BUBBLE_ATTRIBUTE;
		self.btnBaySeqBay.click(self.btnBaySeqBay);
		self.btnBaySeqBay.visible := false;
		self.btnBaySeqBay40.visible := false;
		self.frmToolBarBay.positionToolbarControls();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="38fc32d9-b41a-4f53-a885-b9cec139dd3f">
        <updating/>
        <source>setControlsForView() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	
	self.setEnableBayObjects(false);

	self.ckb40BayIds.readOnly := true;
	self.ckbISOHalfHeight.readOnly := true;
	self.txtNumHolds.readOnly := true;			

	self.cmbStowageNumber.enabled := false;
	self.cmbBridgeAftBay.enabled := false;			
	
	self.btnSaveBase.enabled := false;
	self.cmbVoyage.enabled := true;
	self.cmbBayList.enabled := true;	

	self.btnDirDefaults.enabled := false;
	self.frmToolBarLayout.enabled := false;
	self.btn40BaySlots40.enabled := false;
	self.btnBayCopy.enabled := true;
	self.btnBayApplyBay.enabled := false;
	self.btnBayPrintBay.enabled := true;
	self.btnBayCancelbay.enabled := false;
	self.btnBayRemoveBay.enabled := false;
	self.btnBayEditBay.enabled := false;
	self.btnBayNewBay.enabled := false;	
	
	self.initSDF(self.mySDF);
	self.btnBayTempBay.enabled := false;
	self.btnBayTempBay.userObject := null;
 // ### TFS 50421 04NOV2021 NAVAB1	self.btnBayTempBay.caption := app.getErrorString(Template);
	self.myTemplateBay := null;
	
	self.btnBayNewBay.enabled := false;
	self.btnBayEditBay.enabled := false;
	self.btnBayCancelbay.enabled := false;

	if self.myCurrentBay &lt;&gt; null then
		if global.isValidObject(self.myCurrentBay) then
			if self.myCurrentBay.isTransient then
				delete self.myCurrentBay;
			endif;
		endif;
	endif;

	self.cmbBayList.listIndex := -1;
	self.displayBayDetails(null);
	self.initWithBay := false;	

	self.btnBaySeqBay.visible := true;
	self.btnBaySeqBay40.visible := true;
	self.frmToolBarBay.repositionAfterResize();
				
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableBayObjects" id="58b34c4a-1de8-4f4b-a24c-7ec6af9bac75">
        <updating/>
        <source>setEnableBayObjects(_enable : Boolean)updating, protected;
//-----------------------------------------
// Created: July 2005 By: cnwgd1
//-----------------------------------------
vars
begin

	self.ckbAftwartships.readOnly := (not _enable);
	self.ckbFortyFootOnly.readOnly := (not _enable);
	self.ckbFortyFootBay.readOnly := (not _enable);
	self.ckbForty5FtOnly.readOnly := (not _enable);
	self.ckbForty5FootBay.readOnly := (not _enable);
	self.ckbTwinLiftOD.readOnly := (not _enable);
	self.ckbTwinLiftUD.readOnly := (not _enable);

	self.cmbBayLayout.enabled := _enable;
	self.cmbBayList.enabled := _enable;
	self.cmbBayType.enabled := _enable;
	self.cmbDirOn.enabled := _enable;
	self.cmbDirOn40.enabled := _enable;			
	self.cmbDirUnder.enabled := _enable;
	self.cmbDirUnder40.enabled := _enable;	
	self.cmbLashFrom.enabled := _enable;
	self.cmbUnlashFrom.enabled := _enable;
	self.cmbHolds.enabled := _enable;	
	self.cmbOnShipCrane.enabled := _enable;		
		
	self.txt40FootBayID.readOnly := (not _enable);
	self.txtBayID.readOnly := (not _enable);
	self.txtMaxPileWt20IB.readOnly := (not _enable);
	self.txtMaxPileWt20OB.readOnly := (not _enable);
	self.txtMaxPileWt40IB.readOnly := (not _enable);
	self.txtMaxPileWt40OB.readOnly := (not _enable);
	self.txtMaxPileWtUD.readOnly := (not _enable);
	self.txtNumOfPlugs.readOnly := (not _enable);
	self.txtOnDeckCells.readOnly := (not _enable);
	self.txtOnDeckTier.readOnly := (not _enable);
	self.txtUnderDeckCell.readOnly := (not _enable);
	self.txtUnderDeckTier.readOnly := (not _enable);
	self.txtUDCellsHiCub.readOnly := (not _enable);	
	self.txtRemarks.readOnly := (not _enable);		

	self.tblComboHatchBay.allSelectedObjects.clear;
	self.tblComboHatchBay.enabled := _enable;

end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVoyage" id="24882c1c-523d-4664-b75a-c3d6f293f172">
        <updating/>
        <source>setMyCurrentVoyage(_voyage : CM_Voyage)updating;
//--------------------------------------------------
// Created:	12 March 2004 By: cnwgd1
//--------------------------------------------------
//Used for both the persistant and transient object
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------
// 05/09/2017	jlgdap1		TFS 6832 AAT Permissions for Voyage Bay Definition
vars

begin
	self.myCurrentVoyage := _voyage;

	self.displayVoyage();
	
	if _voyage &lt;&gt; null then
		if (not self.viewModeOnly) then
			//self.viewModeOnly := (not app.myCurrentUserCan(_voyage.myTerminal, PmAdmVoyageDefEdit));	// TFS 6832
			self.viewModeOnly := (not app.myCurrentUserCan(_voyage.myTerminal, PmVoyageBayDefMaint));	// TFS 6832
		endif;
	endif;

	self.setToViewMode();			

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
