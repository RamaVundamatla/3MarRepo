    <JadeMethod name="setFromReserveDetail" id="6c6542e2-989a-40f0-8982-66e3fda1be16">
        <updating/>
        <source>setFromReserveDetail(_reserveDetail : CM_ReserveDetail input; _cargoGroup : CM_CargoGroup input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jun 2023	jlier1	Initial creation 58839
03 Apr 2024	jlika1	TFS 63079 EUP | FR 54026 LOADCO LOADNA - Mapping Width Length Height Fields Are Blank
*/

vars
	subType 	: CM_Product;
	cargoType 	: CM_CargoType;
	cargoGroup 	: CM_CargoGroup;
	reserverDet : CM_ReserveSelection;
begin
	
	self.code:=_reserveDetail.getCargoTypeDescr;
	subType :=_reserveDetail.getMyProduct;
	if subType &lt;&gt; null then
		self.packaging:=subType.description;
	endif;
	
	if _cargoGroup &lt;&gt; null then
		self.length:=(_cargoGroup.length/100).roundedTo(2);
		self.width:=(_cargoGroup.width/100).roundedTo(2);
		self.height:=(_cargoGroup.height/100).roundedTo(2);
		self.mark:=_cargoGroup.id;
	elseif _reserveDetail.isKindOf(CM_ReserveSelection) then
		reserverDet := _reserveDetail.CM_ReserveSelection;
		self.length := reserverDet.lengthSelection;
		self.width := reserverDet.widthSelection;
		self.height := reserverDet.heightSelection;
		self.weight := reserverDet.weightSelection;
	endif;
	
epilog

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="input"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup" usage="input"/>
    </JadeMethod>
</Class>
