    <CompAttribute name="allControls" id="dfc7d889-c3fa-4f72-8be2-00dad2767492">
        <type name="StringArray"/>
        <access>readonly</access>
        <text>
Holds an array of all the control names specified against
the rows in for this definition.  This can be used when
loading the defintion to determine if initialisation of
a control is required.</text>
    </CompAttribute>
