        <source>tblFilesTop_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		15 July 2002 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setState(Busy);
	self.tableDragAndDrop(table, x, y);
epilog
	self.setState(Idle);
end;</source>
