    <JadeMethod name="hasTransitInActualBayPlans" id="7eb06a83-20cb-4690-91e7-a6170856cc82">
        <source>hasTransitInActualBayPlans() : Boolean;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     method is called from the cc dataptr code to establish
//              whether a given slot should be grey or not.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	bVal : Boolean;
	ti : CM_TrackedItem;
begin
	//test for whether this is a load colour code
	if (not self.isLoad) then 
		return false; 
	endif;
	if self.mySlotController = null then 
		return false; 
	endif;
	ti := self.mySlotController.getPrimaryTrackedItem(REAL_MODE);
	if ti = null then
		return false;
	endif;
		
	if not ti.isInTransitOnShip then 
		return false; 
	endif;

	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="id" id="15f6282a-8dd9-432a-9486-bbca7222354f">
        <methodInvocation>mapping</methodInvocation>
        <source>id(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     02 April 2002 by cnwdwq1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tId : String;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	tId := self.cellId;
	tId := tId &amp; self.tierId;
	_value := tId;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
