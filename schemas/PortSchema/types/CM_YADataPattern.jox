    <JadeMethod name="createTransientSelectorLine" id="6d71a793-747d-4203-93a3-1e6a486cac82">
        <source>createTransientSelectorLine(criteriaLineHolder: CM_QueryCriteriaLineHolder input; criteria: CM_YACriteria; className: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2015	cnwndl1	Initial creation

*/

vars

begin

	return criteria.myYACriteriaType.description &amp; " YA data range and pattern searching criteria not converted for Selector";

epilog

end;</source>
