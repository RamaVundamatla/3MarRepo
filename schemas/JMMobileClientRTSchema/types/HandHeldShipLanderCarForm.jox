    <JadeMethod name="setLogicalFocus" id="5dc0156c-f3b1-483c-a905-ab2d0f03d4d1">
        <source>setLogicalFocus() protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.fldMain.topSheet = self.shtError then
		self.txtWrongData.setFocus;
	elseif self.frmMain.visible then
		if self.txtVoyage.text = null then
			self.txtVoyage.setFocus();
		else
			if self.doAutoTab then
				self.txtLocation.setFocus();
			else
				self.txtAltID.setFocus();
			endif;
		endif;
	elseif self.frmDamage.visible then
		self.tblDamage.setFocus();
	endif;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b6f6763a-9ad2-4a8d-9771-fe37f1f108cc">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	12 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod();

	self.frmMain.zOrder(1);
	self.left := 0;
	self.top := 0;
	
	self.loadCmbRemarks();
	self.clearAllInfo(false);
	self.doShowFrmMain();
	
	self.caption := 'CAR CHECKER';
	if not app.isRunningOnCE then 
		self.borderStyle := self.BorderStyle_Single;
		self.caption := 'CAR CHECKER Dev mode ';
		self.height := self.height + 30;
	else
		self.borderStyle :=self.BorderStyle_None;
	endif;
	self.clearAllInfo(false);
end;


</source>
    </JadeMethod>
