    <JadeMethod name="validateForEDILoad" id="d25d7ed8-9abb-4c7d-86b7-549750702c32">
        <source>validateForEDILoad(_slotController: CM_SlotController; _ediStowageTI: CM_EDITrackedItem);

// ---------------------------------------------------------------------------

vars
	myStowageID					: String;
	doUseBayCellTierNumbering	: Boolean;
	theTI						: CM_TrackedItem;
	theTis						: CM_TIArray;
	theSlotDefn					: CM_SlotDefn;
	theRealMe					: CM_SlotRequest;
	meIsTwenty					: Boolean;
	is40 						: Boolean;		//cnwas3 PAR 24273

begin 
	//is it ok to create me in this slot?
	if self.moveType &lt;&gt; LOAD_MOVETYPE then
		return;
	endif;
	
	
	
	if self.getAttrDischargePort() = null then
		app.raiseCMWarning2(ERR_INVALID_VALUE,'discharge port', " The code '" &amp; self.dischargePort &amp; "' is not known." , null, _ediStowageTI, _slotController);
	endif;
	
	theSlotDefn := _slotController.mySlotDefnVoyage;
	myStowageID := _ediStowageTI.CM_EDIStowAdviceTI.stowageId;
	
	is40 := self.getAttrIs40();		//cnwas3 PAR 24273
	
	if theSlotDefn &lt;&gt; null then
		if theSlotDefn.unavailable then // PAR 8089
// PAR 26684			app.raiseCMException2(SlotIsUnavailable,myStowageID, "create Load Colour Code", null, _ediStowageTI); // PAR 8089
			app.raiseCMException2(SlotIsUnavailable,_slotController.getFullId(), "create Load Colour Code", null, _ediStowageTI);// PAR 26684
			return;
		endif;
		
		doUseBayCellTierNumbering := theSlotDefn.myBay.CM_BayVoyage.myCellularVoyageStructure.useBayCellTierNumbering;
		myStowageID := theSlotDefn.getStowageId(is40,doUseBayCellTierNumbering);		//cnwas3 PAR 24273
	endif;

	if _slotController &lt;&gt; null then
		
		// this error is the same as the one further down
		//if _slotController.mySlotRequestDischarge = null then
		//	if not _slotController.allTrackedItems.isEmpty then
		//		app.raiseCMWarning1(WARN_CCSLOT_SEQUENCED_TO,myStowageID, null, _ediStowageTI, null);
		//	endif;		
		//endif;

		// if we are marking up a 40 check for a 20 in the twin slot. Check for 20 footer  - only display warning if one exists
		if is40 then		//cnwas3 PAR 24273
			if not _slotController.myAftSlot.allTrackedItems.isEmpty then
				app.raiseCMWarning1(WARN_SLOT_OCCUPIED, myStowageID, null, _ediStowageTI, self);
			endif;		
		endif;

		if not _slotController.allTrackedItems.isEmpty then	
			// trying load CC where there is not discharge CC - no way!
			if  _slotController.mySlotRequestDischarge = null then
				app.raiseCMWarning1(WARN_CCSLOT_TRA_PRESENT,myStowageID, null, _ediStowageTI, self);
			endif;
		endif;
	endif;

	meIsTwenty := not is40;		//cnwas3 PAR 24273
		
	// AKB2003NOV do not validate the definition of the back end
	if theSlotDefn &lt;&gt; null and ((not theSlotDefn.fortyBack) or meIsTwenty) then 	// JC 09/02/2004  need to also validate 20's in the aft slot
//	if theSlotDefn &lt;&gt; null and not theSlotDefn.fortyBack then
		if not theSlotDefn.power and self.getAttrPowerRequired() then
			app.raiseCMException1(ERR_NON_POWER,myStowageID, null, _ediStowageTI);
		endif;
		if (is40 and not theSlotDefn.fortyFront) or		//cnwas3 PAR 24273
		(is40 and not theSlotDefn.myAftSlot.fortyBack) or		//cnwas3 PAR 24273
		(self.getAttrIsBackend() and not theSlotDefn.fortyBack) then // PAR 21746
			app.raiseCMException1(ERR_NON_40_SLOT,myStowageID , null, _ediStowageTI);
		endif;
// PAR7496 AKB2004FEB			if not (theSlotDefn.reefer or theSlotDefn.power) and self.reefer then
// PAR7496 AKB2004FEB				app.raiseCMException1(ERR_NON_REEFER,myStowageID, 'Temp', _ediStowageTI);
// PAR7496 AKB2004FEB			endif;
		if not theSlotDefn.watercooled and self.getAttrWaterCooled() then
			app.raiseCMException1(ERR_NON_WATERCOOLED,myStowageID, null, _ediStowageTI);
		endif;
//		if not theSlotDefn.highCubed and self.highCubed then
//			app.raiseCMException1(ERR_NON_HICUBED,myStowageID, null, _ediStowageTI);
//		endif;
		if theSlotDefn.mtOnly and not self.getAttrEmpty() then
			app.raiseCMException1(ERR_NON_EMPTY,myStowageID, 'MT', _ediStowageTI);
		endif;
	endif;

end;</source>
        <Parameter name="_slotController" type="CM_SlotController"/>
        <Parameter name="_ediStowageTI" type="CM_EDITrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateForErase" id="8f1b4c69-170f-44ed-9f54-c460916e430d">
        <source>validateForErase();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	myStowageID,theString : String;
	doUseBayCellTierNumbering : Boolean;
	theTI : CM_TrackedItem;
	theTis : CM_TIArray;
	theSlotDefn : CM_SlotDefn;
	theRealMe : CM_SlotRequest;
	theRealSlotController : CM_SlotController;
	theRealMeSCDischargeSR : CM_SlotRequest;
begin
	if self.moveType &lt;&gt; NULL_MOVETYPE then
		return;
	endif;
	
	if self.isTransient then
		theRealMe := self.pxyGetRealObject().CM_SlotRequest;
		if theRealMe = null then // create // 722b testing
			theRealMe := self;  // 722b testing
			theRealSlotController := self.mySlotController; // 722b testing
			theSlotDefn := theRealSlotController.mySlotDefnVoyage; // 722b testing
		else
			theSlotDefn := theRealMe.mySlotDefinition;
			theRealSlotController := theRealMe.mySlotController;
		endif;
	else
		theRealMe := self;
		theSlotDefn := self.mySlotDefinition;
		theRealSlotController := theRealMe.mySlotController;
	endif;
	if theSlotDefn &lt;&gt; null then
		doUseBayCellTierNumbering := theSlotDefn.myBay.CM_BayVoyage.myCellularVoyageStructure.useBayCellTierNumbering;
		myStowageID := theSlotDefn.getStowageId(theRealMe.getAttrIs40(),doUseBayCellTierNumbering);
	endif;

	if theRealMe.myJob = null then
		return;
	endif;
	if theRealMe.myJob &lt;&gt; null then // PAR 8739 AKB2004AUG
		if theRealMe.myJob.CM_VoyageJob.isLoadedToOperations then // PAR 8739 AKB2004AUG
			app.raiseCMException1(ERR_JOB_LOADED, theRealMe.myJob.jobId, null, null); // PAR 8739 AKB2004AUG
		endif;
	endif;
	
	if theRealMe.myJob &lt;&gt; null then
		app.raiseCMWarning2(Slot_part_want_conti_with_eras, myStowageID,theRealMe.myJob.jobId, null, null, self);
	endif;

	if theRealMe.isLoad then
		create theTis transient;
		theRealMe.getAllTrackedItems(theTis);
		if not theTis.isEmpty then
			app.raiseCMWarning1(Slot_load_cargo_plann_want_con,myStowageID, null, null, self);
		endif;
	endif;
epilog
	delete theTis;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="1ad665ff-0ac5-46b8-b8b6-ffa558a00eaf">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     06 June 2002 cnsrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.validateMe();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="c873624d-fbc0-4691-898b-758f604345e7">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:     06 June 2002 cnsrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 06/03/2018	jlgdap1		TFS 37322 QNS Auto discharge colour after loading sequence and plan
//							Because of the way the Auto Discharge Colour Code works, we end up 
//							in here twice after acknowledging any WARN_CCSLOT_SEQUENCED_FROM
//							warnings first time through.
//							CM_SlotController createDefaultDischargeCC creates and valdiates a proxy,
//							then creates a new proxy and proceeds to validate ot again with a TI attached
//							So we need to suppress the warnings here about resequencing if we've already
// 							acknowledged warnings
vars
	myStowageID					: String;
	doUseBayCellTierNumbering	: Boolean;
	theTI						: CM_TrackedItem;
	theTis						: CM_TIArray;
	theSlotDefn					: CM_SlotDefn;
	theRealMe					: CM_SlotRequest;
	theRealSlotController,
	theAftSlot					: CM_SlotController;
	theRealMeSCDischargeSR		: CM_SlotRequest;
	meIsTwenty					: Boolean;
	is40						: Boolean;		//cnwas3 PAR 24273
	isBackendLinked : Boolean;
begin 
	//is it ok to update me
	if self.moveType = NULL_MOVETYPE then
		self.validateForErase();
		return;
	endif;

	if (self.moveType = LOAD_MOVETYPE and self.isDischarge) or
	   (self.moveType = DISCHARGE_MOVETYPE and self.isLoad) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid isLoad (' &amp; self.isLoad.String &amp; ') for moveType (' &amp; self.moveTypeString &amp; ')');
	endif;

	if self.isTransient then
		theRealMe := self.pxyGetRealObject().CM_SlotRequest;
		if theRealMe = null then // create // 722b testing
			theRealMe := self;  // 722b testing
			theRealSlotController := self.mySlotController; // 722b testing
			theSlotDefn := theRealSlotController.mySlotDefnVoyage; // 722b testing
		else
			theSlotDefn := theRealMe.mySlotDefinition;
			theRealSlotController := theRealMe.mySlotController;
		endif;
	else
		theRealMe := self;
		theSlotDefn := self.mySlotDefinition;
		theRealSlotController := theRealMe.mySlotController;
	endif;
	if theSlotDefn &lt;&gt; null then
		doUseBayCellTierNumbering := theSlotDefn.myBay.CM_BayVoyage.myCellularVoyageStructure.useBayCellTierNumbering;
		myStowageID := theSlotDefn.getStowageId(theRealMe.getAttrIs40(),doUseBayCellTierNumbering);
	endif;

	// is a DLR and changing to non DLR? If YES and it is planned then NO
	if theRealMe.moveType = DLR_MOVETYPE and self.moveType &lt;&gt; DLR_MOVETYPE then
		if theRealMe.myJob &lt;&gt; null then
			theTI := theRealMe.getTrackedItem();
			if theTI &lt;&gt; null and theTI.myPrimaryPlannedLocation &lt;&gt; null then
				app.raiseCMException2(Canno_chang_move_type_from_pla, theTI.id, myStowageID, null,  null);
			endif;
		endif;
	endif;
	
	if theRealMe.myJob &lt;&gt; null then
		if theRealMe.myJob.status = JOB_COMPLETE then
			app.raiseCMWarning1(WARN_REWORK_SLOT,myStowageID, null, null, self);
		endif;
	endif;
	
	if theRealMe.isDischarge and theRealSlotController &lt;&gt; null then
		create theTis transient;
		theRealSlotController.getAllPlannedTrackedItems(theTis, true, false);
		
		if not theTis.isEmpty then
			if not app.myPassport.warningsAcknowledged then											// TFS 37322
				app.raiseCMWarning1(WARN_CCSLOT_SEQUENCED_FROM,myStowageID, null, null, self);
			endif;																					// TFS 37322
		endif;		
		delete theTis;
	
	endif;
	
	is40 := self.getAttrIs40();		//cnwas3 PAR 24273
	isBackendLinked := (self.mySlotRequestForward &lt;&gt; null);
	
	if theRealMe.isLoad and theRealSlotController &lt;&gt; null then
		/* an error "WARN_CCSLOT_TRA_PRESENT" is raise below for this  JC 13/06/2005
		if theRealSlotController.mySlotRequestDischarge = null then
			if (not theRealSlotController.allTrackedItems.isEmpty) then
				app.raiseCMWarning1(WARN_CCSLOT_SEQUENCED_TO, myStowageID, null, null, null);
			endif;		
		endif;
		*/
		// if we are marking up a 40 check for a 20 in the twin slot. Check for 20 footer  - only display warning if one exists
		if is40 			//cnwas3 PAR 24273
		and not  isBackendLinked then // PAR 25933 - do not ask the linked back end to look at it's aft slot
			theAftSlot := theRealSlotController.myAftSlot;
			if theAftSlot = null then
				app.raiseCMException(Canno_colou_from_aft_40_slot,null,self);	//12 Dec 2011	NDL	Par 28744
				//app.raiseUnexpectedProgramError(class.name, method.name, 'Attempting to set 40 ft when slot cannot take 40 ft');
				return;
			endif;
			if (not theAftSlot.allTrackedItems.isEmpty) then
				// WAS PAR 5996 
//				app.raiseCMWarning1(WARN_SLOT_OCCUPIED,myStowageID, null, null, null); 
				// NOW from here
				theRealMeSCDischargeSR := theAftSlot.mySlotRequestDischarge ;
				// trying load CC where there is not discharge CC - no way!
				if  theRealMeSCDischargeSR = null 
				// if we erase we do not delete the slot request it will have a null type
				or (theRealMeSCDischargeSR &lt;&gt; null 
					and theRealMeSCDischargeSR.moveType = NULL_MOVETYPE) then
					app.raiseCMWarning1(WARN_CCSLOT_TRA_PRESENT, theAftSlot.getStowageId(null), null, null,self);
				endif;
				// To here
			endif;		
		endif;
	endif;
	
	if self.moveType = LOAD_MOVETYPE then
		if theRealSlotController &lt;&gt; null then
			if not theRealSlotController.allTrackedItems.isEmpty then	
				theRealMeSCDischargeSR := theRealSlotController.mySlotRequestDischarge ;
				// trying load CC where there is not discharge CC - no way!
				if theRealMeSCDischargeSR = null 
				// if we erase we do not delete the slot request it will have a null type
				or (theRealMeSCDischargeSR &lt;&gt; null 
					and theRealMeSCDischargeSR.moveType = NULL_MOVETYPE) then
					app.raiseCMWarning1(WARN_CCSLOT_TRA_PRESENT,myStowageID, null, null, self);
				endif;
			endif;
		endif;

		//meIsTwenty := (not self.fortyFront) and (not self.fortyBack);
		// PAR 16415 CCMS 1029
		meIsTwenty := (self.is20() 
							and not self.fortyBack); // PAR 26516
		// AKB2003NOV do not validate the definition of the back end
		if theSlotDefn &lt;&gt; null and ((not theSlotDefn.fortyBack) or meIsTwenty) then 	// JC 09/02/2004  need to also validate 20's in the aft slot
			if ( not theSlotDefn.power and self.getAttrPowerRequired() ) then
				if not (not meIsTwenty and theSlotDefn.myAftSlot.power) then   // if not 20 and aft slot has power skip // cnwrd1 par 18733 23.1.09
					app.raiseCMException1(ERR_NON_POWER,myStowageID, null, null);
				endif;
			endif;
			if self.getAttrIs53() then
				if not theSlotDefn.is53 then
					app.raiseCMException2(ERR_NON_OS_SLOT, myStowageID,"53", null, null);
				endif;
			elseif self.getAttrIs30() then
				if not theSlotDefn.is30 then
					app.raiseCMException2(ERR_NON_OS_SLOT, myStowageID,"30", null, null);
				endif;
			elseif self.getAttrIs45() then // PAR 18682 CCMS SFW 1055
				if not theSlotDefn.is45 then // PAR 18682 CCMS SFW 1055
					app.raiseCMException2(ERR_NON_OS_SLOT, myStowageID,"45", null, null);
				endif;
			else
				if (is40 and not theSlotDefn.fortyFront) or (self.getAttrIsBackend() and not theSlotDefn.fortyBack) then	//cnwas3 PAR 24273
					app.raiseCMException1(ERR_NON_40_SLOT, myStowageID, null, null);
				endif;
			endif;
			
			
			
			//if self.fortyBack and (self.getForwardSlotRequest() = null) then
			//	app.raiseCMException1(ERR_NON_40_SLOT, myStowageID, null, null);
			//endif;
			//power is also ok for reefers - JC 
// PAR7496 AKB2004FEB				if not (theSlotDefn.reefer or theSlotDefn.power) and self.reefer then
// PAR7496 AKB2004FEB					app.raiseCMException1(ERR_NON_REEFER,myStowageID, null, null);
// PAR7496 AKB2004FEB				endif;
			if not theSlotDefn.watercooled and self.getAttrWaterCooled() then
				app.raiseCMException1(ERR_NON_WATERCOOLED,myStowageID, null, null);
			endif;
//			if not theSlotDefn.highCubed and self.highCubed then
//				app.raiseCMException1(ERR_NON_HICUBED,myStowageID, null, null);
//			endif;
			if theSlotDefn.mtOnly and not self.getAttrEmpty() then
				app.raiseCMException1(ERR_NON_EMPTY,myStowageID, null, null);
			endif;
		endif;
	endif;
epilog
		delete theTis;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="ea88fb9d-ded1-423b-a18e-37a4fd73d803">
        <source>validateMoveTo(_control : CMIF_MoveController input);
/*
------------------------------------------------------------------------
Created:			18 February 2003 by cnwdwq1
Purpose:			Checks the slot request against the intended move
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
20/05/2020		jlgdap1			TFS 49359 PEN Container changed Port of Discharge
------------------------------------------------------------------------
*/
vars
	reserve : CM_ReserveDetail;			// TFS 49359
	selection : CM_ReserveSelection;	// TFS 49359
	release : CM_BulkRelease;			// TFS 49359
	ti : CM_TrackedItem;				// TFS 49359
	opcode : String;					// TFS 49359
	poolParty : CM_MTPoolingParty; 		//25/10/2024	navkc1 JIRA Bug MTN-18830
begin
	if _control.moveMode = REAL_MODE then
		//We only do this if we are PLANNING.
		// TFS 49359 but we also need to do SOMETHING if we're being moved to a different
		// slot that the one we were planned to
		if not _control.doingAutoLoadPlanning 
		and _control.myTrackedItem &lt;&gt; null 
		and _control.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; null 
		and _control.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; _control.myTargetLocation then
			// does the target location have a release request
			if self.isBulkRelease then
				ti := _control.myTrackedItem;
				// check the ti matches the release request
				reserve := self.getBulkReleaseReserveDetail();
				reserve.testCandidateTI(ti);
				// check the ti matches the discharge port on the release request
				release := reserve.myReserveHeader;
				if release.myDischargePort &lt;&gt; null and release.getDischargePortCode &lt;&gt; ti.dischargePort then
					app.raiseCMException4(Discharge_port_does_not_match, ti.id, ti.dischargePort, self.mySlotController.getStowageId(ti), release.myDischargePort.code, null, null);
				endif;
				
				poolParty := release.myPoolingParty(); //25/10/2024	navkc1 JIRA Bug MTN-18830 - Also check the operator pool party
				
				// check the ti matches the operator on the release request
				if (release.myOperator &lt;&gt; null and release.myOperator &lt;&gt; ti.myOperator 
					and (poolParty = null or poolParty.allOperatorTerminals[ti.myOperator] = null)) //25/10/2024	navkc1 JIRA Bug MTN-18830
				or (release.myOperatorGroup &lt;&gt; null and not release.myOperatorGroup.allOperators.includes(ti.myOperator)) then
					if release.myOperator &lt;&gt; null then
						opcode := release.myOperator.code;
					else
						opcode := release.myOperatorGroup.code;
					endif;
					app.raiseCMException4(Operator_does_not_match, ti.id, ti.operatorCode, self.mySlotController.getStowageId(ti), opcode, null, null);
				endif;
				// check the TI matches the isEmpty setting on the release request
				if release.fullRelease and ti.isEmpty then
					app.raiseCMException(ERROR_MT_CONT_FULL, null, null);
				elseif not release.fullRelease and not ti.isEmpty then
					app.raiseCMException(ERROR_FULL_CONT_MT, null, null);
				endif;
			endif;
		endif;
		// TFS 49359 end
		return;
	endif;
	
	if _control.moveMode = PLANNING_MODE 
	and not _control.doingAutoLoadPlanning then // supress warnings for auto load planning
// cnwdad1 30/07/2010 - PAR #24045.
		//_control.myTrackedItem.testAgainstRequest(self);
		_control.myTrackedItem.testAgainstSlotRequest(self, _control);
	endif;
end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateRequestLink" id="d1d4ff39-3c7d-4cf0-ac2f-da3556eba044">
        <updating/>
        <source>validateRequestLink(_theSlotRequest : CM_Request) updating ;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		the request passed in is being linked to us, does it match?
//
// ---------------------------------------------------------------------------
vars
	theLocn,theLLocn : String;
begin
	if self.pxyIsProxy then
		theLocn := _theSlotRequest.pxyGetRealObject.CM_Request.getLC.getStowageId(null);
		theLLocn := self.pxyGetRealObject.CM_SlotRequest.mySlotController.getStowageId(null);
	else
		theLocn := _theSlotRequest.getLC.getStowageId(null);
		theLLocn := self.mySlotController.getStowageId(null);
	endif;
	if self.moveType &lt;&gt; DLR_MOVETYPE and self.moveType &lt;&gt; SOB_MOVETYPE then
		app.raiseCMException2(ERR_INVALID_VALUE,"MOVE TYPE", "The request at " &amp; theLLocn &amp; " cannot be linked since it is not coded for DLR or SOB.", null, null);
	endif;
	if _theSlotRequest.getMoveType &lt;&gt; DLR_MOVETYPE and _theSlotRequest.getMoveType &lt;&gt; SOB_MOVETYPE then
		app.raiseCMException2(ERR_INVALID_VALUE,"MOVE TYPE", "The request at " &amp; theLocn &amp; " cannot be linked since it is not coded for DLR or SOB.", null, null);
	endif;
	if self.moveType &lt;&gt; _theSlotRequest.getMoveType then
		app.raiseCMException2(ERR_INVALID_VALUE,"MOVE TYPE", "The 2 requests being linked, " &amp; theLLocn &amp; "/" &amp; theLocn &amp; ", have different move types.", null, null);
	endif;
	if self.getAttrCargoType() &lt;&gt; _theSlotRequest.getAttrCargoType() then
		app.raiseCMException2(ERR_INVALID_VALUE,"CARGO TYPE", "The 2 requests being linked, " &amp; theLLocn &amp; "/" &amp; theLocn &amp; ", have different cargo types.", null, null);
	endif;
	if self.getAttrEmpty() &lt;&gt; _theSlotRequest.getAttrEmpty() then
		app.raiseCMException2(ERR_INVALID_VALUE,"EMPTY Attribute", "The request at " &amp; theLocn &amp; ", being linked to, does not have a matching empty attribute set.", null, null);
	endif;
// PAR 32120 see validateRequestLinkSameToSame
//	if self.getAttrIs40() &lt;&gt; _theSlotRequest.getAttrIs40() then
//		app.raiseCMException2(ERR_INVALID_VALUE,"FORTY Attribute", "The request at " &amp; theLocn &amp; ", being linked to, does not have a matching forty attribute set.", null, null);
//	endif;
	if self.getAttrPowerRequired() &lt;&gt; _theSlotRequest.getAttrPowerRequired() then
		app.raiseCMException2(ERR_INVALID_VALUE,"POWER Attribute", "The request at " &amp; theLocn &amp; ", being linked to, does not have a matching power attribute set.", null, null);
	endif;
	// only check the reefer setting if I am not on power
// PAR7496 AKB2004FEB		if self.reefer &lt;&gt; _theSlotRequest.reefer and not self.power then
// PAR7496 AKB2004FEB			app.raiseCMException2(ERR_INVALID_VALUE,"REEFER Attribute", "The request at " &amp; theLocn &amp; ", being linked to, does not have a matching reefer attribute set.", null, null);
// PAR7496 AKB2004FEB		endif;
	if self.getAttrWaterCooled() &lt;&gt; _theSlotRequest.getAttrWaterCooled() then
		app.raiseCMException2(ERR_INVALID_VALUE,"WATER COOLED Attribute", "The request at " &amp; theLocn &amp; ", being linked to, does not have a matching water cooled attribute set.", null, null);
	endif;
	
	if self.getAttrDischargePort() &lt;&gt; _theSlotRequest.getAttrDischargePort() then
		app.raiseCMException2(ERR_INVALID_VALUE,"Discharge Port", "The 2 requests being linked, " &amp; theLLocn &amp; "/" &amp; theLocn &amp; ", have different discharge ports.", null, null);
	endif;
	
	// 15/07/2013 cnwmh5 #31938 
	self.validateRequestLinkSameToSame(_theSlotRequest, theLLocn, theLocn);
	
end;</source>
        <Parameter name="_theSlotRequest" type="CM_Request"/>
    </JadeMethod>
</Class>
