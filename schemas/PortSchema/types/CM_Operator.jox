end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="54ecf52a-b82d-43a4-b246-25c617fb8f9a">
        <updating/>
        <source>setProxy(	pCode:String;
			pDescription:String;
			_notAvailableForEntry:Boolean;
			pColour:Integer;
			pReeferReadingsPerDay:Integer;
			pDebtor:CM_Debtor;
			pDisplayTempFahrenheit:Boolean;
			pRequiresBookingReference:Boolean;
			pRequiresCVC:Boolean;
			pRequiresConsigneeConsignor:Boolean;
			pRequiresDeliveryRelease:Boolean;
			pRequiresHumidity:Boolean;
			pRequiresRequestNumber:Boolean;
			pRequiresVentilation:Boolean;
			pRequiresVoyage:Boolean;
			pCargoRelImpFFUpdAllowed:Boolean;	// adm 210708 CCMS 1738
			pNotRoadIds,pNotRailIds:CM_Strings;
			_allCodeGroups:CM_CodeGroupsByTypeDict;
			_reqExpOpNo: Boolean; //cnwrd1 4.11.08 CCMS JMT 1743/1764 
			_reqImpFF: Boolean; //cnwrd1 4.11.08 CCMS JMT 1743/1764 
			_reqImpOperatorPIN : Boolean; //cnwrd1 4.11.08 CCMS JMT 1743/1764 
			_cmifOpTermDict : CMIF_OpTerminalConfigDict;		// cnwar2 PAR 19796
			_emailAddresses : CM_EmailEntityByTypeNameDict; //25 Aug 2009	NDL	Par 20521
			_reeferWashExpiry : Integer;//cnwjo3 CCMS 1892, par 23587
			_showOpExportReleaseWarning :Boolean;	// 14/03/2011 cnwcs5 par 26909
			_bookingsUniqueByNumber : Boolean	// 20/10/2011 cnwdap1 CCMS 2096 PAR #28524
			) updating;


vars
	cmifOpTermConfig	: CMIF_OperatorTerminalConfig;
	opTerm				: CM_OperatorTerminal;

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.code						:=	pCode[1:4];
	self.isNotAvailableForEntry		:=	_notAvailableForEntry;
	self.colour						:=	pColour;
	self.description				:=	pDescription[1:40];
	self.reeferReadingsPerDay		:=	pReeferReadingsPerDay;
	
	//self.myOperatorGroup	:=	pMyOperatorGroup;
	if pDebtor = null then
		self.debtor	:=	app.myRoot.myRootCompany.rootDebtor;
	else
		self.debtor	:=	pDebtor;
	endif;
	
	self.displayTempFahrenheit		:=	pDisplayTempFahrenheit;
	self.requiresBookingReference	:=	pRequiresBookingReference;
    self.requiresCVC				:=	pRequiresCVC;
    self.requiresConsigneeConsignor	:=	pRequiresConsigneeConsignor;
    self.requiresDeliveryRelease	:=	pRequiresDeliveryRelease;
    self.requiresHumidity			:=	pRequiresHumidity;
    self.requiresRequestNumber		:=	pRequiresRequestNumber;
    self.requiresVentilation		:=	pRequiresVentilation;
    self.requiresVoyage				:=	pRequiresVoyage;
	self.setCargoReleaseImpFFUpdAllowed(pCargoRelImpFFUpdAllowed); // adm 210708 CCMS 1738
    
	
	self.setRequiresExportOperatorNo(_reqExpOpNo); //cnwrd1 4.11.08 CCMS JMT 1743/1764 
	self.setRequiresImportFF(_reqImpFF); //cnwrd1 4.11.08 CCMS JMT 1743/1764 
	self.setRequiresImpOperatorPIN(_reqImpOperatorPIN); //cnwrd1 4.11.08 CCMS JMT 1743/1764 

    self.notRoadIds.clear();
    
    if pNotRoadIds &lt;&gt; null then
		pNotRoadIds.clone(self.notRoadIds);
	endif;
	
	self.notRailIds.clear();
	
	if pNotRailIds &lt;&gt; null then
		pNotRailIds.clone(self.notRailIds);
	endif;
	
	self.allCodeGroups.clear();
	if _allCodeGroups&lt;&gt; null then // ### TFS 52237 27OCT2021 NAVAB1
		_allCodeGroups.copy(self.allCodeGroups);
	endif;
	
	if _cmifOpTermDict &lt;&gt; null then
		foreach cmifOpTermConfig in _cmifOpTermDict do
			opTerm := self.getOperatorTerminal(cmifOpTermConfig.myTerminal, true);
			opTerm.setConfig(cmifOpTermConfig);
		endforeach;
	endif;
	
	//25 Aug 2009	NDL	Par 20521 CCMS 1609
	self.allEmailAddresses.clear;
	if _emailAddresses&lt;&gt; null then  // ### TFS 52237 27OCT2021 NAVAB1
	if not _emailAddresses.isEmpty then
		_emailAddresses.copy(self.allEmailAddresses);
	endif; 
	endif;
	
	//cnwjo3 CCMS 1892, par 23587
	self.washExpiryReefer := _reeferWashExpiry;
	
	// cnwcs5 par 26909
	self.setShowOpExportReleaseWarning (_showOpExportReleaseWarning);
	
	// PAR #28524 CCMS POL 2096
	self.bookingsUniqueByNumber := _bookingsUniqueByNumber;
	
	self.myRoot	:=	app.myRoot;
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="pColour" type="Integer"/>
        <Parameter name="pReeferReadingsPerDay" type="Integer"/>
        <Parameter name="pDebtor" type="CM_Debtor"/>
        <Parameter name="pDisplayTempFahrenheit" type="Boolean"/>
        <Parameter name="pRequiresBookingReference" type="Boolean"/>
        <Parameter name="pRequiresCVC" type="Boolean"/>
        <Parameter name="pRequiresConsigneeConsignor" type="Boolean"/>
        <Parameter name="pRequiresDeliveryRelease" type="Boolean"/>
        <Parameter name="pRequiresHumidity" type="Boolean"/>
        <Parameter name="pRequiresRequestNumber" type="Boolean"/>
        <Parameter name="pRequiresVentilation" type="Boolean"/>
        <Parameter name="pRequiresVoyage" type="Boolean"/>
        <Parameter name="pCargoRelImpFFUpdAllowed" type="Boolean"/>
        <Parameter name="pNotRoadIds" type="CM_Strings"/>
        <Parameter name="pNotRailIds" type="CM_Strings"/>
        <Parameter name="_allCodeGroups" type="CM_CodeGroupsByTypeDict"/>
        <Parameter name="_reqExpOpNo" type="Boolean"/>
        <Parameter name="_reqImpFF" type="Boolean"/>
        <Parameter name="_reqImpOperatorPIN" type="Boolean"/>
        <Parameter name="_cmifOpTermDict" type="CMIF_OpTerminalConfigDict"/>
        <Parameter name="_emailAddresses" type="CM_EmailEntityByTypeNameDict"/>
        <Parameter name="_reeferWashExpiry" type="Integer"/>
        <Parameter name="_showOpExportReleaseWarning" type="Boolean"/>
        <Parameter name="_bookingsUniqueByNumber" type="Boolean"/>
    </JadeMethod>
