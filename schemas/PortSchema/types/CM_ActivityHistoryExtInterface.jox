    <JadeMethod name="setMyCashReceipt" id="870c6f5e-534f-4f5d-ab58-07aa7d24b148">
        <updating/>
        <source>setMyCashReceipt(_cashReceipt : CM_CashReceipt) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2018	cnwma1	ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction

*/

vars
	voyage : CM_Voyage;
begin
	self.myCashReceipt := _cashReceipt;
	if self.myCashReceipt &lt;&gt; null then
		voyage:=self.myCashReceipt.myVoyage;
		if voyage &lt;&gt; null then
			self.voyageCode:=voyage.code;
		endif;
		if self.myCashReceipt.getDebtor &lt;&gt; null then
			self.debtorCode:=self.myCashReceipt.getDebtor.code;
		endif;
		if self.myCashReceipt.myWorkOrder &lt;&gt; null then
			self.isCargoTransaction:=not self.myCashReceipt.myWorkOrder.isVoyageWorkOrder;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="setMyInvoice" id="c69fb1dc-41f7-45a6-aa0d-089820e938fc">
        <updating/>
        <source>setMyInvoice(_invoice : CM_Invoice) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2018	cnwma1	ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction

*/

vars
	voyage : CM_Voyage;
begin
	self.myInvoice := _invoice;
	if self.myInvoice &lt;&gt; null then
		voyage:=self.myInvoice.myVoyage;
		if voyage &lt;&gt; null then
			self.voyageCode:=voyage.code;
		endif;
		if self.myInvoice.debtor &lt;&gt; null then
			self.debtorCode:=self.myInvoice.debtor.code;	
		endif;
		self.isCargoTransaction:=self.myInvoice.getSapVesselCargo = "Cargo";
	endif;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyage" id="4b106bd3-7b20-4a35-8cb7-4e92960423a9">
