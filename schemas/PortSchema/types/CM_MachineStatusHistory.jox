    </JadeMethod>
    <JadeMethod name="setAvailabilityCode" id="acff9e1d-33e3-4e21-bc57-f95686b02848">
        <updating/>
        <source>setAvailabilityCode(availCode : String) updating;
//Wraps code to set the availability code for a machine.
//If not required for this machine, then we ignore it.
vars
	machAvail:   CM_MachineAvailability;
begin
	if availCode.trimBlanks = null then
		return;	//Its blank, quit.
	endif;
	//--------------
	//Verify reason code is valid
	//--------------
	if not machine.requireAvailabilityCode then
		return;
	endif;
	//-----------
	//Test that its valid
	//-----------
	if availCode &lt;&gt; "Z!" then
		//AJA 27/11/00: Seems that Z! is the secret code used when setting off line
		//from the RT Q window (ie without a reason). So don't check validity (Oh Boy)
		machAvail:= app.myRoot.allMachineAvailabilities[availCode.toUpper];
		if machAvail = null then
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_MACH_AVAIL_CODE, machine.id, null, null);
			return;
		endif;
	endif;
	availabilityCode := availCode.toUpper;
end;</source>
        <Parameter name="availCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setDownDelayed" id="d8da1684-9ff5-4961-be76-2e18adf1a327">
