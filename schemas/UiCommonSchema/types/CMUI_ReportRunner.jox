    <JadeMethod name="tblParameter_change" id="d68d1653-21b8-40b5-a166-66b5be85ce71">
        <controlMethod name="CM_EntryTable::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblParameter_change(table: CM_EntryTable input) updating;

vars

	value			: Integer;
	array			: ObjectArray;
	voyage			: CM_Voyage;
	globalVoyage	: CM_VoyageGlobal;
	row				: Integer;
begin
	if (not table.isRowVisible(ETRow_SelectAll)) then
		return;
	endif;

	create array transient;
	value := table.getValueByName(ETRow_SelectAll).Integer;
	if value = 1 then
		globalVoyage := self.cmbActualVoy.listObject.CM_VoyageGlobal;
		if globalVoyage = null then
			return;
		endif;
		foreach voyage in globalVoyage.allVoyages discreteLock where self.myReportAgent.allTerminals.includes(voyage.myTerminal) do
//			if (not CM_LogVoyage.hasInstance(voyage)) then
			if (voyage.myLogVoyageStructure = null) then
				continue;
			endif;
			
			voyage.myLogVoyageStructure.allLogLots.copy(array);
		endforeach;
		
		self.lstTblLogLot.setSelected(array);	
	else
		self.lstTblLogLot.setSelected(null);	
	endif;

	self.myAssistant.listTableLostFocus(self.tblParameter, self.saveRowHeight, self.lstTblLogLot, 'lotNo', false);
	
	self.setTblParameterHeight();
epilog
	delete array;
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblParameter_dblClick" id="d14429f7-ccde-4ece-af35-b01bfa0b8b3b">
        <controlMethod name="CM_EntryTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblParameter_dblClick(table: CM_EntryTable input) updating;

vars

begin
	if self.myReportAgent.myQryReport.menuId = self.myReportAgent.myQryReport.getIdPrefix &amp; CM_RepShipLogList.String then
		if table.row = table.getRowByName(ETRow_ExtraDetail) and table.column = CM_EntryTable.ColumnValue then
			if self.myReportController &lt;&gt; null then
				self.myReportController.run(false);
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblParameter_queryRowColChg" id="04f0392c-d123-4e6c-a56a-6a866cf804aa">
        <controlMethod name="CM_EntryTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblParameter_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2019	jlgndl1	Initial creation	TFS 46131
04 Sep 2019	jlgsl4	TFS 46287 - SNO - Selector Query Invoice Report error
*/

vars

	fromControl : Control;
	toControl : Control;

begin

	fromControl := table.accessCell( table.row, table.column ).cellControl;
	toControl := table.accessCell( newRow, newCol ).cellControl;
	
	if fromControl &lt;&gt; null then
		if CMUI_ListTable.hasInstance(fromControl) then
			if fromControl = self.lstUnloadEvts
			or fromControl = self.lstBarges
			or fromControl = self.lstNonBarges
			then
				table.accessRow(table.row).height := 20;
				table.accessCell( table.row, table.column ).text := fromControl.CMUI_ListTable.getSelectedFromDisplay;
			endif;
			if fromControl.isA(CMUI_ListTable) and table.CM_EntryTable.allEntRowTransients[table.row].EntTableRowTransient.getHeadingUnaltered() = self.INVOICETYPE_ISONEOF then // --&gt; TFS 46287
				table.accessRow(table.row).height := 20; // "Invoice Type is one of" comes from CM_QRefInvLineTypeMethod.niceName &amp; CM_QReferenceIsOneOf.description, not xlated
				table.accessCell(table.row, table.column).text := fromControl.CMUI_ListTable.getSelInvTypeFromDisplay();
			endif; // &lt;-- TFS 46287
		endif;
	endif;
	
	if toControl &lt;&gt; null then
		if CMUI_ListTable.hasInstance(toControl) then
			if toControl = self.lstBarges
			or toControl = self.lstUnloadEvts
			or toControl = self.lstNonBarges
			or toControl.isA(CMUI_ListTable) and table.CM_EntryTable.allEntRowTransients[table.row].EntTableRowTransient.getHeadingUnaltered() = self.INVOICETYPE_ISONEOF // TFS 46287
			then
				table.accessRow(newRow).height := 100;
			endif;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblPrintOptions_dblClick" id="06d0cd1a-88ca-45e4-b829-ddd51d922bb2">
        <controlMethod name="CM_EntryTable::dblClick"/>
