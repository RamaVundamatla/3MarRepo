    <JadeMethod name="setArrivalDT" id="7a93340f-c5d8-4caf-8984-49b5c94fadcf">
        <updating/>
        <source>setArrivalDT(_arriveDT : TimeStamp) updating;
//--------------------------------------------------------------
//Created: 08 April 2004 By: cnwgd1
// 
// This method should only be called from
//--------------------------------------------------------------
/*

Date		Who		Reason
10 Apr 2008	cnwkpd1	PAR #16378 - Need to remove and add from parent Global Voyage(s) because
					arrivedDT is a key to this manual collection
15 Mar 2012	cnwkpd1	PAR #29274 - only set key values if they have changed
22 Mar 2024	jlika1	TFS 55410 PNL-Voyage Actual Arrival Date Time Changed - Add a Warning Message when this happens
*/

vars
	newArrive		: TimeStamp;
	
begin
	if _arriveDT.isValid() then
		newArrive := _arriveDT;
	else
		newArrive := null;
	endif;
	
	if self.arrivedDT = newArrive then
		return;		// Do nothing	
	elseif not self.isTransient and (self.status = Voyage_Status_VoyageArrived or self.status = Voyage_Status_EUP_Arrived or self.status = Voyage_Status_Arrived) then
		app.raiseCMWarning(Vesse_arriv_still_wish_conti, null, null, null);
		if not app.myPassport.warningsAcknowledged then
			//we've just raised a warning that has not yet been seen don't bother with the updating yet.
			return;
		endif;
	endif;	
	
	// The voyages are now keyed by code and arrival date in the external dictionary
	// on terminal. If we change the arrival date we must remove it from the4 dict and re-add it
	if not self.isTransient then
		if self.myTerminal &lt;&gt; null then
			self.myTerminal.removeVoyageFromDict(self, false);
		endif;
	endif;
	
	self.removeFromGlobalAllVoyages();			// PAR #16378
	
	self.arrivedDT := newArrive;				// PAR #29274
	
	self.addToGlobalAllVoyages();				// PAR #16378
	
	if not self.isTransient then
		if self.myTerminal &lt;&gt; null then
			self.myTerminal.addVoyageToDict(self.code, self.inwardCode, self);
		endif;
	endif;
	
end;</source>
        <Parameter name="_arriveDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setArrivalDepartureDT" id="52aae349-cd6d-4691-915b-d8322a92a907">
        <updating/>
        <source>setArrivalDepartureDT(_arriveDT, _departDT : TimeStamp; _validateTimes : Boolean ) updating;
//--------------------------------------------------------------
//Created: 30 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if _arriveDT.isValid and
	   _departDT.isValid then
		if _arriveDT &gt; _departDT then
			//Arrives after departure, swap them around
			self.setArrivalDT(_departDT);
			self.setDepartureDT(_arriveDT);
		else
			self.setArrivalDT(_arriveDT);
			self.setDepartureDT(_departDT);
		endif;		
	else
		self.setArrivalDT(_arriveDT);
		self.setDepartureDT(_departDT);
	endif;

	// do test here and raise ex if wrong
	if _validateTimes then
		self.validateArrivalDepartedDates();
	endif;
	
end;</source>
        <Parameter name="_arriveDT" type="TimeStamp"/>
        <Parameter name="_departDT" type="TimeStamp"/>
        <Parameter name="_validateTimes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setArriveDepartOnVoyApproval" id="cbd334db-61c8-4b34-9453-7deb7b1dc0b1">
        <updating/>
        <source>setArriveDepartOnVoyApproval() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/06/2018	jlgndl1	Initial creation	TFS 39248
26/07/2018	jlgdap1	TFS 39741 PEL1 Marine Service Timings Changes
*/

vars

	wodMarineServicesInitial : CM_WodMarineServicesInitial;
	arrivalMovement : HMS_Movement;
	departMovement : HMS_Movement;
	wodVoyageCargoRequest : CM_WodVoyageCargoRequest;
	newArriveTime : TimeStamp;
	newDepartTime : TimeStamp;
	newBerth : HMS_Berth;
	lengthOfTime : Decimal[12,2];
	wodVoyage : CM_WorkOrderVoyageDtl;
	workOrder : CM_WorkOrderVoyage;
	voyage : CM_Voyage;
	berth : HMS_Berth;
	useLengthOfTIme : Boolean;
begin
	

	
	// TFS 39932 refactored - The berth, occurs on and ETMAL are either on the cargo request 
	//										or if there is not a cargo request on the IMSR (Initial Marine Serves Request)
	//										Also added validation of the ETMAL (lengthOfTime) as this was resulting in an arrival and departure DT that were the same.
	arrivalMovement := self.getMovementArrival();
	departMovement := self.getMovementDeparture();
	wodVoyageCargoRequest := self.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL).CM_WodVoyageCargoRequest;
	if wodVoyageCargoRequest &lt;&gt; null then
		wodVoyage := wodVoyageCargoRequest;
		workOrder := wodVoyageCargoRequest.getMyParent.CM_WorkOrderVoyage;
		 
	else
		wodMarineServicesInitial := self.allWorkOrders.getWorkOrderDetailOfType( WO_TASK_MARINEINITIAL ).CM_WodMarineServicesInitial;
		if wodMarineServicesInitial &lt;&gt; null then
			wodVoyage := wodMarineServicesInitial;
			workOrder := wodMarineServicesInitial.getMyParent.CM_WorkOrderVoyage;
		endif;
	endif;
	
	if workOrder = null then
		return;
	endif;
	if arrivalMovement = null then
		return;
	endif;
	if departMovement = null then
		return;
	endif;
	// raise an exception if necessary
	if not wodVoyage.validateRequiresLengthOfTime() then
		return;
	endif;
	
	if not workOrder.hasBeenApproved4VoyageApproval() then
		app.raiseCMException2( Work_order_NotApproved, workOrder.getFullDescription,self.code, null, null );
		return;
	endif;
	
	if self.myHMSVoyageData &lt;&gt; null then
		berth := self.myHMSVoyageData.getBerthForDateTime( workOrder.requiredByDT );
		if berth &lt;&gt; null then
			// If the berth does not require an ETMAL then do not adjust the timestamp for departure.
			useLengthOfTIme := berth.requiresLengthOfTime;
		
		endif;
	endif;
	
	
	newArriveTime := workOrder.requiredByDT;
	if useLengthOfTIme then
		newDepartTime := workOrder.addLengthOfTimeToDT( newArriveTime );
	else
		newDepartTime:= self.departedDT; // leave as is
	endif;
	newBerth := wodVoyage.getMyBerth();
	lengthOfTime := workOrder.lengthOfTime;

	
	arrivalMovement.setMyBerth(newBerth );
	if newArriveTime.isValid() then
		arrivalMovement.setOccursOnDT(newArriveTime );
	endif;
	if newDepartTime.isValid() then
		departMovement.setOccursOnDT( newDepartTime );
	endif;
	
	/* TFS 39932 WAS the following which is wrong
	wodMarineServicesInitial := self.allWorkOrders.getWorkOrderDetailOfType( WS_TASK_VOY_MARINEINITIAL ).CM_WodMarineServicesInitial;
	if wodMarineServicesInitial &lt;&gt; null then
		if arrivalMovement &lt;&gt; null then
			arrivalMovement.setMyBerth( wodMarineServicesInitial.myBerth );
			if wodMarineServicesInitial.requiredByDT.isValid then			// TFS 39741
				arrivalMovement.setOccursOnDT( wodMarineServicesInitial.requiredByDT );
				newArriveTime := wodMarineServicesInitial.getMyParent.CM_WorkOrderVoyage.addLengthOfTimeToDT( wodMarineServicesInitial.requiredByDT );
				self.setArrivalDT( newArriveTime );
			endif;															// TFS 39741
		endif;
		if departMovement &lt;&gt; null then
			wodVoyageCargoRequest := self.allWorkOrders.getWorkOrderDetailOfType(WS_TASK_VOY_VOYCARGOREQUESTS).CM_WodVoyageCargoRequest;
			if wodVoyageCargoRequest &lt;&gt; null then
				newDepartTime := wodVoyageCargoRequest.getMyParent.CM_WorkOrderVoyage.addLengthOfTimeToDT( self.arrivedDT );
				departMovement.setOccursOnDT( newDepartTime );
				self.setDepartureDT( newDepartTime );
			endif;
		endif;
	endif;
	*/
epilog

end;</source>
    </JadeMethod>
