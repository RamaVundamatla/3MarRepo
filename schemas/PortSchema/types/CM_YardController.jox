    <JadeMethod name="getNestedLocationsYA" id="79cb7767-2b7a-4a45-b7ad-23de64948414">
        <source>getNestedLocationsYA(_yaAgent : CM_YAAutoplanAgent input) : Integer;
// -------------------------------------------
// Created 30 March 2005 by cnwdvb1
// -------------------------------------------
vars

	allocation,
	currentAllocation		: CM_YardAllocation;
	rtnValue,
	keepValue				: Integer;

begin
	
	keepValue := 0;
	
	currentAllocation := _yaAgent.myCurrentAllocation;
	
	// CCMS 1013
	//foreach allocation in self.allYardAllocations discreteLock where allocation &lt;&gt; currentAllocation do
	foreach allocation in self.allYardAllocations discreteLock where (allocation &lt;&gt; currentAllocation and allocation.includeInYardDisplays()) do
		rtnValue := _yaAgent.checkForNestedAllocations(self, allocation);
		// Never means never.
		if rtnValue = YAOverlap_Never then
			keepValue := rtnValue;
			return keepValue;
		endif;
		
		// We want to return last resort if it comes up.
		// YAOverlap_Always		= 1
		// YAOverlap_Sometimes  = 2
		// YAOverlap_LastResort = 3
		// YAOverlap_Never		= 4
		keepValue := rtnValue.max(keepValue);
	endforeach;
	
	// May  return 0 which means carry on please.
	
epilog	

	return keepValue;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
