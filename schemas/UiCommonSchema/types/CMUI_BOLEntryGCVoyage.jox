    <JadeMethod name="translateForm" id="5f7885be-258c-404a-a10c-cd9005b84fd1">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007282, locale);
	btnAddCargo.translateCaption(Xlat_0000096, locale);
	btnCancel.translateCaption(Xlat_0000111, locale);
	btnCollapseAll.translateCaption(Xlat_0000083, locale);
	btnCopyCurrent.translateCaption(Xlat_0000084, locale);
	btnDelete.translateCaption(Xlat_0000112, locale);
	btnExpandAll.translateCaption(Xlat_0000089, locale);
	btnNext.translateCaption(Xlat_0000113, locale);
	btnSave.translateCaption(Xlat_0000114, locale);
	frmRowScroll.translateCaption(Xlat_0000090, locale);
	frmScrolling.translateCaption(Xlat_0000091, locale);
	lbNoOfEntries.translateCaption(Xlat_0000088, locale);
	lblBOL.translateCaption(Xlat_0000115, locale);
	lblCargoType.translateCaption(Xlat_0000092, locale);
	lblConsignee.translateCaption(Xlat_0000095, locale);
	lblDescription.translateCaption(Xlat_0000086, locale);
	lblHatch.translateCaption(Xlat_0000116, locale);
	lblId.translateCaption(Xlat_0000117, locale);
	lblLoadPort.translateCaption(Xlat_0000098, locale);
	lblMarks.translateCaption(Xlat_0000118, locale);
	lblMarksNo.translateCaption(Xlat_0000101, locale);
	lblNotifyParty.translateCaption(Xlat_0000087, locale);
	lblNumeredEntry.translateCaption(Xlat_0000124, locale);
	lblProduct.translateCaption(Xlat_0000103, locale);
	lblPurchaseOrder.translateCaption(Xlat_0000127, locale);
	lblQuantity.translateCaption(Xlat_0000100, locale);
	lblRemarks.translateCaption(Xlat_0000104, locale);
	lblShipper.translateCaption(Xlat_0000106, locale);
	lblVolume.translateCaption(Xlat_0000120, locale);
	lblWeight.translateCaption(Xlat_0000122, locale);
end;</source>
    </JadeMethod>
