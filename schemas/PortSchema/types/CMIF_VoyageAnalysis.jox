    <JadeMethod name="addVoyageAnalysis" id="882df6a5-b74e-4f83-8939-d28947b83e2b">
        <updating/>
        <source>addVoyageAnalysis(_voyageAnaly : CMIF_VoyageAnalysis) updating;
//--------------------------------------------------
// Created:	30 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if _voyageAnaly = null then
		return;
	endif;
	
	self.allVoyageAnalysis.add(_voyageAnaly);
	
	self.value := self.value + _voyageAnaly.value;

	self.currentMthLastCYTD := self.currentMthLastCYTD + _voyageAnaly.changeThisLastCYTD;	
	self.currentMthLastFYTD := self.currentMthLastFYTD + _voyageAnaly.currentMthLastFYTD;	
	self.currentMthLastYear := self.currentMthLastYear + _voyageAnaly.currentMthLastYear;	
	self.currentMthThisCYTD := self.currentMthThisCYTD + _voyageAnaly.currentMthThisCYTD;	
	self.currentMthThisFYTD := self.currentMthThisFYTD + _voyageAnaly.currentMthThisFYTD;	
	self.currentMthThisYear := self.currentMthThisYear + _voyageAnaly.currentMthThisYear;

	self.changeThisLastCYTD := self.changeThisLastCYTD + _voyageAnaly.changeThisLastCYTD;
	self.changeThisLastFYTD := self.changeThisLastFYTD + _voyageAnaly.changeThisLastFYTD;
		
end;</source>
        <Parameter name="_voyageAnaly" type="CMIF_VoyageAnalysis"/>
    </JadeMethod>
    <JadeMethod name="generateFigures" id="f422f02b-93a9-45b1-bdef-7afaad65eba7">
        <updating/>
        <source>generateFigures(_voyageStat : CM_VoyageStatistic) updating, protected;
//--------------------------------------------------
// Created:	30 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	mth,
	lastYear,
	thisYear,
	thisMth : Integer;
	tmpDate : Date;
	tmpVoyageStat : CM_VoyageStatistic;
begin
	self.currentMthThisYear := self.value;
	
	thisMth := self.monthYear.month;
	thisYear := self.monthYear.year;
	
	// same month last year
	lastYear := monthYear.cnEcAddYears(-1).year;
	tmpDate.setDate(1, thisMth, lastYear);
	tmpVoyageStat := self.myTerminal.allVoyageStatistics[tmpDate,group,code];
	if tmpVoyageStat &lt;&gt; null then
		self.currentMthLastYear := tmpVoyageStat.value;
	endif;
	
	// from January to this month
	mth := 1;
	while mth &lt;= thisMth do
		
		// this calender year
		tmpDate.setDate(1, mth, thisYear);
		tmpVoyageStat := self.myTerminal.allVoyageStatistics[tmpDate,group,code];
		if tmpVoyageStat &lt;&gt; null then
			self.currentMthThisCYTD := self.currentMthThisCYTD + tmpVoyageStat.value;
		endif;
		
		// last calender year
		tmpDate.setDate(1, mth, lastYear);
		tmpVoyageStat := self.myTerminal.allVoyageStatistics[tmpDate,group,code];
		if tmpVoyageStat &lt;&gt; null then
			self.currentMthLastCYTD := self.currentMthLastCYTD + tmpVoyageStat.value;
		endif;
	
		mth := mth + 1;				
				
	endwhile;

	mth := 1;
	while mth &lt;= 13 do
		
		if mth &lt; 4 then
			// FYTD January to March
			if thisMth &lt; 4 then
				tmpDate.setDate(1, mth, thisYear);
				lastYear := thisYear-1;
			else
				mth := mth + 1;							
				continue;
			endif;
		else
			// FYTD April to December
			if thisMth &gt; 3 then
				tmpDate.setDate(1, mth, thisYear);
				lastYear := thisYear-1;
			else
				tmpDate.setDate(1, mth, thisYear-1);
				lastYear := thisYear-2;			
			endif;		
		endif;

		// this financial year
		tmpVoyageStat := self.myTerminal.allVoyageStatistics[tmpDate,group,code];
		if tmpVoyageStat &lt;&gt; null then
			self.currentMthThisFYTD := self.currentMthThisFYTD + tmpVoyageStat.value;
		endif;
		
		// last financial year
		tmpDate.setDate(1, mth, lastYear);
		tmpVoyageStat := self.myTerminal.allVoyageStatistics[tmpDate,group,code];
		if tmpVoyageStat &lt;&gt; null then
			self.currentMthLastFYTD := self.currentMthLastFYTD + tmpVoyageStat.value;
		endif;
		
		mth := mth + 1;				
				
	endwhile;	

	if self.currentMthLastCYTD &gt; 0 then
		self.changeThisLastCYTD := ((self.currentMthThisCYTD/self.currentMthLastCYTD*100)-100).roundedTo(3);
	endif;
	
	if self.currentMthLastFYTD &gt; 0 then
		self.changeThisLastFYTD := ((self.currentMthThisFYTD/self.currentMthLastFYTD*100)-100).roundedTo(3);
	endif;


	self.currentMthLastCYTD := self.currentMthLastCYTD.roundedTo(3);
	self.currentMthLastFYTD := self.currentMthLastFYTD.roundedTo(3);
	self.currentMthLastYear := self.currentMthLastYear.roundedTo(3);
	self.currentMthThisCYTD := self.currentMthThisCYTD.roundedTo(3);
	self.currentMthThisFYTD := self.currentMthThisFYTD.roundedTo(3);
	self.currentMthThisYear := self.currentMthThisYear.roundedTo(3);
				
end;</source>
        <access>protected</access>
        <Parameter name="_voyageStat" type="CM_VoyageStatistic"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="80457eee-a9ec-45ee-a333-cdc2f544ca88">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	05 December 2005 By: cnwgd1
//--------------------------------------------------
vars

begin

	if _attrName = ETRow_CurrentMthLastCYTD then
		return self.currentMthLastCYTD.numberFormat;
	
	elseif _attrName = ETRow_CurrentMthLastYear then
		return self.currentMthLastYear.numberFormat;		
	
	elseif _attrName = ETRow_CurrentMthLastFYTD then
		return self.currentMthLastFYTD.numberFormat;		
	
	elseif _attrName = ETRow_CurrentMthThisCYTD then
		return self.currentMthThisCYTD.numberFormat;		
	
	elseif _attrName = ETRow_CurrentMthThisFYTD then
		return self.currentMthThisFYTD.numberFormat;		
	
	elseif _attrName = ETRow_CurrentMthThisYear then
		return self.currentMthThisYear.numberFormat;		
	
	elseif _attrName = ETRow_Value then
		return self.value.numberFormat;												
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="groupDescription" id="94b049c1-8345-477d-b35a-a6e2cc490619">
        <methodInvocation>mapping</methodInvocation>
        <source>groupDescription(set: Boolean; _value: String io) mapping;
//--------------------------------------------------
// Created:	30 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if set then
		// set code here
		return;
	else
		// get code here
		_value := app.voyageStatGroupENumToString(self.group);
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isGroupTotal" id="180f6fb9-3264-48be-92f1-087f2a0a94de">
        <source>isGroupTotal() : Boolean;
//--------------------------------------------------
// Created:	30 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpGroup : Integer;
begin
	
	if self.isTotalForGroup then
		return true;
	endif;
	
	if self.myVoyageStat &lt;&gt; null then
		return self.myVoyageStat.isGroupTotal();
	endif;
		
	tmpGroup := self.group;
	
	if tmpGroup = VoyageStat_CargoUnits
	or tmpGroup = VoyageStat_CargoTons
	or tmpGroup = VoyageStat_ChargesTotal		
	or tmpGroup = VoyageStat_ResourcesTotal	
	or tmpGroup = VoyageStat_PassengersTotal
	or tmpGroup = VoyageStat_PassVesselCallTot
	or tmpGroup = VoyageStat_CargoVesCallTot
	or tmpGroup = VoyageStat_VesselCallTotal then
		return true;
	endif;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFormVoyageStatistic" id="4ffe8fc1-5cd9-421f-bbe0-ed3d5e4e71d7">
        <updating/>
        <source>setFormVoyageStatistic(_voyageStat : CM_VoyageStatistic) updating;
//--------------------------------------------------
// Created:	30 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	
	if _voyageStat = null then
		return;
	endif;
	
	self.myVoyageStat := _voyageStat;
	
	self.code := _voyageStat.code;
	self.group := _voyageStat.group;
	self.monthYear := _voyageStat.monthYear;
	self.unitsOfMeasure := _voyageStat.unitsOfMeasure;
	self.value := _voyageStat.value;
	self.myTerminal := _voyageStat.myTerminal;

	self.generateFigures(_voyageStat);
	
end;</source>
        <Parameter name="_voyageStat" type="CM_VoyageStatistic"/>
    </JadeMethod>
    <JadeMethod name="setGroupCodeForTotal" id="10531406-2e28-405c-8dbd-b8a201e72c02">
        <updating/>
        <source>setGroupCodeForTotal(_group : Integer; _uom : String) updating;
//--------------------------------------------------
// Created:	01 December 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.isTotalForGroup := true;

	if _group = VoyageStat_CargoLoaded
	or _group = VoyageStat_CargoOffloaded then
		if _uom = BOL_UOM_UNITS then
			self.group := VoyageStat_CargoUnits;
			self.code := VoyageStat_CargoUnits_Str;
		else
			self.group := VoyageStat_CargoTons;
			self.code := VoyageStat_CargoTons_Str;		
		endif;

	elseif _group = VoyageStat_Charges then
		self.group := VoyageStat_ChargesTotal;
		self.code := VoyageStat_ChargesTotal_Str;

	elseif _group = VoyageStat_Resources then
		self.group := VoyageStat_ResourcesTotal;
		self.code := VoyageStat_ResourcesTotal_Str;				

	elseif _group = VoyageStat_PassengerVesselCall then
		self.group := VoyageStat_PassVesselCallTot;
		self.code := VoyageStat_PassVesCallTot_Str;	
		self.isVesselCall := true;					

	elseif _group = VoyageStat_CargoVesselCall then
		self.group := VoyageStat_CargoVesCallTot;
		self.code := VoyageStat_CargoVesCallTot_Str;
		self.isVesselCall := true;							

	elseif _group = VoyageStat_PassVesselCallTot
	or _group = VoyageStat_CargoVesCallTot then
		self.group := VoyageStat_VesselCallTotal;
		self.code := VoyageStat_VesselCallTotal_Str;

	endif;

	self.unitsOfMeasure := _uom;		
end;</source>
        <Parameter name="_group" type="Integer"/>
        <Parameter name="_uom" type="String"/>
    </JadeMethod>
</Class>
