    <JadeMethod name="getExtraInfo" id="fe071590-b07d-426f-b396-3bd377f33594">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	block : CM_DataContainerBlock;

begin
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Crane_Queue), DC_Label, 1, self);
	block.addNewItem(self.queueId, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(UseRTforPickup), DC_Label, 1, self);
	block.addNewItem(app.getYesNo(self.useRTForPickup), DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(UseRTforSetdown), DC_Label, 1, self);
	block.addNewItem(app.getYesNo(self.useRTForSetDown), DC_Data, 1, self);

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
