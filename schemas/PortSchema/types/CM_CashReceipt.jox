    <JadeMethod name="getStoragePaidTS" id="149fc579-dc77-4b55-858b-d843e1e1a6ef">
        <source>getStoragePaidTS(_ti : CM_TrackedItem) : TimeStamp ;
/*
Purpose:			
Date		Who		Reason
14 May 2015	cnwab1	Initial creation
14 May 2018 jlger1	tfs 38530 removed the updating
*/

vars
	ti : CM_TrackedItem;
	invoiceLine		: CM_InvoiceLine;
	proDetail : CM_ProformaDetails;
	storageTS : TimeStamp;
	time : Time;

begin
	ti := _ti; 
	
	foreach invoiceLine in self.allInvoiceLines do
	
		if invoiceLine.remarks = "Storage" then
			return invoiceLine.chargeTime;
		endif;
	endforeach;
	
	foreach proDetail in self.allProformaDetails do
		if proDetail.remarks = "Storage" then
			return proDetail.chargeTime;
		endif;
	endforeach;
	
	if ti &lt;&gt; null then
		time.setTime(0,0,0,0);
		storageTS.setDate(ti.getFreeStorageExpiryDate());
		storageTS.setTime(time);
		return storageTS;
	endif;
	
	return null;	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
