    <JadeMethod name="setComboValues" id="f7fefc92-9d4c-42f6-817e-49c1e500a248">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries
// Note: transaction types were originally filtered to match the types used in the transaction map, but from Mar 2012
//  	all appropriate types are shown to generalise the possible queries

vars
	qrl				: CM_QReferenceLookup;
	eventType		: CM_EventType;
	eventTypeDict	: CM_EventTypeByTypeDict;
	obj				: Object;
	nameDict		: CM_ObjectByStringDict;
begin
	_combo.clear();
	eventTypeDict := app.myRoot.allEventTypesByType;	
	create nameDict transient;

	foreach eventType in eventTypeDict where not eventType.isLocationActivity do	//12 May 2021	NDL	TFS 50906
		nameDict.putAtKey(eventType.name, eventType);
	endforeach;
	foreach obj in nameDict do
		eventType := obj.CM_EventType;
		_combo.itemObject[_combo.addItem(eventType.name)] := eventType;
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;
epilog
	delete nameDict;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="727b9a70-095b-483c-adf4-12a66fc2c0a8">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QReferenceIsOneOf; _passport : CM_Passport);
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries, for isOneOf
vars
	selectionValue, idx		: Integer;
	eventType		: CM_EventType;
	eventTypeDict	: CM_EventTypeByTypeDict;
	obj				: Object;
	nameDict		: CM_ObjectByStringDict;
begin
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	_tbl.sortColumn[1] := 2; // TFS 7821

	eventTypeDict := app.myRoot.allEventTypesByType;
	create nameDict transient;

	foreach eventType in eventTypeDict where not eventType.isLocationActivity do	//12 May 2021	NDL	TFS 50906
		nameDict.putAtKey(eventType.name, eventType);
	endforeach;
	foreach obj in nameDict do
		eventType := obj.CM_EventType;
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(eventType) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; eventType.name);
		_tbl.accessRow(idx).itemObject := eventType;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;
	
epilog
	delete nameDict;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="36287eab-cb84-4636-a736-2b611376a424">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries, for isOneOf
vars
	str				: String;
	numRows,
	idx				: Integer;
	obj				: Object;
	oa				: ObjectSet;
	op				: Object;
begin

	create oa transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			obj := _tbl.accessRow(idx).itemObject;
			oa.add(obj);
		endif;
	endforeach;
	
	_op.setSearchValue(oa);

epilog
	delete oa;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="1912e9a4-7f45-4dc6-b34f-e1a46ceab198">
        <source>translateToDisplayValue(_value: Any): String;
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries
vars

begin
	if _value &lt;&gt; null then
		return _value.CM_EventType.name;
	endif;
	
	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="387e24a4-cc98-4bdb-8fd0-9cb565b4d65f">
        <source>translateToSearchValue(_value: Any): Any;
//  CCMS 1262 Feb 2012 transaction enquiry and selector queries
vars
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;

		if _value.isKindOf(CM_EventType) then
			return _value.CM_EventType;
		endif;
	endif;
	
	return null;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="93243a64-883c-4dae-b635-2b3bee87d385">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	if _value.isKindOf(Integer) then
		return app.myRoot.allEventTypesByType[_value.Integer];
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
