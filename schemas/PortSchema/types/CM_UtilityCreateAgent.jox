    <JadeMethod name="utlCreateDebtorNode" id="ad91c9f8-2ef6-4901-9349-20dcbf72df54">
        <source>utlCreateDebtorNode(_debtorNodeController: CMIF_DebtorNode; _newDebtorNode:CM_DebtorNode output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 26 July 2018	jlgrh7 TFS #39308 LNX - Include Debtor Maintenance in Audit Enquiry
// ---------------------------------------------------------------------------
vars
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valDebtorNode(_debtorNodeController);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	create _newDebtorNode as _debtorNodeController.myPxyDebtorNode.class persistent;
	_newDebtorNode.setForCreate(_debtorNodeController);
	
	if _passport.noErrors then
		//self.myCreateAuditAgent.audCreateGeneric(_debtorNodeController.myPxyDebtorNode);			//-TFS39308
		self.myCreateAuditAgent.audCreateGeneric(_newDebtorNode);																	//+TFS39308
	endif;
	if _passport.noErrors then
//		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_DEBTORNODE_CREATE),false,_newDebtorNode);
		app.myRoot.causeEvent(EVENT_DEBTORNODE_CREATE,false,_newDebtorNode);
	endif;
end;</source>
