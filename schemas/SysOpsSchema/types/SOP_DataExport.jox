    <JadeMethod name="comboTerminalBuild" id="5d65d87f-eedc-451e-8092-2aa09b008c08">
        <source>comboTerminalBuild() protected;
// ---------------------------------------------------------------------------
// Created:		05 August 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	terminal : CM_Terminal;
	idx : Integer;

begin
	self.cmbTerminal.clear;

	foreach terminal in app.myRoot.allTerminals do
		idx := self.cmbTerminal.addItem(terminal.name);
		self.cmbTerminal.itemObject[idx] := terminal;
	endforeach;

	self.cmbTerminal.listIndex := -1;
end;</source>
        <access>protected</access>
    </JadeMethod>
