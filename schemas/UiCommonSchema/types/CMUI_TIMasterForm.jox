    <JadeMethod name="isMyTypeItem" id="fc86b9b4-5692-47ba-a6d9-b7467dcc2257">
        <updating/>
        <source>isMyTypeItem( _masterItem : CM_TIMaster ) : Boolean protected, updating;
/* ---------------------------------------------------------------------------
Created:	18 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
16 May 2025		navcs2	MTN-34843 Development - Fleet file Form implementation
------------------------------------------------------------------------------*/
vars

begin

	if self.getCargoType() = CargoType_Trailer or self.getCargoType() = CargoType_Mafi then
		if self.isMAFI then															// 16 May 2025		navcs2	MTN-34843
			return _masterItem.isMAFI();											// 16 May 2025		navcs2	MTN-34843
		else																		// 16 May 2025		navcs2	MTN-34843
			return _masterItem.isTILC();											// 16 May 2025		navcs2	MTN-34843
		endif;																		// 16 May 2025		navcs2	MTN-34843
	elseif self.getCargoType() = CargoType_Generator then
		return _masterItem.isGenerator;
	elseif self.getCargoType() = CargoType_Generator then
		return _masterItem.isGenerator;
	else //self.getCargoType() = CargoType_Container then
		return _masterItem.isContainer;
	endif;


end;</source>
