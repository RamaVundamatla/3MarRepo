    <JadeMethod name="create" id="109dc36a-2223-4d50-ba6b-bf7001ecdabe">
        <updating/>
        <source>create() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	create self.myNotesObj transient;
	create self.myVehicleMountedIMVAgent transient;
	self.beginNotification(self.myVehicleMountedIMVAgent, MobileHandHeldThin::VehicleMountedAgent.Event_Server_Note, Response_Continuous , null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="1f6dcdda-f218-4ee4-9f18-d199ee7dda3f">
