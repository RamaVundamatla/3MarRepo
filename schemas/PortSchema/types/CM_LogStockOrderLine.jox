    <JadeMethod name="getMyVoyageOperator" id="300bb9cd-6ee8-4769-af53-f5bcede56617">
        <source>getMyVoyageOperator() : CM_VoyageOperator;
//--------------------------------------------------------------
//Created: 24 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	operator		: CM_Operator;
	voyageOperator 	: CM_VoyageOperator;
	voyage			: CM_Voyage;
begin

	operator := self.myStockOrderHeader.myOperator;
	voyage := self.myStockOrderHeader.myVoyage;
	
	foreach voyageOperator in voyage.allVoyageIOperators do
		if voyageOperator.myOperator = operator then
			break;
		endif;
	endforeach;
	
	return voyageOperator;
end;</source>
        <ReturnType type="CM_VoyageOperator"/>
    </JadeMethod>
    <JadeMethod name="getNumberUnfulfilled" id="455d5044-a2a2-42aa-80d3-99f41e3f7f7e">
        <source>getNumberUnfulfilled(): Decimal;
//--------------------------------------------------------------
//Created: 08 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	allocation		: CM_StockOrderAllocation;
	numAllocated	: Decimal[16,4];
	
begin
	foreach allocation in self.allStockAllocations do
		numAllocated := numAllocated + allocation.allocQuantity;
	endforeach;

	if self.reqdQuantity &gt; numAllocated then
		return (self.reqdQuantity - numAllocated);
	endif;
	return 0;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getNumerStillToAllocate" id="eba91b31-95c5-4d00-8886-5ab32bdfbd9b">
        <source>getNumerStillToAllocate(): String;
//--------------------------------------------------------------
//Created: 17 June 2005 By: cnwgd1
//--------------------------------------------------------------
vars
	allocation		: CM_StockOrderAllocation;
	numAllocated	: Decimal[16,4];
	
begin
	foreach allocation in self.allStockAllocations do
		numAllocated := numAllocated + allocation.allocQuantity;
	endforeach;
	
	// PAR 10314 this may return a negative value for the display
	// and should not be used for allocation calculations
	return (self.reqdQuantity - numAllocated).Integer.String;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
