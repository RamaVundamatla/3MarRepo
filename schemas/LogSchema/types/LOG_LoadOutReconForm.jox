    <JadeMethod name="cmbVoyage_displayEntry" id="775fd242-386e-48f4-b786-808251b5be9c">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	if obj.CM_Voyage.isClosedStatus() then
		return null;
	else
		return obj.CM_Voyage.code &amp; '  ' &amp; obj.CM_Voyage.description;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="ebd78f07-f78c-4910-84e9-7d287dc10758">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.permissionMaint := PmLogLoadOutReconView; // TFS 2198
	self.permissionView  := PmLogLoadOutReconMaint;
	
	self.helpFileName := HelpFile_Logs;

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteDocket" id="8e50b4b7-4cee-4245-80a3-90b4cccaf616">
        <updating/>
        <source>deleteDocket()updating;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	docket	: CM_BOL;
	ext		: CM_BOLExtLogOut;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	// Sep 2011 28082 don't allow save for closed etc voyages
	if self.myCurrentLogVoyage &lt;&gt; null and
	   self.myCurrentLogVoyage.isClosedStatus() then
		app.msgBox("This voyage status is " &amp; self.myCurrentLogVoyage.statusDescription &amp; "," &amp; CrLf &amp; "no updates are allowed.", "Error", 0);
		return;
	endif;

	ext := self.myCurrentBOLExt;
	if ext &lt;&gt; null then
		docket := self.myCurrentBOLExt.myBOL.CM_BOLOut;
	else
		app.raiseCMException2(PleaseSelectAnObject, 'Docket', 'delete', null, null);
		return;
	endif;

	if ext.isPartiallyLoaded then
		app.msgBox('This docket has already been partially loaded','Cannot delete docket...', 0);
		return;
	endif;	
	
	if app.msgBox('Are you sure you want to delete this Log Docket?','Are you sure?', MsgBox_OK_Cancel) = MB_OK then
	
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteBOL(docket.CM_BOL, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				self.loadBOLExtensions();
				break;
			else
				theResult := app.showErrorWarningDialog('Loadout Reconciliation', app.myPassport, ErrWarnMode_Delete);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
	endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadDocket" id="b0ba27f9-b226-48e6-bca5-0c35dd3f99d7">
        <updating/>
        <source>doLoadDocket() updating;
// ---------------------------------------------------------------------------
// Created:     20 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	docket	: CM_BOL;
	ext		: CM_BOLExtLogOut;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	// Sep 2011 28082 don't allow save for closed etc voyages
	if self.myCurrentLogVoyage &lt;&gt; null and
	   self.myCurrentLogVoyage.isClosedStatus() then
		app.msgBox("This voyage status is " &amp; self.myCurrentLogVoyage.statusDescription &amp; "," &amp; CrLf &amp; "no updates are allowed.", "Error", 0);
		return;
	endif;

	ext := self.myCurrentBOLExt;
	if ext &lt;&gt; null then
		docket := self.myCurrentBOLExt.myBOL.CM_BOLOut;
	else
		app.raiseCMException2(PleaseSelectAnObject, 'Docket', 'load', null, null);
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxMoveBOLOutLogWithSplit(docket.CM_BOLOut, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Loadout', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

	self.clearErrorWarnings();
	self.loadBOLExtensions();

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="ecb64d27-4f43-4ed1-aa5a-a5e1790a2f27">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	inheritMethod();
	
	self.grpUpdate.move(splMain.left, self.height - staMain.height - grpUpdate.height - WinBottomMargin, grpUpdate.width, grpUpdate.height);

//	self.btnClose.move(self.width - WinRightMargin - btnClose.width, self.height - staMain.height - WinBottomMargin - btnClose.height, btnClose.width, btnClose.height);
//	self.btnDeleteDocket.move(btnClose.left, btnClose.top - VerticalSpacing - btnDeleteDocket.height, btnDeleteDocket.width, btnDeleteDocket.height);
//	self.btnSelectAll.move(btnClose.left, btnDeleteDocket.top - VerticalSpacing - btnSelectAll.height, btnSelectAll.width, btnSelectAll.height);	

	self.splMain.height := grpUpdate.top - WinTopMargin*2 - cmbVoyage.height;
	self.splMain.width := self.width - WinLeftMargin - WinRightMargin;
	self.splMain.cnEcResizeContents();

end;</source>
    </JadeMethod>
