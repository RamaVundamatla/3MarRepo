        <source>getTotalBOLCountForProdLoc() : Integer;
// -----------------------------------------------------------------------------
// Created:		02 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	prodLoc : CM_SOHLocation;
	cnt : Integer;
begin
	cnt := 0;
	foreach prodLoc in self.allProductLocations do
