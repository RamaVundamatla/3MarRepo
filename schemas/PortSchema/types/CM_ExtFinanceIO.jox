    <JadeMethod name="fileExceptionHandler" id="437f3d54-a804-444b-aae3-ecdf3ed2c448">
        <source>fileExceptionHandler(exObj: Exception): Integer;

vars
	errorText: String;
begin
	if not process.isInTransactionState then
		errorText := "Opening file: '" &amp; exObj.FileException.file.fileName &amp; "' caused error";
		errorText := errorText &amp; Lf &amp; exObj.text &amp; Lf &amp; "    Aborting Export Operation!";
		app.msgBox(errorText, "File Open Error",
			MsgBox_OK_Only  + MsgBox_System_Modal + MsgBox_Exclamation_Mark_Icon);
	endif;

	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;

	return Ex_Abort_Action;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fileSilentExceptionHandler" id="e0538e41-0a7e-4660-8161-41d94868691d">
        <source>fileSilentExceptionHandler(_exObj: Exception; _hadFileException : Boolean io): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2022	jlier1	Initial creation 53545

*/

vars
	returnVal		: Integer;
begin
	returnVal := Ex_Pass_Back;
	if _exObj.errorCode &gt; 5000 and _exObj.errorCode &lt;= 5099 then
		_hadFileException:=true;
		if _exObj.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

	return returnVal;
epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_hadFileException" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="firstMonthOfFinYear" id="4993ef93-facb-4fd0-8bb2-272ac5d607a1">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>firstMonthOfFinYear(set: Boolean; value: Integer io) mapping, updating;

begin
	if set then
		if value &gt;= 1 and value &lt;= 12 then
			firstMonthOfFinYear := value;
		else
			app.setContinueCMExceptions(false);
			app.raiseCMException(ERR_FINMONTH_OUTOFRANGE, null, null);
			return;
		endif;
	else
		value := firstMonthOfFinYear;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="formatAsXML" id="97dee5dc-5bb3-443e-b5fc-664ed2015ab0">
        <source>formatAsXML(pTag: String; pValue: String): String;
// 25113 with XML entity replacement
vars
	work,
	result	: String;
begin
	work := pValue.xmlReplaceReservedChars(true);
	result := '&lt;' &amp; pTag &amp; '&gt;' &amp; work &amp; '&lt;/' &amp; pTag &amp; '&gt;';
	return result;
end;
</source>
        <Parameter name="pTag" type="String"/>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExportFileName" id="464593e1-5a45-4937-b190-bfef2ccbd2d2">
        <source>getExportFileName(_invoice : CM_Invoice; _startDT :TimeStamp) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2022	jlier1	Initial creation 53286

*/

vars
	
begin
	return "InvHead" &amp; _startDT.date.userFormat($CM_YearFormat) &amp; "_";
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_startDT" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExportFileNameBase" id="997d8e14-30e9-49de-bd3e-7d19c1eba755">
        <source>getExportFileNameBase(_usePresentationFileSystem : Boolean): String;
//24 Jun 2019	jlgsl4	TFS 44265 - JMT - Cash Export JMT Default - moved from CM_DefaultFinanceIO

vars
	fdir:         FileFolder;
	target:       String;
	pos:          Integer;
	hadFileException : Boolean;
begin
	if self.exportPath = null then
		target := app.getJadeInstallDir;
		pos := target.reversePos("\");
		if pos &gt; 0 then
			target := target[1:pos - 1];
		endif;
		target := target &amp; "\invoice export\";
	else
		target := self.exportPath.normaliseDirectory().substituteDirectory();
	endif;
		
	create fdir transient;
	fdir.fileName := target;
	fdir.usePresentationFileSystem:=_usePresentationFileSystem; //jlier1 TFS  53286 13/4/22
	
	on FileException do self.fileSilentExceptionHandler(exception,hadFileException);
	
	if not fdir.isAvailable then
		fdir.make;
	endif;
	
	//jlier1 TFS 53545 2/5/22
	if hadFileException then
		target := app.getJadeInstallDir;
		pos := target.reversePos("\");
		if pos &gt; 0 then
			target := target[1:pos - 1];
		endif;
		target := target &amp; "\invoice export\";
		fdir.fileName := target;
		if not fdir.isAvailable then
			fdir.make;
		endif;
	endif;
	

	return target;
epilog
	delete fdir;
end;</source>
        <Parameter name="_usePresentationFileSystem" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExternalCreditNumber" id="61c60878-0932-423a-a4c1-2e8384c31363">
        <source>getExternalCreditNumber(_cashCredit : CM_CashCredit) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2018	jlgrh7	Initial creation
03 Sep 2019	jlgsl4	TFS 45872 - JMT - Cash Credit UI changes
*/

vars
	sequenceKey : String; // --&gt; TFS 45872
	externalNumber : String;
	//cashCredit : CM_CashCredit;
	//idx : Integer; // &lt;-- TFS 45872
begin
	sequenceKey := SN_CashCredit; // --&gt; TFS 45872 - generate externalId using bank's cash credit sequence no.
	externalNumber := _cashCredit.myBank.getSeqNum(sequenceKey).String;
	return externalNumber;
	//cashCredit := _cashCredit.myBank.allCashCreditsById/*allCashCredits*/.last.CM_CashCredit;
	//return (cashCredit.sequenceNum + 1).String;
	
	//return _cashCredit.sequenceNum.String; // &lt;-- TFS 45872
epilog

end;
</source>
        <Parameter name="_cashCredit" type="CM_CashCredit"/>
        <ReturnType type="String"/>
    </JadeMethod>
