    <JadeMethod name="myGrade" id="46d26866-0d1f-4426-9360-dc503338df20">
        <methodInvocation>mapping</methodInvocation>
        <source>myGrade(set: Boolean; _value: CM_LogGrade io) mapping;
// ---------------------------------------------------------------------------
// Created:     08 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		self.allGrades.clear();
		if _value &lt;&gt; null then
			self.allGrades.add(_value.CM_LogGrade);
		endif;
	else
		_value := self.allGrades.first.CM_LogGrade;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_LogGrade" usage="io"/>
    </JadeMethod>
