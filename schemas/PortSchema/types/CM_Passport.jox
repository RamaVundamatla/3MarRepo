    <JadeMethod name="setDataAccessControllers" id="eb7f9066-52c2-4c12-b127-49c04f0c9366">
        <source>setDataAccessControllers(user : CM_User) protected;
// ---------------------------------------------------------------------------
// Created:      05 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 05/06/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars
	dac : CM_DataAccessController;

begin
	self.allDataAccessControllers.clear;
	
	if user = null then
		return;
	endif;

	dac := user.getDataAccessController(CM_Carrier.name);
	if dac &lt;&gt; null then
		self.allDataAccessControllers.add(dac);
	endif;
	
	dac := user.getDataAccessController(CM_ConsigneeConsignor.name);
	if dac &lt;&gt; null then
		self.allDataAccessControllers.add(dac);
	endif;
	
	dac := user.getDataAccessController(CM_Operator.name);
	if dac &lt;&gt; null then
		self.allDataAccessControllers.add(dac);
	endif;

	dac := user.getDataAccessController(CM_Organisation.name);
	if dac &lt;&gt; null then
		self.allDataAccessControllers.add(dac);
	endif;
	
	//09/04/2009 cnwdz2 ccms 1735
	dac := user.getDataAccessController(CM_SubTerminal.name);
	if dac &lt;&gt; null then
		self.allDataAccessControllers.add(dac);
	endif;
	
	//01 Jun 2016	NDL	TFS 2022
	dac := user.getDataAccessController(CM_CustomsAgent.name);
	if dac &lt;&gt; null then
		self.allDataAccessControllers.add(dac);
	endif;
	
	dac := user.getDataAccessController(CM_Stevedore.name);		// TFS 44554
	if dac &lt;&gt; null then											// TFS 44554
		self.allDataAccessControllers.add(dac);					// TFS 44554
	endif;														// TFS 44554
	
end;</source>
        <access>protected</access>
        <Parameter name="user" type="CM_User"/>
    </JadeMethod>
