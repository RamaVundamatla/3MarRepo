    <JadeMethod name="setForUpdate" id="aeaf9827-eeca-4786-94be-280c06595d72">
        <updating/>
        <source>setForUpdate(_proxyTrackClearance:CM_TrackClearance) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2009	cnwndl1	Initial creation

*/

vars

begin
	self.allowHiCube := _proxyTrackClearance.allowHiCube;
	self.description := _proxyTrackClearance.description;
	self.maxHeight := _proxyTrackClearance.maxHeight;
	self.maxWeightWagon := _proxyTrackClearance.maxWeightWagon;
	self.maxWidth := _proxyTrackClearance.maxWidth;
	self.isNotAvailableForEntry := _proxyTrackClearance.isNotAvailableForEntry;
	self.maxWeight := _proxyTrackClearance.maxWeight; // PAR 23176
	self.noEmptyWagons := _proxyTrackClearance.noEmptyWagons; // PAR 23176
	
	self.code := _proxyTrackClearance.code.toUpper.trimBlanks;

epilog

end;</source>
        <Parameter name="_proxyTrackClearance" type="CM_TrackClearance"/>
    </JadeMethod>
