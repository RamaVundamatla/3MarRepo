<Class name="CM_YABlockMAFI" id="660d5f07-6b9b-4c6f-beee-43fdc3288466">
    <superclass name="CM_YABlockBlock"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="searchLCIn" id="5c4487ee-02ed-44bf-99a7-bb6b085d7304">
        <source>searchLCIn(_locationCell: CM_YALocationCell; _yaAgent: CM_YAAutoplanAgent input): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 October 2022		jlier1	Initial creation 54675
31 October 2023		jlizm1	TFS 60985 MAFI queueing behaviour configuration

*/

vars
	rtnValue 		: Boolean;
	yardController  : CM_YardController;
	ti, 
	cargo 			: CM_TrackedItem;
	notSuitMsg 		: Boolean;
	lc 				: CM_LocationsController;
	iter 			: Iterator;
	tilcControlller : CM_TILCController;
	ycFullId		: String;
	cmifAutoPlan	: CMIF_YAAutoPlan;
begin

	if not app.myPassport.myTerminal.getConfig(AutoPlanToEmptyMAFIs).Boolean then
		return inheritMethod(_locationCell, _yaAgent);
	endif;
	
	rtnValue 		:= false;
	yardController  := _locationCell.myYardController;
	ycFullId		:= yardController.getFullId();
	ti 				:= _yaAgent.myCMIFYAAutoPlan.getMyTrackedItem;
	
	
	//if we are autoplanning for a trailer then look for normal location
	
	//if this is for mafi can do normal planning
	
	//if this is for cargo then need to get all the mafi's in the area 
	//should test ya criteria then
	//check mafi is empty or partially loaded
	//voyage on mafi is same as cargo unless is null voyage
	//operator on mafi is the same as cargo operator if null operator or null then ignore
	//if discharge port is same as cargo discharge port if null then ignore
	//if container check room in teu on MAFI CM_TILC::getNextFreeLC

	if ti = null or ti.isKindOf(CM_TILC) then
		return inheritMethod(_locationCell, _yaAgent);
	else
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Testing location " &amp; ycFullId &amp; " for MAFIs", true);
		// Have we tested this one and failed it?
		if _yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.includes(yardController) then
			notSuitMsg := true;
			//29 May 2014	NDL	Par 34246
			if _yaAgent.myCurrentCMIFYAAutoPlan.allLocations &lt;&gt; null then
				foreach lc in _yaAgent.myCurrentCMIFYAAutoPlan.allLocations do
					if _yaAgent.myCurrentCMIFYAAutoPlan.allFailedLocations.includes(lc) then
						notSuitMsg := false;
						_yaAgent.addLogEntry(AP_Log_YA_Default,"Testing location " &amp; ycFullId, true);
						_yaAgent.addLogEntry(AP_Log_YA_Default,'TI already in ' &amp; self.getDisplayDetails(false), true);
						return false;
					endif;
				endforeach;
			endif;
			///////
			if notSuitMsg then
				_yaAgent.addLogEntry(AP_Log_YA_Default,"Testing location " 						&amp; ycFullId, true);	// 14/02/2013 cnwmh5 #30999
				_yaAgent.addLogEntry(AP_Log_YA_Default,"Location not suitable for TI in " 		&amp; ycFullId, true);	// 14/02/2013 cnwmh5 #30999
				return false;
			endif;
		else
			//get all the MAFIs
			iter :=	yardController.allTrackedItems.createIterator;
			while iter.next(cargo)  do
				if not cargo.isMAFI then
					continue;
				endif;
				tilcControlller:= cargo.CM_TILC.testCellSuitabilityForTI(_yaAgent);			
				if tilcControlller &lt;&gt; null then
					_yaAgent.myCMIFYAAutoPlan.allPassedLocations.add(tilcControlller);
					_yaAgent.addLocationToAgent(tilcControlller, CM_YAAutoplanAgent.Locations_Found);
					_yaAgent.numberOfLocationsFound := _yaAgent.numberOfLocationsFound + 1;
					_yaAgent.myCurrentCMIFYAAutoPlan.allUsedYACells.add(_locationCell);
					return true;
				endif;
			endwhile;
			_yaAgent.addLogEntry(AP_Log_YA_Default,"All MAFI's not sutiable in MAFI Heap " &amp; ycFullId, true);
			_yaAgent.addToFailedLocations(yardController);
			
		endif;
	endif;
	
	return false;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_locationCell" type="CM_YALocationCell"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
