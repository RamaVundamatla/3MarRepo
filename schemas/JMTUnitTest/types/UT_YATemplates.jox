    <JadeMethod name="tAddYATmpltWildcardPattern" id="0e92fdee-3813-4746-88b8-e218ab704c5e">
        <source>tAddYATmpltWildcardPattern();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	yATemplate: CM_YATemplate;
	patterns: StringArray;
	pattern: String;
begin
	create patterns transient;
	patterns.add("DOUG*");
	patterns.add("!DOUG");
	patterns.add("DOUG*,!DOUG");
	patterns.add("!DOUG,!DOUG");
	patterns.add("1*");
	patterns.add("!1");
	patterns.add("!DOUG*, !DOUG");
	patterns.add("*DOUG");
	patterns.add("*DOUG*");
	
	foreach pattern in patterns do
		yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_OperatorItem, pattern);
		self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
		self.assertTrueMsg(yATemplate &lt;&gt; null, "yATemplate is null");
		self.assertTrueMsg(yATemplate.myYardAllocation &lt;&gt; null, "yATemplate.myTemplate is null");
		self.assertTrueMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.isKindOf(CM_YADataPattern), "Not a CM_YADataPattern");
		self.assertEqualMsg(yATemplate.myYardAllocation.allCriteria.first.myYAData.CM_YADataPattern.pattern, pattern, "Incorrect CM_YADataPattern");
		
		self.deleteYATemplate("YATemplate");
	endforeach;
	
epilog
	delete patterns;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddYATmpltWildcardPatternErrs" id="58445402-1400-4afb-94b3-9456c561985d">
        <updating/>
        <source>tAddYATmpltWildcardPatternErrs() updating;
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	yATemplate: CM_YATemplate;
	patterns: StringArray;
	pattern: String;
begin
	create patterns transient;
	patterns.add("DO*UG");
	patterns.add("DO*UG*");
	patterns.add("DO!UG");
	patterns.add("DOUG!");
	patterns.add("!DOUG!");
	patterns.add("!DO!UG");
	patterns.add("1!");
		
	foreach pattern in patterns do
		yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_OperatorItem, pattern);
		self.assertTrueMsg(not app.myPassport.trxCompletedOK, "YATemplate did not give expected error for "&amp;pattern);
		self.assertEqualMsg(app.myPassport.allErrors.size, 1, "Error count");
		self.assertEqualMsg(app.myPassport.allErrors.first.errorCode, ErrInvalidYACriteriaPattern, "Wrong error");
	endforeach;
	
epilog
	delete patterns;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdAdd1Criteria" id="4d4aa106-239a-47b8-bd70-10690714bdba">
        <source>tUpdAdd1Criteria();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	oldEdition: Integer;
	yATemplate: CM_YATemplate;
	proxyYA: CM_YardAllocation;
	proxyYATemplate: CM_YATemplate;
	proxyCriterias: CMIF_Array;
	criteria: CM_YACriteria;
	commodities: ObjectSet; 
begin
	yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
	
	proxyYATemplate := self.createUpdateYATemplate(yATemplate, proxyYA, proxyCriterias);
	
	create commodities transient;
	commodities.add(CM_Root.firstInstance.allCommodities.first);
	commodities.add(CM_Root.firstInstance.allCommodities.last);
	proxyCriterias.add(self.createYACriteria(YACriteriaType_Commodity, commodities));
	
	oldEdition := yATemplate.edition;
	app.myTrxUA.trxUpdateYATemplate(proxyYATemplate, proxyCriterias, yATemplate, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
	self.assertTrueMsg(yATemplate.edition &lt;&gt; oldEdition, "Edition not updated");
	self.assertTrueMsg(yATemplate.myYardAllocation.allCriteria.size = 2, "Did not find 2 criteria " &amp; yATemplate.myYardAllocation.allCriteria.size.String);
	
epilog
	delete proxyYATemplate;
	//delete proxyYA;
	if proxyCriterias &lt;&gt; null then 
		proxyCriterias.purge;
		delete proxyCriterias;
	endif;
	delete commodities;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateYATemplate" id="0f45da5c-ea04-4a8b-9755-abca4d186932">
        <source>tUpdateYATemplate();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	oldEdition: Integer;
	yATemplate: CM_YATemplate;
	proxyYA: CM_YardAllocation;
	proxyYATemplate: CM_YATemplate;
	proxyCriterias: CMIF_Array;
	criteria: CM_YACriteria;
begin
	yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
	
	proxyYATemplate := self.createUpdateYATemplate(yATemplate, proxyYA, proxyCriterias);
	
	oldEdition := yATemplate.edition;
	app.myTrxUA.trxUpdateYATemplate(proxyYATemplate, proxyCriterias, yATemplate, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
	self.assertTrueMsg(yATemplate.edition &lt;&gt; oldEdition, "Edition not updated");

epilog
	delete proxyYATemplate;
	//delete proxyYA;
	if proxyCriterias &lt;&gt; null then 
		proxyCriterias.purge;
		delete proxyCriterias;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateYATemplateWithNewCriter" id="7bf3410a-de4f-4907-b938-49e65265bc5d">
        <source>tUpdateYATemplateWithNewCriter();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	oldEdition: Integer;
	yATemplate: CM_YATemplate;
	proxyYA: CM_YardAllocation;
	proxyYATemplate: CM_YATemplate;
	proxyCriterias: CMIF_Array;
	criteria: CM_YACriteria;
begin
	yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
	
	proxyYATemplate := self.createUpdateYATemplate(yATemplate, proxyYA, proxyCriterias);
	
	// Add a new criteria so should end up with two
	proxyCriterias.add(self.createYACriteria(YACriteriaType_IsForty, CM_YADataBoolean.VALUE_TRUE));
	
	oldEdition := yATemplate.edition;
	app.myTrxUA.trxUpdateYATemplate(proxyYATemplate, proxyCriterias, yATemplate, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YATemplate failed");
	self.assertTrueMsg(yATemplate.edition &lt;&gt; oldEdition, "Edition not updated");
	self.assertTrueMsg(yATemplate.myYardAllocation.allCriteria.size = 2, "Didn't find 2 criteria");

epilog
	delete proxyYATemplate;
	//delete proxyYA;
	if proxyCriterias &lt;&gt; null then 
		proxyCriterias.purge;
		delete proxyCriterias;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="uAddYATmpltRangePatternErrs" id="f2cc6f14-ac20-485b-86e4-fd1e6e2040d1">
        <updating/>
        <source>uAddYATmpltRangePatternErrs() updating;
//17 July 2008	cnwdw1	
// Under Construction
vars
	yATemplate: CM_YATemplate;
	patterns: StringArray;
	pattern: String;
begin
	create patterns transient;
	patterns.add("10AB");
	patterns.add("1000--2000");
	patterns.add("&lt;");
	patterns.add("&gt;");
	patterns.add("&gt;=");
	patterns.add("2000&lt;, 5000&gt;");
	patterns.add("2000 - 3000 - 4000");
	patterns.add("1000,,2000,3000");
	
	foreach pattern in patterns do
		yATemplate := self.addYATemplate("YATemplate",  YACriteriaType_Weight, pattern);
		self.assertTrueMsg(not app.myPassport.trxCompletedOK, "YATemplate did not give expected error for "&amp;pattern);
		self.assertEqualMsg(app.myPassport.allErrors.size, 1, "Error count");
		self.assertEqualMsg(app.myPassport.allErrors.first.errorCode, ErrInvalidYACriteriaPattern, "Wrong error");
	endforeach;
	
epilog
	delete patterns;
end;</source>
    </JadeMethod>
    <JadeMethod name="unitTestBefore" id="28a097c5-bd5b-4f73-8e2c-9246eed6d4d4">
        <source>unitTestBefore() protected;
//16 July 2008	cnwdw1	
//
vars

begin
	if self.getYATemplate("YATemplate") &lt;&gt; null then
		self.deleteYATemplate("YATemplate");
		self.assertTrueMsg(self.getYATemplate("YATemplate") = null, "YATemplate exists");
	endif;
end;</source>
        <access>protected</access>
