    <JadeMethod name="appName" id="a51cb9cc-012c-488b-a750-11c319bf56aa">
        <methodInvocation>mapping</methodInvocation>
        <source>appName(set: Boolean; _value: String io) mapping;
// -------------------------------------------
// Created 23 October 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	if set then
		return;
	endif;
	_value := 'BGP_TCPIPClientApp';

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="ff7944c9-ff77-4d40-b537-09e85fda6d12">
        <source>getDisplay(): String;

// cnwdvb1 29 April 2003 

vars

begin

	on Exception do self.xHandlerDisplay(exception);

	return Tab &amp; Tab &amp; Tab &amp; self.displayString &amp; Tab &amp; self.machineName &amp; Tab &amp; self.dateTimeLastStarted.bgpDisplay() &amp; Tab &amp;
	Tab &amp; Tab &amp; Tab &amp; self.isRunning().asRunningStopped(self.isSetup) &amp; Tab &amp; self.isRunningSDSDisplay();	// 11 July 2011	cmwrs1		CCMS1150 - backup sds notification

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFields" id="eac6aee1-6d5f-4ee9-90f3-ad637d24c2d6">
        <source>getFields(_allFields: StringArray input);
// --------------------------------------------------------------------------------
// Created:		23 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_allFields);
	_allFields.add(ETRow_TcpIpPort);
	_allFields.add(ETRow_TcpIpServerName);
	_allFields.add(ETRow_TcpIpClientWorkerType);
	_allFields.add(ETRow_BgpTerminal);
end;</source>
        <Parameter name="_allFields" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="52a063cc-91b6-4469-9713-f2792e737d30">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 October 2018	jlger1	Initial creation

*/

vars

begin
	return self.myTerminal;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="initApp" id="94fbc9b0-c878-4cb6-b863-a766d518989b">
        <updating/>
        <source>initApp() updating;

// cnwdvb1 28 April 2003 
/*

Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #18009 - Allow ini file control of transient check
*/
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

vars

	errorText	: String;
	errorCode	: Integer;
	msg : String;
begin

//	on Exception do app.alertExceptionHandler(exception, null, 'BGP Controller', errorCode, errorText, true, false) global;
	on Exception do self.xHandlerGlobal(exception) global;
	on LockException do app.alertLockExceptionHandler(exception) global;	
	if self.isRunning() then
		app.isBGPAppAbort := true;
		msg := 'ERR &gt;&gt; app is already running';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		app.exitLogFile();
		terminate;
		return;
	endif;
	if  self.myTerminal = null then
		app.isBGPAppAbort := true;
		msg := 'Terminal is invalid';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		terminate;
		return;
	endif;
	app.setIsBackGroundApp(true);
//	app.myCnCntrl.setCheckTransientsOnShutDown(false);	- removed PAR #18009
	app.myTrxUA.trxUpdateBGPControllerProcess(self, process, process.signOnTime, true, app.myPassport);
	self.beginNotification(self, BGP_Object.BGP_TerminateAppRequest, Response_Cancel , null);
	self.beginNotification(self, BGP_Object.BGP_DebugLevelChangeEvent, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_OutputInfo, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_ApplicationStartRequest, Response_Continuous , null);

	if app.myPassport &lt;&gt; null then
 		app.myPassport.setMyUser(self.myUser);
 		app.setMyTerminal(self.myTerminal);
 	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="isSetup" id="a559cec7-d317-4b50-87cf-e67a7e6f7139">
        <methodInvocation>mapping</methodInvocation>
        <source>isSetup(set: Boolean; _value: Boolean io) mapping;

// cnwdvb1 28 July 2003 

vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.tcpIpPort &lt;&gt; 0 and self.serverName &lt;&gt; null and self.myTerminal &lt;&gt; null then
		inheritMethod(set, _value);
		return;
	endif;
	_value := false;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setAttributesForCreate" id="a5e96bbe-e76a-4c7b-b427-1a4cd263bde0">
        <updating/>
        <source>setAttributesForCreate() updating, protected;

// cnwdvb1 28 April 2003 

vars

begin
	
	self.name				:= 'TCP Client';
	self.schemaName			:= 'XMLSchema';
	self.isEditable			:= true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCMIF" id="b798c395-9fa3-49d1-b3d5-204e6fc56971">
        <source>setCMIF(_cmif: CMIF_BGPManagerChildren input);

// cnwdvb1 28 April 2003 

vars

begin

	inheritMethod(_cmif);
	_cmif.serverName	:= self.serverName;
	_cmif.tcpIpPort		:= self.tcpIpPort.String;
	_cmif.workerClass	:= self.workerClass;
	_cmif.myTerminal	:= self.myTerminal;

end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4347dab6-3ae3-451f-be4c-b8b41ac57fbf">
        <updating/>
        <source>setForUpdate(_cmif: CMIF_BGPManagerChildren) updating;

// cnwdvb1 28 April 2003 

vars

begin

	inheritMethod(_cmif);
	self.serverName 	:= _cmif.serverName;
	self.tcpIpPort		:= _cmif.tcpIpPort.Integer;
	self.workerClass	:= _cmif.workerClass;
	self.myTerminal		:= _cmif.myTerminal;
	self.displayString	:= self.workerClass;

end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="7242075a-5fef-44a4-8761-e11c3230f504">
        <source>validateForUpdate();

// cnwdvb1 29 April 2003 
// 12/12/2014  cnwdb2	PAR 35364

vars

begin
	
	inheritMethod();
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', null, null);
		app.raiseCMException(Input_required_field_terminal, null, null); // cnwdb2	PAR 35364
	endif;
end;</source>
    </JadeMethod>
</Class>
