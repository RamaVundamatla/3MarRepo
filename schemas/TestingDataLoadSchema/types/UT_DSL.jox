    <JadeMethod name="deleteSubTerminal" id="17b06a38-5f8f-4a82-aba8-15d22c284473">
        <source>deleteSubTerminal( _code : String );

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
15 October 2010	cnwndl1	Initial creation	
28/04/2014		cnmwh5	Change to also now delete tracked items from the ti txn dict
*/

vars

	subTerm : CM_SubTerminal;
	
	ti							: CM_TrackedItem;
	bulkRelease					: CM_BulkRelease;
	dataAccessController		: CM_DataAccessController;
	obj							: Object;
	txn							: CM_TITransaction;

	tisToDelete					: CM_TIArray;
	
begin

	subTerm := app.myRoot.allSubTerminals[ _code ];
	
	if subTerm &lt;&gt; null then
		
		create tisToDelete transient;															// 28/04/2014 cnwmh5
		
		subTerm.allOnsiteTIsByIdCargoType.copy(tisToDelete);									// 28/04/2014 cnwmh5
		
		// 28/04/2014 cnwmh5
		foreach txn in subTerm.allTITransactionsByDateType do
			if not tisToDelete.includes(txn.myTrackedItem) then
				tisToDelete.add(txn.myTrackedItem);
			endif;
		endforeach;
		
		// 28/04/2014 cnwmh5 
		foreach ti in tisToDelete do
			self.deleteTrackedItem(ti, false);
		endforeach;	
		
		//beginTransaction;																		// 18/09/2012 cnwmh5
		foreach bulkRelease in subTerm.allBulkReleasesByCode do
			app.writeLog('release request: ' &amp; bulkRelease.String &amp; Tab &amp; bulkRelease.code &amp; Tab &amp; 
				subTerm.allBulkReleasesByCode.size.String &amp; Tab, LogINFO);
			self.deleteReleaseRequest(bulkRelease.code);
		endforeach;
		//commitTransaction;
		
		beginTransaction;																		// 18/09/2012 cnwmh5
		foreach obj in subTerm.allDataAccessControllers do
			dataAccessController := obj.CM_DataAccessController;
			//write dataAccessController.String;
			foreach obj in dataAccessController.allObjects do
				if obj.isKindOf(CM_ConsigneeConsignor) then
					self.deleteConsigneeConsignor(obj.CM_ConsigneeConsignor.code);
				elseif obj.isKindOf(CM_SubTerminal) then
					dataAccessController.allObjects.remove(obj.CM_SubTerminal);
				endif;
			endforeach;
		endforeach;		
		commitTransaction;
			
		app.myTrxDA.trxDeleteSubTerminal(subTerm, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();													// 18/09/2012 cnwmh5
	endif;

epilog

	delete tisToDelete;

end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteTAFromSatView" id="c73021c2-f393-49da-8670-d6c1716ad76a">
        <source>deleteTAFromSatView(_ta: CM_TerminalArea);
vars

	viewPosition, pxyViewPosition: CM_TerminalAreaViewPosition;
	view, pxyView: CM_TerminalAreaView;
begin

		// Remove from Sat View
		foreach viewPosition in _ta.allTerminalAreaViewPositions do
			view := viewPosition.myTerminalAreaView;
			pxyView := app.createUpdateProxy(view).CM_TerminalAreaView;
			foreach pxyViewPosition in pxyView.allTerminalAreaViewPositions do
				if pxyViewPosition.myTerminalArea = _ta then
					delete pxyViewPosition;
					break;
				endif;
			endforeach;
			app.myTrxUA.trxUpdateTerminalAreaView(pxyView, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
			delete pxyView;
		endforeach;

epilog
	delete pxyView;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="deleteTATasks" id="950595c6-47be-4533-8d33-c48b6bad13c0">
        <source>deleteTATasks(_ta : CM_TerminalArea);
// logic copied from CM_TerminalArea::checkRTQueueTaskUsage() to delete any tasks which refer to this terminal area,
//  to allow the area to be deleted.
// 19/02/2010	cnwjre1		for CCMS 1101 tests
vars
	task	: CM_RTQueueTask;
	tasks	: CM_RTQueueTaskArray;
	entry	: CM_RTQueueEntry;
	entrySet : CM_RTQueueEntrySet;
	masterQ : CM_MasterQueue;
	invalidTask,
	invalidSource,
	invalidTarget : Boolean;
	sourceLocation,
	targetLocation  : CM_LocationsController;
	sourceParent,
	targetParent : CM_Object;
	
begin
	if _ta.myTerminal = null then
		return;
	endif;
	
	if _ta.myTerminal.radioTelemetry = null then
		return;
	endif;

	masterQ := _ta.myTerminal.radioTelemetry.masterQueue;
	if masterQ = null then
		return;
	endif;

	create tasks transient;
	masterQ.getAllTasks(tasks);
	create entrySet transient;
	
	on Exception do app.handleDeletedObject(exception,task,invalidTask);
	on Exception do app.handleDeletedObject(exception,targetLocation,invalidTarget);
	on Exception do app.handleDeletedObject(exception,sourceLocation,invalidSource);
	//-----------------
	//If a task references us, kill it along with its queue entry
	//-----------------
	foreach task in tasks do

		invalidTask := false;
		invalidTarget := false;
		invalidSource := false;

		sourceLocation := null;
		targetLocation := null;
		
		sourceParent := null;
		targetParent := null;
		
		sourceLocation := task.sourceLocation;
		targetLocation := task.targetLocation;
		if invalidTask then
			continue;
		endif;

		if sourceLocation &lt;&gt; null then
			sourceParent := sourceLocation.getParent();
		endif;

		if targetLocation &lt;&gt; null then
			targetParent := targetLocation.getParent();
		endif;
		
		if sourceParent = _ta or targetParent = _ta then
			entry := task.myEntry;
			if entry &lt;&gt; null and not entrySet.includes(entry) then
				entrySet.add(entry);
			endif;
		endif;
	endforeach;	
	
	beginTransaction;
	foreach entry in entrySet do
		delete entry;
		//app.myTrxDA.trxDeleteQueueEntry(entry, app.myPassport);
		//self.assertNoTrxErrorsOrWarnings();
	endforeach;
	commitTransaction;
	
	
epilog
	delete tasks;
	delete entrySet;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="deleteTIInvoiceLines" id="78a67fab-96f2-4155-9dbc-b6bbcd5782f1">
