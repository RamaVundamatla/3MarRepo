		if thePassport.myCMIFMonitor &lt;&gt; null  and ((progressInt.getMilliseconds &gt;= ProgressBarRefresh) or (count = numCodes)) then
			thePassport.myCMIFMonitor.updateProgress(app.getErrorString1(Creating_msg, app.getErrorString(Vehicle_model)), numCodes, count);
