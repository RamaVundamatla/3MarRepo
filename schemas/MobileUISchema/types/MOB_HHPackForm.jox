    <JadeMethod name="validateSelections" id="0eaad5ae-c15d-47da-85e8-267dd4a0611e">
        <updating/>
        <source>validateSelections():Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2011	cnwndl1	Initial creation	Par 26476
30 Dec 2014     cnwma1  PAR # 35380  Special Stow Bookings

*/

vars
	
	mess : String;
	tiIsoTypeGroup : String;

begin

	self.myTrackedItem := self.doFindTrackedItem();
	if self.myTrackedItem = null then
		mess := "Container not found '" &amp; self.txtContainerId.text.toUpper.trimBlanks &amp; "'";
		self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false );
		self.txtContainerId.setFocus();
		return false;
	endif;
	
	if self.myTrackedItem.myBookingRef &lt;&gt; null and self.myContBookingRef &lt;&gt; null and self.myTrackedItem.myBookingRef &lt;&gt; self.myContBookingRef then
		mess := "The container '" &amp; self.myTrackedItem.id &amp; "' cannot be used as it is already assigned to booking '" &amp; self.myTrackedItem.myBookingRef.bookingReference &amp; "'";
		self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false );
		self.txtContainerId.setFocus();
		return false;
	endif;
	
	if self.myCargoStockBookingRef &lt;&gt; null then
		if not self.myCargoStockBookingRef.allBookingRefItems.isEmpty and self.myCargoStockBookingItem = null then
			mess := "Must select an item for " &amp; self.myCargoStockBookingRef.bookingReference &amp; "'";
			self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false );
			self.cmbCargoBookItem.setFocus();
			return false;
		endif;
	endif;
	
	if self.myContBookingRef &lt;&gt; null then
		if not self.myContBookingRef.allBookingRefItems.isEmpty and self.myContBookingItem = null then
			mess := "Must select an item for " &amp; self.myContBookingRef.bookingReference &amp; "'";
			self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false );
			self.cmbContBookItem.setFocus();
			return false;
		endif;
		
		if self.myContBookingItem &lt;&gt; null then
			if self.myTrackedItem.cargoType &lt;&gt; self.myContBookingItem.cargoType then
				mess := "The container '" &amp; self.myTrackedItem.id &amp; "' cannot be used for the booking "
						&amp; self.myContBookingRef.bookingReference &amp; " as the Cargo Types '"
						&amp; self.myTrackedItem.cargoType.String &amp;  "'/'"
						&amp; self.myContBookingItem.cargoType.String &amp; "' do not match.";
				self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false );
				self.txtContainerId.setFocus();
				return false;
			endif;
			if self.myContBookingItem.isoType &lt;&gt; null and self.myTrackedItem.getISOType &lt;&gt; self.myContBookingItem.isoType then
				mess := "The container '" &amp; self.myTrackedItem.id &amp; "' cannot be used for the booking "
						&amp; self.myContBookingRef.bookingReference &amp; " as the ISO Types '"
						&amp; self.myTrackedItem.getISOType &amp;  "'/'"
						&amp; self.myContBookingItem.isoType.String &amp; "' do not match.";
				self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false );
				self.txtContainerId.setFocus();
				return false;
			endif;
			if self.myTrackedItem.getISOTypeGroup &lt;&gt; null then
				tiIsoTypeGroup := self.myTrackedItem.getISOTypeGroup.code;
			endif;
			if self.myContBookingItem.isoTypeGroup &lt;&gt; null and tiIsoTypeGroup &lt;&gt; self.myContBookingItem.isoTypeGroup then
				mess := "The container '" &amp; self.myTrackedItem.id &amp; "' cannot be used for the booking "
						&amp; self.myContBookingRef.bookingReference &amp; " as the ISO Type Groups '"
						&amp; tiIsoTypeGroup &amp;  "'/'"
						&amp; self.myContBookingItem.isoTypeGroup.String &amp; "' do not match.";
				self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false );
				self.txtContainerId.setFocus();
				return false;
			endif;
			if self.myContBookingItem.mySpecialStow &lt;&gt; null and  self.myTrackedItem.getSpecialStow &lt;&gt; null and   //30/12/2014 cnwma1 PAR #35380
			   self.myTrackedItem.getSpecialStow &lt;&gt; self.myContBookingItem.mySpecialStow then
				mess := "The container '" &amp; self.myTrackedItem.id &amp; "' cannot be used for the booking "
						&amp; self.myContBookingRef.bookingReference &amp; " as the Special Stow Code '"
						&amp; self.myContBookingItem.mySpecialStow.code.String &amp;  "'/'"
						&amp; self.myTrackedItem.specialStow &amp; "' do not match.";
				self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false );
				self.txtContainerId.setFocus();
				return false;
			endif;
		else
			if self.myTrackedItem.cargoType &lt;&gt; self.myContBookingRef.cargoType then
				mess := "The container '" &amp; self.myTrackedItem.id &amp; "' cannot be used for the booking "
						&amp; self.myContBookingRef.bookingReference &amp; " as the Cargo Types '"
						&amp; self.myTrackedItem.cargoType.String &amp;  "'/'"
						&amp; self.myContBookingRef.cargoType.String &amp; "' do not match.";
				self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false );
				self.txtContainerId.setFocus();
				return false;
			endif;
			if self.myContBookingRef.isoType &lt;&gt; null and self.myTrackedItem.getISOType &lt;&gt; self.myContBookingRef.isoType then
				mess := "The container '" &amp; self.myTrackedItem.id &amp; "' cannot be used for the booking "
						&amp; self.myContBookingRef.bookingReference &amp; " as the ISO Types '"
						&amp; self.myTrackedItem.getISOType &amp;  "'/'"
						&amp; self.myContBookingRef.isoType.String &amp; "' do not match.";
				self.msgBox(mess, app.getErrorString(Error), MsgBox_OK_Only, false );
				self.txtContainerId.setFocus();
				return false;
			endif;
			
		endif;
		
	endif;

	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
