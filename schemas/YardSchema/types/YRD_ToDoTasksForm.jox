// 36957 make the searcher wider for longer to do descriptions
vars

begin
	inheritMethod();
	self.frmQuery.width		:=	450;
	self.fldQuery.width		:=	self.frmQuery.clientWidth();
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="removeTIFromTable" id="ca8cdcc5-5f03-4035-97de-cbf9b66124a8">
        <source>removeTIFromTable(_table: CM_DataTable input; _ti: CM_TrackedItem; _row: Integer);
//----------------------------------------------------------------
//	Created:	14 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	
	self.endNotification(_ti, Object_Update_Event);
	_table.removeItem(_row);

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setState" id="82203745-c5b3-4272-a86f-057c55ba04ad">
        <updating/>
        <source>setState(_state : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     08 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if _state = self.STATE_EDIT then
		self.btnSelectorQuery.enabled :=false;
		self.btnSelector.enabled := false;
		self.btnSaveBase.enabled := true;
		self.btnAddComplete.enabled := false;
		self.btnRemoveTasks.enabled := false;
		self.tblData.userInputEnabled := true;
		self.btnPrint.enabled := false;
		self.btnQuery.enabled := false;
		self.mode := self.Mode_Update;
		self.tblData.selectMode := Table.SelectMode_Single;
		self.tblData.selectionType := Table.SelectMode_Single;	
		
	elseif _state = self.STATE_VIEW then
	
		self.btnSelector.enabled := true;
		self.btnSelectorQuery.enabled := true;
		self.btnSaveBase.enabled := false;
		self.btnAddComplete.enabled := true;
		self.btnRemoveTasks.enabled := true;
		self.isRemovingTasks := false;
		self.tblData.userInputEnabled := false;
		self.btnPrint.enabled := true;
		self.btnQuery.enabled := true;
		self.mode := self.Mode_Enquire;
		self.tblData.selectMode := Table.SelectMode_FixedRow;
		self.tblData.selectionType := CM_DataTable.SelectMode_FixedRow;
		
	endif;

end;</source>
        <Parameter name="_state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="00ada7f4-7988-406e-8483-cd2ce2930006">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.usesQueryFrame := true;

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	
// cnwdad1 20/07/2006 - The new skins were preventing the legend colors from showing.
	lblToDoCol.ignoreSkin		:=	true;
	lblCompletedCol.ignoreSkin	:=	true;
	lblRemovedTask.ignoreSkin	:=	true;
	lblToDoColEdit.ignoreSkin	:=	true;
	lblCompColEdit.ignoreSkin	:=	true;
	self.useTableInfo := true;
	self.useTableSorting := true;
	inheritMethod();	
	
	self.initLegend();
	
	self.tblInfo.rows := 0;
	self.initTableData(null);

	self.btnQuery.visible := true;
	self.btnDelete.visible := false;
	
	self.mode := self.Mode_Enquire;
	self.setState(self.STATE_VIEW);
	self.setNavigatorHeading(self.caption);
	self.btnAddComplete.enabled := false;
	self.btnRemoveTasks.enabled := false;
	self.isSelectorCapable := true;
	
	if self.myInitializationTI &lt;&gt; null then
		self.initializeWithTI();
	elseif (not self.myTIQueryFilter.allQryTrackedItems.isEmpty) then
		self.displayTIs(self.myTIQueryFilter.allQryTrackedItems);
		self.frmQuery.visible := false;
		self.btnAddComplete.enabled := true;
		self.btnRemoveTasks.enabled := true;
	endif;
	
	self.doResize();
	
	self.chkIncludeOnship.width := self.shtQuery6.width - 10;	//02 Jun 2916	NDL	TFS 2093

	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled:= false;
		self.btnAddComplete.enabled:= false;
		self.btnRemoveTasks.enabled:= false;
		self.btnEditItem.enabled:= false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showColourLegend" id="45b00f7e-be51-44b2-b75d-97799f968b57">
        <source>showColourLegend();
// ---------------------------------------------------------------------------
// Created:     23 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.frmLegend.visible := (not self.frmLegend.visible);


end;</source>
    </JadeMethod>
    <JadeMethod name="showSelector" id="d29496bb-ddd8-4e97-a907-48a3d2d260b2">
        <updating/>
        <source>showSelector() updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	theSelector		: CMUI_Selector;
	cargoType		: CM_CargoType;
	
begin
	theSelector := app.getSelectorForm(self, self.myMasterMenuAction);
	
	if theSelector = null then
		return;
	endif;

/*	form should still function after launching the selector... don't need these
	self.btnAddComplete.enabled := false;
	self.btnRemoveTasks.enabled := false;
*/
	
	theSelector.myTerminal := self.myTerminal;	
	//get the first cargoType selected to find appropriate selector mode, else just open in TI mode
	if (not self.lstCargoType.allSelectedObjects.isEmpty) and
		(self.lstCargoType.allSelectedObjects.first.CM_CargoType.id = TI_CargoType_Container) then
		theSelector.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Container];	
	endif;//else form will open for tracked item mode
	
	theSelector.myEnquiryCollectionClass := CM_TIArray;
	theSelector.show;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="1a5cde9a-da46-40aa-bf89-a680532d7b11">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2015	cnwndl1	Initial creation

*/

vars

	hide : Boolean;

begin

	if eventTag = Hide_Note_Tag then
		self.hideTimerInProgress := false;
		hide := self.btnHideUnused.value;
		if hide then
			self.doShowHideUnusedAndFilterCols();
		endif;
	endif;

epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="58d14ffd-e0c8-4ac3-b4a7-ecfbf5f067b0">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 November 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008941, locale);
	btnAddComplete.translateCaption(Xlat_0004698, locale);
	btnEdit.translateCaption(Xlat_0004701, locale);
	btnEnquire.translateCaption(Xlat_0004702, locale);
	btnFilter.translateCaption(Xlat_0021099, locale);
	btnHideUnused.translateCaption(Xlat_0021100, locale);
	btnLegend.translateCaption(Xlat_0004703, locale);
	btnRemoveTasks.translateCaption(Xlat_0004699, locale);
	btnSelector.translateCaption(Xlat_0014674, locale);
	btnSelectorQuery.translateCaption(Xlat_0014675, locale);
	chkIncludeOnship.translateCaption(Xlat_0004694, locale);
	frmLegend.translateCaption(Xlat_0004705, locale);
	lblCompEditDesc.translateCaption(Xlat_0004695, locale);
	lblCompleteDesc.translateCaption(Xlat_0004696, locale);
	lblRemTaskDesc.translateCaption(Xlat_0004700, locale);
	lblTaskStatus.translateCaption(Xlat_0004706, locale);
	lblToDoDesc.translateCaption(Xlat_0004707, locale);
	lblToDoEditDesc.translateCaption(Xlat_0004697, locale);
	mnuEnquire.translateCaption(Xlat_0008942, locale);
	mnuTIContext.translateCaption(Xlat_0008943, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="639c0025-2d57-4041-8694-b7b0b6f0c5cd">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:     09 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	delete self.myTIQueryFilter;
	if self.allTasksToCompleteComplex &lt;&gt; null then
		delete self.allTasksToCompleteComplex;
	endif;
	
	if self.hideTimerInProgress then
		self.endTimer(Hide_Note_Tag);
		self.hideTimerInProgress := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="updateItemInTable" id="edb77075-8c34-45f5-a71c-e2462b19f696">
        <source>updateItemInTable(_table : CM_DataTable input; _trackedItem : CM_TrackedItem; _rowIdx: Integer);
//----------------------------------------------------------------
//	Created:	26 July 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	rowObj 	: Object;
	col,
	numCols	: Integer;
	tbl 	: CM_DataTable;
	tiData	: String;
	ti		: CM_TrackedItem;
begin
	ti := _trackedItem;
	if ti = null then
		return;
	endif;

	rowObj	:= _table.accessRow(_rowIdx).itemObject;
	
	if rowObj &lt;&gt; _trackedItem then
		return;
	endif;

	if not checkFilterOK(ti) then
		self.removeTIFromTable(_table, ti, _rowIdx);
		return;
	endif;

	tbl := _table;
	numCols := tbl.columns;
	
	tiData := ti.id &amp; Tab &amp; ti.locationId &amp; Tab &amp; ti.voyageCode &amp; Tab &amp; ti.operatorCode;
	tbl.accessCell(_rowIdx, 1).text := tiData;
		
	foreach col in self.TaskStartColumn to numCols do
		tbl.accessCell(_rowIdx, col);
		if tbl.accessedCell.inputType &lt;&gt; Table.InputType_CheckBox then
			tbl.accessedCell.inputType := Table.InputType_CheckBox;
		endif;
		tbl.accessedCell.text :=  false.cnEcGetTableCheckBoxValue;
		tbl.accessedCell.itemObject := null;
		
		tbl.accessedCell.backColor := White;
	endforeach;
		
	self.populateRowWithTasks(tbl, _trackedItem.allToDoTasksCompleted, _rowIdx, false);
	self.populateRowWithTasks(tbl, _trackedItem.allToDoTasksToDo, _rowIdx, true);
	
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_rowIdx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="e7413159-7633-49f2-882a-6661bb223da2">
        <updating/>
        <source>updateProgress(_cmifMonitor : CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin

	if self.frmModalDialog.visible then
		self.modalDialogShow(null,'Return Data','Cancel',null,
						_cmifMonitor.message,
						'Searched ' &amp; _cmifMonitor.numSearched.String &amp; '  found ' &amp; _cmifMonitor.numFound.String);
						//'Searching for data',
						//'Searched ' &amp; self.numItemsSearched.String &amp; '  found ' &amp; _numFound.String);
	endif;
	
	self.btnModalDefault.doWindowEvents(0);
	if self.modalDialogReturnValue = ModalDialogReturn_Null then
		// see if the user has pressed the Cancel button
		self.btnModalOpt1.doWindowEvents(0);
	endif;

	if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
		_cmifMonitor.monitorReturnValue := _cmifMonitor.MonitorReturnValue_Cancel;
	endif;

end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
</GUIClass>
