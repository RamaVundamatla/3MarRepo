    <JadeMethod name="setToArchived" id="89df7ddb-c628-41a3-8c51-4985eab9d1d9">
        <updating/>
        <source>setToArchived() updating;
// ---------------------------------------------------------------------------
// Created:     19 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	exclusiveLock(self);

	if self.numTIs = 0 then
		self.status := LC_Status_Archived;
		self.ignoreArchiving := false;
	else
		app.raiseCMException1(ArchivedRowCannotHaveTIs, self.ident, ETRow_Status, null);
	endif;

end;</source>
    </JadeMethod>
