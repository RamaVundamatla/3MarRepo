    <JadeMethod name="buildLogProductCode" id="abae91f6-5cc0-47ae-8509-d708fc638583">
        <source>buildLogProductCode(pSpecies, pGrade, pType, pTreatment, pLength : String) : String;
// ---------------------------------------------------------------------------
// Created:     25 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/05/2010	cnwar2		#22731 - remove tabs
// ---------------------------------------------------------------------------

vars
	species, grade, type,
	treatment, length, str	: String;
	
begin
	species 	:= pSpecies;
	grade		:= pGrade;
	type		:= pType;
	treatment	:= pTreatment;
	length		:= pLength;
	
	str	:= species.removeTabCrLfs() &amp; ':' &amp;
		   grade.removeTabCrLfs() &amp; ':' &amp;
		   type.removeTabCrLfs() &amp; ':' &amp;
		   treatment.removeTabCrLfs() &amp; ':' &amp;
		   length.removeTabCrLfs();

	return str;
		   
	/*return pSpecies &amp; ':' &amp;
		   pGrade &amp; ':' &amp;
		   pType &amp; ':' &amp;
		   pTreatment &amp; ':' &amp;
		   pLength;*/
end;</source>
        <Parameter name="pSpecies" type="String"/>
        <Parameter name="pGrade" type="String"/>
        <Parameter name="pType" type="String"/>
        <Parameter name="pTreatment" type="String"/>
        <Parameter name="pLength" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
