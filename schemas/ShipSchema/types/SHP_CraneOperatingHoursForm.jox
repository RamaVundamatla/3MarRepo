    <JadeMethod name="create" id="a8413f86-c416-4501-9c83-4b335ee438b8">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2012	cnwndl1	Initial creation	Par 29369

*/

vars

begin

	self.permissionView  := PmShipJobControllerView; // TFS 2198
	self.permissionMaint := PmShipJobControllerMaint; // TFS 2198
	self.helpFileName := HelpFile_Voyage;

epilog

