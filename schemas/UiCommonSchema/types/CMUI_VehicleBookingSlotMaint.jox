    <JadeMethod name="doSave" id="04a1365e-a843-4436-9829-517f6155e7e5">
        <updating/>
        <source>doSave()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Apr 2013	cnwndl1	Initial creation	Par 31393
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
*/

vars

	startTS : TimeStamp;
	endTS : TimeStamp;
	vbTerm : CM_VehicleBookingTerminal;
	proxy : CM_VehicleBookingTimeSlot;
	carrier : CM_Carrier;
	driver : CM_DriverDetails;
	vehicle : CM_Vehicle;
	remarks : String;
	vvr : CM_VehicleVisitRecord;
	newVBBooking : CM_VehicleBookingTimeSlot;
	theReturn : Integer;
	loadState : Boolean;
	strArray : StringArray;
	allDeliveryIds, allPickupIds : StringArray;		// TFS 51248
	allBookingRefs : CM_BookingRefSet;
	allBulkReleases : CM_BulkReleaseSet;
	tsType : CM_VehicleBookingTimeSlotType;
	id : String;
	bookingStrArray : CnStringArray;
	str : String;
	bookingRef : CM_BookingRef;
	relStrArray : CnStringArray;
	bulkRel : CM_BulkRelease;
	msg : String;
	
begin
	create strArray transient;
	create allDeliveryIds transient;		// TFS 51248
	create allPickupIds transient;			// TFS 51248
	create allBookingRefs transient;
	create allBulkReleases transient;
	
	//if not self.doValidate( startTS, endTS, vbTerm, strArray ) then						// TFS 51248
	if not self.doValidate( startTS, endTS, vbTerm, allDeliveryIds, allPickupIds ) then		// TFS 51248
		return;
	endif;
	allDeliveryIds.copy(strArray);			// TFS 51248
	allPickupIds.copy(strArray);			// TFS 51248
	
	if self.myVehicleBooking = null then
		create proxy transient;
		//id := vbTerm.generateNextVBSTimeslotId();	// ### TFS 53899 21Feb2023 NAVPW1
	else
		app.cmsBeginLoad(loadState);
		proxy := self.myVehicleBooking.pxyCreateUpdateProxy().CM_VehicleBookingTimeSlot;
		app.cmsEndLoad(loadState);
		vvr := self.myVehicleBooking.myVehicleVisitRecord;
		id := proxy.id;
	endif;
	
	carrier := self.cmbCarrier.listObject.CM_Carrier;
	driver := self.cmbDriver.listObject.CM_DriverDetails;
	vehicle := self.cmbVehicle.listObject.CM_Vehicle;
	remarks := self.txtRemarks.text;
	
	//need to populate allBookingRefs and allBulkReleases, from form
	if self.txtCargoBookId.text.trimBlanks &lt;&gt; null then
		bookingStrArray := self.txtCargoBookId.text.toUpper.trimBlanks.cnGetTokens(" ");
		if bookingStrArray &lt;&gt; null then
			foreach str in bookingStrArray do
				bookingRef := self.myTerminal.allBookingRefsByStatusRef.getAtKey(BR_ACTIVE,str.toUpper );
				if bookingRef &lt;&gt; null then
					allBookingRefs.add( bookingRef );
				endif;
			endforeach;
		endif;
	endif;
	if self.txtCargoRelId.text.trimBlanks &lt;&gt; null then
		relStrArray := self.txtCargoRelId.text.toUpper.trimBlanks.cnGetTokens(" ");
		if relStrArray &lt;&gt; null then
			foreach str in relStrArray do
				bulkRel := self.myTerminal.allBulkReleasesByCodeDate.getAtKeyGeq( str, "31/12/3000".Date.TimeStamp ).CM_BulkRelease;
				if bulkRel &lt;&gt; null and bulkRel.code = str then
					allBulkReleases.add( bulkRel );
				endif;
			endforeach;
		endif;
	endif;
	
	if self.cmbTSType.listIndex &gt; 1 then
		tsType := self.cmbTSType.itemObject[ self.cmbTSType.listIndex ].CM_VehicleBookingTimeSlotType;
		if tsType.notAvailableForEntry then
			msg := app.getErrorString1( Marke_not_avail_entry_will_cle, tsType.description );
			app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only );
			self.cmbTSType.listIndex := -1;
			tsType := null;
			return;
		endif;
	endif;
	
	proxy.setProxy(	startTS,	//_scheduleTSstart : TimeStamp;
					endTS,		//_scheduleTSend : TimeStamp;
					vbTerm,		//_myVBTerminal : CM_VehicleBookingTerminal;
					carrier,	//_myCarrier : CM_Carrier;
					null,		//_mySubCarrier : CM_Carrier;
					driver,		//_myDriver : CM_DriverDetails;
					vehicle,	//_myVehicle : CM_Vehicle;
					remarks,	//_remarks : String;
					self.chkDeliver.value,	//_includesDelivery : Boolean;
					self.chkPickUp.value,	//_includesPickUp : Boolean;
					strArray,	//_bookedTiIds : StringArray;
					vvr,	//_myVehicleVisitRecord : CM_VehicleVisitRecord
					tsType,	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType
					id,	//_id : String;
					allBookingRefs,	//_allBookingRefs : CM_BookingRefSet;
					allBulkReleases,	//_allBulkReleases : CM_BulkReleaseSet
					null,	//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
					null,	//_preGateInCheck : Boolean;
					null,	//_preGateOutChck : Boolean;
					null,	//_kioskCheck : Boolean;
					null,	//_externalReference : String
					null	//_myTILCType : CM_TILCType	// 08 Aug 2024 navcs2	ChangeRequest 63928
					);
					
	while true do
		if self.myVehicleBooking = null then
			//app.myTrxCA.trxCreateVehicleBooking(proxy, newVBBooking, app.myPassport);									// TFS 51248
			app.myTrxCA.trxCreateVehicleBooking(proxy, newVBBooking, allDeliveryIds, allPickupIds, app.myPassport);		// TFS 51248
		else
			//app.myTrxUA.trxUpdateVehicleBooking(proxy, app.myPassport);												// TFS 51248
			app.myTrxUA.trxUpdateVehicleBooking(proxy, allDeliveryIds, allPickupIds, app.myPassport);					// TFS 51248
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			if self.myVehicleBooking = null then
				self.myVehicleBooking := newVBBooking;
			endif;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Vehicle_schedul_booking_slot), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
	//20 Mar 2015 NDL	Par 35882
	if self.myCallingForm &lt;&gt; null then
		self.myCallingForm.lblLastVBSUpd2.caption := id;
	endif;
	
	self.unloadForm;
	
epilog

	delete bookingStrArray;
	delete relStrArray;
	delete proxy;
	delete strArray;
	delete allDeliveryIds;			// TFS 51248
	delete allPickupIds;			// TFS 51248
	delete allBookingRefs;
	delete allBulkReleases;
	app.cmsEndLoad(loadState);

end;</source>
    </JadeMethod>
    <JadeMethod name="doValidate" id="4ac5e2e4-e0ee-4053-a489-0c6b219d1e54">
        <source>doValidate( _startTS : TimeStamp output;
			_endTS : TimeStamp output;
			_vbTerm : CM_VehicleBookingTerminal output;
			_allDeliveryIds, _allPickupIds : StringArray input		// TFS 51248
			):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Apr 2013	cnwndl1	Initial creation	Par 31393
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
*/

vars

begin

	_vbTerm := self.myTerminal.getMyVehicleBookingTerminal();
	if _vbTerm = null then
		app.msgBox( app.getErrorString(Terminal_reference_set), app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;

	if not self.txtDateStart.getDate.isValid then
		app.msgBox( app.getErrorString1(ERR_INVALID_TIMESTAMP, self.lblStartDate.caption),  app.getErrorString(Error), MsgBox_OK_Only);
		self.txtDateStart.setFocus();
		return false;
	endif;
	_startTS.setDate( self.txtDateStart.getDate );
	_startTS.setTime( self.txtTimeStart.getTime() );
	
	if not self.txtDateEnd.getDate.isValid then
		app.msgBox( app.getErrorString1(ERR_INVALID_TIMESTAMP, self.lblEndDate.caption),  app.getErrorString(Error), MsgBox_OK_Only);
		self.txtDateEnd.setFocus();
		return false;
	endif;
	_endTS.setDate( self.txtDateEnd.getDate );
	_endTS.setTime( self.txtTimeEnd.getTime() );
	
	if _endTS &lt; _startTS then
		app.msgBox( app.getErrorString2(ERR_DateRangeInvalid, self.lblStartDate.caption, self.lblEndDate.caption),  app.getErrorString(Error), MsgBox_OK_Only);
		self.txtDateEnd.setFocus();
		return false;
	endif;
	
	//if not self.getAllTrackedItemIds( _allTiIds ) then						// TFS 51248
	if not self.getAllTrackedItemIds( _allDeliveryIds, _allPickupIds ) then		// TFS 51248
		return false;
	endif;

	return true;

epilog

end;</source>
        <Parameter name="_startTS" type="TimeStamp" usage="output"/>
        <Parameter name="_endTS" type="TimeStamp" usage="output"/>
        <Parameter name="_vbTerm" type="CM_VehicleBookingTerminal" usage="output"/>
        <Parameter name="_allDeliveryIds" type="StringArray" usage="input"/>
        <Parameter name="_allPickupIds" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllTrackedItemIds" id="b4adb701-b2fb-44a3-99e9-e7851a66754c">
        <source>getAllTrackedItemIds( _allDeliveryIds, _allPickupIds : StringArray input ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

	delim	: String;
	
begin

	if not lostFocusDeliver() then
		return false;
	endif;
	
	if not lostFocusPickup() then
		return false;
	endif;
	
	delim := CrLf;
	
	//self.txtIdsDeliver.text.asStringArrayByDelimiter(_allTiIds, delim);			// TFS 51248
	self.txtIdsDeliver.text.asStringArrayByDelimiter(_allDeliveryIds, delim);		// TFS 51248

	//self.txtIdsPickUp.text.asStringArrayByDelimiter(_allTiIds, delim);			// TFS 51248
	self.txtIdsPickUp.text.asStringArrayByDelimiter(_allPickupIds, delim);			// TFS 51248
	
	return true;

epilog

end;</source>
        <Parameter name="_allDeliveryIds" type="StringArray" usage="input"/>
        <Parameter name="_allPickupIds" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lostFocusBookingRef" id="f0c8af04-94c1-4b40-81a8-e0c46a733ab5">
        <source>lostFocusBookingRef();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2014	cnwndl1	Initial creation

*/

vars

	bookingStrArray : CnStringArray;
	str : String;
	bookingRef : CM_BookingRef;
	

begin

	if self.txtCargoBookId.text.trimBlanks &lt;&gt; null then
		bookingStrArray := self.txtCargoBookId.text.toUpper.trimBlanks.cnGetTokens(" ");
		if bookingStrArray &lt;&gt; null then
			foreach str in bookingStrArray do
				bookingRef := self.myTerminal.allBookingRefsByStatusRef.getAtKey(BR_ACTIVE,str.toUpper );
				if bookingRef = null then
					app.msgBox( app.getErrorString1( Active_booking_not_found, str), app.getErrorString(Warning), MsgBox_OK_Only );
					return;
				else
					//found one
					self.chkDeliver.value := true;
				endif;
			endforeach;
		endif;
	endif;

epilog

	delete bookingStrArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="lostFocusBulkRelease" id="401514cf-b255-46ac-b672-990aa45de5bc">
        <source>lostFocusBulkRelease();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2014	cnwndl1	Initial creation

*/

vars

	relStrArray : CnStringArray;
	str : String;
	bulkRel : CM_BulkRelease;
	

begin

	if self.txtCargoRelId.text.trimBlanks &lt;&gt; null then
		relStrArray := self.txtCargoRelId.text.toUpper.trimBlanks.cnGetTokens(" ");

		if relStrArray &lt;&gt; null then
			foreach str in relStrArray do
				bulkRel := self.myTerminal.allBulkReleasesByCodeDate.getAtKeyGeq( str, "31/12/3000".Date.TimeStamp ).CM_BulkRelease;
				if bulkRel = null or bulkRel.code &lt;&gt; str then
					app.msgBox( app.getErrorString1( No_release_found, str), app.getErrorString(Warning), MsgBox_OK_Only );
					return;
				else
					//found one
					self.chkPickUp.value := true;
				endif;
			endforeach;
		endif;
	endif;

epilog

	delete relStrArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="lostFocusDeliver" id="11ebc326-8df7-493c-bc87-161779849b1a">
        <source>lostFocusDeliver():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Apr 2013	cnwndl1	Initial creation	Par 31393
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
*/

vars

	delim	: String;
	allTiIds : StringArray;
	tiId : String;
	ti : CM_TrackedItem;
	carrier : CM_Carrier;
	tiCarrier : CM_Carrier;
	msg : String;
	
begin

	create allTiIds transient;
	delim := CrLf;
	
	self.txtIdsDeliver.text.asStringArrayByDelimiter( allTiIds, delim);

	if allTiIds.isEmpty then
		return true;
	endif;
	
	carrier := self.cmbCarrier.listObject.CM_Carrier;
	if carrier = null then
		msg := app.getErrorString(Must_select_carrier_first);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	// TFS 51248 validation shifted to the trx layer so web services can share validation
	/*foreach tiId in allTiIds do
		ti := self.myTerminal.lookupTrackedItem(tiId, TI_CargoType_Null, TI_STATE_NOTIFIED, null, true);
		
		if ti &lt;&gt; null then
			if ti.isOnSite then
				// Can't book to deliver cargo already onsite
				ti := null;
			elseif ti.isOnShip then
				// Can't book to deliver cargo already on ship
				ti := null;
			endif;
			if ti &lt;&gt; null then
				tiCarrier := ti.getCarrierReceive;
				if tiCarrier &lt;&gt; null and tiCarrier &lt;&gt; carrier then
					// Can't book to deliver cargo for a different carrier
					ti := null;
				endif;
			endif;
		endif;
		
		if ti = null then
			if msg = null then
				msg := app.getErrorString1(Notif_cargo_item_not_found_sys, tiId );
			else
				msg := msg &amp; CrLf &amp; app.getErrorString1(Notif_cargo_item_not_found_sys, tiId );
			endif;
		else
			self.chkDeliver.value := true;
		endif;
		
	endforeach;
	
	if msg &lt;&gt; null then
		app.msgBox( msg, app.getErrorString(Delivering) &amp; " " &amp; app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	*/
	return true;

epilog

	delete allTiIds;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lostFocusPickup" id="851f4855-8dbe-4738-bd67-c1e81acdbcaf">
        <source>lostFocusPickup():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Apr 2013	cnwndl1	Initial creation	Par 31393
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
*/

vars

	delim	: String;
	allTiIds : StringArray;
	tiId : String;
	ti : CM_TrackedItem;
	carrier : CM_Carrier;
	tiCarrier : CM_Carrier;
	relRequest : CM_YardRequest;
	bulkRelease : CM_BulkRelease;
	msg : String;
	currentVoyages : CM_VoyageSet;
	voyage : CM_Voyage;
	
begin

	create allTiIds transient;
	delim := CrLf;
	
	self.txtIdsPickUp.text.asStringArrayByDelimiter( allTiIds, delim);

	if allTiIds.isEmpty then
		return true;
	endif;
	
	carrier := self.cmbCarrier.listObject.CM_Carrier;
	if carrier = null then
		msg := app.getErrorString(Must_select_carrier_first);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	// TFS 51248 shifted validation to trx layer so web services can share the validation
	/*create currentVoyages transient;
	self.myTerminal.getAllCurrentVoyages( currentVoyages, true, false, false );
	
	foreach tiId in allTiIds do
		ti := null;
		//look for on-site cargo to pick-up
		ti := self.myTerminal.lookupTrackedItem(tiId, TI_CargoType_Null, TI_STATE_NORMAL, null, false);
		if ti &lt;&gt; null and ti.id &lt;&gt; tiId then
			ti := null;
		endif;
		if ti = null then
		//19 May 2015	NDL	Par 35930
			//nothing found on-site, look for cargo on a current voyage that is an import
			foreach voyage in currentVoyages do
				ti := voyage.lookupTrackedItem(tiId, TI_CargoType_Null, false);
				if ti &lt;&gt; null and ti.isImport then
					break;
				endif;
			endforeach;
		endif;
		
		if ti &lt;&gt; null then
			tiCarrier := ti.getCarrierRelease;
			if tiCarrier = null then
				relRequest := ti.releaseRequest;
				if relRequest &lt;&gt; null then
					bulkRelease := relRequest.myOriginatingBulkRelease;
					if bulkRelease &lt;&gt; null then
						tiCarrier := bulkRelease.getCarrier;
					endif;
				endif;
			endif;
			if tiCarrier &lt;&gt; null and tiCarrier &lt;&gt; carrier then
				// Can't book to Pickup cargo for a different carrier
				ti := null;
			endif;
		endif;
		
		if ti = null then
			if msg = null then
				msg := app.getErrorString1(Cargo_item_not_found_not_assig, tiId );
			else
				msg := msg &amp; CrLf &amp; app.getErrorString1(Cargo_item_not_found_not_assig, tiId );
			endif;
		else
			self.chkPickUp.value := true;
		endif;
		
	endforeach;
	
	if msg &lt;&gt; null then
		app.msgBox( msg, app.getErrorString(PickingUp) &amp; " " &amp; app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	*/
	return true;

epilog

	delete allTiIds;
	delete currentVoyages;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCmbTSType" id="15cd5afd-214d-408d-a8c0-5cc438908b37">
        <source>populateCmbTSType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2014	cnwndl1	Initial creation	Par 35008

*/

vars

	tsType : CM_VehicleBookingTimeSlotType;
	index : Integer;
	term : CM_Terminal;
	
begin
	term := self.myTerminal;
	self.cmbTSType.clear();
	self.cmbTSType.addItem( null );
	
	//foreach tsType in app.myRoot.allVehicleBookingTSTypes do			//16.5.2022 navma1 #52351
	foreach tsType in term.allTerminalVBSSlotTypes discreteLock do		//21.06.2022 navma1 #53697
		index := self.cmbTSType.addItem( tsType.description );
		self.cmbTSType.itemObject[index] := tsType;
		if tsType.notAvailableForEntry then
			self.cmbTSType.itemEnabled[index] := false;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyBookingSlot" id="23de6d70-d6bf-480f-947c-850c6702b162">
        <updating/>
        <source>setMyBookingSlot( 	_booking : CM_VehicleBookingTimeSlot;
					_start : TimeStamp;
					_end : TimeStamp
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2013	cnwndl1	Initial creation

*/

vars

begin

	self.myVehicleBooking := _booking;
	if _booking = null then
		if _start &lt;&gt; null then
			self.passedInStartTS := _start;
		else
			self.passedInStartTS := null;
		endif;
		if _end &lt;&gt; null then
			self.passedInEndTS := _end;
		else
			self.passedInEndTS := null;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_booking" type="CM_VehicleBookingTimeSlot"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_end" type="TimeStamp"/>
    </JadeMethod>
