    <JadeMethod name="convertBaseToTarget" id="fd2fc676-bd46-47ef-a49e-5ef4abf9c90e">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.BTU_IT then
		convertedMeasure	:=	pMeasure / 1055.056;
	
	elseif pUnitTo = self.BTU_MEAN then
		convertedMeasure	:=	pMeasure / 1055.87;
	
	elseif pUnitTo = self.BTU_TH then
		convertedMeasure	:=	pMeasure / 1054.350;
	
	elseif pUnitTo = self.CALORIES_15C then
		convertedMeasure	:=	pMeasure / 4.18580;
	
	elseif pUnitTo = self.CALORIES_20C then
		convertedMeasure	:=	pMeasure / 4.18190;
	
	elseif pUnitTo = self.CALORIES_FOOD then
		convertedMeasure	:=	pMeasure / 4186;
	
	elseif pUnitTo = self.CALORIES_IT then
		convertedMeasure	:=	pMeasure / 4.1868;
	
	elseif pUnitTo = self.CALORIES_MEAN then
		convertedMeasure	:=	pMeasure / 4.19002;
	
	elseif pUnitTo = self.CALORIES_TH then
		convertedMeasure	:=	pMeasure / 4.184;
	
	elseif pUnitTo = self.CENTIGRADE_HEAT_UNITS then
		convertedMeasure	:=	pMeasure / 1900.4;
	
	elseif pUnitTo = self.ERGS then
		convertedMeasure	:=	pMeasure * 10000000;
	
	elseif pUnitTo = self.FOOT_POUNDALS then
		convertedMeasure	:=	pMeasure / 0.042140;
	
	elseif pUnitTo = self.FOOT_POUNDS_OF_FORCE then
		convertedMeasure	:=	pMeasure / 1.355818;
	
	elseif pUnitTo = self.GIGAJOULES then
		convertedMeasure	:=	pMeasure / 1000000000;
	
	elseif pUnitTo = self.HORSEPOWER_HOURS then
		convertedMeasure	:=	pMeasure / 2684520;
	
	elseif pUnitTo = self.JOULES then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.KILOCALORIES_IT then
		convertedMeasure	:=	pMeasure / 4186.8;
	
	elseif pUnitTo = self.KILOCALORIES_TH then
		convertedMeasure	:=	pMeasure / 4184;
	
	elseif pUnitTo = self.KILOJOULES then
		convertedMeasure	:=	pMeasure / 1000;
	
	elseif pUnitTo = self.KILOWATT_HOURS then
		convertedMeasure	:=	pMeasure / 3600000;
	
	elseif pUnitTo = self.MEGAJOULES then
		convertedMeasure	:=	pMeasure / 1000000;
	
	elseif pUnitTo = self.NEWTON_METRES then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.THERMS then
		convertedMeasure	:=	pMeasure / 105500000;
	
	elseif pUnitTo = self.WATT_HOURS then
		convertedMeasure	:=	pMeasure;
	
	elseif pUnitTo = self.WATT_SECONDS then
		convertedMeasure	:=	pMeasure / 3600;
	
	else
		JSSException.raise_(JSS_X_03004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of energy to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="a4f3bf03-ec58-4578-ae19-82be0bb2ae54">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		27 May 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.BTU_IT then
		convertedMeasure	:=	self.measure * 1055.056;
	
	elseif pUnitFrom = self.BTU_MEAN then
		convertedMeasure	:=	self.measure * 1055.87;
	
	elseif pUnitFrom = self.BTU_TH then
		convertedMeasure	:=	self.measure * 1054.350;
	
	elseif pUnitFrom = self.CALORIES_15C then
		convertedMeasure	:=	self.measure * 4.18580;
	
	elseif pUnitFrom = self.CALORIES_20C then
		convertedMeasure	:=	self.measure * 4.18190;
	
	elseif pUnitFrom = self.CALORIES_FOOD then
		convertedMeasure	:=	self.measure * 4186;
	
	elseif pUnitFrom = self.CALORIES_IT then
		convertedMeasure	:=	self.measure * 4.1868;
	
	elseif pUnitFrom = self.CALORIES_MEAN then
		convertedMeasure	:=	self.measure * 4.19002;
	
	elseif pUnitFrom = self.CALORIES_TH then
		convertedMeasure	:=	self.measure * 4.184;
	
	elseif pUnitFrom = self.CENTIGRADE_HEAT_UNITS then
		convertedMeasure	:=	self.measure * 1900.4;
	
	elseif pUnitFrom = self.ERGS then
		convertedMeasure	:=	self.measure / 10000000;
	
	elseif pUnitFrom = self.FOOT_POUNDALS then
		convertedMeasure	:=	self.measure * 0.042140;
	
	elseif pUnitFrom = self.FOOT_POUNDS_OF_FORCE then
		convertedMeasure	:=	self.measure * 1.355818;
	
	elseif pUnitFrom = self.GIGAJOULES then
		convertedMeasure	:=	self.measure * 1000000000;
	
	elseif pUnitFrom = self.HORSEPOWER_HOURS then
		convertedMeasure	:=	self.measure * 2684520;
	
	elseif pUnitFrom = self.JOULES then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.KILOCALORIES_IT then
		convertedMeasure	:=	self.measure * 4186.8;
	
	elseif pUnitFrom = self.KILOCALORIES_TH then
		convertedMeasure	:=	self.measure * 4184;
	
	elseif pUnitFrom = self.KILOJOULES then
		convertedMeasure	:=	self.measure * 1000;
	
	elseif pUnitFrom = self.KILOWATT_HOURS then
		convertedMeasure	:=	self.measure * 3600000;
	
	elseif pUnitFrom = self.MEGAJOULES then
		convertedMeasure	:=	self.measure * 1000000;
	
	elseif pUnitFrom = self.NEWTON_METRES then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.THERMS then
		convertedMeasure	:=	self.measure * 105500000;
	
	elseif pUnitFrom = self.WATT_HOURS then
		convertedMeasure	:=	self.measure;
	
	elseif pUnitFrom = self.WATT_SECONDS then
		convertedMeasure	:=	self.measure * 3600;
	
	else
		JSSException.raise_(JSS_X_03003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of energy to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
</Class>
