			beginLoad;
			pxyObj := object.pxyCreateUpdateProxy;
			endLoad;
			pxyColl := pxyObj.getPropertyValue(propname).Collection;
			if pxyColl = null then
				app.writeLog('640 '&amp;object.class.name&amp;' propName='&amp;propname&amp;' aClass='&amp;aClass.name&amp;' coll size='&amp;coll.size.String&amp;' new collection does not exist', LogERROR);
				count += 1;
			elseif coll.size &lt;&gt; pxyColl.size then
				app.writeLog('640 '&amp;object.class.name&amp;' propName='&amp;propname&amp;' aClass='&amp;aClass.name&amp;' coll size='&amp;coll.size.String&amp;' pxyColl size='&amp;pxyColl.size.String&amp;' size mismatch needs checking.', LogERROR);
				count += 1;
