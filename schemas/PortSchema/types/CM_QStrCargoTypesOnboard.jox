<Class name="CM_QStrCargoTypesOnboard" id="89f50562-0eee-431b-a10d-cc3f1a40a25e">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="setComboValues" id="0cfb42ba-4449-4403-8dea-b25bc80b8629">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 May 2024
TFS#		: 63961
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	cargoBOLType	: CM_CargoBOLType;
	cargoTypeDict	: Collection;
	os				: ObjectSet;
	iter 			: Iterator;
	current 		: Any;
begin
	_combo.clear();
	cargoTypeDict := app.myRoot.allCargoTypesById;
	
	create os transient;
	_params.getTerminals(os,_passport);
	
	current:=_queryOperator.getSearchValue();

	iter:=cargoTypeDict.createIterator;
	while iter.next(cargoBOLType) do
		
		if cargoBOLType.id &gt; TI_CargoBOLType_JMTMax and not app.myRoot.isClientCentrePort then	
			continue;																			
		endif;																					
		
		if os.size &gt; 0 and cargoBOLType.isKindOf(CM_CargoType) and not os.includesAny(cargoBOLType.allTerminals) then
			continue;
		endif;
		_combo.itemObject[_combo.addItem(cargoBOLType.description)] := cargoBOLType;
		if cargoBOLType.description = current.asString then
			_combo.listObject:=cargoBOLType;
		endif;
	endwhile;	
	
epilog
	delete iter;
	delete os;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="9b5a25f3-e08a-4a58-8196-0582f35ef7c2">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 May 2024
TFS#		: 63961
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	cargoBOLType		: CM_CargoBOLType;
	selectionValue		: Integer;
	idx					: Integer;
begin
	
	_tbl.clear();
	_tbl.rows := 0;
	
	foreach cargoBOLType in app.myRoot.allCargoTypesByDescription do
		if not cargoBOLType.isKindOf(CM_CargoType) then
			continue;
		endif;
		
		selectionValue := 0;
		if _operator &lt;&gt; null then
			if _operator.CM_QStringLookupIsOneOf.allSelectionValues.includes(cargoBOLType.description) then
				selectionValue := 1;
			endif;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; cargoBOLType.description);
		_tbl.accessRow(idx).itemObject := cargoBOLType.CM_CargoType;
		_tbl.row := idx;
		_tbl.change(_tbl); 
	endforeach;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="af237229-c885-410d-ad63-e53e387814dd">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 May 2024
TFS#		: 63961
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/


vars
	cargoType	: CM_CargoType;
	str			: String;
	numRows,
	idx			: Integer;
	ia			: StringArray;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			cargoType := _tbl.accessRow(idx).itemObject.CM_CargoType;			
			ia.add(cargoType.description);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="79e923c5-7b84-43c2-8149-e876d35b58a5">
        <source>translateToDisplayValue(_value: Any): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 May 2024
TFS#		: 63961
Function	:

*** Changes ***
Date			Name		TFS#		Description
20/05/2024	jlika1	TFS 64730 CUX | Selector Query Onboard Cargo Type is not getting displayed in Data table
****************************************************/
vars
	object 		: CM_CargoType;
	invalidObj 	: Boolean;
	returnVal	: String;
	
begin	
	if _value &lt;&gt; null then
		return _value.String;
	endif;
	
	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="b9efe635-e540-453c-bdb4-04343e717b58">
        <source>translateToSearchValue(_value: Any): Any;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 May 2024
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	invalidObj 		: Boolean;
	object			: CM_CargoBOLType;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			
			return _value;
		endif;
		
		if _value.isKindOf(CM_CargoBOLType) then //epr TFS 47132 16/12/19
			object := _value.CM_CargoBOLType;
		elseif _value.isKindOf(Integer) then						// TFS 45769
			object:= app.myRoot.allCargoTypesById[_value.Integer]; 	// TFS 45769
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.description;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
