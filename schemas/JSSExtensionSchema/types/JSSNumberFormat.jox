    <JadeMethod name="getNumberFormat" id="d0e33247-a7f9-4985-9979-b99014b3ea3d">
        <source>getNumberFormat(pTheNumberFormat:NumberFormat io);
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	pTheNumberFormat.decimalPlaces		:=	self.decimalPlaces;
	pTheNumberFormat.decimalSeparator	:=	self.decimalSeparator;
	pTheNumberFormat.groupings			:=	self.groupings;
	pTheNumberFormat.negativeFormat		:=	self.negativeFormat;
	pTheNumberFormat.negativeSign		:=	self.negativeSign;
	pTheNumberFormat.positiveSign		:=	self.positiveSign;
	pTheNumberFormat.showLeadingZeros	:=	self.showLeadingZeros;
	pTheNumberFormat.thousandSeparator	:=	self.thousandSeparator;
end;</source>
        <Parameter name="pTheNumberFormat" type="NumberFormat" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="ec81bf2b-6ced-48a4-a22f-c7212e41eeae">
        <updating/>
        <source>updateMe(pTheNumberFormat:NumberFormat) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.decimalPlaces		:=	pTheNumberFormat.decimalPlaces;
	self.decimalSeparator	:=	pTheNumberFormat.decimalSeparator;
	self.groupings			:=	pTheNumberFormat.groupings;
	self.negativeFormat		:=	pTheNumberFormat.negativeFormat;
	self.negativeSign		:=	pTheNumberFormat.negativeSign;
	self.positiveSign		:=	pTheNumberFormat.positiveSign;
	self.showLeadingZeros	:=	pTheNumberFormat.showLeadingZeros;
	self.thousandSeparator	:=	pTheNumberFormat.thousandSeparator;
end;</source>
        <Parameter name="pTheNumberFormat" type="NumberFormat"/>
    </JadeMethod>
</Class>
