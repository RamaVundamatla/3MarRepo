    <JadeMethod name="hasWSDL112BgpForLine" id="26d40b31-729b-4af0-a56b-c18ed0d6d71e">
        <source>hasWSDL112BgpForLine( _invLine : CM_InvoiceLine ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2019	jlgndl1	Initial creation	TFS 44248

*/

vars

	bgpRequest : BGP_Request;
	bgpSAPRequest : BGP_SAPWSRequest;
	iter : Iterator;

begin

	if self.allSapRequests.isEmpty then
		return false;
	endif;
	
	iter := self.allSapRequests.createIterator;
	while iter.next( bgpRequest ) do
		if bgpRequest.isSAPWSRequest then
			bgpSAPRequest := bgpRequest.BGP_SAPWSRequest;
			if bgpSAPRequest.isSAPPreBillProdDataReq then// i.e.	WSDL112
				if bgpSAPRequest.allInvoiceLines.includes( _invLine ) then
					return true;
				endif;
			endif;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="incrementExportCount" id="3c769011-5a2c-4c38-9b95-ad764d65e733">
        <updating/>
        <source>incrementExportCount(_ignoreVoided : Boolean)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle

*/

vars
	ignoreVoided : Boolean;
	invLine      : CM_InvoiceLine;
begin
	ignoreVoided := _ignoreVoided;
	if process.isInTransactionState then
		self.exportedCount := self.exportedCount + 1 ;
		
		foreach invLine in self.invoiceLines discreteLock do 
			if not ignoreVoided then
				if invLine.voided then
					if not self.isReverseCredit then
						continue;
					endif;
				endif;
			endif;
			invLine.incrementExportCount();
		endforeach;
	else
		app.myTrxUA.trxIncrementInvoiceExportCount(self,ignoreVoided, app.myPassport);
	endif;
epilog

end;</source>
        <Parameter name="_ignoreVoided" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="dafa5325-4295-4c34-8022-a67046eeecdf">
        <updating/>
        <source>initialise(	theBusinessUnit   : CM_Bank;
			theInvoiceType    : CM_InvoiceDesc;
			theDebtor 	      : CM_Debtor;
			tran 		      : CM_TITransaction;
			_forcedStatusOpen : Boolean;
			_paymentType      : Integer
			) updating;
// 05/04/2013	cnwcs5	CCMS POL 2097 / par 31259
// 22/09/2015	cnwdap1	PAR #36909 CCMS ADP 2537 Minimum Charge changes
// 26/07/2017	cnwdap1	TFS 5397 PKT Merge transaction showing wrong quantity on invoice line 
// 08/06/2020   cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 03/09/2020   cnwma1  Bug 49996: ASPA - Voyage Group Code - Issues
// 18/08/2022	navpw1	TFS: 54564 (54375) - EUP - Inv Config - Debtor Currencies and Countries
// 13/09/2022	navpw1	TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
vars
	cargoSpecific, 
	foundMatch				    : Boolean;
	debtorRef					: String;
	vesselName, 
	voyageCode					: String;
	voyage						: CM_Voyage;
	debtorInvType				: CM_DebtorInvType;
	operator					: CM_Operator;
	dateTime					: TimeStamp;
	finIOClass 					: CM_ExtFinanceIO;
	bolOutSet					: CM_BOLSet;						// PAR #36909
	debtorTerminal				: CM_DebtorTerminal;				// ### TFS 54564 (54375) 19Aug2022 NAVPW1
	releaseRequest				: CM_BulkRelease;					// ### TFS 54565 (54384) 21Sep2022 NAVPW1
	ti : CM_TrackedItem;
	debtorSep : CM_InvTypeDebtorSeparation;
begin
	self.bank 			  := theBusinessUnit;
	self.setMyInvoiceProcess( theBusinessUnit.getMyInvoiceProcess ); // TFS 39618
	self.sequenceNum      := bank.getSeqNum(SN_INVOICE);
	self.paymentType      := _paymentType; //10 Oct 2018	NDL	TFS 41281
	self.debtor           := theDebtor;
	self.invoiceType      := theInvoiceType;
	self.status 		  := -1;// TFS 39618 PATCH 1 to trigger OPEN status email
	
	// ### TFS 54564 (54375) 19Aug2022 NAVPW1
	debtorTerminal := theDebtor.allDebtorTerminals[app.myPassport.myTerminal];
	
	if debtorTerminal &lt;&gt; null then
		self.myCurrencyType := debtorTerminal.myCurrencyType;
		self.myLocale		:= debtorTerminal.myLocale;
	endif;
	
	// ### TFS 54564 (54375) 19Aug2022 NAVPW1
	
	if theDebtor.getDefaultDebtorAddress() &lt;&gt; null then
		self.myBillingAddress := theDebtor.getDefaultDebtorAddress();
	endif;
	
	if tran &lt;&gt; null then // ### BUG 56925 07MAR2023 NAVAB1
		ti := tran.myTrackedItem; // ### BUG 56925 07MAR2023 NAVAB1
	endif;
	debtorSep := self.invoiceType.getDebtorSeparation(self.debtor); // ### BUG 56925 07MAR2023 NAVAB1
	
	// ### PAR 36323
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass.setExternalOnCreate() then
		self.setExternalInvoiceNumber(finIOClass.setExternalInvoiceNumber(self));
	endif;

	self.setStatus( self.invoiceType.getStatusForNewInvoice( _forcedStatusOpen ) );	//13 Jun 2018 NDL TFS 39197
	// CCMS 1280
	//cargoSpecific := self.invoiceType.isCargoItemSpecific();
	 // ### BUG 56925 07MAR2023 NAVAB1 cargoSpecific := self.invoiceType.isCargoItemSpecificDebtor(self.debtor);		// ### TFS 54565 (54384) 22Sep2022 NAVPW1
	cargoSpecific := self.invoiceType.isCargoSpecificSeparation(debtorSep); // ### BUG 56925 07MAR2023 NAVAB1
	
	/*
	//if (invoiceType.isVoyageSpecific
	if (invoiceType.isVoyageSpecificDebtor(self.debtor)								// ### TFS 54565 (54384) 22Sep2022 NAVPW1
		//or invoiceType.isVoyageGroupSpecific										// ### TFS 51219 25MAY2021 NAVAB1
		or invoiceType.isVoyageGroupSpecificDebtor(self.debtor)						// ### TFS 51219 25MAY2021 NAVAB1 // ### TFS 54565 (54384) 22Sep2022 NAVPW1
		)																			// ### TFS 54565 (54384) 13Sep2022 NAVPW1
		*/
	if self.invoiceType.isVoyageGrpSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
	or self.invoiceType.isVoyageSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1
	and ti &lt;&gt; null then // ### BUG 56925 07MAR2023 NAVAB1
		// 37558 Feb 2016 get tranship voyage from transaction to match the code in bank.getMatchingInvoice
		if ti.isTranshipItem  then
			voyage := tran.getVoyage();
		endif;
		if voyage = null then
			voyage := ti.myVoyage;
		endif;
		self.myVoyage := voyage;
		if self.myVoyage &lt;&gt; null then
			self.vesselName	     := self.myVoyage.vesselName;
			self.voyageGroupCode := self.myVoyage.voyageGroupCode;  //03/06/2020 cnwma1 Tfs #49400
			// CPL CCMS 2120 Nov 2011 use debtor invoice type default debtor ref to XL voyage option
			debtorInvType        := self.debtor.allDebtorInvTypes[invoiceType];
			if debtorInvType &lt;&gt; null then
				if debtorInvType.defaultDebtorRefTo = DfltDbtrRef_XlatedVoyageCode then
					voyageCode := self.myVoyage.code;
					vesselName := self.vesselName;
					foreach operator in theDebtor.operators do
						debtorRef := operator.getXlationSystemCode_Voyage(voyageCode, vesselName, null, null, foundMatch);	// par 31259
						
						if debtorRef &lt;&gt; null then
							self.debtorReference := debtorRef[1:30];
							break;
						endif;
					endforeach;
				endif;
			endif;
		endif;
	endif;
	
	if cargoSpecific and ti &lt;&gt; null then // ### BUG 56925 07MAR2023 NAVAB1
		self.myTrackedItem := ti;
	endif;
	// TFS 5397 For Merge where one TI has been merged into another TI					// TFS 5397
	// (NOT the same ID), we want the invoice lines to belong to the TI					// TFS 5397
	// we're merging into																// TFS 5397
	if ti &lt;&gt; null and tran.isKindOf(CM_Merge)			// TFS 5397
	and ((ti.totalWeight = null and ti.isBulkByWeight) 	// TFS 5397
	or (ti.totalVolume = null and ti.isBulkByVolume))	// TFS 5397
	and tran.CM_Merge.getOtherTrackedItem &lt;&gt; null then									// TFS 5397
		self.myTrackedItem := tran.getOtherTrackedItem;									// TFS 5397
	endif;																				// TFS 5397
	
	//if invoiceType.isBOLSpecific and ti &lt;&gt; null then // ### BUG 56925 07MAR2023 NAVAB1			// PAR #36909
	if self.invoiceType.isBOLSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if (invoiceType.isBOLSpecificDebtor(self.debtor))											// ### TFS 54565 (54384) 14Sep2022 NAVPW1
	and ti &lt;&gt; null then // ### BUG 56925 07MAR2023 NAVAB1										// PAR #36909
		self.myTrackedItem := ti;												// PAR #36909
		if self.myTrackedItem.billOfLading &lt;&gt; null then											// PAR #36909
			self.myBOL := self.myTerminal.getBOLInByNumber(	self.myTrackedItem.billOfLading, 	// PAR #36909
															BOLType_GeneralBillOfLading	);		// PAR #36909
			if self.myBOL = null then															// PAR #36909
				create bolOutSet transient;														// PAR #36909
				self.myTerminal.getBOLOutsFromNumber(	bolOutSet, 								// PAR #36909
														BOLType_GeneralBillOfLading,			// PAR #36909
														self.myTrackedItem.billOfLading, 		// PAR #36909
														true,									// PAR #36909
														null	);								// PAR #36909
				if not bolOutSet.isEmpty then													// PAR #36909
					self.myBOL := bolOutSet.first;												// PAR #36909
				endif;																			// PAR #36909
				delete bolOutSet;																// PAR #36909
			endif;																				// PAR #36909
			
			// 03.09.2020 cnwma1 #49996
			if self.myBOL &lt;&gt; null  then
				voyage := self.myBOL.getMyVoyage();
			endif;
			
			// 22.09.2020 cnwma1 #49996
			if voyage = null                        
			and self.myTrackedItem &lt;&gt; null then
				voyage := self.myTrackedItem.myVoyage;
			endif;
			
			if voyage &lt;&gt; null then
				self.myVoyage 		 := voyage;
				self.vesselName	     := voyage.vesselName;
				self.voyageGroupCode := voyage.voyageGroupCode;
			endif;
			// 03.09.2020 cnwma1 #49996
			
		endif;																					// PAR #36909
	endif;																						// PAR #36909
	
	// ### TFS 54565 (54384) 21Sep2022 NAVPW1
	
	//separatedByBooking
	if self.invoiceType.isBookingSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isBookingSpecificDebtor(self.debtor)
	and ti &lt;&gt; null then // ### BUG 56925 07MAR2023 NAVAB1
		self.myBookingRef := ti.myBookingRef;
		
	endif;
	
	//separatedByCargoGroupId
	if self.invoiceType.isCargoGroupSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isCargoGroupSpecificDebtor(self.debtor)
	and ti &lt;&gt; null then // ### BUG 56925 07MAR2023 NAVAB1
		self.myCargoGroup := ti.myCargoGroup;
		
	endif;
	
	//separatedByReleaseRequest
	if self.invoiceType.isReleaseSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isReleaseSpecificDebtor(self.debtor)
	and ti &lt;&gt; null then // ### BUG 56925 07MAR2023 NAVAB1
		releaseRequest := ti.allBulkReleasesReleased.first;
		
		if releaseRequest = null then
			releaseRequest := ti.allBulkReleasesAssigned.first;
		endif;
		
		self.myReleaseRequest := releaseRequest;
	endif;
	
	 // ### BUG 56925 07MAR2023 NAVAB1
	if self.invoiceType.isPONumberSpecificSeparation(debtorSep)
	and ti &lt;&gt; null then
		self.purchaseOrderNumber := ti.purchaseOrder;
	endif;
	
	// ### TFS 54565 (54384) 21Sep2022 NAVPW1
	
	// set from and to date times
	if tran = null then
		dateTime := app.serverTimestampAtTrxStart;
	else
		dateTime := tran.dateTime;
	endif;
	
	//if invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
	if invoiceType.hasDebtorSeparationAccrual(self.debtor) or invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then	// ### TFS 54565 (54384) 06Oct2022 NAVPW1
		// 23510 debtor billing period, debtor parameter added
		fromDT := app.myRoot.myRootCompany.getPeriodEndDateInitialise(theDebtor,invoiceType, dateTime,false); // CCMS 1125 // PAR 8189
		toDT := app.myRoot.myRootCompany.getPeriodEndDateInitialise(theDebtor,invoiceType, dateTime,true); // CCMS 1125 // PAR 8189
	else
		fromDT := dateTime;
	endif;
	// narration generation
	narration := invoiceType.generateNarration(self);
	
    self.setDetailCode();  // ### TFS 51219 25MAY2021 NAVAB1
	
epilog
	delete bolOutSet;											// PAR #36909
	
end;</source>
        <Parameter name="theBusinessUnit" type="CM_Bank"/>
        <Parameter name="theInvoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="theDebtor" type="CM_Debtor"/>
        <Parameter name="tran" type="CM_TITransaction"/>
        <Parameter name="_forcedStatusOpen" type="Boolean"/>
        <Parameter name="_paymentType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialiseAllSeparations" id="4204b55f-65d4-4c1d-82f2-3d3615d525b1">
        <updating/>
        <source>initialiseAllSeparations(
					theDebtor			: CM_Debtor;
					theVoyage		 	: CM_Voyage;
					_ti					: CM_TrackedItem;
					_bol				: CM_BOL;
					_booking			: CM_BookingRef;
					_cargoGroup			: CM_CargoGroup;
					_releaseRequest		: CM_BulkRelease;
					_poNumber : String
					) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type

*/

vars
	cargoSpecific, 
	foundMatch		: Boolean;
	debtorRef		: String;
	vesselName,
	voyageCode		: String;
	debtorInvType	: CM_DebtorInvType;
	operator		: CM_Operator;
	now             : TimeStamp;
	finIOClass 		: CM_ExtFinanceIO;
	debtorSep 		: CM_InvTypeDebtorSeparation;
begin
	if theVoyage &lt;&gt; null then
		self.myVoyage 		 := theVoyage;
		self.vesselName 	 := self.myVoyage.vesselName;
		self.voyageGroupCode := self.myVoyage.voyageGroupCode;
		debtorInvType := self.debtor.allDebtorInvTypes[invoiceType];
		if debtorInvType &lt;&gt; null then
			if debtorInvType.defaultDebtorRefTo = DfltDbtrRef_XlatedVoyageCode then
				voyageCode := self.myVoyage.code;
				vesselName := self.vesselName;
				foreach operator in theDebtor.operators do
					debtorRef := operator.getXlationSystemCode_Voyage(voyageCode, vesselName, null, null, foundMatch);
					if debtorRef &lt;&gt; null then
						self.debtorReference := debtorRef[1:30];
						break;
					endif;
				endforeach;
			endif;
		endif;
	endif;
	
	self.myTrackedItem := _ti;
	
	if _bol &lt;&gt; null then
		self.myBOL := _bol;
	endif;
	
	if _booking &lt;&gt; null then
		self.myBookingRef := _booking;
	endif;
	
	if _cargoGroup &lt;&gt; null then
		self.myCargoGroup := _cargoGroup;
	endif;
	
	if _releaseRequest &lt;&gt; null then
		self.myReleaseRequest := _releaseRequest;
	endif;
	
	self.purchaseOrderNumber := _poNumber;
	
epilog

end;</source>
        <Parameter name="theDebtor" type="CM_Debtor"/>
        <Parameter name="theVoyage" type="CM_Voyage"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
        <Parameter name="_releaseRequest" type="CM_BulkRelease"/>
        <Parameter name="_poNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseBOL" id="0f3dfce8-35a7-4eab-a178-1306c424b065">
        <updating/>
        <source>initialiseBOL(	theBusinessUnit: CM_Bank;
				theInvoiceType: CM_InvoiceDesc;
				theDebtor: CM_Debtor;
				_bolTransaction : CM_BOLTransaction;
				_paymentType : Integer
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100
08/06/2020 			cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
30 May  2025 navrv30 MTN 34789 MTN | Query by BOL option doesn't return results for BOL-generated invoices
*/

vars
	debtorRef	    : String;
	vesselName,
	voyageCode	    : String;
	debtorInvType	: CM_DebtorInvType;
	operator	    : CM_Operator;
	foundMatch	    :Boolean;
	ts 				: TimeStamp;
	finIOClass 		: CM_ExtFinanceIO;
	debtorSep 		: CM_InvTypeDebtorSeparation;
begin
	self.bank 			  := theBusinessUnit;
	self.setMyInvoiceProcess( theBusinessUnit.getMyInvoiceProcess ); // TFS 39618	
	self.sequenceNum 	  := bank.getSeqNum(SN_INVOICE);
	self.debtor 		  := theDebtor;
	self.invoiceType 	  := theInvoiceType;
	self.status  		  := -1;// TFS 39618 PATCH 1 to trigger OPEN status email
	self.paymentType 	  := _paymentType; //10 Oct 2018	NDL	TFS 41281
	
	self.setStatus( INVOICE_OPEN );	//13 Jun 2018	NDL	TFS 39197
	debtorSep := self.invoiceType.getDebtorSeparation(self.debtor);
	// ### TFS 41026
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass.setExternalOnCreate() then
		self.setExternalInvoiceNumber(finIOClass.setExternalInvoiceNumber(self));
	endif;
	//30 May  2025 navrv30 MTN 34789
	if self.invoiceType.isBOLSpecificSeparation(debtorSep) then
		self.myBOL := _bolTransaction.myBOL;
	endif;
	self.myVoyage := _bolTransaction.getMyVoyageObject();
	if self.myVoyage &lt;&gt; null then
		self.vesselName      := self.myVoyage.vesselName;
		self.voyageGroupCode := self.myVoyage.voyageGroupCode;  //03/06/2020 cnwma1 Tfs #49400
		debtorInvType        := self.debtor.allDebtorInvTypes[invoiceType];
		if debtorInvType &lt;&gt; null then
			if debtorInvType.defaultDebtorRefTo = DfltDbtrRef_XlatedVoyageCode then
				voyageCode := self.myVoyage.code;
				vesselName := self.vesselName;
				foreach operator in theDebtor.operators do
					debtorRef := operator.getXlationSystemCode_Voyage(voyageCode, vesselName, null, null, foundMatch);	// par 31259
					if debtorRef &lt;&gt; null then
						self.debtorReference := debtorRef[1:30];
						break;
					endif;
				endforeach;
			endif;
		endif;
	endif;
	

	ts := app.serverTimestampAtTrxStart;
	
	// set from and to date times
	//if invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
	if invoiceType.hasDebtorSeparationAccrual(self.debtor) or invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then // ### TFS 54565 (54384) 06Oct2022 NAVPW1
		fromDT := app.myRoot.myRootCompany.getPeriodEndDateInitialise(theDebtor,invoiceType,ts,false); 
		toDT := app.myRoot.myRootCompany.getPeriodEndDateInitialise(theDebtor,invoiceType,ts,true); 
	else
		fromDT := ts;
	endif;
	// narration generation
	narration := invoiceType.generateNarration(self);
epilog
	
end;</source>
        <Parameter name="theBusinessUnit" type="CM_Bank"/>
        <Parameter name="theInvoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="theDebtor" type="CM_Debtor"/>
        <Parameter name="_bolTransaction" type="CM_BOLTransaction"/>
        <Parameter name="_paymentType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialiseEvent" id="f32c31f0-6d92-403e-8eab-28de5895d14a">
        <updating/>
        <source>initialiseEvent(	theBusinessUnit : CM_Bank;
					theInvoiceType  : CM_InvoiceDesc;
					theDebtor       : CM_Debtor;
					tran		    : CM_EventTransaction;
					_paymentType    : Integer
					) updating;
// 05/04/2013	cnwcs5	CCMS POL 2097 / par 31259
// 08/06/2020   cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 13/09/2022	navpw1	TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
vars
	debtorRef,
	vesselName,
	voyageCode		: String;
	debtorInvType	: CM_DebtorInvType;
	operator		: CM_Operator;
	foundMatch		: Boolean;
	finIOClass		: CM_ExtFinanceIO;
	bolOutSet		: CM_BOLSet;		// ### TFS 54565 (54384) 23Sep2022 NAVPW1
	voyage			: CM_Voyage;		// ### TFS 54565 (54384) 23Sep2022 NAVPW1
	releaseRequest	: CM_BulkRelease;	// ### TFS 54565 (54384) 23Sep2022 NAVPW1
	debtorSep : CM_InvTypeDebtorSeparation;
	
begin
	self.bank 			  := theBusinessUnit;
	self.setMyInvoiceProcess( theBusinessUnit.getMyInvoiceProcess ); // TFS 39618	
	self.sequenceNum 	  := bank.getSeqNum(SN_INVOICE);
	self.debtor 		  := theDebtor;
	self.invoiceType 	  := theInvoiceType;
	self.paymentType 	  := _paymentType; //10 Oct 2018	NDL	TFS 41281
	self.status 		  := -1;// TFS 39618 PATCH 1 to trigger OPEN status email
	debtorSep := self.invoiceType.getDebtorSeparation(self.debtor); // ### BUG 56925 07MAR2023 NAVAB1
	
	self.setStatus( INVOICE_OPEN );	//13 Jun 2018	NDL	TFS 39197
	
	// ### TFS 41026
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass.setExternalOnCreate() then
		self.setExternalInvoiceNumber(finIOClass.setExternalInvoiceNumber(self));
	endif;

	//if (self.invoiceType.isVoyageSpecific
	if self.invoiceType.isVoyageSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if (self.invoiceType.isVoyageSpecificDebtor(self.debtor)				// ### TFS 54565 (54384) 22Sep2022 NAVPW1
		//or self.invoiceType.isVoyageGroupSpecific) then					// ### TFS 51219 25MAY2021 NAVAB1
		or self.invoiceType.isVoyageGrpSpecificSeparation(debtorSep) then	// ### TFS 51219 25MAY2021 NAVAB1 // ### TFS 54565 (54384) 22Sep2022 NAVPW1
		// ### TFS 51219 25MAY2021 NAVAB1or self.invoiceType.isVoyageGroupSpecificDebtor(self.debtor) then	// ### TFS 51219 25MAY2021 NAVAB1 // ### TFS 54565 (54384) 22Sep2022 NAVPW1
		self.myVoyage := tran.getVoyage();
		if self.myVoyage &lt;&gt; null then
			self.vesselName      := self.myVoyage.vesselName;
			self.voyageGroupCode := self.myVoyage.voyageGroupCode;  //03/06/2020 cnwma1 Tfs #49400
			// CPL CCMS 2120 Nov 2011 use debtor invoice type default debtor ref to XL voyage option
			debtorInvType := self.debtor.allDebtorInvTypes[invoiceType];
			if debtorInvType &lt;&gt; null then
				if debtorInvType.defaultDebtorRefTo = DfltDbtrRef_XlatedVoyageCode then
					voyageCode := self.myVoyage.code;
					vesselName := self.vesselName;
					foreach operator in theDebtor.operators do
						debtorRef := operator.getXlationSystemCode_Voyage(voyageCode, vesselName, null, null, foundMatch);	// par 31259
						if debtorRef &lt;&gt; null then
							self.debtorReference := debtorRef[1:30];
							break;
						endif;
					endforeach;
				endif;
			endif;
		endif;
	endif;																// ### TFS 54565 (54384) 23Sep2022 NAVPW1
	//elseif self.invoiceType.isCargoItemSpecific() then
	if self.invoiceType.isCargoSpecificSeparation(debtorSep) then // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if self.invoiceType.isCargoItemSpecificDebtor(self.debtor) then		// ### TFS 54565 (54384) 22Sep2022 NAVPW1
		self.myTrackedItem := tran.getTrackedItem();
	endif;

	// ### TFS 54565 (54384) 21Sep2022 NAVPW1
	
	if self.invoiceType.isBOLSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isBOLSpecificDebtor(self.debtor)
	and tran.getTrackedItem() &lt;&gt; null then
		self.myTrackedItem := tran.getTrackedItem();
		if self.myTrackedItem.billOfLading &lt;&gt; null then
			self.myBOL := self.myTerminal.getBOLInByNumber(	self.myTrackedItem.billOfLading,
															BOLType_GeneralBillOfLading	);
			if self.myBOL = null then
				create bolOutSet transient;
				self.myTerminal.getBOLOutsFromNumber(	bolOutSet,
														BOLType_GeneralBillOfLading,
														self.myTrackedItem.billOfLading,
														true,
														null	);
				if not bolOutSet.isEmpty then
					self.myBOL := bolOutSet.first;
				endif;
				delete bolOutSet;
			endif;
			
			if self.myBOL &lt;&gt; null  then
				voyage := self.myBOL.getMyVoyage();
			endif;
			
			if voyage = null                        
			and self.myTrackedItem &lt;&gt; null then
				voyage := self.myTrackedItem.myVoyage;
			endif;
			
			if voyage &lt;&gt; null then
				self.myVoyage 		 := voyage;
				self.vesselName	     := voyage.vesselName;
				self.voyageGroupCode := voyage.voyageGroupCode;
			endif;
			
		endif;
	endif;
	
	//separatedByBooking
	if self.invoiceType.isBookingSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isBookingSpecificDebtor(self.debtor)
	and tran.getTrackedItem() &lt;&gt; null  then
		self.myTrackedItem := tran.getTrackedItem();
		self.myBookingRef := tran.getTrackedItem.myBookingRef;
		
	endif;
	
	//separatedByCargoGroupId
	if self.invoiceType.isCargoGroupSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isCargoGroupSpecificDebtor(self.debtor)
	and tran.getTrackedItem() &lt;&gt; null then
		self.myTrackedItem := tran.getTrackedItem();
		self.myCargoGroup := tran.getTrackedItem.myCargoGroup;
		
	endif;
	
	//separatedByReleaseRequest
	if self.invoiceType.isReleaseSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isReleaseSpecificDebtor(self.debtor) 
	and tran.getTrackedItem() &lt;&gt; null then
		self.myTrackedItem := tran.getTrackedItem();
		releaseRequest := tran.getTrackedItem.allBulkReleasesReleased.first;
		
		if releaseRequest = null then
			releaseRequest := tran.getTrackedItem.allBulkReleasesAssigned.first;
		endif;
		
		self.myReleaseRequest := releaseRequest;
	endif;
	
	 // ### BUG 56925 07MAR2023 NAVAB1
	if self.invoiceType.isPONumberSpecificSeparation(debtorSep) 
	and tran.getTrackedItem() &lt;&gt; null then
		self.myTrackedItem := tran.getTrackedItem();
		self.purchaseOrderNumber := self.myTrackedItem.purchaseOrder;
	endif;
	
	// ### TFS 54565 (54384) 21Sep2022 NAVPW1
	
	// set from and to date times
	//if invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
	if invoiceType.hasDebtorSeparationAccrual(self.debtor) or invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then // ### TFS 54565 (54384) 06Oct2022 NAVPW1
		// 23510 debtor billing period, debtor parameter added
		fromDT := app.myRoot.myRootCompany.getPeriodEndDateInitialise(theDebtor,invoiceType,tran.dateTime,false); 
		toDT := app.myRoot.myRootCompany.getPeriodEndDateInitialise(theDebtor,invoiceType,tran.dateTime,true); 
	else
		fromDT := tran.dateTime;
	endif;
	// narration generation
	narration := invoiceType.generateNarration(self);

   self.setDetailCode();  // ### TFS 51219 25MAY2021 NAVAB1

end;</source>
        <Parameter name="theBusinessUnit" type="CM_Bank"/>
        <Parameter name="theInvoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="theDebtor" type="CM_Debtor"/>
        <Parameter name="tran" type="CM_EventTransaction"/>
        <Parameter name="_paymentType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialiseManual" id="f3e9b282-7708-4113-8d55-27b69d89e6a2">
        <updating/>
        <source>initialiseManual(	theBusinessUnit		: CM_Bank;
					theInvoiceType		: CM_InvoiceDesc;
					theDebtor			: CM_Debtor;
					theDebtorAddress 	: CM_Address;
					theVoyage		 	: CM_Voyage;
					_status 		 	: Integer;
					_ti					: CM_TrackedItem;
					_paymentType 		: Integer;
					_currencyType		: CM_CurrencyType;	// ### TFS 54564 (54375) 18Aug2022 NAVPW1
					_altAddress 		: CM_Address;		// ### TFS 54564 (54375) 18Aug2022 NAVPW1
					_locale 			: CM_Locale;		// ### TFS 54564 (54375) 18Aug2022 NAVPW1
					_bol				: CM_BOL;			// ### TFS 54565 (54384) 03Oct2022 NAVPW1
					_booking			: CM_BookingRef;	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
					_cargoGroup			: CM_CargoGroup;	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
					_releaseRequest		: CM_BulkRelease;	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
					//_contractIds		: String;			// 19 Jan 2023 navvt20 TFS 55658		navtnr20 10-03-2021 56818
					_category			: Integer; 			// 01/02/2023	navkc1	TFS CR 55305 TASK 55537
					_poNumber 			: String; // ### BUG 56925 07MAR2023 NAVAB1
					_invoiceProcess		: CM_InvoiceProcess; //26.4.2023 navmk20 TFS 57663
					_workOrder			: CM_WorkOrderSet;		//navtnr20 23-05-2023 BUG 58089
					_fromDT				: TimeStamp;			//20/07/2023	navkc1	Bug 58995
					_narr				: String;
					_termOfTradeCode	: String;
					_termOfTradeDesc	: String;
					_debtorReference	: String;
					_allInvoicesToLink	: CM_InvoiceSet			//13/01/2025	navkc1 JIRA Bug MTN-33142
					) updating;
// 05/04/2013	cnwcs5	CCMS POL 2097 / par 31259
// 22/07/2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 08/06/2020   cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 18/08/2022	navpw1	TFS: 54564 (54375) - EUP - Inv Config - Debtor Currencies and Countries
// 03/10/2022	navpw1	TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
// 19/01/2023	navvt20	TFS CR 55628 Task 55658: Jade - Contract Id TRX
// 01/02/2023	navkc1	TFS CR 55305 Task 55537 UI - Invoice List UI changes
// 16 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
// 26 April 2023  navmk20 Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
// 20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes
// 14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
vars
	cargoSpecific, 
	foundMatch		: Boolean;
	debtorRef		: String;
	vesselName,
	voyageCode		: String;
	debtorInvType	: CM_DebtorInvType;
	operator		: CM_Operator;
	now             : TimeStamp;
	finIOClass 		: CM_ExtFinanceIO;
	debtorSep : CM_InvTypeDebtorSeparation;
	
begin
	self.isManual 				:= true;
	self.bank 					:= theBusinessUnit;
	if _invoiceProcess &lt;&gt; null then											//26.4.2023 navmk20 TFS 57663
		self.setMyInvoiceProcess( _invoiceProcess );						//26.4.2023 navmk20 TFS 57663
	else																	//26.4.2023 navmk20 TFS 57663
		self.setMyInvoiceProcess( theBusinessUnit.getMyInvoiceProcess );	// TFS 39618
	endif;																	//26.4.2023 navmk20 TFS 57663
	self.sequenceNum 			:= bank.getSeqNum(SN_INVOICE);
	self.debtor 				:= theDebtor;
	self.myBillingAddress   	:= theDebtorAddress;				 	//22.07.2019 cnwma1 TFS #45577
	self.invoiceType 			:= theInvoiceType;
	self.paymentType			:= _paymentType;						//10 Oct 2018	NDL	TFS 41281
	self.myCurrencyType			:= _currencyType;					 	// ### TFS 54564 (54375) 18Aug2022 NAVPW1
	self.myAlternativeAddress	:= _altAddress;						 	// ### TFS 54564 (54375) 18Aug2022 NAVPW1
	self.myLocale				:= _locale;							 	// ### TFS 54564 (54375) 18Aug2022 NAVPW1
	self.termsOfTrade			:= _termOfTradeDesc; //14/08/2023	navkc1	Bug 59803
	self.termsOfTradeCode		:= _termOfTradeCode; //14/08/2023	navkc1	Bug 59803
	self.debtorReference 		:= _debtorReference; //14/08/2023	navkc1	Bug 59803
	if _workOrder &lt;&gt; null then //navtnr20 23-05-2023 BUG 58089
		self.allWorkOrders.clear();
		_workOrder.copy(self.allWorkOrders);		//navtnr20 23-05-2023 BUG 58089
	endif;
	
	debtorSep := self.invoiceType.getDebtorSeparation(self.debtor); // ### BUG 56925 07MAR2023 NAVAB1

	//self.contractIds			:= _contractIds	; // 19 Jan 2023 navvt20 TFS 55658 navtnr20 10-03-2021 56818
	self.setStatus( _status );	//13 Jun 2018	NDL	TFS 39197
	self.setCategory(_category); // 26/01/2023	navkc1	TFS CR 55305 TASK 55537
	//cargoSpecific := self.invoiceType.isCargoItemSpecific();
	cargoSpecific := self.invoiceType.isCargoSpecificSeparation(debtorSep);  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	cargoSpecific := self.invoiceType.isCargoItemSpecificDebtor(self.debtor); // ### TFS 54565 (54384) 22Sep2022 NAVPW1
	
	// ### PAR 36323
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass.setExternalOnCreate() then
		self.setExternalInvoiceNumber(finIOClass.setExternalInvoiceNumber(self));
	endif;
	
	/* // ### BUG 56925 07MAR2023 NAVAB1
	//if (self.invoiceType.isVoyageSpecific
	if (self.invoiceType.isVoyageSpecificDebtor(self.debtor)				// ### TFS 54565 (54384) 22Sep2022 NAVPW1
		//or self.invoiceType.isVoyageGroupSpecific) then					// ### TFS 51219 25MAY2021 NAVAB1
		or self.invoiceType.isVoyageGroupSpecificDebtor(self.debtor)) then	// ### TFS 51219 25MAY2021 NAVAB1 // ### TFS 54565 (54384) 22Sep2022 NAVPW1
		*/
	//16/03/2023  navmv20 TFS 56128 Task 56129 - START
	if self.myTerminal.getConfig(InvShowAllSeparation).Boolean then
		 self.initialiseAllSeparations(theDebtor,theVoyage,_ti,_bol,_booking,_cargoGroup,_releaseRequest,_poNumber);
	else 
	//16/03/2023  navmv20 TFS 56128 Task 56129 - END
		if self.invoiceType.isVoyageSpecificSeparation(debtorSep) // ### BUG 56925 07MAR2023 NAVAB1
		or self.invoiceType.isVoyageGrpSpecificSeparation(debtorSep) then // ### BUG 56925 07MAR2023 NAVAB1
			if theVoyage &lt;&gt; null then
				self.myVoyage 		 := theVoyage;
				self.vesselName 	 := self.myVoyage.vesselName;
				self.voyageGroupCode := self.myVoyage.voyageGroupCode;   //03/06/2020 cnwma1 Tfs #49400
				// CPL CCMS 2120 Nov 2011 use debtor invoice type default debtor ref to XL voyage option
				debtorInvType := self.debtor.allDebtorInvTypes[invoiceType];
				if debtorInvType &lt;&gt; null then
					if debtorInvType.defaultDebtorRefTo = DfltDbtrRef_XlatedVoyageCode then
						voyageCode := self.myVoyage.code;
						vesselName := self.vesselName;
						foreach operator in theDebtor.operators do
							debtorRef := operator.getXlationSystemCode_Voyage(voyageCode, vesselName, null, null, foundMatch);	// par 31259
							if debtorRef &lt;&gt; null then
								self.debtorReference := debtorRef[1:30];
								break;
							endif;
						endforeach;
					endif;
				endif;
			endif;
		endif;									// ### TFS 54565 (54384) 23Sep2022 NAVPW1
		//elseif cargoSpecific then
		if cargoSpecific then					// ### TFS 54565 (54384) 23Sep2022 NAVPW1
			self.myTrackedItem := _ti;
		endif;
		
		// ### TFS 54565 (54384) 21Sep2022 NAVPW1
		
		if self.invoiceType.isBOLSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
		 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isBOLSpecificDebtor(self.debtor)
			and _bol &lt;&gt; null
		then
			self.myBOL := _bol;
		endif;
		
		//separatedByBooking
		if self.invoiceType.isBookingSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
		 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isBookingSpecificDebtor(self.debtor)
			and _booking &lt;&gt; null
		then
			self.myBookingRef := _booking;
		endif;
	
		//separatedByCargoGroupId
		if self.invoiceType.isCargoGroupSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
		 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isCargoGroupSpecificDebtor(self.debtor) 
			and _cargoGroup &lt;&gt; null
		then
			self.myCargoGroup := _cargoGroup;
			
		endif;
		
		//separatedByReleaseRequest
		if self.invoiceType.isReleaseSpecificSeparation(debtorSep)  // ### BUG 56925 07MAR2023 NAVAB1
		 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isReleaseSpecificDebtor(self.debtor) 
			and _releaseRequest &lt;&gt; null
		then
			self.myReleaseRequest := _releaseRequest;
		endif;

		 // ### BUG 56925 07MAR2023 NAVAB1
		if self.invoiceType.isPONumberSpecificSeparation(debtorSep) then 
			self.purchaseOrderNumber := _poNumber;
		// ### JIRA 33518 28NOV2024 NAVAB1 - if the system has no sepeartions set at all then set the PO Number
		elseif debtorSep = null then
			self.purchaseOrderNumber := _poNumber;
		endif;

		// ### TFS 54565 (54384) 21Sep2022 NAVPW1
	endif; //16/03/2023  navmv20 TFS 56128 Task 56129
	// set from and to date times
	//if invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
	if self.category = InvoiceCategory_CreditNote then //20/07/2023	navkc1	Bug 58995
		if _fromDT &lt;&gt; null then
			fromDT := _fromDT;
		else
			fromDT := now;
		endif;
		if invoiceType.hasDebtorSeparationAccrual(self.debtor) or invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
			toDT   := app.myRoot.myRootCompany.getPeriodEndDateInitialise(theDebtor,invoiceType,now,true);
		endif;
	elseif invoiceType.hasDebtorSeparationAccrual(self.debtor) or invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then	// ### TFS 54565 (54384) 06Oct2022 NAVPW1
		// 23510 debtor billing period, debtor parameter added
		fromDT := app.myRoot.myRootCompany.getPeriodEndDateInitialise(theDebtor,invoiceType,now,false); // CCMS 1125 // PAR 8189
		toDT   := app.myRoot.myRootCompany.getPeriodEndDateInitialise(theDebtor,invoiceType,now,true);  // CCMS 1125 // PAR 8189
	else
		fromDT := now;
		toDT := null;
	endif;

	// narration generation
	if _narr &lt;&gt; null then //14/08/2023	navkc1	Bug 59803
		self.narration := _narr;
	else
		narration := invoiceType.generateNarration(self);
	endif;

    self.setDetailCode();  // ### TFS 51219 25MAY2021 NAVAB1
	
	_allInvoicesToLink.tryCopy(self.allCreditInvoices); //13/01/2025	navkc1 JIRA Bug MTN-33142
	
end;</source>
        <Parameter name="theBusinessUnit" type="CM_Bank"/>
        <Parameter name="theInvoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="theDebtor" type="CM_Debtor"/>
        <Parameter name="theDebtorAddress" type="CM_Address"/>
        <Parameter name="theVoyage" type="CM_Voyage"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_paymentType" type="Integer"/>
        <Parameter name="_currencyType" type="CM_CurrencyType"/>
        <Parameter name="_altAddress" type="CM_Address"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
        <Parameter name="_releaseRequest" type="CM_BulkRelease"/>
        <Parameter name="_category" type="Integer"/>
        <Parameter name="_poNumber" type="String"/>
        <Parameter name="_invoiceProcess" type="CM_InvoiceProcess"/>
        <Parameter name="_workOrder" type="CM_WorkOrderSet"/>
        <Parameter name="_fromDT" type="TimeStamp"/>
        <Parameter name="_narr" type="String"/>
        <Parameter name="_termOfTradeCode" type="String"/>
        <Parameter name="_termOfTradeDesc" type="String"/>
        <Parameter name="_debtorReference" type="String"/>
        <Parameter name="_allInvoicesToLink" type="CM_InvoiceSet"/>
    </JadeMethod>
    <JadeMethod name="initialiseVTMIS" id="5d9ad73d-f5e4-4100-b0b4-6162c348df15">
        <updating/>
        <source>initialiseVTMIS(theBusinessUnit: CM_Bank;
				theInvoiceType : CM_InvoiceDesc;
				theDebtor      : CM_Debtor;
				tran		   : HMS_VTMISTransaction;
				_paymentType   : Integer
				) updating;
// 05/04/2013	cnwcs5	CCMS POL 2097 / par 31259
// 08/06/2020   cnwma1  ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
vars
	debtorRef,	
	vesselName,
	voyageCode	  : String;
	debtorInvType : CM_DebtorInvType;
	operator	  : CM_Operator;
	foundMatch	  : Boolean;
	finIOClass 	  : CM_ExtFinanceIO;
begin
	bank 				  := theBusinessUnit;
	self.setMyInvoiceProcess( theBusinessUnit.getMyInvoiceProcess ); // TFS 39618	
	sequenceNum 		  := bank.getSeqNum(SN_INVOICE);
	debtor 			      := theDebtor;
	invoiceType 		  := theInvoiceType;
	self.status 		  := -1;	  // TFS 39618 PATCH 1 to trigger OPEN status email
	self.paymentType := _paymentType; //10 Oct 2018	NDL	TFS 41281
	

	self.setStatus( INVOICE_OPEN );	//13 Jun 2018	NDL	TFS 39197
	
	// ### TFS 41026
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass.setExternalOnCreate() then
		self.setExternalInvoiceNumber(finIOClass.setExternalInvoiceNumber(self));
	endif;

	self.myVoyage   	 := tran.myVoyage;
	self.vesselName 	 := self.myVoyage.vesselName;
	self.voyageGroupCode := self.myVoyage.voyageGroupCode;  //03/06/2020 cnwma1 Tfs #49400
	// CPL CCMS 2120 Nov 2011 use debtor invoice type default debtor ref to XL voyage option
	debtorInvType := self.debtor.allDebtorInvTypes[invoiceType];
	if debtorInvType &lt;&gt; null then
		if debtorInvType.defaultDebtorRefTo = DfltDbtrRef_XlatedVoyageCode then
			voyageCode := self.myVoyage.code;
			vesselName := self.vesselName;
			foreach operator in theDebtor.operators do
				debtorRef := operator.getXlationSystemCode_Voyage(voyageCode, vesselName, null, null, foundMatch);	// par 31259
				if debtorRef &lt;&gt; null then
					self.debtorReference := debtorRef[1:30];
					break;
				endif;
			endforeach;
		endif;
	endif;

	// set from and to date times
	//if invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
	if invoiceType.hasDebtorSeparationAccrual(self.debtor) or invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then	// ### TFS 54565 (54384) 06Oct2022 NAVPW1
		// 23510 debtor billing period, debtor parameter added
		fromDT := app.myRoot.myRootCompany.getPeriodEndDateInitialise(theDebtor,invoiceType,tran.transactionDT,false); // CCMS 1125 // PAR 8189
		toDT   := app.myRoot.myRootCompany.getPeriodEndDateInitialise(theDebtor,invoiceType,tran.transactionDT,true);  // CCMS 1125 // PAR 8189
	else
		fromDT := tran.transactionDT;
	endif;
	// narration generation
	narration := invoiceType.generateNarration(self);

end;</source>
        <Parameter name="theBusinessUnit" type="CM_Bank"/>
        <Parameter name="theInvoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="theDebtor" type="CM_Debtor"/>
        <Parameter name="tran" type="HMS_VTMISTransaction"/>
        <Parameter name="_paymentType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initialiseWorkOrder" id="67bc672d-f3c5-492c-a34f-7d66dedcc0ef">
        <updating/>
        <source>initialiseWorkOrder(_businessUnit		: CM_Bank;
					_invoiceType		: CM_InvoiceDesc;
					_debtor				: CM_Debtor;
					_workorder 			: CM_WorkOrder;
					_paymentType 		: Integer) updating;

/*
Purpose:			TFS 39237
Date				Who			Reason
JUNE 2018		CNWAB1			Initial creation
TFS 37964  -	 				changed	 to pass in work order rather than transaction
08/06/2020 		cnwma1 			ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
11 Feb 2021 	navma1			ChangeRequest 52580: SAL - Work Order and Invoicing link
13/09/2022		navpw1			TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
*/

vars
	debtorRef,
	vesselName,
	voyageCode		: String;
	debtorInvType  	: CM_DebtorInvType;
	operator		: CM_Operator;
	foundMatch		: Boolean;
	tis 		    : CM_TISet;
	ts 				: TimeStamp;
	finIOClass 		: CM_ExtFinanceIO;
	bolOutSet		: CM_BOLSet;		// ### TFS 54565 (54384) 23Sep2022 NAVPW1
	voyage			: CM_Voyage;		// ### TFS 54565 (54384) 23Sep2022 NAVPW1
	releaseRequest	: CM_BulkRelease;	// ### TFS 54565 (54384) 23Sep2022 NAVPW1
	debtorSep : CM_InvTypeDebtorSeparation;
	
begin
	self.bank 			  := _businessUnit;
	self.setMyInvoiceProcess( _businessUnit.getMyInvoiceProcess ); // TFS 39618	
	self.sequenceNum 	  := bank.getSeqNum(SN_INVOICE);
	self.debtor			  := _debtor;
	self.invoiceType	  := _invoiceType;
	self.status 	 	  := -1;								// TFS 39618 PATCH 1 to trigger OPEN status email
	self.paymentType 	  := _paymentType; 						//10 Oct 2018	NDL	TFS 41281
	
	self.setStatus( INVOICE_OPEN );								//13 Jun 2018	NDL	TFS 39197
	//self.myWorkOrder := _workorder; 							// TFS 39518    11.02.2021 navma1 #52580
	debtorSep := self.invoiceType.getDebtorSeparation(self.debtor); // ### BUG 56925 07MAR2023 NAVAB1
	create tis transient; // ### BUG 56925 07MAR2023 NAVAB1
	_workorder.getAllTIs(tis); // ### BUG 56925 07MAR2023 NAVAB1	
	self.myTrackedItem := tis.first; // ### BUG 56925 07MAR2023 NAVAB1
	
	// ### TFS 41026
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass.setExternalOnCreate() then
		self.setExternalInvoiceNumber(finIOClass.setExternalInvoiceNumber(self));
	endif;

	//if self.invoiceType.isVoyageSpecific or self.invoiceType.isVoyageGroupSpecific then										// ### TFS 51219 25MAY2021 NAVAB1
	if self.invoiceType.isVoyageGrpSpecificSeparation(debtorSep) 
	or  self.invoiceType.isVoyageSpecificSeparation(debtorSep) then // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if self.invoiceType.isVoyageSpecificDebtor(self.debtor) or self.invoiceType.isVoyageGroupSpecificDebtor(self.debtor) then	// ### TFS 54565 (54384) 22Sep2022 NAVPW1
		self.myVoyage := _workorder.getMyVoyageObject();
		if self.myVoyage &lt;&gt; null then
			self.vesselName      := self.myVoyage.vesselName;
			self.voyageGroupCode := self.myVoyage.voyageGroupCode;              			 //03/06/2020 cnwma1 Tfs #49400
			debtorInvType 		 := self.debtor.allDebtorInvTypes[invoiceType];
			if debtorInvType &lt;&gt; null then
				if debtorInvType.defaultDebtorRefTo = DfltDbtrRef_XlatedVoyageCode then
					voyageCode := self.myVoyage.code;
					vesselName := self.vesselName;
					foreach operator in _debtor.operators do
						debtorRef := operator.getXlationSystemCode_Voyage(voyageCode, vesselName, null, null, foundMatch);	// par 31259
						if debtorRef &lt;&gt; null then
							self.debtorReference := debtorRef[1:30];
							break;
						endif;
					endforeach;
				endif;
			endif;
		endif;
	endif;															// ### TFS 54565 (54384) 23Sep2022 NAVPW1
	//elseif self.invoiceType.isCargoItemSpecific() then
	if self.invoiceType.isCargoSpecificSeparation(debtorSep) then  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if self.invoiceType.isCargoItemSpecificDebtor(self.debtor) then // ### TFS 54565 (54384) 22Sep2022 NAVPW1
	 // ### BUG 56925 07MAR2023 NAVAB1	create tis transient;
	 // ### BUG 56925 07MAR2023 NAVAB1	_workorder.getAllTIs(tis);
		
	 // ### BUG 56925 07MAR2023 NAVAB1	self.myTrackedItem := tis.first;
	endif;
	
	// ### TFS 54565 (54384) 21Sep2022 NAVPW1
	
	if self.invoiceType.isBOLSpecificSeparation(debtorSep) then  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if (invoiceType.isBOLSpecificDebtor(self.debtor)) then
 // ### BUG 56925 07MAR2023 NAVAB1		if self.myTrackedItem = null then
 // ### BUG 56925 07MAR2023 NAVAB1			delete tis;
 // ### BUG 56925 07MAR2023 NAVAB1			create tis transient;
 // ### BUG 56925 07MAR2023 NAVAB1			_workorder.getAllTIs(tis);
			
 // ### BUG 56925 07MAR2023 NAVAB1			self.myTrackedItem := tis.first;
 // ### BUG 56925 07MAR2023 NAVAB1		endif;
		
		if self.myTrackedItem &lt;&gt; null then
			if self.myTrackedItem.billOfLading &lt;&gt; null then
				self.myBOL := self.myTerminal.getBOLInByNumber(	self.myTrackedItem.billOfLading,
																BOLType_GeneralBillOfLading	);
				if self.myBOL = null then
					create bolOutSet transient;
					self.myTerminal.getBOLOutsFromNumber(	bolOutSet,
															BOLType_GeneralBillOfLading,
															self.myTrackedItem.billOfLading,
															true,
															null	);
					if not bolOutSet.isEmpty then
						self.myBOL := bolOutSet.first;
					endif;
					delete bolOutSet;
				endif;
				
				if self.myBOL &lt;&gt; null  then
					voyage := self.myBOL.getMyVoyage();
				endif;
				
				if voyage = null                        
				and self.myTrackedItem &lt;&gt; null then
					voyage := self.myTrackedItem.myVoyage;
				endif;
				
				if voyage &lt;&gt; null then
					self.myVoyage 		 := voyage;
					self.vesselName	     := voyage.vesselName;
					self.voyageGroupCode := voyage.voyageGroupCode;
				endif;
			endif;
		endif;
	endif;
	
	//separatedByBooking
	if self.invoiceType.isBookingSpecificSeparation(debtorSep) then  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isBookingSpecificDebtor(self.debtor) then
 // ### BUG 56925 07MAR2023 NAVAB1		if self.myTrackedItem = null then
 // ### BUG 56925 07MAR2023 NAVAB1			delete tis;
 // ### BUG 56925 07MAR2023 NAVAB1			create tis transient;
 // ### BUG 56925 07MAR2023 NAVAB1			_workorder.getAllTIs(tis);
			
 // ### BUG 56925 07MAR2023 NAVAB1			self.myTrackedItem := tis.first;
 // ### BUG 56925 07MAR2023 NAVAB1		endif;
		
		if self.myTrackedItem &lt;&gt; null then
			self.myBookingRef := self.myTrackedItem.myBookingRef;
		endif;
		
	endif;
	
	//separatedByCargoGroupId
	if self.invoiceType.isCargoGroupSpecificSeparation(debtorSep) then  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isCargoGroupSpecificDebtor(self.debtor) then
 // ### BUG 56925 07MAR2023 NAVAB1		if self.myTrackedItem = null then
 // ### BUG 56925 07MAR2023 NAVAB1			delete tis;
 // ### BUG 56925 07MAR2023 NAVAB1			create tis transient;
 // ### BUG 56925 07MAR2023 NAVAB1			_workorder.getAllTIs(tis);
			
 // ### BUG 56925 07MAR2023 NAVAB1			self.myTrackedItem := tis.first;
 // ### BUG 56925 07MAR2023 NAVAB1		endif;
		
		if self.myTrackedItem &lt;&gt; null then
			self.myCargoGroup := self.myTrackedItem.myCargoGroup;
		endif;
		
	endif;
	
	//separatedByReleaseRequest
	if self.invoiceType.isReleaseSpecificSeparation(debtorSep) then  // ### BUG 56925 07MAR2023 NAVAB1
	 // ### BUG 56925 07MAR2023 NAVAB1	if invoiceType.isReleaseSpecificDebtor(self.debtor) then
 // ### BUG 56925 07MAR2023 NAVAB1		if self.myTrackedItem = null then
 // ### BUG 56925 07MAR2023 NAVAB1			delete tis;
 // ### BUG 56925 07MAR2023 NAVAB1			create tis transient;
 // ### BUG 56925 07MAR2023 NAVAB1			_workorder.getAllTIs(tis);
 // ### BUG 56925 07MAR2023 NAVAB1			
 // ### BUG 56925 07MAR2023 NAVAB1			self.myTrackedItem := tis.first;
 // ### BUG 56925 07MAR2023 NAVAB1		endif;
		
		if self.myTrackedItem &lt;&gt; null then
			releaseRequest := self.myTrackedItem.allBulkReleasesReleased.first;
			if releaseRequest = null then
				releaseRequest := self.myTrackedItem.allBulkReleasesAssigned.first;
			endif;
			self.myReleaseRequest := releaseRequest;
		endif;
		
	endif;
	
	 // ### BUG 56925 07MAR2023 NAVAB1
	if self.invoiceType.isPONumberSpecificSeparation(debtorSep) then
		if self.myTrackedItem &lt;&gt; null then
			self.purchaseOrderNumber := self.myTrackedItem.purchaseOrder;
		endif;
	endif;
	
	// ### TFS 54565 (54384) 21Sep2022 NAVPW1
	
	ts := app.serverTimestampAtTrxStart;
	// set from and to date times
	//if invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then
	if invoiceType.hasDebtorSeparationAccrual(self.debtor) or invoiceType.accrualType = CM_InvoiceDesc.Accrue_For_Financial_Period then	// ### TFS 54565 (54384) 06Oct2022 NAVPW1
		fromDT := app.myRoot.myRootCompany.getPeriodEndDateInitialise(_debtor,invoiceType,ts,false); 
		toDT   := app.myRoot.myRootCompany.getPeriodEndDateInitialise(_debtor,invoiceType,ts,true); 
	else
		fromDT := ts;
	endif;
	// narration generation
	narration := invoiceType.generateNarration(self);
	
    self.setDetailCode();  // ### TFS 51219 25MAY2021 NAVAB1
	
epilog
	delete tis;
	
end;</source>
        <Parameter name="_businessUnit" type="CM_Bank"/>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_workorder" type="CM_WorkOrder"/>
        <Parameter name="_paymentType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initializeMyInvStaticData" id="eed2c0a5-03dd-4ba3-a144-0bd41d3ac61a">
        <updating/>
        <source>initializeMyInvStaticData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2024	navra1	Initial creation for TFS 57933 Invoice and Invoice Line details that need to be static &lt;&lt;54090&gt;&gt;

*/
vars

begin
	if self.myInvStaticData = null then
		if process.isInTransactionState() then
			create self.myInvStaticData persistent;
		else
			app.writeLog("Invoice static data not initialized and initialize called while not in trx state", LogERROR);
		endif;		
	endif;
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="isCargoInvoice" id="dbb95005-b31f-4af3-9052-9fdeeafddb80">
        <source>isCargoInvoice() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/11/2018	jlgdap1		Initial creation TFS 41949 PEL1 Tax Number and Stamps based on SKTD and BUT Certificates on a Voyage
// 08/10/2021	jlier1		TFS 51963 - renamed
vars
	line : CM_InvoiceLine;

begin
	foreach line in self.invoiceLines discreteLock do
		if line.myTransactionTI &lt;&gt; null then
			return true;
		endif;
		if line.trackedItem &lt;&gt; null then // TFS 44019
			return true; // TFS 44019
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
