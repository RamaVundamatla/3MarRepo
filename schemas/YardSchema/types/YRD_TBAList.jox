    <JadeMethod name="displayTable" id="eba8504d-718f-4a9c-92dd-751ff5afe264">
        <updating/>
        <source>displayTable() updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTI 			: CM_TrackedItem;
	theDataLine 	: String;
	loadStateSet 	: Boolean;
	tiDict			: CM_TIByCargoTypeIdDict;
	tbl				: CM_DataTable;
	voyage			: CM_Voyage;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	voyage := self.myCurrentVoyage;
	tbl := self.tblData;
	
	if voyage = null then
		return;
	endif;
	
	tbl.rows := tbl.fixedRows;
	tiDict := voyage.allTbaTIsByCargoTypeId;

	app.cmsBeginLoad(loadStateSet);
	foreach theTI in tiDict do
		if theTI.isShipBulkReleaseTBA() then // PAR 33695 ignore Ship Release reqiuest place holders
			continue;
		endif;

		theDataLine := theTI.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		tbl.accessRow(tbl.addItem(theDataLine)).itemObject := theTI;
		if theTI.myMatchedActual &lt;&gt; null then // PAR 35574
			tbl.accessedRow.backColor := LightGreen;
		endif;
		self.doNotableAdd(theTI);
	endforeach;
	
epilog
	app.cmsEndLoad(loadStateSet);
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
