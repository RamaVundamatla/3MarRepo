    <JadeMethod name="tblRowColumnChg" id="fb512c4e-6f27-474b-9362-dc5eff16f26c">
        <updating/>
        <source>tblRowColumnChg(_topTable, _bottomTable : CM_DataTable input) updating;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	obj : Object;
begin
	
	obj := _topTable.accessRow(_topTable.row).itemObject;
	if obj = null then
		return;
	endif;
	
	if CM_TrackedItem.hasInstance(obj) then
		
		self.displayExtraInfoForTI(_bottomTable, obj.CM_TrackedItem);

	elseif CM_BOL.hasInstance(obj) then
		
		self.displayExtraInfoForBOL(_bottomTable, obj.CM_BOL);			
	endif;
	
end;</source>
        <Parameter name="_topTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_bottomTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="toggleViewOption" id="6368b577-4867-4dc7-b2de-178a7659e738">
        <updating/>
        <source>toggleViewOption() updating;
//--------------------------------------------------
// Created:	28 March 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	// clears the table and resets the columns for the data type is needed
	self.resetTblData(self.tblOnShip);
	self.resetTblData(self.tblOnSite);
	self.resetTblData(self.tblPlanned);
	self.resetTblData(self.tblNonPlanned);
	
	self.resetCargoTypeLst();
	self.displayVoyage();
	self.displaySheetCaptions();
	
	// cnwrl1 19/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	// Summarise function is not available unless Cargo option is selected.
	self.btnSummariseAll.enabled	:= self.optCargo.value;
	// cnwrl1 19/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
end;</source>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="e38d55c1-ad52-447b-a4d3-afc59956c7bd">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 20 April 2006
//
//----------------------------------------------------------------------

vars

begin
	

	inheritMethod(_showCaptions);
	
	self.frmToolbar2.showCaptions := false;
	self.frmToolbar2.top := self.frmToolbar.height-1;
	
	self.setToolbarSearch();
	self.frmSearchToolbar.positionToolbarControls();
epilog

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="791587b9-7e56-4035-8e09-2d3964e5d5a7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:51:12.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
