    <JadeMethod name="hkConvertSome" id="1b0fc9f4-b74b-4704-86f7-f25f78ced162">
        <source>hkConvertSome();
//	creates a .grp file for one of the *.conf in the new TestGroupingSplitup format
//	Genernally 2 lines to change for each convertion

vars
	testName,newConfig,s,t:String;
	i,j:Integer;
	f,g,h:File;
begin
	write "Starting";
	
	create f; create g;	create h;
	
	//Change the following line to contain the .conf that you want to convert
	f.fileName := "\\cnwchcm24\cnwjbl$\ManualRunPlayPen\testgroupings\hkConvert\AllReorgFastBuild.conf";
	f.usePresentationFileSystem := false;
	f.kind := File.Kind_Unknown_Text;
	
	//Change the following line to replace .conf with .grp (use full file name)
	g.fileName := f.fileName.replace("AllReorgFastBuild.conf", "AllReorgFastBuild.grp");
	g.usePresentationFileSystem := false;
	g.mode := File.Mode_Output;
	g.writeLine("AutoTestName,QueueType,MinRelease1,MinRelease2,SpecialConditions");
	
	h.fileName:="\\cnwchcm24\cnwjbl$\ManualRunPlayPen\testgroupings\hkConvert\AllCurrent.grp";
	h.usePresentationFileSystem := false;
	t := h.readString(h.fileLength);

	while not f.endOfFile do 
		s := f.readLine;
		i := s.pos("\\cnwchcs118\t$\svnrepocache\jade\plant\TestSuites\TestConfigs\FunctionalTests\jade\", 1);
		if i &lt; 1 then continue; endif;
		i := i + 84;
		testName:=s.scanUntil(".", i);
		j := t.pos(testName, 1);
		if j &gt; 1 then 
			newConfig := t.scanUntil(CrLf, j);
			g.writeLine(newConfig);
		else
			write testName &amp; " does not exist in AllCurrent_jp.csv so will skip.";
		endif;
	endwhile;
		
	write "Finished";
epilog
	delete f; delete g; delete h;
end;</source>
