    <JadeMethod name="trxUpdateBerthSPOG" id="bc09ad69-93fa-4662-8361-172367b68936">
        <updating/>
        <source>trxUpdateBerthSPOG(	_movement : HMS_VoyageMovement input; _berth : HMS_Berth; _passport : CM_Passport input	) updating;
//
// Purpose:			Reset a movement's berth back to its original value if a SPOG message from INAPORTNET changed it
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/02/2019	jlgdap1		Initial creation TFS 43307 PEL1 INAP - SPOG message changes berth
//
vars

begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(true);
	
	if _berth = null or _movement = null then
		return;
	endif;
	if _movement.getMyBerth = _berth then
		return;
	endif;
	
	beginTransaction;
	
	_movement.setMyBerth(_berth);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateBestPickOnsite" id="6085cc29-64de-4d69-a1e9-c7c86a3522d4">
        <updating/>
        <source>trxUpdateBestPickOnsite(_terminal : CM_Terminal; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2025	jlier1	Initial creation JIRA-35632

*/

vars
	iterTi : Iterator;
	ti  : CM_TrackedItem;
	dateType : Integer;
	newDT : TimeStamp;
	subTerminalTrx : CM_SubTerminalReceive;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	if _terminal = null then
		app.raiseCMException1(ERR_NO_OBJECT, "Terminal", null, null);
	endif;

	iterTi := _terminal.allOnsiteTIsByIdCargoType.createIterator;
	
	beginTransaction;
	while iterTi.next( ti ) do
		if ti.myPrimaryActualLocation = null then
			continue;
		endif;
		dateType:=_terminal.getBestPickDateTypeForTI(ti);
		newDT:=null;
		if dateType = CM_BestPickPriority.BestPickRecevialDT then
			if ti.bestPickDT &lt;&gt; ti.receivedDT then
				ti.setBestPickDT(ti.receivedDT,dateType);						
			endif;
		elseif dateType = CM_BestPickPriority.BestPickPTIDT then
			newDT:=ti.getPreTripDT;
			if newDT = null then //if null just set to recieval date/time
				newDT:=ti.receivedDT;
				dateType:=CM_BestPickPriority.BestPickRecevialDT;
			endif;
			if ti.bestPickDT &lt;&gt; newDT then
				ti.setBestPickDT(newDT,dateType);
			endif;
		elseif dateType = CM_BestPickPriority.BestPickSubterminalDT then
			subTerminalTrx:=ti.getLastTransOfTypeClass(CM_SubTerminalReceive).CM_SubTerminalReceive;
			if subTerminalTrx &lt;&gt; null and subTerminalTrx.dateTime &lt;&gt; null then
				newDT:=subTerminalTrx.dateTime;
			endif;
			if newDT = null then //if null just set to recieval date/time
				newDT:=ti.receivedDT;
				dateType:=CM_BestPickPriority.BestPickRecevialDT;
			endif;
			if ti.bestPickDT &lt;&gt; newDT then
				ti.setBestPickDT(newDT,dateType);
			endif;
		endif;
	endwhile;
epilog
	delete iterTi;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
