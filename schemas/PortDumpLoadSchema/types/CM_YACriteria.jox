<Class name="CM_YACriteria">
    <JadeMethod name="exportPDXMLMyReferences" id="8cee544f-3ed1-4a3a-83b6-108c0bc5989a">
        <source>exportPDXMLMyReferences(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars

begin
	// before we write out the myTerminalArea we write out which terminal we are in
//	if _property.name = CM_YACriteria::myYardAllocation.name then
//		_file.writeLine("&lt;myTerminal&gt;"&amp;self.myYardAllocation.myTerminal.theKey&amp;"&lt;/myTerminal&gt;");
//	endif;
	inheritMethod(_file, _objArray, _property, _object);
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="73c6d518-aa7b-472c-819b-6f3190708b75">
        <updating/>
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object updating;

vars

begin
	if _name = CM_YACriteria::myYardAllocation.name then
		return app.getMyTerminalDO_NOT_USE().allYardAllocatonsByCode[_theCode];
	else
		return inheritMethod(_name, _theCode, _referencesBlock);
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
