        <updating/>
        <source>lstTree_mouseMove(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	//tmpHeight : Real;	
begin
	/*
	if table.fixedRows &gt; 0 then
		tmpHeight := table.accessRow(table.fixedRows).height;
		if self.origYPos &lt;= tmpHeight then
			return;
		endif;
	endif;
	*/
	if button = 1 and self.mode &lt;&gt; self.Mode_View then
		if app.dragDetected(x, y, self.origXPos, self.origYPos) then
			self.zDoLstTreeDragObjects();
			self.origXPos := 0;
			self.origYPos := 0;
		endif;
	endif;
end;







</source>
