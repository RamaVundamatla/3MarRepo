    <JadeMethod name="doSelectItemTable" id="4722e44e-d19b-4dea-b8e0-ef9a3bd501df">
        <source>doSelectItemTable();
// ---------------------------------------------------------------------------
// Created:     19 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	r, c :Integer;
	objSelected : CM_Object;
begin
	self.tbl_Items.selectedNext(r,c);
	if r &lt;&gt; 0 and c &lt;&gt; 0 then
		objSelected := self.tbl_Items.accessRow(r).itemObject.CM_Object;
		self.showObjSelected(objSelected);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getTableSettings" id="00dd3ad2-7414-42c2-a7d5-054df95262d1">
        <source>getTableSettings(_columns : Integer output; _header : String output);
/*
	Created on 28 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	_columns := 4;
	_header := app.getErrorString(VoyageCode) &amp; ' #' &amp; Tab &amp; app.getErrorString(VesselName) &amp; Tab &amp; app.getErrorString(Arrival_date_time)&amp; Tab  &amp; app.getErrorString(Departure_date_time);
end;</source>
        <Parameter name="_columns" type="Integer" usage="output"/>
        <Parameter name="_header" type="String" usage="output"/>
    </JadeMethod>
