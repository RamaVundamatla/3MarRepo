end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="f9a709f3-7aa1-40c8-9804-bfe2f3176423">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     07 February 2002 by cnwrs2
//
// Purpose:     
//
