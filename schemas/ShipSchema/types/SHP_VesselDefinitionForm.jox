    <JadeMethod name="doUserNotifyStructuralTables" id="ca2527fd-4589-493a-a580-0765e240b332">
        <source>doUserNotifyStructuralTables(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin


	if eventType = EVENT_DECK_ITEM_CREATE or  eventType = EVENT_DECK_ITEM_UPDATE then
		self.tblExtRamps.updateItemObject(userInfo.CM_Object, null	, null, app.myPassport);	
	elseif eventType = EVENT_DECK_ITEM_DELETE then
		self.tblExtRamps.removeItemObject(userInfo.CM_Object);
	elseif eventType = EVENT_TANK_CREATE or eventType = EVENT_TANK_UPDATE then
		self.tblTanks.updateItemObject(userInfo.CM_Object, null	, null, app.myPassport);	
	elseif eventType = EVENT_TANK_DELETE then
		self.tblTanks.removeItemObject(userInfo.CM_Object);
	elseif  eventType = EVENT_SECTION_CREATE or eventType = EVENT_SECTION_UPDATE then
		self.tblSections.updateItemObject(userInfo.CM_Object, null	, null, app.myPassport);	
	elseif eventType = EVENT_SECTION_DELETE then	
		self.tblSections.removeItemObject(userInfo.CM_Object);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="endVesselStructureNotes" id="40170b9f-180a-4f36-9127-27727390c38e">
        <updating/>
        <source>endVesselStructureNotes() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	roroStructure : CM_ROROVesselStructure;
	//cellularStructure : CM_CellularVesselStructure;
	vesselStruct : CM_VesselStructuralElements;
begin

	if self.myCurrentVessel = null or self.myCurrentVessel.isTransient then
		return;
	endif;
	
	
	vesselStruct := self.myCurrentVessel.myStructuralElements;
	
//	if vesselStruct &lt;&gt; null then
	if vesselStruct &lt;&gt; null and self.notesCell then	//30 Aug 2017 NDL TFS 6578 - Put it back again
		self.endNotification(vesselStruct,EVENT_TANK_CREATE);
		self.endNotification(vesselStruct,EVENT_TANK_UPDATE);
		self.endNotification(vesselStruct,EVENT_TANK_DELETE);	
		
		self.endNotification(vesselStruct,EVENT_SECTION_CREATE);
		self.endNotification(vesselStruct,EVENT_SECTION_UPDATE);
		self.endNotification(vesselStruct,EVENT_SECTION_DELETE);
						
		self.endNotification(vesselStruct,EVENT_DECK_ITEM_CREATE);
		self.endNotification(vesselStruct,EVENT_DECK_ITEM_UPDATE);
		self.endNotification(vesselStruct,EVENT_DECK_ITEM_DELETE);

		self.notesCell := false;	//30 May 2012	NDL	Par 29645		
	endif;
	
	
	roroStructure:=self.myCurrentVessel.myROROVesselStructure ;
	//if roroStructure &lt;&gt; null then
	if roroStructure &lt;&gt; null and self.notesRoRo then	//30 May 2012	NDL	Par 29645
		self.endNotification(roroStructure,EVENT_DECK_ITEM_CREATE);
		self.endNotification(roroStructure,EVENT_DECK_ITEM_UPDATE);
		self.endNotification(roroStructure,EVENT_DECK_ITEM_DELETE);	
		
		self.notesRoRo := false;	//30 May 2012	NDL	Par 29645
		
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
