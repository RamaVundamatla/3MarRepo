    <JadeMethod name="displayStuff" id="5db4012b-d755-4379-a623-dcd92fbf3103">
        <source>displayStuff(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19/07/2013	cnwmh5 		#31938 - Add actual length to discharge details
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
	aSlotRequest : CM_SlotRequest;
	roroReq : CM_RORORequest;
	theString, theLabel : String;
	theTI : CM_TrackedItem;
	theWLE : CM_WorkListEntry;
begin
	
	if _theObject.isKindOf(CM_SlotRequest) then
		aSlotRequest := _theObject.CM_SlotRequest;
		theLabel := aSlotRequest.getActualLength().String;
		if aSlotRequest.isDischarge then
			theWLE := aSlotRequest.allWorkListEntries.first; 
			theTI := null;
			if theWLE &lt;&gt; null then
				theTI := theWLE.myTrackedItem;
			endif;
			theString := "Discharge " &amp; aSlotRequest.mySlotController.getStowageId(theTI) &amp; " " &amp; aSlotRequest.dischargePort &amp; " " &amp; theLabel;
			if theTI &lt;&gt; null then
				theString := theString &amp; " (" &amp; theTI.id &amp; ")";
			endif;
		else
			//theLabel := aSlotRequest.getActualLength().String;
			theString := "Load " &amp; aSlotRequest.mySlotController.getStowageId(null) &amp; " " &amp; aSlotRequest.dischargePort &amp; theLabel;
		endif;
		return  theString;
	elseif _theObject.isKindOf(CM_RORORequest) then
		roroReq := _theObject.CM_RORORequest;
		theLabel := roroReq.getActualLength().String;
		if roroReq.isDischarge then
			theWLE := roroReq.allWorkListEntries.first; 
			theTI := null;
			if theWLE &lt;&gt; null then
				theTI := theWLE.myTrackedItem;
			endif;
			theString := "Discharge " &amp; roroReq.myROROController.getStowageId(theTI) &amp; " " &amp; roroReq.getDischargePort();
			if _theObject.isKindOf(CM_ROROSlotRequest) then								// 22/07/2013 cnwmh5 #31938
				theString := theString &amp;  " " &amp; theLabel;
			endif;
			if theTI &lt;&gt; null then
				theString := theString &amp; " (" &amp; theTI.id &amp; ")";
			endif;
		else
			//theLabel := roroReq.getActualLength().String;
			theString := "Load " &amp; roroReq.myROROController.getStowageId(null) &amp; " " &amp; roroReq.getDischargePort();
			if _theObject.isKindOf(CM_ROROSlotRequest) then							// 22/07/2013 cnwmh5 #31938
				theString := theString &amp; theLabel;
			endif;
		endif;
		return  theString;

	else

		return "Null Object";
	endif;

end;</source>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBtnSaveClick" id="56c42837-7828-4cab-ab9e-050100da8c04">
        <updating/>
        <source>doBtnSaveClick() updating;
// ---------------------------------------------------------------------------
// Created:		OCTOBER 2003 By Andrew Bishop cnwab1
//
// Purpose:		This re links the colour coding, discharge to load. But because this means that the re linked slot requests have incorrect attributes set we erase
//				the attributes and then recreate.
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// ---------------------------------------------------------------------------

vars
	aLeftReq, aRightReq,pxyReq, beReq : CM_Request;
	theLeftRequests, theRightRequests,tmpReqs : CM_RequestArray;
	leastRequests, mostRequests : CM_RequestArray;
	idx, startIDX, endIDX : Integer;
	theRequests : CMIF_SlotRequestLinker;
	thePassport : CM_Passport;
	theSlotController : CM_LocationsController;
	ls : Boolean;
begin
	create theLeftRequests transient;
	create theRightRequests transient;
	create theRequests transient;
//	theRequests.isRORO := false;

	thePassport := app.myPassport;
	
	self.magRequests.getItemsOnLeftSide(theLeftRequests);
	self.magRequests.getItemsOnRightSide(theRightRequests);
	
	if theRightRequests.isEmpty then
		//Stop potential stuff up.
		return;
	endif;
	
	// 11/07/2013 cnwmh5 #31938 - Rewrite
	if theLeftRequests.size &lt;&gt; theRightRequests.size then
		if theLeftRequests.size &gt; theRightRequests.size then
			leastRequests := theRightRequests;
			mostRequests := theLeftRequests;
		else
			leastRequests := theLeftRequests;
			mostRequests := theRightRequests;
		endif;
		while true do
			aRightReq := mostRequests.last;
			mostRequests.remove(aRightReq);
			if leastRequests.size = mostRequests.size then
				break;
			endif;
		endwhile;
	endif;

	if theLeftRequests.size &gt; 0 then
		foreach aLeftReq in theLeftRequests do
			app.cmsBeginLoad(ls);
			pxyReq := aLeftReq.pxyCreateUpdateProxy();
			app.cmsEndLoad(ls);
			theRequests.allLinkedProxyRequests.add(pxyReq);
		endforeach;
		foreach aRightReq in theRightRequests do
			app.cmsBeginLoad(ls);
			pxyReq := aRightReq.pxyCreateUpdateProxy();
			app.cmsEndLoad(ls);
			theRequests.allProxyRequests.add(pxyReq);
		endforeach;

		app.myTrxUA.trxUpdateSlotRequestLnkControl(theRequests,thePassport);			
		if not app.myPassport.trxCompletedOK then
			app.showErrorWarningDialog('Linking Requests', thePassport, ErrWarnMode_Update);
		else
			global.beep;
			self.unloadForm();
		endif;
	endif;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	// clean up the proxies
	theRequests.allLinkedProxyRequests.purge;
	theRequests.allProxyRequests.purge;
	delete theLeftRequests;
	delete theRightRequests;
	delete theRequests;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSaveROROClick" id="922827f7-b2a0-49dc-b3e6-5479b89afb78">
        <updating/>
        <source>doBtnSaveROROClick() updating;
/*
// Purpose:		This re links the colour coding, discharge to load. But because this means that the re linked slot requests have incorrect attributes set we erase
//				the attributes and then recreate.
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	aLeftReq, aRightReq,pxyReq, beReq : CM_Request;
	theLeftRequests, theRightRequests,tmpReqs : CM_RequestArray;
	leastRequests, mostRequests : CM_RequestArray;
	idx, startIDX, endIDX : Integer;
	theRequests : CMIF_SlotRequestLinker;
	thePassport : CM_Passport;
	theSlotController : CM_LocationsController;
	ls : Boolean;
begin
	create theLeftRequests transient;
	create theRightRequests transient;
	create theRequests transient;
	thePassport := app.myPassport;
	
	self.magRequests.getItemsOnLeftSide(theLeftRequests);
	self.magRequests.getItemsOnRightSide(theRightRequests);
	
	if theRightRequests.isEmpty then
		//Stop potential stuff up.
		return;
	endif;
	
	// 11/07/2013 cnwmh5 #31938 - Rewrite
	if theLeftRequests.size &lt;&gt; theRightRequests.size then
		if theLeftRequests.size &gt; theRightRequests.size then
			leastRequests := theRightRequests;
			mostRequests := theLeftRequests;
		else
			leastRequests := theLeftRequests;
			mostRequests := theRightRequests;
		endif;
		while true do
			aRightReq := mostRequests.last;
			mostRequests.remove(aRightReq);
			if leastRequests.size = mostRequests.size then
				break;
			endif;
		endwhile;
	endif;
	
	if theLeftRequests.size &gt; 0 then
		foreach aLeftReq in theLeftRequests do
			app.cmsBeginLoad(ls);
			pxyReq := aLeftReq.pxyCreateUpdateProxy();
			app.cmsEndLoad(ls);
			theRequests.allLinkedProxyRequests.add(pxyReq);
		endforeach;
		foreach aRightReq in theRightRequests do
			app.cmsBeginLoad(ls);
			pxyReq := aRightReq.pxyCreateUpdateProxy();
			app.cmsEndLoad(ls);
			theRequests.allProxyRequests.add(pxyReq);
		endforeach;

		app.myTrxUA.trxUpdateSlotRequestLnkControl(theRequests,thePassport);			
		if not app.myPassport.trxCompletedOK then
			app.showErrorWarningDialog('Linking Rehandles', thePassport, ErrWarnMode_Update);
		else
			global.beep;
			self.unloadForm();
		endif;
	endif;
epilog
	app.cmsEndLoad(ls);	
	// clean up the proxies
	theRequests.allLinkedProxyRequests.purge;
	theRequests.allProxyRequests.purge;
	delete theLeftRequests;
	delete theRightRequests;
	delete theRequests;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnTIAvailIN_click" id="0412e60b-ad4a-42db-8a31-91151bfbf91e">
        <source>doBtnTIAvailIN_click();
/*
Purpose:			
Date		Who		Reason
15 September 2011	cnwab1	Initial creation
*/

vars

	idx : Integer;
	aReq : CM_Request;
//	aROROReq : CM_RORORequest;
	anObject : Object;
begin
	if self.tblTIAvailable.row &lt; 1 then
		global.beep;
		return;
	endif;
	
	if self.magRequests.myAvailableListBox.listCount = self.magRequests.mySelectedListBox.listCount then
		global.beep;
		return;
	endif;
	anObject := self.tblTIAvailable.accessRow(self.tblTIAvailable.row).itemObject;
	
	aReq := anObject.CM_Request;
	idx  := self.magRequests.addItem(self.magRequests.mySelectedListBox,aReq);
	if aReq.getAttrDischargePort() &lt;&gt; null then
		self.magRequests.mySelectedListBox.itemBackColor[idx] := aReq.getAttrDischargePort().colour;
		self.magRequests.mySelectedListBox.itemForeColor[idx] := aReq.getAttrDischargePort().colour.getInverseColour;
	endif;
	self.tblTIAvailable.removeItem(self.tblTIAvailable.row);
	
	/*
	if self.isRORO then
		aROROReq := anObject.CM_RORORequest;
		idx  := self.magRequests.addItem(self.magRequests.mySelectedListBox,aROROReq);
		if aROROReq.getAttrDischargePort() &lt;&gt; null then
			self.magRequests.mySelectedListBox.itemBackColor[idx] := aROROReq.getAttrDischargePort().colour;
			self.magRequests.mySelectedListBox.itemForeColor[idx] := aROROReq.getAttrDischargePort().colour.getInverseColour;
		endif;
	else
		aReq := anObject.CM_SlotRequest;
		idx  := self.magRequests.addItem(self.magRequests.mySelectedListBox,aReq);
		if aReq.getAttrDischargePort() &lt;&gt; null then
			self.magRequests.mySelectedListBox.itemBackColor[idx] := aReq.getAttrDischargePort().colour;
			self.magRequests.mySelectedListBox.itemForeColor[idx] := aReq.getAttrDischargePort().colour.getInverseColour;
		endif;
	endif;
	self.tblTIAvailable.removeItem(self.tblTIAvailable.row);
*/
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnTIAvailOUT_click" id="002c8487-f6fc-4a3b-af9c-09659d9ef1de">
        <source>doBtnTIAvailOUT_click();
/*
Purpose:			
Date		Who		Reason
15 September 2011	cnwab1	Initial creation
*/

vars
	totRows, idx : Integer;
	theObject : Object;
	theLeftRequests : CM_RequestArray;
	theLeftROROs : CM_RequestArray;
begin
	if self.magRequests.mySelectedListBox.selectedCount &gt; 0 then
		totRows := self.magRequests.mySelectedListBox.listCount;
		foreach idx in totRows to 1 step -1 do
			// do in reverse order as removing items
			
			// will screw up index
			if self.magRequests.mySelectedListBox.itemSelected[idx] then
				theObject := self.magRequests.mySelectedListBox.itemObject[idx];
				self.magRequests.takeOutItem(self.magRequests.mySelectedListBox,theObject);
			endif;
		endforeach;
	endif;
	
	if theObject &lt;&gt; null then
		idx := self.tblTIAvailable.addItem(self.displayStuff(theObject));
		
		self.tblTIAvailable.accessRow(idx).itemObject := theObject;
		self.tblTIAvailable.accessColumn(1).sortOrder := 1;

		
		create theLeftRequests transient;
		self.magRequests.getItemsOnLeftSide(theLeftRequests);
		if self.doesMatch(theObject.CM_Request,theLeftRequests) then
			if theObject.CM_Request.getAttrDischargePort() &lt;&gt; null then
				self.tblTIAvailable.accessedRow.backColor := theObject.CM_Request.getAttrDischargePort().colour; 
				self.tblTIAvailable.accessedRow.foreColor := theObject.CM_Request.getAttrDischargePort().colour.getInverseColour;
			endif;
		endif;
		self.tblTIAvailable.resort();
		
/*		
		if self.isRORO then
			create theLeftROROs transient;
			self.magRequests.getItemsOnLeftSide(theLeftROROs);
			if self.doesMatchRORO(theObject.CM_RORORequest,theLeftROROs) then
				if theObject.CM_RORORequest.getAttrDischargePort() &lt;&gt; null then
					self.tblTIAvailable.accessedRow.backColor := theObject.CM_RORORequest.getAttrDischargePort().colour; 
					self.tblTIAvailable.accessedRow.foreColor := theObject.CM_RORORequest.getAttrDischargePort().colour.getInverseColour;
				endif;
			endif;
		else
			create theLeftRequests transient;
			self.magRequests.getItemsOnLeftSide(theLeftRequests);
			if self.doesMatch(theObject.CM_Request,theLeftRequests) then
				if theObject.CM_Request.getAttrDischargePort() &lt;&gt; null then
					self.tblTIAvailable.accessedRow.backColor := theObject.CM_Request.getAttrDischargePort().colour; 
					self.tblTIAvailable.accessedRow.foreColor := theObject.CM_Request.getAttrDischargePort().colour.getInverseColour;
				endif;
			endif;
		endif;
		self.tblTIAvailable.resort();
		*/
		
	endif;
epilog
	delete theLeftRequests;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDragDropFromMSGListBox" id="f0b9c62f-9880-4166-8b3c-604d5f246721">
        <updating/>
        <source>doDragDropFromMSGListBox(_listBox: ListBox input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _listBox = self.magRequests.mySelectedListBox then
		self.btnTIAvailIN_click(self.btnTIAvailIN);
	endif;
end;</source>
        <Parameter name="_listBox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="acf27cdc-2066-4e17-a2a7-bf58e5b225be">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/07/2013	cnwmh5		#31938 - rewrite to handle resize of magRequests
// ---------------------------------------------------------------------------

constants
	MinMagRequestsWidth							: Integer = 350;
vars
	theWidth 									: Integer;
	magRequestsWidth							: Real;
begin

	self.btnClose.move(self.clientWidth - self.btnClose.width - 15,self.clientHeight - self.btnClose.height - 5, 70,25);
	self.btnSave.move(self.btnClose.left - self.btnClose.width - 5,self.btnClose.top, self.btnClose.width, self.btnClose.height);

	self.lblRequests.move(5,5,self.clientWidth - 10, 15 );
	
	// 22/07/2013 cnwmh5 #31938
	magRequestsWidth := MinMagRequestsWidth;
	
	if self.tblTIAvailable.visible then
	
		theWidth := self.clientWidth - 350 - 55;
		if theWidth &gt; self.clientWidth then
			theWidth := self.clientWidth - self.magRequests.clientWidth - 50;
		elseif theWidth &lt; MinMagRequestsWidth then
			theWidth := MinMagRequestsWidth;
		endif;
		self.tblTIAvailable.move(self.magRequests.left + self.magRequests.clientWidth + 30, self.magRequests.top + 22, theWidth, self.magRequests.clientHeight - 30);
		self.lblAvailTI.left := self.tblTIAvailable.left;
		self.lblAvailTI.top := self.tblTIAvailable.top - 20;
		self.btnTIAvailIN.top := 155;
		self.btnTIAvailIN.left := self.magRequests.left + self.magRequests.clientWidth;
		self.btnTIAvailOUT.left := self.btnTIAvailIN.left;
		self.btnTIAvailOUT.top := 185;
	
		magRequestsWidth := self.tblTIAvailable.width;
		if magRequestsWidth &lt; MinMagRequestsWidth then
			magRequestsWidth := MinMagRequestsWidth;
		endif;
	else
		magRequestsWidth := self.clientWidth - 10;
		
	endif;
	
	self.magRequests.move(5, self.lblRequests.top + self.lblRequests.height + 5, magRequestsWidth, self.btnClose.top - 10 - self.lblRequests.height);
	self.magRequests.cnEcResizeContents();
	
	if self.tblTIAvailable.visible then
		theWidth := self.clientWidth - self.magRequests.clientWidth - 50;
		self.tblTIAvailable.move(self.magRequests.left + self.magRequests.clientWidth + 30, self.magRequests.top + 22, theWidth, self.magRequests.clientHeight - 30);
	endif;
		
	// 22/07/2013 cnwmh5 #31938 - removed
	/*
	if self.tblTIAvailable.visible then
		self.magRequests.move(5, self.lblRequests.top + self.lblRequests.height + 5,450, self.btnClose.top - 10 - self.lblRequests.height);
	else
		self.magRequests.move(5, self.lblRequests.top + self.lblRequests.height + 5,self.clientWidth - 10, self.btnClose.top - 10 - self.lblRequests.height);
	endif;
	self.magRequests.cnEcResizeContents();

	if self.tblTIAvailable.visible then
		theWidth := self.clientWidth - self.magRequests.clientWidth - 50;
		self.tblTIAvailable.move(self.magRequests.left + self.magRequests.clientWidth + 30, self.magRequests.top + 22, theWidth,self.magRequests.clientHeight - 30);
		self.lblAvailTI.left := self.tblTIAvailable.left;
		self.lblAvailTI.top := self.tblTIAvailable.top - 20;
		self.btnTIAvailIN.top := 155;
		self.btnTIAvailIN.left := self.magRequests.left + self.magRequests.clientWidth;
		self.btnTIAvailOUT.left := self.btnTIAvailIN.left;
		self.btnTIAvailOUT.top := 185;
	endif;
	*/
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="eb3d4a57-4bdd-44d0-bb0d-299793ee237f">
        <updating/>
        <source>doSave() updating;
/*
Purpose:			
Date				Who			Reason
April 2012		CNWAB1		Initial creation
*/

vars
	aLeftReq, aRightReq,pxyReq, beReq : CM_Request;
	theLeftRequests, theRightRequests,tmpReqs : CM_RequestArray;
	idx, startIDX, endIDX : Integer;
	theRequests : CMIF_SlotRequestLinker;
	thePassport : CM_Passport;
	theSlotController : CM_LocationsController;
	ls : Boolean;
begin
	create theLeftRequests transient;
	create theRightRequests transient;
	create theRequests transient;
//	theRequests.isRORO := false;

	thePassport := app.myPassport;
	
	self.magRequests.getItemsOnLeftSide(theLeftRequests);
	self.magRequests.getItemsOnRightSide(theRightRequests);
	
	if theRightRequests.isEmpty then
		//Stop potential stuff up.
		return;
	endif;
	
	if theLeftRequests.size &lt;&gt; theRightRequests.size then
		while true do
			aRightReq := theRightRequests.last;
			theRightRequests.remove(aRightReq);
			if theLeftRequests.size = theRightRequests.size then
				break;
			endif;
		endwhile;
	endif;

	if theLeftRequests.size &gt; 0 then
		foreach aLeftReq in theLeftRequests do
			app.cmsBeginLoad(ls);
			pxyReq := aLeftReq.pxyCreateUpdateProxy();
			app.cmsEndLoad(ls);
			theRequests.allLinkedProxyRequests.add(pxyReq);
		endforeach;
		foreach aRightReq in theRightRequests do
			app.cmsBeginLoad(ls);
			pxyReq := aRightReq.pxyCreateUpdateProxy();
			app.cmsEndLoad(ls);
			theRequests.allProxyRequests.add(pxyReq);
		endforeach;

		app.myTrxUA.trxUpdateSlotRequestLnkControl(theRequests,thePassport);			
		if not app.myPassport.trxCompletedOK then
			app.showErrorWarningDialog('Linking Requests', thePassport, ErrWarnMode_Update);
		else
			global.beep;
			self.unloadForm();
		endif;
	endif;
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	// clean up the proxies
	theRequests.allLinkedProxyRequests.purge;
	theRequests.allProxyRequests.purge;
	delete theLeftRequests;
	delete theRightRequests;
	delete theRequests;
end;</source>
    </JadeMethod>
    <JadeMethod name="doesMatch" id="351f78d3-61ea-467f-bb6a-796c5969319a">
        <source>doesMatch(_theRequest : CM_Request;_theLeftRequests: CM_RequestArray) : Boolean;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		vaguely say whether the requests match
//
// ---------------------------------------------------------------------------

vars
	aRequest : CM_Request;
begin

	foreach aRequest in _theLeftRequests do
		if aRequest.getAttrDischargePort() = _theRequest.getAttrDischargePort() then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_theRequest" type="CM_Request"/>
        <Parameter name="_theLeftRequests" type="CM_RequestArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
