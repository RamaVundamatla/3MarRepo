<Class name="HostWorkbookInterface" id="aff52623-1909-4ac5-bd50-ad065ba11ca7">
    <superclass name="Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <JadeMethod name="xlGetData" id="3d786330-16d3-4178-acd0-ef82b1691d0e">
        <source>xlGetData(hsa: ExcelHugeStringArray io; excelExtOption: WorkbookExtractOptions; associatedObjType: String; associatedObjName: String; 
associatedObject : Object) : Boolean;


vars
	row, col, seed : Integer;
	now : TimeStamp;
	date : Date;
begin
	app.writeStatement( method.qualifiedName);
	hsa.add(now.date.shortFormat &amp;Tab&amp; now.time.String);
	hsa.add("Date	Value 1	Value 2	Value 3");
	date := '1/1/2005'.Date;
	seed := app.clock;
	foreach row in 1 to 100 do
		hsa.add(date.shortFormat &amp;Tab&amp; 
				(app.random31(seed, 10000)+1).String &amp; Tab &amp; 
				(app.random31(seed, 10000)+1).String &amp; Tab &amp; 
				(app.random31(seed, 10000)+1).String);
		date := date + 1;
	endforeach;
	return true;
end;</source>
        <Parameter name="hsa" type="ExcelInterfacePackage::ExcelHugeStringArray" usage="io"/>
        <Parameter name="excelExtOption" type="WorkbookExtractOptions"/>
        <Parameter name="associatedObjType" type="String"/>
        <Parameter name="associatedObjName" type="String"/>
        <Parameter name="associatedObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xlShowForm" id="2a4696f0-99a3-4048-a918-619cc9911954">
        <source>xlShowForm(form: Form input; option: Integer);

vars

begin
	app.writeStatement( method.qualifiedName);
end;</source>
        <Parameter name="form" type="Form" usage="input"/>
        <Parameter name="option" type="Integer"/>
    </JadeMethod>
</Class>
