    <JadeMethod name="setPxyCargoType" id="a9e4bad0-2550-42b3-973f-cc419c83a589">
        <updating/>
        <source>setPxyCargoType(_cargoType : CM_CargoType) updating;
// ---------------------------------------------------------------------------
// Created:     30 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cargoType : CM_CargoType; //cnwas3 PAR 24273
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.myCargoType := _cargoType;
	cargoType := self.getAttrCargoType();						//cnwas3 PAR 24273
	if cargoType &lt;&gt; null then									//cnwas3 PAR 24273
		self.cargoType := cargoType.id;							//cnwas3 PAR 24273
	else
		self.cargoType := null;
	endif;

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="setPxyCommodityGroup" id="4472eb70-a78e-4b82-b105-7324e2898005">
        <updating/>
        <source>setPxyCommodityGroup(_commodityGroup : CM_CommodityGroup; _terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     31 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.myCommodityGroup := _commodityGroup;
	if _commodityGroup &lt;&gt; null then
		self.commodity := _commodityGroup.code;
		self.empty := _commodityGroup.isEmptyCommodityForTerminal(_terminal);
	else
		self.commodity := null;
		self.empty := false;
	endif;
	
end;</source>
        <Parameter name="_commodityGroup" type="CM_CommodityGroup"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
