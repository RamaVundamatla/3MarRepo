    <JadeMethod name="displayWLEs" id="905c7b56-e2bb-4246-abe8-f623030d18cf">
        <updating/>
        <source>displayWLEs(_wleArray: CM_WLEArray)updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
vars
	wle			: CM_WorkListEntry;	
	rtCol 		: Integer;
begin
	on Exception do self.handleExceptionWLE(exception, wle);
	rtCol := self.tblWorkEntries.getColumnByRowName(ETRow_RadioTelemetry);
	
	foreach wle in _wleArray do
		wle.fetchLatest();
		if wle = null then
			// wle is set to null by the ex handler if it is not found / deleted
			continue;
		endif;
		
		if not self.includeWLE(wle) then // PAR 19710
			continue;
		endif;
		
		// Notes do not resynch the children so have to do it here
		if wle.myTrackedItem &lt;&gt; null then
			self.doNotableAdd(wle.myTrackedItem);
		endif;
		if wle.myBOL &lt;&gt; null then
			wle.myBOL.fetchLatest();
			if wle = null then
				// this will cause nothing to be displayed for this line BUT 
				// is better than getting an exception to prevent anything being
				// displayed.
				
				//Removed as there is nothing the user can do about it and it was frustrating them when the message came up. 03032004
				//app.msgBox($InvalidObjWhenDisplaying($WorkListEntry), $Warning, MsgBox_OK_Only + MsgBox_Information_Icon);
				continue;
			endif;
		endif;		
		
		self.addWLEtoTable(wle); // PAR 19710

	endforeach;
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray"/>
    </JadeMethod>
    <JadeMethod name="displayWLEsShowRT" id="da3b34c4-465f-4909-88ce-9cf2b7947edf">
        <source>displayWLEsShowRT(_table : CM_DataTable input; _row, _rtCol : Integer);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		The new Queue and Planned icons do not have a Q or a P in them 
//				so use letters instead and this method sets the colours
//				Should only be called from self.tblWLESetRowColour()
//
//Date			Who		Reason
//22 May 2019	jlgzm1	TFS 42840 MSL Direct Release between Voyages and Rail
//19 Aug 2019	jlgzm1	TFS 42872 TFS 42872 Moved to CM_BaseForm, multiple forms using same code
// ---------------------------------------------------------------------------

vars
	theCell : JadeTableCell;

begin
	inheritMethod(_table, _row, _rtCol);
	/*
	theCell := self.tblWorkEntries.accessCell(_row,_col);
	
	if theCell.text.pos("H",1) &gt; 0  then
		//Job entry is held
		if theCell.backColor = Red then
			theCell.foreColor := White; // Incase the line is overstowed, i.e. the background is RED
		else
			theCell.foreColor := Red;
		endif;
		theCell.fontBold := true;
		
	elseif theCell.text.pos("P",1) &gt; 0 then
		//Job entry is planned
		theCell.foreColor := Green;
	
	elseif theCell.text.pos("Q",1) &gt; 0 then
		//Job entry is Queued
		if theCell.backColor = Red then
			theCell.foreColor := White; // Incase the line is overstowed, i.e. the background is RED
		else
			theCell.foreColor := Red;
		endif;
	// tfs42840	
	elseif theCell.text.pos("DR",1) &gt; 0 then
		//Job entry is a direct release
		theCell.foreColor := Green;
		
	else
		theCell.foreColor := Blue;		
	endif;	
	*/
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_rtCol" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doAssignReleasesToWagons" id="16746e80-90b1-4312-a99e-ffd4a15ef8f7">
        <updating/>
        <source>doAssignReleasesToWagons(menuItem: MenuItem input; _doRtQueue : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwndl1	Initial creation CCMS 1094

*/

vars

	selectedWleArray : CM_WLEArray;
	wle : CM_WorkListEntry;
	wleArray : CM_WLEArray;
	wagon : CM_Wagon;
	wagonArray : CM_WagonArray;
	
begin
	
	create selectedWleArray transient;
	create wleArray transient;
	
	// Get a collection of the selected WLE's in the table 
	self.getAllWLEsInTableSelected(selectedWleArray);
	
	//we only want those that are Delivery Requests with no locationTarget and not already assigned.
	foreach wle in selectedWleArray do
		if wle.myRequest = null then
			continue;
		endif;
		//if not wle.myRequest.isKindOf(CM_DeliveryRequest) then
		if not wle.myRequest.isKindOf(CM_DeliveryRequest) and not wle.myRequest.isKindOf(CM_TIRequest) then	//11 July 2014	NDL	Par 34552
			if wle.isRailBreakBulkRelease then
				// these are ok too.
			else
				continue;
			endif;
		endif;
		if wle.locationTarget &lt;&gt; null then
			continue;
		endif;
		if wle.isYardReleaseAssigned then
			continue;
		endif;
		wleArray.add(wle);
	endforeach;
	
	if wleArray.isEmpty then
		app.msgBox(app.getErrorString(No_Unassigned_Rail_Reqs_Select),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//get a collection of selected wagons
	create wagonArray transient;
	
	self.getSelectedWagons( wagonArray, null );
	
	if wagonArray.isEmpty then
		app.msgBox(app.getErrorString(No_Wagons_Selected_To_Assign),app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	//self.myAssistant.doAssignReleasesToWagons(wleArray,wagonArray);
	self.myAssistant.doAssignReleasesToWagons(wleArray, wagonArray, _doRtQueue);	//11 May 2010	NDL	Otago CCMS 1935, currently in testing.
	self.doRefresh();	//10 May 2010	NDL Par 24064
	
epilog

	delete selectedWleArray;
	delete wleArray;
	delete wagonArray;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
        <Parameter name="_doRtQueue" type="Boolean"/>
    </JadeMethod>
