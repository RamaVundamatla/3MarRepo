    <JadeMethod name="getRampUsage" id="0e75160b-68c6-4a7d-a02e-1ff03c12bbf5">
        <source>getRampUsage(_invoiceLine : CM_InvoiceLine) : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/04/2019	jlgdap1		Initial creation TFS 43694 PEL1 Charging for Vessels that use a Ramp
// 23 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1		Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	workOrder : CM_WorkOrder;
	workOrderDtl : CM_WorkOrderDtl;
	hasRamp : Boolean;
	rampMovement : HMS_VoyageMovement;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	// ESTIMATE
	// HMS Ramp Penalty - there will never be a Ramp Penalty on an estimation
	// HMS Ramp Used and HMS Ramp Not Used - return the value on the Work Order
	//		1 for ramp used, 2 for ramp not used
	//
	// INVOICING
	// HMS Ramp Penalty - compare the movement hasRamp with the work order originalHasRamp
	//		If work order origialHasRamp is different to movement hasRamp this is a penalty
	// 		return 3
	// HMS Ramp Used and HMS Ramp Not Used - if there is no penalty, return the value on the movement
	// 		1 for ramp used, 2 for ramp not used
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog(method.qualifiedName, LogINFO.String);
	endif;
	// TFS 43694 if JMT Default just use whats on the movement. There will be no work order
	//						so for JMT Default there can be no penalty rate
	if self.getMyTerminal().isUsingDefaultProcessJMT then 
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("JMT Default voyage process", LogTRACE.String);
		endif;
		if self.myMarineServiceTimings &lt;&gt; null then
			hasRamp := self.myMarineServiceTimings.hasRamp;
			if hasRamp then
				if canLogExtra then	//28.02.2025 navah1	#34141
					app.invLog(" Ramp Used", LogTRACE.String);
				endif;
				return CM_Rate.RAMP_USED;
			else
				if canLogExtra then	//28.02.2025 navah1	#34141
					app.invLog("Ramp Not Used", LogTRACE.String);
				endif;
				return CM_Rate.RAMP_NOT_USED;
			endif;
		endif;
	else
		rampMovement := self.HMS_VoyageMovement;
		// TFS 43694 Switch to previous movement if invoicing for berthage
		if _invoiceLine.invoiceLineDesc.isBerthageCalcType() then
		//or process.isJLGAB1 then 
			if canLogExtra then	//28.02.2025 navah1	#34141
				app.invLog("Is Berthage Calc Type", LogTRACE.String);
			endif;
			rampMovement:= self.HMS_VoyageMovement.getVoyageMovementPrevious(); // TFS 43694
			
		endif; // TFS 43694
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("rampMovement is " &amp; rampMovement.moveType, LogTRACE.String);		
			app.invLog("selfMovement is " &amp; self.moveType, LogTRACE.String);	
		endif;
		
		if self.myMarineServiceTimings &lt;&gt; null then // TFS 43694
			hasRamp := self.myMarineServiceTimings.hasRamp; // TFS 43694
		endif;
		if canLogExtra then	//28.02.2025 navah1	#34141
			app.invLog("Has Ramp on Self Movement is " &amp; hasRamp.String, LogTRACE.String);
		endif;
		workOrder :=rampMovement.getWorkOrder();
		if workOrder = null then
			if canLogExtra then	//28.02.2025 navah1	#34141
				app.invLog("Work order for movement is null", LogTRACE.String);
			endif;
			if hasRamp then
				if canLogExtra then	//28.02.2025 navah1	#34141
					app.invLog(" Ramp Used", LogTRACE.String);
				endif;
				return CM_Rate.RAMP_USED;
			else
				if canLogExtra then	//28.02.2025 navah1	#34141
					app.invLog(" Ramp Used", LogTRACE.String);
				endif;
				return CM_Rate.RAMP_NOT_USED;
			endif;
			
		endif;
		workOrderDtl := workOrder.allWoDtls.first;
		if workOrderDtl = null then
			if canLogExtra then	//28.02.2025 navah1	#34141
				app.invLog("Work order detail is null", LogTRACE.String);
			endif;
			if hasRamp then
				if canLogExtra then	//28.02.2025 navah1	#34141
					app.invLog(" Ramp Used", LogTRACE.String);
				endif;
				return CM_Rate.RAMP_USED;
			else
				if canLogExtra then	//28.02.2025 navah1	#34141
					app.invLog(" Ramp Not Used",LogTRACE.String);
				endif;
				return CM_Rate.RAMP_NOT_USED;
			endif;
		endif;
		
		// Estimation - app.isInProformMode
		if app.isInProformaMode then
			if canLogExtra then	//28.02.2025 navah1	#34141
				app.invLog("Is PROFORMA", LogTRACE.String);
			endif;
			// return the current value on the work order
			if workOrderDtl.wasRampUsed then
				if canLogExtra then	//28.02.2025 navah1	#34141
					app.invLog(" Ramp Used", LogTRACE.String);
				endif;
				return CM_Rate.RAMP_USED;
			else
				if canLogExtra then	//28.02.2025 navah1	#34141
					app.invLog(" Ramp NOT Used", LogTRACE.String);
				endif;
				return CM_Rate.RAMP_NOT_USED;
			endif;
		
		// Invoicing - app.isinProformaMode is false
		else
		// if the movement is different to the original work order value - PENALTY
			 // TFS 43694 - Ian Says 'The penalty rate should only be applied when the ramp is not requested but is used.'
			if hasRamp and not workOrderDtl.wasRampRequested then
				if canLogExtra then	//28.02.2025 navah1	#34141
					app.invLog("Movement Has Ramp but it was not Requested - PENALTY Rate", LogTRACE.String);
				endif;
				return CM_Rate.RAMP_PENALTY;
			else
				if hasRamp then
					if canLogExtra then	//28.02.2025 navah1	#34141
						app.invLog("Movement does have Ramp, Ramp was Requested - Ramp Used Rate", LogTRACE.String);
					endif;
					return CM_Rate.RAMP_USED;
				else
					if workOrderDtl.wasRampRequested then // TFS ramp requested but not used, still charge for ramp.
						if canLogExtra then	//28.02.2025 navah1	#34141
							app.invLog("Movement does not have Ramp, but a Ramp was Requested - Ramp Used Rate", LogTRACE.String);
						endif;
						return CM_Rate.RAMP_USED;
					else
						if canLogExtra then	//28.02.2025 navah1	#34141
							app.invLog("Movement does not have Ramp, Ramp was not Requested - Ramp Not Used Rate", LogTRACE.String);
						endif;
						return CM_Rate.RAMP_NOT_USED;
					endif;
				endif;
			endif;
		endif;
	endif;
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog("Default -  Ramp NOT Used", LogTRACE.String);
	endif;
	return CM_Rate.RAMP_NOT_USED;
epilog

end;</source>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTerminal" id="f33da9bb-6ed6-4c57-8fcc-68eb6295996f">
        <source>getTerminal():CM_Terminal;
// --------------------------------------------------------------------------------
// Created:		18 October 2006 by cnwdad1
//
// Purpose:		Returns a reference to the Terminal from which the receiver is/will
//				be sailing.
//
// Parameters:	None
//
// Returns:		A reference to a Terminal object, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	harbourRegionObj	: HMS_HarbourRegion;
	terminalObj			: CM_Terminal;
	
begin
	if self.getMyBerth() &lt;&gt; null then
		harbourRegionObj	:=	self.getMyBerth().myHarbourRegion;
	endif;
	
	if harbourRegionObj &lt;&gt; null then
		terminalObj			:=	harbourRegionObj.getTerminal();
		
		if terminalObj &lt;&gt; null then
			return terminalObj;
		endif;
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getTerminalForCargo" id="f226c292-14cc-436b-beb2-0024d15a567e">
        <source>getTerminalForCargo() : CM_Terminal;
// ---------------------------------------------------------------------------
// Created:     28 January 2008 by cnwrs2
//
// Purpose:     Returns the Terminal associated with cargo (for Voyage
//				Commodity Planning) for this movement.  This is the 
//				Terminal associated with the PREVIOUS Berth
// ---------------------------------------------------------------------------
vars
	tmpBerth		: HMS_Berth;
	harbourRegionObj	: HMS_HarbourRegion;
	terminalObj			: CM_Terminal;
	
begin
	tmpBerth := self.getMyBerthPrevious();
	if tmpBerth = null then
		return null;
	endif;
	
	harbourRegionObj	:=	tmpBerth.myHarbourRegion;
	
	if harbourRegionObj = null then
		return null;	
	endif;
	
	return harbourRegionObj.getTerminal();
	
end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getToLocationDescr" id="d0de8f9a-4d8e-46af-9c21-c810c33052bc">
        <source>getToLocationDescr() : String;
// ---------------------------------------------------------------------------
// Created:     26 October 2006 by cnwrs2
//
// Purpose:     Returns the harbour region for the berth
// ---------------------------------------------------------------------------
vars
	tmpBerth	: HMS_Berth;
	tmpRegion	: HMS_HarbourRegion;
	str			: String;
	
begin
	tmpBerth := self.getMyBerth();
	if tmpBerth &lt;&gt; null then
		//epr 16932 10/6/08 
		if tmpBerth.myHarbourRegion &lt;&gt; null then
			str := tmpBerth.myHarbourRegion.code;
		endif;
		if (not tmpBerth.isLogicalBerth) then
			str := str &amp; ' (' &amp; tmpBerth.code &amp; ')';
		endif;
		return str;
	endif;
	
	return '&lt;unknown&gt;';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
