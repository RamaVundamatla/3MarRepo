    <JadeMethod name="translateForm" id="d18e8ad0-a3cb-451d-be88-e9634ce68b1f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 November 2021 14:55:04.
	//13 December 2024	navrv30	JIRA 33578 EUP | Incoming API Logging
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017432, locale);		   // set in calling form
	btnClose.translateCaption(Xlat_0011977, locale);
	btnExportRequest.translateBubbleHelp(Xlat_0023017, locale);
	btnExportRequest.translateCaption(Xlat_0023018, locale);
	btnExportResponse.translateBubbleHelp(Xlat_0023019, locale);
	btnExportResponse.translateCaption(Xlat_0023020, locale);
	btnFind.translateBubbleHelp(Xlat_0023021, locale);
	btnFind.translateCaption(Xlat_0023022, locale);
	btnFindNext.translateBubbleHelp(Xlat_0023023, locale);
	btnFindNext.translateCaption(Xlat_0023024, locale);
	btnUnformatted.translateBubbleHelp(Xlat_0024550, locale);
	btnUnformatted.translateCaption(Xlat_0024551, locale);
	//13 December 2024	navrv30	JIRA 33578
	btnSaveBase.translateBubbleHelp(Xlat_0005397, locale);
	btnSaveBase.translateCaption(Xlat_0005398, locale);
end;</source>
    </JadeMethod>
</GUIClass>
